.com/go-git/go-git/v6\\\"\\n    17→\\t\\\"github.com/go-git/go-git/v6/plumbing\\\"\\n    18→\\t\\\"github.com/go-git/go-git/v6/plumbing/object\\\"\\n    19→)\\n    20→\\n    21→// pushSessionsBranchCommon is the shared implementation for pushing session branches.\\n    22→// By default, session logs are pushed automatically alongside user pushes.\\n    23→// Configuration (stored in .entire/settings.json under strategy_options.push_sessions):\\n    24→//   - false: disable automatic pushing\\n    25→//   - true or not set: push automatically (default)\\n    26→func pushSessionsBranchCommon(ctx context.Context, remote, branchName string) error {\\n    27→\\t// Check if pushing is disabled\\n    28→\\tif isPushSessionsDisabled(ctx) {\\n    29→\\t\\treturn nil\\n    30→\\t}\\n    31→\\n    32→\\treturn pushBranchIfNeeded(ctx, remote, branchName)\\n    33→}\\n    34→\\n    35→// pushBranchIfNeeded pushes a branch to the remote if it has unpushed changes.\\n    36→// Does not check any settings — callers are responsible for gating.\\n    37→func pushBranchIfNeeded(ctx context.Context, remote, branchName string) error {\\n    38→\\trepo, err := OpenRepository(ctx)\\n    39→\\tif err != nil {\\n    40→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n    41→\\t}\\n    42→\\n    43→\\t// Check if branch exists locally\\n    44→\\tbranchRef := plumbing.NewBranchReferenceName(branchName)\\n    45→\\tlocalRef, err := repo.Reference(branchRef, true)\\n    46→\\tif err != nil {\\n    47→\\t\\t// No branch, nothing to push\\n    48→\\t\\treturn nil //nolint:nilerr // Expected when no sessions exist yet\\n    49→\\t}\\n    50→\\n    51→\\t// Check if there's actually something to push (local differs from remote)\\n    52→\\tif !hasUnpushedSessionsCommon(repo, remote, localRef.Hash(), branchName) {\\n    53→\\t\\t// Nothing to push - skip silently\\n    54→\\t\\treturn nil\\n    55→\\t}\\n    56→\\n    57→\\treturn doPushBranch(ctx, remote, branchName)\\n    58→}\\n    59→\\n    60→// hasUnpushedSessionsCommon checks if the local branch differs from the remote.\\n    61→// Returns true if there's any difference that needs syncing (local ahead, remote ahead, or diverged).\\n    62→func hasUnpushedSessionsCommon(repo *git.Repository, remote string, localHash plumbing.Hash, branchName string) bool {\\n    63→\\t// Check for remote tracking ref: refs/remotes/<remote>/<branch>\\n    64→\\tremoteRefName := plumbing.NewRemoteReferenceName(remote, branchName)\\n    65→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n    66→\\tif err != nil {\\n    67→\\t\\t// Remote branch doesn't exist yet - we have content to push\\n    68→\\t\\treturn true\\n    69→\\t}\\n    70→\\n    71→\\t// If local and remote point to same commit, nothing to sync\\n    72→\\t// This is the only case where we skip - any difference needs handling\\n    73→\\treturn localHash != remoteRef.Hash()\\n    74→}\\n    75→\\n    76→// isPushSessionsDisabled checks if push_sessions is disabled in settings.\\n    77→// Returns true if push_sessions is explicitly set to false.\\n    78→func isPushSessionsDisabled(ctx context.Context) bool {\\n    79→\\ts, err := settings.Load(ctx)\\n    80→\\tif err != nil {\\n    81→\\t\\treturn false // Default: push is enabled\\n    82→\\t}\\n    83→\\treturn s.IsPushSessionsDisabled()\\n    84→}\\n    85→\\n    86→// doPushBranch pushes the given branch to the remote with fetch+merge recovery.\\n    87→func doPushBranch(ctx context.Context, remote, branchName string) error {\\n    88→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Pushing %s to %s...\\\\n\\\", branchName, remote)\\n    89→\\n    90→\\t// Try pushing first\\n    91→\\tif err := tryPushSessionsCommon(ctx, remote, branchName); err == nil {\\n    92→\\t\\treturn nil\\n    93→\\t}\\n    94→\\n    95→\\t// Push failed - likely non-fast-forward. Try to fetch and merge.\\n    96→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Syncing %s with remote...\\\\n\\\", branchName)\\n    97→\\n    98→\\tif err := fetchAndMergeSessionsCommon(ctx, remote, branchName); err != nil {\\n    99→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: couldn't sync %s: %v\\\\n\\\", branchName, err)\\n   100→\\t\\treturn nil // Don't fail the main push\\n   101→\\t}\\n   102→\\n   103→\\t// Try pushing again after merge\\n   104→\\tif err := tryPushSessionsCommon(ctx, remote, branchName); err != nil {\\n   105→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to push %s after sync: %v\\\\n\\\", branchName, err)\\n   106→\\t}\\n   107→\\n   108→\\treturn nil\\n   109→}\\n   110→\\n   111→// tryPushSessionsCommon attempts to push the sessions branch.\\n   112→func tryPushSessionsCommon(ctx context.Context, remote, branchName string) error {\\n   113→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   114→\\tdefer cancel()\\n   115→\\n   116→\\t// Use --no-verify to prevent recursive hook calls\\n   117→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"push\\\", \\\"--no-verify\\\", remote, branchName)\\n   118→\\tcmd.Stdin = nil // Disconnect stdin to prevent hanging in hook context\\n   119→\\n   120→\\toutput, err := cmd.CombinedOutput()\\n   121→\\tif err != nil {\\n   122→\\t\\t// Check if it's a non-fast-forward error (we can try to recover)\\n   123→\\t\\tif strings.Contains(string(output), \\\"non-fast-forward\\\") ||\\n   124→\\t\\t\\tstrings.Contains(string(output), \\\"rejected\\\") {\\n   125→\\t\\t\\treturn errors.New(\\\"non-fast-forward\\\")\\n   126→\\t\\t}\\n   127→\\t\\treturn fmt.Errorf(\\\"push failed: %s\\\", output)\\n   128→\\t}\\n   129→\\treturn nil\\n   130→}\\n   131→\\n   132→// fetchAndMergeSessionsCommon fetches remote sessions and merges into local using go-git.\\n   133→// Since session logs are append-only (unique cond-* directories), we just combine trees.\\n   134→func fetchAndMergeSessionsCommon(ctx context.Context, remote, branchName string) error {\\n   135→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minu