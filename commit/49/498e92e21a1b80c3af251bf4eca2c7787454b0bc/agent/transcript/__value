t, TreeObject, AnyObject\\n    // If plumbing.AnyObject is given, object is looked up regardless of type.\\n    EncodedObject(plumbing.ObjectType, plumbing.Hash) (plumbing.EncodedObject, error)\\n}\\n```\\n\\n**Filesystem Implementation** (storage/filesystem/object.go, lines 364-409):\\n\\n```go\\nfunc (s *ObjectStorage) EncodedObject(t plumbing.ObjectType, h plumbing.Hash) (plumbing.EncodedObject, error) {\\n    // Strategy: try packfile first if index exists, else try loose objects first\\n    if s.index != nil {\\n        obj, err = s.getFromPackfile(h, false)         // Try packfile (no delta resolution)\\n        if errors.Is(err, plumbing.ErrObjectNotFound) {\\n            obj, err = s.getFromUnpacked(h)\\n        }\\n    } else {\\n        obj, err = s.getFromUnpacked(h)                // Try loose objects\\n        if errors.Is(err, plumbing.ErrObjectNotFound) {\\n            obj, err = s.getFromPackfile(h, false)\\n        }\\n    }\\n\\n    // Check alternates for shared object repositories\\n    if errors.Is(err, plumbing.ErrObjectNotFound) {\\n        dotgits, e := s.dir.Alternates()\\n        if e == nil {\\n            for _, dg := range dotgits {\\n                o := NewObjectStorage(dg, s.objectCache)\\n                enobj, enerr := o.EncodedObject(t, h)\\n                if enerr != nil {\\n                    continue\\n                }\\n                return enobj, nil\\n            }\\n        }\\n    }\\n\\n    if err != nil {\\n        return nil, err\\n    }\\n\\n    // Type validation\\n    if obj == nil || (plumbing.AnyObject != t && obj.Type() != t) {\\n        return nil, plumbing.ErrObjectNotFound\\n    }\\n\\n    return obj, nil\\n}\\n```\\n\\n---\\n\\n### 5. **How Fetch Works** (remote.go, lines 350-502)\\n\\n**High-level flow:**\\n```\\nRemote.Fetch(o *FetchOptions)\\n  └─> Remote.FetchContext(ctx, o)  [wrapper with context]\\n      └─> Remote.fetch(ctx, o) [main implementation]\\n          ├─> Validate options\\n          ├─> Create transport connection\\n          ├─> Handshake with server (UploadPackService)\\n          ├─> Get remote refs via conn.GetRemoteRefs()\\n          ├─> Calculate refs to fetch based on RefSpecs and Tags\\n          ├─> Build FetchRequest with:\\n          │   ├─> Wants: hashes to fetch\\n          │   ├─> Haves: hashes already local\\n          │   ├─> Depth: shallow clone depth\\n          │   ├─> Progress: progress callback\\n          │   ├─> IncludeTags: whether to include tags\\n          │   └─> Filter: o.Filter (line 452) ◄─── FILTER FIELD\\n          ├─> conn.Fetch(ctx, req) ◄─── PASS FILTER TO TRANSPORT\\n          └─> Update local references\\n```\\n\\n**Filter is passed at line 452 in remote.go:**\\n```go\\nreq := &transport.FetchRequest{\\n    Wants:       wants,\\n    Haves:       haves,\\n    Depth:       o.Depth,\\n    Progress:    o.Progress,\\n    IncludeTags: isWildcard && o.Tags == plumbing.TagFollowing,\\n    Filter:      o.Filter,  // <─── FROM FetchOptions\\n}\\n\\nif err := conn.Fetch(ctx, req); err != nil {\\n    // ...\\n}\\n```\\n\\n---\\n\\n### 6. **FetchRequest Transport Structure** (plumbing/transport/common.go, lines 86-110)\\n\\n```go\\ntype FetchRequest struct {\\n    Progress sideband.Progress              // Progress sideband\\n    Wants []plumbing.Hash                   // List of references to fetch\\n    Haves []plumbing.Hash                   // List of references client already has\\n    Depth int                               // Depth of the fetch\\n    Filter packp.Filter                     // Filters for partial clone (line 106)\\n    IncludeTags bool                        // Whether tags should be fetched\\n}\\n```\\n\\n**Note:** `Wants` is not for specific object hashes - it contains **ref target hashes** (what the refs point to). The transport layer converts these to a fetch request sent to the server. The server's upload-pack service then determines what objects are needed.\\n\\n---\\n\\n### 7. **Repository Object Convenience Methods** (repository.go, lines 1533-1576)\\n\\nThese are wrappers around `r.Storer.EncodedObject()`:\\n\\n```go\\nfunc (r *Repository) TreeObject(h plumbing.Hash) (*object.Tree, error) {\\n    return object.GetTree(r.Storer, h)\\n}\\n\\nfunc (r *Repository) CommitObject(h plumbing.Hash) (*object.Commit, error) {\\n    return object.GetCommit(r.Storer, h)\\n}\\n\\nfunc (r *Repository) BlobObject(h plumbing.Hash) (*object.Blob, error) {\\n    return object.GetBlob(r.Storer, h)\\n}\\n\\nfunc (r *Repository) TagObject(h plumbing.Hash) (*object.Tag, error) {\\n    return object.GetTag(r.Storer, h)\\n}\\n\\nfunc (r *Repository) Object(t plumbing.ObjectType, h plumbing.Hash) (object.Object, error) {\\n    obj, err := r.Storer.EncodedObject(t, h)\\n    if err != nil {\\n        return nil, err\\n    }\\n    return object.DecodeObject(r.Storer, obj)\\n}\\n```\\n\\n**All use `r.Storer.EncodedObject()` under the hood** which checks both packfiles and loose objects.\\n\\n---\\n\\n### 8. **Limitations: Cannot Fetch Specific Object Hashes**\\n\\ngo-git's transport **does NOT support fetching by specific object hash** (ref negotiation only):\\n\\n- **FetchRequest.Wants** contains **commit hashes** (what refs point to), not arbitrary objects\\n- The server's upload-pack service determines which **related objects** to send\\n- The `Wants` list is built from ref names/targets via `calculateRefs()` and `getWants()`\\n- You cannot directly request a blob hash - only commit hashes reachable via refs\\n\\n**The Filter helps narrow down WHICH objects the server sends**, but you still cannot directly fetch a specific blob without a ref pointing to a commit that references it.\\n\\n---\\n\\n### 9. **Filter Encoding for Network Transport** (filter.go, lines 71-80)\\n\\n```go\\nfunc FilterCombine(filters ...Filter) Filter {\\n    escapedFilters := make([]string, 0, len(filters))\\n    \\n    for _, filter := range filters {\\n        escapedFilters = append(escapedFilters, url.QueryEscape(string(filter)))\\n    }\\n    \\n    return Filter(fmt.Sprintf(\\\"combine:%s\\\", strings.Join(escapedFilters, \\\"+\\\")))\\n}\\n```\\n\\n**Filters are URL-encoded when combined**, then sent as a single string to the server.\\n\\n---\\n\\n### 10. **Object Storage Lookup Priority** (storage/filesystem/object.go)\\n\\n**When `s.index != nil` (packfiles exist):**\\n1. Try packfile lookup first\\n2. Fall back to loose objects\\n3. Check alternates\\n\\n**When `s.index == nil` (no packfiles):**\\n1. Try loose objects first\\n2. Fall back to packfile lookup (loads index on demand)\\n3. Check alternates\\n\\n**Alternates are checked if object not found in main storage** (supports clones with `--shared` or `git worktree`).\\n\\n---\\n\\n## File Paths in go-git v6\\n\\n- `/home/coder/go/pkg/mod/github.com/go-git/go-git/v6@v6.0.0-20260305211659-2083cf940afa/options.go` - FetchOptions struct\\n- `/home/coder/go/pkg/mod/github.com/go-git/go-git/v6@v6.0.0-20260305211659-2083cf940afa/plumbing/protocol/packp/filter.go` - Filter API\\n- `/home/coder/go/pkg/mod/github.com/go-git/go-git/v6@v6.0.0-20260305211659-2083cf940afa/plumbing/storer/object.go` - EncodedObjectStorer interface\\n- `/home/coder/go/pkg/mod/github.com/go-git/go-git/v6@v6.0.0-20260305211659-2083cf940afa/storage/filesystem/object.go` - ObjectStorage implementation\\n- `/home/coder/go/pkg/mod/github.com/go-git/go-git/v6@v6.0.0-20260305211659-2083cf940afa/remote.go` - Remote.Fetch() implementation\\n- `/home/coder/go/pkg/mod/github.com/go-git/go-git/v6@v6.0.0-20260305211659-2083cf940afa/plumbing/transport/common.go` - FetchRequest struct\\n- `/home/coder/go/pkg/mod/github.com/go-git/go-git/v6@v6.0.0-20260305211659-2083cf940afa/repository.go` - Repository object convenience methods\"}],\"totalDurationMs\":461636,\"totalTokens\":89031,\"totalToolUseCount\":26,\"usage\":{\"input_tokens\":0,\"cache_creation_input_tokens\":1460,\"cache_read_input_tokens\":83937,\"output_tokens\":3634,\"server_tool_use\":{\"we