func redactCodeLearnings(cls []CodeLearning) []CodeLearning {\\n   658→\\tif cls == nil {\\n   659→\\t\\treturn nil\\n   660→\\t}\\n   661→\\tout := make([]CodeLearning, len(cls))\\n   662→\\tfor i, cl := range cls {\\n   663→\\t\\tout[i] = CodeLearning{\\n   664→\\t\\t\\tPath:    cl.Path,\\n   665→\\t\\t\\tLine:    cl.Line,\\n   666→\\t\\t\\tEndLine: cl.EndLine,\\n   667→\\t\\t\\tFinding: redact.String(cl.Finding),\\n   668→\\t\\t}\\n   669→\\t}\\n   670→\\treturn out\\n   671→}\\n   672→\\n   673→// readMetadataFromBlob reads CommittedMetadata from a blob hash.\\n   674→func (s *GitStore) readMetadataFromBlob(hash plumbing.Hash) (*CommittedMetadata, error) {\\n   675→\\treturn readJSONFromBlob[CommittedMetadata](s.repo, hash)\\n   676→}\\n   677→\\n   678→// buildCommitMessage constructs the commit message with proper trailers.\\n   679→// The commit subject is always \\\"Checkpoint: <id>\\\" for consistency.\\n   680→// If CommitSubject is provided (e.g., for task checkpoints), it's included in the body.\\n   681→func (s *GitStore) buildCommitMessage(opts WriteCommittedOptions, taskMetadataPath string) string {\\n   682→\\tvar commitMsg strings.Builder\\n   683→\\n   684→\\t// Subject line is always the checkpoint ID for consistent formatting\\n   685→\\tfmt.Fprintf(&commitMsg, \\\"Checkpoint: %s\\\\n\\\\n\\\", opts.CheckpointID)\\n   686→\\n   687→\\t// Include custom description in body if provided (e.g., task checkpoint details)\\n   688→\\tif opts.CommitSubject != \\\"\\\" {\\n   689→\\t\\tcommitMsg.WriteString(opts.CommitSubject + \\\"\\\\n\\\\n\\\")\\n   690→\\t}\\n   691→\\tfmt.Fprintf(&commitMsg, \\\"%s: %s\\\\n\\\", trailers.SessionTrailerKey, opts.SessionID)\\n   692→\\tfmt.Fprintf(&commitMsg, \\\"%s: %s\\\\n\\\", trailers.StrategyTrailerKey, opts.Strategy)\\n   693→\\tif opts.Agent != \\\"\\\" {\\n   694→\\t\\tfmt.Fprintf(&commitMsg, \\\"%s: %s\\\\n\\\", trailers.AgentTrailerKey, opts.Agent)\\n   695→\\t}\\n   696→\\tif opts.EphemeralBranch != \\\"\\\" {\\n   697→\\t\\tfmt.Fprintf(&commitMsg, \\\"%s: %s\\\\n\\\", trailers.EphemeralBranchTrailerKey, opts.EphemeralBranch)\\n   698→\\t}\\n   699→\\tif taskMetadataPath != \\\"\\\" {\\n   700→\\t\\tfmt.Fprintf(&commitMsg, \\\"%s: %s\\\\n\\\", trailers.MetadataTaskTrailerKey, taskMetadataPath)\\n   701→\\t}\\n   702→\\n   703→\\treturn commitMsg.String()\\n   704→}\\n   705→\\n   706→// incrementalCheckpointData represents an incremental checkpoint during subagent execution.\\n   707→// This mirrors strategy.SubagentCheckpoint but avoids import cycles.\\n   708→type incrementalCheckpointData struct {\\n   709→\\tType      string          `json:\\\"type\\\"`\\n   710→\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   711→\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n   712→\\tData      json.RawMessage `json:\\\"data\\\"`\\n   713→}\\n   714→\\n   715→// taskCheckpointData represents a final task checkpoint.\\n   716→// This mirrors strategy.TaskCheckpoint but avoids import cycles.\\n   717→type taskCheckpointData struct {\\n   718→\\tSessionID      string `json:\\\"session_id\\\"`\\n   719→\\tToolUseID      string `json:\\\"tool_use_id\\\"`\\n   720→\\tCheckpointUUID string `json:\\\"checkpoint_uuid\\\"`\\n   721→\\tAgentID        string `json:\\\"agent_id,omitempty\\\"`\\n   722→}\\n   723→\\n   724→// ReadCommitted reads a committed checkpoint's summary by ID from the entire/checkpoints/v1 branch.\\n   725→// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n   726→// Use ReadSessionContent to read actual transcript/prompts/context.\\n   727→// Returns nil, nil if the checkpoint doesn't exist.\\n   728→//\\n   729→// The storage format uses numbered subdirectories for each session (0-based):\\n   730→//\\n   731→//\\t<checkpoint-id>/\\n   732→//\\t├── metadata.json      # CheckpointSummary with sessions map\\n   733→//\\t├── 0/                 # First session\\n   734→//\\t│   ├── metadata.json  # Session-specific metadata\\n   735→//\\t│   └── full.jsonl     # Transcript\\n   736→//\\t├── 1/                 # Second session\\n   737→//\\t└── ...\\n   738→func (s *GitStore) ReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error) {\\n   739→\\tif err := ctx.Err(); err != nil {\\n   740→\\t\\treturn nil, err //nolint:wrapcheck // Propagating context cancellation\\n   741→\\t}\\n   742→\\n   743→\\ttree, err := s.getSessionsBranchTree()\\n   744→\\tif err != nil {\\n   745→\\t\\treturn nil, nil //nolint:nilnil,nilerr // No sessions branch means no checkpoint exists\\n   746→\\t}\\n   747→\\n   748→\\tcheckpointPath := checkpointID.Path()\\n   749→\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n   750→\\tif err != nil {\\n   751→\\t\\treturn nil, nil //nolint:nilnil,nilerr // Checkpoint directory not found\\n   752→\\t}\\n   753→\\n   754→\\t// Read root metadata.json as CheckpointSummary\\n   755→\\tmetadataFile, err := checkpointTree.File(paths.MetadataFileName)\\n   756→\\tif err != nil {\\n   757→\\t\\treturn nil, nil //nolint:nilnil,nilerr // metadata.json not found\\n   758→\\t}\\n   759→\\n   760→\\tcontent, err := metadataFile.Contents()\\n   761→\\tif err != nil {\\n   762→\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata.json: %w\\\", err)\\n   763→\\t}\\n   764→\\n   765→\\tvar summary CheckpointSummary\\n   766→\\tif err := json.Unmarshal([]byte(content), &summary); err != nil {\\n   767→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata.json: %w\\\", err)\\n   768→\\t}\\n   769→\\n   770→\\treturn &summary, nil\\n   771→}\\n   772→\\n   773→// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n   774→// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n   775→// Returns the session's metadata, transcript, prompts, and context.\\n   776→// Returns an error if the checkpoint or session doesn't exist.\\n   777→func (s *GitStore) ReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error) {\\n   778→\\tif err := ctx.Err(); err != nil {\\n   779→\\t\\treturn nil, err //nolint:wrapcheck // Propagating context cancellation\\n   780→\\t}\\n   781→\\n   782→\\ttree, err := s.getSessionsBranchTree()\\n   783→\\tif err != nil {\\n   784→\\t\\treturn nil, ErrCheckpointNotFound\\n   785→\\t}\\n   786→\\n   787→\\tcheckpointPath := checkpointID.Path()\\n   788→\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n   789→\\tif err != nil {\\n   790→\\t\\treturn nil, ErrCheckpointNotFound\\n   791→\\t}\\n   792→\\n   793→\\t// Get the session subdirectory\\n   794→\\tsessionDir := strconv.Itoa(sessionIndex)\\n   795→\\tsessionTree, err := checkpointTree.Tree(sessionDir)\\n   796→\\tif err != nil {\\n   797→\\t\\treturn nil, fmt.Errorf(\\\"session %d not found: %w\\\", sessionIndex, err)\\n   798→\\t}\\n   799→\"}]},\"uuid\":\"2025b88f-1cfd-4674-8a86-69f4e49a18ff\",\"timestamp\":\"2026-03-11T10:32:23.310Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a159c6eb580cebc56\"},\"toolUseID\":\"agent_msg_011vMvvbDtPAZ1r6yyMHPhR4\",\"parentToolUseID\":\"toolu_018JLpj3aCB2orosaBVb23F2\",\"uuid\":\"4e46fea3-9c42-4e48-b901-fb5942032744\",\"timestamp\":\"2026-03-11T10:32:23.473Z\"}\n{\"parentUuid\":\"4e46fea3-9c42-4e48-b901-fb5942032744\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/home/coder/git/entireio/cli\",\"sessionId\":\"3261e1c6-a0db-489e-8d99-ad60228e4158\",\"version\":\"2.1.72\",\"gitBranch\":\"pjbgf/jsonl-data2\",\"slug\":\"reactive-dancing-wolf\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-11T10:32:23.487Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01J75LQcGPnk1YPMd9oqZEDn\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01UTw3dnMGr1iN8HKQPWQpEv\",\"name\":\"Read\",\"input\":{\"file_path\":\"/home/coder/git/entireio/cli/cmd/entire/c