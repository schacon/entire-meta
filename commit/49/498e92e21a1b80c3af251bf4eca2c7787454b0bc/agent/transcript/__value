cks local config first, then falls back to global config.\\n    36→// If go-git can't find the config, it falls back to using the git command.\\n    37→// Returns fallback defaults if no user is configured anywhere.\\n    38→func GetGitAuthor(ctx context.Context) (*GitAuthor, error) {\\n    39→\\trepo, err := openRepository(ctx)\\n    40→\\tif err != nil {\\n    41→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n    42→\\t}\\n    43→\\n    44→\\tname, email := strategy.GetGitAuthorFromRepo(repo)\\n    45→\\n    46→\\t// If go-git returned defaults, try using git command as fallback\\n    47→\\t// This handles cases where go-git can't find the config (e.g., different HOME paths,\\n    48→\\t// non-standard config locations, or environment issues in hook contexts)\\n    49→\\tif name == \\\"Unknown\\\" {\\n    50→\\t\\tif gitName := getGitConfigValue(ctx, \\\"user.name\\\"); gitName != \\\"\\\" {\\n    51→\\t\\t\\tname = gitName\\n    52→\\t\\t}\\n    53→\\t}\\n    54→\\tif email == \\\"unknown@local\\\" {\\n    55→\\t\\tif gitEmail := getGitConfigValue(ctx, \\\"user.email\\\"); gitEmail != \\\"\\\" {\\n    56→\\t\\t\\temail = gitEmail\\n    57→\\t\\t}\\n    58→\\t}\\n    59→\\n    60→\\treturn &GitAuthor{\\n    61→\\t\\tName:  name,\\n    62→\\t\\tEmail: email,\\n    63→\\t}, nil\\n    64→}\\n    65→\\n    66→// getGitConfigValue retrieves a git config value using the git command.\\n    67→// Returns empty string if the value is not set or on error.\\n    68→func getGitConfigValue(ctx context.Context, key string) string {\\n    69→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"config\\\", \\\"--get\\\", key)\\n    70→\\toutput, err := cmd.Output()\\n    71→\\tif err != nil {\\n    72→\\t\\treturn \\\"\\\"\\n    73→\\t}\\n    74→\\treturn strings.TrimSpace(string(output))\\n    75→}\\n    76→\\n    77→// IsOnDefaultBranch checks if the repository is currently on the default branch.\\n    78→// It determines the default branch by:\\n    79→// 1. Checking the remote origin's HEAD reference\\n    80→// 2. Falling back to common names (main, master) if remote HEAD is unavailable\\n    81→// Returns (isDefault, branchName, error)\\n    82→func IsOnDefaultBranch(ctx context.Context) (bool, string, error) {\\n    83→\\trepo, err := openRepository(ctx)\\n    84→\\tif err != nil {\\n    85→\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n    86→\\t}\\n    87→\\n    88→\\t// Get current branch\\n    89→\\thead, err := repo.Head()\\n    90→\\tif err != nil {\\n    91→\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n    92→\\t}\\n    93→\\n    94→\\tif !head.Name().IsBranch() {\\n    95→\\t\\t// Detached HEAD - not on any branch\\n    96→\\t\\treturn false, \\\"\\\", nil\\n    97→\\t}\\n    98→\\n    99→\\tcurrentBranch := head.Name().Short()\\n   100→\\n   101→\\t// Try to get default branch from remote origin's HEAD\\n   102→\\tdefaultBranch := getDefaultBranchFromRemote(repo)\\n   103→\\n   104→\\t// If we couldn't determine from remote, use common defaults\\n   105→\\tif defaultBranch == \\\"\\\" {\\n   106→\\t\\t// Check if current branch is a common default name\\n   107→\\t\\tif currentBranch == \\\"main\\\" || currentBranch == \\\"master\\\" {\\n   108→\\t\\t\\treturn true, currentBranch, nil\\n   109→\\t\\t}\\n   110→\\t\\treturn false, currentBranch, nil\\n   111→\\t}\\n   112→\\n   113→\\treturn currentBranch == defaultBranch, currentBranch, nil\\n   114→}\\n   115→\\n   116→// getDefaultBranchFromRemote tries to determine the default branch from the origin remote.\\n   117→// Returns empty string if unable to determine.\\n   118→func getDefaultBranchFromRemote(repo *git.Repository) string {\\n   119→\\t// Try to get the symbolic reference for origin/HEAD\\n   120→\\tref, err := repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", \\\"HEAD\\\"), true)\\n   121→\\tif err == nil && ref != nil {\\n   122→\\t\\t// re