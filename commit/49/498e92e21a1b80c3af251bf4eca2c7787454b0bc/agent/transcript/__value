g.NewBranchReferenceName(paths.MetadataBranchName)\\n  1216→\\tnewRef := plumbing.NewHashReference(refName, newCommitHash)\\n  1217→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1218→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1219→\\t}\\n  1220→\\n  1221→\\treturn nil\\n  1222→}\\n  1223→\\n  1224→// replaceTranscript writes the full transcript content, replacing any existing transcript.\\n  1225→// Also removes any chunk files from a previous write and updates the content hash.\\n  1226→func (s *GitStore) replaceTranscript(ctx context.Context, transcript []byte, agentType types.AgentType, sessionPath string, entries map[string]object.TreeEntry) error {\\n  1227→\\t// Remove existing transcript files (base + any chunks)\\n  1228→\\ttranscriptBase := sessionPath + paths.TranscriptFileName\\n  1229→\\tfor key := range entries {\\n  1230→\\t\\tif key == transcriptBase || strings.HasPrefix(key, transcriptBase+\\\".\\\") {\\n  1231→\\t\\t\\tdelete(entries, key)\\n  1232→\\t\\t}\\n  1233→\\t}\\n  1234→\\n  1235→\\t// Chunk the transcript (matches writeTranscript behavior)\\n  1236→\\tchunks, err := agent.ChunkTranscript(ctx, transcript, agentType)\\n  1237→\\tif err != nil {\\n  1238→\\t\\treturn fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n  1239→\\t}\\n  1240→\\n  1241→\\t// Write chunk files\\n  1242→\\tfor i, chunk := range chunks {\\n  1243→\\t\\tchunkPath := sessionPath + agent.ChunkFileName(paths.TranscriptFileName, i)\\n  1244→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, chunk)\\n  1245→\\t\\tif err != nil {\\n  1246→\\t\\t\\treturn fmt.Errorf(\\\"failed to create transcript blob: %w\\\", err)\\n  1247→\\t\\t}\\n  1248→\\t\\tentries[chunkPath] = object.TreeEntry{\\n  1249→\\t\\t\\tName: chunkPath,\\n  1250→\\t\\t\\tMode: filemode.Regular,\\n  1251→\\t\\t\\tHash: blobHash,\\n  1252→\\t\\t}\\n  1253→\\t}\\n  1254→\\n  1255→\\t// Update content hash\\n  1256→\\tcontentHash := fmt.Sprintf(\\\"sha256:%x\\\", sha256.Sum256(transcript))\\n  1257→\\thashBlob, err := CreateBlobFromContent(s.repo, []byte(contentHash))\\n  1258→\\tif err != nil {\\n  1259→\\t\\treturn fmt.Errorf(\\\"failed to create content hash blob: %w\\\", err)\\n  1260→\\t}\\n  1261→\\thashPath := sessionPath + paths.ContentHashFileName\\n  1262→\\tentries[hashPath] = object.TreeEntry{\\n  1263→\\t\\tName: hashPath,\\n  1264→\\t\\tMode: filemode.Regular,\\n  1265→\\t\\tHash: hashBlob,\\n  1266→\\t}\\n  1267→\\n  1268→\\treturn nil\\n  1269→}\\n  1270→\\n  1271→// ensureSessionsBranch ensures the entire/checkpoints/v1 branch exists.\\n  1272→func (s *GitStore) ensureSessionsBranch() error {\\n  1273→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1274→\\t_, err := s.repo.Reference(refName, true)\\n  1275→\\tif err == nil {\\n  1276→\\t\\treturn nil // Branch exists\\n  1277→\\t}\\n  1278→\\n  1279→\\t// Create orphan branch with empty tree\\n  1280→\\temptyTreeHash, err := BuildTreeFromEntries(s.repo, make(map[string]object.TreeEntry))\\n  1281→\\tif err != nil {\\n  1282→\\t\\treturn err\\n  1283→\\t}\\n  1284→\\n  1285→\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n  1286→\\tcommitHash, err := s.createCommit(emptyTreeHash, plumbing.ZeroHash, \\\"Initialize sessions branch\\\", authorName, authorEmail)\\n  1287→\\tif err != nil {\\n  1288→\\t\\treturn err\\n  1289→\\t}\\n  1290→\\n  1291→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n  1292→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1293→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1294→\\t}\\n  1295→\\treturn nil\\n  1296→}\\n  1297→\\n  1298→// getSessionsBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\n  1299→// Falls back to origin/entire/checkpoints/v1 if the local branch doesn't exist.\\n  1300→func (s *GitStore) getSessionsBranchTree() (*object.Tree, error) {\\n  1301→\\trefName := plumbing.NewBranc