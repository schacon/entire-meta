\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store blob object: %w\\\", err)\\n  1349→\\t}\\n  1350→\\treturn hash, nil\\n  1351→}\\n  1352→\\n  1353→// copyMetadataDir copies all files from a directory to the checkpoint path.\\n  1354→// Used to include additional metadata files like task checkpoints, subagent transcripts, etc.\\n  1355→func (s *GitStore) copyMetadataDir(metadataDir, basePath string, entries map[string]object.TreeEntry) error {\\n  1356→\\terr := filepath.Walk(metadataDir, func(path string, info os.FileInfo, err error) error {\\n  1357→\\t\\tif err != nil {\\n  1358→\\t\\t\\treturn err\\n  1359→\\t\\t}\\n  1360→\\n  1361→\\t\\t// Skip symlinks to prevent reading files outside the metadata directory.\\n  1362→\\t\\t// A symlink could point to sensitive files (e.g., /etc/passwd) which would\\n  1363→\\t\\t// then be captured in the checkpoint and stored in git history.\\n  1364→\\t\\t// NOTE: filepath.Walk uses os.Stat (follows symlinks), so info.Mode() never\\n  1365→\\t\\t// reports ModeSymlink. We use os.Lstat to check the entry itself.\\n  1366→\\t\\t// This check MUST come before IsDir() because Walk follows symlinked\\n  1367→\\t\\t// directories and would recurse into them otherwise.\\n  1368→\\t\\tlinfo, lstatErr := os.Lstat(path)\\n  1369→\\t\\tif lstatErr != nil {\\n  1370→\\t\\t\\treturn fmt.Errorf(\\\"failed to lstat %s: %w\\\", path, lstatErr)\\n  1371→\\t\\t}\\n  1372→\\t\\tif linfo.Mode()&os.ModeSymlink != 0 {\\n  1373→\\t\\t\\tif info.IsDir() {\\n  1374→\\t\\t\\t\\treturn filepath.SkipDir\\n  1375→\\t\\t\\t}\\n  1376→\\t\\t\\treturn nil\\n  1377→\\t\\t}\\n  1378→\\n  1379→\\t\\tif info.IsDir() {\\n  1380→\\t\\t\\treturn nil\\n  1381→\\t\\t}\\n  1382→\\n  1383→\\t\\t// Get relative path within metadata dir\\n  1384→\\t\\trelPath, err := filepath.Rel(metadataDir, path)\\n  1385→\\t\\tif err != nil {\\n  1386→\\t\\t\\treturn fmt.Errorf(\\\"failed to get relative path for %s: %w\\\", path, err)\\n  1387→\\t\\t}\\n  1388→\\n  1