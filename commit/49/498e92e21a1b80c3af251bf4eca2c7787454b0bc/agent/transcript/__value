sive\\n    22→// operation.\\n    23→type SubmoduleRecursivity uint\\n    24→\\n    25→const (\\n    26→\\t// DefaultRemoteName name of the default Remote, just like git command.\\n    27→\\tDefaultRemoteName = \\\"origin\\\"\\n    28→\\n    29→\\t// NoRecurseSubmodules disables the recursion for a submodule operation.\\n    30→\\tNoRecurseSubmodules SubmoduleRecursivity = 0\\n    31→\\t// DefaultSubmoduleRecursionDepth allow recursion in a submodule operation.\\n    32→\\tDefaultSubmoduleRecursionDepth SubmoduleRecursivity = 10\\n    33→)\\n    34→\\n    35→// ErrMissingURL is returned when a URL is required but not provided.\\n    36→var ErrMissingURL = errors.New(\\\"URL field is required\\\")\\n    37→\\n    38→// CloneOptions describes how a clone should be performed.\\n    39→type CloneOptions struct {\\n    40→\\t// The (possibly remote) repository URL to clone from.\\n    41→\\tURL string\\n    42→\\t// Auth credentials, if required, to use with the remote repository.\\n    43→\\tAuth transport.AuthMethod\\n    44→\\t// Name of the remote to be added, by default `origin`.\\n    45→\\tRemoteName string\\n    46→\\t// Remote branch to clone.\\n    47→\\tReferenceName plumbing.ReferenceName\\n    48→\\t// Fetch only ReferenceName if true.\\n    49→\\tSingleBranch bool\\n    50→\\t// Mirror clones the repository as a mirror.\\n    51→\\t//\\n    52→\\t// Compared to a bare clone, mirror not only maps local branches of the\\n    53→\\t// source to local branches of the target, it maps all refs (including\\n    54→\\t// remote-tracking branches, notes etc.) and sets up a refspec configuration\\n    55→\\t// such that all these refs are overwritten by a git remote update in the\\n    56→\\t// target repository.\\n    57→\\tMirror bool\\n    58→\\t// No checkout of HEAD after clone if true.\\n    59→\\tNoCheckout bool\\n    60→\\t// Limit fetching to the specified number of commits.\\n    61→\\tDepth int\\n    62→\\t// RecurseSubmodules after the clone is created, initialize all submodules\\n    63→\\t// within, using their default settings. This option is ignored if the\\n    64→\\t// cloned repository does not have a worktree.\\n    65→\\tRecurseSubmodules SubmoduleRecursivity\\n    66→\\t// ShallowSubmodules limit cloning submodules to the 1 level of depth.\\n    67→\\t// It matches the git command --shallow-submodules.\\n    68→\\tShallowSubmodules bool\\n    69→\\t// Progress is where the human readable information sent by the server is\\n    70→\\t// stored, if nil nothing is stored and the capability (if supported)\\n    71→\\t// no-progress, is sent to the server to avoid send this information.\\n    72→\\tProgress sideband.Progress\\n    73→\\t// Tags describe how the tags will be fetched from the remote repository,\\n    74→\\t// by default is AllTags.\\n    75→\\tTags plumbing.TagMode\\n    76→\\t// InsecureSkipTLS skips ssl verify if protocol is https\\n    77→\\tInsecureSkipTLS bool\\n    78→\\t// CABundle specify additional ca bundle with system cert pool\\n    79→\\tCABundle []byte\\n    80→\\t// ProxyOptions provides info required for connecting to a proxy.\\n    81→\\tProxyOptions transport.ProxyOptions\\n    82→\\t// When the repository to clone is on the local machine, instead of\\n    83→\\t// using hard links, automatically setup .git/objects/info/alternates\\n    84→\\t// to share the objects with the source repository.\\n    85→\\t// The resulting repository starts out without any object of its own.\\n    86→\\t// NOTE: this is a possibly dangerous operation; do not use it unless\\n    87→\\t// you understand what it does.\\n    88→\\t//\\n    89→\\t// [Reference]: https://git-scm.com/docs/git-clone#Documentation/git-clone.txt---shared\\n    90→\\tShared bool\\n    91→\\t// Filter requests that the server to send only a subset of the objects.\\n    92→\\t// See https://git-scm.com/docs/git-clone#Documentation/git-clone.txt-code--filterltfilter-specgtcode\\n    93→\\tFilter packp.Filter\\n    94→\\t// Bare determines whether the repository will have a worktree (non-bare)\\n    95→\\t// or not (bare).\\n    96→\\tBare bool\\n    97→\\n    98→\\t// worktree defines the worktree filesystem for non-bare clone operations.\\n    99→\\t// This is only used internally due to partial inits.\\n   100→\\tworktree billy.Filesystem\\n   101→}\\n   102→\\n   103→// MergeOptions describes how a merge should be performed.\\n   104→type MergeOptions struct {\\n   105→\\t// Strategy defines the merge strategy to be used.\\n   106→\\tStrategy MergeStrategy\\n   107→}\\n   108→\\n   109→// MergeStrategy represents the different types of merge strategies.\\n   110→type MergeStrategy int8\\n   111→\\n   112→const (\\n   113→\\t// FastForwardMerge represents a Git merge strategy where the current\\n   114→\\t// branch can be simply updated to point to the HEAD of the branch being\\n   115→\\t// merged. This is only possible if the history of the branch being merged\\n   116→\\t// is a linear descendant of the current branch, with no conflicting commits.\\n   117→\\t//\\n   118→\\t// This is the default option.\\n   119→\\tFastForwardMerge MergeStrategy = iota\\n   120→)\\n   121→\\n   122→// OrtMergeStrategyOption defines the merge strategy options for the ORT merge strategy, which can only resolve two heads using a 3-way merge algorithm.\\n   123→// Since Git v2.50.0, ORT is synonym of recursive.\\n   124→type OrtMergeStrategyOption int8\\n   125→\\n   126→const (\\n   127→\\t// TheirsMergeStrategy is a merge strategy option that auto-resolves the changes by accepting the incoming version of the changes.\\n   128→\\tTheirsMergeStrategy OrtMergeStrategyOption = iota\\n   129→\\n   130→\\t// OursMergeStrategy is a merge strategy option that auto-resolves the changes by accepting our version of the changes and rejecting the incoming changes.\\n   131→\\tOursMergeStrategy\\n   132→)\\n   133→\\n   134→// Validate validates the fields and sets the default values.\\n   135→func (o *CloneOptions) Validate() error {\\n   136→\\tif o.URL == \\\"\\\" {\\n   137→\\t\\treturn ErrMissingURL\\n   138→\\t}\\n   139→\\n   140→\\tif o.RemoteName == \\\"\\\" {\\n   141→\\t\\to.RemoteName = DefaultRemoteName\\n   142→\\t}\\n   143→\\n   144→\\tif o.ReferenceName == \\\"\\\" {\\n   145→\\t\\to.ReferenceName = plumbing.HEAD\\n   146→\\t}\\n   147→\\n   148→\\tif o.Tags == plumbing.InvalidTagMode {\\n   149→\\t\\to.Tags = plumbing.AllTags\\n   150→\\t}\\n   151→\\n   152→\\treturn nil\\n   153→}\\n   154→\\n   155→// PullOptions describes how a pull should be performed.\\n   156→type PullOptions struct {\\n   157→\\t// Name of the remote to be pulled. If empty, uses the default.\\n   158→\\tRemoteName string\\n   159→\\t// RemoteURL overrides the remote repo address with a custom URL\\n   160→\\tRemoteURL string\\n   161→\\t// Remote branch to clone. If empty, uses HEAD.\\n   162→\\tReferenceName plumbing.ReferenceName\\n   163→\\t// Fetch only ReferenceName if true.\\n   164→\\tSingleBranch bool\\n   165→\\t// Limit fetching to the specified number of commits.\\n   166→\\tDepth int\\n   167→\\t// Auth credentials, if required, to use with the remote repository.\\n   168→\\tAuth transport.AuthMethod\\n   169→\\t// RecurseSubmodules controls if new commits of all populated submodules\\n   170→\\t// should be fetched too.\\n   171→\\tRecurseSubmodules SubmoduleRecursivity\\n   172→\\t// Progress is where the human readable information sent by the server is\\n   173→\\t// stored, if nil nothing is stored and the capability (if supported)\\n   174→\\t// no-progress, is sent to the server to avoid send this information.\\n   175→\\tProgress sideband.Progress\\n   176→\\t// Force allows the pull to update a local branch even when the remote\\n   177→\\t// branch does not descend from it.\\n   178→\\tForce bool\\n   179→\\t// InsecureSkipTLS skips ssl verify if protocol is https\\n   180→\\tInsecureSkipTLS bool\\n   181→\\t// CABundle specify additional ca bundle with system cert pool\\n   182→\\tCABundle []byte\\n   183→\\t// ProxyOptions provides info required for connecting to a proxy.\\n   184→\\tProxyOptions transport.ProxyOptions\\n   185→}\\n   186→\\n   187→// Validate validates the fields and sets the default values.\\n   188→func (o *PullOptions) Validate() error {\\n   189→\\tif o.RemoteName == \\\"\\\" {\\n   190→\\t\\to.RemoteName = DefaultRemoteName\\n   191→\\t}\\n   192→\\n   193→\\tif o.ReferenceName == \\\"\\\" {\\n   194→\\t\\to.ReferenceName = plumbing.HEAD\\n   195→\\t}\\n   196→\\n   197→\\treturn nil\\n   198→}\\n   199→\\n   200→// Tag modes for fetching.\\n   201→const (\\n   202→\\tInvalidTagMode = plumbing.InvalidTagMode\\n   203→\\t// TagFollowing any tag that points into the histories being fetched is also\\n   204→\\t// fetched. TagFollowing requires a server with `include-tag` capability\\n   205→\\t// in order to fetch the annotated tags objects.\\n   206→\\tTagFollowing = plumbing.TagFollowing\\n   207→\\t// AllTags fetch all tags from the remote (i.e., fetch remote tags\\n   208→\\t// refs/tags/* into local tags with the same name)\\n   209→\\tAllTags = plumbing.AllTags\\n   210→\\t// NoTags fetch no tags from the remote at all\\n   211→\\tNoTags = plumbing.NoTags\\n   212→)\\n   213→\\n   214→// FetchOptions describes how a fetch should be performed\\n   215→type FetchOptions struct {\\n   216→\\t// Name of the remote to fetch from. Defaults to origin.\\n   217→\\tRemoteName string\\n   218→\\t// RemoteURL overrides the remote repo address with a custom URL\\n   219→\\tRemoteURL string\\n   220→\\tRefSpecs  []config.RefSpec\\n   221→\\t// Depth limit fetching to the specified number of commits from the tip of\\n   222→\\t// each remote branch history.\\n   223→\\tDepth int\\n   224→\\t// Auth credentials, if required, to use with the remote repository.\\n   225→\\tAuth transport.AuthMethod\\n   226→\\t// Progress is where the human readable information sent by the server is\\n   227→\\t// stored, if nil nothing is stored and the capability (if supported)\\n   228→\\t// no-progress, is sent to the server to avoid send this information.\\n   229→\\tProgress sideband.Progress\\n   230→\\t// Tags describe how the tags will be fetched from the remote repository,\\n   231→\\t// by default is TagFollowing.\\n   232→\\tTags plumbing.TagMode\\n   233→\\t// Force allows the fetch to update a local branch even when the remote\\n   234→\\t// branch does not descend from it.\\n   235→\\tForce bool\\n   236→\\t// InsecureSkipTLS skips ssl verify if protocol is https\\n   237→\\tInsecureSkipTLS bool\\n   238→\\t// CABundle specify additional ca bundle with system cert pool\\n   239→\\tCABundle []byte\\n   240→\\t// ProxyOptions provides info required for connecting to a proxy.\\n   241→\\tProxyOptions transport.ProxyOptions\\n   242→\\t// Prune specify that local refs that match given RefSpecs and that do\\n   243→\\t// not exist remotely will be removed.\\n   244→\\tPrune bool\\n   245→\\t// Filter requests that the server to send only a subset of the objects.\\n   246→\\t// See https://git-scm.com/docs/git-clone#Documentation/git-clone.txt-code--filterltfilter-specgtcode\\n   247→\\tFilter packp.Filter\\n   248→}\\n   249→\\n   250→// Validate validates the fields and sets the default values.\\n   251→func (o *FetchOptions) Validate() error {\\n   252→\\tif o.RemoteName == \\\"\\\" {\\n   253→\\t\\to.RemoteName = DefaultRemoteName\\n   254→\\t}\\n   255→\\n   256→\\tif o.Tags == plumbing.InvalidTagMode {\\n   257→\\t\\to.Tags = plumbing.TagFollowing\\n   258→\\t}\\n   259→\\n   260→\\tfor _, r := range o.RefSpecs {\\n   261→\\t\\tif err := r.Validate(); err != nil {\\n   262→\\t\\t\\treturn err\\n   263→\\t\\t}\\n   264→\\t}\\n   265→\\n   266→\\treturn nil\\n   267→}\\n   268→\\n   269→// PushOptions describes how a push should be performed.\\n   270→type PushOptions struct {\\n   271→\\t// RemoteName is the name of the remote to be pushed to.\\n   272→\\tRemoteName string\\n   273→\\t// RemoteURL overrides the remote repo address with a custom URL\\n   274→\\tRemoteURL string\\n   275→\\t// RefSpecs specify what destination ref to update with what source object.\\n   276→\\t//\\n   277→\\t// The format of a <refspec> parameter is an optional plus +, followed by\\n   278→\\t//  the source object <src>, followed by a colon :, followed by the destination ref <dst>.\\n   279→\\t// The <src> is often the name of the branch you would want to push, but it can be a SHA-1.\\n   280→\\t// The <dst> tells which ref on the remote side is updated with this push.\\n   281→\\t//\\n   282→\\t// A refspec with empty src can be used to delete a reference.\\n   283→\\tRefSpecs []config.RefSpec\\n   284→\\t// Auth credentials, if required, to use with the remote repository.\\n   285→\\tAuth transport.AuthMethod\\n   286→\\t// Progress is where the human readable information sent by the server is\\n   287→\\t// stored, if nil nothing is stored.\\n   288→\\tProgress sideband.Progress\\n   289→\\t// Prune specify that remote refs that match given RefSpecs and that do\\n   290→\\t// not exist locally will be removed.\\n   291→\\tPrune bool\\n   292→\\t// Force allows the push to update a remote branch even when the local\\n   293→\\t// branch does not descend from it.\\n   294→\\tForce bool\\n   295→\\t// InsecureSkipTLS skips ssl verify if protocol is https\\n   296→\\tInsecureSkipTLS bool\\n   297→\\t// CABundle specify additional ca bundle with system cert pool\\n   298→\\tCABundle []byte\\n   299→\\t// RequireRemoteRefs only allows a remote ref to be updated if its current\\n   300→\\t// value is the one specified here.\\n   301→\\tRequireRemoteRefs []config.RefSpec\\n   302→\\t// FollowTags will send any annotated tags with a commit target reachable from\\n   303→\\t// the refs already being pushed\\n   304→\\tFollowTags bool\\n   305→\\t// ForceWithLease allows a force push as long as the remote ref adheres to a \\\"lease\\\"\\n   306→\\tForceWithLease *ForceWithLease\\n   307→\\t// PushOptions sets options to be transferred to the server during push.\\n   308→\\tOptions []string\\n   309→\\t// Atomic sets option to be an atomic push\\n   310→\\tAtomic bool\\n   311→\\t// ProxyOptions provides info required for connecting to a proxy.\\n   312→\\tProxyOptions transport.ProxyOptions\\n   313→\\t// Quiet indicates whether the server should suppress human-readable\\n   314→\\t// output.\\n   315→\\tQuiet bool\\n   316→}\\n   317→\\n   318→// ForceWithLease sets fields on the lease\\n   319→// If neither RefName nor Hash are set, ForceWithLease protects\\n   320→// all refs in the refspec by ensuring the ref of the remote in the local repository\\n   321→// matches the one in the ref advertisement.\\n   322→type ForceWithLease struct {\\n   323→\\t// RefName, when set will protect the ref by ensuring it matches the\\n   324→\\t// hash in the ref advertisement.\\n   325→\\tRefName plumbing.ReferenceName\\n   326→\\t// Hash is the expected object id of RefName. The push will be rejected unless this\\n   327→\\t// matches the corresponding object id of RefName in the refs advertisement.\\n   328→\\tHash plumbing.Hash\\n   329→}\\n   330→\\n   331→// Validate validates the fields and sets the default values.\\n   332→func (o *PushOptions) Validate() error {\\n   333→\\tif o.RemoteName == \\\"\\\" {\\n   334→\\t\\to.RemoteName = DefaultRemoteName\\n   335→\\t}\\n   336→\\n   337→\\tif len(o.RefSpecs) == 0 {\\n   338→\\t\\to.RefSpecs = []config.RefSpec{\\n   339→\\t\\t\\tconfig.RefSpec(config.DefaultPushRefSpec),\\n   340→\\t\\t}\\n   341→\\t}\\n   342→\\n   343→\\tfor _, r := range o.RefSpecs {\\n   344→\\t\\tif err := r.Validate(); err != nil {\\n   345→\\t\\t\\treturn err\\n   346→\\t\\t}\\n   347→\\t}\\n   348→\\n   349→\\treturn nil\\n   350→}\\n   351→\\n   352→// SubmoduleUpdateOptions describes how a submodule update should be performed.\\n   353→type SubmoduleUpdateOptions struct {\\n   354→\\t// Init, if true initializes the submodules recorded in the index.\\n   355→\\tInit bool\\n   356→\\t// NoFetch tell to the update command to not fetch new objects from the\\n   357→\\t// remote site.\\n   358→\\tNoFetch bool\\n   359→\\t// RecurseSubmodules the update is performed not only in the submodules of\\n   360→\\t// the current repository but also in any nested submodules inside those\\n   361→\\t// submodules (and so on). Until the SubmoduleRecursivity is reached.\\n   362→\\tRecurseSubmodules SubmoduleRecursivity\\n   363→\\t// Auth credentials, if required, to use with the remote repository.\\n   364→\\tAuth transport.AuthMethod\\n   365→\\t// Depth limit fetching to the specified number of commits from the tip of\\n   366→\\t// each remote branch history.\\n   367→\\tDepth int\\n   368→}\\n   369→\\n   370→// Checkout errors.\\n   371→var (\\n   372→\\tErrBranchHashExclusive  = errors.New(\\\"Branch and Hash are mutually exclusive\\\")\\n   373→\\tErrCreateRequiresBranch = errors.New(\\\"Branch is mandatory when Create is used\\\")\\n   374→)\\n   375→\\n   376→// CheckoutOptions describes how a checkout operation should be performed.\\n   377→type CheckoutOptions struct {\\n   378→\\t// Hash is the hash of a commit or tag to be checked out. If used, HEAD\\n   379→\\t// will be in detached mode. If Create is not used, Branch and Hash are\\n   380→\\t// mutually exclusive.\\n   381→\\tHash plumbing.Hash\\n   382→\\t// Branch to be checked out, if Branch and Hash are empty is set to `master`.\\n   383→\\tBranch plumbing.ReferenceName\\n   384→\\t// Create a new branch named Branch and start it at Hash.\\n   385→\\tCreate bool\\n   386→\\t// Force, if true when switching branches, proceed even if the index or the\\n   387→\\t// working tree differs from HEAD. This is used to throw away local changes\\n   388→\\tForce bool\\n   389→\\t// Keep, if true when switching branches, local changes (the index or the\\n   390→\\t// working tree changes) will be kept so that they can be committed to the\\n   391→\\t// target branch. Force and Keep are mutually exclusive, should not be both\\n   392→\\t// set to true.\\n   393→\\tKeep bool\\n   394→\\t// SparseCheckoutDirectories\\n   395→\\tSparseCheckoutDirectories []string\\n   396→}\\n   397→\\n   398→// Validate validates the fields and sets the default values.\\n   399→func (o *CheckoutOptions) Validate() error {\\n   400→\\tif !o.Create && !o.Hash.IsZero() && o.Branch != \\\"\\\" {\\n   401→\\t\\treturn ErrBranchHashExclusive\\n   402→\\t}\\n   403→\\n   404→\\tif o.Create && o.Branch == \\\"\\\" {\\n   405→\\t\\treturn ErrCreateRequiresBranch\\n   406→\\t}\\n   407→\\n   408→\\tif o.Branch == \\\"\\\" {\\n   409→\\t\\to.Branch = plumbing.Master\\n   410→\\t}\\n   411→\\n   412→\\treturn nil\\n   413→}\\n   414→\\n   415→// ResetMode defines the mode of a reset operation.\\n   416→type ResetMode int8\\n   417→\\n   418→const (\\n   419→\\t// MixedReset resets the index but not the working tree (i.e., the changed\\n   420→\\t// files are preserved but not marked for commit) and reports what has not\\n   421→\\t// been updated. This is the default action.\\n   422→\\tMixedReset ResetMode = iota\\n   423→\\t// HardReset resets the index and working tree. Any changes to tracked files\\n   424→\\t// in the working tree are discarded.\\n   425→\\tHardReset\\n   426→\\t// MergeReset resets the index and updates the files in the working tree\\n   427→\\t// that are different between Commit and HEAD, but keeps those which are\\n   428→\\t// different between the index and working tree (i.e. which have changes\\n   429→\\t// which have not been added).\\n   430→\\t//\\n   431→\\t// If a file that is different between Commit and the index has unstaged\\n   432→\\t// changes, reset is aborted.\\n   433→\\tMergeReset\\n   434→\\t// SoftReset does not touch the index file or the working tree at all (but\\n   435→\\t// resets the head to <commit>, just like all modes do). This leaves all\\n   436→\\t// your changed files \\\"Changes to be committed\\\", as git status would put it.\\n   437→\\tSoftReset\\n   438→)\\n   439→\\n   440→// ResetOptions describes how a reset operation should be performed.\\n   441→type ResetOptions struct {\\n   442→\\t// Commit, if commit is present set the current branch head (HEAD) to it.\\n   443→\\tCommit plumbing.Hash\\n   444→\\t// Mode, form resets the current branch head to Commit and possibly updates\\n   445→\\t// the index (resetting it to the tree of Commit) and the working tree\\n   446→\\t// depending on Mode. If empty MixedReset is used.\\n   447→\\tMode ResetMode\\n   448→\\t// Files, if not empty will constrain the resetting the index to only files\\n   449→\\t// specified in this list.\\n   450→\\tFiles []string\\n   451→\\n   452→\\t// SparseDirs specifies which directories should be checked out.\\n   453→\\t// Directories not listed here will not appear in the worktree.\\n   454→\\tSparseDirs []string\\n   455→\\n   456→\\t// SkipSparseDirValidation will skip the validation for SparseDirs.\\n   457→\\tSkipSparseDirValidation bool\\n   458→}\\n   459→\\n   460→// Validate validates the fields and sets the default values.\\n   461→func (o *ResetOptions) Validate(r *Repository) error {\\n   462→\\tif o.Commit == plumbing.ZeroHash {\\n   463→\\t\\tref, err := r.Head()\\n   464→\\t\\tif err != nil {\\n   465→\\t\\t\\treturn err\\n   466→\\t\\t}\\n   467→\\n   468→\\t\\to.Commit = ref.Hash()\\n   469→\\t} else {\\n   470→\\t\\t_, err := r.CommitObject(o.Commit)\\n   471→\\t\\tif err != nil {\\n   472→\\t\\t\\treturn fmt.Errorf(\\\"invalid reset option: %w\\\", err)\\n   473→\\t\\t}\\n   474→\\t}\\n   475→\\n   476→\\treturn nil\\n   477→}\\n   478→\\n   479→// LogOrder represents the order in which commits are traversed during log operations.\\n   480→type LogOrder int8\\n   481→\\n   482→// Log traversal order options.\\n   483→const (\\n   484→\\t// LogOrderDefault uses depth-first search.\\n   485→\\tLogOrderDefault LogOrder = iota\\n   486→\\tLogOrderDFS\\n   487→\\tLogOrderDFSPost\\n   488→\\tLogOrderBSF\\n   489→\\tLogOrderCommitterTime\\n   490→\\tLogOrderDFSPostFirstParent\\n   491→)\\n   492→\\n   493→// LogOptions describes how a log action should be performed.\\n   494→type LogOptions struct {\\n   495→\\t// When the From option is set the log will only contain commits\\n   496→\\t// reachable from it. If this option is not set, HEAD will be used as\\n   497→\\t// the default From.\\n   498→\\tFrom plumbing.Hash\\n   499→\\n   500→\\t// When To is set the log will go down until it reaches to the commit with the\\n   501→\\t// specified hash. The default value for this field in nil\\n   502→\\tTo plumbing.Hash\\n   503→\\n   504→\\t// The default traversal algorithm is Depth-first search\\n   505→\\t// set Order=LogOrderCommitterTime for ordering by committer time (more compatible with `git log`)\\n   506→\\t// set Order=LogOrderBSF for Breadth-first search\\n   507→\\tOrder LogOrder\\n   508→\\n   509→\\t// Show only those commits in which the specified file was inserted/updated.\\n   510→\\t// It is equivalent to running `git log -- <file-name>`.\\n   511→\\t// this field is kept for compatibility, it can be replaced with PathFilter\\n   512→\\tFileName *string\\n   513→\\n   514→\\t// Filter commits based on the path of files that are updated\\n   515→\\t// takes file path as argument and should return true if the file is desired\\n   516→\\t// It can be used to implement `git log -- <path>`\\n   517→\\t// either <path> is a file path, or directory path, or a regexp of file/directory path\\n   518→\\tPathFilter func(string) bool\\n   519→\\n   520→\\t// Pretend as if all the refs in refs/, along with HEAD, are listed on the command line as <commit>.\\n   521→\\t// It is equivalent to running `git log --all`.\\n   522→\\t// If set on true, the From option will be ignored.\\n   523→\\tAll bool\\n   524→\\n   525→\\t// Show commits more recent than a specific date.\\n   526→\\t// It is equivalent to running `git log --since <date>` or `git log --after <date>`.\\n   527→\\tSince *time.Time\\n   528→\\n   529→\\t// Show commits older than a specific date.\\n   530→\\t// It is equivalent to running `git log --until <date>` or `git log --before <date>`.\\n   531→\\tUntil *time.Time\\n   532→}\\n   533→\\n   534→// ErrMissingAuthor is returned when the author field is required but not provided.\\n   535→var ErrMissingAuthor = errors.New(\\\"author field is required\\\")\\n   536→\\n   537→// AddOptions describes how an `add` operation should be performed\\n   538→type AddOptions struct {\\n   539→\\t// All equivalent to `git add -A`, update the index not only where the\\n   540→\\t// working tree has a file matching `Path` but also where the index already\\n   541→\\t// has an entry. This adds, modifies, and removes index entries to match the\\n   542→\\t// working tree.  If no `Path` nor `Glob` is given when `All` option is\\n   543→\\t// used, all files in the entire working tree are updated.\\n   544→\\tAll bool\\n   545→\\t// Path is the exact filepath to the file or directory to be added.\\n   546→\\tPath string\\n   547→\\t// Glob adds all paths, matching pattern, to the index. If pattern matches a\\n   548→\\t// directory path, all directory contents are added to the index recursively.\\n   549→\\tGlob string\\n   550→\\t// SkipStatus adds the path with no status check. This option is relevant only\\n   551→\\t// when the `Path` option is specified and does not apply when the `All` option is used.\\n   552→\\t// Notice that when passing an ignored path it will be added anyway.\\n   553→\\t// When true it can speed up adding files to the worktree in very large repositories.\\n   554→\\tSkipStatus bool\\n   555→}\\n   556→\\n   557→// Validate validates the fields and sets the default values.\\n   558→func (o *AddOptions) Validate(_ *Repository) error {\\n   559→\\tif o.Path != \\\"\\\" && o.Glob != \\\"\\\" {\\n   560→\\t\\treturn fmt.Errorf(\\\"fields Path and Glob are mutual exclusive\\\")\\n   561→\\t}\\n   562→\\n   563→\\treturn nil\\n   564→}\\n   565→\\n   566→// CommitOptions describes how a commit operation should be performed.\\n   567→type CommitOptions struct {\\n   568→\\t// All automatically stage files that have been modified and deleted, but\\n   569→\\t// new files you have not told Git about are not affected.\\n   570→\\tAll bool\\n   571→\\t// AllowEmptyCommits enable empty commits to be created. An empty commit\\n   572→\\t// is when no changes to the tree were made, but a new commit message is\\n   573→\\t// provided. The default behavior is false, which results in ErrEmptyCommit.\\n   574→\\tAllowEmptyCommits bool\\n   575→\\t// Author is the author's signature of the commit. If Author is empty the\\n   576→\\t// Name and Email is read from the config, and time.Now it's used as When.\\n   577→\\tAuthor *object.Signature\\n   578→\\t// Committer is the committer's signature of the commit. If Committer is\\n   579→\\t// nil the Author signature is used.\\n   580→\\tCommitter *object.Signature\\n   581→\\t// Parents are the parents commits for the new commit, by default when\\n   582→\\t// len(Parents) is zero, the hash of HEAD reference is used.\\n   583→\\tParents []plumbing.Hash\\n   584→\\t// Signer denotes a cryptographic signer to sign the commit with.\\n   585→\\t// A nil value here means the commit will not be signed.\\n   586→\\tSigner Signer\\n   587→\\t// Amend will create a new commit object and replace the commit that HEAD currently\\n   588→\\t// points to. Cannot be used with All nor Parents.\\n   589→\\tAmend bool\\n   590→}\\n   591→\\n   592→// Validate validates the fields and sets the default values.\\n   593→func (o *CommitOptions) Validate(r *Repository) error {\\n   594→\\tif o.All && o.Amend {\\n   595→\\t\\treturn errors.New(\\\"all and amend cannot be used together\\\")\\n   596→\\t}\\n   597→\\n   598→\\tif o.Amend && len(o.Parents) > 0 {\\n   599→\\t\\treturn errors.New(\\\"parents cannot be used with amend\\\")\\n   600→\\t}\\n   601→\\n   602→\\tif o.Author == nil {\\n   603→\\t\\tif err := o.loadConfigAuthorAndCommitter(r); err != nil {\\n   604→\\t\\t\\treturn err\\n   605→\\t\\t}\\n   606→\\t}\\n   607→\\n   608→\\tif o.Committer == nil {\\n   609→\\t\\to.Committer = o.Author\\n   610→\\t}\\n   611→\\n   612→\\tif len(o.Parents) == 0 {\\n   613→\\t\\thead, err := r.Head()\\n   614→\\t\\tif err != nil && !errors.Is(err, plumbing.ErrReferenceNotFound) {\\n   615→\\t\\t\\treturn err\\n   616→\\t\\t}\\n   617→\\n   618→\\t\\tif head != nil {\\n   619→\\t\\t\\to.Parents = []plumbing.Hash{head.Hash()}\\n   620→\\t\\t}\\n   621→\\t}\\n   622→\\n   623→\\treturn nil\\n   624→}\\n   625→\\n   626→func (o *CommitOptions) loadConfigAuthorAndCommitter(r *Repository) error {\\n   627→\\tcfg, err := r.ConfigScoped(config.SystemScope)\\n   628→\\tif err != nil {\\n   629→\\t\\treturn err\\n   630→\\t}\\n   631→\\n   632→\\tif o.Author == nil && cfg.Author.Email != \\\"\\\" && cfg.Author.Name != \\\"\\\" {\\n   633→\\t\\to.Author = &object.Signature{\\n   634→\\t\\t\\tName:  cfg.Author.Name,\\n   635→\\t\\t\\tEmail: cfg.Author.Email,\\n   636→\\t\\t\\tWhen:  time.Now(),\\n   637→\\t\\t}\\n   638→\\t}\\n   639→\\n   640→\\tif o.Committer == nil && cfg.Committer.Email != \\\"\\\" && cfg.Committer.Name != \\\"\\\" {\\n   641→\\t\\to.Committer = &object.Signature{\\n   642→\\t\\t\\tName:  cfg.Committer.Name,\\n   643→\\t\\t\\tEmail: cfg.Committer.Email,\\n   644→\\t\\t\\tWhen:  time.Now(),\\n   645→\\t\\t}\\n   646→\\t}\\n   647→\\n   648→\\tif o.Author == nil && cfg.User.Email != \\\"\\\" && cfg.User.Name != \\\"\\\" {\\n   649→\\t\\to.Author = &object.Signature{\\n   650→\\t\\t\\tName:  cfg.User.Name,\\n   651→\\t\\t\\tEmail: cfg.User.Email,\\n   652→\\t\\t\\tWhen:  time.Now(),\\n   653→\\t\\t}\\n   654→\\t}\\n   655→\\n   656→\\tif o.Author == nil {\\n   657→\\t\\treturn ErrMissingAuthor\\n   658→\\t}\\n   659→\\n   660→\\treturn nil\\n   661→}\\n   662→\\n   663→// Tag creation errors.\\n   664→var (\\n   665→\\tErrMissingName    = errors.New(\\\"name field is required\\\")\\n   666→\\tErrMissingTagger  = errors.New(\\\"tagger field is required\\\")\\n   667→\\tErrMissingMessage = errors.New(\\\"message field is required\\\")\\n   668→)\\n   669→\\n   670→// CreateTagOptions describes how a tag object should be created.\\n   671→type CreateTagOptions struct {\\n   672→\\t// Tagger defines the signature of the tag creator. If Tagger is empty the\\n   673→\\t// Name and Email is read from the config, and time.Now it's used as When.\\n   674→\\tTagger *object.Signature\\n   675→\\t// Message defines the annotation of the tag. It is canonicalized during\\n   676→\\t// validation into the format expected by git - no leading whitespace and\\n   677→\\t// ending in a newline.\\n   678→\\tMessage string\\n   679→\\t// SignKey denotes a key to sign the tag with. A nil value here means the tag\\n   680→\\t// will not be signed. The private key must be present and already decrypted.\\n   681→\\tSignKey *openpgp.Entity\\n   682→}\\n   683→\\n   684→// Validate validates the fields and sets the default values.\\n   685→func (o *CreateTagOptions) Validate(r *Repository, _ plumbing.Hash) error {\\n   686→\\tif o.Tagger == nil {\\n   687→\\t\\tif err := o.loadConfigTagger(r); err != nil {\\n   688→\\t\\t\\treturn err\\n   689→\\t\\t}\\n   690→\\t}\\n   691→\\n   692→\\tif o.Message == \\\"\\\" {\\n   693→\\t\\treturn ErrMissingMessage\\n   694→\\t}\\n   695→\\n   696→\\t// Canonicalize the message into the expected message format.\\n   697→\\to.Message = strings.TrimSpace(o.Message) + \\\"\\\\n\\\"\\n   698→\\n   699→\\treturn nil\\n   700→}\\n   701→\\n   702→func (o *CreateTagOptions) loadConfigTagger(r *Repository) error {\\n   703→\\tcfg, err := r.ConfigScoped(config.SystemScope)\\n   704→\\tif err != nil {\\n   705→\\t\\treturn err\\n   706→\\t}\\n   707→\\n   708→\\tif o.Tagger == nil && cfg.Au