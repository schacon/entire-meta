t returns ErrObjNotFound if the object doesn't exist.\\n    // If the object does exist, it returns nil.\\n    HasEncodedObject(plumbing.Hash) error\\n    // ... other methods\\n}\\n```\\n\\n**Filesystem Storage Implementation** (storage/filesystem/object.go, lines 200-224):\\n\\n```go\\nfunc (s *ObjectStorage) HasEncodedObject(h plumbing.Hash) (err error) {\\n    // Check unpacked objects first\\n    f, err := s.dir.Object(h)                          // Try loose object\\n    if err != nil {\\n        if !os.IsNotExist(err) {\\n            return err\\n        }\\n        // Fall through to check packed objects\\n    } else {\\n        defer ioutil.CheckClose(f, &err)\\n        return nil                                      // Found loose object\\n    }\\n\\n    // Check packed objects (requires index)\\n    if err := s.requireIndex(); err != nil {\\n        return err\\n    }\\n    _, _, offset := s.findObjectInPackfile(h)          // Find in packfile index\\n    if offset == -1 {\\n        return plumbing.ErrObjectNotFound\\n    }\\n    return nil\\n}\\n```\\n\\n**Behavior:**\\n- **Checks loose objects first** (unpacked, `.git/objects/xx/...`)\\n- **Falls back to packfiles** (via index search, no full read)\\n- **Also checks alternates** (shared object repositories via `.git/objects/info/alternates`)\\n\\n---\\n\\n### 4. **EncodedObject API** (plumbing/storer/object.go, lines 27-35)\\n\\n**Interface Definition:**\\n```go\\ntype EncodedObjectStorer interface {\\n    // EncodedObject gets an object by hash with the given plumbing.ObjectType.\\n    // Returns (nil, plumbing.ErrObjectNotFound) if object doesn't exist with both hash and type.\\n    //\\n    // Valid plumbing.ObjectType values: CommitObject, BlobObject, TagObject, TreeObject, AnyObject\\n    // If plumbing.AnyObject is given, object is looked up regardless of type.\\n    EncodedObject(plumbing.ObjectType, plumbing.Hash) (plumbing.EncodedObject, error)\\n}\\n```\\n\\n**Filesystem Implementation** (storage/filesystem/object.go, lines 364-409):\\n\\n```go\\nfunc (s *ObjectStorage) EncodedObject(t plumbing.ObjectType, h plumbing.Hash) (plumbing.EncodedObject, error) {\\n    // Strategy: try packfile first if index exists, else try loose objects first\\n    if s.index != nil {\\n        obj, err = s.getFromPackfile(h, false)         // Try packfile (no delta resolution)\\n        if errors.Is(err, plumbing.ErrObjectNotFound) {\\n            obj, err = s.getFromUnpacked(h)\\n        }\\n    } else {\\n        obj, err = s.getFromUnpacked(h)                // Try loose objects\\n        if errors.Is(err, plumbing.ErrObjectNotFound) {\\n            obj, err = s.getFromPackfile(h, false)\\n        }\\n    }\\n\\n    // Check alternates for shared object repositories\\n    if errors.Is(err, plumbing.ErrObjectNotFound) {\\n        dotgits, e := s.dir.Alternates()\\n        if e == nil {\\n            for _, dg := range dotgits {\\n                o := NewObjectStorage(dg, s.objectCache)\\n                enobj, enerr := o.EncodedObject(t, h)\\n                if enerr != nil {\\n                    continue\\n                }\\n                return enobj, nil\\n            }\\n        }\\n    }\\n\\n    if err != nil {\\n        return nil, err\\n    }\\n\\n    // Type validation\\n    if obj == nil || (plumbing.AnyObject != t && obj.Type() != t) {\\n        return nil, plumbing.ErrObjectNotFound\\n    }\\n\\n    return obj, nil\\n}\\n```\\n\\n---\\n\\n### 5. **How Fetch Works** (remote.go, lines 350-502)\\n\\n**High-level flow:**\\n```\\nRemote.Fetch(o *FetchOptions)\\n  └─> Remote.FetchContext(ctx, o)  [wrapper with context]\\n      └─> Remote.fetch(ctx, o) [main implementation]\\n          ├─> Validate options\\n          ├─> Create transport connection\\n          ├─> Handshake with server (UploadPackService)\\n          ├─> Get remote refs via conn.GetRemoteRefs()\\n          ├─> Calculate refs to fetch based on RefSpecs and Tags\\n          ├─> Build FetchRequest 