his branch (not on main)\\n    38→3. Restores the session log if it doesn't exist locally\\n    39→4. Shows the command to resume the session\\n    40→\\n    41→If the branch doesn't exist locally but exists on origin, you'll be prompted\\n    42→to fetch it.\\n    43→\\n    44→If newer commits without checkpoints exist on the branch (e.g., after merging main\\n    45→or cherry-picking from elsewhere), this operation will reset your Git status to the\\n    46→most recent commit with a checkpoint.  You'll be prompted to confirm resuming in this case.`,\\n    47→\\t\\tArgs: cobra.ExactArgs(1),\\n    48→\\t\\tRunE: func(cmd *cobra.Command, args []string) error {\\n    49→\\t\\t\\tif checkDisabledGuard(cmd.Context(), cmd.OutOrStdout()) {\\n    50→\\t\\t\\t\\treturn nil\\n    51→\\t\\t\\t}\\n    52→\\t\\t\\treturn runResume(cmd.Context(), args[0], force)\\n    53→\\t\\t},\\n    54→\\t}\\n    55→\\n    56→\\tcmd.Flags().BoolVarP(&force, \\\"force\\\", \\\"f\\\", false, \\\"Resume from older checkpoint without confirmation\\\")\\n    57→\\n    58→\\treturn cmd\\n    59→}\\n    60→\\n    61→func runResume(ctx context.Context, branchName string, force bool) error {\\n    62→\\t// Check if we're already on this branch\\n    63→\\tcurrentBranch, err := GetCurrentBranch(ctx)\\n    64→\\tif err == nil && currentBranch == branchName {\\n    65→\\t\\t// Already on the branch, skip checkout\\n    66→\\t\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n    67→\\t}\\n    68→\\n    69→\\t// Check if branch exists locally\\n    70→\\texists, err := BranchExistsLocally(ctx, branchName)\\n    71→\\tif err != nil {\\n    72→\\t\\treturn fmt.Errorf(\\\"failed to check branch: %w\\\", err)\\n    73→\\t}\\n    74→\\n    75→\\tif !exists {\\n    76→\\t\\t// Branch doesn't exist locally, check if it exists on remote\\n    77→\\t\\tremoteExists, err := BranchExistsOnRemote(ctx, branchName)\\n    78→\\t\\tif err != nil {\\n    79→\\t\\t\\treturn fmt.Errorf(\\\"failed to check remote branch: %w\\\", err)\\n    80→\\t\\t}\\n    81→\\n    82→\\t\\tif !remoteExists {\\n    83→\\t\\t\\treturn fmt.Errorf(\\\"branch '%s' not found locally or on origin\\\", branchName)\\n    84→\\t\\t}\\n    85→\\n    86→\\t\\t// Ask user if they want to fetch from remote\\n    87→\\t\\tshouldFetch, err := promptFetchFromRemote(branchName)\\n    88→\\t\\tif err != nil {\\n    89→\\t\\t\\treturn err\\n    90→\\t\\t}\\n    91→\\t\\tif !shouldFetch {\\n    92→\\t\\t\\treturn nil\\n    93→\\t\\t}\\n    94→\\n    95→\\t\\t// Fetch and checkout the remote branch\\n    96→\\t\\tfmt.Fprintf(os.Stderr, \\\"Fetching branch '%s' from origin...\\\\n\\\", branchName)\\n    97→\\t\\tif err := FetchAndCheckoutRemoteBranch(ctx, branchName); err != nil {\\n    98→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n    99→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   100→\\t\\t}\\n   101→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   102→\\t} else {\\n   103→\\t\\t// Branch exists locally, check for uncommitted changes before checkout\\n   104→\\t\\thasChanges, err := HasUncommittedChanges(ctx)\\n   105→\\t\\tif err != nil {\\n   106→\\t\\t\\treturn fmt.Errorf(\\\"failed to check for uncommitted changes: %w\\\", err)\\n   107→\\t\\t}\\n   108→\\t\\tif hasChanges {\\n   109→\\t\\t\\treturn errors.New(\\\"you have uncommitted changes. Please commit or stash them first\\\")\\n   110→\\t\\t}\\n   111→\\n   112→\\t\\t// Checkout the branch\\n   113→\\t\\tif err := CheckoutBranch(ctx, branchName); err != nil {\\n   114→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n   115→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   116→\\t\\t}\\n   117→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   118→\\t}\\n   119→\\n   120→\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n   121→}\\n   122→\\n   123→func resumeFromCurrentBranch(ctx context.Context, branchName string, force bool) error {\\n   124→\\trepo, err := openRepository(ctx)\\n   125→\\tif err != nil {\\n   126→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   127→\\t}\\n   128→\\n   129→\\t// Find a commit with an Entire-Checkpoint trailer, looking at branch-only commits\\n   130→\\tresult, err := findBranchCheckpoints(repo, branchName)\\n   131→\\tif err != nil {\\n   132→\\t\\treturn err\\n   133→\\t}\\n   134→\\tif len(result.checkpointIDs) == 0 {\\n   135→\\t\\tfmt.Fprintf(os.Stderr, \\\"No Entire checkpoint found on branch '%s'\\\\n\\\", branchName)\\n   136→\\t\\treturn nil\\n   137→\\t}\\n   138→\\n   139→\\t// If there are newer commits without checkpoints, ask for confirmation.\\n   140→\\t// Merge commits (e.g., from merging main) don't count as \\\"work\\\" and are skipped silently.\\n   141→\\tif result.newerCommitsExist && !force {\\n   142→\\t\\tfmt.Fprintf(os.Stderr, \\\"Found checkpoint in an older commit.\\\\n\\\")\\n   143→\\t\\tfmt.Fprintf(os.Stderr, \\\"There are %d newer commit(s) on this branch without checkpoints.\\\\n\\\", result.newerCommitCount)\\n   144→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint from: %s %s\\\\n\\\\n\\\", result.commitHash[:7], firstLine(result.commitMessage))\\n   145→\\n   146→\\t\\tshouldResume, err := promptResumeFromOlderCheckpoint()\\n   147→\\t\\tif err != nil {\\n   148→\\t\\t\\treturn err\\n   149→\\t\\t}\\n   150→\\t\\tif !shouldResume {\\n   151→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled.\\\\n\\\")\\n   152→\\t\\t\\treturn nil\\n   153→\\t\\t}\\n   154→\\t}\\n   155→\\n   156→\\tcheckpointID := result.checkpointIDs[0]\\n   157→\\n   158→\\t// Multiple checkpoints (squash merge): resolve latest by CreatedAt timestamp.\\n   159→\\t// resolveLatestCheckpoint also returns the metadata tree so we can reuse it\\n   160→\\t// for the ReadCheckpointMetadata call below without a redundant lookup.\\n   161→\\tvar metadataTree *object.Tree\\n   162→\\tif len(result.checkpointIDs) > 1 {\\n   163→\\t\\tlatest, tree, err := resolveLatestCheckpoint(ctx, repo, result.checkpointIDs)\\n   164→\\t\\tif err != nil {\\n   165→\\t\\t\\t// No metadata available — nothing to resume from\\n   166→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Found %d checkpoints for commit %s but metadata is not available\\\\n\\\",\\n   167→\\t\\t\\t\\tlen(result.checkpointIDs), result.commitHash[:7])\\n   168→\\t\\t\\treturn checkRemoteMetadata(ctx, repo, result.checkpointIDs[0])\\n   169→\\t\\t}\\n   170→\\t\\tskipped := len(result.checkpointIDs) - 1\\n   171→\\t\\tfmt.Fprintf(os.Stderr, \\\"Found %d checkpoints for commit %s, resuming from the latest (%d older checkpoints skipped)\\\\n\\\",\\n   172→\\t\\t\\tlen(result.checkpointIDs), result.commitHash[:7], skipped)\\n   173→\\t\\tcheckpointID = latest\\n   174→\\t\\tmetadataTree = tree\\n   175→\\t}\\n   176→\\n   177→\\t// Get metadata branch tree for lookups (reuse from resolveLatestCheckpoint if available)\\n   178→\\tif metadataTree == nil {\\n   179→\\t\\tvar err error\\n   180→\\t\\tmetadataTree, err = strategy.GetMetadataBranchTree(repo)\\n   181→\\t\\tif err != nil {\\n   182→\\t\\t\\t// No local metadata branch, check if remote has it\\n   183→\\t\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   184→\\t\\t}\\n   185→\\t}\\n   186→\\n   187→\\t// Look up metadata from sharded path\\n   188→\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n   189→\\tif err != nil {\\n   190→\\t\\t// Checkpoint exists in commit but no local metadata - check remote\\n   191→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   192→\\t}\\n   193→\\n   194→\\treturn resumeSession(ctx, metadata, force)\\n   195→}\\n   196→\\n   197→// resolveLatestCheckpoint reads metadata for each checkpoint ID and returns\\n   198→// the one with the latest CreatedAt, along with the metadata tree for reuse.\\n   199→// It tries the local metadata branch first, then fetches from remote, then\\n   200→// falls back to the remote tree directly.\\n   201→func resolveLatestCheckpoint(ctx context.Context, repo *git.Repository, checkpointIDs []id.CheckpointID) (id.CheckpointID, *object.Tree, error) {\\n   202→\\tmetadataTree, err := getMetadataTree(ctx, repo)\\n   203→\\tif err != nil {\\n   204→\\t\\treturn id.EmptyCheckpointID, nil, err\\n   205→\\t}\\n   206→\\tinfoMap := make(map[id.CheckpointID]strategy.CheckpointInfo, len(checkpointIDs))\\n   207→\\tfor _, cpID := range checkpointIDs {\\n   208→\\t\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, cpID.Path())\\n   209→\\t\\tif err != nil {\\n   210→\\t\\t\\tcontinue\\n   211→\\t\\t}\\n   212→\\t\\tinfoMap[cpID] = *metadata\\n   213→\\t}\\n   214→\\tlatest, found := strategy.ResolveLatestCheckpointFromMap(checkpointIDs, infoMap)\\n   215→\\tif !found {\\n   216→\\t\\treturn id.EmptyCheckpointID, nil, errors.New(\\\"no checkpoint metadata found\\\")\\n   217→\\t}\\n   218→\\treturn latest.CheckpointID, metadataTree, nil\\n   219→}\\n   220→\\n   221→// getMetadataTree returns the metadata branch tree, trying local first,\\n   222→// then fetching from remote, then falling back to the remote tree directly.\\n   223→func getMetadataTree(ctx context.Context, repo *git.Repository) (*object.Tree, error) {\\n   224→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   225→\\tif err == nil {\\n   226→\\t\\treturn metadataTree, nil\\n   227→\\t}\\n   228→\\n   229→\\t// Try fetching from remote\\n   230→\\tif fetchErr := FetchMetadataBranch(ctx); fetchErr == nil {\\n   231→\\t\\tmetadataTree, err = strategy.GetMetadataBranchTree(repo)\\n   232→\\t\\tif err == nil {\\n   233→\\t\\t\\treturn metadataTree, nil\\n   234→\\t\\t}\\n   235→\\t}\\n   236→\\n   237→\\t// Try remote tree directly\\n   238→\\tremoteTree, remoteErr := strategy.GetRemoteMetadataBranchTree(repo)\\n   239→\\tif remoteErr != nil {\\n   240→\\t\\treturn nil, fmt.Errorf(\\\"metadata branch not available: %w\\\", remoteErr)\\n   241→\\t}\\n   242→\\treturn remoteTree, nil\\n   243→}\\n   244→\\n   245→// branchCheckpointsResult contains the result of searching for checkpoints on a branch.\\n   246→type branchCheckpointsResult struct {\\n   247→\\tcheckpointIDs     []id.CheckpointID\\n   248→\\tcommitHash        string\\n   249→\\tcommitMessage     string\\n   250→\\tnewerCommitsExist bool // true if there are branch-only commits (not merge commits) without checkpoints\\n   251→\\tnewerCommitCount  int  // count of branch-only commits without checkpoints\\n   252→}\\n   253→\\n   254→// findBranchCheckpoints finds the most recent commit with an Entire-Checkpoint trailer\\n   255→// among commits that are unique to this branch (not reachable from the default branch).\\n   256→// This handles the case where main has been merged into the feature branch.\\n   257→func findBranchCheckpoints(repo *git.Repository, branchName string) (*branchCheckpointsResult, error) {\\n   258→\\tresult := &branchCheckpointsResult{}\\n   259→\\n   260→\\t// Get HEAD commit\\n   261→\\thead, err := repo.Head()\\n   262→\\tif err != nil {\\n   263→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   264→\\t}\\n   265→\\n   266→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   267→\\tif err != nil {\\n   268→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   269→\\t}\\n   270→\\n   271→\\t// First, check if HEAD itself has a checkpoint (most common case)\\n   272→\\tif cpIDs := trailers.ParseAllCheckpoints(headCommit.Message); len(cpIDs) > 0 {\\n   273→\\t\\tresult.checkpointIDs = cpIDs\\n   274→\\t\\tresult.commitHash = head.Hash().String()\\n   275→\\t\\tresult.commitMessage = headCommit.Message\\n   276→\\t\\tresult.newerCommitsExist = false\\n   277→\\t\\treturn result, nil\\n   278→\\t}\\n   279→\\n   280→\\t// HEAD doesn't have a checkpoint - find branch-only commits\\n   281→\\t// Get the default branch name\\n   282→\\tdefaultBranch := getDefaultBranchFromRemote(repo)\\n   283→\\tif defaultBranch == \\\"\\\" {\\n   284→\\t\\t// Fallback: try common names\\n   285→\\t\\tfor _, name := range []string{\\\"main\\\", \\\"master\\\"} {\\n   286→\\t\\t\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(name), true); err == nil {\\n   287→\\t\\t\\t\\tdefaultBranch = name\\n   288→\\t\\t\\t\\tbreak\\n   289→\\t\\t\\t}\\n   290→\\t\\t}\\n   291→\\t}\\n   292→\\n   293→\\t// If we can't find a default branch, or we're on it, just walk all commits\\n   294→\\tif defaultBranch == \\\"\\\" || defaultBranch == branchName {\\n   295→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil\\n   296→\\t}\\n   297→\\n   298→\\t// Get the default branch reference\\n   299→\\tdefaultRef, err := repo.Reference(plumbing.NewBranchReferenceName(defaultBranch), true)\\n   300→\\tif err != nil {\\n   301→\\t\\t// Default branch doesn't exist locally, fall back to walking all commits\\n   302→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   303→\\t}\\n   304→\\n   305→\\tdefaultCommit, err := repo.CommitObject(defaultRef.Hash())\\n   306→\\tif err != nil {\\n   307→\\t\\t// Can't get default commit, fall back to walking all commits\\n   308→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   309→\\t}\\n   310→\\n   311→\\t// Find merge base\\n   312→\\tmergeBase, err := headCommit.MergeBase(defaultCommit)\\n   313→\\tif err != nil || len(mergeBase) == 0 {\\n   314→\\t\\t// No common ancestor, fall back to walking all commits\\n   315→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   316→\\t}\\n   317→\\n   318→\\t// Walk from HEAD to merge base, looking for checkpoint\\n   319→\\treturn findCheckpointInHistory(headCommit, &mergeBase[0].Hash), nil\\n   320→}\\n   321→\\n   322→// findCheckpointInHistory walks commit history from start looking for a checkpoint trailer.\\n   323→// If stopAt is provided, stops when reaching that commit (exclusive).\\n   324→// Returns the first checkpoint found and info about commits between HEAD and the checkpoint.\\n   325→// It distinguishes between merge commits (bringing in other branches) and regular commits\\n   326→// (actual branch work) to avoid false warnings after merging main.\\n   327→func findCheckpointInHistory(start *object.Commit, stopAt *plumbing.Hash) *branchCheckpointsResult {\\n   328→\\tresult := &branchCheckpointsResult{}\\n   329→\\tbranchWorkCommits := 0 // Regular commits without checkpoints (actual work)\\n   330→\\tconst maxCommits = 100 // Limit search depth\\n   331→\\ttotalChecked := 0\\n   332→\\n   333→\\tcurrent := start\\n   334→\\tfor current != nil && totalChecked < maxCommits {\\n   335→\\t\\t// Stop if we've reached the boundary\\n   336→\\t\\tif stopAt != nil && current.Hash == *stopAt {\\n   337→\\t\\t\\tbreak\\n   338→\\t\\t}\\n   339→\\n   340→\\t\\t// Check for checkpoint trailer\\n   341→\\t\\tif cpIDs := trailers.ParseAllCheckpoints(current.Message); len(cpIDs) > 0 {\\n   342→\\t\\t\\tresult.checkpointIDs = cpIDs\\n   343→\\t\\t\\tresult.commitHash = current.Hash.String()\\n   344→\\t\\t\\tresult.commitMessage = current.Message\\n   345→\\t\\t\\t// Only warn about branch work commits, not merge commits\\n   346→\\t\\t\\tresult.newerCommitsExist = branchWorkCommits > 0\\n   347→\\t\\t\\tresult.newerCommitCount = branchWorkCommits\\n   348→\\t\\t\\treturn result\\n   349→\\t\\t}\\n   350→\\n   351→\\t\\t// Only count regular commits (not merge commits) as \\\"branch work\\\"\\n   352→\\t\\tif current.NumParents() <= 1 {\\n   353→\\t\\t\\tbranchWorkCommits++\\n   354→\\t\\t}\\n   355→\\n   356→\\t\\ttotalChecked++\\n   357→\\n   358→\\t\\t// Move to parent (first parent for merge commits - follows the main line)\\n   359→\\t\\tif current.NumParents() == 0 {\\n   360→\\t\\t\\tbreak\\n   361→\\t\\t}\\n   362→\\t\\tparent, err := current.Parent(0)\\n   363→\\t\\tif err != nil {\\n   364→\\t\\t\\t// Can't get parent, treat as end of history\\n   365→\\t\\t\\tbreak\\n   366→\\t\\t}\\n   367→\\t\\tcurrent = parent\\n   368→\\t}\\n   369→\\n   370→\\t// No checkpoint found\\n   371→\\treturn result\\n   372→}\\n   373→\\n   374→// promptResumeFromOlderCheckpoint asks the user if they want to resume from an older checkpoint.\\n   375→func promptResumeFromOlderCheckpoint() (bool, error) {\\n   376→\\tvar confirmed bool\\n   377→\\n   378→\\tform := NewAccessibleForm(\\n   379→\\t\\thuh.NewGroup(\\n   380→\\t\\t\\thuh.NewConfirm().\\n   381→\\t\\t\\t\\tTitle(\\\"Resume from this older checkpoint?\\\").\\n   382→\\t\\t\\t\\tValue(&confirmed),\\n   383→\\t\\t),\\n   384→\\t)\\n   385→\\n   386→\\tif err := form.Run(); err != nil {\\n   387→\\t\\tif errors.Is(err, huh.ErrUserAborted) {\\n   388→\\t\\t\\treturn false, nil\\n   389→\\t\\t}\\n   390→\\t\\treturn false, fmt.Errorf(\\\"failed to get confirmation: %w\\\", err)\\n   391→\\t}\\n   392→\\n   393→\\treturn confirmed, nil\\n   394→}\\n   395→\\n   396→// checkRemoteMetadata checks if checkpoint metadata exists on origin/entire/checkpoints/v1\\n   397→// and automatically fetches it if available.\\n   398→func checkRemoteMetadata(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID) error {\\n   399→\\t// Try to get remote metadata branch tree\\n   400→\\tremoteTree, err := strategy.GetRemoteMetadataBranchTree(repo)\\n   401→\\tif err != nil {\\n   402→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   403→\\t\\tfmt.Fprintf(os.Stderr, \\\"The entire/checkpoints/v1 branch may not exist locally or on the remote.\\\\n\\\")\\n   404→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   405→\\t}\\n   406→\\n   407→\\t// Check if the checkpoint exists on the remote\\n   408→\\tmetadata, err := strategy.ReadCheckpointMetadata(remoteTree, checkpointID.Path())\\n   409→\\tif err != nil {\\n   410→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   411→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   412→\\t}\\n   413→\\n   414→\\t// Metadata exists on remote but not locally - fetch it automatically\\n   415→\\tfmt.Fprintf(os.Stderr, \\\"Fetching session metadata from origin...\\\\n\\\")\\n   416→\\tif err := FetchMetadataBranch(ctx); err != nil {\\n   417→\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to fetch metadata: %v\\\\n\\\", err)\\n   418→\\t\\tfmt.Fprintf(os.Stderr, \\\"You can try manually: git fetch origin entire/checkpoints/v1:entire/checkpoints/v1\\\\n\\\")\\n   419→\\t\\treturn NewSilentError(errors.New(\\\"failed to fetch metadata\\\"))\\n   420→\\t}\\n   421→\\n   422→\\t// Now resume the session with the fetched metadata\\n   423→\\treturn resumeSession(ctx, metadata, false)\\n   424→}\\n   425→\\n   426→// resumeSession restores and displays the resume command for a specific session.\\n   427→// For multi-session checkpoints, restores ALL sessions and shows commands for each.\\n   428→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   429→// The caller must provide the already-resolved checkpoint metadata to avoid redundant lookups\\n   430→// and to support both local and remote metadata trees.\\n   431→func resumeSession(ctx context.Context, metadata *strategy.CheckpointInfo, force bool) error {\\n   432→\\tcheckpointID := metadata.CheckpointID\\n   433→\\tsessionID := metadata.SessionID\\n   434→\\n   435→\\t// Resolve agent from checkpoint metadata (same as rewind)\\n   436→\\tag, err := strategy.ResolveAgentForRewind(metadata.Agent)\\n   437→\\tif err != nil {\\n   438→\\t\\treturn fmt.Errorf(\\\"failed to resolve agent: %w\\\", err)\\n   439→\\t}\\n   440→\\n   441→\\t// Initialize logging context with agent\\n   442→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"resume\\\"), ag.Name())\\n   443→\\n   444→\\tlogging.Debug(logCtx, \\\"resume session started\\\",\\n   445→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   446→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   447→\\t)\\n   448→\\n   449→\\t// Get worktree root for session directory lookup\\n   450→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   451→\\tif err != nil {\\n   452→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   453→\\t}\\n   454→\\n   455→\\tsessionDir, err := ag.GetSessionDir(repoRoot)\\n   456→\\tif err != nil {\\n   457→\\t\\treturn fmt.Errorf(\\\"failed to determine session directory: %w\\\", err)\\n   458→\\t}\\n   459→\\n   460→\\t// Create directory if it doesn't exist\\n   461→\\tif err := os.MkdirAll(sessionDir, 0o700); err != nil {\\n   462→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   463→\\t}\\n   464→\\n   465→\\t// Get strategy and restore sessions using full checkpoint data\\n   466→\\tstrat := GetStrategy(ctx)\\n   467→\\n   468→\\t// Use RestoreLogsOnly via LogsOnlyRestorer interface for multi-session support\\n   469→\\t// Create a logs-only rewind point with Agent populated (same as rewind)\\n   470→\\tpoint := strategy.RewindPoint{\\n   471→\\t\\tIsLogsOnly:   true,\\n   472→\\t\\tCheckpointID: checkpointID,\\n   473→\\t\\tAgent:        metadata.Agent,\\n   474→\\t}\\n   475→\\n   476→\\tsessions, restoreErr := strat.RestoreLogsOnly(ctx, point, force)\\n   477→\\tif restoreErr != nil || len(sessions) == 0 {\\n   478→\\t\\t// Fall back to single-session restore (e.g., old checkpoints without agent metadata)\\n   479→\\t\\treturn resumeSingleSession(ctx, ag, sessionID, checkpointID, repoRoot, force)\\n   480→\\t}\\n   481→\\n   482→\\tlogging.Debug(logCtx, \\\"resume session completed\\\",\\n   483→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   484→\\t\\tslog.Int(\\\"session_count\\\", len(sessions)),\\n   485→\\t)\\n   486→\\n   487→\\treturn displayRestoredSessions(sessions)\\n   488→}\\n   489→\\n   490→// displayRestoredSessions sorts sessions by CreatedAt and prints resume commands.\\n   491→func displayRestoredSessions(sessions []strategy.RestoredSession) error {\\n   492→\\tsort.SliceStable(sessions, func(i, j int) bool {\\n   493→\\t\\treturn sessions[i].CreatedAt.Before(sessions[j].CreatedAt)\\n   494→\\t})\\n   495→\\n   496→\\tif len(sessions) > 1 {\\n   497→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nRestored %d sessions. To continue, run:\\\\n\\\", len(sessions))\\n   498→\\t} else if len(sessions) == 1 {\\n   499→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session: %s\\\\n\\\", sessions[0].SessionID)\\n   500→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   501→\\t}\\n   502→\\n   503→\\tfor i, sess := range sessions {\\n   504→\\t\\tsessionAgent, err := strategy.ResolveAgentForRewind(sess.Agent)\\n   505→\\t\\tif err != nil {\\n   506→\\t\\t\\treturn fmt.Errorf(\\\"failed to resolve agent for session %s: %w\\\", sess.SessionID, err)\\n   507→\\t\\t}\\n   508→\\t\\tcmd := sessionAgent.FormatResumeCommand(sess.SessionID)\\n   509→\\n   510→\\t\\tisLast := i == len(sessions)-1\\n   511→\\t\\tswitch {\\n   512→\\t\\tcase len(sessions) > 1 && isLast && sess.Prompt != \\\"\\\":\\n   513→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # %s (most recent)\\\\n\\\", cmd, sess.Prompt)\\n   514→\\t\\tcase len(sessions) > 1 && isLast:\\n   515→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # (most recent)\\\\n\\\", cmd)\\n   516→\\t\\tcase sess.Prompt != \\\"\\\":\\n   517→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # %s\\\\n\\\", cmd, sess.Prompt)\\n   518→\\t\\tdefault:\\n   519→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", cmd)\\n   520→\\t\\t}\\n   521→\\t}\\n   522→\\n   523→\\treturn nil\\n   524→}\\n   525→\\n   526→// resumeSingleSession restores a single session (fallback when multi-session restore fails).\\n   527→// Always overwrites existing session logs to ensure consistency with checkpoint state.\\n   528→// If force is false, prompts for confirmation when local log has newer timestamps.\\n   529→func resumeSingleSession(ctx context.Context, ag agent.Agent, sessionID string, checkpointID id.CheckpointID, repoRoot string, force bool) error {\\n   530→\\tsessionLogPath, err := resolveTranscriptPath(ctx, sessionID, ag)\\n   531→\\tif err != nil {\\n   532→\\t\\treturn fmt.Errorf(\\\"failed to resolve transcript path: %w\\\", err)\\n   533→\\t}\\n   534→\\n   535→\\tif checkpointID.IsEmpty() {\\n   536→\\t\\tlogging.Debug(ctx, \\\"resume session: empty checkpoint ID\\\",\\n   537→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   538→\\t\\t)\\n   539→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session '%s' found in commit trailer but session log not available\\\\n\\\", sessionID)\\n   540→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   541→\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", ag.FormatResumeCommand(sessionID))\\n   542→\\t\\treturn nil\\n   543→\\t}\\n   544→\\n   545→\\tlogContent, _, err := checkpoint.LookupSessionLog(ctx, checkpointID)\\n   546→\\tif err != nil {\\n   547→\\t\\tif errors.Is(err, checkpoint.ErrCheckpointNotFound) || errors.Is(err, checkpoint.ErrNoTranscript) {\\n   548→\\t\\t\\tlogging.Debug(ctx, \\\"resume session completed (no metadata)\\\",\\n   549→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   550→\\t\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   551→\\t\\t\\t)\\n   552→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Session '%s' found in commit trailer but session log not available\\\\n\\\", sessionID)\\n   553→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   554→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", ag.FormatResumeCommand(sessionID))\\n   555→\\t\\t\\treturn nil\\n   556→\\t\\t}\\n  