turn false, \\\"\\\", fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n    92→\\t}\\n    93→\\n    94→\\tif !head.Name().IsBranch() {\\n    95→\\t\\t// Detached HEAD - not on any branch\\n    96→\\t\\treturn false, \\\"\\\", nil\\n    97→\\t}\\n    98→\\n    99→\\tcurrentBranch := head.Name().Short()\\n   100→\\n   101→\\t// Try to get default branch from remote origin's HEAD\\n   102→\\tdefaultBranch := getDefaultBranchFromRemote(repo)\\n   103→\\n   104→\\t// If we couldn't determine from remote, use common defaults\\n   105→\\tif defaultBranch == \\\"\\\" {\\n   106→\\t\\t// Check if current branch is a common default name\\n   107→\\t\\tif currentBranch == \\\"main\\\" || currentBranch == \\\"master\\\" {\\n   108→\\t\\t\\treturn true, currentBranch, nil\\n   109→\\t\\t}\\n   110→\\t\\treturn false, currentBranch, nil\\n   111→\\t}\\n   112→\\n   113→\\treturn currentBranch == defaultBranch, currentBranch, nil\\n   114→}\\n   115→\\n   116→// getDefaultBranchFromRemote tries to determine the default branch from the origin remote.\\n   117→// Returns empty string if unable to determine.\\n   118→func getDefaultBranchFromRemote(repo *git.Repository) string {\\n   119→\\t// Try to get the symbolic reference for origin/HEAD\\n   120→\\tref, err := repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", \\\"HEAD\\\"), true)\\n   121→\\tif err == nil && ref != nil {\\n   122→\\t\\t// ref.Target() gives us something like \\\"refs/remotes/origin/main\\\"\\n   123→\\t\\ttarget := ref.Target().String()\\n   124→\\t\\tif strings.HasPrefix(target, \\\"refs/remotes/origin/\\\") {\\n   125→\\t\\t\\treturn strings.TrimPrefix(target, \\\"refs/remotes/origin/\\\")\\n   126→\\t\\t}\\n   127→\\t}\\n   128→\\n   129→\\t// Fallback: check if origin/main or origin/master exists\\n   130→\\tif _, err := repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", \\\"main\\\"), true); err == nil {\\n   131→\\t\\treturn \\\"main\\\"\\n   132→\\t}\\n   133→\\tif _, err := repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", \\\"master\\\"), true); err == nil {\\n   134→\\t\\treturn \\\"master\\\"\\n   135→\\t}\\n   136→\\n   137→\\treturn \\\"\\\"\\n   138→}\\n   139→\\n   140→// ShouldSkipOnDefaultBranch checks if we're on the default branch.\\n   141→// Returns (shouldSkip, branchName). If shouldSkip is true, the caller should\\n   142→// skip the operation to avoid polluting main/master history.\\n   143→// If the branch cannot be determined, returns (false, \\\"\\\") to allow the operation.\\n   144→func ShouldSkipOnDefaultBranch(ctx context.Context) (bool, string) {\\n   145→\\tisDefault, branchName, err := IsOnDefaultBranch(ctx)\\n   146→\\tif err != nil {\\n   147→\\t\\t// If we can't determine, allow the operation\\n   148→\\t\\treturn false, \\\"\\\"\\n   149→\\t}\\n   150→\\treturn isDefault, branchName\\n   151→}\\n   152→\\n   153→// GetCurrentBranch returns the name of the current branch.\\n   154→// Returns an error if in detached HEAD state or if not in a git repository.\\n   155→func GetCurrentBranch(ctx context.Context) (string, error) {\\n   156→\\trepo, err := openRepository(ctx)\\n   157→\\tif err != nil {\\n   158→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   159→\\t}\\n   160→\\n   161→\\thead, err := repo.Head()\\n   162→\\tif err != nil {\\n   163→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   164→\\t}\\n   165→\\n   166→\\tif !head.Name().IsBranch() {\\n   167→\\t\\treturn \\\"\\\", errors.New(\\\"not on a branch (detached HEAD)\\\")\\n   168→\\t}\\n   169→\\n   170→\\treturn head.Name().Short(), nil\\n   171→}\\n   172→\\n   173→// GetMergeBase finds the common ancestor (merge-base) between two branches.\\n   174→// Returns the hash of the merge-base commit.\\n   175→func GetMergeBase(ctx context.Context, branch1, branch2 string) (*plumbing.Hash, error) {\\n   176→\\trepo, err := openRepository(ctx)\\n   177→\\tif err != nil {\\n   178→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   179→\\t}\\n   180→\\n   181→\\t// Resolve branch references\\n   182→\\tref1, err := repo.Reference(plumbing.NewBranchReferenceName(branch1), true)\\n   183→\\tif err != nil {\\n   184→\\t\\treturn nil, fmt.Errorf(\\\"failed to resolve branch %s: %w\\\", branch1, err)\\n   185→\\t}\\n   186→\\n   187→\\tref2, err := repo.Reference(plumbing.NewBranchReferenceName(branch2), true)\\n   188→\\tif err != nil {\\n   189→\\t\\treturn nil, fmt.Errorf(\\\"failed to resolve branch %s: %w\\\", branch2, err)\\n   190→\\t}\\n   191→\\n   192→\\t// Get commit objects\\n   193→\\tcommit1, err := repo.CommitObject(ref1.Hash())\\n   194→\\tif err != nil {\\n   195→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit for %s: %w\\\", branch1, err)\\n   196→\\t}\\n   197→\\n   198→\\tcommit2, err := repo.CommitObject(ref2.Hash())\\n   199→\\tif err != nil {\\n   200→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit for %s: %w\\\", branch2, err)\\n   201→\\t}\\n   202→\\n   203→\\t// Find common ancestor\\n   204→\\tmergeBase, err := commit1.MergeBase(commit2)\\n   205→\\tif err != nil {\\n   206→\\t\\treturn nil, fmt.Errorf(\\\"failed to find merge base: %w\\\", err)\\n   207→\\t}\\n   208→\\n   209→\\tif len(mergeBase) == 0 {\\n   210→\\t\\treturn nil, errors.New(\\\"no common ancestor found\\\")\\n   211→\\t}\\n   212→\\n   213→\\thash := mergeBase[0].Hash\\n   214→\\treturn &hash, nil\\n   215→}\\n   216→\\n   217→// HasUncommittedChanges checks if there are any uncommitted changes in the repository.\\n   218→// This includes staged changes, unstaged changes, and untracked files.\\n   219→// Uses git CLI instead of go-git because go-git doesn't respect global gitignore\\n   220→// (core.excludesfile) which can cause false positives for globally ignored files.\\n   221→func HasUncommittedChanges(ctx context.Context) (bool, error) {\\n   222→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"status\\\", \\\"--porcelain\\\")\\n   223→\\toutput, err := cmd.Output()\\n   224→\\tif err != nil {\\n   225→\\t\\treturn false, fmt.Errorf(\\\"failed to get git status: %w\\\", err)\\n   226→\\t}\\n   227→\\n   228→\\t// If output is empty, there are no changes\\n   229→\\treturn len(strings.TrimSpace(string(output))) > 0, nil\\n   230→}\\n   231→\\n   232→// findNewUntrackedFiles finds files that are newly untracked (not in pre-existing list)\\n   233→func findNewUntrackedFiles(current, preExisting []string) []string {\\n   234→\\tpreExistingSet := make(map[string]bool)\\n   235→\\tfor _, file := range preExisting {\\n   236→\\t\\tpreExistingSet[file] = true\\n   237→\\t}\\n   238→\\n   239→\\tvar newFiles []string\\n   240→\\tfor _, file := range current {\\n   241→\\t\\tif !preExistingSet[file] {\\n   242→\\t\\t\\tnewFiles = append(newFiles, file)\\n   243→\\t\\t}\\n   244→\\t}\\n   245→\\treturn newFiles\\n   246→}\\n   247→\\n   248→// BranchExistsOnRemote checks if a branch exists on the origin remote.\\n   249→// Returns true if the branch is tracked on origin, false otherwise.\\n   250→func BranchExistsOnRemote(ctx context.Context, branchName string) (bool, error) {\\n   251→\\trepo, err := openRepository(ctx)\\n   252→\\tif err != nil {\\n   253→\\t\\treturn false, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   254→\\t}\\n   255→\\n   256→\\t// Check for remote reference: refs/remotes/origin/<branchName>\\n   257→\\t_, err = repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", branchName), true)\\n   258→\\tif err != nil {\\n   259→\\t\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n   260→\\t\\t\\treturn false, nil\\n   261→\\t\\t}\\n   262→\\t\\treturn false, fmt.Errorf(\\\"failed to check remote branch: %w\\\", err)\\n   263→\\t}\\n   264→\\n   265→\\treturn true, nil\\n   266→}\\n   267→\\n   268→// BranchExistsLocally checks if a local branch exists.\\n   269→func BranchExistsLocally(ctx context.Context, branchName string) (bool, error) {\\n   270→\\trepo, err := openRepository(ctx)\\n   271→\\tif err != nil {\\n   272→\\t\\treturn false, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   273→\\t}\\n   274→\\n   275→\\t_, err = repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   276→\\tif err != nil {\\n   277→\\t\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n   278→\\t\\t\\treturn false, nil\\n   279→\\t\\t}\\n   280→\\t\\treturn false, fmt.Errorf(\\\"failed to check branch: %w\\\", err)\\n   281→\\t}\\n   282→\\n   283→\\treturn true, nil\\n   284→}\\n   285→\\n   286→// CheckoutBranch switches to the specified local branch or commit.\\n   287→// Uses git CLI instead of go-git to work around go-git v5 bug where Checkout\\n   288→// deletes untracked files (see https://github.com/go-git/go-git/issues/970).\\n   289→// Should be switched back to go-git once we upgrade to go-git v6\\n   290→// Returns an error if the ref doesn't exist or checkout fails.\\n   291→func CheckoutBranch(ctx context.Context, ref string) error {\\n   292→\\tif strings.HasPrefix(ref, \\\"-\\\") {\\n   293→\\t\\treturn fmt.Errorf(\\\"checkout failed: invalid ref %q\\\", ref)\\n   294→\\t}\\n   295→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"checkout\\\", ref)\\n   296→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   297→\\t\\treturn fmt.Errorf(\\\"checkout failed: %s: %w\\\", strings.TrimSpace(string(output)), err)\\n   298→\\t}\\n   299→\\treturn nil\\n   300→}\\n   301→\\n   302→// ValidateBranchName checks if a branch name is valid using git check-ref-format.\\n   303→// Returns an error if the name is invalid or contains unsafe characters.\\n   304→func ValidateBranchName(ctx context.Context, branchName string) error {\\n   305→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"check-ref-format\\\", \\\"--branch\\\", branchName)\\n   306→\\tif err := cmd.Run(); err != nil {\\n   307→\\t\\treturn fmt.Errorf(\\\"invalid branch name %q\\\", branchName)\\n   308→\\t}\\n   309→\\treturn nil\\n   310→}\\n   311→\\n   312→// FetchAndCheckoutRemoteBranch fetches a branch from origin and creates a local tracking branch.\\n   313→// Uses git CLI instead of go-git for fetch because go-git doesn't use credential helpers,\\n   314→// which breaks HTTPS URLs that require authentication.\\n   315→func FetchAndCheckoutRemoteBranch(ctx context.Context, branchName string) error {\\n   316→\\t// Validate branch name before using in shell command (branchName comes from user CLI input)\\n   317→\\tif err := ValidateBranchName(ctx, branchName); err != nil {\\n   318→\\t\\treturn err\\n   319→\\t}\\n   320→\\n   321→\\t// Use git CLI for fetch (go-git's fetch can be tricky with auth)\\n   322→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   323→\\tdefer cancel()\\n   324→\\n   325→\\trefSpec := fmt.Sprintf(\\\"+refs/heads/%s:refs/remotes/origin/%s\\\", branchName, branchName)\\n   326→\\n   327→\\tfetchCmd := exec.CommandContext(ctx, \\\"git\\\", \\\"fetch\\\", \\\"origin\\\", refSpec)\\n   328→\\tif output, err := fetchCmd.CombinedOutput(); err != nil {\\n   329→\\t\\tif ctx.Err() == context.DeadlineExceeded {\\n   330→\\t\\t\\treturn errors.New(\\\"fetch timed out after 2 minutes\\\")\\n   331→\\t\\t}\\n   332→\\t\\treturn fmt.Errorf(\\\"failed to fetch branch from origin: %s: %w\\\", strings.TrimSpace(string(output)), err)\\n   333→\\t}\\n   334→\\n   335→\\trepo, err := openRepository(ctx)\\n   336→\\tif err != nil {\\n   337→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   338→\\t}\\n   339→\\n   340→\\t// Get the remote branch reference\\n   341→\\tremoteRef, err := repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", branchName), true)\\n   342→\\tif err != nil {\\n   343→\\t\\treturn fmt.Errorf(\\\"branch '%s' not found on origin: %w\\\", branchName, err)\\n   344→\\t}\\n   345→\\n   346→\\t// Create local branch pointing to the same commit\\n   347→\\tlocalRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(branchName), remoteRef.Hash())\\n   348→\\terr = repo.Storer.SetReference(localRef)\\n   349→\\tif err != nil {\\n   350→\\t\\treturn fmt.Errorf(\\\"failed to create local branch: %w\\\", err)\\n   351→\\t}\\n   352→\\n   353→\\t// Checkout the new local branch\\n   354→\\treturn CheckoutBranch(ctx, branchName)\\n   355→}\\n   356→\\n   357→// FetchMetadataBranch fetches the entire/checkpoints/v1 branch from origin and creates/updates the local branch.\\n   358→// This is used when the metadata branch exists on remote but not locally.\\n   359→// Uses git CLI instead of go-git for fetch because go-git doesn't use credential helpers,\\n   360→// which breaks HTTPS URLs that require authentication.\\n   361→func FetchMetadataBranch(ctx context.Context) error {\\n   362→\\tbranchName := paths.MetadataBranchName\\n   363→\\n   364→\\t// Use git CLI for fetch (go-git's fetch can be tricky with auth)\\n   365→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   366→\\tdefer cancel()\\n   367→\\n   368→\\trefSpec := fmt.Sprintf(\\\"+refs/heads/%s:refs/remotes/origin/%s\\\", branchName, branchName)\\n   369→\\n   370→\\tfetchCmd := exec.CommandContext(ctx, \\\"git\\\", \\\"fetch\\\", \\\"origin\\\", refSpec)\\n   371→\\tif output, err := fetchCmd.CombinedOutput(); err != nil {\\n   372→\\t\\tif ctx.Err() == context.DeadlineExceeded {\\n   373→\\t\\t\\treturn errors.New(\\\"fetch timed out after 2 minutes\\\")\\n   374→\\t\\t}\\n   375→\\t\\treturn fmt.Errorf(\\\"failed to fetch %s from origin: %s: %w\\\", branchName, strings.TrimSpace(string(output)), err)\\n   376→\\t}\\n   377→\\n   378→\\trepo, err := openRepository(ctx)\\n   379→\\tif err != nil {\\n   380→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   381→\\t}\\n   382→\\n   383→\\t// Get the remote branch reference\\n   384→\\tremoteRef, err := repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", branchName), true)\\n   3