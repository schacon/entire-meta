ch, tree objects are local but blobs may not be.\\n// BlobResolver checks the local object store first and tracks which blobs\\n// are missing so callers can decide whether to trigger a second fetch.\\ntype BlobResolver struct {\\n    storer storer.EncodedObjectStorer\\n}\\n\\n// HasBlob checks if a blob exists in the local object store.\\n// Uses HasEncodedObject which checks both loose objects and packfiles\\n// without reading the blob content.\\nfunc (r *BlobResolver) HasBlob(hash plumbing.Hash) bool {\\n    return r.storer.HasEncodedObject(hash) == nil\\n}\\n\\n// ReadBlob reads a blob from the local object store.\\n// Returns plumbing.ErrObjectNotFound if the blob isn't local.\\nfunc (r *BlobResolver) ReadBlob(hash plumbing.Hash) ([]byte, error) {\\n    // Use storer.EncodedObject directly — no network calls\\n}\\n\\n// ResolveFileFromTree gets a file's blob hash from a tree entry\\n// without reading the blob content.\\nfunc (r *BlobResolver) ResolveFileFromTree(tree *object.Tree, path string) (plumbing.Hash, error) {\\n    entry, err := tree.FindEntry(path)  // tree entries are local\\n    return entry.Hash, err\\n}\\n```\\n\\n**Testability**: Pure local operations against the go-git storer. Tests create repos with/without blobs and verify behavior.\\n\\n#### 2. New `FetchMetadataTreeOnly()` in `git_operations.go`\\n\\n```go\\n// FetchMetadataTreeOnly fetches only commit and tree objects for the\\n// metadata branch using go-git's blob:none filter.\\n// After this call, tree navigation works but blob reads may fail\\n// for objects not previously fetched.\\nfunc FetchMetadataTreeOnly(ctx context.Context) error {\\n    repo, err := openRepository(ctx)\\n    // ...\\n    remote, err := repo.Remote(\\\"origin\\\")\\n    // ...\\n    err = remote.FetchContext(ctx, &git.FetchOptions{\\n        RefSpecs: []config.RefSpec{refSpec},\\n        Filter:   packp.FilterBlobNone(),\\n        Force:    true,\\n    })\\n    // Update local branch ref (same as current FetchMetadataBranch)\\n}\\n\\n// FetchMetadataBlobsIfNeeded does a second unfiltered fetch of the\\n// metadata branch only if needed blobs are missing from the local store.\\n// Returns true if a fetch was performed.\\nfunc FetchMetadataBlobsIfNeeded(ctx context.Context, repo *git.Repository, needed []plumbing.Hash) (bool, error) {\\n    // Check each hash with HasEncodedObject\\n    allLocal := true\\n    for _, h := range needed {\\n        if repo.Storer.HasEncodedObject(h) != nil {\\n            allLocal = false\\n            break\\n        }\\n    }\\n    if allLocal {\\n        return false, nil  // fast path: no fetch needed\\n    }\\n    // Second fetch without filter — pack negotiation skips already-local objects\\n    remote, _ := repo.Remote(\\\"origin\\\")\\n    return true, remote.FetchContext(ctx, &git.FetchOptions{\\n        RefSpecs: []config.RefSpec{refSpec},\\n        Force:    true,\\n    })\\n}\\n```\\n\\n#### 3. New `CollectTranscriptBlobHashes()` in `checkpoint/committed.go`\\n\\n```go\\n// CollectTranscriptBlobHashes walks the metadata tree for a checkpoint and\\n// returns the blob hashes for all full.jsonl files (one per session).\\n// Only navigates tree objects (no blob reads), so works after a treeless fetch.\\nfunc (s *GitStore) CollectTranscriptBlobHashes(\\n    ctx context.Context,\\n    checkpointID id.CheckpointID,\\n) ([]TranscriptBlobRef, error) {\\n    tree, err := s.getSessionsBranchTree()\\n    // Navigate to checkpoint: <id[:2]>/<id[2:]>/\\n    checkpointTree, err := tree.Tree(checkpointID.Path())\\n    // Read root metadata.json to get session count\\n    // (metadata.json blob hash — add to results too)\\n    summaryEntry, _ := checkpointTree.FindEntry(paths.MetadataFileName)\\n\\n    var refs []TranscriptBlobRef\\n    refs = append(refs, TranscriptBlobRef{Path: \\\"metadata.json\\\", Hash: summaryEntry.Hash})\\n\\n    // For each session subdirectory (0, 1, 2, ...)\\n    for i := 0; ; i++ {\\n        sessionTree, err := checkpointTree.Tree(strconv.Itoa(i))\\n        if err != nil { break }\\n        // Get full.jsonl blob hash from tree entry (no blob read)\\n        if entry, err := sessionTree.FindEntry(\\\"full.jsonl\\\"); err == nil {\\n            refs = append(refs, TranscriptBlobRef{\\n                SessionIndex: i,\\n                Hash:         entry.Hash,\\n                Path:         fmt.Sprintf(\\\"%d/full.jsonl\\\", i),\\n            })\\n        }\\n        // Also handle chunked transcripts: full.jsonl.0, full.jsonl.1, ...\\n        for chunk := 0; ; chunk++ {\\n            name := fmt.Sprintf(\\\"full.jsonl.%d\\\", chunk)\\n            if entry, err := sessionTree.FindEntry(name); err == nil {\\n                refs = append(refs, TranscriptBlobRef{...})\\n            } else { break }\\n        }\\n    }\\n    return refs, nil\\n}\\n\\ntype TranscriptBlobRef struct {\\n    SessionIndex int\\n    Hash         plumbing.Hash\\n    Path         string  // relative to checkpoint dir\\n}\\n```\\n\\n**Key property**: This function only walks **tree objects** (local after treeless fetch). It uses `FindEntry` to get blob hashes without reading blob content.\\n\\n#### 4. Updated resume flow\\n\\n```go\\n// resume.go — updated getMetadataTree()\\n\\nfunc getMetadataTree(ctx context.Context, repo *git.Repository) (*object.Tree, error) {\\n    // 1. Try local branch (existing fast path)\\n    if tree, err := strategy.GetMetadataBranchTree(repo); err == nil {\\n        return tree, nil\\n    }\\n\\n    // 2. Treeless fetch — gets tree structure only\\n    if err := FetchMetadataTreeOnly(ctx); err == nil {\\n        if tree, err := strategy.GetMetadataBranchTree(repo); err == nil {\\n            return tree, nil\\n        }\\n    }\\n\\n    // 3. Fallback: full fetch (handles auth failures, old servers)\\n    if err := FetchMetadataBranch(ctx); err == nil {\\n        return strategy.GetMetadataBranchTree(repo)\\n    }\\n\\n    return nil, fmt.Errorf(\\\"metadata branch not available\