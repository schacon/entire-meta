→\\t// Sort for consistent output\\n   592→\\tsort.Strings(filesToRestore)\\n   593→\\tsort.Strings(filesToDelete)\\n   594→\\n   595→\\treturn &RewindPreview{\\n   596→\\t\\tFilesToRestore: filesToRestore,\\n   597→\\t\\tFilesToDelete:  filesToDelete,\\n   598→\\t}, nil\\n   599→}\\n   600→\\n   601→// RestoreLogsOnly restores session logs from a logs-only rewind point.\\n   602→// This fetches the transcript from entire/checkpoints/v1 and writes it to the agent's session directory.\\n   603→// Does not modify the working directory.\\n   604→// When multiple sessions were condensed to the same checkpoint, ALL sessions are restored.\\n   605→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   606→// Returns info about each restored session so callers can print correct per-session resume commands.\\n   607→func (s *ManualCommitStrategy) RestoreLogsOnly(ctx context.Context, point RewindPoint, force bool) ([]RestoredSession, error) {\\n   608→\\tif !point.IsLogsOnly {\\n   609→\\t\\treturn nil, errors.New(\\\"not a logs-only rewind point\\\")\\n   610→\\t}\\n   611→\\n   612→\\tif point.CheckpointID.IsEmpty() {\\n   613→\\t\\treturn nil, errors.New(\\\"missing checkpoint ID\\\")\\n   614→\\t}\\n   615→\\n   616→\\t// Get checkpoint store\\n   617→\\tstore, err := s.getCheckpointStore()\\n   618→\\tif err != nil {\\n   619→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   620→\\t}\\n   621→\\n   622→\\t// Read checkpoint summary to get session count\\n   623→\\tsummary, err := store.ReadCommitted(ctx, point.CheckpointID)\\n   624→\\tif err != nil {\\n   625→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   626→\\t}\\n   627→\\tif summary == nil {\\n   628→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", point.CheckpointID)\\n   629→\\t}\\n   630→\\n   631→\\t// Get worktree root for agent session directory lookup\\n   632→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   633→\\tif err != nil {\\n   634→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   635→\\t}\\n   636→\\n   637→\\t// Check for newer local logs if not forcing\\n   638→\\tif !force {\\n   639→\\t\\tsessions := s.classifySessionsForRestore(ctx, repoRoot, store, point.CheckpointID, summary)\\n   640→\\t\\thasConflicts := false\\n   641→\\t\\tfor _, sess := range sessions {\\n   642→\\t\\t\\tif sess.Status == StatusLocalNewer {\\n   643→\\t\\t\\t\\thasConflicts = true\\n   644→\\t\\t\\t\\tbreak\\n   645→\\t\\t\\t}\\n   646→\\t\\t}\\n   647→\\t\\tif hasConflicts {\\n   648→\\t\\t\\tshouldOverwrite, promptErr := PromptOverwriteNewerLogs(sessions)\\n   649→\\t\\t\\tif promptErr != nil {\\n   650→\\t\\t\\t\\treturn nil, promptErr\\n   651→\\t\\t\\t}\\n   652→\\t\\t\\tif !shouldOverwrite {\\n   653→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled. Local session logs preserved.\\\\n\\\")\\n   654→\\t\\t\\t\\treturn nil, nil\\n   655→\\t\\t\\t}\\n   656→\\t\\t}\\n   657→\\t}\\n   658→\\n   659→\\t// Count sessions to restore\\n   660→\\ttotalSessions := len(summary.Sessions)\\n   661→\\tif totalSessions > 1 {\\n   662→\\t\\tfmt.Fprintf(os.Stderr, \\\"Restoring %d sessions from checkpoint:\\\\n\\\", totalSessions)\\n   663→\\t}\\n   664→\\n   665→\\t// Restore all sessions (oldest to newest, using 0-based indexing)\\n   666→\\tvar restored []RestoredSession\\n   667→\\tfor i := range totalSessions {\\n   668→\\t\\tcontent, readErr := store.ReadSessionContent(ctx, point.CheckpointID, i)\\n   669→\\t\\tif readErr != nil {\\n   670→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: failed to read session %d: %v\\\\n\\\", i, readErr)\\n   671→\\t\\t\\tcontinue\\n   672→\\t\\t}\\n   673→\\t\\tif content == nil || len(content.Transcript) == 0 {\\n   674→\\t\\t\\tcontinue\\n   675→\\t\\t}\\n   676→\\n   677→\\t\\tsessionID := content.Metadata.SessionID\\n   678→\\t\\tif sessionID == \\\"\\\" {\\n   679→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d has no session ID, skipping\\\\n\\\", i)\\n   680→\\t\\t\\tcontinue\\n   681→\\t\\t}\\n   682→\\n   683→\\t\\t// Resolve per-session agent from metadata — skip if agent is unknown\\n   684→\\t\\tif content.Metadata.Agent == \\\"\\\" {\\n   685→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d (%s) has no agent metadata, skipping (cannot determine target directory)\\\\n\\\", i, sessionID)\\n   686→\\t\\t\\tcontinue\\n   687→\\t\\t}\\n   688→\\t\\tsessionAgent, agErr := ResolveAgentForRewind(content.Metadata.Agent)\\n   689→\\t\\tif agErr != nil {\\n   690→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d (%s) has unknown agent %q, skipping\\\\n\\\", i, sessionID, content.Metadata.Agent)\\n   691→\\t\\t\\tcontinue\\n   692→\\t\\t}\\n   693→\\n   694→\\t\\t// Compute transcript path from current repo location for cross-machine portability.\\n   695→\\t\\tsessionAgentDir, dirErr := sessionAgent.GetSessionDir(repoRoot)\\n   696→\\t\\tif dirErr != nil {\\n   697→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: failed to get session dir for session %d: %v\\\\n\\\", i, dirErr)\\n   698→\\t\\t\\tcontinue\\n   699→\\t\\t}\\n   700→\\t\\tsessionFile := sessionAgent.ResolveSessionFile(sessionAgentDir, sessionID)\\n   701→\\n   702→\\t\\t// Get first prompt for display\\n   703→\\t\\tpromptPreview := ExtractFirstPrompt(content.Prompts)\\n   704→\\n   705→\\t\\tif totalSessions > 1 {\\n   706→\\t\\t\\tisLatest := i == totalSessions-1\\n   707→\\t\\t\\tif promptPreview != \\\"\\\" {\\n   708→\\t\\t\\t\\tif isLatest {\\n   709→\\t\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Session %d (latest): %s\\\\n\\\", i+1, promptPreview)\\n   710→\\t\\t\\t\\t} else {\\n   711→\\t\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Session %d: %s\\\\n\\\", i+1, promptPreview)\\n   712→\\t\\t\\t\\t}\\n   713→\\t\\t\\t}\\n   714→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"    Writing to: %s\\\\n\\\", sessionFile)\\n   715→\\t\\t} else {\\n   716→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Writing transcript to: %s\\\\n\\\", sessionFile)\\n   717→\\t\\t}\\n   718→\\n   719→\\t\\t// Ensure parent directory exists (session file may be in a different dir than sessionAgentDir)\\n   720→\\t\\tif mkdirErr := os.MkdirAll(filepath.Dir(sessionFile), 0o750); mkdirErr != nil {\\n   721→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"    Warning: failed to create directory: %v\\\\n\\\", mkdirErr)\\n   722→\\t\\t\\tcontinue\\n   723→\\t\\t}\\n   724→\\n   725→\\t\\tagentSession := &agent.AgentSession{\\n   726→\\t\\t\\tSessionID:  sessionID,\\n   727→\\t\\t\\tAgentName:  sessionAgent.Name(),\\n   728→\\t\\t\\tRepoPath:   repoRoot,\\n   729→\\t\\t\\tSessionRef: sessionFile,\\n   730→\\t\\t\\tNativeData: content.Transcript,\\n   731→\\t\\t}\\n   732→\\t\\tif writeErr := sessionAgent.WriteSession(ctx, agentSession); writeErr != nil {\\n   733→\\t\\t\\tif totalSessions > 1 {\\n   734→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"    Warning: failed to write session: %v\\\\n\\\", writeErr)\\n   735→\\t\\t\\t\\tcontinue\\n   736→\\t\\t\\t}\\n   737→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to write session: %w\\\", writeErr)\\n   738→\\t\\t}\\n   739→\\n   740→\\t\\trestored = append(restored, RestoredSession{\\n   741→\\t\\t\\tSessionID: sessionID,\\n   742→\\t\\t\\tAgent:     sessionAgent.Type(),\\n   743→\\t\\t\\tPrompt:    promptPreview,\\n   744→\\t\\t\\tCreatedAt: content.Metadata.CreatedAt,\\n   745→\\t\\t})\\n   746→\\t}\\n   747→\\n   748→\\treturn restored, nil\\n   749→}\\n   750→\\n   751→// ResolveAgentForRewind resolves the agent from checkpoint metadata.\\n   752→func ResolveAgentForRewind(agentType types.AgentType) (agent.Agent, error) {\\n   753→\\tag, err := agent.GetByAgentType(agentType)\\n   754→\\tif err != nil {\\n   755→\\t\\treturn nil, fmt.Errorf(\\\"resolving agent %q: %w\\\", agentType, err)\\n   756→\\t}\\n   757→\\treturn ag, nil\\n   758→}\\n   759→\\n   760→// readSessionPrompt reads the first prompt from the session's prompt.txt file stored in git.\\n   761→// Returns an empty string if the prompt cannot be read.\\n   762→func readSessionPrompt(repo *git.Repository, commitHash plumbing.Hash, metadataDir string) string {\\n   763→\\t// Get the commit and its tree\\n   764→\\tcommit, err := repo.CommitObject(commitHash)\\n   765→\\tif err != nil {\\n   766→\\t\\treturn \\\"\\\"\\n   767→\\t}\\n   768→\\n   769→\\ttree, err := commit.Tree()\\n   770→\\tif err != nil {\\n   771→\\t\\treturn \\\"\\\"\\n   772→\\t}\\n   773→\\n   774→\\t// Look for prompt.txt in the metadata directory\\n   775→\\tpromptPath := metadataDir + \\\"/\\\" + paths.PromptFileName\\n   776→\\tpromptEntry, err := tree.File(promptPath)\\n   777→\\tif err != nil {\\n   778→\\t\\treturn \\\"\\\"\\n   779→\\t}\\n   780→\\n   781→\\tcontent, err := promptEntry.Contents()\\n   782→\\tif err != nil {\\n   783→\\t\\treturn \\\"\\\"\\n   784→\\t}\\n   785→\\n   786→\\treturn ExtractFirstPrompt(content)\\n   787→}\\n   788→\\n   789→// SessionRestoreStatus represents the status of a session being restored.\\n   790→type SessionRestoreStatus int\\n   791→\\n   792→const (\\n   793→\\tStatusNew             SessionRestoreStatus = iota // Local file doesn't exist\\n   794→\\tStatusUnchanged                                   // Local and checkpoint are the same\\n   795→\\tStatusCheckpointNewer                             // Checkpoint has newer entries\\n   796→\\tStatusLocalNewer                                  // Local has newer entries (conflict)\\n   797→)\\n   798→\\n   799→// SessionRestoreInfo contains information about a session being restored.\\n   800→type SessionRestoreInfo struct {\\n   801→\\tSessionID      string\\n   802→\\tPrompt         string               // First prompt preview for display\\n   803→\\tStatus         SessionRestoreStatus // Status of this session\\n   804→\\tLocalTime      time.Time\\n   805→\\tCheckpointTime time.Time\\n   806→}\\n   807→\\n   808→// classifySessionsForRestore checks all sessions in a checkpoint and returns in