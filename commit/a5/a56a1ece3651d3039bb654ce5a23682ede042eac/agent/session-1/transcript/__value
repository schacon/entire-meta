  18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    22→)\\n    23→\\n    24→//nolint:gochecknoinits // Agent self-registration is the intended pattern\\n    25→func init() {\\n    26→\\tagent.Register(agent.AgentNameKiro, NewKiroAgent)\\n    27→}\\n    28→\\n    29→// KiroAgent implements the Agent interface for Amazon's Kiro CLI.\\n    30→//\\n    31→//nolint:revive // KiroAgent is clearer than Agent in this context\\n    32→type KiroAgent struct{}\\n    33→\\n    34→// NewKiroAgent creates a new Kiro agent instance.\\n    35→func NewKiroAgent() agent.Agent {\\n    36→\\treturn &KiroAgent{}\\n    37→}\\n    38→\\n    39→// --- Identity ---\\n    40→\\n    41→func (k *KiroAgent) Name() types.AgentName   { return agent.AgentNameKiro }\\n    42→func (k *KiroAgent) Type() types.AgentType   { return agent.AgentTypeKiro }\\n    43→func (k *KiroAgent) Description() string     { return \\\"Kiro - Amazon AI coding CLI\\\" }\\n    44→func (k *KiroAgent) IsPreview() bool         { return true }\\n    45→func (k *KiroAgent) ProtectedDirs() []string { return []string{\\\".kiro\\\"} }\\n    46→\\n    47→// DetectPresence checks if Kiro is configured in the repository.\\n    48→func (k *KiroAgent) DetectPresence(ctx context.Context) (bool, error) {\\n    49→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    50→\\tif err != nil {\\n    51→\\t\\tworktreeRoot = \\\".\\\"\\n    52→\\t}\\n    53→\\tif _, err := os.Stat(filepath.Join(worktreeRoot, \\\".kiro\\\")); err == nil {\\n    54→\\t\\treturn true, nil\\n    55→\\t}\\n    56→\\treturn false, nil\\n    57→}\\n    58→\\n    59→// --- Transcript Storage ---\\n    60→\\n    61→// ReadTranscript reads the cached transcript JSON for a session.\\n    62→func (k *KiroAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    63→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    64→\\tif err != nil {\\n    65→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    66→\\t}\\n    67→\\treturn data, nil\\n    68→}\\n    69→\\n    70→// ChunkTranscript splits a JSON transcript into chunks.\\n    71→// Kiro transcripts are single JSON objects; we use the JSONL chunker since the\\n    72→// cached format is a JSON blob that fits in a single chunk in most cases.\\n    73→func (k *KiroAgent) ChunkTranscript(_ context.Context, content []byte, maxSize int) ([][]byte, error) {\\n    74→\\tif len(content) <= maxSize {\\n    75→\\t\\treturn [][]byte{content}, nil\\n    76→\\t}\\n    77→\\t// For large transcripts, split at line boundaries\\n    78→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    79→\\tif err != nil {\\n    80→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n    81→\\t}\\n    82→\\treturn chunks, nil\\n    83→}\\n    84→\\n    85→// ReassembleTranscript combines transcript chunks back into a single blob.\\n    86→func (k *KiroAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    87→\\tif len(chunks) == 1 {\\n    88→\\t\\treturn chunks[0], nil\\n    89→\\t}\\n    90→\\treturn agent.ReassembleJSONL(chunks), nil\\n    91→}\\n    92→\\n    93→// --- Session Management ---\\n    94→\\n    95→// GetSessionID extracts the session ID from hook input.\\n    96→func (k *KiroAgent) GetSessionID(input *agent.HookInput) string {\\n    97→\\treturn input.SessionID\\n    98→}\\n    99→\\n   100→// GetSessionDir returns the directory where Kiro stores session data.\\n   101→// For Kiro, sessions are in SQLite, but we cache transcripts to .entire/tmp/.\\n   102→func (k *KiroAgent) GetSessionDir(repoPath string) (string, error) {\\n   103→\\treturn filepath.Join(repoPath, \\\".entire\\\", \\\"tmp\\\"), nil\\n   104→}\\n   105→\\n   106→// ResolveSessionFile returns the path to the cached transcript file.\\n   107→func (k *KiroAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   108→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".json\\\")\\n   109→}\\n   110→\\n   111→// ReadSession reads session data from the cached transcript.\\n   112→func (k *KiroAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   113→\\tif input.SessionRef == \\\"\\\" {\\n   114→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   115→\\t}\\n   116→\\n   117→\\tdata, err := os.ReadFile(input.SessionRef)\\n   118→\\tif err != nil {\\n   119→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   120→\\t}\\n   121→\\n   122→\\treturn &agent.AgentSession{\\n   123→\\t\\tSessionID:  input.SessionID,\\n   124→\\t\\tAgentName:  k.Name(),\\n   125→\\t\\tSessionRef: input.SessionRef,\\n   126→\\t\\tStartTime:  time.Now(),\\n   127→\\t\\tNativeData: data,\\n   128→\\t}, nil\\n   129→}\\n   130→\\n   131→// WriteSession writes session data for resumption.\\n   132→func (k *KiroAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   133→\\tif session == nil {\\n   134→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   135→\\t}\\n   136→\\tif session.AgentName != \\\"\\\" && session.AgentName != k.Name() {\\n   137→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, k.Name())\\n   138→\\t}\\n   139→\\tif session.SessionRef == \\\"\\\" {\\n   140→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   141→\\t}\\n   142→\\tif len(session.NativeData) == 0 {\\n   143→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   144→\\t}\\n   145→\\n   146→\\tif err := os.MkdirAll(filepath.Dir(session.SessionRef), 0o750); err != nil {\\n   147→\\t\\treturn fmt.Errorf(\\\"failed to create session dir: %w\\\", err)\\n   148→\\t}\\n   149→\\n   150→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   151→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   152→\\t}\\n   153→\\treturn nil\\n   154→}\\n   155→\\n   156→// FormatResumeCommand returns the command to resume a Kiro session.\\n   157→func (k *KiroAgent) FormatResumeCommand(_ string) string {\\n   158→\\treturn \\\"kiro-cli chat --resume\\\"\\n   159→}\\n   160→\\n   161→// GetHookConfigPath returns the path to the hook config file relative to repo root.\\n   162→func (k *KiroAgent) GetHookConfigPath() string {\\n   163→\\treturn filepath.Join(\\\".kiro\\\", hooksDir, HooksFileName)\\n   164→}\\n   165→\\n   166→// --- TranscriptAnalyzer interface implementation ---\\n   167→\\n   168→// GetTranscriptPosition returns the number of history entries in a Kiro transcript.\\n   169→// Kiro uses JSON format with paired user+assistant history entries, so position\\n   170→// is the entry count. Returns 0 if the file doesn't exist, is empty, or is a\\n   171→// placeholder \\\"{}\\\".\\n   172→func (k *KiroAgent) GetTranscriptPosition(path string) (int, error) {\\n   173→\\tif path == \\\"\\\" {\\n   174→\\t\\treturn 0, nil\\n   175→\\t}\\n   176→\\n   177→\\tdata, err := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   178→\\tif err != nil {\\n   179→\\t\\tif os.IsNotExist(err) {\\n   180→\\t\\t\\treturn 0, nil\\n   181→\\t\\t}\\n   182→\\t\\treturn 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   183→\\t}\\n   184→\\n   185→\\tif len(data) == 0 {\\n   186→\\t\\treturn 0, nil\\n   187→\\t}\\n   188→\\n   189→\\tt, err := parseTranscript(data)\\n   190→\\tif err != nil {\\n   191→\\t\\treturn 0, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   192→\\t}\\n   193→\\n   194→\\treturn len(t.History), nil\\n   195→}\\n   196→\\n   197→// ExtractModifiedFilesFromOffset extracts files modified since a given history index.\\n   198→// For Kiro (JSON format), offset is the starting history entry index.\\n   199→func (k *KiroAgent) ExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error) {\\n   200→\\tif path == \\\"\\\" {\\n   201→\\t\\treturn nil, 0, nil\\n   202→\\t}\\n   203→\\n   204→\\tdata, readErr := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   205→\\tif readErr != nil {\\n   206→\\t\\tif os.IsNotExist(readErr) {\\n   207→\\t\\t\\treturn nil, 0, nil\\n   208→\\t\\t}\\n   209→\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", readErr)\\n   210→\\t}\\n   211→\\n   212→\\tif len(data) == 0 {\\n   213→\\t\\treturn nil, 0, nil\\n   214→\\t}\\n   215→\\n   216→\\tt, parseErr := parseTranscript(data)\\n   217→\\tif parseErr != nil {\\n   218→\\t\\treturn nil, 0, parseErr\\n   219→\\t}\\n   220→\\n   221→\\ttotalEntries := len(t.History)\\n   222→\\n   223→\\tif startOffset >= totalEntries {\\n   224→\\t\\treturn nil, totalEntries, nil\\n   225→\\t}\\n   226→\\n   227→\\tmodifiedFiles := extractModifiedFilesFromHistory(t.History[startOffset:])\\n   228→\\treturn modifiedFiles, totalEntries, nil\\n   229→}\\n   230→\\n   231→// ExtractPrompts extracts user prompts from the transcript starting at the given offset.\\n   232→// Only Prompt-type user messages are returned; ToolUseResults entries are skipped.\\n   233→func (k *KiroAgent) ExtractPrompts(sessionRef string, fromOffset int) ([]string, error) {\\n   234→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n   235→\\tif err != nil {\\n   236→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   237→\\t}\\n   238→\\n   239→\\tt, parseErr := parseTranscript(data)\\n   240→\\tif parseErr != nil {\\n   241→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", parseErr)\\n   242→\\t}\\n   243→\\n   244→\\tvar prompts []string\\n   245→\\tfor i := fromOffset; i < len(t.History); i++ {\\n   246→\\t\\tif prompt := extractUserPrompt(t.History[i].User.Content); prompt != \\\"\\\" {\\n   247→\\t\\t\\tprompts = append(prompts, prompt)\\n   248→\\t\\t}\\n   249→\\t}\\n   250→\\treturn prompts, nil\\n   251→}\\n   252→\\n   253→// ExtractSummary extracts the last assistant response as a session summary.\\n   254→func (k *KiroAgent) ExtractSummary(sessionRef string) (string, error) {\\n   255→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n   256→\\tif err != nil {\\n   257→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   258→\\t}\\n   259→\\n   260→\\tt, parseErr := parseTranscript(data)\\n   261→\\tif parseErr != nil {\\n   262→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse transcript: %w\\\", parseErr)\\n   263→\\t}\\n   264→\\n   265→\\treturn extractLastAssistantResponse(t.History), nil\\n   266→}\\n   267→\\n   268→// --- SQLite helpers ---\\n   269→\\n   270→// escapeSQLString escapes single quotes for use in SQLite string literals.\\n   271→func escapeSQLString(s string) string {\\n   272→\\treturn strings.ReplaceAll(s, \\\"'\\\", \\\"''\\\")\\n   273→}\\n   274→\\n   275→// --- SQLite session resolution ---\\n   276→\\n   277→// dbPath returns the path to Kiro's SQLite database.\\n   278→func dbPath() (string, error) {\\n   279→\\thome, err := os.UserHomeDir()\\n   280→\\tif err != nil {\\n   281→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   282→\\t}\\n   283→\\tswitch runtime.GOOS {\\n   284→\\tcase \\\"darwin\\\":\\n   285→\\t\\treturn filepath.Join(home, \\\"Library\\\", \\\"Application Support\\\", \\\"kiro-cli\\\", \\\"data.sqlite3\\\"), nil\\n   286→\\tdefault: // linux\\n   287→\\t\\treturn filepath.Join(home, \\\".local\\\", \\\"share\\\", \\\"kiro-cli\\\", \\\"data.sqlite3\\\"), nil\\n   288→\\t}\\n   289→}\\n   290→\\n   291→// querySessionID queries the SQLite database for the most recent conversation ID\\n   292→// associated with the given CWD.\\n   293→func (k *KiroAgent) querySessionID(ctx context.Context, cwd string) (string, error) {\\n   294→\\tif os.Getenv(\\\"ENTIRE_TEST_KIRO_MOCK_DB\\\") == \\\"1\\\" {\\n   295→\\t\\treturn \\\"mock-session-id\\\", nil\\n   296→\\t}\\n   297→\\n   298→\\tdb, err := dbPath()\\n   299→\\tif err != nil {\\n   300→\\t\\treturn \\\"\\\", err\\n   301→\\t}\\n   302→\\tif _, err := os.Stat(db); err != nil {\\n   303→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"kiro database not found at %s: %w\\\", db, err)\\n   304→\\t}\\n   305→\\n   306→\\tquery := fmt.Sprintf(\\n   307→\\t\\t\\\"SELECT json_extract(value, '$.conversation_id') FROM conversations_v2 WHERE key = '%s' ORDER BY updated_at DESC LIMIT 1\\\",\\n   308→\\t\\tescapeSQLString(cwd),\\n   309→\\t)\\n   310→\\n   311→\\tcmd := exec.CommandContext(ctx, \\\"sqlite3\\\", \\\"-json\\\", db, query)\\n   312→\\tout, err := cmd.Output()\\n   313→\\tif err != nil {\\n   314→\\t\\tlogging.Warn(ctx, \\\"kiro: sqlite3 query failed\\\", \\\"err\\\", err, \\\"cwd\\\", cwd)\\n   315→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"sqlite3 query failed: %w\\\", err)\\n   316→\\t}\\n   317→\\n   318→\\tresult := strings.TrimSpace(string(out))\\n   319→\\tif result == \\\"\\\" || result == \\\"[]\\\" {\\n   320→\\t\\treturn \\\"\\\", nil\\n   321→\\t}\\n   322→\\n   323→\\t// sqlite3 -json returns an array of objects\\n   324→\\tvar rows []map[string]string\\n   325→\\tif err := json.Unmarshal([]byte(result), &rows); err != nil {\\n   326→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse sqlite3 output: %w\\\", err)\\n   327→\\t}\\n   328→\\tif len(rows) == 0 {\\n   329→\\t\\treturn \\\"\\\", nil\\n   330→\\t}\\n   331→\\n   332→\\t// The column name from json_extract\\n   333→\\tfor _, v := range rows[0] {\\n   334→\\t\\treturn v, nil\\n   335→\\t}\\n   336→\\treturn \\\"\\\", nil\\n   337→}\\n   338→\\n   339→// ensureCachedTranscript fetches the conversation from SQLite and caches it\\n   340→// to .entire/tmp/<sessionID>.json. Returns the cache file path.\\n   341→func (k *KiroAgent) ensureCachedTranscript(ctx context.Context, cwd, sessionID string) (string, error) {\\n   342→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   343→\\tif err != nil {\\n   344→\\t\\trepoRoot = cwd\\n   345→\\t}\\n   346→\\n   347→\\tcacheDir := filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\")\\n   348→\\tcachePath := filepath.Join(cacheDir, sessionID+\\\".json\\\")\\n   349→\\n   350→\\t// Fetch fresh transcript from SQLite on every call (transcript grows during session)\\n   351→\\tif os.Getenv(\\\"ENTIRE_TEST_KIRO_MOCK_DB\\\") == \\\"1\\\" {\\n   352→\\t\\t// In test mode, return the expected cache path without hitting SQLite.\\n   353→\\t\\treturn cachePath, nil\\n   354→\\t}\\n   355→\\n   356→\\tdb, err := dbPath()\\n   357→\\tif err != nil {\\n   358→\\t\\treturn \\\"\\\", err\\n   359→\\t}\\n   360→\\n   361→\\tquery := fmt.Sprintf(\\n   362→\\t\\t\\\"SELECT value FROM conversations_v2 WHERE key = '%s' ORDER BY updated_at DESC LIMIT 1\\\",\\n   363→\\t\\tescapeSQLString(cwd),\\n   364→\\t)\\n   365→\\n   366→\\tcmd := exec.CommandContext(ctx, \\\"sqlite3\\\", db, query)\\n   367→\\tout, err := cmd.Output()\\n   368→\\tif err != nil {\\n   369→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"sqlite3 transcript query failed: %w\\\", err)\\n   370→\\t}\\n   371→\\n   372→\\ttranscript := strings.TrimSpace(string(out))\\n   373→\\tif transcript == \\\"\\\" {\\n   374→\\t\\treturn \\\"\\\", errors.New(\\\"no transcript found\\\")\\n   375→\\t}\\n   376→\\n   377→\\tif err := os.MkdirAll(cacheDir, 0o750); err != nil {\\n   378→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create cache dir: %w\\\", err)\\n   379→\\t}\\n   380→\\n   381→\\tif err := os.WriteFile(cachePath, []byte(transcript), 0o600); err != nil {\\n   382→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write cached transcript: %w\\\", err)\\n   383→\\t}\\n   384→\\n   385→\\treturn cachePath, nil\\n   386→}\\n   387→\\n   388→// --- IDE transcript discovery ---\\n   389→\\n   390→// ideWorkspaceSessionsDir returns the directory where the Kiro IDE stores\\n   391→// session files for the given working directory. The directory is derived from\\n   392→// the base64-encoded CWD.\\n   393→func ideWorkspaceSessionsDir(cwd string) (string, error) {\\n   394→\\thome, err := os.UserHomeDir()\\n   395→\\tif err != nil {\\n   396→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   397→\\t}\\n   398→\\n   399→\\tencoded := base64.StdEncoding.EncodeToString([]byte(cwd))\\n   400→\\n   401→\\tvar baseDir string\\n   402→\\tswitch runtime.GOOS {\\n   403→\\tcase \\\"darwin\\\":\\n   404→\\t\\tbaseDir = filepath.Join(home, \\\"Library\\\", \\\"Application Support\\\", \\\"Kiro\\\", \\\"User\\\", \\\"globalStorage\\\", \\\"kiro.kiroagent\\\", \\\"workspace-sessions\\\")\\n   405→\\tdefault: // linux\\n   406→\\t\\tbaseDir = filepath.Join(home, \\\".config\\\", \\\"Kiro\\\", \\\"User\\\", \\\"globalStorage\\\", \\\"kiro.kiroagent\\\", \\\"workspace-sessions\\\")\\n   407→\\t}\\n   408→\\n   409→\\treturn filepath.Join(baseDir, encoded), nil\\n   410→}\\n   411→\\n   412→// ensureIDETranscript looks for the most recent Kiro IDE session transcript\\n   413→// for the given CWD and copies it to .entire/tmp/<sessionID>.json.\\n   414→// Returns the cache path on success, or empty string if no transcript is found.\\n   415→func (k *KiroAgent) ensureIDETranscript(ctx context.Context, cwd, sessionID string) (string, error) {\\n   416→\\tsessDir, err := ideWorkspaceSessionsDir(cwd)\\n   417→\\tif err != nil {\\n   418→\\t\\treturn \\\"\\\", err\\n   419→\\t}\\n   420→\\n   421→\\t// Read the sessions.json index.\\n   422→\\tindexPath := filepath.Join(sessDir, \\\"sessions.json\\\")\\n   423→\\tindexData, err := os.ReadFile(indexPath) //nolint:gosec // Controlled path from IDE storage\\n   424→\\tif err != nil {\\n   425→\\t\\tlogging.Debug(ctx, \\\"kiro: IDE sessions.json not found\\\", \\\"path\\\", indexPath, \\\"err\\\", err)\\n   426→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"IDE sessions.json not found: %w\\\", err)\\n   427→\\t}\\n   428→\\n   429→\\tvar sessions []kiroIDESessionEntry\\n   430→\\tif err := json.Unmarshal(indexData, &sessions); err != nil {\\n   431→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse IDE sessions.json: %w\\\", err)\\n   432→\\t}\\n   433→\\n   434→\\tif len(sessions) == 0 {\\n   435→\\t\\treturn \\\"\\\", errors.New(\\\"no IDE sessions found\\\")\\n   436→\\t}\\n   437→\\n   438→\\t// Sort by dateCreated descending to find the most recent session.\\n   439→\\tsort.Slice(sessions, func(i, j int) bool {\\n   440→\\t\\treturn sessions[i].DateCreated > sessions[j].DateCreated\\n   441→\\t})\\n   442→\\n   443→\\t// Read the most recent session's transcript.\\n   444→\\tlatestSession := sessions[0]\\n   445→\\ttranscriptPath := filepath.Join(sessDir, latestSession.SessionID+\\\".json\\\")\\n   446→\\ttranscriptData, err := os.ReadFile(transcriptPath) //nolint:gosec // Controlled path from IDE storage\\n   447→\\tif err != nil {\\n   448→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read IDE transcript %s: %w\\\", transcriptPath, err)\\n   449→\\t}\\n   450→\\n   451→\\t// Cache the transcript under our session ID.\\n   452→\\trepoRoot, rootErr := paths.WorktreeRoot(ctx)\\n   453→\\tif rootErr != nil {\\n   454→\\t\\trepoRoot = cwd\\n   455→\\t}\\n   456→\\n   457→\\tcacheDir := filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\")\\n   458→\\tcachePath := filepath.Join(cacheDir, sessionID+\\\".json\\\")\\n   459→\\n   460→\\tif err := os.MkdirAll(cacheDir, 0o750); err != nil {\\n   461→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create cache dir: %w\\\", err)\\n   462→\\t}\\n   463→\\n   464→\\tif err := os.WriteFile(cachePath, transcriptData, 0o600); err != nil {\\n   465→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write cached IDE transcript: %w\\\", err)\\n   466→\\t}\\n   467→\\n   468→\\tlogging.Info(ctx, \\\"kiro: cached IDE transcript\\\",\\n   469→\\t\\t\\\"ide_session\\\", latestSession.SessionID,\\n   470→\\t\\t\\\"our_session\\\", sessionID,\\n   471→\\t\\t\\\"cache_path\\\", cachePath,\\n   472→\\t)\\n   473→\\n   474→\\treturn cachePath, nil\\n   475→}\\n   476→\"}]},\"uuid\":\"47d38254-9190-42f9-9f3e-710b25b8f0eb\",\"timestamp\":\"2026-03-04T00:47:25.811Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alisha/Projects/wt/kiro-oneshot/cmd/entire/cli/agent/kiro/kiro.go\",\"content\":\"// Package kiro implements the Agent interface for Amazon's Kiro CLI.\\npackage kiro\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/base64\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"os/exec\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"runtime\\\"\\n\\t\\\"sort\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n)\\n\\n//nolint:gochecknoinits // Agent self-registration is the intended pattern\\nfunc init() {\\n\\tagent.Register(agent.AgentNameKiro, NewKiroAgent)\\n}\\n\\n// KiroAgent implements the Agent interface for Amazon's Kiro CLI.\\n//\\n//nolint:revive // KiroAgent is clearer than Agent in this context\\ntype KiroAgent struct{}\\n\\n// NewKiroAgent creates a new Kiro agent instance.\\nfunc NewKiroAgent() agent.Agent {\\n\\treturn &KiroAgent{}\\n}\\n\\n// --- Identity ---\\n\\nfunc (k *KiroAgent) Name() types.AgentName   { return agent.AgentNameKiro }\\nfunc (k *KiroAgent) Type() types.AgentType   { return agent.AgentTypeKiro }\\nfunc (k *KiroAgent) Description() string     { return \\\"Kiro - Amazon AI coding CLI\\\" }\\nfunc (k *KiroAgent) IsPreview() bool         { return true }\\nfunc (k *KiroAgent) ProtectedDirs() []string { return []string{\\\".kiro\\\"} }\\n\\n// DetectPresence checks if Kiro is configured in the repository.\\nfunc (k *KiroAgent) DetectPresence(ctx context.Context) (bool, error) {\\n\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n\\tif err != nil {\\n\\t\\tworktreeRoot = \\\".\\\"\\n\\t}\\n\\tif _, err := os.Stat(filepath.Join(worktreeRoot, \\\".kiro\\\")); err == nil {\\n\\t\\treturn true, nil\\n\\t}\\n\\treturn false, nil\\n}\\n\\n// --- Transcript Storage ---\\n\\n// ReadTranscript reads the cached transcript JSON for a session.\\nfunc (k *KiroAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n\\t}\\n\\treturn data, nil\\n}\\n\\n// ChunkTranscript splits a JSON transcript into chunks.\\n// Kiro transcripts are single JSON objects; we use the JSONL chunker since the\\n// cached format is a JSON blob that fits in a single chunk in most cases.\\nfunc (k *KiroAgent) ChunkTranscript(_ context.Context, content []byte, maxSize int) ([][]byte, error) {\\n\\tif len(content) <= maxSize {\\n\\t\\treturn [][]byte{content}, nil\\n\\t}\\n\\t// For large transcripts, split at line boundaries\\n\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n\\t}\\n\\treturn chunks, nil\\n}\\n\\n// ReassembleTranscript combines transcript chunks back into a single blob.\\nfunc (k *KiroAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n\\tif len(chunks) == 1 {\\n\\t\\treturn chunks[0], nil\\n\\t}\\n\\treturn agent.ReassembleJSONL(chunks), nil\\n}\\n\\n// --- Session Management ---\\n\\n// GetSessionID extracts the session ID from hook input.\\nfunc (k *KiroAgent) GetSessionID(input *agent.HookInput) string {\\n\\treturn input.SessionID\\n}\\n\\n// GetSessionDir returns the directory where Kiro stores session data.\\n// For Kiro, sessions are in SQLite, but we cache transcripts to .entire/tmp/.\\nfunc (k *KiroAgent) GetSessionDir(repoPath string) (string, error) {\\n\\treturn filepath.Join(repoPath, \\\".entire\\\", \\\"tmp\\\"), nil\\n}\\n\\n// ResolveSessionFile returns the path to the cached transcript file.\\nfunc (k *KiroAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n\\treturn filepath.Join(sessionDir, agentSessionID+\\\".json\\\")\\n}\\n\\n// ReadSession reads session data from the cached transcript.\\nfunc (k *KiroAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n\\tif input.SessionRef == \\\"\\\" {\\n\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n\\t}\\n\\n\\tdata, err := os.ReadFile(input.SessionRef)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n\\t}\\n\\n\\treturn &agent.AgentSession{\\n\\t\\tSessionID:  input.SessionID,\\n\\t\\tAgentName:  k.Name(),\\n\\t\\tSessionRef: input.SessionRef,\\n\\t\\tStartTime:  time.Now(),\\n\\t\\tNativeData: data,\\n\\t}, nil\\n}\\n\\n// WriteSession writes session data for resumption.\\nfunc (k *KiroAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n\\tif session == nil {\\n\\t\\treturn errors.New(\\\"session is nil\\\")\\n\\t}\\n\\tif session.AgentName != \\\"\\\" && session.AgentName != k.Name() {\\n\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, k.Name())\\n\\t}\\n\\tif session.SessionRef == \\\"\\\" {\\n\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n\\t}\\n\\tif len(session.NativeData) == 0 {\\n\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n\\t}\\n\\n\\tif err := os.MkdirAll(filepath.Dir(session.SessionRef), 0o750); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create session dir: %w\\\", err)\\n\\t}\\n\\n\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\