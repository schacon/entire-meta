 pre-tool-use\\\"\\n   150→\\t\\tpostTaskCmd = \\\"entire hooks factoryai-droid post-tool-use\\\"\\n   151→\\t\\tpreCompactCmd = \\\"entire hooks factoryai-droid pre-compact\\\"\\n   152→\\t}\\n   153→\\n   154→\\tcount := 0\\n   155→\\n   156→\\t// Add hooks if they don't exist\\n   157→\\tif !hookCommandExists(sessionStart, sessionStartCmd) {\\n   158→\\t\\tsessionStart = addHookToMatcher(sessionStart, \\\"\\\", sessionStartCmd)\\n   159→\\t\\tcount++\\n   160→\\t}\\n   161→\\t// Also install user-prompt-submit on SessionStart to ensure TurnStart fires\\n   162→\\t// even when UserPromptSubmit doesn't (e.g., droid exec mode).\\n   163→\\t// The user-prompt-submit handler gracefully handles SessionStart's stdin format\\n   164→\\t// (userPromptSubmitRaw is a superset of sessionInfoRaw; Prompt defaults to \\\"\\\").\\n   165→\\tif !hookCommandExists(sessionStart, userPromptSubmitCmd) {\\n   166→\\t\\tsessionStart = addHookToMatcher(sessionStart, \\\"\\\", userPromptSubmitCmd)\\n   167→\\t\\tcount++\\n   168→\\t}\\n   169→\\tif !hookCommandExists(sessionEnd, sessionEndCmd) {\\n   170→\\t\\tsessionEnd = addHookToMatcher(sessionEnd, \\\"\\\", sessionEndCmd)\\n   171→\\t\\tcount++\\n   172→\\t}\\n   173→\\tif !hookCommandExists(stop, stopCmd) {\\n   174→\\t\\tstop = addHookToMatcher(stop, \\\"\\\", stopCmd)\\n   175→\\t\\tcount++\\n   176→\\t}\\n   177→\\tif !hookCommandExists(userPromptSubmit, userPromptSubmitCmd) {\\n   178→\\t\\tuserPromptSubmit = addHookToMatcher(userPromptSubmit, \\\"\\\", userPromptSubmitCmd)\\n   179→\\t\\tcount++\\n   180→\\t}\\n   181→\\tif !hookCommandExistsWithMatcher(preToolUse, \\\"Task\\\", preTaskCmd) {\\n   182→\\t\\tpreToolUse = addHookToMatcher(preToolUse, \\\"Task\\\", preTaskCmd)\\n   183→\\t\\tcount++\\n   184→\\t}\\n   185→\\tif !hookCommandExistsWithMatcher(postToolUse, \\\"Task\\\", postTaskCmd) {\\n   186→\\t\\tpostToolUse = addHookToMatcher(postToolUse, \\\"Task\\\", postTaskCmd)\\n   187→\\t\\tcount++\\n   188→\\t}\\n   189→\\tif !hookCommandExists(preCompact, preCompactCmd) {\\n   190→\\t\\tpreCompact = addHookToMatcher(preCompact, \\\"\\\", preCompactCmd)\\n   191→\\t\\tcount++\\n   192→\\t}\\n   193→\\n   194→\\t// Add permissions.deny rule if not present\\n   195→\\tpermissionsChanged := false\\n   196→\\tvar denyRules []string\\n   197→\\tif denyRaw, ok := rawPermissions[\\\"deny\\\"]; ok {\\n   198→\\t\\tif err := json.Unmarshal(denyRaw, &denyRules); err != nil {\\n   199→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse permissions.deny in settings.json: %w\\\", err)\\n   200→\\t\\t}\\n   201→\\t}\\n   202→\\tif !slices.Contains(denyRules, metadataDenyRule) {\\n   203→\\t\\tdenyRules = append(denyRules, metadataDenyRule)\\n   204→\\t\\tdenyJSON, err := json.Marshal(denyRules)\\n   205→\\t\\tif err != nil {\\n   206→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal permissions.deny: %w\\\", err)\\n   207→\\t\\t}\\n   208→\\t\\trawPermissions[\\\"deny\\\"] = denyJSON\\n   209→\\t\\tpermissionsChanged = true\\n   210→\\t}\\n   211→\\n   212→\\tif count == 0 && !permissionsChanged {\\n   213→\\t\\treturn 0, nil // All hooks and permissions already installed\\n   214→\\t}\\n   215→\\n   216→\\t// Marshal modified hook types back to rawHooks\\n   217→\\tmarshalHookType(rawHooks, \\\"SessionStart\\\", sessionStart)\\n   218→\\tmarshalHookType(rawHooks, \\\"SessionEnd\\\", sessionEnd)\\n   219→\\tmarshalHookType(rawHooks, \\\"Stop\\\", stop)\\n   220→\\tmarshalHookType(rawHooks, \\\"UserPromptSubmit\\\", userPromptSubmit)\\n   221→\\tmarshalHookType(rawHooks, \\\"PreToolUse\\\", preToolUse)\\n   222→\\tmarshalHookType(rawHooks, \\\"PostToolUse\\\", postToolUse)\\n   223→\\tmarshalHookType(rawHooks, \\\"PreCompact\\\", preCompact)\\n   224→\\n   225→\\t// Marshal hooks and update raw settings\\n   226→\\thooksJSON, err := json.Marshal(rawHooks)\\n   227→\\tif err != nil {\\n   228→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal hooks: %w\\\", err)\\n   229→\\t}\\n   230→\\trawSettings[\\\"hooks\\\"] = hooksJSON\\n   231→\\n   232→\\t// Marshal permissions and update raw settings\\n   233→\\tpermJSON, err := json.Marshal(rawPermissions)\\n   234→\\tif err != nil {\\n   235→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal permissions: %w\\\", err)\\n   236→\\t}\\n   237→\\trawSettings[\\\"permissions\\\"] = permJSON\\n   238→\\n   239→\\t// Write back to file\\n   240→\\tif err := os.MkdirAll(filepath.Dir(settingsPath), 0o750); err != nil {\\n   241→\\t\\treturn 0, fmt.Errorf(\\\"failed to create .factory directory: %w\\\", err)\\n   242→\\t}\\n   243→\\n   244→\\toutput, err := jsonutil.MarshalIndentWithNewline(rawSettings, \\\"\\\", \\\"  \\\")\\n   245→\\tif err != nil {\\n   246→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal settings: %w\\\", err)\\n   247→\\t}\\n   248→\\n   249→\\tif err := os.WriteFile(settingsPath, output, 0o600); err != nil {\\n   250→\\t\\treturn 0, fmt.Errorf(\\\"failed to write settings.json: %w\\\", err)\\n   251→\\t}\\n   252→\\n   253→\\treturn count, nil\\n   254→}\\n   255→\\n   256→// parseHookType parses a specific hook type from rawHooks into the target slice.\\n   257→// Silently ignores parse errors (leaves target unchanged).\\n   258→func parseHookType(rawHooks map[string]json.RawMessage, hookType string, target *[]FactoryHookMatcher) {\\n   259→\\tif data, ok := rawHooks[hookType]; ok {\\n   260→\\t\\t//nolint:errcheck,gosec // Intentionally ignoring parse errors - leave target as nil/empty\\n   261→\\t\\tjson.Unmarshal(data, target)\\n   262→\\t}\\n   263→}\\n   264→\\n   265→// marshalHookType marshals a hook type back to rawHooks.\\n   266→// If the slice is empty, removes the key from rawHooks.\\n   267→func marshalHookType(rawHooks map[string]json.RawMessage, hookType string, matchers []FactoryHookMatcher) {\\n   268→\\tif len(matchers) == 0 {\\n   269→\\t\\tdelete(rawHooks, hookType)\\n   270→\\t\\treturn\\n   271→\\t}\\n   272→\\tdata, err := json.Marshal(matchers)\\n   273→\\tif err != nil {\\n   274→\\t\\treturn // Silently ignore marshal errors (shouldn't happen)\\n   275→\\t}\\n   276→\\trawHooks[hookType] = data\\n   277→}\\n   278→\\n   279→// UninstallHooks removes Entire hooks from Factory AI Droid settings.\\n   280→func (f *FactoryAIDroidAgent) UninstallHooks() error {\\n   281→\\t// Use repo root to find .factory directory when run from a subdirectory\\n   282→\\trepoRoot, err := paths.RepoRoot()\\n   283→\\tif err != nil {\\n   284→\\t\\trepoRoot = \\\".\\\" // Fallback to CWD if not in a git repo\\n   285→\\t}\\n   286→\\tsettingsPath := filepath.Join(repoRoot, \\\".factory\\\", FactorySettingsFileName)\\n   287→\\tdata, err := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   288→\\tif err != nil {\\n   289→\\t\\treturn nil //nolint:nilerr // No settings file means nothing to uninstall\\n   290→\\t}\\n   291→\\n   292→\\tvar rawSettings map[string]json.RawMessage\\n   293→\\tif err := json.Unmarshal(data, &rawSettings); err != nil {\\n   294→\\t\\treturn fmt.Errorf(\\\"failed to parse settings.json: %w\\\", err)\\n   295→\\t}\\n   296→\\n   297→\\t// rawHooks preserves unknown hook types\\n   298→\\tvar rawHooks map[string]json.RawMessage\\n   299→\\tif hooksRaw, ok := rawSettings[\\\"hooks\\\"]; ok {\\n   300→\\t\\tif err := json.Unmarshal(hooksRaw, &rawHooks); err != nil {\\n   301→\\t\\t\\treturn fmt.Errorf(\\\"failed to parse hooks: %w\\\", err)\\n   302→\\t\\t}\\n   303→\\t}\\n   304→\\tif rawHooks == nil {\\n   305→\\t\\trawHooks = make(map[string]json.RawMessage)\\n   306→\\t}\\n   307→\\n   308→\\t// Parse only the hook types we need to modify\\n   309→\\tvar sessionStart, sessionEnd, stop, userPromptSubmit, preToolUse, postToolUse, preCompact []FactoryHookMatcher\\n   310→\\tparseHookType(rawHooks, \\\"SessionStart\\\", &sessionStart)\\n   311→\\tparseHookType(rawHooks, \\\"SessionEnd\\\", &sessionEnd)\\n   312→\\tparseHookType(rawHooks, \\\"Stop\\\", &stop)\\n   313→\\tparseHookType(rawHooks, \\\"UserPromptSubmit\\\", &userPromptSubmit)\\n   314→\\tparseHookType(rawHooks, \\\"PreToolUse\\\", &preToolUse)\\n   315→\\tparseHookType(rawHooks, \\\"PostToolUse\\\", &postToolUse)\\n   316→\\tparseHookType(rawHooks, \\\"PreCompact\\\", &preCompact)\\n   317→\\n   318→\\t// Remove Entire hooks from all hook types\\n   319→\\tsessionStart = removeEntireHooks(sessionStart)\\n   320→\\tsessionEnd = removeEntireHooks(sessionEnd)\\n   321→\\tstop = removeEntireHooks(stop)\\n   322→\\tuserPromptSubmit = removeEntireHooks(userPromptSubmit)\\n   323→\\tpreToolUse = removeEntireHooksFromMatchers(preToolUse)\\n   324→\\tpostToolUse = removeEntireHooksFromMatchers(postToolUse)\\n   325→\\tpreCompact = removeEntireHooks(preCompact)\\n   326→\\n   327→\\t// Marshal modified hook types back to rawHooks\\n   328→\\tmarshalHookType(rawHooks, \\\"SessionStart\\\", sessionStart)\\n   329→\\tmarshalHookType(rawHooks, \\\"SessionEnd\\\", sessionEnd)\\n   330→\\tmarshalHookType(rawHooks, \\\"Stop\\\", stop)\\n   331→\\tmarshalHookType(rawHooks, \\\"UserPromptSubmit\\\", userPromptSubmit)\\n   332→\\tmarshalHookType(rawHooks, \\\"PreToolUse\\\", preToolUse)\\n   333→\\tmarshalHookType(rawHooks, \\\"PostToolUse\\\", postToolUse)\\n   334→\\tmarshalHookType(rawHooks, \\\"PreCompact\\\", preCompact)\\n   335→\\n   336→\\t// Also remove the metadata deny rule from permissions\\n   337→\\tvar rawPermissions map[string]json.RawMessage\\n   338→\\tif permRaw, ok := rawSettings[\\\"permissions\\\"]; ok {\\n   339→\\t\\tif err := json.Unmarshal(permRaw, &rawPermissions); err != nil {\\n   340→\\t\\t\\t// If parsing fails, just skip permissions cleanup\\n   341→\\t\\t\\trawPermissions = nil\\n   342→\\t\\t}\\n   343→\\t}\\n   344→\\n   345→\\tif rawPermissions != nil {\\n   346→\\t\\tif denyRaw, ok := rawPermissions[\\\"deny\\\"]; ok {\\n   347→\\t\\t\\tvar denyRules []string\\n   348→\\t\\t\\tif err := json.Unmarshal(denyRaw, &denyRules); err == nil {\\n   349→\\t\\t\\t\\t// Filter out the 