eturns interface; error is acceptable to ignore for default\\n   171→func Default() Agent {\\n   172→\\ta, _ := Get(DefaultAgentName)\\n   173→\\treturn a\\n   174→}\\n   175→\"}]},\"uuid\":\"d75bf093-c1d1-4170-913b-6c3aee685c0b\",\"timestamp\":\"2026-03-04T15:50:46.760Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"ab3c9e0a9cb8bcbad\"},\"toolUseID\":\"agent_msg_01PqEKyLvvfnycEJ3pSRsq8y\",\"parentToolUseID\":\"toolu_01DAiUEacnNGvAK5Tu4DFv4k\",\"uuid\":\"b272b66d-f51e-4d24-b8a4-0d52ee47afb8\",\"timestamp\":\"2026-03-04T15:50:46.787Z\"}\n{\"parentUuid\":\"b272b66d-f51e-4d24-b8a4-0d52ee47afb8\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"a1a5082c-34f9-4b1f-af70-2870eacef097\",\"version\":\"2.1.68\",\"gitBranch\":\"nodo/external-plugins\",\"slug\":\"cozy-wandering-wall\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-04T15:50:46.805Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01VBD2JsPXgHNxhNnUWf8VKi\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01XFgdPhkRKsnPF2yNw5yrv1\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/nodo/work/cli/cmd/entire/cli/agent/types.go\",\"limit\":80},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":7,\"cache_creation_input_tokens\":564,\"cache_read_input_tokens\":50922,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":564},\"output_tokens\":5,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYiJhwo8SF8hLRmeTJrnX\",\"uuid\":\"562fee99-5cba-4d4b-a37c-bb12d671c054\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"ab3c9e0a9cb8bcbad\"},\"toolUseID\":\"agent_msg_01PqEKyLvvfnycEJ3pSRsq8y\",\"parentToolUseID\":\"toolu_01DAiUEacnNGvAK5Tu4DFv4k