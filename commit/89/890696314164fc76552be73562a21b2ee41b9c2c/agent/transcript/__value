 Each method invokes a subcommand on the binary and parses the JSON response.\\n    21→type Agent struct {\\n    22→\\tbinaryPath string\\n    23→\\tinfo       *InfoResponse\\n    24→}\\n    25→\\n    26→// New creates an Agent by calling the binary's \\\"info\\\" subcommand\\n    27→// to cache its metadata. Returns an error if the binary cannot be invoked or returns\\n    28→// invalid/incompatible protocol data.\\n    29→func New(binaryPath string) (*Agent, error) {\\n    30→\\tea := &Agent{binaryPath: binaryPath}\\n    31→\\n    32→\\tstdout, err := ea.run(context.Background(), nil, \\\"info\\\")\\n    33→\\tif err != nil {\\n    34→\\t\\treturn nil, fmt.Errorf(\\\"info: %w\\\", err)\\n    35→\\t}\\n    36→\\n    37→\\tvar info InfoResponse\\n    38→\\tif err := json.Unmarshal(stdout, &info); err != nil {\\n    39→\\t\\treturn nil, fmt.Errorf(\\\"info: invalid JSON: %w\\\", err)\\n    40→\\t}\\n    41→\\n    42→\\tif info.ProtocolVersion != ProtocolVersion {\\n    43→\\t\\treturn nil, fmt.Errorf(\\\"protocol version mismatch: binary reports %d, expected %d\\\",\\n    44→\\t\\t\\tinfo.ProtocolVersion, ProtocolVersion)\\n    45→\\t}\\n    46→\\n    47→\\tea.info = &info\\n    48→\\treturn ea, nil\\n    49→}\\n    50→\\n    51→// Info returns the cached info response.\\n    52→func (e *Agent) Info() *InfoResponse {\\n    53→\\treturn e.info\\n    54→}\\n    55→\\n    56→// --- Agent interface: Identity ---\\n    57→\\n    58→func (e *Agent) Name() types.AgentName {\\n    59→\\treturn types.AgentName(e.info.Name)\\n    60→}\\n    61→\\n    62→func (e *Agent) Type() types.AgentType {\\n    63→\\treturn types.AgentType(e.info.Type)\\n    64→}\\n    65→\\n    66→func (e *Agent) Description() string {\\n    67→\\treturn e.info.Description\\n    68→}\\n    69→\\n    70→func (e *Agent) IsPreview() bool {\\n    71→\\treturn e.info.IsPreview\\n    72→}\\n    73→\\n    74→func (e *Agent) DetectPresence(ctx context.Context) (bool, error) {\\n    75→\\tstdout, err := e.run(ctx, nil, \\\"detect\\\")\\n    76→\\tif err != nil {\\n    77→\\t\\treturn false, fmt.Errorf(\\\"detect: %w\\\", err)\\n    78→\\t}\\n    79→\\tvar resp DetectResponse\\n    80→\\tif err := json.Unmarshal(stdout, &resp); err != nil {\\n    81→\\t\\treturn false, fmt.Errorf(\\\"detect: invalid JSON: %w\\\", err)\\n    82→\\t}\\n    83→\\treturn resp.Present, nil\\n    84→}\\n    85→\\n    86→func (e *Agent) ProtectedDirs() []string {\\n    87→\\treturn e.info.ProtectedDirs\\n    88→}\\n    89→\\n    90→// --- Agent interface: Transcript Storage ---\\n    91→\\n    92→func (e *Agent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    93→\\treturn e.run(context.Background(), nil, \\\"read-transcript\\\", \\\"--session-ref\\\", sessionRef)\\n    94→}\\n    95→\\n    96→func (e *Agent) ChunkTranscript(ctx context.Context, content []byte, maxSize int) ([][]byte, error) {\\n    97→\\tstdout, err := e.run(ctx, content, \\\"chunk-transcript\\\", \\\"--max-size\\\", strconv.Itoa(maxSize))\\n    98→\\tif err != nil {\\n    99→\\t\\treturn nil, fmt.Errorf(\\\"chunk-transcript: %w\\\", err)\\n   100→\\t}\\n   101→\\tvar resp ChunkResponse\\n   102→\\tif err := json.Unmarshal(stdout, &resp); err != nil {\\n   103→\\t\\treturn nil, fmt.Errorf(\\\"chunk-transcript: invalid JSON: %w\\\", err)\\n   104→\\t}\\n   105→\\treturn resp.Chunks, nil\\n   106→}\\n   107→\\n   108→func (e *Agent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n   109→\\tinput, err := json.Marshal(ChunkResponse{Chunks: chunks})\\n   110→\\tif err != nil {\\n   111→\\t\\treturn nil, fmt.Errorf(\\\"reassemble-transcript: marshal: %w\\\", err)\\n   112→\\t}\\n   113→\\treturn e.run(context.Background(), input, \\\"reassemble-transcript\\\")\\n   114→}\\n   115→\\n   116→// --- Agent interface: Legacy methods ---\\n   117→\\n   118→func (e *Agent) GetSessionID(input *agent.HookInput) string {\\n   119→\\tdata, err := marshalHookInput(input)\\n   120→\\tif err != nil {\\n   121→\\t\\treturn \\\"\\\"\