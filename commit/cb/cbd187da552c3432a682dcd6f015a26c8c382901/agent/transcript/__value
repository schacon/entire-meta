}\\n    34→func (a *OpenCodeAgent) Description() string     { return \\\"OpenCode - AI-powered terminal coding agent\\\" }\\n    35→func (a *OpenCodeAgent) IsPreview() bool         { return true }\\n    36→func (a *OpenCodeAgent) ProtectedDirs() []string { return []string{\\\".opencode\\\"} }\\n    37→\\n    38→func (a *OpenCodeAgent) DetectPresence() (bool, error) {\\n    39→\\trepoRoot, err := paths.RepoRoot()\\n    40→\\tif err != nil {\\n    41→\\t\\trepoRoot = \\\".\\\"\\n    42→\\t}\\n    43→\\t// Check for .opencode directory or opencode.json config\\n    44→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\".opencode\\\")); err == nil {\\n    45→\\t\\treturn true, nil\\n    46→\\t}\\n    47→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\"opencode.json\\\")); err == nil {\\n    48→\\t\\treturn true, nil\\n    49→\\t}\\n    50→\\treturn false, nil\\n    51→}\\n    52→\\n    53→// --- Transcript Storage ---\\n    54→\\n    55→func (a *OpenCodeAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    56→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    57→\\tif err != nil {\\n    58→\\t\\treturn nil, fmt.Errorf(\\\"failed to read opencode transcript: %w\\\", err)\\n    59→\\t}\\n    60→\\treturn data, nil\\n    61→}\\n    62→\\n    63→func (a *OpenCodeAgent) ChunkTranscript(content []byte, maxSize int) ([][]byte, error) {\\n    64→\\t// OpenCode uses JSON format (like Gemini). Parse and split by messages.\\n    65→\\tif len(content) <= maxSize {\\n    66→\\t\\treturn [][]byte{content}, nil\\n    67→\\t}\\n    68→\\n    69→\\tvar transcript Transcript\\n    70→\\tif err := json.Unmarshal(content, &transcript); err != nil {\\n    71→\\t\\t// Fallback to JSONL chunking if not valid JSON\\n    72→\\t\\tchunks, chunkErr := agent.ChunkJSONL(content, maxSize)\\n    73→\\t\\tif chunkErr != nil {\\n    74→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk transcript as JSONL: %w\\\", chunkErr)\\n    75→\\t\\t}\\n    76→\\t\