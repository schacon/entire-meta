ageStore = new Map<string, any>()\\n    19→  // partStore: keyed by message ID, stores accumulated parts from message.part.updated events\\n    20→  const partStore = new Map<string, any[]>()\\n    21→  let currentSessionID: string | null = null\\n    22→\\n    23→  // Ensure transcript directory exists\\n    24→  await $`mkdir -p ${transcriptDir}`.quiet().nothrow()\\n    25→\\n    26→  /**\\n    27→   * Pipe JSON payload to an entire hooks command.\\n    28→   * Errors are logged but never thrown — plugin failures must not crash OpenCode.\\n    29→   */\\n    30→  async function callHook(hookName: string, payload: Record<string, unknown>) {\\n    31→    try {\\n    32→      const json = JSON.stringify(payload)\\n    33→      await $`echo ${json} | ${ENTIRE_CMD} hooks opencode ${hookName}`.quiet().nothrow()\\n    34→    } catch {\\n    35→      // Silently ignore — plugin failures must not crash OpenCode\\n    36→    }\\n    37→  }\\n    38→\\n    39→  /** Extract text content from a list of parts. */\\n    40→  function textFromParts(parts: any[]): string {\\n    41→    return parts\\n    42→      .filter((p: any) => p.type === \\\"text\\\")\\n    43→      .map((p: any) => p.text ?? \\\"\\\")\\n    44→      .join(\\\"\\\\n\\\")\\n    45→  }\\n    46→\\n    47→  /** Format a message for the transcript using its accumulated parts. */\\n    48→  function formatMessageFromStore(msg: any) {\\n    49→    const parts = partStore.get(msg.id) ?? []\\n    50→    return {\\n    51→      id: msg.id,\\n    52→      role: msg.role,\\n    53→      content: textFromParts(parts),\\n    54→      time: msg.time,\\n    55→      ...(msg.role === \\\"assistant\\\" ? {\\n    56→        tokens: msg.tokens,\\n    57→        cost: msg.cost,\\n    58→        parts: parts.map((p: any) => ({\\n    59→          type: p.type,\\n    60→          ...(p.type === \\\"text\\\" ? { text: p.text } : {}),\\n    61→          ...(p.type === \\\"tool\\\" ? { tool: p.tool, callID: p.callID, state: p.state }