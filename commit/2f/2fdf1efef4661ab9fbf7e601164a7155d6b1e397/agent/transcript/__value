unc(cmd *cobra.Command, _ []string) error {\\n    53→\\t\\t\\t// Check if we're in a git repository first - this is a prerequisite error,\\n    54→\\t\\t\\t// not a usage error, so we silence Cobra's output and use SilentError\\n    55→\\t\\t\\t// to prevent duplicate error output in main.go\\n    56→\\t\\t\\tif _, err := paths.WorktreeRoot(); err != nil {\\n    57→\\t\\t\\t\\tfmt.Fprintln(cmd.ErrOrStderr(), \\\"Not a git repository. Please run 'entire enable' from within a git repository.\\\")\\n    58→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n    59→\\t\\t\\t}\\n    60→\\n    61→\\t\\t\\tif err := validateSetupFlags(opts.UseLocalSettings, opts.UseProjectSettings); err != nil {\\n    62→\\t\\t\\t\\treturn err\\n    63→\\t\\t\\t}\\n    64→\\n    65→\\t\\t\\t// Warn if repo has no commits yet\\n    66→\\t\\t\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n    67→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Note: This repository has no commits yet. Entire will be configured, but\\\")\\n    68→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"session checkpoints won't work until you create your first commit.\\\")\\n    69→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout())\\n    70→\\t\\t\\t}\\n    71→\\n    72→\\t\\t\\t// Non-interactive mode if --agent flag is provided\\n    73→\\t\\t\\tif cmd.Flags().Changed(\\\"agent\\\") && agentName == \\\"\\\" {\\n    74→\\t\\t\\t\\tprintMissingAgentError(cmd.ErrOrStderr())\\n    75→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n    76→\\t\\t\\t}\\n    77→\\n    78→\\t\\t\\tif agentName != \\\"\\\" {\\n    79→\\t\\t\\t\\tag, err := agent.Get(agent.AgentName(agentName))\\n    80→\\t\\t\\t\\tif err != nil {\\n    81→\\t\\t\\t\\t\\tprintWrongAgentError(cmd.ErrOrStderr(), agentName)\\n    82→\\t\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"wrong agent name\\\"))\\n    83→\\t\\t\\t\\t}\\n    84→\\t\\t\\t\\t// --agent is a targeted operation: set up this specific agent without\\n    85→\\t\\t\\t\\t// affecting other agents. Unlike the interactive path, it does not\\n    86→\\t\\t\\t\\t// uninstall hooks for other previously-enabled agents.\\n    87→\\t\\t\\t\\treturn setupAgentHooksNonInteractive(cmd.OutOrStdout(), ag, opts)\\n    88→\\t\\t\\t}\\n    89→\\t\\t\\t// Detect or prompt for agents\\n    90→\\t\\t\\tagents, err := detectOrSelectAgent(cmd.OutOrStdout(), nil)\\n    91→\\t\\t\\tif err != nil {\\n    92→\\t\\t\\t\\treturn fmt.Errorf(\\\"agent selection failed: %w\\\", err)\\n    93→\\t\\t\\t}\\n    94→\\n    95→\\t\\t\\treturn runEnableInteractive(cmd.OutOrStdout(), agents, opts)\\n    96→\\t\\t},\\n    97→\\t}\\n    98→\\n    99→\\tcmd.Flags().BoolVar(&opts.LocalDev, \\\"local-dev\\\", false, \\\"Use go run instead of entire binary for hooks\\\")\\n   100→\\tcmd.Flags().MarkHidden(\\\"local-dev\\\") //nolint:errcheck,gosec // flag is defined above\\n   101→\\tcmd.Flags().BoolVar(&ignoreUntracked, \\\"ignore-untracked\\\", false, \\\"Commit all new files without tracking pre-existing untracked files\\\")\\n   102→\\tcmd.Flags().MarkHidden(\\\"ignore-untracked\\\") //nolint:errcheck,gosec // flag is defined above\\n   103→\\tcmd.Flags().BoolVar(&opts.UseLocalSettings, \\\"local\\\", false, \\\"Write settings to .entire/settings.local.json instead of .entire/settings.json\\\")\\n   104→\\tcmd.Flags().BoolVar(&opts.UseProjectSettings, \\\"project\\\", false, \\\"Write settings to .entire/settings.json even if it already exists\\\")\\n   105→\\tcmd.Flags().StringVar(&agentName, \\\"agent\\\", \\\"\\\", \\\"Agent to set up hooks for (e.g., claude-code, gemini, opencode). Enables non-interactive mode.\\\")\\n   106→\\tcmd.Flags().BoolVarP(&opts.ForceHooks, \\\"force\\\", \\\"f\\\", false, \\\"Force reinstall hooks (removes existing Entire hooks first)\\\")\\n   107→\\tcmd.Flags().BoolVar(&opts.SkipPushSessions, \\\"skip-push-sessions\\\", false, \\\"Disable automatic pushing of session logs on git push\\\")\\n   108→\\tcmd.Flags().BoolVar(&opts.Telemetry, \\\"telemetry\\\", true, \\\"Enable anonymous usage analytics\\\")\\n   109→\\tcmd.Flags().BoolVar(&opts.AbsoluteGitHookPath, \\\"absolute-git-hook-path\\\", false, \\\"Embed full binary path in git hooks (for GUI git clients that don't source shell profiles)\\\")\\n   110→\\n   111→\\t// Provide a helpful error when --agent is used without a value\\n   112→\\tdefaultFlagErr := cmd.FlagErrorFunc()\\n   113→\\tcmd.SetFlagErrorFunc(func(c *cobra.Command, err error) error {\\n   114→\\t\\tvar valErr *pflag.ValueRequiredError\\n   115→\\t\\tif errors.As(err, &valErr) && valErr.GetSpecifiedName() == \\\"agent\\\" {\\n   116→\\t\\t\\tprintMissingAgentError(c.ErrOrStderr())\\n   117→\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n   118→\\t\\t}\\n   119→\\t\\treturn defaultFlagErr(c, err)\\n   120→\\t})\\n   121→\\n   122→\\t// Add subcommands for automation/testing\\n   123→\\tcmd.AddCommand(newSetupGitHookCmd())\\n   124→\\n   125→\\treturn cmd\\n   126→}\\n   127→\\n   128→func newDisableCmd() *cobra.Command {\\n   129→\\tvar useProjectSettings bool\\n   130→\\tvar uninstall bool\\n   131→\\tvar force bool\\n   132→\\n   133→\\tcmd := &cobra.Command{\\n   134→\\t\\tUse:   \\\"disable\\\",\\n   135→\\t\\tShort: \\\"Disable Entire in current project\\\",\\n   136→\\t\\tLong: `Disable Entire integrations in the current project.\\n   137→\\n   138→By default, this command will disable Entire. Hooks will exit silently and commands will\\n   139→show a disabled message.\\n   140→\\n   141→To completely remove Entire integrations from this repository, use --uninstall:\\n   142→  - .entire/ directory (settings, logs, metadata)\\n   143→  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\n   144→  - Session state files (.git/entire-sessions/)\\n   145→  - Shadow branches (entire/<hash>)\\n   146→  - Agent hooks`,\\n   147→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   148→\\t\\t\\tif uninstall {\\n   149→\\t\\t\\t\\treturn runUninstall(cmd.OutOrStdout(), cmd.ErrOrStderr(), force)\\n   150→\\t\\t\\t}\\n   151→\\t\\t\\treturn runDisable(cmd.OutOrStdout(), useProjectSettings)\\n   152→\\t\\t},\\n   153→\\t}\\n   154→\\n   155→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Update .entire/settings.json instead of .entire/settings.local.json\\\")\\n   156→\\tcmd.Flags().BoolVar(&uninstall, \\\"uninstall\\\", false, \\\"Completely remove Entire from this repository\\\")\\n   157→\\tcmd.Flags().BoolVar(&force, \\\"force\\\", false, \\\"Skip confirmation prompt (use with --uninstall)\\\")\\n   158→\\n   159→\\treturn cmd\\n   160→}\\n   161→\\n   162→// runEnableInteractive runs the interactive enable flow.\\n   163→// agents must be provided by the caller (via detectOrSelectAgent).\\n   164→func runEnableInteractive(w io.Writer, agents []agent.Agent, opts EnableOptions) error {\\n   165→\\t// Uninstall hooks for agents that were previously active but are no longer selected\\n   166→\\tif err := uninstallDeselectedAgentHooks(w, agents); err != nil {\\n   167→\\t\\treturn fmt.Errorf(\\\"failed to clean up deselected agents: %w\\\", err)\\n   168→\\t}\\n   169→\\n   170→\\t// Setup agent hooks for all selected agents\\n   171→\\tfor _, ag := range agents {\\n   172→\\t\\tif _, err := setupAgentHooks(ag, opts.LocalDev, opts.ForceHooks); err != nil {\\n   173→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   174→\\t\\t}\\n   175→\\t}\\n   176→\\n   177→\\t// Setup .entire directory\\n   178→\\tif _, err := setupEntireDirectory(); err != nil {\\n   179→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   180→\\t}\\n   181→\\n   182→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   183→\\tsettings, err := LoadEntireSettings()\\n   184→\\tif err != nil {\\n   185→\\t\\t// If we can't load, start with defaults\\n   186→\\t\\tsettings = &EntireSettings{}\\n   187→\\t}\\n   188→\\t// Update the specific fields\\n   189→\\tsettings.Enabled = true\\n   190→\\tif opts.LocalDev {\\n   191→\\t\\tsettings.LocalDev = true\\n   192→\\t}\\n   193→\\tif opts.AbsoluteGitHookPath {\\n   194→\\t\\tsettings.AbsoluteGitHookPath = true\\n   195→\\t}\\n   196→\\n   197→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   198→\\tif opts.SkipPushSessions {\\n   199→\\t\\tif settings.StrategyOptions == nil {\\n   200→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   201→\\t\\t}\\n   202→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   203→\\t}\\n   204→\\n   205→\\t// Determine which settings file to write to\\n   206→\\t// First run always creates settings.json (no prompt)\\n   207→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   208→\\tif err != nil {\\n   209→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   210→\\t}\\n   211→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, opts.UseLocalSettings, opts.UseProjectSettings)\\n   212→\\n   213→\\tif showNotification {\\n   214→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   215→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   216→\\t}\\n   217→\\n   218→\\t// Helper to save settings to the appropriate file\\n   219→\\tsaveSettings := func() error {\\n   220→\\t\\tif shouldUseLocal {\\n   221→\\t\\t\\treturn SaveEntireSettingsLocal(settings)\\n   222→\\t\\t}\\n   223→\\t\\treturn SaveEntireSettings(settings)\\n   224→\\t}\\n   225→\\n   226→\\t// Save settings before telemetry prompt so config is persisted even if the user cancels\\n   227→\\tif err := saveSettings(); err != nil {\\n   228→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   229→\\t}\\n   230→\\n   231→\\tif _, err := strategy.InstallGitHook(true, opts.LocalDev, opts.AbsoluteGitHookPath); err != nil {\\n   232→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   233→\\t}\\n   234→\\tstrategy.CheckAndWarnHookManagers(w, opts.LocalDev, opts.AbsoluteGitHookPath)\\n   235→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   236→\\n   237→\\tconfigDisplay := configDisplayProject\\n   238→\\tif shouldUseLocal {\\n   239→\\t\\tconfigDisplay = configDisplayLocal\\n   240→\\t}\\n   241→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   242→\\n   243→\\t// Ask about telemetry consent (only if not already asked)\\n   244→\\tfmt.Fprintln(w)\\n   245→\\tif err := promptTelemetryConsent(settings, opts.Telemetry); err != nil {\\n   246→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   247→\\t}\\n   248→\\t// Save again to persist telemetry choice\\n   249→\\tif err := saveSettings(); err != nil {\\n   250→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   251→\\t}\\n   252→\\n   253→\\tif err := strategy.EnsureSetup(); err != nil {\\n   254→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   255→\\t}\\n   256→\\n   257→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   258→\\n   259→\\treturn nil\\n   260→}\\n   261→\\n   262→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   263→func runEnable(w io.Writer) error {\\n   264→\\tsettings, err := LoadEntireSettings()\\n   265→\\tif err != nil {\\n   266→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   267→\\t}\\n   268→\\n   269→\\tsettings.Enabled = true\\n   270→\\tif err := SaveEntireSettings(settings); err != nil {\\n   271→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   272→\\t}\\n   273→\\n   274→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   275→\\treturn nil\\n   276→}\\n   277→\\n   278→func runDisable(w io.Writer, useProjectSettings bool) error {\\n   279→\\tsettings, err := LoadEntireSettings()\\n   280→\\tif err != nil {\\n   281→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   282→\\t}\\n   283→\\n   284→\\tsettings.Enabled = false\\n   285→\\n   286→\\t// If --project flag is specified, always write to project settings\\n   287→\\tif useProjectSettings {\\n   288→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   289→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   290→\\t\\t}\\n   291→\\t} else {\\n   292→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   293→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   294→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   295→\\t\\t}\\n   296→\\t}\\n   297→\\n   298→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   299→\\treturn nil\\n   300→}\\n   301→\\n   302→// DisabledMessage is the message shown when Entire is disabled\\n   303→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   304→\\n   305→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   306→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   307→// On error reading settings, defaults to enabled (returns false).\\n   308→func checkDisabledGuard(w io.Writer) bool {\\n   309→\\tenabled, err := IsEnabled()\\n   310→\\tif err != nil {\\n   311→\\t\\t// Default to enabled on error\\n   312→\\t\\treturn false\\n   313→\\t}\\n   314→\\tif !enabled {\\n   315→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   316→\\t\\treturn true\\n   317→\\t}\\n   318→\\treturn false\\n   319→}\\n   320→\\n   321→// uninstallDeselectedAgentHooks removes hooks for agents that were previously\\n   322→// installed but are not in the selected list. This handles the case where a user\\n   323→// re-runs `entire enable` and deselects an agent.\\n   324→func uninstallDeselectedAgentHooks(w io.Writer, selectedAgents []agent.Agent) error {\\n   325→\\tinstalledNames := GetAgentsWithHooksInstalled()\\n   326→\\tif len(installedNames) == 0 {\\n   327→\\t\\treturn nil\\n   328→\\t}\\n   329→\\n   330→\\tselectedSet := make(map[agent.AgentName]struct{}, len(selectedAgents))\\n   331→\\tfor _, ag := range selectedAgents {\\n   332→\\t\\tselectedSet[ag.Name()] = struct{}{}\\n   333→\\t}\\n   334→\\n   335→\\tvar errs []error\\n   336→\\tfor _, name := range installedNames {\\n   337→\\t\\tif _, selected := selectedSet[name]; selected {\\n   338→\\t\\t\\tcontinue\\n   339→\\t\\t}\\n   340→\\t\\tag, err := agent.Get(name)\\n   341→\\t\\tif err != nil {\\n   342→\\t\\t\\tcontinue\\n   343→\\t\\t}\\n   344→\\t\\thookAgent, ok := ag.(agent.HookSupport)\\n   345→\\t\\tif !ok {\\n   346→\\t\\t\\tcontinue\\n   347→\\t\\t}\\n   348→\\t\\tif err := hookAgent.UninstallHooks(); err != nil {\\n   349→\\t\\t\\terrs = append(errs, fmt.Errorf(\\\"failed to uninstall %s hooks: %w\\\", ag.Type(), err))\\n   350→\\t\\t} else {\\n   351→\\t\\t\\tfmt.Fprintf(w, \\\"Removed %s hooks\\\\n\\\", ag.Type())\\n   352→\\t\\t}\\n   353→\\t}\\n   354→\\treturn errors.Join(errs...)\\n   355→}\\n   356→\\n   357→// setupAgentHooks sets up hooks for a given agent.\\n   358→// Returns the number of hooks installed (0 if already installed).\\n   359→func setupAgentHooks(ag agent.Agent, localDev, forceHooks bool) (int, error) {\\n   360→\\thookAgent, ok := ag.(agent.HookSupport)\\n   361→\\tif !ok {\\n   362→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   363→\\t}\\n   364→\\n   365→\\tcount, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   366→\\tif err != nil {\\n   367→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   368→\\t}\\n   369→\\n   370→\\treturn count, nil\\n   371→}\\n   372→\\n   373→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   374→// Returns the detected/selected agents and any error.\\n   375→//\\n   376→// On first run (no hooks installed):\\n   377→//   - Single detected agent: used automatically\\n   378→//   - Multiple/no detected agents: interactive multi-select prompt\\n   379→//\\n   380→// On re-run (hooks already installed):\\n   381→//   - Always shows the interactive multi-select\\n   382→//   - Pre-selects only agents that have hooks installed (respects prior deselection)\\n   383→//\\n   384→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   385→// It receives available agent names and returns the selected names.\\n   386→func detectOrSelectAgent(w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   387→\\t// Check for agents with hooks already installed (re-run detection)\\n   388→\\tinstalledAgentNames := GetAgentsWithHooksInstalled()\\n   389→\\thasInstalledHooks := len(installedAgentNames) > 0\\n   390→\\n   391→\\t// Try auto-detection\\n   392→\\tdetected := agent.DetectAll()\\n   393→\\n   394→\\t// First run: use existing auto-detect shortcuts\\n   395→\\tif !hasInstalledHooks {\\n   396→\\t\\tswitch {\\n   397→\\t\\tcase len(detected) == 1:\\n   398→\\t\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   399→\\t\\t\\treturn detected, nil\\n   400→\\n   401→\\t\\tcase len(detected) > 1:\\n   402→\\t\\t\\tagentTypes := make([]string, 0, len(detected))\\n   403→\\t\\t\\tfor _, ag := range detected {\\n   404→\\t\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   405→\\t\\t\\t}\\n   406→\\t\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   407→\\t\\t\\tfmt.Fprintln(w)\\n   408→\\t\\t}\\n   409→\\t}\\n   410→\\n   411→\\t// Check if we can prompt interactively\\n   412→\\tif !canPromptInteractively() {\\n   413→\\t\\tif hasInstalledHooks {\\n   414→\\t\\t\\t// Re-run without TTY — keep currently installed agents\\n   415→\\t\\t\\tagents := make([]agent.Agent, 0, len(installedAgentNames))\\n   416→\\t\\t\\tfor _, name := range installedAgentNames {\\n   417→\\t\\t\\t\\tag, err := agent.Get(name)\\n   418→\\t\\t\\t\\tif err != nil {\\n   419→\\t\\t\\t\\t\\tcontinue\\n   420→\\t\\t\\t\\t}\\n   421→\\t\\t\\t\\tagents = append(agents, ag)\\n   422→\\t\\t\\t}\\n   423→\\t\\t\\treturn agents, nil\\n   424→\\t\\t}\\n   425→\\t\\tif len(detected) > 0 {\\n   426→\\t\\t\\treturn detected, nil\\n   427→\\t\\t}\\n   428→\\t\\tdefaultAgent := agent.Default()\\n   429→\\t\\tif defaultAgent == nil {\\n   430→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   431→\\t\\t}\\n   432→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   433→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   434→\\t}\\n   435→\\n   436→\\tif !hasInstalledHooks && len(detected) == 0 {\\n   437→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., .claude, .gemini, or .opencode directory).\\\")\\n   438→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   439→\\t\\tfmt.Fprintln(w)\\n   440→\\t}\\n   441→\\n   442→\\t// Build pre-selection set.\\n   443→\\t// On re-run: only pre-select agents with hooks installed (respect prior deselection).\\n   444→\\t// On first run: pre-select all detected agents.\\n   445→\\tpreSelectedSet := make(map[agent.AgentName]struct{})\\n   446→\\tif hasInstalledHooks {\\n   447→\\t\\tfor _, name := range installedAgentNames {\\n   448→\\t\\t\\tpreSelectedSet[name] = struct{}{}\\n   449→\\t\\t}\\n   450→\\t} else {\\n   451→\\t\\tfor _, ag := range detected {\\n   452→\\t\\t\\tpreSelectedSet[ag.Name()] = struct{}{}\\n   453→\\t\\t}\\n   454→\\t}\\n   455→\\n   456→\\t// Build options from registered agents\\n   457→\\tagentNames := agent.List()\\n   458→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   459→\\tfor _, name := range agentNames {\\n   460→\\t\\tag, err := agent.Get(name)\\n   461→\\t\\tif err != nil {\\n   462→\\t\\t\\tcontinue\\n   463→\\t\\t}\\n   464→\\t\\t// Only show agents that support hooks\\n   465→\\t\\tif _, ok := ag.(agent.HookSupport); !ok {\\n   466→\\t\\t\\tcontinue\\n   467→\\t\\t}\\n   468→\\t\\topt := huh.NewOption(string(ag.Type()), string(name))\\n   469→\\t\\tif _, isPreSelected := preSelectedSet[name]; isPreSelected {\\n   470→\\t\\t\\topt = opt.Selected(true)\\n   471→\\t\\t}\\n   472→\\t\\toptions = append(options, opt)\\n   473→\\t}\\n   474→\\n   475→\\tif len(options) == 0 {\\n   476→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   477→\\t}\\n   478→\\n   479→\\t// Collect available agent names for the selector\\n   480→\\tavailableNames := make([]string, 0, len(options))\\n   481→\\tfor _, opt := range options {\\n   482→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   483→\\t}\\n   484→\\n   485→\\tvar selectedAgentNames []string\\n   486→\\tif selectFn != nil {\\n   487→\\t\\tvar err error\\n   488→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   489→\\t\\tif err != nil {\\n   490→\\t\\t\\treturn nil, err\\n   491→\\t\\t}\\n   492→\\t\\tif len(selectedAgentNames) == 0 {\\n   493→\\t\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   494→\\t\\t}\\n   495→\\t} else {\\n   496→\\t\\tform := NewAccessibleForm(\\n   497→\\t\\t\\thuh.NewGroup(\\n   498→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   499→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   500→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   501→\\t\\t\\t\\t\\tOptions(options...).\\n   502→\\t\\t\\t\\t\\tValidate(func(selected []string) error {\\n   503→\\t\\t\\t\\t\\t\\tif len(selected) == 0 {\\n   504→\\t\\t\\t\\t\\t\\t\\treturn errors.New(\\\"please select at least one agent\\\")\\n   505→\\t\\t\\t\\t\\t\\t}\\n   506→\\t\\t\\t\\t\\t\\treturn nil\\n   507→\\t\\t\\t\\t\\t}).\\n   508→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   509→\\t\\t\\t),\\n   510→\\t\\t)\\n   511→\\t\\tif err := form.Run(); err != nil {\\n   512→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   513→\\t\\t}\\n   514→\\t}\\n   515→\\n   516→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   517→\\tfor _, name := range selectedAgentNames {\\n   518→\\t\\tselectedAgent, err := agent.Get(agent.AgentName(name))\\n   519→\\t\\tif err != nil {\\n   520→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   521→\\t\\t}\\n   522→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   523→\\t}\\n   524→\\n   525→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   526→\\tfor _, ag := range selectedAgents {\\n   527→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   528→\\t}\\n   529→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   530→\\treturn selectedAgents, nil\\n   531→}\\n   532→\\n   533→// canPromptInteractively checks if we can show interactive prompts.\\n   534→// Returns false when running in CI, tests, or other non-interactive environments.\\n   535→func canPromptInteractively() bool {\\n   536→\\t// Check for test environment\\n   537→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   538→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   539→\\t}\\n   540→\\n   541→\\t// Check if /dev/tty is available\\n   542→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   543→\\tif err != nil {\\n   544→\\t\\treturn false\\n   545→\\t}\\n   546→\\t_ = tty.Close()\\n   547→\\treturn true\\n   548→}\\n   549→\\n   550→// printAgentError writes an error message followed by available agents and usage.\\n   551→func printAgentError(w io.Writer, message string) {\\n   552→\\tagents := agent.List()\\n   553→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   554→\\tfmt.Fprintln(w)\\n   555→\\tfor _, a := range agents {\\n   556→\\t\\tsuffix := \\\"\\\"\\n   557→\\t\\tif a == agent.DefaultAgentName {\\n   558→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   559→\\t\\t}\\n   560→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   561→\\t}\\n   562→\\tfmt.Fprintln(w)\\n   563→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   564→}\\n   565→\\n   566→// printMissingAgentError writes a helpful error listing available agents.\\n   567→func printMissingAgentError(w io.Writer) {\\n   568→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   569→}\\n   570→\\n   571→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   572→func printWrongAgentError(w io.Writer, name string) {\\n   573→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   574→}\\n   575→\\n   576→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   577→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   578→func setupAgentHooksNonInteractive(w io.Writer, ag agent.Agent, opts EnableOptions) error {\\n   579→\\tagentName := ag.Name()\\n   580→\\t// Check if agent supports hooks\\n   581→\\thookAgent, ok := ag.(agent.HookSupport)\\n   582→\\tif !ok {\\n   583→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   584→\\t}\\n   585→\\n   586→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   587→\\n   588→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   589→\\tinstalledHooks, err := hookAgent.InstallHooks(opts.LocalDev, opts.ForceHooks)\\n   590→\\tif err != nil {\\n   591→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   592→\\t}\\n   593→\\n   594→\\t// Setup .entire directory\\n   595→\\tif _, err := setupEntireDirectory(); err != nil {\\n   596→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   597→\\t}\\n   598→\\n   599→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   600→\\tsettings, err := LoadEntireSettings()\\n   601→\\tif err != nil {\\n   602→\\t\\t// If we can't load, start with defaults\\n   603→\\t\\tsettings = &EntireSettings{}\\n   604→\\t}\\n   605→\\tsettings.Enabled = true\\n   606→\\tif opts.LocalDev {\\n   607→\\t\\tsettings.LocalDev = true\\n   608→\\t}\\n   609→\\tif opts.AbsoluteGitHookPath {\\n   610→\\t\\tsettings.AbsoluteGitHookPath = true\\n   611→\\t}\\n   612→\\n   613→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   614→\\tif opts.SkipPushSessions {\\n   615→\\t\\tif settings.StrategyOptions == nil {\\n   616→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   617→\\t\\t}\\n   618→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   619→\\t}\\n   620→\\n   621→\\t// Handle telemetry for non-interactive mode\\n   622→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   623→\\tif !opts.Telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   624→\\t\\tf := false\\n   625→\\t\\tsettings.Telemetry = &f\\n   626→\\t}\\n   627→\\n   628→\\tif err := SaveEntireSettings(settings); err != nil {\\n   629→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   630→\\t}\\n   631→\\n   632→\\tif _, err := strategy.InstallGitHook(true, opts.LocalDev, opts.AbsoluteGitHookPath); err != nil {\\n   633→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   634→\\t}\\n   635→\\tstrategy.CheckAndWarnHookManagers(w, opts.LocalDev, opts.AbsoluteGitHookPath)\\n   636→\\n   637→\\tif installedHooks == 0 {\\n   638→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   639→\\t\\tif ag.IsPreview() {\\n   640→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   641→\\t\\t}\\n   642→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   643→\\t} else {\\n   644→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   645→\\t\\tif ag.IsPreview() {\\n   646→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   647→\\t\\t}\\n   648→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   649→\\t}\\n   650→\\n   651→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   652→\\n   653→\\tif err := strategy.EnsureSetup(); err != nil {\\n   654→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   655→\\t}\\n   656→\\n   657→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   658→\\n   659→\\treturn nil\\n   660→}\\n   661→\\n   662→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   663→func validateSetupFlags(useLocal, useProject bool) error {\\n   664→\\tif useLocal && useProject {\\n   665→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   666→\\t}\\n   667→\\treturn nil\\n   668→}\\n   669→\\n   670→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   671→// - Whether settings.json already exists\\n   672→// - The --local and --project flags\\n   673→// Returns (useLocal, showNotification).\\n   674→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   675→\\t// Explicit --local flag always uses local settings\\n   676→\\tif useLocal {\\n   677→\\t\\treturn true, false\\n   678→\\t}\\n   679→\\n   680→\\t// Explicit --project flag always uses project settings\\n   681→\\tif useProject {\\n   682→\\t\\treturn false, false\\n   683→\\t}\\n   684→\\n   685→\\t// No flags specified - check if settings file exists\\n   686→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   687→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   688→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   689→\\t\\treturn true, true\\n   690→\\t}\\n   691→\\n   692→\\t// Settings file doesn't exist - create it\\n   693→\\treturn false, false\\n   694→}\\n   695→\\n   696→// setupEntireDirectory creates the .entire directory and gitignore.\\n   697→// Returns true if the directory was created, false if it already existed.\\n   698→func setupEntireDirectory() (bool, error) { //nolint:unparam // already present in codebase\\n   699→\\t// Get absolute path for the .entire directory\\n   700→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   701→\\tif err != nil {\\n   702→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   703→\\t}\\n   704→\\n   705→\\t// Check if directory already exists\\n   706→\\tcreated := false\\n   707→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   708→\\t\\tcreated = true\\n   709→\\t}\\n   710→\\n   711→\\t// Create .entire directory\\n   712→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   713→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   714→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   715→\\t}\\n   716→\\n   717→\\t// Create/update .gitignore with all required entries\\n   718→\\tif err := strategy.EnsureEntireGitignore(); err != nil {\\n   719→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   720→\\t}\\n   721→\\n   722→\\treturn created, nil\\n   723→}\\n   724→\\n   725→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   726→func setupGitHook() error {\\n   727→\\ts, err := settings.Load()\\n   728→\\tlocalDev := err == nil && s.LocalDev\\n   729→\\tabsoluteHookPath := err == nil && s.AbsoluteGitHookPath\\n   730→\\tif _, err := strategy.InstallGitHook(false, localDev, absoluteHookPath); err != nil {\\n   731→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   732→\\t}\\n   733→\\tstrategy.CheckAndWarnHookManagers(os.Stderr, localDev, absoluteHookPath)\\n   734→\\treturn nil\\n   735→}\\n   736→\\n   737→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   738→func newSetupGitHookCmd() *cobra.Command {\\n   739→\\tcmd := &cobra.Command{\\n   740→\\t\\tUse:    \\\"git-hook\\\",\\n   741→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   742→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   743→\\t\\tRunE: func(_ *cobra.Command, _ []string) error {\\n   744→\\t\\t\\treturn setupGitHook()\\n   745→\\t\\t},\\n   746→\\t}\\n   747→\\n   748→\\treturn cmd\\n   749→}\\n   750→\\n   751→func newCurlBashPostInstallCmd() *cobra.Command {\\n   752→\\treturn &cobra.Command{\\n   753→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   754→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   755→\\t\\tHidden: true,\\n   756→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   757→\\t\\t\\tw := cmd.OutOrStdout()\\n   758→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   759→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   760→\\t\\t\\t}\\n   761→\\t\\t\\treturn nil\\n   762→\\t\\t},\\n   763→\\t}\\n   764→}\\n   765→\\n   766→// shellCompletionComment is the comment preceding the completion line\\n   767→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   768→\\n   769→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   770→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   771→\\n   772→// shellCompletionTarget returns the rc file path and completion lines for the\\n   773→// user's current shell.\\n   774→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   775→\\thome, err := os.UserHomeDir()\\n   776→\\tif err != nil {\\n   777→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   778→\\t}\\n   779→\\n   780→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   781→\\tswitch {\\n   782→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   783→\\t\\treturn \\\"Zsh\\\",\\n   784→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   785→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   786→\\t\\t\\tnil\\n   787→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   788→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   789→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   790→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   791→\\t\\t}\\n   792→\\t\\treturn \\\"Bash\\\",\\n   793→\\t\\t\\tbashRC,\\n   794→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   795→\\t\\t\\tnil\\n   796→\\tcase strings.Contains(shell, \\\"fish\\\"):\\n   797→\\t\\treturn \\\"Fish\\\",\\n   798→\\t\\t\\tfilepath.Join(home, \\\".config\\\", \\\"fish\\\", \\\"config.fish\\\"),\\n   799→\\t\\t\\t\\\"entire completion fish | source\\\",\\n   800→\\t\\t\\tnil\\n   801→\\tdefault:\\n   802→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   803→\\t}\\n   804→}\\n   805→\\n   806→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   807→// Only prompts if completion is not already configured.\\n   808→func promptShellCompletion(w io.Writer) error {\\n   809→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   810→\\tif err != nil {\\n   811→\\t\\tif errors.Is(err, errUnsupportedShell) {\\n   812→\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion not available for your shell. Supported: zsh, bash, fish.\\\\n\\\")\\n   813→\\t\\t\\treturn nil\\n   814→\\t\\t}\\n   815→\\t\\treturn fmt.Errorf(\\\"shell completion: %w\\\", err)\\n   816→\\t}\\n   817→\\n   818→\\tif isCompletionConfigured(rcFile) {\\n   819→\\t\\tfmt.Fprintf(w, \\\"✓ Shell completion already configured in %s\\\\n\\\", rcFile)\\n   820→\\t\\treturn nil\\n   821→\\t}\\n   822→\\n   823→\\tvar selected string\\n   824→\\tform := NewAccessibleForm(\\n   825→\\t\\thuh.NewGroup(\\n   826→\\t\\t\\thuh.NewSelect[string]().\\n   827→\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Enable shell completion? (detected: %s)\\\", shellName)).\\n   828→\\t\\t\\t\\tOptions(\\n   829→\\t\\t\\t\\t\\thuh.NewOption(\\\"Yes\\\", \\\"yes\\\"),\\n   830→\\t\\t\\t\\t\\thuh.NewOption(\\\"No\\\", \\\"no\\\"),\\n   831→\\t\\t\\t\\t).\\n   832→\\t\\t\\t\\tValue(&selected),\\n   833→\\t\\t),\\n   834→\\t)\\n   835→\\n   836→\\tif err := form.Run(); err != nil {\\n   837→\\t\\t//nolint:nilerr // User cancelled - not a fatal error, just skip\\n   838→\\t\\treturn nil\\n   839→\\t}\\n   840→\\n   841→\\tif selected != \\\"yes\\\" {\\n   842→\\t\\treturn nil\\n   843→\\t}\\n   844→\\n   845→\\tif err := appendShellCompletion(rcFile, completionLine); err != nil {\\n   846→\\t\\treturn fmt.Errorf(\\\"failed to update %s: %w\\\", rcFile, err)\\n   847→\\t}\\n   848→\\n   849→\\tfmt.Fprintf(w, \\\"✓ Shell completion added to %s\\\\n\\\", rcFile)\\n   850→\\tfmt.Fprintln(w, \\\"  Restart your shell to activate\\\")\\n   851→\\n   852→\\treturn nil\\n   853→}\\n   854→\\n   855→// isCompletionConfigured checks if shell completion is already in the rc file.\\n   856→func isCompletionConfigured(rcFile string) bool {\\n   857→\\t//nolint:gosec // G304: rcFile is constructed from home dir + known filename, not user input\\n   858→\\tcontent, err := os.ReadFile(rcFile)\\n   859→\\tif err != nil {\\n   860→\\t\\treturn false // File doesn't exist or can't read, treat as not configured\\n   861→\\t}\\n   862→\\treturn strings.Contains(string(content), \\\"entire completion\\\")\\n   863→}\\n   864→\\n   865→// appendShellCompletion adds the completion line to the rc file.\\n   866→func appendShellCompletion(rcFile, completionLine string) error {\\n   867→\\tif err := os.MkdirAll(filepath.Dir(rcFile), 0o700); err != nil {\\n   868→\\t\\treturn fmt.Errorf(\\\"creating directory: %w\\\", err)\\n   869→\\t}\\n   870→\\t//nolint:gosec // G302: Shell rc files need 0644 for user readability\\n   871→\\tf, err := os.OpenFile(rcFile, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0o644)\\n   872→\\tif err != nil {\\n   873→\\t\\treturn fmt.Errorf(\\\"opening file: %w\\\", err)\\n   874→\\t}\\n   875→\\tdefer f.Close()\\n   876→\\n   877→\\t_, err = f.WriteString(\\\"\\\\n\\\" + shellCompletionComment + \\\"\\\\n\\\" + completionLine + \\\"\\\\n\\\")\\n   878→\\tif err != nil {\\n   879→\\t\\treturn fmt.Errorf(\\\"writing completion: %w\\\", err)\\n   880→\\t}\\n   881→\\treturn nil\\n   882→}\\n   883→\\n   884→// promptTelemetryConsent asks the user if they want to enable telemetry.\\n   885→// It modifies settings.Telemetry based on the user's choice or flags.\\n   886→// The caller is responsible for saving settings.\\n   887→func promptTelemetryConsent(settings *EntireSettings, telemetryFlag bool) error {\\n   888→\\t// Handle --telemetry=false flag first (always overrides existing setting)\\n   889→\\tif !telemetryFlag {\\n   890→\\t\\tf := false\\n   891→\\t\\tsettings.Telemetry = &f\\n   892→\\t\\treturn nil\\n   893→\\t}\\n   894→\\n   895→\\t// Skip if already asked\\n   896→\\tif settings.Telemetry != nil {\\n   897→\\t\\treturn nil\\n   898→\\t}\\n   899→\\n   900→\\t// Skip if env var disables telemetry (record as disabled)\\n   901→\\tif os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   902→\\t\\tf := false\\n   903→\\t\\tsettings.Telemetry = &f\\n   904→\\t\\treturn nil\\n   905→\\t}\\n   906→\\n   907→\\tconsent := true // Default to Yes\\n   908→\\tform := NewAccessibleForm(\\n   909→\\t\\thuh.NewGroup(\\n   910→\\t\\t\\thuh.NewConfirm().\\n   911→\\t\\t\\t\\tTitle(\\\"Help improve Entire CLI?\\\").\\n   912→\\t\\t\\t\\tDescription(\\\"Share anonymous usage data. No code or personal info collected.\\\").\\n   913→\\t\\t\\t\\tAffirmative(\\\"Yes\\\").\\n   914→\\t\\t\\t\\tNegative(\\\"No\\\").\\n   915→\\t\\t\\t\\tValue(&consent),\\n   916→\\t\\t),\\n   917→\\t)\\n   918→\\n   919→\\tif err := form.Run(); err != nil {\\n   920→\\t\\treturn fmt.Errorf(\\\"telemetry prompt: %w\\\", err)\\n   921→\\t}\\n   922→\\n   923→\\tsettings.Telemetry = &consent\\n   924→\\treturn nil\\n   925→}\\n   926→\\n   927→// runUninstall completely removes Entire from the repository.\\n   928→func runUninstall(w, errW io.Writer, force bool) error {\\n   929→\\t// Check if we're in a git repository\\n   930→\\tif _, err := paths.WorktreeRoot(); err != nil {\\n   931→\\t\\tfmt.Fprintln(errW, \\\"Not a git repository. Nothing to uninstall.\\\")\\n   932→\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n   933→\\t}\\n   934→\\n   935→\\t// Gather counts for display\\n   936→\\tsessionStateCount := countSessionStates()\\n   937→\\tshadowBranchCount := countShadowBranches()\\n   938→\\tgitHooksInstalled := strategy.IsGitHookInstalled()\\n   939→\\tagentsWithInstalledHooks := GetAgentsWithHooksInstalled()\\n   940→\\tentireDirExists := checkEntireDirExists()\\n   941→\\n   942→\\t// Check if there's anything to uninstall\\n   943→\\tif !entireDirExists && !gitHooksInstalled && sessionStateCount == 0 &&\\n   944→\\t\\tshadowBranchCount == 0 && len(agentsWithInstalledHooks) == 0 {\\n   945→\\t\\tfmt.Fprintln(w, \\\"Entire is not installed in this repository.\\\")\\n   946→\\t\\treturn nil\\n   947→\\t}\\n   948→\\n   949→\\t// Show confirmation prompt unless --force\\n   950→\\tif !force {\\n   951→\\t\\tfmt.Fprintln(w, \\\"\\\\nThis will completely remove Entire from this repository:\\\")\\n   952→\\t\\tif entireDirExists {\\n   953→\\t\\t\\tfmt.Fprintln(w, \\\"  - .entire/ directory\\\")\\n   954→\\t\\t}\\n   955→\\t\\tif gitHooksInstalled {\\n   956→\\t\\t\\tfmt.Fprintln(w, \\\"  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\\")\\n   957→\\t\\t}\\n   958→\\t\\tif sessionStateCount > 0 {\\n   959→\\t\\t\\tfmt.Fprintf(w, \\\"  - Session state files (%d)\\\\n\\\", sessionStateCount)\\n   960→\\t\\t}\\n   961→\\t\\tif shadowBranchCount > 0 {\\n   962→\\t\\t\\tfmt.Fprintf(w, \\\"  - Shadow branches (%d)\\\\n\\\", shadowBranchCount)\\n   963→\\t\\t}\\n   964→\\t\\tif len(agentsWithInstalledHooks) > 0 {\\n   965→\\t\\t\\tdisplayNames := make([]string, 0, len(agentsWithInstalledHooks))\\n   966→\\t\\t\\tfor _, name := range agentsWithInstalledHooks {\\n   967→\\t\\t\\t\\tif ag, err := agent.Get(name); err == nil {\\n   968→\\t\\t\\t\\t\\tdisplayNames = append(displayNames, string(ag.Type()))\\n   969→\\t\\t\\t\\t}\\n   970→\\t\\t\\t}\\n   971→\\t\\t\\tfmt.Fprintf(w, \\\"  - Agent hooks (%s)\\\\n\\\", strings.Join(displayNames, \\\", \\\"))\\n   972→\\t\\t}\\n   973→\\t\\tfmt.Fprintln(w)\\n   974→\\n   975→\\t\\tvar confirmed bool\\n   976→\\t\\tform := NewAccessibleForm(\\n   977→\\t\\t\\thuh.NewGroup(\\n   978→\\t\\t\\t\\thuh.NewConfirm().\\n   979→\\t\\t\\t\\t\\tTitle(\\\"Are you sure you want to uninstall Entire?\\\").\\n   980→\\t\\t\\t\\t\\tAffirmative(\\\"Yes, uninstall\\\").\\n   981→\\t\\t\\t\\t\\tNegative(\\\"Cancel\\\").\\n   982→\\t\\t\\t\\t\\tValue(&confirmed),\\n   983→\\t\\t\\t),\\n   984→\\t\\t)\\n   985→\\n   986→\\t\\tif err := form.Run(); err != nil {\\n   987→\\t\\t\\treturn fmt.Errorf(\\\"confirmation cancelled: %w\\\", err)\\n   988→\\t\\t}\\n   989→\\n   990→\\t\\tif !confirmed {\\n   991→\\t\\t\\tfmt.Fprintln(w, \\\"Uninstall cancelled.\\\")\\n   992→\\t\\t\\treturn nil\\n   993→\\t\\t}\\n   994→\\t}\\n   995→\\n   996→\\tfmt.Fprintln(w, \\\"\\\\nUninstalling Entire CLI...\\\")\\n   997→\\n   998→\\t// 1. Remove agent hooks (lowest risk)\\n   999→\\tif err := removeAgentHooks(w); err != nil {\\n  1000→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove agent hooks: %v\\\\n\\\", err)\\n  1001→\\t}\\n  1002→\\n  1003→\\t// 2. Remove git hooks\\n  1004→\\tremoved, err := strategy.RemoveGitHook()\\n  1005→\\tif err != nil {\\n  1006→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove git hooks: %v\\\\n\\\", err)\\n  1007→\\t} else if removed > 0 {\\n  1008→\\t\\tfmt.Fprintf(w, \\\"  Removed git hooks (%d)\\\\n\\\", removed)\\n  1009→\\t}\\n  1010→\\n  1011→\\t// 3. Remove session state files\\n  1012→\\tstatesRemoved, err := removeAllSessionStates()\\n  1013→\\tif err != nil {\\n  1014→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove session states: %v\\\\n\\\", err)\\n  1015→\\t} else if statesRemoved > 0 {\\n  1016→\\t\\tfmt.Fprintf(w, \\\"  Removed session states (%d)\\\\n\\\", statesRemoved)\\n  1017→\\t}\\n  1018→\\n  1019→\\t// 4. Remove .entire/ directory\\n  1020→\\tif err := removeEntireDirectory(); err != nil {\\n  1021→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove .entire directory: %v\\\\n\\\", err)\\n  1022→\\t} else if entireDirExists {\\n  1023→\\t\\tfmt.Fprintln(w, \\\"  Removed .entire directory\\\")\\n  1024→\\t}\\n  1025→\\n  1026→\\t// 5. Remove shadow branches\\n  1027→\\tbranchesRemoved, err := removeAllShadowBranches()\\n  1028→\\tif err != nil {\\n  1029→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove shadow branches: %v\\\\n\\\", err)\\n  1030→\\t} else if branchesRemoved > 0 {\\n  1031→\\t\\tfmt.Fprintf(w, \\\"  Removed %d shadow branches\\\\n\\\", branchesRemoved)\\n  1032→\\t}\\n  1033→\\n  1034→\\tfmt.Fprintln(w, \\\"\\\\nEntire CLI uninstalled successfully.\\\")\\n  1035→\\treturn nil\\n  1036→}\\n  1037→\\n  1038→// countSessionStates returns the number of active session state files.\\n  1039→func countSessionStates() int {\\n  1040→\\tstore, err := session.NewStateStore()\\n  1041→\\tif err != nil {\\n  1042→\\t\\treturn 0\\n  1043→\\t}\\n  1044→\\tstates, err := store.List(context.Background())\\n  1045→\\tif err != nil {\\n  1046→\\t\\treturn 0\\n  1047→\\t}\\n  1048→\\treturn len(states)\\n  1049→}\\n  1050→\\n  1051→// countShadowBranches returns the number of shadow branches.\\n  1052→func countShadowBranches() int {\\n  1053→\\tbranches, err := strategy.ListShadowBranches()\\n  1054→\\tif err != nil {\\n  1055→\\t\\treturn 0\\n  1056→\\t}\\n  1057→\\treturn len(branches)\\n  1058→}\\n  1059→\\n  1060→// checkEntireDirExists checks if the .entire directory exists.\\n  1061→func checkEntireDirExists() bool {\\n  1062→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n  1063→\\tif err != nil {\\n  1064→\\t\\tentireDirAbs = paths.EntireDir\\n  1065→\\t}\\n  1066→\\t_, err = os.Stat(entireDirAbs)\\n  1067→\\treturn err == nil\\n  1068→}\\n  1069→\\n  1070→// removeAgentHooks removes hooks from all agents that support hooks.\\n  1071→func removeAgentHooks(w io.Writer) error {\\n  1072→\\tvar errs []error\\n  1073→\\tfor _, name := range agent.List() {\\n  1074→\\t\\tag, err := agent.Get(name)\\n  1075→\\t\\tif err != nil {\\n  1076→\\t\\t\\tcontinue\\n  1077→\\t\\t}\\n  1078→\\t\\ths, ok := ag.(agent.HookSupport)\\n  1079→\\t\\tif !ok {\\n  1080→\\t\\t\\tcontinue\\n  1081→\\t\\t}\\n  1082→\\t\\twasInstalled := hs.AreHooksInstalled()\\n  1083→\\t\\tif err := hs.UninstallHooks(); err != nil {\\n  1084→\\t\\t\\terrs = append(errs, err)\\n  1085→\\t\\t} else if wasInstalled {\\n  1086→\\t\\t\\tfmt.Fprintf(w, \\\"  Removed %s hooks\\\\n\\\", ag.Type())\\n  1087→\\t\\t}\\n  1088→\\t}\\n  1089→\\treturn errors.Join(errs...)\\n  1090→}\\n  1091→\\n  1092→// removeAllSessionStates removes all session state files and the directory.\\n  1093→func removeAllSessionStates() (int, error) {\\n  1094→\\tstore, err := session.NewStateStore()\\n  1095→\\tif err != nil {\\n  1096→\\t\\treturn 0, fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n  1097→\\t}\\n  1098→\\n  1099→\\t// Count states before removing\\n  1100→\\tstates, err := store.List(context.Background())\\n  1101→\\tif err != nil {\\n  1102→\\t\\treturn 0, fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n  1103→\\t}\\n  1104→\\tcount := len(states)\\n  1105→\\n  1106→\\t// Remove the entire directory\\n  1107→\\tif err := store.RemoveAll(); err != nil {\\n  1108→\\t\\treturn 0, fmt.Errorf(\\\"failed to remove session states: %w\\\", err)\\n  1109→\\t}\\n  1110→\\n  1111→\\treturn count, nil\\n  1112→}\\n  1113→\\n  1114→// removeEntireDirectory removes the .entire directory.\\n  1115→func removeEntireDirectory() error {\\n  1116→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n  1117→\\tif err != nil {\\n  1118→\\t\\tentireDirAbs = paths.EntireDir\\n  1119→\\t}\\n  1120→\\tif err := os.RemoveAll(entireDirAbs); err != nil {\\n  1121→\\t\\treturn fmt.Errorf(\\\"failed to remove .entire directory: %w\\\", err)\\n  1122→\\t}\\n  1123→\\treturn nil\\n  1124→}\\n  1125→\\n  1126→// removeAllShadowBranches removes all shadow branches.\\n  1127→func removeAllShadowBranches() (int, error) {\\n  1128→\\tbranches, err := strategy.ListShadowBranches()\\n  1129→\\tif err != nil {\\n  1130→\\t\\treturn 0, fmt.Errorf(\\\"failed to list shadow branches: %w\\\", err)\\n  1131→\\t}\\n  1132→\\tif len(branches) == 0 {\\n  1133→\\t\\treturn 0, nil\\n  1134→\\t}\\n  1135→\\tdeleted, _, err := strategy.DeleteShadowBranches(branches)\\n  1136→\\treturn len(deleted), err\\n  1137→}\\n  1138→\\n\\n<system-reminder>\\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\\n</system-reminder>\\n\"}]},\"uuid\":\"53599fdb-06ab-44b4-b7b8-246e363fdb33\",\"timestamp\":\"2026-02-25T20:24:17.478Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli_worktree1/cmd/entire/cli/setup.go\",\"content\":\"package cli\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"io\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\n\\t\\\"github.com/charmbracelet/huh\\\"\\n\\t\\\"github.com/spf13/cobra\\\"\\n\\t\\\"github.com/spf13/pflag\\\"\\n)\\n\\n// Config path display strings\\nconst (\\n\\tconfigDisplayProject = \\\".entire/settings.json\\\"\\n\\tconfigDisplayLocal   = \\\".entire/settings.local.json\\\"\\n)\\n\\n// EnableOptions holds the flags for `entire enable`.\\ntype EnableOptions struct {\\n\\tLocalDev            bool\\n\\tUseLocalSettings    bool\\n\\tUseProjectSettings  bool\\n\\tForceHooks          bool\\n\\tSkipPushSessions    bool\\n\\tTelemetry           bool\\n\\tAbsoluteGitHookPath bool\\n}\\n\\nfunc newEnableCmd() *cobra.Command {\\n\\tvar opts EnableOptions\\n\\tvar ignoreUntracked bool\\n\\tvar agentName string\\n\\n\\tcmd := &cobra.Command{\\n\\t\\tUse:   \\\"enable\\\",\\n\\t\\tShort: \\\"Enable Entire in current project\\\",\\n\\t\\tLong: `Enable Entire with session tracking for your AI agent workflows.\\n\\nUses the manual-commit strategy, which creates session checkpoints without\\nmodifying your active branch.`,\\n\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n\\t\\t\\t// Check if we're in a git repository first - this is a prerequisite error,\\n\\t\\t\\t// not a usage error, so we silence Cobra's output and use SilentError\\n\\t\\t\\t// to prevent duplicate error output in main.go\\n\\t\\t\\tif _, err := paths.WorktreeRoot(); err != nil {\\n\\t\\t\\t\\tfmt.Fprintln(cmd.ErrOrStderr(), \\\"Not a git repository. Please run 'entire enable' from within a git repository.\\\")\\n\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n\\t\\t\\t}\\n\\n\\t\\t\\tif err := validateSetupFlags(opts.UseLocalSettings, opts.UseProjectSettings); err != nil {\\n\\t\\t\\t\\treturn err\\n\\t\\t\\t}\\n\\n\\t\\t\\t// Warn if repo has no commits yet\\n\\t\\t\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Note: This repository has no commits yet. Entire will be configured, but\\\")\\n\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"session checkpoints won't work until you create your first commit.\\\")\\n\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout())\\n\\t\\t\\t}\\n\\n\\t\\t\\t// Non-interactive mode if --agent flag is provided\\n\\t\\t\\tif cmd.Flags().Changed(\\\"agent\\\") && agentName == \\\"\\\" {\\n\\t\\t\\t\\tprintMissingAgentError(cmd.ErrOrStderr())\\n\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n\\t\\t\\t}\\n\\n\\t\\t\\tif agentName != \\\"\\\" {\\n\\t\\t\\t\\tag, err := agent.Get(agent.AgentName(agentName))\\n\\t\\t\\t\\tif err != nil {\\n\\t\\t\\t\\t\\tprintWrongAgentError(cmd.ErrOrStderr(), agentName)\\n\\t\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"wrong agent name\\\"))\\n\\t\\t\\t\\t}\\n\\t\\t\\t\\t// --agent is a targeted operation: set up this specific agent without\\n\\t\\t\\t\\t// affecting other agents. Unlike the interactive path, it does not\\n\\t\\t\\t\\t// uninstall hooks for other previously-enabled agents.\\n\\t\\t\\t\\treturn setupAgentHooksNonInteractive(cmd.OutOrStdout(), ag, opts)\\n\\t\\t\\t}\\n\\t\\t\\t// Detect or prompt for agents\\n\\t\\t\\tagents, err := detectOrSelectAgent(cmd.OutOrStdout(), nil)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\treturn fmt.Errorf(\\\"agent selection failed: %w\\\", err)\\n\\t\\t\\t}\\n\\n\\t\\t\\treturn runEnableInteractive(cmd.OutOrStdout(), agents, opts)\\n\\t\\t},\\n\\t}\\n\\n\\tcmd.Flags().BoolVar(&opts.LocalDev, \\\"local-dev\\\", false, \\\"Use go run instead of entire binary for hooks\\\")\\n\\tcmd.Flags().MarkHidden(\\\"local-dev\\\") //nolint:errcheck,gosec // flag is defined above\\n\\tcmd.Flags().BoolVar(&ignoreUntracked, \\\"ignore-untracked\\\", false, \\\"Commit all new files without tracking pre-existing untracked files\\\")\\n\\tcmd.Flags().MarkHidden(\\\"ignore-untracked\\\") //nolint:errcheck,gosec // flag is defined above\\n\\tcmd.Flags().BoolVar(&opts.UseLocalSettings, \\\"local\\\", false, \\\"Write settings to .entire/settings.local.json instead of .entire/settings.json\\\")\\n\\tcmd.Flags().BoolVar(&opts.UseProjectSettings, \\\"project\\\", false, \\\"Write settings to .entire/settings.json even if it already exists\\\")\\n\\tcmd.Flags().StringVar(&agentName, \\\"agent\\\", \\\"\\\", \\\"Agent to set up hooks for (e.g., claude-code, gemini, opencode). Enables non-interactive mode.\\\")\\n\\tcmd.Flags().BoolVarP(&opts.ForceHooks, \\\"force\\\", \\\"f\\\", false, \\\"Force reinstall hooks (removes existing Entire hooks first)\\\")\\n\\tcmd.Flags().BoolVar(&opts.SkipPushSessions, \\\"skip-push-sessions\\\", false, \\\"Disable automatic pushing of session logs on git push\\\")\\n\\tcmd.Flags().BoolVar(&opts.Telemetry, \\\"telemetry\\\", true, \\\"Enable anonymous usage analytics\\\")\\n\\tcmd.Flags().BoolVar(&opts.AbsoluteGitHookPath, \\\"absolute-git-hook-path\\\", false, \\\"Embed full binary path in git hooks (for GUI git clients that don't source shell profiles)\\\")\\n\\n\\t// Provide a helpful error when --agent is used without a value\\n\\tdefaultFlagErr := cmd.FlagErrorFunc()\\n\\tcmd.SetFlagErrorFunc(func(c *cobra.Command, err error) error {\\n\\t\\tvar valErr *pflag.ValueRequiredError\\n\\t\\tif errors.As(err, &valErr) && valErr.GetSpecifiedName() == \\\"agent\\\" {\\n\\t\\t\\tprintMissingAgentError(c.ErrOrStderr())\\n\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n\\t\\t}\\n\\t\\treturn defaultFlagErr(c, err)\\n\\t})\\n\\n\\t// Add subcommands for automation/testing\\n\\tcmd.AddCommand(newSetupGitHookCmd())\\n\\n\\treturn cmd\\n}\\n\\nfunc newDisableCmd() *cobra.Command {\\n\\tvar useProjectSettings bool\\n\\tvar uninstall bool\\n\\tvar force bool\\n\\n\\tcmd := &cobra.Command{\\n\\t\\tUse:   \\\"disable\\\",\\n\\t\\tShort: \\\"Disable Entire in current project\\\",\\n\\t\\tLong: `Disable Entire integrations in the current project.\\n\\nBy default, this command will disable Entire. Hooks will exit silently and commands will\\nshow a disabled message.\\n\\nTo completely remove Entire integrations from this repository, use --uninstall:\\n  - .entire/ directory (settings, logs, metadata)\\n  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\n  - Session state files (.git/entire-sessions/)\\n  - Shadow branches (entire/<hash>)\\n  - Agent hooks`,\\n\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n\\t\\t\\tif uninstall {\\n\\t\\t\\t\\treturn runUninstall(cmd.OutOrStdout(), cmd.ErrOrStderr(), force)\\n\\t\\t\\t}\\n\\t\\t\\treturn runDisable(cmd.OutOrStdout(), useProjectSettings)\\n\\t\\t},\\n\\t}\\n\\n\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Update .entire/settings.json instead of .entire/settings.local.json\\\")\\n\\tcmd.Flags().BoolVar(&uninstall, \\\"uninstall\\\", false, \\\"Completely remove Entire from this repository\\\")\\n\\tcmd.Flags().BoolVar(&force, \\\"force\\\", false, \\\"Skip confirmation prompt (use with --uninstall)\\\")\\n\\n\\treturn cmd\\n}\\n\\n// runEnableInteractive runs the interactive enable flow.\\n// agents must be provided by the caller (via detectOrSelectAgent).\\nfunc runEnableInteractive(w io.Writer, agents []agent.Agent, opts EnableOptions) error {\\n\\t// Uninstall hooks for agents that were previously active but are no longer selected\\n\\tif err := uninstallDeselectedAgentHooks(w, agents); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to clean up deselected agents: %w\\\", err)\\n\\t}\\n\\n\\t// Setup agent hooks for all selected agents\\n\\tfor _, ag := range agents {\\n\\t\\tif _, err := setupAgentHooks(ag, opts.LocalDev, opts.ForceHooks); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n\\t\\t}\\n\\t}\\n\\n\\t// Setup .entire directory\\n\\tif _, err := setupEntireDirectory(); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n\\t}\\n\\n\\t// Load existing settings to preserve other options (like strategy_options.push)\\n\\tsettings, err := LoadEntireSettings()\\n\\tif err != nil {\\n\\t\\t// If we can't load, start with defaults\\n\\t\\tsettings = &EntireSettings{}\\n\\t}\\n\\t// Update the specific fields\\n\\tsettings.Enabled = true\\n\\tif opts.LocalDev {\\n\\t\\tsettings.LocalDev = true\\n\\t}\\n\\tif opts.AbsoluteGitHookPath {\\n\\t\\tsettings.AbsoluteGitHookPath = true\\n\\t}\\n\\n\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n\\tif opts.SkipPushSessions {\\n\\t\\tif settings.StrategyOptions == nil {\\n\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n\\t\\t}\\n\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n\\t}\\n\\n\\t// Determine which settings file to write to\\n\\t// First run always creates settings.json (no prompt)\\n\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n\\tif err != nil {\\n\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n\\t}\\n\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, opts.UseLocalSettings, opts.UseProjectSettings)\\n\\n\\tif showNotification {\\n\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n\\t}\\n\\n\\t// Helper to save settings to the appropriate file\\n\\tsaveSettings := func() error {\\n\\t\\tif shouldUseLocal {\\n\\t\\t\\treturn SaveEntireSettingsLocal(settings)\\n\\t\\t}\\n\\t\\treturn SaveEntireSettings(settings)\\n\\t}\\n\\n\\t// Save settings before telemetry prompt so config is persisted even if the user cancels\\n\\tif err := saveSettings(); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n\\t}\\n\\n\\tif _, err := strategy.InstallGitHook(true, opts.LocalDev, opts.AbsoluteGitHookPath); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n\\t}\\n\\tstrategy.CheckAndWarnHookManagers(w, opts.LocalDev, opts.AbsoluteGitHookPath)\\n\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n\\n\\tconfigDisplay := configDisplayProject\\n\\tif shouldUseLocal {\\n\\t\\tconfigDisplay = configDisplayLocal\\n\\t}\\n\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n\\n\\t// Ask about telemetry consent (only if not already asked)\\n\\tfmt.Fprintln(w)\\n\\tif err := promptTelemetryConsent(settings, opts.Telemetry); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n\\t}\\n\\t// Save again to persist telemetry choice\\n\\tif err := saveSettings(); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n\\t}\\n\\n\\tif err := strategy.EnsureSetup(); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n\\t}\\n\\n\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n\\n\\treturn nil\\n}\\n\\n// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\nfunc runEnable(w io.Writer) error {\\n\\tsettings, err := LoadEntireSettings()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n\\t}\\n\\n\\tsettings.Enabled = true\\n\\tif err := SaveEntireSettings(settings); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n\\t}\\n\\n\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n\\treturn nil\\n}\\n\\nfunc runDisable(w io.Writer, useProjectSettings bool) error {\\n\\tsettings, err := LoadEntireSettings()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n\\t}\\n\\n\\tsettings.Enabled = false\\n\\n\\t// If --project flag is specified, always write to project settings\\n\\tif useProjectSettings {\\n\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n\\t\\t}\\n\\t} else {\\n\\t\\t// Always write to local settings file (create if doesn't exist)\\n\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n\\treturn nil\\n}\\n\\n// DisabledMessage is the message shown when Entire is disabled\\nconst DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n\\n// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n// Returns true if the caller should exit (i.e., Entire is disabled).\\n// On error reading settings, defaults to enabled (returns false).\\nfunc checkDisabledGuard(w io.Writer) bool {\\n\\tenabled, err := IsEnabled()\\n\\tif err != nil {\\n\\t\\t// Default to enabled on error\\n\\t\\treturn false\\n\\t}\\n\\tif !enabled {\\n\\t\\tfmt.Fprintln(w, DisabledMessage)\\n\\t\\treturn true\\n\\t}\\n\\treturn false\\n}\\n\\n// uninstallDeselectedAgentHooks removes hooks for agents that were previously\\n// installed but are not in the selected list. This handles the case where a user\\n// re-runs `entire enable` and deselects an agent.\\nfunc uninstallDeselectedAgentHooks(w io.Writer, selectedAgents []agent.Agent) error {\\n\\tinstalledNames := GetAgentsWithHooksInstalled()\\n\\tif len(installedNames) == 0 {\\n\\t\\treturn nil\\n\\t}\\n\\n\\tselectedSet := make(map[agent.AgentName]struct{}, len(selectedAgents))\\n\\tfor _, ag := range selectedAgents {\\n\\t\\tselectedSet[ag.Name()] = struct{}{}\\n\\t}\\n\\n\\tvar errs []error\\n\\tfor _, name := range installedNames {\\n\\t\\tif _, selected := selectedSet[name]; selected {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tag, err := agent.Get(name)\\n\\t\\tif err != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\thookAgent, ok := ag.(agent.HookSupport)\\n\\t\\tif !ok {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tif err := hookAgent.UninstallHooks(); err != nil {\\n\\t\\t\\terrs = append(errs, fmt.Errorf(\\\"failed to uninstall %s hooks: %w\\\", ag.Type(), err))\\n\\t\\t} else {\\n\\t\\t\\tfmt.Fprintf(w, \\\"Removed %s hooks\\\\n\\\", ag.Type())\\n\\t\\t}\\n\\t}\\n\\treturn errors.Join(errs...)\\n}\\n\\n// setupAgentHooks sets up hooks for a given agent.\\n// Returns the number of hooks installed (0 if already installed).\\nfunc setupAgentHooks(ag agent.Agent, localDev, forceHooks bool) (int, error) {\\n\\thookAgent, ok := ag.(agent.HookSupport)\\n\\tif !ok {\\n\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n\\t}\\n\\n\\tcount, err := hookAgent.InstallHooks(localDev, forceHooks)\\n\\tif err != nil {\\n\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n\\t}\\n\\n\\treturn count, nil\\n}\\n\\n// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n// Returns the detected/selected agents and any error.\\n//\\n// On first run (no hooks installed):\\n//   - Single detected agent: used automatically\\n//   - Multiple/no detected agents: interactive multi-select prompt\\n//\\n// On re-run (hooks already installed):\\n//   - Always shows the interactive multi-select\\n//   - Pre-selects only agents that have hooks installed (respects prior deselection)\\n//\\n// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n// It receives available agent names and returns the selected names.\\nfunc detectOrSelectAgent(w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n\\t// Check for agents with hooks already installed (re-run detection)\\n\\tinstalledAgentNames := GetAgentsWithHooksInstalled()\\n\\thasInstalledHooks := len(installedAgentNames) > 0\\n\\n\\t// Try auto-detection\\n\\tdetected := agent.DetectAll()\\n\\n\\t// First run: use existing auto-detect shortcuts\\n\\tif !hasInstalledHooks {\\n\\t\\tswitch {\\n\\t\\tcase len(detected) == 1:\\n\\t\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n\\t\\t\\treturn detected, nil\\n\\n\\t\\tcase len(detected) > 1:\\n\\t\\t\\tagentTypes := make([]string, 0, len(detected))\\n\\t\\t\\tfor _, ag := range detected {\\n\\t\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n\\t\\t\\t}\\n\\t\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n\\t\\t\\tfmt.Fprintln(w)\\n\\t\\t}\\n\\t}\\n\\n\\t// Check if we can prompt interactively\\n\\tif !canPromptInteractively() {\\n\\t\\tif hasInstalledHooks {\\n\\t\\t\\t// Re-run without TTY — keep currently installed agents\\n\\t\\t\\tagents := make([]agent.Agent, 0, len(installedAgentNames))\\n\\t\\t\\tfor _, name := range installedAgentNames {\\n\\t\\t\\t\\tag, err := agent.Get(name)\\n\\t\\t\\t\\tif err != nil {\\n\\t\\t\\t\\t\\tcontinue\\n\\t\\t\\t\\t}\\n\\t\\t\\t\\tagents = append(agents, ag)\\n\\t\\t\\t}\\n\\t\\t\\treturn agents, nil\\n\\t\\t}\\n\\t\\tif len(detected) > 0 {\\n\\t\\t\\treturn detected, nil\\n\\t\\t}\\n\\t\\tdefaultAgent := agent.Default()\\n\\t\\tif defaultAgent == nil {\\n\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n\\t\\t}\\n\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n\\t\\treturn []agent.Agent{defaultAgent}, nil\\n\\t}\\n\\n\\tif !hasInstalledHooks && len(detected) == 0 {\\n\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., .claude, .gemini, or .opencode directory).\\\")\\n\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n\\t\\tfmt.Fprintln(w)\\n\\t}\\n\\n\\t// Build pre-selection set.\\n\\t// On re-run: only pre-select agents with hooks installed (respect prior deselection).\\n\\t// On first run: pre-select all detected agents.\\n\\tpreSelectedSet := make(map[agent.AgentName]struct{})\\n\\tif hasInstalledHooks {\\n\\t\\tfor _, name := range installedAgentNames {\\n\\t\\t\\tpreSelectedSet[name] = struct{}{}\\n\\t\\t}\\n\\t} else {\\n\\t\\tfor _, ag := range detected {\\n\\t\\t\\tpreSelectedSet[ag.Name()] = struct{}{}\\n\\t\\t}\\n\\t}\\n\\n\\t// Build options from registered agents\\n\\tagentNames := agent.List()\\n\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n\\tfor _, name := range agentNames {\\n\\t\\tag, err := agent.Get(name)\\n\\t\\tif err != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\t// Only show agents that support hooks\\n\\t\\tif _, ok := ag.(agent.HookSupport); !ok {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\topt := huh.NewOption(string(ag.Type()), string(name))\\n\\t\\tif _, isPreSelected := preSelectedSet[name]; isPreSelected {\\n\\t\\t\\topt = opt.Selected(true)\\n\\t\\t}\\n\\t\\toptions = append(options, opt)\\n\\t}\\n\\n\\tif len(options) == 0 {\\n\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n\\t}\\n\\n\\t// Collect available agent names for the selector\\n\\tavailableNames := make([]string, 0, len(options))\\n\\tfor _, opt := range options {\\n\\t\\tavailableNames = append(availableNames, opt.Value)\\n\\t}\\n\\n\\tvar selectedAgentNames []string\\n\\tif selectFn != nil {\\n\\t\\tvar err error\\n\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, err\\n\\t\\t}\\n\\t\\tif len(selectedAgentNames) == 0 {\\n\\t\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n\\t\\t}\\n\\t} else {\\n\\t\\tform := NewAccessibleForm(\\n\\t\\t\\thuh.NewGroup(\\n\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n\\t\\t\\t\\t\\tOptions(options...).\\n\\t\\t\\t\\t\\tValidate(func(selected []string) error {\\n\\t\\t\\t\\t\\t\\tif len(selected) == 0 {\\n\\t\\t\\t\\t\\t\\t\\treturn errors.New(\\\"please select at least one agent\\\")\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\treturn nil\\n\\t\\t\\t\\t\\t}).\\n\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n\\t\\t\\t),\\n\\t\\t)\\n\\t\\tif err := form.Run(); err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n\\tfor _, name := range selectedAgentNames {\\n\\t\\tselectedAgent, err := agent.Get(agent.AgentName(name))\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n\\t\\t}\\n\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n\\t}\\n\\n\\tagentTypes := make([]string, 0, len(selectedAgents))\\n\\tfor _, ag := range selectedAgents {\\n\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n\\t}\\n\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n\\treturn selectedAgents, nil\\n}\\n\\n// canPromptInteractively checks if we can show interactive prompts.\\n// Returns false when running in CI, tests, or other non-interactive environments.\\nfunc canPromptInteractively() bool {\\n\\t// Check for test environment\\n\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n\\t}\\n\\n\\t// Check if /dev/tty is available\\n\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n\\tif err != nil {\\n\\t\\treturn false\\n\\t}\\n\\t_ = tty.Close()\\n\\treturn true\\n}\\n\\n// printAgentError writes an error message followed by available agents and usage.\\nfunc printAgentError(w io.Writer, message string) {\\n\\tagents := agent.List()\\n\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n\\tfmt.Fprintln(w)\\n\\tfor _, a := range agents {\\n\\t\\tsuffix := \\\"\\\"\\n\\t\\tif a == agent.DefaultAgentName {\\n\\t\\t\\tsuffix = \\\"    (default)\\\"\\n\\t\\t}\\n\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n\\t}\\n\\tfmt.Fprintln(w)\\n\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n}\\n\\n// printMissingAgentError writes a helpful error listing available agents.\\nfunc printMissingAgentError(w io.Writer) {\\n\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n}\\n\\n// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\nfunc printWrongAgentError(w io.Writer, name string) {\\n\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n}\\n\\n// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n// If strategyName is provided, it sets the strategy; otherwise uses default.\\nfunc setupAgentHooksNonInteractive(w io.Writer, ag agent.Agent, opts EnableOptions) error {\\n\\tagentName := ag.Name()\\n\\t// Check if agent supports hooks\\n\\thookAgent, ok := ag.(agent.HookSupport)\\n\\tif !ok {\\n\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n\\t}\\n\\n\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n\\n\\t// Install agent hooks (agent hooks don't depend on settings)\\n\\tinstalledHooks, err := hookAgent.InstallHooks(opts.LocalDev, opts.ForceHooks)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n\\t}\\n\\n\\t// Setup .entire directory\\n\\tif _, err := setupEntireDirectory(); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n\\t}\\n\\n\\t// Load existing settings to preserve other options (like strategy_options.push)\\n\\tsettings, err := LoadEntireSettings()\\n\\tif err != nil {\\n\\t\\t// If we can't load, start with defaults\\n\\t\\tsettings = &EntireSettings{}\\n\\t}\\n\\tsettings.Enabled = true\\n\\tif opts.LocalDev {\\n\\t\\tsettings.LocalDev = true\\n\\t}\\n\\tif opts.AbsoluteGitHookPath {\\n\\t\\tsettings.AbsoluteGitHookPath = true\\n\\t}\\n\\n\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n\\tif opts.SkipPushSessions {\\n\\t\\tif settings.StrategyOptions == nil {\\n\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n\\t\\t}\\n\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n\\t}\\n\\n\\t// Handle telemetry for non-interactive mode\\n\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n\\tif !opts.Telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n\\t\\tf := false\\n\\t\\tsettings.Telemetry = &f\\n\\t}\\n\\n\\tif err := SaveEntireSettings(settings); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n\\t}\\n\\n\\tif _, err := strategy.InstallGitHook(true, opts.LocalDev, opts.AbsoluteGitHookPath); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n\\t}\\n\\tstrategy.CheckAndWarnHookManagers(w, opts.LocalDev, opts.AbsoluteGitHookPath)\\n\\n\\tif installedHooks == 0 {\\n\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n\\t\\tif ag.IsPreview() {\\n\\t\\t\\tmsg += \\\" (Preview)\\\"\\n\\t\\t}\\n\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n\\t} else {\\n\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n\\t\\tif ag.IsPreview() {\\n\\t\\t\\tmsg += \\\" (Preview)\\\"\\n\\t\\t}\\n\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n\\t}\\n\\n\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n\\n\\tif err := strategy.EnsureSetup(); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n\\t}\\n\\n\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n\\n\\treturn nil\\n}\\n\\n// validateSetupFlags checks that --local and --project flags are not both specified.\\nfunc validateSetupFlags(useLocal, useProject bool) error {\\n\\tif useLocal && useProject {\\n\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n\\t}\\n\\treturn nil\\n}\\n\\n// determineSettingsTarget decides whether to write to settings.local.json based on:\\n// - Whether settings.json already exists\\n// - The --local and --project flags\\n// Returns (useLocal, showNotification).\\nfunc determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n\\t// Explicit --local flag always uses local settings\\n\\tif useLocal {\\n\\t\\treturn true, false\\n\\t}\\n\\n\\t// Explicit --project flag always uses project settings\\n\\tif useProject {\\n\\t\\treturn false, false\\n\\t}\\n\\n\\t// No flags specified - check if settings file exists\\n\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n\\tif _, err := os.Stat(settingsPath); err == nil {\\n\\t\\t// Settings file exists - auto-redirect to local with notification\\n\\t\\treturn true, true\\n\\t}\\n\\n\\t// Settings file doesn't exist - create it\\n\\treturn false, false\\n}\\n\\n// setupEntireDirectory creates the .entire directory and gitignore.\\n// Returns true if the directory was created, false if it already existed.\\nfunc setupEntireDirectory() (bool, error) { //nolint:unparam // already present in codebase\\n\\t// Get absolute path for the .entire directory\\n\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n\\tif err != nil {\\n\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n\\t}\\n\\n\\t// Check if directory already exists\\n\\tcreated := false\\n\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n\\t\\tcreated = true\\n\\t}\\n\\n\\t// Create .entire directory\\n\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n\\t}\\n\\n\\t// Create/update .gitignore with all required entries\\n\\tif err := strategy.EnsureEntireGitignore(); err != nil {\\n\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n\\t}\\n\\n\\treturn created, nil\\n}\\n\\n// setupGitHook installs the prepare-commit-msg hook for context trailers.\\nfunc setupGitHook() error {\\n\\ts, err := settings.Load()\\n\\tlocalDev := err == nil && s.LocalDev\\n\\tabsoluteHookPath := err == nil && s.AbsoluteGitHookPath\\n\\tif _, err := strategy.InstallGitHook(false, localDev, absoluteHookPath); err != nil {\\n\\t\\treturn fm