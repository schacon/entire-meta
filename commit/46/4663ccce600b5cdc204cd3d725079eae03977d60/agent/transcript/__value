ath.\\n   147→func isFullyEnabled() (enabled bool, agentDesc string, configPath string) {\\n   148→\\t// Check settings exist and Enabled == true\\n   149→\\ts, err := LoadEntireSettings()\\n   150→\\tif err != nil || !s.Enabled {\\n   151→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   152→\\t}\\n   153→\\n   154→\\t// Check any agent hooks installed (not just Claude Code — works with Gemini too)\\n   155→\\tinstalledAgents := GetAgentsWithHooksInstalled()\\n   156→\\tif len(installedAgents) == 0 {\\n   157→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   158→\\t}\\n   159→\\n   160→\\t// Check git hooks installed\\n   161→\\tif !strategy.IsGitHookInstalled() {\\n   162→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   163→\\t}\\n   164→\\n   165→\\t// Check .entire directory exists\\n   166→\\tif !checkEntireDirExists() {\\n   167→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   168→\\t}\\n   169→\\n   170→\\t// Determine agent description from first installed agent\\n   171→\\tdesc := string(installedAgents[0]) // fallback to agent name\\n   172→\\tif ag, err := agent.Get(installedAgents[0]); err == nil {\\n   173→\\t\\tdesc = string(ag.Type())\\n   174→\\t}\\n   175→\\n   176→\\t// Determine config path - check if local settings exists, otherwise show project settings\\n   177→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   178→\\tif err != nil {\\n   179→\\t\\tentireDirAbs = paths.EntireDir\\n   180→\\t}\\n   181→\\tconfigDisplay := configDisplayProject\\n   182→\\tlocalSettingsPath := filepath.Join(entireDirAbs, \\\"settings.local.json\\\")\\n   183→\\tif _, err := os.Stat(localSettingsPath); err == nil {\\n   184→\\t\\tconfigDisplay = configDisplayLocal\\n   185→\\t}\\n   186→\\n   187→\\treturn true, desc, configDisplay\\n   188→}\\n   189→\\n   190→// runEnableWithStrategy enables Entire with a specified strategy (non-interactive).\\n   191→// The selectedStrategy can be either a display name (manual-commit, auto-commit)\\n   192→// or an internal name (manual-commit, auto-commit).\\n   193→func runEnableWithStrategy(w io.Writer, selectedStrategy string, localDev, _, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry bool) error {\\n   194→\\t// Map the strategy to internal name if it's a display name\\n   195→\\tinternalStrategy := selectedStrategy\\n   196→\\tif mapped, ok := strategyDisplayToInternal[selectedStrategy]; ok {\\n   197→\\t\\tinternalStrategy = mapped\\n   198→\\t}\\n   199→\\n   200→\\t// Validate the strategy exists\\n   201→\\tstrat, err := strategy.Get(internalStrategy)\\n   202→\\tif err != nil {\\n   203→\\t\\treturn fmt.Errorf(\\\"unknown strategy: %s (use manual-commit or auto-commit)\\\", selectedStrategy)\\n   204→\\t}\\n   205→\\n   206→\\t// Detect default agent\\n   207→\\tag := agent.Default()\\n   208→\\tagentType := string(agent.AgentTypeClaudeCode)\\n   209→\\tif ag != nil {\\n   210→\\t\\tagentType = string(ag.Type())\\n   211→\\t}\\n   212→\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", agentType)\\n   213→\\n   214→\\t// Setup Claude Code hooks + git hooks → combined \\\"Hooks installed\\\" message\\n   215→\\tif _, err := setupClaudeCodeHook(localDev, forceHooks); err != nil {\\n   216→\\t\\treturn fmt.Errorf(\\\"failed to setup Claude Code hooks: %w\\\", err)\\n   217→\\t}\\n   218→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   219→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   220→\\t}\\n   221→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   222→\\n   223→\\t// Setup .entire directory\\n   224→\\tif _, err := setupEntireDirectory(); err != nil {\\n   225→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   226→\\t}\\n   227→\\n   228→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   229→\\tsettings, err := LoadEntireSettings()\\n   230→\\tif err != nil {\\n   231→\\t\\t// If we can't load, start with defaults\\n   232→\\t\\tsettings = &EntireSettings{}\\n   233→\\t}\\n   234→\\t// Update the specific fields\\n   235→\\tsettings.Strategy = internalStrategy\\n   236→\\tsettings.LocalDev = localDev\\n   237→\\tsettings.Enabled = true\\n   238→\\n   239→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   240→\\tif skipPushSessions {\\n   241→\\t\\tif settings.StrategyOptions == nil {\\n   242→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   243→\\t\\t}\\n   244→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   245→\\t}\\n   246→\\n   247→\\t// Handle telemetry for non-interactive mode\\n   248→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   249→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   250→\\t\\tf := false\\n   251→\\t\\tsettings.Telemetry = &f\\n   252→\\t}\\n   253→\\n   254→\\t// Determine which settings file to write to\\n   255→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   256→\\tif err != nil {\\n   257→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   258→\\t}\\n   259→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   260→\\n   261→\\tif showNotification {\\n   262→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   263→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   264→\\t}\\n   265→\\n   266→\\tconfigDisplay := configDisplayProject\\n   267→\\tif shouldUseLocal {\\n   268→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   269→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   270→\\t\\t}\\n   271→\\t\\tconfigDisplay = configDisplayLocal\\n   272→\\t} else {\\n   273→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   274→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   275→\\t\\t}\\n   276→\\t}\\n   277→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   278→\\n   279→\\t// Let the strategy handle its own setup requirements\\n   280→\\tif err := strat.EnsureSetup(); err != nil {\\n   281→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   282→\\t}\\n   283→\\n   284→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   285→\\n   286→\\treturn nil\\n   287→}\\n   288→\\n   289→// runEnableInteractive runs the interactive enable flow.\\n   290→func runEnableInteractive(w io.Writer, localDev, _, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry bool) error {\\n   291→\\t// Check if already fully enabled — show summary and return early.\\n   292→\\t// Skip early return if any configuration flags are set (user wants to reconfigure).\\n   293→\\thasConfigFlags := forceHooks || skipPushSessions || !telemetry || useLocalSettings || useProjectSettings || localDev\\n   294→\\tif !hasConfigFlags {\\n   295→\\t\\tif fullyEnabled, agentDesc, configPath := isFullyEnabled(); fullyEnabled {\\n   296→\\t\\t\\tfmt.Fprintln(w, \\\"Already enabled. Everything looks good.\\\")\\n   297→\\t\\t\\tfmt.Fprintln(w)\\n   298→\\t\\t\\tfmt.Fprintf(w, \\\"  Agent: %s\\\\n\\\", agentDesc)\\n   299→\\t\\t\\tfmt.Fprintf(w, \\\"  Config: %s\\\\n\\\", configPath)\\n   300→\\t\\t\\treturn nil\\n   301→\\t\\t}\\n   302→\\t}\\n   303→\\n   304→\\t// Detect default agent\\n   305→\\tag := agent.Default()\\n   306→\\tagentType := string(agent.AgentTypeClaudeCode)\\n   307→\\tif ag != nil {\\n   308→\\t\\tagentType = string(ag.Type())\\n   309→\\t}\\n   310→\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", agentType)\\n   311→\\n   312→\\t// Install Claude Code hooks + git hooks → combined \\\"Hooks installed\\\" message\\n   313→\\tif _, err := setupClaudeCodeHook(localDev, forceHooks); err != nil {\\n   314→\\t\\treturn fmt.Errorf(\\\"failed to setup Claude Code hooks: %w\\\", err)\\n   315→\\t}\\n   316→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   317→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   318→\\t}\\n   319→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   320→\\n   321→\\t// Setup .entire directory\\n   322→\\tif _, err := setupEntireDirectory(); err != nil {\\n   323→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   324→\\t}\\n   325→\\n   326→\\t// Use the default strategy (manual-commit)\\n   327→\\tinternalStrategy := strategy.DefaultStrategyName\\n   328→\\n   329→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   330→\\tsettings, err := LoadEntireSettings()\\n   331→\\tif err != nil {\\n   332→\\t\\t// If we can't load, start with defaults\\n   333→\\t\\tsettings = &EntireSettings{}\\n   334→\\t}\\n   335→\\t// Update the specific fields\\n   336→\\tsettings.Strategy = internalStrategy\\n   337→\\tsettings.LocalDev = localDev\\n   338→\\tsettings.Enabled = true\\n   339→\\n   340→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   341→\\tif skipPushSessions {\\n   342→\\t\\tif settings.StrategyOptions == nil {\\n   343→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   344→\\t\\t}\\n   345→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   346→\\t}\\n   347→\\n   348→\\t// Determine which settings file to write to\\n   349→\\t// First run always creates settings.json (no prompt)\\n   350→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   351→\\tif err != nil {\\n   352→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   353→\\t}\\n   354→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   355→\\n   356→\\tif showNotification {\\n   357→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   358→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   359→\\t}\\n   360→\\n   361→\\t// Helper to save settings to the appropriate file\\n   362→\\tsaveSettings := func() error {\\n   363→\\t\\tif shouldUseLocal {\\n   364→\\t\\t\\treturn SaveEntireSettingsLocal(settings)\\n   365→\\t\\t}\\n   366→\\t\\treturn SaveEntireSettings(settings)\\n   367→\\t}\\n   368→\\n   369→\\t// Save settings before telemetry prompt so config is persisted even if the user cancels\\n   370→\\tif err := saveSettings(); err != nil {\\n   371→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   372→\\t}\\n   373→\\tconfigDisplay := configDisplayProject\\n   374→\\tif shouldUseLocal {\\n   375→\\t\\tconfigDisplay = configDisplayLocal\\n   376→\\t}\\n   377→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   378→\\n   379→\\t// Ask about telemetry consent (only if not already asked)\\n   380→\\tfmt.Fprintln(w)\\n   381→\\tif err := promptTelemetryConsent(settings, telemetry); err != nil {\\n   382→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   383→\\t}\\n   384→\\t// Save again to persist telemetry choice\\n   385→\\tif err := saveSettings(); err != nil {\\n   386→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   387→\\t}\\n   388→\\n   389→\\t// Let the strategy handle its own setup requirements\\n   390→\\tstrat, err := strategy.Get(internalStrategy)\\n   391→\\tif err != nil {\\n   392→\\t\\treturn fmt.Errorf(\\\"failed to get strategy: %w\\\", err)\\n   393→\\t}\\n   394→\\tif err := strat.EnsureSetup(); err != nil {\\n   395→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   396→\\t}\\n   397→\\n   398→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   399→\\n   400→\\treturn nil\\n   401→}\\n   402→\\n   403→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   404→func runEnable(w io.Writer) error {\\n   405→\\tsettings, err := LoadEntireSettings()\\n   406→\\tif err != nil {\\n   407→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   408→\\t}\\n   409→\\n   410→\\tsettings.Enabled = true\\n   411→\\tif err := SaveEntireSettings(settings); err != nil {\\n   412→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   413→\\t}\\n   414→\\n   415→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   416→\\treturn nil\\n   417→}\\n   418→\\n   419→func runDisable(w io.Writer, useProjectSettings bool) error {\\n   420→\\tsettings, err := LoadEntireSettings()\\n   421→\\tif err != nil {\\n   422→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   423→\\t}\\n   424→\\n   425→\\tsettings.Enabled = false\\n   426→\\n   427→\\t// If --project flag is specified, always write to project settings\\n   428→\\tif useProjectSettings {\\n   429→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   430→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   431→\\t\\t}\\n   432→\\t} else {\\n   433→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   434→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   435→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   436→\\t\\t}\\n   437→\\t}\\n   438→\\n   439→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   440→\\treturn nil\\n   441→}\\n   442→\\n   443→// DisabledMessage is the message shown when Entire is disabled\\n   444→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   445→\\n   446→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   447→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   448→// On error reading settings, defaults to enabled (returns false).\\n   449→func checkDisabledGuard(w io.Writer) bool {\\n   450→\\tenabled, err := IsEnabled()\\n   451→\\tif err != nil {\\n   452→\\t\\t// Default to enabled on error\\n   453→\\t\\treturn false\\n   454→\\t}\\n   455→\\tif !enabled {\\n   456→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   457→\\t\\treturn true\\n   458→\\t}\\n   459→\\treturn false\\n   460→}\\n   461→\\n   462→// setupClaudeCodeHook sets up Claude Code hooks.\\n   463→// This is a convenience wrapper that uses the agent package.\\n   464→// Returns the number of hooks installed (0 if already installed).\\n   465→func setupClaudeCodeHook(localDev, forceHooks bool) (int, error) {\\n   466→\\tag, err := agent.Get(agent.AgentNameClaudeCode)\\n   467→\\tif err != nil {\\n   468→\\t\\treturn 0, fmt.Errorf(\\\"failed to get claude-code agent: %w\\\", err)\\n   469→\\t}\\n   470→\\n   471→\\thookAgent, ok := ag.(agent.HookSupport)\\n   472→\\tif !ok {\\n   473→\\t\\treturn 0, errors.New(\\\"claude-code agent does not support hooks\\\")\\n   474→\\t}\\n   475→\\n   476→\\tcount, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   477→\\tif err != nil {\\n   478→\\t\\treturn 0, fmt.Errorf(\\\"failed to install claude-code hooks: %w\\\", err)\\n   479→\\t}\\n   480→\\n   481→\\treturn count, nil\\n   482→}\\n   483→\\n   484→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   485→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   486→func setupAgentHooksNonInteractive(w io.Writer, agentName agent.AgentName, strategyName string, localDev, forceHooks, skipPushSessions, telemetry bool) error {\\n   487→\\tag, err := agent.Get(agentName)\\n   488→\\tif err != nil {\\n   489→\\t\\treturn fmt.Errorf(\\\"unknown agent: %s\\\", agentName)\\n   490→\\t}\\n   491→\\n   492→\\t// Check if agent supports hooks\\n   493→\\thookAgent, ok := ag.(agent.HookSupport)\\n   494→\\tif !ok {\\n   495→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   496→\\t}\\n   497→\\n   498→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   499→\\n   500→\\t// Install agent hooks + git hooks\\n   501→\\tif _, err := hookAgent.InstallHooks(localDev, forceHooks); err != nil {\\n   502→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   503→\\t}\\n   504→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   505→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   506→\\t}\\n   507→\\n   508→\\tif agentName == agent.AgentNameGemini {\\n   509→\\t\\tfmt.Fprintln(w, \\\"✓ Hooks installed - This is a work in progress\\\")\\n   510→\\t} else {\\n   511→\\t\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   512→\\t}\\n   513→\\n   514→\\t// Setup .entire directory\\n   515→\\tif _, err := setupEntireDirectory(); err != nil {\\n   516→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   517→\\t}\\n   518→\\n   519→\\t// Update settings to store the strategy\\n   520→\\tsettings, _ := LoadEntireSettings() //nolint:errcheck // settings defaults are fine\\n   521→\\tsettings.Enabled = true\\n   522→\\tif localDev {\\n   523→\\t\\tsettings.LocalDev = localDev\\n   524→\\t}\\n   525→\\n   526→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   527→\\tif skipPushSessions {\\n   528→\\t\\tif settings.StrategyOptions == nil {\\n   529→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   530→\\t\\t}\\n   531→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   532→\\t}\\n   533→\\n   534→\\t// Set strategy if provided\\n   535→\\tif strategyName != \\\"\\\" {\\n   536→\\t\\t// Map display name to internal name if needed\\n   537→\\t\\tinternalStrategy := strategyName\\n   538→\\t\\tif mapped, ok := strategyDisplayToInternal[strategyName]; ok {\\n   539→\\t\\t\\tinternalStrategy = mapped\\n   540→\\t\\t}\\n   541→\\t\\t// Validate the strategy exists\\n   542→\\t\\tif _, err := strategy.Get(internalStrategy); err != nil {\\n   543→\\t\\t\\treturn fmt.Errorf(\\\"unknown strategy: %s (use manual-commit or auto-commit)\\\", strategyName)\\n   544→\\t\\t}\\n   545→\\t\\tsettings.Strategy = internalStrategy\\n   546→\\t}\\n   547→\\n   548→\\t// Handle telemetry for non-interactive mode\\n   549→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   550→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   551→\\t\\tf := false\\n   552→\\t\\tsettings.Telemetry = &f\\n   553→\\t}\\n   554→\\n   555→\\tif err := SaveEntireSettings(settings); err != nil {\\n   556→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   557→\\t}\\n   558→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   559→\\n   560→\\t// Let the strategy handle its own setup requirements (creates entire/sessions branch, etc.)\\n   561→\\tstrat, err := strategy.Get(settings.Strategy)\\n   562→\\tif err != nil {\\n   563→\\t\\treturn fmt.Errorf(\\\"failed to get strategy: %w\\\", err)\\n   564→\\t}\\n   565→\\tif err := strat.EnsureSetup(); err != nil {\\n   566→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   567→\\t}\\n   568→\\n   569→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   570→\\n   571→\\treturn nil\\n   572→}\\n   573→\\n   574→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   575→func validateSetupFlags(useLocal, useProject bool) error {\\n   576→\\tif useLocal && useProject {\\n   577→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   578→\\t}\\n   579→\\treturn nil\\n   580→}\\n   581→\\n   582→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   583→// - Whether settings.json already exists\\n   584→// - The --local and --project flags\\n   585→// Returns (useLocal, showNotification).\\n   586→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   587→\\t// Explicit --local flag always uses local settings\\n   588→\\tif useLocal {\\n   589→\\t\\treturn true, false\\n   590→\\t}\\n   591→\\n   592→\\t// Explicit --project flag always uses project settings\\n   593→\\tif useProject {\\n   594→\\t\\treturn false, false\\n   595→\\t}\\n   596→\\n   597→\\t// No flags specified - check if settings file exists\\n   598→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   599→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   600→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   601→\\t\\treturn true, true\\n   602→\\t}\\n   603→\\n   604→\\t// Settings file doesn't exist - create it\\n   605→\\treturn false, false\\n   606→}\\n   607→\\n   608→// setupEntireDirectory creates the .entire directory and gitignore.\\n   609→// Returns true if the directory was created, false if it already existed.\\n   610→func setupEntireDirectory() (bool, error) {\\n   611→\\t// Get absolute path for the .entire directory\\n   612→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   613→\\tif err != nil {\\n   614→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   615→\\t}\\n   616→\\n   617→\\t// Check if directory already exists\\n   618→\\tcreated := false\\n   619→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   620→\\t\\tcreated = true\\n   621→\\t}\\n   622→\\n   623→\\t// Create .entire directory\\n   624→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   625→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   626→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   627→\\t}\\n   628→\\n   629→\\t// Create/update .gitignore with all required entries\\n   630→\\tif err := strategy.EnsureEntireGitignore(); err != nil {\\n   631→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   632→\\t}\\n   633→\\n   634→\\treturn created, nil\\n   635→}\\n   636→\\n   637→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   638→func setupGitHook() error {\\n   639→\\t// Use shared implementation from strategy package\\n   640→\\t// The localDev setting is read from settings.json\\n   641→\\t_, err := strategy.InstallGitHook(false) // not silent - show output during setup\\n   642→\\tif err != nil {\\n   643→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   644→\\t}\\n   645→\\treturn nil\\n   646→}\\n   647→\\n   648→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   649→func newSetupGitHookCmd() *cobra.Command {\\n   650→\\tcmd := &cobra.Command{\\n   651→\\t\\tUse:    \\\"git-hook\\\",\\n   652→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   653→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   654→\\t\\tRunE: func(_ *cobra.Command, _ []string) error {\\n   655→\\t\\t\\treturn setupGitHook()\\n   656→\\t\\t},\\n   657→\\t}\\n   658→\\n   659→\\treturn cmd\\n   660→}\\n   661→\\n   662→func newCurlBashPostInstallCmd() *cobra.Command {\\n   663→\\treturn &cobra.Command{\\n   664→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   665→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   666→\\t\\tHidden: true,\\n   667→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   668→\\t\\t\\tw := cmd.OutOrStdout()\\n   669→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   670→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   671→\\t\\t\\t}\\n   672→\\t\\t\\treturn nil\\n   673→\\t\\t},\\n   674→\\t}\\n   675→}\\n   676→\\n   677→// shellCompletionComment is the comment preceding the completion line\\n   678→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   679→\\n   680→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   681→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   682→\\n   683→// shellCompletionTarget returns the rc file path and completion lines for the\\n   684→// user's current shell.\\n   685→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   686→\\thome, err := os.UserHomeDir()\\n   687→\\tif err != nil {\\n   688→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   689→\\t}\\n   690→\\n   691→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   692→\\tswitch {\\n   693→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   694→\\t\\treturn \\\"Zsh\\\",\\n   695→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   696→\\t\\t\\t\\\"source <(entire completion zsh)\\\",\\n   697→\\t\\t\\tnil\\n   698→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   699→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   700→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   701→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   702→\\t\\t}\\n   703→\\t\\treturn \\\"Bash\\\",\\n   704→\\t\\t\\tbashRC,\\n   705→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   706→\\t\\t\\tnil\\n   707→\\tdefault:\\n   708→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   709→\\t}\\n   710→}\\n   711→\\n   712→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   713→// Only prompts if completion is not already configured.\\n   714→func promptShellCompletion(w io.Writer) error {\\n   715→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   716→\\tif err != nil {\\n   717→\\t\\tif errors.Is(err, errUnsupportedShell) {\\n   718→\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion not available for your shell. Supported: zsh, bash.\\\\n\\\")\\n   719→\\t\\t\\treturn nil\\n   720→\\t\\t}\\n   721→\\t\\treturn fmt.Errorf(\\\"shell completion: %w\\\", err)\\n   722→\\t}\\n   723→\\n   724→\\tif isCompletionConfigured(rcFile) {\\n   725→\\t\\tfmt.Fprintf(w, \\\"✓ Shell completion already configured in %s\\\\n\\\", rcFile)\\n   726→\\t\\treturn nil\\n   727→\\t}\\n   728→\\n   729→\\tvar selected string\\n   730→\\tform := NewAccessibleForm(\\n   731→\\t\\thuh.NewGroup(\\n   732→\\t\\t\\thuh.NewSelect[string]().\\n   733→\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Enable shell completion? (detected: %s)\\\", shellName)).\\n   734→\\t\\t\\t\\tOptions(\\n   735→\\t\\t\\t\\t\\thuh.NewOption(\\\"Yes\\\", \\\"yes\\\"),\\n   736→\\t\\t\\t\\t\\thuh.NewOption(\\\"No\\\", \\\"no\\\"),\\n   737→\\t\\t\\t\\t).\\n   738→\\t\\t\\t\\tValue(&selected),\\n   739→\\t\\t),\\n   740→\\t)\\n   741→\\n   742→\\tif err := form.Run(); err != nil {\\n   743→\\t\\t//nolint:nilerr // User cancelled - not a fatal error, just skip\\n   744→\\t\\treturn nil\\n   745→\\t}\\n   746→\\n   747→\\tif selected != \\\"yes\\\" {\\n   748→\\t\\treturn nil\\n   749→\\t}\\n   750→\\n   751→\\tif err := appendShellCompletion(rcFile, completionLine); err != nil {\\n   752→\\t\\treturn fmt.Errorf(\\\"failed to update %s: %w\\\", rcFile, err)\\n   753→\\t}\\n   754→\\n   755→\\tfmt.Fprintf(w, \\\"✓ Shell completion added to %s\\\\n\\\", rcFile)\\n   756→\\tfmt.Fprintln(w, \\\"  Restart your shell to activate\\\")\\n   757→\\n   758→\\treturn nil\\n   759→}\\n   760→\\n   761→// isCompletionConfigured checks if shell completion is already in the rc file.\\n   762→func isCompletionConfigured(rcFile string) bool {\\n   763→\\t//nolint:gosec // G304: rcFile is constructed from home dir + known filename, not user input\\n   764→\\tcontent, err := os.ReadFile(rcFile)\\n   765→\\tif err != nil {\\n   766→\\t\\treturn false // File doesn't exist or can't read, treat as not configured\\n   767→\\t}\\n   768→\\treturn strings.Contains(string(content), \\\"entire completion\\\")\\n   769→}\\n   770→\\n   771→// appendShellCompletion adds the completion line to the rc file.\\n   772→func appendShellCompletion(rcFile, completionLine string) error {\\n   773→\\t//nolint:gosec // G302: Shell rc files need 0644 for user readability\\n   774→\\tf, err := os.OpenFile(rcFile, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0o644)\\n   775→\\tif err != nil {\\n   776→\\t\\treturn fmt.Errorf(\\\"opening file: %w\\\", err)\\n   777→\\t}\\n   778→\\tdefer f.Close()\\n   779→\\n   780→\\t_, err = f.WriteString(\\\"\\\\n\\\" + shellCompletionComment + \\\"\\\\n\\\" + completionLine + \\\"\\\\n\\\")\\n   781→\\tif err != nil {\\n   782→\\t\\treturn fmt.Errorf(\\\"writing completion: %w\\\", err)\\n   783→\\t}\\n   784→\\treturn nil\\n   785→}\\n   786→\\n   787→// promptTelemetryConsent asks the user if they want to enable telemetry.\\n   788→// It modifies settings.Telemetry based on the user's choice or flags.\\n   789→// The caller is responsible for saving settings.\\n   790→func promptTelemetryConsent(settings *EntireSettings, telemetryFlag bool) error {\\n   791→\\t// Handle --telemetry=false flag first (always overrides existing setting)\\n   792→\\tif !telemetryFlag {\\n   793→\\t\\tf := false\\n   794→\\t\\tsettings.Telemetry = &f\\n   795→\\t\\treturn nil\\n   796→\\t}\\n   797→\\n   798→\\t// Skip if already asked\\n   799→\\tif settings.Telemetry != nil {\\n   800→\\t\\treturn nil\\n   801→\\t}\\n   802→\\n   803→\\t// Skip if env var disables telemetry (record as disabled)\\n   804→\\tif os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   805→\\t\\tf := false\\n   806→\\t\\tsettings.Telemetry = &f\\n   807→\\t\\treturn nil\\n   808→\\t}\\n   809→\\n   810→\\tconsent := true // Default to Yes\\n   811→\\tform := NewAccessibleForm(\\n   812→\\t\\thuh.NewGroup(\\n   813→\\t\\t\\thuh.NewConfirm().\\n   814→\\t\\t\\t\\tTitle(\\\"Help improve Entire CLI?\\\").\\n   815→\\t\\t\\t\\tDescription(\\\"Share anonymous usage data. No code or personal info collected.\\\").\\n   816→\\t\\t\\t\\tAffirmative(\\\"Yes\\\").\\n   817→\\t\\t\\t\\tNegative(\\\"No\\\").\\n   818→\\t\\t\\t\\tValue(&consent),\\n   819→\\t\\t),\\n   820→\\t)\\n   821→\\n   822→\\tif err := form.Run(); err != nil {\\n   823→\\t\\treturn fmt.Errorf(\\\"telemetry prompt: %w\\\", err)\\n   824→\\t}\\n   825→\\n   826→\\tsettings.Telemetry = &consent\\n   827→\\treturn nil\\n   828→}\\n   829→\\n   830→// runUninstall completely removes Entire from the repository.\\n   831→func runUninstall(w, errW io.Writer, force bool) error {\\n   832→\\t// Check if we're in a git repository\\n   833→\\tif _, err := paths.RepoRoot(); err != nil {\\n   834→\\t\\tfmt.Fprintln(errW, \\\"Not a git repository. Nothing to uninstall.\\\")\\n   835→\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n   836→\\t}\\n   837→\\n   838→\\t// Gather counts for display\\n   839→\\tsessionStateCount := countSessionStates()\\n   840→\\tshadowBranchCount := countShadowBranches()\\n   841→\\tgitHooksInstalled := strategy.IsGitHookInstalled()\\n   842→\\tclaudeHooksInstalled := checkClaudeCodeHooksInstalled()\\n   843→\\tgeminiHooksInstalled := checkGeminiCLIHooksInstalled()\\n   844→\\tentireDirExists := checkEntireDirExists()\\n   845→\\n   846→\\t// Check if there's anything to uninstall\\n   847→\\tif !entireDirExists && !gitHooksInstalled && sessionStateCount == 0 &&\\n   848→\\t\\tshadowBranchCount == 0 && !claudeHooksInstalled && !geminiHooksInstalled {\\n   849→\\t\\tfmt.Fprintln(w, \\\"Entire is not installed in this repository.\\\")\\n   850→\\t\\treturn nil\\n   851→\\t}\\n   852→\\n   853→\\t// Show confirmation prompt unless --force\\n   854→\\tif !force {\\n   855→\\t\\tfmt.Fprintln(w, \\\"\\\\nThis will completely remove Entire from this repository:\\\")\\n   856→\\t\\tif entireDirExists {\\n   857→\\t\\t\\tfmt.Fprintln(w, \\\"  - .entire/ directory\\\")\\n   858→\\t\\t}\\n   859→\\t\\tif gitHooksInstalled {\\n   860→\\t\\t\\tfmt.Fprintln(w, \\\"  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\\")\\n   861→\\t\\t}\\n   862→\\t\\tif sessionStateCount > 0 {\\n   863→\\t\\t\\tfmt.Fprintf(w, \\\"  - Session state files (%d)\\\\n\\\", sessionStateCount)\\n   864→\\t\\t}\\n   865→\\t\\tif shadowBranchCount > 0 {\\n   866→\\t\\t\\tfmt.Fprintf(w, \\\"  - Shadow branches (%d)\\\\n\\\", shadowBranchCount)\\n   867→\\t\\t}\\n   868→\\t\\tswitch {\\n   869→\\t\\tcase claudeHooksInstalled && geminiHooksInstalled:\\n   870→\\t\\t\\tfmt.Fprintln(w, \\\"  - Agent hooks (Claude Code, Gemini CLI)\\\")\\n   871→\\t\\tcase claudeHooksInstalled:\\n   872→\\t\\t\\tfmt.Fprintln(w, \\\"  - Agent hooks (Claude Code)\\\")\\n   873→\\t\\tcase geminiHooksInstalled:\\n   874→\\t\\t\\tfmt.Fprintln(w, \\\"  - Agent hooks (Gemini CLI)\\\")\\n   875→\\t\\t}\\n   876→\\t\\tfmt.Fprintln(w)\\n   877→\\n   878→\\t\\tvar confirmed bool\\n   879→\\t\\tform := NewAccessibleForm(\\n   880→\\t\\t\\thuh.NewGroup(\\n   881→\\t\\t\\t\\thuh.NewConfirm().\\n   882→\\t\\t\\t\\t\\tTitle(\\\"Are you sure you want to uninstall Entire?\\\").\\n   883→\\t\\t\\t\\t\\tAffirmative(\\\"Yes, uninstall\\\").\\n   884→\\t\\t\\t\\t\\tNegative(\\\"Cancel\\\").\\n   885→\\t\\t\\t\\t\\tValue(&confirmed),\\n   886→\\t\\t\\t),\\n   887→\\t\\t)\\n   888→\\n   889→\\t\\tif err := form.Run(); err != nil {\\n   890→\\t\\t\\treturn fmt.Errorf(\\\"confirmation cancelled: %w\\\", err)\\n   891→\\t\\t}\\n   892→\\n   893→\\t\\tif !confirmed {\\n   894→\\t\\t\\tfmt.Fprintln(w, \\\"Uninstall cancelled.\\\")\\n   895→\\t\\t\\treturn nil\\n   896→\\t\\t}\\n   897→\\t}\\n   898→\\n   899→\\tfmt.Fprintln(w, \\\"\\\\nUninstalling Entire CLI...\\\")\\n   900→\\n   901→\\t// 1. Remove agent hooks (lowest risk)\\n   902→\\tif err := removeAgentHooks(w); err != nil {\\n   903→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove agent hooks: %v\\\\n\\\", err)\\n   904→\\t}\\n   905→\\n   906→\\t// 2. Remove git hooks\\n   907→\\tremoved, err := strategy.RemoveGitHook()\\n   908→\\tif err != nil {\\n   909→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove git hooks: %v\\\\n\\\", err)\\n   910→\\t} else if removed > 0 {\\n   911→\\t\\tfmt.Fprintf(w, \\\"  Removed git hooks (%d)\\\\n\\\", removed)\\n   912→\\t}\\n   913→\\n   914→\\t// 3. Remove session state files\\n   915→\\tstatesRemoved, err := removeAllSessionStates()\\n   916→\\tif err != nil {\\n   917→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove session states: %v\\\\n\\\", err)\\n   918→\\t} else if statesRemoved > 0 {\\n   919→\\t\\tfmt.Fprintf(w, \\\"  Removed session states (%d)\\\\n\\\", statesRemoved)\\n   920→\\t}\\n   921→\\n   922→\\t// 4. Remove .entire/ directory\\n   923→\\tif err := removeEntireDirectory(); err != nil {\\n   924→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove .entire directory: %v\\\\n\\\", err)\\n   925→\\t} else if entireDirExists {\\n   926→\\t\\tfmt.Fprintln(w, \\\"  Removed .entire directory\\\")\\n   927→\\t}\\n   928→\\n   929→\\t// 5. Remove shadow branches\\n   930→\\tbranchesRemoved, err := removeAllShadowBranches()\\n   931→\\tif err != nil {\\n   932→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove shadow branches: %v\\\\n\\\", err)\\n   933→\\t} else if branchesRemoved > 0 {\\n   934→\\t\\tfmt.Fprintf(w, \\\"  Removed %d shadow branches\\\\n\\\", branchesRemoved)\\n   935→\\t}\\n   936→\\n   937→\\tfmt.Fprintln(w, \\\"\\\\nEntire CLI uninstalled successfully.\\\")\\n   938→\\treturn nil\\n   939→}\\n   940→\\n   941→// countSessionStates returns the number of active session state files.\\n   942→func countSessionStates() int {\\n   943→\\tstore, err := session.NewStateStore()\\n   944→\\tif err != nil {\\n   945→\\t\\treturn 0\\n   946→\\t}\\n   947→\\tstates, err := store.List(context.Background())\\n   948→\\tif err != nil {\\n   949→\\t\\treturn 0\\n   950→\\t}\\n   951→\\treturn len(states)\\n   952→}\\n   953→\\n   954→// countShadowBranches returns the number of shadow branches.\\n   955→func countShadowBranches() int {\\n   956→\\tbranches, err := strategy.ListShadowBranches()\\n   957→\\tif err != nil {\\n   958→\\t\\treturn 0\\n   959→\\t}\\n   960→\\treturn len(branches)\\n   961→}\\n   962→\\n   963→// checkClaudeCodeHooksInstalled checks if Claude Code hooks are installed.\\n   964→func checkClaudeCodeHooksInstalled() bool {\\n   965→\\tag, err := agent.Get(agent.AgentNameClaudeCode)\\n   966→\\tif err != nil {\\n   967→\\t\\treturn false\\n   968→\\t}\\n   969→\\thookAgent, ok := ag.(agent.HookSupport)\\n   970→\\tif !ok {\\n   971→\\t\\treturn false\\n   972→\\t}\\n   973→\\treturn hookAgent.AreHooksInstalled()\\n   974→}\\n   975→\\n   976→// checkGeminiCLIHooksInstalled checks if Gemini CLI hooks are installed.\\n   977→func checkGeminiCLIHooksInstalled() bool {\\n   978→\\tag, err := agent.Get(agent.AgentNameGemini)\\n   979→\\tif err != nil {\\n   980→\\t\\treturn false\\n   981→\\t}\\n   982→\\thookAgent, ok := ag.(agent.HookSupport)\\n   983→\\tif !ok {\\n   984→\\t\\treturn false\\n   985→\\t}\\n   986→\\treturn hookAgent.AreHooksInstalled()\\n   987→}\\n   988→\\n   989→// checkEntireDirExists checks if the .entire directory exists.\\n   990→func checkEntireDirExists() bool {\\n   991→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   992→\\tif err != nil {\\n   993→\\t\\tentireDirAbs = paths.EntireDir\\n   994→\\t}\\n   995→\\t_, err = os.Stat(entireDirAbs)\\n   996→\\treturn err == nil\\n   997→}\\n   998→\\n   999→// removeAgentHooks removes hooks from all agents that support hooks.\\n  1000→func removeAgentHooks(w io.Writer) error {\\n  1001→\\tvar errs []error\\n  1002→\\n  1003→\\t// Remove Claude Code hooks\\n  1004→\\tclaudeAgent, err := agent.Get(agent.AgentNameClaudeCode)\\n  1005→\\tif err == nil {\\n  1006→\\t\\tif hookAgent, ok := claudeAgent.(agent.HookSupport); ok {\\n  1007→\\t\\t\\twasInstalled := hookAgent.AreHooksInstalled()\\n  1008→\\t\\t\\tif err := hookAgent.UninstallHooks(); err != nil {\\n  1009→\\t\\t\\t\\terrs = append(errs, err)\\n  1010→\\t\\t\\t} else if wasInstalled {\\n  1011→\\t\\t\\t\\tfmt.Fprintln(w, \\\"  Removed Claude Code hooks\\\")\\n  1012→\\t\\t\\t}\\n  1013→\\t\\t}\\n  1014→\\t}\\n  1015→\\n  1016→\\t// Remove Gemini CLI hooks\\n  1017→\\tgeminiAgent, err := 