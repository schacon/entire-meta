: \\\"created.txt\\\", Content: \\\"created by claude\\\"},\\n    93→\\t})\\n    94→\\n    95→\\t// Simulate stop - this should NOT fail even though file is already committed\\n    96→\\terr = env.SimulateStop(session.ID, session.TranscriptPath)\\n    97→\\tif err != nil {\\n    98→\\t\\tt.Fatalf(\\\"SimulateStop should handle already-committed files gracefully, got error: %v\\\", err)\\n    99→\\t}\\n   100→}\\n   101→\\n   102→func TestSession_CreateTranscript(t *testing.T) {\\n   103→\\tt.Parallel()\\n   104→\\tenv := NewRepoWithCommit(t)\\n   105→\\tsession := env.NewSession()\\n   106→\\ttranscriptPath := session.CreateTranscript(\\\"Test prompt\\\", []FileChange{\\n   107→\\t\\t{Path: \\\"file1.txt\\\", Content: \\\"content1\\\"},\\n   108→\\t\\t{Path: \\\"file2.txt\\\", Content: \\\"content2\\\"},\\n   109→\\t})\\n   110→\\n   111→\\t// Verify transcript file exists\\n   112→\\tif _, err := os.Stat(transcriptPath); os.IsNotExist(err) {\\n   113→\\t\\tt.Error(\\\"transcript file should exist\\\")\\n   114→\\t}\\n   115→\\n   116→\\t// Verify session ID format\\n   117→\\tif session.ID != \\\"test-session-1\\\" {\\n   118→\\t\\tt.Errorf(\\\"session ID = %s, want test-session-1\\\", session.ID)\\n   119→\\t}\\n   120→}\\n   121→\\n   122→// TestHookRunner_SimulateStop_SubagentOnlyChanges tests that the stop hook correctly\\n   123→// creates a checkpoint when ONLY subagents (spawned via Task tool) modify files.\\n   124→// This is a regression test for ENT-297 where subagent file modifications were invisible\\n   125→// to checkpoint detection because ExtractModifiedFiles only looked at the main transcript.\\n   126→// The fix (ExtractAllModifiedFiles) also reads subagent transcript files.\\n   127→func TestHookRunner_SimulateStop_SubagentOnlyChanges(t *testing.T) {\\n   128→\\tt.Parallel()\\n   129→\\tenv := NewRepoWithCommit(t)\\n   130→\\t// Create a session\\n   131→\\tsession := env.NewSession()\\n   132→\\n   133→\\t// Simulate user prompt submit first (captures pre-prompt state)\\n   134→\\terr := env.SimulateUserPromptSubmit(session.ID)\\n   135→\\tif err != nil {\\n   136→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   137→\\t}\\n   138→\\n   139→\\t// Create a file on disk (simulating what a subagent would write)\\n   140→\\tenv.WriteFile(\\\"subagent_output.go\\\", \\\"package main\\\\n\\\\nfunc SubagentWork() {}\\\\n\\\")\\n   141→\\n   142→\\t// Build the main transcript manually. The main transcript contains ONLY\\n   143→\\t// a Task tool call (no Write/Edit). All file modifications happened in\\n   144→\\t// the subagent.\\n   145→\\tmainTranscript := NewTranscriptBuilder()\\n   146→\\tmainTranscript.AddUserMessage(\\\"Create a function in a new file\\\")\\n   147→\\tmainTranscript.AddAssistantMessage(\\\"I'll delegate this to a subagent.\\\")\\n   148→\\n   149→\\t// Add Task tool use\\n   150→\\ttaskToolUseID := mainTranscript.AddTaskToolUse(\\\"\\\", \\\"Create the function\\\")\\n   151→\\n   152→\\t// Add Task tool result with agentId\\n   153→\\tagentID := \\\"sub123abc\\\"\\n   154→\\tmainTranscript.AddTaskToolResult(taskToolUseID, agentID)\\n   155→\\n   156→\\tmainTranscript.AddAssistantMessage(\\\"The subagent completed the task.\\\")\\n   157→\\n   158→\\t// Write the main transcript\\n   159→\\tif err := mainTranscript.WriteToFile(session.TranscriptPath); err != nil {\\n   160→\\t\\tt.Fatalf(\\\"failed to write main transcript: %v\\\", err)\\n   161→\\t}\\n   162→\\n   163→\\t// Create the subagent transcript file in the directory structure the Stop hook expects:\\n   164→\\t// <transcriptDir>/<modelSessionID>/subagents/agent-<agentID>.jsonl\\n   165→\\ttranscriptDir := filepath.Dir(session.TranscriptPath)\\n   166→\\tsubagentsDir := filepath.Join(transcriptDir, session.ID, \\\"subagents\\\")\\n   167→\\tsubagentTranscriptPath := filepath.Join(subagentsDir, \\\"agent-\\\"+agentID+\\\".jsonl\\\")\\n   168→\\n   169→\\t// Build the subagent transcript with Write tool calls\\n