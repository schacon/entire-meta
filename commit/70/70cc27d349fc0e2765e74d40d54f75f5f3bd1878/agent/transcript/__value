role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01STzVpbvBgKAQco1ksHrWyX\",\"type\":\"tool_result\",\"content\":\"  1996→// TestPostCommit_EndedSession_SetsFullyCondensed verifies that an ENDED session\\n  1997→// is marked FullyCondensed after condensation when no carry-forward files remain.\\n  1998→func TestPostCommit_EndedSession_SetsFullyCondensed(t *testing.T) {\\n  1999→\\tdir := setupGitRepo(t)\\n  2000→\\tt.Chdir(dir)\\n  2001→\\n  2002→\\trepo, err := git.PlainOpen(dir)\\n  2003→\\trequire.NoError(t, err)\\n  2004→\\n  2005→\\ts := &ManualCommitStrategy{}\\n  2006→\\tsessionID := \\\"test-postcommit-ended-fully-condensed\\\"\\n  2007→\\n  2008→\\t// Initialize session and save a checkpoint\\n  2009→\\tsetupSessionWithCheckpoint(t, s, repo, dir, sessionID)\\n  2010→\\n  2011→\\t// Set phase to ENDED with files touched (the committed file matches shadow branch)\\n  2012→\\tstate, err := s.loadSessionState(context.Background(), sessionID)\\n  2013→\\trequire.NoError(t, err)\\n  2014→\\tnow := time.Now()\\n  2015→\\tstate.Phase = session.PhaseEnded\\n  2016→\\tstate.EndedAt = &now\\n  2017→\\tstate.FilesTouched = []string{\\\"test.txt\\\"}\"}]},\"uuid\":\"f89fa54c-e674-4b5c-9146-b6d9372d2228\",\"timestamp\":\"2026-03-01T20:13:33.521Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a406c86c765c14195\"},\"toolUseID\":\"agent_msg_01HJNoqk1URu2wWHAzC59tam\",\"parentToolUseID\":\"toolu_01TAAHUAkVJTks2M5qBDK6BD\",\"uuid\":\"434fd38f-e1f0-48ca-97e2-58889f2f7d11\",\"timestamp\":\"2026-03-01T20:13:33.522Z\"}\n{\"parentUuid\":\"434fd38f-e1f0-48ca-97e2-58889f2f7d11\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli\",\"sessionId\":\"db57b693-b4f5-47da-9cc5-651e9169ac1d\",\"version\":\"2.1.63\",\"gitBranch\":\"skip-fully-condensed-sessions\",\"slug\":\"cozy-napping-bachman\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-01T20:13:37.496Z\",