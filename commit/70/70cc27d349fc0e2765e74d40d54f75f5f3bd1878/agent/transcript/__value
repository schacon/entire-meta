\\t\\t// It previously meant \\\"agent active + commit happened during turn\\\".\\n    34→\\t\\t// Normalize to ACTIVE so HandleTurnEnd can finalize any pending checkpoints.\\n    35→\\t\\treturn PhaseActive\\n    36→\\tcase PhaseIdle:\\n    37→\\t\\treturn PhaseIdle\\n    38→\\tcase PhaseEnded:\\n    39→\\t\\treturn PhaseEnded\\n    40→\\tdefault:\\n    41→\\t\\t// Backward compat: truly unknown phases normalize to idle.\\n    42→\\t\\treturn PhaseIdle\\n    43→\\t}\\n    44→}\\n    45→\\n    46→// IsActive reports whether the phase represents an active agent turn.\\n    47→func (p Phase) IsActive() bool {\\n    48→\\treturn p == PhaseActive\\n    49→}\\n    50→\\n    51→// Event represents something that happened to a session.\\n    52→type Event int\\n    53→\\n    54→const (\\n    55→\\tEventTurnStart    Event = iota // Agent begins working on a prompt\\n    56→\\tEventTurnEnd                   // Agent finishes its turn\\n    57→\\tEventGitCommit                 // A git commit was made (PostCommit hook)\\n    58→\\tEventSessionStart              // Session process started (SessionStart hook)\\n    59→\\tEventSessionStop               // Session process ended (SessionStop hook)\\n    60→\\tEventCompaction                // Agent compacted context mid-turn (PreCompress hook)\\n    61→)\\n    62→\\n    63→// allEvents is the canonical list of events for enumeration.\\n    64→var allEvents = []Event{EventTurnStart, EventTurnEnd, EventGitCommit, EventSessionStart, EventSessionStop, EventCompaction}\\n    65→\\n    66→// String returns a human-readable name for the event.\\n    67→func (e Event) String() string {\\n    68→\\tswitch e {\\n    69→\\tcase EventTurnStart:\\n    70→\\t\\treturn \\\"TurnStart\\\"\\n    71→\\tcase EventTurnEnd:\\n    72→\\t\\treturn \\\"TurnEnd\\\"\\n    73→\\tcase EventGitCommit:\\n    74→\\t\\treturn \\\"GitCommit\\\"\\n    75→\\tcase EventSessionStart:\\n    76→\\t\\treturn \\\"SessionStart\\\"\\n    77→\\tcase EventSessionStop:\\n    7