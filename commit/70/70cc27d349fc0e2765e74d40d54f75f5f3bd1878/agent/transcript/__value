head, err := repo.Head()\\n   711→\\tif err != nil {\\n   712→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   713→\\t}\\n   714→\\n   715→\\tcommit, err := repo.CommitObject(head.Hash())\\n   716→\\tif err != nil {\\n   717→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   718→\\t}\\n   719→\\n   720→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   721→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   722→\\tif !found {\\n   723→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   724→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   725→\\t\\ts.postCommitUpdateBaseCommitOnly(ctx, head)\\n   726→\\t\\treturn nil\\n   727→\\t}\\n   728→\\n   729→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   730→\\tif err != nil {\\n   731→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   732→\\t}\\n   733→\\n   734→\\t// Find all active sessions for this worktree\\n   735→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   736→\\tif err != nil || len(sessions) == 0 {\\n   737→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   738→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   739→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   740→\\t\\t)\\n   741→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   742→\\t}\\n   743→\\n   744→\\t// Build transition context\\n   745→\\tisRebase := isGitSequenceOperation(ctx)\\n   746→\\ttransitionCtx := session.TransitionContext{\\n   747→\\t\\tIsRebaseInProgress: isRebase,\\n   748→\\t}\\n   749→\\n   750→\\tif isRebase {\\n   751→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   752→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   753→\\t\\t)\\n   754→\\t}\\n   755→\\n   756→\\t// Track shadow branch names and whether they can be deleted\\n   757→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   758→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   759→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   760→\\n   761→\\tnewHead := head.Hash().String()\\n   762→\\n   763→\\t// Pre-resolve HEAD tree and parent tree once for the entire PostCommit.\\n   764→\\t// These are immutable within this hook invocation and used by multiple\\n   765→\\t// per-session functions (filesChangedInCommit, filesOverlapWithContent,\\n   766→\\t// filesWithRemainingAgentChanges, calculateSessionAttributions).\\n   767→\\tvar headTree *object.Tree\\n   768→\\tif t, err := commit.Tree(); err == nil {\\n   769→\\t\\theadTree = t\\n   770→\\t}\\n   771→\\tvar parentTree *object.Tree\\n   772→\\tif commit.NumParents() > 0 {\\n   773→\\t\\tif parent, err := commit.Parent(0); err == nil {\\n   774→\\t\\t\\tif t, err := parent.Tree(); err == nil {\\n   775→\\t\\t\\t\\tparentTree = t\\n   776→\\t\\t\\t}\\n   777→\\t\\t}\\n   778→\\t}\\n   779→\\n   780→\\tcommittedFileSet := filesChangedInCommit(commit, headTree, parentTree)\\n   781→\\n   782→\\tfor _, state := range sessions {\\n   783→\\t\\t// Skip fully-condensed ended sessions — no work remains.\\n   784→\\t\\t// These sessions only persist for LastCheckpointID (amend trailer reuse).\\n   785→\\t\\tif state.FullyCondensed && state.Phase == session.PhaseEnded {\\n   786→\\t\\t\\tcontinue\\n   787→\\t\\t}\\n   788→\\t\\ts.postCommitProcessSession(ctx, repo, state, &transitionCtx, checkpointID,\\n   789→\\t\\t\\thead, commit, newHead, headTree, parentTree, committedFileSet,\\n   790→\\t\\t\\tshadowBranchesToDelete, uncondensedActiveOnBranch)\\n   791→\\t}\\n   792→\\n   793→\\t// Clean up shadow branches — only delete when ALL sessions on the branch are non-active\\n   794→\\t// or were condensed during this PostCommit.\\n   795→\\tfor shadowBranchName := range shadowBranchesToDelete {\\n   796→\\t\\tif uncondensedActiveOnBranch[shadowBranchName] {\\n   797→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: preserving shadow branch (active session exists)\\\",\\n   798→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   799→\\t\\t\\t)\\n   800→\\t\\t\\tcontinue\\n   801→\\t\\t}\\n   802→\\t\\tif err := deleteShadowBranch(ctx, repo, shadowBranchName); err != nil {\\n   803→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to clean up shadow branch\\\",\\n   804→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   805→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   806→\\t\\t} else {\\n   807→\\t\\t\\tlogging.Info(logCtx, \\\"shadow branch deleted\\\",\\n   808→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   809→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   810→\\t\\t\\t)\\n   811→\\t\\t}\\n   812→\\t}\\n   813→\\n   814→\\treturn nil\\n   815→}\\n   816→\\n   817→// postCommitProcessSession handles a single session within the PostCommit loop.\\n   818→// Pre-resolved git objects (headTree, parentTree) are shared across all sessions;\\n   819→// per-session shadow ref/tree are resolved once here and threaded through sub-calls.\\n   820→func (s *ManualCommitStrategy) postCommitProcessSession(\\n   821→\\tctx context.Context,\\n   822→\\trepo *git.Repository,\\n   823→\\tstate *SessionState,\\n   824→\\ttransitionCtx *session.TransitionContext,\\n   825→\\tcheckpointID id.CheckpointID,\\n   826→\\thead *plumbing.Reference,\\n   827→\\tcommit *object.Commit,\\n   828→\\tnewHead string,\\n   829→\\theadTree, parentTree *object.Tree,\\n   830→\\tcommittedFileSet map[string]struct{},\\n   831→\\tshadowBranchesToDelete map[string]struct{},\\n   832→\\tuncondensedActiveOnBranch map[string]bool,\\n   833→) {\\n   834→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   835→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   836→\\n   837→\\t// Pre-resolve shadow branch ref and tree for this session.\\n   838→\\t// These are read 4+ times across sessionHasNewContent, filesOverlapWithContent,\\n   839→\\t// CondenseSession, filesWithRemainingAgentChanges, and calculateSessionAttributions.\\n   840→\\tvar shadowRef *plumbing.Reference\\n   841→\\tvar shadowTree *object.Tree\\n   842→\\tif ref, refErr := repo.Reference(plumbing.NewBranchReferenceName(shadowBranchName), true); refErr == nil {\\n   843→\\t\\tshadowRef = ref\\n   844→\\t\\tif sc, scErr := repo.CommitObject(ref.Hash()); scErr == nil {\\n   845→\\t\\t\\tif st, stErr := sc.Tree(); stErr == nil {\\n   846→\\t\\t\\t\\tshadowTree = st\\n   847→\\t\\t\\t}\\n   848→\\t\\t}\\n   849→\\t}\\n   850→\\n   851→\\t// Check for new content (needed for TransitionContext and condensation).\\n   852→\\t// Fail-open: if content check errors, assume new content exists so we\\n   853→\\t// don't silently skip data that should have been condensed.\\n   854→\\t//\\n   855→\\t// For ACTIVE sessions: the commit has a checkpoint trailer (verified above),\\n   856→\\t// meaning PrepareCommitMsg already determined this commit is session-related.\\n   857→\\t// The trailer is only added when either:\\n   858→\\t//   - No TTY (agent/subagent committing) — added unconditionally\\n   859→\\t//   - TTY (human committing) — added after content detection confirmed agent work\\n   860→\\t// In both cases, PrepareCommitMsg already validated this commit. We trust\\n   861→\\t// that decision here. Transcript-based re-validation is unreliable because\\n   862→\\t// subagent transcripts may not be available yet (subagent still running).\\n   863→\\tvar hasNew bool\\n   864→\\tif state.Phase.IsActive() {\\n   865→\\t\\thasNew = true\\n   866→\\t} else {\\n   867→\\t\\tvar contentErr error\\n   868→\\t\\thasNew, contentErr = s.sessionHasNewContent(ctx, repo, state, shadowTree)\\n   869→\\t\\tif c