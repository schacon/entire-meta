ransitionContext struct {\\n   122→\\tHasFilesTouched    bool // len(FilesTouched) > 0\\n   123→\\tIsRebaseInProgress bool // .git/rebase-merge/ or .git/rebase-apply/ exists\\n   124→}\\n   125→\\n   126→// TransitionResult holds the outcome of a state machine transition.\\n   127→type TransitionResult struct {\\n   128→\\tNewPhase Phase\\n   129→\\tActions  []Action\\n   130→}\\n   131→\\n   132→// Transition computes the next phase and required actions given the current\\n   133→// phase and an event. This is a pure function with no side effects.\\n   134→//\\n   135→// Empty or unknown phase values are normalized to PhaseIdle for backward\\n   136→// compatibility with session state files created before phase tracking.\\n   137→func Transition(current Phase, event Event, ctx TransitionContext) TransitionResult {\\n   138→\\t// Normalize empty/unknown phase to idle for backward compatibility.\\n   139→\\tcurrent = PhaseFromString(string(current))\\n   140→\\n   141→\\tswitch current {\\n   142→\\tcase PhaseIdle:\\n   143→\\t\\treturn transitionFromIdle(event, ctx)\\n   144→\\tcase PhaseActive:\\n   145→\\t\\treturn transitionFromActive(event, ctx)\\n   146→\\tcase PhaseEnded:\\n   147→\\t\\treturn transitionFromEnded(event, ctx)\\n   148→\\tdefault:\\n   149→\\t\\t// PhaseFromString guarantees we only get known phases, but the\\n   150→\\t\\t// exhaustive linter requires handling the default case.\\n   151→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   152→\\t}\\n   153→}\\n   154→\\n   155→func transitionFromIdle(event Event, ctx TransitionContext) TransitionResult {\\n   156→\\tswitch event {\\n   157→\\tcase EventTurnStart:\\n   158→\\t\\treturn TransitionResult{\\n   159→\\t\\t\\tNewPhase: PhaseActive,\\n   160→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   161→\\t\\t}\\n   162→\\tcase EventTurnEnd:\\n   163→\\t\\t// Turn end while idle is a no-op (no active turn to end).\\n   164→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n  