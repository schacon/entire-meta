irCache    string\\n   399→\\tgitCommonDirCacheDir string\\n   400→)\\n   401→\\n   402→// ClearGitCommonDirCache clears the cached git common dir.\\n   403→// Useful for testing when changing directories.\\n   404→func ClearGitCommonDirCache() {\\n   405→\\tgitCommonDirMu.Lock()\\n   406→\\tgitCommonDirCache = \\\"\\\"\\n   407→\\tgitCommonDirCacheDir = \\\"\\\"\\n   408→\\tgitCommonDirMu.Unlock()\\n   409→}\\n   410→\\n   411→// getGitCommonDir returns the path to the shared git directory.\\n   412→// In a regular checkout, this is .git/\\n   413→// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n   414→// The result is cached per working directory.\\n   415→func getGitCommonDir(ctx context.Context) (string, error) {\\n   416→\\tcwd, err := os.Getwd() //nolint:forbidigo // used for cache key, not git-relative paths\\n   417→\\tif err != nil {\\n   418→\\t\\tcwd = \\\"\\\"\\n   419→\\t}\\n   420→\\n   421→\\t// Check cache with read lock first\\n   422→\\tgitCommonDirMu.RLock()\\n   423→\\tif gitCommonDirCache != \\\"\\\" && gitCommonDirCacheDir == cwd {\\n   424→\\t\\tcached := gitCommonDirCache\\n   425→\\t\\tgitCommonDirMu.RUnlock()\\n   426→\\t\\treturn cached, nil\\n   427→\\t}\\n   428→\\tgitCommonDirMu.RUnlock()\\n   429→\\n   430→\\t// Cache miss — resolve via git subprocess\\n   431→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-common-dir\\\")\\n   432→\\tcmd.Dir = \\\".\\\"\\n   433→\\toutput, err := cmd.Output()\\n   434→\\tif err != nil {\\n   435→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   436→\\t}\\n   437→\\n   438→\\tcommonDir := strings.TrimSpace(string(output))\\n   439→\\n   440→\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\n   441→\\t// so we need to make it absolute if it isn't already\\n   442→\\tif !filepath.IsAbs(commonDir) {\\n   443→\\t\\tcommonDir = filepath.Join(\\\".\\\", commonDir)\\n   444→\\t