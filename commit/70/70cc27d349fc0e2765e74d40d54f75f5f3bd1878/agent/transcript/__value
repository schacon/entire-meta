    51→\\t}\\n    52→\\n    53→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n    54→\\tif err != nil {\\n    55→\\t\\treturn false\\n    56→\\t}\\n    57→\\t_ = tty.Close()\\n    58→\\treturn true\\n    59→}\\n    60→\\n    61→// ttyResult represents the outcome of a TTY confirmation prompt.\\n    62→type ttyResult int\\n    63→\\n    64→const (\\n    65→\\tttyResultLink       ttyResult = iota // Link: add the checkpoint trailer\\n    66→\\tttyResultSkip                        // Skip: don't add the trailer\\n    67→\\tttyResultLinkAlways                  // Link and remember: add trailer + save \\\"always\\\" preference\\n    68→)\\n    69→\\n    70→// askConfirmTTY prompts the user via /dev/tty whether to link a commit to session context.\\n    71→// This requires a controlling terminal — callers must check hasTTY() first and handle\\n    72→// the no-TTY case (agent subprocesses, CI) themselves.\\n    73→//\\n    74→// header is displayed as the first line (e.g., \\\"Entire: Active Claude Code session\\\").\\n    75→// detail lines are displayed indented below the header.\\n    76→func askConfirmTTY(header string, details []string, prompt string, defaultYes bool) ttyResult {\\n    77→\\tdefaultResult := ttyResultSkip\\n    78→\\tif defaultYes {\\n    79→\\t\\tdefaultResult = ttyResultLink\\n    80→\\t}\\n    81→\\n    82→\\t// In test mode, don't try to interact with the real TTY — just use the default.\\n    83→\\t// ENTIRE_TEST_TTY=1 simulates \\\"a human is present\\\" for the hasTTY() check\\n    84→\\t// but we can't actually read from the TTY in tests.\\n    85→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n    86→\\t\\treturn defaultResult\\n    87→\\t}\\n    88→\\n    89→\\t// Open /dev/tty for both reading and writing.\\n    90→\\t// This is the controlling terminal, which works even when stdin/stderr are redirected\\n    91→\\t// (e.g., human runs git commit -m where stdin is not a pipe).\\n    92→\\ttty, err := os.OpenFile(\\\"