 its own checkpoint)\\n   551→//   - IDLE → condense immediately\\n   552→//   - ENDED → condense if files touched, discard if empty\\n   553→//\\n   554→// After condensation for ACTIVE sessions, remaining uncommitted files are\\n   555→// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n   556→//\\n   557→// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n   558→// and were condensed during this PostCommit.\\n   559→\\n   560→// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n   561→// Each session in the loop gets its own handler with per-session context.\\n   562→// Handler methods use the *State parameter from ApplyTransition (same pointer\\n   563→// as the state being transitioned) rather than capturing state separately.\\n   564→type postCommitActionHandler struct {\\n   565→\\ts                      *ManualCommitStrategy\\n   566→\\tctx                    context.Context\\n   567→\\trepo                   *git.Repository\\n   568→\\tcheckpointID           id.CheckpointID\\n   569→\\thead                   *plumbing.Reference\\n   570→\\tcommit                 *object.Commit\\n   571→\\tnewHead                string\\n   572→\\tshadowBranchName       string\\n   573→\\tshadowBranchesToDelete map[string]struct{}\\n   574→\\tcommittedFileSet       map[string]struct{}\\n   575→\\thasNew                 bool\\n   576→\\tfilesTouchedBefore     []string\\n   577→\\n   578→\\t// Cached git objects — resolved once per PostCommit invocation to avoid\\n   579→\\t// redundant reads across filesOverlapWithContent, filesWithRemainingAgentChanges,\\n   580→\\t// CondenseSession, and calculateSessionAttributions.\\n   581→\\theadTree   *object.Tree        // HEAD commit tree (shared across all sessions)\\n   582→\\tparentTree *object.Tree        // HEAD's first parent tree (shared, nil for initial commits)\\n   583→\\tshadowRef  *plumbing.Reference // Per-session shadow branch ref (nil if branch doesn't exist)\\n   584→\\tshadowTree *object.Tree        // Per-session shadow commit tree (nil if branch doesn't exist)\\n   585→\\n   586→\\t// Output: set by handler methods, read by caller after TransitionAndLog.\\n   587→\\tcondensed bool\\n   588→}\\n   589→\\n   590→func (h *postCommitActionHandler) HandleCondense(state *session.State) error {\\n   591→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   592→\\tshouldCondense := h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   593→\\n   594→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondense decision\\\",\\n   595→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   596→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   597→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   598→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   599→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   600→\\t)\\n   601→\\n   602→\\tif shouldCondense {\\n   603→\\t\\th.condensed = h.s.condenseAndUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   604→\\t\\t\\tshadowRef: h.shadowRef,\\n   605→\\t\\t\\theadTree:  h.headTree,\\n   606→\\t\\t})\\n   607→\\t} else {\\n   608→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   609→\\t}\\n   610→\\treturn nil\\n   611→}\\n   612→\\n   613→func (h *postCommitActionHandler) HandleCondenseIfFilesTouched(state *session.State) error {\\n   614→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   615→\\tshouldCondense := len(state.FilesTouched) > 0 && h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   616→\\n   617→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondenseIfFilesTouched decision\\\",\\n   618→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   619→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   620→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   621→\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n   622→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   623→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   624→\\t)\\n   625→\\n   626→\\tif shouldCondense {\\n   627→\\t\\th.condensed = h.s.condenseAndUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   628→\\t\\t\\tshadowRef: h.shadowRef,\\n   629→\\t\\t\\theadTree:  h.headTree,\\n   630→\\t\\t})\\n   631→\\t} else {\\n   632→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   633→\\t}\\n   634→\\treturn nil\\n   635→}\\n   636→\\n   637→// shouldCondenseWithOverlapCheck returns true if the session should be condensed\\n   638→// into this commit. Requires both that hasNew is true AND that the session's files\\n   639→// overlap with the committed files with matching content.\\n   640→//\\n   641→// This prevents stale sessions (ACTIVE sessions where the agent was killed, or\\n   642→// ENDED/IDLE sessions with carry-forward files) from being condensed into every\\n   643→// unrelated commit.\\n   644→//\\n   645→// filesTouchedBefore is populated from:\\n   646→//   - state.FilesTouched for IDLE/ENDED sessions (set via SaveStep/SaveTaskStep -> mergeFilesTouched)\\n   647→//   - transcript extraction for ACTIVE sessions when FilesTouched is empty\\n   648→//\\n   649→// When filesTouchedBefore is empty:\\n   650→//   - For ACTIVE sessions: fail-open (trust hasNew) because the agent may be\\n   651→//     mid-turn before any files are saved to state.\\n   652→//   - For IDLE/ENDED sessions: return false because there are no files to\\n   653→//     overlap with the commit.\\n   654→func (h *postCommitActionHandler) shouldCondenseWithOverlapCheck(isActive bool) bool {\\n   655→\\tif !h.hasNew {\\n   656→\\t\\treturn false\\n   657→\\t}\\n   658→\\tif len(h.filesTouchedBefore) == 0 {\\n   659→\\t\