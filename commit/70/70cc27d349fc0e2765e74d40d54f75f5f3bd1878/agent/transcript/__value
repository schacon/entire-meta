9QA1mT\",\"type\":\"tool_result\",\"content\":\"     1→package session\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"encoding/json\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"log/slog\\\"\\n     8→\\t\\\"os\\\"\\n     9→\\t\\\"os/exec\\\"\\n    10→\\t\\\"path/filepath\\\"\\n    11→\\t\\\"strings\\\"\\n    12→\\t\\\"sync\\\"\\n    13→\\t\\\"time\\\"\\n    14→\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    21→)\\n    22→\\n    23→const (\\n    24→\\t// SessionStateDirName is the directory name for session state files within git common dir.\\n    25→\\tSessionStateDirName = \\\"entire-sessions\\\"\\n    26→\\n    27→\\t// StaleSessionThreshold is the duration after which an ended session is considered stale\\n    28→\\t// and will be automatically deleted during load/list operations.\\n    29→\\tStaleSessionThreshold = 7 * 24 * time.Hour\\n    30→)\\n    31→\\n    32→// State represents the state of an active session.\\n    33→// This is stored in .git/entire-sessions/<session-id>.json\\n    34→type State struct {\\n    35→\\t// SessionID is the unique session identifier\\n    36→\\tSessionID string `json:\\\"session_id\\\"`\\n    37→\\n    38→\\t// CLIVersion is the version of the CLI that created this session\\n    39→\\tCLIVersion string `json:\\\"cli_version,omitempty\\\"`\\n    40→\\n    41→\\t// BaseCommit tracks the current shadow branch base. Initially set to HEAD when the\\n    42→\\t// session starts, but updated on migration (pull/rebase) and after condensation.\\n    43→\\t// Used for shadow branch naming and checkpoint storage — NOT for attribution.\\n    44→\\tBaseCommit string `json:\\\"base_commit\\\"`\\n    45→\\n    46→\\t// AttributionBaseCommit is the commit used as the reference point for attribution calculations.\\n    47→\\t// Unlike BaseCommit (which tracks the shadow branch and moves with migration), this field\\n    48→\\t// preserves the original base commit so deferred condensation can correctly calculate\\n    49→\\t// agent vs human line attribution. Updated only after successful condensation.\\n    50→\\tAttributionBaseCommit string `json:\\\"attribution_base_commit,omitempty\\\"`\\n    51→\\n    52→\\t// WorktreePath is the absolute path to the worktree root\\n    53→\\tWorktreePath string `json:\\\"worktree_path,omitempty\\\"`\\n    54→\\n    55→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n    56→\\t// Derived from .git/worktrees/<name>/, stable across git worktree move\\n    57→\\tWorktreeID string `json:\\\"worktree_id,omitempty\\\"`\\n    58→\\n    59→\\t// StartedAt is when the session was started\\n    60→\\tStartedAt time.Time `json:\\\"started_at\\\"`\\n    61→\\n    62→\\t// EndedAt is when the session was explicitly closed by the user.\\n    63→\\t// nil means the session is still active or was not cleanly closed.\\n    64→\\tEndedAt *time.Time `json:\\\"ended_at,omitempty\\\"`\\n    65→\\n    66→\\t// Phase is the lifecycle stage of this session (see phase.go).\\n    67→\\t// Empty means idle (backward compat with pre-state-machine files).\\n    68→\\tPhase Phase `json:\\\"phase,omitempty\\\"`\\n    69→\\n    70→\\t// TurnID is a unique identifier for the current agent turn.\\n    71→\\t// Lifecycle:\\n    72→\\t//   - Generated fresh in InitializeSession at each turn start\\n    73→\\t//   - Shared across all checkpoints within the same turn\\n    74→\\t//   - Used to correlate related checkpoints when a turn's work spans multiple commits\\n    75→\\t//   - Persists until the next InitializeSession call generates a new one\\n    76→\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n    77→\\n    78→\\t// TurnCheckpointIDs tracks all checkpoint IDs condensed during the current turn.\\n    79→\\t// Lifecycle:\\n    80→\\t//   - Set in PostCommit when a checkpoint is condensed for an ACTIVE session\\n    81→\\t//   - Consumed in HandleTurnEnd to finalize all checkpoints with the full transcript\\n    82→\\t//   - Cleared in HandleTurnEnd after finalization completes\\n    83→\\t//   - Cleared in InitializeSession when a new prompt starts\\n    84→\\t//   - Cleared when session is reset (ResetSession deletes the state file entirely)\\n    85→\\tTurnCheckpointIDs []string `json:\\\"turn_checkpoint_ids,omitempty\\\"`\\n    86→\\n    87→\\t// LastInteractionTime is updated on every hook invocation.\\n    88→\\t// Used for stale session detection in \\\"entire doctor\\\".\\n    89→\\tLastInteractionTime *time.Time `json:\\\"last_interaction_time,omitempty\\\"`\\n    90→\\n    91→\\t// StepCount is the number of checkpoints/steps created in this session.\\n    92→\\t// JSON tag kept as \\\"checkpoint_count\\\" for backward compatibility with existing state files.\\n    93→\\tStepCount int `json:\\\"checkpoint_count\\\"`\\n    94→\\n    95→\\t// CheckpointTranscriptStart is the transcript line offset where the current\\n    96→\\t// checkpoint cycle began. Set to 0 at session start, updated to current\\n    97→\\t// transcript length after each condensation. Used to scope the transcript\\n    98→\\t// for checkpoint condensation: \\\"everything since last checkpoint\\\".\\n    99→\\tCheckpointTranscriptStart int `json:\\\"checkpoint_transcript_start,omitempty\\\"`\\n   100→\\n   101→\\t// Deprecated: CondensedTranscriptLines is replaced by CheckpointTranscriptStart.\\n   102→\\t// Kept for backward compatibility with existing state files.\\n   103→\\t// Use NormalizeAfterLoad() to migrate.\\n   104→\\tCondensedTranscriptLines int `json:\\\"condensed_transcript_lines,omitempty\\\"`\\n   105→\\n   106→\\t// UntrackedFilesAtStart tracks files that existed at session start (to preserve during rewind)\\n   107→\\tUntrackedFilesAtStart []string `json:\\\"untracked_files_at_start,omitempty\\\"`\\n   108→\\n   109→\\t// FilesTouched tracks files modified/created/deleted during this session\\n   110→\\tFilesTouched []string `json:\\\"files_touched,omitempty\\\"`\\n   111→\\n   112→\\t// LastCheckpointID is the checkpoint ID from the most recent condensation.\\n   113→\\t// Used to restore the Entire-Checkpoint trailer on amend and to identify\\n   114→\\t// sessions that have been condensed at least once. Cleared on new prompt.\\n   115→\\tLastCheckpointID id.CheckpointID `json:\\\"last_checkpoint_id,omitempty\\\"`\\n   116→\\n   117→\\t// FullyCondensed indicates this session has been condensed and has no remaining\\n   118→\\t// carry-forward files. PostCommit skips fully-condensed sessions entirely.\\n   119→\\t// Set after successful condensation when no files remain for carry-forward\\n   120→\\t// and the session phase is ENDED. Cleared on session reactivation (ENDED →\\n   121→\\t// ACTIVE via TurnStart, or ENDED → IDLE via SessionStart) by ActionClearEndedAt.\\n   122→\\tFullyCondensed bool `json:\\\"fully_condensed,omitempty\\\"`\\n   123→\\n   124→\\t// AgentType identifies the agent that created this session (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\", \\\"Cursor\\\")\\n   125→\\tAgentType types.AgentType `json:\\\"agent_type,omitempty\\\"`\\n   126→\\n   127→\\t// Token usage tracking (accumulated across all checkpoints in this session)\\n   128→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   129→\\n   130→\\t// Deprecated: TranscriptLinesAtStart is replaced by CheckpointTranscriptStart.\\n   131→\\t// Kept for backward compatibility with existing state files.\\n   132→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   133→\\n   134→\\t// TranscriptIdentifierAtStart is the last transcript identifier when the session started.\\n   135→\\t// Used for identifier-based transcript scoping (UUID for Claude, message ID for Gemini).\\n   136→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"`\\n   137→\\n   138→\\t// TranscriptPath is the path to the live transcript file (for mid-session commit detection)\\n   139→\\tTranscriptPath string `json:\\\"transcript_path,omitempty\\\"`\\n   140→\\n   141→\\t// FirstPrompt is the first user prompt that started this session (truncated for display)\\n   142→\\tFirstPrompt string `json:\\\"first_prompt,omitempty\\\"`\\n   143→\\n   144→\\t// PromptAttributions tracks user and agent line changes at each prompt start.\\n   145→\\t// This enables accurate attribution by capturing user edits between checkpoints.\\n   146→\\tPromptAttributions []PromptAttribution `json:\\\"prompt_attributions,omitempty\\\"`\\n   147→\\n   148→\\t// PendingPromptAttribution holds attribution calculated at prompt start (before agent runs).\\n   149→\\t// This is moved to PromptAttributions when SaveStep is called.\\n   150→\\tPendingPromptAttribution *PromptAttribution `json:\\\"pending_prompt_attribution,omitempty\\\"`\\n   151→}\\n   152→\\n   153→// PromptAttribution captures line-level attribution data at the start of each prompt.\\n   154→// By recording what changed since the last checkpoint BEFORE the agent works,\\n   155→// we can accurately separate user edits from agent contributions.\\n   156→type PromptAttribution struct {\\n   157→\\t// CheckpointNumber is which checkpoint this was recorded before (1-indexed)\\n   158→\\tCheckpointNumber int `json:\\\"checkpoint_number\\\"`\\n   159→\\n   160→\\t// UserLinesAdded is lines added by user since the last checkpoint\\n   161→\\tUserLinesAdded int `json:\\\"user_lines_added\\\"`\\n   162→\\n   163→\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   164→\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   165→\\n   166→\\t// AgentLinesAdded is total agent lines added so far (base → last checkpoint).\\n   167→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   168→\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   169→\\n   170→\\t// AgentLinesRemoved is total agent lines removed so far (base → last checkpoint).\\n   171→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   172→\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   173→\\n   174→\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   175→\\t// This enables distinguishing user self-modifications from agent modifications.\\n   176→\\t// See docs/architecture/attribution.md for details.\\n   177→\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   178→}\\n   179→\\n   180→// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   181→// Call this after deserializing a State from JSON.\\n   182→func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   183→\\t// Normalize legacy phase values. \\\"active_committed\\\" was removed with the\\n   184→\\t// 1:1 checkpoint model in favor of the state machine handling commits\\n   185→\\t// during ACTIVE phase with immediate condensation.\\n   186→\\tif s.Phase == \\\"active_committed\\\" {\\n   187→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   188→\\t\\tlogging.Info(logCtx, \\\"migrating legacy active_committed phase to active\\\",\\n   189→\\t\\t\\tslog.String(\\\"session_id\\\", s.SessionID),\\n   190→\\t\\t)\\n   191→\\t\\ts.Phase = PhaseActive\\n   192→\\t}\\n   193→\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n   194→\\ts.Phase = PhaseFromString(string(s.Phase))\\n   195→\\n   196→\\t// Migrate transcript fields: CheckpointTranscriptStart replaces both\\n   197→\\t// CondensedTranscriptLines and TranscriptLinesAtStart from older state files.\\n   198→\\tif s.CheckpointTranscriptStart == 0 {\\n   199→\\t\\tif s.CondensedTranscriptLines > 0 {\\n   200→\\t\\t\\ts.CheckpointTranscriptStart = s.CondensedTranscriptLines\\n   201→\\t\\t} else if s.TranscriptLinesAtStart > 0 {\\n   202→\\t\\t\\ts.CheckpointTranscriptStart = s.TranscriptLinesAtStart\\n   203→\\t\\t}\\n   204→\\t}\\n   205→\\t// Clear deprecated fields so they aren't re-persisted.\\n   206→\\t// Note: this is a one-way migration. If the state is re-saved, older CLI versions\\n   207→\\t// will see 0 for these fields and fall back to scoping from the transcript start.\\n   208→\\t// This is acceptable since CLI upgrades are monotonic and the worst case is\\n   209→\\t// redundant transcript content in a condensation, not data loss.\\n   210→\\ts.CondensedTranscriptLines = 0\\n   211→\\ts.TranscriptLinesAtStart = 0\\n   212→\\n   213→\\t// Backfill AttributionBaseCommit for sessions created before this field existed.\\n   214→\\t// Without this, a mid-turn commit would migrate BaseCommit and the fallback in\\n   215→\\t// calculateSessionAttributions would use the migrated value, producing zero attribution.\\n   216→\\tif s.AttributionBaseCommit == \\\"\\\" && s.BaseCommit != \\\"\\\" {\\n   217→\\t\\ts.AttributionBaseCommit = s.BaseCommit\\n   218→\\t}\\n   219→}\\n   220→\\n   221→// IsStale returns true when the last time a session saw interaction exceeds StaleSessionThreshold.\\n   222→// If LastInteractionTime isn't set, we don't consider a session stale to avoid aggressively\\n   223→// deleting things.\\n   224→func (s *State) IsStale() bool {\\n   225→\\treturn s.LastInteractionTime != nil && time.Since(*s.LastInteractionTime) > StaleSessionThreshold\\n   226→}\\n   227→\\n   228→// StateStore provides low-level operations for managing session state files.\\n   229→//\\n   230→// StateStore is a primitive for session state persistence. It is NOT the same as\\n   231→// the Sessions interface - it only handles state files in .git/entire-sessions/,\\n   232→// not the full session data which includes checkpoint content.\\n   233→//\\n   234→// Use StateStore directly in strategies for performance-critical state operations.\\n   235→// Use the Sessions interface (when implemented) for high-level session management.\\n   236→type StateStore struct {\\n   237→\\t// stateDir is the directory where session state files are stored\\n   238→\\tstateDir string\\n   239→}\\n   240→\\n   241→// NewStateStore creates a new state store.\\n   242→// Uses the git common dir to store session state (shared across worktrees).\\n   243→func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   244→\\tcommonDir, err := getGitCommonDir(ctx)\\n   245→\\tif err != nil {\\n   246→\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   247→\\t}\\n   248→\\treturn &StateStore{\\n   249→\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   250→\\t}, nil\\n   251→}\\n   252→\\n   253→// NewStateStoreWithDir creates a new state store with a custom directory.\\n   254→// This is useful for testing.\\n   255→func NewStateStoreWithDir(stateDir string) *StateStore {\\n   256→\\treturn &StateStore{stateDir: stateDir}\\n   257→}\\n   258→\\n   259→// Load loads the session state for the given session ID.\\n   260→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   261→// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   262→func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   263→\\t// Validate session ID to prevent path traversal\\n   264→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   265→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   266→\\t}\\n   267→\\n   268→\\tstateFile := s.stateFilePath(sessionID)\\n   269→\\n   270→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is der