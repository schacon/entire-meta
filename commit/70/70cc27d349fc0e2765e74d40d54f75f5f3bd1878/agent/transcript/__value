egy) PostCommit(ctx context.Context) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   702→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\"}]},\"uuid\":\"ae49005e-b440-49d7-ad42-a734213aba31\",\"timestamp\":\"2026-03-01T20:12:27.559Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a01cd1a052f66820c\"},\"toolUseID\":\"agent_msg_01HJNoqk1URu2wWHAzC59tam\",\"parentToolUseID\":\"toolu_01QCFR9pgvxo8KHSPiXfzXDC\",\"uuid\":\"35a53c80-cce1-4c87-98b9-7ef7037c1824\",\"timestamp\":\"2026-03-01T20:12:27.561Z\"}\n{\"parentUuid\":\"35a53c80-cce1-4c87-98b9-7ef7037c1824\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli\",\"sessionId\":\"db57b693-b4f5-47da-9cc5-651e9169ac1d\",\"version\":\"2.1.63\",\"gitBranch\":\"skip-fully-condensed-sessions\",\"slug\":\"cozy-napping-bachman\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-01T20:12:27.999Z\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01DEt7ro2rtANNBUEswNGkbq\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_016BCw7sezQfyrRNCQ6ADYhn\",\"name\":\"Grep\",\"input\":{\"pattern\":\"FullyCondensed\",\"path\":\"/Users/soph/Work/entire/devenv/cli\",\"output_mode\":\"content\",\"-n\":true},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":783,\"cache_read_input_tokens\":34819,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":783},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYcyELKwZVFU79CreqPmX\",\"uuid\":\"9f7df241-8856-4c91-baf5-40a8e38c9a98\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a406c86c765c14195\"},\"toolUseID\":\"agent_msg_01HJNoqk1UR