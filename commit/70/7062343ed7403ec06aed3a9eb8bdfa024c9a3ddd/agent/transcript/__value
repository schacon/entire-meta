rcommit.yml\\\", false},\\n    29→\\t}\\n    30→\\n    31→\\t// Lefthook supports {.,}lefthook{,-local}.{yml,yaml,json,toml}\\n    32→\\tfor _, prefix := range []string{\\\"\\\", \\\".\\\"} {\\n    33→\\t\\tfor _, variant := range []string{\\\"\\\", \\\"-local\\\"} {\\n    34→\\t\\t\\tfor _, ext := range []string{\\\"yml\\\", \\\"yaml\\\", \\\"json\\\", \\\"toml\\\"} {\\n    35→\\t\\t\\t\\tname := prefix + \\\"lefthook\\\" + variant + \\\".\\\" + ext\\n    36→\\t\\t\\t\\tchecks = append(checks, hookManager{\\\"Lefthook\\\", name, false})\\n    37→\\t\\t\\t}\\n    38→\\t\\t}\\n    39→\\t}\\n    40→\\n    41→\\tseen := make(map[string]bool)\\n    42→\\tfor _, c := range checks {\\n    43→\\t\\tpath := filepath.Join(repoRoot, c.ConfigPath)\\n    44→\\t\\tif _, err := os.Stat(path); err == nil {\\n    45→\\t\\t\\tif seen[c.Name] {\\n    46→\\t\\t\\t\\tcontinue // e.g., lefthook.yml and .lefthook.yml both present\\n    47→\\t\\t\\t}\\n    48→\\t\\t\\tseen[c.Name] = true\\n    49→\\t\\t\\tmanagers = append(managers, c)\\n    50→\\t\\t}\\n    51→\\t}\\n    52→\\n    53→\\treturn managers\\n    54→}\\n    55→\\n    56→// hookManagerWarning builds a warning string for detected hook managers.\\n    57→// cmdPrefix is the CLI command prefix (e.g., \\\"entire\\\" or \\\"go run ./cmd/entire/main.go\\\").\\n    58→func hookManagerWarning(managers []hookManager, cmdPrefix string) string {\\n    59→\\tif len(managers) == 0 {\\n    60→\\t\\treturn \\\"\\\"\\n    61→\\t}\\n    62→\\n    63→\\tvar b strings.Builder\\n    64→\\n    65→\\tspecs := buildHookSpecs(cmdPrefix)\\n    66→\\n    67→\\tfor _, m := range managers {\\n    68→\\t\\tif m.OverwritesHooks {\\n    69→\\t\\t\\tfmt.Fprintf(&b, \\\"Warning: %s detected (%s)\\\\n\\\", m.Name, m.ConfigPath)\\n    70→\\t\\t\\tfmt.Fprintf(&b, \\\"\\\\n\\\")\\n    71→\\t\\t\\tfmt.Fprintf(&b, \\\"  %s may overwrite hooks installed by Entire on npm install.\\\\n\\\", m.Name)\\n    72→\\t\\t\\tfmt.Fprintf(&b, \\\"  To make Entire hooks permanent