\\"encoding/json\\\"\\n     7→\\t\\\"errors\\\"\\n     8→\\t\\\"fmt\\\"\\n     9→\\t\\\"io\\\"\\n    10→\\t\\\"os\\\"\\n    11→\\t\\\"path/filepath\\\"\\n    12→\\t\\\"regexp\\\"\\n    13→\\t\\\"time\\\"\\n    14→\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    18→)\\n    19→\\n    20→//nolint:gochecknoinits // Agent self-registration is the intended pattern\\n    21→func init() {\\n    22→\\tagent.Register(agent.AgentNameClaudeCode, NewClaudeCodeAgent)\\n    23→}\\n    24→\\n    25→// ClaudeCodeAgent implements the Agent interface for Claude Code.\\n    26→//\\n    27→//nolint:revive // ClaudeCodeAgent is clearer than Agent in this context\\n    28→type ClaudeCodeAgent struct{}\\n    29→\\n    30→// NewClaudeCodeAgent creates a new Claude Code agent instance.\\n    31→func NewClaudeCodeAgent() agent.Agent {\\n    32→\\treturn &ClaudeCodeAgent{}\\n    33→}\\n    34→\\n    35→// Name returns the agent registry key.\\n    36→func (c *ClaudeCodeAgent) Name() agent.AgentName {\\n    37→\\treturn agent.AgentNameClaudeCode\\n    38→}\\n    39→\\n    40→// Type returns the agent type identifier.\\n    41→func (c *ClaudeCodeAgent) Type() agent.AgentType {\\n    42→\\treturn agent.AgentTypeClaudeCode\\n    43→}\\n    44→\\n    45→// Description returns a human-readable description.\\n    46→func (c *ClaudeCodeAgent) Description() string {\\n    47→\\treturn \\\"Claude Code - Anthropic's CLI coding assistant\\\"\\n    48→}\\n    49→\\n    50→func (c *ClaudeCodeAgent) IsPreview() bool { return false }\\n    51→\\n    52→// DetectPresence checks if Claude Code is configured in the repository.\\n    53→func (c *ClaudeCodeAgent) DetectPresence() (bool, error) {\\n    54→\\t// Get repo root to check for .claude directory\\n    55→\\t// This is needed because the CLI may be run from a subdirectory\\n    56→\\trepoRoot, err := paths.RepoRoot()\\n    57→\\tif err != nil {\\n    58→\\t\\t// Not in a git repo, fall back to CWD-relative check\\n    59→\\t\\trepoRoot = \\\".\\\"\\n    60→\\t}\\n    61→\\n    62→\\t// Check for .claude directory\\n    63→\\tclaudeDir := filepath.Join(repoRoot, \\\".claude\\\")\\n    64→\\tif _, err := os.Stat(claudeDir); err == nil {\\n    65→\\t\\treturn true, nil\\n    66→\\t}\\n    67→\\t// Check for .claude/settings.json\\n    68→\\tsettingsFile := filepath.Join(repoRoot, \\\".claude\\\", \\\"settings.json\\\")\\n    69→\\tif _, err := os.Stat(settingsFile); err == nil {\\n    70→\\t\\treturn true, nil\\n    71→\\t}\\n    72→\\treturn false, nil\\n    73→}\\n    74→\\n    75→// GetSessionID extracts the session ID from hook input.\\n    76→func (c *ClaudeCodeAgent) GetSessionID(input *agent.HookInput) string {\\n    77→\\treturn input.SessionID\\n    78→}\\n    79→\\n    80→// ResolveSessionFile returns the path to a Claude session file.\\n    81→// Claude names files directly as <id>.jsonl.\\n    82→func (c *ClaudeCodeAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n    83→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".jsonl\\\")\\n    84→}\\n    85→\\n    86→// ProtectedDirs returns directories that Claude uses for config/state.\\n    87→func (c *ClaudeCodeAgent) ProtectedDirs() []string { return []string{\\\".claude\\\"} }\\n    88→\\n    89→// GetSessionDir returns the directory where Claude stores session transcripts.\\n    90→func (c *ClaudeCodeAgent) GetSessionDir(repoPath string) (string, error) {\\n    91→\\t// Check for test environment override\\n    92→\\tif override := os.Getenv(\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR\\\"); override != \\\"\\\" {\\n    93→\\t\\treturn override, nil\\n    94→\\t}\\n    95→\\n    96→\\thomeDir, err := os.UserHomeDir()\\n    97→\\tif err != nil {\\n    98→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n    99→\\t}\\n   100→\\n   101→\\tprojectDir := SanitizePathForClaude(repoPath)\\n   102→\\treturn filepath.Join(homeDir, \\\".claude\\\", \\\"projects\\\", projectDir), nil\\n   103→}\\n   104→\\n   105→// ReadSession reads a session from Claude's storage (JSONL transcript file).\\n   106→// The session data is stored in NativeData as raw JSONL bytes.\\n   107→// ModifiedFiles is computed by parsing the transcript.\\n   108→func (c *ClaudeCodeAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   109→\\tif input.SessionRef == \\\"\\\" {\\n   110→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   111→\\t}\\n   112→\\n   113→\\t// Read the raw JSONL file\\n   114→\\tdata, err := os.ReadFile(input.SessionRef)\\n   115→\\tif err != nil {\\n   116→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   117→\\t}\\n   118→\\n   119→\\t// Parse to extract computed fields\\n   120→\\tlines, err := transcript.ParseFromBytes(data)\\n   121→\\tif err != nil {\\n   122→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   123→\\t}\\n   124→\\n   125→\\treturn &agent.AgentSession{\\n   126→\\t\\tSessionID:     input.SessionID,\\n   127→\\t\\tAgentName:     c.Name(),\\n   128→\\t\\tSessionRef:    input.SessionRef,\\n   129→\\t\\tStartTime:     time.Now(),\\n   130→\\t\\tNativeData:    data,\\n   131→\\t\\tModifiedFiles: ExtractModifiedFiles(lines),\\n   132→\\t}, nil\\n   133→}\\n   134→\\n   135→// WriteSession writes a session to Claude's storage (JSONL transcript file).\\n   136→// Uses the NativeData field which contains raw JSONL bytes.\\n   137→// The session must have been created by Claude Code (AgentName check).\\n   138→func (c *ClaudeCodeAgent) WriteSession(session *agent.AgentSession) error {\\n   139→\\tif session == nil {\\n   140→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   141→\\t}\\n   142→\\n   143→\\t// Verify this session belongs to Claude Code\\n   144→\\tif session.AgentName != \\\"\\\" && session.AgentName != c.Name() {\\n   145→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, c.Name())\\n   146→\\t}\\n   147→\\n   148→\\tif session.SessionRef == \\\"\\\" {\\n   149→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   150→\\t}\\n   151→\\n   152→\\tif len(session.NativeData) == 0 {\\n   153→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   154→\\t}\\n   155→\\n   156→\\t// Write the raw JSONL data\\n   157→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   158→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   159→\\t}\\n   160→\\n   161→\\treturn nil\\n   162→}\\n   163→\\n   164→// FormatResumeCommand returns the command to resume a Claude Code session.\\n   165→func (c *ClaudeCodeAgent) FormatResumeCommand(sessionID string) string {\\n   166→\\treturn \\\"claude -r \\\" + sessionID\\n   167→}\\n   168→\\n   169→// Session helper methods - work on AgentSession with Claude's native JSONL data\\n   170→\\n   171→// GetLastUserPrompt extracts the last user prompt from the session.\\n   172→// Requires NativeData to be populated (call ReadSession first).\\n   173→func (c *ClaudeCodeAgent) GetLastUserPrompt(session *agent.AgentSession) string {\\n   174→\\tif session == nil || len(session.NativeData) == 0 {\\n   175→\\t\\treturn \\\"\\\"\\n   176→\\t}\\n   177→\\n   178→\\tlines, err := transcript.ParseFromBytes(session.NativeData)\\n   179→\\tif err != nil {\\n   180→\\t\\treturn \\\"\\\"\\n   181→\\t}\\n   182→\\n   183→\\treturn ExtractLastUserPrompt(lines)\\n   184→}\\n   185→\\n   186→// TruncateAtUUID returns a new session truncated at the given UUID (inclusive).\\n   187→// This is used for rewind operations to restore transcript state.\\n   188→// Requires NativeData to be populated.\\n   189→func (c *ClaudeCodeAgent) TruncateAtUUID(session *agent.AgentSession, uuid string) (*agent.AgentSession, error) {\\n   190→\\tif session == nil {\\n   191→\\t\\treturn nil, errors.New(\\\"session is nil\\\")\\n   192→\\t}\\n   193→\\n   194→\\tif len(session.NativeData) == 0 {\\n   195→\\t\\treturn nil, errors.New(\\\"session has no native data\\\")\\n   196→\\t}\\n   197→\\n   198→\\tif uuid == \\\"\\\" {\\n   199→\\t\\t// No truncation needed, return copy\\n   200→\\t\\treturn &agent.AgentSession{\\n   201→\\t\\t\\tSessionID:     session.SessionID,\\n   202→\\t\\t\\tAgentName:     session.AgentName,\\n   203→\\t\\t\\tRepoPath:      session.RepoPath,\\n   204→\\t\\t\\tSessionRef:    session.SessionRef,\\n   205→\\t\\t\\tStartTime:     session.StartTime,\\n   206→\\t\\t\\tNativeData:    session.NativeData,\\n   207→\\t\\t\\tModifiedFiles: session.ModifiedFiles,\\n   208→\\t\\t}, nil\\n   209→\\t}\\n   210→\\n   211→\\t// Parse, truncate, re-serialize\\n   212→\\tlines, err := transcript.ParseFromBytes(session.NativeData)\\n   213→\\tif err != nil {\\n   214→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   215→\\t}\\n   216→\\n   217→\\ttruncated := TruncateAtUUID(lines, uuid)\\n   218→\\n   219→\\tnewData, err := SerializeTranscript(truncated)\\n   220→\\tif err != nil {\\n   221→\\t\\treturn nil, fmt.Errorf(\\\"failed to serialize truncated transcript: %w\\\", err)\\n   222→\\t}\\n   223→\\n   224→\\treturn &agent.AgentSession{\\n   225→\\t\\tSessionID:     session.SessionID,\\n   226→\\t\\tAgentName:     session.AgentName,\\n   227→\\t\\tRepoPath:      session.RepoPath,\\n   228→\\t\\tSessionRef:    session.SessionRef,\\n   229→\\t\\tStartTime:     session.StartTime,\\n   230→\\t\\tNativeData:    newData,\\n   231→\\t\\tModifiedFiles: ExtractModifiedFiles(truncated),\\n   232→\\t}, nil\\n   233→}\\n   234→\\n   235→// FindCheckpointUUID finds the UUID of the message containing the tool_result\\n   236→// for the given tool use ID. Used for task checkpoint rewind.\\n   237→// Returns the UUID and true if found, empty string and false otherwise.\\n   238→func (c *ClaudeCodeAgent) FindCheckpointUUID(session *agent.AgentSession, toolUseID string) (string, bool) {\\n   239→\\tif session == nil || len(session.NativeData) == 0 {\\n   240→\\t\\treturn \\\"\\\", false\\n   241→\\t}\\n   242→\\n   243→\\tlines, err := transcript.ParseFromBytes(session.NativeData)\\n   244→\\tif err != nil {\\n   245→\\t\\treturn \\\"\\\", false\\n   246→\\t}\\n   247→\\n   248→\\treturn FindCheckpointUUID(lines, toolUseID)\\n   249→}\\n   250→\\n   251→// ReadSessionFromPath is a convenience method that reads a session directly from a file path.\\n   252→// This is useful when you have the path but not a HookInput.\\n   253→func (c *ClaudeCodeAgent) ReadSessionFromPath(transcriptPath, sessionID string) (*agent.AgentSession, error) {\\n   254→\\treturn c.ReadSession(&agent.HookInput{\\n   255→\\t\\tSessionID:  sessionID,\\n   256→\\t\\tSessionRef: transcriptPath,\\n   257→\\t})\\n   258→}\\n   259→\\n   260→// SanitizePathForClaude converts a path to Claude's project directory format.\\n   261→// Claude replaces any non-alphanumeric character with a dash.\\n   262→var nonAlphanumericRegex = regexp.MustCompile(`[^a-zA-Z0-9]`)\\n   263→\\n   264→func SanitizePathForClaude(path string) string {\\n   265→\\treturn nonAlphanumericRegex.ReplaceAllString(path, \\\"-\\\")\\n   266→}\\n   267→\\n   268→// TranscriptAnalyzer interface implementation\\n   269→\\n   270→// GetTranscriptPosition returns the current line count of a Claude Code transcript.\\n   271→// Claude Code uses JSONL format, so position is the number of lines.\\n   272→// This is a lightweight operation that only counts lines without parsing JSON.\\n   273→// Uses bufio.Reader to handle arbitrarily long lines (no size limit).\\n   274→// Returns 0 if the file doesn't exist or is empty.\\n   275→func (c *ClaudeCodeAgent) GetTranscriptPosition(path string) (int, error) {\\n   276→\\tif path == \\\"\\\" {\\n   277→\\t\\treturn 0, nil\\n   278→\\t}\\n   279→\\n   280→\\tfile, err := os.Open(path) //nolint:gosec // Path comes from Claude Code transcript location\\n   281→\\tif err != nil {\\n   282→\\t\\tif os.IsNotExist(err) {\\n   283→\\t\\t\\treturn 0, nil\\n   284→\\t\\t}\\n   285→\\t\\treturn 0, fmt.Errorf(\\\"failed to open transcript file: %w\\\", err)\\n   286→\\t}\\n   287→\\tdefer file.Close()\\n   288→\\n   289→\\treader := bufio.NewReader(file)\\n   290→\\tlineCount := 0\\n   291→\\n   292→\\tfor {\\n   293→\\t\\tline, err := reader.ReadBytes('\\\\n')\\n   294→\\t\\tif err != nil {\\n   295→\\t\\t\\tif err == io.EOF {\\n   296→\\t\\t\\t\\tif len(line) > 0 {\\n   297→\\t\\t\\t\\t\\tlineCount++ // Count final line without trailing newline\\n   298→\\t\\t\\t\\t}\\n   299→\\t\\t\\t\\tbreak\\n   300→\\t\\t\\t}\\n   301→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   302→\\t\\t}\\n   303→\\t\\tlineCount++\\n   304→\\t}\\n   305→\\n   306→\\treturn lineCount, nil\\n   307→}\\n   308→\\n   309→// ExtractModifiedFilesFromOffset extracts files modified since a given line number.\\n   310→// For Claude Code (JSONL format), offset is the starting line number.\\n   311→// Uses bufio.Reader to handle arbitrarily long lines (no size limit).\\n   312→// Returns:\\n   313→//   - files: list of file paths modified by Claude (from Write/Edit tools)\\n   314→//   - currentPosition: total number of lines in the file\\n   315→//   - error: any error encountered during reading\\n   316→func (c *ClaudeCodeAgent) ExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error) {\\n   317→\\tif path == \\\"\\\" {\\n   318→\\t\\treturn nil, 0, nil\\n   319→\\t}\\n   320→\\n   321→\\tfile, openErr := os.Open(path) //nolint:gosec // Path comes from Claude Code transcript location\\n   322→\\tif openErr != nil {\\n   323→\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to open transcript file: %w\\\", openErr)\\n   324→\\t}\\n   325→\\tdefer file.Close()\\n   326→\\n   327→\\treader := bufio.NewReader(file)\\n   328→\\tvar lines []TranscriptLine\\n   329→\\tlineNum := 0\\n   330→\\n   331→\\tfor {\\n   332→\\t\\tlineData, readErr := reader.ReadBytes('\\\\n')\\n   333→\\t\\tif readErr != nil && readErr != io.EOF {\\n   334→\\t\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", readErr)\\n   335→\\t\\t}\\n   336→\\n   337→\\t\\tif len(lineData) > 0 {\\n   338→\\t\\t\\tlineNum++\\n   339→\\t\\t\\tif lineNum > startOffset {\\n   340→\\t\\t\\t\\tvar line TranscriptLine\\n   341→\\t\\t\\t\\tif parseErr := json.Unmarshal(lineData, &line); parseErr == nil {\\n   342→\\t\\t\\t\\t\\tlines = append(lines, line)\\n   343→\\t\\t\\t\\t}\\n   344→\\t\\t\\t\\t// Skip malformed lines silently\\n   345→\\t\\t\\t}\\n   346→\\t\\t}\\n   347→\\n   348→\\t\\tif readErr == io.EOF {\\n   349→\\t\\t\\tbreak\\n   350→\\t\\t}\\n   351→\\t}\\n   352→\\n   353→\\treturn ExtractModifiedFiles(lines), lineNum, nil\\n   354→}\\n   355→\\n   356→// ChunkTranscript splits a JSONL transcript at line boundaries.\\n   357→// Claude Code uses JSONL format (one JSON object per line), so chunking\\n   358→// is done at newline boundaries to preserve message integrity.\\n   359→func (c *ClaudeCodeAgent) ChunkTranscript(content []byte, maxSize int) ([][]byte, error) {\\n   360→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n   361→\\tif err != nil {\\n   362→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk JSONL transcript: %w\\\", err)\\n   363→\\t}\\n   364→\\treturn chunks, nil\\n   365→}\\n   366→\\n   367→// ReassembleTranscript concatenates JSONL chunks with newlines.\\n   368→//\\n   369→\\n   370→func (c *ClaudeCodeAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n   371→\\treturn agent.ReassembleJSONL(chunks), nil\\n   372→}\\n   373→\\n   374→// SubagentAwareExtractor interface implementation\\n   375→\\n   376→// ExtractAllModifiedFiles extracts files modified by both the main agent and any spawned subagents.\\n   377→// Claud