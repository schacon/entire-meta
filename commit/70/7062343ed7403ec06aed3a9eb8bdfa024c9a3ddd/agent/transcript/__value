() {\\n    34→\\t\\tstore, err := session.NewStateStore()\\n    35→\\t\\tif err != nil {\\n    36→\\t\\t\\ts.stateStoreErr = fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n    37→\\t\\t\\treturn\\n    38→\\t\\t}\\n    39→\\t\\ts.stateStore = store\\n    40→\\t})\\n    41→\\treturn s.stateStore, s.stateStoreErr\\n    42→}\\n    43→\\n    44→// getCheckpointStore returns the checkpoint store, initializing it lazily if needed.\\n    45→// Thread-safe via sync.Once.\\n    46→func (s *ManualCommitStrategy) getCheckpointStore() (*checkpoint.GitStore, error) {\\n    47→\\ts.checkpointStoreOnce.Do(func() {\\n    48→\\t\\trepo, err := OpenRepository()\\n    49→\\t\\tif err != nil {\\n    50→\\t\\t\\ts.checkpointStoreErr = fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n    51→\\t\\t\\treturn\\n    52→\\t\\t}\\n    53→\\t\\ts.checkpointStore = checkpoint.NewGitStore(repo)\\n    54→\\t})\\n    55→\\treturn s.checkpointStore, s.checkpointStoreErr\\n    56→}\\n    57→\\n    58→// NewManualCommitStrategy creates a new manual-commit strategy instance.\\n    59→//\\n    60→\\n    61→func NewManualCommitStrategy() Strategy {\\n    62→\\treturn &ManualCommitStrategy{}\\n    63→}\\n    64→\\n    65→// NewShadowStrategy creates a new manual-commit strategy instance.\\n    66→// This legacy constructor delegates to NewManualCommitStrategy.\\n    67→//\\n    68→\\n    69→func NewShadowStrategy() Strategy {\\n    70→\\treturn NewManualCommitStrategy()\\n    71→}\\n    72→\\n    73→// Name returns the strategy name.\\n    74→func (s *ManualCommitStrategy) Name() string {\\n    75→\\treturn StrategyNameManualCommit\\n    76→}\\n    77→\\n    78→// Description returns the strategy description.\\n    79→func (s *ManualCommitStrategy) Description() string {\\n    80→\\treturn \\\"Manual commit checkpoints with session logs on entire/checkpoints/v1\\\"\\n    81→}\\n    82→\\n    83→// ValidateRepository validates that the repository is suitable for this strategy.\\n    84→func (s *ManualCommitStrategy) ValidateRepository() error {\\n    85→\\trepo, err := OpenRepository()\\n    86→\\tif err != nil {\\n    87→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n    88→\\t}\\n    89→\\n    90→\\t_, err = repo.Worktree()\\n    91→\\tif err != nil {\\n    92→\\t\\treturn fmt.Errorf(\\\"failed to access worktree: %w\\\", err)\\n    93→\\t}\\n    94→\\n    95→\\treturn nil\\n    96→}\\n    97→\\n    98→// EnsureSetup ensures the strategy is properly set up.\\n    99→func (s *ManualCommitStrategy) EnsureSetup() error {\\n   100→\\tif err := EnsureEntireGitignore(); err != nil {\\n   101→\\t\\treturn err\\n   102→\\t}\\n   103→\\n   104→\\t// Ensure the entire/checkpoints/v1 orphan branch exists for permanent session storage\\n   105→\\trepo, err := OpenRepository()\\n   106→\\tif err != nil {\\n   107→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   108→\\t}\\n   109→\\tif err := EnsureMetadataBranch(repo); err != nil {\\n   110→\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n   111→\\t}\\n   112→\\n   113→\\t// Install generic hooks (they delegate to strategy at runtime)\\n   114→\\tif !IsGitHookInstalled() {\\n   115→\\t\\tif _, err := InstallGitHook(true); err != nil {\\n   116→\\t\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   117→\\t\\t}\\n   118→\\t}\\n   119→\\treturn nil\\n   120→}\"}]},\"uuid\":\"8901410b-58d8-439a-b1f7-aa412c0fffe5\",\"timestamp\":\"2026-02-20T13:46:49.688Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand how the Claude Code agent integration stores temporary state between hook invocations. Specifically:\\n\\n1. How does state get passed between different hook calls (e.g., session-start → user-prompt-submit → stop → session-end)?\\n2. Where is temporary state stored on disk between hooks?\\n3. What kind of state is tracked (transcript position, session ID, etc.)?\\n4. How does t