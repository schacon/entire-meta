, false\\n  1145→\\t}\\n  1146→\\n  1147→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1148→\\tif !ok {\\n  1149→\\t\\treturn nil, false\\n  1150→\\t}\\n  1151→\\n  1152→\\t// Check if transcript has grown since last condensation\\n  1153→\\tcurrentPos, err := analyzer.GetTranscriptPosition(state.TranscriptPath)\\n  1154→\\tif err != nil {\\n  1155→\\t\\treturn nil, false\\n  1156→\\t}\\n  1157→\\tif currentPos <= state.CheckpointTranscriptStart {\\n  1158→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no new content\\\",\\n  1159→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1160→\\t\\t\\tslog.Int(\\\"current_pos\\\", currentPos),\\n  1161→\\t\\t\\tslog.Int(\\\"start_offset\\\", state.CheckpointTranscriptStart),\\n  1162→\\t\\t)\\n  1163→\\t\\treturn nil, true // No new content, but extraction succeeded\\n  1164→\\t}\\n  1165→\\n  1166→\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart), true\\n  1167→}\\n  1168→\\n  1169→// extractModifiedFilesFromLiveTranscript extracts modified files from the live transcript\\n  1170→// (including subagent transcripts) starting from the given offset, and normalizes them\\n  1171→// to repo-relative paths. Returns the normalized file list.\\n  1172→func (s *ManualCommitStrategy) extractModifiedFilesFromLiveTranscript(state *SessionState, offset int) []string {\\n  1173→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1174→\\n  1175→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1176→\\t\\treturn nil\\n  1177→\\t}\\n  1178→\\n  1179→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1180→\\tif err != nil {\\n  1181→\\t\\treturn nil\\n  1182→\\t}\\n  1183→\\n  1184→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1185→\\tif !ok {\\n  1186→\\t\\treturn nil\\n  1187→\\t}\\n  1188→\\n  1189→\\tvar modifiedFiles []string\\n  1190→\\n  1191→\\t// For Claude Code, use ExtractAllModifiedFiles which p