tateFile(sessionID string) (string, error) {\\n    32→\\tstateDir, err := getSessionStateDir()\\n    33→\\tif err != nil {\\n    34→\\t\\treturn \\\"\\\", err\\n    35→\\t}\\n    36→\\treturn filepath.Join(stateDir, sessionID+\\\".json\\\"), nil\\n    37→}\\n    38→\\n    39→// LoadSessionState loads the session state for the given session ID.\\n    40→// Returns (nil, nil) when session file doesn't exist (not an error condition).\\n    41→func LoadSessionState(sessionID string) (*SessionState, error) {\\n    42→\\t// Validate session ID to prevent path traversal\\n    43→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n    44→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n    45→\\t}\\n    46→\\n    47→\\tstateFile, err := sessionStateFile(sessionID)\\n    48→\\tif err != nil {\\n    49→\\t\\treturn nil, fmt.Errorf(\\\"failed to get session state file path: %w\\\", err)\\n    50→\\t}\\n    51→\\n    52→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is derived from sessionID, not user input\\n    53→\\tif os.IsNotExist(err) {\\n    54→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n    55→\\t}\\n    56→\\tif err != nil {\\n    57→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n    58→\\t}\\n    59→\\n    60→\\tvar state SessionState\\n    61→\\tif err := json.Unmarshal(data, &state); err != nil {\\n    62→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal session state: %w\\\", err)\\n    63→\\t}\\n    64→\\tstate.NormalizeAfterLoad()\\n    65→\\treturn &state, nil\\n    66→}\\n    67→\\n    68→// SaveSessionState saves the session state atomically.\\n    69→func SaveSessionState(state *SessionState) error {\\n    70→\\t// Validate session ID to prevent path traversal\\n    71→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n    72→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n    73→\\t}\\n    74→\\n    75→\\tstateDir, err := getSessionStateDir()\\n    76→\\tif err != nil {\\n    77→\\t\\treturn fmt.Errorf(\\\"failed to get session state directory: %w\\\", err)\\n    78→\\t}\\n    79→\\n    80→\\tif err := os.MkdirAll(stateDir, 0o750); err != nil {\\n    81→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n    82→\\t}\\n    83→\\n    84→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n    85→\\tif err != nil {\\n    86→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n    87→\\t}\\n    88→\\n    89→\\tstateFile, err := sessionStateFile(state.SessionID)\\n    90→\\tif err != nil {\\n    91→\\t\\treturn fmt.Errorf(\\\"failed to get session state file path: %w\\\", err)\\n    92→\\t}\\n    93→\\n    94→\\t// Atomic write: write to temp file, then rename\\n    95→\\ttmpFile := stateFile + \\\".tmp\\\"\\n    96→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n    97→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n    98→\\t}\\n    99→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n   100→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n   101→\\t}\\n   102→\\treturn nil\\n   103→}\\n   104→\\n   105→// ListSessionStates returns all session states from the state directory.\\n   106→// This is a package-level function that doesn't require a specific strategy instance.\\n   107→func ListSessionStates() ([]*SessionState, error) {\\n   108→\\tstore, err := session.NewStateStore()\\n   109→\\tif err != nil {\\n   110→\\t\\treturn nil, fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n   111→\\t}\\n   112→\\n   113→\\tstates, err := store.List(context.Background())\\n   114→\\tif err != nil {\\n   115→\\t\\treturn nil, fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   116→\\t}\\n   117→\\treturn states, nil\\n   118→}\\n   119→\\n   120→// FindMostRecentSession returns the session ID of the most recently interacted session\\n   121→// (by LastInteractionTime) in the current worktree. Returns empty string if no sessions exist.\\n   122→// Scoping to the current worktree prevents cross-worktree pollution in log routing.\\n   123→// Falls back to unfiltered search if the worktree path can't be determined.\\n   124→func FindMostRecentSession() string {\\n   125→\\tstates, err := ListSessionStates()\\n   126→\\tif err != nil || len(states) == 0 {\\n   127→\\t\\treturn \\\"\\\"\\n   128→\\t}\\n   129→\\n   130→\\t// Scope to current worktree to prevent cross-worktree pollution.\\n   131→\\tworktreePath, wpErr := GetWorktreePath()\\n   132→\\tif wpErr == nil && worktreePath != \\\"\\\" {\\n   133→\\t\\tvar filtered []*SessionState\\n   134→\\t\\tfor _, s := range states {\\n   135→\\t\\t\\tif s.WorktreePath == worktreePath {\\n   136→\\t\\t\\t\\tfiltered = append(filtered, s)\\n   137→\\t\\t\\t}\\n   138→\\t\\t}\\n   139→\\t\\tif len(filtered) > 0 {\\n   140→\\t\\t\\tstates = filtered\\n   141→\\t\\t}\\n   142→\\t\\t// If no sessions match the worktree, fall back to all sessions\\n   143→\\t}\\n   144→\\n   145→\\tvar best *SessionState\\n   146→\\tfor _, s := range states {\\n   147→\\t\\tif s.LastInteractionTime == nil {\\n   148→\\t\\t\\tcontinue\\n   149→\\t\\t}\\n   150→\\t\\tif best == nil || s.LastInteractionTime.After(*best.LastInteractionTime) {\\n   151→\\t\\t\\tbest = s\\n   152→\\t\\t}\\n   153→\\t}\\n   154→\\tif best != nil {\\n   155→\\t\\treturn best.SessionID\\n   156→\\t}\\n   157→\\n   158→\\t// Fallback: return most recently started session\\n   159→\\tfor _, s := range states {\\n   160→\\t\\tif best == nil || s.StartedAt.After(best.StartedAt) {\\n   161→\\t\\t\\tbest = s\\n   162→\\t\\t}\\n   163→\\t}\\n   164→\\tif best != nil {\\n   165→\\t\\treturn best.SessionID\\n   166→\\t}\\n   167→\\treturn \\\"\\\"\\n   168→}\\n   169→\\n   170→// TransitionAndLog runs a session phase transition, applies actions via