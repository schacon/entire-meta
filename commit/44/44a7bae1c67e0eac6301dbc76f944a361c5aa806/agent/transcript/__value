:= os.Getenv(\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR\\\"); override != \\\"\\\" {\\n    94→\\t\\treturn override, nil\\n    95→\\t}\\n    96→\\n    97→\\thomeDir, err := os.UserHomeDir()\\n    98→\\tif err != nil {\\n    99→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   100→\\t}\\n   101→\\n   102→\\tprojectDir := SanitizePathForClaude(repoPath)\\n   103→\\treturn filepath.Join(homeDir, \\\".claude\\\", \\\"projects\\\", projectDir), nil\\n   104→}\\n   105→\\n   106→// ReadSession reads a session from Claude's storage (JSONL transcript file).\\n   107→// The session data is stored in NativeData as raw JSONL bytes.\\n   108→// ModifiedFiles is computed by parsing the transcript.\\n   109→func (c *ClaudeCodeAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   110→\\tif input.SessionRef == \\\"\\\" {\\n   111→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   112→\\t}\\n   113→\\n   114→\\t// Read the raw JSONL file\\n   115→\\tdata, err := os.ReadFile(input.SessionRef)\\n   116→\\tif err != nil {\\n   117→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   118→\\t}\\n   119→\\n   120→\\t// Parse to extract computed fields\\n   121→\\tlines, err := transcript.ParseFromBytes(data)\\n   122→\\tif err != nil {\\n   123→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   124→\\t}\\n   125→\\n   126→\\treturn &agent.AgentSession{\\n   127→\\t\\tSessionID:     input.SessionID,\\n   128→\\t\\tAgentName:     c.Name(),\\n   129→\\t\\tSessionRef:    input.SessionRef,\\n   130→\\t\\tStartTime:     time.Now(),\\n   131→\\t\\tNativeData:    data,\\n   132→\\t\\tModifiedFiles: ExtractModifiedFiles(lines),\\n   133→\\t}, nil\\n   134→}\\n   135→\\n   136→// WriteSession writes a session to Claude's storage (JSONL transcript file).\\n   137→// Uses the NativeData field which contains raw JSONL bytes.\\n   138→// The session must have