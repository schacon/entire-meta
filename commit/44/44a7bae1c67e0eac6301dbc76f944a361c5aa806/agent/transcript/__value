\t\\t\\ttextContent += textContentSb361.String()\\n   287→\\t\\t\\t} else {\\n   288→\\t\\t\\t\\t// Try as plain string\\n   289→\\t\\t\\t\\tvar str string\\n   290→\\t\\t\\t\\tif err := json.Unmarshal(block.Content, &str); err == nil {\\n   291→\\t\\t\\t\\t\\ttextContent = str\\n   292→\\t\\t\\t\\t}\\n   293→\\t\\t\\t}\\n   294→\\n   295→\\t\\t\\t// Look for agentId in the text\\n   296→\\t\\t\\tif agentID := extractAgentIDFromText(textContent); agentID != \\\"\\\" {\\n   297→\\t\\t\\t\\tagentIDs[agentID] = block.ToolUseID\\n   298→\\t\\t\\t}\\n   299→\\t\\t}\\n   300→\\t}\\n   301→\\n   302→\\treturn agentIDs\\n   303→}\\n   304→\\n   305→// extractAgentIDFromText extracts an agent ID from text containing \\\"agentId: <id>\\\".\\n   306→func extractAgentIDFromText(text string) string {\\n   307→\\tconst prefix = \\\"agentId: \\\"\\n   308→\\tidx := strings.Index(text, prefix)\\n   309→\\tif idx == -1 {\\n   310→\\t\\treturn \\\"\\\"\\n   311→\\t}\\n   312→\\n   313→\\t// Extract the ID (alphanumeric characters after the prefix)\\n   314→\\tstart := idx + len(prefix)\\n   315→\\tend := start\\n   316→\\tfor end < len(text) && (text[end] >= 'a' && text[end] <= 'z' ||\\n   317→\\t\\ttext[end] >= 'A' && text[end] <= 'Z' ||\\n   318→\\t\\ttext[end] >= '0' && text[end] <= '9') {\\n   319→\\t\\tend++\\n   320→\\t}\\n   321→\\n   322→\\tif end > start {\\n   323→\\t\\treturn text[start:end]\\n   324→\\t}\\n   325→\\treturn \\\"\\\"\\n   326→}\\n   327→\\n   328→// CalculateTotalTokenUsage calculates token usage for a turn, including subagents.\\n   329→// It parses the main transcript bytes from startLine, extracts spawned agent IDs,\\n   330→// and calculates their token usage from transcript files in subagentsDir.\\n   331→func (c *ClaudeCodeAgent) CalculateTotalTokenUsage(transcriptData []byte, startLine int, subagentsDir string) (*agent.TokenUsage, error) {\\n   332→\\tif len(transcriptData) == 0 {\\n   333→\\t\\treturn &agent.TokenUsage{}, nil\\n   334→\\t}\\n   335→\\n   336→\\t// Slice to the relevant portion and parse\\n   337→\\tsliced := transcript.SliceFromLine(transcriptData, startLine)\\n   338→\\tparsed, err := transcript.ParseFromBytes(sliced)\\n   339→\\tif err != nil {\\n   340→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   341→\\t}\\n   342→\\n   343→\\t// Calculate token usage from parsed transcript\\n   344→\\tmainUsage := CalculateTokenUsage(parsed)\\n   345→\\n   346→\\t// Extract spawned agent IDs from the same parsed transcript\\n   347→\\tagentIDs := ExtractSpawnedAgentIDs(parsed)\\n   348→\\n   349→\\t// Calculate subagent token usage (skip when subagentsDir is empty to avoid reading from cwd)\\n   350→\\tif len(agentIDs) > 0 && subagentsDir != \\\"\\\" {\\n   351→\\t\\tsubagentUsage := &agent.TokenUsage{}\\n   352→\\t\\tfor agentID := range agentIDs {\\n   353→\\t\\t\\tagentPath := filepath.Join(subagentsDir, fmt.Sprintf(\\\"agent-%s.jsonl\\\", agentID))\\n   354→\\t\\t\\tagentUsage, err := CalculateTokenUsageFromFile(agentPath, 0)\\n   355→\\t\\t\\tif err != nil {\\n   356→\\t\\t\\t\\t// Agent transcript may not exist yet or may have been cleaned up\\n   357→\\t\\t\\t\\tcontinue\\n   358→\\t\\t\\t}\\n   359→\\t\\t\\tsubagentUsage.InputTokens += agentUsage.InputTokens\\n   360→\\t\\t\\tsubagentUsage.CacheCreationTokens += agentUsage.CacheCreationTokens\\n   361→\\t\\t\\tsubagentUsage.CacheReadTokens += agentUsage.CacheReadTokens\\n   362→\\t\\t\\tsubagentUsage.OutputTokens += agentUsage.OutputTokens\\n   363→\\t\\t\\tsubagentUsage.APICallCount += agentUsage.APICallCount\\n   364→\\t\\t}\\n   365→\\t\\tif subagentUsage.APICallCount > 0 {\\n   366→\\t\\t\\tmainUsage.SubagentTokens = subagentUsage\\n   367→\\t\\t}\\n   368→\\t}\\n   369→\\n   370→\\treturn mainUsage, nil\\n   371→}\\n   372→\\n   373→// ExtractAllModifiedFiles extracts files modified by both the main agent and\\n   374→// any subagents spawned via the Task tool. It parses the main transcript bytes from\\n   375→// startLine, collects modified files from the main agent, then reads each\\n   376→// subagent's transcript from subagentsDir to collect their modified files too.\\n   377→// The result is a deduplicated list of all modified file paths.\\n   378→func (c *ClaudeCodeAgent) ExtractAllModifiedFiles(transcriptData []byte, startLine int, subagentsDir string) ([]string, error) {\\n   379→\\tif len(transcriptData) == 0 {\\n   380→\\t\\treturn nil, nil\\n   381→\\t}\\n   382→\\n   383→\\t// Slice to the relevant portion and parse\\n   384→\\tsliced := transcript.SliceFromLine(transcriptData, startLine)\\n   385→\\tparsed, err := transcript.ParseFromBytes(sliced)\\n   386→\\tif err != nil {\\n   387→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   388→\\t}\\n   389→\\n   390→\\t// Collect modified files from main agent\\n   391→\\tfileSet := make(map[string]bool)\\n   392→\\tvar files []string\\n   393→\\tfor _, f := range ExtractModifiedFiles(parsed) {\\n   394→\\t\\tif !fileSet[f] {\\n   395→\\t\\t\\tfileSet[f] = true\\n   396→\\t\\t\\tfiles = append(files, f)\\n   397→\\t\\t}\\n   398→\\t}\\n   399→\\n   400→\\t// Find spawned subagents and collect their modified files (skip when subagentsDir is empty to avoid reading from cwd)\\n   401→\\tagentIDs := ExtractSpawnedAgentIDs(parsed)\\n   402→\\tif subagentsDir == \\\"\\\" {\\n   403→\\t\\treturn files, nil\\n   404→\\t}\\n   405→\\tfor agentID := range agentIDs {\\n   406→\\t\\tagentPath := filepath.Join(subagentsDir, fmt.Sprintf(\\\"agent-%s.jsonl\\\", agentID))\\n   407→\\t\\tagentLines, agentErr := transcript.ParseFromFileAtLine(agentPath, 0)\\n   408→\\t\\tif agentErr != nil {\\n   409→\\t\\t\\t// Subagent transcript may not exist yet or may have been cleaned up\\n   410→\\t\\t\\tcontinue\\n   411→\\t\\t}\\n   412→\\t\\tfor _, f := range ExtractModifiedFiles(agentLines) {\\n   413→\\t\\t\\tif !fileSet[f] {\\n   414→\\t\\t\\t\\tfileSet[f] = true\\n   415→\\t\\t\\t\\tfiles = append(files, f