18→func init() {\\n    19→\\tagent.Register(agent.AgentNameCursor, NewCursorAgent)\\n    20→}\\n    21→\\n    22→// CursorAgent implements the Agent interface for Cursor.\\n    23→//\\n    24→//nolint:revive // CursorAgent is clearer than Agent in this context\\n    25→type CursorAgent struct{}\\n    26→\\n    27→// NewCursorAgent creates a new Cursor agent instance.\\n    28→func NewCursorAgent() agent.Agent {\\n    29→\\treturn &CursorAgent{}\\n    30→}\\n    31→\\n    32→// Name returns the agent registry key.\\n    33→func (c *CursorAgent) Name() agent.AgentName {\\n    34→\\treturn agent.AgentNameCursor\\n    35→}\\n    36→\\n    37→// Type returns the agent type identifier.\\n    38→func (c *CursorAgent) Type() agent.AgentType {\\n    39→\\treturn agent.AgentTypeCursor\\n    40→}\\n    41→\\n    42→// Description returns a human-readable description.\\n    43→func (c *CursorAgent) Description() string {\\n    44→\\treturn \\\"Cursor - AI-powered code editor\\\"\\n    45→}\\n    46→\\n    47→func (c *CursorAgent) IsPreview() bool { return true }\\n    48→\\n    49→// DetectPresence checks if Cursor is configured in the repository.\\n    50→func (c *CursorAgent) DetectPresence(ctx context.Context) (bool, error) {\\n    51→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    52→\\tif err != nil {\\n    53→\\t\\tworktreeRoot = \\\".\\\"\\n    54→\\t}\\n    55→\\n    56→\\tcursorDir := filepath.Join(worktreeRoot, \\\".cursor\\\")\\n    57→\\tif _, err := os.Stat(cursorDir); err == nil {\\n    58→\\t\\treturn true, nil\\n    59→\\t}\\n    60→\\treturn false, nil\\n    61→}\\n    62→\\n    63→// GetSessionID extracts the session ID from hook input.\\n    64→func (c *CursorAgent) GetSessionID(input *agent.HookInput) string {\\n    65→\\treturn input.SessionID\\n    66→}\\n    67→\\n    68→// ResolveSessionFile returns the path to a Cursor session file.\\n    69→// Cursor IDE uses a nested layout: <dir>/<id>/<id>.jsonl\\n    70→// Cursor CLI uses a flat layout: <dir>/