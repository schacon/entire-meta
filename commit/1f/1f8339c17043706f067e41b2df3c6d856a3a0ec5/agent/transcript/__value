ntext, checkpointID id.CheckpointID) ([]byte, error) {\\n    88→\\tstore, err := s.getCheckpointStore()\\n    89→\\tif err != nil {\\n    90→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    91→\\t}\\n    92→\\n    93→\\tcontent, err := store.ReadLatestSessionContent(ctx, checkpointID)\\n    94→\\tif err != nil {\\n    95→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    96→\\t}\\n    97→\\tif content == nil {\\n    98→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n    99→\\t}\\n   100→\\tif len(content.Transcript) == 0 {\\n   101→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   102→\\t}\\n   103→\\n   104→\\treturn content.Transcript, nil\\n   105→}\\n   106→\\n   107→// condenseOpts provides pre-resolved git objects to avoid redundant reads.\\n   108→type condenseOpts struct {\\n   109→\\tshadowRef *plumbing.Reference // Pre-resolved shadow branch ref (nil = resolve from repo)\\n   110→\\theadTree  *object.Tree        // Pre-resolved HEAD tree (passed through to calculateSessionAttributions)\\n   111→}\\n   112→\\n   113→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   114→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   115→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   116→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   117→//\\n   118→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   119→// In this case, data is extracted from the live transcript instead.\\n   120→func (s *ManualCommitStrategy) CondenseSession(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}, opts ...condenseOpts) (*CondenseResult, error) {\\n   121→\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   122→\\tvar o condenseOpts\\n   123→\\tif len(opts) > 0 {\\n   124→\\t\\to = opts[0]\\n   125→\\t}\\n   126→\\n   127→\\t// Get shadow branch — use pre-resolved ref if available, otherwise resolve from repo.\\n   128→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   129→\\tref := o.shadowRef\\n   130→\\tvar hasShadowBranch bool\\n   131→\\tif ref != nil {\\n   132→\\t\\thasShadowBranch = true\\n   133→\\t} else {\\n   134→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   135→\\t\\tvar err error\\n   136→\\t\\tref, err = repo.Reference(refName, true)\\n   137→\\t\\thasShadowBranch = err == nil\\n   138→\\t}\\n   139→\\n   140→\\tvar sessionData *ExtractedSessionData\\n   141→\\tif hasShadowBranch {\\n   142→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   143→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   144→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   145→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   146→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   147→\\t\\t// last turn had no code changes).\\n   148→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   149→\\t\\tvar extractErr error\\n   150→\\t\\tsessionData, extractErr = s.extractSessionData(ctx, repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n   151→\\t\\tif extractErr != nil {\\n   152→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", extractErr)\\n   153→\\t\\t}\\n   154→\\t} else {\\n   155→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   156→\\t\\t// Extract data directly from live transcript.\\n   157→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   158→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   159→\\t\\t}\\n   160→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   161→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   162→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   163→\\t\\tif state.Phase.IsActive() {\\n   164→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, state.TranscriptPath)\\n   165→\\t\\t}\\n   166→\\t\\tvar extractErr error\\n   167→\\t\\tsessionData, extractErr = s.extractSessionDataFromLiveTranscript(ctx, state)\\n   168→\\t\\tif extractErr != nil {\\n   169→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", extractErr)\\n   170→\\t\\t}\\n   171→\\t}\\n   172→\\n   173→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   174→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   175→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   176→\\tif len(committedFiles) > 0 {\\n   177→\\t\\t// Track if we had files before filtering to distinguish between:\\n   178→\\t\\t// - Session had files but none were committed (don't fallback)\\n   179→\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n   180→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   181→\\n   182→\\t\\tif hadFilesBeforeFiltering {\\n   183→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   184→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   185→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   186→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   187→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   188→\\t\\t\\t\\t}\\n   189→\\t\\t\\t}\\n   190→\\t\\t\\tsessionData.FilesTouched = filtered\\n   191→\\t\\t}\\n   192→\\n   193→\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n   194→\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n   195→\\t\\t// the session had files that simply didn't overlap with the commit - that\\n   196→\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n   197→\\t\\t// overwritten with unrelated committed files.\\n   198→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   199→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   200→\\t\\t\\tfor f := range committedFiles {\\n   201→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   202→\\t\\t\\t}\\n   203→\\t\\t}\\n   204→\\t}\\n   205→\\n   206→\\t// Get checkpoint store\\n   207→\\tstore, err := s.getCheckpointStore()\\n   208→\\tif err != nil {\\n   209→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   210→\\t}\\n   211→\\n   212→\\t// Get author info\\n   213→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   214→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   215→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   216→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   217→\\tattribution := calculateSessionAttributions(ctx, repo, ref, sessionData, state, attributionOpts{\\n   218→\\t\\theadTree: o.headTree,\\n   219→\\t})\\n   220→\\t// Get current branch name\\n   221→\\tbranchName := GetCurrentBranchName(repo)\\n   222→\\n   223→\\t// Generate summary if enabled\\n   224→\\tvar summary *cpkg.Summary\\n   225→\\tif settings.IsSummarizeEnabled(ctx) && len(sessionData.Transcript) > 0 {\\n   226→\\t\\tsummarizeCtx := logging.WithComponent(ctx, \\\"summarize\\\")\\n   227→\\n   228→\\t\\t// Scope transcript to this checkpoint's portion.\\n   229→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   230→\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n   231→\\t\\tvar scopedTranscript []byte\\n   232→\\t\\tswitch state.AgentType {\\n   233→\\t\\tcase agent.AgentTypeGemini:\\n   234→\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   235→\\t\\t\\tif sliceErr != nil {\\n   236→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n   237→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   238→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   239→\\t\\t\\t}\\n   240→\\t\\t\\tscopedTranscript = scoped\\n   241→\\t\\tcase agent.AgentTypeOpenCode:\\n   242→\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   243→\\t\\t\\tif sliceErr != nil {\\n   244→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n   245→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   246→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   247→\\t\\t\\t}\\n   248→\\t\\t\\tscopedTranscript = scoped\\n   249→\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeUnknown:\\n   250→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   251→\\t\\t}\\n   252→\\t\\tif len(scopedTranscript) > 0 {\\n   253→\\t\\t\\tvar err error\\n   254→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   255→\\t\\t\\tif err != nil {\\n   256→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   257→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   258→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   259→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   260→\\t\\t\\t} else {\\n   261→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   262→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   263→\\t\\t\\t}\\n   264→\\t\\t}\\n   265→\\t}\\n   266→\\n   267→\\t// Write checkpoint metadata using the checkpoint store\\n   268→\\tif err := store.WriteCommitted(ctx, cpkg.WriteCommittedOptions{\\n   269→\\t\\tCheckpointID:                checkpointID,\\n   270→\\t\\tSessionID:                   state.SessionID,\\n   271→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   272→\\t\\tBranch:                      branchName,\\n   273→\\t\\tTranscript:                  sessionData.Transcript,\\n   274→\\t\\tPrompts:                     sessionData.Prompts,\\n   275→\\t\\tContext:                     sessionData.Context,\\n   276→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   277→\\t\\tCheckpointsCount:            state.StepCount,\\n   278→\\t\\tEphemeralBranch:             shadowBranchName,\\n   279→\\t\\tAuthorName:                  authorName,\\n   280→\\t\\tAuthorEmail:                 authorEmail,\\n   281→\\t\\tAgent:                       state.AgentType,\\n   282→\\t\\tTurnID:                      state.TurnID,\\n   283→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   284→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   285→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   286→\\t\\tInitialAttribution:          attribution,\\n   287→\\t\\tSummary:                     summary,\\n   288→\\t}); err != nil {\\n   289→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   290→\\t}\\n   291→\\n   292→\\treturn &CondenseResult{\\n   293→\\t\\tCheckpointID:         checkpointID,\\n   294→\\t\\tSessionID:            state.SessionID,\\n   295→\\t\\tCheckpointsCount:     state.StepCount,\\n   296→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   297→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   298→\\t}, nil\\n   299→}\\n   300→\\n   301→// attributionOpts provides pre-resolved git objects to avoid redundant reads.\\n   302→type attributionOpts struct {\\n   303→\\theadTree   *object.Tree // HEAD commit tree (already resolved by PostCommit)\\n   304→\\tshadowTree *object.Tree // Shadow branch tree (already resolved by PostCommit)\\n   305→}\\n   306→\\n   307→func calculateSessionAttributions(ctx context.Context, repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState, opts ...attributionOpts) *cpkg.InitialAttribution {\\n   308→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   309→\\t// This uses user edits captured at each prompt start (before agent works),\\n   310→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   311→\\t//\\n   312→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   313→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   314→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   315→\\tlogCtx := logging.WithComponent(ctx, \\\"attribution\\\")\\n   316→\\n   317→\\tvar o attributionOpts\\n   318→\\tif len(opts) > 0 {\\n   319→\\t\\to = opts[0]\\n   320→\\t}\\n   321→\\n   322→\\theadTree := o.headTree\\n   323→\\tif headTree == nil {\\n   324→\\t\\theadRef, headErr := repo.Head()\\n   325→\\t\\tif headErr != nil {\\n   326→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   327→\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   328→\\t\\t\\treturn nil\\n   329→\\t\\t}\\n   330→\\n   331→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   332→\\t\\tif commitErr != nil {\\n   333→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   334→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   335→\\t\\t\\treturn nil\\n   336→\\t\\t}\\n   337→\\n   338→\\t\\tvar treeErr error\\n   339→\\t\\theadTree, treeErr = headCommit.Tree()\\n   340→\\t\\tif treeErr != nil {\\n   341→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   342→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   343→\\t\\t\\treturn nil\\n   344→\\t\\t}\\n   345→\\t}\\n   346→\\n   347→\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n   348→\\tshadowTree := o.shadowTree\\n   349→\\tif shadowTree == nil {\\n   350→\\t\\tif shadowRef != nil {\\n   351→\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   352→\\t\\t\\tif shadowErr != nil {\\n   353→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   354→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   355→\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   356→\\t\\t\\t\\treturn nil\\n   357→\\t\\t\\t}\\n   358→\\t\\t\\tvar shadowTreeErr error\\n   359→\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   360→\\t\\t\\tif shadowTreeErr != nil {\\n   361→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   362→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   363→\\t\\t\\t\\treturn nil\\n   364→\\t\\t\\t}\\n   365→\\t\\t} else {\\n   366→\\t\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   367→\\t\\t\\t// because the agent's work is the commit itself.\\n   368→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   369→\\t\\t\\tshadowTree = headTree\\n   370→\\t\\t}\\n   371→\\t}\\n   372→\\n   373→\\t// Get base tree (state before session started)\\n   374→\\tvar baseTree *object.Tree\\n   375→\\tattrBase := state.AttributionBaseCommit\\n   376→\\tif attrBase == \\\"\\\" {\\n   377→\\t\\tattrBase = state.BaseCommit // backward compat\\n   378→\\t}\\n   379→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   380→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   381→\\t\\t\\tbaseTree = tree\\n   382→\\t\\t} else {\\n   383→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   384→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   385→\\t\\t}\\n   386→\\t} else {\\n   387→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   388→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   389→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   390→\\t}\\n   391→\\n   392→\\t// Log accumulated prompt attributions for debugging\\n   393→\\tvar totalUserAdded, totalUserRemoved int\\n   394→\\tfor i, pa := range state.PromptAttributions {\\n   395→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   396→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   397→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   398→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   399→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   400→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   401→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   402→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   403→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   404→\\t}\\n   405→\\n   406→\\tattribution := CalculateAttributionWithAccumulated(\\n   407→\\t\\tbaseTree,\\n   408→\\t\\tshadowTree,\\n   409→\\t\\theadTree,\\n   410→\\t\\tsessionData.FilesTouched,\\n   411→\\t\\tstate.PromptAttributions,\\n   412→\\t)\\n   413→\\n   414→\\tif attribution != nil {\\n   415→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   416→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   417→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   418→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   419→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   420→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   421→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   422→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   423→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   424→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   425→\\t}\\n   426→\\n   427→\\treturn attribution\\n   428→}\\n   429→\\n   430→// extractSessionData extracts session data from the shadow branch.\\n   431→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   432→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   433→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   434→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   435→// continued growing — the shadow branch copy would be stale.\\n   436→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   437→func (s *ManualCommitStrategy) extractSessionData(ctx context.Context, repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n   438→\\tag, _ := agent.GetByAgentType(agentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   439→\\tcommit, err := repo.CommitObject(shadowRef)\\n   440→\\tif err != nil {\\n   441→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   442→\\t}\\n   443→\\n   444→\\ttree, err := commit.Tree()\\n   445→\\tif err != nil {\\n   446→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   447→\\t}\\n   448→\\n   449→\\tdata := &ExtractedSessionData{}\\n   450→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   451→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   452→\\n   453→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   454→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   455→\\t// (SaveStep is only called when there are file modifications).\\n   456→\\tvar fullTranscript string\\n   457→\\tif liveTranscriptPath != \\\"\\\" {\\n   458→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   459→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   460→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   461→\\t\\tif isActive {\\n   462→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, liveTranscriptPath)\\n   463→\\t\\t}\\n   464→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   465→\\t\\t\\tfullTranscript = string(liveData)\\n   466→\\t\\t}\\n   467→\\t}\\n   468→\\tif fullTranscript == \\\"\\\" {\\n   469→\\t\\t// Fall back to shadow branch copy\\n   470→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   471→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   472→\\t\\t\\t\\tfullTranscript = content\\n   473→\\t\\t\\t}\\n   474→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   475→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   476→\\t\\t\\t\\tfullTranscript = content\\n   477→\\t\\t\\t}\\n   478→\\t\\t}\\n   479→\\t}\\n   480→\\n   481→\\t// Process transcript based on agent type\\n   482→\\tif fullTranscript != \\\"\\\" {\\n   483→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   484→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   485→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   486→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   487→\\t}\\n   488→\\n   489→\\t// Use tracked files from session state (not all files in tree)\\n   490→\\tdata.FilesTouched = filesTouched\\n   491→\\n   492→\\t// Calculate token usage from the extracted transcript portion\\n   493→\\tif len(data.Transcript) > 0 {\\n   494→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, checkpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   495→\\t}\\n   496→\\n   497→\\treturn data, nil\\n   498→}\\n   499→\\n   500→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   501→// This is used for mid-session commits where no shadow branch exists yet.\\n   502→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(ctx context.Context, state *SessionState) (*ExtractedSessionData, error) {\\n   503→\\tdata := &ExtractedSessionData{}\\n   504→\\n   505→\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   506→\\n   507→\\t// Read the live transcript\\n   508→\\tif state.TranscriptPath == \\\"\\\" {\\n   509→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   510→\\t}\\n   511→\\n   512→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   513→\\tif err != nil {\\n   514→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   515→\\t}\\n   516→\\n   517→\\tif len(liveData) == 0 {\\n   518→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   519→\\t}\\n   520→\\n   521→\\tfullTranscript := string(liveData)\\n   522→\\tdata.Transcript = liveData\\n   523→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   524→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   525→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   526→\\n   527→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   528→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   529→\\tif len(state.FilesTouched) > 0 {\\n   530→\\t\\tdata.FilesTouched = state.FilesTouched\\n   531→\\t} else {\\n   532→\\t\\t// Use the shared helper which includes subagent transcripts\\n   533→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(ctx, state, state.CheckpointTranscriptStart)\\n   534→\\t}\\n   535→\\n   536→\\t// Calculate token usage from the extracted transcript portion\\n   537→\\tif len(data.Transcript) > 0 {\\n   538→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, state.CheckpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   539→\\t}\\n   540→\\n   541→\\treturn data, nil\\n   542→}\\n   543→\\n   544→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   545→// For Claude Code and JSONL-based agents, this counts lines.\\n   546→// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n   547→// Returns 0 if the content is empty or malformed.\\n   548→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   549→\\tif content == \\\"\\\" {\\n   550→\\t\\treturn 0\\n   551→\\t}\\n   552→\\n   553→\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n   554→\\tif agentType == agent.AgentTypeOpenCode {\\n   555→\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n   556→\\t\\tif err == nil && session != nil {\\n   557→\\t\\t\\treturn len(session.Messages)\\n   558→\\t\\t}\\n   559→\\t\\treturn 0\\n   560→\\t}\\n   561→\\n   562→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   563→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   564→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   565→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   566→\\t\\t\\treturn len(transcript.Messages)\\n   567→\\t\\t}\\n   568→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   569→\\t\\tif agentType == agent.AgentTypeGemini {\\n   570→\\t\\t\\treturn 0\\n   571→\\t\\t}\\n   572→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   573→\\t}\\n   574→\\n   575→\\t// Claude Code and other JSONL-based agents\\n   576→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   577→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   578→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   579→\\t\\tallLines = allLines[:len(allLines)-1]\\n   580→\\t}\\n   581→\\treturn len(allLines)\\n   582→}\\n   583→\\n   584→// extractUserPrompts extracts all user prompts from transcript content.\\n   585→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   586→func extractUserPrompts(agentType agent.AgentType, content string) []string {\\n   587→\\tif content == \\\"\\\" {\\n   588→\\t\\treturn nil\\n   589→\\t}\\n   590→\\n   591→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   592→\\tif agentType == agent.AgentTypeOpenCode {\\n   593→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   594→\\t\\tif err == nil && len(prompts) > 0 {\\n   595→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   596→\\t\\t\\tfor _, prompt := range prompts {\\n   597→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   598→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   599→\\t\\t\\t\\t}\\n   600→\\t\\t\\t}\\n   601→\\t\\t\\treturn cleaned\\n   602→\\t\\t}\\n   603→\\t\\treturn nil\\n   604→\\t}\\n   605→\\n   606→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   607→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   608→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   609→\\t\\tif err == nil && len(prompts) > 0 {\\n   610→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   611→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   612→\\t\\t\\tfor _, prompt := range prompts {\\n   613→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   614→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   615→\\t\\t\\t\\t}\\n   616→\\t\\t\\t}\\n   617→\\t\\t\\treturn cleaned\\n   618→\\t\\t}\\n   619→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   620→\\t\\tif agentType == agent.AgentTypeGemini {\\n   621→\\t\\t\\treturn nil\\n   622→\\t\\t}\\n   623→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   624→\\t}\\n   625→\\n   626→\\t// Claude Code and other JSONL-based agents\\n   627→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   628→}\\n   629→\\n   630→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   631→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   632→func extractUserPromptsFromLines(lines []string) []string {\\n   633→\\tvar prompts []string\\n   634→\\tfor _, line := range lines {\\n   635→\\t\\tline = strings.TrimSpace(line)\\n   636→\\t\\tif line == \\\"\\\" {\\n   637→\\t\\t\\tcontinue\\n   638→\\t\\t}\\n   639→\\n   640→\\t\\tvar entry map[string]interface{}\\n   641→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   642→\\t\\t\\tcontinue\\n   643→\\t\\t}\\n   644→\\n   645→\\t\\t// Check for user message:\\n   646→\\t\\t// - Claude Code uses \\\"type\\\": \\\"human\\\" or \\\"type\\\": \\\"user\\\"\\n   647→\\t\\t// - Cursor uses \\\"role\\\": \\\"user\\\"\\n   648→\\t\\tmsgType, _ := entry[\\\"type\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   649→\\t\\tmsgRole, _ := entry[\\\"role\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   650→\\t\\tisUser := msgType == \\\"human\\\" || msgType == \\\"user\\\" || msgRole == \\\"user\\\"\\n   651→\\t\\tif !isUser {\\n   652→\\t\\t\\tcontinue\\n   653→\\t\\t}\\n   654→\\n   655→\\t\\t// Extract message content\\n   656→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   657→\\t\\tif !ok {\\n   658→\\t\\t\\tcontinue\\n   659→\\t\\t}\\n   660→\\n   661→\\t\\t// Handle string content\\n   662→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   663→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   664→\\t\\t\\tif cleaned != \\\"\\\" {\\n   665→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   666→\\t\\t\\t}\\n   667→\\t\\t\\tcontinue\\n   668→\\t\\t}\\n   669→\\n   670→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   671→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   672→\\t\\t\\tvar texts []string\\n   673→\\t\\t\\tfor _, item := range arr {\\n   674→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   675→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   676→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   677→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   678→\\t\\t\\t\\t\\t\\t}\\n   679→\\t\\t\\t\\t\\t}\\n   680→\\t\\t\\t\\t}\\n   681→\\t\\t\\t}\\n   682→\\t\\t\\tif len(texts) > 0 {\\n   683→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   684→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   685→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   686→\\t\\t\\t\\t}\\n   687→\\t\\t\\t}\\n   688→\\t\\t}\\n   689→\\t}\\n   690→\\treturn prompts\\n   691→}\\n   692→\\n   693→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   694→func generateContextFromPrompts(prompts []string) []byte {\\n   695→\\tif len(prompts) == 0 {\\n   696→\\t\\treturn nil\\n   697→\\t}\\n   698→\\n   699→\\tvar buf strings.Builder\\n   700→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   701→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   702→\\n   703→\\tfor i, prompt := range prompts {\\n   704→\\t\\t// Truncate very long prompts for readability.\\n   705→\\t\\t// Use rune-based truncation to avoid splitting multi-byte UTF-8 characters (e.g. CJK).\\n   706→\\t\\tconst maxDisplayPromptRunes = 500\\n   707→\\t\\tdisplayPrompt := stringutil.TruncateRunes(prompt, maxDisplayPromptRunes, \\\"...\\\")\\n   708→\\t\\tfmt.Fprintf(&buf, \\\"### Prompt %d\\\\n\\\\n\\\", i+1)\\n   709→\\t\\tbuf.WriteString(displayPrompt)\\n   710→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   711→\\t}\\n   712→\\n   713→\\treturn []byte(buf.String())\\n   714→}\\n   715→\\n   716→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   717→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   718→func (s *ManualCommitStrategy) CondenseSessionByID(ctx context.Context, sessionID string) error {\\n   719→\\tlogCtx := logging.WithComponent(ctx, \\\"condense-by-id\\\")\\n   720→\\n   721→\\t// Load session state\\n   722→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   723→\\tif err != nil {\\n   724→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   725→\\t}\\n   726→\\tif state == nil {\\n   727→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   728→\\t}\\n   729→\\n   730→\\t// Open repository\\n   731→\\trepo, err := OpenRepository(ctx)\\n   732→\\tif err != nil {\\n   733→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   734→\\t}\\n   735→\\n   736→\\t// Generate a checkpoint ID\\n   737→\\tcheckpointID, err := id.Generate()\\n   738→\\tif err != nil {\\n   739→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   740→\\t}\\n   741→\\n   742→\\t// Check if shadow branch exists (required for condensation)\\n   743→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   744→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   745→\\t_, refErr := repo.Reference(refName, true)\\n   746→\\thasShadowBranch := refErr == nil\\n   747→\\n   748→\\tif !hasShadowBranch {\\n   749→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   750→\\t\\t// Just clean up the state file.\\n   751→\\t\\tlogging.Info(logCtx, \\\"no shadow branch for session, clearing state only\\\",\\n   752→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   753→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   754→\\t\\t)\\n   755→\\t\\tif err := s.clearSessionState(ctx, sessionID); err != nil {\\n   756→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   757→\\t\\t}\\n   758→\\t\\treturn nil\\n   759→\\t}\\n   760→\\n   761→\\t// Condense the session\\n   762→\\tresult, err := s.CondenseSession(ctx, repo, checkpointID, state, nil)\\n   763→\\tif err != nil {\\n   764→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   765→\\t}\\n   766→\\n   767→\\tlogging.Info(logCtx, \\\"session condensed by ID\\\",\\n   768→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   769→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   770→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   771→\\t)\\n   772→\\n   773→\\t// Update session state: reset step count and transition to idle\\n   774→\\tstate.StepCount = 0\\n   775→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   776→\\tstate.Phase = session.PhaseIdle\\n   777→\\tstate.LastCheckpointID = checkpointID\\n   778→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   779→\\tstate.PromptAttributions = nil\\n   780→\\tstate.PendingPromptAttribution = nil\\n   781→\\n   782→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   783→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   784→\\t}\\n   785→\\n   786→\\t// Clean up shadow branch if no other sessions need it\\n   787→\\tif err := s.cleanupShadowBranchIfUnused(ctx, repo, shadowBranchName, sessionID); err != nil {\\n   788→\\t\\tlogging.Warn(logCtx, \\\"failed to clean up shadow branch\\\",\\n   789→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   790→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   791→\\t\\t)\\n   792→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   793→\\t}\\n   794→\\n   795→\\treturn nil\\n   796→}\\n   797→\\n   798→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   799→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(ctx context.Context, _ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   800→\\t// List all session states to check if any other session uses this shadow branch\\n   801→\\tallStates, err := s.listAllSessionStates(ctx)\\n   802→\\tif err != nil {\\n   803→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   804→\\t}\\n   805→\\n   806→\\tfor _, state := range allStates {\\n   807→\\t\\tif state.SessionID == excludeSessionID {\\n   808→\\t\\t\\tcontinue\\n   809→\\t\\t}\\n   810→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   811→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   812→\\t\\t\\t// Another session still needs this shadow branch\\n   813→\\t\\t\\treturn nil\\n   814→\\t\\t}\\n   815→\\t}\\n   816→\\n   817→\\t// No other sessions need it, delete the shadow branch via CLI\\n   818→\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n   819→\\tif err := DeleteBranchCLI(ctx, shadowBranchName); err != nil {\\n   820→\\t\\t// Branch already gone is not an error\\n   821→\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n   822→\\t\\t\\treturn nil\\n   823→\\t\\t}\\n   824→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n   825→\\t}\\n   826→\\treturn nil\\n   827→}\\n   828→\"}]},\"uuid\":\"b2deec99-a488-4f4a-996f-1b084024ee6f\",\"timestamp\":\"2026-02-26T16:27:32.835Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli_experiments/cmd/entire/cli/strategy/manual_commit_condensation.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/opencode\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/stringutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// listCheckpoints returns all checkpoints from the metadata branch.\\n// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) listCheckpoints(ctx context.Context) ([]CheckpointInfo, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcommitted, err := store.ListCommitted(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n\\t}\\n\\n\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n\\tresult := make([]CheckpointInfo, 0, len(committed))\\n\\tfor _, c := range committed {\\n\\t\\tresult = append(result, CheckpointInfo{\\n\\t\\t\\tCheckpointID:     c.CheckpointID,\\n\\t\\t\\tSessionID:        c.SessionID,\\n\\t\\t\\tCreatedAt:        c.CreatedAt,\\n\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n\\t\\t\\tFilesTouched:     c.FilesTouched,\\n\\t\\t\\tAgent:            c.Agent,\\n\\t\\t\\tIsTask:           c.IsTask,\\n\\t\\t\\tToolUseID:        c.ToolUseID,\\n\\t\\t\\tSessionCount:     c.SessionCount,\\n\\t\\t\\tSessionIDs:       c.SessionIDs,\\n\\t\\t})\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointsForSession returns all checkpoints for a session ID.\\nfunc (s *ManualCommitStrategy) getCheckpointsForSession(ctx context.Context, sessionID string) ([]CheckpointInfo, error) {\\n\\tall, err := s.listCheckpoints(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tvar result []CheckpointInfo\\n\\tfor _, cp := range all {\\n\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n\\t\\t\\tresult = append(result, cp)\\n\\t\\t}\\n\\t}\\n\\n\\tif len(result) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) getCheckpointLog(ctx context.Context, checkpointID id.CheckpointID) ([]byte, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(ctx, checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// condenseOpts provides pre-resolved git objects to avoid redundant reads.\\ntype condenseOpts struct {\\n\\tshadowRef *plumbing.Reference // Pre-resolved shadow branch ref (nil = resolve from repo)\\n\\theadTree  *object.Tree        // Pre-resolved HEAD tree (passed through to calculateSessionAttributions)\\n}\\n\\n// CondenseSession condenses a session's shadow branch to permanent storage.\\n// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n//\\n// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n// In this case, data is extracted from the live transcript instead.\\nfunc (s *ManualCommitStrategy) CondenseSession(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}, opts ...condenseOpts) (*CondenseResult, error) {\\n\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n\\tvar o condenseOpts\\n\\tif len(opts) > 0 {\\n\\t\\to = opts[0]\\n\\t}\\n\\n\\t// Get shadow branch — use pre-resolved ref if available, otherwise resolve from repo.\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\tref := o.shadowRef\\n\\tvar hasShadowBranch bool\\n\\tif ref != nil {\\n\\t\\thasShadowBranch = true\\n\\t} else {\\n\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\t\\tvar err error\\n\\t\\tref, err = repo.Reference(refName, true)\\n\\t\\thasShadowBranch = err == nil\\n\\t}\\n\\n\\tvar sessionData *ExtractedSessionData\\n\\tif hasShadowBranch {\\n\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n\\t\\t// last turn had no code changes).\\n\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n\\t\\tvar extractErr error\\n\\t\\tsessionData, extractErr = s.extractSessionData(ctx, repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n\\t\\tif extractErr != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", extractErr)\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n\\t\\t// Extract data directly from live transcript.\\n\\t\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n\\t\\t}\\n\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n\\t\\tif state.Phase.IsActive() {\\n\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, state.TranscriptPath)\\n\\t\\t}\\n\\t\\tvar extractErr error\\n\\t\\tsessionData, extractErr = s.extractSessionDataFromLiveTranscript(ctx, state)\\n\\t\\tif extractErr != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", extractErr)\\n\\t\\t}\\n\\t}\\n\\n\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n\\t// committed in this specific commit. This ensures each checkpoint represents\\n\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n\\tif len(committedFiles) > 0 {\\n\\t\\t// Track if we had files before filtering to distinguish between:\\n\\t\\t// - Session had files but none were committed (don't fallback)\\n\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n\\n\\t\\tif hadFilesBeforeFiltering {\\n\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tsessionData.FilesTouched = filtered\\n\\t\\t}\\n\\n\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n\\t\\t// the session had files that simply didn't overlap with the commit - that\\n\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n\\t\\t// overwritten with unrelated committed files.\\n\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n\\t\\t\\tfor f := range committedFiles {\\n\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Get checkpoint store\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get author info\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n\\tattribution := calculateSessionAttributions(ctx, repo, ref, sessionData, state, attributionOpts{\\n\\t\\theadTree: o.headTree,\\n\\t})\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Generate summary if enabled\\n\\tvar summary *cpkg.Summary\\n\\tif settings.IsSummarizeEnabled(ctx) && len(sessionData.Transcript) > 0 {\\n\\t\\tsummarizeCtx := logging.WithComponent(ctx, \\\"summarize\\\")\\n\\n\\t\\t// Scope transcript to this checkpoint's portion.\\n\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n\\t\\tvar scopedTranscript []byte\\n\\t\\tswitch state.AgentType {\\n\\t\\tcase agent.AgentTypeGemini:\\n\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t\\tif sliceErr != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n\\t\\t\\t}\\n\\t\\t\\tscopedTranscript = scoped\\n\\t\\tcase agent.AgentTypeOpenCode:\\n\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t\\tif sliceErr != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n\\t\\t\\t}\\n\\t\\t\\tscopedTranscript = scoped\\n\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeUnknown:\\n\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t}\\n\\t\\tif len(scopedTranscript) > 0 {\\n\\t\\t\\tvar err error\\n\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t\\t// Continue without summary - non-blocking\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write checkpoint metadata using the checkpoint store\\n\\tif err := store.WriteCommitted(ctx, cpkg.WriteCommittedOptions{\\n\\t\\tCheckpointID:                checkpointID,\\n\\t\\tSessionID:                   state.SessionID,\\n\\t\\tStrategy:                    StrategyNameManualCommit,\\n\\t\\tBranch:                      branchName,\\n\\t\\tTranscript:                  sessionData.Transcript,\\n\\t\\tPrompts:                     sessionData.Prompts,\\n\\t\\tContext:                     sessionData.Context,\\n\\t\\tFilesTouched:                sessionData.FilesTouched,\\n\\t\\tCheckpointsCount:            state.StepCount,\\n\\t\\tEphemeralBranch:             shadowBranchName,\\n\\t\\tAuthorName:                  authorName,\\n\\t\\tAuthorEmail:                 authorEmail,\\n\\t\\tAgent:                       state.AgentType,\\n\\t\\tTurnID:                      state.TurnID,\\n\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n\\t\\tInitialAttribution:          attribution,\\n\\t\\tSummary:                     summary,\\n\\t}); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n\\t}\\n\\n\\treturn &CondenseResult{\\n\\t\\tCheckpointID:         checkpointID,\\n\\t\\tSessionID:            state.SessionID,\\n\\t\\tCheckpointsCount:     state.StepCount,\\n\\t\\tFilesTouched:         sessionData.FilesTouched,\\n\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n\\t}, nil\\n}\\n\\n// attributionOpts provides pre-resolved git objects to avoid redundant reads.\\ntype attributionOpts struct {\\n\\theadTree   *object.Tree // HEAD commit tree (already resolved by PostCommit)\\n\\tshadowTree *object.Tree // Shadow branch tree (already resolved by PostCommit)\\n}\\n\\nfunc calculateSessionAttributions(ctx context.Context, repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState, opts ...attributionOpts) *cpkg.InitialAttribution {\\n\\t// Calculate initial attribution using accumulated prompt attribution data.\\n\\t// This uses user edits captured at each prompt start (before agent works),\\n\\t// plus any user edits after the final checkpoint (shadow → head).\\n\\t//\\n\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n\\tlogCtx := logging.WithComponent(ctx, \\\"attribution\\\")\\n\\n\\tvar o attributionOpts\\n\\tif len(opts) > 0 {\\n\\t\\to = opts[0]\\n\\t}\\n\\n\\theadTree := o.headTree\\n\\tif headTree == nil {\\n\\t\\theadRef, headErr := repo.Head()\\n\\t\\tif headErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n\\t\\tif commitErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\tvar treeErr error\\n\\t\\theadTree, treeErr = headCommit.Tree()\\n\\t\\tif treeErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t}\\n\\n\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n\\tshadowTree := o.shadowTree\\n\\tif shadowTree == nil {\\n\\t\\tif shadowRef != nil {\\n\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n\\t\\t\\tif shadowErr != nil {\\n\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n\\t\\t\\t\\treturn nil\\n\\t\\t\\t}\\n\\t\\t\\tvar shadowTreeErr error\\n\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n\\t\\t\\tif shadowTreeErr != nil {\\n\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n\\t\\t\\t\\treturn nil\\n\\t\\t\\t}\\n\\t\\t} else {\\n\\t\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n\\t\\t\\t// because the agent's work is the commit itself.\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n\\t\\t\\tshadowTree = headTree\\n\\t\\t}\\n\\t}\\n\\n\\t// Get base tree (state before session started)\\n\\tvar baseTree *object.Tree\\n\\tattrBase := state.AttributionBaseCommit\\n\\tif attrBase == \\\"\\\" {\\n\\t\\tattrBase = state.BaseCommit // backward compat\\n\\t}\\n\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n\\t\\t\\tbaseTree = tree\\n\\t\\t} else {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n\\t\\t}\\n\\t} else {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n\\t}\\n\\n\\t// Log accumulated prompt attributions for debugging\\n\\tvar totalUserAdded, totalUserRemoved int\\n\\tfor i, pa := range state.PromptAttributions {\\n\\t\\ttotalUserAdded += pa.UserLinesAdded\\n\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"index\\\", i))\\n\\t}\\n\\n\\tattribution := CalculateAttributionWithAccumulated(\\n\\t\\tbaseTree,\\n\\t\\tshadowTree,\\n\\t\\theadTree,\\n\\t\\tsessionData.FilesTouched,\\n\\t\\tstate.PromptAttributions,\\n\\t)\\n\\n\\tif attribution != nil {\\n\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n\\t}\\n\\n\\treturn attribution\\n}\\n\\n// extractSessionData extracts session data from the shadow branch.\\n// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n// continued growing — the shadow branch copy would be stale.\\n// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\nfunc (s *ManualCommitStrategy) extractSessionData(ctx context.Context, repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n\\tag, _ := agent.GetByAgentType(agentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n\\tcommit, err := repo.CommitObject(shadowRef)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\tdata := &ExtractedSessionData{}\\n\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\n\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n\\t// (SaveStep is only called when there are file modifications).\\n\\tvar fullTranscript string\\n\\tif liveTranscriptPath != \\\"\\\" {\\n\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n\\t\\tif isActive {\\n\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, liveTranscriptPath)\\n\\t\\t}\\n\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n\\t\\t\\tfullTranscript = string(liveData)\\n\\t\\t}\\n\\t}\\n\\tif fullTranscript == \\\"\\\" {\\n\\t\\t// Fall back to shadow branch copy\\n\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Process transcript based on agent type\\n\\tif fullTranscript != \\\"\\\" {\\n\\t\\tdata.Transcript = []byte(fullTranscript)\\n\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\t}\\n\\n\\t// Use tracked files from session state (not all files in tree)\\n\\tdata.FilesTouched = filesTouched\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, checkpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n// This is used for mid-session commits where no shadow branch exists yet.\\nfunc (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(ctx context.Context, state *SessionState) (*ExtractedSessionData, error) {\\n\\tdata := &ExtractedSessionData{}\\n\\n\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n\\n\\t// Read the live transcript\\n\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n\\t}\\n\\n\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n\\t}\\n\\n\\tif len(liveData) == 0 {\\n\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n\\t}\\n\\n\\tfullTranscript := string(liveData)\\n\\tdata.Transcript = liveData\\n\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\n\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n\\t// (no SaveStep/Stop has been called yet to populate it)\\n\\tif len(state.FilesTouched) > 0 {\\n\\t\\tdata.FilesTouched = state.FilesTouched\\n\\t} else {\\n\\t\\t// Use the shared helper which includes subagent transcripts\\n\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(ctx, state, state.CheckpointTranscriptStart)\\n\\t}\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, state.CheckpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n// For Claude Code and JSONL-based agents, this counts lines.\\n// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n// Returns 0 if the content is empty or malformed.\\nfunc countTranscriptItems(agentType agent.AgentType, content string) int {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn 0\\n\\t}\\n\\n\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n\\tif agentType == agent.AgentTypeOpenCode {\\n\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n\\t\\tif err == nil && session != nil {\\n\\t\\t\\treturn len(session.Messages)\\n\\t\\t}\\n\\t\\treturn 0\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n\\t\\t\\treturn len(transcript.Messages)\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn 0\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n\\t\\tallLines = allLines[:len(allLines)-1]\\n\\t}\\n\\treturn len(allLines)\\n}\\n\\n// extractUserPrompts extracts all user prompts from transcript content.\\n// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\nfunc extractUserPrompts(agentType agent.AgentType, content string) []string {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n\\tif agentType == agent.AgentTypeOpenCode {\\n\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n\\t\\tif err == nil && len(prompts) > 0 {\\n\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n\\t\\t\\tfor _, prompt := range prompts {\\n\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\treturn cleaned\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n\\t\\tif err == nil && len(prompts) > 0 {\\n\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n\\t\\t\\tfor _, prompt := range prompts {\\n\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\treturn cleaned\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n}\\n\\n// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\nfunc extractUserPromptsFromLines(lines []string) []string {\\n\\tvar prompts []string\\n\\tfor _, line := range lines {\\n\\t\\tline = strings.TrimSpace(line)\\n\\t\\tif line == \\\"\\\" {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tvar entry map[string]interface{}\\n\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Check for user message:\\n\\t\\t// - Claude Code uses \\\"type\\\": \\\"human\\\" or \\\"type\\\": \\\"user\\\"\\n\\t\\t// - Cursor uses \\\"role\\\": \\\"user\\\"\\n\\t\\tmsgType, _ := entry[\\\"type\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n\\t\\tmsgRole, _ := entry[\\\"role\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n\\t\\tisUser := msgType == \\\"human\\\" || msgType == \\\"user\\\" || msgRole == \\\"user\\\"\\n\\t\\tif !isUser {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Extract message content\\n\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n\\t\\tif !ok {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Handle string content\\n\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n\\t\\t\\tif cleaned != \\\"\\\" {\\n\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n\\t\\t\\t}\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n\\t\\t\\tvar texts []string\\n\\t\\t\\tfor _, item := range arr {\\n\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tif len(texts) > 0 {\\n\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\treturn prompts\\n}\\n\\n// generateContextFromPrompts generates context.md content from a list of prompts.\\nfunc generateContextFromPrompts(prompts []string) []byte {\\n\\tif len(prompts) == 0 {\\n\\t\\treturn nil\\n\\t}\\n\\n\\tvar buf strings.Builder\\n\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n\\n\\tfor i, prompt := range prompts {\\n\\t\\t// Truncate very long prompts for readability.\\n\\t\\t// Use rune-based truncation to avoid splitting multi-byte UTF-8 characters (e.g. CJK).\\n\\t\\tconst maxDisplayPromptRunes = 500\\n\\t\\tdisplayPrompt := stringutil.TruncateRunes(prompt, maxDisplayPromptRunes, \\\"...\\\")\\n\\t\\tfmt.Fprintf(&buf, \\\"### Prompt %d\\\\n\\\\n\\\", i+1)\\n\\t\\tbuf.WriteString(displayPrompt)\\n\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n\\t}\\n\\n\\treturn []byte(buf.String())\\n}\\n\\n// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\nfunc (s *ManualCommitStrategy) CondenseSessionByID(ctx context.Context, sessionID string) error {\\n\\tlogCtx := logging.WithComponent(ctx, \\\"condense-by-id\\\")\\n\\n\\t// Load session state\\n\\tstate, err := s.loadSessionState(ctx, sessionID)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n\\t}\\n\\tif state == nil {\\n\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n\\t}\\n\\n\\t// Open repository\\n\\trepo, err := OpenRepository(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\t// Generate a checkpoint ID\\n\\tcheckpointID, err := id.Generate()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n\\t}\\n\\n\\t// Check if shadow branch exists (required for condensation)\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\t_, refErr := repo.Reference(refName, true)\\n\\thasShadowBranch := refErr == nil\\n\\n\\tif !hasShadowBranch {\\n\\t\\t// No shadow branch means no checkpoint data to condense.\\n\\t\\t// Just clean up the state file.\\n\\t\\tlogging.Info(logCtx, \\\"no shadow branch for session, clearing state only\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n\\t\\t)\\n\\t\\tif err := s.clearSessionState(ctx, sessionID); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Condense the session\\n\\tresult, err := s.CondenseSession(ctx, repo, checkpointID, state, nil)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n\\t}\\n\\n\\tlogging.Info(logCtx, \\\"session condensed by ID\\\",\\n\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n\\t)\\n\\n\\t// Update session state: reset step count and transition to idle\\n\\tstate.StepCount = 0\\n\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n\\tstate.Phase