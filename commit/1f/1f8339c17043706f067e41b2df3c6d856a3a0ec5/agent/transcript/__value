7→\\t\\tslog.String(\\\"hook\\\", g.hookName),\\n    58→\\t\\tslog.String(\\\"hook_type\\\", \\\"git\\\"),\\n    59→\\t\\tslog.String(\\\"strategy\\\", g.strategyName),\\n    60→\\t\\tslog.Bool(\\\"success\\\", err == nil),\\n    61→\\t}\\n    62→\\tlogging.LogDuration(g.ctx, slog.LevelDebug, g.hookName+\\\" hook completed\\\", g.start, append(attrs, extraAttrs...)...)\\n    63→}\\n    64→\\n    65→// initHookLogging initializes logging for hooks by finding the most recent session.\\n    66→// Returns a cleanup function that should be deferred.\\n    67→// If Entire is not set up or disabled, returns a no-op to avoid creating files.\\n    68→func initHookLogging(ctx context.Context) func() {\\n    69→\\t// Don't create any files if Entire is not set up or disabled.\\n    70→\\t// This is checked here as defense-in-depth (also checked in PersistentPreRunE).\\n    71→\\tif !settings.IsSetUpAndEnabled(ctx) {\\n    72→\\t\\treturn func() {}\\n    73→\\t}\\n    74→\\n    75→\\t// Set up log level getter so logging can read from settings\\n    76→\\tlogging.SetLogLevelGetter(GetLogLevel)\\n    77→\\n    78→\\t// Read session ID for the slog attribute (empty string is fine - log file is fixed)\\n    79→\\tsessionID := strategy.FindMostRecentSession(ctx)\\n    80→\\tif err := logging.Init(ctx, sessionID); err != nil {\\n    81→\\t\\t// Init failed - logging will use stderr fallback\\n    82→\\t\\treturn func() {}\\n    83→\\t}\\n    84→\\treturn logging.Close\\n    85→}\\n    86→\\n    87→// hookLogCleanup stores the cleanup function for hook logging.\\n    88→// Set by PersistentPreRunE, called by PersistentPostRunE.\\n    89→var hookLogCleanup func()\\n    90→\\n    91→func newHooksGitCmd() *cobra.Command {\\n    92→\\tcmd := &cobra.Command{\\n    93→\\t\\tUse:    \\\"git\\\",\\n    94→\\t\\tShort:  \\\"Git hook handlers\\\",\\n    95→\\t\\tLong:   \\\"Commands called by git hooks. These delegate to the current strategy.\\\",\\n    96→\\t\\tHidden: true, // Internal comma