→\\t}\\n   182→\\n   183→\\tattribution := calculateSessionAttributions(ctx, repo, ref, sessionData, state, attributionOpts{\\n   184→\\t\\theadTree:              o.headTree,\\n   185→\\t\\trepoDir:               o.repoDir,\\n   186→\\t\\tattributionBaseCommit: attrBase,\\n   187→\\t\\theadCommitHash:        o.headCommitHash,\\n   188→\\t})\\n   189→\\n   190→\\t// Get current branch name\\n   191→\\tbranchName := GetCurrentBranchName(repo)\\n   192→\\n   193→\\t// Generate summary if enabled\\n   194→\\tvar summary *cpkg.Summary\\n   195→\\tif settings.IsSummarizeEnabled(ctx) && len(sessionData.Transcript) > 0 {\\n   196→\\t\\tsummarizeCtx := logging.WithComponent(ctx, \\\"summarize\\\")\\n   197→\\n   198→\\t\\tvar scopedTranscript []byte\\n   199→\\t\\tswitch state.AgentType {\\n   200→\\t\\tcase agent.AgentTypeGemini:\\n   201→\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   202→\\t\\t\\tif sliceErr != nil {\\n   203→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n   204→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   205→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   206→\\t\\t\\t}\\n   207→\\t\\t\\tscopedTranscript = scoped\\n   208→\\t\\tcase agent.AgentTypeOpenCode:\\n   209→\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   210→\\t\\t\\tif sliceErr != nil {\\n   211→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n   212→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   213→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   214→\\t\\t\\t}\\n   215→\\t\\t\\tscopedTranscript = scoped\\n   216→\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeFactoryAIDroid, agent.AgentTypeUnknown:\\n   217→\\t\\t\\tscopedTranscript = transcript.Sli