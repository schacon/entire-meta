); font-size: 0.75rem; line-height: 1.7; overflow-x: auto; white-space: pre; }\\n\\n.rewind-points { display: flex; flex-direction: column; gap: 8px; }\\n.rewind-point { display: flex; align-items: center; gap: 12px; padding: 10px 14px; border: 1px solid var(--border); border-radius: var(--radius); cursor: pointer; transition: all 0.2s; }\\n.rewind-point:hover { border-color: var(--purple); background: var(--purple-bg); }\\n.rewind-point.selected { border-color: var(--purple); background: var(--purple-bg); }\\n.rp-dot { width: 12px; height: 12px; border-radius: 50%; background: var(--purple); flex-shrink: 0; }\\n.rp-info { flex: 1; }\\n.rp-title { font-size: 0.85rem; font-weight: 500; }\\n.rp-meta { font-size: 0.72rem; color: var(--text-dim); font-family: var(--mono); }\\n\\n.file-change { display: flex; align-items: center; gap: 8px; padding: 4px 0; font-size: 0.8rem; font-family: var(--mono); }\\n.file-change .badge { font-size: 0.65rem; padding: 1px 6px; border-radius: 3px; font-weight: 600; text-transform: uppercase; }\\n.badge.restore { background: var(--green-bg); color: var(--green); }\\n.badge.delete { background: rgba(248,81,73,0.12); color: var(--red); }\\n.badge.revert { background: var(--orange-bg); color: var(--orange); }\\n\\n.link-viz { display: grid; grid-template-columns: 1fr 100px 1fr; gap: 0; align-items: center; min-height: 200px; }\\n.link-arrow { display: flex; flex-direction: column; align-items: center; gap: 4px; }\\n.link-box { border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem; background: var(--surface); transition: all 0.4s; }\\n.link-box.highlight { border-color: var(--green); box-shadow: 0 0 20px rgba(63,185,80,0.15); }\\n\\n.commit-block { font-family: var(--mono); font-size: 0.78rem; line-height: 1.8; }\\n.commit-block .hash { color: var(--orange); }\\n.commit-block .msg { color: var(--text); }\\n.commit-block .trailer { color: var(--green); }\\n.commit-block .trailer-label { color: var(--text-dim); }\\n\\n.fade-in { animation: fadeIn 0.4s ease; }\\n@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }\\n\\n::-webkit-scrollbar { width: 6px; }\\n::-webkit-scrollbar-track { background: transparent; }\\n::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }\\n\\n.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }\\n@media (max-width: 800px) { .two-col { grid-template-columns: 1fr; } .sm-container { flex-direction: column; } .sm-controls { width: 100%; } .cond-flow, .link-viz { grid-template-columns: 1fr; } }\\n\\n.dedup-msg { color: var(--orange); font-size: 0.8rem; font-style: italic; padding: 8px 12px; background: var(--orange-bg); border-radius: var(--radius); animation: fadeIn 0.3s ease; }\\n.step-counter { font-size: 0.75rem; color: var(--text-dim); }\\n.tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 0.7rem; font-weight: 600; }\\n.tag.shadow { background: var(--purple-bg); color: var(--purple); }\\n.tag.meta { background: var(--green-bg); color: var(--green); }\\n.tag.main { background: var(--blue-bg); color: var(--blue); }\\n</style>\\n</head>\\n<body>\\n\\n<div class=\\\"header\\\">\\n  <h1>Entire CLI &mdash; Checkpoint Playground</h1>\\n  <p>Interactive explorer for understanding how Entire checkpoints capture, condense, and restore your AI coding sessions.</p>\\n</div>\\n\\n<div class=\\\"tabs\\\">\\n  <div class=\\\"tab active\\\" onclick=\\\"switchTab(0)\\\"><span class=\\\"num\\\">1</span>Session Phases</div>\\n  <div class=\\\"tab\\\" onclick=\\\"switchTab(1)\\\"><span class=\\\"num\\\">2</span>Shadow Branch</div>\\n  <div class=\\\"tab\\\" onclick=\\\"switchTab(2)\\\"><span class=\\\"num\\\">3</span>Condensation</div>\\n  <div class=\\\"tab\\\" onclick=\\\"switchTab(3)\\\"><span class=\\\"num\\\">4</span>Rewind</div>\\n  <div class=\\\"tab\\\" onclick=\\\"switchTab(4)\\\"><span class=\\\"num\\\">5</span>Checkpoint Linking</div>\\n</div>\\n\\n<!-- Panel 1: Session Phases -->\\n<div class=\\\"panel active\\\" id=\\\"panel-0\\\">\\n  <div class=\\\"desc\\\" style=\\\"margin-bottom:1.5rem;\\\">\\n    Sessions track their lifecycle through a state machine with three phases. Events from agent hooks trigger transitions that emit actions like condensing checkpoints or updating timestamps.\\n  </div>\\n  <div class=\\\"sm-container\\\">\\n    <div class=\\\"sm-viz\\\">\\n      <div class=\\\"phase-nodes\\\">\\n        <div class=\\\"phase-node idle current\\\" id=\\\"pn-idle\\\">\\n          <div class=\\\"label\\\">IDLE</div>\\n          <div class=\\\"sub\\\">Between turns</div>\\n        </div>\\n        <div class=\\\"phase-node active-phase\\\" id=\\\"pn-active\\\">\\n          <div class=\\\"label\\\">ACTIVE</div>\\n          <div class=\\\"sub\\\">Agent working</div>\\n        </div>\\n        <div class=\\\"phase-node ended\\\" id=\\\"pn-ended\\\">\\n          <div class=\\\"label\\\">ENDED</div>\\n          <div class=\\\"sub\\\">Session stopped</div>\\n        </div>\\n      </div>\\n      <div class=\\\"card\\\" style=\\\"margin-top:1rem;\\\">\\n        <h3>Last Action</h3>\\n        <div class=\\\"action-toast\\\" id=\\\"action-toast\\\">\\n          <span id=\\\"action-text\\\">Click an event to trigger a transition</span>\\n        </div>\\n      </div>\\n      <div class=\\\"card\\\" style=\\\"margin-top:0.75rem;\\\">\\n        <h3>Transition Log</h3>\\n        <div class=\\\"transition-log\\\" id=\\\"transition-log\\\"></div>\\n      </div>\\n    </div>\\n    <div class=\\\"sm-controls\\\">\\n      <div class=\\\"card\\\">\\n        <h3>Fire Event</h3>\\n        <p style=\\\"margin-bottom:0.75rem;\\\">Click an event to see which phase transition and action it triggers from the current state.</p>\\n        <div class=\\\"btn-group\\\" style=\\\"flex-direction:column;\\\">\\n          <button class=\\\"btn green\\\" onclick=\\\"fireEvent('TurnStart')\\\">TurnStart</button>\\n          <button class=\\\"btn green\\\" onclick=\\\"fireEvent('TurnEnd')\\\">TurnEnd</button>\\n          <button class=\\\"btn primary\\\" onclick=\\\"fireEvent('GitCommit')\\\">GitCommit</button>\\n          <button class=\\\"btn\\\" onclick=\\\"fireEvent('SessionStart')\\\">SessionStart</button>\\n          <button class=\\\"btn orange\\\" onclick=\\\"fireEvent('SessionStop')\\\">SessionStop</button>\\n        </div>\\n      </div>\\n      <div class=\\\"card\\\" style=\\\"margin-top:0.75rem;\\\">\\n        <h3>Reset</h3>\\n        <button class=\\\"btn\\\" onclick=\\\"resetStateMachine()\\\">Reset to IDLE</button>\\n      </div>\\n    </div>\\n  </div>\\n</div>\\n\\n<!-- Panel 2: Shadow Branch -->\\n<div class=\\\"panel\\\" id=\\\"panel-1\\\">\\n  <div class=\\\"desc\\\" style=\\\"margin-bottom:1.5rem;\\\">\\n    When an agent works, each step is saved as a commit on a <span class=\\\"tag shadow\\\">shadow branch</span>. The shadow branch forks from the current HEAD and stores full file snapshots + session metadata. It never touches your working branch.\\n  </div>\\n  <div class=\\\"card\\\">\\n    <div class=\\\"card-header\\\">\\n      <h3>Branch Visualization</h3>\\n      <div class=\\\"step-counter\\\" id=\\\"step-counter\\\">0 checkpoints</div>\\n    </div>\\n    <canvas class=\\\"branch-canvas\\\" id=\\\"branch-canvas\\\"></canvas>\\n  </div>\\n  <div class=\\\"two-col\\\">\\n    <div class=\\\"card\\\">\\n      <h3>Controls</h3>\\n      <div class=\\\"btn-group\\\" style=\\\"flex-direction:column;\\\">\\n        <button class=\\\"btn purple\\\" onclick=\\\"addCheckpoint(false)\\\">Save Step (agent checkpoint)</button>\\n        <button class=\\\"btn purple\\\" onclick=\\\"addCheckpoint(true)\\\">Save Step (duplicate &mdash; dedup test)</button>\\n        <button class=\\\"btn primary\\\" onclick=\\\"addMainCommit()\\\">User Commit on main</button>\\n        <button class=\\\"btn\\\" onclick=\\\"resetBranch()\\\">Reset</button>\\n      </div>\\n      <div id=\\\"dedup-area\\\" style=\\\"margin-top:0.75rem;\\\"></div>\\n    </div>\\n    <div class=\\\"card\\\">\\n      <h3>Shadow Branch Metadata</h3>\\n      <div class=\\\"file-tree\\\" id=\\\"shadow-tree\\\">\\n        <em class=\\\"desc\\\">Save a step to see the metadata tree</em>\\n      </div>\\n    </div>\\n  </div>\\n</div>\\n\\n<!-- Panel 3: Condensation -->\\n<div class=\\\"panel\\\" id=\\\"panel-2\\\">\\n  <div class=\\\"desc\\\" style=\\\"margin-bottom:1.5rem;\\\">\\n    When you make a git commit, the PostCommit hook triggers <strong>condensation</strong>: session data flows from the <span class=\\\"tag shadow\\\">shadow branch</span> to the permanent <span class=\\\"tag meta\\\">entire/checkpoints/v1</span> metadata branch, linked by a 12-char checkpoint ID.\\n  </div>\\n  <div class=\\\"card\\\">\\n    <div class=\\\"card-header\\\"><h3>Condensation Flow</h3></div>\\n    <div class=\\\"cond-flow\\\">\\n      <div class=\\\"card\\\" id=\\\"cond-source\\\" style=\\\"border-color:var(--purple);\\\">\\n        <h3><span class=\\\"tag shadow\\\">Shadow Branch</span></h3>\\n        <div id=\\\"cond-source-content\\\">\\n          <p>Session data stored here during agent work:</p>\\n          <div class=\\\"file-tree\\\" style=\\\"margin-top:0.5rem;\\\">\\n            <div><span class=\\\"dir\\\">.entire/metadata/2026-03-06-abc/</span></div>\\n            <div><span class=\\\"indent\\\"></span><span class=\\\"file\\\">full.jsonl</span> &mdash; transcript</div>\\n            <div><span class=\\\"indent\\\"></span><span class=\\\"file\\\">prompt.txt</span> &mdash; user prompt</div>\\n          </div>\\n        </div>\\n      </div>\\n      <div class=\\\"arrow-col\\\">\\n        <div class=\\\"cond-arrow\\\" id=\\\"cond-arrow\\\"></div>\\n        <div style=\\\"font-size:0.7rem;color:var(--text-dim);margin-top:8px;text-align:center;\\\" id=\\\"cond-flow-label\\\">click below</div>\\n      </div>\\n      <div class=\\\"card\\\" id=\\\"cond-target\\\" style=\\\"border-color:var(--green); opacity:0.5;\\\">\\n        <h3><span class=\\\"tag meta\\\">entire/checkpoints/v1</span></h3>\\n        <div id=\\\"cond-target-content\\\">\\n          <p style=\\\"color:var(--text-dim)\\\">Metadata will appear here after condensation...</p>\\n        </div>\\n      </div>\\n    </div>\\n  </div>\\n  <div class=\\\"two-col\\\">\\n    <div class=\\\"card\\\">\\n      <h3>Controls</h3>\\n      <div class=\\\"btn-group\\\" style=\\\"flex-direction:column;\\\">\\n        <button class=\\\"btn primary\\\" onclick=\\\"runCondensation()\\\" id=\\\"btn-condense\\\">Trigger Condensation (git commit)</button>\\n        <button class=\\\"btn green\\\" onclick=\\\"addSecondSession()\\\">Add Second Session</button>\\n        <button class=\\\"btn\\\" onclick=\\\"resetCondensation()\\\">Reset</button>\\n      </div>\\n      <div id=\\\"cond-status\\\" style=\\\"margin-top:0.75rem;\\\"></div>\\n    </div>\\n    <div class=\\\"card\\\">\\n      <h3>User Commit</h3>\\n      <div class=\\\"commit-block\\\" id=\\\"cond-commit\\\">\\n        <div><span class=\\\"hash\\\">abc1234</span> <span class=\\\"msg\\\">Implement login feature</span></div>\\n        <div style=\\\"margin-top:4px;color:var(--text-dim);font-size:0.72rem;\\\">No checkpoint trailer yet</div>\\n      </div>\\n    </div>\\n  </div>\\n</div>\\n\\n<!-- Panel 4: Rewind -->\\n<div class=\\\"panel\\\" id=\\\"panel-3\\\">\\n  <div class=\\\"desc\\\" style=\\\"margin-bottom:1.5rem;\\\">\\n    Rewind restores your working directory to a previous checkpoint. Unlike <code>git reset</code>, it reads files directly from the checkpoint's git tree and writes them to disk, preserving your branch history.\\n  </div>\\n  <div class=\\\"two-col\\\">\\n    <div class=\\\"card\\\">\\n      <h3>Rewind Points</h3>\\n      <p style=\\\"margin-bottom:0.75rem;\\\">Click a checkpoint to preview the rewind:</p>\\n      <div class=\\\"rewind-points\\\" id=\\\"rewind-points\\\"></div>\\n    </div>\\n    <div class=\\\"card\\\" id=\\\"rewind-preview-card\\\" style=\\\"opacity:0.5;\\\">\\n      <h3>Rewind Preview</h3>\\n      <div id=\\\"rewind-preview\\\">\\n        <p class=\\\"desc\\\">Select a rewind point to see what would change</p>\\n      </div>\\n    </div>\\n  </div>\\n  <div class=\\\"card\\\" style=\\\"margin-top:1rem;\\\">\\n    <h3>How Rewind Works (Step by Step)</h3>\\n    <div class=\\\"desc\\\" style=\\\"line-height:2;\\\">\\n      <strong>1.</strong> Read checkpoint commit tree from shadow branch<br>\\n      <strong>2.</strong> Compare files in tree vs. current working directory<br>\\n      <strong>3.</strong> Compute <code>FilesToRestore</code> &mdash; files from checkpoint to write<br>\\n      <strong>4.</strong> Compute <code>FilesToDelete</code> &mdash; untracked files created after checkpoint<br>\\n      <strong>5.</strong> Compute <code>TrackedChanges</code> &mdash; uncommitted tracked changes to revert<br>\\n      <strong>6.</strong> Write files from git tree to disk (no <code>git reset</code>)<br>\\n      <strong>7.</strong> Session metadata is preserved for reference\\n    </div>\\n  </div>\\n</div>\\n\\n<!-- Panel 5: Checkpoint Linking -->\\n<div class=\\\"panel\\\" id=\\\"panel-4\\\">\\n  <div class=\\\"desc\\\" style=\\\"margin-bottom:1.5rem;\\\">\\n    A 12-hex-char <strong>checkpoint ID</strong> creates a bidirectional link between your git commit and the session metadata. The ID is embedded as a trailer in your commit and used as a sharded directory path on the metadata branch.\\n  </div>\\n  <div class=\\\"card\\\">\\n    <div class=\\\"card-header\\\"><h3>Bidirectional Linking</h3></div>\\n    <div class=\\\"link-viz\\\">\\n      <div class=\\\"link-box\\\" id=\\\"link-commit\\\">\\n        <h3><span class=\\\"tag main\\\">User Commit</span></h3>\\n        <div class=\\\"commit-block\\\" style=\\\"margin-top:0.75rem;\\\">\\n          <div><span class=\\\"hash\\\">e7f2a91</span> <span class=\\\"msg\\\">Implement login feature</span></div>\\n          <div style=\\\"margin-top:6px;\\\"><span class=\\\"trailer-label\\\">Entire-Checkpoint:</span> <span class=\\\"trailer\\\" id=\\\"link-id-commit\\\">a3b2c4d5e6f7</span></div>\\n        </div>\\n      </div>\\n      <div class=\\\"link-arrow\\\">\\n        <svg id=\\\"link-arrow-right\\\" width=\\\"80\\\" height=\\\"30\\\" viewBox=\\\"0 0 80 30\\\">\\n          <line x1=\\\"0\\\" y1=\\\"12\\\" x2=\\\"60\\\" y2=\\\"12\\\" stroke=\\\"#30363d\\\" stroke-width=\\\"2\\\"/>\\n          <polygon points=\\\"60,6 72,12 60,18\\\" fill=\\\"#30363d\\\"/>\\n          <text x=\\\"36\\\" y=\\\"28\\\" font-size=\\\"9\\\" fill=\\\"#8b949e\\\" text-anchor=\\\"middle\\\">lookup</text>\\n        </svg>\\n        <svg id=\\\"link-arrow-left\\\" width=\\\"80\\\" height=\\\"30\\\" viewBox=\\\"0 0 80 30\\\" style=\\\"margin-top:4px;\\\">\\n          <line x1=\\\"20\\\" y1=\\\"12\\\" x2=\\\"80\\\" y2=\\\"12\\\" stroke=\\\"#30363d\\\" stroke-width=\\\"2\\\"/>\\n          <polygon points=\\\"20,6 8,12 20,18\\\" fill=\\\"#30363d\\\"/>\\n          <text x=\\\"46\\\" y=\\\"28\\\" font-size=\\\"9\\\" fill=\\\"#8b949e\\\" text-anchor=\\\"middle\\\">search</text>\\n        </svg>\\n      </div>\\n      <div class=\\\"link-box\\\" id=\\\"link-meta\\\">\\n        <h3><span class=\\\"tag meta\\\">Metadata Branch</span></h3>\\n        <div style=\\\"margin-top:0.75rem;\\\">\\n          <div class=\\\"shard-path\\\"><span class=\\\"prefix\\\">a3</span><span class=\\\"sep\\\">/</span><span class=\\\"rest\\\">b2c4d5e6f7</span><span class=\\\"sep\\\">/</span></div>\\n          <div class=\\\"file-tree\\\" style=\\\"margin-top:0.4rem;\\\">\\n            <div><span class=\\\"file\\\">metadata.json</span></div>\\n            <div><span class=\\\"dir\\\">0/</span></div>\\n            <div><span class=\\\"indent\\\"></span><span class=\\\"file\\\">full.jsonl</span></div>\\n            <div><span class=\\\"indent\\\"></span><span class=\\\"file\\\">prompt.txt</span></div>\\n          </div>\\n        </div>\\n      </div>\\n    </div>\\n  </div>\\n  <div class=\\\"two-col\\\">\\n    <div class=\\\"card\\\">\\n      <h3>Try It: Forward Lookup</h3>\\n      <p style=\\\"margin-bottom:0.5rem;\\\">Extract the trailer from a user commit to find its metadata:</p>\\n      <button class=\\\"btn primary\\\" onclick=\\\"animateLinkForward()\\\">Commit &rarr; Metadata</button>\\n      <div id=\\\"link-fwd-result\\\" style=\\\"margin-top:0.75rem;\\\"></div>\\n    </div>\\n    <div class=\\\"card\\\">\\n      <h3>Try It: Reverse Lookup</h3>\\n      <p style=\\\"margin-bottom:0.5rem;\\\">Given a checkpoint ID, search commit history for matches:</p>\\n      <button class=\\\"btn green\\\" onclick=\\\"animateLinkReverse()\\\">Metadata &rarr; Commit</button>\\n      <div id=\\\"link-rev-result\\\" style=\\\"margin-top:0.75rem;\\\"></div>\\n    </div>\\n  </div>\\n  <div class=\\\"card\\\" style=\\\"margin-top:1rem;\\\">\\n    <h3>Sharding Explained</h3>\\n    <p>The checkpoint ID <code>a3b2c4d5e6f7</code> is split: first 2 chars become a directory prefix (<code>a3/</code>), remaining 10 become a subdirectory (<code>b2c4d5e6f7/</code>). This creates up to 256 shards (00-ff), preventing any single directory from holding too many entries.</p>\\n    <div style=\\\"margin-top:0.75rem;\\\">\\n      <button class=\\\"btn\\\" onclick=\\\"generateNewId()\\\">Generate New ID</button>\\n      <span id=\\\"generated-shard\\\" style=\\\"margin-left:12px;\\\"></span>\\n    </div>\\n  </div>\\n</div>\\n\\n<script>\\n// ==================== Utilities ====================\\nfunction randHex(n) {\\n  var s = '';\\n  for (var i = 0; i < n; i++) s += Math.floor(Math.random() * 16).toString(16);\\n  return s;\\n}\\n\\nfunction esc(str) {\\n  var d = document.createElement('div');\\n  d.textContent = str;\\n  return d.innerHTML;\\n}\\n\\nfunction setHTML(id, html) {\\n  document.getElementById(id).innerHTML = html;\\n}\\n\\n// ==================== Tab switching ====================\\nfunction switchTab(i) {\\n  document.querySelectorAll('.tab').forEach(function(t, j) { t.classList.toggle('active', j === i); });\\n  document.querySelectorAll('.panel').forEach(function(p, j) { p.classList.toggle('active', j === i); });\\n  if (i === 1) drawBranch();\\n}\\n\\n// ==================== Panel 1: State Machine ====================\\nvar SM_TRANSITIONS = {\\n  'IDLE': {\\n    'TurnStart':    { next: 'ACTIVE',  action: 'ActionUpdateLastInteraction' },\\n    'GitCommit':    { next: 'IDLE',    action: 'ActionCondense' },\\n    'SessionStop':  { next: 'ENDED',   action: null },\\n    'SessionStart': { next: 'IDLE',    action: 'ActionWarnStaleSession' },\\n  },\\n  'ACTIVE': {\\n    'TurnEnd':      { next: 'IDLE',    action: null },\\n    'GitCommit':    { next: 'ACTIVE',  action: 'ActionCondense' },\\n    'SessionStop':  { next: 'ENDED',   action: null },\\n  },\\n  'ENDED': {\\n    'TurnStart':    { next: 'ACTIVE',  action: 'ActionClearEndedAt, ActionUpdateLastInteraction' },\\n    'GitCommit':    { next: 'ENDED',   action: 'ActionDiscardIfNoFiles' },\\n    'SessionStart': { next: 'IDLE',    action: null },\\n  }\\n};\\n\\nvar currentPhase = 'IDLE';\\nvar transitionLog = [];\\n\\nfunction fireEvent(event) {\\n  var trans = SM_TRANSITIONS[currentPhase] ? SM_TRANSITIONS[currentPhase][event] : null;\\n  if (!trans) {\\n    showAction('Invalid: ' + esc(event) + ' not allowed in ' + currentPhase, true);\\n    return;\\n  }\\n  var from = currentPhase;\\n  currentPhase = trans.next;\\n  updatePhaseViz();\\n  var actionStr = trans.action || '(no action)';\\n  showAction(from + ' + ' + event + ' \\\\u2192 ' + currentPhase + '  \\\\u27F9  ' + actionStr);\\n  transitionLog.unshift({ from: from, event: event, to: currentPhase, action: actionStr });\\n  renderLog();\\n}\\n\\nfunction updatePhaseViz() {\\n  document.querySelectorAll('.phase-node').forEach(function(n) { n.classList.remove('current'); });\\n  var map = { 'IDLE': 'pn-idle', 'ACTIVE': 'pn-active', 'ENDED': 'pn-ended' };\\n  document.getElementById(map[currentPhase]).classList.add('current');\\n}\\n\\nfunction showAction(text, isError) {\\n  var toast = document.getElementById('action-toast');\\n  document.getElementById('action-text').textContent = text;\\n  toast.classList.remove('flash');\\n  if (isError) {\\n    toast.style.background = 'rgba(248,81,73,0.12)';\\n    toast.style.borderColor = 'rgba(248,81,73,0.3)';\\n    toast.style.color = 'var(--red)';\\n  } else {\\n    toast.style.background = '';\\n    toast.style.borderColor = '';\\n    toast.style.color = '';\\n  }\\n  void toast.offsetWidth;\\n  toast.classList.add('flash');\\n}\\n\\nfunction renderLog() {\\n  var el = document.getElementById('transition-log');\\n  el.textContent = '';\\n  transitionLog.forEach(function(e, i) {\\n    var div = document.createElement('div');\\n    div.className = 'log-entry' + (i === 0 ? ' latest' : '');\\n    div.textContent = e.from + ' + ' + e.event + ' \\\\u2192 ' + e.to + '  \\\\u27F9  ' + e.action;\\n    el.appendChild(div);\\n  });\\n}\\n\\nfunction resetStateMachine() {\\n  currentPhase = 'IDLE';\\n  transitionLog = [];\\n  updatePhaseViz();\\n  document.getElementById('action-text').textContent = 'Click an event to trigger a transition';\\n  document.getElementById('transition-log').textContent = '';\\n}\\n\\n// ==================== Panel 2: Shadow Branch ====================\\nvar mainCommits = [\\n  { hash: 'a1b2c3d', msg: 'Initial commit', x: 0 },\\n  { hash: 'e4f5678', msg: 'Add auth module', x: 0 },\\n];\\nvar shadowCommits = [];\\nvar SESSION_ID = '2026-03-06-' + randHex(4);\\n\\nfunction addCheckpoint(isDuplicate) {\\n  var dedupArea = document.getElementById('dedup-area');\\n  if (isDuplicate && shadowCommits.length > 0) {\\n    dedupArea.textContent = '';\\n    var msg = document.createElement('div');\\n    msg.className = 'dedup-msg fade-in';\\n    msg.textContent = 'Skipped: tree hash matches previous checkpoint (deduplication)';\\n    dedupArea.appendChild(msg);\\n    return;\\n  }\\n  dedupArea.textContent = '';\\n  var step = shadowCommits.length + 1;\\n  var msgs = ['Edit auth logic','Add handler','Refactor middleware','Update tests'];\\n  var files = ['src/auth.go', 'src/handler.go'];\\n  if (step > 2) files.push('src/middleware.go');\\n  shadowCommits.push({\\n    hash: randHex(7),\\n    msg: 'Step ' + step + ': ' + msgs[step % 4],\\n    files: files,\\n    sessionId: SESSION_ID,\\n  });\\n  document.getElementById('step-counter').textContent = shadowCommits.length + ' checkpoint' + (shadowCommits.length !== 1 ? 's' : '');\\n  updateShadowTree();\\n  drawBranch();\\n  populateRewindPoints();\\n}\\n\\nfunction addMainCommit() {\\n  mainCommits.push({ hash: randHex(7), msg: 'User commit #' + (mainCommits.length - 1) });\\n  drawBranch();\\n}\\n\\nfunction resetBranch() {\\n  mainCommits = [\\n    { hash: 'a1b2c3d', msg: 'Initial commit' },\\n    { hash: 'e4f5678', msg: 'Add auth module' },\\n  ];\\n  shadowCommits = [];\\n  document.getElementById('step-counter').textContent = '0 checkpoints';\\n  var tree = document.getElementById('shadow-tree');\\n  tree.textContent = '';\\n  var em = document.createElement('em');\\n  em.className = 'desc';\\n  em.textContent = 'Save a step to see the metadata tree';\\n  tree.appendChild(em);\\n  document.getElementById('dedup-area').textContent = '';\\n  drawBranch();\\n  populateRewindPoints();\\n}\\n\\nfunction updateShadowTree() {\\n  var el = document.getElementById('shadow-tree');\\n  var sid = SESSION_ID.length > 20 ? SESSION_ID.substring(0, 20) + '...' : SESSION_ID;\\n  var lines = [\\n    { cls: 'dir', text: '.entire/metadata/' + sid + '/', indent: 0 },\\n    { cls: 'file', text: 'full.jsonl', indent: 1, note: ' \\\\u2014 ' + shadowCommits.length + ' entries' },\\n    { cls: 'file', text: 'prompt.txt', indent: 1, note: ' \\\\u2014 latest prompt' },\\n  ];\\n  if (shadowCommits.length > 2) {\\n    lines.push({ cls: 'dir', text: 'tasks/toolu_01X.../', indent: 1 });\\n    lines.push({ cls: 'file', text: 'checkpoint.json', indent: 2 });\\n    lines.push({ cls: 'file', text: 'agent-sub1.jsonl', indent: 2 });\\n  }\\n  el.textContent = '';\\n  lines.forEach(function(l) {\\n    var div = document.createElement('div');\\n    for (var i = 0; i < l.indent; i++) {\\n      var sp = document.createElement('span');\\n      sp.className = 'indent';\\n      div.appendChild(sp);\\n    }\\n    var span = document.createElement('span');\\n    span.className = l.cls;\\n    span.textContent = l.text;\\n    div.appendChild(span);\\n    if (l.note) {\\n      var note = document.createTextNode(l.note);\\n      div.appendChild(note);\\n    }\\n    el.appendChild(div);\\n  });\\n}\\n\\nfunction drawBranch() {\\n  var canvas = document.getElementById('branch-canvas');\\n  var ctx = canvas.getContext('2d');\\n  var dpr = window.devicePixelRatio || 1;\\n  canvas.width = canvas.clientWidth * dpr;\\n  canvas.height = canvas.clientHeight * dpr;\\n  ctx.scale(dpr, dpr);\\n  var W = canvas.clientWidth, H = canvas.clientHeight;\\n  ctx.clearRect(0, 0, W, H);\\n\\n  var mainY = 100, shadowY = 220;\\n  var total = Math.max(mainCommits.length + shadowCommits.length, 4);\\n  var startX = 80, gap = Math.min(120, (W - 160) / total);\\n\\n  // Main branch line\\n  ctx.strokeStyle = '#58a6ff';\\n  ctx.lineWidth = 3;\\n  ctx.beginPath();\\n  ctx.moveTo(startX - 40, mainY);\\n  ctx.lineTo(startX + (mainCommits.length - 1) * gap + 40, mainY);\\n  ctx.stroke();\\n\\n  // Main commits\\n  mainCommits.forEach(function(c, i) {\\n    c.x = startX + i * gap;\\n    drawCommitNode(ctx, c.x, mainY, '#58a6ff', c.hash, c.msg);\\n  });\\n\\n  // Main branch label\\n  ctx.font = 'bold 12px -apple-system, sans-serif';\\n  ctx.fillStyle = '#58a6ff';\\n  ctx.textAlign = 'start';\\n  ctx.fillText('main', startX - 40, mainY - 28);\\n\\n  if (shadowCommits.length > 0) {\\n    var forkX = mainCommits[mainCommits.length - 1].x;\\n    var shadowStartX = forkX + gap * 0.5;\\n\\n    // Fork line (dashed)\\n    ctx.strokeStyle = '#bc8cff';\\n    ctx.lineWidth = 2;\\n    ctx.setLineDash([5, 4]);\\n    ctx.beginPath();\\n    ctx.moveTo(forkX, mainY);\\n    ctx.quadraticCurveTo(forkX + 20, mainY + 50, shadowStartX, shadowY);\\n    ctx.stroke();\\n    ctx.setLineDash([]);\\n\\n    // Shadow branch line\\n    ctx.strokeStyle = '#bc8cff';\\n    ctx.lineWidth = 3;\\n    ctx.beginPath();\\n    ctx.moveTo(shadowStartX, shadowY);\\n    ctx.lineTo(shadowStartX + (shadowCommits.length - 1) * gap + 40, shadowY);\\n    ctx.stroke();\\n\\n    // Shadow commits\\n    shadowCommits.forEach(function(c, i) {\\n      drawCommitNode(ctx, shadowStartX + i * gap, shadowY, '#bc8cff', c.hash, c.msg);\\n    });\\n\\n    // Shadow branch label\\n    var baseHash = mainCommits[mainCommits.length - 1].hash.substring(0, 7);\\n    ctx.font = 'bold 11px SF Mono, Fira Code, monospace';\\n    ctx.fillStyle = '#bc8cff';\\n    ctx.textAlign = 'start';\\n    ctx.fillText('entire/' + baseHash + '-x4f2a1', shadowStartX - 10, shadowY - 28);\\n  }\\n}\\n\\nfunction drawCommitNode(ctx, x, y, color, hash, msg) {\\n  ctx.beginPath();\\n  ctx.arc(x, y, 10, 0, Math.PI * 2);\\n  ctx.fillStyle = color;\\n  ctx.fill();\\n  ctx.beginPath();\\n  ctx.arc(x, y, 7, 0, Math.PI * 2);\\n  ctx.fillStyle = '#0d1117';\\n  ctx.fill();\\n  ctx.beginPath();\\n  ctx.arc(x, y, 4, 0, Math.PI * 2);\\n  ctx.fillStyle = color;\\n  ctx.fill();\\n\\n  ctx.font = '10px SF Mono, Fira Code, monospace';\\n  ctx.fillStyle = '#d29922';\\n  ctx.textAlign = 'center';\\n  ctx.fillText(hash.substring(0, 7), x, y + 24);\\n\\n  ctx.font = '11px -apple-system, sans-serif';\\n  ctx.fillStyle = '#8b949e';\\n  var truncMsg = msg.length > 18 ? msg.substring(0, 16) + '...' : msg;\\n  ctx.fillText(truncMsg, x, y + 38);\\n  ctx.textAlign = 'start';\\n}\\n\\n// ==================== Panel 3: Condensation ====================\\nvar condState = 'ready';\\nvar checkpointId = null;\\n\\nfunction runCondensation() {\\n  if (condState !== 'ready') return;\\n  checkpointId = randHex(12);\\n  condState = 'condensed';\\n\\n  document.getElementById('cond-arrow').classList.add('active');\\n  document.getElementById('cond-flow-label').textContent = 'condensing...';\\n  document.getElementById('cond-target').style.opacity = '1';\\n\\n  setTimeout(function() {\\n    document.getElementById('cond-flow-label').textContent = 'complete';\\n    var prefix = checkpointId.substring(0, 2);\\n    var rest = checkpointId.substring(2);\\n    renderCondensedTarget(prefix, rest, ['\\\"2026-03-06-abc\\\"'], 1);\\n    renderCondCommit(checkpointId);\\n    var status = document.getElementById('cond-status');\\n    status.textContent = '';\\n    var div = document.createElement('div');\\n    div.className = 'fade-in';\\n    div.style.color = 'var(--green)';\\n    div.style.fontSize = '0.8rem';\\n    div.textContent = 'Condensation complete. Checkpoint ID: ' + checkpointId;\\n    status.appendChild(div);\\n  }, 800);\\n}\\n\\nfunction renderCondensedTarget(prefix, rest, sessionIds, count) {\\n  var target = document.getElementById('cond-target-content');\\n  target.textContent = '';\\n  var wrap = document.createElement('div');\\n  wrap.className = 'fade-in';\\n\\n  var idDiv = document.createElement('div');\\n  idDiv.className = 'checkpoint-id';\\n  idDiv.style.marginBottom = '0.75rem';\\n  idDiv.textContent = checkpointId;\\n  wrap.appendChild(idDiv);\\n\\n  var shardDiv = document.createElement('div');\\n  shardDiv.className = 'shard-path';\\n  shardDiv.style.marginBottom = '0.5rem';\\n  shardDiv.appendChild(makeSpan('prefix', prefix));\\n  shardDiv.appendChild(makeSpan('sep', '/'));\\n  shardDiv.appendChild(makeSpan('rest', rest));\\n  shardDiv.appendChild(makeSpan('sep', '/'));\\n  wrap.appendChild(shardDiv);\\n\\n  var jsonBlock = document.createElement('div');\\n  jsonBlock.className = 'json-block';\\n  jsonBlock.textContent =\\n    '{\\\\n' +\\n    '  \\\"checkpoint_id\\\": \\\"' + checkpointId + '\\\",\\\\n' +\\n    '  \\\"session_ids\\\": [' + sessionIds.join(', ') + '],\\\\n' +\\n    '  \\\"session_count\\\": ' + count + ',\\\\n' +\\n    '  \\\"strategy\\\": \\\"manual-commit\\\",\\\\n' +\\n    '  \\\"files_touched\\\": [\\\"src/auth.go\\\", \\\"src/handler.go\\\"]\\\\n' +\\n    '}';\\n  wrap.appendChild(jsonBlock);\\n\\n  var tree = document.createElement('div');\\n  tree.className = 'file-tree';\\n  tree.style.marginTop = '0.75rem';\\n  var treeLines = [\\n    { cls: 'dir', text: prefix + '/' + rest + '/', indent: 0 },\\n    { cls: 'file', text: 'metadata.json', indent: 1 },\\n    { cls: 'dir', text: '0/', indent: 1 },\\n    { cls: 'file', text: 'metadata.json, full.jsonl, prompt.txt', indent: 2 },\\n  ];\\n  if (count > 1) {\\n    treeLines.push({ cls: 'dir', text: '1/', indent: 1, highlight: true });\\n    treeLines.push({ cls: 'file', text: 'metadata.json, full.jsonl, prompt.txt', indent: 2 });\\n  }\\n  treeLines.forEach(function(l) {\\n    var div = document.createElement('div');\\n    for (var i = 0; i < l.indent; i++) {\\n      var sp = document.createElement('span');\\n      sp.className = 'indent';\\n      div.appendChild(sp);\\n    }\\n    var span = document.createElement('span');\\n    span.className = l.cls;\\n    span.textContent = l.text;\\n    if (l.highlight) span.style.color = 'var(--green)';\\n    div.appendChild(span);\\n    tree.appendChild(div);\\n  });\\n  wrap.appendChild(tree);\\n  target.appendChild(wrap);\\n}\\n\\nfunction renderCondCommit(cpId) {\\n  var el = document.getElementById('cond-commit');\\n  el.textContent = '';\\n  var wrap = document.createElement('div');\\n  wrap.className = 'fade-in';\\n  var line1 = document.createElement('div');\\n  var hashSpan = makeSpan('hash', 'abc1234');\\n  var msgSpan = makeSpan('msg', ' Implement login feature');\\n  line1.appendChild(hashSpan);\\n  line1.appendChild(msgSpan);\\n  wrap.appendChild(line1);\\n  var line2 = document.createElement('div');\\n  line2.style.marginTop = '6px';\\n  line2.appendChild(makeSpan('trailer-label', 'Entire-Checkpoint: '));\\n  line2.appendChild(makeSpan('trailer', cpId));\\n  wrap.appendChild(line2);\\n  el.appendChild(wrap);\\n}\\n\\nfunction makeSpan(cls, text) {\\n  var s = document.createElement('span');\\n  s.className = cls;\\n  s.textContent = text;\\n  return s;\\n}\\n\\nfunction addSecondSession() {\\n  if (condState !== 'condensed') {\\n    var status = document.getElementById('cond-status');\\n    status.textContent = '';\\n    var div = document.createElement('div');\\n    div.className = 'invalid-msg';\\n    div.textContent = 'Run condensation first';\\n    status.appendChild(div);\\n    return;\\n  }\\n  condState = 'multi';\\n  var prefix = checkpointId.substring(0, 2);\\n  var rest = checkpointId.substring(2);\\n  renderCondensedTarget(prefix, rest, ['\\\"2026-03-06-abc\\\"', '\\\"2026-03-06-xyz\\\"'], 2);\\n  var status = document.getElementById('cond-status');\\n  status.textContent = '';\\n  var div = document.createElement('div');\\n  div.className = 'fade-in';\\n  div.style.color = 'var(--green)';\\n  div.style.fontSize = '0.8rem';\\n  div.textContent = 'Second session added to subfolder 1/. session_count incremented to 2.';\\n  status.appendChild(div);\\n}\\n\\nfunction resetCondensation() {\\n  condState = 'ready';\\n  checkpointId = null;\\n  document.getElementById('cond-arrow').classList.remove('active');\\n  document.getElementById('cond-flow-label').textContent = 'click below';\\n  document.getElementById('cond-target').style.opacity = '0.5';\\n  var target = document.getElementById('cond-target-content');\\n  target.textContent = '';\\n  var p = document.createElement('p');\\n  p.style.color = 'var(--text-dim)';\\n  p.textContent = 'Metadata will appear here after condensation...';\\n  target.appendChild(p);\\n  var commit = document.getElementById('cond-commit');\\n  commit.textContent = '';\\n  var d1 = document.createElement('div');\\n  d1.appendChild(makeSpan('hash', 'abc1234'));\\n  d1.appendChild(makeSpan('msg', ' Implement login feature'));\\n  commit.appendChild(d1);\\n  var d2 = document.createElement('div');\\n  d2.style.marginTop = '4px';\\n  d2.style.color = 'var(--text-dim)';\\n  d2.style.fontSize = '0.72rem';\\n  d2.textContent = 'No checkpoint trailer yet';\\n  commit.appendChild(d2);\\n  document.getElementById('cond-status').textContent = '';\\n}\\n\\n// ==================== Panel 4: Rewind ====================\\nvar SAMPLE_REWIND = [\\n  { id: 'cp3', hash: 'f1a2b3c', prompt: 'Add error handling to auth', files: ['src/auth.go', 'src/errors.go'], step: 3 },\\n  { id: 'cp2', hash: 'd4e5f6a', prompt: 'Create handler for /login', files: ['src/handler.go', 'src/auth.go'], step: 2 },\\n  { id: 'cp1', hash: 'b7c8d9e', prompt: 'Set up auth module', files: ['src/auth.go'], step: 1 },\\n];\\n\\nfunction getRewindData() {\\n  if (shadowCommits.length > 0) {\\n    return shadowCommits.map(function(c, i) {\\n      return { id: 'cp' + (i + 1), hash: c.hash, prompt: c.msg, files: c.files, step: i + 1 };\\n    }).reverse();\\n  }\\n  return SAMPLE_REWIND;\\n}\\n\\nfunction populateRewindPoints() {\\n  var el = document.getElementById('rewind-points');\\n  el.textContent = '';\\n  var points = getRewindData();\\n  points.forEach(function(p) {\\n    var div = document.createElement('div');\\n    div.className = 'rewind-point';\\n    div.setAttribute('data-id', p.id);\\n    div.addEventListener('click', function() { selectRewind(p.id, div); });\\n\\n    var dot = document.createElement('div');\\n    dot.className = 'rp-dot';\\n    div.appendChild(dot);\\n\\n    var info = document.createElement('div');\\n    info.className = 'rp-info';\\n    var title = document.createElement('div');\\n    title.className = 'rp-title';\\n    title.textContent = 'Step ' + p.step + ': ' + p.prompt;\\n    info.appendChild(title);\\n    var meta = document.createElement('div');\\n    meta.className = 'rp-meta';\\n    meta.textContent = p.hash + ' \\\\u00B7 ' + p.files.length + ' file' + (p.files.length !== 1 ? 's' : '');\\n    info.appendChild(meta);\\n    div.appendChild(info);\\n\\n    el.appendChild(div);\\n  });\\n}\\n\\nfunction selectRewind(id, el) {\\n  document.querySelectorAll('.rewind-point').forEach(function(p) { p.classList.remove('selected'); });\\n  el.classList.add('selected');\\n  document.getElementById('rewind-preview-card').style.opacity = '1';\\n  var points = getRewindData();\\n  var point = null;\\n  for (var i = 0; i < points.length; i++) {\\n    if (points[i].id === id) { point = points[i]; break; }\\n  }\\n  if (!point) return;\\n\\n  var preview = document.getElementById('rewind-preview');\\n  preview.textContent = '';\\n  var wrap = document.createElement('div');\\n  wrap.className = 'fade-in';\\n\\n  var h = document.createElement('h3');\\n  h.style.marginBottom = '0.5rem';\\n  h.textContent = 'Restoring to Step ' + point.step;\\n  wrap.appendChild(h);\\n\\n  var desc = document.createElement('p');\\n  desc.className = 'desc';\\n  desc.style.marginBottom = '0.75rem';\\n  desc.textContent = 'Commit: ' + point.hash;\\n  wrap.appendChild(desc);\\n\\n  // Files to Restore\\n  var rh = document.createElement('h3');\\n  rh.style.color = 'var(--green)';\\n  rh.style.marginBottom = '0.4rem';\\n  rh.textContent = 'Files to Restore';\\n  wrap.appendChild(rh);\\n  point.files.forEach(function(f) {\\n    wrap.appendChild(makeFileChange('restore', f));\\n  });\\n\\n  // Files to Delete (if not latest)\\n  if (point.step < points.length) {\\n    var dh = document.createElement('h3');\\n    dh.style.color = 'var(--red)';\\n    dh.style.marginTop = '0.75rem';\\n    dh.style.marginBottom = '0.4rem';\\n    dh.textContent = 'Files to Delete';\\n    wrap.appendChild(dh);\\n    wrap.appendChild(makeFileChange('delete', 'src/new_feature.go'));\\n  }\\n\\n  // Tracked Changes\\n  var th = document.createElement('h3');\\n  th.style.color = 'var(--orange)';\\n  th.style.marginTop = '0.75rem';\\n  th.style.marginBottom = '0.4rem';\\n  th.textContent = 'Tracked Changes to Revert';\\n  wrap.append