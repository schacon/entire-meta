  126→\\tModifiedFiles []string\\n   127→\\n   128→\\t// NewFiles is the list of new files created during the session\\n   129→\\t// (pre-computed by CLI from pre-prompt state comparison)\\n   130→\\tNewFiles []string\\n   131→\\n   132→\\t// DeletedFiles is the list of files deleted during the session\\n   133→\\t// (tracked files that no longer exist)\\n   134→\\tDeletedFiles []string\\n   135→\\n   136→\\t// MetadataDir is the path to the session metadata directory\\n   137→\\tMetadataDir string\\n   138→\\n   139→\\t// MetadataDirAbs is the absolute path to the session metadata directory\\n   140→\\tMetadataDirAbs string\\n   141→\\n   142→\\t// CommitMessage is the generated commit message\\n   143→\\tCommitMessage string\\n   144→\\n   145→\\t// TranscriptPath is the path to the transcript file\\n   146→\\tTranscriptPath string\\n   147→\\n   148→\\t// AuthorName is the name to use for commits\\n   149→\\tAuthorName string\\n   150→\\n   151→\\t// AuthorEmail is the email to use for commits\\n   152→\\tAuthorEmail string\\n   153→\\n   154→\\t// AgentType is the human-readable agent name (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   155→\\tAgentType types.AgentType\\n   156→\\n   157→\\t// Transcript position at step/turn start - tracks what was added during this step\\n   158→\\tStepTranscriptIdentifier string // Last identifier when step started (UUID for Claude, message ID for Gemini)\\n   159→\\tStepTranscriptStart      int    // Transcript line count when this step/turn started\\n   160→\\n   161→\\t// TokenUsage contains the token usage for this checkpoint\\n   162→\\tTokenUsage *agent.TokenUsage\\n   163→}\\n   164→\\n   165→// TaskStepContext contains all information needed for saving a task step checkpoint.\\n   166→// This is called by the PostToolUse[Task] hook when a subagent completes.\\n   167→// The strategy is responsible for creating metadata structures and storing them\\n   168→// according to its storage approach.\\n   169→type TaskStepContext struct {\\n   170→\\t// SessionID is the Claude Code session identifier\\n   171→\\tSessionID string\\n   172→\\n   173→\\t// ToolUseID is the unique identifier for this Task tool invocation\\n   174→\\tToolUseID string\\n   175→\\n   176→\\t// AgentID is the subagent identifier (from tool_response.agentId)\\n   177→\\tAgentID string\\n   178→\\n   179→\\t// ModifiedFiles is the list of files modified by the subagent\\n   180→\\t// (extracted from the subagent's transcript)\\n   181→\\tModifiedFiles []string\\n   182→\\n   183→\\t// NewFiles is the list of new files created by the subagent\\n   184→\\t// (computed from pre-task state comparison)\\n   185→\\tNewFiles []string\\n   186→\\n   187→\\t// DeletedFiles is the list of files deleted by the subagent\\n   188→\\tDeletedFiles []string\\n   189→\\n   190→\\t// TranscriptPath is the path to the main session transcript\\n   191→\\tTranscriptPath string\\n   192→\\n   193→\\t// SubagentTranscriptPath is the path to the subagent's transcript (if available)\\n   194→\\tSubagentTranscriptPath string\\n   195→\\n   196→\\t// CheckpointUUID is the UUID for transcript truncation when rewinding\\n   197→\\tCheckpointUUID string\\n   198→\\n   199→\\t// AuthorName is the name to use for commits\\n   200→\\tAuthorName string\\n   201→\\n   202→\\t// AuthorEmail is the email to use for commits\\n   203→\\tAuthorEmail string\\n   204→\\n   205→\\t// IsIncremental indicates this is an incremental checkpoint during task execution,\\n   206→\\t// not a final task completion checkpoint. When true:\\n   207→\\t// - Writes to checkpoints/NNN-{tool-use-id}.json instead of checkpoint.json\\n   208→\\t// - Skips transcript handling\\n   209→\\t// - Uses incremental commit message\\n   210→\\tIsIncremental bool\\n   211→\\n   212→\\t// IncrementalSequence is the checkpoint sequence number (1, 2, 3, ...)\\n   213→\\t// Only used when IsIncremental is true\\n   214→\\tIncrementalSequence int\\n   215→\\n   216→\\t// IncrementalType