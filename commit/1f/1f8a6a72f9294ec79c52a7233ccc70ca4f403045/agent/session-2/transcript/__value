sitory worktree path for git CLI commands\\n   289→\\tattributionBaseCommit string       // Base commit hash for non-agent file detection (empty = fall back to go-git tree walk)\\n   290→\\theadCommitHash        string       // HEAD commit hash for non-agent file detection (empty = fall back to go-git tree walk)\\n   291→}\\n   292→\\n   293→func calculateSessionAttributions(ctx context.Context, repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState, opts ...attributionOpts) *cpkg.InitialAttribution {\\n   294→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   295→\\t// This uses user edits captured at each prompt start (before agent works),\\n   296→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   297→\\t//\\n   298→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   299→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   300→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   301→\\tlogCtx := logging.WithComponent(ctx, \\\"attribution\\\")\\n   302→\\n   303→\\tvar o attributionOpts\\n   304→\\tif len(opts) > 0 {\\n   305→\\t\\to = opts[0]\\n   306→\\t}\\n   307→\\n   308→\\theadTree := o.headTree\\n   309→\\tif headTree == nil {\\n   310→\\t\\theadRef, headErr := repo.Head()\\n   311→\\t\\tif headErr != nil {\\n   312→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   313→\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   314→\\t\\t\\treturn nil\\n   315→\\t\\t}\\n   316→\\n   317→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   318→\\t\\tif commitErr != nil {\\n   319→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   320→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   321→\\t\\t\\treturn nil\\n   322→\\t\\t}\\n   323→\\n   324→\\t\\tvar treeErr error\\n   325→\\t\\theadTree, treeErr = headCommit.Tree()\\n   326→\\t\\tif treeErr != nil {\\n   327→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   328→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   329→\\t\\t\\treturn nil\\n   330→\\t\\t}\\n   331→\\t}\\n   332→\\n   333→\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n   334→\\tshadowTree := o.shadowTree\\n   335→\\tif shadowTree == nil {\\n   336→\\t\\tif shadowRef != nil {\\n   337→\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   338→\\t\\t\\tif shadowErr != nil {\\n   339→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   340→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   341→\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   342→\\t\\t\\t\\treturn nil\\n   343→\\t\\t\\t}\\n   344→\\t\\t\\tvar shadowTreeErr error\\n   345→\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   346→\\t\\t\\tif shadowTreeErr != nil {\\n   347→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   348→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   349→\\t\\t\\t\\treturn nil\\n   350→\\t\\t\\t}\\n   351→\\t\\t} else {\\n   352→\\t\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   353→\\t\\t\\t// because the agent's work is the commit itself.\\n   354→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   355→\\t\\t\\tshadowTree = headTree\\n   356→\\t\\t}\\n   357→\\t}\\n   358→\\n   359→\\t// Get base tree (state before session started)\\n   360→\\tvar baseTree *object.Tree\\n   361→\\tattrBase := state.AttributionBaseCommit\\n   362→\\tif attrBase == \\\"\\\" {\\n   363→\\t\\tattrBase = state.BaseCommit // backward compat\\n   364→\\t}\\n   365→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   366→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   367→\\t\\t\\tbaseTree = tree\\n   368→\\t\\t} else {\\n   369→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   370→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   371→\\t\\t}\\n   372→\\t} else {\\n   373→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   374→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   375→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   376→\\t}\\n   377→\\n   378→\\t// Log accumulated prompt attributions for debugging\\n   379→\\tvar totalUserAdded, totalUserRemoved int\\n   380→\\tfor i, pa := range state.PromptAttributions {\\n   381→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   382→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   383→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   384→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   385→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   386→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   387→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   388→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   389→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   390→\\t}\\n   391→\\n   392→\\tattribution := CalculateAttributionWithAccumulated(\\n   393→\\t\\tctx,\\n   394→\\t\\tbaseTree,\\n   395→\\t\\tshadowTree,\\n   396→\\t\\theadTree,\\n   397→\\t\\tsessionData.FilesTouched,\\n   398→\\t\\tstate.PromptAttributions,\\n   399→\\t\\to.repoDir,\\n   400→\\t\\to.attributionBaseCommit,\\n   401→\\t\\to.headCommitHash,\\n   402→\\t)\\n   403→\\n   404→\\tif attribution != nil {\\n   405→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   406→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   407→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   408→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   409→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   410→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   411→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   412→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   413→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   414→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   415→\\t}\\n   416→\\n   417→\\treturn attribution\\n   418→}\\n   419→\\n   420→// extractSessionData extracts session data from the shadow branch.\\n   421→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   422→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   423→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   424→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   425→// continued growing — the shadow branch copy would be stale.\\n   426→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   427→func (s *ManualCommitStrategy) extractSessionData(ctx context.Context, repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType types.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n   428→\\tag, _ := agent.GetByAgentType(agentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   429→\\tcommit, err := repo.CommitObject(shadowRef)\\n   430→\\tif err != nil {\\n   431→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   432→\\t}\\n   433→\\n   434→\\ttree, err := commit.Tree()\\n   435→\\tif err != nil {\\n   436→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   437→\\t}\\n   438→\\n   439→\\tdata := &ExtractedSessionData{}\\n   440→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   441→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   442→\\n   443→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   444→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   445→\\t// (SaveStep is only called when there are file modifications).\\n   446→\\tvar fullTranscript string\\n   447→\\tif liveTranscriptPath != \\\"\\\" {\\n   448→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   449→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   450→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   451→\\t\\tif isActive {\\n   452→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, liveTranscriptPath)\\n   453→\\t\\t}\\n   454→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   455→\\t\\t\\tfullTranscript = string(liveData)\\n   456→\\t\\t}\\n   457→\\t}\\n   458→\\tif fullTranscript == \\\"\\\" {\\n   459→\\t\\t// Fall back to shadow branch copy\\n   460→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   461→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   462→\\t\\t\\t\\tfullTranscript = content\\n   463→\\t\\t\\t}\\n   464→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   465→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   466→\\t\\t\\t\\tfullTranscript = co