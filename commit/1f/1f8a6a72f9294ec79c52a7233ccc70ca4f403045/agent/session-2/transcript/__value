en at turn start and updated at each SaveStep, providing prompt data\\n   723→// even for mid-turn commits where the shadow branch may not have been updated.\\n   724→func readPromptsFromFilesystem(ctx context.Context, sessionID string) []string {\\n   725→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   726→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   727→\\tif err != nil {\\n   728→\\t\\treturn nil\\n   729→\\t}\\n   730→\\tdata, err := os.ReadFile(filepath.Join(sessionDirAbs, paths.PromptFileName)) //nolint:gosec // path from session ID\\n   731→\\tif err != nil || len(data) == 0 {\\n   732→\\t\\treturn nil\\n   733→\\t}\\n   734→\\treturn splitPromptContent(string(data))\\n   735→}\\n   736→\\n   737→// clearFilesystemPrompt removes the filesystem prompt.txt for a session.\\n   738→// Called after condensation so subsequent checkpoints start fresh.\\n   739→func clearFilesystemPrompt(ctx context.Context, sessionID string) {\\n   740→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   741→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   742→\\tif err != nil {\\n   743→\\t\\treturn\\n   744→\\t}\\n   745→\\tpromptPath := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   746→\\t_ = os.Remove(promptPath)\\n   747→}\\n   748→\\n   749→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   750→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   751→func (s *ManualCommitStrategy) CondenseSessionByID(ctx context.Context, sessionID string) error {\\n   752→\\tlogCtx := logging.WithComponent(ctx, \\\"condense-by-id\\\")\\n   753→\\n   754→\\t// Load session state\\n   755→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   756→\\tif err != nil {\\n   757→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   758→\\t}\\n   759→\\tif state == nil {\\n   760→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   761→\\t}\\n   762→\\n   763→\\t// Open repository\\n   764→\\trepo, err := OpenRepository(ctx)\\n   765→\\tif err != nil {\\n   766→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   767→\\t}\\n   768→\\n   769→\\t// Generate a checkpoint ID\\n   770→\\tcheckpointID, err := id.Generate()\\n   771→\\tif err != nil {\\n   772→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   773→\\t}\\n   774→\\n   775→\\t// Check if shadow branch exists (required for condensation)\\n   776→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   777→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   778→\\t_, refErr := repo.Reference(refName, true)\\n   779→\\thasShadowBranch := refErr == nil\\n   780→\\n   781→\\tif !hasShadowBranch {\\n   782→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   783→\\t\\t// Just clean up the state file.\\n   784→\\t\\tlogging.Info(logCtx, \\\"no shadow branch for session, clearing state only\\\",\\n   785→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   786→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   787→\\t\\t)\\n   788→\\t\\tif err := s.clearSessionState(ctx, sessionID); err != nil {\\n   789→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   790→\\t\\t}\\n   791→\\t\\treturn nil\\n   792→\\t}\\n   793→\\n   794→\\t// Condense the session\\n   795→\\tresult, err := s.CondenseSession(ctx, repo, checkpointID, state, nil)\\n   796→\\tif err != nil {\\n   797→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   798→\\t}\\n   799→\\n   800→\\tlogging.Info(logCtx, \\\"session condensed by ID\\\",\\n   801→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   802→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   803→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   804→\\t)\\n   805→\\n   806→\\t// Up