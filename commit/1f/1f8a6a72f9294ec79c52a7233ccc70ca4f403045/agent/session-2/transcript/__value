o nil is safe\\n   504→\\n   505→\\t// Read the live transcript\\n   506→\\tif state.TranscriptPath == \\\"\\\" {\\n   507→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   508→\\t}\\n   509→\\n   510→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   511→\\tif err != nil {\\n   512→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   513→\\t}\\n   514→\\n   515→\\tif len(liveData) == 0 {\\n   516→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   517→\\t}\\n   518→\\n   519→\\tfullTranscript := string(liveData)\\n   520→\\tdata.Transcript = liveData\\n   521→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   522→\\tdata.Prompts = readPromptsFromFilesystem(ctx, state.SessionID)\\n   523→\\n   524→\\t// Resolve files touched: prefers hook-populated state, falls back to transcript extraction\\n   525→\\tdata.FilesTouched = s.resolveFilesTouched(ctx, state)\\n   526→\\n   527→\\t// Calculate token usage from the extracted transcript portion\\n   528→\\tif len(data.Transcript) > 0 {\\n   529→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ctx, ag, data.Transcript, state.CheckpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   530→\\t}\\n   531→\\n   532→\\treturn data, nil\\n   533→}\\n   534→\\n   535→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   536→// For Claude Code and JSONL-based agents, this counts lines.\\n   537→// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n   538→// Returns 0 if the content is empty or malformed.\\n   539→func countTranscriptItems(agentType types.AgentType, content string) int {\\n   540→\\tif content == \\\"\\\" {\\n   541→\\t\\treturn 0\\n   542→\\t}\\n   543→\\n   544→\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n   545→\\tif agentType == agent.AgentTypeOpenCode {\\n   546→\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n   547→\\t\\tif err == nil && session != nil {\\n   548→\\t\\t\\treturn len(session.Messages)\\n   549→\\t\\t}\\n   550→\\t\\treturn 0\\n   551→\\t}\\n   552→\\n   553→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   554→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   555→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   556→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   557→\\t\\t\\treturn len(transcript.Messages)\\n   558→\\t\\t}\\n   559→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   560→\\t\\tif agentType == agent.AgentTypeGemini {\\n   561→\\t\\t\\treturn 0\\n   562→\\t\\t}\\n   563→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   564→\\t}\\n   565→\\n   566→\\t// Claude Code and other JSONL-based agents\\n   567→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   568→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   569→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   570→\\t\\tallLines = allLines[:len(allLines)-1]\\n   571→\\t}\\n   572→\\treturn len(allLines)\\n   573→}\\n   574→\\n   575→// extractUserPrompts extracts all user prompts from transcript content.\\n   576→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   577→func extractUserPrompts(agentType types.AgentType, content string) []string {\\n   578→\\tif content == \\\"\\\" {\\n   579→\\t\\treturn nil\\n   580→\\t}\\n   581→\\n   582→\\t// Droid has its own envelope format — use its parser to normalize first\\n   583→\\tif agentType == agent.AgentTypeFactoryAIDroid {\\n   584→\\t\\tlines, _, err := factoryaidroid.ParseDroidTranscriptFromBytes([]byte(content), 0)\\n   585→\\t\\tif err != nil {\\n   586→\\t\\t\\treturn nil\\n   587→\\t\\t}\\n   588→\\t\\tvar prompts []string\\n   589→\\t\\tfor _, line := range lines {\\n   590→\\t\\t\\tif line.Type != transcript.TypeUser {\\n   591→\\t\\t\\t\\tcontinue\\n   592→\\t\\t\\t}\\n   593→\\t\\t\\tif text := transcript.ExtractUserContent(line.Message); text != \\\"\\\" {\\n   594→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(text); stripped != \\\"\\\" {\\n   595→\\t\\t\\t\\t\\tprompts = append(prompts, stripped)\\n   596→\\t\\t\\t\\t}\\n   597→\\t\\t\\t}\\n   598→\\t\\t}\\n   599→\\t\\treturn prompts\\n   600→\\t}\\n   601→\\n   602→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   603→\\tif agentType == agent.AgentTypeOpenCode {\\n   604→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   605→\\t\\tif err == nil && len(prompts) > 0 {\\n   606→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   607→\\t\\t\\tfor _, prompt := range prompts {\\n   608→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   609→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   610→\\t\\t\\t\\t}\\n   611→\\t\\t\\t}\\n   612→\\t\\t\\treturn cleaned\\n   613→\\t\\t}\\n   614→\\t\\treturn nil\\n   615→\\t}\\n   616→\\n   617→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   618→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   619→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   620→\\t\\tif err == nil && len(prompts) > 0 {\\n   621→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   622→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   623→\\t\\t\\tfor _, prompt := range prompts {\\n   624→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   625→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   626→\\t\\t\\t\\t}\\n   627→\\t\\t\\t}\\n   628→\\t\\t\\treturn cleaned\\n   629→\\t\\t}\\n   630→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   631→\\t\\tif agentType == agent.AgentTypeGemini {\\n   632→\\t\\t\\treturn nil\\n   633→\\t\\t}\\n   634→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   635→\\t}\\n   636→\\n   637→\\t// Claude Code and other JSONL-based agents\\n   638→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   639→}\\n   640→\\n   641→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   642→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   643→func extractUserPromptsFromLines(lines []string) []string {\\n   644→\\tvar prompts []string\\n   645→\\tfor _, line := range lines {\\n   646→\\t\\tline = strings.TrimSpace(line)\\n   647→\\t\\tif line == \\\"\\\" {\\n   648→\\t\\t\\tcontinue\\n   649→\\t\\t}\\n   650→\\n   651→\\t\\tvar entry map[string]interface{}\\n   652→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   653→\\t\\t\\tcontinue\\n   654→\\t\\t}\\n   655→\\n   656→\\t\\t// Check for user message:\\n   657→\\t\\t// - Claude Code uses \\\"type\\\": \\\"human\\\" or \\\"type\\\": \\\"user\\\"\\n   658→\\t\\t// - Cursor uses \\\"role\\\": \\\"user\\\"\\n   659→\\t\\tmsgType, _ := entry[\\\"type\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   660→\\t\\tmsgRole, _ := entry[\\\"role\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   661→\\t\\tisUser := msgType == \\\"human\\\" || msgType == \\\"user\\\" || msgRole == \\\"user\\\"\\n   662→\\t\\tif !isUser {\\n   663→\\t\\t\\tcontinue\\n   664→\\t\\t}\\n   665→\\n   666→\\t\\t// Extract message content\\n   667→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   668→\\t\\tif !ok {\\n   669→\\t\\t\\tcontinue\\n   670→\\t\\t}\\n   671→\\n   672→\\t\\t// Handle string content\\n   673→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != 