ass=\\\"touchpoint-list\\\" id=\\\"tp-list\\\"></div>\\n      <div class=\\\"add-row\\\" style=\\\"margin-top:6px;\\\">\\n        <input type=\\\"text\\\" id=\\\"new-tp-name\\\" placeholder=\\\"Channel name...\\\" onkeydown=\\\"if(event.key==='Enter')addTouchpoint()\\\">\\n        <button class=\\\"small\\\" onclick=\\\"addTouchpoint()\\\">+ Add</button>\\n      </div>\\n    </section>\\n\\n    <section id=\\\"custom-section\\\" class=\\\"hidden\\\">\\n      <h2>Custom Weights</h2>\\n      <div id=\\\"custom-weights\\\"></div>\\n      <label style=\\\"margin-top:4px;\\\">Weights are auto-normalized to 100%</label>\\n    </section>\\n\\n    <section>\\n      <h2>View</h2>\\n      <div style=\\\"display:flex; gap:4px;\\\">\\n        <button id=\\\"btn-journey\\\" class=\\\"active\\\" onclick=\\\"setView('journey')\\\">Journey</button>\\n        <button id=\\\"btn-compare\\\" onclick=\\\"setView('compare')\\\">Compare All</button>\\n      </div>\\n    </section>\\n  </div>\\n\\n  <div class=\\\"canvas-area\\\">\\n    <div class=\\\"viz\\\" id=\\\"viz\\\">\\n      <div id=\\\"view-journey\\\">\\n        <div class=\\\"journey\\\">\\n          <div class=\\\"timeline-line\\\"></div>\\n          <div id=\\\"tp-nodes\\\" style=\\\"display:flex; justify-content:space-between; position:relative; z-index:1; padding:0 10px;\\\"></div>\\n        </div>\\n        <div style=\\\"max-width:900px; margin:30px auto 0;\\\">\\n          <h2 style=\\\"text-align:center;\\\">Credit Distribution</h2>\\n          <div id=\\\"bars\\\" style=\\\"display:flex; align-items:flex-end; justify-content:center; gap:8px; height:160px; padding:0 20px; margin-top:10px;\\\"></div>\\n        </div>\\n        <div class=\\\"explanation-box\\\" id=\\\"explanation\\\"></div>\\n      </div>\\n\\n      <div id=\\\"view-compare\\\" class=\\\"hidden\\\">\\n        <div class=\\\"comparison\\\">\\n          <h2 style=\\\"margin-bottom:10px;\\\">Model Comparison</h2>\\n          <table id=\\\"compare-table\\\"></table>\\n        </div>\\n      </div>\\n    </div>\\n\\n    <div class=\\\"prompt-area\\\">\\n      <h2>Prompt Output</h2>\\n      <button class=\\\"copy-btn\\\" onclick=\\\"copyPrompt()\\\">Copy</button>\\n      <div class=\\\"prompt-text\\\" id=\\\"prompt-output\\\"></div>\\n    </div>\\n  </div>\\n</div>\\n\\n<script>\\nconst COLORS = ['#4fc3f7','#66bb6a','#ffa726','#f06292','#ab47bc','#ffee58','#ef5350','#26a69a','#42a5f5','#8d6e63','#78909c','#dce775'];\\n\\nconst PRESETS = {\\n  saas: [\\n    { name: 'Google Ad', days: 0 },\\n    { name: 'Blog Post', days: 3 },\\n    { name: 'Email Nurture', days: 7 },\\n    { name: 'Webinar', days: 14 },\\n    { name: 'Free Trial', days: 18 },\\n    { name: 'Sales Demo', days: 25 },\\n    { name: 'Pricing Page', days: 28 },\\n  ],\\n  ecommerce: [\\n    { name: 'Instagram Ad', days: 0 },\\n    { name: 'Product Review', days: 1 },\\n    { name: 'Retargeting Ad', days: 3 },\\n    { name: 'Email Coupon', days: 5 },\\n    { name: 'Direct Visit', days: 6 },\\n  ],\\n  b2b: [\\n    { name: 'LinkedIn Ad', days: 0 },\\n    { name: 'Whitepaper', days: 10 },\\n    { name: 'Conference', days: 30 },\\n    { name: 'Case Study', days: 45 },\\n    { name: 'Sales Call', days: 60 },\\n    { name: 'Proposal', days: 75 },\\n    { name: 'Negotiation', days: 85 },\\n    { name: 'Contract', days: 90 },\\n  ],\\n  simple: [\\n    { name: 'Awareness', days: 0 },\\n    { name: 'Consideration', days: 5 },\\n    { name: 'Conversion', days: 10 },\\n  ],\\n  content: [\\n    { name: 'SEO Blog', days: 0 },\\n    { name: 'YouTube Video', days: 4 },\\n    { name: 'Podcast', days: 8 },\\n    { name: 'Newsletter', days: 12 },\\n    { name: 'Social Share', days: 14 },\\n    { name: 'Landing Page', days: 15 },\\n  ],\\n};\\n\\nconst MODEL_INFO = {\\n  'first-touch': {\\n    short: 'First Touch',\\n    desc: 'First Touch gives 100% of the credit to the first interaction. It answers: \\\"What channel introduced this customer?\\\" Great for measuring awareness campaigns, but ignores everything that nurtured the lead afterward.',\\n    bias: 'Overvalues top-of-funnel channels. Undervalues nurture and closing efforts.',\\n  },\\n  'last-touch': {\\n    short: 'Last Touch',\\n    desc: 'Last Touch gives 100% of the credit to the last interaction before conversion. It answers: \\\"What closed the deal?\\\" Simple and widely used (Google Analytics default), but ignores the entire journey.',\\n    bias: 'Overvalues bottom-of-funnel. Undervalues awareness and consideration.',\\n  },\\n  'linear': {\\n    short: 'Linear',\\n    desc: 'Linear splits credit equally across all touchpoints. It answers: \\\"Every interaction mattered the same.\\\" Fair and simple, but unrealistic \\\\u2014 not all touches have equal impact.',\\n    bias: 'Treats a passing glance the same as an hour-long demo.',\\n  },\\n  'time-decay': {\\n    short: 'Time Decay',\\n    desc: 'Time Decay gives more credit to touchpoints closer to the conversion. Uses exponential decay with a configurable half-life. Good for short sales cycles where recent interactions drive decisions.',\\n    bias: 'Undervalues early awareness that planted the seed.',\\n  },\\n  'u-shaped': {\\n    short: 'U-Shaped (40/20/40)',\\n    desc: 'U-Shaped (Position-Based) gives 40% to the first touch, 40% to the last touch, and splits the remaining 20% among middle interactions. Recognizes that discovery and conversion are pivotal moments.',\\n    bias: 'Middle-funnel nurturing (often the hardest work) gets minimal credit.',\\n  },\\n  'w-shaped': {\\n    short: 'W-Shaped (30/30/30/10)',\\n    desc: 'W-Shaped gives 30% to the first touch, 30% to the lead-creation midpoint, 30% to the last touch, and splits the remaining 10% among everything else. Best for B2B funnels with a distinct qualification step.',\\n    bias: 'Assumes a clear midpoint exists. Less useful for short or uniform journeys.',\\n  },\\n  'custom': {\\n    short: 'Custom',\\n    desc: 'Custom Weights let you manually assign relative importance to each touchpoint. Weights are normalized to 100%. Use this to model your own attribution theory or domain expertise.',\\n    bias: 'Only as good as your assumptions.',\\n  },\\n};\\n\\nlet state = {\\n  model: 'linear',\\n  touchpoints: [],\\n  customWeights: [],\\n  decayHalfLife: 7,\\n  view: 'journey',\\n};\\n\\n// --- Attribution math ---\\nfunction calcCredits(model, tps, halfLife, customW) {\\n  const n = tps.length;\\n  if (n === 0) return [];\\n  if (n === 1) return [1];\\n\\n  switch (model) {\\n    case 'first-touch': {\\n      const c = Array(n).fill(0);\\n      c[0] = 1;\\n      return c;\\n    }\\n    case 'last-touch': {\\n      const c = Array(n).fill(0);\\n      c[n - 1] = 1;\\n      return c;\\n    }\\n    case 'linear': {\\n      return Array(n).fill(1 / n);\\n    }\\n    case 'time-decay': {\\n      const maxDay = tps[n - 1].days;\\n      const rawDecay = tps.map(function(tp) {\\n        const daysBeforeConversion = maxDay - tp.days;\\n        return Math.pow(2, -daysBeforeConversion / halfLife);\\n      });\\n      const sum = rawDecay.reduce(function(a, b) { return a + b; }, 0);\\n      return rawDecay.map(function(v) { return v / sum; });\\n    }\\n    case 'u-shaped': {\\n      const c = Array(n).fill(0);\\n      if (n === 2) return [0.5, 0.5];\\n      c[0] = 0.4;\\n      c[n - 1] = 0.4;\\n      const mid = 0.2 / (n - 2);\\n      for (let i = 1; i < n - 1; i++) c[i] = mid;\\n      return c;\\n    }\\n    case 'w-shaped': {\\n      const c = Array(n).fill(0);\\n      if (n === 2) return [0.5, 0.5];\\n      if (n === 3) return [0.333, 0.334, 0.333];\\n      const midIdx = Math.floor(n / 2);\\n      c[0] = 0.3;\\n      c[midIdx] = 0.3;\\n      c[n - 1] = 0.3;\\n      let others = n - 3;\\n      if (others <= 0) {\\n        const s = c.reduce(function(a, b) { return a + b; }, 0);\\n        return c.map(function(v) { return v / s; });\\n      }\\n      const each = 0.1 / others;\\n      for (let i = 0; i < n; i++) {\\n        if (i !== 0 && i !== midIdx && i !== n - 1) c[i] = each;\\n      }\\n      return c;\\n    }\\n    case 'custom': {\\n      if (!customW || customW.length !== n) return Array(n).fill(1 / n);\\n      const sum = customW.reduce(function(a, b) { return a + b; }, 0);\\n      if (sum === 0) return Array(n).fill(1 / n);\\n      return customW.map(function(w) { return w / sum; });\\n    }\\n    default: return Array(n).fill(1 / n);\\n  }\\n}\\n\\nfunction calcAllModels(tps, halfLife, customW) {\\n  var models = ['first-touch', 'last-touch', 'linear', 'time-decay', 'u-shaped', 'w-shaped'];\\n  var result = {};\\n  for (var i = 0; i < models.length; i++) {\\n    result[models[i]] = calcCredits(models[i], tps, halfLife, customW);\\n  }\\n  return result;\\n}\\n\\n// --- Safe DOM helpers ---\\nfunction clearEl(el) { while (el.firstChild) el.removeChild(el.firstChild); }\\n\\nfunction makeEl(tag, attrs, children) {\\n  var el = document.createElement(tag);\\n  if (attrs) {\\n    Object.keys(attrs).forEach(function(k) {\\n      if (k === 'style' && typeof attrs[k] === 'object') {\\n        Object.assign(el.style, attrs[k]);\\n      } else if (k.startsWith('on')) {\\n        el.addEventListener(k.slice(2), attrs[k]);\\n      } else if (k === 'className') {\\n        el.className = attrs[k];\\n      } else {\\n        el.setAttribute(k, attrs[k]);\\n      }\\n    });\\n  }\\n  if (children) {\\n    if (typeof children === 'string') {\\n      el.textContent = children;\\n    } else if (Array.isArray(children)) {\\n      children.forEach(function(c) { if (c) el.appendChild(c); });\\n    }\\n  }\\n  return el;\\n}\\n\\n// --- Rendering ---\\nfunction renderTouchpointList() {\\n  var list = document.getElementById('tp-list');\\n  clearEl(list);\\n  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n  state.touchpoints.forEach(function(tp, i) {\\n    var dot = makeEl('span', { className: 'dot', style: { background: COLORS[i % COLORS.length], width: '10px', height: '10px', borderRadius: '50%', flexShrink: '0', display: 'inline-block' } });\\n    var name = makeEl('span', { style: { flex: '1', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }, title: tp.name }, tp.name);\\n    var credit = makeEl('span', { style: { fontFamily: 'monospace', color: 'var(--accent)', minWidth: '40px', textAlign: 'right' } }, (credits[i] * 100).toFixed(1) + '%');\\n    var removeBtn = makeEl('button', { className: 'small danger', title: 'Remove', onclick: function() { removeTouchpoint(i); } }, 'x');\\n\\n    var item = makeEl('div', {\\n      style: { display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 6px', background: 'var(--bg)', borderRadius: '4px', fontSize: '0.8rem' }\\n    }, [dot, name, credit, removeBtn]);\\n    list.appendChild(item);\\n  });\\n}\\n\\nfunction renderJourney() {\\n  var container = document.getElementById('tp-nodes');\\n  clearEl(container);\\n  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n\\n  state.touchpoints.forEach(function(tp, i) {\\n    var pct = credits[i] * 100;\\n    var size = 28 + pct * 0.4;\\n    var borderW = pct > 30 ? 4 : pct > 10 ? 3 : 2;\\n    var alphaVal = 0.2 + pct / 200;\\n\\n    var circle = makeEl('div', {\\n      style: {\\n        width: size + 'px', height: size + 'px', borderRadius: '50%',\\n        display: 'flex', alignItems: 'center', justifyContent: 'center',\\n        fontSize: '0.7rem', fontWeight: '700', color: '#000',\\n        background: COLORS[i % COLORS.length],\\n        border: borderW + 'px solid rgba(255,255,255,' + alphaVal + ')',\\n        boxShadow: '0 0 ' + (pct / 3) + 'px ' + COLORS[i % COLORS.length] + '40',\\n        transition: 'all 0.3s'\\n      }\\n    }, String(i + 1));\\n\\n    var label = makeEl('div', {\\n      style: { fontSize: '0.7rem', textAlign: 'center', color: 'var(--muted)', maxWidth: '80px', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' },\\n      title: tp.name\\n    }, tp.name);\\n\\n    var creditLabel = makeEl('div', {\\n      style: { fontSize: '0.85rem', fontWeight: '700', fontFamily: 'monospace', marginTop: '2px', color: COLORS[i % COLORS.length] }\\n    }, pct.toFixed(1) + '%');\\n\\n    var node = makeEl('div', {\\n      style: { display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', cursor: 'default', minWidth: '60px', maxWidth: '100px', transition: 'transform 0.2s' }\\n    }, [circle, label, creditLabel]);\\n\\n    node.addEventListener('mouseenter', function() { node.style.transform = 'translateY(-3px)'; });\\n    node.addEventListener('mouseleave', function() { node.style.transform = 'translateY(0)'; });\\n\\n    container.appendChild(node);\\n  });\\n}\\n\\nfunction renderBars() {\\n  var container = document.getElementById('bars');\\n  clearEl(container);\\n  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n  var maxCredit = Math.max.apply(null, credits.concat([0.01]));\\n\\n  credits.forEach(function(c, i) {\\n    var h = (c / maxCredit) * 130;\\n\\n    var valueLabel = makeEl('div', {\\n      style: { fontSize: '0.75rem', fontFamily: 'monospace', fontWeight: '700', color: COLORS[i % COLORS.length] }\\n    }, (c * 100).toFixed(1) + '%');\\n\\n    var bar = makeEl('div', {\\n      style: {\\n        width: '100%', minHeight: '2px', height: h + 'px',\\n        borderRadius: '4px 4px 0 0', transition: 'height 0.4s ease',\\n        background: 'linear-gradient(180deg, ' + COLORS[i % COLORS.length] + ', ' + COLORS[i % COLORS.length] + '80)'\\n      }\\n    });\\n\\n    var nameLabel = makeEl('div', {\\n      style: { fontSize: '0.65rem', color: 'var(--muted)', textAlign: 'center', maxWidth: '70px', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' },\\n      title: state.touchpoints[i].name\\n    }, state.touchpoints[i].name);\\n\\n    var col = makeEl('div', {\\n      style: { display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', flex: '1', maxWidth: '80px' }\\n    }, [valueLabel, bar, nameLabel]);\\n\\n    container.appendChild(col);\\n  });\\n}\\n\\nfunction renderExplanation() {\\n  var el = document.getElementById('explanation');\\n  clearEl(el);\\n  var info = MODEL_INFO[state.model];\\n\\n  var descEl = makeEl('span', { style: { color: 'var(--accent)', fontWeight: '700' } }, info.short + ': ');\\n  var descText = document.createTextNode(info.desc);\\n  var br = document.createElement('br');\\n  var br2 = document.createElement('br');\\n  var biasLabel = makeEl('span', { style: { color: 'var(--orange)' } }, 'Bias: ');\\n  var biasText = document.createTextNode(info.bias);\\n\\n  el.appendChild(descEl);\\n  el.appendChild(descText);\\n  el.appendChild(br);\\n  el.appendChild(br2);\\n  el.appendChild(biasLabel);\\n  el.appendChild(biasText);\\n}\\n\\nfunction renderCompare() {\\n  var table = document.getElementById('compare-table');\\n  clearEl(table);\\n  var all = calcAllModels(state.touchpoints, state.decayHalfLife, state.customWeights);\\n  var models = ['first-touch', 'last-touch', 'linear', 'time-decay', 'u-shaped', 'w-shaped'];\\n\\n  // Header\\n  var headerRow = makeEl('tr');\\n  headerRow.appendChild(makeEl('th', {}, 'Touchpoint'));\\n  models.forEach(function(m) {\\n    headerRow.appendChild(makeEl('th', {}, MODEL_INFO[m].short));\\n  });\\n  table.appendChild(headerRow);\\n\\n  // Data rows\\n  state.touchpoints.forEach(function(tp, i) {\\n    var row = makeEl('tr');\\n    var dot = makeEl('span', { style: { color: COLORS[i % COLORS.length] } }, '\\\\u25CF ');\\n    var nameCell = makeEl('td');\\n    nameCell.appendChild(dot);\\n    nameCell.appendChild(document.createTextNode(tp.name));\\n    row.appendChild(nameCell);\\n\\n    models.forEach(function(m) {\\n      var v = (all[m][i] * 100).toFixed(1) + '%';\\n      var isCurrent = m === state.model;\\n      var cell = makeEl('td', {\\n        style: isCurrent ? { color: 'var(--accent)', fontWeight: '700' } : {}\\n      }, v);\\n      row.appendChild(cell);\\n    });\\n    table.appendChild(row);\\n  });\\n\\n  // Winner row\\n  var winnerRow = makeEl('tr', { style: { borderTop: '2px solid var(--border)' } });\\n  winnerRow.appendChild(makeEl('td', { style: { fontFamily: 'system-ui', color: 'var(--muted)' } }, 'Top Channel'));\\n  models.forEach(function(m) {\\n    var credits = all[m];\\n    var maxIdx = credits.indexOf(Math.max.apply(null, credits));\\n    var isCurrent = m === state.model;\\n    var cell = makeEl('td', {\\n      style: { color: COLORS[maxIdx % COLORS.length], fontWeight: isCurrent ? '700' : 'normal' }\\n    }, state.touchpoints[maxIdx].name);\\n    winnerRow.appendChild(cell);\\n  });\\n  table.appendChild(winnerRow);\\n}\\n\\nfunction renderCustomWeights() {\\n  var section = document.getElementById('custom-section');\\n  var container = document.getElementById('custom-weights');\\n  if (state.model !== 'custom') {\\n    section.classList.add('hidden');\\n    return;\\n  }\\n  section.classList.remove('hidden');\\n  clearEl(container);\\n\\n  while (state.customWeights.length < state.touchpoints.length) state.customWeights.push(1);\\n  while (state.customWeights.length > state.touchpoints.length) state.customWeights.pop();\\n\\n  state.touchpoints.forEach(function(tp, i) {\\n    var dot = makeEl('span', { style: { background: COLORS[i % COLORS.length], width: '8px', height: '8px', borderRadius: '50%', display: 'inline-block' } });\\n    var label = makeEl('span', { style: { fontSize: '0.75rem', flex: '1', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' } }, tp.name);\\n    var input = makeEl('input', { type: 'number', min: '0', max: '100', value: String(state.customWeights[i]), style: { width: '55px' } });\\n    (function(idx) {\\n      input.addEventListener('change', function() {\\n        state.customWeights[idx] = parseFloat(this.value) || 0;\\n        updateAll();\\n      });\\n    })(i);\\n\\n    var row = makeEl('div', { style: { display: 'flex', alignItems: 'center', gap: '6px', marginBottom: '4px' } }, [dot, label, input]);\\n    container.appendChild(row);\\n  });\\n}\\n\\nfunction renderPrompt() {\\n  var el = document.getElementById('prompt-output');\\n  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n  var info = MODEL_INFO[state.model];\\n  var n = state.touchpoints.length;\\n\\n  if (n === 0) {\\n    el.textContent = 'Add touchpoints to generate a prompt.';\\n    return;\\n  }\\n\\n  var sorted = credits\\n    .map(function(c, i) { return { name: state.touchpoints[i].name, credit: c }; })\\n    .sort(function(a, b) { return b.credit - a.credit; });\\n\\n  var top = sorted[0];\\n  var bottom = sorted[sorted.length - 1];\\n  var journey = state.touchpoints.map(function(tp) { return tp.name; }).join(' -> ');\\n\\n  var parts = [];\\n  parts.push(\\\"I'm analyzing a \\\" + n + \\\"-step customer journey using the \\\" + info.short + \\\" attribution model.\\\");\\n  parts.push(\\\"\\\\nJourney: \\\" + journey);\\n  parts.push(\\\"\\\\nCredit distribution:\\\");\\n  sorted.forEach(function(s) {\\n    parts.push(\\\"  \\\" + s.name + \\\": \\\" + (s.credit * 100).toFixed(1) + \\\"%\\\");\\n  });\\n\\n  if (state.model === 'time-decay') {\\n    parts.push(\\\"\\\\nDecay half-life: \\\" + state.decayHalfLife + \\\" days\\\");\\n  }\\n\\n  parts.push(\\\"\\\\nThe \\\" + info.short + \\\" model \\\" + (top.credit > 0.5 ? 'heavily favors' : 'gives the most credit to') + ' \\\"' + top.name + '\\\" (' + (top.credit * 100).toFixed(1) + '%).');\\n\\n  if (n > 2) {\\n    parts.push('\\\"' + bottom.name + '\\\" gets the least credit at ' + (bottom.credit * 100).toFixed(1) + '%.');\\n  }\\n\\n  parts.push(\\\"\\\\nHelp me understand: Is \\\" + info.short + \\\" the right model for this journey? What would change if I used a different model? Which touchpoints might be over- or under-valued?\\\");\\n\\n  el.textContent = parts.join('\\\\n');\\n}\\n\\n// --- Actions ---\\nfunction updateAll() {\\n  renderTouchpointList();\\n  renderJourney();\\n  renderBars();\\n  renderExplanation();\\n  renderCompare();\\n  renderCustomWeights();\\n  renderPrompt();\\n}\\n\\nfunction handleModelChange() {\\n  state.model = document.getElementById('model-select').value;\\n  document.getElementById('decay-section').classList.toggle('hidden', state.model !== 'time-decay');\\n  updateAll();\\n}\\n\\nfunction updateDecayLabel() {\\n  state.decayHalfLife = parseInt(document.getElementById('decay-slider').value);\\n  document.getElementById('decay-label').textContent = state.decayHalfLife + 'd';\\n}\\n\\nfunction loadPreset(name) {\\n  state.touchpoints = PRESETS[name].map(function(tp) { return { name: tp.name, days: tp.days }; });\\n  state.customWeights = state.touchpoints.map(function() { return 1; });\\n  updateAll();\\n}\\n\\nfunction addTouchpoint() {\\n  var input = document.getElementById('new-tp-name');\\n  var name = input.value.trim();\\n  if (!name) return;\\n  var lastDay = state.touchpoints.length > 0 ? state.touchpoints[state.touchpoints.length - 1].days : 0;\\n  state.touchpoints.push({ name: name, days: lastDay + 5 });\\n  state.customWeights.push(1);\\n  input.value = '';\\n  updateAll();\\n}\\n\\nfunction removeTouchpoint(i) {\\n  state.touchpoints.splice(i, 1);\\n  state.customWeights.splice(i, 1);\\n  updateAll();\\n}\\n\\nfunction setView(view) {\\n  state.view = view;\\n  document.getElementById('view-journey').classList.toggle('hidden', view !== 'journey');\\n  document.getElementById('view-compare').classList.toggle('hidden', view !== 'compare');\\n  document.getElementById('btn-journey').classList.toggle('active', view === 'journey');\\n  document.getElementById('btn-compare').classList.toggle('active', view === 'compare');\\n  if (view === 'compare') renderCompare();\\n}\\n\\nfunction copyPrompt() {\\n  var text = document.getElementById('prompt-output').textContent;\\n  navigator.clipboard.writeText(text).then(function() {\\n    var btn = document.querySelector('.copy-btn');\\n    btn.textContent = 'Copied!';\\n    setTimeout(function() { btn.textContent = 'Copy'; }, 1500);\\n  });\\n}\\n\\n// --- Init ---\\nloadPreset('saas');\\n</script>\\n</body>\\n</html>\\n\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":\"tool_use\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":9832,\"cache_read_input_tokens\":33325,\"output_tokens\":9501,\"server_tool_use\":{\"web_search_requests\":0,\"web_fetch_requests\":0},\"service_tier\":\"standard\",\"cache_creation\":{\"ephemeral_1h_input_tokens\":9832,\"ephemeral_5m_input_tokens\":0},\"inference_geo\":\"\",\"iterations\":[],\"speed\":\"standard\"}},\"requestId\":\"req_011CYnEidHy3gBzbFTnQP8Jv\",\"type\":\"assistant\",\"uuid\":\"4b17e074-5656-4b89-99ae-495841713c99\",\"timestamp\":\"2026-03-06T17:42:46.949Z\"}\n{\"parentUuid\":\"4b17e074-5656-4b89-99ae-495841713c99\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/devenv/cli\",\"sessionId\":\"6ce8c9a4-5500-40f6-a6c7-8746f1f799f4\",\"version\":\"2.1.70\",\"gitBranch\":\"main\",\"slug\":\"cuddly-skipping-duckling\",\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"PreToolUse\",\"hookName\":\"PreToolUse:Write\",\"command\":\"python3 ${CLAUDE_PLUGIN_ROOT}/hooks/security_reminder_hook.py\"},\"toolUseID\":\"toolu_011UwXgXmxt7kJ73qkn3Yb4S\",\"parentToolUseID\":\"toolu_011UwXgXmxt7kJ73qkn3Yb4S\",\"uuid\":\"901ee0b3-df91-4380-a5aa-5a30376ea972\",\"timestamp\":\"2026-03-06T17:42:46.959Z\"}\n{\"type\":\"file-history-snapshot\",\"messageId\":\"4b17e074-5656-4b89-99ae-495841713c99\",\"snapshot\":{\"messageId\":\"6ca4bfdb-7531-4599-b962-dd42a98e6a2a\",\"trackedFileBackups\":{\"attribution-playground.html\":{\"backupFileName\":null,\"version\":1,\"backupTime\":\"2026-03-06T17:42:57.838Z\"}},\"timestamp\":\"2026-03-06T17:37:57.188Z\"},\"isSnapshotUpdate\":true}\n{\"parentUuid\":\"901ee0b3-df91-4380-a5aa-5a30376ea972\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/devenv/cli\",\"sessionId\":\"6ce8c9a4-5500-40f6-a6c7-8746f1f799f4\",\"version\":\"2.1.70\",\"gitBranch\":\"main\",\"slug\":\"cuddly-skipping-duckling\",\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"PostToolUse\",\"hookName\":\"PostToolUse:Write\",\"command\":\"callback\"},\"parentToolUseID\":\"toolu_011UwXgXmxt7kJ73qkn3Yb4S\",\"toolUseID\":\"toolu_011UwXgXmxt7kJ73qkn3Yb4S\",\"timestamp\":\"2026-03-06T17:42:58.131Z\",\"uuid\":\"55cb9b03-514a-40ee-96ca-750e5f421c5d\"}\n{\"parentUuid\":\"4b17e074-5656-4b89-99ae-495841713c99\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/devenv/cli\",\"sessionId\":\"6ce8c9a4-5500-40f6-a6c7-8746f1f799f4\",\"version\":\"2.1.70\",\"gitBranch\":\"main\",\"slug\":\"cuddly-skipping-duckling\",\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_011UwXgXmxt7kJ73qkn3Yb4S\",\"type\":\"tool_result\",\"content\":\"File created successfully at: /Users/alisha/Projects/devenv/cli/attribution-playground.html\"}]},\"uuid\":\"71624785-29d4-466e-b6fa-64649e0a8620\",\"timestamp\":\"2026-03-06T17:42:58.131Z\",\"toolUseResult\":{\"type\":\"create\",\"filePath\":\"/Users/alisha/Projects/devenv/cli/attribution-playground.html\",\"content\":\"<!DOCTYPE html>\\n<html lang=\\\"en\\\">\\n<head>\\n<meta charset=\\\"UTF-8\\\">\\n<meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\">\\n<title>Attribution Models Playground</title>\\n<style>\\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\\n  :root {\\n    --bg: #1a1a2e; --surface: #16213e; --border: #2a3a5c;\\n    --text: #e0e0e0; --muted: #8892a4; --accent: #4fc3f7;\\n    --green: #66bb6a; --orange: #ffa726; --pink: #f06292;\\n    --purple: #ab47bc; --yellow: #ffee58; --red: #ef5350;\\n    --teal: #26a69a; --blue: #42a5f5;\\n  }\\n  body { font-family: system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); height: 100vh; display: flex; flex-direction: column; overflow: hidden; }\\n  h1 { font-size: 1.1rem; color: var(--accent); padding: 12px 16px; border-bottom: 1px solid var(--border); }\\n  h2 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); margin-bottom: 8px; }\\n\\n  .main { display: flex; flex: 1; overflow: hidden; }\\n\\n  .sidebar { width: 280px; min-width: 280px; background: var(--surface); border-right: 1px solid var(--border); overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 16px; }\\n  .sidebar section { display: flex; flex-direction: column; gap: 6px; }\\n\\n  label { font-size: 0.8rem; color: var(--muted); display: block; margin-bottom: 2px; }\\n  select, input[type=\\\"number\\\"], input[type=\\\"text\\\"] {\\n    width: 100%; background: var(--bg); color: var(--text); border: 1px solid var(--border);\\n    border-radius: 4px; padding: 6px 8px; font-size: 0.85rem; outline: none;\\n  }\\n  select:focus, input:focus { border-color: var(--accent); }\\n  button {\\n    background: var(--border); color: var(--text); border: none; border-radius: 4px;\\n    padding: 6px 12px; font-size: 0.8rem; cursor: pointer; transition: background 0.15s;\\n  }\\n  button:hover { background: var(--accent); color: #000; }\\n  button.active { background: var(--accent); color: #000; }\\n  button.small { padding: 3px 8px; font-size: 0.75rem; }\\n  button.danger { background: var(--red); color: #fff; }\\n  button.danger:hover { background: #c62828; }\\n\\n  .presets { display: flex; flex-wrap: wrap; gap: 4px; }\\n  .presets button { flex: 1; min-width: 80px; font-size: 0.75rem; }\\n\\n  .touchpoint-list { display: flex; flex-direction: column; gap: 4px; max-height: 200px; overflow-y: auto; }\\n\\n  .add-row { display: flex; gap: 4px; }\\n  .add-row input { flex: 1; }\\n\\n  .canvas-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; }\\n  .viz { flex: 1; position: relative; padding: 20px; overflow: auto; }\\n\\n  .journey { position: relative; margin: 20px auto; max-width: 900px; }\\n  .timeline-line { height: 3px; background: var(--border); position: absolute; top: 40px; left: 30px; right: 30px; }\\n\\n  .explanation-box {\\n    max-width: 900px; margin: 20px auto 0; padding: 12px 16px;\\n    background: var(--surface); border-radius: 6px; border-left: 3px solid var(--accent);\\n    font-size: 0.85rem; line-height: 1.5;\\n  }\\n\\n  .prompt-area {\\n    background: var(--surface); border-top: 1px solid var(--border);\\n    padding: 12px 16px; max-height: 160px; overflow-y: auto; position: relative;\\n  }\\n  .prompt-area h2 { margin-bottom: 6px; }\\n  .prompt-text { font-family: monospace; font-size: 0.8rem; line-height: 1.5; color: var(--text); white-space: pre-wrap; }\\n  .copy-btn {\\n    position: absolute; top: 10px; right: 16px; background: var(--accent); color: #000;\\n    font-weight: 600; padding: 4px 12px; border-radius: 4px; font-size: 0.75rem;\\n  }\\n  .copy-btn:hover { background: #81d4fa; }\\n\\n  input[type=\\\"range\\\"] { width: 100%; accent-color: var(--accent); }\\n  .slider-row { display: flex; align-items: center; gap: 8px; }\\n  .slider-row span { font-family: monospace; font-size: 0.8rem; min-width: 30px; }\\n\\n  .comparison { max-width: 900px; margin: 20px auto 0; }\\n  table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }\\n  th { text-align: left; padding: 6px 8px; border-bottom: 1px solid var(--border); color: var(--muted); font-weight: 600; }\\n  td { padding: 6px 8px; border-bottom: 1px solid rgba(42,58,92,0.4); font-family: monospace; }\\n  td:first-child { font-family: system-ui; }\\n\\n  .hidden { display: none; }\\n</style>\\n</head>\\n<body>\\n\\n<h1>Attribution Models Playground</h1>\\n\\n<div class=\\\"main\\\">\\n  <div class=\\\"sidebar\\\">\\n    <section>\\n      <h2>Attribution Model</h2>\\n      <select id=\\\"model-select\\\" onchange=\\\"handleModelChange()\\\">\\n        <option value=\\\"first-touch\\\">First Touch</option>\\n        <option value=\\\"last-touch\\\">Last Touch</option>\\n        <option value=\\\"linear\\\" selected>Linear</option>\\n        <option value=\\\"time-decay\\\">Time Decay</option>\\n        <option value=\\\"u-shaped\\\">U-Shaped (Position-Based)</option>\\n        <option value=\\\"w-shaped\\\">W-Shaped</option>\\n        <option value=\\\"custom\\\">Custom Weights</option>\\n      </select>\\n    </section>\\n\\n    <section id=\\\"decay-section\\\" class=\\\"hidden\\\">\\n      <h2>Decay Half-Life</h2>\\n      <div class=\\\"slider-row\\\">\\n        <input type=\\\"range\\\" id=\\\"decay-slider\\\" min=\\\"1\\\" max=\\\"14\\\" value=\\\"7\\\" oninput=\\\"updateDecayLabel(); updateAll();\\\">\\n        <span id=\\\"decay-label\\\">7d</span>\\n      </div>\\n      <label style=\\\"margin-top:4px;\\\">How quickly credit fades for older touchpoints</label>\\n    </section>\\n\\n    <section>\\n      <h2>Presets</h2>\\n      <div class=\\\"presets\\\">\\n        <button onclick=\\\"loadPreset('saas')\\\">SaaS Funnel</button>\\n        <button onclick=\\\"loadPreset('ecommerce')\\\">E-commerce</button>\\n        <button onclick=\\\"loadPreset('b2b')\\\">B2B Long Sale</button>\\n        <button onclick=\\\"loadPreset('simple')\\\">Simple (3)</button>\\n        <button onclick=\\\"loadPreset('content')\\\">Content Mktg</button>\\n      </div>\\n    </section>\\n\\n    <section>\\n      <h2>Touchpoints</h2>\\n      <div class=\\\"touchpoint-list\\\" id=\\\"tp-list\\\"></div>\\n      <div class=\\\"add-row\\\" style=\\\"margin-top:6px;\\\">\\n        <input type=\\\"text\\\" id=\\\"new-tp-name\\\" placeholder=\\\"Channel name...\\\" onkeydown=\\\"if(event.key==='Enter')addTouchpoint()\\\">\\n        <button class=\\\"small\\\" onclick=\\\"addTouchpoint()\\\">+ Add</button>\\n      </div>\\n    </section>\\n\\n    <section id=\\\"custom-section\\\" class=\\\"hidden\\\">\\n      <h2>Custom Weights</h2>\\n      <div id=\\\"custom-weights\\\"></div>\\n      <label style=\\\"margin-top:4px;\\\">Weights are auto-normalized to 100%</label>\\n    </section>\\n\\n    <section>\\n      <h2>View</h2>\\n      <div style=\\\"display:flex; gap:4px;\\\">\\n        <button id=\\\"btn-journey\\\" class=\\\"active\\\" onclick=\\\"setView('journey')\\\">Journey</button>\\n        <button id=\\\"btn-compare\\\" onclick=\\\"setView('compare')\\\">Compare All</button>\\n      </div>\\n    </section>\\n  </div>\\n\\n  <div class=\\\"canvas-area\\\">\\n    <div class=\\\"viz\\\" id=\\\"viz\\\">\\n      <div id=\\\"view-journey\\\">\\n        <div class=\\\"journey\\\">\\n          <div class=\\\"timeline-line\\\"></div>\\n          <div id=\\\"tp-nodes\\\" style=\\\"display:flex; justify-content:space-between; position:relative; z-index:1; padding:0 10px;\\\"></div>\\n        </div>\\n        <div style=\\\"max-width:900px; margin:30px auto 0;\\\">\\n          <h2 style=\\\"text-align:center;\\\">Credit Distribution</h2>\\n          <div id=\\\"bars\\\" style=\\\"display:flex; align-items:flex-end; justify-content:center; gap:8px; height:160px; padding:0 20px; margin-top:10px;\\\"></div>\\n        </div>\\n        <div class=\\\"explanation-box\\\" id=\\\"explanation\\\"></div>\\n      </div>\\n\\n      <div id=\\\"view-compare\\\" class=\\\"hidden\\\">\\n        <div class=\\\"comparison\\\">\\n          <h2 style=\\\"margin-bottom:10px;\\\">Model Comparison</h2>\\n          <table id=\\\"compare-table\\\"></table>\\n        </div>\\n      </div>\\n    </div>\\n\\n    <div class=\\\"prompt-area\\\">\\n      <h2>Prompt Output</h2>\\n      <button class=\\\"copy-btn\\\" onclick=\\\"copyPrompt()\\\">Copy</button>\\n      <div class=\\\"prompt-text\\\" id=\\\"prompt-output\\\"></div>\\n    </div>\\n  </div>\\n</div>\\n\\n<script>\\nconst COLORS = ['#4fc3f7','#66bb6a','#ffa726','#f06292','#ab47bc','#ffee58','#ef5350','#26a69a','#42a5f5','#8d6e63','#78909c','#dce775'];\\n\\nconst PRESETS = {\\n  saas: [\\n    { name: 'Google Ad', days: 0 },\\n    { name: 'Blog Post', days: 3 },\\n    { name: 'Email Nurture', days: 7 },\\n    { name: 'Webinar', days: 14 },\\n    { name: 'Free Trial', days: 18 },\\n    { name: 'Sales Demo', days: 25 },\\n    { name: 'Pricing Page', days: 28 },\\n  ],\\n  ecommerce: [\\n    { name: 'Instagram Ad', days: 0 },\\n    { name: 'Product Review', days: 1 },\\n    { name: 'Retargeting Ad', days: 3 },\\n    { name: 'Email Coupon', days: 5 },\\n    { name: 'Direct Visit', days: 6 },\\n  ],\\n  b2b: [\\n    { name: 'LinkedIn Ad', days: 0 },\\n    { name: 'Whitepaper', days: 10 },\\n    { name: 'Conference', days: 30 },\\n    { name: 'Case Study', days: 45 },\\n    { name: 'Sales Call', days: 60 },\\n    { name: 'Proposal', days: 75 },\\n    { name: 'Negotiation', days: 85 },\\n    { name: 'Contract', days: 90 },\\n  ],\\n  simple: [\\n    { name: 'Awareness', days: 0 },\\n    { name: 'Consideration', days: 5 },\\n    { name: 'Conversion', days: 10 },\\n  ],\\n  content: [\\n    { name: 'SEO Blog', days: 0 },\\n    { name: 'YouTube Video', days: 4 },\\n    { name: 'Podcast', days: 8 },\\n    { name: 'Newsletter', days: 12 },\\n    { name: 'Social Share', days: 14 },\\n    { name: 'Landing Page', days: 15 },\\n  ],\\n};\\n\\nconst MODEL_INFO = {\\n  'first-touch': {\\n    short: 'First Touch',\\n    desc: 'First Touch gives 100% of the credit to the first interaction. It answers: \\\"What channel introduced this customer?\\\" Great for measuring awareness campaigns, but ignores everything that nurtured the lead afterward.',\\n    bias: 'Overvalues top-of-funnel channels. Undervalues nurture and closing efforts.',\\n  },\\n  'last-touch': {\\n    short: 'Last Touch',\\n    desc: 'Last Touch gives 100% of the credit to the last interaction before conversion. It answers: \\\"What closed the deal?\\\" Simple and widely used (Google Analytics default), but ignores the entire journey.',\\n    bias: 'Overvalues bottom-of-funnel. Undervalues awareness and consideration.',\\n  },\\n  'linear': {\\n    short: 'Linear',\\n    desc: 'Linear splits credit equally across all touchpoints. It answers: \\\"Every interaction mattered the same.\\\" Fair and simple, but unrealistic \\\\u2014 not all touches have equal impact.',\\n    bias: 'Treats a passing glance the same as an hour-long demo.',\\n  },\\n  'time-decay': {\\n    short: 'Time Decay',\\n    desc: 'Time Decay gives more credit to touchpoints closer to the conversion. Uses exponential decay with a configurable half-life. Good for short sales cycles where recent interactions drive decisions.',\\n    bias: 'Undervalues early awareness that planted the seed.',\\n  },\\n  'u-shaped': {\\n    short: 'U-Shaped (40/20/40)',\\n    desc: 'U-Shaped (Position-Based) gives 40% to the first touch, 40% to the last touch, and splits the remaining 20% among middle interactions. Recognizes that discovery and conversion are pivotal moments.',\\n    bias: 'Middle-funnel nurturing (often the hardest work) gets minimal credit.',\\n  },\\n  'w-shaped': {\\n    short: 'W-Shaped (30/30/30/10)',\\n    desc: 'W-Shaped gives 30% to the first touch, 30% to the lead-creation midpoint, 30% to the last touch, and splits the remaining 10% among everything else. Best for B2B funnels with a distinct qualification step.',\\n    bias: 'Assumes a clear midpoint exists. Less useful for short or uniform journeys.',\\n  },\\n  'custom': {\\n    short: 'Custom',\\n    desc: 'Custom Weights let you manually assign relative importance to each touchpoint. Weights are normalized to 100%. Use this to model your own attribution theory or domain expertise.',\\n    bias: 'Only as good as your assumptions.',\\n  },\\n};\\n\\nlet state = {\\n  model: 'linear',\\n  touchpoints: [],\\n  customWeights: [],\\n  decayHalfLife: 7,\\n  view: 'journey',\\n};\\n\\n// --- Attribution math ---\\nfunction calcCredits(model, tps, halfLife, customW) {\\n  const n = tps.length;\\n  if (n === 0) return [];\\n  if (n === 1) return [1];\\n\\n  switch (model) {\\n    case 'first-touch': {\\n      const c = Array(n).fill(0);\\n      c[0] = 1;\\n      return c;\\n    }\\n    case 'last-touch': {\\n      const c = Array(n).fill(0);\\n      c[n - 1] = 1;\\n      return c;\\n    }\\n    case 'linear': {\\n      return Array(n).fill(1 / n);\\n    }\\n    case 'time-decay': {\\n      const maxDay = tps[n - 1].days;\\n      const rawDecay = tps.map(function(tp) {\\n        const daysBeforeConversion = maxDay - tp.days;\\n        return Math.pow(2, -daysBeforeConversion / halfLife);\\n      });\\n      const sum = rawDecay.reduce(function(a, b) { return a + b; }, 0);\\n      return rawDecay.map(function(v) { return v / sum; });\\n    }\\n    case 'u-shaped': {\\n      const c = Array(n).fill(0);\\n      if (n === 2) return [0.5, 0.5];\\n      c[0] = 0.4;\\n      c[n - 1] = 0.4;\\n      const mid = 0.2 / (n - 2);\\n      for (let i = 1; i < n - 1; i++) c[i] = mid;\\n      return c;\\n    }\\n    case 'w-shaped': {\\n      const c = Array(n).fill(0);\\n      if (n === 2) return [0.5, 0.5];\\n      if (n === 3) return [0.333, 0.334, 0.333];\\n      const midIdx = Math.floor(n / 2);\\n      c[0] = 0.3;\\n      c[midIdx] = 0.3;\\n      c[n - 1] = 0.3;\\n      let others = n - 3;\\n      if (others <= 0) {\\n        const s = c.reduce(function(a, b) { return a + b; }, 0);\\n        return c.map(function(v) { return v / s; });\\n      }\\n      const each = 0.1 / others;\\n      for (let i = 0; i < n; i++) {\\n        if (i !== 0 && i !== midIdx && i !== n - 1) c[i] = each;\\n      }\\n      return c;\\n    }\\n    case 'custom': {\\n      if (!customW || customW.length !== n) return Array(n).fill(1 / n);\\n      const sum = customW.reduce(function(a, b) { return a + b; }, 0);\\n      if (sum === 0) return Array(n).fill(1 / n);\\n      return customW.map(function(w) { return w / sum; });\\n    }\\n    default: return Array(n).fill(1 / n);\\n  }\\n}\\n\\nfunction calcAllModels(tps, halfLife, customW) {\\n  var models = ['first-touch', 'last-touch', 'linear', 'time-decay', 'u-shaped', 'w-shaped'];\\n  var result = {};\\n  for (var i = 0; i < models.length; i++) {\\n    result[models[i]] = calcCredits(models[i], tps, halfLife, customW);\\n  }\\n  return result;\\n}\\n\\n// --- Safe DOM helpers ---\\nfunction clearEl(el) { while (el.firstChild) el.removeChild(el.firstChild); }\\n\\nfunction makeEl(tag, attrs, children) {\\n  var el = document.createElement(tag);\\n  if (attrs) {\\n    Object.keys(attrs).forEach(function(k) {\\n      if (k === 'style' && typeof attrs[k] === 'object') {\\n        Object.assign(el.style, attrs[k]);\\n      } else if (k.startsWith('on')) {\\n        el.addEventListener(k.slice(2), attrs[k]);\\n      } else if (k === 'className') {\\n        el.className = attrs[k];\\n      } else {\\n        el.setAttribute(k, attrs[k]);\\n      }\\n    });\\n  }\\n  if (children) {\\n    if (typeof children === 'string') {\\n      el.textContent = children;\\n    } else if (Array.isArray(children)) {\\n      children.forEach(function(c) { if (c) el.appendChild(c); });\\n    }\\n  }\\n  return el;\\n}\\n\\n// --- Rendering ---\\nfunction renderTouchpointList() {\\n  var list = document.getElementById('tp-list');\\n  clearEl(list);\\n  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n  state.touchpoints.forEach(function(tp, i) {\\n    var dot = makeEl('span', { className: 'dot', style: { background: COLORS[i % COLORS.length], width: '10px', height: '10px', borderRadius: '50%', flexShrink: '0', display: 'inline-block' } });\\n    var name = makeEl('span', { style: { flex: '1', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }, title: tp.name }, tp.name);\\n    var credit = makeEl('span', { style: { fontFamily: 'monospace', color: 'var(--accent)', minWidth: '40px', textAlign: 'right' } }, (credits[i] * 100).toFixed(1) + '%');\\n    var removeBtn = makeEl('button', { className: 'small danger', title: 'Remove', onclick: function() { removeTouchpoint(i); } }, 'x');\\n\\n    var item = makeEl('div', {\\n      style: { display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 6px', background: 'var(--bg)', borderRadius: '4px', fontSize: '0.8rem' }\\n    }, [dot, name, credit, removeBtn]);\\n    list.appendChild(item);\\n  });\\n}\\n\\nfunction renderJourney() {\\n  var container = document.getElementById('tp-nodes');\\n  clearEl(container);\\n  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n\\n  state.touchpoints.forEach(function(tp, i) {\\n    var pct = credits[i] * 100;\\n    var size = 28 + pct * 0.4;\\n    var borderW = pct > 30 ? 4 : pct > 10 ? 3 : 2;\\n    var alphaVal = 0.2 + pct / 200;\\n\\n    var circle = makeEl('div', {\\n      style: {\\n        width: size + 'px', height: size + 'px', borderRadius: '50%',\\n        display: 'flex', alignItems: 'center', justifyContent: 'center',\\n        fontSize: '0.7rem', fontWeight: '700', color: '#000',\\n        background: COLORS[i % COLORS.length],\\n        border: borderW + 'px solid rgba(255,255,255,' + alphaVal + ')',\\n        boxShadow: '0 0 ' + (pct / 3) + 'px ' + COLORS[i % COLORS.length] + '40',\\n        transition: 'all 0.3s'\\n      }\\n    }, String(i + 1));\\n\\n    var label = makeEl('div', {\\n      style: { fontSize: '0.7rem', textAlign: 'center', color: 'var(--muted)', maxWidth: '80px', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' },\\n      title: tp.name\\n    }, tp.name);\\n\\n    var creditLabel = makeEl('div', {\\n      style: { fontSize: '0.85rem', fontWeight: '700', fontFamily: 'monospace', marginTop: '2px', color: COLORS[i % COLORS.length] }\\n    }, pct.toFixed(1) + '%');\\n\\n    var node = makeEl('div', {\\n      style: { display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', cursor: 'default', minWidth: '60px', maxWidth: '100px', transition: 'transform 0.2s' }\\n    }, [circle, label, creditLabel]);\\n\\n    node.addEventListener('mouseenter', function() { node.style.transform = 'translateY(-3px)'; });\\n    node.addEventListener('mouseleave', function() { node.style.transform = 'translateY(0)'; });\\n\\n    container.appendChild(node);\\n  });\\n}\\n\\nfunction renderBars() {\\n  var container = document.getElementById('bars');\\n  clearEl(container);\\n  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n  var maxCredit = Math.max.apply(null, credits.concat([0.01]));\\n\\n  credits.forEach(function(c, i) {\\n    var h = (c / maxCredit) * 130;\\n\\n    var valueLabel = makeEl('div', {\\n      style: { fontSize: '0.75rem', fontFamily: 'monospace', fontWeight: '700', color: COLORS[i % COLORS.length] }\\n    }, (c * 100).toFixed(1) + '%');\\n\\n    var bar = makeEl('div', {\\n      style: {\\n        width: '100%', minHeight: '2px', height: h + 'px',\\n        borderRadius: '4px 4px 0 0', transition: 'height 0.4s ease',\\n        background: 'linear-gradient(180deg, ' + COLORS[i % COLORS.length] + ', ' + COLORS[i % COLORS.length] + '80)'\\n      }\\n    });\\n\\n    var nameLabel = makeEl('div', {\\n      style: { fontSize: '0.65rem', color: 'var(--muted)', textAlign: 'center', maxWidth: '70px', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' },\\n      title: state.touchpoints[i].name\\n    }, state.touchpoints[i].name);\\n\\n    var col = makeEl('div', {\\n      style: { display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', flex: '1', maxWidth: '80px' }\\n    }, [valueLabel, bar, nameLabel]);\\n\\n    container.appendChild(col);\\n  });\\n}\\n\\nfunction renderExplanation() {\\n  var el = document.getElementById('explanation');\\n  clearEl(el);\\n  var info = MODEL_INFO[state.model];\\n\\n  var descEl = makeEl('span', { style: { color: 'var(--accent)', fontWeight: '700' } }, info.short + ': ');\\n  var descText = document.createTextNode(info.desc);\\n  var br = document.createElement('br');\\n  var br2 = document.createElement('br');\\n  var biasLabel = makeEl('span', { style: { color: 'var(--orange)' } }, 'Bias: ');\\n  var biasText = document.createTextNode(info.bias);\\n\\n  el.appendChild(descEl);\\n  el.appendChild(descText);\\n  el.appendChild(br);\\n  el.appendChild(br2);\\n  el.appendChild(biasLabel);\\n  el.appendChild(biasText);\\n}\\n\\nfunction renderCompare() {\\n  var table = document.getElementById('compare-table');\\n  clearEl(table);\\n  var all = calcAllModels(state.touchpoints, state.decayHalfLife, state.customWeights);\\n  var models = ['first-touch', 'last-touch', 'linear', 'time-decay', 'u-shaped', 'w-shaped'];\\n\\n  // Header\\n  var headerRow = makeEl('tr');\\n  headerRow.appendChild(makeEl('th', {}, 'Touchpoint'));\\n  models.forEach(function(m) {\\n    headerRow.appendChild(makeEl('th', {}, MODEL_INFO[m].short));\\n  });\\n  table.appendChild(headerRow);\\n\\n  // Data rows\\n  state.touchpoints.forEach(function(tp, i) {\\n    var row = makeEl('tr');\\n    var dot = makeEl('span', { style: { color: COLORS[i % COLORS.length] } }, '\\\\u25CF ');\\n    var nameCell = makeEl('td');\\n    nameCell.appendChild(dot);\\n    nameCell.appendChild(document.createTextNode(tp.name));\\n    row.appendChild(nameCell);\\n\\n    models.forEach(function(m) {\\n      var v = (all[m][i] * 100).toFixed(1) + '%';\\n      var isCurrent = m === state.model;\\n      var cell = makeEl('td', {\\n        style: isCurrent ? { color: 'var(--accent)', fontWeight: '700' } : {}\\n      }, v);\\n      row.appendChild(cell);\\n    });\\n    table.appendChild(row);\\n  });\\n\\n  // Winner row\\n  var winnerRow = makeEl('tr', { style: { borderTop: '2px solid var(--border)' } });\\n  winnerRow.appendChild(makeEl('td', { style: { fontFamily: 'system-ui', color: 'var(--muted)' } }, 'Top Channel'));\\n  models.forEach(function(m) {\\n    var credits = all[m];\\n    var maxIdx = credits.indexOf(Math.max.apply(null, credits));\\n    var isCurrent = m === state.model;\\n    var cell = makeEl('td', {\\n      style: { color: COLORS[maxIdx % COLORS.length], fontWeight: isCurrent ? '700' : 'normal' }\\n    }, state.touchpoints[maxIdx].name);\\n    winnerRow.appendChild(cell);\\n  });\\n  table.appendChild(winnerRow);\\n}\\n\\nfunction renderCustomWeights() {\\n  var section = document.getElementById('custom-section');\\n  var container = document.getElementById('custom-weights');\\n  if (state.model !== 'custom') {\\n    section.classList.add('hidden');\\n    return;\\n  }\\n  section.classList.remove('hidden');\\n  clearEl(container);\\n\\n  while (state.customWeights.length < state.touchpoints.length) state.customWeights.push(1);\\n  while (state.customWeights.length > state.touchpoints.length) state.customWeights.pop();\\n\\n  state.touchpoints.forEach(function(tp, i) {\\n    var dot = makeEl('span', { style: { background: COLORS[i % COLORS.length], width: '8px', height: '8px', borderRadius: '50%', display: 'inline-block' } });\\n    var label = makeEl('span', { style: { fontSize: '0.75rem', flex: '1', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' } }, tp.name);\\n    var input = makeEl('input', { type: 'number', min: '0', max: '100', value: String(state.customWeights[i]), style: { width: '55px' } });\\n    (function(idx) {\\n      input.addEventListener('change', function() {\\n        state.customWeights[idx] = parseFloat(this.value) || 0;\\n        updateAll();\\n      });\\n    })(i);\\n\\n    var row = makeEl('div', { style: { display: 'flex', alignItems: 'center', gap: '6px', marginBottom: '4px' } }, [dot, label, input]);\\n    container.appendChild(row);\\n  });\\n}\\n\\nfunction renderPrompt() {\\n  var el = document.getElementById('prompt-output');\\n  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n  var info = MODEL_INFO[state.model];\\n  var n = state.touchpoints.length;\\n\\n  if (n === 0) {\\n    el.textContent = 'Add touchpoints to generate a prompt.';\\n    return;\\n  }\\n\\n  var sorted = credits\\n    .map(function(c, i) { return { name: state.touchpoints[i].name, credit: c }; })\\n    .sort(function(a, b) { return b.credit - a.credit; });\\n\\n  var top = sorted[0];\\n  var bottom = sorted[sorted.length - 1];\\n  var journey = state.touchpoints.map(function(tp) { return tp.name; }).join(' -> ');\\n\\n  var parts = [];\\n  parts.push(\\\"I'm analyzing a \\\" + n + \\\"-step customer journey using the \\\" + info.short + \\\" attribution model.\\\");\\n  parts.push(\\\"\\\\nJourney: \\\" + journey);\\n  parts.push(\\\"\\\\nCredit distribution:\\\");\\n  sorted.forEach(function(s) {\\n    parts.push(\\\"  \\\" + s.name + \\\": \\\" + (s.credit * 100).toFixed(1) + \\\"%\\\");\\n  });\\n\\n  if (state.model === 'time-decay') {\\n    parts.push(\\\"\\\\nDecay half-life: \\\" + state.decayHalfLife + \\\" days\\\");\\n  }\\n\\n  parts.push(\\\"\\\\nThe \\\" + info.short + \\\" model \\\" + (top.credit > 0.5 ? 'heavily favors' : 'gives the most credit to') + ' \\\"' + top.name + '\\\" (' + (top.credit * 100).toFixed(1) + '%).');\\n\\n  if (n > 2) {\\n    parts.push('\\\"' + bottom.name + '\\\" gets the least credit at ' + (bottom.credit * 100).toFixed(1) + '%.');\\n  }\\n\\n  parts.push(\\\"\\\\nHelp me understand: Is \\\" + info.short + \\\" the right model for this journey? What would change if I used a different model? Which touchpoints might be over- or under-valued?\\\");\\n\\n  el.textContent = parts.join('\\\\n');\\n}\\n\\n// --- Actions ---\\nfunction updateAll() {\\n  renderTouchpointList();\\n  renderJourney();\\n  renderBars();\\n  renderExplanation();\\n  renderCompare();\\n  renderCustomWeights();\\n  renderPrompt();\\n}\\n\\nfunction handleModelChange() {\\n  state.model = document.getElementById('model-select').value;\\n  document.getElementById('decay-section').classList.toggle('hidden', state.model !== 'time-decay');\\n  updateAll();\\n}\\n\\nfunction updateDecayLabel() {\\n  state.decayHalfLife = parseInt(document.getElementById('decay-slider').value);\\n  document.getElementById('decay-label').textContent = state.decayHalfLife + 'd';\\n}\\n\\nfunction loadPreset(name) {\\n  state.touchpoints = PRESETS[name].map(function(tp) { return { name: tp.name, days: tp.days }; });\\n  state.customWeights = state.touchpoints.map(function() { return 1; });\\n  updateAll();\\n}\\n\\nfunction addTouchpoint() {\\n  var input = document.getElementById('new-tp-name');\\n  var name = input.value.trim();\\n  if (!name) return;\\n  var lastDay = state.touchpoints.length > 0 ? state.touchpoints[state.touchpoints.length - 1].days : 0;\\n  state.touchpoints.push({ name: name, days: lastDay + 5 });\\n  state.customWeights.push(1);\\n  input.value = '';\\n  updateAll();\\n}\\n\\nfunction removeTouchpoint(i) {\\n  state.touchpoints.splice(i, 1);\\n  state.customWeights.splice(i, 1);\\n  updateAll();\\n}\\n\\nfunction setView(view) {\\n  state.view = view;\\n  document.getElementById('view-journey').classList.toggle('hidden', view !== 'journey');\\n  document.getElementById('view-compare').classList.toggle('hidden', view !== 'compare');\\n  document.getElementById('btn-journey').classList.toggle('active', view === 'journey');\\n  document.getElementById('btn-compare').classList.toggle('active', view === 'compare');\\n  if (view === 'compare') renderCompare();\\n}\\n\\nfunction copyPrompt() {\\n  var text = document.getElementById('prompt-output').textContent;\\n  navigator.clipboard.writeText(text).then(function() {\\n    var btn = document.querySelector('.copy-btn');\\n    btn.textContent = 'Copied!';\\n    setTimeout(function() { btn.textContent = 'Copy'; }, 1500);\\n  });\\n}\\n\\n// --- Init ---\\nloadPreset('saas');\\n</script>\\n</body>\\n</html>\\n\",\"structuredPatch\":[],\"originalFile\":nu