d: #8892a4; --accent: #4fc3f7;\\n    --green: #66bb6a; --orange: #ffa726; --pink: #f06292;\\n    --purple: #ab47bc; --yellow: #ffee58; --red: #ef5350;\\n    --teal: #26a69a; --blue: #42a5f5;\\n  }\\n  body { font-family: system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); height: 100vh; display: flex; flex-direction: column; overflow: hidden; }\\n  h1 { font-size: 1.1rem; color: var(--accent); padding: 12px 16px; border-bottom: 1px solid var(--border); }\\n  h2 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); margin-bottom: 8px; }\\n\\n  .main { display: flex; flex: 1; overflow: hidden; }\\n\\n  /* Sidebar */\\n  .sidebar { width: 280px; min-width: 280px; background: var(--surface); border-right: 1px solid var(--border); overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 16px; }\\n  .sidebar section { display: flex; flex-direction: column; gap: 6px; }\\n\\n  label { font-size: 0.8rem; color: var(--muted); display: block; margin-bottom: 2px; }\\n  select, input[type=\\\"number\\\"], input[type=\\\"text\\\"] {\\n    width: 100%; background: var(--bg); color: var(--text); border: 1px solid var(--border);\\n    border-radius: 4px; padding: 6px 8px; font-size: 0.85rem; outline: none;\\n  }\\n  select:focus, input:focus { border-color: var(--accent); }\\n  button {\\n    background: var(--border); color: var(--text); border: none; border-radius: 4px;\\n    padding: 6px 12px; font-size: 0.8rem; cursor: pointer; transition: background 0.15s;\\n  }\\n  button:hover { background: var(--accent); color: #000; }\\n  button.active { background: var(--accent); color: #000; }\\n  button.small { padding: 3px 8px; font-size: 0.75rem; }\\n  button.danger { background: var(--red); color: #fff; }\\n  button.danger:hover { background: #c62828; }\\n\\n  .presets { display: flex; flex-wrap: wrap; gap: 4px; }\\n  .presets button { flex: 1; min-width: 80px; font-size: 0.75rem; }\\n\\n  .touchp