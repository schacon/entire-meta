 .chart-section { margin-top: 30px; max-width: 900px; margin-left: auto; margin-right: auto; }\\n  .chart-section h2 { text-align: center; }\\n  .bars { display: flex; align-items: flex-end; justify-content: center; gap: 8px; height: 160px; padding: 0 20px; margin-top: 10px; }\\n  .bar-col { display: flex; flex-direction: column; align-items: center; gap: 4px; flex: 1; max-width: 80px; }\\n  .bar {\\n    width: 100%; min-height: 2px; border-radius: 4px 4px 0 0; transition: height 0.4s ease;\\n    position: relative;\\n  }\\n  .bar-label { font-size: 0.65rem; color: var(--muted); text-align: center; max-width: 70px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }\\n  .bar-value { font-size: 0.75rem; font-family: monospace; font-weight: 700; }\\n\\n  /* Model explanation */\\n  .explanation {\\n    max-width: 900px; margin: 20px auto 0; padding: 12px 16px;\\n    background: var(--surface); border-radius: 6px; border-left: 3px solid var(--accent);\\n    font-size: 0.85rem; line-height: 1.5;\\n  }\\n  .explanation strong { color: var(--accent); }\\n\\n  /* Prompt output */\\n  .prompt-area {\\n    background: var(--surface); border-top: 1px solid var(--border);\\n    padding: 12px 16px; max-height: 160px; overflow-y: auto; position: relative;\\n  }\\n  .prompt-area h2 { margin-bottom: 6px; }\\n  .prompt-text { font-family: monospace; font-size: 0.8rem; line-height: 1.5; color: var(--text); white-space: pre-wrap; }\\n  .copy-btn {\\n    position: absolute; top: 10px; right: 16px; background: var(--accent); color: #000;\\n    font-weight: 600; padding: 4px 12px; border-radius: 4px; font-size: 0.75rem;\\n  }\\n  .copy-btn:hover { background: #81d4fa; }\\n\\n  /* Decay slider */\\n  input[type=\\\"range\\\"] { width: 100%; accent-color: var(--accent); }\\n  .slider-row { display: flex; align-items: center; gap: 8px; }\\n  .slider-row span { font-family: monospace; font-size: 0.8rem; min-width: 30px; }\\n\\n  /* Comparison table */\\n  .comparison { max-width: 900px; margin: 20px auto 0; }\\n  table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }\\n  th { text-align: left; padding: 6px 8px; border-bottom: 1px solid var(--border); color: var(--muted); font-weight: 600; }\\n  td { padding: 6px 8px; border-bottom: 1px solid rgba(42,58,92,0.4); font-family: monospace; }\\n  td:first-child { font-family: system-ui; }\\n  tr.active-row { background: rgba(79,195,247,0.08); }\\n\\n  .hidden { display: none; }\\n</style>\\n</head>\\n<body>\\n\\n<h1>Attribution Models Playground</h1>\\n\\n<div class=\\\"main\\\">\\n  <div class=\\\"sidebar\\\">\\n    <section>\\n      <h2>Attribution Model</h2>\\n      <select id=\\\"model-select\\\" onchange=\\\"handleModelChange()\\\">\\n        <option value=\\\"first-touch\\\">First Touch</option>\\n        <option value=\\\"last-touch\\\">Last Touch</option>\\n        <option value=\\\"linear\\\" selected>Linear</option>\\n        <option value=\\\"time-decay\\\">Time Decay</option>\\n        <option value=\\\"u-shaped\\\">U-Shaped (Position-Based)</option>\\n        <option value=\\\"w-shaped\\\">W-Shaped</option>\\n        <option value=\\\"custom\\\">Custom Weights</option>\\n      </select>\\n    </section>\\n\\n    <section id=\\\"decay-section\\\" class=\\\"hidden\\\">\\n      <h2>Decay Half-Life</h2>\\n      <div class=\\\"slider-row\\\">\\n        <input type=\\\"range\\\" id=\\\"decay-slider\\\" min=\\\"1\\\" max=\\\"14\\\" value=\\\"7\\\" oninput=\\\"updateDecayLabel(); updateAll();\\\">\\n        <span id=\\\"decay-label\\\">7d</span>\\n      </div>\\n      <label style=\\\"margin-top:4px;\\\">How quickly credit fades for older touchpoints</label>\\n    </section>\\n\\n    <section>\\n      <h2>Presets</h2>\\n      <div class=\\\"presets\\\">\\n        <button onclick=\\\"loadPreset('saas')\\\">SaaS Funnel</button>\\n        <button onclick=\\\"loadPreset('ecommerce')\\\">E-commerce</button>\\n        <button onclick=\\\"loadPreset('b2b')\\\">B2B Long Sale</button>\\n        <button onclick=\\\"loadPreset('simple')\\\">Simple (3)</button>\\n        <button onclick=\\\"loadPreset('content')\\\">Content Mktg</button>\\n      </div>\\n    </section>\\n\\n    <section>\\n      <h2>Touchpoints <span style=\\\"font-size:0.7rem; color:var(--muted);\\\">(drag to reorder)</span></h2>\\n      <div class=\\\"touchpoint-list\\\" id=\\\"tp-list\\\"></div>\\n      <div class=\\\"add-row\\\" style=\\\"margin-top:6px;\\\">\\n        <input type=\\\"text\\\" id=\\\"new-tp-name\\\" placeholder=\\\"Channel name...\\\" onkeydown=\\\"if(event.key==='Enter')addTouchpoint()\\\">\\n        <button class=\\\"small\\\" onclick=\\\"addTouchpoint()\\\">+ Add</button>\\n      </div>\\n    </section>\\n\\n    <section id=\\\"custom-section\\\" class=\\\"hidden\\\">\\n      <h2>Custom Weights</h2>\\n      <div id=\\\"custom-weights\\\"></div>\\n      <label style=\\\"margin-top:4px;\\\">Weights are auto-normalized to 100%</label>\\n    </section>\\n\\n    <section>\\n      <h2>View</h2>\\n      <div style=\\\"display:flex; gap:4px;\\\">\\n        <button id=\\\"btn-journey\\\" class=\\\"active\\\" onclick=\\\"setView('journey')\\\">Journey</button>\\n        <button id=\\\"btn-compare\\\" onclick=\\\"setView('compare')\\\">Compare All</button>\\n      </div>\\n    </section>\\n  </div>\\n\\n  <div class=\\\"canvas-area\\\">\\n    <div class=\\\"viz\\\" id=\\\"viz\\\">\\n      <!-- Journey view -->\\n      <div id=\\\"view-journey\\\">\\n        <div class=\\\"journey\\\">\\n          <div class=\\\"timeline-line\\\"></div>\\n          <div class=\\\"touchpoints-row\\\" id=\\\"tp-nodes\\\"></div>\\n        </div>\\n        <div class=\\\"chart-section\\\">\\n          <h2>Credit Distribution</h2>\\n          <div class=\\\"bars\\\" id=\\\"bars\\\"></div>\\n        </div>\\n        <div class=\\\"explanation\\\" id=\\\"explanation\\\"></div>\\n      </div>\\n\\n      <!-- Compare view -->\\n      <div id=\\\"view-compare\\\" class=\\\"hidden\\\">\\n        <div class=\\\"comparison\\\">\\n          <h2 style=\\\"margin-bottom:10px;\\\">Model Comparison</h2>\\n          <table id=\\\"compare-table\\\"></table>\\n        </div>\\n      </div>\\n    </div>\\n\\n    <div class=\\\"prompt-area\\\">\\n      <h2>Prompt Output</h2>\\n      <button class=\\\"copy-btn\\\" onclick=\\\"copyPrompt()\\\">Copy</button>\\n      <div class=\\\"prompt-text\\\" id=\\\"prompt-output\\\"></div>\\n    </div>\\n  </div>\\n</div>\\n\\n<script>\\nconst COLORS = ['#4fc3f7','#66bb6a','#ffa726','#f06292','#ab47bc','#ffee58','#ef5350','#26a69a','#42a5f5','#8d6e63','#78909c','#dce775'];\\n\\nconst PRESETS = {\\n  saas: [\\n    { name: 'Google Ad', days: 0 },\\n    { name: 'Blog Post', days: 3 },\\n    { name: 'Email Nurture', days: 7 },\\n    { name: 'Webinar', days: 14 },\\n    { name: 'Free Trial', days: 18 },\\n    { name: 'Sales Demo', days: 25 },\\n    { name: 'Pricing Page', days: 28 },\\n  ],\\n  ecommerce: [\\n    { name: 'Instagram Ad', days: 0 },\\n    { name: 'Product Review', days: 1 },\\n    { name: 'Retargeting Ad', days: 3 },\\n    { name: 'Email Coupon', days: 5 },\\n    { name: 'Direct Visit', days: 6 },\\n  ],\\n  b2b: [\\n    { name: 'LinkedIn Ad', days: 0 },\\n    { name: 'Whitepaper', days: 10 },\\n    { name: 'Conference', days: 30 },\\n    { name: 'Case Study', days: 45 },\\n    { name: 'Sales Call', days: 60 },\\n    { name: 'Proposal', days: 75 },\\n    { name: 'Negotiation', days: 85 },\\n    { name: 'Contract', days: 90 },\\n  ],\\n  simple: [\\n    { name: 'Awareness', days: 0 },\\n    { name: 'Consideration', days: 5 },\\n    { name: 'Conversion', days: 10 },\\n  ],\\n  content: [\\n    { name: 'SEO Blog', days: 0 },\\n    { name: 'YouTube Video', days: 4 },\\n    { name: 'Podcast', days: 8 },\\n    { name: 'Newsletter', days: 12 },\\n    { name: 'Social Share', days: 14 },\\n    { name: 'Landing Page', days: 15 },\\n  ],\\n};\\n\\nconst MODEL_EXPLANATIONS = {\\n  'first-touch': {\\n    short: 'First Touch',\\n    desc: '<strong>First Touch</strong> gives 100% of the credit to the <em>first</em> interaction. It answers: \\\"What channel introduced this customer?\\\" Great for measuring awareness campaigns, but ignores everything that nurtured the lead afterward.',\\n    bias: 'Overvalues top-of-funnel channels. Undervalues nurture and closing efforts.',\\n  },\\n  'last-touch': {\\n    short: 'Last Touch',\\n    desc: '<strong>Last Touch</strong> gives 100% of the credit to the <em>last</em> interaction before conversion. It answers: \\\"What closed the deal?\\\" Simple and widely used (Google Analytics default), but ignores the entire journey.',\\n    bias: 'Overvalues bottom-of-funnel. Undervalues awareness and consideration.',\\n  },\\n  'linear': {\\n    short: 'Linear',\\n    desc: '<strong>Linear</strong> splits credit equally across all touchpoints. It answers: \\\"Every interaction mattered the same.\\\" Fair and simple, but unrealistic — not all touches have equal impact.',\\n    bias: 'Treats a passing glance the same as an hour-long demo.',\\n  },\\n  'time-decay': {\\n    short: 'Time Decay',\\n    desc: '<strong>Time Decay</strong> gives more credit to touchpoints closer to the conversion. Uses an exponential decay with a configurable half-life. Good for short sales cycles where recent interactions drive decisions.',\\n    bias: 'Undervalues early awareness that planted the seed.',\\n  },\\n  'u-shaped': {\\n    short: 'U-Shaped (40/20/40)',\\n    desc: '<strong>U-Shaped</strong> (Position-Based) gives 40% to the first touch, 40% to the last touch, and splits the remaining 20% among middle interactions. Recognizes that discovery and conversion are pivotal moments.',\\n    bias: 'Middle-funnel nurturing (often the hardest work) gets minimal credit.',\\n  },\\n  'w-shaped': {\\n    short: 'W-Shaped (30/30/30/10)',\\n    desc: '<strong>W-Shaped</strong> gives 30% to the first touch, 30% to the lead-creation midpoint, 30% to the last touch, and splits the remaining 10% among everything else. Best for B2B funnels with a distinct qualification step.',\\n    bias: 'Assumes a clear midpoint exists. Less useful for short or uniform journeys.',\\n  },\\n  'custom': {\\n    short: 'Custom',\\n    desc: '<strong>Custom Weights</strong> let you manually assign relative importance to each touchpoint. Weights are normalized to 100%. Use this to model your own attribution theory or domain expertise.',\\n    bias: 'Only as good as your assumptions.',\\n  },\\n};\\n\\nlet state = {\\n  model: 'linear',\\n  touchpoints: [],\\n  customWeights: [],\\n  decayHalfLife: 7,\\n  view: 'journey',\\n};\\n\\n// --- Attribution math ---\\nfunction calcCredits(model, tps, halfLife, customW) {\\n  const n = tps.length;\\n  if (n === 0) return [];\\n  if (n === 1) return [1];\\n\\n  switch (model) {\\n    case 'first-touch': {\\n      const c = Array(n).fill(0);\\n      c[0] = 1;\\n      return c;\\n    }\\n    case 'last-touch': {\\n      const c = Array(n).fill(0);\\n      c[n - 1] = 1;\\n      return c;\\n    }\\n    case 'linear': {\\n      return Array(n).fill(1 / n);\\n    }\\n    case 'time-decay': {\\n      const maxDay = tps[n - 1].days;\\n      const raw = tps.map(tp => Math.pow(2, -(maxDay - tp.days) / halfLife));\\n      // Reverse: more recent = higher weight, so actually closer to conversion = higher\\n      // Correction: time decay gives more to recent. \\\"days\\\" is days before conversion.\\n      // Let's treat last touchpoint as day of conversion.\\n      const rawDecay = tps.map((tp, i) => {\\n        const daysBeforeConversion = maxDay - tp.days;\\n        return Math.pow(2, -daysBeforeConversion / halfLife);\\n      });\\n      const sum = rawDecay.reduce((a, b) => a + b, 0);\\n      return rawDecay.map(v => v / sum);\\n    }\\n    case 'u-shaped': {\\n      const c = Array(n).fill(0);\\n      if (n === 1) return [1];\\n      if (n === 2) return [0.5, 0.5];\\n      c[0] = 0.4;\\n      c[n - 1] = 0.4;\\n      const mid = 0.2 / (n - 2);\\n      for (let i = 1; i < n - 1; i++) c[i] = mid;\\n      return c;\\n    }\\n    case 'w-shaped': {\\n      const c = Array(n).fill(0);\\n      if (n === 1) return [1];\\n      if (n === 2) return [0.5, 0.5];\\n      if (n === 3) return [0.333, 0.334, 0.333];\\n      const midIdx = Math.floor(n / 2);\\n      c[0] = 0.3;\\n      c[midIdx] = 0.3;\\n      c[n - 1] = 0.3;\\n      const remaining = 0.1;\\n      let others = n - 3;\\n      if (others <= 0) {\\n        // redistribute\\n        const s = c.reduce((a, b) => a + b, 0);\\n        return c.map(v => v / s);\\n      }\\n      const each = remaining / others;\\n      for (let i = 0; i < n; i++) {\\n        if (i !== 0 && i !== midIdx && i !== n - 1) c[i] = each;\\n      }\\n      return c;\\n    }\\n    case 'custom': {\\n      if (!customW || customW.length !== n) return Array(n).fill(1 / n);\\n      const sum = customW.reduce((a, b) => a + b, 0);\\n      if (sum === 0) return Array(n).fill(1 / n);\\n      return customW.map(w => w / sum);\\n    }\\n    default: return Array(n).fill(1 / n);\\n  }\\n}\\n\\nfunction calcAllModels(tps, halfLife, customW) {\\n  const models = ['first-touch', 'last-touch', 'linear', 'time-decay', 'u-shaped', 'w-shaped'];\\n  const result = {};\\n  for (const m of models) {\\n    result[m] = calcCredits(m, tps, halfLife, customW);\\n  }\\n  return result;\\n}\\n\\n// --- Rendering ---\\nfunction renderTouchpointList() {\\n  const list = document.getElementById('tp-list');\\n  list.innerHTML = '';\\n  const credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n  state.touchpoints.forEach((tp, i) => {\\n    const item = document.createElement('div');\\n    item.className = 'tp-item';\\n    item.draggable = true;\\n    item.dataset.index = i;\\n    item.innerHTML = `\\n      <span class=\\\"dot\\\" style=\\\"background:${COLORS[i % COLORS.length]}\\\"></span>\\n      <span class=\\\"name\\\" title=\\\"${tp.name}\\\">${tp.name}</span>\\n      <span class=\\\"credit\\\">${(credits[i] * 100).toFixed(1)}%</span>\\n      <button class=\\\"small danger\\\" onclick=\\\"removeTouchpoint(${i})\\\" title=\\\"Remove\\\">x</button>\\n    `;\\n    item.addEventListener('dragstart', e => { e.dataTransfer.setData('text/plain', i); item.style.opacity = '0.4'; });\\n    item.addEventListener('dragend', () => { item.style.opacity = '1'; });\\n    item.addEventListener('dragover', e => { e.preventDefault(); item.style.borderTop = '2px solid var(--accent)'; });\\n    item.addEventListener('dragleave', () => { item.style.borderTop = 'none'; });\\n    item.addEventListener('drop', e => {\\n      e.preventDefault();\\n      item.style.borderTop = 'none';\\n      const from = parseInt(e.dataTransfer.getData('text/plain'));\\n      const to = i;\\n      if (from !== to) {\\n        const tp = state.touchpoints.splice(from, 1)[0];\\n        state.touchpoints.splice(to, 0, tp);\\n        // Recalc days sequentially\\n        state.touchpoints.forEach((t, idx) => { t.days = idx * 5; });\\n        if (state.customWeights.length) {\\n          const w = state.customWeights.splice(from, 1)[0];\\n          state.customWeights.splice(to, 0, w);\\n        }\\n        updateAll();\\n      }\\n    });\\n    list.appendChild(item);\\n  });\\n}\\n\\nfunction renderJourney() {\\n  const container = document.getElementById('tp-nodes');\\n  container.innerHTML = '';\\n  const credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n\\n  state.touchpoints.forEach((tp, i) => {\\n    const node = document.createElement('div');\\n    node.className = 'tp-node';\\n    const pct = credits[i] * 100;\\n    const size = 28 + pct * 0.4;\\n    const borderWidth = pct > 30 ? 4 : pct > 10 ? 3 : 2;\\n    node.innerHTML = `\\n      <div class=\\\"tp-circle\\\" style=\\\"\\n        width:${size}px; height:${size}px;\\n        background:${COLORS[i % COLORS.length]};\\n        border: ${borderWidth}px solid rgba(255,255,255,${0.2 + pct/200});\\n        box-shadow: 0 0 ${pct/3}px ${COLORS[i % COLORS.length]}40;\\n      \\\">${i + 1}</div>\\n      <div class=\\\"tp-label\\\" title=\\\"${tp.name}\\\">${tp.name}</div>\\n      <div class=\\\"tp-credit\\\" style=\\\"color:${COLORS[i % COLORS.length]}\\\">${pct.toFixed(1)}%</div>\\n    `;\\n    container.appendChild(node);\\n  });\\n}\\n\\nfunction renderBars() {\\n  const container = document.getElementById('bars');\\n  container.innerHTML = '';\\n  const credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n  const maxCredit = Math.max(...credits, 0.01);\\n\\n  credits.forEach((c, i) => {\\n    const col = document.createElement('div');\\n    col.className = 'bar-col';\\n    const h = (c / maxCredit) * 130;\\n    col.innerHTML = `\\n      <div class=\\\"bar-value\\\" style=\\\"color:${COLORS[i % COLORS.length]}\\\">${(c * 100).toFixed(1)}%</div>\\n      <div class=\\\"bar\\\" style=\\\"height:${h}px; background: linear-gradient(180deg, ${COLORS[i % COLORS.length]}, ${COLORS[i % COLORS.length]}80);\\\"></div>\\n      <div class=\\\"bar-label\\\" title=\\\"${state.touchpoints[i].name}\\\">${state.touchpoints[i].name}</div>\\n    `;\\n    container.appendChild(col);\\n  });\\n}\\n\\nfunction renderExplanation() {\\n  const el = document.getElementById('explanation');\\n  const info = MODEL_EXPLANATIONS[state.model];\\n  el.innerHTML = `${info.desc}<br><br><span style=\\\"color:var(--orange);\\\">Bias:</span> ${info.bias}`;\\n}\\n\\nfunction renderCompare() {\\n  const table = document.getElementById('compare-table');\\n  const all = calcAllModels(state.touchpoints, state.decayHalfLife, state.customWeights);\\n  const models = ['first-touch', 'last-touch', 'linear', 'time-decay', 'u-shaped', 'w-shaped'];\\n\\n  let html = '<tr><th>Touchpoint</th>';\\n  for (const m of models) html += `<th>${MODEL_EXPLANATIONS[m].short}</th>`;\\n  html += '</tr>';\\n\\n  state.touchpoints.forEach((tp, i) => {\\n    const isActive = state.model !== 'custom';\\n    html += `<tr>`;\\n    html += `<td><span style=\\\"color:${COLORS[i % COLORS.length]};\\\">&#9679;</span> ${tp.name}</td>`;\\n    for (const m of models) {\\n      const v = (all[m][i] * 100).toFixed(1);\\n      const isCurrent = m === state.model;\\n      html += `<td style=\\\"${isCurrent ? 'color:var(--accent); font-weight:700;' : ''}\\\">${v}%</td>`;\\n    }\\n    html += '</tr>';\\n  });\\n\\n  // Winner row\\n  html += '<tr style=\\\"border-top:2px solid var(--border);\\\"><td style=\\\"font-family:system-ui; color:var(--muted);\\\">Top Channel</td>';\\n  for (const m of models) {\\n    const credits = all[m];\\n    const maxIdx = credits.indexOf(Math.max(...credits));\\n    const isCurrent = m === state.model;\\n    html += `<td style=\\\"color:${COLORS[maxIdx % COLORS.length]}; ${isCurrent ? 'font-weight:700;' : ''}\\\">${state.touchpoints[maxIdx].name}</td>`;\\n  }\\n  html += '</tr>';\\n\\n  table.innerHTML = html;\\n}\\n\\nfunction renderCustomWeights() {\\n  const section = document.getElementById('custom-section');\\n  const container = document.getElementById('custom-weights');\\n  if (state.model !== 'custom') {\\n    section.classList.add('hidden');\\n    return;\\n  }\\n  section.classList.remove('hidden');\\n  container.innerHTML = '';\\n\\n  while (state.customWeights.length < state.touchpoints.length) state.customWeights.push(1);\\n  while (state.customWeights.length > state.touchpoints.length) state.customWeights.pop();\\n\\n  state.touchpoints.forEach((tp, i) => {\\n    const row = document.createElement('div');\\n    row.style.cssText = 'display:flex; align-items:center; gap:6px; margin-bottom:4px;';\\n    row.innerHTML = `\\n      <span class=\\\"dot\\\" style=\\\"background:${COLORS[i % COLORS.length]}; width:8px; height:8px; border-radius:50; display:inline-block;\\\"></span>\\n      <span style=\\\"font-size:0.75rem; flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;\\\">${tp.name}</span>\\n      <input type=\\\"number\\\" min=\\\"0\\\" max=\\\"100\\\" value=\\\"${state.customWeights[i]}\\\" style=\\\"width:55px;\\\"\\n        onchange=\\\"state.customWeights[${i}]=parseFloat(this.value)||0; updateAll();\\\">\\n    `;\\n    container.appendChild(row);\\n  });\\n}\\n\\nfunction renderPrompt() {\\n  const el = document.getElementById('prompt-output');\\n  const credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n  const info = MODEL_EXPLANATIONS[state.model];\\n  const n = state.touchpoints.length;\\n\\n  if (n === 0) {\\n    el.textContent = 'Add touchpoints to generate a prompt.';\\n    return;\\n  }\\n\\n  const sorted = credits\\n    .map((c, i) => ({ name: state.touchpoints[i].name, credit: c }))\\n    .sort((a, b) => b.credit - a.credit);\\n\\n  const top = sorted[0];\\n  const bottom = sorted[sorted.length - 1];\\n\\n  const journey = state.touchpoints.map(tp => tp.name).join(' -> ');\\n\\n  let parts = [];\\n  parts.push(`I'm analyzing a ${n}-step customer journey using the ${info.short} attribution model.`);\\n  parts.push(`\\\\nJourney: ${journey}`);\\n  parts.push(`\\\\nCredit distribution:`);\\n  sorted.forEach(s => {\\n    parts.push(`  ${s.name}: ${(s.credit * 100).toFixed(1)}%`);\\n  });\\n\\n  if (state.model === 'time-decay') {\\n    parts.push(`\\\\nDecay half-life: ${state.decayHalfLife} days`);\\n  }\\n\\n  parts.push(`\\\\nThe ${info.short} model ${top.credit > 0.5 ? 'heavily favors' : 'gives the most credit to'} \\\"${top.name}\\\" (${(top.credit*100).toFixed(1)}%).`);\\n\\n  if (n > 2) {\\n    parts.push(`\\\"${bottom.name}\\\" gets the least credit at ${(bottom.credit*100).toFixed(1)}%.`);\\n  }\\n\\n  parts.push(`\\\\nHelp me understand: Is ${info.short} the right model for this journey? What would change if I used a different model? Which touchpoints might be over- or under-valued?`);\\n\\n  el.textContent = parts.join('\\\\n');\\n}\\n\\n// --- Actions ---\\nf