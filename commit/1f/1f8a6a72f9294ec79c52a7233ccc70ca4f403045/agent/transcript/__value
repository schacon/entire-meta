; margin-right: 6px; display: flex; align-items: center; justify-content: center; font-size: 8px; font-weight: 700; }\\n  .lo-h { color: var(--human); }\\n  .lo-a { color: var(--agent); }\\n  .lo-b { color: var(--text3); }\\n  .lc { flex: 1; white-space: pre; }\\n  .callout { padding: 10px 14px; background: var(--bg); border-radius: 5px; border-left: 3px solid var(--accent); font-size: 12px; line-height: 1.6; color: var(--text2); }\\n  .callout code { font-family: var(--mono); color: var(--accent); font-size: 11px; }\\n  .calc { font-family: var(--mono); font-size: 11px; line-height: 1.8; }\\n  .cs { margin-bottom: 10px; }\\n  .ct { color: var(--accent); font-weight: 600; margin-bottom: 2px; }\\n  .cx { color: var(--text2); padding-left: 14px; }\\n  .cx .v { color: var(--text); }\\n  .cx .hv { color: var(--human); }\\n  .cx .av { color: var(--agent); }\\n  .cx .op { color: var(--text3); }\\n  .cx .rv { color: var(--removed); }\\n  .result-box { margin-top: 8px; padding: 12px; background: var(--bg); border-radius: 5px; border: 1px solid var(--border); }\\n  .big-pct { font-size: 28px; font-weight: 700; font-family: var(--mono); }\\n  .pct-bar { height: 6px; border-radius: 3px; background: var(--bg3); overflow: hidden; margin-top: 6px; display: flex; }\\n  .pf-a { background: var(--agent); transition: width 0.4s; }\\n  .pf-h { background: var(--human); transition: width 0.4s; }\\n  .vtabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); }\\n  .vtab { padding: 8px 16px; font-size: 12px; cursor: pointer; color: var(--text2); border-bottom: 2px solid transparent; transition: all 0.15s; }\\n  .vtab:hover { color: var(--text); }\\n  .vtab.active { color: var(--text); border-bottom-color: var(--accent); }\\n  .vc { display: none; }\\n  .vc.active { display: block; }\\n  .tree-dia { display: flex; align-items: center; justify-content: center; gap: 24px; padding: 16px; flex-wrap: wrap; }\\n  .tnode { text-align: center; }\\n  .tbox { padding: 8px 16px; border-radius: 6px; border: 2px solid var(--border); font-family: var(--mono); font-size: 12px; margin-bottom: 3px; transition: all 0.3s; }\\n  .tbox.hl { border-color: var(--accent); box-shadow: 0 0 10px rgba(210,168,255,0.2); }\\n  .tlbl { font-size: 9px; color: var(--text3); }\\n  .tarr { color: var(--text3); font-size: 18px; }\\n  .tarrl { font-size: 9px; color: var(--text3); text-align: center; max-width: 90px; }\\n  .lifo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }\\n  .lifo-p { background: var(--bg); border-radius: 5px; padding: 10px; border: 1px solid var(--border); }\\n  .lifo-p h4 { font-size: 11px; margin-bottom: 6px; color: var(--text2); }\\n  .ll { display: flex; align-items: center; gap: 6px; padding: 3px 6px; border-radius: 3px; margin-bottom: 2px; font-family: var(--mono); font-size: 11px; cursor: pointer; transition: all 0.15s; }\\n  .ll:hover { opacity: 0.8; }\\n  .ll.hl { background: var(--human-bg); }\\n  .ll.al { background: var(--agent-bg); }\\n  .ll.struck { text-decoration: line-through; opacity: 0.3; }\\n  .lchip { font-size: 8px; padding: 1px 4px; border-radius: 2px; font-weight: 700; }\\n  .lr { margin-top: 10px; padding: 8px; background: var(--bg2); border-radius: 5px; font-family: var(--mono); font-size: 10px; line-height: 1.7; white-space: pre-wrap; }\\n  .legend { display: flex; gap: 14px; font-size: 10px; color: var(--text2); }\\n  .legend-i { display: flex; align-items: center; gap: 3px; }\\n  .legend-d { width: 8px; height: 8px; border-radius: 2px; }\\n  ::-webkit-scrollbar { width: 5px; }\\n  ::-webkit-scrollbar-track { background: transparent; }\\n  ::-webkit-scrollbar-thumb { background: var(--bg3); border-radius: 3px; }\\n</style>\\n</head>\\n<body>\\n<div class=\\\"app\\\">\\n  <div class=\\\"header\\\">\\n    <h1>Code Attribution Playground</h1>\\n    <span class=\\\"sub\\\">How Entire CLI tracks human vs AI code contributions</span>\\n    <div style=\\\"flex:1\\\"></div>\\n    <div class=\\\"legend\\\">\\n      <span class=\\\"legend-i\\\"><span class=\\\"legend-d\\\" style=\\\"background:var(--base)\\\"></span> Base</span>\\n      <span class=\\\"legend-i\\\"><span class=\\\"legend-d\\\" style=\\\"background:var(--human)\\\"></span> Human</span>\\n      <span class=\\\"legend-i\\\"><span class=\\\"legend-d\\\" style=\\\"background:var(--agent)\\\"></span> Agent</span>\\n    </div>\\n  </div>\\n\\n  <div class=\\\"sidebar\\\">\\n    <div class=\\\"sec\\\">\\n      <div class=\\\"sec-title\\\">Scenarios</div>\\n      <div class=\\\"preset-grid\\\" id=\\\"presets\\\"></div>\\n    </div>\\n    <div class=\\\"sec\\\">\\n      <div class=\\\"sec-title\\\">Session Timeline</div>\\n      <div class=\\\"timeline\\\" id=\\\"timeline\\\"></div>\\n      <div class=\\\"nav\\\">\\n        <button id=\\\"prevBtn\\\" onclick=\\\"prev()\\\">&#9664; Prev</button>\\n        <button id=\\\"nextBtn\\\" onclick=\\\"next()\\\">Next &#9654;</button>\\n      </div>\\n    </div>\\n    <div class=\\\"sec\\\" id=\\\"fileSection\\\" style=\\\"margin-top:4px\\\">\\n      <div class=\\\"sec-title\\\">File</div>\\n      <div class=\\\"file-tabs\\\" id=\\\"fileTabs\\\"></div>\\n    </div>\\n  </div>\\n\\n  <div class=\\\"main\\\">\\n    <div id=\\\"callout\\\" class=\\\"callout\\\"></div>\\n    <div class=\\\"vtabs\\\">\\n      <div class=\\\"vtab active\\\" data-v=\\\"code\\\" onclick=\\\"switchView('code',this)\\\">Code View</div>\\n      <div class=\\\"vtab\\\" data-v=\\\"trees\\\" onclick=\\\"switchView('trees',this)\\\">Git Trees</div>\\n      <div class=\\\"vtab\\\" data-v=\\\"lifo\\\" onclick=\\\"switchView('lifo',this)\\\">LIFO Demo</div>\\n    </div>\\n\\n    <div class=\\\"vc active\\\" id=\\\"v-code\\\">\\n      <div class=\\\"panel\\\">\\n        <div class=\\\"panel-hdr\\\"><span id=\\\"codeTitle\\\">main.go</span><div style=\\\"flex:1\\\"></div><span id=\\\"codeState\\\" style=\\\"font-size:10px;color:var(--text3)\\\"></span></div>\\n        <div class=\\\"panel-body\\\"><div class=\\\"code-view\\\" id=\\\"codeView\\\"></div></div>\\n      </div>\\n      <div class=\\\"panel\\\" style=\\\"margin-top:12px\\\">\\n        <div class=\\\"panel-hdr\\\">Attribution Calculation</div>\\n        <div class=\\\"panel-body\\\"><div id=\\\"calcView\\\" class=\\\"calc\\\"></div></div>\\n      </div>\\n    </div>\\n\\n    <div class=\\\"vc\\\" id=\\\"v-trees\\\">\\n      <div class=\\\"panel\\\">\\n        <div class=\\\"panel-hdr\\\">Three-Tree Model</div>\\n        <div class=\\\"panel-body\\\">\\n          <div class=\\\"callout\\\" style=\\\"border-left-color:var(--agent);margin-bottom:12px\\\">\\n            Attribution compares three git trees: <code>baseTree</code> (session start), <code>shadowTree</code> (last checkpoint on shadow branch), and <code>headTree</code> (worktree at commit). The shadow branch captures agent work + any user edits baked into checkpoints.\\n          </div>\\n          <div class=\\\"tree-dia\\\" id=\\\"treeDia\\\"></div>\\n          <div style=\\\"margin-top:16px\\\" id=\\\"treeDiffs\\\" class=\\\"calc\\\"></div>\\n        </div>\\n      </div>\\n    </div>\\n\\n    <div class=\\\"vc\\\" id=\\\"v-lifo\\\">\\n      <div class=\\\"panel\\\">\\n        <div class=\\\"panel-hdr\\\">LIFO Heuristic: Per-File Pool Tracking</div>\\n        <div class=\\\"panel-body\\\">\\n          <div class=\\\"callout\\\" style=\\\"margin-bottom:12px\\\">\\n            When a user removes lines, who originally wrote them? The CLI uses a <strong>LIFO heuristic</strong>: assume users modify their <em>own</em> recent additions first. Click lines below to \\\"remove\\\" them and see how attribution changes. Compare <strong>with</strong> vs <strong>without</strong> per-file tracking.\\n          </div>\\n          <div class=\\\"lifo-grid\\\">\\n            <div class=\\\"lifo-p\\\"><h4>main.go &mdash; Click lines to remove</h4><div id=\\\"lifoLines\\\"></div></div>\\n            <div class=\\\"lifo-p\\\"><h4>LIFO Attribution Impact</h4><div id=\\\"lifoResult\\\" class=\\\"lr\\\"></div></div>\\n          </div>\\n          <div class=\\\"lifo-grid\\\" style=\\\"margin-top:12px\\\">\\n            <div class=\\\"lifo-p\\\"><h4 style=\\\"color:var(--agent)\\\">With Per-File Tracking (actual)</h4><div id=\\\"lifoWith\\\" class=\\\"lr\\\"></div></div>\\n            <div class=\\\"lifo-p\\\"><h4 style=\\\"color:var(--removed)\\\">Without Per-File Tracking (naive)</h4><div id=\\\"lifoWithout\\\" class=\\\"lr\\\"></div></div>\\n          </div>\\n        </div>\\n      </div>\\n    </div>\\n  </div>\\n\\n  <div class=\\\"prompt-bar\\\">\\n    <pre id=\\\"promptOut\\\"></pre>\\n    <button class=\\\"copy-btn\\\" onclick=\\\"copyPrompt()\\\">Copy</button>\\n  </div>\\n</div>\\n\\n<script>\\nconst S = { preset:'mixed', step:0, file:'main.go', view:'code', lifoRm:new Set() };\\n\\nconst P = {\\n  simple: {\\n    name:'Agent Only', desc:'Agent writes everything, no human edits', pct:'100%',\\n    files:{ 'main.go':{ base:[\\n      {t:'package main',o:'base'},{t:'',o:'base'},{t:'func main() {',o:'base'},{t:'}',o:'base'}\\n    ]}},\\n    steps:[\\n      {l:'Session start',g:'s',d:'Base commit established. File has 4 lines of boilerplate.'},\\n      {l:'Prompt submitted',g:'s',d:'<code>CalculatePromptAttribution()</code> runs. No user edits to capture &mdash; UserLinesAdded=0, UserAddedPerFile={}.'},\\n      {l:'Agent writes code',g:'a',d:'Agent adds 8 lines: imports, fmt.Println, and a helper function. Checkpoint saved to shadow branch.',\\n        acts:{'main.go':{add:[\\n          {a:1,ls:[{t:'import \\\"fmt\\\"',o:'agent'}]},\\n          {a:3,ls:[{t:'    fmt.Println(\\\"Hello\\\")',o:'agent'},{t:'    result := compute(42)',o:'agent'},{t:'    fmt.Println(result)',o:'agent'}]},\\n          {a:99,ls:[{t:'',o:'agent'},{t:'func compute(n int) int {',o:'agent'},{t:'    return n * 2',o:'agent'},{t:'}',o:'agent'}]}\\n        ]}}},\\n      {l:'User commits',g:'s',d:'<code>CalculateAttributionWithAccumulated()</code>: Agent wrote all 8 new lines. No human edits. Result: <strong>100% agent</strong>.'}\\n    ]\\n  },\\n  mixed: {\\n    name:'Mixed Contributions', desc:'Both agent and human contribute code', pct:'~60%',\\n    files:{ 'main.go':{ base:[\\n      {t:'package main',o:'base'},{t:'',o:'base'},{t:'func main() {',o:'base'},{t:'}',o:'base'}\\n    ]}},\\n    steps:[\\n      {l:'Session start',g:'s',d:'Base commit: minimal main.go with 4 lines.'},\\n      {l:'User adds code',g:'h',d:'Human adds 3 lines: an import and two print statements.',\\n        acts:{'main.go':{add:[\\n          {a:1,ls:[{t:'import \\\"fmt\\\"',o:'human'}]},\\n          {a:3,ls:[{t:'    fmt.Println(\\\"starting\\\")',o:'human'},{t:'    fmt.Println(\\\"ready\\\")',o:'human'}]}\\n        ]}}},\\n      {l:'Prompt submitted',g:'s',d:'<code>CalculatePromptAttribution()</code> captures: UserLinesAdded=<span class=\\\"hv\\\">3</span>, UserAddedPerFile={\\\"main.go\\\": <span class=\\\"hv\\\">3</span>}. These edits are recorded <em>before</em> the agent runs.'},\\n      {l:'Agent writes code',g:'a',d:'Agent adds 6 lines: error handling, a helper function. Shadow branch checkpoint saved.',\\n        acts:{'main.go':{add:[\\n          {a:2,ls:[{t:'import \\\"os\\\"',o:'agent'}]},\\n          {a:6,ls:[{t:'    if err := run(); err != nil {',o:'agent'},{t:'        os.Exit(1)',o:'agent'},{t:'    }',o:'agent'}]},\\n          {a:99,ls:[{t:'',o:'agent'},{t:'func run() error {',o:'agent'},{t:'    return nil',o:'agent'}]}\\n        ]}}},\\n      {l:'User makes final edit',g:'h',d:'Human adds 1 more line after agent\\\\'s work.',\\n        acts:{'main.go':{add:[{a:99,ls:[{t:'}',o:'human'}]}]}}},\\n      {l:'User commits',g:'s',d:'<code>CalculateAttributionWithAccumulated()</code>: base&rarr;shadow=9 lines (3 human + 6 agent). Accumulated user=3, so agent=6. Post-checkpoint: +1 human. Total: 6+4=10. <strong>Agent: 60%</strong>.'}\\n    ]\\n  },\\n  heavy_edit: {\\n    name:'Heavy Editing', desc:'Human rewrites most of agent\\\\'s code', pct:'~25%',\\n    files:{ 'main.go':{ base:[\\n      {t:'package main',o:'base'},{t:'',o:'base'},{t:'import \\\"fmt\\\"',o:'base'},{t:'',o:'base'},\\n      {t:'func main() {',o:'base'},{t:'    fmt.Println(\\\"hello\\\")',o:'base'},{t:'}',o:'base'}\\n    ]}},\\n    steps:[\\n      {l:'Session start',g:'s',d:'Base commit: simple hello-world program, 7 lines.'},\\n      {l:'Prompt submitted',g:'s',d:'<code>CalculatePromptAttribution()</code>: no user edits yet. UserAddedPerFile={}.'},\\n      {l:'Agent writes code',g:'a',d:'Agent adds 8 lines: a struct, constructor, and method. Shadow checkpoint saved.',\\n        acts:{'main.go':{add:[\\n          {a:7,ls:[{t:'',o:'agent'},{t:'type Server struct {',o:'agent'},{t:'    port int',o:'agent'},{t:'}',o:'agent'},\\n          {t:'',o:'agent'},{t:'func NewServer() *Server {',o:'agent'},{t:'    return &Server{port: 8080}',o:'agent'},{t:'}',o:'agent'}]}\\n        ]}}},\\n      {l:'User rewrites agent code',g:'h',d:'Human removes 6 of 8 agent lines, replaces with own implementation. Per-file LIFO: user had 0 prior adds to main.go, so all 6 removals target agent lines.',\\n        acts:{'main.go':{rm:[8,9,10,11,12,13],add:[\\n          {a:7,ls:[{t:'',o:'human'},{t:'type App struct {',o:'human'},{t:'    name string',o:'human'},{t:'    port int',o:'human'},{t:'}',o:'human'},{t:'',o:'human'}]}\\n        ]}}},\\n      {l:'User commits',g:'s',d:'Agent added 8, user removed 6 agent lines (LIFO: 0 self-mods). Surviving agent=2, user added=6. Total=8. <strong>Agent: 25%</strong>.'}\\n    ]\\n  },\\n  self_mod: {\\n    name:'Self-Modification', desc:'User edits own code; LIFO preserves agent credit', pct:'~67%',\\n    files:{ 'main.go':{ base:[\\n      {t:'package main',o:'base'},{t:'',o:'base'},{t:'func main() {',o:'base'},{t:'}',o:'base'}\\n    ]}},\\n    steps:[\\n      {l:'Session start',g:'s',d:'Base commit: minimal main.go.'},\\n      {l:'User adds 5 lines',g:'h',d:'Human writes 5 lines of setup code.',\\n        acts:{'main.go':{add:[\\n          {a:1,ls:[{t:'import \\\"fmt\\\"',o:'human'}]},\\n          {a:3,ls:[{t:'    name := \\\"world\\\"',o:'human'},{t:'    greeting := \\\"hello\\\"',o:'human'},{t:'    msg := greeting + \\\" \\\" + name',o:'human'},{t:'    fmt.Println(msg)',o:'human'}]}\\n        ]}}},\\n      {l:'Prompt submitted',g:'s',d:'<code>CalculatePromptAttribution()</code>: UserLinesAdded=<span class=\\\"hv\\\">5</span>, UserAddedPerFile={\\\"main.go\\\": <span class=\\\"hv\\\">5</span>}. This per-file data is <strong>critical</strong> for the LIFO heuristic.'},\\n      {l:'Agent adds 10 lines',g:'a',d:'Agent adds error handling and a helper function. Shadow checkpoint saved.',\\n        acts:{'main.go':{add:[\\n          {a:2,ls:[{t:'import \\\"os\\\"',o:'agent'}]},\\n          {a:8,ls:[{t:'    if err := validate(msg); err != nil {',o:'agent'},{t:'        fmt.Fprintf(os.Stderr, \\\"error: %v\\\\\\\\n\\\", err)',o:'agent'},{t:'        os.Exit(1)',o:'agent'},{t:'    }',o:'agent'}]},\\n          {a:99,ls:[{t:'',o:'agent'},{t:'func validate(s string) error {',o:'agent'},{t:'    if s == \\\"\\\" {',o:'agent'},{t:'        return fmt.Errorf(\\\"empty\\\")',o:'agent'},{t:'    }',o:'agent'},{t:'    return nil',o:'agent'}]}\\n        ]}}},\\n      {l:'User modifies own 3 lines',g:'h',d:'Human removes 3 of <em>their own</em> lines and replaces with 3 new ones. LIFO: user added 5 to main.go, removed 3 &rarr; selfMod=min(3,5)=<strong>3</strong>. Agent lines untouched!',\\n        acts:{'main.go':{rm:[5,6,7],add:[\\n          {a:4,ls:[{t:'    name := \\\"Gopher\\\"',o:'human'},{t:'    greeting := \\\"Hi\\\"',o:'human'},{t:'    msg := fmt.Sprintf(\\\"%s, %s!\\\", greeting, name)',o:'human'}]}\\n        ]}}},\\n      {l:'User commits',g:'s',d:'LIFO: removed 3 from main.go, user added 5 prior &rarr; selfMod=min(3,5)=3, humanModifiedAgent=0. Agent lines=10. Total=10+5=15. <strong>Agent: 66.7%</strong>. Without LIFO, it would incorrectly be 46.7%!'}\\n    ]\\n  },\\n  multi_file: {\\n    name:'Multi-File', desc:'Per-file tracking across multiple files', pct:'~63%',\\n    files:{\\n      'main.go':{ base:[{t:'package main',o:'base'},{t:'',o:'base'},{t:'func main() {',o:'base'},{t:'}',o:'base'}]},\\n      'utils.go':{ base:[{t:'package main',o:'base'}]}\\n    },\\n    steps:[\\n      {l:'Session start',g:'s',d:'Base commit: two files &mdash; main.go (4 lines) and utils.go (1 line).'},\\n      {l:'User edits main.go',g:'h',d:'Human adds 3 lines to main.go only.',\\n        acts:{'main.go':{add:[{a:3,ls:[{t:'    result := add(1, 2)',o:'human'},{t:'    println(result)',o:'human'},{t:'    println(\\\"done\\\")',o:'human'}]}]}}},\\n      {l:'Prompt submitted',g:'s',d:'<code>CalculatePromptAttribution()</code>: UserAddedPerFile={\\\"main.go\\\": <span class=\\\"hv\\\">3</span>}. Human only touched main.go, not utils.go.'},\\n      {l:'Agent writes both files',g:'a',d:'Agent adds 3 lines to main.go and 5 to utils.go. Shadow checkpoint captures both.',\\n        acts:{\\n          'main.go':{add:[{a:6,ls:[{t:'    diff := subtract(5, 3)',o:'agent'},{t:'    println(diff)',o:'agent'},{t:'    println(\\\"computed\\\")',o:'agent'}]}]},\\n          'utils.go':{add:[{a:1,ls:[{t:'',o:'agent'},{t:'func add(a, b int) int {',o:'agent'},{t:'    return a + b',o:'agent'},{t:'}',o:'agent'},{t:'',o:'agent'}]}]}\\n        }},\\n      {l:'User edits both files',g:'h',d:'Human removes 2 lines from main.go (own code) and adds 3 to utils.go. LIFO per-file: main.go removals=2, prior adds=3 &rarr; selfMod=min(2,3)=2.',\\n        acts:{\\n          'main.go':{rm:[5,6]},\\n          'utils.go':{add:[{a:6,ls:[{t:'func subtract(a, b int) int {',o:'human'},{t:'    return a - b',o:'human'},{t:'}',o:'human'}]}]}\\n        }},\\n      {l:'User commits',g:'s',d:'Per-file LIFO: main.go selfMod=min(2,3)=2, utils.go selfMod=0. Agent lines=8, user added=4. Total=12. <strong>Agent: 62.5%</strong>.'}\\n    ]\\n  }\\n};\\n\\nlet lines = {};\\nlet pAs = [];\\nlet agentFiles = new Set();\\n\\nfunction reset() {\\n  const p = P[S.preset];\\n  lines = {}; pAs = []; agentFiles = new Set();\\n  for (const [f,d] of Object.entries(p.files)) lines[f] = d.base.map(x=>({...x}));\\n}\\n\\nfunction applyStep(i) {\\n  const st = P[S.preset].steps[i];\\n  if (!st) return;\\n  for (const [f,a] of Object.entries(st.acts||{})) {\\n    if (!lines[f]) lines[f] = [];\\n    let ls = lines[f];\\n    if (a.rm) { const r=[...a.rm].sort((a,b)=>b-a); for(const idx of r) if(idx-1<ls.length) ls.splice(idx-1,1); }\\n    if (a.add) { const sorted=[...a.add].sort((a,b)=>b.a-a.a); for(const ad of sorted){ const p=ad.a>=99?ls.length:Math.min(ad.a,ls.length); ls.splice(p,0,...ad.ls.map(x=>({...x}))); } }\\n    if (st.g==='a') agentFiles.add(f);\\n    lines[f] = ls;\\n  }\\n  if (st.g==='s' && st.l.includes('Prompt')) {\\n    const pa = {userAdded:0, perFile:{}};\\n    for (const f of Object.keys(P[S.preset].files)) {\\n      const n = (lines[f]||[]).filter(x=>x.o==='human').length;\\n      if (n>0) { pa.userAdded+=n; pa.perFile[f]=n; }\\n    }\\n    pAs.push(pa);\\n  }\\n}\\n\\nfunction simTo(step) { reset(); for(let i=0;i<=step;i++) applyStep(i); }\\n\\nfunction lastAgentStep() { const ss=P[S.preset].steps; for(let i=S.step;i>=0;i--) if(ss[i].g==='a') return i; return -1; }\\n\\nfunction calcAttr() {\\n  const p=P[S.preset], files=Object.keys(p.files);\\n  let aL=0,hL=0;\\n  for(const f of files) for(const l of(lines[f]||[])) { if(l.o==='agent')aL++; else if(l.o==='human')hL++; }\\n\\n  let accU=0, accPF={};\\n  for(const pa of pAs) { accU+=pa.userAdded; for(const[f,n]of Object.entries(pa.perFile)) accPF[f]=(accPF[f]||0)+n; }\\n\\n  const las=lastAgentStep();\\n  let shA=0, shH=0;\\n  if(las>=0){\\n    const savedLines={...lines}, savedPAs=[...pAs], savedAF=new Set(agentFiles);\\n    simTo(las);\\n    for(const f of files) for(const l of(lines[f]||[])) { if(l.o==='agent')shA++; else if(l.o==='human')shH++; }\\n    lines={...savedLines}; pAs=savedPAs; agentFiles=savedAF;\\n    simTo(S.step);\\n  }\\n\\n  const b2s=shA+shH;\\n  const tAgentAdded=Math.max(0,b2s-accU);\\n  const postUA=Math.max(0,hL-accU);\\n  let postUR=0, postURPF={};\\n  for(const f of files){ const cur=(lines[f]||[]).filter(x=>x.o==='human').length; const acc=accPF[f]||0; if(cur<acc){ const r=acc-cur; postUR+=r; postURPF[f]=r; } }\\n\\n  let selfMod=0;\\n  for(const[f,r]of Object.entries(postURPF)) selfMod+=Math.min(r,accPF[f]||0);\\n\\n  const tHM=Math.min(hL+postUA,postUR);\\n  const hMA=Math.max(0,tHM-selfMod);\\n  const pUA=Math.max(0,hL-tHM);\\n  const pUR=Math.max(0,postUR-tHM);\\n  const aInC=Math.max(0,tAgentAdded-pUR-hMA);\\n  let tC=aInC+pUA; if(tC<=0) tC=Math.max(0,tAgentAdded);\\n  const pct=tC>0?(aInC/tC*100):0;\\n\\n  return {aL,hL,accU,accPF,b2s,tAgentAdded,postUA,postUR,postURPF,selfMod,hMA,pUA,pUR,aInC,tC,pct,shA,shH};\\n}\\n\\nfunction esc(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }\\n\\nfunction render() {\\n  // Presets\\n  document.getElementById('presets').innerHTML = Object.entries(P).map(([k,v])=>\\n    `<button class=\\\"preset-btn ${S.preset===k?'active':''}\\\" onclick=\\\"selPreset('${k}')\\\"><span>${v.name}</span><span class=\\\"pct\\\">${v.pct}</span></button>`\\n  ).join('');\\n\\n  // Timeline\\n  const ss=P[S.preset].steps;\\n  document.getElementById('timeline').innerHTML = ss.map((s,i)=>{\\n    const cls=i===S.step?'active':(i<S.step?'done':'');\\n    const tc=s.g==='h'?'tag-h':s.g==='a'?'tag-a':'tag-s';\\n    return `<div class=\\\"step ${cls}\\\" onclick=\\\"goTo(${i})\\\"><span class=\\\"dot\\\"></span><span class=\\\"step-label\\\">${s.l}</span><span class=\\\"tag ${tc}\\\">${s.g==='h'?'human':s.g==='a'?'agent':'system'}</span></div>`;\\n  }).join('');\\n  document.getElementById('prevBtn').disabled=S.step===0;\\n  document.getElementById('nextBtn').disabled=S.step===ss.length-1;\\n\\n  // File tabs\\n  const files=Object.keys(P[S.preset].files);\\n  document.getElementById('fileSection').style.display=files.length>1?'block':'none';\\n  document.getElementById('fileTabs').innerHTML=files.map(f=>\\n    `<div class=\\\"ftab ${S.file===f?'active':''}\\\" onclick=\\\"selFile('${f}')\\\">${f}</div>`\\n  ).join('');\\n\\n  // Callout\\n  document.getElementById('callout').innerHTML=ss[S.step].d;\\n\\n  // Code view\\n  const ls=lines[S.file]||[];\\n  document.getElementById('codeTitle').textContent=S.file;\\n  const st=ss[S.step];\\n  document.getElementById('codeState').textContent=st.g==='a'?'shadow branch (checkpoint)':st.l.toLowerCase().includes('commit')?'HEAD (commit time)':'working tree';\\n  document.getElementById('codeView').innerHTML=ls.length===0?'<div style=\\\"color:var(--text3);padding:16px;text-align:center\\\">Empty file</div>':\\n    ls.map((l,i)=>{\\n      const ic=l.o==='human'?'<span class=\\\"lo-h\\\">H</span>':l.o==='agent'?'<span class=\\\"lo-a\\\">A</span>':'<span class=\\\"lo-b\\\">&middot;</span>';\\n      return `<div class=\\\"cl ${l.o}\\\"><span class=\\\"ln\\\">${i+1}</span><span class=\\\"lo\\\">${ic}</span><span class=\\\"lc\\\">${esc(l.t)}</span></div>`;\\n    }).join('');\\n\\n  // Calc\\n  renderCalc();\\n  renderTrees();\\n  renderLIFO();\\n  updatePrompt();\\n}\\n\\nfunction renderCalc() {\\n  const el=document.getElementById('calcView');\\n  const las=lastAgentStep();\\n  if(las<0){\\n    const hc=Object.values(lines).flat().filter(l=>l.o==='human').length;\\n    const ac=Object.values(lines).flat().filter(l=>l.o==='agent').length;\\n    el.innerHTML=`<div class=\\\"cs\\\"><div class=\\\"ct\\\">Current State</div><div class=\\\"cx\\\">Human lines: <span class=\\\"hv\\\">${hc}</span></div><div class=\\\"cx\\\">Agent lines: <span class=\\\"av\\\">${ac}</span></div><div class=\\\"cx\\\" style=\\\"color:var(--text3)\\\">Full calculation shown after agent runs</div></div>`;\\n    return;\\n  }\\n  const a=calcAttr();\\n  let h='';\\n  if(pAs.length>0){\\n    h+=`<div class=\\\"cs\\\"><div class=\\\"ct\\\">Prompt Attributions (accumulated)</div>`;\\n    pAs.forEach((pa,i)=>{ const pf=Object.entries(pa.perFile).map(([f,n])=>`${f}:${n}`).join(', ');\\n      h+=`<div class=\\\"cx\\\">PA #${i+1}: <span class=\\\"hv\\\">+${pa.userAdded}</span> user lines${pf?` <span class=\\\"op\\\">(${pf})</span>`:''};</div>`; });\\n    h+=`</div>`;\\n  }\\n  h+=`<div class=\\\"cs\\\"><div class=\\\"ct\\\">Step 1: base &rarr; shadow diff</div><div class=\\\"cx\\\">Total in shadow: <span class=\\\"v\\\">${a.b2s}</span> lines <span class=\\\"op\\\">(${a.shA} agent + ${a.shH} human baked in)</span></div></div>`;\\n  h+=`<div class=\\\"cs\\\"><div class=\\\"ct\\\">Step 2: Isolate agent work</div><div class=\\\"cx\\\">Agent = <span class=\\\"v\\\">${a.b2s}</span> <span class=\\\"op\\\">&minus;</span> <span class=\\\"hv\\\">${a.accU}</span> accumulated user <span class=\\\"op\\\">=</span> <span class=\\\"av\\\">${a.tAgentAdded}</span></div></div>`;\\n  h+=`<div class=\\\"cs\\\"><div class=\\\"ct\\\">Step 3: shadow &rarr; head (post-checkpoint)</div><div class=\\\"cx\\\">User added: <span class=\\\"hv\\\">+${a.postUA}</span>, removed: <span class=\\\"rv\\\">${a.postUR}</span></div></div>`;\\n  if(a.postUR>0){\\n    h+=`<div class=\\\"cs\\\"><div class=\\\"ct\\\">Step 4: LIFO self-modification</div>`;\\n    for(const[f,r]of Object.entries(a.postURPF)){ const ua=a.accPF[f]||0;\\n      h+=`<div class=\\\"cx\\\">${f}: removed <span class=\\\"rv\\\">${r}</span>, user prior adds <span class=\\\"hv\\\">${ua}</span> &rarr; selfMod=min(${r},${ua})=<span class=\\\"v\\\">${Math.min(r,ua)}</span></div>`; }\\n    h+=`<div class=\\\"cx\\\">Modified agent lines: <span class=\\\"v\\\">${a.hMA}</span></div></div>`;\\n  }\\n  h+=`<div class=\\\"cs\\\"><div class=\\\"ct\\\">Step 5: Final calculation</div>`;\\n  h+=`<div class=\\\"cx\\\">Agent in commit: <span class=\\\"av\\\">${a.aInC}</span> <span class=\\\"op\\\">= ${a.tAgentAdded} &minus; ${a.pUR} removed &minus; ${a.hMA} modified</span></div>`;\\n  h+=`<div class=\\\"cx\\\">Pure user added: <span class=\\\"hv\\\">${a.pUA}</span></div>`;\\n  h+=`<div class=\\\"cx\\\">Total committed: <span class=\\\"v\\\">${a.tC}</span></div></div>`;\\n  const hp=(100-a.pct).toFixed(1);\\n  h+=`<div class=\\\"result-box\\\"><div class=\\\"big-pct\\\"><span style=\\\"color:var(--agent)\\\">${a.pct.toFixed(1)}%</span> <span style=\\\"color:var(--text3);font-size:16px\\\">/</span> <span style=\\\"color:var(--human)\\\">${hp}%</span></div><div style=\\\"font-size:10px;color:var(--text3);margin-top:2px\\\">agent / human</div><div class=\\\"pct-bar\\\"><div class=\\\"pf-a\\\" style=\\\"width:${a.pct}%\\\"></div><div class=\\\"pf-h\\\" style=\\\"width:${hp}%\\\"></div></div></div>`;\\n  el.innerHTML=h;\\n}\\n\\nfunction renderTrees() {\\n  const las=lastAgentStep(), st=P[S.preset].steps[S.step];\\n  const bhl=S.step===0?'hl':'', shl=st.g==='a'?'hl':'', hhl=st.l.toLowerCase().includes('commit')||st.g==='h'?'hl':'';\\n  document.getElementById('treeDia').innerHTML=`\\n    <div class=\\\"tnode\\\"><div class=\\\"tbox ${bhl}\\\">baseTree</div><div class=\\\"tlbl\\\">Session start</div></div>\\n    <div style=\\\"text-align:center\\\"><div class=\\\"tarr\\\">&rarr;</div><div class=\\\"tarrl\\\">agent work + baked-in user edits</div></div>\\n    <div class=\\\"tnode\\\"><div class=\\\"tbox ${shl}\\\" style=\\\"${las<0?'opacity:0.3':''}\\\">shadowTree</div><div class=\\\"tlbl\\\">Last checkpoint</div></div>\\n    <div style=\\\"text-align:center\\\"><div class=\\\"tarr\\\">&rarr;</div><div class=\\\"tarrl\\\">post-checkpoint user edits</div></div>\\n    <div class=\\\"tnode\\\"><div class=\\\"tbox ${hhl}\\\">headTree</div><div class=\\\"tlbl\\\">Worktree / commit</div></div>`;\\n  const td=document.getElementById('treeDiffs');\\n  if(las<0){ td.innerHTML='<div style=\\\"color:var(--text3);text-align:center\\\">No checkpoint yet</div>'; return; }\\n  const a=calcAttr();\\n  td.innerHTML=`\\n    <div class=\\\"cs\\\"><div class=\\\"ct\\\">base &rarr; shadow</div><div class=\\\"cx\\\"><span class=\\\"av\\\">${a.shA}</span> agent + <span class=\\\"hv\\\">${a.shH}</span> human = <span class=\\\"v\\\">${a.b2s}</span> total</div></div>\\n    <div class=\\\"cs\\\"><div class=\\\"ct\\\">shadow &rarr; head</div><div class=\\\"cx\\\">User: <span class=\\\"hv\\\">+${a.postUA}</span> added, <span class=\\\"rv\\\">${a.postUR}</span> removed</div></div>\\n    <div class=\\\"cs\\\"><div class=\\\"ct\\\">base &rarr; head (final)</div><div class=\\\"cx\\\"><span class=\\\"av\\\">${a.aInC}</span> agent + <span class=\\\"hv\\\">${a.pUA}</span> human = <span class=\\\"v\\\">${a.tC}</span> net</div></div>`;\\n}\\n\\nfunction renderLIFO() {\\n  const ls=[\\n    {t:'func main() {',o:'base',id:0},\\n    {t:'    name := \\\"world\\\"',o:'human',id:1},\\n    {t:'    greeting := \\\"hello\\\"',o:'human',id:2},\\n    {t:'    msg := greeting + \\\" \\\" + name',o:'human',id:3},\\n    {t:'    fmt.Println(msg)',o:'human',id:4},\\n    {t:'    if err := validate(msg); err != nil {',o:'agent',id:5},\\n    {t:'        log.Fatal(err)',o:'agent',id:6},\\n    {t:'    }',o:'agent',id:7},\\n    {t:'    result := process(msg)',o:'agent',id:8},\\n    {t:'    fmt.Println(result)',o:'agent',id:9},\\n    {t:'}',o:'base',id:10},\\n  ];\\n  const hTotal=ls.filter(l=>l.o==='human').length; // 4\\n  const aTotal=ls.filter(l=>l.o==='agent').length; // 5\\n  document.getElementById('lifoLines').innerHTML=ls.filter(l=>l.o!=='base').map(l=>{\\n    const struck=S.lifoRm.has(l.id)?'struck':'';\\n    const cls=l.o==='human'?'hl':'al';\\n    const chip=l.o==='human'?'<span class=\\\"lchip\\\" style=\\\"background:var(--human-bg);color:var(--human)\\\">H</span>':'<span class=\\\"lchip\\\" style=\\\"background:var(--agent-bg);color:var(--agent)\\\">A</span>';\\n    return `<div class=\\\"ll ${cls} ${struck}\\\" onclick=\\\"togLifo(${l.id})\\\">${chip} ${esc(l.t)}</div>`;\\n  }).join('');\\n\\n  const rmH=ls.filter(l=>l.o==='human'&&S.lifoRm.has(l.id)).length;\\n  const rmA=ls.filter(l=>l.o==='agent'&&S.lifoRm.has(l.id)).leng