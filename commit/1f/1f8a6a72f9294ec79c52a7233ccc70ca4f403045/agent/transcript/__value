ion value=\\\"w-shaped\\\">W-Shaped</option>\\n   101→        <option value=\\\"custom\\\">Custom Weights</option>\\n   102→      </select>\\n   103→    </section>\\n   104→\\n   105→    <section id=\\\"decay-section\\\" class=\\\"hidden\\\">\\n   106→      <h2>Decay Half-Life</h2>\\n   107→      <div class=\\\"slider-row\\\">\\n   108→        <input type=\\\"range\\\" id=\\\"decay-slider\\\" min=\\\"1\\\" max=\\\"14\\\" value=\\\"7\\\" oninput=\\\"updateDecayLabel(); updateAll();\\\">\\n   109→        <span id=\\\"decay-label\\\">7d</span>\\n   110→      </div>\\n   111→      <label style=\\\"margin-top:4px;\\\">How quickly credit fades for older touchpoints</label>\\n   112→    </section>\\n   113→\\n   114→    <section>\\n   115→      <h2>Presets</h2>\\n   116→      <div class=\\\"presets\\\">\\n   117→        <button onclick=\\\"loadPreset('saas')\\\">SaaS Funnel</button>\\n   118→        <button onclick=\\\"loadPreset('ecommerce')\\\">E-commerce</button>\\n   119→        <button onclick=\\\"loadPreset('b2b')\\\">B2B Long Sale</button>\\n   120→        <button onclick=\\\"loadPreset('simple')\\\">Simple (3)</button>\\n   121→        <button onclick=\\\"loadPreset('content')\\\">Content Mktg</button>\\n   122→      </div>\\n   123→    </section>\\n   124→\\n   125→    <section>\\n   126→      <h2>Touchpoints</h2>\\n   127→      <div class=\\\"touchpoint-list\\\" id=\\\"tp-list\\\"></div>\\n   128→      <div class=\\\"add-row\\\" style=\\\"margin-top:6px;\\\">\\n   129→        <input type=\\\"text\\\" id=\\\"new-tp-name\\\" placeholder=\\\"Channel name...\\\" onkeydown=\\\"if(event.key==='Enter')addTouchpoint()\\\">\\n   130→        <button class=\\\"small\\\" onclick=\\\"addTouchpoint()\\\">+ Add</button>\\n   131→      </div>\\n   132→    </section>\\n   133→\\n   134→    <section id=\\\"custom-section\\\" class=\\\"hidden\\\">\\n   135→      <h2>Custom Weights</h2>\\n   136→      <div id=\\\"custom-weights\\\"></div>\\n   137→      <label style=\\\"margin-top:4px;\\\">Weights are auto-normalized to 100%</label>\\n   138→    </section>\\n   139→\\n   140→    <section>\\n   141→      <h2>View</h2>\\n   142→      <div style=\\\"display:flex; gap:4px;\\\">\\n   143→        <button id=\\\"btn-journey\\\" class=\\\"active\\\" onclick=\\\"setView('journey')\\\">Journey</button>\\n   144→        <button id=\\\"btn-compare\\\" onclick=\\\"setView('compare')\\\">Compare All</button>\\n   145→      </div>\\n   146→    </section>\\n   147→  </div>\\n   148→\\n   149→  <div class=\\\"canvas-area\\\">\\n   150→    <div class=\\\"viz\\\" id=\\\"viz\\\">\\n   151→      <div id=\\\"view-journey\\\">\\n   152→        <div class=\\\"journey\\\">\\n   153→          <div class=\\\"timeline-line\\\"></div>\\n   154→          <div id=\\\"tp-nodes\\\" style=\\\"display:flex; justify-content:space-between; position:relative; z-index:1; padding:0 10px;\\\"></div>\\n   155→        </div>\\n   156→        <div style=\\\"max-width:900px; margin:30px auto 0;\\\">\\n   157→          <h2 style=\\\"text-align:center;\\\">Credit Distribution</h2>\\n   158→          <div id=\\\"bars\\\" style=\\\"display:flex; align-items:flex-end; justify-content:center; gap:8px; height:160px; padding:0 20px; margin-top:10px;\\\"></div>\\n   159→        </div>\\n   160→        <div class=\\\"explanation-box\\\" id=\\\"explanation\\\"></div>\\n   161→      </div>\\n   162→\\n   163→      <div id=\\\"view-compare\\\" class=\\\"hidden\\\">\\n   164→        <div class=\\\"comparison\\\">\\n   165→          <h2 style=\\\"margin-bottom:10px;\\\">Model Comparison</h2>\\n   166→          <table id=\\\"compare-table\\\"></table>\\n   167→        </div>\\n   168→      </div>\\n   169→    </div>\\n   170→\\n   171→    <div class=\\\"prompt-area\\\">\\n   172→      <h2>Prompt Output</h2>\\n   173→      <button class=\\\"copy-btn\\\" onclick=\\\"copyPrompt()\\\">Copy</button>\\n   174→      <div class=\\\"prompt-text\\\" id=\\\"prompt-output\\\"></div>\\n   175→    </div>\\n   176→  </div>\\n   177→</div>\\n   178→\\n   179→<script>\\n   180→const COLORS = ['#4fc3f7','#66bb6a','#ffa726','#f06292','#ab47bc','#ffee58','#ef5350','#26a69a','#42a5f5','#8d6e63','#78909c','#dce775'];\\n   181→\\n   182→const PRESETS = {\\n   183→  saas: [\\n   184→    { name: 'Google Ad', days: 0 },\\n   185→    { name: 'Blog Post', days: 3 },\\n   186→    { name: 'Email Nurture', days: 7 },\\n   187→    { name: 'Webinar', days: 14 },\\n   188→    { name: 'Free Trial', days: 18 },\\n   189→    { name: 'Sales Demo', days: 25 },\\n   190→    { name: 'Pricing Page', days: 28 },\\n   191→  ],\\n   192→  ecommerce: [\\n   193→    { name: 'Instagram Ad', days: 0 },\\n   194→    { name: 'Product Review', days: 1 },\\n   195→    { name: 'Retargeting Ad', days: 3 },\\n   196→    { name: 'Email Coupon', days: 5 },\\n   197→    { name: 'Direct Visit', days: 6 },\\n   198→  ],\\n   199→  b2b: [\\n   200→    { name: 'LinkedIn Ad', days: 0 },\\n   201→    { name: 'Whitepaper', days: 10 },\\n   202→    { name: 'Conference', days: 30 },\\n   203→    { name: 'Case Study', days: 45 },\\n   204→    { name: 'Sales Call', days: 60 },\\n   205→    { name: 'Proposal', days: 75 },\\n   206→    { name: 'Negotiation', days: 85 },\\n   207→    { name: 'Contract', days: 90 },\\n   208→  ],\\n   209→  simple: [\\n   210→    { name: 'Awareness', days: 0 },\\n   211→    { name: 'Consideration', days: 5 },\\n   212→    { name: 'Conversion', days: 10 },\\n   213→  ],\\n   214→  content: [\\n   215→    { name: 'SEO Blog', days: 0 },\\n   216→    { name: 'YouTube Video', days: 4 },\\n   217→    { name: 'Podcast', days: 8 },\\n   218→    { name: 'Newsletter', days: 12 },\\n   219→    { name: 'Social Share', days: 14 },\\n   220→    { name: 'Landing Page', days: 15 },\\n   221→  ],\\n   222→};\\n   223→\\n   224→const MODEL_INFO = {\\n   225→  'first-touch': {\\n   226→    short: 'First Touch',\\n   227→    desc: 'First Touch gives 100% of the credit to the first interaction. It answers: \\\"What channel introduced this customer?\\\" Great for measuring awareness campaigns, but ignores everything that nurtured the lead afterward.',\\n   228→    bias: 'Overvalues top-of-funnel channels. Undervalues nurture and closing efforts.',\\n   229→  },\\n   230→  'last-touch': {\\n   231→    short: 'Last Touch',\\n   232→    desc: 'Last Touch gives 100% of the credit to the last interaction before conversion. It answers: \\\"What closed the deal?\\\" Simple and widely used (Google Analytics default), but ignores the entire journey.',\\n   233→    bias: 'Overvalues bottom-of-funnel. Undervalues awareness and consideration.',\\n   234→  },\\n   235→  'linear': {\\n   236→    short: 'Linear',\\n   237→    desc: 'Linear splits credit equally across all touchpoints. It answers: \\\"Every interaction mattered the same.\\\" Fair and simple, but unrealistic \\\\u2014 not all touches have equal impact.',\\n   238→    bias: 'Treats a passing glance the same as an hour-long demo.',\\n   239→  },\\n   240→  'time-decay': {\\n   241→    short: 'Time Decay',\\n   242→    desc: 'Time Decay gives more credit to touchpoints closer to the conversion. Uses exponential decay with a configurable half-life. Good for short sales cycles where recent interactions drive decisions.',\\n   243→    bias: 'Undervalues early awareness that planted the seed.',\\n   244→  },\\n   245→  'u-shaped': {\\n   246→    short: 'U-Shaped (40/20/40)',\\n   247→    desc: 'U-Shaped (Position-Based) gives 40% to the first touch, 40% to the last touch, and splits the remaining 20% among middle interactions. Recognizes that discovery and conversion are pivotal moments.',\\n   248→    bias: 'Middle-funnel nurturing (often the hardest work) gets minimal credit.',\\n   249→  },\\n   250→  'w-shaped': {\\n   251→    short: 'W-Shaped (30/30/30/10)',\\n   252→    desc: 'W-Shaped gives 30% to the first touch, 30% to the lead-creation midpoint, 30% to the last touch, and splits the remaining 10% among everything else. Best for B2B funnels with a distinct qualification step.',\\n   253→    bias: 'Assumes a clear midpoint exists. Less useful for short or uniform journeys.',\\n   254→  },\\n   255→  'custom': {\\n   256→    short: 'Custom',\\n   257→    desc: 'Custom Weights let you manually assign relative importance to each touchpoint. Weights are normalized to 100%. Use this to model your own attribution theory or domain expertise.',\\n   258→    bias: 'Only as good as your assumptions.',\\n   259→  },\\n   260→};\\n   261→\\n   262→let state = {\\n   263→  model: 'linear',\\n   264→  touchpoints: [],\\n   265→  customWeights: [],\\n   266→  decayHalfLife: 7,\\n   267→  view: 'journey',\\n   268→};\\n   269→\\n   270→// --- Attribution math ---\\n   271→function calcCredits(model, tps, halfLife, customW) {\\n   272→  const n = tps.length;\\n   273→  if (n === 0) return [];\\n   274→  if (n === 1) return [1];\\n   275→\\n   276→  switch (model) {\\n   277→    case 'first-touch': {\\n   278→      const c = Array(n).fill(0);\\n   279→      c[0] = 1;\\n   280→      return c;\\n   281→    }\\n   282→    case 'last-touch': {\\n   283→      const c = Array(n).fill(0);\\n   284→      c[n - 1] = 1;\\n   285→      return c;\\n   286→    }\\n   287→    case 'linear': {\\n   288→      return Array(n).fill(1 / n);\\n   289→    }\\n   290→    case 'time-decay': {\\n   291→      const maxDay = tps[n - 1].days;\\n   292→      const rawDecay = tps.map(function(tp) {\\n   293→        const daysBeforeConversion = maxDay - tp.days;\\n   294→        return Math.pow(2, -daysBeforeConversion / halfLife);\\n   295→      });\\n   296→      const sum = rawDecay.reduce(function(a, b) { return a + b; }, 0);\\n   297→      return rawDecay.map(function(v) { return v / sum; });\\n   298→    }\\n   299→    case 'u-shaped': {\\n   300→      const c = Array(n).fill(0);\\n   301→      if (n === 2) return [0.5, 0.5];\\n   302→      c[0] = 0.4;\\n   303→      c[n - 1] = 0.4;\\n   304→      const mid = 0.2 / (n - 2);\\n   305→      for (let i = 1; i < n - 1; i++) c[i] = mid;\\n   306→      return c;\\n   307→    }\\n   308→    case 'w-shaped': {\\n   309→      const c = Array(n).fill(0);\\n   310→      if (n === 2) return [0.5, 0.5];\\n   311→      if (n === 3) return [0.333, 0.334, 0.333];\\n   312→      const midIdx = Math.floor(n / 2);\\n   313→      c[0] = 0.3;\\n   314→      c[midIdx] = 0.3;\\n   315→      c[n - 1] = 0.3;\\n   316→      let others = n - 3;\\n   317→      if (others <= 0) {\\n   318→        const s = c.reduce(function(a, b) { return a + b; }, 0);\\n   319→        return c.map(function(v) { return v / s; });\\n   320→      }\\n   321→      const each = 0.1 / others;\\n   322→      for (let i = 0; i < n; i++) {\\n   323→        if (i !== 0 && i !== midIdx && i !== n - 1) c[i] = each;\\n   324→      }\\n   325→      return c;\\n   326→    }\\n   327→    case 'custom': {\\n   328→      if (!customW || customW.length !== n) return Array(n).fill(1 / n);\\n   329→      const sum = customW.reduce(function(a, b) { return a + b; }, 0);\\n   330→      if (sum === 0) return Array(n).fill(1 / n);\\n   331→      return customW.map(function(w) { return w / sum; });\\n   332→    }\\n   333→    default: return Array(n).fill(1 / n);\\n   334→  }\\n   335→}\\n   336→\\n   337→function calcAllModels(tps, halfLife, customW) {\\n   338→  var models = ['first-touch', 'last-touch', 'linear', 'time-decay', 'u-shaped', 'w-shaped'];\\n   339→  var result = {};\\n   340→  for (var i = 0; i < models.length; i++) {\\n   341→    result[models[i]] = calcCredits(models[i], tps, halfLife, customW);\\n   342→  }\\n   343→  return result;\\n   344→}\\n   345→\\n   346→// --- Safe DOM helpers ---\\n   347→function clearEl(el) { while (el.firstChild) el.removeChild(el.firstChild); }\\n   348→\\n   349→function makeEl(tag, attrs, children) {\\n   350→  var el = document.createElement(tag);\\n   351→  if (attrs) {\\n   352→    Object.keys(attrs).forEach(function(k) {\\n   353→      if (k === 'style' && typeof