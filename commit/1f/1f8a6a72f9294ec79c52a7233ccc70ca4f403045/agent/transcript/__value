s all touchpoints. It answers: \\\"Every interaction mattered the same.\\\" Fair and simple, but unrealistic \\\\u2014 not all touches have equal impact.',\\n   238→    bias: 'Treats a passing glance the same as an hour-long demo.',\\n   239→  },\\n   240→  'time-decay': {\\n   241→    short: 'Time Decay',\\n   242→    desc: 'Time Decay gives more credit to touchpoints closer to the conversion. Uses exponential decay with a configurable half-life. Good for short sales cycles where recent interactions drive decisions.',\\n   243→    bias: 'Undervalues early awareness that planted the seed.',\\n   244→  },\\n   245→  'u-shaped': {\\n   246→    short: 'U-Shaped (40/20/40)',\\n   247→    desc: 'U-Shaped (Position-Based) gives 40% to the first touch, 40% to the last touch, and splits the remaining 20% among middle interactions. Recognizes that discovery and conversion are pivotal moments.',\\n   248→    bias: 'Middle-funnel nurturing (often the hardest work) gets minimal credit.',\\n   249→  },\\n   250→  'w-shaped': {\\n   251→    short: 'W-Shaped (30/30/30/10)',\\n   252→    desc: 'W-Shaped gives 30% to the first touch, 30% to the lead-creation midpoint, 30% to the last touch, and splits the remaining 10% among everything else. Best for B2B funnels with a distinct qualification step.',\\n   253→    bias: 'Assumes a clear midpoint exists. Less useful for short or uniform journeys.',\\n   254→  },\\n   255→  'custom': {\\n   256→    short: 'Custom',\\n   257→    desc: 'Custom Weights let you manually assign relative importance to each touchpoint. Weights are normalized to 100%. Use this to model your own attribution theory or domain expertise.',\\n   258→    bias: 'Only as good as your assumptions.',\\n   259→  },\\n   260→};\\n   261→\\n   262→let state = {\\n   263→  model: 'linear',\\n   264→  touchpoints: [],\\n   265→  customWeights: [],\\n   266→  decayHalfLife: 7,\\n   267→  view: 'journey',\\n   268→};\\n   269→\\n   270→// --- Attribution math ---\\n   271→function calcCredits(model, tps, halfLife, customW) {\\n   272→  const n = tps.length;\\n   273→  if (n === 0) return [];\\n   274→  if (n === 1) return [1];\\n   275→\\n   276→  switch (model) {\\n   277→    case 'first-touch': {\\n   278→      const c = Array(n).fill(0);\\n   279→      c[0] = 1;\\n   280→      return c;\\n   281→    }\\n   282→    case 'last-touch': {\\n   283→      const c = Array(n).fill(0);\\n   284→      c[n - 1] = 1;\\n   285→      return c;\\n   286→    }\\n   287→    case 'linear': {\\n   288→      return Array(n).fill(1 / n);\\n   289→    }\\n   290→    case 'time-decay': {\\n   291→      const maxDay = tps[n - 1].days;\\n   292→      const rawDecay = tps.map(function(tp) {\\n   293→        const daysBeforeConversion = maxDay - tp.days;\\n   294→        return Math.pow(2, -daysBeforeConversion / halfLife);\\n   295→      });\\n   296→      const sum = rawDecay.reduce(function(a, b) { return a + b; }, 0);\\n   297→      return rawDecay.map(function(v) { return v / sum; });\\n   298→    }\\n   299→    case 'u-shaped': {\\n   300→      const c = Array(n).fill(0);\\n   301→      if (n === 2) return [0.5, 0.5];\\n   302→      c[0] = 0.4;\\n   303→      c[n - 1] = 0.4;\\n   304→      const mid = 0.2 / (n - 2);\\n   305→      for (let i = 1; i < n - 1; i++) c[i] = mid;\\n   306→      return c;\\n   307→    }\\n   308→    case 'w-shaped': {\\n   309→      const c = Array(n).fill(0);\\n   310→      if (n === 2) return [0.5, 0.5];\\n   311→      if (n === 3) return [0.333, 0.334, 0.333];\\n   312→      const midIdx = Math.floor(n / 2);\\n   313→      c[0] = 0.3;\\n   314→      c[midIdx] = 0.3;\\n   315→      c[n - 1] = 0.3;\\n   316→      let others = n - 3;\\n   317→      if (others <= 0) {\\n   318→        const s = c.reduce(function(a, b) { return a + b; }, 0);\\n   319→        return c.map(function(v) { return v / s; });\\n   320→      }\\n   321→      const each = 0.1 / others;\\n   322→      for (let i = 0; i < n; i++) {\\n   323→        if (i !== 0 && i !== midIdx && i !== n - 1) c[i] = each;\\n   324→      }\\n   325→      return c;\\n   326→    }\\n   327→    case 'custom': {\\n   328→      if (!customW || customW.length !== n) return Array(n).fill(1 / n);\\n   329→      const sum = customW.reduce(function(a, b) { return a + b; }, 0);\\n   330→      if (sum === 0) return Array(n).fill(1 / n);\\n   331→      return customW.map(function(w) { return w / sum; });\\n   332→    }\\n   333→    default: return Array(n).fill(1 / n);\\n   334→  }\\n   335→}\\n   336→\\n   337→function calcAllModels(tps, halfLife, customW) {\\n   338→  var models = ['first-touch', 'last-touch', 'linear', 'time-decay', 'u-shaped', 'w-shaped'];\\n   339→  var result = {};\\n   340→  for (var i = 0; i < models.length; i++) {\\n   341→    result[models[i]] = calcCredits(models[i], tps, halfLife, customW);\\n   342→  }\\n   343→  return result;\\n   344→}\\n   345→\\n   346→// --- Safe DOM helpers ---\\n   347→function clearEl(el) { while (el.firstChild) el.removeChild(el.firstChild); }\\n   348→\\n   349→function makeEl(tag, attrs, children) {\\n   350→  var el = document.createElement(tag);\\n   351→  if (attrs) {\\n   352→    Object.keys(attrs).forEach(function(k) {\\n   353→      if (k === 'style' && typeof attrs[k] === 'object') {\\n   354→        Object.assign(el.style, attrs[k]);\\n   355→      } else if (k.startsWith('on')) {\\n   356→        el.addEventListener(k.slice(2), attrs[k]);\\n   357→      } else if (k === 'className') {\\n   358→        el.className = attrs[k];\\n   359→      } else {\\n   360→        el.setAttribute(k, attrs[k]);\\n   361→      }\\n   362→    });\\n   363→  }\\n   364→  if (children) {\\n   365→    if (typeof children === 'string') {\\n   366→      el.textContent = children;\\n   367→    } else if (Array.isArray(children)) {\\n   368→      children.forEach(function(c) { if (c) el.appendChild(c); });\\n   369→    }\\n   370→  }\\n   371→  return el;\\n   372→}\\n   373→\\n   374→// --- Rendering ---\\n   375→function renderTouchpointList() {\\n   376→  var list = document.getElementById('tp-list');\\n   377→  clearEl(list);\\n   378→  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n   379→  state.touchpoints.forEach(function(tp, i) {\\n   380→    var dot = makeEl('span', { className: 'dot', style: { background: COLORS[i % COLORS.length], width: '10px', height: '10px', borderRadius: '50%', flexShrink: '0', display: 'inline-block' } });\\n   381→    var name = makeEl('span', { style: { flex: '1', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }, title: tp.name }, tp.name);\\n   382→    var credit = makeEl('span', { style: { fontFamily: 'monospace', color: 'var(--accent)', minWidth: '40px', textAlign: 'right' } }, (credits[i] * 100).toFixed(1) + '%');\\n   383→    var removeBtn = makeEl('button', { className: 'small danger', title: 'Remove', onclick: function() { removeTouchpoint(i); } }, 'x');\\n   384→\\n   385→    var item = makeEl('div', {\\n   386→      style: { display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 6px', background: 'var(--bg)', borderRadius: '4px', fontSize: '0.8rem' }\\n   387→    }, [dot, name, credit, removeBtn]);\\n   388→    list.appendChild(item);\\n   389→  });\\n   390→}\\n   391→\\n   392→function renderJourney() {\\n   393→  var container = document.getElementById('tp-nodes');\\n   394→  clearEl(container);\\n   395→  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n   396→\\n   397→  state.touchpoints.forEach(function(tp, i) {\\n   398→    var pct = credits[i] * 100;\\n   399→    var size = 28 + pct * 0.4;\\n   400→    var borderW = pct > 30 ? 4 : pct > 10 ? 3 : 2;\\n   401→    var alphaVal = 0.2 + pct / 200;\\n   402→\\n   403→    var circle = makeEl('div', {\\n   404→      style: {\\n   405→        width: size + 'px', height: size + 'px', borderRadius: '50%',\\n   406→        display: 'flex', alignItems: 'center', justifyContent: 'center',\\n   407→        fontSize: '0.7rem', fontWeight: '700', color: '#000',\\n   408→        background: COLORS[i % COLORS.length],\\n   409→        border: borderW + 'px solid rgba(255,255,255,' + alphaVal + ')',\\n   410→        boxShadow: '0 0 ' + (pct / 3) + 'px ' + COLORS[i % COLORS.length] + '40',\\n   411→        transition: 'all 0.3s'\\n   412→      }\\n   413→    }, String(i + 1));\\n   414→\\n   415→    var label = makeEl('div', {\\n   416→      style: { fontSize: '0.7rem', textAlign: 'center', color: 'var(--muted)', maxWidth: '80px', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' },\\n   417→      title: tp.name\\n   418→    }, tp.name);\\n   419→\\n   420→    var creditLabel = makeEl('div', {\\n   421→      style: { fontSize: '0.85rem', fontWeight: '700', fontFamily: 'monospace', marginTop: '2px', color: COLORS[i % COLORS.length] }\\n   422→    }, pct.toFixed(1) + '%');\\n   423→\\n   424→    var node = makeEl('div', {\\n   425→      style: { display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', cursor: 'default', minWidth: '60px', maxWidth: '100px', transition: 'transform 0.2s' }\\n   426→    }, [circle, label, creditLabel]);\\n   427→\\n   428→    node.addEventListener('mouseenter', function() { node.style.transform = 'translateY(-3px)'; });\\n   429→    node.addEventListener('mouseleave', function() { node.style.transform = 'translateY(0)'; });\\n   430→\\n   431→    container.appendChild(node);\\n   432→  });\\n   433→}\\n   434→\\n   435→function renderBars() {\\n   436→  var container = document.getElementById('bars');\\n   437→  clearEl(container);\\n   438→  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n   439→  var maxCredit = Math.max.apply(null, credits.concat([0.01]));\\n   440→\\n   441→  credits.forEach(function(c, i) {\\n   442→    var h = (c / maxCredit) * 130;\\n   443→\\n   444→    var valueLabel = makeEl('div', {\\n   445→      style: { fontSize: '0.75rem', fontFamily: 'monospace', fontWeight: '700', color: COLORS[i % COLORS.length] }\\n   446→    }, (c * 100).toFixed(1) + '%');\\n   447→\\n   448→    var bar = makeEl('div', {\\n   449→      style: {\\n   450→        width: '100%', minHeight: '2px', height: h + 'px',\\n   451→        borderRadius: '4px 4px 0 0', transition: 'height 0.4s ease',\\n   452→        background: 'linear-gradient(180deg, ' + COLORS[i % COLORS.length] + ', ' + COLORS[i % COLORS.length] + '80)'\\n   453→      }\\n   454→    });\\n   455→\\n   456→    var nameLabel = makeEl('div', {\\n   457→      style: { fontSize: '0.65rem', color: 'var(--muted)', textAlign: 'center', maxWidth: '70px', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' },\\n   458→      title: state.touchpoints[i].name\\n   459→    }, state.touchpoints[i].name);\\n   460→\\n   461→    var col = makeEl('div', {\\n   462→      style: { display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', flex: '1', maxWidth: '80px' }\\n   463→    }, [valueLabel, bar, nameLabel]);\\n   464→\\n   465→    container.appendChild(col);\\n   466→  });\\n   467→}\\n   468→\\n   469→function renderExplanation() {\\n   470→  var el = document.getElementById('explanation');\\n   471→  clearEl(el);\\n   472→  var info = MODEL_INFO[state.model];\\n   473→\\n   474→  var descEl = makeEl('span', { style: { color: 'var(--accent)', fontWeight: '700' } }, info.short + ': ');\\n   475→  var descText = document.createTextNode(info.desc);\\n   476→  var br = document.createElement('br');\\n   477→  var br2 = document.createElement('br');\\n   478→  var biasLabel = makeEl('span', { style: { color: 'var(--orange)' } }, 'Bias: ');\\n   479→  var biasText = document.createTextNode(info.bias);\\n   480→\\n   481→  el.appendChild(descEl);\\n   482→  el.appendChild(descText);\\n   483→  el.appendChild(br);\\n   484→  el.appendChild(br2);\\n   485→  el.appendChild(biasLabel);\\n   486→  el.appendChild(biasText);\\n   487→}\\n   488→\\n   489→function renderCompare() {\\n   490→  var table = document.getElementById('compare-table');\\n   491→  clearEl(table);\\n   492→  var all = calcAllModels(state.touchpoints, state.decayHalfLife, state.customWeights);\\n   493→  var models = ['first-touch', 'last-touch', 'linear', 'time-decay', 'u-shaped', 'w-shaped'];\\n   494→\\n   495→  // Header\\n   496→  var headerRow = makeEl('tr');\\n   497→  headerRow.appendChild(makeEl('th', {}, 'Touchpoint'));\\n   498→  models.forEach(function(m) {\\n   499→    headerRow.appendChild(makeEl('th', {}, MODEL_INFO[m].short));\\n   500→  });\\n   501→  table.appendChild(headerRow);\\n   502→\\n   503→  // Data rows\\n   504→  state.touchpoints.forEach(function(tp, i) {\\n   505→    var row = makeEl('tr');\\n   506→    var dot = makeEl('span', { style: { color: COLORS[i % COLORS.length] } }, '\\\\u25CF ');\\n   507→    var nameCell = makeEl('td');\\n   508→    nameCell.appendChild(dot);\\n   509→    nameCell.appendChild(document.createTextNode(tp.name));\\n   510→    row.appendChild(nameCell);\\n   511→\\n   512→    models.forEach(function(m) {\\n   513→      var v = (all[m][i] * 100).toFixed(1) + '%';\\n   514→      var isCurrent = m === state.model;\\n   515→      var cell = makeEl('td', {\\n   516→        style: isCurrent ? { color: 'var(--accent)', fontWeight: '700' } : {}\\n   517→      }, v);\\n   518→      row.appendChild(cell);\\n   519→    });\\n   520→    table.appendChild(row);\\n   521→  });\\n   522→\\n   523→  // Winner row\\n   524→  var winnerRow = makeEl('tr', { style: { borderTop: '2px solid var(--border)' } });\\n   525→  winnerRow.appendChild(makeEl('td', { style: { fontFamily: 'system-ui', color: 'var(--muted)' } }, 'Top Channel'));\\n   526→  models.forEach(function(m) {\\n   527→    var credits = all[m];\\n   528→    var maxIdx = credits.indexOf(Math.max.apply(null, credits));\\n   529→    var isCurrent = m === state.model;\\n   530→    var cell = makeEl('td', {\\n   531→      style: { color: COLORS[maxIdx % COLORS.length], fontWeight: isCurrent ? '700' : 'normal' }\\n   532→    }, state.touchpoints[maxIdx].name);\\n   533→    winnerRow.appendChild(cell);\\n   534→  });\\n   535→  table.appendChild(winnerRow);\\n   536→}\\n   537→\\n   538→function renderCustomWeights() {\\n   539→  var section = document.getElementById('custom-section');\\n   540→  var container = document.getElementById('custom-weights');\\n   541→  if (state.model !== 'custom') {\\n   542→    section.classList.add('hidden');\\n   543→    return;\\n   544→  }\\n   545→  section.classList.remove('hidden');\\n   546→  clearEl(container);\\n   547→\\n   548→  while (state.customWeights.length < state.touchpoints.length) state.customWeights.push(1);\\n   549→  while (state.customWeights.length > state.touchpoints.length) state.customWeights.pop();\\n   550→\\n   551→  state.touchpoints.forEach(function(tp, i) {\\n   552→    var dot = makeEl('span', { style: { background: COLORS[i % COLORS.length], width: '8px', height: '8px', borderRadius: '50%', display: 'inline-block' } });\\n   553→    var label = makeEl('span', { style: { fontSize: '0.75rem', flex: '1', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' } }, tp.name);\\n   554→    var input = makeEl('input', { type: 'number', min: '0', max: '100', value: String(state.customWeights[i]), style: { width: '55px' } });\\n   555→    (function(idx) {\\n   556→      input.addEventListener('change', function() {\\n   557→        state.customWeights[idx] = parseFloat(this.value) || 0;\\n   558→        updateAll();\\n   559→      });\\n   560→    })(i);\\n   561→\\n   562→    var row = makeEl('div', { style: { display: 'flex', alignItems: 'center', gap: '6px', marginBottom: '4px' } }, [dot, label, input]);\\n   563→    container.appendChild(row);\\n   564→  });\\n   565→}\\n   566→\\n   567→function renderPrompt() {\\n   568→  var el = document.getElementById('prompt-output');\\n   569→  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n   570→  var info = MODEL_INFO[state.model];\\n   571→  var n = state.touchpoints.length;\\n   572→\\n   573→  if (n === 0) {\\n   574→    el.textContent = 'Add touchpoints to generate a prompt.';\\n   575→    return;\\n   576→  }\\n   577→\\n   578→  var sorted = credits\\n   579→    .map(function(c, i) { return { name: state.touchpoints[i].name, credit: c }; })\\n   580→    .sort(function(a, b) { return b.credit - a.credit; });\\n   581→\\n   582→  var top = sorted[0];\\n   583→  var bottom = sorted[sorted.length - 1];\\n   584→  var journey = state.touchpoints.map(function(tp) { return tp.name; }).join(' -> ');\\n   585→\\n   586→  var parts = [];\\n   587→  parts.push(\\\"I'm analyzing a \\\" + n + \\\"-step customer journey using the \\\" + info.short + \\\" attribution model.\\\");\\n   588→  parts.push(\\\"\\\\nJourney: \\\" + journey);\\n   589→  parts.push(\\\"\\\\nCredit distribution:\\\");\\n   590→  sorted.forEach(function(s) {\\n   591→    parts.push(\\\"  \\\" + s.name + \\\": \\\" + (s.credit * 100).toFixed(1) + \\\"%\\\");\\n   592→  });\\n   593→\\n   594→  if (state.model === 'time-decay') {\\n   595→    parts.push(\\\"\\\\nDecay half-life: \\\" + state.decayHalfLife + \\\" days\\\");\\n   596→  }\\n   597→\\n   598→  parts.push(\\\"\\\\nThe \\\" + info.short + \\\" model \\\" + (top.credit > 0.5 ? 'heavily favors' : 'gives the most credit to') + ' \\\"' + top.name + '\\\" (' + (top.credit * 100).toFixed(1) + '%).');\\n   599→\\n   600→  if (n > 2) {\\n   601→    parts.push('\\\"' + bottom.name + '\\\" gets the least credit at ' + (bottom.credit * 100).toFixed(1) + '%.');\\n   602→  }\\n   603→\\n   604→  parts.push(\\\"\\\\nHelp me understand: Is \\\" + info.short + \\\" the right model for this journey? What would change if I used a different model? Which touchpoints might be over- or under-valued?\\\");\\n   605→\\n   606→  el.textContent = parts.join('\\\\n');\\n   607→}\\n   608→\\n   609→// --- Actions ---\\n   610→function updateAll() {\\n   611→  renderTouchpointList();\\n   612→  renderJourney();\\n   613→  renderBars();\\n   614→  renderExplanation();\\n   615→  renderCompare();\\n   616→  renderCustomWeights();\\n   617→  renderPrompt();\\n   618→}\\n   619→\\n   620→function handleModelChange() {\\n   621→  state.model = document.getElementById('model-select').value;\\n   622→  document.getElementById('decay-section').classList.toggle('hidden', state.model !== 'time-decay');\\n   623→  updateAll();\\n   624→}\\n   625→\\n   626→function updateDecayLabel() {\\n   627→  state.decayHalfLife = parseInt(document.getElementById('decay-slider').value);\\n   628→  document.getElementById('decay-label').textContent = state.decayHalfLife + 'd';\\n   629→}\\n   630→\\n   631→function loadPreset(name) {\\n   632→  state.touchpoints = PRESETS[name].map(function(tp) { return { name: tp.name, days: tp.days }; });\\n   633→  state.customWeights = state.touchpoints.map(function() { return 1; });\\n   634→  updateAll();\\n   635→}\\n   636→\\n   637→function addTouchpoint() {\\n   638→  var input = document.getElementById('new-tp-name');\\n   639→  var name = input.value.trim();\\n   640→  if (!name) return;\\n   641→  var lastDay = state.touchpoints.length > 0 ? state.touchpoints[state.touchpoints.length - 1].days : 0;\\n   642→  state.touchpoints.push({ name: name, days: lastDay + 5 });\\n   643→  state.customWeights.push(1);\\n   644→  input.value = '';\\n   645→  updateAll();\\n   646→}\\n   647→\\n   648→function removeTouchpoint(i) {\\n   649→  state.touchpoints.splice(i, 1);\\n   650→  state.customWeights.splice(i, 1);\\n   651→  updateAll();\\n   652→}\\n   653→\\n   654→function setView(view) {\\n   655→  state.view = view;\\n   656→  document.getElementById('view-journey').classList.toggle('hidden', view !== 'journey');\\n   657→  document.getElementById('view-compare').classList.toggle('hidden', view !== 'compare');\\n   658→  document.getElementById('btn-journey').classList.toggle('active', view === 'journey');\\n   659→  document.getElementById('btn-compare').classList.toggle('active', view === 'compare');\\n   660→  if (view === 'compare') renderCompare();\\n   661→}\\n   662→\\n   663→function copyPrompt() {\\n   664→  var text = document.getElementById('prompt-output').textContent;\\n   665→  navigator.clipboard.writeText(text).then(function() {\\n   666→    var btn = document.querySelector('.copy-btn');\\n   667→    btn.textContent = 'Copied!';\\n   668→    setTimeout(function() { btn.textContent = 'Copy'; }, 1500);\\n   669→  });\\n   670→}\\n   671→\\n   672→// --- Init ---\\n   673→loadPreset('saas');\\n   674→</script>\\n   675→</body>\\n   676→</html>\\n   677→\"}]},\"uuid\":\"b233a536-953e-4776-8e86-15e4bca84c30\",\"timestamp\":\"2026-03-06T17:50:53.054Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alisha/Projects/devenv/cli/attribution-playground.html\",\"content\":\"<!DOCTYPE html>\\n<html lang=\\\"en\\\">\\n<head>\\n<meta charset=\\\"UTF-8\\\">\\n<meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\">\\n<title>Attribution Models Playground</title>\\n<style>\\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\\n  :root {\\n    --bg: #1a1a2e; --surface: #16213e; --border: #2a3a5c;\\n    --text: #e0e0e0; --muted: #8892a4; --accent: #4fc3f7;\\n    --green: #66bb6a; --orange: #ffa726; --pink: #f06292;\\n    --purple: #ab47bc; --yellow: #ffee58; --red: #ef5350;\\n    --teal: #26a69a; --blue: #42a5f5;\\n  }\\n  body { font-family: system-ui, -apple-system, sans-serif; background: var(--bg); color: var(--text); height: 100vh; display: flex; flex-direction: column; overflow: hidden; }\\n  h1 { font-size: 1.1rem; color: var(--accent); padding: 12px 16px; border-bottom: 1px solid var(--border); }\\n  h2 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); margin-bottom: 8px; }\\n\\n  .main { display: flex; flex: 1; overflow: hidden; }\\n\\n  .sidebar { width: 280px; min-width: 280px; background: var(--surface); border-right: 1px solid var(--border); overflow-y: auto; padding: 16px; display: flex; flex-direction: column; gap: 16px; }\\n  .sidebar section { display: flex; flex-direction: column; gap: 6px; }\\n\\n  label { font-size: 0.8rem; color: var(--muted); display: block; margin-bottom: 2px; }\\n  select, input[type=\\\"number\\\"], input[type=\\\"text\\\"] {\\n    width: 100%; background: var(--bg); color: var(--text); border: 1px solid var(--border);\\n    border-radius: 4px; padding: 6px 8px; font-size: 0.85rem; outline: none;\\n  }\\n  select:focus, input:focus { border-color: var(--accent); }\\n  button {\\n    background: var(--border); color: var(--text); border: none; border-radius: 4px;\\n    padding: 6px 12px; font-size: 0.8rem; cursor: pointer; transition: background 0.15s;\\n  }\\n  button:hover { background: var(--accent); color: #000; }\\n  button.active { background: var(--accent); color: #000; }\\n  button.small { padding: 3px 8px; font-size: 0.75rem; }\\n  button.danger { background: var(--red); color: #fff; }\\n  button.danger:hover { background: #c62828; }\\n\\n  .presets { display: flex; flex-wrap: wrap; gap: 4px; }\\n  .presets button { flex: 1; min-width: 80px; font-size: 0.75rem; }\\n\\n  .touchpoint-list { display: flex; flex-direction: column; gap: 4px; max-height: 200px; overflow-y: auto; }\\n\\n  .add-row { display: flex; gap: 4px; }\\n  .add-row input { flex: 1; }\\n\\n  .canvas-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; }\\n  .viz { flex: 1; position: relative; padding: 20px; overflow: auto; }\\n\\n  .journey { position: relative; margin: 20px auto; max-width: 900px; }\\n  .timeline-line { height: 3px; background: var(--border); position: absolute; top: 40px; left: 30px; right: 30px; }\\n\\n  .explanation-box {\\n    max-width: 900px; margin: 20px auto 0; padding: 12px 16px;\\n    background: var(--surface); border-radius: 6px; border-left: 3px solid var(--accent);\\n    font-size: 0.85rem; line-height: 1.5;\\n  }\\n\\n  .prompt-area {\\n    background: var(--surface); border-top: 1px solid var(--border);\\n    padding: 12px 16px; max-height: 160px; overflow-y: auto; position: relative;\\n  }\\n  .prompt-area h2 { margin-bottom: 6px; }\\n  .prompt-text { font-family: monospace; font-size: 0.8rem; line-height: 1.5; color: var(--text); white-space: pre-wrap; }\\n  .copy-btn {\\n    position: absolute; top: 10px; right: 16px; background: var(--accent); color: #000;\\n    font-weight: 600; padding: 4px 12px; border-radius: 4px; font-size: 0.75rem;\\n  }\\n  .copy-btn:hover { background: #81d4fa; }\\n\\n  input[type=\\\"range\\\"] { width: 100%; accent-color: var(--accent); }\\n  .slider-row { display: flex; align-items: center; gap: 8px; }\\n  .slider-row span { font-family: monospace; font-size: 0.8rem; min-width: 30px; }\\n\\n  .comparison { max-width: 900px; margin: 20px auto 0; }\\n  table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }\\n  th { text-align: left; padding: 6px 8px; border-bottom: 1px solid var(--border); color: var(--muted); font-weight: 600; }\\n  td { padding: 6px 8px; border-bottom: 1px solid rgba(42,58,92,0.4); font-family: monospace; }\\n  td:first-child { font-family: system-ui; }\\n\\n  .hidden { display: none; }\\n</style>\\n</head>\\n<body>\\n\\n<h1>Attribution Models Playground</h1>\\n\\n<div class=\\\"main\\\">\\n  <div class=\\\"sidebar\\\">\\n    <section>\\n      <h2>Attribution Model</h2>\\n      <select id=\\\"model-select\\\" onchange=\\\"handleModelChange()\\\">\\n        <option value=\\\"first-touch\\\">First Touch</option>\\n        <option value=\\\"last-touch\\\">Last Touch</option>\\n        <option value=\\\"linear\\\" selected>Linear</option>\\n        <option value=\\\"time-decay\\\">Time Decay</option>\\n        <option value=\\\"u-shaped\\\">U-Shaped (Position-Based)</option>\\n        <option value=\\\"w-shaped\\\">W-Shaped</option>\\n        <option value=\\\"custom\\\">Custom Weights</option>\\n      </select>\\n    </section>\\n\\n    <section id=\\\"decay-section\\\" class=\\\"hidden\\\">\\n      <h2>Decay Half-Life</h2>\\n      <div class=\\\"slider-row\\\">\\n        <input type=\\\"range\\\" id=\\\"decay-slider\\\" min=\\\"1\\\" max=\\\"14\\\" value=\\\"7\\\" oninput=\\\"updateDecayLabel(); updateAll();\\\">\\n        <span id=\\\"decay-label\\\">7d</span>\\n      </div>\\n      <label style=\\\"margin-top:4px;\\\">How quickly credit fades for older touchpoints</label>\\n    </section>\\n\\n    <section>\\n      <h2>Presets</h2>\\n      <div class=\\\"presets\\\">\\n        <button onclick=\\\"loadPreset('saas')\\\">SaaS Funnel</button>\\n        <button onclick=\\\"loadPreset('ecommerce')\\\">E-commerce</button>\\n        <button onclick=\\\"loadPreset('b2b')\\\">B2B Long Sale</button>\\n        <button onclick=\\\"loadPreset('simple')\\\">Simple (3)</button>\\n        <button onclick=\\\"loadPreset('content')\\\">Content Mktg</button>\\n      </div>\\n    </section>\\n\\n    <section>\\n      <h2>Touchpoints</h2>\\n      <div class=\\\"touchpoint-list\\\" id=\\\"tp-list\\\"></div>\\n      <div class=\\\"add-row\\\" style=\\\"margin-top:6px;\\\">\\n        <input type=\\\"text\\\" id=\\\"new-tp-name\\\" placeholder=\\\"Channel name...\\\" onkeydown=\\\"if(event.key==='Enter')addTouchpoint()\\\">\\n        <button class=\\\"small\\\" onclick=\\\"addTouchpoint()\\\">+ Add</button>\\n      </div>\\n    </section>\\n\\n    <section id=\\\"custom-section\\\" class=\\\"hidden\\\">\\n      <h2>Custom Weights</h2>\\n      <div id=\\\"custom-weights\\\"></div>\\n      <label style=\\\"margin-top:4px;\\\">Weights are auto-normalized to 100%</label>\\n    </section>\\n\\n    <section>\\n      <h2>View</h2>\\n      <div style=\\\"display:flex; gap:4px;\\\">\\n        <button id=\\\"btn-journey\\\" class=\\\"active\\\" onclick=\\\"setView('journey')\\\">Journey</button>\\n        <button id=\\\"btn-compare\\\" onclick=\\\"setView('compare')\\\">Compare All</button>\\n      </div>\\n    </section>\\n  </div>\\n\\n  <div class=\\\"canvas-area\\\">\\n    <div class=\\\"viz\\\" id=\\\"viz\\\">\\n      <div id=\\\"view-journey\\\">\\n        <div class=\\\"journey\\\">\\n          <div class=\\\"timeline-line\\\"></div>\\n          <div id=\\\"tp-nodes\\\" style=\\\"display:flex; justify-content:space-between; position:relative; z-index:1; padding:0 10px;\\\"></div>\\n        </div>\\n        <div style=\\\"max-width:900px; margin:30px auto 0;\\\">\\n          <h2 style=\\\"text-align:center;\\\">Credit Distribution</h2>\\n          <div id=\\\"bars\\\" style=\\\"display:flex; align-items:flex-end; justify-content:center; gap:8px; height:160px; padding:0 20px; margin-top:10px;\\\"></div>\\n        </div>\\n        <div class=\\\"explanation-box\\\" id=\\\"explanation\\\"></div>\\n      </div>\\n\\n      <div id=\\\"view-compare\\\" class=\\\"hidden\\\">\\n        <div class=\\\"comparison\\\">\\n          <h2 style=\\\"margin-bottom:10px;\\\">Model Comparison</h2>\\n          <table id=\\\"compare-table\\\"></table>\\n        </div>\\n      </div>\\n    </div>\\n\\n    <div class=\\\"prompt-area\\\">\\n      <h2>Prompt Output</h2>\\n      <button class=\\\"copy-btn\\\" onclick=\\\"copyPrompt()\\\">Copy</button>\\n      <div class=\\\"prompt-text\\\" id=\\\"prompt-output\\\"></div>\\n    </div>\\n  </div>\\n</div>\\n\\n<script>\\nconst COLORS = ['#4fc3f7','#66bb6a','#ffa726','#f06292','#ab47bc','#ffee58','#ef5350','#26a69a','#42a5f5','#8d6e63','#78909c','#dce775'];\\n\\nconst PRESETS = {\\n  saas: [\\n    { name: 'Google Ad', days: 0 },\\n    { name: 'Blog Post', days: 3 },\\n    { name: 'Email Nurture', days: 7 },\\n    { name: 'Webinar', days: 14 },\\n    { name: 'Free Trial', days: 18 },\\n    { name: 'Sales Demo', days: 25 },\\n    { name: 'Pricing Page', days: 28 },\\n  ],\\n  ecommerce: [\\n    { name: 'Instagram Ad', days: 0 },\\n    { name: 'Product Review', days: 1 },\\n    { name: 'Retargeting Ad', days: 3 },\\n    { name: 'Email Coupon', days: 5 },\\n    { name: 'Direct Visit', days: 6 },\\n  ],\\n  b2b: [\\n    { name: 'LinkedIn Ad', days: 0 },\\n    { name: 'Whitepaper', days: 10 },\\n    { name: 'Conference', days: 30 },\\n    { name: 'Case Study', days: 45 },\\n    { name: 'Sales Call', days: 60 },\\n    { name: 'Proposal', days: 75 },\\n    { name: 'Negotiation', days: 85 },\\n    { name: 'Contract', days: 90 },\\n  ],\\n  simple: [\\n    { name: 'Awareness', days: 0 },\\n    { name: 'Consideration', days: 5 },\\n    { name: 'Conversion', days: 10 },\\n  ],\\n  content: [\\n    { name: 'SEO Blog', days: 0 },\\n    { name: 'YouTube Video', days: 4 },\\n    { name: 'Podcast', days: 8 },\\n    { name: 'Newsletter', days: 12 },\\n    { name: 'Social Share', days: 14 },\\n    { name: 'Landing Page', days: 15 },\\n  ],\\n};\\n\\nconst MODEL_INFO = {\\n  'first-touch': {\\n    short: 'First Touch',\\n    desc: 'First Touch gives 100% of the credit to the first interaction. It answers: \\\"What channel introduced this customer?\\\" Great for measuring awareness campaigns, but ignores everything that nurtured the lead afterward.',\\n    bias: 'Overvalues top-of-funnel channels. Undervalues nurture and closing efforts.',\\n  },\\n  'last-touch': {\\n    short: 'Last Touch',\\n    desc: 'Last Touch gives 100% of the credit to the last interaction before conversion. It answers: \\\"What closed the deal?\\\" Simple and widely used (Google Analytics default), but ignores the entire journey.',\\n    bias: 'Overvalues bottom-of-funnel. Undervalues awareness and consideration.',\\n  },\\n  'linear': {\\n    short: 'Linear',\\n    desc: 'Linear splits credit equally across all touchpoints. It answers: \\\"Every interaction mattered the same.\\\" Fair and simple, but unrealistic \\\\u2014 not all touches have equal impact.',\\n    bias: 'Treats a passing glance the same as an hour-long demo.',\\n  },\\n  'time-decay': {\\n    short: 'Time Decay',\\n    desc: 'Time Decay gives more credit to touchpoints closer to the conversion. Uses exponential decay with a configurable half-life. Good for short sales cycles where recent interactions drive decisions.',\\n    bias: 'Undervalues early awareness that planted the seed.',\\n  },\\n  'u-shaped': {\\n    short: 'U-Shaped (40/20/40)',\\n    desc: 'U-Shaped (Position-Based) gives 40% to the first touch, 40% to the last touch, and splits the remaining 20% among middle interactions. Recognizes that discovery and conversion are pivotal moments.',\\n    bias: 'Middle-funnel nurturing (often the hardest work) gets minimal credit.',\\n  },\\n  'w-shaped': {\\n    short: 'W-Shaped (30/30/30/10)',\\n    desc: 'W-Shaped gives 30% to the first touch, 30% to the lead-creation midpoint, 30% to the last touch, and splits the remaining 10% among everything else. Best for B2B funnels with a distinct qualification step.',\\n    bias: 'Assumes a clear midpoint exists. Less useful for short or uniform journeys.',\\n  },\\n  'custom': {\\n    short: 'Custom',\\n    desc: 'Custom Weights let you manually assign relative importance to each touchpoint. Weights are normalized to 100%. Use this to model your own attribution theory or domain expertise.',\\n    bias: 'Only as good as your assumptions.',\\n  },\\n};\\n\\nlet state = {\\n  model: 'linear',\\n  touchpoints: [],\\n  customWeights: [],\\n  decayHalfLife: 7,\\n  view: 'journey',\\n};\\n\\n// --- Attribution math ---\\nfunction calcCredits(model, tps, halfLife, customW) {\\n  const n = tps.length;\\n  if (n === 0) return [];\\n  if (n === 1) return [1];\\n\\n  switch (model) {\\n    case 'first-touch': {\\n      const c = Array(n).fill(0);\\n      c[0] = 1;\\n      return c;\\n    }\\n    case 'last-touch': {\\n      const c = Array(n).fill(0);\\n      c[n - 1] = 1;\\n      return c;\\n    }\\n    case 'linear': {\\n      return Array(n).fill(1 / n);\\n    }\\n    case 'time-decay': {\\n      const maxDay = tps[n - 1].days;\\n      const rawDecay = tps.map(function(tp) {\\n        const daysBeforeConversion = maxDay - tp.days;\\n        return Math.pow(2, -daysBeforeConversion / halfLife);\\n      });\\n      const sum = rawDecay.reduce(function(a, b) { return a + b; }, 0);\\n      return rawDecay.map(function(v) { return v / sum; });\\n    }\\n    case 'u-shaped': {\\n      const c = Array(n).fill(0);\\n      if (n === 2) return [0.5, 0.5];\\n      c[0] = 0.4;\\n      c[n - 1] = 0.4;\\n      const mid = 0.2 / (n - 2);\\n      for (let i = 1; i < n - 1; i++) c[i] = mid;\\n      return c;\\n    }\\n    case 'w-shaped': {\\n      const c = Array(n).fill(0);\\n      if (n === 2) return [0.5, 0.5];\\n      if (n === 3) return [0.333, 0.334, 0.333];\\n      const midIdx = Math.floor(n / 2);\\n      c[0] = 0.3;\\n      c[midIdx] = 0.3;\\n      c[n - 1] = 0.3;\\n      let others = n - 3;\\n      if (others <= 0) {\\n        const s = c.reduce(function(a, b) { return a + b; }, 0);\\n        return c.map(function(v) { return v / s; });\\n      }\\n      const each = 0.1 / others;\\n      for (let i = 0; i < n; i++) {\\n        if (i !== 0 && i !== midIdx && i !== n - 1) c[i] = each;\\n      }\\n      return c;\\n    }\\n    case 'custom': {\\n      if (!customW || customW.length !== n) return Array(n).fill(1 / n);\\n      const sum = customW.reduce(function(a, b) { return a + b; }, 0);\\n      if (sum === 0) return Array(n).fill(1 / n);\\n      return customW.map(function(w) { return w / sum; });\\n    }\\n    default: return Array(n).fill(1 / n);\\n  }\\n}\\n\\nfunction calcAllModels(tps, halfLife, customW) {\\n  var models = ['first-touch', 'last-touch', 'linear', 'time-decay', 'u-shaped', 'w-shaped'];\\n  var result = {};\\n  for (var i = 0; i < models.length; i++) {\\n    result[models[i]] = calcCredits(models[i], tps, halfLife, customW);\\n  }\\n  return result;\\n}\\n\\n// --- Safe DOM helpers ---\\nfunction clearEl(el) { while (el.firstChild) el.removeChild(el.firstChild); }\\n\\nfunction makeEl(tag, attrs, children) {\\n  var el = document.createElement(tag);\\n  if (attrs) {\\n    Object.keys(attrs).forEach(function(k) {\\n      if (k === 'style' && typeof attrs[k] === 'object') {\\n        Object.assign(el.style, attrs[k]);\\n      } else if (k.startsWith('on')) {\\n        el.addEventListener(k.slice(2), attrs[k]);\\n      } else if (k === 'className') {\\n        el.className = attrs[k];\\n      } else {\\n        el.setAttribute(k, attrs[k]);\\n      }\\n    });\\n  }\\n  if (children) {\\n    if (typeof children === 'string') {\\n      el.textContent = children;\\n    } else if (Array.isArray(children)) {\\n      children.forEach(function(c) { if (c) el.appendChild(c); });\\n    }\\n  }\\n  return el;\\n}\\n\\n// --- Rendering ---\\nfunction renderTouchpointList() {\\n  var list = document.getElementById('tp-list');\\n  clearEl(list);\\n  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n  state.touchpoints.forEach(function(tp, i) {\\n    var dot = makeEl('span', { className: 'dot', style: { background: COLORS[i % COLORS.length], width: '10px', height: '10px', borderRadius: '50%', flexShrink: '0', display: 'inline-block' } });\\n    var name = makeEl('span', { style: { flex: '1', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' }, title: tp.name }, tp.name);\\n    var credit = makeEl('span', { style: { fontFamily: 'monospace', color: 'var(--accent)', minWidth: '40px', textAlign: 'right' } }, (credits[i] * 100).toFixed(1) + '%');\\n    var removeBtn = makeEl('button', { className: 'small danger', title: 'Remove', onclick: function() { removeTouchpoint(i); } }, 'x');\\n\\n    var item = makeEl('div', {\\n      style: { display: 'flex', alignItems: 'center', gap: '6px', padding: '4px 6px', background: 'var(--bg)', borderRadius: '4px', fontSize: '0.8rem' }\\n    }, [dot, name, credit, removeBtn]);\\n    list.appendChild(item);\\n  });\\n}\\n\\nfunction renderJourney() {\\n  var container = document.getElementById('tp-nodes');\\n  clearEl(container);\\n  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n\\n  state.touchpoints.forEach(function(tp, i) {\\n    var pct = credits[i] * 100;\\n    var size = 28 + pct * 0.4;\\n    var borderW = pct > 30 ? 4 : pct > 10 ? 3 : 2;\\n    var alphaVal = 0.2 + pct / 200;\\n\\n    var circle = makeEl('div', {\\n      style: {\\n        width: size + 'px', height: size + 'px', borderRadius: '50%',\\n        display: 'flex', alignItems: 'center', justifyContent: 'center',\\n        fontSize: '0.7rem', fontWeight: '700', color: '#000',\\n        background: COLORS[i % COLORS.length],\\n        border: borderW + 'px solid rgba(255,255,255,' + alphaVal + ')',\\n        boxShadow: '0 0 ' + (pct / 3) + 'px ' + COLORS[i % COLORS.length] + '40',\\n        transition: 'all 0.3s'\\n      }\\n    }, String(i + 1));\\n\\n    var label = makeEl('div', {\\n      style: { fontSize: '0.7rem', textAlign: 'center', color: 'var(--muted)', maxWidth: '80px', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' },\\n      title: tp.name\\n    }, tp.name);\\n\\n    var creditLabel = makeEl('div', {\\n      style: { fontSize: '0.85rem', fontWeight: '700', fontFamily: 'monospace', marginTop: '2px', color: COLORS[i % COLORS.length] }\\n    }, pct.toFixed(1) + '%');\\n\\n    var node = makeEl('div', {\\n      style: { display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', cursor: 'default', minWidth: '60px', maxWidth: '100px', transition: 'transform 0.2s' }\\n    }, [circle, label, creditLabel]);\\n\\n    node.addEventListener('mouseenter', function() { node.style.transform = 'translateY(-3px)'; });\\n    node.addEventListener('mouseleave', function() { node.style.transform = 'translateY(0)'; });\\n\\n    container.appendChild(node);\\n  });\\n}\\n\\nfunction renderBars() {\\n  var container = document.getElementById('bars');\\n  clearEl(container);\\n  var credits = calcCredits(state.model, state.touchpoints, state.decayHalfLife, state.customWeights);\\n  var maxCredit = Math.max.apply(null, credits.concat([0.01]));\\n\\n  credits.forEach(function(c, i) {\\n    var h = (c / maxCredit) * 130;\\n\\n    var valueLabel = makeEl('div', {\\n      style: { fontSize: '0.75rem', fontFamily: 'monospace', fontWeight: '700', color: COLORS[i % COLORS.length] }\\n    }, (c * 100).toFixed(1) + '%');\\n\\n    var bar = makeEl('div', {\\n      style: {\\n        width: '100%', minHeight: '2px', height: h + 'px',\\n        borderRadius: '4px 4px 0 0', transition: 'height 0.4s ease',\\n        background: 'linear-gradient(180deg, ' + COLORS[i % COLORS.length] + ', ' + COLORS[i % COLORS.length] + '80)'\\n      }\\n    });\\n\\n    var nameLabel = makeEl('div', {\\n      style: { fontSize: '0.65rem', color: 'var(--muted)', textAlign: 'center', maxWidth: '70px', overflow: 'hidden', textOverflow: 'ellipsis', whiteSpace: 'nowrap' },\\n      title: state.touchpoints[i].name\\n    }, state.touchpoints[i].name);\\n\\n    var col = makeEl('div', {\\n      style: { display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '4px', flex: '1', maxWidth: '80px' }\\n    }, [valueLabel, bar, nameLabel]);\\n\\n    container.appendChild(col);\\n  });\\n}\\n\\nfunction renderExplanation() {\\n  var el = document.getElementById('explanation');\\n  clearEl(el);\\n  var info = MODEL_INFO[state.model];\\n\\n  var descEl = makeEl('span', { style: { color: 'var(--accent)', fontWeight: '700' } }, info.short + ': ');\\n  var descText = document.createTextNode(info.desc);\\n  var br = document.createElement('br');\\n  var br2 = document.createElement('br');\\n  var biasLabel = makeEl('span', { style: { color: 'var(--orange)' } }, 'Bias: ');\\n  var biasText = document.createTextNode(info.bias);\\n\\n  el.appendChild(descEl);\\n 