ly calculate\\n    49→\\t// agent vs human line attribution. Updated only after successful condensation.\\n    50→\\tAttributionBaseCommit string `json:\\\"attribution_base_commit,omitempty\\\"`\\n    51→\\n    52→\\t// WorktreePath is the absolute path to the worktree root\\n    53→\\tWorktreePath string `json:\\\"worktree_path,omitempty\\\"`\\n    54→\\n    55→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n    56→\\t// Derived from .git/worktrees/<name>/, stable across git worktree move\\n    57→\\tWorktreeID string `json:\\\"worktree_id,omitempty\\\"`\\n    58→\\n    59→\\t// StartedAt is when the session was started\\n    60→\\tStartedAt time.Time `json:\\\"started_at\\\"`\\n    61→\\n    62→\\t// EndedAt is when the session was explicitly closed by the user.\\n    63→\\t// nil means the session is still active or was not cleanly closed.\\n    64→\\tEndedAt *time.Time `json:\\\"ended_at,omitempty\\\"`\\n    65→\\n    66→\\t// Phase is the lifecycle stage of this session (see phase.go).\\n    67→\\t// Empty means idle (backward compat with pre-state-machine files).\\n    68→\\tPhase Phase `json:\\\"phase,omitempty\\\"`\\n    69→\\n    70→\\t// TurnID is a unique identifier for the current agent turn.\\n    71→\\t// Lifecycle:\\n    72→\\t//   - Generated fresh in InitializeSession at each turn start\\n    73→\\t//   - Shared across all checkpoints within the same turn\\n    74→\\t//   - Used to correlate related checkpoints when a turn's work spans multiple commits\\n    75→\\t//   - Persists until the next InitializeSession call generates a new one\\n    76→\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n    77→\\n    78→\\t// TurnCheckpointIDs tracks all checkpoint IDs condensed during the current turn.\\n    79→\\t// Lifecycle:\\n    80→\\t//   - Set in PostCommit when a checkpoint is condensed for an ACTIVE session\\n    81→\\t//   - Consumed in HandleTurnEnd to finalize all checkpoints with the full transcript\\n    82→\\t//   - Cleared in HandleTurnEnd after finalization completes\\n    83→\\t//   - Cleared in InitializeSession when a new prompt starts\\n    84→\\t//   - Cleared when session is reset (ResetSession deletes the state file entirely)\\n    85→\\tTurnCheckpointIDs []string `json:\\\"turn_checkpoint_ids,omitempty\\\"`\\n    86→\\n    87→\\t// LastInteractionTime is updated on agent-interaction events (TurnStart,\\n    88→\\t// TurnEnd, SessionStop, Compaction) but NOT on git commit hooks.\\n    89→\\t// Used for stale session detection in \\\"entire doctor\\\".\\n    90→\\tLastInteractionTime *time.Time `json:\\\"last_interaction_time,omitempty\\\"`\\n    91→\\n    92→\\t// StepCount is the number of checkpoints/steps created in this session.\\n    93→\\t// JSON tag kept as \\\"checkpoint_count\\\" for backward compatibility with existing state files.\\n    94→\\tStepCount int `json:\\\"checkpoint_count\\\"`\\n    95→\\n    96→\\t// CheckpointTranscriptStart is the transcript line offset where the current\\n    97→\\t// checkpoint cycle began. Set to 0 at session start, updated to current\\n    98→\\t// transcript length after each condensation. Used to scope the transcript\\n    99→\\t// for checkpoint condensation: \\\"everything since last checkpoint\\\".\\n   100→\\tCheckpointTranscriptStart int `json:\\\"checkpoint_transcript_start,omitempty\\\"`\\n   101→\\n   102→\\t// Deprecated: CondensedTranscriptLines is replaced by CheckpointTranscriptStart.\\n   103→\\t// Kept for backward compatibility with existing state files.\\n   104→\\t// Use NormalizeAfterLoad() to migrate.\\n   105→\\tCondensedTranscriptLines int `json:\\\"condensed_transcript_lines,omitempty\\\"`\\n   106→\\n   107→\\t// UntrackedFilesAtStart tracks files that existed at session start (to preserve during rewind)\\n   108→\\tUntrackedFilesAtStart []string `json:\\\"untracked_files_at_start,omitempty\\\"`\\n   109→\\n   110→\\t// FilesTouched tracks files modified/created/deleted during this session\\n   111→\\tFilesTouched []string `json:\\\"files_touched,omitempty\\\"`\\n   112→\\n   113→\\t// LastCheckpointID is the checkpoint ID from the most recent condensation.\\n   114→\\t// Used to restore the Entire-Checkpoint trailer on amend and to identify\\n   115→\\t// sessions that have been condensed at least once. Cleared on new prompt.\\n   116→\\tLastCheckpointID id.CheckpointID `json:\\\"last_checkpoint_id,omitempty\\\"`\\n   117→\\n   118→\\t// FullyCondensed indicates this session has been condensed and has no remaining\\n   119→\\t// carry-forward files. PostCommit skips fully-condensed sessions entirely.\\n   120→\\t// Set after successful condensation when no files remain for carry-forward\\n   121→\\t// and the session phase is ENDED. Cleared on session reactivation (ENDED →\\n   122→\\t// ACTIVE via TurnStart, or ENDED → IDLE via SessionStart) by ActionClearEndedAt.\\n   123→\\tFullyCondensed bool `json:\\\"fully_condensed,omitempty\\\"`\\n   124→\\n   125→\\t// AgentType identifies the agent that created this session (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\", \\\"Cursor\\\")\\n   126→\\tAgentType types.AgentType `json:\\\"agent_type,omitempty\\\"`\\n   127→\\n   128→\\t// ModelName is the LLM model used in this session (e.g., \\\"claude-sonnet-4-20250514\\\", \\\"gpt-4o\\\").\\n   129→\\t// Set from hook data when the agent provides it.\\n   130→\\tModelName string `json:\\\"model_name,omitempty\\\"`\\n   131→\\n   132→\\t// Token usage tracking (accumulated across all checkpoints in this session)\\n   133→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   134→\\n   135→\\t// Hook-provided session metrics (for agents like Cursor that report via hooks)\\n   136→\\tSessionDurationMs int64 `json:\\\"session_duration_ms,omitempty\\\"`\\n   137→\\tSessionTurnCount  int   `json:\\\"session_turn_count,omitempty\\\"`\\n   138→\\tContextTokens     int   `json:\\\"context_tokens,omitempty\\\"`\\n   139→\\tContextWindowSize int  