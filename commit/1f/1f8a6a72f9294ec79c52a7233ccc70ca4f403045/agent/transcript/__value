es code',g:'a',d:'Agent adds 8 lines: a struct, constructor, and method. Shadow checkpoint saved.',\\n        acts:{'main.go':{add:[{a:7,ls:[{t:'',o:'agent'},{t:'type Server struct {',o:'agent'},{t:'    port int',o:'agent'},{t:'}',o:'agent'},{t:'',o:'agent'},{t:'func NewServer() *Server {',o:'agent'},{t:'    return &Server{port: 8080}',o:'agent'},{t:'}',o:'agent'}]}]}}},\\n      {l:'User rewrites agent code',g:'h',d:'Human removes 6 of 8 agent lines, replaces with own implementation. Per-file LIFO: user had 0 prior adds to main.go, so all 6 removals target agent lines.',\\n        acts:{'main.go':{rm:[8,9,10,11,12,13],add:[{a:7,ls:[{t:'',o:'human'},{t:'type App struct {',o:'human'},{t:'    name string',o:'human'},{t:'    port int',o:'human'},{t:'}',o:'human'},{t:'',o:'human'}]}]}}},\\n      {l:'User commits',g:'s',d:'Agent added 8, user removed 6 agent lines (LIFO: 0 self-mods). Surviving agent=2, user added=6. Total=8. Agent: 25%.'}\\n    ]\\n  },\\n  self_mod: {\\n    name:'Self-Modification', desc:'User edits own code; LIFO preserves agent credit', pct:'~67%',\\n    files:{ 'main.go':{ base:[{t:'package main',o:'base'},{t:'',o:'base'},{t:'func main() {',o:'base'},{t:'}',o:'base'}]}},\\n    steps:[\\n      {l:'Session start',g:'s',d:'Base commit: minimal main.go.'},\\n      {l:'User adds 5 lines',g:'h',d:'Human writes 5 lines of setup code.',\\n        acts:{'main.go':{add:[{a:1,ls:[{t:'import \\\"fmt\\\"',o:'human'}]},{a:3,ls:[{t:'    name := \\\"world\\\"',o:'human'},{t:'    greeting := \\\"hello\\\"',o:'human'},{t:'    msg := greeting + \\\" \\\" + name',o:'human'},{t:'    fmt.Println(msg)',o:'human'}]}]}}},\\n      {l:'Prompt submitted',g:'s',d:'CalculatePromptAttribution(): UserLinesAdded=5, UserAddedPerFile={\\\"main.go\\\": 5}. This per-file data is critical for the LIFO heuristic.'},\\n      {l:'Agent adds 10 lines',g:'a',d:'Agent adds error handling and a helper function. Shadow checkpoint saved.',\\n        acts:{'main.go':{add:[{a:2,ls:[{t:'import \\\"os\\\"',o:'agent'}]},{a:8,ls:[{t:'    if err := validate(msg); err != nil {',o:'agent'},{t:'        fmt.Fprintf(os.Stderr, \\\"error: %v\\\\\\\\n\\\", err)',o:'agent'},{t:'        os.Exit(1)',o:'agent'},{t:'    }',o:'agent'}]},{a:99,ls:[{t:'',o:'agent'},{t:'func validate(s string) error {',o:'agent'},{t:'    if s == \\\"\\\" {',o:'agent'},{t:'        return fmt.Errorf(\\\"empty\\\")',o:'agent'},{t:'    }',o:'agent'},{t:'    return nil',o:'agent'}]}]}}},\\n      {l:'User modifies own 3 lines',g:'h',d:'Human removes 3 of their own lines and replaces with 3 new ones. LIFO: user added 5 to main.go, removed 3. selfMod=min(3,5)=3. Agent lines untouched!',\\n        acts:{'main.go':{rm:[5,6,7],add:[{a:4,ls:[{t:'    name := \\\"Gopher\\\"',o:'human'},{t:'    greeting := \\\"Hi\\\"',o:'human'},{t:'    msg := fmt.Sprintf(\\\"%s, %s!\\\", greeting, name)',o:'human'}]}]}}},\\n      {l:'User commits',g:'s',d:'LIFO: removed 3 from main.go, user added 5 prior. selfMod=min(3,5)=3, humanModifiedAgent=0. Agent lines=10. Total=10+5=15. Agent: 66.7%. Without LIFO, it would incorrectly be 46.7%!'}\\n    ]\\n  },\\n  multi_file: {\\n    name:'Multi-File', desc:'Per-file tracking across multiple files', pct:'~63%',\\n    files:{\\n      'main.go':{ base:[{t:'package main',o:'base'},{t:'',o:'base'},{t:'func main() {',o:'base'},{t:'}',o:'base'}]},\\n      'utils.go':{ base:[{t:'package main',o:'base'}]}\\n    },\\n    steps:[\\n      {l:'Session start',g:'s',d:'Base commit: two files, main.go (4 lines) and utils.go (1 line).'},\\n      {l:'User edits main.go',g:'h',d:'Human adds 3 lines to main.go only.',\\n        acts:{'main.go':{add:[{a:3,ls:[{t:'    result := add(1, 2)',o:'human'},{t:'    println(result)',o:'human'},{t:'    println(\\\"done\\\")',o:'human'}]}]}}},\\n      {l:'Prompt submitted',g:'s',d:'CalculatePromptAttribution(): UserAddedPerFile={\\\"main.go\\\": 3}. Human only touched main.go, not utils.go.'},\\n      {l:'Agent writes both files',g:'a',d:'Agent adds 3 lines to main.go and 5 to utils.go. Shadow checkpoint captures both.',\\n        acts:{\\n          'main.go':{add:[{a:6,ls:[{t:'    diff := subtract(5, 3)',o:'agent'},{t:'    println(diff)',o:'agent'},{t:'    println(\\\"computed\\\")',o:'agent'}]}]},\\n          'utils.go':{add:[{a:1,ls:[{t:'',o:'agent'},{t:'func add(a, b int) int {',o:'agent'},{t:'    return a + b',o:'agent'},{t:'}',o:'agent'},{t:'',o:'agent'}]}]}\\n        }},\\n      {l:'User edits both files',g:'h',d:'Human removes 2 lines from main.go (own code) and adds 3 to utils.go. LIFO per-file: main.go removals=2, prior adds=3 => selfMod=min(2,3)=2.',\\n        acts:{\\n          'main.go':{rm:[5,6]},\\n          'utils.go':{add:[{a:6,ls:[{t:'func subtract(a, b int) int {',o:'human'},{t:'    return a - b',o:'human'},{t:'}',o:'human'}]}]}\\n        }},\\n      {l:'User commits',g:'s',d:'Per-file LIFO: main.go selfMod=min(2,3)=2, utils.go selfMod=0. Agent lines=8, user added=4. Total=12. Agent: 62.5%.'}\\n    ]\\n  }\\n};\\n\\n// ── Simulation ───────────────────────────────────────────\\nfunction reset() {\\n  const p = P[S.preset];\\n  lines = {}; pAs = []; agentFiles = new Set();\\n  for (const [f,d] of Object.entries(p.files)) lines[f] = d.base.map(x=>({...x}));\\n}\\n\\nfunction applyStep(i) {\\n  const st = P[S.preset].steps[i];\\n  if (!st || !st.acts) return;\\n  for (const [f,a] of Object.entries(st.acts)) {\\n    if (!lines[f]) lines[f] = [];\\n    let ls = lines[f];\\n    if (a.rm) { const r=[...a.rm].sort((a,b)=>b-a); for(const idx of r) if(idx-1<ls.length) ls.splice(idx-1,1); }\\n    if (a.add) { const sorted=[...a.add].sort((a,b)=>b.a-a.a); for(const ad of sorted){ const p=ad.a>=99?ls.length:Math.min(ad.a,ls.length); ls.splice(p,0,...ad.ls.map(x=>({...x}))); } }\\n    if (st.g==='a') agentFiles.add(f);\\n    lines[f] = ls;\\n  }\\n}\\n\\nfunction capturePA() {\\n  const pa = {userAdded:0, perFile:{}};\\n  for (const f of Object.keys(P[S.preset].files)) {\\n    const n = (lines[f]||[]).filter(x=>x.o==='human').length;\\n    if (n>0) { pa.userAdded+=n; pa.perFile[f]=n; }\\n  }\\n  pAs.push(pa);\\n}\\n\\nfunction simTo(step) {\\n  reset();\\n  for (let i = 0; i <= step; i++) {\\n    applyStep(i);\\n    const st = P[S.preset].steps[i];\\n    if (st.g === 's' && st.l.includes('Prompt')) capturePA();\\n  }\\n}\\n\\nfunction lastAgentStep() {\\n  const ss = P[S.preset].steps;\\n  for (let i = S.step; i >= 0; i--) if (ss[i].g === 'a') return i;\\n  return -1;\\n}\\n\\n// ── Attribution Calc ─────────────────────────────────────\\nfunction calcAttr() {\\n  const p = P[S.preset], files = Object.keys(p.files);\\n  let aL=0, hL=0;\\n  for (const f of files) for (const l of (lines[f]||[])) { if(l.o==='agent')aL++; else if(l.o==='human')hL++; }\\n\\n  let accU=0, accPF={};\\n  for (const pa of pAs) { accU+=pa.userAdded; for(const[f,n]of Object.entries(pa.perFile)) accPF[f]=(accPF[f]||0)+n; }\\n\\n  const las = lastAgentStep();\\n  let shA=0, shH=0;\\n  if (las >= 0) {\\n    const savedL=JSON.parse(JSON.stringify(lines)), savedPA=[...pAs], savedAF=new Set(agentFiles);\\n    simTo(las);\\n    for (const f of files) for (const l of (lines[f]||[])) { if(l.o==='agent')shA++; else if(l.o==='human')shH++; }\\n    lines = savedL; pAs = savedPA; agentFiles = savedAF;\\n  }\\n\\n  const b2s=shA+shH, tAgentAdded=Math.max(0,b2s-accU);\\n  const postUA=Math.max(0,hL-accU);\\n  let postUR=0, postURPF={};\\n  for (const f of files) { const cur=(lines[f]||[]).filter(x=>x.o==='human').length; const acc=accPF[f]||0; if(cur<acc){ const r=acc-cur; postUR+=r; postURPF[f]=r; } }\\n  let selfMod=0;\\n  for (const[f,r]of Object.entries(postURPF)) selfMod+=Math.min(r,accPF[f]||0);\\n  const tHM=Math.min(hL+postUA,postUR), hMA=Math.max(0,tHM-selfMod);\\n  const pUA=Math.max(0,hL-tHM), pUR=Math.max(0,postUR-tHM);\\n  const aInC=Math.max(0,tAgentAdded-pUR-hMA);\\n  let tC=aInC+pUA; if(tC<=0)tC=Math.max(0,tAgentAdded);\\n  const pct=tC>0?(aInC/tC*100):0;\\n  return {aL,hL,accU,accPF,b2s,tAgentAdded,postUA,postUR,postURPF,selfMod,hMA,pUA,pUR,aInC,tC,pct,shA,shH};\\n}\\n\\n// ── Rendering ────────────────────────────────────────────\\nfunction render() {\\n  renderLegend();\\n  renderPresets();\\n  renderTimeline();\\n  renderNav();\\n  renderFileTabs();\\n  renderCallout();\\n  renderViewTabs();\\n  renderCodeView();\\n  renderCalcView();\\n  renderTrees();\\n  renderLIFO();\\n  updatePrompt();\\n}\\n\\nfunction renderLegend() {\\n  const c = $('legend');\\n  clear(c);\\n  [{color:'var(--base)',label:'Base'},{color:'var(--human)',label:'Human'},{color:'var(--agent)',label:'Agent'}].forEach(x => {\\n    const dot = el('span',{style:{width:'8px',height:'8px',borderRadius:'2px',background:x.color,display:'inline-block'}});\\n    const item = el('span',{style:{display:'flex',alignItems:'center',gap:'3px'}}, [dot, el('span',null,x.label)]);\\n    c.appendChild(item);\\n  });\\n}\\n\\nfunction renderPresets() {\\n  const c = $('presets'); clear(c);\\n  for (const [k,v] of Object.entries(P)) {\\n    const btn = el('button',{\\n      cls:'preset-btn'+(S.preset===k?' active':''),\\n      style:{padding:'7px 10px',background:S.preset===k?'rgba(210,168,255,0.08)':'var(--bg)',border:'1px solid '+(S.preset===k?'var(--accent)':'var(--border)'),color:S.preset===k?'var(--accent)':'var(--text)',borderRadius:'5px',cursor:'pointer',fontSize:'11px',display:'flex',justifyContent:'space-between',width:'100%',marginBottom:'3px'},\\n      onclick: () => selPreset(k)\\n    });\\n    btn.appendChild(el('span',null,v.name));\\n    btn.appendChild(el('span',{style:{color:'var(--text3)',fontFamily:'var(--mono)',fontSize:'10px'}},v.pct));\\n    c.appendChild(btn);\\n  }\\n}\\n\\nfunction renderTimeline() {\\n  const c = $('timeline'); clear(c);\\n  P[S.preset].steps.forEach((s,i) => {\\n    const isDone = i < S.step, isActive = i === S.step;\\n    const dot = el('span',{style:{width:'7px',height:'7px',borderRadius:'50%',background:isActive?'var(--accent)':(isDone?'var(--agent)':'var(--bg3)'),flexShrink:'0',boxShadow:isActive?'0 0 6px rgba(210,168,255,0.4)':'none'}});\\n    const label = el('span',{style:{flex:'1',fontSize:'11px'}},s.l);\\n    const tagColor = s.g==='h'?{bg:'var(--human-bg)',c:'var(--human)',border:'var(--human-border)'}:s.g==='a'?{bg:'var(--agent-bg)',c:'var(--agent)',border:'var(--agent-border)'}:{bg:'rgba(210,168,255,0.08)',c:'var(--accent)',border:'rgba(210,168,255,0.25)'};\\n    const tagText = s.g==='h'?'human':s.g==='a'?'agent':'system';\\n    const tag = el('span',{style:{fontSize:'9px',padding:'1px 5px',borderRadius:'3px',fontFamily:'var(--mono)',background:tagColor.bg,color:tagColor.c,border:'1px solid '+tagColor.border}},tagText);\\n    const row = el('div',{style:{display:'flex',alignItems:'center',gap:'6px',padding:'5px 8px',borderRadius:'5px',cursor:'pointer',border:isActive?'1px solid var(--border)':'1px solid transparent',background:isActive?'var(--bg)':'transparent'},onclick:()=>goTo(i)},[dot,label,tag]);\\n    c.appendChild(row);\\n  });\\n}\\n\\nfunction renderNav() {\\n  const c = $('navBar'); clear(c);\\n  const mkBtn = (text, disabled, onclick) => {\\n    const b = el('button',{style:{flex:'1',padding:'6px',background:'var(--bg)',border:'1px solid var(--border)',color:'var(--text)',borderRadius:'5px',cursor:disabled?'default':'pointer',fontSize:'11px',opacity:disabled?'0.3':'1'},onclick:disabled?null:onclick},text);\\n    return b;\\n  };\\n  c.appendChild(mkBtn('< Prev', S.step===0, prev));\\n  c.appendChild(mkBtn('Next >', S.step===P[S.preset].steps.length-1, next));\\n}\\n\\nfunction renderFileTabs() {\\n  const files = Object.keys(P[S.preset].files);\\n  const sec = $('fileSection');\\n  sec.style.display = files.length > 1 ? 'block' : 'none';\\n  const c = $('fileTabs'); clear(c);\\n  files.forEach(f => {\\n    const tab = el('div',{style:{padding:'5px 12px',fontSize:'11px',cursor:'pointer',color:S.file===f?'var(--text)':'var(--text2)',borderBottom:S.file===f?'2px solid var(--accent)':'2px solid transparent',fontFamily