.sidebar { grid-column: 1; overflow-y: auto; border-right: 1px solid var(--border); background: var(--bg2); padding: 16px; }\\n  .main { grid-column: 2; overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 24px; }\\n  .prompt-bar { grid-column: 1 / -1; border-top: 1px solid var(--border); background: var(--bg2); padding: 12px 24px; display: flex; align-items: center; gap: 12px; }\\n  .prompt-bar pre { flex: 1; font-family: var(--mono); font-size: 12px; color: var(--text2); white-space: pre-wrap; max-height: 80px; overflow-y: auto; line-height: 1.5; }\\n  .copy-btn { padding: 6px 16px; background: var(--bg3); border: 1px solid var(--border); color: var(--text); border-radius: 6px; cursor: pointer; font-size: 12px; white-space: nowrap; }\\n  .copy-btn:hover { background: var(--border); }\\n\\n  /* Sidebar sections */\\n  .section { margin-bottom: 20px; }\\n  .section-title { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text3); margin-bottom: 8px; }\\n  .preset-grid { display: flex; flex-direction: column; gap: 4px; }\\n  .preset-btn { padding: 8px 12px; background: var(--bg); border: 1px solid var(--border); color: var(--text); border-radius: 6px; cursor: pointer; font-size: 12px; text-align: left; transition: all 0.15s; }\\n  .preset-btn:hover { border-color: var(--accent); color: var(--accent); }\\n  .preset-btn.active { border-color: var(--accent); background: rgba(210,168,255,0.08); color: var(--accent); }\\n  .preset-btn .pct { float: right; color: var(--text3); font-family: var(--mono); font-size: 11px; }\\n\\n  /* Timeline */\\n  .timeline { display: flex; flex-direction: column; gap: 2px; }\\n  .step { display: flex; align-items: center; gap: 8px; padding: 6px 10px; border-radius: 6px; cursor: pointer; font-size: 12px; transition: all 0.15s; }\\n  .step:hover { background: var(--bg); }\\n  .step.active { background: var(--bg); border: 1px solid var(--border); }\\n  .step.completed .dot { background: var(--agent); }\\n  .step.active .dot { background: var(--accent); box-shadow: 0 0 8px rgba(210,168,255,0.4); }\\n  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--bg3); flex-shrink: 0; }\\n  .step-label { flex: 1; }\\n  .step-tag { font-size: 10px; padding: 1px 6px; border-radius: 3px; font-family: var(--mono); }\\n  .tag-human { background: var(--human-bg); color: var(--human); border: 1px solid var(--human-border); }\\n  .tag-agent { background: var(--agent-bg); color: var(--agent); border: 1px solid var(--agent-border); }\\n  .tag-system { background: rgba(210,168,255,0.08); color: var(--accent); border: 1px solid rgba(210,168,255,0.25); }\\n\\n  /* Navigation */\\n  .nav-bar { display: flex; gap: 8px; margin-top: 12px; }\\n  .nav-btn { flex: 1; padding: 8px; background: var(--bg); border: 1px solid var(--border); color: var(--text); border-radius: 6px; cursor: pointer; font-size: 12px; }\\n  .nav-btn:hover { border-color: var(--text2); }\\n  .nav-btn:disabled { opacity: 0.3; cursor: not-allowed; }\\n\\n  /* Main panels */\\n  .panel { background: var(--bg2); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }\\n  .panel-header { padding: 10px 16px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; font-size: 13px; font-weight: 600; }\\n  .panel-body { padding: 16px; }\\n  .tab-bar { display: flex; gap: 0; }\\n  .tab { padding: 8px 16px; font-size: 12px; cursor: pointer; color: var(--text2); border-bottom: 2px solid transparent; }\\n  .tab.active { color: var(--text); border-bottom-color: var(--accent); }\\n\\n  /* Code editor */\\n  .code-view { font-family: var(--mono); font-size: 12px; line-height: 1.7; }\\n  .code-line { display: flex; padding: 0 12px; border-radius: 3px; }\\n  .code-line.human { background: var(--human-bg); }\\n  .code-line.agent { background: var(--agent-bg); }\\n  .code-line.base { background: transparent; }\\n  .code-line.removed { background: var(--removed-bg); text-decoration: line-through; opacity: 0.5; }\\n  .line-num { color: var(--text3); width: 32px; text-align: right; margin-right: 16px; user-select: none; flex-shrink: 0; }\\n  .line-content { flex: 1; white-space: pre; }\\n  .line-owner { width: 12px; flex-shrink: 0; margin-right: 8px; display: flex; align-items: center; justify-content: center; font-size: 8px; }\\n  .owner-h { color: var(--human); }\\n  .owner-a { color: var(--agent); }\\n  .owner-b { color: var(--text3); }\\n\\n  /* Tree diagram */\\n  .tree-diagram { display: flex; align-items: center; justify-content: center; gap: 40px; padding: 20px; }\\n  .tree-node { text-align: center; }\\n  .tree-box { padding: 10px 20px; border-radius: 8px; border: 2px solid var(--border); font-family: var(--mono); font-size: 12px; margin-bottom: 4px; transition: all 0.3s; }\\n  .tree-box.highlight { border-color: var(--accent); box-shadow: 0 0 12px rgba(210,168,255,0.2); }\\n  .tree-label { font-size: 10px; color: var(--text3); }\\n  .tree-arrow { color: var(--text3); font-size: 20px; }\\n  .tree-arrow-label { font-size: 10px; color: var(--text3); text-align: center; max-width: 100px; }\\n\\n  /* Calculation */\\n  .calc { font-family: var(--mono); font-size: 12px; line-height: 1.8; }\\n  .calc-section { margin-bottom: 12px; }\\n  .calc-title { color: var(--accent); font-weight: 600; margin-bottom: 4px; }\\n  .calc-line { color: var(--text2); padding-left: 16px; }\\n  .calc-line .val { color: var(--text); }\\n  .calc-line .human-val { color: var(--human); }\\n  .calc-line .agent-val { color: var(--agent); }\\n  .calc-line .op { color: var(--text3); }\\n  .calc-result { margin-top: 8px; padding: 12px; background: var(--bg); border-radius: 6px; border: 1px solid var(--border); }\\n  .pct-bar { height: 8px; border-radius: 4px; background: var(--bg3); overflow: hidden; margin-top: 8px; display: flex; }\\n  .pct-fill-agent { background: var(--agent); transition: width 0.5s ease; }\\n  .pct-fill-human { background: var(--human); transition: width 0.5s ease; }\\n  .big-pct { font-size: 32px; font-weight: 700; font-family: var(--mono); }\\n  .big-pct .agent-pct { color: var(--agent); }\\n  .big-pct .human-pct { color: var(--human); }\\n  .big-pct .sep { color: var(--text3); font-size: 20px; margin: 0 8px; }\\n\\n  /* LIFO demo */\\n  .lifo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }\\n  .lifo-panel { background: var(--bg); border-radius: 6px; padding: 12px; border: 1px solid var(--border); }\\n  .lifo-panel h4 { font-size: 12px; margin-bottom: 8px; color: var(--text2); }\\n  .lifo-line { display: flex; align-items: center; gap: 8px; padding: 4px 8px; border-radius: 4px; margin-bottom: 2px; font-family: var(--mono); font-size: 12px; cursor: pointer; transition: all 0.15s; }\\n  .lifo-line:hover { opacity: 0.8; }\\n  .lifo-line.human-line { background: var(--human-bg); border: 1px solid transparent; }\\n  .lifo-line.agent-line { background: var(--agent-bg); border: 1px solid transparent; }\\n  .lifo-line.struck { text-decoration: line-through; opacity: 0.35; }\\n  .lifo-chip { font-size: 9px; padding: 1px 5px; border-radius: 3px; }\\n  .lifo-result { margin-top: 12px; padding: 10px; background: var(--bg2); border-radius: 6px; font-family: var(--mono); font-size: 11px; line-height: 1.7; }\\n\\n  /* Description callout */\\n  .callout { padding: 12px 16px; background: var(--bg); border-radius: 6px; border-left: 3px solid var(--accent); font-size: 13px; line-height: 1.6; color: var(--text2); margin-bottom: 16px; }\\n  .callout code { font-family: var(--mono); color: var(--accent); font-size: 12px; }\\n  .legend { display: flex; gap: 16px; font-size: 11px; color: var(--text2); }\\n  .legend-item { display: flex; align-items: center; gap: 4px; }\\n  .legend-dot { width: 10px; height: 10px; border-radius: 3px; }\\n\\n  /* Tabs for main view */\\n  .view-tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border); margin-bottom: 0; }\\n  .view-tab { padding: 10px 20px; font-size: 13px; cursor: pointer; color: var(--text2); border-bottom: 2px solid transparent; transition: all 0.15s; }\\n  .view-tab:hover { color: var(--text); }\\n  .view-tab.active { color: var(--text); border-bottom-color: var(--accent); }\\n  .view-content { display: none; }\\n  .view-content.active { display: block; }\\n\\n  /* Scrollbar */\\n  ::-webkit-scrollbar { width: 6px; }\\n  ::-webkit-scrollbar-track { background: transparent; }\\n  ::-webkit-scrollbar-thumb { background: var(--bg3); border-radius: 3px; }\\n</style>\\n</head>\\n<body>\\n<div class=\\\"app\\\">\\n  <!-- Header -->\\n  <div class=\\\"header\\\">\\n    <h1>Attribution Playground</h1>\\n    <span class=\\\"subtitle\\\">Understand how Entire CLI tracks human vs AI code contributions</span>\\n    <div style=\\\"flex:1\\\"></div>\\n    <div class=\\\"legend\\\">\\n      <span class=\\\"legend-item\\\"><span class=\\\"legend-dot\\\" style=\\\"background:var(--base)\\\"></span> Base</span>\\n      <span class=\\\"legend-item\\\"><span class=\\\"legend-dot\\\" style=\\\"background:var(--human)\\\"></span> Human</span>\\n      <span class=\\\"legend-item\\\"><span class=\\\"legend-dot\\\" style=\\\"background:var(--agent)\\\"></span> Agent</span>\\n    </div>\\n  </div>\\n\\n  <!-- Sidebar -->\\n  <div class=\\\"sidebar\\\">\\n    <div class=\\\"section\\\">\\n      <div class=\\\"section-title\\\">Presets</div>\\n      <div class=\\\"preset-grid\\\" id=\\\"presets\\\"></div>\\n    </div>\\n    <div class=\\\"section\\\">\\n      <div class=\\\"section-title\\\">Session Timeline</div>\\n      <div class=\\\"timeline\\\" id=\\\"timeline\\\"></div>\\n      <div class=\\\"nav-bar\\\">\\n        <button class=\\\"nav-btn\\\" id=\\\"prevBtn\\\" onclick=\\\"prevStep()\\\">Prev</button>\\n        <button class=\\\"nav-btn\\\" id=\\\"nextBtn\\\" onclick=\\\"nextStep()\\\">Next</button>\\n      </div>\\n    </div>\\n    <div class=\\\"section\\\" style=\\\"margin-top: 16px;\\\">\\n      <div class=\\\"section-title\\\">File</div>\\n      <div class=\\\"tab-bar\\\" id=\\\"fileTabs\\\"></div>\\n    </div>\\n  </div>\\n\\n  <!-- Main content -->\\n  <div class=\\\"main\\\" id=\\\"mainContent\\\">\\n    <div id=\\\"stepCallout\\\" class=\\\"callout\\\"></div>\\n\\n    <div style=\\\"display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:0;\\\">\\n      <div class=\\\"view-tab active\\\" onclick=\\\"switchView('code')\\\">Code View</div>\\n      <div class=\\\"view-tab\\\" onclick=\\\"switchView('trees')\\\">Git Trees</div>\\n      <div class=\\\"view-tab\\\" onclick=\\\"switchView('lifo')\\\">LIFO Demo</div>\\n    </div>\\n\\n    <!-- Code View -->\\n    <div class=\\\"view-content active\\\" id=\\\"view-code\\\">\\n      <div class=\\\"panel\\\">\\n        <div class=\\\"panel-header\\\">\\n          <span id=\\\"codeTitle\\\">main.go</span>\\n          <div style=\\\"flex:1\\\"></div>\\n          <span id=\\\"codeState\\\" style=\\\"font-size:11px;color:var(--text3)\\\"></span>\\n        </div>\\n        <div class=\\\"panel-body\\\">\\n          <div class=\\\"code-view\\\" id=\\\"codeView\\\"></div>\\n        </div>\\n      </div>\\n      <div class=\\\"panel\\\" style=\\\"margin-top:16px\\\">\\n        <div class=\\\"panel-header\\\">Attribution Calculation</div>\\n        <div class=\\\"panel-body\\\">\\n          <div id=\\\"calcView\\\" class=\\\"calc\\\"></div>\\n        </div>\\n      </div>\\n    </div>\\n\\n    <!-- Trees View -->\\n    <div class=\\\"view-content\\\" id=\\\"view-trees\\\">\\n      <div class=\\\"panel\\\">\\n        <div class=\\\"panel-header\\\">Three-Tree Model</div>\\n        <div class=\\\"panel-body\\\">\\n          <div class=\\\"callout\\\" style=\\\"border-left-color:var(--agent)\\\">\\n            Attribution compares three git trees: <code>baseTree</code> (session start), <code>shadowTree</code> (last checkpoint), and <code>headTree</code> (current worktree at commit time). The shadow branch captures agent work + any user edits baked into checkpoints.\\n          </div>\\n          <div class=\\\"tree-diagram\\\" id=\\\"treeDiagram\\\"></div>\\n          <div style=\\\"margin-top:20px\\\">\\n            <div class=\\\"calc\\\" id=\\\"treeDiffs\\\"></div>\\n          </div>\\n        </div>\\n      </div>\\n    </div>\\n\\n    <!-- LIFO View -->\\n    <div class=\\\"view-content\\\" id=\\\"view-lifo\\\">\\n      <div class=\\\"panel\\\">\\n        <div class=\\\"panel-header\\\">LIFO Heuristic: Per-File Pool Tracking</div>\\n        <div class=\\\"panel-body\\\">\\n          <div class=\\\"callout\\\">\\n            When a user removes lines, who wrote them? The CLI uses a <strong>LIFO heuristic</strong>: assume users modify their own recent additions first. Click lines below to \\\"remove\\\" them and see how the algorithm attributes the change.\\n          </div>\\n          <div class=\\\"lifo-grid\\\">\\n            <div class=\\\"lifo-panel\\\">\\n              <h4>main.go - Click lines to remove</h4>\\n              <div id=\\\"lifoLines\\\"></div>\\n            </div>\\n            <div class=\\\"lifo-panel\\\">\\n              <h4>Attribution Impact</h4>\\n              <div id=\\\"lifoResult\\\" class=\\\"lifo-result\\\"></div>\\n            </div>\\n          </div>\\n          <div style=\\\"margin-top:16px\\\">\\n            <div class=\\\"lifo-grid\\\">\\n              <div class=\\\"lifo-panel\\\">\\n                <h4>With Per-File Tracking (actual)</h4>\\n                <div id=\\\"lifoWithTracking\\\" class=\\\"lifo-result\\\"></div>\\n              </div>\\n              <div class=\\\"lifo-panel\\\">\\n                <h4>Without Per-File Tracking (naive)</h4>\\n                <div id=\\\"lifoWithoutTracking\\\" class=\\\"lifo-result\\\"></div>\\n              </div>\\n            </div>\\n          </div>\\n        </div>\\n      </div>\\n    </div>\\n  </div>\\n\\n  <!-- Prompt bar -->\\n  <div class=\\\"prompt-bar\\\">\\n    <pre id=\\\"promptOutput\\\"></pre>\\n    <button class=\\\"copy-btn\\\" onclick=\\\"copyPrompt()\\\">Copy</button>\\n  </div>\\n</div>\\n\\n<script>\\n// ─── State ───────────────────────────────────────────────────────\\nconst state = {\\n  preset: 'mixed',\\n  step: 0,\\n  activeFile: 'main.go',\\n  activeView: 'code',\\n  lifoRemoved: new Set(),\\n};\\n\\n// ─── Presets ─────────────────────────────────────────────────────\\nconst PRESETS = {\\n  simple: {\\n    name: 'Agent Only',\\n    desc: 'Agent writes everything',\\n    pct: '100%',\\n    files: {\\n      'main.go': {\\n        base: [\\n          { text: 'package main', owner: 'base' },\\n          { text: '', owner: 'base' },\\n          { text: 'func main() {', owner: 'base' },\\n          { text: '}', owner: 'base' },\\n        ]\\n      }\\n    },\\n    steps: [\\n      { label: 'Session start', tag: 'system', desc: 'Base commit established. File has 4 lines of boilerplate.',\\n        actions: {} },\\n      { label: 'Prompt submitted', tag: 'system', desc: '<code>CalculatePromptAttribution()</code> runs. No user edits to capture (UserLinesAdded=0).',\\n        actions: {} },\\n      { label: 'Agent writes code', tag: 'agent', desc: 'Agent adds 8 lines: imports, fmt.Println, and a helper function. Checkpoint saved to shadow branch.',\\n        actions: { 'main.go': { add: [\\n          { after: 1, lines: [{ text: 'import \\\"fmt\\\"', owner: 'agent' }] },\\n          { after: 4, lines: [\\n            { text: '    fmt.Println(\\\"Hello\\\")', owner: 'agent' },\\n            { text: '    result := compute(42)', owner: 'agent' },\\n            { text: '    fmt.Println(result)', owner: 'agent' },\\n          ]},\\n          { after: 99, lines: [\\n            { text: '', owner: 'agent' },\\n            { text: 'func compute(n int) int {', owner: 'agent' },\\n            { text: '    return n * 2', owner: 'agent' },\\n            { text: '}', owner: 'agent' },\\n          ]}\\n        ]}},\\n      },\\n      { label: 'User commits', tag: 'system', desc: '<code>CalculateAttributionWithAccumulated()</code> runs. Agent wrote all 8 new lines. No human edits at all.',\\n        actions: {} },\\n    ],\\n  },\\n  mixed: {\\n    name: 'Mixed Contributions',\\n    desc: 'Both agent and human contribute',\\n    pct: '~67%',\\n    files: {\\n      'main.go': {\\n        base: [\\n          { text: 'package main', owner: 'base' },\\n          { text: '', owner: 'base' },\\n          { text: 'func main() {', owner: 'base' },\\n          { text: '}', owner: 'base' },\\n        ]\\n      }\\n    },\\n    steps: [\\n      { label: 'Session start', tag: 'system', desc: 'Base commit established. Starting with a minimal main.go.',\\n        actions: {} },\\n      { label: 'User adds code', tag: 'human', desc: 'Human adds 3 lines: an import and two function calls.',\\n        actions: { 'main.go': { add: [\\n          { after: 1, lines: [{ text: 'import \\\"fmt\\\"', owner: 'human' }] },\\n          { after: 4, lines: [\\n            { text: '    fmt.Println(\\\"starting\\\")', owner: 'human' },\\n            { text: '    fmt.Println(\\\"ready\\\")', owner: 'human' },\\n          ]},\\n        ]}}\\n      },\\n      { label: 'Prompt submitted', tag: 'system', desc: '<code>CalculatePromptAttribution()</code> captures: UserLinesAdded=3, UserAddedPerFile={\\\"main.go\\\": 3}. These edits happened BEFORE the agent runs.',\\n        actions: {} },\\n      { label: 'Agent writes code', tag: 'agent', desc: 'Agent adds 6 lines: error handling, a helper function, and a constant. Shadow branch checkpoint saved.',\\n        actions: { 'main.go': { add: [\\n          { after: 2, lines: [{ text: 'import \\\"os\\\"', owner: 'agent' }] },\\n          { after: 7, lines: [\\n            { text: '    if err := run(); err != nil {', owner: 'agent' },\\n            { text: '        os.Exit(1)', owner: 'agent' },\\n            { text: '    }', owner: 'agent' },\\n          ]},\\n          { after: 99, lines: [\\n            { text: '', owner: 'agent' },\\n            { text: 'func run() error {', owner: 'agent' },\\n            { text: '    return nil', owner: 'agent' },\\n          ]}\\n        ]}}\\n      },\\n      { label: 'User makes final edits', tag: 'human', desc: 'Human adds 1 more line after the agent\\\\'s work. No lines removed.',\\n        actions: { 'main.go': { add: [\\n          { after: 99, lines: [{ text: '}', owner: 'human' }] },\\n        ]}}\\n      },\\n      { label: 'User commits', tag: 'system', desc: '<code>CalculateAttributionWithAccumulated()</code>: base->shadow has 9 adds (3 human + 6 agent). Accumulated user=3, so agent=6. Post-checkpoint: +1 human. Total: 6 agent + 4 human = 10 lines. Agent: 60%.',\\n        actions: {} },\\n    ],\\n  },\\n  heavy_edit: {\\n    name: 'Heavy Editing',\\n    desc: 'Human rewrites agent code',\\n    pct: '~25%',\\n    files: {\\n      'main.go': {\\n        base: [\\n          { text: 'package main', owner: 'base' },\\n          { text: '', owner: 'base' },\\n          { text: 'import \\\"fmt\\\"', owner: 'base' },\\n          { text: '', owner: 'base' },\\n          { text: 'func main() {', owner: 'base' },\\n          { text: '    fmt.Println(\\\"hello\\\")', owner: 'base' },\\n          { text: '}', owner: 'base' },\\n        ]\\n      }\\n    },\\n    steps: [\\n      { label: 'Session start', tag: 'system', desc: 'Base commit: a simple hello-world program with 7 lines.',\\n        actions: {} },\\n      { label: 'Prompt submitted', tag: 'system', desc: '<code>CalculatePromptAttribution()</code>: no user edits yet.',\\n        actions: {} },\\n      { label: 'Agent writes code', tag: 'agent', desc: 'Agent adds 8 lines: a struct, constructor, and method. Shadow checkpoint saved.',\\n        actions: { 'main.go': { add: [\\n          { after: 7, lines: [\\n            { text: '', owner: 'agent' },\\n            { text: 'type Server struct {', owner: 'agent' },\\n            { text: '    port int', owner: 'agent' },\\n            { text: '}', owner: 'agent' },\\n            { text: '', owner: 'agent' },\\n            { text: 'func NewServer() *Server {', owner: 'agent' },\\n            { text: '    return &Server{port: 8080}', owner: 'agent' },\\n            { text: '}', owner: 'agent' },\\n          ]}\\n        ]}}\\n      },\\n      { label: 'User rewrites agent code', tag: 'human', desc: 'Human removes 6 of the agent\\\\'s 8 lines and replaces with 6 of their own (different implementation). Per-file LIFO: user had 0 prior additions to main.go, so all 6 removals target agent lines.',\\n        actions: { 'main.go': { remove: [8,9,10,11,12,13], add: [\\n          { after: 7, lines: [\\n            { text: '', owner: 'human' },\\n            { text: 'type App struct {', owner: 'human' },\\n            { text: '    name string', owner: 'human' },\\n            { text: '    port int', owner: 'human' },\\n            { text: '}', owner: 'human' },\\n            { text: '', owner: 'human' },\\n          ]}\\n        ]}}\\n      },\\n      { label: 'User commits', tag: 'system', desc: 'Agent originally added 8, user removed 6 agent lines (LIFO: 0 self-mods since user had 0 prior adds). Agent surviving = 8-6-0 = 2. User added 6. Total committed = 2+6 = 8. Agent: 25%.',\\n        actions: {} },\\n    ],\\n  },\\n  self_mod: {\\n    name: 'Self-Modification',\\n    desc: 'LIFO preserves agent credit',\\n    pct: '~67%',\\n    files: {\\n      'main.go': {\\n        base: [\\n          { text: 'package main', owner: 'base' },\\n          { text: '', owner: 'base' },\\n          { text: 'func main() {', owner: 'base' },\\n          { text: '}', owner: 'base' },\\n        ]\\n      }\\n    },\\n    steps: [\\n      { label: 'Session start', tag: 'system', desc: 'Base commit: minimal main.go.',\\n        actions: {} },\\n      { label: 'User adds 5 lines', tag: 'human', desc: 'Human writes 5 lines of setup code in main.go.',\\n        actions: { 'main.go': { add: [\\n          { after: 1, lines: [{ text: 'import \\\"fmt\\\"', owner: 'human' }] },\\n          { after: 4, lines: [\\n            { text: '    name := \\\"world\\\"', owner: 'human' },\\n            { text: '    greeting := \\\"hello\\\"', owner: 'human' },\\n            { text: '    msg := greeting + \\\" \\\" + name', owner: 'human' },\\n            { text: '    fmt.Println(msg)', owner: 'human' },\\n          ]},\\n        ]}}\\n      },\\n      { label: 'Prompt submitted', tag: 'system', desc: '<code>CalculatePromptAttribution()</code>: UserLinesAdded=5, UserAddedPerFile={\\\"main.go\\\": 5}. This per-file tracking is critical for the LIFO heuristic later.',\\n        actions: {} },\\n      { label: 'Agent adds 10 lines', tag: 'agent', desc: 'Agent adds error handling and a helper. Shadow checkpoint saved with both human and agent code.',\\n        actions: { 'main.go': { add: [\\n          { after: 2, lines: [{ text: 'import \\\"os\\\"', owner: 'agent' }] },\\n          { after: 8, lines: [\\n            { text: '    if err := validate(msg); err != nil {', owner: 'agent' },\\n            { text: '        fmt.Fprintf(os.Stderr, \\\"error: %v\\\\\\\\n\\\", err)', owner: 'agent' },\\n            { text: '        os.Exit(1)', owner: 'agent' },\\n            { text: '    }', owner: 'agent' },\\n          ]},\\n          { after: 99, lines: [\\n            { text: '', owner: 'agent' },\\n            { text: 'func validate(s string) error {', owner: 'agent' },\\n            { text: '    if s == \\\"\\\" {', owner: 'agent' },\\n            { text: '        return fmt.Errorf(\\\"empty\\\")', owner: 'agent' },\\n            { text: '    }', owner: 'agent' },\\n            { text: '    return nil', owner: 'agent' },\\n          ]},\\n        ]}}\\n      },\\n      { label: 'User modifies own 3 lines', tag: 'human', desc: 'Human removes 3 of their own lines and replaces with 3 new ones. LIFO: user added 5 to main.go, removing 3 -> min(3,5)=3 self-modifications. Agent lines untouched!',\\n        actions: { 'main.go': { remove: [5,6,7], add: [\\n          { after: 4, lines: [\\n            { text: '    name := \\\"Gopher\\\"', owner: 'human' },\\n            { text: '    greeting := \\\"Hi\\\"', owner: 'human' },\\n            { text: '    msg := fmt.Sprintf(\\\"%s, %s!\\\", greeting, name)', owner: 'human' },\\n          ]}\\n        ]}}\\n      },\\n      { label: 'User commits', tag: 'system', desc: 'LIFO calculation: user removed 3 from main.go, previously added 5. selfModified=min(3,5)=3. humanModifiedAgent=max(0,3-3)=0. Agent lines preserved at 10. Total=10+5=15. Agent: 66.7%. Without LIFO, it would be 46.7%!',\\n        actions: {} },\\n    ],\\n  },\\n  multi_file: {\\n    name: 'Multi-File',\\n    desc: 'Per-file tracking across files',\\n    pct: '~62%',\\n    files: {\\n      'main.go': {\\n        base: [\\n          { text: 'package main', owner: 'base' },\\n          { text: '', owner: 'base' },\\n          { text: 'func main() {', owner: 'base' },\\n          { text: '}', owner: 'base' },\\n        ]\\n      },\\n      'utils.go': {\\n        base: [\\n          { text: 'package main', owner: 'base' },\\n        ]\\n      },\\n    },\\n    steps: [\\n      { label: 'Session start', tag: 'system', desc: 'Base commit: two files, main.go and utils.go.',\\n        actions: {} },\\n      { label: 'User edits main.go', tag: 'human', desc: 'Human adds 3 lines to main.go only.',\\n        actions: { 'main.go': { add: [\\n          { after: 3, lines: [\\n            { text: '    result := add(1, 2)', owner: 'human' },\\n            { text: '    println(result)', owner: 'human' },\\n            { text: '    println(\\\"done\\\")', owner: 'human' },\\n          ]}\\n        ]}}\\n      },\\n      { label: 'Prompt submitted', tag: 'system', desc: '<code>CalculatePromptAttribution()</code>: UserAddedPerFile={\\\"main.go\\\": 3, \\\"utils.go\\\": 0}. Per-file tracking shows human only touched main.go.',\\n        actions: {} },\\n      { label: 'Agent writes both files', tag: 'agent', desc: 'Agent adds 3 lines to main.go and 5 to utils.go. Shadow checkpoint captures both files.',\\n        actions: {\\n          'main.go': { add: [\\n            { after: 6, lines: [\\n              { text: '    diff := subtract(5, 3)', owner: 'agent' },\\n              { text: '    println(diff)', owner: 'agent' },\\n              { text: '    println(\\\"computed\\\")', owner: 'agent' },\\n            ]}\\n          ]},\\n          'utils.go': { add: [\\n            { after: 1, lines: [\\n              { text: '', owner: 'agent' },\\n              { text: 'func add(a, b int) int {', owner: 'agent' },\\n              { text: '    return a + b', owner: 'agent' },\\n              { text: '}', owner: 'agent' },\\n              { text: '', owner: 'agent' },\\n            ]}\\n          ]}\\n        }\\n      },\\n      { label: 'User edits both files', tag: 'human', desc: 'Human removes 2 lines from main.go (their own code) and adds 3 to utils.go. Per-file LIFO: main.go removals=2, user added 3 before -> selfMod=min(2,3)=2. utils.go removals=0.',\\n        actions: {\\n          'main.go': { remove: [5,6] },\\n          'utils.go': { add: [\\n            { after: 6, lines: [\\n              { text: 'func subtract(a, b int) int {', owner: 'human' },\\n              { text: '    return a - b', owner: 'human' },\\n              { text: '}', owner: 'human' },\\n            ]}\\n          ]}\\n        }\\n      },\\n      { label: 'User commits', tag: 'system', desc: 'Per-file LIFO across files: main.go selfMod=min(2,3)=2 (user edited own code). utils.go selfMod=0. Agent=8, pureUserAdded=4, pureUserRemoved=0. Total=12. Agent: 62.5%.',\\n        actions: {} },\\n    ],\\n  },\\n};\\n\\n// ─── Simulation State ────────────────────────────────────────────\\nlet currentLines = {}; // file -> array of {text, owner}\\nlet promptAttributions = []; // accumulated\\nlet filesTrackedByAgent = new Set();\\n\\nfunction resetSimulation() {\\n  const preset = PRESETS[state.preset];\\n  currentLines = {};\\n  promptAttributions = [];\\n  filesTrackedByAgent = new Set();\\n  for (const [fname, fdata] of Object.entries(preset.files)) {\\n    currentLines[fname] = fdata.base.map(l => ({...l}));\\n  }\\n}\\n\\nfunction applyStepActions(stepIdx) {\\n  const preset = PRESETS[state.preset];\\n  const step = preset.steps[stepIdx];\\n  if (!step || !step.actions) return;\\n\\n  for (const [fname, action] of Object.entries(step.actions)) {\\n    if (!currentLines[fname]) currentLines[fname] = [];\\n    let lines = currentLines[fname];\\n\\n    // Remove lines first (by 1-indexed positions, descending)\\n    if (action.remove) {\\n      const toRemove = [...action.remove].sort((a,b) => b-a);\\n      for (const idx of toRemove) {\\n        if (idx - 1 < lines.length) lines.splice(idx - 1, 1);\\n      }\\n    }\\n\\n    // Add lines\\n    if (action.add) {\\n      // Sort additions by position descending so indices stay valid\\n      const sorted = [...action.add].sort((a,b) => b.after - a.after);\\n      for (const addition of sorted) {\\n        const pos = addition.after >= 99 ? lines.length : Math.min(addition.after, lines.length);\\n        lines.splice(pos, 0, ...addition.lines.map(l => ({...l})));\\n      }\\n    }\\n\\n    // Track agent-touched files\\n    if (step.tag === 'agent') filesTrackedByAgent.add(fname);\\n\\n    currentLines[fname] = lines;\\n  }\\n\\n  // Capture prompt attribution at \\\"prompt submitted\\\" steps\\n  if (step.tag === 'system' && step.label.includes('Prompt')) {\\n    const pa = calculatePromptAttribution();\\n    promptAttributions.push(pa);\\n  }\\n}\\n\\nfunction calculatePromptAttribution() {\\n  const preset = PRESETS[state.preset];\\n  const pa = { userAdded: 0, userRemoved: 0, userAddedPerFile: {} };\\n  for (const fname of Object.keys(preset.files)) {\\n    const base = preset.files[fname].base;\\n    const current = currentLines[fname] || [];\\n    const added = current.filter(l => l.owner === 'human').length;\\n    if (added > 0) {\\n      pa.userAdded += added;\\n      pa.userAddedPerFile[fname] = added;\\n    }\\n  }\\n  return pa;\\n}\\n\\nfunction simulateToStep(targetStep) {\\n  resetSimulation();\\n  for (let i = 0; i <= targetStep; i++) {\\n    applyStepActions(i);\\n  }\\n}\\n\\n// ─── Attribution Calculation ─────────────────────────────────────\\nfunction calculateAttribution() {\\n  const preset = PRESETS[state.preset];\\n  const files = Object.keys(preset.files);\\n\\n  // Count lines by owner across all files at current state\\n  let agentLines = 0, humanLines = 0, baseLines = 0;\\n  for (const fname of files) {\\n    for (const line of (currentLines[fname] || [])) {\\n      if (line.owner === 'agent') agentLines++;\\n      else if (line.owner === 'human') humanLines++;\\n      else baseLines++;\\n    }\\n  }\\n\\n  // Accumulated user adds from prompt attributions\\n  let accUserAdded = 0;\\n  const accUserAddedPerFile = {};\\n  for (const pa of promptAttributions) {\\n    accUserAdded += pa.userAdded;\\n    for (const [f, n] of Object.entries(pa.userAddedPerFile)) {\\n      accUserAddedPerFile[f] = (accUserAddedPerFile[f] || 0) + n;\\n    }\\n  }\\n\\n  // Count what's in the shadow (checkpoint = agent + user edits baked in)\\n  // For our simulation, shadow = state at the last agent step\\n  const lastAgentStep = findLastAgentStep();\\n  let shadowAgentLines = 0, shadowHumanLines = 0;\\n  if (lastAgentStep >= 0) {\\n    const saved = {};\\n    resetSimulation();\\n    for (let i = 0; i <= lastAgentStep; i++) applyStepActions(i);\\n    for (const fname of files) {\\n      for (const line of (currentLines[fname] || [])) {\\n        if (line.owner === 'agent') shadowAgentLines++;\\n        else if (line.owner === 'human') shadowHumanLines++;\\n      }\\n    }\\n    // Restore to current step\\n    simulateToStep(state.step);\\n  }\\n\\n  const baseToShadowAdded = shadowAgentLines + shadowHumanLines;\\n  const totalAgentAdded = Math.max(0, baseToShadowAdded - accUserAdded);\\n\\n  // Post-checkpoint user edits\\n  const postUserAdded = Math.max(0, humanLines - accUserAdded);\\n  // Estimate removals\\n  let postUserRemoved = 0;\\n  let postUserRemovedPerFile = {};\\n  // Compare current human lines per file vs accumulated\\n  for (const fname of files) {\\n    const currentHuman = (currentLines[fname] || []).filter(l => l.owner === 'human').length;\\n    const accForFile = accUserAddedPerFile[fname] || 0;\\n    if (currentHuman < accForFile) {\\n      const removed = accForFile - currentHuman;\\n      postUserRemoved += removed;\\n      postUserRemovedPerFile[fname] = removed;\\n    }\\n  }\\n\\n  // LIFO self-modification\\n  let selfModified = 0;\\n  for (const [fname, removed] of Object.entries(postUserRemovedPerFile)) {\\n    const userAddedToFile = accUserAddedPerFile[fname] || 0;\\n    selfModified += Math.min(removed, userAddedToFile);\\n  }\\n\\n  const totalHumanModified = Math.min(humanLines + postUserAdded, postUserRemoved);\\n  const humanModifiedAgent = Math.max(0, totalHumanModified - selfModified);\\n  const pureUserAdded = Math.max(0, humanLines - totalHumanModified);\\n  const pureUserRemoved = Math.max(0, postUserRemoved - totalHumanModified);\\n\\n  const agentLinesInCommit = Math.max(0, totalAgentAdded - pureUserRemoved - humanModifiedAgent);\\n  let totalCommitted = agentLinesInCommit + pureUserAdded;\\n  if (totalCommitted <= 0) totalCommitted = Math.max(0, totalAgentAdded);\\n\\n  const agentPct = totalCommitted > 0 ? (agentLinesInCommit / totalCommitted * 100) : 0;\\n\\n  return {\\n    agentLines, humanLines, baseLines,\\n    accUserAdded, accUserAddedPerFile,\\n    baseToShadowAdded, totalAgentAdded,\\n    postUserAdded, postUserRemoved, postUserRemovedPerFile,\\n    selfModified, humanModifiedAgent,\\n    pureUserAdded, pureUserRemoved,\\n    agentLinesInCommit, totalCommitted,\\n    agentPct,\\n    shadowAgentLines, shadowHumanLines,\\n  };\\n}\\n\\nfunction findLastAgentStep() {\\n  const preset = PRESETS[state.preset];\\n  for (let i = state.step; i >= 0; i--) {\\n    if (preset.steps[i].tag === 'agent') return i;\\n  }\\n  return -1;\\n}\\n\\n// ─── Rendering ───────────────────────────────────────────────────\\nfunction render() {\\n  renderPresets();\\n  renderTimeline();\\n  renderFileTabs();\\n  renderCodeView();\\n  renderCalcView();\\n  renderTreeDiagram();\\n  renderLIFO();\\n  updatePrompt();\\n\\n  document.getElementById('prevBtn').disabled = state.step === 0;\\n  document.getElementById('nextBtn').disabled = state.step === PRESETS[state.preset].steps.length - 1;\\n}\\n\\nfunction renderPresets() {\\n  const el = document.getElementById('presets');\\n  el.innerHTML = Object.entries(PRESETS).map(([key, p]) =>\\n    `<button class=\\\"preset-btn ${state.preset === key ? 'active' : ''}\\\" onclick=\\\"selectPreset('${key}')\\\">\\n      ${p.name} <span class=\\\"pct\\\">${p.pct}</span>\\n    </button>`\\n  ).join('');\\n}\\n\\nfunction renderTimeline() {\\n  const preset = PRESETS[state.preset];\\n  const el = document.getElementById('timeline');\\n  el.innerHTML = preset.steps.map((s, i) => {\\n    const cls = i === state.step ? 'active' : (i < state.step ? 'completed' : '');\\n    const tagCls = s.tag === 'human' ? 'tag-human' : (s.tag === 'agent' ? 'tag-agent' : 'tag-system');\\n    return `<div class=\\\"step ${cls}\\\" onclick=\\\"goToStep(${i})\\\">\\n      <span class=\\\"dot\\\"></span>\\n      <span class=\\\"step-label\\\">${s.label}</span>\\n      <span class=\\\"step-tag ${tagCls}\\\">${s.tag}</span>\\n    </div>`;\\n  }).join('');\\n\\n  document.getElementById('stepCallout').innerHTML = preset.steps[state.step].desc;\\n}\\n\\nfunction renderFileTabs() {\\n  const preset = PRESETS[state.preset];\\n  const files = Object.keys(preset.files);\\n  const el = document.getElementById('fileTabs');\\n  el.innerHTML = files.map(f =>\\n    `<div class=\\\"tab ${state.activeFile === f ? 'active' : ''}\\\" onclick=\\\"selectFile('${f}')\\\">${f}</div>`\\n  ).join('');\\n}\\n\\nfunction renderCodeView() {\\n  const lines = currentLines[state.activeFile] || [];\\n  const el = document.getElementById('codeView');\\n  document.getElementById('codeTitle', state.activeFile);\\n\\n  if (lines.length === 0) {\\n    el.innerHTML = '<div style=\\\"color:var(--text3);padding:20px;text-align:center\\\">Empty file</div>';\\n    return;\\n  }\\n\\n  el.innerHTML = lines.map((l, i) => {\\n    const ownerIcon = l.owner === 'human' ? '<span class=\\\"owner-h\\\">H</span>'\\n                    : l.owner === 'agent' ? '<span class=\\\"owner-a\\\">A</span>'\\n                    : '<span class=\\\"owner-b\\\">.</span>';\\n    return `<div class=\\\"code-line ${l.owner}\\\">\\n      <span class=\\\"line-num\\\">${i+1}</span>\\n      <span class=\\\"line-owner\\\">${ownerIcon}</span>\\n      <span class=\\\"line-content\\\">${escapeHtml(l.text)}</span>\\n    </div>`;\\n  }).join('');\\n\\n  // Update state label\\n  const preset = PRESETS[state.preset];\\n  const step = preset.steps[state.step];\\n  document.getElementById('codeState').textContent =\\n    step.tag === 'agent' ? 'Shadow branch (checkpoint)' :\\n    step.label.includes('commit') ? 'HEAD (commit time)' : 'Working tree';\\n}\\n\\nfunction renderCalcView() {\\n  const el = document.getElementById('calcView');\\n  const preset = PRESETS[state.preset];\\n  const isCommitStep = preset.steps[state.step].label.toLowerCase().includes('commit');\\n  const hasAgentWork = findLastAgentStep() >= 0;\\n\\n  if (!hasAgentWork && !isCommitStep) {\\n    const humanCount = Object.values(currentLines).flat().filter(l => l.owner === 'human').length;\\n    const agentCount = Object.values(currentLines).flat().filter(l => l.owner === 'agent').length;\\n    el.innerHTML = `<div class=\\\"calc-section\\\">\\n      <div class=\\\"calc-title\\\">Current State</div>\\n      <div class=\\\"calc-line\\\">Human lines: <span class=\\\"human-val\\\">${humanCount}</span></div>\\n      <div class=\\\"calc-line\\\">Agent lines: <span class=\\\"agent-val\\\">${agentCount}</span></div>\\n      <div class=\\\"calc-line\\\" style=\\\"color:var(--text3)\\\">Full calculation shown at commit step</div>\\n    </div>`;\\n    return;\\n  }\\n\\n  const a = calculateAttribution();\\n\\n  let html = '';\\n\\n  // Prompt attributions\\n  if (promptAttributions.length > 0) {\\n    html += `<div class=\\\"calc-section\\\"><div class=\\\"calc-title\\\">Prompt Attributions (accumulated)</div>`;\\n    promptAttributions.forEach((pa, i) => {\\n      html += `<div class=\\\"calc-line\\\">PA #${i+1}: <span class=\\\"human-val\\\">+${pa.userAdded}</span> user lines`;\\n      const perFile = Object.entries(pa.userAddedPerFile).map(([f,n]) => `${f}:${n}`).join(', ');\\n      if (perFile) html += ` <span class=\\\"op\\\">(${perFile})</span>`;\\n      html += `</div>`;\\n    });\\n    html += `</div>`;\\n  }\\n\\n  // Step 1: base -> shadow\\n  html += `<div class=\\\"calc-section\\\"><div class=\\\"calc-title\\\">Step 1: base -> shadow diff</div>\\n    <div class=\\\"calc-line\\\">Total in shadow: <span class=\\\"val\\\">${a.baseToShadowAdded}</span> lines added <span class=\\\"op\\\">(${a.shadowAgentLines} agent + ${a.shadowHumanLines} human baked in)</span></div>\\n  </div>`;\\n\\n  // Step 2: subtract accumulated\\n  html += `<div class=\\\"calc-section\\\"><div class=\\\"calc-title\\\">Step 2: Isolate agent work</div>\\n    <div class=\\\"calc-line\\\">Agent added = <span class=\\\"val\\\">${a.baseToShadowAdded}</span> <span class=\\\"op\\\">-</span> <span class=\\\"human-val\\\">${a.accUserAdded}</span> accumulated user <span class=\\\"op\\\">=</span> <span class=\\\"agent-val\\\">${a.totalAgentAdded}</span></div>\\n  </div>`;\\n\\n  // Step 3: post-checkpoint\\n  html += `<div class=\\\"calc-section\\\"><div class=\\\"calc-title\\\">Step 3: shadow -> head (post-checkpoint)</div>\\n    <div class=\\\"calc-line\\\">User added: <span clas