ty\\\"`\\n   164→}\\n   165→\\n   166→// PromptAttribution captures line-level attribution data at the start of each prompt.\\n   167→// By recording what changed since the last checkpoint BEFORE the agent works,\\n   168→// we can accurately separate user edits from agent contributions.\\n   169→type PromptAttribution struct {\\n   170→\\t// CheckpointNumber is which checkpoint this was recorded before (1-indexed)\\n   171→\\tCheckpointNumber int `json:\\\"checkpoint_number\\\"`\\n   172→\\n   173→\\t// UserLinesAdded is lines added by user since the last checkpoint\\n   174→\\tUserLinesAdded int `json:\\\"user_lines_added\\\"`\\n   175→\\n   176→\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   177→\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   178→\\n   179→\\t// AgentLinesAdded is total agent lines added so far (base → last checkpoint).\\n   180→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   181→\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   182→\\n   183→\\t// AgentLinesRemoved is total agent lines removed so far (base → last checkpoint).\\n   184→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   185→\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   186→\\n   187→\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   188→\\t// This enables distinguishing user self-modifications from agent modifications.\\n   189→\\t// See docs/architecture/attribution.md for details.\\n   190→\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   191→}\\n   192→\\n   193→// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   194→// Call this after deserializing a State from JSON.\\n   195→func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   196→\\t// Normalize legacy phase values. \\\"active_committe