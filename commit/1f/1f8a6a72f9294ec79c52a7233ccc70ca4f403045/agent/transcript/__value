\\n  return {aL,hL,accU,accPF,b2s,tAgentAdded,postUA,postUR,postURPF,selfMod,hMA,pUA,pUR,aInC,tC,pct,shA,shH};\\n}\\n\\n// ── Rendering ────────────────────────────────────────────\\nfunction render() {\\n  renderLegend();\\n  renderPresets();\\n  renderTimeline();\\n  renderNav();\\n  renderFileTabs();\\n  renderCallout();\\n  renderViewTabs();\\n  renderCodeView();\\n  renderCalcView();\\n  renderTrees();\\n  renderLIFO();\\n  updatePrompt();\\n}\\n\\nfunction renderLegend() {\\n  const c = $('legend');\\n  clear(c);\\n  [{color:'var(--base)',label:'Base'},{color:'var(--human)',label:'Human'},{color:'var(--agent)',label:'Agent'}].forEach(x => {\\n    const dot = el('span',{style:{width:'8px',height:'8px',borderRadius:'2px',background:x.color,display:'inline-block'}});\\n    const item = el('span',{style:{display:'flex',alignItems:'center',gap:'3px'}}, [dot, el('span',null,x.label)]);\\n    c.appendChild(item);\\n  });\\n}\\n\\nfunction renderPresets() {\\n  const c = $('presets'); clear(c);\\n  for (const [k,v] of Object.entries(P)) {\\n    const btn = el('button',{\\n      cls:'preset-btn'+(S.preset===k?' active':''),\\n      style:{padding:'7px 10px',background:S.preset===k?'rgba(210,168,255,0.08)':'var(--bg)',border:'1px solid '+(S.preset===k?'var(--accent)':'var(--border)'),color:S.preset===k?'var(--accent)':'var(--text)',borderRadius:'5px',cursor:'pointer',fontSize:'11px',display:'flex',justifyContent:'space-between',width:'100%',marginBottom:'3px'},\\n      onclick: () => selPreset(k)\\n    });\\n    btn.appendChild(el('span',null,v.name));\\n    btn.appendChild(el('span',{style:{color:'var(--text3)',fontFamily:'var(--mono)',fontSize:'10px'}},v.pct));\\n    c.appendChild(btn);\\n  }\\n}\\n\\nfunction renderTimeline() {\\n  const c = $('timeline'); clear(c);\\n  P[S.preset].steps.forEach((s,i) => {\\n    const isDone = i < S.step, isActive = i === S.step;\\n    const dot = el('span',{style:{width:'7px',height:'7px',borderRadius:'50%',background:isActive?'var(--accent)':(isDone?'var(--agent)':'var(--bg3)'),flexShrink:'0',boxShadow:isActive?'0 0 6px rgba(210,168,255,0.4)':'none'}});\\n    const label = el('span',{style:{flex:'1',fontSize:'11px'}},s.l);\\n    const tagColor = s.g==='h'?{bg:'var(--human-bg)',c:'var(--human)',border:'var(--human-border)'}:s.g==='a'?{bg:'var(--agent-bg)',c:'var(--agent)',border:'var(--agent-border)'}:{bg:'rgba(210,168,255,0.08)',c:'var(--accent)',border:'rgba(210,168,255,0.25)'};\\n    const tagText = s.g==='h'?'human':s.g==='a'?'agent':'system';\\n    const tag = el('span',{style:{fontSize:'9px',padding:'1px 5px',borderRadius:'3px',fontFamily:'var(--mono)',background:tagColor.bg,color:tagColor.c,border:'1px solid '+tagColor.border}},tagText);\\n    const row = el('div',{style:{display:'flex',alignItems:'center',gap:'6px',padding:'5px 8px',borderRadius:'5px',cursor:'pointer',border:isActive?'1px solid var(--border)':'1px solid transparent',background:isActive?'var(--bg)':'transparent'},onclick:()=>goTo(i)},[dot,label,tag]);\\n    c.appendChild(row);\\n  });\\n}\\n\\nfunction renderNav() {\\n  const c = $('navBar'); clear(c);\\n  const mkBtn = (text, disabled, onclick) => {\\n    const b = el('button',{style:{flex:'1',padding:'6px',background:'var(--bg)',border:'1px solid var(--border)',color:'var(--text)',borderRadius:'5px',cursor:disabled?'default':'pointer',fontSize:'11px',opacity:disabled?'0.3':'1'},onclick:disabled?null:onclick},text);\\n    return b;\\n  };\\n  c.appendChild(mkBtn('< Prev', S.step===0, prev));\\n  c.appendChild(mkBtn('Next >', S.step===P[S.preset].steps.length-1, next));\\n}\\n\\nfunction renderFileTabs() {\\n  const files = Object.keys(P[S.preset].files);\\n  const sec = $('fileSection');\\n  sec.style.display = files.length > 1 ? 'block' : 'none';\\n  const c = $('fileTabs'); clear(c);\\n  files.forEach(f => {\\n    const tab = el('div',{style:{padding:'5px 12px',fontSize:'11px',cursor:'pointer',color:S.file===f?'var(--text)':'var(--text2)',borderBottom:S.file===f?'2px solid var(--accent)':'2px solid transparent',fontFamily:'var(--mono)'},onclick:()=>selFile(f)},f);\\n    c.appendChild(tab);\\n  });\\n}\\n\\nfunction renderCallout() {\\n  const c = $('callout');\\n  c.textContent = P[S.preset].steps[S.step].d;\\n}\\n\\nfunction renderViewTabs() {\\n  const c = $('viewTabs'); clear(c);\\n  [{id:'code',label:'Code View'},{id:'trees',label:'Git Trees'},{id:'lifo',label:'LIFO Demo'}].forEach(v => {\\n    const tab = el('div',{cls:'vtab'+(S.view===v.id?' active':''),style:{padding:'8px 16px',fontSize:'12px',cursor:'pointer',color:S.view===v.id?'var(--text)':'var(--text2)',borderBottom:S.view===v.id?'2px solid var(--accent)':'2px solid transparent'},\\n      onclick:()=>{S.view=v.id; render();}\\n    },v.label);\\n    c.appendChild(tab);\\n  });\\n  document.querySelectorAll('.vc').forEach(e=>e.classList.remove('active'));\\n  $('v-'+S.view).classList.add('active');\\n}\\n\\nfunction renderCodeView() {\\n  const ls = lines[S.file] || [];\\n  $('codeTitle').textContent = S.file;\\n  const st = P[S.preset].steps[S.step];\\n  $('codeState').textContent = st.g==='a'?'shadow branch (checkpoint)':st.l.toLowerCase().includes('commit')?'HEAD (commit time)':'working tree';\\n  const c = $('codeView'); clear(c);\\n  if (ls.length === 0) {\\n    c.appendChild(el('div',{style:{color:'var(--text3)',padding:'16px',textAlign:'center'}},'Empty file'));\\n    return;\\n  }\\n  ls.forEach((l,i) => {\\n    const bg = l.o==='human'?'var(--human-bg)':l.o==='agent'?'var(--agent-bg)':'transparent';\\n    const ownerColor = l.o==='human'?'var(--human)':l.o==='agent'?'var(--agent)':'var(--text3)';\\n    const ownerChar = l.o==='human'?'H':l.o==='agent'?'A':'\\\\u00B7';\\n    const row = el('div',{style:{display:'flex',padding:'0 10px',borderRadius:'2px',background:bg}},[\\n      el('span',{style:{color:'var(--text3)',width:'28px',textAlign:'right',marginRight:'12px',userSelect:'none',flexShrink:'0'}},String(i+1)),\\n      el('span',{style:{width:'14px',flexShrink:'0',marginRight:'6px',display:'flex',alignItems:'center',justifyContent:'center',fontSize:'8px',fontWeight:'700',color:ownerColor}},ownerChar),\\n      el('span',{style:{flex:'1',whiteSpace:'pre',fontFamily:'var(--mono)'}},l.t)\\n    ]);\\n    c.appendChild(row);\\n  });\\n}\\n\\nfunction renderCalcView() {\\n  const c = $('calcView'); clear(c);\\n  const las = lastAgentStep();\\n  if (las < 0) {\\n    const hc = Object.values(lines).flat().filter(l=>l.o==='human').length;\\n    const ac = Object.values(lines).flat().filter(l=>l.o==='agent').length;\\n    const s = el('div');\\n    s.appendChild(mkCalcTitle('Current State'));\\n    s.appendChild(mkCalcLine(['Human lines: ',mkSpan(String(hc),'var(--human)')]));\\n    s.appendChild(mkCalcLine(['Agent lines: ',mkSpan(String(ac),'var(--agent)')]));\\n    s.appendChild(mkCalcLine([mkSpan('Full calculation shown after agent runs','var(--text3)')]));\\n    c.appendChild(s);\\n    return;\\n  }\\n  const a = calcAttr();\\n\\n  // Prompt attributions\\n  if (pAs.length > 0) {\\n    const s = el('div',{style:{marginBottom:'10px'}});\\n    s.appendChild(mkCalcTitle('Prompt Attributions (accumulated)'));\\n    pAs.forEach((pa,i) => {\\n      const pf = Object.entries(pa.perFile).map(([f,n])=>f+':'+n).join(', ');\\n      s.appendChild(mkCalcLine(['PA #'+(i+1)+': ',mkSpan('+'+pa.userAdded,'var(--human)'),' user lines',pf?mkSpan(' ('+pf+')','var(--text3)'):null]));\\n    });\\n    c.appendChild(s);\\n  }\\n\\n  // Steps\\n  const s1 = el('div',{style:{marginBottom:'10px'}});\\n  s1.appendChild(mkCalcTitle('Step 1: base \\\\u2192 shadow diff'));\\n  s1.appendChild(mkCalcLine(['Total in shadow: ',mkSpan(String(a.b2s),'var(--text)'), ' lines ',mkSpan('('+a.shA+' agent + '+a.shH+' human baked in)','var(--text3)')]));\\n  c.appendChild(s1);\\n\\n  const s2 = el('div',{style:{marginBottom:'10px'}});\\n  s2.appendChild(mkCalcTitle('Step 2: Isolate agent work'));\\n  s2.appendChild(mkCalcLine(['Agent = ',mkSpan(String(a.b2s),'var(--text)'),' ',mkSpan('\\\\u2212','var(--text3)'),' ',mkSpan(String(a.accU),'var(--human)'),' accumulated user ',mkSpan('=','var(--text3)'),' ',mkSpan(String(a.tAgentAdded),'var(--agent)')]));\\n  c.appendChild(s2);\\n\\n  const s3 = el('div',{style:{marginBottom:'10px'}});\\n  s3.appendChild(mkCalcTitle('Step 3: shadow \\\\u2192 head (post-checkpoint)'));\\n  s3.appendChild(mkCalcLine(['User added: ',mkSpan('+'+a.postUA,'var(--human)'),', removed: ',mkSpan(String(a.postUR),'var(--removed)')]));\\n  c.appendChild(s3);\\n\\n  if (a.postUR > 0) {\\n    const s4 = el('div',{style:{marginBottom:'10px'}});\\n    s4.appendChild(mkCalcTitle('Step 4: LIFO self-modification'));\\n    for (const [f,r] of Object.entries(a.postURPF)) {\\n      const ua = a.accPF[f]||0;\\n      s4.appendChild(mkCalcLine([f+': removed ',mkSpan(String(r),'var(--removed)'),', user prior adds ',mkSpan(String(ua),'var(--human)'),' \\\\u2192 selfMod=min('+r+','+ua+')=',mkSpan(String(Math.min(r,ua)),'var(--text)')]));\\n    }\\n    s4.appendChild(mkCalcLine(['Modified agent lines: ',mkSpan(String(a.hMA),'var(--text)')]));\\n    c.appendChild(s4);\\n  }\\n\\n  const s5 = el('div',{style:{marginBottom:'10px'}});\\n  s5.appendChild(mkCalcTitle('Step 5: Final calculation'));\\n  s5.appendChild(mkCalcLine(['Agent in commit: ',mkSpan(String(a.aInC),'var(--agent)'),' ',mkSpan('= '+a.tAgentAdded+' \\\\u2212 '+a.pUR+' removed \\\\u2212 '+a.hMA+' modified','var(--text3)')]));\\n  s5.appendChild(mkCalcLine(['Pure user added: ',mkSpan(String(a.pUA),'var(--human)')]));\\n  s5.appendChild(mkCalcLine(['Total committed: ',mkSpan(String(a.tC),'var(--text)')]));\\n  c.appendChild(s5);\\n\\n  // Result box\\n  const hp = (100-a.pct).toFixed(1);\\n  const rb = el('div',{style:{marginTop:'8px',padding:'12px',background:'var(--bg)',borderRadius:'5px',border:'1px solid var(--border)'}});\\n  const bigPct = el('div',{style:{fontSize:'28px',fontWeight:'700',fontFamily:'var(--mono)'}});\\n  bigPct.appendChild(mkSpan(a.pct.toFixed(1)+'%','var(--agent)'));\\n  bigPct.appendChild(mkSpan(' / ','var(--text3)'));\\n  bigPct.appendChild(mkSpan(hp+'%','var(--human)'));\\n  rb.appendChild(bigPct);\\n  rb.appendChild(el('div',{style:{fontSize:'10px',color:'var(--text3)',marginTop:'2px'}},'agent / human'));\\n  const bar = el('div',{style:{height:'6px',borderRadius:'3px',background:'var(--bg3)',overflow:'hidden',marginTop:'6px',display:'flex'}});\\n  bar.appendChild(el('div',{style:{background:'var(--agent)',width:a.pct+'%',transition:'width 0.4s'}}));\\n  bar.appendChild(el('div',{style:{background:'var(--human)',width:hp+'%',transition:'width 0.4s'}}));\\n  rb.appendChild(bar);\\n  c.appendChild(rb);\\n}\\n\\nfunction mkCalcTitle(text) {\\n  return el('div',{style:{color:'var(--accent)',fontWeight:'600',marginBottom:'2px'}},text);\\n}\\nfunction mkCalcLine(parts) {\\n  const d = el('div',{style:{color:'var(--text2)',paddingLeft:'14px'}});\\n  parts.forEach(p => { if (p) { if (typeof p === 'string') d.appendChild(document.createTextNode(p)); else d.appendChild(p); } });\\n  return d;\\n}\\nfunction mkSpan(text, color) {\\n  return el('span',{style:{color:color}},text);\\n}\\n\\nfunction renderTrees() {\\n  const las = lastAgentStep(), st = P[S.preset].steps[S.step];\\n  const bhl = S.step===0, shl = st.g==='a', hhl = st.l.toLowerCase().includes('commit')||st.g==='h';\\n\\n  $('treeCallout').textContent = 'Attribution compares three git trees: baseTree (session start), shadowTree (last checkpoint on shadow branch), and headTree (worktree at commit). The shadow branch captures agent work + any user edits baked into checkpoints.';\\n\\n  const c = $('treeDia'); clear(c);\\n  [{label:'baseTree',sub:'Session start',hl:bhl},{arrow:true,text:'agent work +\\\\nbaked-in user edits'},{label:'shadowTree',sub:'Last checkpoint',hl:shl,dim:las<0},{arrow:true,text:'post-checkpoint\\\\nuser edits'},{label:'headTree',sub:'Worktree / commit',hl:hhl}].forEach(item => {\\n    if (item.arrow) {\\n      const d = el('div',{style:{textAlign:'center'}});\\n      d.appendChild(el('div',{style:{color:'var(--text3)',fontSize:'18px'}},'\\\\u2192'));\\n      d.appendChild(el('div',{style:{fontSize:'9px',color:'var(--text3)',textAlign:'center',maxWidth:'90px',whiteSpace:'pre-wrap'}},item.text));\\n      c.appendChild(d);\\n    } else {\\n      const d = el('div',{style:{textAlign:'center'}});\\n      const box = el('div',{style:{padding:'8px 16px',borderRadius:'6px',border:'2px solid '+(item.hl?'var(--accent)':'var(--border)'),fontFamily:'var(--mono)',fontSize:'12px',marginBottom:'3px',boxShadow:item.hl?'0 0 10px rgba(210,168,255,0.2)':'none',opacity:item.dim?'0.3':'1'}},item.label);\\n      d.appendChild(box);\\n      d.appendChild(el('div',{style:{fontSize:'9px',color:'var(--text3)'}},item.sub));\\n      c.appendChild(d);\\n    }\\n  });\\n\\n  const td = $('treeDiffs'); clear(td);\\n  if (las < 0) {\\n    td.appendChild(el('div',{style:{color:'var(--text3)',textAlign:'center'}},'No checkpoint yet'));\\n    return;\\n  }\\n  const a = calcAttr();\\n\\n  const d1 = el('div',{style:{marginBottom:'10px'}});\\n  d1.appendChild(mkCalcTitle('base \\\\u2192 shadow'));\\n  d1.appendChild(mkCalcLine([mkSpan(String(a.shA),'var(--agent)'),' agent + ',mkSpan(String(a.shH),'var(--human)'),' human = ',mkSpan(String(a.b2s),'var(--text)'),' total']));\\n  td.appendChild(d1);\\n\\n  const d2 = el('div',{style:{marginBottom:'10px'}});\\n  d2.appendChild(mkCalcTitle('shadow \\\\u2192 head'));\\n  d2.appendChild(mkCalcLine(['User: ',mkSpan('+'+a.postUA,'var(--human)'),' added, ',mkSpan(String(a.postUR),'var(--removed)'),' removed']));\\n  td.appendChild(d2);\\n\\n  const d3 = el('div',{style:{marginBottom:'10px'}});\\n  d3.appendChild(mkCalcTitle('base \\\\u2192 head (final)'));\\n  d3.appendChild(mkCalcLine([mkSpan(String(a.aInC),'var(--agent)'),' agent + ',mkSpan(String(a.pUA),'var(--human)'),' human = ',mkSpan(String(a.tC),'var(--text)'),' net']));\\n  td.appendChild(d3);\\n}\\n\\nfunction renderLIFO() {\\n  $('lifoCallout').textContent = 'When a user removes lines, who originally wrote them? The CLI uses a LIFO heuristic: assume users modify their own recent additions first. Click lines below to \\\"remove\\\" them and see how attribution changes.';\\n\\n  const allLines = [\\n    {t:'func main() {',o:'base',id:0},{t:'    name := \\\"world\\\"',o:'human',id:1},{t:'    greeting := \\\"hello\\\"',o:'human',id:2},\\n    {t:'    msg := greeting + \\\" \\\" + name',o:'human',id:3},{t:'    fmt.Println(msg)',o:'human',id:4},\\n    {t:'    if err := validate(msg); err != nil {',o:'agent',id:5},{t:'        log.Fatal(err)',o:'agent',id:6},\\n    {t:'    }',o:'agent',id:7},{t:'    result := process(msg)',o:'agent',id:8},{t:'    fmt.Println(result)',o:'agent',id:9},\\n    {t:'}',o:'base',id:10}\\n  ];\\n  const hTotal = allLines.filter(l=>l.o==='human').length;\\n  const aTotal = allLines.filter(l=>l.o==='agent').length;\\n\\n  // Lines panel\\n  const lp = $('lifoLinesPanel'); clear(lp);\\n  lp.appendChild(el('div',{style:{fontSize:'11px',marginBottom:'6px',color:'var(--text2)',fontWeight:'600'}},'main.go \\\\u2014 Click lines to remove'));\\n  allLines.filter(l=>l.o!=='base').forEach(l => {\\n    const struck = S.lifoRm.has(l.id);\\n    const bg = l.o==='human'?'var(--human-bg)':'var(--agent-bg)';\\n    const chipColor = l.o==='human'?'var(--human)':'var(--agent)';\\n    const chip = el('span',{style:{fontSize:'8px',padding:'1px 4px',borderRadius:'2px',fontWeight:'700',background:l.o==='human'?'var(--human-bg)':'var(--agent-bg)',color:chipColor}},l.o==='human'?'H':'A');\\n    const row = el('div',{\\n      style:{display:'flex',alignItems:'center',gap:'6px',padding:'3px 6px',borderRadius:'3px',marginBottom:'2px',fontFamily:'var(--mono)',fontSize:'11px',cursor:'pointer',background:bg,textDecoration:struck?'line-through':'none',opacity:struck?'0.3':'1'},\\n      onclick:()=>togLifo(l.id)\\n    },[chip, el('span',null,l.t)]);\\n    lp.appendChild(row);\\n  });\\n\\n  // Calculations\\n  const rmH = allLines.filter(l=>l.o==='human'&&S.lifoRm.has(l.id)).length;\\n  const rmA = allLines.filter(l=>l.o==='agent'&&S.lifoRm.has(l.id)).length;\\n  const tot = rmH + rmA;\\n  const selfLIFO = Math.min(tot, hTotal);\\n  const agentModLIFO = Math.max(0, tot - selfLIFO);\\n\\n  // Result panel\\n  const rp = $('lifoResultPanel'); clear(rp);\\n  rp.appendChild(el('div',{style:{fontSize:'11px',marginBottom:'6px',color:'var(--text2)',fontWeight:'600'}},'LIFO Attribution Impact'));\\n  const r = el('div',{style:{fontFamily:'var(--mono)',fontSize:'10px',lineHeight:'1.7',whiteSpace:'pre-wrap',padding:'8px',background:'var(--bg2)',borderRadius:'5px'}});\\n  const addLine = (parts) => { const d = el('div'); parts.forEach(p=>{if(typeof p==='string')d.appendChild(document.createTextNode(p));else d.appendChild(p);}); r.appendChild(d); };\\n\\n  addLine(['Lines removed: '+tot]);\\n  addLine(['  Actually human: ',mkSpan(String(rmH),'var(--human)')]);\\n  addLine(['  Actually agent: ',mkSpan(String(rmA),'var(--agent)')]);\\n  addLine(['']);\\n  addLine([mkSpan('LIFO estimate:','var(--accent)')]);\\n  addLine(['  Self-modified: min('+tot+', '+hTotal+') = ',mkSpan(String(selfLIFO),'var(--text)')]);\\n  addLine(['  Modified agent: max(0, '+tot+' - '+selfLIFO+') = ',mkSpan(String(agentModLIFO),'var(--text)')]);\\n  addLine(['']);\\n  const correct = agentModLIFO === rmA;\\n  addLine([mkSpan(correct ? 'Correct!' : 'Off by '+Math.abs(agentModLIFO-rmA)+' (actual agent mod: '+rmA+')', correct?'var(--agent)':'var(--removed)')]);\\n  rp.appendChild(r);\\n\\n  // With tracking\\n  const aSurv = aTotal - agentModLIFO, hRem = hTotal - rmH;\\n  const tWith = aSurv + hRem, pWith = tWith > 0 ? (aSurv/tWith*100).toFixed(1) : '0.0';\\n\\n  const wp = $('lifoWithPanel'); clear(wp);\\n  wp.appendChild(el('div',{style:{fontSize:'11px',marginBottom:'6px',color:'var(--agent)',fontWeight:'600'}},'With Per-File Tracking (actual)'));\\n  const wr = el('div',{style:{fontFamily:'var(--mono)',fontSize:'10px',lineHeight:'1.7',whiteSpace:'pre-wrap',padding:'8px',background:'var(--bg2)',borderRadius:'5px'}});\\n  const addWLine = (parts) => { const d = el('div'); parts.forEach(p=>{if(typeof p==='string')d.appendChild(document.createTextNode(p));else d.appendChild(p);}); wr.appendChild(d); };\\n  addWLine(['Agent surviving: ',mkSpan(aSurv+'/'+aTotal,'var(--agent)')]);\\n  addWLine(['Human remaining: ',mkSpan(hRem+'/'+hTotal,'var(--human)')]);\\n  addWLine(['Total: ',mkSpan(String(tWith),'var(--text)')]);\\n  addWLine([mkSpan('Agent: '+pWith+'%','var(--agent)')]);\\n  const bar1 = el('div',{style:{height:'6px',borderRadius:'3px',background:'var(--bg3)',overflow:'hidden',marginTop:'6px',display:'flex'}});\\n  bar1.appendChild(el('div',{style:{background:'var(--agent)',width:pWith+'%'}}));\\n  bar1.appendChild(el('div',{style:{background:'var(--human)',width:(100-parseFloat(pWith))+'%'}}));\\n  wr.appendChild(bar1);\\n  wp.appendChild(wr);\\n\\n  // Without tracking\\n  const naiveAMod = tot, aSurvN = Math.max(0, aTotal - naiveAMod);\\n  const tWo = aSurvN + hRem, pWo = tWo > 0 ? (aSurvN/tWo*100).toFixed(1) : '0.0';\\n\\n  const wop = $('lifoWithoutPanel'); clear(wop);\\n  wop.appendChild(el('div',{style:{fontSize:'11px',marginBottom:'6px',color:'var(--removed)',fontWeight:'600'}},'Without Per-File Tracking (naive)'));\\n  const wor = el('div',{style:{fontFamily:'var(--mono)',fontSize:'10px',lineHeight:'1.7',whiteSpace:'pre-wrap',padding:'8px',background:'var(--bg2)',borderRadius:'5px'}});\\n  const addWoLine = (parts) => { const d = el('div'); parts.forEach(p=>{if(typeof p==='string')d.appendChild(document.createTextNode(p));else d.appendChild(p);}); wor.appendChild(d); };\\n  addWoLine(['Agent surviving: ',mkSpan(aSurvN+'/'+aTotal,'var(--agent)'),' ',mkSpan('(over-penalized)','var(--removed)')]);\\n  addWoLine(['Human remaining: ',mkSpan(hRem+'/'+hTotal,'var(--human)')]);\\n  addWoLine(['Total: ',mkSpan(String(tWo),'var(--text)')]);\\n  addWoLine([mkSpan('Agent: '+pWo+'%','var(--removed)')]);\\n  const bar2 = el('div',{style:{height:'6px',borderRadius:'3px',background:'var(--bg3)',overflow:'hidden',marginTop:'6px',display:'flex'}});\\n  bar2.appendChild(el('div',{style:{background:'var(--agent)',width:pWo+'%'}}));\\n  bar2.appendChild(el('div',{style:{background:'var(--human)',width:(100-parseFloat(pWo))+'%'}}));\\n  wor.appendChild(bar2);\\n  wor.appendChild(el('div',{style:{marginTop:'6px',color:'var(--text3)',fontSize:'9px'}},'Naive approach: ALL removals penalize agent, even when user edited their own code.'));\\n  wop.appendChild(wor);\\n}\\n\\nfunction updatePrompt() {\\n  const p = P[S.preset], st = p.steps[S.step], las = lastAgentStep();\\n  const parts = ['Entire CLI attribution: three-tree model (baseTree, shadowTree, headTree).'];\\n  parts.push('Scenario: \\\"'+p.name+'\\\" - '+p.desc+'.');\\n  parts.push('Step: \\\"'+st.l+'\\\" ('+String(S.step+1)+'/'+p.steps.length+').');\\n  if (las >= 0) {\\n    const a = calcAttr();\\n    parts.push('Agent: '+a.aInC+' lines ('+a.pct.toFixed(1)+'%), Human: '+a.pUA+' lines ('+(100-a.pct).toFixed(1)+'%).');\\n    if (a.selfMod > 0) parts.push('LIFO: '+a.selfMod+' self-modifications detected (user editing own code).');\\n    if (Object.keys(a.accPF).length > 1) parts.push('Per-file: '+Object.entries(a.accPF).map(([f,n])=>f+':'+n).join(', ')+'.');\\n  }\\n  parts.push('Key fn: CalculateAttributionWithAccumulated() in manual_commit_attribution.go');\\n  $('promptOut').textContent = parts.join('\\\\n');\\n}\\n\\n// ── Actions ──────────────────────────────────────────────\\nfunction selPreset(k) { S.preset=k; S.step=0; S.file=Object.keys(P[k].files)[0]; S.lifoRm=new Set(); simTo(0); render(); }\\nfunction goTo(i) { S.step=i; simTo(i); render(); }\\nfunction next() { if(S.step<P[S.preset].steps.length-1) goTo(S.step+1); }\\nfunction prev() { if(S.step>0) goTo(S.step-1); }\\nfunction selFile(f) { S.file=f; render(); }\\nfunction togLifo(id) { if(S.lifoRm.has(id))S.lifoRm.delete(id)