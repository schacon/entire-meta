testify/assert\\\"\\n    15→)\\n    16→\\n    17→// TestLineAttributionReasonable: agent creates a file, attribution metadata\\n    18→// should reflect that agent wrote most/all of the content.\\n    19→// GH #344: attribution metadata is significantly off for simple agent-created content.\\n    20→func TestLineAttributionReasonable(t *testing.T) {\\n    21→\\ttestutil.ForEachAgent(t, 3*time.Minute, func(t *testing.T, s *testutil.RepoState, ctx context.Context) {\\n    22→\\t\\t_, err := s.RunPrompt(t, ctx,\\n    23→\\t\\t\\t\\\"create a single markdown file at docs/example.md with a few paragraphs about software testing. Do not ask for confirmation, just make the change.\\\")\\n    24→\\t\\tif err != nil {\\n    25→\\t\\t\\tt.Fatalf(\\\"agent failed: %v\\\", err)\\n    26→\\t\\t}\\n    27→\\t\\ttestutil.AssertFileExists(t, s.Dir, \\\"docs/example.md\\\")\\n    28→\\n    29→\\t\\ts.Git(t, \\\"add\\\", \\\"docs/\\\")\\n    30→\\t\\ts.Git(t, \\\"commit\\\", \\\"-m\\\", \\\"Add example.md\\\")\\n    31→\\n    32→\\t\\ttestutil.WaitForCheckpoint(t, s, 15*time.Second)\\n    33→\\n    34→\\t\\tcpID := testutil.AssertHasCheckpointTrailer(t, s.Dir, \\\"HEAD\\\")\\n    35→\\t\\tsm := testutil.ReadSessionMetadata(t, s.Dir, cpID, 0)\\n    36→\\n    37→\\t\\tassert.Greater(t, sm.InitialAttribution.AgentLines, 0,\\n    38→\\t\\t\\t\\\"agent lines should be > 0\\\")\\n    39→\\t\\tassert.Greater(t, sm.InitialAttribution.TotalCommitted, 0,\\n    40→\\t\\t\\t\\\"total committed should be > 0\\\")\\n    41→\\t\\tassert.Greater(t, sm.InitialAttribution.AgentPercentage, 50.0,\\n    42→\\t\\t\\t\\\"agent created 100%% of content, percentage should be > 50%%\\\")\\n    43→\\t\\ttestutil.AssertNoShadowBranches(t, s.Dir)\\n    44→\\t})\\n    45→}\\n    46→\\n    47→// TestAttributionOnAgentCommit: agent creates a file and commits it in the\\n    48→// same prompt (interactive session). The first commit's checkpoint should have\\n    49→// initial_attribution populated.\\n    50→func TestAttributionOnAgentCommit(t *testing.T) {\\n    51→\\ttestutil.ForEachAgent(t, 3*time.Minute, func(t *testing.T, s *testutil.RepoState, ctx context.Context) {\\n    52→\\t\\tprompt := s.Agent.PromptPattern()\\n    53→\\n    54→\\t\\tsession := s.StartSession(t, ctx)\\n    55→\\t\\tif session == nil {\\n    56→\\t\\t\\tt.Skipf(\\\"agent %s does not support interactive mode\\\", s.Agent.Name())\\n    57→\\t\\t}\\n    58→\\n    59→\\t\\ts.WaitFor(t, session, prompt, 30*time.Second)\\n    60→\\n    61→\\t\\ts.Send(t, session, \\\"create a file called hello.txt containing 'hello world', then commit it. Do not ask for confirmation.\\\")\\n    62→\\t\\ts.WaitFor(t, session, prompt, 90*time.Second)\\n    63→\\t\\ttestutil.AssertNewCommits(t, s, 1)\\n    64→\\n    65→\\t\\ttestutil.WaitForCheckpoint(t, s, 15*time.Second)\\n    66→\\t\\tcpID := testutil.AssertHasCheckpointTrailer(t, s.Dir, \\\"HEAD\\\")\\n    67→\\t\\tsm := testutil.ReadSessionMetadata(t, s.Dir, cpID, 0)\\n    68→\\n    69→\\t\\tassert.Greater(t, sm.InitialAttribution.AgentLines, 0,\\n    70→\\t\\t\\t\\\"agent lines should be > 0 on first agent commit\\\")\\n    71→\\t\\tassert.Greater(t, sm.InitialAttribution.TotalCommitted, 0,\\n    72→\\t\\t\\t\\\"total committed should be > 0 on first agent commit\\\")\\n    73→\\t\\ttestutil.AssertNoShadowBranches(t, s.Dir)\\n    74→\\t})\\n    75→}\\n    76→\\n    77→// TestAttributionMultiCommitSameSession: two prompts in the same interactive\\n    78→// session, agent modifies the same file and commits both times. The second\\n    79→// checkpoint's initial_attribution should have non-zero values.\\n    80→func TestAttributionMultiCommitSameSession(t *testing.T) {\\n    81→\\ttestutil.ForEachAgent(t, 4*time.Minute, func(t *testing.T, s *testutil.RepoState, ctx context.Context) {\\n    82→\\t\\tprompt := s.Agent.PromptPattern()\\n    83→\\n    84→\\t\\tsession := s.StartSession(t, ctx)\\n    85→\\t\\tif session == nil {\\n    86→\\t\\t\\tt.Skipf(\\\"agent %s does not support interactive mode\\\", s.Agent.Name())\\n    87→\\t\\t}\\n    88→\\n    89→\\t\\ts.WaitFor(t, session, prompt, 30*time.Second)\\n    90→\\n    91→\\t\\t// First prompt: create file and commit.\\n    92→\\t\\ts.Send(t, session, \\\"create a file called poem.txt with a short poem about coding, then commit it. Do not ask for confirmation.\\\")\\n    93→\\t\\ts.WaitFor(t, session, prompt, 60*time.Second)\\n    94→\\t\\ttestutil.AssertNewCommits(t, s, 1)\\n    95→\\n    96→\\t\\ttestutil.WaitForCheckpoint(t, s, 15*time.Second)\\n    97→\\t\\tcpBranch1 := testutil.GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n    98→\\n    99→\\t\\t// Second prompt: modify same file and commit again.\\n   100→\\t\\ts.Send(t, session, \\\"add another stanza to poem.txt about debugging, then create a NEW commit (do not amend). Do not ask for confirmation.\\\")\\n   101→\\t\\ts.WaitFor(t, session, prompt, 90*time.Second)\\n   102→\\t\\ttestutil.AssertNewCommits(t, s, 2)\\n   103→\\n   104→\\t\\ttestutil.WaitForCheckpointAdvanceFrom(t, s.Dir, cpBranch1, 15*time.Second)\\n   105→\\t\\tcpID2 := testutil.AssertHasCheckpointTrailer(t, s.Dir, \\\"HEAD\\\")\\n   106→\\t\\tsm := testutil.WaitForSessionMetadata(t, s.Dir, cpID2, 0, 10*time.Second)\\n   107→\\n   108→\\t\\tassert.Greater(t, sm.InitialAttribution.AgentLines, 0,\\n   109→\\t\\t\\t\\\"agent lines should be > 0 on second commit\\\")\\n   110→\\t\\tassert.Greater(t, sm.InitialAttribution.TotalCommitted, 0,\\n   111→\\t\\t\\t\\\"total committed should be > 0 on second commit\\\")\\n   112→\\t\\tassert.Greater(t, sm.InitialAttribution.AgentPercentage, 50.0,\\n   113→\\t\\t\\t\\\"agent wrote all content, percentage should be > 50%%\\\")\\n   114→\\t\\ttestutil.AssertNoShadowBranches(t, s.Dir)\\n   115→\\t})\\n   116→}\\n   117→\\n   118→// TestShadowBranchCleanedAfterAgentCommit: after an agent creates a file\\n   119→// and commits it, there should be no lingering shadow branches. Shadow\\n   120→// branches match entire/* but are not entire/checkpoints/*.\\n   121→func TestShadowBranchCleanedAfterAgentCommit(t *testing.T) {\\n   122→\\ttestutil.ForEachAgent(t, 3*time.Minute, func(t *testing.T, s *testutil.RepoState, ctx context.Context) {\\n   123→\\t\\tprompt := s.Agent.PromptPattern()\\n   124→\\n   125→\\t\\tsession := s.StartSession(t, ctx)\\n   126→\\t\\tif session == nil {\\n   127→\\t\\t\\tt.Skipf(\\\"agent %s does not support interactive mode\\\", s.Agent.Name())\\n   128→\\t\\t}\\n   129→\\n   130→\\t\\ts.WaitFor(t, session, prompt, 30*time.Second)\\n   131→\\n   132→\\t\\ts.Send(t, session, \\\"create a file called hello.txt containing 'hello world', then commit it. Do not ask for confirmation.\\\")\\n   133→\\t\\ts.WaitFor(t, session, prompt, 90*time.Second)\\n   134→\\t\\ttestutil.AssertNewCommits(t, s, 1)\\n   135→\\n   136→\\t\\ttestutil.WaitForCheckpoint(t, s, 15*time.Second)\\n   137→\\n   138→\\t\\ttestutil.AssertNoShadowBranches(t, s.Dir)\\n   139→\\t})\\n   140→}\\n   141→\\n   142→// TestAttributionMixedHumanAndAgent: agent creates one file, human creates\\n   143→// another with known content, both are committed together. Attribution should\\n   144→// correctly separate agent lines from human lines.\\n   145→func TestAttributionMixedHumanAndAgent(t *testing.T) {\\n   146→\\ttestutil.ForEachAgent(t, 3*time.Minute, func(t *testing.T, s *testutil.RepoState, ctx context.Context) {\\n   147→\\t\\t// Agent creates a file.\\n   148→\\t\\t_, err := s.RunPrompt(t, ctx,\\n   149→\\t\\t\\t\\\"create a file called agent.txt with a few lines about software testing. Do not create any other files. Do not ask for confirmation, just make the change.\\\")\\n   150→\\t\\tif err != nil {\\n   151→\\t\\t\\tt.Fatalf(\\\"agent failed: %v\\\", err)\\n   152→\\t\\t}\\n   153→\\t\\ttestutil.AssertFileExists(t, s.Dir, \\\"agent.txt\\\")\\n   154→\\n   155→\\t\\t// Count agent lines before human changes.\\n   156→\\t\\tagentContent, err := os.ReadFile(filepath.Join(s.Dir, \\\"agent.txt\\\"))\\n   157→\\t\\tif err != nil {\\n   158→\\t\\t\\tt.Fatalf(\\\"read agent.txt: %v\\\", err)\\n   159→\\t\\t}\\n   160→\\t\\tagentLines := len(strings.Split(strings.TrimRight(string(agentContent), \\\"\\\\n\\\"), \\\"\\\\n\\\"))\\n   161→\\n   162→\\t\\t// Human creates a known file.\\n   163→\\t\\thumanContent := \\\"line one\\\\nline two\\\\nline three\\\\n\\\"\\n   164→\\t\\thumanLines := 3\\n   165→\\t\\tif err := os.WriteFile(filepath.Join(s.Dir, \\\"human.txt\\\"), []byte(humanContent), 0o644); err != nil {\\n   166→\\t\\t\\tt.Fatalf(\\\"write human.txt: %v\\\", err)\\n   167→\\t\\t}\\n   168→\\n   169→\\t\\t// Commit both (stage only intended files — attribution checks exact line counts).\\n   170→\\t\\ts.Git(t, \\\"add\\\", \\\"agent.txt\\\", \\\"human.txt\\\")\\n   171→\\t\\ts.Git(t, \\\"commit\\\", \\\"-m\\\", \\\"Add agent and human files\\\")\\n   172→\\n   173→\\t\\ttestutil.WaitForCheckpoint(t, s, 15*time.Second)\\n   174→\\n   175→\\t\\tcpID := testutil.AssertHasCheckpointTrailer(t, s.Dir, \\\"HEAD\\\")\\n   176→\\t\\tsm := testutil.ReadSessionMetadata(t, s.Dir, cpID, 0)\\n   177→\\n   178→\\t\\tassert.Equal(t, agentLines, sm.InitialAttribution.AgentLines,\\n   179→\\t\\t\\t\\\"agent_lines should match actual lines in agent.txt\\\")\\n   180→\\t\\tassert.Equal(t, humanLines, sm.InitialAttribution.HumanAdded,\\n   181→\\t\\t\\t\\\"human_added should match lines in human.txt\\\")\\n   182→\\t\\tassert.Equal(t, agentLines+humanLines, sm.InitialAttribution.TotalCommitted,\\n   183→\\t\\t\\t\\\"total_committed should be sum of agent and human lines\\\")\\n   184→\\t\\tassert.Greater(t, sm.InitialAttribution.AgentPercentage, 0.0,\\n   185→\\t\\t\\t\\\"agent_percentage should be > 0 when agent wrote content\\\")\\n   186→\\t\\tassert.Less(t, sm.InitialAttribution.AgentPercentage, 100.0,\\n   187→\\t\\t\\t\\\"agent_percentage should be < 100 when human also wrote content\\\")\\n   188→\\t\\t// Shadow branch may persist if agent created extra files beyond\\n   189→\\t\\t// agent.txt — we only stage the two known files for precise\\n   190→\\t\\t// attribution counting.\\n   191→\\t})\\n   192→}\\n   193→\"}]},\"uuid\":\"59d9c0f9-db6d-4373-82d4-2dfc693e1f3d\",\"timestamp\":\"2026-03-06T17:44:42.464Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"afc698f953c341c14\"},\"toolUseID\":\"agent_msg_01KLfjXamBrHzDU5JPCL1LET\",\"parentToolUseID\":\"toolu_012SQ2zcCKKv5nU63NZZr8r5\",\"uuid\":\"d7e8f320-340d-4923-ac5b-cbee037edbc8\",\"timestamp\":\"2026-03-06T17:44:42.465Z\"}\n{\"parentUuid\":\"d7e8f320-340d-4923-ac5b-cbee037edbc8\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/devenv/cli\",\"sessionId\":\"09356618-966a-4751-9a19-8254300ef35a\",\"version\":\"2.1.70\",\"gitBranch\":\"main\",\"slug\":\"linked-chasing-storm\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-06T17:44:44.927Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01XrXcmUH8CJ9NGXCSUmi321\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_019iuwF8adTpfXZgqJdLCx5j\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/alisha/Projects/devenv/cli/cmd/entire/cli/checkpoint/checkpoint.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":7,\"cache_creation_input_tokens\":11154,\"cache_read_input_tokens\":56831,\"cache_creation\":{\"ephemeral_5m_input_tokens\":11154,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":4,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYnF1oiFvZ6mJdoEMnJW2\",\"uuid\":\"633910ab-a7a2-4538-bff7-e563d123f0b9\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"afc698f953c341c14\"},\"toolUseID\":\"agent_msg_01KLfjXamBrHzDU5JPCL1LET\",\"parentToolUseID\":\"toolu_012SQ2zcCKKv5nU63NZZr8r5\",\"uuid\":\"a0fcbbe9-73bc-4ce7-bd9f-9f46979be714\",\"timestamp\":\"2026-03-06T17:44:44.928Z\"}\n{\"parentUuid\":\"a0fcbbe9-73bc-4ce7-bd9f-9f46979be714\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/devenv/cli\",\"sessionId\":\"09356618-966a-4751-9a19-8254300ef35a\",\"version\":\"2.1.70\",\"gitBranch\":\"main\",\"slug\":\"linked-chasing-storm\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_019iuwF8adTpfXZgqJdLCx5j\",\"type\":\"tool_result\",\"content\":\"     1→// Package checkpoint provides types and interfaces for checkpoint storage.\\n     2→//\\n     3→// A Checkpoint captures a point-in-time within a session, containing either\\n     4→// full state (Temporary) or metadata with a commit reference (Committed).\\n     5→//\\n     6→// See docs/architecture/sessions-and-checkpoints.md for the full domain model.\\n     7→package checkpoint\\n     8→\\n     9→import (\\n    10→\\t\\\"context\\\"\\n    11→\\t\\\"errors\\\"\\n    12→\\t\\\"time\\\"\\n    13→\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    17→\\n    18→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    19→)\\n    20→\\n    21→// Errors returned by checkpoint operations.\\n    22→var (\\n    23→\\t// ErrCheckpointNotFound is returned when a checkpoint ID doesn't exist.\\n    24→\\tErrCheckpointNotFound = errors.New(\\\"checkpoint not found\\\")\\n    25→\\n    26→\\t// ErrNoTranscript is returned when a checkpoint exists but has no transcript.\\n    27→\\tErrNoTranscript = errors.New(\\\"no transcript found for checkpoint\\\")\\n    28→)\\n    29→\\n    30→// Checkpoint represents a save point within a session.\\n    31→type Checkpoint struct {\\n    32→\\t// ID is the unique checkpoint identifier\\n    33→\\tID string\\n    34→\\n    35→\\t// SessionID is the session this checkpoint belongs to\\n    36→\\tSessionID string\\n    37→\\n    38→\\t// Timestamp is when this checkpoint was created\\n    39→\\tTimestamp time.Time\\n    40→\\n    41→\\t// Type indicates temporary (full state) or committed (metadata only)\\n    42→\\tType Type\\n    43→\\n    44→\\t// Message is a human-readable description of the checkpoint\\n    45→\\tMessage string\\n    46→}\\n    47→\\n    48→// Type indicates the storage location and lifecycle of a checkpoint.\\n    49→type Type int\\n    50→\\n    51→const (\\n    52→\\t// Temporary checkpoints contain full state (code + metadata) and are stored\\n    53→\\t// on shadow branches (entire/<commit-hash>). Used for intra-session rewind.\\n    54→\\tTemporary Type = iota\\n    55→\\n    56→\\t// Committed checkpoints contain metadata + commit reference and are stored\\n    57→\\t// on the entire/checkpoints/v1 branch. They are the permanent record.\\n    58→\\tCommitted\\n    59→)\\n    60→\\n    61→// Store provides low-level primitives for reading and writing checkpoints.\\n    62→// This is used by strategies to implement their storage approach.\\n    63→//\\n    64→// The interface matches the GitStore implementation signatures directly:\\n    65→// - WriteTemporary takes WriteTemporaryOptions and returns a result with commit hash and skip status\\n    66→// - ReadTemporary takes baseCommit (not sessionID) since shadow branches are keyed by commit\\n    67→// - List methods return implementation-specific info types for richer data\\n    68→type Store interface {\\n    69→\\t// WriteTemporary writes a temporary checkpoint (full state) to a shadow branch.\\n    70→\\t// Shadow branches are named entire/<base-commit-short-hash>.\\n    71→\\t// Returns a result containing the commit hash and whether the checkpoint was skipped.\\n    72→\\t// Checkpoints are skipped (deduplicated) when the tree hash matches the previous checkpoint.\\n    73→\\tWriteTemporary(ctx context.Context, opts WriteTemporaryOptions) (WriteTemporaryResult, error)\\n    74→\\n    75→\\t// ReadTemporary reads the latest checkpoint from a shadow branch.\\n    76→\\t// baseCommit is the commit hash the session is based on.\\n    77→\\t// worktreeID is the internal git worktree identifier (empty for main worktree).\\n    78→\\t// Returns nil, nil if the shadow branch doesn't exist.\\n    79→\\tReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error)\\n    80→\\n    81→\\t// ListTemporary lists all shadow branches with their checkpoint info.\\n    82→\\tListTemporary(ctx context.Context) ([]TemporaryInfo, error)\\n    83→\\n    84→\\t// WriteCommitted writes a committed checkpoint to the entire/checkpoints/v1 branch.\\n    85→\\t// Checkpoints are stored at sharded paths: <id[:2]>/<id[2:]>/\\n    86→\\tWriteCommitted(ctx context.Context, opts WriteCommittedOptions) error\\n    87→\\n    88→\\t// ReadCommitted reads a committed checkpoint's summary by ID.\\n    89→\\t// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n    90→\\t// Use ReadSessionContent to read actual transcript/prompts.\\n    91→\\t// Returns nil, nil if the checkpoint does not exist.\\n    92→\\tReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error)\\n    93→\\n    94→\\t// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n    95→\\t// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n    96→\\t// Returns the session's metadata, transcript, and prompts.\\n    97→\\tReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error)\\n    98→\\n    99→\\t// ReadSessionContentByID reads a session's content by its session ID.\\n   100→\\t// Useful when you have the session ID but don't know its index within the checkpoint.\\n   101→\\tReadSessionContentByID(ctx context.Context, checkpointID id.CheckpointID, sessionID string) (*SessionContent, error)\\n   102→\\n   103→\\t// ListCommitted lists all committed checkpoints.\\n   104→\\tListCommitted(ctx context.Context) ([]CommittedInfo, error)\\n   105→\\n   106→\\t// UpdateCommitted replaces the transcript and prompts for an existing\\n   107→\\t// committed checkpoint. Used at stop time to finalize checkpoints with the full\\n   108→\\t// session transcript (prompt to stop event).\\n   109→\\t// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   110→\\tUpdateCommitted(ctx context.Context, opts UpdateCommittedOptions) error\\n   111→}\\n   112→\\n   113→// WriteTemporaryResult contains the result of writing a temporary checkpoint.\\n   114→type WriteTemporaryResult struct {\\n   115→\\t// CommitHash is the hash of the created or existing checkpoint commit\\n   116→\\tCommitHash plumbing.Hash\\n   117→\\n   118→\\t// Skipped is true if the checkpoint was skipped due to no changes\\n   119→\\t// (tree hash matched the previous checkpoint)\\n   120→\\tSkipped bool\\n   121→}\\n   122→\\n   123→// WriteTemporaryOptions contains options for writing a temporary checkpoint.\\n   124→type WriteTemporaryOptions struct {\\n   125→\\t// SessionID is the session identifier\\n   126→\\tSessionID string\\n   127→\\n   128→\\t// BaseCommit is the commit hash this session is based on\\n   129→\\tBaseCommit string\\n   130→\\n   131→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n   132→\\t// Used to create worktree-specific shadow branch names\\n   133→\\tWorktreeID string\\n   134→\\n   135→\\t// ModifiedFiles are files that have been modified (relative paths)\\n   136→\\tModifiedFiles []string\\n   137→\\n   138→\\t// NewFiles are files that have been created (relative paths)\\n   139→\\tNewFiles []string\\n   140→\\n   141→\\t// DeletedFiles are files that have been deleted (relative paths)\\n   142→\\tDeletedFiles []string\\n   143→\\n   144→\\t// MetadataDir is the relative path to the metadata directory\\n   145→\\tMetadataDir string\\n   146→\\n   147→\\t// MetadataDirAbs is the absolute path to the metadata directory\\n   148→\\tMetadataDirAbs string\\n   149→\\n   150→\\t// CommitMessage is the commit subject line\\n   151→\\tCommitMessage string\\n   152→\\n   153→\\t// AuthorName is the name to use for commits\\n   154→\\tAuthorName string\\n   155→\\n   156→\\t// AuthorEmail is the email to use for commits\\n   157→\\tAuthorEmail string\\n   158→\\n   159→\\t// IsFirstCheckpoint indicates if this is the first checkpoint of the session\\n   160→\\t// When true, all working directory files are captured (not just modified)\\n   161→\\tIsFirstCheckpoint bool\\n   162→}\\n   163→\\n   164→// ReadTemporaryResult contains the result of reading a temporary checkpoint.\\n   165→type ReadTemporaryResult struct {\\n   166→\\t// CommitHash is the hash of the checkpoint commit\\n   167→\\tCommitHash plumbing.Hash\\n   168→\\n   169→\\t// TreeHash is the hash of the tree containing the checkpoint state\\n   170→\\tTreeHash plumbing.Hash\\n   171→\\n   172→\\t// SessionID is the session identifier from the commit trailer\\n   173→\\tSessionID string\\n   174→\\n   175→\\t// MetadataDir is the metadata directory path from the commit trailer\\n   176→\\tMetadataDir string\\n   177→\\n   178→\\t// Timestamp is when the checkpoint was created\\n   179→\\tTimestamp time.Time\\n   180→}\\n   181→\\n   182→// TemporaryInfo contains summary information about a shadow branch.\\n   183→type TemporaryInfo struct {\\n   184→\\t// BranchName is the full branch name (e.g., \\\"entire/abc1234\\\")\\n   185→\\tBranchName string\\n   186→\\n   187→\\t// BaseCommit is the short commit hash this branch is based on\\n   188→\\tBaseCommit string\\n   189→\\n   190→\\t// LatestCommit is the hash of the latest commit on the branch\\n   191→\\tLatestCommit plumbing.Hash\\n   192→\\n   193→\\t// SessionID is the session identifier from the latest commit\\n   194→\\tSessionID string\\n   195→\\n   196→\\t// Timestamp is when the latest checkpoint was created\\n   197→\\tTimestamp time.Time\\n   198→}\\n   199→\\n   200→// WriteCommittedOptions contains options for writing a committed checkpoint.\\n   201→type WriteCommittedOptions struct {\\n   202→\\t// CheckpointID is the stable 12-hex-char identifier\\n   203→\\tCheckpointID id.CheckpointID\\n   204→\\n   205→\\t// SessionID is the session identifier\\n   206→\\tSessionID string\\n   207→\\n   208→\\t// Strategy is the name of the strategy that created this checkpoint\\n   209→\\tStrategy string\\n   210→\\n   211→\\t// Branch is the branch name where the checkpoint was created (empty if detached HEAD)\\n   212→\\tBranch string\\n   213→\\n   214→\\t// Transcript is the session transcript content (full.jsonl)\\n   215→\\tTranscript []byte\\n   216→\\n   217→\\t// Prompts contains user prompts from the session\\n   218→\\tPrompts []string\\n   219→\\n   220→\\t// FilesTouched are files modified during the session\\n   221→\\tFilesTouched []string\\n   222→\\n   223→\\t// CheckpointsCount is the number of checkpoints in this session\\n   224→\\tCheckpointsCount int\\n   225→\\n   226→\\t// EphemeralBranch is the shadow branch name (for manual-commit strategy)\\n   227→\\tEphemeralBranch string\\n   228→\\n   229→\\t// AuthorName is the name to use for commits\\n   230→\\tAuthorName string\\n   231→\\n   232→\\t// AuthorEmail is the email to use for commits\\n   233→\\tAuthorEmail string\\n   234→\\n   235→\\t// MetadataDir is a directory containing additional metadata files to copy\\n   236→\\t// If set, all files in this directory will be copied to the checkpoint path\\n   237→\\t// This is useful for copying task metadata files, subagent transcripts, etc.\\n   238→\\tMetadataDir string\\n   239→\\n   240→\\t// Task checkpoint fields (for task/subagent checkpoints)\\n   241→\\tIsTask    bool   // Whether this is a task checkpoint\\n   242→\\tToolUseID string // Tool use ID for task checkpoints\\n   243→\\n   244→\\t// Additional task checkpoint fields for subagent checkpoints\\n   245→\\tAgentID                string // Subagent identifier\\n   246→\\tCheckpointUUID         string // UUID for transcript truncation when rewinding\\n   247→\\tTranscriptPath         string // Path to session transcript file (alternative to in-memory Transcript)\\n   248→\\tSubagentTranscriptPath string // Path to subagent's transcript file\\n   249→\\n   250→\\t// Incremental checkpoint fields\\n   251→\\tIsIncremental       bool   // Whether this is an incremental checkpoint\\n   252→\\tIncrementalSequence int    // Checkpoint sequence number\\n   253→\\tIncrementalType     string // Tool type that triggered this checkpoint\\n   254→\\tIncrementalData     []byte // Tool input payload for this checkpoint\\n   255→\\n   256→\\t// Commit message fields (used for task checkpoints)\\n   257→\\tCommitSubject string // Subject line for the metadata commit (overrides default)\\n   258→\\n   259→\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   260→\\tAgent types.AgentType\\n   261→\\n   262→\\t// Model is the LLM model used during the session (e.g., \\\"claude-sonnet-4-20250514\\\")\\n   263→\\tModel string\\n   264→\\n   265→\\t// TurnID correlates checkpoints from the same agent turn.\\n   266→\\tTurnID string\\n   267→\\n   268→\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n   269→\\tTranscriptIdentifierAtStart string // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n   270→\\tCheckpointTranscriptStart   int    // Transcript line offset at start of this checkpoint's data\\n   271→\\n   272→\\t// CheckpointTranscriptStart is written to both CommittedMetadata.CheckpointTranscriptStart\\n   273→\\t// and the deprecated CommittedMetadata.TranscriptLinesAtStart for backward compatibility.\\n   274→\\n   275→\\t// TokenUsage contains the token usage for this checkpoint\\n   276→\\tTokenUsage *agent.TokenUsage\\n   277→\\n   278→\\t// SessionMetrics contains hook-provided session metrics (duration, turns, context usage)\\n   279→\\tSessionMetrics *SessionMetrics\\n   280→\\n   281→\\t// InitialAttribution is line-level attribution calculated at commit time\\n   282→\\t// comparing checkpoint tree (agent work) to committed tree (may include human edits)\\n   283→\\tInitialAttribution *InitialAttribution\\n   284→\\n   285→\\t// Summary is an optional AI-generated summary for this checkpoint.\\n   286→\\t// This field may be nil when:\\n   287→\\t//   - summarization is disabled in settings\\n   288→\\t//   - summary generation failed (non-blocking, logged as warning)\\n   289→\\t//   - the transcript was empty or too short to summarize\\n   290→\\t//   - the checkpoint predates the summarization feature\\n   291→\\tSummary *Summary\\n   292→}\\n   293→\\n   294→// UpdateCommittedOptions contains options for updating an existing committed checkpoint.\\n   295→// Uses replace semantics: the transcript and prompts are fully replaced,\\n   296→// not appended. At stop time we have the complete session transcript and want every\\n   297→// checkpoint to contain it identically.\\n   298→type UpdateCommittedOptions struct {\\n   299→\\t// CheckpointID identifies the checkpoint to update\\n   300→\\tCheckpointID id.CheckpointID\\n   301→\\n   302→\\t// SessionID identifies which session slot to update within the checkpoint\\n   303→\\tSessionID string\\n   304→\\n   305→\\t// Transcript is the full session transcript (replaces existing)\\n   306→\\tTranscript []byte\\n   307→\\n   308→\\t// Prompts contains all user prompts (replaces existing)\\n   309→\\tPrompts []string\\n   310→\\n   311→\\t// Agent identifies the agent type (needed for transcript chunking)\\n   312→\\tAgent types.AgentType\\n   313→}\\n   314→\\n   315→// CommittedInfo contains summary information about a committed checkpoint.\\n   316→type CommittedInfo struct {\\n   317→\\t// CheckpointID is the stable 12-hex-char identifier\\n   318→\\tCheckpointID id.CheckpointID\\n   319→\\n   320→\\t// SessionID is the session identifier (most recent session for multi-session checkpoints)\\n   321→\\tSessionID string\\n   322→\\n   323→\\t// CreatedAt is when the checkpoint was created\\n   324→\\tCreatedAt time.Time\\n   325→\\n   326→\\t// CheckpointsCount is the total number of checkpoints across all sessions\\n   327→\\tCheckpointsCount int\\n   328→\\n   329→\\t// FilesTouched are files modified during all sessions\\n   330→\\tFilesTouched []string\\n   331→\\n   332→\\t// Agent identifies the agent that created this checkpoint\\n   333→\\tAgent types.AgentType\\n   334→\\n   335→\\t// IsTask indicates if this is a task checkpoint\\n   336→\\tIsTask bool\\n   337→\\n   338→\\t// ToolUseID is the tool use ID for task checkpoints\\n   339→\\tToolUseID string\\n   340→\\n   341→\\t// Multi-session support\\n   342→\\tSessionCount int      // Number of sessions (1 if single session)\\n   343→\\tSessionIDs   []string // All session IDs that contributed\\n   344→}\\n   345→\\n   346→// SessionContent contains the actual content for a session.\\n   347→// This is used when reading full session data (transcript, prompts, context)\\n   348→// as opposed to just the metadata/summary.\\n   349→type SessionContent struct {\\n   350→\\t// Metadata contains the session-specific metadata\\n   351→\\tMetadata CommittedMetadata\\n   352→\\n   353→\\t// Transcript is the session transcript content\\n   354→\\tTranscript []byte\\n   355→\\n   356→\\t// Prompts contains user prompts from this session\\n   357→\\tPrompts string\\n   358→}\\n   359→\\n   360→// CommittedMetadata contains the metadata stored in metadata.json for each checkpoint.\\n   361→type CommittedMetadata struct {\\n   362→\\tCLIVersion       string          `json:\\\"cli_version,omitempty\\\"`\\n   363→\\tCheckpointID     id.CheckpointID `json:\\\"checkpoint_id\\\"`\\n   364→\\tSessionID        string          `json:\\\"session_id\\\"`\\n   365→\\tStrategy         string          `json:\\\"strategy\\\"`\\n   366→\\tCreatedAt        time.Time       `json:\\\"created_at\\\"`\\n   367→\\tBranch           string          `json:\\\"branch,omitempty\\\"` // Branch where checkpoint was created (empty if detached HEAD)\\n   368→\\tCheckpointsCount int             `json:\\\"checkpoints_count\\\"`\\n   369→\\tFilesTouched     []string        `json:\\\"files_touched\\\"`\\n   370→\\n   371→\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   372→\\tAgent types.AgentType `json:\\\"agent,omitempty\\\"`\\n   373→\\n   374→\\t// Model is the LLM model used during the session (e.g., \\\"claude-sonnet-4-20250514\\\")\\n   375→\\tModel string `json:\\\"model,omitempty\\\"`\\n   376→\\n   377→\\t// TurnID correlates checkpoints from the same agent turn.\\n   378→\\t// When a turn's work spans multiple commits, each gets its own checkpoint\\n   379→\\t// but they share the same TurnID for future aggregation/deduplication.\\n   380→\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n   381→\\n   382→\\t// Task checkpoint fields (only populated for task checkpoints)\\n   383→\\tIsTask    bool   `json:\\\"is_task,omitempty\\\"`\\n   384→\\tToolUseID string `json:\\\"tool_use_id,omitempty\\\"`\\n   385→\\n   386→\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n   387→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"` // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n   388→\\tCheckpointTranscriptStart   int    `json:\\\"checkpoint_transcript_start,omitempty\\\"`    // Transcript line offset at start of this checkpoint's data\\n   389→\\n   390→\\t// Deprecated: Use CheckpointTranscriptStart instead. Written for backward compatibility with older CLI versions.\\n   391→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   392→\\n   393→\\t// Token usage for this checkpoint\\n   394→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   395→\\n   396→\\t// SessionMetrics contains hook-provided session metrics (duration, turns, context usage).\\n   397→\\t// Populated for agents that provide these metrics via hooks (e.g., Cursor).\\n   398→\\tSessionMetrics *SessionMetrics `json:\\\"session_metrics,omitempty\\\"`\\n   399→\\n   400→\\t// AI-generated summary of the checkpoint\\n   401→\\tSummary *Summary `json:\\\"summary,omitempty\\\"`\\n   402→\\n   403→\\t// InitialAttribution is line-level attribution calculated at commit time\\n   404→\\tInitialAttribution *InitialAttribution `json:\\\"initial_attribution,omitempty\\\"`\\n   405→}\\n   406→\\n   407→// GetTranscriptStart returns the transcript line offset at which this checkpoint's data begins.\\n   408→// Returns 0 for new checkpoints (start from beginning). For data written by older CLI versions,\\n   409→// falls back to the deprecated TranscriptLinesAtStart field.\\n   410→func (m CommittedMetadata) GetTranscriptStart() int {\\n   411→\\tif m.CheckpointTranscriptStart > 0 {\\n   412→\\t\\treturn m.CheckpointTranscriptStart\\n   413→\\t}\\n   414→\\treturn m.TranscriptLinesAtStart\\n   415→}\\n   416→\\n   417→// SessionFilePaths contains the absolute paths to session files from the git tree root.\\n   418→// Paths include the full checkpoint path prefix (e.g., \\\"/a1/b2c3d4e5f6/1/metadata.json\\\").\\n   419→// Used in CheckpointSummary.Sessions to map session IDs to their file locations.\\n   420→type SessionFilePaths struct {\\n   421→\\tMetadata    string `json:\\\"metadata\\\"`\\n   422→\\tTranscript  string `json:\\\"transcript\\\"`\\n   423→\\tContentHash string `json:\\\"content_hash\\\"`\\n   424→\\tPrompt      string `json:\\\"prompt\\\"`\\n   425→}\\n   426→\\n   427→// CheckpointSummary is the root-level metadata.json for a checkpoint.\\n   428→// It contains aggregated statistics from all sessions and a map of session IDs\\n   429→// to their file paths. Session-specific data (including initial_attribution)\\n   430→// is stored in the session's subdirectory metadata.json.\\n   431→//\\n   432→// Structure on entire/checkpoints/v1 branch:\\n   433→//\\n   434→//\\t<checkpoint-id[:2]>/<checkpoint-id[2:]>/\\n   435→//\\t├── metadata.json         # This CheckpointSummary\\n   436→//\\t├── 1/                    # First session\\n   437→//\\t│   ├── metadata.json     # Session-specific CommittedMetadata\\n   438→//\\t│   ├── full.jsonl\\n   439→//\\t│   ├── prompt.txt\\n   440→//\\t│   └── content_hash.txt\\n   441→//\\t├── 2/                    # Second session\\n   442→//\\t└── 3/                    # Third session...\\n   443→//\\n   444→//nolint:revive // Named CheckpointSummary to avoid conflict with existing Summary struct\\n   445→type CheckpointSummary struct {\\n   446→\\tCLIVersion       string             `json:\\\"cli_version,omitempty\\\"`\\n   447→\\tCheckpointID     id.CheckpointID    `json:\\\"checkpoint_id\\\"`\\n   448→\\tStrategy         string             `json:\\\"strategy\\\"`\\n   449→\\tBranch           string             `json:\\\"branch,omitempty\\\"`\\n   450→\\tCheckpointsCount int                `json:\\\"checkpoints_count\\\"`\\n   451→\\tFilesTouched     []string           `json:\\\"files_touched\\\"`\\n   452→\\tSessions         []SessionFilePaths `json:\\\"sessions\\\"`\\n   453→\\tTokenUsage       *agent.TokenUsage  `json:\\\"token_usage,omitempty\\\"`\\n   454→}\\n   455→\\n   456→// SessionMetrics contains hook-provided session metrics from agents that report\\n   457→// them via lifecycle hooks (e.g., Cursor). These supplement transcript-derived\\n   458→// metrics for agents whose transcripts lack usage/timing data.\\n   459→type SessionMetrics struct {\\n   460→\\tDurationMs        int64 `json:\\\"duration_ms,omitempty\\\"`\\n   461→\\tTurnCount         int   `json:\\\"turn_count,omitempty\\\"`\\n   462→\\tContextTokens     int   `json:\\\"context_tokens,omitempty\\\"`\\n   463→\\tContextWindowSize int   `json:\\\"context_window_size,omitempty\\\"`\\n   464→}\\n   465→\\n   466→// Summary contains AI-generated summary of a checkpoint.\\n   467→type Summary struct {\\n   468→\\tIntent    string           `json:\\\"intent\\\"`     // What user wanted to accomplish\\n   469→\\tOutcome   string           `json:\\\"outcome\\\"`    // What was achieved\\n   470→\\tLearnings LearningsSummary `json:\\\"learnings\\\"`  // Categorized learnings\\n   471→\\tFriction  []string         `json:\\\"friction\\\"`   // Problems/annoyances encountered\\n   472→\\tOpenItems []string         `json:\\\"open_items\\\"` // Tech debt, unfinished work\\n   473→}\\n   474→\\n   475→// LearningsSummary contains learnings grouped by scope.\\n   476→type LearningsSummary struct {\\n   477→\\tRepo     []string       `json:\\\"repo\\\"`     // Codebase-specific patterns/conventions\\n   478→\\tCode     []CodeLearning `json:\\\"code\\\"`     // File/module specific findings\\n   479→\\tWorkflow []string       `json:\\\"workflow\\\"` // General dev practices\\n   480→}\\n   481→\\n   482→// CodeLearning captures a learning tied to a specific code location.\\n   483→type CodeLearning struct {\\n   484→\\tPath    string `json:\\\"path\\\"`               // File path\\n   485→\\tLine    int    `json:\\\"line,omitempty\\\"`     // Start line number\\n   486→\\tEndLine int    `json:\\\"end_line,omitempty\\\"` // End line for ranges (optional)\\n   487→\\tFinding string `json:\\\"finding\\\"`            // What was learned\\n   488→}\\n   489→\\n   490→// InitialAttribution captures line-level attribution metrics at commit time.\\n   491→// This is a point-in-time snapshot comparing the checkpoint tree (agent work)\\n   492→// against the committed tree (may include human edits).\\n   493→//\\n   494→// Attribution Metrics:\\n   495→//