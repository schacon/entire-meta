n        acts:{'main.go':{add:[{a:2,ls:[{t:'import \\\"os\\\"',o:'agent'}]},{a:8,ls:[{t:'    if err := validate(msg); err != nil {',o:'agent'},{t:'        fmt.Fprintf(os.Stderr, \\\"error: %v\\\\\\\\n\\\", err)',o:'agent'},{t:'        os.Exit(1)',o:'agent'},{t:'    }',o:'agent'}]},{a:99,ls:[{t:'',o:'agent'},{t:'func validate(s string) error {',o:'agent'},{t:'    if s == \\\"\\\" {',o:'agent'},{t:'        return fmt.Errorf(\\\"empty\\\")',o:'agent'},{t:'    }',o:'agent'},{t:'    return nil',o:'agent'}]}]}}},\\n      {l:'User modifies own 3 lines',g:'h',d:'Human removes 3 of their own lines and replaces with 3 new ones. LIFO: user added 5 to main.go, removed 3. selfMod=min(3,5)=3. Agent lines untouched!',\\n        acts:{'main.go':{rm:[5,6,7],add:[{a:4,ls:[{t:'    name := \\\"Gopher\\\"',o:'human'},{t:'    greeting := \\\"Hi\\\"',o:'human'},{t:'    msg := fmt.Sprintf(\\\"%s, %s!\\\", greeting, name)',o:'human'}]}]}}},\\n      {l:'User commits',g:'s',d:'LIFO: removed 3 from main.go, user added 5 prior. selfMod=min(3,5)=3, humanModifiedAgent=0. Agent lines=10. Total=10+5=15. Agent: 66.7%. Without LIFO, it would incorrectly be 46.7%!'}\\n    ]\\n  },\\n  multi_file: {\\n    name:'Multi-File', desc:'Per-file tracking across multiple files', pct:'~63%',\\n    files:{\\n      'main.go':{ base:[{t:'package main',o:'base'},{t:'',o:'base'},{t:'func main() {',o:'base'},{t:'}',o:'base'}]},\\n      'utils.go':{ base:[{t:'package main',o:'base'}]}\\n    },\\n    steps:[\\n      {l:'Session start',g:'s',d:'Base commit: two files, main.go (4 lines) and utils.go (1 line).'},\\n      {l:'User edits main.go',g:'h',d:'Human adds 3 lines to main.go only.',\\n        acts:{'main.go':{add:[{a:3,ls:[{t:'    result := add(1, 2)',o:'human'},{t:'    println(result)',o:'human'},{t:'    println(\\\"done\\\")',o:'human'}]}]}}},\\n      {l:'Prompt submitted',g:'s',d:'CalculatePromptAttribution(): UserAddedPerFile={\\\"main.go\\\": 3}. Human only touched main.go, not utils.go.'},\\n      {l:'Agent writes both files',g:'a',d:'Agent adds 3 lines to main.go and 5 to utils.go. Shadow checkpoint captures both.',\\n        acts:{\\n          'main.go':{add:[{a:6,ls:[{t:'    diff := subtract(5, 3)',o:'agent'},{t:'    println(diff)',o:'agent'},{t:'    println(\\\"computed\\\")',o:'agent'}]}]},\\n          'utils.go':{add:[{a:1,ls:[{t:'',o:'agent'},{t:'func add(a, b int) int {',o:'agent'},{t:'    return a + b',o:'agent'},{t:'}',o:'agent'},{t:'',o:'agent'}]}]}\\n        }},\\n      {l:'User edits both files',g:'h',d:'Human removes 2 lines from main.go (own code) and adds 3 to utils.go. LIFO per-file: main.go removals=2, prior adds=3 => selfMod=min(2,3)=2.',\\n        acts:{\\n          'main.go':{rm:[5,6]},\\n          'utils.go':{add:[{a:6,ls:[{t:'func subtract(a, b int) int {',o:'human'},{t:'    return a - b',o:'human'},{t:'}',o:'human'}]}]}\\n        }},\\n      {l:'User commits',g:'s',d:'Per-file LIFO: main.go selfMod=min(2,3)=2, utils.go selfMod=0. Agent lines=8, user added=4. Total=12. Agent: 62.5%.'}\\n    ]\\n  }\\n};\\n\\n// ── Simulation ───────────────────────────────────────────\\nfunction reset() {\\n  const p = P[S.preset];\\n  lines = {}; pAs = []; agentFiles = new Set();\\n  for (const [f,d] of Object.entries(p.files)) lines[f] = d.base.map(x=>({...x}));\\n}\\n\\nfunction applyStep(i) {\\n  const st = P[S.preset].steps[i];\\n  if (!st || !st.acts) return;\\n  for (const [f,a] of Object.entries(st.acts)) {\\n    if (!lines[f]) lines[f] = [];\\n    let ls = lines[f];\\n    if (a.rm) { const r=[...a.rm].sort((a,b)=>b-a); for(const idx of r) if(idx-1<ls.length) ls.splice(idx-1,1); }\\n    if (a.add) { const sorted=[...a.add].sort((a,b)=>b.a-a.a); for(const ad of sorted){ const p=ad.a>=99?ls.length:Math.min(ad.a,ls.length); ls.splice(p,0,...ad.ls.map(x=>({...x}))); } }\\n    if (st.g==='a') agentFiles.add(f);\\n    lines[f] = ls;\\n  }\\n}\\n\\nfunction capturePA() {\\n  const pa = {userAdded:0, perFile:{}};\\n  for (const f of Object.keys(P[S.preset].files)