handles all orchestration: state transitions, strategy calls,\\n     7→// file change detection, metadata generation.\\n     8→package cli\\n     9→\\n    10→import (\\n    11→\\t\\\"context\\\"\\n    12→\\t\\\"errors\\\"\\n    13→\\t\\\"fmt\\\"\\n    14→\\t\\\"log/slog\\\"\\n    15→\\t\\\"os\\\"\\n    16→\\t\\\"path/filepath\\\"\\n    17→\\t\\\"time\\\"\\n    18→\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    22→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    23→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    25→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    26→)\\n    27→\\n    28→// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n    29→// Returns nil if the event was handled successfully.\\n    30→func DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    31→\\tif ag == nil {\\n    32→\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    33→\\t}\\n    34→\\tif event == nil {\\n    35→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    36→\\t}\\n    37→\\n    38→\\tswitch event.Type {\\n    39→\\tcase agent.SessionStart:\\n    40→\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n    41→\\tcase agent.TurnStart:\\n    42→\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n    43→\\tcase agent.TurnEnd:\\n    44→\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n    45→\\tcase agent.Compaction:\\n    46→\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n    47→\\tcase agent.SessionEnd:\\n    48→\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n    49→\\tcase agent.SubagentStart:\\n    50→\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n    51→\\tcase agent.SubagentEnd:\\n    52→\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n    53→\\tcase agent.ModelUpdate:\\n    54→\\t\\treturn handleLifecycleModelUpdate(ctx, ag, event)\\n    55→\\tdefault:\\n    56→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    57→\\t}\\n    58→}\\n    59→\\n    60→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    61→// fires state machine transition.\\n    62→func handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    63→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n    64→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    65→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    66→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    67→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    68→\\t\\tslog.String(\\\"model\\\", event.Model),\\n    69→\\t)\\n    70→\\n    71→\\tif event.SessionID == \\\"\\\" {\\n    72→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    73→\\t}\\n    74→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    75→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    76→\\t}\\n    77→\\n    78→\\t// Build informational message\\n    79→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    80→\\n    81→\\t// Check for concurrent sessions and append count if any\\n    82→\\tstrat := GetStrategy(ctx)\\n    83→\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n    84→\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    85→\\t}\\n    86→\\n    87→\\t// Output informational message if the agent supports hook responses.\\n    88→\\t// Claude Code reads JSON from stdout; agents that don't implement\\n    89→\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n    90→\\tif event.ResponseMessage != \\\"\\\" {\\n    91→\\t\\tmessage = event.ResponseMessage\\n    92→\\t}\\n    93→\\tif writer, ok := ag.(agent.HookResponseWriter); ok {\\n    94→\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n    95→\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n    96→\\t\\t}\\n    97→\\t}\\n    98→\\n    99→\\t// Store model hint if the agent provided model info on SessionStart\\n   100→\\tif event.Model != \\\"\\\" {\\n   101→\\t\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n   102→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint on session start\\\",\\n   103→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   104→\\t\\t}\\n   105→\\t}\\n   106→\\n   107→\\t// Fire EventSessionStart for the current session (if state exists).\\n   108→\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n   109→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n   110→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   111→\\t} else if state != nil {\\n   112→\\t\\tpersistEventMetadataToState(event, state)\\n   113→\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   114→\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n   115→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   116→\\t\\t}\\n   117→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   118→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n   119→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   120→\\t\\t}\\n   121→\\t}\\