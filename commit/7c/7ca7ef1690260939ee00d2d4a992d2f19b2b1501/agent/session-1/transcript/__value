\" for all other agent hooks.\\n    78→func getHookType(hookName string) string {\\n    79→\\tswitch hookName {\\n    80→\\tcase claudecode.HookNamePreTask, claudecode.HookNamePostTask, claudecode.HookNamePostTodo:\\n    81→\\t\\treturn \\\"subagent\\\"\\n    82→\\tcase geminicli.HookNameBeforeTool, geminicli.HookNameAfterTool:\\n    83→\\t\\treturn \\\"tool\\\"\\n    84→\\tdefault:\\n    85→\\t\\treturn \\\"agent\\\"\\n    86→\\t}\\n    87→}\\n    88→\\n    89→// executeAgentHook runs the core hook execution logic for a given agent and hook name.\\n    90→// It handles git repo checks, enabled checks, logging, event parsing, and lifecycle dispatch.\\n    91→// Used by both the registered subcommand path and the RunE fallback for external agents.\\n    92→// When initLogging is true, it initializes and cleans up hook logging (used by the RunE fallback\\n    93→// since it doesn't go through PersistentPreRunE). Built-in agent subcommands pass false since\\n    94→// their parent command's PersistentPreRunE already handles logging.\\n    95→func executeAgentHook(cmd *cobra.Command, agentName types.AgentName, hookName string, initLogging bool) error {\\n    96→\\t// Skip silently if not in a git repository - hooks shouldn't prevent the agent from working\\n    97→\\tif _, err := paths.WorktreeRoot(cmd.Context()); err != nil {\\n    98→\\t\\treturn nil\\n    99→\\t}\\n   100→\\n   101→\\t// Skip if Entire is not enabled\\n   102→\\tenabled, err := IsEnabled(cmd.Context())\\n   103→\\tif err == nil && !enabled {\\n   104→\\t\\treturn nil\\n   105→\\t}\\n   106→\\n   107→\\tif initLogging {\\n   108→\\t\\tcleanup := initHookLogging(cmd.Context())\\n   109→\\t\\tdefer cleanup()\\n   110→\\t}\\n   111→\\n   112→\\tstart := time.Now()\\n   113→\\n   114→\\t// Initialize logging context with agent name\\n   115→\\tctx := logging.WithAgent(logging.WithComponent(cmd.Context(), \\\"hooks\\\"), agentName)\\n   116→\\n   117→\\t// Strategy name for logging\\n   118→\\tstrategyName