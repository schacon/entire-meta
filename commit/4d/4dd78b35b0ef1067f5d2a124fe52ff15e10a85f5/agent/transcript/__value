b.com/go-git/go-git/v6/plumbing/filemode\\\"\\n    33→\\t\\\"github.com/go-git/go-git/v6/plumbing/object\\\"\\n    34→\\t\\\"github.com/go-git/go-git/v6/utils/binary\\\"\\n    35→)\\n    36→\\n    37→// errStopIteration is used to stop commit iteration early in GetCheckpointAuthor.\\n    38→var errStopIteration = errors.New(\\\"stop iteration\\\")\\n    39→\\n    40→// WriteCommitted writes a committed checkpoint to the entire/checkpoints/v1 branch.\\n    41→// Checkpoints are stored at sharded paths: <id[:2]>/<id[2:]>/\\n    42→//\\n    43→// For task checkpoints (IsTask=true), additional files are written under tasks/<tool-use-id>/:\\n    44→//   - For incremental checkpoints: checkpoints/NNN-<tool-use-id>.json\\n    45→//   - For final checkpoints: checkpoint.json and agent-<agent-id>.jsonl\\n    46→func (s *GitStore) WriteCommitted(ctx context.Context, opts WriteCommittedOptions) error {\\n    47→\\t// Validate identifiers to prevent path traversal and malformed data\\n    48→\\tif opts.CheckpointID.IsEmpty() {\\n    49→\\t\\treturn errors.New(\\\"invalid checkpoint options: checkpoint ID is required\\\")\\n    50→\\t}\\n    51→\\tif err := validation.ValidateSessionID(opts.SessionID); err != nil {\\n    52→\\t\\treturn fmt.Errorf(\\\"invalid checkpoint options: %w\\\", err)\\n    53→\\t}\\n    54→\\tif err := validation.ValidateToolUseID(opts.ToolUseID); err != nil {\\n    55→\\t\\treturn fmt.Errorf(\\\"invalid checkpoint options: %w\\\", err)\\n    56→\\t}\\n    57→\\tif err := validation.ValidateAgentID(opts.AgentID); err != nil {\\n    58→\\t\\treturn fmt.Errorf(\\\"invalid checkpoint options: %w\\\", err)\\n    59→\\t}\\n    60→\\n    61→\\t// Ensure sessions branch exists\\n    62→\\tif err := s.ensureSessionsBranch(); err != nil {\\n    63→\\t\\treturn fmt.Errorf(\\\"failed to ensure sessions branch: %w\\\", err)\\n    64→\\t}\\n    65→\\n    66→\\t// Get branch ref and root tree hash (O(1), no flatten)\\n    67→\\tparentHash, rootTreeHash, err := s.getSessionsBranchRef()\\n    68→\\tif err != nil {\\n    69→\\t\\treturn err\\n    70→\\t}\\n    71→\\n    72→\\t// Use sharded path: <id[:2]>/<id[2:]>/\\n    73→\\tbasePath := opts.CheckpointID.Path() + \\\"/\\\"\\n    74→\\tcheckpointPath := opts.CheckpointID.Path()\\n    75→\\n    76→\\t// Flatten only the checkpoint subtree (O(files in checkpoint))\\n    77→\\tentries, err := s.flattenCheckpointEntries(rootTreeHash, checkpointPath)\\n    78→\\tif err != nil {\\n    79→\\t\\treturn err\\n    80→\\t}\\n    81→\\n    82→\\t// Track task metadata path for commit trailer\\n    83→\\tvar taskMetadataPath string\\n    84→\\n    85→\\t// Handle task checkpoints\\n    86→\\tif opts.IsTask && opts.ToolUseID != \\\"\\\" {\\n    87→\\t\\ttaskMetadataPath, err = s.writeTaskCheckpointEntries(ctx, opts, basePath, entries)\\n    88→\\t\\tif err != nil {\\n    89→\\t\\t\\treturn err\\n    90→\\t\\t}\\n    91→\\t}\\n    92→\\n    93→\\t// Write standard checkpoint entries (transcript, prompts, context, metadata)\\n    94→\\tif err := s.writeStandardCheckpointEntries(ctx, opts, basePath, entries); err != nil {\\n    95→\\t\\treturn err\\n    96→\\t}\\n    97→\\n    98→\\t// Build checkpoint subtree and splice into root (O(depth) tree surgery)\\n    99→\\tnewTreeHash, err := s.spliceCheckpointSubtree(rootTreeHash, opts.CheckpointID, basePath, entries)\\n   100→\\tif err != nil {\\n   101→\\t\\treturn err\\n   102→\\t}\\n   103→\\n   104→\\tcommitMsg := s.buildCommitMessage(opts, taskMetadataPath)\\n   105→\\tnewCommitHash, err := s.createCommit(newTreeHash, parentHash, commitMsg, opts.AuthorName, opts.AuthorEmail)\\n   106→\\tif err != nil {\\n   107→\\t\\treturn err\\n   108→\\t}\\n   109→\\n   110→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   111→\\tnewRef := plumbing.NewHashReference(refName, newCommitHash)\\n   112→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n   113→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n   114→\\t}\\n   115→\\n   116→\\treturn nil\\n   117→}\\n   118→\\n   119→// flattenCheckpointEntries reads only the entries under a specific checkpoint path\\n   120→// from the sessions branch tree. This is O(files in checkpoint) instead of O(all checkpoints).\\n   121→// Returns an empty map if the checkpoint doesn't exist yet.\\n   122→func (s *GitStore) flattenCheckpointEntries(rootTreeHash plumbing.Hash, checkpointPath string) (map[string]object.TreeEntry, error) {\\n   123→\\tentries := make(map[string]object.TreeEntry)\\n   124→\\tif rootTreeHash == plumbing.ZeroHash {\\n   125→\\t\\treturn entries, nil\\n   126→\\t}\\n   127→\\n   128→\\trootTree, err := s.repo.TreeObject(rootTreeHash)\\n   129→\\tif err != nil {\\n   130→\\t\\tif errors.Is(err, plumbing.ErrObjectNotFound) {\\n   131→\\t\\t\\treturn entries, nil // Tree doesn't exist yet\\n   132→\\t\\t}\\n   133→\\t\\treturn nil, fmt.Errorf(\\\"failed to read root tree %s: %w\\\", rootTreeHash, err)\\n   134→\\t}\\n   135→\\n   136→\\tsubtree, err := rootTree.Tree(checkpointPath)\\n   137→\\tif err != nil {\\n   138→\\t\\treturn entries, nil //nolint:nilerr // Checkpoint doesn't exist yet\\n   139→\\t}\\n   140→\\n   141→\\t// Flatten just this subtree with the full path prefix\\n   142→\\tif err := FlattenTree(s.repo, subtree, checkpointPath, entries); err != nil {\\n   143→\\t\\treturn nil, err\\n   144→\\t}\\n   145→\\treturn entries, nil\\n   146→}\\n   147→\\n   148→// spliceCheckpointSubtree builds a tree from checkpoint-local entries and installs it\\n   149→// at the correct shard location in the root tree using O(depth) tree surgery.\\n   150→// basePath is like \\\"a3/b2c4d5e6f7/\\\" (with trailing slash).\\n   151→// Returns the new root tree hash.\\n   152→func (s *GitStore) spliceCheckpointSubtree(rootTreeHash plumbing.Hash, checkpointID id.CheckpointID, basePath string, entries map[string]object.TreeEntry) (plumbing.Hash, error) {\\n   153→\\t// Convert entries to relative paths (strip basePath prefix)\\n   154→\\trelEntries := make(map[string]object.TreeEntry, len(entries))\\n   155→\\tfor path, entry := range entries {\\n   156→\\t\\trelPath := strings.TrimPrefix(path, basePath)\\n   157→\\t\\tif relPath == path {\\n   158→\\t\\t\\tcontinue // Entry doesn't have the expected prefix\\n   159→\\t\\t}\\n   160→\\t\\trelEntries[relPath] = entry\\n   161→\\t}\\n   162→\\n   163→\\t// Build the checkpoint subtree from relative entries\\n   164→\\tcheckpointTreeHash, err := BuildTreeFromEntries(s.repo, relEntries)\\n   165→\\tif err != nil {\\n   166→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to build checkpoint subtree: %w\\\", err)\\n   167→\\t}\\n   168→\\n   169→\\t// Splice into root tree at the shard path using tree surgery\\n   170→\\t// Path: [\\\"a3\\\"] with entry \\\"b2c4d5e6f7\\\" pointing to the checkpoint tree\\n   171→\\tshardPrefix := string(checkpointID[:2])\\n   172→\\tshardSuffix := string(checkpointID[2:])\\n   173→\\treturn UpdateSubtree(s.repo, rootTreeHash, []string{shardPrefix}, []object.TreeEntry{\\n   174→\\t\\t{Name: shardSuffix, Mode: filemode.Dir, Hash: checkpointTreeHash},\\n   175→\\t}, UpdateSubtreeOptions{MergeMode: MergeKeepExisting})\\n   176→}\\n   177→\\n   178→// writeTaskCheckpointEntries writes task-specific checkpoint entries and returns the task metadata path.\\n   179→func (s *GitStore) writeTaskCheckpointEntries(ctx context.Context, opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry) (string, error) {\\n   180→\\ttaskPath := basePath + \\\"tasks/\\\" + opts.ToolUseID + \\\"/\\\"\\n   181→\\n   182→\\tif opts.IsIncremental {\\n   183→\\t\\treturn s.writeIncrementalTaskCheckpoint(opts, taskPath, entries)\\n   184→\\t}\\n   185→\\treturn s.writeFinalTaskCheckpoint(ctx, opts, taskPath, entries)\\n   186→}\\n   187→\\n   188→// writeIncrementalTaskCheckpoint writes an incremental checkpoint file during task execution.\\n   189→func (s *GitStore) writeIncrementalTaskCheckpoint(opts WriteCommittedOptions, taskPath string, entries map[string]object.TreeEntry) (string, error) {\\n   190→\\tincData, err := redact.JSONLBytes(opts.IncrementalData)\\n   191→\\tif err != nil {\\n   192→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to redact incremental checkpoint: %w\\\", err)\\n   193→\\t}\\n   194→\\tcheckpoint := incrementalCheckpointData{\\n   195→\\t\\tType:      opts.IncrementalType,\\n   196→\\t\\tToolUseID: opts.ToolUseID,\\n   197→\\t\\tTimestamp: time.Now().UTC(),\\n   198→\\t\\tData:      incData,\\n   199→\\t}\\n   200→\\tcpData, err := jsonutil.MarshalIndentWithNewline(checkpoint, \\\"\\\", \\\"  \\\")\\n   201→\\tif err != nil {\\n   202→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to marshal incremental checkpoint: %w\\\", err)\\n   203→\\t}\\n   204→\\tcpBlobHash, err := CreateBlobFromContent(s.repo, cpData)\\n   205→\\tif err != nil {\\n   206→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create incremental checkpoint blob: %w\\\", err)\\n   207→\\t}\\n   208→\\n   209→\\tcpFilename := fmt.Sprintf(\\\"%03d-%s.json\\\", opts.IncrementalSequence, opts.ToolUseID)\\n   210→\\tcpPath := taskPath + \\\"checkpoints/\\\" + cpFilename\\n   211→\\tentries[cpPath] = object.TreeEntry{\\n   212→\\t\\tName: cpPath,\\n   213→\\t\\tMode: filemode.Regular,\\n   214→\\t\\tHash: cpBlobHash,\\n   215→\\t}\\n   216→\\treturn cpPath, nil\\n   217→}\\n   218→\\n   219→// writeFinalTaskCheckpoint writes the final checkpoint.json and subagent transcript.\\n   220→func (s *GitStore) writeFinalTaskCheckpoint(ctx context.Context, opts WriteCommittedOptions, taskPath string, entries map[string]object.TreeEntry) (string, error) {\\n   221→\\tcheckpoint := taskCheckpointData{\\n   222→\\t\\tSessionID:      opts.SessionID,\\n   223→\\t\\tToolUseID:      opts.ToolUseID,\\n   224→\\t\\tCheckpointUUID: opts.CheckpointUUID,\\n   225→\\t\\tAgentID:        opts.AgentID,\\n   226→\\t}\\n   227→\\tcheckpointData, err := jsonutil.MarshalIndentWithNewline(checkpoin