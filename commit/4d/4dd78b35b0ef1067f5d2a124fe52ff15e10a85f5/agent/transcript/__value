log.String(\\\"new_base\\\", currentHead[:7]))\\n    57→\\t\\treturn true, nil //nolint:nilerr // err is \\\"reference not found\\\" which is fine - just need to update state\\n    58→\\t}\\n    59→\\n    60→\\t// Old shadow branch exists - move it to new base commit\\n    61→\\tnewRefName := plumbing.NewBranchReferenceName(newShadowBranch)\\n    62→\\n    63→\\t// Create new reference pointing to same commit as old shadow branch\\n    64→\\tnewRef := plumbing.NewHashReference(newRefName, oldRef.Hash())\\n    65→\\tif err := repo.Storer.SetReference(newRef); err != nil {\\n    66→\\t\\treturn false, fmt.Errorf(\\\"failed to create new shadow branch %s: %w\\\", newShadowBranch, err)\\n    67→\\t}\\n    68→\\n    69→\\t// Delete old reference via CLI (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n    70→\\tlogCtx := logging.WithComponent(ctx, \\\"migration\\\")\\n    71→\\tif err := DeleteBranchCLI(ctx, oldShadowBranch); err != nil {\\n    72→\\t\\t// Non-fatal: log but continue - the important thing is the new branch exists\\n    73→\\t\\tlogging.Warn(logCtx, \\\"failed to remove old shadow branch\\\",\\n    74→\\t\\t\\tslog.String(\\\"shadow_branch\\\", oldShadowBranch),\\n    75→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n    76→\\t}\\n    77→\\n    78→\\tlogging.Info(logCtx, \\\"moved shadow branch (HEAD changed during session)\\\",\\n    79→\\t\\tslog.String(\\\"from\\\", oldShadowBranch),\\n    80→\\t\\tslog.String(\\\"to\\\", newShadowBranch))\\n    81→\\n    82→\\t// Update state with new base commit\\n    83→\\tstate.BaseCommit = currentHead\\n    84→\\treturn true, nil\\n    85→}\\n    86→\\n    87→// migrateAndPersistIfNeeded checks for HEAD changes, migrates the shadow branch if needed,\\n    88→// and persists the updated session state. Used by SaveStep and SaveTaskStep.\\n    89→func (s *ManualCommitStrategy) migrateAndPersistIfNeeded(ctx context.Context, repo *git.Repository, state *SessionState) error {\\n    90→\\tm