func ValidateID(s string) error {\\n    38→\\tif !idRegex.MatchString(s) {\\n    39→\\t\\treturn fmt.Errorf(\\\"invalid trail ID %q: must be 12 lowercase hex characters\\\", s)\\n    40→\\t}\\n    41→\\treturn nil\\n    42→}\\n    43→\\n    44→// String returns the trail ID as a string.\\n    45→func (id ID) String() string {\\n    46→\\treturn string(id)\\n    47→}\\n    48→\\n    49→// IsEmpty returns true if the trail ID is empty or unset.\\n    50→func (id ID) IsEmpty() bool {\\n    51→\\treturn id == EmptyID\\n    52→}\\n    53→\\n    54→// Path returns the sharded storage path for this trail ID.\\n    55→// Uses first 2 characters as shard (256 buckets), remaining as folder name.\\n    56→// Example: \\\"a3b2c4d5e6f7\\\" -> \\\"a3/b2c4d5e6f7\\\"\\n    57→func (id ID) Path() string {\\n    58→\\tif len(id) < 3 {\\n    59→\\t\\treturn string(id)\\n    60→\\t}\\n    61→\\treturn string(id[:2]) + \\\"/\\\" + string(id[2:])\\n    62→}\\n    63→\\n    64→// ShardParts returns the shard prefix and suffix separately.\\n    65→// Example: \\\"a3b2c4d5e6f7\\\" -> (\\\"a3\\\", \\\"b2c4d5e6f7\\\")\\n    66→func (id ID) ShardParts() (shard, suffix string) {\\n    67→\\tif len(id) < 3 {\\n    68→\\t\\treturn string(id), \\\"\\\"\\n    69→\\t}\\n    70→\\treturn string(id[:2]), string(id[2:])\\n    71→}\\n    72→\\n    73→// Status represents the lifecycle status of a trail.\\n    74→type Status string\\n    75→\\n    76→const (\\n    77→\\tStatusDraft      Status = \\\"draft\\\"\\n    78→\\tStatusOpen       Status = \\\"open\\\"\\n    79→\\tStatusInProgress Status = \\\"in_progress\\\"\\n    80→\\tStatusInReview   Status = \\\"in_review\\\"\\n    81→\\tStatusMerged     Status = \\\"merged\\\"\\n    82→\\tStatusClosed     Status = \\\"closed\\\"\\n    83→)\\n    84→\\n    85→// ValidStatuses returns all valid trail statuses in lifecycle order.\\n    86→func ValidStatuses() []Status {\\n    87→\\treturn []Status{\\n    88→\\t\\tStatusDraft,\\n    89→\\t\\tStatusOpen,\\n    90→\\t\\tStatusInProgress,\\n    91→\\t\\tStatusInReview,\\n    92→\\t\\tStatusMerged,\\n    93→\\t\\tStatusClosed,\\n    94→\\t}\\n    95→}\\n    96→\\n    97→// IsValid returns true if the status is a recognized trail status.\\n    98→func (s Status) IsValid() bool {\\n    99→\\tfor _, vs := range ValidStatuses() {\\n   100→\\t\\tif s == vs {\\n   101→\\t\\t\\treturn true\\n   102→\\t\\t}\\n   103→\\t}\\n   104→\\treturn false\\n   105→}\\n   106→\\n   107→// Priority represents the priority level of a trail.\\n   108→type Priority string\\n   109→\\n   110→const (\\n   111→\\tPriorityUrgent Priority = \\\"urgent\\\"\\n   112→\\tPriorityHigh   Priority = \\\"high\\\"\\n   113→\\tPriorityMedium Priority = \\\"medium\\\"\\n   114→\\tPriorityLow    Priority = \\\"low\\\"\\n   115→\\tPriorityNone   Priority = \\\"none\\\"\\n   116→)\\n   117→\\n   118→// Type represents the type/category of a trail.\\n   119→type Type string\\n   120→\\n   121→const (\\n   122→\\tTypeBug      Type = \\\"bug\\\"\\n   123→\\tTypeFeature  Type = \\\"feature\\\"\\n   124→\\tTypeChore    Type = \\\"chore\\\"\\n   125→\\tTypeDocs     Type = \\\"docs\\\"\\n   126→\\tTypeRefactor Type = \\\"refactor\\\"\\n   127→)\\n   128→\\n   129→// ReviewerStatus represents the review status for a reviewer.\\n   130→type ReviewerStatus string\\n   131→\\n   132→const (\\n   133→\\tReviewerPending          ReviewerStatus = \\\"pending\\\"\\n   134→\\tReviewerApproved         ReviewerStatus = \\\"approved\\\"\\n   135→\\tReviewerChangesRequested ReviewerStatus = \\\"changes_requested\\\"\\n   136→)\\n   137→\\n   138→// Reviewer represents a reviewer assigned to a trail.\\n   139→type Reviewer struct {\\n   140→\\tLogin  string         `json:\\\"login\\\"`\\n   141→\\tStatus ReviewerStatus `json:\\\"status\\\"`\\n   142→}\\n   143→\\n   144→// Metadata represents the metadata for a trail, matching the web PR format.\\n   145→type Metadata struct {\\n   146→\\tTrailID   ID         `json:\\\"trail_id\\\"`\\n   147→\\tBranch    string     `json:\\\"branch\\\"`\\n   148→\\tBase      string     `json:\\\"base\\\"`\\n   149→\\tTitle     string     `json:\\\"title\\\"`\\n   150→\\tBody      string     `json:\\\"body\\\"`\\n   151→\\tStatus    Status     `json:\\\"status\\\"`\\n   152→\\tAuthor    string     `json:\\\"author\\\"`\\n   153→\\tAssignees []string   `json:\\\"assignees\\\"`\\n   154→\\tLabels    []string   `json:\\\"labels\\\"`\\n   155→\\tCreatedAt time.Time  `json:\\\"created_at\\\"`\\n   156→\\tUpdatedAt time.Time  `json:\\\"updated_at\\\"`\\n   157→\\tMergedAt  *time.Time `json:\\\"merged_at\\\"`\\n   158→\\tPriority  Priority   `json:\\\"priority,omitempty\\\"`\\n   159→\\tType      Type       `json:\\\"type,omitempty\\\"`\\n   160→\\tReviewers []Reviewer `json:\\\"reviewers,omitempty\\\"`\\n   161→}\\n   162→\\n   163→// Discussion holds the discussion/comments for a trail.\\n   164→type Discussion struct {\\n   165→\\tComments []Comment `json:\\\"comments\\\"`\\n   166→}\\n   167→\\n   168→// Comment represents a single comment on a trail.\\n   169→type Comment struct {\\n   170→\\tID         string         `json:\\\"id\\\"`\\n   171→\\tAuthor     string         `json:\\\"author\\\"`\\n   172→\\tBody       string         `json:\\\"body\\\"`\\n   173→\\tCreatedAt  time.Time      `json:\\\"created_at\\\"`\\n   174→\\tResolved   bool           `json:\\\"resolved\\\"`\\n   175→\\tResolvedBy *string        `json:\\\"resolved_by\\\"`\\n   176→\\tResolvedAt *time.Time     `json:\\\"resolved_at\\\"`\\n   177→\\tReplies    []CommentReply `json:\\\"replies,omitempty\\\"`\\n   178→}\\n   179→\\n   180→// CommentReply represents a reply to a comment.\\n   181→type CommentReply struct {\\n   182→\\tID        string    `json:\\\"id\\\"`\\n   183→\\tAuthor    string    `json:\\\"author\\\"`\\n   184→\\tBody      string    `json:\\\"body\\\"`\\n   185→\\tCreatedAt time.Time `json:\\\"created_at\\\"`\\n   186→}\\n   187→\\n   188→// commonBranchPrefixes are stripped from branch names when humanizing.\\n   189→var commonBranchPrefixes = []string{\\n   190→\\t\\\"feature/\\\",\\n   191→\\t\\\"fix/\\\",\\n   192→\\t\\\"bugfix/\\\",\\n   193→\\t\\\"chore/\\\",\\n   194→\\t\\\"hotfix/\\\",\\n   195→\\t\\\"release/\\\",\\n   196→}\\n   197→\\n   198→// CheckpointRef links a checkpoint to a trail.\\n   199→type CheckpointRef struct {\\n   200→\\tCheckpointID string    `json:\\\"checkpoint_id\\\"`\\n   201→\\tCommitSHA    string    `json:\\\"commit_sha\\\"`\\n   202→\\tCreatedAt    time.Time `json:\\\"created_at\\\"`\\n   203→\\tSummary      *string   `json:\\\"summary\\\"`\\n   204→}\\n   205→\\n   206→// Checkpoints holds the list of checkpoint references for a trail.\\n   207→type Checkpoints struct {\\n   208→\\tCheckpoints []CheckpointRef `json:\\\"checkpoints\\\"`\\n   209→}\\n   210→\\n   211→// HumanizeBranchName converts a branch name into a human-readable title.\\n   212→// It strips common prefixes (feature/, fix/, etc.), replaces dashes/underscores\\n   213→// with spaces, and capitalizes the first word.\\n   214→func HumanizeBranchName(branch string) string {\\n   215→\\tname := branch\\n   216→\\tfor _, prefix := range commonBranchPrefixes {\\n   217→\\t\\tif strings.HasPrefix(name, prefix) {\\n   218→\\t\\t\\tname = strings.TrimPrefix(name, prefix)\\n   219→\\t\\t\\tbreak\\n   220→\\t\\t}\\n   221→\\t}\\n   222→\\n   223→\\t// Replace - and _ with spaces\\n   224→\\tname = strings.NewReplacer(\\\"-\\\", \\\" \\\", \\\"_\\\", \\\" \\\").Replace(name)\\n   225→\\n   226→\\t// Trim spaces and capitalize first letter\\n   227→\\tname = strings.TrimSpace(name)\\n   228→\\tif name == \\\"\\\" {\\n   229→\\t\\treturn branch\\n   230→\\t}\\n   231→\\n   232→\\t// Capitalize first character\\n   233→\\treturn strings.ToUpper(name[:1]) + name[1:]\\n   234→}\\n   235→\"}]},\"uuid\":\"6dcc2743-9bae-40ce-8cd5-c6e1573437d7\",\"timestamp\":\"2026-03-07T00:37:23.909Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a90079da00a244817