f _, err := rand.Read(bytes); err != nil {\\n    31→\\t\\treturn EmptyID, fmt.Errorf(\\\"failed to generate random trail ID: %w\\\", err)\\n    32→\\t}\\n    33→\\treturn ID(hex.EncodeToString(bytes)), nil\\n    34→}\\n    35→\\n    36→// ValidateID checks if a string is a valid trail ID format.\\n    37→func ValidateID(s string) error {\\n    38→\\tif !idRegex.MatchString(s) {\\n    39→\\t\\treturn fmt.Errorf(\\\"invalid trail ID %q: must be 12 lowercase hex characters\\\", s)\\n    40→\\t}\\n    41→\\treturn nil\\n    42→}\\n    43→\\n    44→// String returns the trail ID as a string.\\n    45→func (id ID) String() string {\\n    46→\\treturn string(id)\\n    47→}\\n    48→\\n    49→// IsEmpty returns true if the trail ID is empty or unset.\\n    50→func (id ID) IsEmpty() bool {\\n    51→\\treturn id == EmptyID\\n    52→}\\n    53→\\n    54→// Path returns the sharded storage path for this trail ID.\\n    55→// Uses first 2 characters as shard (256 buckets), remaining as folder name.\\n    56→// Example: \\\"a3b2c4d5e6f7\\\" -> \\\"a3/b2c4d5e6f7\\\"\\n    57→func (id ID) Path() string {\\n    58→\\tif len(id) < 3 {\\n    59→\\t\\treturn string(id)\\n    60→\\t}\\n    61→\\treturn string(id[:2]) + \\\"/\\\" + string(id[2:])\\n    62→}\\n    63→\\n    64→// ShardParts returns the shard prefix and suffix separately.\\n    65→// Example: \\\"a3b2c4d5e6f7\\\" -> (\\\"a3\\\", \\\"b2c4d5e6f7\\\")\\n    66→func (id ID) ShardParts() (shard, suffix string) {\\n    67→\\tif len(id) < 3 {\\n    68→\\t\\treturn string(id), \\\"\\\"\\n    69→\\t}\\n    70→\\treturn string(id[:2]), string(id[2:])\\n    71→}\\n    72→\\n    73→// Status represents the lifecycle status of a trail.\\n    74→type Status string\\n    75→\\n    76→const (\\n    77→\\tStatusDraft      Status = \\\"draft\\\"\\n    78→\\tStatusActive     Status = \\\"active\\\"\\n    79→\\tStatusValidating Status = \\\"validating\\\"\\n    80→\\tStatusDone       Status = \\\"done\\\"\\n    81→\\tStatusAbandoned  Status = \\\"abandoned\\\"\\n    82→)\\n    83→\\n    84→// ValidStatuses returns all valid trail statuses in lifecycle order.\\n    85→func ValidStatuses() []Status {\\n    86→\\treturn []Status{\\n    87→\\t\\tStatusDraft,\\n    88→\\t\\tStatusActive,\\n    89→\\t\\tStatusValidating,\\n    90→\\t\\tStatusDone,\\n    91→\\t\\tStatusAbandoned,\\n    92→\\t}\\n    93→}\\n    94→\\n    95→// IsValid returns true if the status is a recognized trail status.\\n    96→func (s Status) IsValid() bool {\\n    97→\\tfor _, vs := range ValidStatuses() {\\n    98→\\t\\tif s == vs {\\n    99→\\t\\t\\treturn true\\n   100→\\t\\t}\\n   101→\\t}\\n   102→\\treturn false\\n   103→}\\n   104→\\n   105→// Priority represents the priority level of a trail.\\n   106→type Priority string\\n   107→\\n   108→const (\\n   109→\\tPriorityUrgent Priority = \\\"urgent\\\"\\n   110→\\tPriorityHigh   Priority = \\\"high\\\"\\n   111→\\tPriorityMedium Priority = \\\"medium\\\"\\n   112→\\tPriorityLow    Priority = \\\"low\\\"\\n   113→\\tPriorityNone   Priority = \\\"none\\\"\\n   114→)\\n   115→\\n   116→// Type represents the type/category of a trail.\\n   117→type Type string\\n   118→\\n   119→const (\\n   120→\\tTypeBug      Type = \\\"bug\\\"\\n   121→\\tTypeFeature  Type = \\\"feature\\\"\\n   122→\\tTypeChore    Type = \\\"chore\\\"\\n   123→\\tTypeDocs     Type = \\\"docs\\\"\\n   124→\\tTypeRefactor Type = \\\"refactor\\\"\\n   125→)\\n   126→\\n   127→// ReviewerStatus represents the review status for a reviewer.\\n   128→type ReviewerStatus string\\n   129→\\n   130→const (\\n   131→\\tReviewerPending          ReviewerStatus = \\\"pending\\\"\\n   132→\\tReviewerApproved         ReviewerStatus = \\\"approved\\\"\\n   133→\\tReviewerChangesRequested ReviewerStatus = \\\"changes_requested\\\"\\n   134→)\\n   135→\\n   136→// Reviewer represents a reviewer assigned to a trail.\\n   137→type Reviewer struct {\\n   138→\\tLogin  string         `json:\\\"login\\\"`\\n   139→\\tStatus ReviewerStatus `json:\\\"status\\\"`\\n   140→}\\n   141→\\n   142→// BranchStatus represents the status of a branch within a trail.\\n   143→type BranchStatus string\\n   144→\\n   145→const (\\n   146→\\tBranchOpen      BranchStatus = \\\"open\\\"\\n   147→\\tBranchMerged    BranchStatus = \\\"merged\\\"\\n   148→\\tBranchDiscarded BranchStatus = \\\"discarded\\\"\\n   149→)\\n   150→\\n   151→// IsValid returns true if the branch status is a recognized value.\\n   152→func (s BranchStatus) IsValid() bool {\\n   153→\\tswitch s {\\n   154→\\tcase BranchOpen, BranchMerged, BranchDiscarded:\\n   155→\\t\\treturn true\\n   156→\\t}\\n   157→\\treturn false\\n   158→}\\n   159→\\n   160→// Intent describes the human intent behind a trail.\\n   161→type Intent struct {\\n   162→\\tKind       string      `json:\\\"kind\\\"`\\n   163→\\tValue      string      `json:\\\"value\\\"`\\n   164→\\tContent    string      `json:\\\"content,omitempty\\\"`\\n   165→\\tAmendments []Amendment `json:\\\"amendments,omitempty\\\"`\\n   166→}\\n   167→\\n   168→// Amendment records a change to the trail's intent.\\n   169→type Amendment struct {\\n   170→\\tDescription string    `json:\\\"description\\\"`\\n   171→\\tReasoning   string    `json:\\\"reasoning\\\"`\\n   172→\\tTimestamp   time.Time `json:\\\"timestamp\\\"`\\n   173→}\\n   174→\\n   175→// BranchEntry represents a branch associated with a trail.\\n   176→type BranchEntry struct {\\n   177→\\tID         string       `json:\\\"id\\\"`\\n   178→\\tName       string       `json:\\\"name\\\"`\\n   179→\\tBaseBranch string       `json:\\\"base_branch\\\"`\\n   180→\\tBaseCommit string       `json:\\\"base_commit,omitempty\\\"`\\n   181→\\tStatus     BranchStatus `json:\\\"status\\\"`\\n   182→\\tPR         *PRRef       `json:\\\"pr,omitempty\\\"`\\n   183→\\tAddedAt    time.Time    `json:\\\"added_at\\\"`\\n   184→}\\n   185→\\n   186→// PRRef holds a reference to a pull request.\\n   187→type PRRef struct {\\n   188→\\tNumber int    `json:\\\"number\\\"`\\n   189→\\tURL    string `json:\\\"url,omitempty\\\"`\\n   190→}\\n   191→\\n   192→// VerificationEvent records a single verification event for a trail.\\n   193→type VerificationEvent struct {\\n   194→\\tKind      string    `json:\\\"kind\\\"`\\n   195→\\tBranchID  string    `json:\\\"branch_id,omitempty\\\"`\\n   196→\\tStatus    string    `json:\\\"status\\\"`\\n   197→\\tTimestamp time.Time `json:\\\"timestamp\\\"`\\n   198→\\tDetails   string    `json:\\\"details,omitempty\\\"`\\n   199→}\\n   200→\\n   201→// Verification holds the verification events for a trail.\\n   202→type Verification struct {\\n   203→\\tEvents []VerificationEvent `json:\\\"events\\\"`\\n   204→}\\n   205→\\n   206→// Metadata represents the metadata for a trail, matching the web PR format.\\n   207→type Metadata struct {\\n   208→\\tTrailID   ID         `json:\\\"trail_id\\\"`\\n   209→\\tBranch    string     `json:\\\"branch\\\"`\\n   210→\\tBase      string     `json:\\\"base\\\"`\\n   211→\\tTitle     string     `json:\\\"title\\\"`\\n   212→\\tBody      string     `json:\\\"body\\\"`\\n   213→\\tStatus    Status     `json:\\\"status\\\"`\\n   214→\\tAuthor    string     `json:\\\"author\\\"`\\n   215→\\tAssignees []string   `json:\\\"assignees\\\"`\\n   216→\\tLabels    []string   `json:\\\"labels\\\"`\\n   217→\\tCreatedAt time.Time  `json:\\\"created_at\\\"`\\n   218→\\tUpdatedAt time.Time  `json:\\\"updated_at\\\"`\\n   219→\\tMergedAt  *time.Time `json:\\\"merged_at\\\"`\\n   220→\\tPriority  Priority   `json:\\\"priority,omitempty\\\"`\\n   221→\\tType      Type       `json:\\\"type,omitempty\\\"`\\n   222→\\tReviewers []Reviewer `json:\\\"reviewers,omitempty\\\"`\\n   223→}\\n   224→\\n   225→// Discussion holds the discussion/comments for a trail.\\n   226→type Discussion struct {\\n   227→\\tComments []Comment `json:\\\"comments\\\"`\\n   228→}\\n   229→\\n   230→// Comment represents a single comment on a trail.\\n   231→type Comment struct {\\n   232→\\tI