h\\\", \\\"\\\", \\\"Branch to update trail for (defaults to current)\\\")\\n   377→\\tcmd.Flags().StringSliceVar(&labelAdd, \\\"add-label\\\", nil, \\\"Add label(s)\\\")\\n   378→\\tcmd.Flags().StringSliceVar(&labelRemove, \\\"remove-label\\\", nil, \\\"Remove label(s)\\\")\\n   379→\\n   380→\\treturn cmd\\n   381→}\\n   382→\\n   383→func runTrailUpdate(w io.Writer, statusStr, title, body, branch string, labelAdd, labelRemove []string) error {\\n   384→\\trepo, err := strategy.OpenRepository(context.Background())\\n   385→\\tif err != nil {\\n   386→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   387→\\t}\\n   388→\\n   389→\\t// Determine branch\\n   390→\\tif branch == \\\"\\\" {\\n   391→\\t\\tbranch, err = GetCurrentBranch(context.Background())\\n   392→\\t\\tif err != nil {\\n   393→\\t\\t\\treturn fmt.Errorf(\\\"failed to determine current branch: %w\\\", err)\\n   394→\\t\\t}\\n   395→\\t}\\n   396→\\n   397→\\tstore := trail.NewStore(repo)\\n   398→\\tmetadata, err := store.FindByBranch(branch)\\n   399→\\tif err != nil {\\n   400→\\t\\treturn fmt.Errorf(\\\"failed to find trail: %w\\\", err)\\n   401→\\t}\\n   402→\\tif metadata == nil {\\n   403→\\t\\treturn fmt.Errorf(\\\"no trail found for branch %q\\\", branch)\\n   404→\\t}\\n   405→\\n   406→\\t// Interactive mode when no flags are provided\\n   407→\\tnoFlags := statusStr == \\\"\\\" && title == \\\"\\\" && body == \\\"\\\" && labelAdd == nil && labelRemove == nil\\n   408→\\tif noFlags {\\n   409→\\t\\t// Build status options with current value as default.\\n   410→\\t\\t// Exclude \\\"merged\\\" and \\\"closed\\\" unless the trail is already in that status\\n   411→\\t\\t// (otherwise the select would silently reset to the first option).\\n   412→\\t\\tvar statusOptions []huh.Option[string]\\n   413→\\t\\tfor _, s := range trail.ValidStatuses() {\\n   414→\\t\\t\\tif (s == trail.StatusMerged || s == trail.StatusClosed) && s != metadata.Status {\\n   415→\\t\\t\\t\\tcontinue\\n   416→\\t\\t\\t}\\n   417→\\t\\t\\tlabel := string(s)\\n   418→\\t\\t\\tif s == metadata.Status {\\n   419→\\t\\t\\t\\tlabel += \\\" (current)\\\"\\n   420→\\t\\t\\t}\\n   421→\\t\\t\\tstatusOptions = append(statusOptions, huh.NewOption(label, string(s)))\\n   422→\\t\\t}\\n   423→\\t\\tstatusStr = string(metadata.Status)\\n   424→\\t\\ttitle = metadata.Title\\n   425→\\t\\tbody = metadata.Body\\n   426→\\n   427→\\t\\tform := NewAccessibleForm(\\n   428→\\t\\t\\thuh.NewGroup(\\n   429→\\t\\t\\t\\thuh.NewSelect[string]().\\n   430→\\t\\t\\t\\t\\tTitle(\\\"Status\\\").\\n   431→\\t\\t\\t\\t\\tOptions(statusOptions...).\\n   432→\\t\\t\\t\\t\\tValue(&statusStr),\\n   433→\\t\\t\\t\\thuh.NewInput().\\n   434→\\t\\t\\t\\t\\tTitle(\\\"Title\\\").\\n   435→\\t\\t\\t\\t\\tValue(&title),\\n   436→\\t\\t\\t\\thuh.NewText().\\n   437→\\t\\t\\t\\t\\tTitle(\\\"Body\\\").\\n   438→\\t\\t\\t\\t\\tValue(&body),\\n   439→\\t\\t\\t),\\n   440→\\t\\t)\\n   441→\\t\\tif formErr := form.Run(); formErr != nil {\\n   442→\\t\\t\\treturn fmt.Errorf(\\\"form cancelled: %w\\\", formErr)\\n   443→\\t\\t}\\n   444→\\t}\\n   445→\\n   446→\\t// Validate status if provided\\n   447→\\tif statusStr != \\\"\\\" {\\n   448→\\t\\tstatus := trail.Status(statusStr)\\n   449→\\t\\tif !status.IsValid() {\\n   450→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusStr, formatValidStatuses())\\n   451→\\t\\t}\\n   452→\\t}\\n   453→\\n   454→\\terr = store.Update(metadata.TrailID, func(m *trail.Metadata) {\\n   455→\\t\\tif statusStr != \\\"\\\" {\\n   456→\\t\\t\\tm.Status = trail.Status(statusStr)\\n   457→\\t\\t}\\n   458→\\t\\tif title != \\\"\\\" {\\n   459→\\t\\t\\tm.Title = title\\n   460→\\t\\t}\\n   461→\\t\\tif body != \\\"\\\" {\\n   462→\\t\\t\\tm.Body = body\\n   463→\\t\\t}\\n   464→\\t\\tfor _, l := range labelAdd {\\n   465→\\t\\t\\tif !slices.Contains(m.Labels, l) {\\n   466→\\t\\t\\t\\tm.Labels = append(m.Labels, l)\\n   467→\\t\\t\\t}\\n   468→\\t\\