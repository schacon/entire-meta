\", err)\\n\\t}\\n\\tintent = &trail.Intent{Kind: \\\"file\\\", Value: intentFile, Content: string(content)}\\ncase intentIssue != \\\"\\\":\\n\\tintent = &trail.Intent{Kind: \\\"issue\\\", Value: intentIssue}\\ncase intentInline != \\\"\\\":\\n\\tintent = &trail.Intent{Kind: \\\"inline\\\", Value: intentInline, Content: intentInline}\\n}\\n\\nmetadata.Intent = intent\\n```\\n\\n**Step 2: Run tests and lint**\\n\\nRun: `cd /Users/alex/workspace/cli/.worktrees/1 && mise run fmt && mise run lint && mise run test:ci`\\nExpected: PASS\\n\\n**Step 3: Commit**\\n\\n```bash\\ngit add cmd/entire/cli/trail_cmd.go\\ngit commit -m \\\"trail: update 'trail create' to populate Branches[] and Intent\\\"\\n```\\n\\n---\\n\\n## Task 10: Update `trail show` for Multi-Branch Display\\n\\nUpdate the trail display to show branches, their statuses, and PRs.\\n\\n**Files:**\\n- Modify: `cmd/entire/cli/trail_cmd.go`\\n\\n**Step 1: Update printTrailDetails**\\n\\nModify the `printTrailDetails` function (or equivalent display function) to show multi-branch information:\\n\\n```go\\n// In the trail details display, after showing title/status/author:\\nif len(m.Branches) > 0 {\\n\\tfmt.Fprintf(w, \\\"\\\\nBranches:\\\\n\\\")\\n\\tfor _, b := range m.Branches {\\n\\t\\tprInfo := \\\"\\\"\\n\\t\\tif b.PR != nil {\\n\\t\\t\\tprInfo = fmt.Sprintf(\\\" (PR #%d)\\\", b.PR.Number)\\n\\t\\t}\\n\\t\\tstatusIcon := \\\" \\\"\\n\\t\\tswitch b.Status {\\n\\t\\tcase trail.BranchMerged:\\n\\t\\t\\tstatusIcon = \\\"+\\\"\\n\\t\\tcase trail.BranchDiscarded:\\n\\t\\t\\tstatusIcon = \\\"x\\\"\\n\\t\\t}\\n\\t\\tfmt.Fprintf(w, \\\"  %s %s -> %s [%s]%s\\\\n\\\", statusIcon, b.Name, b.BaseBranch, b.Status, prInfo)\\n\\t}\\n} else if m.Branch != \\\"\\\" {\\n\\t// Legacy single-branch display\\n\\tfmt.Fprintf(w, \\\"\\\\nBranch: %s -> %s\\\\n\\\", m.Branch, m.Base)\\n}\\n\\nif m.Intent != nil {\\n\\tfmt.Fprintf(w, \\\"\\\\nIntent (%s): %s\\\\n\\\", m.Intent.Kind, m.Intent.Value)\\n}\\n```\\n\\n**Step 2: Run lint**\