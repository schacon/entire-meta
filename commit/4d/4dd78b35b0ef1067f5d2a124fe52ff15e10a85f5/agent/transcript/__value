ring\\n   199→\\tvar checkout bool\\n   200→\\n   201→\\tcmd := &cobra.Command{\\n   202→\\t\\tUse:   \\\"create\\\",\\n   203→\\t\\tShort: \\\"Create a trail for the current or a new branch\\\",\\n   204→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   205→\\t\\t\\treturn runTrailCreate(cmd, title, body, base, branch, status, checkout)\\n   206→\\t\\t},\\n   207→\\t}\\n   208→\\n   209→\\tcmd.Flags().StringVar(&title, \\\"title\\\", \\\"\\\", \\\"Trail title\\\")\\n   210→\\tcmd.Flags().StringVar(&body, \\\"body\\\", \\\"\\\", \\\"Trail body\\\")\\n   211→\\tcmd.Flags().StringVar(&base, \\\"base\\\", \\\"\\\", \\\"Base branch (defaults to detected default branch)\\\")\\n   212→\\tcmd.Flags().StringVar(&branch, \\\"branch\\\", \\\"\\\", \\\"Branch for the trail (defaults to current branch)\\\")\\n   213→\\tcmd.Flags().StringVar(&status, \\\"status\\\", \\\"\\\", \\\"Initial status (defaults to draft)\\\")\\n   214→\\tcmd.Flags().BoolVar(&checkout, \\\"checkout\\\", false, \\\"Check out the branch after creating it\\\")\\n   215→\\n   216→\\treturn cmd\\n   217→}\\n   218→\\n   219→//nolint:cyclop // sequential steps for creating a trail — splitting would obscure the flow\\n   220→func runTrailCreate(cmd *cobra.Command, title, body, base, branch, statusStr string, checkout bool) error {\\n   221→\\tw := cmd.OutOrStdout()\\n   222→\\terrW := cmd.ErrOrStderr()\\n   223→\\n   224→\\trepo, err := strategy.OpenRepository(context.Background())\\n   225→\\tif err != nil {\\n   226→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   227→\\t}\\n   228→\\n   229→\\t// Determine base branch\\n   230→\\tif base == \\\"\\\" {\\n   231→\\t\\tbase = strategy.GetDefaultBranchName(repo)\\n   232→\\t\\tif base == \\\"\\\" {\\n   233→\\t\\t\\tbase = defaultBaseBranch\\n   234→\\t\\t}\\n   235→\\t}\\n   236→\\n   237→\\t_, currentBranch, _ := IsOnDefaultBranch(context.Background()) //nolint:errcheck // best-effort detection\\n   238→\\tinteractive := !cmd.Flags().Changed(\\\"title\\\") && !cmd.Flags().Changed(\\\"branch\\\")\\n   239→\\n   240→\\tif interactive {\\n   241→\\t\\t// Interactive flow: title → body → branch (derived) → status\\n   242→\\t\\tif err := runTrailCreateInteractive(&title, &body, &branch, &statusStr); err != nil {\\n   243→\\t\\t\\treturn err\\n   244→\\t\\t}\\n   245→\\t} else {\\n   246→\\t\\t// Non-interactive: derive missing values from provided flags\\n   247→\\t\\tif branch == \\\"\\\" {\\n   248→\\t\\t\\tif cmd.Flags().Changed(\\\"title\\\") {\\n   249→\\t\\t\\t\\tbranch = slugifyTitle(title)\\n   250→\\t\\t\\t} else {\\n   251→\\t\\t\\t\\tbranch = currentBranch\\n   252→\\t\\t\\t}\\n   253→\\t\\t}\\n   254→\\t\\tif title == \\\"\\\" {\\n   255→\\t\\t\\ttitle = trail.HumanizeBranchName(branch)\\n   256→\\t\\t}\\n   257→\\t}\\n   258→\\tif branch == \\\"\\\" {\\n   259→\\t\\treturn errors.New(\\\"branch name is required\\\")\\n   260→\\t}\\n   261→\\n   262→\\t// Create the branch if it doesn't exist\\n   263→\\tneedsCreation := branchNeedsCreation(repo, branch)\\n   264→\\tif needsCreation {\\n   265→\\t\\tif err := createBranch(repo, branch); err != nil {\\n   266→\\t\\t\\treturn fmt.Errorf(\\\"failed to create branch %q: %w\\\", branch, err)\\n   267→\\t\\t}\\n   268→\\t\\tfmt.Fprintf(w, \\\"Created branch %s\\\\n\\\", branch)\\n   269→\\t} else if currentBranch != branch {\\n   270→\\t\\tfmt.Fprintf(errW, \\\"Note: trail will be created for branch %q (not the current branch)\\\\n\\\", branch)\\n   271→\\t}\\n   272→\\n   273→\\t// Check if trail already exists for this branch\\n   274→\\tstore := trail.NewStore(repo)\\n   275→\\texisting, err := store.FindByBranch(branch)\\n   276→\\tif err == nil && existing != nil {\\n   277→\\t\\tfmt.Fprintf(w, \\\"Trail already exists for branch %q (ID: %s)\\\\n\\\", branch, existing.TrailID)\\n   278→\\t\\treturn nil\\n   279→\\t}\\n   280→\\n   281→\\t// Determine status\\n   282→\\tvar trailStatus trail.Status\\n   283→\\tif statusStr != \\\"\\\" {\\n   284→\\t\\ttrailStatus = trail.Status(statusStr)\\n   285→\\t\\tif !trailStatus.IsValid() {\\n   286→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusStr, formatValidStatuses())\\n   287→\\t\\t}\\n   288→\\t} else {\\n   289→\\t\\ttrailStatus = trail.StatusDraft\\n   290→\\t}\\n   291→\\n   292→\\t// Generate trail ID\\n   293→\\ttrailID, err := trail.GenerateID()\\n   294→\\tif err != nil {\\n   295→\\t\\treturn fmt.Errorf(\\\"failed to generate trail ID: %w\\\", err)\\n   296→\\t}\\n   297→\\n   298→\\t// Get author (GitHub username, falls back to git user.name)\\n   299→\\tauthorName := getTrailAuthor(repo)\\n   300→\\n   301→\\tnow := time.Now()\\n   302→\\tmetadata := &trail.Metadata{\\n   303→\\t\\tTrailID:   trailID,\\n   304→\\t\\tBranch:    branch,\\n   305→\\t\\tBase:      base,\\n   306→\\t\\tTitle:     title,\\n   307→\\t\\tBody:      body,\\n   308→\\t\\tStatus:    trailStatus,\\n   309→\\t\\tAuthor:    authorName,\\n   310→\\t\\tAssignees: []string{},\\n   311→\\t\\tLabels:    []string{},\\n   312→\\t\\tCreatedAt: now,\\n   313→\\t\\tUpdatedAt: now,\\n   314→\\t}\\n   315→\\n   316→\\tif err := store.Write(metadata, nil, nil); err != nil {\\n   317→\\t\\treturn fmt.Errorf(\\\"failed to create trail: %w\\\", err)\\n   318→\\t}\\n   319→\\n   320→\\tfmt.Fprintf(w, \\\"Created trail %q for branch %s (ID: %s)\\\\n\\\", title, branch, trailID)\\n   321→\\n   322→\\t// Push the branch and trail data to origin\\n   323→\\tif needsCreation {\\n   324→\\t\\tif err := pushBranchToOrigin(branch); err != nil {\\n   325→\\t\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to push branch: %v\\\\n\\\", err)\\n   326→\\t\\t} else {\\n   327→\\t\\t\\tfmt.Fprintf(w, \\\"Pushed branch %s to origin\\\\n\\\", branch)\\n   328→\\t\\t}\\n   329→\\t}\\n   330→\\tif err := strategy.PushTrailsBranch(context.Background(), \\\"origin\\\"); err != nil {\\n   331→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to push trail data: %v\\\\n\\\", err)