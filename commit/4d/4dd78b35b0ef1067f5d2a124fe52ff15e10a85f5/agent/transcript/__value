oot\\n    90→\\tworktreeRootCacheDir = cwd\\n    91→\\tworktreeRootMu.Unlock()\\n    92→\\n    93→\\treturn root, nil\\n    94→}\\n    95→\\n    96→// ClearWorktreeRootCache clears the cached worktree root.\\n    97→// This is primarily useful for testing when changing directories.\\n    98→func ClearWorktreeRootCache() {\\n    99→\\tworktreeRootMu.Lock()\\n   100→\\tworktreeRootCache = \\\"\\\"\\n   101→\\tworktreeRootCacheDir = \\\"\\\"\\n   102→\\tworktreeRootMu.Unlock()\\n   103→}\\n   104→\\n   105→// AbsPath returns the absolute path for a relative path within the repository.\\n   106→// If the path is already absolute, it is returned as-is.\\n   107→// Uses WorktreeRoot() to resolve paths relative to the worktree root.\\n   108→func AbsPath(ctx context.Context, relPath string) (string, error) {\\n   109→\\tif filepath.IsAbs(relPath) {\\n   110→\\t\\treturn relPath, nil\\n   111→\\t}\\n   112→\\n   113→\\troot, err := WorktreeRoot(ctx)\\n   114→\\tif err != nil {\\n   115→\\t\\treturn \\\"\\\", err\\n   116→\\t}\\n   117→\\n   118→\\treturn filepath.Join(root, relPath), nil\\n   119→}\\n   120→\\n   121→// IsInfrastructurePath returns true if the path is part of CLI infrastructure\\n   122→// (i.e., inside the .entire directory)\\n   123→func IsInfrastructurePath(path string) bool {\\n   124→\\treturn strings.HasPrefix(path, EntireDir+\\\"/\\\") || path == EntireDir\\n   125→}\\n   126→\\n   127→// ToRelativePath converts an absolute path to relative.\\n   128→// Returns empty string if the path is outside the working directory.\\n   129→func ToRelativePath(absPath, cwd string) string {\\n   130→\\tif !filepath.IsAbs(absPath) {\\n   131→\\t\\treturn absPath\\n   132→\\t}\\n   133→\\trelPath, err := filepath.Rel(cwd, absPath)\\n   134→\\tif err != nil || strings.HasPrefix(relPath, \\\"..\\\") {\\n   135→\\t\\treturn \\\"\\\"\\n   136→\\t}\\n   137→\\treturn relPath\\n   138→}\\n   139→\\n   140→// nonAlphanumericRegex matches any non-alphanumeric character\\n  