 Branch:  %s\\\\n\\\", m.Branch)\\n    75→\\tfmt.Fprintf(w, \\\"  Base:    %s\\\\n\\\", m.Base)\\n    76→\\tfmt.Fprintf(w, \\\"  Status:  %s\\\\n\\\", m.Status)\\n    77→\\tfmt.Fprintf(w, \\\"  Author:  %s\\\\n\\\", m.Author)\\n    78→\\tif m.Body != \\\"\\\" {\\n    79→\\t\\tfmt.Fprintf(w, \\\"  Body:    %s\\\\n\\\", m.Body)\\n    80→\\t}\\n    81→\\tif len(m.Labels) > 0 {\\n    82→\\t\\tfmt.Fprintf(w, \\\"  Labels:  %s\\\\n\\\", strings.Join(m.Labels, \\\", \\\"))\\n    83→\\t}\\n    84→\\tif len(m.Assignees) > 0 {\\n    85→\\t\\tfmt.Fprintf(w, \\\"  Assignees: %s\\\\n\\\", strings.Join(m.Assignees, \\\", \\\"))\\n    86→\\t}\\n    87→\\tfmt.Fprintf(w, \\\"  Created: %s\\\\n\\\", m.CreatedAt.Format(time.RFC3339))\\n    88→\\tfmt.Fprintf(w, \\\"  Updated: %s\\\\n\\\", m.UpdatedAt.Format(time.RFC3339))\\n    89→}\\n    90→\\n    91→func newTrailListCmd() *cobra.Command {\\n    92→\\tvar statusFilter string\\n    93→\\tvar jsonOutput bool\\n    94→\\tvar showAll bool\\n    95→\\n    96→\\tcmd := &cobra.Command{\\n    97→\\t\\tUse:   \\\"list\\\",\\n    98→\\t\\tShort: \\\"List all trails\\\",\\n    99→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   100→\\t\\t\\treturn runTrailListAll(cmd.OutOrStdout(), statusFilter, jsonOutput, showAll)\\n   101→\\t\\t},\\n   102→\\t}\\n   103→\\n   104→\\tcmd.Flags().StringVar(&statusFilter, \\\"status\\\", \\\"\\\", \\\"Filter by status (draft, open, in_progress, in_review, merged, closed)\\\")\\n   105→\\tcmd.Flags().BoolVar(&jsonOutput, \\\"json\\\", false, \\\"Output as JSON\\\")\\n   106→\\tcmd.Flags().BoolVarP(&showAll, \\\"all\\\", \\\"a\\\", false, \\\"Include merged and closed trails\\\")\\n   107→\\n   108→\\treturn cmd\\n   109→}\\n   110→\\n   111→func runTrailListAll(w io.Writer, statusFilter string, jsonOutput, showAll bool) error {\\n   112→\\t// Fetch remote trails branch so we see trails from collaborators\\n   113→\\tfetchTrailsBranch()\\n   114→\\n   115→\\trepo, err := strategy.OpenRepository(context.Background())\\n   116→\\tif err != nil {\\n   117→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   118→\\t}\\n   119→\\n   120→\\tstore := trail.NewStore(repo)\\n   121→\\ttrails, err := store.List()\\n   122→\\tif err != nil {\\n   123→\\t\\treturn fmt.Errorf(\\\"failed to list trails: %w\\\", err)\\n   124→\\t}\\n   125→\\n   126→\\tif trails == nil {\\n   127→\\t\\ttrails = []*trail.Metadata{}\\n   128→\\t}\\n   129→\\n   130→\\ttotalCount := len(trails)\\n   131→\\n   132→\\t// Apply status filter\\n   133→\\tif statusFilter != \\\"\\\" {\\n   134→\\t\\tstatus := trail.Status(statusFilter)\\n   135→\\t\\tif !status.IsValid() {\\n   136→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusFilter, formatValidStatuses())\\n   137→\\t\\t}\\n   138→\\t\\tvar filtered []*trail.Metadata\\n   139→\\t\\tfor _, t := range trails {\\n   140→\\t\\t\\tif t.Status == status {\\n   141→\\t\\t\\t\\tfiltered = append(filtered, t)\\n   142→\\t\\t\\t}\\n   143→\\t\\t}\\n   144→\\t\\ttrails = filtered\\n   145→\\t} else if !showAll {\\n   146→\\t\\t// By default, hide merged and closed trails\\n   147→\\t\\tvar filtered []*trail.Metadata\\n   148→\\t\\tfor _, t := range trails {\\n   149→\\t\\t\\tif t.Status != trail.StatusMerged && t.Status != trail.StatusClosed {\\n   150→\\t\\t\\t\\tfiltered = append(filtered, t)\\n   151→\\t\\t\\t}\\n   152→\\t\\t}\\n   153→\\t\\ttrails = filtered\\n   154→\\t}\\n   155→\\n   156→\\t// Sort by updated_at descending\\n   157→\\tsort.Slice(trails, func(i, j int) bool {\\n   158→\\t\\treturn trails[i].UpdatedAt.After(trails[j].UpdatedAt)\\n   159→\\t})\\n   160→\\n   161→\\tif jsonOutput {\\n   162→\\t\\tenc := json.NewEncoder(w)\\n   163→\\t\\tenc.SetIndent(\\\"\\\", \\\"  \\\")\\n   164→\\t\\tif err := enc.Encode(trails); err != nil {\\n   165→\\t\\t\\treturn fmt.Errorf(\\\"failed to encode JSON: %w\\\", err)\\n   166→\\t\\t}\\n   167→\\t\\treturn nil\\n   168→\\t}\\n   169→\\n   170→\\tif len(trails) == 0 {\\n   171→\\t\\thiddenCount := totalCount - len(trails)\\n   172→\\t\\tif hiddenCount > 0 {\\n   173→\\t\\t\\tfmt.Fprintf(w, \\\"No active trails found. %d merged/closed trail(s) hidden — use --all to show.\\\\n\\\", hiddenCount)\\n   174→\\t\\t} else {\\n   175→\\t\\t\\tfmt.Fprintln(w, \\\"No trails found.\\\")\\n   176→\\t\\t\\tfmt.Fprintln(w)\\n   177→\\t\\t\\tfmt.Fprintln(w, \\\"Commands:\\\")\\n   178→\\t\\t\\tfmt.Fprintln(w, \\\"  entire trail create   Create a trail for the current branch\\\")\\n   179→\\t\\t\\tfmt.Fprintln(w, \\\"  entire trail list     List all trails\\\")\\n   180→\\t\\t\\tfmt.Fprintln(w, \\\"  entire trail update   Update trail metadata\\\")\\n   181→\\t\\t}\\n   182→\\t\\treturn nil\\n   183→\\t}\\n   184→\\n   185→\\t// Table output\\n   186→\\tfmt.Fprintf(w, \\\"%-30s %-40s %-13s %-15s %s\\\\n\\\", \\\"BRANCH\\\", \\\"TITLE\\\", \\\"STATUS\\\", \\\"AUTHOR\\\", \\\"UPDATED\\\")\\n   187→\\tfor _, t := range trails {\\n   188→\\t\\tbranch := stringutil.TruncateRunes(t.Branch, 30, \\\"...\\\")\\n   189→\\t\\ttitle := stringutil.TruncateRunes(t.Title, 40, \\\"...\\\")\\n   190→\\t\\tfmt.Fprintf(w, \\\"%-30s %-40s %-13s %-15s %s\\\\n\\\",\\n   191→\\t\\t\\tbranch, title, t.Status, stringutil.TruncateRunes(t.Author, 15, \\\"...\\\"), timeAgo(t.UpdatedAt))\\n   192→\\t}\\n   193→\\n   194→\\treturn nil\\n   195→}\\n   196→\\n   197→func newTrailCreateCmd() *cobra.Command {\\n   198→\\tvar title, body, base, branch, status string\\n   199→\\tvar checkout bool\\n   200→\\n   201→\\tcmd := &cobra.Command{\\n   202→\\t\\tUse:   \\\"create\\\",\\n   203→\\t\\tShort: \\\"Create a trail for the current or a new branch\\\",\\n   204→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   205→\\t\\t\\treturn runTrailCreate(cmd, title, body, base, branch, status, checkout)\\n   206→\\t\\t},\\n   207→\\t}\\n   208→\\n   209→\\tcmd.Flags().StringVar(&title, \\\"title\\\", \\\"\\\", \\\"Trail title\\\")\\n   210→\\tcmd.Flags().StringVar(&body, \\\"body\\\", \\\"\\\", \\\"Trail body\\\")\\n   211→\\tcmd.Flags().StringVar(&base, \\\"base\\\", \\\"\\\", \\\"Base branch (defaults to detected default branch)\\\")\\n   212→\\tcmd.Flags().StringVar(&branch, \\\"branch\\\", \\\"\\\", \\\"Branch for the trail (defaults to current branch)\\\")\\n   213→\\tcmd.Flags().StringVar(&status, \\\"status\\\", \\\"\\\", \\\"Initial status (defaults to draft)\\\")\\n   214→\\tcmd.Flags().BoolVar(&checkout, \\\"checkout\\\", false, \\\"Check out the branch after creating it\\\")\\n   215→\\n   216→\\treturn cmd\\n   217→}\\n   218→\\n   219→//nolint:cyclop // sequential steps for creating a trail — splitting would obscure the flow\\n   220→func runTrailCreate(cmd *cobra.Command, title, body, base, branch, statusStr string, checkout bool) error {\\n   221→\\tw := cmd.OutOrStdout()\\n   222→\\terrW := cmd.ErrOrStderr()\\n   223→\\n   224→\\trepo, err := strategy.OpenRepository(context.Background())\\n   225→\\tif err != nil {\\n   226→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   227→\\t}\\n   228→\\n   229→\\t// Determine base branch\\n   230→\\tif base == \\\"\\\" {\\n   231→\\t\\tbase = strategy.GetDefaultBranchName(repo)\\n   232→\\t\\tif base == \\\"\\\" {\\n   233→\\t\\t\\tbase = defaultBaseBranch\\n   234→\\t\\t}\\n   235→\\t}\\n   236→\\n   237→\\t_, currentBranch, _ := IsOnDefaultBranch(context.Background()) //nolint:errcheck // best-effort detection\\n   238→\\tinteractive := !cmd.Flags().Changed(\\\"title\\\") && !cmd.Flags().Changed(\\\"branch\\\")\\n   239→\\n   240→\\tif interactive {\\n   241→\\t\\t// Interactive flow: title → body → branch (derived) → status\\n   242→\\t\\tif err := runTrailCreateInteractive(&title, &body, &branch, &statusStr); err != nil {\\n   243→\\t\\t\\treturn err\\n   244→\\t\\t}\\n   245→\\t} else {\\n   246→\\t\\t// Non-interactive: derive missing values from provided flags\\n   247→\\t\\tif branch == \\\"\\\" {\\n   248→\\t\\t\\tif cmd.Flags().Changed(\\\"title\\\") {\\n   249→\\t\\t\\t\\tbranch = slugifyTitle(title)\\n   250→\\t\\t\\t} else {\\n   251→\\t\\t\\t\\tbranch = currentBranch\\n   252→\\t\\t\\t}\\n   253→\\t\\t}\\n   254→\\t\\tif title == \\\"\\\" {\\n   255→\\t\\t\\ttitle = trail.HumanizeBranchName(branch)\\n   256→\\t\\t}\\n   257→\\t}\\n   258→\\tif branch == \\\"\\\" {\\n   259→\\t\\treturn errors.New(\\\"branch name is required\\\")\\n   260→\\t}\\n   261→\\n   262→\\t// Create the branch if it doesn't exist\\n   263→\\tneedsCreation := branchNeedsCreation(repo, branch)\\n   264→\\tif needsCreation {\\n   265→\\t\\tif err := createBranch(repo, branch); err != nil {\\n   266→\\t\\t\\treturn fmt.Errorf(\\\"failed to create branch %q: %w\\\", branch, err)\\n   267→\\t\\t}\\n   268→\\t\\tfmt.Fprintf(w, \\\"Created branch %s\\\\n\\\", branch)\\n   269→\\t} else if currentBranch != branch {\\n   270→\\t\\tfmt.Fprintf(errW, \\\"Note: trail will be created for branch %q (not the current branch)\\\\n\\\", branch)\\n   271→\\t}\\n   272→\\n   273→\\t// Check if trail already exists for this branch\\n   274→\\tstore := trail.NewStore(repo)\\n   275→\\texisting, err := store.FindByBranch(branch)\\n   276→\\tif err == nil && existing != nil {\\n   277→\\t\\tfmt.Fprintf(w, \\\"Trail already exists for branch %q (ID: %s)\\\\n\\\", branch, existing.TrailID)\\n   278→\\t\\treturn nil\\n   279→\\t}\\n   280→\\n   281→\\t// Determine status\\n   282→\\tvar trailStatus trail.Status\\n   283→\\tif statusStr != \\\"\\\" {\\n   284→\\t\\ttrailStatus = trail.Status(statusStr)\\n   285→\\t\\tif !trailStatus.IsValid() {\\n   286→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusStr, formatValidStatuses())\\n   287→\\t\\t}\\n   288→\\t} else {\\n   289→\\t\\ttrailStatus = trail.StatusDraft\\n   290→\\t}\\n   291→\\n   292→\\t// Generate trail ID\\n   293→\\ttrailID, err := trail.GenerateID()\\n   294→\\tif err != nil {\\n   295→\\t\\treturn fmt.Errorf(\\\"failed to generate trail ID: %w\\\", err)\\n   296→\\t}\\n   297→\\n   298→\\t// Get author (GitHub username, falls back to git user.name)\\n   299→\\tauthorName := getTrailAuthor(repo)\\n   300→\\n   301→\\tnow := time.Now()\\n   302→\\tmetadata := &trail.Metadata{\\n   303→\\t\\tTrailID:   trailID,\\n   304→\\t\\tBranch:    branch,\\n   305→\\t\\tBase:      base,\\n   306→\\t\\tTitle:     title,\\n   307→\\t\\tBody:      body,\\n   308→\\t\\tStatus:    trailStatus,\\n   309→\\t\\tAuthor:    authorName,\\n   310→\\t\\tAssignees: []string{},\\n   311→\\t\\tLabels:    []string{},\\n   312→\\t\\tCreatedAt: now,\\n   313→\\t\\tUpdatedAt: now,\\n   314→\\t}\\n   315→\\n   316→\\tif err := store.Write(metadata, nil, nil); err != nil {\\n   317→\\t\\treturn fmt.Errorf(\\\"failed to create trail: %w\\\", err)\\n   318→\\t}\\n   319→\\n   320→\\tfmt.Fprintf(w, \\\"Created trail %q for branch %s (ID: %s)\\\\n\\\", title, branch, trailID)\\n   321→\\n   322→\\t// Push the branch and trail data to origin\\n   323→\\tif needsCreation {\\n   324→\\t\\tif err := pushBranchToOrigin(branch); err != nil {\\n   325→\\t\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to push branch: %v\\\\n\\\", err)\\n   326→\\t\\t} else {\\n   327→\\t\\t\\tfmt.Fprintf(w, \\\"Pushed branch %s to origin\\\\n\\\", branch)\\n   328→\\t\\t}\\n   329→\\t}\\n   330→\\tif err := strategy.PushTrailsBranch(context.Background(), \\\"origin\\\"); err != nil {\\n   331→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to push trail data: %v\\\\n\\\", err)\\n   332→\\t}\\n   333→\\n   334→\\t// Checkout the branch if requested or prompted\\n   335→\\tif needsCreation && currentBranch != branch {\\n   336→\\t\\tshouldCheckout := checkout\\n   337→\\t\\tif !shouldCheckout && !cmd.Flags().Changed(\\\"checkout\\\") {\\n   338→\\t\\t\\t// Interactive: ask whether to checkout\\n   339→\\t\\t\\tform := NewAccessibleForm(\\n   340→\\t\\t\\t\\thuh.NewGroup(\\n   341→\\t\\t\\t\\t\\thuh.NewConfirm().\\n   342→\\t\\t\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Check out branch %s