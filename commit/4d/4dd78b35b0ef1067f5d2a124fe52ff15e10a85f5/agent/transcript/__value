etion.\\n    17→type TreeChange struct {\\n    18→\\t// Path is the full path within the tree (e.g., \\\"src/pkg/handler.go\\\").\\n    19→\\tPath string\\n    20→\\t// Entry is the new tree entry. Nil means delete the file at Path.\\n    21→\\tEntry *object.TreeEntry\\n    22→}\\n    23→\\n    24→// MergeMode controls how entries at the leaf directory are handled by UpdateSubtree.\\n    25→type MergeMode int\\n    26→\\n    27→const (\\n    28→\\t// ReplaceAll replaces the entire leaf directory contents with the new entries.\\n    29→\\tReplaceAll MergeMode = iota\\n    30→\\t// MergeKeepExisting merges new entries into the existing leaf directory,\\n    31→\\t// keeping existing entries that are not overwritten (unless in DeleteNames).\\n    32→\\tMergeKeepExisting\\n    33→)\\n    34→\\n    35→// UpdateSubtreeOptions configures the behavior of UpdateSubtree.\\n    36→type UpdateSubtreeOptions struct {\\n    37→\\t// MergeMode controls how entries at the leaf directory are handled.\\n    38→\\tMergeMode MergeMode\\n    39→\\t// DeleteNames lists entry names (at the leaf directory level) to delete.\\n    40→\\t// Only applicable when MergeMode is MergeKeepExisting.\\n    41→\\tDeleteNames []string\\n    42→}\\n    43→\\n    44→// UpdateSubtree replaces or creates a subtree at the given path within an existing tree.\\n    45→// It walks the tree path, replacing only the entries along the modified path.\\n    46→// All sibling entries at each level retain their original hashes — no re-reading needed.\\n    47→//\\n    48→// pathSegments is the directory path split into segments (e.g., [\\\"a3\\\", \\\"b2c4d5e6f7\\\"]).\\n    49→// newEntries are the files/dirs to place at the leaf directory.\\n    50→// Returns the new root tree hash.\\n    51→func UpdateSubtree(\\n    52→\\trepo *git.Repository,\\n    53→\\trootTreeHash plumbing.Hash,\\n    54→\\tpathSegments []string,\\n    55→\\tnewEntries []object.TreeEntry,\\n    56→\\topts UpdateSubtreeOptions,\\n    57→) (plumbing.Hash, error) {\\n    58→\\tif len(pathSegments) == 0 {\\n    59→\\t\\treturn buildLeafTree(repo, rootTreeHash, newEntries, opts)\\n    60→\\t}\\n    61→\\n    62→\\t// Read the current tree at this level\\n    63→\\t// Get all entries in the tree and add them to the currentEntries slice\\n    64→\\tvar currentEntries []object.TreeEntry\\n    65→\\tif rootTreeHash != plumbing.ZeroHash {\\n    66→\\t\\ttree, err := repo.TreeObject(rootTreeHash)\\n    67→\\t\\tif err != nil {\\n    68→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to read tree %s: %w\\\", rootTreeHash, err)\\n    69→\\t\\t}\\n    70→\\t\\tcurrentEntries = tree.Entries\\n    71→\\t}\\n    72→\\n    73→\\ttargetDir := pathSegments[0]\\n    74→\\tremainingPath := pathSegments[1:]\\n    75→\\n    76→\\t// Find the existing subtree entry for targetDir\\n    77→\\tvar existingSubtreeHash plumbing.Hash\\n    78→\\tfound := false\\n    79→\\tfor _, entry := range currentEntries {\\n    80→\\t\\tif entry.Name == targetDir && entry.Mode == filemode.Dir {\\n    81→\\t\\t\\texistingSubtreeHash = entry.Hash\\n    82→\\t\\t\\tfound = true\\n    83→\\t\\t\\tbreak\\n    84→\\t\\t}\\n    85→\\t}\\n    86→\\n    87→\\t// Recurse into the subtree\\n    88→\\tnewSubtreeHash, err := UpdateSubtree(repo, existingSubtreeHash, remainingPath, newEntries, opts)\\n    89→\\tif err != nil {\\n    90→\\t\\treturn plumbing.ZeroHash, err\\n    91→\\t}\\n    92→\\n    93→\\t// Build a new tree at this level with the updated subtree entry\\n    94→\\tupdatedEntries := make([]object.TreeEntry, 0, len(currentEntries)+1)\\n    95→\\treplaced := false\\n    96→\\tfor _, entry := range currentEntries {\\n    97→\\t\\tif entry.Name == targetDir {\\n    98→\\t\\t\\tupdatedEntries = append(updatedEntries, object.TreeEntry{\\n    99→\\t\\t\\t\\tName: targetDir,\\n   100→\\t\\t\\t\\tMode: filemode.Dir,\\n   101→\\t\\t\\t\\tHash: newSubtreeHash,\\n   102→\\t\\t\\t})\\n   103→\\t\\t\\treplaced = true\\n   104→\\t\\t} else {\\n   105→\\t\\t\\tupdatedEntries = append(updatedEntries, entry)\\n   106→\\t\\t}\\n   107→\\t}\\n   108→\\tif !found && !replaced {\\n   109→\\t\\tupdatedEntries = append(updatedEntries, object.TreeEntry{\\n   110→\\t\\t\\tName: targetDir,\\n   111→\\t\\t\\tMode: filemode.Dir,\\n   112→\\t\\t\\tHash: newSubtreeHash,\\n   113→\\t\\t})\\n   114→\\t}\\n   115→\\n   116→\\tsortTreeEntries(updatedEntries)\\n   117→\\treturn storeTree(repo, updatedEntries)\\n   118→}\\n   119→\\n   120→// buildLeafTree builds the tree at the leaf of the UpdateSubtree path.\\n   121→func buildLeafTree(\\n   122→\\trepo *git.Repository,\\n   123→\\texistingTreeHash plumbing.Hash,\\n   124→\\tnewEntries []object.TreeEntry,\\n   125→\\topts UpdateSubtreeOptions,\\n   126→) (plumbing.Hash, error) {\\n   127→\\tif opts.MergeMode == ReplaceAll || existingTreeHash == plumbing.ZeroHash {\\n   128→\\t\\tsorted := make([]object.TreeEntry, len(newEntries))\\n   129→\\t\\tcopy(sorted, newEntries)\\n   130→\\t\\tsortTreeEntries(sorted)\\n   131→\\t\\treturn storeTree(repo, sorted)\\n   132→\\t}\\n   133→\\n   134→\\t// MergeKeepExisting: read existing tree, merge\\n   135→\\texistingTree, err := repo.TreeObject(existingTreeHash)\\n   136→\\tif err != nil {\\n   137→\\t\\tsorted := make([]object.TreeEntry, len(newEntries))\\n   138→\\t\\tcopy(sorted, newEntries)\\n   139→\\t\\tsortTreeEntries(sorted)\\n   140→\\t\\treturn storeTree(repo, sorted)\\n   141→\\t}\\n   142→\\n   143→\\t// Build lookup of new entries by name\\n   144→\\tnewByName := make(map[string]object.TreeEntry, len(newEntries))\\n   145→\\tfor _, e := range newEntries {\\n   146→\\t\\tnewByName[e.Name] = e\\n   147→\\t}\\n   148→\\n   149→\\t// Build delete set\\n   150→\\tdeleteSet := make(map[string]bool, len(opts.DeleteNames))\\n   151→\\tfor _, name := range opts.DeleteNames {\\n   152→\\t\\tdeleteSet[name] = true\\n   153→\\t}\\n   154→\\n   155→\\t// Merge: keep existing unless overwritten or deleted\\n   156→\\tmerged := make([]object.TreeEntry, 0, len(existingTree.Entries)+len(newEntries))\\n   157→\\tfor _, existing := range existingTree.Entries {\\n   158→\\t\\tif deleteSet[existing.Name] {\\n   159→\\t\\t\\tcontinue\\n   160→\\t\\t}\\n   161→\\t\\tif replacement, ok := newByName[existing.Name]; ok {\\n   162→\\t\\t\\tmerged = append(merged, replacement)\\n   163→\\t\\t\\tdelete(newByName, existing.Name)\\n   164→\\t\\t} else {\\n   165→\\t\\t\\tmerged = append(merged, existing)\\n   166→\\t\\t}\\n   167→\\t}\\n   168→\\t// Add remaining new entries (ones that didn't replace an existing entry)\\n   169→\\tfor _, e := range newEntries {\\n   170→\\t\\tif _, stillNew := newByName[e.Name]; stillNew {\\n   171→\\t\\t\\tmerged = append(merged, e)\\n   172→\\t\\t}\\n   173→\\t}\\n   174→\\n   175→\\tsortTreeEntries(merged)\\n   176→\\treturn storeTree(repo, merged)\\n   177→}\\n   178→\\n   179→// storeTree creates a git tree object from entries and stores it in the repo.\\n   180→func storeTree(repo *git.Repository, entries []object.TreeEntry) (plumbing.Hash, error) {\\n   181→\\ttree := &object.Tree{Entries: entries}\\n   182→\\tobj := repo.Storer.NewEncodedObject()\\n   183→\\tif err := tree.Encode(obj); err != nil {\\n   184→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode tree: %w\\\", err)\\n   185→\\t}\\n   186→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n   187→\\tif err != nil {\\n   188→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store tree: %w\\\", err)\\n   189→\\t}\\n   190→\\treturn hash, nil\\n   191→}\\n   192→\\n   193→// ApplyTreeChanges applies multiple file-level changes to a tree efficiently.\\n   194→// Changes are grouped by directory and applied in a single recursive pass.\\n   195→// Unchanged subdirectories retain their hashes — this is the key optimization\\n   196→// over FlattenTree + BuildTreeFromEntries for sparse changes.\\n   197→func ApplyTreeChanges(\\n   198→\\trepo *git.Repository,\\n   199→\\trootTreeHash plumbing.Hash,\\n   200→