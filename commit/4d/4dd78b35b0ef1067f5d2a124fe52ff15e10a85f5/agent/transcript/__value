branch and collect checkpoints\\n   537→\\tfor _, branch := range branches {\\n   538→\\t\\t// Use the branch name directly to get checkpoints\\n   539→\\t\\tbranchCheckpoints, branchErr := s.listCheckpointsForBranch(ctx, branch.BranchName, sessionID, limit)\\n   540→\\t\\tif branchErr != nil {\\n   541→\\t\\t\\tif errors.Is(branchErr, context.Canceled) || errors.Is(branchErr, context.DeadlineExceeded) {\\n   542→\\t\\t\\t\\treturn nil, branchErr\\n   543→\\t\\t\\t}\\n   544→\\t\\t\\tcontinue // Skip branches we can't read\\n   545→\\t\\t}\\n   546→\\t\\tresults = append(results, branchCheckpoints...)\\n   547→\\t\\tif len(results) >= limit {\\n   548→\\t\\t\\tresults = results[:limit]\\n   549→\\t\\t\\tbreak\\n   550→\\t\\t}\\n   551→\\t}\\n   552→\\n   553→\\treturn results, nil\\n   554→}\\n   555→\\n   556→// extractToolUseIDFromPath extracts the ToolUseID from a task metadata directory path.\\n   557→// Task metadata dirs have format: .entire/metadata/<session>/tasks/<toolUseID>\\n   558→func extractToolUseIDFromPath(metadataDir string) string {\\n   559→\\tparts := strings.Split(metadataDir, \\\"/\\\")\\n   560→\\tif len(parts) >= 2 && parts[len(parts)-2] == \\\"tasks\\\" {\\n   561→\\t\\treturn parts[len(parts)-1]\\n   562→\\t}\\n   563→\\treturn \\\"\\\"\\n   564→}\\n   565→\\n   566→// errStop is a sentinel error used to break out of git log iteration.\\n   567→var errStop = errors.New(\\\"stop iteration\\\")\\n   568→\\n   569→// GetTranscriptFromCommit retrieves the transcript from a specific commit's tree.\\n   570→// This is used for shadow branch checkpoints where the transcript is stored in the commit tree\\n   571→// rather than on the entire/checkpoints/v1 branch.\\n   572→// commitHash is the commit to read from, metadataDir is the path within the tree.\\n   573→// agentType is used for reassembling chunked transcripts in the correct format.\\n   574→// Handles both chunked and non-chunked transcripts.\\n   575→func (s *GitStore) GetTranscriptFromCommit(ctx context.Context, commitHash plumbing.Hash, metadataDir string, agentType types.AgentType) ([]byte, error) {\\n   576→\\tcommit, err := s.repo.CommitObject(commitHash)\\n   577→\\tif err != nil {\\n   578→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   579→\\t}\\n   580→\\n   581→\\ttree, err := commit.Tree()\\n   582→\\tif err != nil {\\n   583→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   584→\\t}\\n   585→\\n   586→\\t// Try to get the metadata subtree for chunk detection\\n   587→\\tsubTree, subTreeErr := tree.Tree(metadataDir)\\n   588→\\tif subTreeErr == nil {\\n   589→\\t\\t// Use the helper function that handles chunking\\n   590→\\t\\ttranscript, err := readTranscriptFromTree(ctx, subTree, agentType)\\n   591→\\t\\tif err == nil && transcript != nil {\\n   592→\\t\\t\\treturn transcript, nil\\n   593→\\t\\t}\\n   594→\\t}\\n   595→\\n   596→\\t// Fall back to direct file access (for backwards compatibility)\\n   597→\\ttranscriptPath := metadataDir + \\\"/\\\" + paths.TranscriptFileName\\n   598→\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n   599→\\t\\tcontent, contentErr := file.Contents()\\n   600→\\t\\tif contentErr == nil {\\n   601→\\t\\t\\treturn []byte(content), nil\\n   602→\\t\\t}\\n   603→\\t}\\n   604→\\n   605→\\ttranscriptPath = metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n   606→\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n   607→\\t\\tcontent, contentErr := file.Contents()\\n   608→\\t\\tif contentErr == nil {\\n   609→\\t\\t\\treturn []byte(content), nil\\n   610→\\t\\t}\\n   611→\\t}\\n   612→\\n   613→\\treturn nil, ErrNoTranscript\\n   614→}\\n   615→\\n   616→// ShadowBranchExists checks if a shadow branch exists for the given base commit and worktree.\\n   617→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   618→func (s *GitStore) ShadowBranchExists(baseCommit, worktreeID string) bool {\\n   619→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   620→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   621→\\t_, err := s.repo.Reference(refName, true)\\n   622→\\treturn err == nil\\n   623→}\\n   624→\\n   625→// DeleteShadowBranch deletes the shadow branch for the given base commit and worktree.\\n   626→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   627→// Uses git CLI instead of go-git's RemoveReference because go-git v5 doesn't properly\\n   628→// persist deletions with packed refs or worktrees.\\n   629→func (s *GitStore) DeleteShadowBranch(ctx context.Context, baseCommit, worktreeID string) error {\\n   630→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   631→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", shadowBranchName)\\n   632→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   633→\\t\\treturn fmt.Errorf(\\\"failed to delete shadow branch %s: %s: %w\\\", shadowBranchName, strings.TrimSpace(string(output)), err)\\n   634→\\t}\\n   635→\\treturn nil\\n   636→}\\n   637→\\n   638→// ShadowBranchNameForCommit returns the shadow branch name for a base commit hash\\n   639→// and worktree identifier. The worktree ID should be empty for the main worktree\\n   640→// or the internal git worktree name for linked worktrees.\\n   641→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   642→func ShadowBranchNameForCommit(baseCommit, worktreeID string) string {\\n   643→\\tcommitPart := baseCommit\\n   644→\\tif len(baseCommit) >= ShadowBranchHashLength {\\n   645→\\t\\tcommitPart = baseCommit[:ShadowBranchHashLength]\\n   646→\\t}\\n   647→\\tworktreeHash := HashWorktreeID(worktreeID)\\n   648→\\treturn ShadowBranchPrefix + commitPart + \\\"-\\\" + worktreeHash\\n   649→}\\n   650→\\n   651→// ParseShadowBranchName extracts the commit prefix and worktree hash from a shadow branch name.\\n   652→// Input format: \\\"entire/<commit[:7]>-<worktreeHash[:6]>\\\"\\n   653→// Returns (commitPrefix, worktreeHash, ok). Returns (\\\"\\\", \\\"\\\", false) if not a valid shadow branch.\\n   654→func ParseShadowBranchName(branchName string) (commitPrefix, worktreeHash string, ok bool) {\\n   655→\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n   656→\\t\\treturn \\\"\\\", \\\"\\\", false\\n   657→\\t}\\n   658→\\tsuffix := strings.TrimPrefix(branchName, ShadowBranchPrefix)\\n   659→\\n   660→\\t// Find the last dash - everything before is commit prefix, after is worktree hash\\n   661→\\tlastDash := strings.LastIndex(suffix, \\\"-\\\")\\n   662→\\tif lastDash == -1 || lastDash == 0 || lastDash == len(suffix)-1 {\\n   663→\\t\\t// No dash, or dash at start/end - invalid format\\n   664→\\t\\t// Could be old format \\\"entire/<commit[:7]>\\\" without worktree hash\\n   665→\\t\\treturn suffix, \\\"\\\", true // Return as commit prefix with empty worktree hash\\n   666→\\t}\\n   667→\\n   668→\\treturn suffix[:lastDash], suffix[lastDash+1:], true\\n   669→}\\n   670→\\n   671→// getOrCreateShadowBranch gets or creates the shadow branch for checkpoints.\\n   672→// Returns (parentHash, baseTreeHash, error).\\n   673→func (s *GitStore) getOrCreateShadowBranch(branchName string) (plumbing.Hash, plumbing.Hash, error) {\\n   674→\\trefName := plumbing.NewBranchReferenceName(branchName)\\n   675→\\tref, err := s.repo.Reference(refName, true)\\n   676→\\n   677→\\tif err == nil {\\n   678→\\t\\t// Branch exists\\n   679→\\t\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n   680→\\t\\tif err != nil {\\n   681→\\t\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   682→\\t\\t}\\n   683→\\t\\treturn ref.Hash(), commit.TreeHash, nil\\n   684→\\t}\\n   685→\\n   686→\\t// Branch doesn't exist, use current HEAD's tree as base\\n   687→\\thea