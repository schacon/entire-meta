\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   387→\\t})\\n   388→\\trequire.NoError(t, err)\\n   389→\\n   390→\\tcommit, err := repo.CommitObject(headCommit)\\n   391→\\trequire.NoError(t, err)\\n   392→\\n   393→\\t// Non-existent shadow branch should fall back to file-level subtraction\\n   394→\\tcommittedFiles := map[string]struct{}{\\\"test.txt\\\": {}}\\n   395→\\tremaining := filesWithRemainingAgentChanges(repo, \\\"entire/nonexistent-e3b0c4\\\", commit, []string{\\\"test.txt\\\", \\\"other.txt\\\"}, committedFiles)\\n   396→\\n   397→\\t// With file-level subtraction: test.txt is in committedFiles, other.txt is not\\n   398→\\tassert.Equal(t, []string{\\\"other.txt\\\"}, remaining, \\\"Fallback should use file-level subtraction\\\")\\n   399→}\\n   400→\\n   401→// TestStagedFilesOverlapWithContent_ModifiedFile tests that a modified file\\n   402→// (exists in HEAD) always counts as overlap.\\n   403→func TestStagedFilesOverlapWithContent_ModifiedFile(t *testing.T) {\\n   404→\\tt.Parallel()\\n   405→\\tdir := setupGitRepo(t)\\n   406→\\n   407→\\trepo, err := git.PlainOpen(dir)\\n   408→\\trequire.NoError(t, err)\\n   409→\\n   410→\\t// Initial file is created by setupGitRepo\\n   411→\\t// Modify it and stage\\n   412→\\ttestFile := filepath.Join(dir, \\\"test.txt\\\")\\n   413→\\trequire.NoError(t, os.WriteFile(testFile, []byte(\\\"modified content\\\"), 0o644))\\n   414→\\twt, err := repo.Worktree()\\n   415→\\trequire.NoError(t, err)\\n   416→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   417→\\trequire.NoError(t, err)\\n   418→\\n   419→\\t// Create shadow branch (content doesn't matter for modified files)\\n   420→\\tcreateShadowBranchWithContent(t, repo, \\\"abc1234\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   421→\\t\\t\\\"test.txt\\\": []byte(\\\"shadow content\\\"),\\n   422→\\t})\\n   423→\\n   424→\\t// Get shadow tree\\n   425→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"abc1234\\\", \\\"e3b0c4\\\")\\n   426→\\tshadowRef, err := repo.Reference(plumbing.NewBranchReferenceName(shadowBranch), true)\\n   427→\\trequire.NoError(t, err)\\n   428→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   429→\\trequire.NoError(t, err)\\n   430→\\tshadowTree, err := shadowCommit.Tree()\\n   431→\\trequire.NoError(t, err)\\n   432→\\n   433→\\t// Modified file should count as overlap regardless of content\\n   434→\\tresult := stagedFilesOverlapWithContent(repo, shadowTree, []string{\\\"test.txt\\\"}, []string{\\\"test.txt\\\"})\\n   435→\\tassert.True(t, result, \\\"Modified file should always count as overlap\\\")\\n   436→}\\n   437→\\n   438→// TestStagedFilesOverlapWithContent_NewFile_ContentMatch tests that a new file\\n   439→// with matching content counts as overlap.\\n   440→func TestStagedFilesOverlapWithContent_NewFile_ContentMatch(t *testing.T) {\\n   441→\\tt.Parallel()\\n   442→\\tdir := setupGitRepo(t)\\n   443→\\n   444→\\trepo, err := git.PlainOpen(dir)\\n   445→\\trequire.NoError(t, err)\\n   446→\\n   447→\\t// Create a NEW file (doesn't exist in HEAD)\\n   448→\\tcontent := []byte(\\\"new file content\\\")\\n   449→\\tnewFile := filepath.Join(dir, \\\"newfile.txt\\\")\\n   450→\\trequire.NoError(t, os.WriteFile(newFile, content, 0o644))\\n   451→\\twt, err := repo.Worktree()\\n   452→\\trequire.NoError(t, err)\\n   453→\\t_, err = wt.Add(\\\"newfile.txt\\\")\\n   454→\\trequire.NoError(t, err)\\n   455→\\n   456→\\t// Create shadow branch with SAME content\\n   457→\\tcreateShadowBranchWithContent(t, repo, \\\"def5678\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   458→\\t\\t\\\"newfile.txt\\\": content,\\n   459→\\t})\\n   460→\\n   461→\\t// Get shadow tree\\n   462→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"def5678\\\", \\\"e3b0c4\\\")\\n   463→\\tshadowRef, err := repo.Reference(plumbing.NewBranchReferenceName(shadowBranch), true)\\n   464→\\trequire.NoError(t, err)\\n   465→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n  