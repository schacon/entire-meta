trequire.NoError(t, os.WriteFile(testFile, content, 0o644))\\n   311→\\twt, err := repo.Worktree()\\n   312→\\trequire.NoError(t, err)\\n   313→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   314→\\trequire.NoError(t, err)\\n   315→\\theadCommit, err := wt.Commit(\\\"Add file with same content\\\", &git.CommitOptions{\\n   316→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   317→\\t})\\n   318→\\trequire.NoError(t, err)\\n   319→\\n   320→\\tcommit, err := repo.CommitObject(headCommit)\\n   321→\\trequire.NoError(t, err)\\n   322→\\n   323→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"def5678\\\", \\\"e3b0c4\\\")\\n   324→\\tcommittedFiles := map[string]struct{}{\\\"test.txt\\\": {}}\\n   325→\\n   326→\\t// File was fully committed - should NOT be in remaining\\n   327→\\tremaining := filesWithRemainingAgentChanges(repo, shadowBranch, commit, []string{\\\"test.txt\\\"}, committedFiles)\\n   328→\\tassert.Empty(t, remaining, \\\"Fully committed file should not be in remaining\\\")\\n   329→}\\n   330→\\n   331→// TestFilesWithRemainingAgentChanges_PartialCommit tests that files committed with\\n   332→// different content (partial commit via git add -p) ARE in the remaining list.\\n   333→func TestFilesWithRemainingAgentChanges_PartialCommit(t *testing.T) {\\n   334→\\tt.Parallel()\\n   335→\\tdir := setupGitRepo(t)\\n   336→\\n   337→\\trepo, err := git.PlainOpen(dir)\\n   338→\\trequire.NoError(t, err)\\n   339→\\n   340→\\t// Shadow branch has the full agent content\\n   341→\\tfullContent := []byte(\\\"line 1\\\\nline 2\\\\nline 3\\\\nline 4\\\\n\\\")\\n   342→\\tcreateShadowBranchWithContent(t, repo, \\\"ghi9012\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   343→\\t\\t\\\"test.txt\\\": fullContent,\\n   344→\\t})\\n   345→\\n   346→\\t// User commits only partial content (simulating git add -p)\\n   347→\\tpartialContent := []byte(\\\"line 1\\\\nline 2\\\\n\\\")\\n   348→\\ttestFile := filepath.Join