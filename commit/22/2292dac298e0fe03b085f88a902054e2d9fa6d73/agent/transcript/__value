4→\\trequire.NoError(t, err)\\n   505→\\n   506→\\t// New file with different content should NOT count as overlap\\n   507→\\tresult := stagedFilesOverlapWithContent(repo, shadowTree, []string{\\\"newfile.txt\\\"}, []string{\\\"newfile.txt\\\"})\\n   508→\\tassert.False(t, result, \\\"New file with mismatched content should not count as overlap\\\")\\n   509→}\\n   510→\\n   511→// TestStagedFilesOverlapWithContent_NoOverlap tests that non-overlapping files\\n   512→// return false.\\n   513→func TestStagedFilesOverlapWithContent_NoOverlap(t *testing.T) {\\n   514→\\tt.Parallel()\\n   515→\\tdir := setupGitRepo(t)\\n   516→\\n   517→\\trepo, err := git.PlainOpen(dir)\\n   518→\\trequire.NoError(t, err)\\n   519→\\n   520→\\t// Stage a file NOT in filesTouched\\n   521→\\totherFile := filepath.Join(dir, \\\"other.txt\\\")\\n   522→\\trequire.NoError(t, os.WriteFile(otherFile, []byte(\\\"other content\\\"), 0o644))\\n   523→\\twt, err := repo.Worktree()\\n   524→\\trequire.NoError(t, err)\\n   525→\\t_, err = wt.Add(\\\"other.txt\\\")\\n   526→\\trequire.NoError(t, err)\\n   527→\\n   528→\\t// Create shadow branch\\n   529→\\tcreateShadowBranchWithContent(t, repo, \\\"jkl3456\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   530→\\t\\t\\\"session.txt\\\": []byte(\\\"session content\\\"),\\n   531→\\t})\\n   532→\\n   533→\\t// Get shadow tree\\n   534→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"jkl3456\\\", \\\"e3b0c4\\\")\\n   535→\\tshadowRef, err := repo.Reference(plumbing.NewBranchReferenceName(shadowBranch), true)\\n   536→\\trequire.NoError(t, err)\\n   537→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   538→\\trequire.NoError(t, err)\\n   539→\\tshadowTree, err := shadowCommit.Tree()\\n   540→\\trequire.NoError(t, err)\\n   541→\\n   542→\\t// Staged file \\\"other.txt\\\" is not in filesTouched \\\"session.txt\\\"\\n   543→\\tresult := stagedFilesOverlapWithContent(repo, shadowTree, []string{\\\"other.txt\\\"}, []string{\\\"session.txt\\\"})\\n   544→\\tassert.False(t, result, \\\"Non-overlapping files should return false\\\")\\n   545→}\\n   546→\\n   547→// TestStagedFilesOverlapWithContent_DeletedFile tests that a deleted file\\n   548→// (exists in HEAD but staged for deletion) DOES count as overlap.\\n   549→// The agent's action of deleting the file is being committed, so the session\\n   550→// context should be linked to this commit.\\n   551→func TestStagedFilesOverlapWithContent_DeletedFile(t *testing.T) {\\n   552→\\tt.Parallel()\\n   553→\\n   554→\\tdir := t.TempDir()\\n   555→\\trepo, err := git.PlainInit(dir, false)\\n   556→\\trequire.NoError(t, err)\\n   557→\\n   558→\\tworktree, err := repo.Worktree()\\n   559→\\trequire.NoError(t, err)\\n   560→\\n   561→\\t// Create and commit a file that will be deleted\\n   562→\\tfilePath := filepath.Join(dir, \\\"to_delete.txt\\\")\\n   563→\\terr = os.WriteFile(filePath, []byte(\\\"original content\\\"), 0644)\\n   564→\\trequire.NoError(t, err)\\n   565→\\t_, err = worktree.Add(\\\"to_delete.txt\\\")\\n   566→\\trequire.NoError(t, err)\\n   567→\\t_, err = worktree.Commit(\\\"Add to_delete.txt\\\", &git.CommitOptions{\\n   568→\\t\\tAuthor: &object.Signature{\\n   569→\\t\\t\\tName:  \\\"Test\\\",\\n   570→\\t\\t\\tEmail: \\\"test@test.com\\\",\\n   571→\\t\\t\\tWhen:  time.Now(),\\n   572→\\t\\t},\\n   573→\\t})\\n   574→\\trequire.NoError(t, err)\\n   575→\\n   576→\\t// Create shadow branch (simulating agent work on the file)\\n   577→\\tcreateShadowBranchWithContent(t, repo, \\\"mno7890\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   578→\\t\\t\\\"to_delete.txt\\\": []byte(\\\"agent modified content\\\"),\\n   579→\\t})\\n   580→\\n   581→\\t// Stage the file for deletion (git rm)\\n   582→\\t_, err = worktree.Remove(\\\"to_delete.txt\\\")\\n   583→\\trequire.NoError(t, err)\\n   584→\\n   585→\\t// Get shadow tree\\n   586→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"mno7890\\\", \\\"e3b0c4\\\")\\n   587→\\tshadowRef, err := repo.Reference(plumbing.NewBranchReferenceName(shadowBranch), true)\\n   588→\\trequire.NoError(t, err)\\n   589→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   590→\\trequire.NoError(t, err)\\n   591→\\tshadowTree, err := shadowCommit.Tree()\\n   592→\\trequire.NoError(t, err)\\n   593→\\n   594→\\t// Deleted file SHOULD count as overlap - the agent's deletion is being committed\\n   595→\\tresult := stagedFilesOverlapWithContent(repo, shadowTree, []string{\\\"to_delete.txt\\\"}, []string{\\\"to_delete.txt\\\"})\\n   596→\\tassert.True(t, result, \\\"Deleted file should count as overlap (agent's deletion being committed)\\\")\\n   597→}\\n   598→\\n   599→// createShadowBranchWithContent creates a shadow branch with the given file contents.\\n   600→// This helper directly uses go-git APIs to avoid paths.WorktreeRoot() dependency.\\n   601→//\\n   602→//nolint:unparam // worktreeID is kept as a parameter for flexibility even if tests currently use same value\\n   603→func createShadowBranchWithContent(t *testing.T, repo *git.Repository, baseCommit, worktreeID string, fileContents map[string][]byte) {\\n   604→\\tt.Helper()\\n   605→\\n   606→\\tshadowBranchName := checkpoint.ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   607→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   608→\\n   609→\\t// Get HEAD for base tree\\n   610→\\thead, err := repo.Head()\\n   611→\\trequire.NoError(t, err)\\n   612→\\n   613→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   614→\\trequire.NoError(t, err)\\n   615→\\n   616→\\tbaseTree, err := headCommit.Tree()\\n   617→\\trequire.NoError(t, err)\\n   618→\\n   619→\\t// Flatten existing tree into map\\n   620→\\tentries := make(map[string]object.TreeEntry)\\n   621→\\terr = checkpoint.FlattenTree(repo, baseTree, \\\"\\\", entries)\\n   622→\\trequire.NoError(t, err)\\n   623→\\n   624→\\t// Add/update files with provided content\\n   625→\\tfor filePath, content := range f