\n   108→\\n   109→// DefaultAgentName is the registry key for the default agent.\\n   110→const DefaultAgentName AgentName = AgentNameClaudeCode\\n   111→\\n   112→// GetByAgentType retrieves an agent by its type identifier.\\n   113→//\\n   114→// Note: This uses a linear search that instantiates agents until a match is found.\\n   115→// This is acceptable because:\\n   116→//   - Agent count is small (~2-20 agents)\\n   117→//   - Agent factories are lightweight (empty struct allocation)\\n   118→//   - Called infrequently (commit hooks, rewind, debug commands - not hot paths)\\n   119→//   - Cost is ~400ns worst case vs milliseconds for I/O operations\\n   120→//\\n   121→// Only optimize if agent count exceeds 100 or profiling shows this as a bottleneck.\\n   122→func GetByAgentType(agentType AgentType) (Agent, error) {\\n   123→\\tregistryMu.RLock()\\n   124→\\tdefer registryMu.RUnlock()\\n   125→\\n   126→\\tfor _, factory := range registry {\\n   127→\\t\\tag := factory()\\n   128→\\t\\tif ag.Type() == agentType {\\n   129→\\t\\t\\treturn ag, nil\\n   130→\\t\\t}\\n   131→\\t}\\n   132→\\n   133→\\treturn nil, fmt.Errorf(\\\"unknown agent type: %s\\\", agentType)\\n   134→}\\n   135→\\n   136→// AllProtectedDirs returns the union of ProtectedDirs from all registered agents.\\n   137→func AllProtectedDirs() []string {\\n   138→\\t// Copy factories under the lock, then release before calling external code.\\n   139→\\tregistryMu.RLock()\\n   140→\\tfactories := make([]Factory, 0, len(registry))\\n   141→\\tfor _, f := range registry {\\n   142→\\t\\tfactories = append(factories, f)\\n   143→\\t}\\n   144→\\tregistryMu.RUnlock()\\n   145→\\n   146→\\tseen := make(map[string]struct{})\\n   147→\\tvar dirs []string\\n   148→\\tfor _, factory := range factories {\\n   149→\\t\\tfor _, d := range factory().ProtectedDirs() {\\n   150→\\t\\t\\tif _, ok := seen[d]; !ok {\\n   151→\\t\\t\\t\\tseen[d] = struct{}{}\\n   152→\\t\\t\\t\\tdirs = append(dirs, d)\\n   153→\\t\\t\\t}\\n   154→\\t\\t}\\n   155→\\t}\\n   156→\\tslices.Sort(dirs)\\n   157→\\treturn dirs\\n   158→}\\n   159→\\n   160→// Default returns the default agent.\\n   161→// Returns nil if the default agent is not registered.\\n   162→//\\n   163→//nolint:errcheck // Factory pattern returns interface; error is acceptable to ignore for default\\n   164→func Default() Agent {\\n   165→\\ta, _ := Get(DefaultAgentName)\\n   166→\\treturn a\\n   167→}\\n   168→\"}]},\"uuid\":\"4a830fe6-606a-435a-b84b-61a02b64be6d\",\"timestamp\":\"2026-02-25T14:03:26.706Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Thoroughly explore the Cursor agent implementation in this codebase. Find all files related to the Cursor agent in:\\n1. cmd/entire/cli/agent/ - the agent implementation\\n2. docs/ - any existing docs about cursor\\n3. Any other references to \\\"cursor\\\" in the codebase\\n\\nFor each file found, read its contents. I need to understand the full Cursor implementation to write documentation.\",\"agentId\":\"abd5990\"},\"toolUseID\":\"agent_msg_01UFjmLJ58nBLibP9x4xFgit\",\"parentToolUseID\":\"toolu_01NSiYxxaeESGRjTnF4EaSnC\",\"uuid\":\"4aba4e1c-0f98-4ebc-bd96-b2aa8b0a4ce0\",\"timestamp\":\"2026-02-25T14:03:26.709Z\"}\n{\"parentUuid\":\"4aba4e1c-0f98-4ebc-bd96-b2aa8b0a4ce0\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/robin/Developer/cli\",\"sessionId\":\"0a6fa8ce-14c1-4d76-b8cd-3e2d721777e9\",\"version\":\"2.1.49\",\"gitBranch\":\"rwr/cursor-docs\",\"slug\":\"serialized-growing-starfish\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-02-25T14:03:28.856Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01K9iveYasxxjwPCSFi2TfMF\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01FtQisMgafNUrJyTixiXL7p\",\"name\":\"Bash\",\"input\":{\"command\":\"find /Users/robin/Developer/cli/docs -name \\\"*.md\\\" | xargs grep -l -i cursor\