uential(t *testing.T, strategies []string, testFn func(t *testing.T, strategyName string)) {\\n   246→\\tt.Helper()\\n   247→\\tfor _, strat := range strategies {\\n   248→\\t\\tt.Run(strat, func(t *testing.T) {\\n   249→\\t\\t\\ttestFn(t, strat)\\n   250→\\t\\t})\\n   251→\\t}\\n   252→}\\n   253→\\n   254→// InitRepo initializes a git repository in the test environment.\\n   255→func (env *TestEnv) InitRepo() {\\n   256→\\tenv.T.Helper()\\n   257→\\n   258→\\trepo, err := git.PlainInit(env.RepoDir, false)\\n   259→\\tif err != nil {\\n   260→\\t\\tenv.T.Fatalf(\\\"failed to init git repo: %v\\\", err)\\n   261→\\t}\\n   262→\\n   263→\\t// Configure git user for commits\\n   264→\\tcfg, err := repo.Config()\\n   265→\\tif err != nil {\\n   266→\\t\\tenv.T.Fatalf(\\\"failed to get repo config: %v\\\", err)\\n   267→\\t}\\n   268→\\tcfg.User.Name = \\\"Test User\\\"\\n   269→\\tcfg.User.Email = \\\"test@example.com\\\"\\n   270→\\n   271→\\t// Disable GPG signing for test commits (prevents failures if user has commit.gpgsign=true globally)\\n   272→\\tif cfg.Raw == nil {\\n   273→\\t\\tcfg.Raw = config.New()\\n   274→\\t}\\n   275→\\tcfg.Raw.Section(\\\"commit\\\").SetOption(\\\"gpgsign\\\", \\\"false\\\")\\n   276→\\n   277→\\tif err := repo.SetConfig(cfg); err != nil {\\n   278→\\t\\tenv.T.Fatalf(\\\"failed to set repo config: %v\\\", err)\\n   279→\\t}\\n   280→}\\n   281→\\n   282→// InitEntire initializes the .entire directory with the specified strategy.\\n   283→func (env *TestEnv) InitEntire(strategyName string) {\\n   284→\\tenv.InitEntireWithOptions(strategyName, nil)\\n   285→}\\n   286→\\n   287→// InitEntireWithOptions initializes the .entire directory with the specified strategy and options.\\n   288→func (env *TestEnv) InitEntireWithOptions(strategyName string, strategyOptions map[string]any) {\\n   289→\\tenv.T.Helper()\\n   290→\\tenv.initEntireInternal(strategyName, \\\"\\\", strategyOptions)\\n   291→}\\n   292→\\n   293→// InitEntireWithAgent initializes an Entire test environment with a specific agent.\\n   294→// If agentName is empty, defaults to claude-code.\\n   295→func (env *TestEnv) InitEntireWithAgent(strategyName string, agentName agent.AgentName) {\\n   296→\\tenv.T.Helper()\\n   297→\\tenv.initEntireInternal(strategyName, agentName, nil)\\n   298→}\\n   299→\\n   300→// InitEntireWithAgentAndOptions initializes Entire with the specified strategy, agent, and options.\\n   301→func (env *TestEnv) InitEntireWithAgentAndOptions(strategyName string, agentName agent.AgentName, strategyOptions map[string]any) {\\n   302→\\tenv.T.Helper()\\n   303→\\tenv.initEntireInternal(strategyName, agentName, strategyOptions)\\n   304→}\\n   305→\\n   306→// initEntireInternal is the common implementation for InitEntire variants.\\n   307→func (env *TestEnv) initEntireInternal(strategyName string, agentName agent.AgentName, strategyOptions map[string]any) {\\n   308→\\tenv.T.Helper()\\n   309→\\n   310→\\t// Create .entire directory structure\\n   311→\\tentireDir := filepath.Join(env.RepoDir, \\\".entire\\\")\\n   312→\\tif err := os.MkdirAll(entireDir, 0o755); err != nil {\\n   313→\\t\\tenv.T.Fatalf(\\\"failed to create .entire directory: %v\\\", err)\\n   314→\\t}\\n   315→\\n   316→\\t// Create tmp directory\\n   317→\\ttmpDir := filepath.Join(entireDir, \\\"tmp\\\")\\n   318→\\tif err := os.MkdirAll(tmpDir, 0o755); err != nil {\\n   319→\\t\\tenv.T.Fatalf(\\\"failed to create .entire/tmp directory: %v\\\", err)\\n   320→\\t}\\n   321→\\n   322→\\t// Write settings.json\\n   323→\\tsettings := map[string]any{\\n   324→\\t\\t\\\"strategy\\\":  strategyName,\\n   325→\\t\\t\\\"local_dev\\\": true, // Note: git-triggered hooks won't work (path is relative); tests call hooks via getTestBinary() instead\\n   326→\\t}\\n   327→\\t// Only add agent if specified (otherwise defaults to claude-code)\\n   328→\\tif agentName != \\\"\\\" {\\n   329→\\t\\tsettings[\\\"agent\\\"] = string(agentName)\\n   330→\\t}\\n   331→\\tif strategyOptions != nil {\\n   332→\\t\\tsettings[\\\"strategy_options\\\"] = strategyOptions\\n   333→\\t}\\n   334→\\tdata, err := jsonutil.MarshalIndentWithNewline(settings, \\\"\\\", \\\"  \\\")\\n   335→\\tif err != nil {\\n   336→\\t\\tenv.T.Fatalf(\\\"failed to marshal settings: %v\\\", err)\\n   337→\\t}\\n   338→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   339→\\tif err := os.WriteFile(settingsPath, data, 0o644); err != nil {\\n   340→\\t\\tenv.T.Fatalf(\\\"failed to write %s: %v\\\", paths.SettingsFileName, err)\\n   341→\\t}\\n   342→}\\n   343→\\n   344→// WriteFile creates a file with the given content in the test repo.\\n   345→// It creates parent directories as needed.\\n   346→func (env *TestEnv) WriteFile(path, content string) {\\n   347→\\tenv.T.Helper()\\n   348→\\n   349→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   350→\\n   351→\\t// Create parent directories\\n   352→\\tdir := filepath.Dir(fullPath)\\n   353→\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   354→\\t\\tenv.T.Fatalf(\\\"failed to create directory %s: %v\\\", dir, err)\\n   355→\\t}\\n   356→\\n   357→\\tif err := os.WriteFile(fullPath, []byte(content), 0o644); err != nil {\\n   358→\\t\\tenv.T.Fatalf(\\\"failed to write file %s: %v\\\", path, err)\\n   359→\\t}\\n   360→}\\n   361→\\n   362→// ReadFile reads a file from the test repo.\\n   363→func (env *TestEnv) ReadFile(path string) string {\\n   364→\\tenv.T.Helper()\\n   365→\\n   366→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   367→\\tdata, err := os.ReadFile(fullPath)\\n   368→\\tif err != nil {\\n   369→\\t\\tenv.T.Fatalf(\\\"failed to read file %s: %v\\\", path, err)\\n   370→\\t}\\n   371→\\treturn string(data)\\n   372→}\\n   373→\\n   374→// ReadFileAbsolute reads a file using an absolute path.\\n   375→func (env *TestEnv) ReadFileAbsolute(path string) string {\\n   376→\\tenv.T.Helper()\\n   377→\\n   378→\\tdata, err := os.ReadFile(path)\\n   379→\\tif err != nil {\\n   380→\\t\\tenv.T.Fatalf(\\\"failed to read file %s: %v\\\", path, err)\\n   381→\\t}\\n   382→\\treturn string(data)\\n   383→}\\n   384→\\n   385→// FileExists checks if a file exists in the test repo.\\n   386→func (env *TestEnv) FileExists(path string) bool {\\n   387→\\tenv.T.Helper()\\n   388→\\n   389→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   390→\\t_, err := os.Stat(fullPath)\\n   391→\\treturn err == nil\\n   392→}\\n   393→\\n   394→// GitAdd stages files for commit.\\n   395→func (env *TestEnv) GitAdd(paths ...string) {\\n   396→\\tenv.T.Helper()\\n   397→\\n   398→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   399→\\tif err != nil {\\n   400→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   401→\\t}\\n   402→\\n   403→\\tworktree, err := repo.Worktree()\\n   404→\\tif err != nil {\\n   405→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   406→\\t}\\n   407→\\n   408→\\tfor _, path := range paths {\\n   409→\\t\\tif _, err := worktree.Add(path); err != nil {\\n   410→\\t\\t\\tenv.T.Fatalf(\\\"failed to add file %s: %v\\\", path, err)\\n   411→\\t\\t}\\n   412→\\t}\\n   413→}\\n   414→\\n   415→// GitCommit creates a commit with all staged files.\\n   416→func (env *TestEnv) GitCommit(message string) {\\n   417→\\tenv.T.Helper()\\n   418→\\n   419→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   420→\\tif err != nil {\\n   421→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   422→\\t}\\n   423→\\n   424→\\tworktree, err := repo.Worktree()\\n   425→\\tif err != nil {\\n   426→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   427→\\t}\\n   428→\\n   429→\\t_, err = worktree.Commit(message, &git.CommitOptions{\\n   430→\\t\\tAuthor: &object.Signature{\\n   431→\\t\\t\\tName:  \\\"Test User\\\",\\n   432→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   433→\\t\\t\\tWhen:  time.Now(),\\n   434→\\t\\t},\\n   435→\\t})\\n   436→\\tif err != nil {\\n   437→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   438→\\t}\\n   439→}\\n   440→\\n   441→// GitCommitWithMetadata creates a commit with Entire-Metadata trailer.\\n   442→// This simulates commits created by the commit strategy.\\n   443→func (env *TestEnv) GitCommitWithMetadata(message, metadataDir string) {\\n   444→\\tenv.T.Helper()\\n   445→\\n   446→\\t// Format message with metadata trailer\\n   447→\\tfullMessage := message + \\\"\\\\n\\\\nEntire-Metadata: \\\" + metadataDir + \\\"\\\\n\\\"\\n   448→\\n   449→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   450→\\tif err != nil {\\n   451→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   452→\\t}\\n   453→\\n   454→\\tworktree, err := repo.Worktree()\\n   455→\\tif err != nil {\\n   456→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   457→\\t}\\n   458→\\n   459→\\t_, err = worktree.Commit(fullMessage, &git.CommitOptions{\\n   460→\\t\\tAuthor: &object.Signature{\\n   461→\\t\\t\\tName:  \\\"Test User\\\",\\n   462→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   463→\\t\\t\\tWhen:  time.Now(),\\n   464→\\t\\t},\\n   465→\\t})\\n   466→\\tif err != nil {\\n   467→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   468→\\t}\\n   469→}\\n   470→\\n   471→// GitCommitWithCheckpointID creates a commit with Entire-Checkpoint trailer.\\n   472→// This simulates commits created by the auto-commit strategy.\\n   473→func (env *TestEnv) GitCommitWithCheckpointID(message, checkpointID string) {\\n   474→\\tenv.T.Helper()\\n   475→\\n   476→\\t// Format message with checkpoint trailer\\n   477→\\tfullMessage := message + \\\"\\\\n\\\\nEntire-Checkpoint: \\\" + checkpointID + \\\"\\\\n\\\"\\n   478→\\n   479→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   480→\\tif err != nil {\\n   481→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   482→\\t}\\n   483→\\n   484→\\tworktree, err := repo.Worktree()\\n   485→\\tif err != nil {\\n   486→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   487→\\t}\\n   488→\\n   489→\\t_, err = worktree.Commit(fullMessage, &git.CommitOptions{\\n   490→\\t\\tAuthor: &object.Signature{\\n   491→\\t\\t\\tName:  \\\"Test User\\\",\\n   492→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   493→\\t\\t\\tWhen:  time.Now(),\\n   494→\\t\\t},\\n   495→\\t})\\n   496→\\tif err != nil {\\n   497→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   498→\\t}\\n   499→}\\n   500→\\n   501→// GitCommitWithMultipleSessions creates a commit with multiple Entire-Session trailers.\\n   502→// This simulates merge commits that combine work from multiple sessions.\\n   503→func (env *TestEnv) GitCommitWithMultipleSessions(message string, sessionIDs []string) {\\n   504→\\tenv.T.Helper()\\n   505→\\n   506→\\t// Format message with multiple session trailers\\n   507→\\tfullMessage := message + \\\"\\\\n\\\\n\\\"\\n   508→\\tvar fullMessageSb404 strings.Builder\\n   509→\\tfor _, sessionID := range sessionIDs {\\n   510→\\t\\tfullMessageSb404.WriteString(\\\"Entire-Session: \\\" + sessionID + \\\"\\\\n\\\")\\n   511→\\t}\\n   512→\\tfullMessage += fullMessageSb404.String()\\n   513→\\n   514→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   515→\\tif err != nil {\\n   516→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   517→\\t}\\n   518→\\n   519→\\tworktree, err := repo.Worktree()\\n   520→\\tif err != nil {\\n   521→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   522→\\t}\\n   523→\\n   524→\\t_, err = worktree.Commit(fullMessage, &git.CommitOptions{\\n   525→\\t\\tAuthor: &object.Signature{\\n   526→\\t\\t\\tName:  \\\"Test User\\\",\\n   527→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   528→\\t\\t\\tWhen:  time.Now(),\\n   529→\\t\\t},\\n   530→\\t})\\n   531→\\tif err != nil {\\n   532→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   533→\\t}\\n   534→}\\n   535→\\n   536→// GetHeadHash returns the current HEAD commit hash.\\n   537→func (env *TestEnv) GetHeadHash() string {\\n   538→\\tenv.T.Helper()\\n   539→\\n   540→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   541→\\tif err != nil {\\n   542→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   543→\\t}\\n   544→\\n   545→\\thead, err := repo.Head()\\n   546→\\tif err != nil {\\n   547→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   548→\\t}\\n   549→\\n   550→\\treturn head.Hash().String()\\n   551→}\\n   552→\\n   553→// GetShadowBranchName returns the worktree-specific shadow branch name for the current HEAD.\\n   554→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   555→func (env *TestEnv) GetShadowBranchName() string {\\n   556→\\tenv.T.Helper()\\n   557→\\n   558→\\theadHash := env.GetHeadHash()\\n   559→\\tworktreeID, err := paths.GetWorktreeID(env.RepoDir)\\n   560→\\tif err != nil {\\n   561→\\t\\tenv.T.Fatalf(\\\"failed to get worktree ID: %v\\\", err)\\n   562→\\t}\\n   563→\\treturn checkpoint.ShadowBranchNameForCommit(headHash, worktreeID)\\n   564→}\\n   565→\\n   566→// GetShadowBranchNameForCommit returns the worktree-specific shadow branch name for a given commit.\\n   567→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   568→func (env *TestEnv) GetShadowBranchNameForCommit(commitHash string) string {\\n   569→\\tenv.T.Helper()\\n   570→\\n   571→\\tworktreeID, err := paths.GetWorktreeID(env.RepoDir)\\n   572→\\tif err != nil {\\n   573→\\t\\tenv.T.Fatalf(\\\"failed to get worktree ID: %v\\\", err)\\n   574→\\t}\\n   575→\\treturn checkpoint.ShadowBranchNameForCommit(commitHash, worktreeID)\\n   576→}\\n   577→\\n   578→// GetGitLog returns a list of commit hashes from HEAD.\\n   579→func (env *TestEnv) GetGitLog() []string {\\n   580→\\tenv.T.Helper()\\n   581→\\n   582→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   583→\\tif err != nil {\\n   584→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   585→\\t}\\n   586→\\n   587→\\thead, err := repo.Head()\\n   588→\\tif err != nil {\\n   589→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   590→\\t}\\n   591→\\n   592→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   593→\\tif err != nil {\\n   594→\\t\\tenv.T.Fatalf(\\\"failed to get log: %v\\\", err)\\n   595→\\t}\\n   596→\\n   597→\\tvar commits []string\\n   598→\\terr = commitIter.ForEach(func(c *object.Commit) error {\\n   599→\\t\\tcommits = append(commits, c.Hash.String())\\n   600→\\t\\treturn nil\\n   601→\\t})\\n   602→\\tif err != nil {\\n   603→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   604→\\t}\\n   605→\\n   606→\\treturn commits\\n   607→}\\n   608→\\n   609→// GitCheckoutNewBranch creates and checks out a new branch.\\n   610→// Uses git CLI instead of go-git to work around go-git v5 bug where Checkout\\n   611→// deletes untracked files (see https://github.com/go-git/go-git/issues/970).\\n   612→func (env *TestEnv) GitCheckoutNewBranch(branchName string) {\\n   613→\\tenv.T.Helper()\\n   614→\\n   615→\\tcmd := exec.Command(\\\"git\\\", \\\"checkout\\\", \\\"-b\\\", branchName)\\n   616→\\tcmd.Dir = env.RepoDir\\n   617→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   618→\\t\\tenv.T.Fatalf(\\\"failed to checkout new branch %s: %v\\\\nOutput: %s\\\", branchName, err, output)\\n   619→\\t}\\n   620→}\\n   621→\\n   622→// GetCurrentBranch returns the current branch name.\\n   623→func (env *TestEnv) GetCurrentBranch() string {\\n   624→\\tenv.T.Helper()\\n   625→\\n   626→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   627→\\tif err != nil {\\n   628→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   629→\\t}\\n   630→\\n   631→\\thead, err := repo.Head()\\n   632→\\tif err != nil {\\n   633→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   634→\\t}\\n   635→\\n   636→\\tif !head.Name().IsBranch() {\\n   637→\\t\\treturn \\\"\\\" // Detached HEAD\\n   638→\\t}\\n   639→\\n   640→\\treturn head.Name().Short()\\n   641→}\\n   642→\\n   643→// RewindPoint mirrors strategy.RewindPoint for test assertions.\\n   644→type RewindPoint struct {\\n   645→\\tID               string\\n   646→\\tMessage          string\\n   647→\\tMetadataDir      string\\n   648→\\tDate             time.Time\\n   649→\\tIsTaskCheckpoint bool\\n   650→\\tToolUseID        string\\n   651→\\tIsLogsOnly       bool\\n   652→\\tCondensationID   string\\n   653→}\\n   654→\\n   655→// GetRewindPoints returns available rewind points using the CLI.\\n   656→func (env *TestEnv) GetRewindPoints() []RewindPoint {\\n   657→\\tenv.T.Helper()\\n   658→\\n   659→\\t// Run rewind --list using the shared binary\\n   660→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--list\\\")\\n   661→\\tcmd.Dir = env.RepoDir\\n   662→\\tcmd.Env = env.cliEnv()\\n   663→\\n   664→\\toutput, err := cmd.CombinedOutput()\\n   665→\\tif err != nil {\\n   666→\\t\\tenv.T.Fatalf(\\\"rewind --list failed: %v\\\\nOutput: %s\\\", err, output)\\n   667→\\t}\\n   668→\\n   669→\\t// Parse JSON output\\n   670→\\tvar jsonPoints []struct {\\n   671→\\t\\tID               string `json:\\\"id\\\"`\\n   672→\\t\\tMessage          string `json:\\\"message\\\"`\\n   673→\\t\\tMetadataDir      string `json:\\\"metadata_dir\\\"`\\n   674→\\t\\tDate             string `json:\\\"date\\\"`\\n   675→\\t\\tIsTaskCheckpoint bool   `json:\\\"is_task_checkpoint\\\"`\\n   676→\\t\\tToolUseID        string `json:\\\"tool_use_id\\\"`\\n   677→\\t\\tIsLogsOnly       bool   `json:\\\"is_logs_only\\\"`\\n   678→\\t\\tCondensationID   string `json:\\\"condensation_id\\\"`\\n   679→\\t}\\n   680→\\n   681→\\tif err := json.Unmarshal(output, &jsonPoints); err != nil {\\n   682→\\t\\tenv.T.Fatalf(\\\"failed to parse rewind points: %v\\\\nOutput: %s\\\", err, output)\\n   683→\\t}\\n   684→\\n   685→\\tpoints := make([]RewindPoint, len(jsonPoints))\\n   686→\\tfor i, jp := range jsonPoints {\\n   687→\\t\\tdate, _ := time.Parse(time.RFC3339, jp.Date)\\n   688→\\t\\tpoints[i] = RewindPoint{\\n   689→\\t\\t\\tID:               jp.ID,\\n   690→\\t\\t\\tMessage:          jp.Message,\\n   691→\\t\\t\\tMetadataDir:      jp.MetadataDir,\\n   692→\\t\\t\\tDate:             date,\\n   693→\\t\\t\\tIsTaskCheckpoint: jp.IsTaskCheckpoint,\\n   694→\\t\\t\\tToolUseID:        jp.ToolUseID,\\n   695→\\t\\t\\tIsLogsOnly:       jp.IsLogsOnly,\\n   696→\\t\\t\\tCondensationID:   jp.CondensationID,\\n   697→\\t\\t}\\n   698→\\t}\\n   699→\\n   700→\\treturn points\\n   701→}\\n   702→\\n   703→// Rewind performs a rewind to the specified commit ID using the CLI.\\n   704→func (env *TestEnv) Rewind(commitID string) error {\\n   705→\\tenv.T.Helper()\\n   706→\\n   707→\\t// Run rewind --to <commitID> using the shared binary\\n   708→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID)\\n   709→\\tcmd.Dir = env.RepoDir\\n   710→\\tcmd.Env = env.cliEnv()\\n   711→\\n   712→\\toutput, err := cmd.CombinedOutput()\\n   713→\\tif err != nil {\\n   714→\\t\\treturn errors.New(\\\"rewind failed: \\\" + string(output))\\n   715→\\t}\\n   716→\\n   717→\\tenv.T.Logf(\\\"Rewind output: %s\\\", output)\\n   718→\\treturn nil\\n   719→}\\n   720→\\n   721→// RewindLogsOnly performs a logs-only rewind using the CLI.\\n   722→// This restores session logs without modifying the working directory.\\n   723→func (env *TestEnv) RewindLogsOnly(commitID string) error {\\n   724→\\tenv.T.Helper()\\n   725→\\n   726→\\t// Run rewind --to <commitID> --logs-only using the shared binary\\n   727→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID, \\\"--logs-only\\\")\\n   728→\\tcmd.Dir = env.RepoDir\\n   729→\\tcmd.Env = env.cliEnv()\\n   730→\\n   731→\\toutput, err := cmd.CombinedOutput()\\n   732→\\tif err != nil {\\n   733→\\t\\treturn errors.New(\\\"rewind logs-only failed: \\\" + string(output))\\n   734→\\t}\\n   735→\\n   736→\\tenv.T.Logf(\\\"Rewind logs-only output: %s\\\", output)\\n   737→\\treturn nil\\n   738→}\\n   739→\\n   740→// RewindReset performs a reset rewind using the CLI.\\n   741→// This resets the branch to the specified commit (destructive).\\n   742→func (env *TestEnv) RewindReset(commitID string) error {\\n   743→\\tenv.T.Helper()\\n   744→\\n   745→\\t// Run rewind --to <commitID> --reset using the shared binary\\n   746→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID, \\\"--reset\\\")\\n   747→\\tcmd.Dir = env.RepoDir\\n   748→\\tcmd.Env = env.cliEnv()\\n   749→\\n   750→\\toutput, err := cmd.CombinedOutput()\\n   751→\\tif err != nil {\\n   752→\\t\\treturn errors.New(\\\"rewind reset failed: \\\" + string(output))\\n   753→\\t}\\n   754→\\n   755→\\tenv.T.Logf(\\\"Rewind reset output: %s\\\", output)\\n   756→\\treturn nil\\n   757→}\\n   758→\\n   759→// BranchExists checks if a branch exists in the repository.\\n   760→func (env *TestEnv) BranchExists(branchName string) bool {\\n   761→\\tenv.T.Helper()\\n   762→\\n   763→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   764→\\tif err != nil {\\n   765→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   766→\\t}\\n   767→\\n   768→\\trefs, err := repo.References()\\n   769→\\tif err != nil {\\n   770→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   771→\\t}\\n   772→\\n   773→\\tfound := false\\n   774→\\t_ = refs.ForEach(func(ref *plumbing.Reference) error {\\n   775→\\t\\tif ref.Name().Short() == branchName {\\n   776→\\t\\t\\tfound = true\\n   777→\\t\\t}\\n   778→\\t\\treturn nil\\n   779→\\t})\\n   780→\\n   781→\\treturn found\\n   782→}\\n   783→\\n   784→// GetCommitMessage returns the commit message for the given commit hash.\\n   785→func (env *TestEnv) GetCommitMessage(hash string) string {\\n   786→\\tenv.T.Helper()\\n   787→\\n   788→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   789→\\tif err != nil {\\n   790→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   791→\\t}\\n   792→\\n   793→\\tcommitHash := plumbing.NewHash(hash)\\n   794→\\tcommit, err := repo.CommitObject(commitHash)\\n   795→\\tif err != nil {\\n   796→\\t\\tenv.T.Fatalf(\\\"failed to get commit %s: %v\\\", hash, err)\\n   797→\\t}\\n   798→\\n   799→\\treturn commit.Message\\n   800→}\\n   801→\\n   802→// FileExistsInBranch checks if a file exists in a specific branch's tree.\\n   803→func (env *TestEnv) FileExistsInBranch(branchName, filePath string) bool {\\n   804→\\tenv.T.Helper()\\n   805→\\n   806→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   807→\\tif err != nil {\\n   808→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   809→\\t}\\n   810→\\n   811→\\t// Get the branch reference\\n   812→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   813→\\tif err != nil {\\n   814→\\t\\t// Try as a remote-style ref\\n   815→\\t\\tref, err = repo.Reference(plumbing.ReferenceName(\\\"refs/heads/\\\"+branchName), true)\\n   816→\\t\\tif err != nil {\\n   817→\\t\\t\\treturn false\\n   818→\\t\\t}\\n   819→\\t}\\n   820→\\n   821→\\t// Get the commit\\n   822→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   823→\\tif err != nil {\\n   824→\\t\\treturn false\\n   825→\\t}\\n   826→\\n   827→\\t// Get the tree\\n   828→\\ttree, err := commit.Tree()\\n   829→\\tif err != nil {\\n   830→\\t\\treturn false\\n   831→\\t}\\n   832→\\n   833→\\t// Check if file exists\\n   834→\\t_, err = tree.File(filePath)\\n   835→\\treturn err == nil\\n   836→}\\n   837→\\n   838→// ReadFileFromBranch reads a file's content from a specific branch's tree.\\n   839→// Returns the content and true if found, empty string and false if not found.\\n   840→func (env *TestEnv) ReadFileFromBranch(branchName, filePath string) (string, bool) {\\n   841→\\tenv.T.Helper()\\n   842→\\n   843→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   844→\\tif err != nil {\\n   845→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   846→\\t}\\n   847→\\n   848→\\t// Get the branch reference\\n   849→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   850→\\tif err != nil {\\n   851→\\t\\t// Try as a remote-style ref\\n   852→\\t\\tref, err = repo.Reference(plumbing.ReferenceName(\\\"refs/heads/\\\"+branchName), true)\\n   853→\\t\\tif err != nil {\\n   854→\\t\\t\\treturn \\\"\\\", false\\n   855→\\t\\t}\\n   856→\\t}\\n   857→\\n   858→\\t// Get the commit\\n   859→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   860→\\tif err != nil {\\n   861→\\t\\treturn \\\"\\\", false\\n   862→\\t}\\n   863→\\n   864→\\t// Get the tree\\n   865→\\ttree, err := commit.Tree()\\n   866→\\tif err != nil {\\n   867→\\t\\treturn \\\"\\\", false\\n   868→\\t}\\n   869→\\n   870→\\t// Get the file\\n   871→\\tfile, err := tree.File(filePath)\\n   872→\\tif err != nil {\\n   873→\\t\\treturn \\\"\\\", false\\n   874→\\t}\\n   875→\\n   876→\\t// Get the content\\n   877→\\tcontent, err := file.Contents()\\n   878→\\tif err != nil {\\n   879→\\t\\treturn \\\"\\\", false\\n   880→\\t}\\n   881→\\n   882→\\treturn content, true\\n   883→}\\n   884→\\n   885→// GetLatestCommitMessageOnBranch returns the commit message of the latest commit on the given branch.\\n   886→func (env *TestEnv) GetLatestCommitMessageOnBranch(branchName string) string {\\n   887→\\tenv.T.Helper()\\n   888→\\n   889→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   890→\\tif err != nil {\\n   891→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   892→\\t}\\n   893→\\n   894→\\t// Get the branch reference\\n   895→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   896→\\tif err != nil {\\n   897→\\t\\tenv.T.Fatalf(\\\"failed to get branch %s reference: %v\\\", branchName, err)\\n   898→\\t}\\n   899→\\n   900→\\t// Get the commit\\n   901→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   902→\\tif err != nil {\\n   903→\\t\\tenv.T.Fatalf(\\\"failed to get commit object: %v\\\", err)\\n   904→\\t}\\n   905→\\n   906→\\treturn commit.Message\\n   907→}\\n   908→\\n   909→// GitCommitWithShadowHooks stages and commits files, simulating the prepare-commit-msg\\n   910→// and post-commit hooks as a human (with TTY). This is the default for tests.\\n   911→func (env *TestEnv) GitCommitWithShadowHooks(message string, files ...string) {\\n   912→\\tenv.T.Helper()\\n   913→\\tenv.gitCommitWithShadowHooks(message, true, files...)\\n   914→}\\n   915→\\n   916→// GitCommitWithShadowHooksAsAgent is like GitCommitWithShadowHooks but simulates\\n   917→// an agent commit (no TTY). This triggers the fast path in PrepareCommitMsg that\\n   918→// skips content detection and interactive prompts for ACTIVE sessions.\\n   919→func (env *TestEnv) GitCommitWithShadowHooksAsAgent(message string, files ...string) {\\n   920→\\tenv.T.Helper()\\n   921→\\tenv.gitCommitWithShadowHooks(message, false, files...)\\n   922→}\\n   923→\\n   924→// gitCommitWithShadowHooks is the shared implementation for committing with shadow hooks.\\n   925→// When simulateTTY is true, sets ENTIRE_TEST_TTY=1 to simulate a human at the terminal.\\n   926→// When false, filters it out to simulate an agent subprocess (no controlling terminal).\\n   927→func (env *TestEnv) gitCommitWithShadowHooks(message string, simulateTTY bool, files ...string) {\\n   928→\\tenv.T.Helper()\\n   929→\\n   930→\\t// Stage files using go-git\\n   931→\\tfor _, file := range files {\\n   932→\\t\\tenv.GitAdd(file)\\n   933→\\t}\\n   934→\\n   935→\\t// Create a temp file for the commit message (prepare-commit-msg hook modifies this)\\n   936→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n   937→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n   938→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n   939→\\t}\\n   940→\\n   941→\\t// Run prepare-commit-msg hook using the shared binary.\\n   942→\\t// Pass source=\\\"message\\\" to match real `git commit -m` behavior.\\n   943→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile, \\\"message\\\")\\n   944→\\tprepCmd.Dir = env.RepoDir\\n   945→\\tif simulateTTY {\\n   946→\\t\\t// Simulate human at terminal: ENTIRE_TEST_TTY=1 makes hasTTY() return true\\n   947→\\t\\t// and askConfirmTTY() return defaultYes without reading from /dev/tty.\\n   948→\\t\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n   949→\\t} else {\\n   950→\\t\\t// Simulate agent: ENTIRE_TEST_TTY=0 makes hasTTY() return false,\\n   951→\\t\\t// triggering the fast path that adds trailers for ACTIVE sessions.\\n   952→\\t\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   953→\\t}\\n   954→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n   955→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n   956→\\t\\t// Don't fail - hook may silently succeed\\n   957→\\t}\\n   958→\\n   959→\\t// Read the modified message\\n   960→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n   961→\\tif err != nil {\\n   962→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n   963→\\t}\\n   964→\\n   965→\\t// Create the commit using go-git with the modified message\\n   966→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   967→\\tif err != nil {\\n   968→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   969→\\t}\\n   970→\\n   971→\\tworktree, err := repo.Worktree()\\n   972→\\tif err != nil {\\n   973→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   974→\\t}\\n   975→\\n   976→\\t_, err = worktree.Commit(string(modifiedMsg), &git.CommitOptions{\\n   977→\\t\\tAuthor: &object.Signature{\\n   978→\\t\\t\\tName:  \\\"Test User\\\",\\n   979→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   980→\\t\\t\\tWhen:  time.Now(),\\n   981→\\t\\t},\\n   982→\\t})\\n   983→\\tif err != nil {\\n   984→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   985→\\t}\\n   986→\\n   987→\\t// Run post-commit hook using the shared binary\\n   988→\\t// This triggers condensation if the commit has an Entire-Checkpoint trailer\\n   989→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n   990→\\tpostCmd.Dir = env.RepoDir\\n   991→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n   992→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n   993→\\t\\t// Don't fail - hook may silently succeed\\n   994→\\t}\\n   995→}\\n   996→\\n   997→// GitCommitAmendWithShadowHooks amends the last commit with shadow hooks.\\n   998→// This simulates `git commit --amend` with the prepare-commit-msg and post-commit hooks.\\n   999→// The prepare-commit-msg hook is called with \\\"commit\\\" source to indicate an amend.\\n  1000→func (env *TestEnv) GitCommitAmendWithShadowHooks(message string, files ...string) {\\n  1001→\\tenv.T.Helper()\\n  1002→\\n  1003→\\t// Stage any additional files\\n  1004→\\tfor _, file := range files {\\n  1005→\\t\\tenv.GitAdd(file)\\n  1006→\\t}\\n  1007→\\n  1008→\\t// Write commit message to temp file\\n  1009→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n  1010→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n  1011→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n  1012→\\t}\\n  1013→\\n  1014→\\t// Run prepare-commit-msg hook with \\\"commit\\\" source (indicates amend).\\n  1015→\\t// Set ENTIRE_TEST_TTY=1 to simulate human (amend is always a human operation).\\n  1016→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile, \\\"commit\\\")\\n  1017→\\tprepCmd.Dir = env.RepoDir\\n  1018→\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n  1019→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n  1020→\\t\\tenv.T.Logf(\\\"prepare-commit-msg (amend) output: %s\\\", output)\\n  1021→\\t}\\n  1022→\\n  1023→\\t// Read the modified