0→\\tAllowedTools []string\\n    91→}\\n    92→\\n    93→// NewClaudeCodeRunner creates a new Claude Code runner with the given config.\\n    94→func NewClaudeCodeRunner(config AgentRunnerConfig) *ClaudeCodeRunner {\\n    95→\\tmodel := config.Model\\n    96→\\tif model == \\\"\\\" {\\n    97→\\t\\tmodel = os.Getenv(\\\"E2E_CLAUDE_MODEL\\\")\\n    98→\\t\\tif model == \\\"\\\" {\\n    99→\\t\\t\\tmodel = \\\"haiku\\\"\\n   100→\\t\\t}\\n   101→\\t}\\n   102→\\n   103→\\ttimeout := config.Timeout\\n   104→\\tif timeout == 0 {\\n   105→\\t\\tif envTimeout := os.Getenv(\\\"E2E_TIMEOUT\\\"); envTimeout != \\\"\\\" {\\n   106→\\t\\t\\tif parsed, err := time.ParseDuration(envTimeout); err == nil {\\n   107→\\t\\t\\t\\ttimeout = parsed\\n   108→\\t\\t\\t}\\n   109→\\t\\t}\\n   110→\\t\\tif timeout == 0 {\\n   111→\\t\\t\\ttimeout = 2 * time.Minute\\n   112→\\t\\t}\\n   113→\\t}\\n   114→\\n   115→\\treturn &ClaudeCodeRunner{\\n   116→\\t\\tModel:        model,\\n   117→\\t\\tTimeout:      timeout,\\n   118→\\t\\tAllowedTools: []string{\\\"Edit\\\", \\\"Read\\\", \\\"Write\\\", \\\"Bash\\\", \\\"Glob\\\", \\\"Grep\\\"},\\n   119→\\t}\\n   120→}\\n   121→\\n   122→func (r *ClaudeCodeRunner) Name() string {\\n   123→\\treturn AgentNameClaudeCode\\n   124→}\\n   125→\\n   126→// IsAvailable checks if Claude CLI is installed and responds to --version.\\n   127→// Note: This does NOT verify authentication status. Claude Code uses OAuth\\n   128→// authentication (via `claude login`), not ANTHROPIC_API_KEY. If the CLI is\\n   129→// installed but not logged in, tests will fail at RunPrompt time.\\n   130→func (r *ClaudeCodeRunner) IsAvailable() (bool, error) {\\n   131→\\t// Check if claude CLI is in PATH\\n   132→\\tif _, err := exec.LookPath(\\\"claude\\\"); err != nil {\\n   133→\\t\\treturn false, fmt.Errorf(\\\"claude CLI not found in PATH: %w\\\", err)\\n   134→\\t}\\n   135→\\n   136→\\t// Check if claude is working (--version doesn't require auth)\\n   137→\\tctx, cancel 