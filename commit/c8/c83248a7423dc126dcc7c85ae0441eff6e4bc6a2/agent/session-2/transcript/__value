thods.\\n    20→// Uses session.StateStore for persistence.\\n    21→\\n    22→// loadSessionState loads session state using the StateStore.\\n    23→func (s *ManualCommitStrategy) loadSessionState(sessionID string) (*SessionState, error) {\\n    24→\\tstore, err := s.getStateStore()\\n    25→\\tif err != nil {\\n    26→\\t\\treturn nil, err\\n    27→\\t}\\n    28→\\tstate, err := store.Load(context.Background(), sessionID)\\n    29→\\tif err != nil {\\n    30→\\t\\treturn nil, fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n    31→\\t}\\n    32→\\treturn state, nil\\n    33→}\\n    34→\\n    35→// saveSessionState saves session state using the StateStore.\\n    36→func (s *ManualCommitStrategy) saveSessionState(state *SessionState) error {\\n    37→\\tstore, err := s.getStateStore()\\n    38→\\tif err != nil {\\n    39→\\t\\treturn err\\n    40→\\t}\\n    41→\\tif err := store.Save(context.Background(), state); err != nil {\\n    42→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n    43→\\t}\\n    44→\\treturn nil\\n    45→}\\n    46→\\n    47→// clearSessionState clears session state using the StateStore.\\n    48→func (s *ManualCommitStrategy) clearSessionState(sessionID string) error {\\n    49→\\tstore, err := s.getStateStore()\\n    50→\\tif err != nil {\\n    51→\\t\\treturn err\\n    52→\\t}\\n    53→\\tif err := store.Clear(context.Background(), sessionID); err != nil {\\n    54→\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n    55→\\t}\\n    56→\\treturn nil\\n    57→}\\n    58→\\n    59→// listAllSessionStates returns all active session states.\\n    60→// It filters out orphaned sessions whose shadow branch no longer exists.\\n    61→func (s *ManualCommitStrategy) listAllSessionStates() ([]*SessionState, error) {\\n    62→\\tstore, err := s.getStateStore()\\n    63→\\tif err != nil {\\n    64→\\t\\treturn nil, fmt.Errorf(\\\"failed to get state store: %w\\\", err)\\n    65→\\t}\\n    66→\\n    67→\\tsessionStates, err := store.List(context.Background())\\n    68→\\tif err != nil {\\n    69→\\t\\treturn nil, fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n    70→\\t}\\n    71→\\n    72→\\tif len(sessionStates) == 0 {\\n    73→\\t\\treturn nil, nil\\n    74→\\t}\\n    75→\\n    76→\\trepo, err := OpenRepository()\\n    77→\\tif err != nil {\\n    78→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n    79→\\t}\\n    80→\\n    81→\\tvar states []*SessionState\\n    82→\\tfor _, sessionState := range sessionStates {\\n    83→\\t\\tstate := sessionState\\n    84→\\n    85→\\t\\t// Skip and cleanup orphaned sessions whose shadow branch no longer exists.\\n    86→\\t\\t// Keep active sessions (shadow branch may not be created yet) and sessions\\n    87→\\t\\t// with LastCheckpointID (needed for checkpoint ID reuse on subsequent commits).\\n    88→\\t\\t// Clean up everything else: stale pre-state-machine sessions (empty phase),\\n    89→\\t\\t// IDLE/ENDED sessions that were never condensed, etc.\\n    90→\\t\\tshadowBranch := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n    91→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranch)\\n    92→\\t\\tif _, err := repo.Reference(refName, true); err != nil {\\n    93→\\t\\t\\tif !state.Phase.IsActive() && state.LastCheckpointID.IsEmpty() {\\n    94→\\t\\t\\t\\t//nolint:errcheck,gosec // G104: Cleanup is best-effort, shouldn't fail the list operation\\n    95→\\t\\t\\t\\tstore.Clear(context.Background(), state.SessionID)\\n    96→\\t\\t\\t\\tcontinue\\n    97→\\t\\t\\t}\\n    98→\\t\\t}\\n    99→\\n   100→\\t\\tstates = append(states, state)\\n   101→\\t}\\n   102→\\treturn states, nil\\n   103→}\\n   104→\\n   105→// findSessionsForWorktree finds all sessions for the given worktree path.\\n   106→func (s *ManualCommitStrategy) findSessionsForWorktree(worktreePath string) ([]*SessionState, error) {\\n   107→\\tallStates, err := s.listAllSessionStates()\\n   108→\\tif err != nil {\\n   109→\\t\\treturn nil, err\\n   110→\\t}\\n   111→\\n   112→\\tvar matching []*SessionState\\n   113→\\tfor _, state := range allStates {\\n   114→\\t\\tif state.WorktreePath == worktreePath {\\n   115→\\t\\t\\tmatching = append(matching, state)\\n   116→\\t\\t}\\n   117→\\t}\\n   118→\\treturn matching, nil\\n   119→}\\n   120→\\n   121→// findSessionsForCommit finds all sessions where base_commit matches the given SHA.\\n   122→func (s *ManualCommitStrategy) findSessionsForCommit(baseCommitSHA string) ([]*SessionState, error) {\\n   123→\\tallStates, err := s.listAllSessionStates()\\n   124→\\tif err != nil {\\n   125→\\t\\treturn nil, err\\n   126→\\t}\\n   127→\\n   128→\\tvar matching []*SessionState\\n   129→\\tfor _, state := range allStates {\\n   130→\\t\\tif state.BaseCommit == baseCommitSHA {\\n   131→\\t\\t\\tmatching = append(matching, state)\\n   132→\\t\\t}\\n   133→\\t}\\n   134→\\treturn matching, nil\\n   135→}\\n   136→\\n   137→// FindSessionsForCommit is the exported version of findSessionsForCommit.\\n   138→// Used by the rewind reset command to find sessions to clean up.\\n   139→func (s *ManualCommitStrategy) FindSessionsForCommit(baseCommitSHA string) ([]*SessionState, error) {\\n   140→\\treturn s.findSessionsForCommit(baseCommitSHA)\\n   141→}\\n   142→\\n   143→// ClearSessionState is the exported version of clearSessionState.\\n   144→// Used by the rewind reset command to clean up session state files.\\n   145→func (s *ManualCommitStrategy) ClearSessionState(sessionID string) error {\\n   146→\\treturn s.clearSessionState(sessionID)\\n   147→}\\n   148→\\n   149→// CountOtherActiveSessionsWithCheckpoints counts how many other active sessions\\n   150→// from the SAME worktree (different from currentSessionID) have created checkpoints\\n   151→// on the SAME base commit (current HEAD). This is used to show an informational message\\n   152→// about concurrent sessions that will be included in the next commit.\\n   153→// Returns 0, nil if no such sessions exist.\\n   154→func (s *ManualCommitStrategy) CountOtherActiveSessionsWithCheckpoints(currentSessionID string) (int, error) {\\n   155→\\tcurrentWorktree, err := GetWorktreePath()\\n   156→\\tif err != nil {\\n   157→\\t\\treturn 0, err\\n   158→\\t}\\n   159→\\n   160→\\t// Get current HEAD to compare with session base commits\\n   161→\\trepo, err := OpenRepository()\\n   162→\\tif err != nil {\\n   163→\\t\\treturn 0, err\\n   164→\\t}\\n   165→\\thead, err := repo.Head()\\n   166→\\tif err != nil {\\n   167→\\t\\treturn 0, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   168→\\t}\\n   169→\\tcurrentHead := head.Hash().String()\\n   170→\\n   171→\\tallStates, err := s.listAllSessionStates()\\n   172→\\tif err != nil {\\n   173→\\t\\treturn 0, err\\n   174→\\t}\\n   175→\\n   176→\\tcount := 0\\n   177→\\tfor _, state := range allStates {\\n   178→\\t\\t// Only consider sessions from the same worktree with checkpoints\\n   179→\\t\\t// AND based on the same commit (current HEAD)\\n   180→\\t\\t// Sessions from different base commits are independent and shouldn't be counted\\n   181→\\t\\tif state.SessionID != currentSessionID &&\\n   182→\\t\\t\\tstate.WorktreePath == currentWorktree &&\\n   183→\\t\\t\\tstate.StepCount > 0 &&\\n   184→\\t\\t\\tstate.BaseCommit == currentHead {\\n   185→\\t\\t\\tcount++\\n   186→\\t\\t}\\n   187→\\t}\\n   188→\\treturn count, nil\\n   189→}\\n   190→\\n   191→// initializeSession creates a new session state or updates a partial one.\\n   192→// A partial state may exist if the concurrent session warning was shown.\\n   193→// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n   194→// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n   195→// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\n   196→func (s *ManualCommitStrategy) initializeSession(repo *git.