hest output_tokens (final streaming state)\\n   196→\\t\\texisting, exists := usageByMessageID[msg.ID]\\n   197→\\t\\tif !exists || msg.Usage.OutputTokens > existing.OutputTokens {\\n   198→\\t\\t\\tusageByMessageID[msg.ID] = msg.Usage\\n   199→\\t\\t}\\n   200→\\t}\\n   201→\\n   202→\\t// Sum up all unique messages\\n   203→\\tusage := &agent.TokenUsage{\\n   204→\\t\\tAPICallCount: len(usageByMessageID),\\n   205→\\t}\\n   206→\\tfor _, u := range usageByMessageID {\\n   207→\\t\\tusage.InputTokens += u.InputTokens\\n   208→\\t\\tusage.CacheCreationTokens += u.CacheCreationInputTokens\\n   209→\\t\\tusage.CacheReadTokens += u.CacheReadInputTokens\\n   210→\\t\\tusage.OutputTokens += u.OutputTokens\\n   211→\\t}\\n   212→\\n   213→\\treturn usage\\n   214→}\\n   215→\\n   216→// CalculateTokenUsageFromFile calculates token usage from a transcript file.\\n   217→// If startLine > 0, only considers lines from startLine onwards.\\n   218→func CalculateTokenUsageFromFile(path string, startLine int) (*agent.TokenUsage, error) {\\n   219→\\tif path == \\\"\\\" {\\n   220→\\t\\treturn &agent.TokenUsage{}, nil\\n   221→\\t}\\n   222→\\n   223→\\tlines, _, err := ParseDroidTranscript(path, startLine)\\n   224→\\tif err != nil {\\n   225→\\t\\treturn nil, err //nolint:wrapcheck // caller adds context\\n   226→\\t}\\n   227→\\n   228→\\treturn CalculateTokenUsage(lines), nil\\n   229→}\\n   230→\\n   231→// ExtractSpawnedAgentIDs extracts agent IDs from Task tool results in a transcript.\\n   232→// When a Task tool completes, the tool_result contains \\\"agentId: <id>\\\" in its content.\\n   233→// Returns a map of agentID -> toolUseID for all spawned agents.\\n   234→func ExtractSpawnedAgentIDs(transcriptLines []TranscriptLine) map[string]string {\\n   235→\\tagentIDs := make(map[string]string)\\n   236→\\n   237→\\tfor _, line := range transcriptLines {\\n   238→\\t\\tif line.Type != \\\"user\\\" {\\n   239→\\t\\t\\tcontinue\\n   240→\\t\\t}\\n   241→\\n   242→\\t\\t// P