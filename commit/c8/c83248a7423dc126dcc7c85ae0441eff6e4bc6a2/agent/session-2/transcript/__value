Factory AI Droid supports.\\n    28→func (f *FactoryAIDroidAgent) HookNames() []string {\\n    29→\\treturn f.GetHookNames()\\n    30→}\\n    31→\\n    32→// ParseHookEvent translates a Factory AI Droid hook into a normalized lifecycle Event.\\n    33→// Returns nil if the hook has no lifecycle significance.\\n    34→func (f *FactoryAIDroidAgent) ParseHookEvent(hookName string, stdin io.Reader) (*agent.Event, error) {\\n    35→\\tswitch hookName {\\n    36→\\tcase HookNameSessionStart:\\n    37→\\t\\treturn f.parseSessionStart(stdin)\\n    38→\\tcase HookNameUserPromptSubmit:\\n    39→\\t\\treturn f.parseTurnStart(stdin)\\n    40→\\tcase HookNameStop:\\n    41→\\t\\treturn f.parseTurnEnd(stdin)\\n    42→\\tcase HookNameSessionEnd:\\n    43→\\t\\treturn f.parseSessionEnd(stdin)\\n    44→\\tcase HookNamePreToolUse:\\n    45→\\t\\treturn f.parseSubagentStart(stdin)\\n    46→\\tcase HookNamePostToolUse:\\n    47→\\t\\treturn f.parseSubagentEnd(stdin)\\n    48→\\tcase HookNamePreCompact:\\n    49→\\t\\treturn f.parseCompaction(stdin)\\n    50→\\tcase HookNameSubagentStop, HookNameNotification:\\n    51→\\t\\t// Acknowledged hooks with no lifecycle action\\n    52→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    53→\\tdefault:\\n    54→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    55→\\t}\\n    56→}\\n    57→\\n    58→// --- TranscriptAnalyzer ---\\n    59→\\n    60→// GetTranscriptPosition returns the current line count of the JSONL transcript.\\n    61→func (f *FactoryAIDroidAgent) GetTranscriptPosition(path string) (int, error) {\\n    62→\\t_, pos, err := transcript.ParseFromFileAtLine(path, 0)\\n    63→\\tif err != nil {\\n    64→\\t\\treturn 0, err //nolint:wrapcheck // caller adds context\\n    65→\\t}\\n    66→\\treturn pos, nil\\n    67→}\\n    68→\\n    69→// ExtractModifiedFilesFromOffset extracts files modified since a given line offset.\\n    70→func (f *FactoryAIDroidAgent) ExtractModifiedFilesFromOffset(path string, startOffset int) ([]string, int, error) {\\n    71→\\tlines, currentPos, err := transcript.ParseFromFileAtLine(path, startOffset)\\n    72→\\tif err != nil {\\n    73→\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    74→\\t}\\n    75→\\tfiles := ExtractModifiedFiles(lines)\\n    76→\\treturn files, currentPos, nil\\n    77→}\\n    78→\\n    79→// ExtractPrompts extracts user prompts from the transcript starting at the given line offset.\\n    80→func (f *FactoryAIDroidAgent) ExtractPrompts(sessionRef string, fromOffset int) ([]string, error) {\\n    81→\\tlines, _, err := transcript.ParseFromFileAtLine(sessionRef, fromOffset)\\n    82→\\tif err != nil {\\n    83→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    84→\\t}\\n    85→\\n    86→\\tvar prompts []string\\n    87→\\tfor i := range lines {\\n    88→\\t\\tif lines[i].Type != transcript.TypeUser {\\n    89→\\t\\t\\tcontinue\\n    90→\\t\\t}\\n    91→\\t\\tcontent := transcript.ExtractUserContent(lines[i].Message)\\n    92→\\t\\tif content != \\\"\\\" {\\n    93→\\t\\t\\tprompts = append(prompts, textutil.StripIDEContextTags(content))\\n    94→\\t\\t}\\n    95→\\t}\\n    96→\\treturn prompts, nil\\n    97→}\\n    98→\\n    99→// ExtractSummary extracts the last assistant message as a session summary.\\n   100→func (f *FactoryAIDroidAgent) ExtractSummary(sessionRef string) (string, error) {\\n   101→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n   102→\\tif err != nil {\\n   103→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   104→\\t}\\n   105→\\n   106→\\tlines, parseErr := transcript.ParseFromBytes(data)\\n   107→\\tif parseErr != nil {\\n   108→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse transcript: %w\\\", parseErr)\\n   109→\\t}\\n   110→\\n   111→\\tfor i := len(lines) - 1; i >= 0; i-- {\\n   112→\\t\\tif lines[i].Type != transcript.TypeAssistant {\\n   113→\\t\\t\\tcontinue\\n   114→\\t\\t}\\n   115→\\t\\tvar msg transcript.AssistantMessage\\n   116→\\t\\tif err := json.Unmarshal(lines[i].Message, &msg); err != nil {\\n   117→\\t\\t\\tcontinue\\n   118→\\t\\t}\\n   119→\\t\\tfor _, block := range msg.Content {\\n   120→\\t\\t\\tif block.Type == transcript.ContentTypeText && block.Text != \\\"\\\" {\\n   121→\\t\\t\\t\\treturn block.Text, nil\\n   122→\\t\\t\\t}\\n   123→\\t\\t}\\n   124→\\t}\\n   125→\\treturn \\\"\\\", nil\\n   126→}\\n   127→\\n   128→// --- TranscriptPreparer ---\\n   129→\\n   130→// PrepareTranscript waits for Factory Droid's async transcript flush to complete.\\n   131→func (f *FactoryAIDroidAgent) PrepareTranscript(sessionRef string) error {\\n   132→\\twaitForTranscriptFlush(sessionRef, time.Now())\\n   133→\\treturn nil\\n   134→}\\n   135→\\n   136→// --- TokenCalculator ---\\n   137→\\n   138→// CalculateTokenUsage computes token usage from the transcript starting at the given line offset.\\n   139→func (f *FactoryAIDroidAgent) CalculateTokenUsage(sessionRef string, fromOffset int) (*agent.TokenUsage, error) {\\n   140→\\treturn CalculateTotalTokenUsageFromTranscript(sessionRef, fromOffset, \\\"\\\")\\n   141→}\\n   142→\\n   143→// --- SubagentAwareExtractor ---\\n   144→\\n   145→// ExtractAllModifiedFiles extracts files modified by both the main agent and any spawned subagents.\\n   146→func (f *FactoryAIDroidAgent) ExtractAllModifiedFiles(sessionRef string, fromOffset int, subagentsDir string) ([]string, error) {\\n   147→\\treturn ExtractAllModifiedFilesFromTranscript(sessionRef, fromOffset, subagentsDir)\\n   148→}\\n   149→\\n   150→// CalculateTotalTokenUsage computes token usage including all spawned subagents.\\n   151→func (f *FactoryAIDroidAgent) CalculateTotalTokenUsage(sessionRef string, fromOffset int, subagentsDir string) (*agent.TokenUsage, error) {\\n   152→\\treturn CalculateTotalTokenUsageFromTranscript(sessionRef, fromOffset, subagentsDir)\\n   153→}\\n   154→\\n   155→// --- Internal hook parsing functions ---\\n   156→\\n   157→func (f *FactoryAIDroidAgent) parseSessionStart(stdin io.Reader) (*agent.Event, error) {\\n   158→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   159→\\tif err != nil {\\n   160→\\t\\treturn nil, err\\n   161→\\t}\\n   162→\\treturn &agent.Event{\\n   163→\\t\\tType:       agent.SessionStart,\\n   164→\\t\\tSessionID:  raw.SessionID,\\n   165→\\t\\tSessionRef: raw.TranscriptPath,\\n   166→\\t\\tTimestamp:  time.Now(),\\n   167→\\t}, nil\\n   168→}\\n   169→\\n   170→func (f *FactoryAIDroidAgent) parseTurnStart(stdin io.Reader) (*agent.Event, error) {\\n   171→\\traw, err := agent.ReadAndParseHookInput[userPromptSubmitRaw](stdin)\\n   172→\\tif err != nil {\\n   173→\\t\\treturn nil, err\\n   174→\\t}\\n   175→\\treturn &agent.Event{\\n   176→\\t\\tType:       agent.TurnStart,\\n   177→\\t\\tSessionID:  raw.SessionID,\\n   178→\\t\\tSessionRef: raw.TranscriptPath,\\n   179→\\t\\tPrompt:     raw.Prompt,\\n   180→\\t\\tTimestamp:  time.Now(),\\n   181→\\t}, nil\\n   182→}\\n   183→\\n   184→func (f *FactoryAIDroidAgent) parseTurnEnd(stdin io.Reader) (*agent.Event, error) {\\n   185→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   186→\\tif err != nil {\\n   187→\\t\\treturn nil, err\\n   188→\\t}\\n   189→\\treturn &agent.Event{\\n   190→\\t\\tType:       agent.TurnEnd,\\n   191→\\t\\tSessionID:  raw.SessionID,\\n   192→\\t\\tSessionRef: raw.TranscriptPath,\\n   193→\\t\\tTimestamp:  time.Now(),\\n   194→\\t}, nil\\n   195→}\\n   196→\\n   197→func (f *FactoryAIDroidAgent) parseSessionEnd(stdin io.Reader) (*agent.Event, error) {\\n   198→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   199→\\tif err != nil {\\n   200→\\t\\treturn nil, err\\n   201→\\t}\\n   202→\\treturn &agent.Event{\\n   203→\\t\\tType:       agent.SessionEnd,\\n   204→\\t\\tSessionID:  raw.SessionID,\\n   205→\\t\\tSessionRef: raw.TranscriptP