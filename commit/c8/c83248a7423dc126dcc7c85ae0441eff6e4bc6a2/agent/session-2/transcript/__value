ifiedFiles(lines)\\n    71→\\treturn files, currentPos, nil\\n    72→}\\n    73→\\n    74→// ExtractPrompts extracts user prompts from the transcript starting at the given line offset.\\n    75→func (f *FactoryAIDroidAgent) ExtractPrompts(sessionRef string, fromOffset int) ([]string, error) {\\n    76→\\tlines, _, err := ParseDroidTranscript(sessionRef, fromOffset)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    79→\\t}\\n    80→\\n    81→\\tvar prompts []string\\n    82→\\tfor i := range lines {\\n    83→\\t\\tif lines[i].Type != transcript.TypeUser {\\n    84→\\t\\t\\tcontinue\\n    85→\\t\\t}\\n    86→\\t\\tcontent := transcript.ExtractUserContent(lines[i].Message)\\n    87→\\t\\tif content != \\\"\\\" {\\n    88→\\t\\t\\tprompts = append(prompts, textutil.StripIDEContextTags(content))\\n    89→\\t\\t}\\n    90→\\t}\\n    91→\\treturn prompts, nil\\n    92→}\\n    93→\\n    94→// ExtractSummary extracts the last assistant message as a session summary.\\n    95→func (f *FactoryAIDroidAgent) ExtractSummary(sessionRef string) (string, error) {\\n    96→\\tlines, err := func() ([]transcript.Line, error) {\\n    97→\\t\\tdata, readErr := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n    98→\\t\\tif readErr != nil {\\n    99→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", readErr)\\n   100→\\t\\t}\\n   101→\\t\\tparsed, parseErr := ParseDroidTranscriptFromBytes(data)\\n   102→\\t\\tif parseErr != nil {\\n   103→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", parseErr)\\n   104→\\t\\t}\\n   105→\\t\\treturn parsed, nil\\n   106→\\t}()\\n   107→\\tif err != nil {\\n   108→\\t\\treturn \\\"\\\", err\\n   109→\\t}\\n   110→\\n   111→\\tfor i := len(lines) - 1; i >= 0; i-- {\\n   112→\\t\\tif lines[i].Type != transcript.TypeAssistant {\\n   113→\\t\\t\\tcontinue\\n   114→\\t\\t}\\n   115→\\t\\tvar msg transcript.AssistantMessage\\n   116→\\t\\tif err := json.Unmarshal(lines[i].Message, &msg); err != nil {\\n   117→\\t\\t\\tcontinue\\n   118→\\t\\t}\\n   119→\\t\\tfor _, block := range msg.Content {\\n   120→\\t\\t\\tif block.Type == transcript.ContentTypeText && block.Text != \\\"\\\" {\\n   121→\\t\\t\\t\\treturn block.Text, nil\\n   122→\\t\\t\\t}\\n   123→\\t\\t}\\n   124→\\t}\\n   125→\\treturn \\\"\\\", nil\\n   126→}\\n   127→\\n   128→// --- TokenCalculator ---\\n   129→\\n   130→// CalculateTokenUsage computes token usage from the transcript starting at the given line offset.\\n   131→func (f *FactoryAIDroidAgent) CalculateTokenUsage(sessionRef string, fromOffset int) (*agent.TokenUsage, error) {\\n   132→\\treturn CalculateTotalTokenUsageFromTranscript(sessionRef, fromOffset, \\\"\\\")\\n   133→}\\n   134→\\n   135→// --- SubagentAwareExtractor ---\\n   136→\\n   137→// ExtractAllModifiedFiles extracts files modified by both the main agent and any spawned subagents.\\n   138→func (f *FactoryAIDroidAgent) ExtractAllModifiedFiles(sessionRef string, fromOffset int, subagentsDir string) ([]string, error) {\\n   139→\\treturn ExtractAllModifiedFilesFromTranscript(sessionRef, fromOffset, subagentsDir)\\n   140→}\\n   141→\\n   142→// CalculateTotalTokenUsage computes token usage including all spawned subagents.\\n   143→func (f *FactoryAIDroidAgent) CalculateTotalTokenUsage(sessionRef string, fromOffset int, subagentsDir string) (*agent.TokenUsage, error) {\\n   144→\\treturn CalculateTotalTokenUsageFromTranscript(sessionRef, fromOffset, subagentsDir)\\n   145→}\\n   146→\\n   147→// --- Internal hook parsing functions ---\\n   148→\\n   149→func (f *FactoryAIDroidAgent) parseSessionStart(stdin io.Reader) (*agent.Event, error) {\\n   150→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   151→\\tif err != nil {\\n   152→\\t\\treturn nil, err\\n   153→\\t}\\n   154→\\treturn &agent.Event{\\n   155→\\t\\tType:       agent.SessionStart,\\n   156→\\t\\tSessionID:  raw.SessionID,\\n   157→\\t\\tSessionRef: raw.TranscriptPath,\\n   158→\\t\\tTimestamp:  time.Now(),\\n   159→\\t}, nil\\n   160→}\\n   161→\\n   162→func (f *FactoryAIDroidAgent) parseTurnStart(stdin io.Reader) (*agent.Event, error) {\\n   163→\\traw, err := agent.ReadAndParseHookInput[userPromptSubmitRaw](stdin)\\n   164→\\tif err != nil {\\n   165→\\t\\treturn nil, err\\n   166→\\t}\\n   167→\\treturn &agent.Event{\\n   168→\\t\\tType:       agent.TurnStart,\\n   169→\\t\\tSessionID:  raw.SessionID,\\n   170→\\t\\tSessionRef: raw.TranscriptPath,\\n   171→\\t\\tPrompt:     raw.Prompt,\\n   172→\\t\\tTimestamp:  time.Now(),\\n   173→\\t}, nil\\n   174→}\\n   175→\\n   176→func (f *FactoryAIDroidAgent) parseTurnEnd(stdin io.Reader) (*agent.Event, error) {\\n   177→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   178→\\tif err != nil {\\n   179→\\t\\treturn nil, err\\n   180→\\t}\\n   181→\\treturn &agent.Event{\\n   182→\\t\\tType:       agent.TurnEnd,\\n   183→\\t\\tSessionID:  raw.SessionID,\\n   184→\\t\\tSessionRef: raw.TranscriptPath,\\n   185→\\t\\tTimestamp:  time.Now(),\\n   186→\\t}, nil\\n   187→}\\n   188→\\n   189→func (f *FactoryAIDroidAgent) parseSessionEnd(stdin io.Reader) (*agent.Event, error) {\\n   190→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   191→\\tif err != nil {\\n   192→\\t\\treturn nil, err\\n   193→\\t}\\n   194→\\treturn &agent.Event{\\n   195→\\t\\tType:       agent.SessionEnd,\\n   196→\\t\\tSessionID:  raw.SessionID,\\n   197→\\t\\tSessionRef: raw.TranscriptPath,\\n   198→\\t\\tTimestamp:  time.Now(),\\n   199→\\t}, nil\\n   200→}\\n   201→\\n   202→func (f *FactoryAIDroidAgent) parseSubagentStart(stdin io.Reader) (*agent.Event, error) {\\n   203→\\traw, err := agent.ReadAndParseHookInput[taskHookInputRaw](stdin)\\n   204→\\tif err != nil {\\n   205→\\t\\treturn nil, err\\n   206→\\t}\\n   207→\\treturn &agent.Event{\\n   208→\\t\\tType:       agent.SubagentStart,\\n   209→\\t\\tSessionID:  raw.