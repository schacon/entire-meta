n   396→// AreHooksInstalled checks if Entire hooks are installed.\\n   397→func (f *FactoryAIDroidAgent) AreHooksInstalled() bool {\\n   398→\\t// Use repo root to find .factory directory when run from a subdirectory\\n   399→\\trepoRoot, err := paths.RepoRoot()\\n   400→\\tif err != nil {\\n   401→\\t\\trepoRoot = \\\".\\\" // Fallback to CWD if not in a git repo\\n   402→\\t}\\n   403→\\tsettingsPath := filepath.Join(repoRoot, \\\".factory\\\", FactorySettingsFileName)\\n   404→\\tdata, err := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   405→\\tif err != nil {\\n   406→\\t\\treturn false\\n   407→\\t}\\n   408→\\n   409→\\tvar settings FactorySettings\\n   410→\\tif err := json.Unmarshal(data, &settings); err != nil {\\n   411→\\t\\treturn false\\n   412→\\t}\\n   413→\\n   414→\\t// Check for at least one of our hooks (new or old format)\\n   415→\\treturn hookCommandExists(settings.Hooks.Stop, \\\"entire hooks factoryai-droid stop\\\") ||\\n   416→\\t\\thookCommandExists(settings.Hooks.Stop, \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid stop\\\")\\n   417→}\\n   418→\\n   419→// GetSupportedHooks returns the hook types Factory AI Droid supports.\\n   420→func (f *FactoryAIDroidAgent) GetSupportedHooks() []agent.HookType {\\n   421→\\treturn []agent.HookType{\\n   422→\\t\\tagent.HookSessionStart,\\n   423→\\t\\tagent.HookSessionEnd,\\n   424→\\t\\tagent.HookUserPromptSubmit,\\n   425→\\t\\tagent.HookStop,\\n   426→\\t\\tagent.HookPreToolUse,\\n   427→\\t\\tagent.HookPostToolUse,\\n   428→\\t}\\n   429→}\\n   430→\\n   431→// Helper functions for hook management\\n   432→\\n   433→func hookCommandExists(matchers []FactoryHookMatcher, command string) bool {\\n   434→\\tfor _, matcher := range matchers {\\n   435→\\t\\tfor _, hook := range matcher.Hooks {\\n   436→\\t\\t\\tif hook.Command == command {\\n   437→\\t\\t\\t\\treturn true\\n   438→\\t\\t\\t}\\n   439→\\t\\t}\\n   440→\\t}\