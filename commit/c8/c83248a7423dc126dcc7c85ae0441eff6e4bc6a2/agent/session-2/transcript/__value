allyExclusive(\\\"generate\\\", \\\"raw-transcript\\\")\\n   156→\\n   157→\\treturn cmd\\n   158→}\\n   159→\\n   160→// runExplain routes to the appropriate explain function based on flags.\\n   161→func runExplain(w, errW io.Writer, sessionID, commitRef, checkpointID string, noPager, verbose, full, rawTranscript, generate, force, searchAll bool) error {\\n   162→\\t// Count mutually exclusive flags (--commit and --checkpoint are mutually exclusive)\\n   163→\\t// --session is now a filter for the list view, not a separate mode\\n   164→\\tflagCount := 0\\n   165→\\tif commitRef != \\\"\\\" {\\n   166→\\t\\tflagCount++\\n   167→\\t}\\n   168→\\tif checkpointID != \\\"\\\" {\\n   169→\\t\\tflagCount++\\n   170→\\t}\\n   171→\\t// If --session is combined with --commit or --checkpoint, that's still an error\\n   172→\\tif sessionID != \\\"\\\" && flagCount > 0 {\\n   173→\\t\\treturn errors.New(\\\"cannot specify multiple of --session, --commit, --checkpoint\\\")\\n   174→\\t}\\n   175→\\tif flagCount > 1 {\\n   176→\\t\\treturn errors.New(\\\"cannot specify multiple of --session, --commit, --checkpoint\\\")\\n   177→\\t}\\n   178→\\n   179→\\t// Route to appropriate handler\\n   180→\\tif commitRef != \\\"\\\" {\\n   181→\\t\\treturn runExplainCommit(w, commitRef, noPager, verbose, full, searchAll)\\n   182→\\t}\\n   183→\\tif checkpointID != \\\"\\\" {\\n   184→\\t\\treturn runExplainCheckpoint(w, errW, checkpointID, noPager, verbose, full, rawTranscript, generate, force, searchAll)\\n   185→\\t}\\n   186→\\n   187→\\t// Default or with session filter: show list view (optionally filtered by session)\\n   188→\\treturn runExplainBranchWithFilter(w, noPager, sessionID)\\n   189→}\\n   190→\\n   191→// runExplainCheckpoint explains a specific checkpoint.\\n   192→// Supports both committed checkpoints (by checkpoint ID) and temporary checkpoints (by git SHA).\\n   193→// First tries to match committed checkpoints, then falls back to temporary checkpoints.\\n   194→// When generate is true, generates an AI summary for the checkpoint.\\n   195→// When force is true, regenerates even if a summary already exists.\\n   196→// When rawTranscript is true, outputs only the raw transcript file (JSONL format).\\n   197→// When searchAll is true, searches all commits without branch/depth limits (used for finding associated commits).\\n   198→func runExplainCheckpoint(w, errW io.Writer, checkpointIDPrefix string, noPager, verbose, full, rawTranscript, generate, force, searchAll bool) error {\\n   199→\\trepo, err := openRepository()\\n   200→\\tif err != nil {\\n   201→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   202→\\t}\\n   203→\\n   204→\\tstore := checkpoint.NewGitStore(repo)\\n   205→\\n   206→\\t// First, try to find in committed checkpoints by checkpoint ID prefix\\n   207→\\tcommitted, err := store.ListCommitted(context.Background())\\n   208→\\tif err != nil {\\n   209→\\t\\treturn fmt.Errorf(\\\"failed to list checkpoints: %w\\\", err)\\n   210→\\t}\\n   211→\\n   212→\\t// Collect all matching checkpoint IDs to detect ambiguity\\n   213→\\tvar matches []id.CheckpointID\\n   214→\\tfor _, info := range committed {\\n   215→\\t\\tif strings.HasPrefix(info.CheckpointID.String(), checkpointIDPrefix) {\\n   216→\\t\\t\\tmatches = append(matches, info.CheckpointID)\\n   217→\\t\\t}\\n   218→\\t}\\n   219→\\n   220→\\tvar fullCheckpointID id.CheckpointID\\n   221→\\tswitch len(matches) {\\n   222→\\tcase 0:\\n   223→\\t\\t// Not found in committed, try temporary checkpoints by git SHA\\n   224→\\t\\tif generate {\\n   225→\\t\\t\\treturn fmt.Errorf(\\\"cannot generate summary for temporary checkpoint %s (only committed checkpoints supported)\\\", checkpointIDPrefix)\\n   226→\\t\\t}\\n   227→\\t\\toutput, found := explainTemporaryCheckpoint(w, repo, store, checkpointIDPrefix, verbose, full, rawTranscript)\\n   228→\\t\\tif found {\\n   229→\\t\\t\\toutputExplainContent(w, output, noPager)\\n   230→\\t\\t\\treturn nil\\n   231→\\t\\t}\\n   232→\\t\\t// If output is non-empty, it contains an error message (e.g., ambiguous prefix)\\n   233→\\t\\tif output != \\\"\\\" {\\n   234→\\t\\t\\treturn errors.New(output)\\n   235→\\t\\t}\\n   236→\\t\\treturn fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointIDPrefix)\\n   237→\\tcase 1:\\n   238→\\t\\tfullCheckpointID = matches[0]\\n   239→\\tdefault:\\n   240→\\t\\t// Ambiguous prefix - show up to 5 examples\\n   241→\\t\\texamples := make([]string, 0, 5)\\n   242→\\t\\tfor i := 0; i < len(matches) && i < 5; i++ {\\n   243→\\t\\t\\texamples = append(examples, matches[i].String())\\n   244→\\t\\t}\\n   245→\\t\\treturn fmt.Errorf(\\\"ambiguous checkpoint prefix %q matches %d checkpoints: %s\\\", checkpointIDPrefix, len(matches), strings.Join(examples, \\\", \\\"))\\n   246→\\t}\\n   247→\\n   248→\\t// Load checkpoint summary\\n   249→\\tsummary, err := store.ReadCommitted(context.Background(), fullCheckpointID)\"}]},\"uuid\":\"970ef6aa-5d6f-41ee-a02d-ae26117946bc\",\"timestamp\":\"2026-02-19T20:40:22.444Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand how checkpoints can be viewed in this CLI tool. Look for:\\n\\n1. Any \\\"explain\\\" or \\\"log\\\" or \\\"ui\\\" commands that display checkpoints\\n2. Any web UI or TUI (terminal UI) for viewing checkpoints\\n3. The `entire explain` and `entire log` commands - what do they show and how\\n4. Any local web server or dashboard functionality\\n5. Check cmd/entire/cli/commands/ for relevant command files\\n\\nFocus on user-facing features for viewing/browsing checkpoints. Keep the answer concise.\",\"agentId\":\"a9ed43b\"},\"toolUseID\":\"agent_msg_01XghacebG5xSyeyrvQdjvii\",\"parentToolUseID\":\"toolu_01RU6gYUtv67NynTPfGAX6Qo\",\"uuid\":\"7e045fb8-1776-4ade-a494-4780e9f11206\",\"timestamp\":\"2026-02-19T20:40:22.586Z\"}\n{\"parentUuid\":\"7e045fb8-1776-4ade-a494-4780e9f11206\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Use