271→\\trawHooks[hookType] = data\\n   272→}\\n   273→\\n   274→// UninstallHooks removes Entire hooks from Factory AI Droid settings.\\n   275→func (f *FactoryAIDroidAgent) UninstallHooks() error {\\n   276→\\t// Use repo root to find .factory directory when run from a subdirectory\\n   277→\\trepoRoot, err := paths.RepoRoot()\\n   278→\\tif err != nil {\\n   279→\\t\\trepoRoot = \\\".\\\" // Fallback to CWD if not in a git repo\\n   280→\\t}\\n   281→\\tsettingsPath := filepath.Join(repoRoot, \\\".factory\\\", FactorySettingsFileName)\\n   282→\\tdata, err := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   283→\\tif err != nil {\\n   284→\\t\\treturn nil //nolint:nilerr // No settings file means nothing to uninstall\\n   285→\\t}\\n   286→\\n   287→\\tvar rawSettings map[string]json.RawMessage\\n   288→\\tif err := json.Unmarshal(data, &rawSettings); err != nil {\\n   289→\\t\\treturn fmt.Errorf(\\\"failed to parse settings.json: %w\\\", err)\\n   290→\\t}\\n   291→\\n   292→\\t// rawHooks preserves unknown hook types\\n   293→\\tvar rawHooks map[string]json.RawMessage\\n   294→\\tif hooksRaw, ok := rawSettings[\\\"hooks\\\"]; ok {\\n   295→\\t\\tif err := json.Unmarshal(hooksRaw, &rawHooks); err != nil {\\n   296→\\t\\t\\treturn fmt.Errorf(\\\"failed to parse hooks: %w\\\", err)\\n   297→\\t\\t}\\n   298→\\t}\\n   299→\\tif rawHooks == nil {\\n   300→\\t\\trawHooks = make(map[string]json.RawMessage)\\n   301→\\t}\\n   302→\\n   303→\\t// Parse only the hook types we need to modify\\n   304→\\tvar sessionStart, sessionEnd, stop, userPromptSubmit, preToolUse, postToolUse, preCompact []FactoryHookMatcher\\n   305→\\tparseHookType(rawHooks, \\\"SessionStart\\\", &sessionStart)\\n   306→\\tparseHookType(rawHooks, \\\"SessionEnd\\\", &sessionEnd)\\n   307→\\tparseHookType(rawHooks, \\\"Stop\\\", &stop)\\n   308→\\tparseHookType(rawHooks, \\\"UserPromptSubmit\\\", &userPromptSubmit)\\n   309→\\tparseHookType(rawHooks, \\\"PreToolUse\\\", &preToolUse)\\n   310→\\tparseHookType(rawHooks, \\\"PostToolUse\\\", &postToolUse)\\n   311→\\tparseHookType(rawHooks, \\\"PreCompact\\\", &preCompact)\\n   312→\\n   313→\\t// Remove Entire hooks from all hook types\\n   314→\\tsessionStart = removeEntireHooks(sessionStart)\\n   315→\\tsessionEnd = removeEntireHooks(sessionEnd)\\n   316→\\tstop = removeEntireHooks(stop)\\n   317→\\tuserPromptSubmit = removeEntireHooks(userPromptSubmit)\\n   318→\\tpreToolUse = removeEntireHooksFromMatchers(preToolUse)\\n   319→\\tpostToolUse = removeEntireHooksFromMatchers(postToolUse)\\n   320→\\tpreCompact = removeEntireHooks(preCompact)\\n   321→\\n   322→\\t// Marshal modified hook types back to rawHooks\\n   323→\\tmarshalHookType(rawHooks, \\\"SessionStart\\\", sessionStart)\\n   324→\\tmarshalHookType(rawHooks, \\\"SessionEnd\\\", sessionEnd)\\n   325→\\tmarshalHookType(rawHooks, \\\"Stop\\\", stop)\\n   326→\\tmarshalHookType(rawHooks, \\\"UserPromptSubmit\\\", userPromptSubmit)\\n   327→\\tmarshalHookType(rawHooks, \\\"PreToolUse\\\", preToolUse)\\n   328→\\tmarshalHookType(rawHooks, \\\"PostToolUse\\\", postToolUse)\\n   329→\\tmarshalHookType(rawHooks, \\\"PreCompact\\\", preCompact)\\n   330→\\n   331→\\t// Also remove the metadata deny rule from permissions\\n   332→\\tvar rawPermissions map[string]json.RawMessage\\n   333→\\tif permRaw, ok := rawSettings[\\\"permissions\\\"]; ok {\\n   334→\\t\\tif err := json.Unmarshal(permRaw, &rawPermissions); err != nil {\\n   335→\\t\\t\\t// If parsing fails, just skip permissions cleanup\\n   336→\\t\\t\\trawPermissions = nil\\n   337→\\t\\t}\\n   338→\\t}\\n   339→\\n   340→\\tif rawPermissions != nil {\\n   341→\\t\\tif denyRaw, ok := rawPermissions[\\\"deny\\\"]; ok {\\n   342→\\t\\t\\tvar denyRules []string\\n   343→\\t\\t\\tif err := json.Unmarshal(denyRaw, &denyRules); err == nil {\\n   344→\\t\\t\\t\\t// Filter out the metadata deny rule\\n   345→\\t\\t\\t\\tfilteredRules := make([]string, 0, len(denyRule