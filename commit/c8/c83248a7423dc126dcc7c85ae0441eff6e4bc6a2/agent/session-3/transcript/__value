78→\\tinnerMsg := mustMarshal(t, map[string]interface{}{\\n   779→\\t\\t\\\"role\\\": \\\"assistant\\\",\\n   780→\\t\\t\\\"content\\\": []map[string]interface{}{\\n   781→\\t\\t\\t{\\n   782→\\t\\t\\t\\t\\\"type\\\":  \\\"tool_use\\\",\\n   783→\\t\\t\\t\\t\\\"id\\\":    \\\"toolu_\\\" + id,\\n   784→\\t\\t\\t\\t\\\"name\\\":  toolName,\\n   785→\\t\\t\\t\\t\\\"input\\\": map[string]string{\\\"file_path\\\": filePath},\\n   786→\\t\\t\\t},\\n   787→\\t\\t},\\n   788→\\t})\\n   789→\\tline := mustMarshal(t, map[string]interface{}{\\n   790→\\t\\t\\\"type\\\":    \\\"message\\\",\\n   791→\\t\\t\\\"id\\\":      id,\\n   792→\\t\\t\\\"message\\\": json.RawMessage(innerMsg),\\n   793→\\t})\\n   794→\\treturn string(line)\\n   795→}\\n   796→\\n   797→// makeWriteToolLine returns a Droid-format JSONL line with a Write tool_use for the given file.\\n   798→func makeWriteToolLine(t *testing.T, id, filePath string) string {\\n   799→\\tt.Helper()\\n   800→\\treturn makeFileToolLine(t, \\\"Write\\\", id, filePath)\\n   801→}\\n   802→\\n   803→// makeEditToolLine returns a Droid-format JSONL line with an Edit tool_use for the given file.\\n   804→func makeEditToolLine(t *testing.T, id, filePath string) string {\\n   805→\\tt.Helper()\\n   806→\\treturn makeFileToolLine(t, \\\"Edit\\\", id, filePath)\\n   807→}\\n   808→\\n   809→// makeTaskToolUseLine returns a Droid-format JSONL line with a Task tool_use (spawning a subagent).\\n   810→func makeTaskToolUseLine(t *testing.T, id, toolUseID string) string {\\n   811→\\tt.Helper()\\n   812→\\tinnerMsg := mustMarshal(t, map[string]interface{}{\\n   813→\\t\\t\\\"role\\\": \\\"assistant\\\",\\n   814→\\t\\t\\\"content\\\": []map[string]interface{}{\\n   815→\\t\\t\\t{\\n   816→\\t\\t\\t\\t\\\"type\\\":  \\\"tool_use\\\",\\n   817→\\t\\t\\t\\t\\\"id\\\":    toolUseID,\\n   818→\\t\\t\\t\\t\\\"name\\\":  \\\"Task\\\",\\n   819→\\t\\t\\t\\t\\\"input\\\": map[string]string{\\\"prompt\\\": \\\"do something\\\"},\\n   820→\\t\\t\\t},\