 84→\\t// rawHooks preserves unknown hook types\\n    85→\\tvar rawHooks map[string]json.RawMessage\\n    86→\\n    87→\\t// rawPermissions preserves unknown permission fields (e.g., \\\"ask\\\")\\n    88→\\tvar rawPermissions map[string]json.RawMessage\\n    89→\\n    90→\\texistingData, readErr := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from cwd + fixed path\\n    91→\\tif readErr == nil {\\n    92→\\t\\tif err := json.Unmarshal(existingData, &rawSettings); err != nil {\\n    93→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse existing settings.json: %w\\\", err)\\n    94→\\t\\t}\\n    95→\\t\\tif hooksRaw, ok := rawSettings[\\\"hooks\\\"]; ok {\\n    96→\\t\\t\\tif err := json.Unmarshal(hooksRaw, &rawHooks); err != nil {\\n    97→\\t\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse hooks in settings.json: %w\\\", err)\\n    98→\\t\\t\\t}\\n    99→\\t\\t}\\n   100→\\t\\tif permRaw, ok := rawSettings[\\\"permissions\\\"]; ok {\\n   101→\\t\\t\\tif err := json.Unmarshal(permRaw, &rawPermissions); err != nil {\\n   102→\\t\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse permissions in settings.json: %w\\\", err)\\n   103→\\t\\t\\t}\\n   104→\\t\\t}\\n   105→\\t} else {\\n   106→\\t\\trawSettings = make(map[string]json.RawMessage)\\n   107→\\t}\\n   108→\\n   109→\\tif rawHooks == nil {\\n   110→\\t\\trawHooks = make(map[string]json.RawMessage)\\n   111→\\t}\\n   112→\\tif rawPermissions == nil {\\n   113→\\t\\trawPermissions = make(map[string]json.RawMessage)\\n   114→\\t}\\n   115→\\n   116→\\t// Parse only the hook types we need to modify\\n   117→\\tvar sessionStart, sessionEnd, stop, userPromptSubmit, preToolUse, postToolUse, preCompact []FactoryHookMatcher\\n   118→\\tparseHookType(rawHooks, \\\"SessionStart\\\", &sessionStart)\\n   119→\\tparseHookType(rawHooks, \\\"SessionEnd\\\", &sessionEnd)\\n   120→\\tparseHookType(rawHooks, \\\"Stop\\\", &stop)\\n   121→\\tparseHookType(rawHooks, \\\"UserPromptSubmit\\\", &userPromptSubmit)\\n   122→\\tparseHookType(rawHooks, \\\"PreToolUse\\\", &preToolUse)\\n   123→\\tparseHookType(rawHooks, \\\"PostToolUse\\\", &postToolUse)\\n   124→\\tparseHookType(rawHooks, \\\"PreCompact\\\", &preCompact)\\n   125→\\n   126→\\t// If force is true, remove all existing Entire hooks first\\n   127→\\tif force {\\n   128→\\t\\tsessionStart = removeEntireHooks(sessionStart)\\n   129→\\t\\tsessionEnd = removeEntireHooks(sessionEnd)\\n   130→\\t\\tstop = removeEntireHooks(stop)\\n   131→\\t\\tuserPromptSubmit = removeEntireHooks(userPromptSubmit)\\n   132→\\t\\tpreToolUse = removeEntireHooksFromMatchers(preToolUse)\\n   133→\\t\\tpostToolUse = removeEntireHooksFromMatchers(postToolUse)\\n   134→\\t\\tpreCompact = removeEntireHooks(preCompact)\\n   135→\\t}\\n   136→\\n   137→\\t// Define hook commands\\n   138→\\tvar sessionStartCmd, sessionEndCmd, stopCmd, userPromptSubmitCmd, preTaskCmd, postTaskCmd, preCompactCmd string\\n   139→\\tif localDev {\\n   140→\\t\\tsessionStartCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid session-start\\\"\\n   141→\\t\\tsessionEndCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid session-end\\\"\\n   142→\\t\\tstopCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid stop\\\"\\n   143→\\t\\tuserPromptSubmitCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid user-prompt-submit\\\"\\n   144→\\t\\tpreTaskCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid pre-tool-use\\\"\\n   145→\\t\\tpostTaskCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid post-tool-use\\\"\\n   146→\\t\\tpreCompactCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid pre-compact\\\"\\n   147→\\t} else {\\n   148→\\t\\tsessionStartCmd = \\\"entire hooks factoryai-droid session-start\\\"\\n   149→\\t\\tsessionEndCmd = \\\"entire hooks factoryai-droid session-end\\\"\\n   150→\\t\\tstopCmd = \\\"entire hooks factoryai-droid stop\\\"\\n   151→\\t\\tuserPromptSubmitCmd = \\\"entire hooks factoryai-droid user-prompt-submit\\\"\\n   152→\\t\\tpreTaskCmd = \\\"entire hooks factoryai-droid pre-tool-use\\\"\\n   153→\\t\\tpostTaskCmd = \\\"entire hooks factoryai-droid post-tool-use\\\"\\n   154→\\t\\tpreCompactCmd = \\\"entire hooks factoryai-droid pre-compact\\\"\\n   155→\\t}\\n   156→\\n   157→\\tcount := 0\\n   158→\\n   159→\\t// Add hooks if they don't exist\\n   160→\\tif !hookCommandExists(sessionStart, sessionStartCmd) {\\n   161→\\t\\tsessionStart = addHookToMatcher(sessionStart, \\\"\\\", sessionStartCmd)\\n   162→\\t\\tcount++\\n   163→\\t}\\n   164→\\tif !hookCommandExists(sessionEnd, sessionEndCmd) {\\n   165→\\t\\tsessionEnd = addHookToMatcher(sessionEnd, \\\"\\\", sessionEndCmd)\\n   166→\\t\\tcount++\\n   167→\\t}\\n   168→\\tif !hookCommandExists(stop, stopCmd) {\\n   169→\\t\\tstop = addHookToMatcher(stop, \\\"\\\", stopCmd)\\n   170→\\t\\tcount++\\n   171→\\t}\\n   172→\\tif !hookCommandExists(userPromptSubmit, userPromptSubmitCmd) {\\n   173→\\t\\tuserPromptSubmit = addHookToMatcher(userPromptSubmit, \\\"\\\", userPromptSubmitCmd)\\n   174→\\t\\tcount++\\n   175→\\t}\\n   176→\\tif !hookCommandExistsWithMatcher(preToolUse, \\\"Task\\\", preTaskCmd) {\\n   177→\\t\\tpreToolUse = addHookToMatcher(preToolUse, \\\"Task\\\", preTaskCmd)\\n   178→\\t\\tcount++\\n   179→\\t}\\n   180→\\tif !hookCommandExistsWithMatcher(postToolUse, \\\"Task\\\", postTaskCmd) {\\n   181→\\t\\tpostToolUse = addHookToMatcher(postToolUse, \\\"Task\\\", postTaskCmd)\\n   182→\\t\\tcount++\\n   183→\\t}\\n   184→\\tif !hookCommandExists(preCompact, preCompactCmd) {\\n   185→\\t\\tpreCompact = addHookToMatcher(preCompact, \\\"\\\", preCompactCmd)\\n   186→\\t\\tcount++\\n   187→\\t}\\n   188→\\n   189→\\t// Add permissions.deny rule if not present\\n   190→\\tpermissionsChanged := false\\n   191→\\tvar denyRules []string\\n   192→\\tif denyRaw, ok := rawPermissions[\\\"deny\\\"]; ok {\\n   193→\\t\\tif err := json.Unmarshal(denyRaw, &denyRules); err != nil {\\n   194→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse permissions.deny in settings.json: %w\\\", err)\\n   195→\\t\\t}\\n   196→\\t}\\n   197→\\tif !slices.Contains(denyRules, metadataDenyRule) {\\n   198→\\t\\tdenyRules = append(denyRules, metadataDenyRule)\\n   199→\\t\\tdenyJSON, err := json.Marshal(denyRules)\\n   200→\\t\\tif err != nil {\\n   201→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal permissions.deny: %w\\\", err)\\n   202→\\t\\t}\\n   203→\\t\\trawPermissions[\\\"deny\\\"] = denyJSON\\n   204→\\t\\tpermissionsChanged = true\\n   205→\\t}\\n   206→\\n   207→\\tif count == 0 && !permissionsChanged {\\n   208→\\t\\treturn 0, nil // All hooks and permissions already installed\\n   209→\\t}\\n   210→\\n   211→\\t// Marshal modified hook types back to rawHooks\\n   212→\\tmarshalHookType(rawHooks, \\\"SessionStart\\\", sessionStart)\\n   213→\\tmarshalHookType(rawHooks, \\\"SessionEnd\\\", sessionEnd)\\n   214→\\tmarshalHookType(rawHooks, \\\"Stop\\\", stop)\\n   215→\\tmarshalHookType(rawHooks, \\\"UserPromptSubmit\\\", userPromptSubmit)\\n   216→\\tmarshalHookType(rawHooks, \\\"PreToolUse\\\", preToolUse)\\n   217→\\tmarshalHookType(rawHooks, \\\"PostToolUse\\\", postToolUse)\\n   218→\\tmarshalHookType(rawHooks, \\\"PreCompact\\\", preCompact)\\n   219→\\n   220→\\t// Marshal hooks and update raw settings\\n   221→\\thooksJSON, err := json.Marshal(rawHooks)\\n   222→\\tif err != nil {\\n   223→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal hooks: %w\\\", err)\\n   224→\\t}\\n   225→\\trawSettings[\\\"hooks\\\"] = hooksJSON\\n   226→\\n   227→\\t// Marshal permissions and update raw settings\\n   228→\\tpermJSON, err := json.Marshal(rawPermissions)\\n   229→\\tif err != nil {\\n   230→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal permissions: %w\\\", err)\\n   231→\\t}\\n   232→\\trawSettings[\\\"permissions\\\"] = permJSON\\n   233→\\n   234→\\t// Write back to file\\n   235→\\tif err := os.MkdirAll(filepath.Dir(settingsPath), 0o750); err != nil {\\n   236→\\t\\treturn 0, fmt.Errorf(\\\"failed to create .factory directory: %w\\\", err)\\n   237→\\t}\\n   238→\\n   239→\\toutput, err := jsonutil.MarshalIndentWithNewline(rawSettings, \\\"\\\", \\\"  \\\")\\n   240→\\tif err != nil {\\n   241→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal settings: %w\\\", err)\\n   242→\\t}\\n   243→\\n   244→\\tif err := os.WriteFile(settingsPath, output, 0o600); err != nil {\\n   245→\\t\\treturn 0, fmt.Errorf(\\\"failed to write settings.json: %w\\\", err)\\n   246→\\t}\\n   247→\\n   248→\\treturn count, nil\\n   249→}\\n   250→\\n   251→// parseHookType parses a specific hook type from rawHooks into the target slice.\\n   252→// Silently ignores parse errors (leaves target unchanged).\\n   253→func parseHookType(rawHooks map[string]json.RawMessage, hookType string, target *[]FactoryHookMatcher) {\\n   254→\\tif data, ok := rawHooks[hookType]; ok {\\n   255→\\t\\t//nolint:errcheck,gosec // Intentionally ignoring parse errors - leave target as nil/empty\\n   256→\\t\\tjson.Unmarshal(data, target)\\n   257→\\t}\\n   258→}\\n   259→\\n   260→// marshalHookType marshals a hook type back to rawHooks.\\n   261→// If the slice is empty, removes the key from rawHooks.\\n   262→func marshalHookType(rawHooks map[string]json.RawMessage, hookType string, matchers []FactoryHookMatcher) {\\n   263→\\tif len(matchers) == 0 {\\n   264→\\t\\tdelete(rawHooks, hookType)\\n   265→\\t\\treturn\\n   266→\\t}\\n   267→\\tdata, err := json.Marshal(matchers)\\n   268→\\tif err != nil {\\n   269→\\t\\treturn // Silently ignore marshal errors (shouldn't happen)\\n   270→\\t}\\n   271→\\trawHooks[hookType] = data\\n   272→}\\n   273→\\n   274→// UninstallHooks removes Entire hooks from Factory AI Droid settings.\\n   275→func (f *FactoryAIDroidAgent) UninstallHooks() error {\\n   276→\\t// Use repo root to find .factory directory when run from a subdirectory\\n   277→\\trepoRoot, err := paths.RepoRoot()\\n   278→\\tif err != nil {\\n   279→\\t\\trepoRoot = \\\".\\\" // Fallback to CWD if not in a git repo\\n   280→\\t}\\n   281→\\tsettingsPath := filepath.Join(repoRoot, \\\".factory\\\", FactorySettingsFileName)\\n   282→\\tdata, err := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   283→\\tif err != nil {\\n   284→\\t\\treturn nil //nolint:nilerr // No settings file means nothing to uninstall\\n   285→\\t}\\n   286→\\n   287→\\tvar rawSettings map[string]json.RawMessage\\n   288→\\tif err := json.Unmarshal(data, &rawSettings); err != nil {\\n   289→\\t\\treturn fmt.Errorf(\\\"failed to parse settings.json: %w\\\", err)\\n   290→\\t}\\n   291→\\n   292→\\t// rawHooks preserves unknown hook types\\n   293→\\tvar rawHooks map[string]json.RawMessage\\n   294→\\tif hooksRaw, ok := rawSettings[\\\"hooks\\\"]; ok {\\n   295→\\t\\tif err := json.Unmarshal(hooksRaw, &rawHooks); err != nil {\\n   296→\\t\\t\\treturn fmt.Errorf(\\\"failed to parse hooks: %w\\\", err)\\n   297→\\t\\t}\\n   298→\\t}\\n   299→\\tif rawHooks == nil {\\n   300→\\t\\trawHooks = make(map[string]json.RawMessage)\\n   301→\\t}\\n   302→\\n   303→\\t// Parse only the hook types we need to modify\\n   304→\\tvar sessionStart, sessionEnd, stop, userPromptSubmit, preToolUse, postToolUse, preCompact []FactoryHookMatcher\\n   305→\\tparseHookType(rawHooks, \\\"SessionStart\\\", &sessionStart)\\n   306→\\tparseHookType(rawHooks, \\\"SessionEnd\\\", &sessionEnd)\\n   307→\\tparseHookType(rawHooks, \\\"Stop\\\", &stop)\\n   308→\\tparseHookType(rawHooks, \\\"UserPromptSubmit\\\", &userPromptSubmit)\\n   309→\\tparseHookType(rawHooks, \\\"PreToolUse\\\", &preToolUse)\\n   310→\\tparseHookType(rawHooks, \\\"PostToolUse\\\", &postToolUse)\\n   311→\\tparseHookType(rawHooks, \\\"PreCompact\\\", &preCompact)\\n   312→\\n   313→\\t// Remove Entire hooks from all hook types\\n   314→\\tsessionStart = removeEntireHooks(sessionStart)\\n   315→\\tsessionEnd = removeEntireHooks(sessionEnd)\\n   316→\\tstop = removeEntireHooks(stop)\\n   317→\\tuserPromptSubmit = removeEntireHooks(userPromptSubmit)\\n   318→\\tpreToolUse = removeEntireHooksFromMatchers(preToolUse)\\n   319→\\tpostToolUse = removeEntireHooksFromMatchers(postToolUse)\\n   320→\\tpreCompact = removeEntireHooks(preCompact)\\n   321→\\n   322→\\t// Marshal modified hook types back to rawHooks\\n   323→\\tmarshalHookType(rawHooks, \\\"SessionStart\\\", sessionStart)\\n   324→\\tmarshalHookType(rawHooks, \\\"SessionEnd\\\", sessionEnd)\\n   325→\\tmarshalHookType(rawHooks, \\\"Stop\\\", stop)\\n   326→\\tmarshalHookType(rawHooks, \\\"UserPromptSubmit\\\", userPromptSubmit)\\n   327→\\tmarshalHookType(rawHooks, \\\"PreToolUse\\\", preToolUse)\\n   328→\\tmarshalHookType(rawHooks, \\\"PostToolUse\\\", postToolUse)\\n   329→\\tmarshalHookType(rawHooks, \\\"PreCompact\\\", preCompact)\\n   330→\\n   331→\\t// Also remove the metadata deny rule from permissions\\n   332→\\tvar rawPermissions map[string]json.RawMessage\\n   333→\\tif permRaw, ok := rawSettings[\\\"permissions\\\"]; ok {\\n   334→\\t\\tif err := json.Unmarshal(permRaw, &rawPermissions); err != nil {\\n   335→\\t\\t\\t// If parsing fails, just skip permissions cleanup\\n   336→\\t\\t\\trawPermissions = nil\\n   337→\\t\\t}\\n   338→\\t}\\n   339→\\n   340→\\tif rawPermissions != nil {\\n   341→\\t\\tif denyRaw, ok := rawPermissions[\\\"deny\\\"]; ok {\\n   342→\\t\\t\\tvar denyRules []string\\n   343→\\t\\t\\tif err := json.Unmarshal(denyRaw, &denyRules); err == nil {\\n   344→\\t\\t\\t\\t// Filter out the metadata deny rule\\n   345→\\t\\t\\t\\tfilteredRules := make([]string, 0, len(denyRules))\\n   346→\\t\\t\\t\\tfor _, rule := range denyRules {\\n   347→\\t\\t\\t\\t\\tif rule != metadataDenyRule {\\n   348→\\t\\t\\t\\t\\t\\tfilteredRules = append(filteredRules, rule)\\n   349→\\t\\t\\t\\t\\t}\\n   350→\\t\\t\\t\\t}\\n   351→\\t\\t\\t\\t