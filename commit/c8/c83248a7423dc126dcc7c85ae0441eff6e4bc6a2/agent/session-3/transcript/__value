n   602→\\tif err != nil {\\n   603→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   604→\\t}\\n   605→\\n   606→\\treturn commits\\n   607→}\\n   608→\\n   609→// GitCheckoutNewBranch creates and checks out a new branch.\\n   610→// Uses git CLI instead of go-git to work around go-git v5 bug where Checkout\\n   611→// deletes untracked files (see https://github.com/go-git/go-git/issues/970).\\n   612→func (env *TestEnv) GitCheckoutNewBranch(branchName string) {\\n   613→\\tenv.T.Helper()\\n   614→\\n   615→\\tcmd := exec.Command(\\\"git\\\", \\\"checkout\\\", \\\"-b\\\", branchName)\\n   616→\\tcmd.Dir = env.RepoDir\\n   617→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   618→\\t\\tenv.T.Fatalf(\\\"failed to checkout new branch %s: %v\\\\nOutput: %s\\\", branchName, err, output)\\n   619→\\t}\\n   620→}\\n   621→\\n   622→// GetCurrentBranch returns the current branch name.\\n   623→func (env *TestEnv) GetCurrentBranch() string {\\n   624→\\tenv.T.Helper()\\n   625→\\n   626→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   627→\\tif err != nil {\\n   628→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   629→\\t}\\n   630→\\n   631→\\thead, err := repo.Head()\\n   632→\\tif err != nil {\\n   633→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   634→\\t}\\n   635→\\n   636→\\tif !head.Name().IsBranch() {\\n   637→\\t\\treturn \\\"\\\" // Detached HEAD\\n   638→\\t}\\n   639→\\n   640→\\treturn head.Name().Short()\\n   641→}\\n   642→\\n   643→// RewindPoint mirrors strategy.RewindPoint for test assertions.\\n   644→type RewindPoint struct {\\n   645→\\tID               string\\n   646→\\tMessage          string\\n   647→\\tMetadataDir      string\\n   648→\\tDate             time.Time\\n   649→\\tIsTaskCheckpoint bool\\n   650→\\tToolUseID        string\\n   651→\\tIsLogsOnly       bool\\n   652→\\tCondensationID   string\\n   653→}\\n   654→\\n   655→// GetRewindPoints returns available rewind points using the CLI.\\n   656→func (env *TestEnv) GetRewindPoints() []RewindPoint {\\n   657→\\tenv.T.Helper()\\n   658→\\n   659→\\t// Run rewind --list using the shared binary\\n   660→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--list\\\")\\n   661→\\tcmd.Dir = env.RepoDir\\n   662→\\tcmd.Env = env.cliEnv()\\n   663→\\n   664→\\toutput, err := cmd.CombinedOutput()\\n   665→\\tif err != nil {\\n   666→\\t\\tenv.T.Fatalf(\\\"rewind --list failed: %v\\\\nOutput: %s\\\", err, output)\\n   667→\\t}\\n   668→\\n   669→\\t// Parse JSON output\\n   670→\\tvar jsonPoints []struct {\\n   671→\\t\\tID               string `json:\\\"id\\\"`\\n   672→\\t\\tMessage          string `json:\\\"message\\\"`\\n   673→\\t\\tMetadataDir      string `json:\\\"metadata_dir\\\"`\\n   674→\\t\\tDate             string `json:\\\"date\\\"`\\n   675→\\t\\tIsTaskCheckpoint bool   `json:\\\"is_task_checkpoint\\\"`\\n   676→\\t\\tToolUseID        string `json:\\\"tool_use_id\\\"`\\n   677→\\t\\tIsLogsOnly       bool   `json:\\\"is_logs_only\\\"`\\n   678→\\t\\tCondensationID   string `json:\\\"condensation_id\\\"`\\n   679→\\t}\\n   680→\\n   681→\\tif err := json.Unmarshal(output, &jsonPoints); err != nil {\\n   682→\\t\\tenv.T.Fatalf(\\\"failed to parse rewind points: %v\\\\nOutput: %s\\\", err, output)\\n   683→\\t}\\n   684→\\n   685→\\tpoints := make([]RewindPoint, len(jsonPoints))\\n   686→\\tfor i, jp := range jsonPoints {\\n   687→\\t\\tdate, _ := time.Parse(time.RFC3339, jp.Date)\\n   688→\\t\\tpoints[i] = RewindPoint{\\n   689→\\t\\t\\tID:               jp.ID,\\n   690→\\t\\t\\tMessage:          jp.Message,\\n   691→\\t\\t\\tMetadataDir:      jp.MetadataDir,\\n   692→\\t\\t\\tDate:             date,\\n   693→\\t\\t\\tIsTaskCheckpoint: jp.IsTaskCheckpoint,\\n   694→\\t\\t\\tToolUseID:        jp.ToolUseID,\\n   695→\\t\\t\\tIsLogsOnly:       jp.IsLogsOnly,\\n   696→\\t\\t\\tCondensationID:   jp.CondensationID,\\n   697→\\t\\t}\\n   698→\\t}\\n   699→\\n   700→\\treturn points\\n   701→}\\n   702→\\n   703→// Rewind performs a rewind to the specified commit ID using the CLI.\\n   704→func (env *TestEnv) Rewind(commitID string) error {\\n   705→\\tenv.T.Helper()\\n   706→\\n   707→\\t// Run rewind --to <commitID> using the shared binary\\n   708→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID)\\n   709→\\tcmd.Dir = env.RepoDir\\n   710→\\tcmd.Env = env.cliEnv()\\n   711→\\n   712→\\toutput, err := cmd.CombinedOutput()\\n   713→\\tif err != nil {\\n   714→\\t\\treturn errors.New(\\\"rewind failed: \\\" + string(output))\\n   715→\\t}\\n   716→\\n   717→\\tenv.T.Logf(\\\"Rewind output: %s\\\", output)\\n   718→\\treturn nil\\n   719→}\\n   720→\\n   721→// RewindLogsOnly performs a logs-only rewind using the CLI.\\n   722→// This restores session logs without modifying the working directory.\\n   723→func (env *TestEnv) RewindLogsOnly(commitID string) error {\\n   724→\\tenv.T.Helper()\\n   725→\\n   726→\\t// Run rewind --to <commitID> --logs-only using the shared binary\\n   727→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID, \\\"--logs-only\\\")\\n   728→\\tcmd.Dir = env.RepoDir\\n   729→\\tcmd.Env = env.cliEnv()\\n   730→\\n   731→\\toutput, err := cmd.CombinedOutput()\\n   732→\\tif err != nil {\\n   733→\\t\\treturn errors.New(\\\"rewind logs-only failed: \\\" + string(output))\\n   734→\\t}\\n   735→\\n   736→\\tenv.T.Logf(\\\"Rewind logs-only output: %s\\\", output)\\n   737→\\treturn nil\\n   738→}\\n   739→\\n   740→// RewindReset performs a reset rewind using the CLI.\\n   741→// This resets the branch to the specified commit (destructive).\\n   742→func (env *TestEnv) RewindReset(commitID string) error {\\n   743→\\tenv.T.Helper()\\n   744→\\n   745→\\t// Run rewind --to <commitID> --reset using the shared binary\\n   746→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID, \\\"--reset\\\")\\n   747→\\tcmd.Dir = env.RepoDir\\n   748→\\tcmd.Env = env.cliEnv()\\n   749→\\n   750→\\toutput, err := cmd.CombinedOutput()\\n   751→\\tif err != nil {\\n   752→\\t\\treturn errors.New(\\\"rewind reset failed: \\\" + string(output))\\n   753→\\t}\\n   754→\\n   755→\\tenv.T.Logf(\\\"Rewind reset output: %s\\\", output)\\n   756→\\treturn nil\\n   757→}\\n   758→\\n   759→// BranchExists checks if a branch exists in the repository.\\n   760→func (env *TestEnv) BranchExists(branchName string) bool {\\n   761→\\tenv.T.Helper()\\n   762→\\n   763→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   764→\\tif err != nil {\\n   765→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   766→\\t}\\n   767→\\n   768→\\trefs, err := repo.References()\\n   769→\\tif err != nil {\\n   770→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   771→\\t}\\n   772→\\n   773→\\tfound := false\\n   774→\\t_ = refs.ForEach(func(ref *plumbing.Reference) error {\\n   775→\\t\\tif ref.Name().Short() == branchName {\\n   776→\\t\\t\\tfound = true\\n   777→\\t\\t}\\n   778→\\t\\treturn nil\\n   779→\\t})\\n   780→\\n   781→\\treturn found\\n   782→}\\n   783→\\n   784→// GetCommitMessage returns the commit message for the given commit hash.\\n   785→func (env *TestEnv) GetCommitMessage(hash string) string {\\n   786→\\tenv.T.Helper()\\n   787→\\n   788→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   789→\\tif err != nil {\\n   790→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   791→\\t}\\n   792→\\n   793→\\tcommitHash := plumbing.NewHash(hash)\\n   794→\\tcommit, err := repo.CommitObject(commitHash)\\n   795→\\tif err != nil {\\n   796→\\t\\tenv.T.Fatalf(\\\"failed to get commit %s: %v\\\", hash, err)\\n   797→\\t}\\n   798→\\n   799→\\treturn commit.Message\\n   800→}\\n   801→\\n   802→// FileExistsInBranch checks if a file exists in a specific branch's tree.\\n   803→func (env *TestEnv) FileExistsInBranch(branchName, filePath string) bool {\\n   804→\\tenv.T.Helper()\\n   805→\\n   806→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   807→\\tif err != nil {\\n   808→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   809→\\t}\\n   810→\\n   811→\\t// Get the branch reference\\n   812→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   813→\\tif err != nil {\\n   814→\\t\\t// Try as a remote-style ref\\n   815→\\t\\tref, err = repo.Reference(plumbing.ReferenceName(\\\"refs/heads/\\\"+branchName), true)\\n   816→\\t\\tif err != nil {\\n   817→\\t\\t\\treturn false\\n   818→\\t\\t}\\n   819→\\t}\\n   820→\\n   821→\\t// Get the commit\\n   822→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   823→\\tif err != nil {\\n   824→\\t\\treturn false\\n   825→\\t}\\n   826→\\n   827→\\t// Get the tree\\n   828→\\ttree, err := commit.Tree()\\n   829→\\tif err != nil {\\n   830→\\t\\treturn false\\n   831→\\t}\\n   832→\\n   833→\\t// Check if file exists\\n   834→\\t_, err = tree.File(filePath)\\n   835→\\treturn err == nil\\n   836→}\\n   837→\\n   838→// ReadFileFromBranch reads a file's content from a specific branch's tree.\\n   839→// Returns the content and true if found, empty string and false if not found.\\n   840→func (env *TestEnv) ReadFileFromBranch(branchName, filePath string) (string, bool) {\\n   841→\\tenv.T.Helper()\\n   842→\\n   843→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   844→\\tif err != nil {\\n   845→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   846→\\t}\\n   847→\\n   848→\\t// Get the branch reference\\n   849→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   850→\\tif err != nil {\\n   851→\\t\\t// Try as a remote-style ref\\n   852→\\t\\tref, err = repo.Reference(plumbing.ReferenceName(\\\"refs/heads/\\\"+branchName), true)\\n   853→\\t\\tif err != nil {\\n   854→\\t\\t\\treturn \\\"\\\", false\\n   855→\\t\\t}\\n   856→\\t}\\n   857→\\n   858→\\t// Get the commit\\n   859→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   860→\\tif err != nil {\\n   861→\\t\\treturn \\\"\\\", false\\n   862→\\t}\\n   863→\\n   864→\\t// Get the tree\\n   865→\\ttree, err := commit.Tree()\\n   866→\\tif err != nil {\\n   867→\\t\\treturn \\\"\\\", false\\n   868→\\t}\\n   869→\\n   870→\\t// Get the file\\n   871→\\tfile, err := tree.File(filePath)\\n   872→\\tif err != nil {\\n   873→\\t\\treturn \\\"\\\", false\\n   874→\\t}\\n   875→\\n   876→\\t// Get the content\\n   877→\\tcontent, err := file.Contents()\\n   878→\\tif err != nil {\\n   879→\\t\\treturn \\\"\\\", false\\n   880→\\t}\\n   881→\\n   882→\\treturn content, true\\n   883→}\\n   884→\\n   885→// GetLatestCommitMessageOnBranch returns the commit message of the latest commit on the given branch.\\n   886→func (env *TestEnv) GetLatestCommitMessageOnBranch(branchName string) string {\\n   887→\\tenv.T.Helper()\\n   888→\\n   889→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   890→\\tif err != nil {\\n   891→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   892→\\t}\\n   893→\\n   894→\\t// Get the branch reference\\n   895→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   896→\\tif err != nil {\\n   897→\\t\\tenv.T.Fatalf(\\\"failed to get branch %s reference: %v\\\", branchName, err)\\n   898→\\t}\\n   899→\\n   900→\\t// Get the commit\\n   901→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   902→\\tif err != nil {\\n   903→\\t\\tenv.T.Fatalf(\\\"failed to get commit object: %v\\\", err)\\n   904→\\t}\\n   905→\\n   906→\\treturn commit.Message\\n   907→}\\n   908→\\n   909→// GitCommitWithShadowHooks stages and commits files, simulating the prepare-commit-msg\\n   910→// and post-commit hooks as a human (with TTY). This is the default for tests.\\n   911→func (env *TestEnv) GitCommitWithShadowHooks(message string, files ...string) {\\n   912→\\tenv.T.Helper()\\n   913→\\tenv.gitCommitWithShadowHooks(message, true, files...)\\n   914→}\\n   915→\\n   916→// GitCommitWithShadowHooksAsAgent is like GitCommitWithShadowHooks but simulates\\n   917→// an agent commit (no TTY). This triggers the fast path in PrepareCommitMsg that\\n   918→// skips content detection and interactive prompts for ACTIVE sessions.\\n   919→func (env *TestEnv) GitCommitWithShadowHooksAsAgent(message string, files ...string) {\\n   920→\\tenv.T.Helper()\\n   921→\\tenv.gitCommitWithShadowHooks(message, false, files...)\\n   922→}\\n   923→\\n   924→// gitCommitWithShadowHooks is the shared implementation for committing with shadow hooks.\\n   925→// When simulateTTY is true, sets ENTIRE_TEST_TTY=1 to simulate a human at the terminal.\\n   926→// When false, filters it out to simulate an agent subprocess (no controlling terminal).\\n   927→func (env *TestEnv) gitCommitWithShadowHooks(message string, simulateTTY bool, files ...string) {\\n   928→\\tenv.T.Helper()\\n   929→\\n   930→\\t// Stage files using go-git\\n   931→\\tfor _, file := range files {\\n   932→\\t\\tenv.GitAdd(file)\\n   933→\\t}\\n   934→\\n   935→\\t// Create a temp file for the commit message (prepare-commit-msg hook modifies this)\\n   936→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n   937→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n   938→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n   939→\\t}\\n   940→\\n   941→\\t// Run prepare-commit-msg hook using the shared binary.\\n   942→\\t// Pass source=\\\"message\\\" to match real `git commit -m` behavior.\\n   943→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile, \\\"message\\\")\\n   944→\\tprepCmd.Dir = env.RepoDir\\n   945→\\tif simulateTTY {\\n   946→\\t\\t// Simulate human at terminal: ENTIRE_TEST_TTY=1 makes hasTTY() return true\\n   947→\\t\\t// and askConfirmTTY() return defaultYes without reading from /dev/tty.\\n   948→\\t\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n   949→\\t} else {\\n   950→\\t\\t// Simulate agent: ENTIRE_TEST_TTY=0 makes hasTTY() return false,\\n   951→\\t\\t// triggering the fast path that adds trailers for ACTIVE sessions.\\n   952→\\t\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   953→\\t}\\n   954→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n   955→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n   956→\\t\\t// Don't fail - hook may silently succeed\\n   957→\\t}\\n   958→\\n   959→\\t// Read the modified message\\n   960→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n   961→\\tif err != nil {\\n   962→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n   963→\\t}\\n   964→\\n   965→\\t// Create the commit using go-git with the modified message\\n   966→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   967→\\tif err != nil {\\n   968→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   969→\\t}\\n   970→\\n   971→\\tworktree, err := repo.Worktree()\\n   972→\\tif err != nil {\\n   973→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   974→\\t}\\n   975→\\n   976→\\t_, err = worktree.Commit(string(modifiedMsg), &git.CommitOptions{\\n   977→\\t\\tAuthor: &object.Signature{\\n   978→\\t\\t\\tName:  \\\"Test User\\\",\\n   979→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   980→\\t\\t\\tWhen:  time.Now(),\\n   981→\\t\\t},\\n   982→\\t})\\n   983→\\tif err != nil {\\n   984→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   985→\\t}\\n   986→\\n   987→\\t// Run post-commit hook using the shared binary\\n   988→\\t// This triggers condensation if the commit has an Entire-Checkpoint trailer\\n   989→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n   990→\\tpostCmd.Dir = env.RepoDir\\n   991→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n   992→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n   993→\\t\\t// Don't fail - hook may silently succeed\\n   994→\\t}\\n   995→}\\n   996→\\n   997→// GitCommitAmendWithShadowHooks amends the last commit with shadow hooks.\\n   998→// This simulates `git commit --amend` with the prepare-commit-msg and post-commit hooks.\\n   999→// The prepare-commit-msg hook is called with \\\"commit\\\" source to indicate an amend.\\n  1000→func (env *TestEnv) GitCommitAmendWithShadowHooks(message string, files ...string) {\\n  1001→\\tenv.T.Helper()\\n  1002→\\n  1003→\\t// Stage any additional files\\n  1004→\\tfor _, file := range files {\\n  1005→\\t\\tenv.GitAdd(file)\\n  1006→\\t}\\n  1007→\\n  1008→\\t// Write commit message to temp file\\n  1009→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n  1010→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n  1011→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n  1012→\\t}\\n  1013→\\n  1014→\\t// Run prepare-commit-msg hook with \\\"commit\\\" source (indicates amend).\\n  1015→\\t// Set ENTIRE_TEST_TTY=1 to simulate human (amend is always a human operation).\\n  1016→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile, \\\"commit\\\")\\n  1017→\\tprepCmd.Dir = env.RepoDir\\n  1018→\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n  1019→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n  1020→\\t\\tenv.T.Logf(\\\"prepare-commit-msg (amend) output: %s\\\", output)\\n  1021→\\t}\\n  1022→\\n  1023→\\t// Read the modified message\\n  1024→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n  1025→\\tif err != nil {\\n  1026→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n  1027→\\t}\\n  1028→\\n  1029→\\t// Amend the commit using go-git\\n  1030→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1031→\\tif err != nil {\\n  1032→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1033→\\t}\\n  1034→\\n  1035→\\tworktree, err := repo.Worktree()\\n  1036→\\tif err != nil {\\n  1037→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n  1038→\\t}\\n  1039→\\n  1040→\\t_, err = worktree.Commit(string(modifiedMsg), &git.CommitOptions{\\n  1041→\\t\\tAuthor: &object.Signature{\\n  1042→\\t\\t\\tName:  \\\"Test User\\\",\\n  1043→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n  1044→\\t\\t\\tWhen:  time.Now(),\\n  1045→\\t\\t},\\n  1046→\\t\\tAmend: true,\\n  1047→\\t})\\n  1048→\\tif err != nil {\\n  1049→\\t\\tenv.T.Fatalf(\\\"failed to amend commit: %v\\\", err)\\n  1050→\\t}\\n  1051→\\n  1052→\\t// Run post-commit hook\\n  1053→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n  1054→\\tpostCmd.Dir = env.RepoDir\\n  1055→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n  1056→\\t\\tenv.T.Logf(\\\"post-commit (amend) output: %s\\\", output)\\n  1057→\\t}\\n  1058→}\\n  1059→\\n  1060→// GitCommitWithTrailerRemoved stages and commits files, simulating what happens when\\n  1061→// a user removes the Entire-Checkpoint trailer during commit message editing.\\n  1062→// This tests the opt-out behavior where removing the trailer skips condensation.\\n  1063→func (env *TestEnv) GitCommitWithTrailerRemoved(message string, files ...string) {\\n  1064→\\tenv.T.Helper()\\n  1065→\\n  1066→\\t// Stage files using go-git\\n  1067→\\tfor _, file := range files {\\n  1068→\\t\\tenv.GitAdd(file)\\n  1069→\\t}\\n  1070→\\n  1071→\\t// Create a temp file for the commit message (prepare-commit-msg hook modifies this)\\n  1072→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n  1073→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n  1074→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n  1075→\\t}\\n  1076→\\n  1077→\\t// Run prepare-commit-msg hook using the shared binary.\\n  1078→\\t// Set ENTIRE_TEST_TTY=1 to simulate human (this tests the editor flow where\\n  1079→\\t// the user removes the trailer before committing).\\n  1080→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile)\\n  1081→\\tprepCmd.Dir = env.RepoDir\\n  1082→\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n  1083→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n  1084→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n  1085→\\t}\\n  1086→\\n  1087→\\t// Read the modified message (with trailer added by hook)\\n  1088→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n  1089→\\tif err != nil {\\n  1090→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n  1091→\\t}\\n  1092→\\n  1093→\\t// REMOVE the Entire-Checkpoint trailer (simulating user editing the message)\\n  1094→\\tlines := strings.Split(string(modifiedMsg), \\\"\\\\n\\\")\\n  1095→\\tvar cleanedLines []string\\n  1096→\\tfor _, line := range lines {\\n  1097→\\t\\t// Skip the trailer and the comments about it\\n  1098→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n  1099→\\t\\t\\tcontinue\\n  1100→\\t\\t}\\n  1101→\\t\\tif strings.Contains(line, \\\"Remove the Entire-Checkpoint trailer\\\") {\\n  1102→\\t\\t\\tcontinue\\n  1103→\\t\\t}\\n  1104→\\t\\tif strings.Contains(line, \\\"trailer will be added to your next commit\\\") {\\n  1105→\\t\\t\\tcontinue\\n  1106→\\t\\t}\\n  1107→\\t\\tcleanedLines = append(cleanedLines, line)\\n  1108→\\t}\\n  1109→\\tcleanedMsg := strings.TrimRight(strings.Join(cleanedLines, \\\"\\\\n\\\"), \\\"\\\\n\\\") + \\\"\\\\n\\\"\\n  1110→\\n  1111→\\t// Create the commit using go-git with the cleaned message (no trailer)\\n  1112→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1113→\\tif err != nil {\\n  1114→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1115→\\t}\\n  1116→\\n  1117→\\tworktree, err := repo.Worktree()\\n  1118→\\tif err != nil {\\n  1119→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\