niHookInRepoDir(hookName, inputJSON)\\n   535→}\\n   536→\\n   537→func (r *GeminiHookRunner) runGeminiHookInRepoDir(hookName string, inputJSON []byte) error {\\n   538→\\t// Run using the shared test binary\\n   539→\\t// Command structure: entire hooks gemini <hook-name>\\n   540→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n   541→\\tcmd.Dir = r.RepoDir\\n   542→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   543→\\tcmd.Env = append(os.Environ(),\\n   544→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n   545→\\t)\\n   546→\\n   547→\\toutput, err := cmd.CombinedOutput()\\n   548→\\tif err != nil {\\n   549→\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n   550→\\t\\t\\thookName, err, inputJSON, output)\\n   551→\\t}\\n   552→\\n   553→\\tr.T.Logf(\\\"Gemini hook %s output: %s\\\", hookName, output)\\n   554→\\treturn nil\\n   555→}\\n   556→\\n   557→// runGeminiHookWithOutput runs a Gemini hook and returns both stdout and stderr separately.\\n   558→func (r *GeminiHookRunner) runGeminiHookWithOutput(hookName string, inputJSON []byte) HookOutput {\\n   559→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n   560→\\tcmd.Dir = r.RepoDir\\n   561→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   562→\\tcmd.Env = append(os.Environ(),\\n   563→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n   564→\\t)\\n   565→\\n   566→\\tvar stdout, stderr bytes.Buffer\\n   567→\\tcmd.Stdout = &stdout\\n   568→\\tcmd.Stderr = &stderr\\n   569→\\n   570→\\terr := cmd.Run()\\n   571→\\treturn HookOutput{\\n   572→\\t\\tStdout: stdout.Bytes(),\\n   573→\\t\\tStderr: stderr.Bytes(),\\n   574→\\t\\tErr:    err,\\n   575→\\t}\\n   576→}\\n   577→\\n   578→// SimulateGeminiBeforeAgent simulates the BeforeAgent hook for Gemini CLI.\\n   579→// This is equivalent to Claude Code's UserPromptSubmit.\\n   580→func (r *GeminiHookRunner) SimulateGeminiBeforeAgent(sessionID string) error {\\n   581→\\tr.T.Helper()\\n   582→\\n   583→\\tinput := map[string]string{\\n   584→\\t\\t\\\"session_id\\\":      sessionID,\\n   585→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   586→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   587→\\t\\t\\\"hook_event_name\\\": \\\"BeforeAgent\\\",\\n   588→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   589→\\t\\t\\\"prompt\\\":          \\\"test prompt\\\",\\n   590→\\t}\\n   591→\\n   592→\\treturn r.runGeminiHookWithInput(\\\"before-agent\\\", input)\\n   593→}\\n   594→\\n   595→// SimulateGeminiBeforeAgentWithOutput simulates the BeforeAgent hook and returns the output.\\n   596→func (r *GeminiHookRunner) SimulateGeminiBeforeAgentWithOutput(sessionID string) HookOutput {\\n   597→\\tr.T.Helper()\\n   598→\\n   599→\\tinput := map[string]string{\\n   600→\\t\\t\\\"session_id\\\":      sessionID,\\n   601→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   602→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   603→\\t\\t\\\"hook_event_name\\\": \\\"BeforeAgent\\\",\\n   604→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   605→\\t\\t\\\"prompt\\\":          \\\"test prompt\\\",\\n   606→\\t}\\n   607→\\n   608→\\tinputJSON, err := json.Marshal(input)\\n   609→\\tif err != nil {\\n   610→\\t\\treturn HookOutput{Err: fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)}\\n   611→\\t}\\n   612→\\n   613→\\treturn r.runGeminiHookWithOutput(\\\"before-agent\\\", inputJSON)\\n   614→}\\n   615→\\n   616→// SimulateGeminiAfterAgent simulates the AfterAgent hook for Gemini CLI.\\n   617→// This is the primary checkpoint creation hook, equivalent to Claude Code's Stop hook.\\n   618→func (r *GeminiHookRunner) SimulateGeminiAfterAgent(sessionID, transcriptPath string) error {\\n   619→\\tr.T.Helper()\\n   620→\\n   621→\\tinput := map[string]string{\\n   622→\\t\\t\\\"session_id\\\":      sessionID,\\n   623→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   624→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   625→\\t\\t\\\"hook_event_name\\\": \\\"AfterAgent\\\",\\n   626→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   627→\\t}\\n   628→\\n   629→\\treturn r.runGeminiHookWithInput(\\\"after-agent\\\", input)\\n   630→}\\n   631→\\n   632→// SimulateGeminiSessionEnd simulates the SessionEnd hook for Gemini CLI.\\n   633→// This is a cleanup/fallback hook that fires on explicit exit.\\n   634→func (r *GeminiHookRunner) SimulateGeminiSessionEnd(sessionID, transcriptPath string) error {\\n   635→\\tr.T.Helper()\\n   636→\\n   637→\\tinput := map[string]string{\\n   638→\\t\\t\\\"session_id\\\":      sessionID,\\n   639→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   640→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   641→\\t\\t\\\"hook_event_name\\\": \\\"SessionEnd\\\",\\n   642→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   643→\\t\\t\\\"reason\\\":          \\\"exit\\\",\\n   644→\\t}\\n   645→\\n   646→\\treturn r.runGeminiHookWithInput(\\\"session-end\\\", input)\\n   647→}\\n   648→\\n   649→// GeminiSession represents a simulated Gemini CLI session.\\n   650→type GeminiSession struct {\\n   651→\\tID             string // Raw model session ID (e.g., \\\"gemini-session-1\\\")\\n   652→\\tTranscriptPath string\\n   653→\\tenv            *TestEnv\\n   654→}\\n   655→\\n   656→// NewGeminiSession creates a new simulated Gemini session.\\n   657→func (env *TestEnv) NewGeminiSession() *GeminiSession {\\n   658→\\tenv.T.Helper()\\n   659→\\n   660→\\tenv.SessionCounter++\\n   661→\\tsessionID := fmt.Sprintf(\\\"gemini-session-%d\\\", env.SessionCounter)\\n   662→\\ttranscriptPath := filepath.Join(env.RepoDir, \\\".entire\\\", \\\"tmp\\\", sessionID+\\\".json\\\")\\n   663→\\n   664→\\treturn &GeminiSession{\\n   665→\\t\\tID:             sessionID,\\n   666→\\t\\tTranscriptPath: transcriptPath,\\n   667→\\t\\tenv:            env,\\n   668→\\t}\\n   669→}\\n   670→\\n   671→// CreateGeminiTranscript creates a Gemini JSON transcript file for the session.\\n   672→func (s *GeminiSession) CreateGeminiTranscript(prompt string, changes []FileChange) string {\\n   673→\\t// Build Gemini-format transcript (JSON, not JSONL)\\n   674→\\tmessages := []map[string]interface{}{\\n   675→\\t\\t{\\n   676→\\t\\t\\t\\\"type\\\":    \\\"user\\\",\\n   677→\\t\\t\\t\\\"content\\\": prompt,\\n   678→\\t\\t},\\n   679→\\t\\t{\\n   680→\\t\\t\\t\\\"type\\\":    \\\"assistant\\\",\\n   681→\\t\\t\\t\\\"content\\\": \\\"I'll help you with that.\\\",\\n   682→\\t\\t},\\n   683→\\t}\\n   684→\\n   685→\\tfor _, change := range changes {\\n   686→\\t\\tmessages = append(messages, map[string]interface{}{\\n   687→\\t\\t\\t\\\"type\\\": \\\"tool_use\\\",\\n   688→\\t\\t\\t\\\"name\\\": \\\"write_file\\\",\\n   689→\\t\\t\\t\\\"input\\\": map[string]string{\\n   690→\\t\\t\\t\\t\\\"path\\\":    change.Path,\\n   691→\\t\\t\\t\\t\\\"content\\\": change.Content,\\n   692→\\t\\t\\t},\\n   693→\\t\\t})\\n   694→\\t\\tmessages = append(messages, map[string]interface{}{\\n   695→\\t\\t\\t\\\"type\\\":   \\\"tool_result\\\",\\n   696→\\t\\t\\t\\\"output\\\": \\\"File written successfully\\\",\\n   697→\\t\\t})\\n   698→\\t}\\n   699→\\n   700→\\tmessages = append(messages, map[string]interface{}{\\n   701→\\t\\t\\\"type\\\":    \\\"assistant\\\",\\n   702→\\t\\t\\\"content\\\": \\\"Done!\\\",\\n   703→\\t})\\n   704→\\n   705→\\ttranscript := map[string]interface{}{\\n   706→\\t\\t\\\"sessionId\\\": s.ID,\\n   707→\\t\\t\\\"messages\\\":  messages,\\n   708→\\t}\\n   709→\\n   710→\\t// Ensure directory exists\\n   711→\\tif err := os.MkdirAll(filepath.Dir(s.TranscriptPath), 0o755); err != nil {\\n   712→\\t\\ts.env.T.Fatalf(\\\"failed to create transcript dir: %v\\\", err)\\n   713→\\t}\\n   714→\\n   715→\\t// Write transcript\\n   716→\\tdata, err := json.MarshalIndent(transcript, \\\"\\\", \\\"  \\\")\\n   717→\\tif err != nil {\\n   718→\\t\\ts.env.T.Fatalf(\\\"failed to marshal transcript: %v\\\", err)\\n   719→\\t}\\n   720→\\tif err := os.WriteFile(s.TranscriptPath, data, 0o644); err != nil {\\n   721→\\t\\ts.env.T.Fatalf(\\\"failed to write transcript: %v\\\", err)\\n   722→\\t}\\n   723→\\n   724→\\treturn s.TranscriptPath\\n   725→}\\n   726→\\n   727→// SimulateGeminiBeforeAgent is a convenience method on TestEnv.\\n   728→func (env *TestEnv) SimulateGeminiBeforeAgent(sessionID string) error {\\n   729→\\tenv.T.Helper()\\n   730→\\trunner := NewGeminiHookRunner(env.RepoDir, env.GeminiProjectDir, env.T)\\n   731→\\treturn runner.SimulateGeminiBeforeAgent(sessionID)\\n   732→}\\n   733→\\n   734→// SimulateGeminiBeforeAgentWithOutput is a convenience method on TestEnv.\\n   735→func (env *TestEnv) SimulateGeminiBeforeAgentWithOutput(sessionID string) HookOutput {\\n   736→\\tenv.T.Helper()\\n   737→\\trunner := NewGeminiHookRunner(env.RepoDir, env.GeminiProjectDir, env.T)\\n   738→\\treturn runner.SimulateGeminiBeforeAgentWithOutput(sessionID)\\n   739→}\\n   740→\\n   741→// SimulateGeminiAfterAgent is a convenience method on TestEnv.\\n   742→func (env *TestEnv) SimulateGeminiAfterAgent(sessionID, transcriptPath string) error {\\n   743→\\tenv.T.Helper()\\n   744→\\trunner := NewGeminiHookRunner(env.RepoDir, env.GeminiProjectDir, env.T)\\n   745→\\treturn runner.SimulateGeminiAfterAgent(sessionID, transcriptPath)\\n   746→}\\n   747→\\n   748→// SimulateGeminiSessionEnd is a convenience method on TestEnv.\\n   749→func (env *TestEnv) SimulateGeminiSessionEnd(sessionID, transcriptPath string) error {\\n   750→\\tenv.T.Helper()\\n   751→\\trunner := NewGeminiHookRunner(env.RepoDir, env.GeminiProjectDir, env.T)\\n   752→\\treturn runner.SimulateGeminiSessionEnd(sessionID, transcriptPath)\\n   753→}\\n   754→\"}]},\"uuid\":\"0254392b-bc3a-4491-89e3-c938f927a62b\",\"timestamp\":\"2026-02-19T21:45:10.252Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Design integration tests for Factory AI Droid agent in `cmd/entire/cli/integration_test/`, mirroring the patterns used for Claude Code and Gemini CLI.\\n\\n## Current State\\n\\n### What exists:\\n- `agent_test.go` — Has tests for Claude Code (detection, hook installation, session ops, helpers) and Gemini CLI (detection, hook installation, session ops, helpers). No factoryaidroid tests.\\n- `agent_strategy_test.go` — Tests agent+strategy composition. Currently only tests Claude Code via `RunForAllStrategies`. No factoryaidroid equivalents.\\n- `setup_gemini_hooks_test.go` — Smoke tests for `entire enable --agent gemini` (adds hooks, preserves settings).\\n- `hooks.go` — Has `HookRunner` (claude-code) and `GeminiHookRunner` with simulation methods. No `FactoryDroidHookRunner`.\\n\\n### Factory AI Droid agent capabilities:\\n- **Registered as** `\\\"factoryai-droid\\\"` (`agent.AgentNameFactoryAIDroid`)\\n- **Implements**: `agent.Agent`, `agent.HookSupport`, `agent.HookHandler`, `agent.TranscriptAnalyzer`, `agent.TokenCalculator`, `agent.SubagentAwareExtractor`\\n- **HookSupport**: `InstallHooks`, `UninstallHooks`, `AreHooksInstalled` (writes to `.factory/settings.json`)\\n- **InstallHooks** installs 7 hooks: SessionStart, SessionEnd, Stop, UserPromptSubmit, PreToolUse[Task], PostToolUse[Task], PreCompact\\n- **Hook command format**: `entire hooks factoryai-droid <verb>` (prod) or `go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid <verb>` (localDev)\\n- **Permissions deny rule**: `Read(./.entire/metadata/**)`\\n- **ParseHookInput**: Maps `session_id` → `SessionID`, `transcript_path` → `SessionRef`\\n- **Transcript format**: JSONL (same as Claude Code, NOT JSON like Gemini)\\n- **Session stubs**: GetSessionDir, ReadSession, WriteSession all return \\\"not implemented\\\" errors\\n- **FormatResumeCommand**: `\\\"droid --session-id \\\" + sessionID`\\n- **DetectPresence**: checks for `.factory` directory\\n- **ProtectedDirs**: `[\\\".factory\\\"]`\\n- **GetHookConfigPath**: `.factory/settings.json`\\n\\n### Key differences from Gemini:\\n- Uses JSONL transcript format (like Claude Code), not JSON\\n- Hook structure uses `FactoryHookMatcher` with `matcher` + `hooks` array (similar to Claude but with Factory-specific hook types like `PreCompact`)\\n- ReadSession/WriteSession/GetSessionDir are not yet implemented (stubs that return errors)\\n- Hook runner commands go to `entire hooks factoryai-droid <verb>` instead of `entire hooks gemini <verb>`\\n\\n## What to create:\\n\\n### 1. Add to `agent_test.go` (following existing patterns):\\n\\n**TestFactoryAIDroidAgentDetection** — Mirror of `TestGeminiCLIAgentDetection`\\n- Subtest: \\\"factoryai-droid agent is registered\\\" — `agent.List()` contains \\\"factoryai-droid\\\" \\n- Subtest: \\\"factoryai-droid detects presence when .factory exists\\\" — os.Chdir, create `.factory` dir, DetectPresence returns true\\n\\n**TestFactoryAIDroidHookInstallation** — Mirror of `TestGeminiCLIHookInstallation`  \\n- Subtest: \\\"installs all required hooks\\\" — InstallHooks(false, false) returns 7, AreHooksInstalled() true, settings.json contains all hook types\\n- Subtest: \\\"idempotent - second install returns 0\\\"\\n- Subtest: \\\"localDev mode uses go run\\\" — settings.json contains \\\"go run\\\" and \\\"${FACTORY_PROJECT_DIR}\\\"\\n- Subtest: \\\"production mode uses entire binary\\\" — settings.json contains \\\"entire hooks factoryai-droid\\\"\\n- Subtest: \\\"force flag reinstalls hooks\\\" — force=true returns 7 after initial install\\n- Subtest: \\\"adds permissions.deny rule\\\" — settings.json has `Read(./.entire/metadata/**)`\\n\\n**TestFactoryAIDroidHelperMethods** — Mirror of `TestGeminiCLIHelperMethods`\\n- Subtest: \\\"FormatResumeCommand returns droid --session-id\\\"\\n- Subtest: \\\"GetHookConfigPath returns .factory/settings.json\\\"\\n\\n**TestFactoryAIDroidSessionStubs** — Unique to Factory AI Droid (since ReadSession/WriteSession are stubs)\\n- Subtest: \\\"ReadSession returns not-implemented error\\\"\\n- Subtest: \\\"WriteS