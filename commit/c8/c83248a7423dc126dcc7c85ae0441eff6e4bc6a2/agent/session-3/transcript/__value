 143→\\tag := &FactoryAIDroidAgent{}\\n   144→\\tcontent := []byte(`{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"hello\\\"}`)\\n   145→\\n   146→\\tchunks, err := ag.ChunkTranscript(content, agent.MaxChunkSize)\\n   147→\\tif err != nil {\\n   148→\\t\\tt.Fatalf(\\\"ChunkTranscript() error = %v\\\", err)\\n   149→\\t}\\n   150→\\tif len(chunks) != 1 {\\n   151→\\t\\tt.Errorf(\\\"Expected 1 chunk, got %d\\\", len(chunks))\\n   152→\\t}\\n   153→}\\n   154→\\n   155→func TestChunkTranscript_LargeContent(t *testing.T) {\\n   156→\\tt.Parallel()\\n   157→\\tag := &FactoryAIDroidAgent{}\\n   158→\\n   159→\\t// Build multi-line JSONL that exceeds a small maxSize\\n   160→\\tvar lines []string\\n   161→\\tfor i := range 50 {\\n   162→\\t\\tlines = append(lines, fmt.Sprintf(`{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"message %d %s\\\"}`, i, strings.Repeat(\\\"x\\\", 200)))\\n   163→\\t}\\n   164→\\tcontent := []byte(strings.Join(lines, \\\"\\\\n\\\"))\\n   165→\\n   166→\\tmaxSize := 2000\\n   167→\\tchunks, err := ag.ChunkTranscript(content, maxSize)\\n   168→\\tif err != nil {\\n   169→\\t\\tt.Fatalf(\\\"ChunkTranscript() error = %v\\\", err)\\n   170→\\t}\\n   171→\\tif len(chunks) < 2 {\\n   172→\\t\\tt.Errorf(\\\"Expected at least 2 chunks for large content, got %d\\\", len(chunks))\\n   173→\\t}\\n   174→\\n   175→\\t// Verify each chunk is valid JSONL (each line is valid JSON)\\n   176→\\tfor i, chunk := range chunks {\\n   177→\\t\\tchunkLines := strings.Split(string(chunk), \\\"\\\\n\\\")\\n   178→\\t\\tfor j, line := range chunkLines {\\n   179→\\t\\t\\tif line == \\\"\\\" {\\n   180→\\t\\t\\t\\tcontinue\\n   181→\\t\\t\\t}\\n   182→\\t\\t\\tif line[0] != '{' {\\n   183→\\t\\t\\t\\tt.Errorf(\\\"Chunk %d, line %d doesn't look like JSON: %q\\\", i, j, line[:min(len(line), 40)])\\n   184→\\t\\t\\t}\\n   185→\\t\\t}\\n   186→\\t}\\n   187→}\\n   188→\\n   189→func TestChunkTranscript_RoundTrip(t *testing.T) {\\n   190→\\tt.Parallel()\\n   191→\\tag := &FactoryAIDroidAgent{}\\n   192→\\n   193→\\toriginal := `{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"hello\\\"}\\n   194→{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":\\\"hi there\\\"}\\n   195→{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"thanks\\\"}`\\n   196→\\n   197→\\tchunks, err := ag.ChunkTranscript([]byte(original), 60)\\n   198→\\tif err != nil {\\n   199→\\t\\tt.Fatalf(\\\"ChunkTranscript() error = %v\\\", err)\\n   200→\\t}\\n   201→\\n   202→\\treassembled, err := ag.ReassembleTranscript(chunks)\\n   203→\\tif err != nil {\\n   204→\\t\\tt.Fatalf(\\\"ReassembleTranscript() error = %v\\\", err)\\n   205→\\t}\\n   206→\\n   207→\\tif string(reassembled) != original {\\n   208→\\t\\tt.Errorf(\\\"Round-trip mismatch:\\\\n got: %q\\\\nwant: %q\\\", string(reassembled), original)\\n   209→\\t}\\n   210→}\\n   211→\\n   212→func TestReassembleTranscript_SingleChunk(t *testing.T) {\\n   213→\\tt.Parallel()\\n   214→\\tag := &FactoryAIDroidAgent{}\\n   215→\\n   216→\\tchunk := []byte(`{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"hello\\\"}`)\\n   217→\\tresult, err := ag.ReassembleTranscript([][]byte{chunk})\\n   218→\\tif err != nil {\\n   219→\\t\\tt.Fatalf(\\\"ReassembleTranscript() error = %v\\\", err)\\n   220→\\t}\\n   221→\\tif string(result) != string(chunk) {\\n   222→\\t\\tt.Errorf(\\\"ReassembleTranscript() = %q, want %q\\\", string(result), string(chunk))\\n   223→\\t}\\n   224→}\\n   225→\\n   226→func TestReassembleTranscript_MultipleChunks(t *testing.T) {\\n   227→\\tt.Parallel()\\n   228→\\tag := &FactoryAIDroidAgent{}\\n   229→\\n   230→\\tchunk1 := []byte(`{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"hello\\\"}`)\\n   231→\\tchunk2 := []byte(`{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":\\\"hi\\\"}`)\\n   232→\\n   233→\\tresult, err := ag.ReassembleTranscript([][]byte{chunk1, chunk2})\\n   234→\\tif err != nil {\\n   235→\\t\\tt.Fatalf(\\\"ReassembleTranscript() error = %v\\\", err)\\n   236→\\t}\\n   237→\\n   238→\\texpected := `{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"hello\\\"}\\n   239→{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":\\\"hi\\\"}`\\n   240→\\tif string(result) != expected {\\n   241→\\t\\tt.Errorf(\\\"ReassembleTranscript() = %q, want %q\\\", string(result), expected)\\n   242→\\t}\\n   243→}\\n   244→\\n   245→// --- ParseHookInput tests ---\\n   246→\\n   247→func TestParseHookInput_Valid(t *testing.T) {\\n   248→\\tt.Parallel()\\n   249→\\tag := &FactoryAIDroidAgent{}\\n   250→\\tinput := `{\\\"session_id\\\":\\\"sess-abc\\\",\\\"transcript_path\\\":\\\"/tmp/transcript.jsonl\\\"}`\\n   251→\\n   252→\\tresult, err := ag.ParseHookInput(agent.HookSessionStart, strings.NewReader(input))\\n   253→\\tif err != nil {\\n   254→\\t\\tt.Fatalf(\\\"ParseHookInput() error = %v\\\", err)\\n   255→\\t}\\n   256→\\tif result.SessionID != \\\"sess-abc\\\" {\\n   257→\\t\\tt.Errorf(\\\"SessionID = %q, want %q\\\", result.SessionID, \\\"sess-abc\\\")\\n   258→\\t}\\n   259→\\tif result.SessionRef != \\\"/tmp/transcript.jsonl\\\" {\\n   260→\\t\\tt.Errorf(\\\"SessionRef = %q, want %q\\\", result.SessionRef, \\\"/tmp/transcript.jsonl\\\")\\n   261→\\t}\\n   262→}\\n   263→\\n   264→func TestParseHookInput_Empty(t *testing.T) {\\n   265→\\tt.Parallel()\\n   266→\\tag := &FactoryAIDroidAgent{}\\n   267→\\t_, err := ag.ParseHookInput(agent.HookSessionStart, strings.NewReader(\\\"\\\"))\\n   268→\\tif err == nil {\\n   269→\\t\\tt.Error(\\\"ParseHookInput() should error on empty input\\\")\\n   270→\\t}\\n   271→}\\n   272→\\n   273→func TestParseHookInput_InvalidJSON(t *testing.T) {\\n   274→\\tt.Parallel()\\n   275→\\tag := &FactoryAIDroidAgent{}\\n   276→\\t_, err := ag.ParseHookInput(agent.HookSessionStart, strings.NewReader(\\\"not json\\\"))\\n   277→\\tif err == nil {\\n   278→\\t\\tt.Error(\\\"ParseHookInput() should error on invalid JSON\\\")\\n   279→\\t}\\n   280→}\\n   281→\\n   282→// --- Session stub tests ---\\n   283→\\n   284→func TestGetSessionID(t *testing.T) {\\n   285→\\t