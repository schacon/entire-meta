e, err := repo.Worktree()\\n  1036→\\tif err != nil {\\n  1037→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n  1038→\\t}\\n  1039→\\n  1040→\\t_, err = worktree.Commit(string(modifiedMsg), &git.CommitOptions{\\n  1041→\\t\\tAuthor: &object.Signature{\\n  1042→\\t\\t\\tName:  \\\"Test User\\\",\\n  1043→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n  1044→\\t\\t\\tWhen:  time.Now(),\\n  1045→\\t\\t},\\n  1046→\\t\\tAmend: true,\\n  1047→\\t})\\n  1048→\\tif err != nil {\\n  1049→\\t\\tenv.T.Fatalf(\\\"failed to amend commit: %v\\\", err)\\n  1050→\\t}\\n  1051→\\n  1052→\\t// Run post-commit hook\\n  1053→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n  1054→\\tpostCmd.Dir = env.RepoDir\\n  1055→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n  1056→\\t\\tenv.T.Logf(\\\"post-commit (amend) output: %s\\\", output)\\n  1057→\\t}\\n  1058→}\\n  1059→\\n  1060→// GitCommitWithTrailerRemoved stages and commits files, simulating what happens when\\n  1061→// a user removes the Entire-Checkpoint trailer during commit message editing.\\n  1062→// This tests the opt-out behavior where removing the trailer skips condensation.\\n  1063→func (env *TestEnv) GitCommitWithTrailerRemoved(message string, files ...string) {\\n  1064→\\tenv.T.Helper()\\n  1065→\\n  1066→\\t// Stage files using go-git\\n  1067→\\tfor _, file := range files {\\n  1068→\\t\\tenv.GitAdd(file)\\n  1069→\\t}\\n  1070→\\n  1071→\\t// Create a temp file for the commit message (prepare-commit-msg hook modifies this)\\n  1072→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n  1073→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n  1074→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n  1075→\\t}\\n  1076→\\n  1077→\\t// Run prepare-commit-msg hook using the shared binary.\\n  1078→\\t// Set ENTIRE_TEST_TTY=1 to simulate human (this tests the editor flow where\\n  1079→\\t// the user removes the trailer before committing).\\n  1080→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile)\\n  1081→\\tprepCmd.Dir = env.RepoDir\\n  1082→\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n  1083→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n  1084→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n  1085→\\t}\\n  1086→\\n  1087→\\t// Read the modified message (with trailer added by hook)\\n  1088→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n  1089→\\tif err != nil {\\n  1090→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n  1091→\\t}\\n  1092→\\n  1093→\\t// REMOVE the Entire-Checkpoint trailer (simulating user editing the message)\\n  1094→\\tlines := strings.Split(string(modifiedMsg), \\\"\\\\n\\\")\\n  1095→\\tvar cleanedLines []string\\n  1096→\\tfor _, line := range lines {\\n  1097→\\t\\t// Skip the trailer and the comments about it\\n  1098→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n  1099→\\t\\t\\tcontinue\\n  1100→\\t\\t}\\n  1101→\\t\\tif strings.Contains(line, \\\"Remove the Entire-Checkpoint trailer\\\") {\\n  1102→\\t\\t\\tcontinue\\n  1103→\\t\\t}\\n  1104→\\t\\tif strings.Contains(line, \\\"trailer will be added to your next commit\\\") {\\n  1105→\\t\\t\\tcontinue\\n  1106→\\t\\t}\\n  1107→\\t\\tcleanedLines = append(cleanedLines, line)\\n  1108→\\t}\\n  1109→\\tcleanedMsg := strings.TrimRight(strings.Join(cleanedLines, \\\"\\\\n\\\"), \\\"\\\\n\\\") + \\\"\\\\n\\\"\\n  1110→\\n  1111→\\t// Create the commit using go-git with the cleaned message (no trailer)\\n  1112→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1113→\\tif err != nil {\\n  1114→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1115→\\t}\\n  1116→\\n  1117→\\tworktree, err := repo.Worktree()\\n  1118→\\tif err != nil {\\n  1119→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n  1120→\\t}\\n  1121→\\n  1122→\\t_, err = worktree.Commit(cleanedMsg, &git.CommitOptions{\\n  1123→\\t\\tAuthor: &object.Signature{\\n  1124→\\t\\t\\tName:  \\\"Test User\\\",\\n  1125→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n  1126→\\t\\t\\tWhen:  time.Now(),\\n  1127→\\t\\t},\\n  1128→\\t})\\n  1129→\\tif err != nil {\\n  1130→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n  1131→\\t}\\n  1132→\\n  1133→\\t// Run post-commit hook - since trailer was removed, no condensation should happen\\n  1134→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n  1135→\\tpostCmd.Dir = env.RepoDir\\n  1136→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n  1137→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n  1138→\\t}\\n  1139→}\\n  1140→\\n  1141→// GitRm stages file deletions using git rm.\\n  1142→func (env *TestEnv) GitRm(paths ...string) {\\n  1143→\\tenv.T.Helper()\\n  1144→\\n  1145→\\targs := append([]string{\\\"rm\\\", \\\"--\\\"}, paths...)\\n  1146→\\tcmd := exec.Command(\\\"git\\\", args...)\\n  1147→\\tcmd.Dir = env.RepoDir\\n  1148→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1149→\\t\\tenv.T.Fatalf(\\\"git rm failed: %v\\\\nOutput: %s\\\", err, output)\\n  1150→\\t}\\n  1151→}\\n  1152→\\n  1153→// GitCommitStagedWithShadowHooks commits whatever is already staged (without adding files first),\\n  1154→// running the prepare-commit-msg and post-commit hooks like a real workflow.\\n  1155→// Use this after GitRm or when files are already staged.\\n  1156→func (env *TestEnv) GitCommitStagedWithShadowHooks(message string) {\\n  1157→\\tenv.T.Helper()\\n  1158→\\tenv.gitCommitStagedWithShadowHooks(message, true)\\n  1159→}\\n  1160→\\n  1161→// gitCommitStagedWithShadowHooks is the shared implementation for committing staged changes with hooks.\\n  1162→func (env *TestEnv) gitCommitStagedWithShadowHooks(message string, simulateTTY bool) {\\n  1163→\\tenv.T.Helper()\\n  1164→\\n  1165→\\t// Create a temp file for the commit message (prepare-commit-msg hook modifies this)\\n  1166→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n  1167→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n  1168→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n  1169→\\t}\\n  1170→\\n  1171→\\t// Run prepare-commit-msg hook using the shared binary.\\n  1172→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile, \\\"message\\\")\\n  1173→\\tprepCmd.Dir = env.RepoDir\\n  1174→\\tif simulateTTY {\\n  1175→\\t\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n  1176→\\t} else {\\n  1177→\\t\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n  1178→\\t}\\n  1179→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n  1180→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n  1181→\\t}\\n  1182→\\n  1183→\\t// Read the modified message\\n  1184→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n  1185→\\tif err != nil {\\n  1186→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n  1187→\\t}\\n  1188→\\n  1189→\\t// Create the commit using go-git with the modified message\\n  1190→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1191→\\tif err != nil {\\n  1192→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1193→\\t}\\n  1194→\\n  1195→\\tworktree, err := repo.Worktree()\\n  1196→\\tif err != nil {\\n  1197→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n  1198→\\t}\\n  1199→\\n  1200→\\t_, err = worktree.Commit(string(modifiedMsg), &git.CommitOptions{\\n  1201→\\t\\tAuthor: &object.Signature{\\n  1202→\\t\\t\\tName:  \\\"Test User\\\",\\n  1203→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n  1204→\\t\\t\\tWhen:  time.Now(),\\n  1205→\\t\\t},\\n  1206→\\t})\\n  1207→\\tif err != nil {\\n  1208→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n  1209→\\t}\\n  1210→\\n  1211→\\t// Run post-commit hook\\n  1212→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n  1213→\\tpostCmd.Dir = env.RepoDir\\n  1214→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n  1215→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n  1216→\\t}\\n  1217→}\\n  1218→\\n  1219→// ListBranchesWithPrefix returns all branches that start with the given prefix.\\n  1220→func (env *TestEnv) ListBranchesWithPrefix(prefix string) []string {\\n  1221→\\tenv.T.Helper()\\n  1222→\\n  1223→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1224→\\tif err != nil {\\n  1225→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1226→\\t}\\n  1227→\\n  1228→\\trefs, err := repo.References()\\n  1229→\\tif err != nil {\\n  1230→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n  1231→\\t}\\n  1232→\\n  1233→\\tvar branches []string\\n  1234→\\t_ = refs.ForEach(func(ref *plumbing.Reference) error {\\n  1235→\\t\\tname := ref.Name().Short()\\n  1236→\\t\\tif len(name) >= len(prefix) && name[:len(prefix)] == prefix {\\n  1237→\\t\\t\\tbranches = append(branches, name)\\n  1238→\\t\\t}\\n  1239→\\t\\treturn nil\\n  1240→\\t})\\n  1241→\\n  1242→\\treturn branches\\n  1243→}\\n  1244→\\n  1245→// GetLatestCheckpointID returns the most recent checkpoint ID from the entire/checkpoints/v1 branch.\\n  1246→// This is used by tests that previously extracted the checkpoint ID from commit message trailers.\\n  1247→// Now that active branch commits are clean (no trailers), we get the ID from the sessions branch.\\n  1248→// Fatals if the checkpoint ID cannot be found, with detailed context about what was found.\\n  1249→func (env *TestEnv) GetLatestCheckpointID() string {\\n  1250→\\tenv.T.Helper()\\n  1251→\\n  1252→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1253→\\tif err != nil {\\n  1254→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1255→\\t}\\n  1256→\\n  1257→\\t// Get the entire/checkpoints/v1 branch\\n  1258→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1259→\\tref, err := repo.Reference(refName, true)\\n  1260→\\tif err != nil {\\n  1261→\\t\\tenv.T.Fatalf(\\\"failed to get %s branch: %v\\\", paths.MetadataBranchName, err)\\n  1262→\\t}\\n  1263→\\n  1264→\\tcommit, err := repo.CommitObject(ref.Hash())\\n  1265→\\tif err != nil {\\n  1266→\\t\\tenv.T.Fatalf(\\\"failed to get commit: %v\\\", err)\\n  1267→\\t}\\n  1268→\\n  1269→\\t// Extract checkpoint ID from commit message\\n  1270→\\t// Format: \\\"Checkpoint: <12-hex-char-id>\\\\n\\\\nSession: ...\\\\nStrategy: ...\\\"\\n  1271→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n  1272→\\t\\tline = strings.TrimSpace(line)\\n  1273→\\t\\tif strings.HasPrefix(line, \\\"Checkpoint: \\\") {\\n  1274→\\t\\t\\treturn strings.TrimPrefix(line, \\\"Checkpoint: \\\")\\n  1275→\\t\\t}\\n  1276→\\t}\\n  1277→\\n  1278→\\tenv.T.Fatalf(\\\"could not find checkpoint ID in %s branch commit message:\\\\n%s\\\",\\n  1279→\\t\\tpaths.MetadataBranchName, commit.Message)\\n  1280→\\treturn \\\"\\\"\\n  1281→}\\n  1282→\\n  1283→// TryGetLatestCheckpointID returns the most recent checkpoint ID from the entire/checkpoints/v1 branch.\\n  1284→// Returns empty string if the branch doesn't exist or has no checkpoint commits yet.\\n  1285→// Use this when you need to check if a checkpoint exists without failing the test.\\n  1286→func (env *TestEnv) TryGetLatestCheckpointID() string {\\n  1287→\\tenv.T.Helper()\\n  1288→\\n  1289→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1290→\\tif err != nil {\\n  1291→\\t\\treturn \\\"\\\"\\n  1292→\\t}\\n  1293→\\n  1294→\\t// Get the entire/checkpoints/v1 branch\\n  1295→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1296→\\tref, err := repo.Reference(refName, true)\\n  1297→\\tif err != nil {\\n  1298→\\t\\treturn \\\"\\\"\\n  1299→\\t}\\n  1300→\\n  1301→\\tcommit, err := repo.CommitObject(ref.Hash())\\n  1302→\\tif err != nil {\\n  1303→\\t\\treturn \\\"\\\"\\n  1304→\\t}\\n  1305→\\n  1306→\\t// Extract checkpoint ID from commit message\\n  1307→\\t// Format: \\\"Checkpoint: <12-hex-char-id>\\\\n\\\\nSession: ...\\\\nStrategy: ...\\\"\\n  1308→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n  1309→\\t\\tline = strings.TrimSpace(line)\\n  1310→\\t\\tif strings.HasPrefix(line, \\\"Checkpoint: \\\") {\\n  1311→\\t\\t\\treturn strings.TrimPrefix(line, \\\"Checkpoint: \\\")\\n  1312→\\t\\t}\\n  1313→\\t}\\n  1314→\\n  1315→\\treturn \\\"\\\"\\n  1316→}\\n  1317→\\n  1318→// GetLatestCondensationID is an alias for GetLatestCheckpointID for backwards compatibility.\\n  1319→func (env *TestEnv) GetLatestCondensationID() string {\\n  1320→\\treturn env.GetLatestCheckpointID()\\n  1321→}\\n  1322→\\n  1323→// GetCheckpointIDFromCommitMessage extracts the Entire-Checkpoint trailer from a commit message.\\n  1324→// Returns empty string if no trailer found.\\n  1325→func (env *TestEnv) GetCheckpointIDFromCommitMessage(commitSHA string) string {\\n  1326→\\tenv.T.Helper()\\n  1327→\\n  1328→\\tmsg := env.GetCommitMessage(commitSHA)\\n  1329→\\tcpID, found := trailers.ParseCheckpoint(msg)\\n  1330→\\tif !found {\\n  1331→\\t\\treturn \\\"\\\"\\n  1332→\\t}\\n  1333→\\treturn cpID.String()\\n  1334→}\\n  1335→\\n  1336→// GetLatestCheckpointIDFromHistory walks backwards from HEAD on the active branch\\n  1337→// and returns the checkpoint ID from the first commit that has an Entire-Checkpoint trailer.\\n  1338→// This verifies that condensation actually happened (commit has trailer) without relying\\n  1339→// on timestamp-based matching.\\n  1340→func (env *TestEnv) GetLatestCheckpointIDFromHistory() string {\\n  1341→\\tenv.T.Helper()\\n  1342→\\n  1343→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1344→\\tif err != nil {\\n  1345→\\t\\tenv.T.Fatalf(\\\"failed to open