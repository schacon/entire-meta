33→\\t}\\n   134→\\treturn \\\"\\\", nil\\n   135→}\\n   136→\\n   137→// PrepareTranscript waits for Claude Code's async transcript flush to complete.\\n   138→// Claude writes a hook_progress sentinel entry after flushing all pending writes.\\n   139→func (c *ClaudeCodeAgent) PrepareTranscript(ctx context.Context, sessionRef string) error {\\n   140→\\twaitForTranscriptFlush(ctx, sessionRef, time.Now())\\n   141→\\treturn nil\\n   142→}\\n   143→\\n   144→// CalculateTokenUsage computes token usage from the transcript starting at the given line offset.\\n   145→func (c *ClaudeCodeAgent) CalculateTokenUsage(transcriptData []byte, fromOffset int) (*agent.TokenUsage, error) {\\n   146→\\treturn c.CalculateTotalTokenUsage(transcriptData, fromOffset, \\\"\\\")\\n   147→}\\n   148→\\n   149→// --- Internal hook parsing functions ---\\n   150→\\n   151→func (c *ClaudeCodeAgent) parseSessionStart(stdin io.Reader) (*agent.Event, error) {\\n   152→\\traw, err := agent.ReadAndParseHookInput[sessionStartRaw](stdin)\\n   153→\\tif err != nil {\\n   154→\\t\\treturn nil, err\\n   155→\\t}\\n   156→\\treturn &agent.Event{\\n   157→\\t\\tType:       agent.SessionStart,\\n   158→\\t\\tSessionID:  raw.SessionID,\\n   159→\\t\\tSessionRef: raw.TranscriptPath,\\n   160→\\t\\tTimestamp:  time.Now(),\\n   161→\\t\\tModel:      raw.Model,\\n   162→\\t}, nil\\n   163→}\\n   164→\\n   165→func (c *ClaudeCodeAgent) parseTurnStart(stdin io.Reader) (*agent.Event, error) {\\n   166→\\traw, err := agent.ReadAndParseHookInput[userPromptSubmitRaw](stdin)\\n   167→\\tif err != nil {\\n   168→\\t\\treturn nil, err\\n   169→\\t}\\n   170→\\treturn &agent.Event{\\n   171→\\t\\tType:       agent.TurnStart,\\n   172→\\t\\tSessionID:  raw.SessionID,\\n   173→\\t\\tSessionRef: raw.TranscriptPath,\\n   174→\\t\\tPrompt:     raw.Prompt,\\n   175→\\t\\tTimestamp:  time.Now(),\\n   176→\\t}, nil\\n   177→}\\n   178→\\n   179→func (c *ClaudeCodeAgent) parseTurnEnd(stdin io.Reader) (*agent.Event, error) {\\n 