// This ensures the CLI subprocess and test use consistent paths\\n    65→\\trepoDir := t.TempDir()\\n    66→\\tif resolved, err := filepath.EvalSymlinks(repoDir); err == nil {\\n    67→\\t\\trepoDir = resolved\\n    68→\\t}\\n    69→\\tclaudeProjectDir := t.TempDir()\\n    70→\\tif resolved, err := filepath.EvalSymlinks(claudeProjectDir); err == nil {\\n    71→\\t\\tclaudeProjectDir = resolved\\n    72→\\t}\\n    73→\\tgeminiProjectDir := t.TempDir()\\n    74→\\tif resolved, err := filepath.EvalSymlinks(geminiProjectDir); err == nil {\\n    75→\\t\\tgeminiProjectDir = resolved\\n    76→\\t}\\n    77→\\topenCodeProjectDir := t.TempDir()\\n    78→\\tif resolved, err := filepath.EvalSymlinks(openCodeProjectDir); err == nil {\\n    79→\\t\\topenCodeProjectDir = resolved\\n    80→\\t}\\n    81→\\n    82→\\tenv := &TestEnv{\\n    83→\\t\\tT:                  t,\\n    84→\\t\\tRepoDir:            repoDir,\\n    85→\\t\\tClaudeProjectDir:   claudeProjectDir,\\n    86→\\t\\tGeminiProjectDir:   geminiProjectDir,\\n    87→\\t\\tOpenCodeProjectDir: openCodeProjectDir,\\n    88→\\t}\\n    89→\\n    90→\\t// Note: Don't use t.Setenv here - it's incompatible with t.Parallel()\\n    91→\\t// CLI commands receive ENTIRE_TEST_*_PROJECT_DIR via cmd.Env instead\\n    92→\\n    93→\\treturn env\\n    94→}\\n    95→\\n    96→// Cleanup is a no-op retained for backwards compatibility.\\n    97→//\\n    98→// Previously this method restored the working directory after NewTestEnv changed it.\\n    99→// With the refactor to remove os.Chdir from NewTestEnv:\\n   100→// - Temp directories are now cleaned up automatically by t.TempDir()\\n   101→// - Working directory is never changed, so no restoration is needed\\n   102→//\\n   103→// This method is kept to avoid breaking existing tests that call defer env.Cleanup().\\n   104→// New tests should not call this method as it serves no purpose.\\n   105→//\\n   106→// Deprecated: This method is a no-op and will be removed in a future version.\\n   107→func (env *TestEnv) Cleanup() {\\n   108→\\t// No-op - temp dirs are cleaned up by t.TempDir()\\n   109→}\\n   110→\\n   111→// cliEnv returns the environment variables for CLI execution.\\n   112→// Includes Claude, Gemini, and OpenCode project dirs so tests work for any agent.\\n   113→func (env *TestEnv) cliEnv() []string {\\n   114→\\treturn append(os.Environ(),\\n   115→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+env.ClaudeProjectDir,\\n   116→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+env.GeminiProjectDir,\\n   117→\\t\\t\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR=\\\"+env.OpenCodeProjectDir,\\n   118→\\t\\t\\\"ENTIRE_TEST_TTY=0\\\", // Prevent interactive prompts from blocking in tests\\n   119→\\t)\\n   120→}\\n   121→\\n   122→// RunCLI runs the entire CLI with the given arguments and returns stdout.\\n   123→func (env *TestEnv) RunCLI(args ...string) string {\\n   124→\\tenv.T.Helper()\\n   125→\\toutput, err := env.RunCLIWithError(args...)\\n   126→\\tif err != nil {\\n   127→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   128→\\t}\\n   129→\\treturn output\\n   130→}\\n   131→\\n   132→// RunCLIWithError runs the entire CLI and returns output and error.\\n   133→func (env *TestEnv) RunCLIWithError(args ...string) (string, error) {\\n   134→\\tenv.T.Helper()\\n   135→\\n   136→\\t// Run CLI using the shared binary\\n   137→\\tcmd := exec.Command(getTestBinary(), args...)\\n   138→\\tcmd.Dir = env.RepoDir\\n   139→\\tcmd.Env = env.cliEnv()\\n   140→\\n   141→\\toutput, err := cmd.CombinedOutput()\\n   142→\\treturn string(output), err\\n   143→}\\n   144→\\n   145→// RunCLIWithStdin runs the CLI with stdin input.\\n   146→func (env *TestEnv) RunCLIWithStdin(stdin string, args ...string) string {\\n   147→\\tenv.T.Helper()\\n   148→\\n   149→\\t// Run CLI with stdin using the shared binary\\n   150→\\tcmd := exec.Command(getTestBinary(), args...)\\n   151→\\tcmd.Dir = env.RepoDir\\n   152→\\tcmd.Env = env.cliEnv()\\n   153→\\tcmd.Stdin = strings.NewReader(stdin)\\n   154→\\n   155→\\toutput, err := cmd.CombinedOutput()\\n   156→\\tif err != nil {\\n   157→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   158→\\t}\\n   159→\\treturn string(output)\\n   160→}\\n   161→\\n   162→// NewRepoEnv creates a TestEnv with an initialized git repo and Entire.\\n   163→// This is a convenience factory for tests that need a basic repo setup.\\n   164→func NewRepoEnv(t *testing.T, strategy string) *TestEnv {\\n   165→\\tt.Helper()\\n   166→\\tenv := NewTestEnv(t)\\n   167→\\tenv.InitRepo()\\n   168→\\tenv.InitEntire(strategy)\\n   169→\\treturn env\\n   170→}\\n   171→\\n   172→// NewRepoWithCommit creates a TestEnv with a git repo, Entire, and an initial commit.\\n   173→// The initial commit contains a README.md and .gitignore (excluding .entire/).\\n   174→func NewRepoWithCommit(t *testing.T, strategy string) *TestEnv {\\n   175→\\tt.Helper()\\n   176→\\tenv := NewRepoEnv(t, strategy)\\n   177→\\tenv.WriteFile(\\\".gitignore\\\", \\\".entire/\\\\n\\\")\\n   178→\\tenv.WriteFile(\\\"README.md\\\", \\\"# Test Repository\\\")\\n   179→\\tenv.GitAdd(\\\".gitignore\\\")\\n   180→\\tenv.GitAdd(\\\"README.md\\\")\\n   181→\\tenv.GitCommit(\\\"Initial commit\\\")\\n   182→\\treturn env\\n   183→}\\n   184→\\n   185→// NewFeatureBranchEnv creates a TestEnv ready for session testing.\\n   186→// It initializes the repo, creates an initial commit on main,\\n   187→// and checks out a feature branch. This is the most common setup\\n   188→// for session and rewind tests since Entire tracking skips main/master.\\n   189→func NewFeatureBranchEnv(t *testing.T, strategyName string) *TestEnv {\\n   190→\\tt.Helper()\\n   191→\\tenv := NewRepoWithCommit(t, strategyName)\\n   192→\\tenv.GitCheckoutNewBranch(\\\"feature/test-branch\\\")\\n   193→\\treturn env\\n   194→}\\n   195→\\n   196→// AllStrategies returns all strategy names for parameterized tests.\\n   197→func AllStrategies() []string {\\n   198→\\treturn []string{\\n   199→\\t\\tstrategy.StrategyNameAutoCommit,\\n   200→\\t\\tstrategy.StrategyNameManualCommit,\\n   201→\\t}\\n   202→}\\n   203→\\n   204→// RunForAllStrategies runs a test function for each strategy in parallel.\\n   205→// This reduces boilerplate for tests that need to verify behavior across all strategies.\\n   206→// Each subtest gets its own TestEnv with a feature branch ready for testing.\\n   207→func RunForAllStrategies(t *testing.T, testFn func(t *testing.T, env *TestEnv, strategyName string)) {\\n   208→\\tt.Helper()\\n   209→\\tfor _, strat := range AllStrategies() {\\n   210→\\t\\tstrat := strat // capture for parallel\\n   211→\\t\\tt.Run(strat, func(t *testing.T) {\\n   212→\\t\\t\\tt.Parallel()\\n   213→\\t\\t\\tenv := NewFeatureBranchEnv(t, strat)\\n   214→\\t\\t\\ttestFn(t, env, strat)\\n   215→\\t\\t})\\n   216→\\t}\\n   217→}\\n   218→\\n   219→// RunForAllStrategiesWithRepoEnv runs a test function for each strategy in parallel,\\n   220→// using NewRepoWithCommit instead of NewFeatureBranchEnv. Use this for tests\\n   221→// that need to test behavior on the main branch.\\n   222→func RunForAllStrategiesWithRepoEnv(t *testing.T, testFn func(t *testing.T, env *TestEnv, strategyName string)) {\\n   223→\\tt.Helper()\\n   224→\\tfor _, strat := range AllStrategies() {\\n   225→\\t\\tstrat := strat // capture for parallel\\n   226→\\t\\tt.Run(strat, func(t *testing.T) {\\n   227→\\t\\t\\tt.Parallel()\\n   228→\\t\\t\\tenv := NewRepoWithCommit(t, strat)\\n   229→\\t\\t\\ttestFn(t, env, strat)\\n   230→\\t\\t})\\n   231→\\t}\\n   232→}\\n   233→\\n   234→// RunForAllStrategiesWithBasicEnv runs a test function for each strategy in parallel,\\n   235→// using NewRepoEnv (git repo + entire init, no commits). Use this for tests\\n   236→// that need to verify basic initialization behavior.\\n   237→func RunForAllStrategiesWithBasicEnv(t *testing.T, testFn func(t *testing.T, env *TestEnv, strategyName string)) {\\n   238→\\tt.Helper()\\n   239→\\tfor _, strat := range AllStrategies() {\\n   240→\\t\\tstrat := strat // capture for parallel\\n   241→\\t\\tt.Run(strat, func(t *testing.T) {\\n   242→\\t\\t\\tt.Parallel()\\n   243→\\t\\t\\tenv := NewRepoEnv(t, strat)\\n   244→\\t\\t\\ttestFn(t, env, strat)\\n   245→\\t\\t})\\n   246→\\t}\\n   247→}\\n   248→\\n   249→// RunForStrategiesSequential runs a test function for specific strategies sequentially.\\n   250→// Use this for tests that cannot be parallelized (e.g., tests using os.Chdir).\\n   251→// The strategies parameter allows testing a subset of strategies.\\n   252→func RunForStrategiesSequential(t *testing.T, strategies []string, testFn func(t *testing.T, strategyName string)) {\\n   253→\\tt.Helper()\\n   254→\\tfor _, strat := range strategies {\\n   255→\\t\\tt.Run(strat, func(t *testing.T) {\\n   256→\\t\\t\\ttestFn(t, strat)\\n   257→\\t\\t})\\n   258→\\t}\\n   259→}\\n   260→\\n   261→// InitRepo initializes a git repository in the test environment.\\n   262→func (env *TestEnv) InitRepo() {\\n   263→\\tenv.T.Helper()\\n   264→\\n   265→\\trepo, err := git.PlainInit(env.RepoDir, false)\\n   266→\\tif err != nil {\\n   267→\\t\\tenv.T.Fatalf(\\\"failed to init git repo: %v\\\", err)\\n   268→\\t}\\n   269→\\n   270→\\t// Configure git user for commits\\n   271→\\tcfg, err := repo.Config()\\n   272→\\tif err != nil {\\n   273→\\t\\tenv.T.Fatalf(\\\"failed to get repo config: %v\\\", err)\\n   274→\\t}\\n   275→\\tcfg.User.Name = \\\"Test User\\\"\\n   276→\\tcfg.User.Email = \\\"test@example.com\\\"\\n   277→\\n   278→\\t// Disable GPG signing for test commits (prevents failures if user has commit.gpgsign=true globally)\\n   279→\\tif cfg.Raw == nil {\\n   280→\\t\\tcfg.Raw = config.New()\\n   281→\\t}\\n   282→\\tcfg.Raw.Section(\\\"commit\\\").SetOption(\\\"gpgsign\\\", \\\"false\\\")\\n   283→\\n   284→\\tif err := repo.SetConfig(cfg); err != nil {\\n   285→\\t\\tenv.T.Fatalf(\\\"failed to set repo config: %v\\\", err)\\n   286→\\t}\\n   287→}\\n   288→\\n   289→// InitEntire initializes the .entire directory with the specified strategy.\\n   290→func (env *TestEnv) InitEntire(strategyName string) {\\n   291→\\tenv.InitEntireWithOptions(strategyName, nil)\\n   292→}\\n   293→\\n   294→// InitEntireWithOptions initializes the .entire directory with the specified strategy and options.\\n   295→func (env *TestEnv) InitEntireWithOptions(strategyName string, strategyOptions map[string]any) {\\n   296→\\tenv.T.Helper()\\n   297→\\tenv.initEntireInternal(strategyName, strategyOptions)\\n   298→}\\n   299→\\n   300→// InitEntireWithAgent initializes an Entire test environment with a specific agent.\\n   301→// The agent name is for test documentation only — the CLI resolves the agent from\\n   302→// hook commands and checkpoint metadata, not from settings.json.\\n   303→func (env *TestEnv) InitEntireWithAgent(strategyName string, _ agent.AgentName) {\\n   304→\\tenv.T.Helper()\\n   305→\\tenv.initEntireInternal(strategyName, nil)\\n   306→}\\n   307→\\n   308→// InitEntireWithAgentAndOptions initializes Entire with the specified strategy, agent, and options.\\n   309→func (env *TestEnv) InitEntireWithAgentAndOptions(strategyName string, _ agent.AgentName, strategyOptions map[string]any) {\\n   310→\\tenv.T.Helper()\\n   311→\\tenv.initEntireInternal(strategyName, strategyOptions)\\n   312→}\\n   313→\\n   314→// initEntireInternal is the common implementation for InitEntire variants.\\n   315→func (env *TestEnv) initEntireInternal(strategyName string, strategyOptions map[string]any) {\\n   316→\\tenv.T.Helper()\\n   317→\\n   318→\\t// Create .entire directory structure\\n   319→\\tentireDir := filepath.Join(env.RepoDir, \\\".entire\\\")\\n   320→\\tif err := os.MkdirAll(entireDir, 0o755); err != nil {\\n   321→\\t\\tenv.T.Fatalf(\\\"failed to create .entire directory: %v\\\", err)\\n   322→\\t}\\n   323→\\n   324→\\t// Create tmp directory\\n   325→\\ttmpDir := filepath.Join(entireDir, \\\"tmp\\\")\\n   326→\\tif err := os.MkdirAll(tmpDir, 0o755); err != nil {\\n   327→\\t\\tenv.T.Fatalf(\\\"failed to create .entire/tmp directory: %v\\\", err)\\n   328→\\t}\\n   329→\\n   330→\\t// Write settings.json\\n   331→\\t// Note: The agent name is NOT stored in settings.json — the CLI determines\\n   332→\\t// the agent from installed hooks (detect presence) or checkpoint metadata.\\n   333→\\t// The settings parser uses DisallowUnknownFields(), so only recognized fields are allowed.\\n   334→\\tsettings := map[string]any{\\n   335→\\t\\t\\\"strategy\\\":  strategyName,\\n   336→\\t\\t\\\"local_dev\\\": true, // Note: git-triggered hooks won't work (path is relative); tests call hooks via getTestBinary() instead\\n   337→\\t}\\n   338→\\tif strategyOptions != nil {\\n   339→\\t\\tsettings[\\\"strategy_options\\\"] = strategyOptions\\n   340→\\t}\\n   341→\\tdata, err := jsonutil.MarshalIndentWithNewline(settings, \\\"\\\", \\\"  \\\")\\n   342→\\tif err != nil {\\n   343→\\t\\tenv.T.Fatalf(\\\"failed to marshal settings: %v\\\", err)\\n   344→\\t}\\n   345→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   346→\\tif err := os.WriteFile(settingsPath, data, 0o644); err != nil {\\n   347→\\t\\tenv.T.Fatalf(\\\"failed to write %s: %v\\\", paths.SettingsFileName, err)\\n   348→\\t}\\n   349→}\\n   350→\\n   351→// WriteFile creates a file with the given content in the test repo.\\n   352→// It creates parent directories as needed.\\n   353→func (env *TestEnv) WriteFile(path, content string) {\\n   354→\\tenv.T.Helper()\\n   355→\\n   356→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   357→\\n   358→\\t// Create parent directories\\n   359→\\tdir := filepath.Dir(fullPath)\\n   360→\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   361→\\t\\tenv.T.Fatalf(\\\"failed to create directory %s: %v\\\", dir, err)\\n   362→\\t}\\n   363→\\n   364→\\tif err := os.WriteFile(fullPath, []byte(content), 0o644); err != nil {\\n   365→\\t\\tenv.T.Fatalf(\\\"failed to write file %s: %v\\\", path, err)\\n   366→\\t}\\n   367→}\\n   368→\\n   369→// ReadFile reads a file from the test repo.\\n   370→func (env *TestEnv) ReadFile(path string) string {\\n   371→\\tenv.T.Helper()\\n   372→\\n   373→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   374→\\tdata, err := os.ReadFile(fullPath)\\n   375→\\tif err != nil {\\n   376→\\t\\tenv.T.Fatalf(\\\"failed to read file %s: %v\\\", path, err)\\n   377→\\t}\\n   378→\\treturn string(data)\\n   379→}\\n   380→\\n   381→// ReadFileAbsolute reads a file using an absolute path.\\n   382→func (env *TestEnv) ReadFileAbsolute(path string) string {\\n   383→\\tenv.T.Helper()\\n   384→\\n   385→\\tdata, err := os.ReadFile(path)\\n   386→\\tif err != nil {\\n   387→\\t\\tenv.T.Fatalf(\\\"failed to read file %s: %v\\\", path, err)\\n   388→\\t}\\n   389→\\treturn string(data)\\n   390→}\\n   391→\\n   392→// FileExists checks if a file exists in the test repo.\\n   393→func (env *TestEnv) FileExists(path string) bool {\\n   394→\\tenv.T.Helper()\\n   395→\\n   396→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   397→\\t_, err := os.Stat(fullPath)\\n   398→\\treturn err == nil\\n   399→}\\n   400→\\n   401→// GitAdd stages files for commit.\\n   402→func (env *TestEnv) GitAdd(paths ...string) {\\n   403→\\tenv.T.Helper()\\n   404→\\n   405→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   406→\\tif err != nil {\\n   407→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   408→\\t}\\n   409→\\n   410→\\tworktree, err := repo.Worktree()\\n   411→\\tif err != nil {\\n   412→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   413→\\t}\\n   414→\\n   415→\\tfor _, path := range paths {\\n   416→\\t\\tif _, err := worktree.Add(path); err != nil {\\n   417→\\t\\t\\tenv.T.Fatalf(\\\"failed to add file %s: %v\\\", path, err)\\n   418→\\t\\t}\\n   419→\\t}\\n   420→}\\n   421→\\n   422→// GitCommit creates a commit with all staged files.\\n   423→func (env *TestEnv) GitCommit(message string) {\\n   424→\\tenv.T.Helper()\\n   425→\\n   426→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   427→\\tif err != nil {\\n   428→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   429→\\t}\\n   430→\\n   431→\\tworktree, err := repo.Worktree()\\n   432→\\tif err != nil {\\n   433→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   434→\\t}\\n   435→\\n   436→\\t_, err = worktree.Commit(message, &git.CommitOptions{\\n   437→\\t\\tAuthor: &object.Signature{\\n   438→\\t\\t\\tName:  \\\"Test User\\\",\\n   439→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   440→\\t\\t\\tWhen:  time.Now(),\\n   441→\\t\\t},\\n   442→\\t})\\n   443→\\tif err != nil {\\n   444→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   445→\\t}\\n   446→}\\n   447→\\n   448→// GitCommitWithMetadata creates a commit with Entire-Metadata trailer.\\n   449→// This simulates commits created by the commit strategy.\\n   450→func (env *TestEnv) GitCommitWithMetadata(message, metadataDir string) {\\n   451→\\tenv.T.Helper()\\n   452→\\n   453→\\t// Format message with metadata trailer\\n   454→\\tfullMessage := message + \\\"\\\\n\\\\nEntire-Metadata: \\\" + metadataDir + \\\"\\\\n\\\"\\n   455→\\n   456→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   457→\\tif err != nil {\\n   458→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   459→\\t}\\n   460→\\n   461→\\tworktree, err := repo.Worktree()\\n   462→\\tif err != nil {\\n   463→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   464→\\t}\\n   465→\\n   466→\\t_, err = worktree.Commit(fullMessage, &git.CommitOptions{\\n   467→\\t\\tAuthor: &object.Signature{\\n   468→\\t\\t\\tName:  \\\"Test User\\\",\\n   469→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   470→\\t\\t\\tWhen:  time.Now(),\\n   471→\\t\\t},\\n   472→\\t})\\n   473→\\tif err != nil {\\n   474→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   475→\\t}\\n   476→}\\n   477→\\n   478→// GitCommitWithCheckpointID creates a commit with Entire-Checkpoint trailer.\\n   479→// This simulates commits created by the auto-commit strategy.\\n   480→func (env *TestEnv) GitCommitWithCheckpointID(message, checkpointID string) {\\n   481→\\tenv.T.Helper()\\n   482→\\n   483→\\t// Format message with checkpoint trailer\\n   484→\\tfullMessage := message + \\\"\\\\n\\\\nEntire-Checkpoint: \\\" + checkpointID + \\\"\\\\n\\\"\\n   485→\\n   486→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   487→\\tif err != nil {\\n   488→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   489→\\t}\\n   490→\\n   491→\\tworktree, err := repo.Worktree()\\n   492→\\tif err != nil {\\n   493→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   494→\\t}\\n   495→\\n   496→\\t_, err = worktree.Commit(fullMessage, &git.CommitOptions{\\n   497→\\t\\tAuthor: &object.Signature{\\n   498→\\t\\t\\tName:  \\\"Test User\\\",\\n   499→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   500→\\t\\t\\tWhen:  time.Now(),\\n   501→\\t\\t},\\n   502→\\t})\\n   503→\\tif err != nil {\\n   504→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   505→\\t}\\n   506→}\\n   507→\\n   508→// GitCommitWithMultipleSessions creates a commit with multiple Entire-Session trailers.\\n   509→// This simulates merge commits that combine work from multiple sessions.\\n   510→func (env *TestEnv) GitCommitWithMultipleSessions(message string, sessionIDs []string) {\\n   511→\\tenv.T.Helper()\\n   512→\\n   513→\\t// Format message with multiple session trailers\\n   514→\\tfullMessage := message + \\\"\\\\n\\\\n\\\"\\n   515→\\tvar fullMessageSb404 strings.Builder\\n   516→\\tfor _, sessionID := range sessionIDs {\\n   517→\\t\\tfullMessageSb404.WriteString(\\\"Entire-Session: \\\" + sessionID + \\\"\\\\n\\\")\\n   518→\\t}\\n   519→\\tfullMessage += fullMessageSb404.String()\\n   520→\\n   521→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   522→\\tif err != nil {\\n   523→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   524→\\t}\\n   525→\\n   526→\\tworktree, err := repo.Worktree()\\n   527→\\tif err != nil {\\n   528→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   529→\\t}\\n   530→\\n   531→\\t_, err = worktree.Commit(fullMessage, &git.CommitOptions{\\n   532→\\t\\tAuthor: &object.Signature{\\n   533→\\t\\t\\tName:  \\\"Test User\\\",\\n   534→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   535→\\t\\t\\tWhen:  time.Now(),\\n   536→\\t\\t},\\n   537→\\t})\\n   538→\\tif err != nil {\\n   539→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   540→\\t}\\n   541→}\\n   542→\\n   543→// GetHeadHash returns the current HEAD commit hash.\\n   544→func (env *TestEnv) GetHeadHash() string {\\n   545→\\tenv.T.Helper()\\n   546→\\n   547→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   548→\\tif err != nil {\\n   549→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   550→\\t}\\n   551→\\n   552→\\thead, err := repo.Head()\\n   553→\\tif err != nil {\\n   554→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   555→\\t}\\n   556→\\n   557→\\treturn head.Hash().String()\\n   558→}\\n   559→\\n   560→// GetShadowBranchName returns the worktree-specific shadow branch name for the current HEAD.\\n   561→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   562→func (env *TestEnv) GetShadowBranchName() string {\\n   563→\\tenv.T.Helper()\\n   564→\\n   565→\\theadHash := env.GetHeadHash()\\n   566→\\tworktreeID, err := paths.GetWorktreeID(env.RepoDir)\\n   567→\\tif err != nil {\\n   568→\\t\\tenv.T.Fatalf(\\\"failed to get worktree ID: %v\\\", err)\\n   569→\\t}\\n   570→\\treturn checkpoint.ShadowBranchNameForCommit(headHash, worktreeID)\\n   571→}\\n   572→\\n   573→// GetShadowBranchNameForCommit returns the worktree-specific shadow branch name for a given commit.\\n   574→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   575→func (env *TestEnv) GetShadowBranchNameForCommit(commitHash string) string {\\n   576→\\tenv.T.Helper()\\n   577→\\n   578→\\tworktreeID, err := paths.GetWorktreeID(env.RepoDir)\\n   579→\\tif err != nil {\\n   580→\\t\\tenv.T.Fatalf(\\\"failed to get worktree ID: %v\\\", err)\\n   581→\\t}\\n   582→\\treturn checkpoint.ShadowBranchNameForCommit(commitHash, worktreeID)\\n   583→}\\n   584→\\n   585→// GetGitLog returns a list of commit hashes from HEAD.\\n   586→func (env *TestEnv) GetGitLog() []string {\\n   587→\\tenv.T.Helper()\\n   588→\\n   589→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   590→\\tif err != nil {\\n   591→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   592→\\t}\\n   593→\\n   594→\\thead, err := repo.Head()\\n   595→\\tif err != nil {\\n   596→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   597→\\t}\\n   598→\\n   599→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   600→\\tif err != nil {\\n   601→\\t\\tenv.T.Fatalf(\\\"failed to get log: %v\\\", err)\\n   602→\\t}\\n   603→\\n   604→\\tvar commits []string\\n   605→\\terr = commitIter.ForEach(func(c *object.Commit) error {\\n   606→\\t\\tcommits = append(commits, c.Hash.String())\\n   607→\\t\\treturn nil\\n   608→\\t})\\n   609→\\tif err != nil {\\n   610→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   611→\\t}\\n   612→\\n   613→\\treturn commits\\n   614→}\\n   615→\\n   616→// GitCheckoutNewBranch creates and checks out a new branch.\\n   617→// Uses git CLI instead of go-git to work around go-git v5 bug where Checkout\\n   618→// deletes untracked files (see https://github.com/go-git/go-git/issues/970).\\n   619→func (env *TestEnv) GitCheckoutNewBranch(branchName string) {\\n   620→\\tenv.T.Helper()\\n   621→\\n   622→\\tcmd := exec.Command(\\\"git\\\", \\\"checkout\\\", \\\"-b\\\", branchName)\\n   623→\\tcmd.Dir = env.RepoDir\\n   624→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   625→\\t\\tenv.T.Fatalf(\\\"failed to checkout new branch %s: %v\\\\nOutput: %s\\\", branchName, err, output)\\n   626→\\t}\\n   627→}\\n   628→\\n   629→// GetCurrentBranch returns the current branch name.\\n   630→func (env *TestEnv) GetCurrentBranch() string {\\n   631→\\tenv.T.Helper()\\n   632→\\n   633→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   634→\\tif err != nil {\\n   635→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   636→\\t}\\n   637→\\n   638→\\thead, err := repo.Head()\\n   639→\\tif err != nil {\\n   640→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   641→\\t}\\n   642→\\n   643→\\tif !head.Name().IsBranch() {\\n   644→\\t\\treturn \\\"\\\" // Detached HEAD\\n   645→\\t}\\n   646→\\n   647→\\treturn head.Name().Short()\\n   648→}\\n   649→\\n   650→// RewindPoint mirrors strategy.RewindPoint for test assertions.\\n   651→type RewindPoint struct {\\n   652→\\tID               string\\n   653→\\tMessage          string\\n   654→\\tMetadataDir      string\\n   655→\\tDate             time.Time\\n   656→\\tIsTaskCheckpoint bool\\n   657→\\tToolUseID        string\\n   658→\\tIsLogsOnly       bool\\n   659→\\tCondensationID   string\\n   660→}\\n   661→\\n   662→// GetRewindPoints returns available rewind points using the CLI.\\n   663→func (env *TestEnv) GetRewindPoints() []RewindPoint {\\n   664→\\tenv.T.Helper()\\n   665→\\n   666→\\t// Run rewind --list using the shared binary\\n   667→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--list\\\")\\n   668→\\tcmd.Dir = env.RepoDir\\n   669→\\tcmd.Env = env.cliEnv()\\n   670→\\n   671→\\toutput, err := cmd.CombinedOutput()\\n   672→\\tif err != nil {\\n   673→\\t\\tenv.T.Fatalf(\\\"rewind --list failed: %v\\\\nOutput: %s\\\", err, output)\\n   674→\\t}\\n   675→\\n   676→\\t// Parse JSON output\\n   677→\\tvar jsonPoints []struct {\\n   678→\\t\\tID               string `json:\\\"id\\\"`\\n   679→\\t\\tMessage          string `json:\\\"message\\\"`\\n   680→\\t\\tMetadataDir      string `json:\\\"metadata_dir\\\"`\\n   681→\\t\\tDate             string `json:\\\"date\\\"`\\n   682→\\t\\tIsTaskCheckpoint bool   `json:\\\"is_task_checkpoint\\\"`\\n   683→\\t\\tToolUseID        string `json:\\\"tool_use_id\\\"`\\n   684→\\t\\tIsLogsOnly       bool   `json:\\\"is_logs_only\\\"`\\n   685→\\t\\tCondensationID   string `json:\\\"condensation_id\\\"`\\n   686→\\t}\\n   687→\\n   688→\\tif err := json.Unmarshal(output, &jsonPoints); err != nil {\\n   689→\\t\\tenv.T.Fatalf(\\\"failed to parse rewind points: %v\\\\nOutput: %s\\\", err, output)\\n   690→\\t}\\n   691→\\n   692→\\tpoints := make([]RewindPoint, len(jsonPoints))\\n   693→\\tfor i, jp := range jsonPoints {\\n   694→\\t\\tdate, _ := time.Parse(time.RFC3339, jp.Date)\\n   695→\\t\\tpoints[i] = RewindPoint{\\n   696→\\t\\t\\tID:               jp.ID,\\n   697→\\t\\t\\tMessage:          jp.Message,\\n   698→\\t\\t\\tMetadataDir:      jp.MetadataDir,\\n   699→\\t\\t\\tDate:             date,\\n   700→\\t\\t\\tIsTaskCheckpoint: jp.IsTaskCheckpoint,\\n   701→\\t\\t\\tToolUseID:        jp.ToolUseID,\\n   702→\\t\\t\\tIsLogsOnly:       jp.IsLogsOnly,\\n   703→\\t\\t\\tCondensationID:   jp.CondensationID,\\n   704→\\t\\t}\\n   705→\\t}\\n   706→\\n   707→\\treturn points\\n   708→}\\n   709→\\n   710→// Rewind performs a rewind to the specified commit ID using the CLI.\\n   711→func (env *TestEnv) Rewind(commitID string) error {\\n   712→\\tenv.T.Helper()\\n   713→\\n   714→\\t// Run rewind --to <commitID> using the shared binary\\n   715→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID)\\n   716→\\tcmd.Dir = env.RepoDir\\n   717→\\tcmd.Env = env.cliEnv()\\n   718→\\n   719→\\toutput, err := cmd.CombinedOutput()\\n   720→\\tif err != nil {\\n   721→\\t\\treturn errors.New(\\\"rewind failed: \\\" + string(output))\\n   722→\\t}\\n   723→\\n   724→\\tenv.T.Logf(\\\"Rewind output: %s\\\", output)\\n   725→\\treturn nil\\n   726→}\\n   727→\\n   728→// RewindLogsOnly performs a logs-only rewind using the CLI.\\n   729→// This restores session logs without modifying the working directory.\\n   730→func (env *TestEnv) RewindLogsOnly(commitID string) error {\\n   731→\\tenv.T.Helper()\\n   732→\\n   733→\\t// Run rewind --to <commitID> --logs-only using the shared binary\\n   734→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID, \\\"--logs-only\\\")\\n   735→\\tcmd.Dir = env.RepoDir\\n   736→\\tcmd.Env = env.cliEnv()\\n   737→\\n   738→\\toutput, err := cmd.CombinedOutput()\\n   739→\\tif err != nil {\\n   740→\\t\\treturn errors.New(\\\"rewind logs-only failed: \\\" + string(output))\\n   741→\\t}\\n   742→\\n   743→\\tenv.T.Logf(\\\"Rewind logs-only output: %s\\\", output)\\n   744→\\treturn nil\\n   745→}\\n   746→\\n   747→// RewindReset performs a reset rewind using the CLI.\\n   748→// This resets the branch to the specified commit (destructive).\\n   749→func (env *TestEnv) RewindReset(commitID string) error {\\n   750→\\tenv.T.Helper()\\n   751→\\n   752→\\t// Run rewind --to <commitID> --reset using the shared binary\\n   753→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID, \\\"--reset\\\")\\n   754→\\tcmd.Dir = env.RepoDir\\n   755→\\tcmd.Env = env.cliEnv()\\n   756→\\n   757→\\toutput, err := cmd.CombinedOutput()\\n   758→\\tif err != nil {\\n   759→\\t\\treturn errors.New(\\\"rewind reset failed: \\\" + string(output))\\n   760→\\t}\\n   761→\\n   762→\\tenv.T.Logf(\\\"Rewind reset output: %s\\\", output)\\n   763→\\treturn nil\\n   764→}\\n   765→\\n   766→// BranchExists checks if a branch exists in the repository.\\n   767→func (env *TestEnv) BranchExists(branchName string) bool {\\n   768→\\tenv.T.Helper()\\n   769→\\n   770→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   771→\\tif err != nil {\\n   772→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   773→\\t}\\n   774→\\n   775→\\trefs, err := repo.References()\\n   776→\\tif err != nil {\\n   777→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   778→\\t}\\n   779→\\n   780→\\tfound := false\\n   781→\\t_ = refs.ForEach(func(ref *plumbing.Reference) error {\\n   782→\\t\\tif ref.Name().Short() == branchName {\\n   783→\\t\\t\\tfound = true\\n   784→\\t\\t}\\n   785→\\t\\treturn nil\\n   786→\\t})\\n   787→\\n   788→\\treturn found\\n   789→}\\n   790→\\n   791→// GetCommitMessage returns the commit message for the given commit hash.\\n   792→func (env *TestEnv) GetCommitMessage(hash string) string {\\n   793→\\tenv.T.Helper()\\n   794→\\n   795→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   796→\\tif err != nil {\\n   797→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   798→\\t}\\n   799→\\n   800→\\tcommitHash := plumbing.NewHash(hash)\\n   801→\\tcommit, err := repo.CommitObject(commitHash)\\n   802→\\tif err != nil {\\n   803→\\t\\tenv.T.Fatalf(\\\"failed to get commit %s: %v\\\", hash, err)\\n   804→\\t}\\n   805→\\n   806→\\treturn commit.Message\\n   807→}\\n   808→\\n   809→// FileExistsInBranch checks if a file exists in a specific branch's tree.\\n   810→func (env *TestEnv) FileExistsInBranch(branchName, filePath string) bool {\\n   811→\\tenv.T.Helper()\\n   812→\\n   813→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   814→\\tif err != nil {\\n   815→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   816→\\t}\\n   817→\\n   818→\\t// Get the branch reference\\n   819→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   820→\\tif err != nil {\\n   821→\\t\\t// Try as a remote-style ref\\n   822→\\t\\tref, err = repo.Reference(plumbing.ReferenceName(\\\"refs/heads/\\\"+branchName), true)\\n   823→\\t\\tif err != nil {\\n   824→\\t\\t\\treturn false\\n   825→\\t\\t}\\n   826→\\t}\\n   827→\\n   828→\\t// Get the commit\\n   829→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   830→\\tif err != nil {\\n   831→\\t\\treturn false\\n   832→\\t}\\n   833→\\n   834→\\t// Get the tree\\n   835→\\ttree, err := commit.Tree()\\n   836→\\tif err != nil {\\n   837→\\t\\treturn false\\n   838→\\t}\\n   839→\\n   840→\\t// Check if file exists\\n   841→\\t_, err = tree.File(filePath)\\n   842→\\treturn err == nil\\n   843→}\\n   844→\\n   845→// ReadFileFromBranch reads a file's content from a specific branch's tree.\\n   846→// Returns the content and true if found, empty string and false if not found.\\n   847→func (env *TestEnv) ReadFileFromBranch(branchName, filePath string) (string, bool) {\\n   848→\\tenv.T.Helper()\\n   849→\\n   850→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   851→\\tif err != nil {\\n   852→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   853→\\t}\\n   854→\\n   855→\\t// Get the branch reference\\n   856→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   857→\\tif err != nil {\\n   858→\\t\\t// Try as a remote-style ref\\n   859→\\t\\tref, err = repo.Reference(plumbing.ReferenceName(\\\"refs/heads/\\\"+branchName), true)\\n   860→\\t\\tif err != nil {\\n   861→\\t\\t\\treturn \\\"\\\", false\\n   862→\\t\\t}\\n   863→\\t}\\n   864→\\n   865→\\t// Get the commit\\n   866→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   867→\\tif err != nil {\\n   868→\\t\\treturn \\\"\\\", false\\n   869→\\t}\\n   870→\\n   871→\\t// Get the tree\\n   872→\\ttree, err := commit.Tree()\\n   873→\\tif err != nil {\\n   874→\\t\\treturn \\\"\\\", false\\n   875→\\t}\\n   876→\\n   877→\\t// Get the file\\n   878→\\tfile, err := tree.File(filePath)\\n   879→\\tif err != nil {\\n   880→\\t\\treturn \\\"\\\", false\\n   881→\\t}\\n   882→\\n   883→\\t// Get the content\\n   884→\\tcontent, err := file.Contents()\\n   885→\\tif err != nil {\\n   886→\\t\\treturn \\\"\\\", false\\n   887→\\t}\\n   888→\\n   889→\\treturn content, true\\n   890→}\\n   891→\\n   892→// GetLatestCommitMessageOnBranch returns the commit message of the latest commit on the given branch.\\n   893→func (env *TestEnv) GetLatestCommitMessageOnBranch(branchName string) string {\\n   894→\\tenv.T.Helper()\\n   895→\\n   896→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   897→\\tif err != nil {\\n   898→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   899→\\t}\\n   900→\\n   901→\\t// Get the branch reference\\n   902→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   903→\\tif err != nil {\\n   904→\\t\\tenv.T.Fatalf(\\\"failed to get branch %s reference: %v\\\", branchName, err)\\n   905→\\t}\\n   906→\\n   907→\\t// Get the commit\\n   908→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   909→\\tif err != nil {\\n   910→\\t\\tenv.T.Fatalf(\\\"failed to get commit object: %v\\\", err)\\n   911→\\t}\\n   912→\\n   913→\\treturn commit.Message\\n   914→}\\n   915→\\n   916→// GitCommitWithShadowHooks stages and commits files, simulating the prepare-commit-msg\\n   917→// and post-commit hooks as a human (with TTY). This is the default for tests.\\n   918→func (env *TestEnv) GitCommitWithShadowHooks(message string, files ...string) {\\n   919→\\tenv.T.Helper()\\n   920→\\tenv.gitCommitWithShadowHooks(message, true, files...)\\n   921→}\\n   922→\\n   923→// GitCommitWithShadowHooksAsAgent is like GitCommitWithShadowHooks but simulates\\n   924→// an agent commit (no TTY). This triggers the fast path in PrepareCommitMsg that\\n   925→// skips content detection and interactive prompts for ACTIVE sessions.\\n   926→func (env *TestEnv) GitCommitWithShadowHooksAsAgent(message string, files ...string) {\\n   927→\\tenv.T.Helper()\\n   928→\\tenv.gitCommitWithShadowHooks(message, false, files...)\\n   929→}\\n   930→\\n   931→// gitCommitWithShadowHooks is the shared implementation for committing with shadow hooks.\\n   932→// When simulateTTY is true, sets ENTIRE_TEST_TTY=1 to simulate a human at the terminal.\\n   933→// When false, filters it out to simulate an agent subprocess (no controlling terminal).\\n   934→func (env *TestEnv) gitCommitWithShadowHooks(message string, simulateTTY bool, files ...string) {\\n   935→\\tenv.T.Helper()\\n   936→\\n   937→\\t// Stage files using go-git\\n   938→\\tfor _, file := range files {\\n   939→\\t\\tenv.GitAdd(file)\\n   940→\\t}\\n   941→\\n   942→\\t// Create a temp file for the commit message (prepare-commit-msg hook modifies this)\\n   943→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n   944→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n   945→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n   946→\\t}\\n   947→\\n   948→\\t// Run prepare-commit-msg hook using the shared binary.\\n   949→\\t// Pass source=\\\"message\\\" to match real `git commit -m` behavior.\\n   950→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile, \\\"message\\\")\\n   951→\\tprepCmd.Dir = env.RepoDir\\n   952→\\tif simulateTTY {\\n   953→\\t\\t// Simulate human at terminal: ENTIRE_TEST_TTY=1 makes hasTTY() return true\\n   954→\\t\\t// and askConfirmTTY() return defaultYes without reading from /dev/tty.\\n   955→\\t\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n   956→\\t} else {\\n   957→\\t\\t// Simulate agent: ENTIRE_TEST_TTY=0 makes hasTTY() return false,\\n   958→\\t\\t// triggering the fast path that adds trailers for ACTIVE sessions.\\n   959→\\t\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   960→\\t}\\n   961→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n   962→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n   963→\\t\\t// Don't fail - hook may silently succeed\\n   964→\\t}\\n   965→\\n   966→\\t// Read the modified message\\n   967→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n   968→\\tif err != nil {\\n   969→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n   970→\\t}\\n   971→\\n   972→\\t// Create the commit using go-git with the modified message\\n   973→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   974→\\tif err != nil {\\n   975→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   976→\\t}\\n   977→\\n   978→\\tworktree, err := repo.Worktree()\\n   979→\\tif err != nil {\\n   980→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   981→\\t}\\n   982→\\n   983→\\t_, err = worktree.Commit(string(modifiedMsg), &git.CommitOptions{\\n   984→\\t\\tAuthor: &object.Signature{\\n   985→\\t\\t\\tName:  \\\"Test User\\\",\\n   986→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   987→\\t\\t\\tWhen:  time.Now(),\\n   988→\\t\\t},\\n   989→\\t})\\n   990→\\tif err != nil {\\n   991→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   992→\\t}\\n   993→\\n   994→\\t// Run post-commit hook using the shared binary\\n   995→\\t// This triggers condensation if the commit has an Entire-Checkpoint trailer\\n   996→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n   997→\\tpostCmd.Dir = env.RepoDir\\n   998→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n   999→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n  1000→\\t\\t// Don't fail - hook may silently succeed\\n  1001→\\t}\\n  1002→}\\n  1003→\\n  1004→// GitCommitAmendWithShadowHooks amends the last commit with shadow hooks.\\n  1005→// This simulates `git commit --amend` with the prepare-commit-msg and post-commit hooks.\\n  1006→// The prepare-commit-msg hook is called with \\\"commit\\\" source to indicate an amend.\\n  1007→func (env *TestEnv) GitCommitAmendWithShadowHooks(message string, files ...string) {\\n  1008→\\tenv.T.Helper()\\n  1009→\\n  1010→\\t// Stage any additional files\\n  1011→\\tfor _, file := range files {\\n  1012→\\t\\tenv.GitAdd(file)\\n  1013→\\t}\\n  1014→\\n  1015→\\t// Write commit message to temp file\\n  1016→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n  1017→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n  1018→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n  1019→\\t}\\n  1020→\\n  1021→\\t// Run prepare-commit-msg hook with \\\"commit\\\" source (indicates amend).\\n  1022→\\t// Set ENTIRE_TEST_TTY=1 to simulate human (amend is always a human operation).\\n  1023→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile, \\\"commit\\\")\\n  1024→\\tprepCmd.Dir = env.RepoDir\\n  1025→\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n  1026→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n  1027→\\t\\tenv.T.Logf(\\\"prepare-commit-msg (amend) output: %s\\\", output)\\n  1028→\\t}\\n  1029→\\n  1030→\\t// Read the modified message\\n  1031→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n  1032→\\tif err != nil {\\n  1033→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n  1034→\\t}\\n  1035→\\n  1036→\\t// Amend the commit using go-git\\n  1037→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1038→\\tif err != nil {\\n  1039→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1040→\\t}\\n  1041→\\n  1042→\\tworktree, err := repo.Worktree()\\n  1043→\\tif err != nil {\\n  1044→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n  1045→\\t}\\n  1046→\\n  1047→\\t_, err = worktree.Commit(string(modifiedMsg), &git.CommitOptions{\\n  1048→\\t\\tAuthor: &object.Signature{\\n  1049→\\t\\t\\tName:  \\\"Test User\\\",\\n  1050→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n  1051→\\t\\t\\tWhen:  time.Now(),\\n  1052→\\t\\t},\\n  1053→\\t\\tAmend: true,\\n  1054→\\t})\\n  1055→\\tif err != nil {\\n  1056→\\t\\tenv.T.Fatalf(\\\"failed to amend commit: %v\\\", err)\\n  1057→\\t}\\n  1058→\\n  1059→\\t// Run post-commit hook\\n  1060→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n  1061→\\tpostCmd.Dir = env