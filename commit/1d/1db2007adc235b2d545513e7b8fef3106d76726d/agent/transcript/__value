n   455→}\\n   456→\\n   457→// GetSessionState reads and returns the session state for the given session ID.\\n   458→func (env *TestEnv) GetSessionState(sessionID string) (*strategy.SessionState, error) {\\n   459→\\tenv.T.Helper()\\n   460→\\n   461→\\tstateFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\", sessionID+\\\".json\\\")\\n   462→\\n   463→\\tdata, err := os.ReadFile(stateFile)\\n   464→\\tif os.IsNotExist(err) {\\n   465→\\t\\treturn nil, nil\\n   466→\\t}\\n   467→\\tif err != nil {\\n   468→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   469→\\t}\\n   470→\\n   471→\\tvar state strategy.SessionState\\n   472→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   473→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse session state: %w\\\", err)\\n   474→\\t}\\n   475→\\treturn &state, nil\\n   476→}\\n   477→\\n   478→// WriteSessionState writes the session state for the given session ID.\\n   479→// This is useful for tests that need to manipulate session state directly.\\n   480→func (env *TestEnv) WriteSessionState(sessionID string, state *strategy.SessionState) error {\\n   481→\\tenv.T.Helper()\\n   482→\\n   483→\\tstateDir := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\")\\n   484→\\tif err := os.MkdirAll(stateDir, 0o755); err != nil {\\n   485→\\t\\treturn fmt.Errorf(\\\"failed to create session state dir: %w\\\", err)\\n   486→\\t}\\n   487→\\n   488→\\tstateFile := filepath.Join(stateDir, sessionID+\\\".json\\\")\\n   489→\\n   490→\\tdata, err := json.MarshalIndent(state, \\\"\\\", \\\"  \\\")\\n   491→\\tif err != nil {\\n   492→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   493→\\t}\\n   494→\\n   495→\\tif err := os.WriteFile(stateFile, data, 0o644); err != nil {\\n   496→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   497→\\t}\\n   498→\\treturn nil\\n   499→}\\n   500→\\n   501→// GeminiHookRunner