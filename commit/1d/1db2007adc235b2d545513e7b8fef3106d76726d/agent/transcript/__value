ostTodo(input)\\n   364→}\\n   365→\\n   366→// ClearSessionState removes the session state file for the given session ID.\\n   367→// This simulates what happens when a user commits their changes (session is \\\"completed\\\").\\n   368→// Used in tests to allow sequential sessions to run without triggering concurrent session warnings.\\n   369→func (env *TestEnv) ClearSessionState(sessionID string) error {\\n   370→\\tenv.T.Helper()\\n   371→\\n   372→\\t// Session state is stored in .git/entire-sessions/<session-id>.json\\n   373→\\tstateFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\", sessionID+\\\".json\\\")\\n   374→\\n   375→\\tif err := os.Remove(stateFile); err != nil && !os.IsNotExist(err) {\\n   376→\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   377→\\t}\\n   378→\\treturn nil\\n   379→}\\n   380→\\n   381→// HookOutput contains the result of running a hook.\\n   382→type HookOutput struct {\\n   383→\\tStdout []byte\\n   384→\\tStderr []byte\\n   385→\\tErr    error\\n   386→}\\n   387→\\n   388→// runHookWithOutput runs a hook and returns both stdout and stderr separately.\\n   389→func (r *HookRunner) runHookWithOutput(hookName string, inputJSON []byte) HookOutput {\\n   390→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"claude-code\\\", hookName)\\n   391→\\tcmd.Dir = r.RepoDir\\n   392→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   393→\\tcmd.Env = append(os.Environ(),\\n   394→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+r.ClaudeProjectDir,\\n   395→\\t)\\n   396→\\n   397→\\tvar stdout, stderr bytes.Buffer\\n   398→\\tcmd.Stdout = &stdout\\n   399→\\tcmd.Stderr = &stderr\\n   400→\\n   401→\\terr := cmd.Run()\\n   402→\\treturn HookOutput{\\n   403→\\t\\tStdout: stdout.Bytes(),\\n   404→\\t\\tStderr: stderr.Bytes(),\\n   405→\\t\\tErr:    err,\\n   406→\\t}\\n   407→}\\n   408→\\n   409→// SimulateUserPromptSubmitWithOutput simulates the UserPromptSubmit hook and returns the output