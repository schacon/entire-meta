→\\n   110→\\tcount := 0\\n   111→\\n   112→\\t// Add hooks that don't already exist\\n   113→\\tfor _, hookName := range c.HookNames() {\\n   114→\\t\\tcmd := cmdPrefix + hookName\\n   115→\\t\\tentries := hookEntries[hookName]\\n   116→\\t\\tif !hookBashExists(entries, cmd) {\\n   117→\\t\\t\\tentries = append(entries, CopilotHookEntry{\\n   118→\\t\\t\\t\\tType:    \\\"command\\\",\\n   119→\\t\\t\\t\\tBash:    cmd,\\n   120→\\t\\t\\t\\tComment: \\\"Entire CLI\\\",\\n   121→\\t\\t\\t})\\n   122→\\t\\t\\thookEntries[hookName] = entries\\n   123→\\t\\t\\tcount++\\n   124→\\t\\t}\\n   125→\\t}\\n   126→\\n   127→\\tif count == 0 {\\n   128→\\t\\treturn 0, nil\\n   129→\\t}\\n   130→\\n   131→\\t// Marshal modified hook types back into rawHooks\\n   132→\\tfor _, hookName := range c.HookNames() {\\n   133→\\t\\tkey := hookConfigKey[hookName]\\n   134→\\t\\tif err := marshalCopilotHookType(rawHooks, key, hookEntries[hookName]); err != nil {\\n   135→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal %s hooks: %w\\\", key, err)\\n   136→\\t\\t}\\n   137→\\t}\\n   138→\\n   139→\\t// Marshal hooks and update raw file\\n   140→\\thooksJSON, err := json.Marshal(rawHooks)\\n   141→\\tif err != nil {\\n   142→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal hooks: %w\\\", err)\\n   143→\\t}\\n   144→\\trawFile[\\\"hooks\\\"] = hooksJSON\\n   145→\\n   146→\\t// Write to file\\n   147→\\tif err := os.MkdirAll(filepath.Dir(hooksPath), 0o750); err != nil {\\n   148→\\t\\treturn 0, fmt.Errorf(\\\"failed to create %s directory: %w\\\", hooksDir, err)\\n   149→\\t}\\n   150→\\n   151→\\toutput, err := jsonutil.MarshalIndentWithNewline(rawFile, \\\"\\\", \\\"  \\\")\\n   152→\\tif err != nil {\\n   153→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal %s: %w\\\", HooksFileName, err)\\n   154→\\t}\\n   155→\\n   156→\\tif err := os.WriteFile(hooksPath, output, 0o600); err != nil {\\n   157→\\t\\treturn 0, fmt.Errorf(\\\"failed to write %s: %w\\\", HooksFileName, err)\\n   158→\\t}\