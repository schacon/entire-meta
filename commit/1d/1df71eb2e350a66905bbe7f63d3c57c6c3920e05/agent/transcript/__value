 json.Marshal(entries)\\n   270→\\tif err != nil {\\n   271→\\t\\treturn // Silently ignore marshal errors (shouldn't happen)\\n   272→\\t}\\n   273→\\trawHooks[hookType] = data\\n   274→}\\n   275→\\n   276→// hookBashExists checks if a hook with the given bash command already exists.\\n   277→func hookBashExists(entries []CopilotHookEntry, bash string) bool {\\n   278→\\tfor _, entry := range entries {\\n   279→\\t\\tif entry.Bash == bash {\\n   280→\\t\\t\\treturn true\\n   281→\\t\\t}\\n   282→\\t}\\n   283→\\treturn false\\n   284→}\\n   285→\\n   286→// isEntireHook checks if a hook entry's bash command belongs to Entire.\\n   287→func isEntireHook(bash string) bool {\\n   288→\\tfor _, prefix := range entireHookPrefixes {\\n   289→\\t\\tif strings.HasPrefix(bash, prefix) {\\n   290→\\t\\t\\treturn true\\n   291→\\t\\t}\\n   292→\\t}\\n   293→\\treturn false\\n   294→}\\n   295→\\n   296→// hasEntireHook checks if any entry in the slice is an Entire hook.\\n   297→func hasEntireHook(entries []CopilotHookEntry) bool {\\n   298→\\tfor _, entry := range entries {\\n   299→\\t\\tif isEntireHook(entry.Bash) {\\n   300→\\t\\t\\treturn true\\n   301→\\t\\t}\\n   302→\\t}\\n   303→\\treturn false\\n   304→}\\n   305→\\n   306→// removeEntireHooks removes all Entire hooks from the slice.\\n   307→func removeEntireHooks(entries []CopilotHookEntry) []CopilotHookEntry {\\n   308→\\tresult := make([]CopilotHookEntry, 0, len(entries))\\n   309→\\tfor _, entry := range entries {\\n   310→\\t\\tif !isEntireHook(entry.Bash) {\\n   311→\\t\\t\\tresult = append(result, entry)\\n   312→\\t\\t}\\n   313→\\t}\\n   314→\\treturn result\\n   315→}\\n   316→\"}]},\"uuid\":\"89817039-706a-4055-9ae2-53f8de2b0c3d\",\"timestamp\":\"2026-03-04T03:51:00.778Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a23b46a424818f2ab\"},\"toolUseID\":\"agent_msg_01Bhy2u1TFqAdgiwpk3koMNW\",\"parentToolUseID\":\"toolu_013Wdxq3xiAFLCxeoVSaXuPQ\",\"uuid\":\"97b664ab-