\tslices.Sort(names)\\n    64→\\treturn names\\n    65→}\\n    66→\\n    67→// DetectAll returns all agents whose DetectPresence reports true.\\n    68→// Agents are checked in sorted name order (via List()) for deterministic results.\\n    69→// Returns an empty slice when no agent is detected.\\n    70→func DetectAll(ctx context.Context) []Agent {\\n    71→\\tnames := List() // sorted, lock-safe\\n    72→\\n    73→\\tvar detected []Agent\\n    74→\\tfor _, name := range names {\\n    75→\\t\\tag, err := Get(name)\\n    76→\\t\\tif err != nil {\\n    77→\\t\\t\\tcontinue\\n    78→\\t\\t}\\n    79→\\t\\tif present, err := ag.DetectPresence(ctx); err == nil && present {\\n    80→\\t\\t\\tdetected = append(detected, ag)\\n    81→\\t\\t}\\n    82→\\t}\\n    83→\\treturn detected\\n    84→}\\n    85→\\n    86→// Detect attempts to auto-detect which agent is being used.\\n    87→// Iterates registered agents in sorted name order for deterministic results.\\n    88→// Returns the first agent whose DetectPresence reports true.\\n    89→func Detect(ctx context.Context) (Agent, error) {\\n    90→\\tdetected := DetectAll(ctx)\\n    91→\\tif len(detected) == 0 {\\n    92→\\t\\treturn nil, fmt.Errorf(\\\"no agent detected (available: %v)\\\", List())\\n    93→\\t}\\n    94→\\treturn detected[0], nil\\n    95→}\\n    96→\\n    97→// Agent name constants (registry keys)\\n    98→const (\\n    99→\\tAgentNameClaudeCode     types.AgentName = \\\"claude-code\\\"\\n   100→\\tAgentNameCopilotCLI     types.AgentName = \\\"copilot-cli\\\"\\n   101→\\tAgentNameCursor         types.AgentName = \\\"cursor\\\"\\n   102→\\tAgentNameFactoryAIDroid types.AgentName = \\\"factoryai-droid\\\"\\n   103→\\tAgentNameGemini         types.AgentName = \\\"gemini\\\"\\n   104→\\tAgentNameOpenCode       types.AgentName = \\\"opencode\\\"\\n   105→)\\n   106→\\n   107→// Agent type constants (type identifiers stored in metadata/trailers)\\n   108→const (\\n   109→\\tAgentTypeClaudeCode     types.AgentType