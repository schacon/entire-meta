tify Entire hooks in the bash field.\\n    25→var entireHookPrefixes = []string{\\n    26→\\t\\\"entire \\\",\\n    27→\\t\\\"go run ${COPILOT_PROJECT_DIR}/cmd/entire/main.go \\\",\\n    28→}\\n    29→\\n    30→// hookConfigKey maps our kebab-case hook names to camelCase JSON keys.\\n    31→var hookConfigKey = map[string]string{\\n    32→\\tHookNameUserPromptSubmitted: \\\"userPromptSubmitted\\\",\\n    33→\\tHookNameSessionStart:        \\\"sessionStart\\\",\\n    34→\\tHookNameAgentStop:           \\\"agentStop\\\",\\n    35→\\tHookNameSessionEnd:          \\\"sessionEnd\\\",\\n    36→\\tHookNameSubagentStop:        \\\"subagentStop\\\",\\n    37→\\tHookNamePreToolUse:          \\\"preToolUse\\\",\\n    38→\\tHookNamePostToolUse:         \\\"postToolUse\\\",\\n    39→\\tHookNameErrorOccurred:       \\\"errorOccurred\\\",\\n    40→}\\n    41→\\n    42→// InstallHooks installs Copilot CLI hooks in .github/hooks/entire.json.\\n    43→// If force is true, removes existing Entire hooks before installing.\\n    44→// Returns the number of hooks installed.\\n    45→// Unknown top-level fields and hook types are preserved on round-trip.\\n    46→func (c *CopilotCLIAgent) InstallHooks(ctx context.Context, localDev bool, force bool) (int, error) {\\n    47→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    48→\\tif err != nil {\\n    49→\\t\\tworktreeRoot = \\\".\\\"\\n    50→\\t}\\n    51→\\n    52→\\thooksPath := filepath.Join(worktreeRoot, hooksDir, HooksFileName)\\n    53→\\n    54→\\t// Use raw maps to preserve unknown fields on round-trip\\n    55→\\tvar rawFile map[string]json.RawMessage\\n    56→\\tvar rawHooks map[string]json.RawMessage\\n    57→\\n    58→\\texistingData, readErr := os.ReadFile(hooksPath) //nolint:gosec // path is constructed from repo root + fixed path\\n    59→\\tswitch {\\n    60→\\tcase readErr == nil:\\n    61→\\t\\tif err := json.Unmarshal(existingData, &rawFile); err != nil {\\n    62→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse exis