es the strategy is properly set up.\\n    52→func EnsureSetup() error {\\n    53→\\tif err := EnsureEntireGitignore(); err != nil {\\n    54→\\t\\treturn err\\n    55→\\t}\\n    56→\\n    57→\\t// Ensure the entire/checkpoints/v1 orphan branch exists for permanent session storage\\n    58→\\trepo, err := OpenRepository()\\n    59→\\tif err != nil {\\n    60→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n    61→\\t}\\n    62→\\tif err := EnsureMetadataBranch(repo); err != nil {\\n    63→\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n    64→\\t}\\n    65→\\n    66→\\t// Install generic hooks (they delegate to strategy at runtime)\\n    67→\\tif !IsGitHookInstalled() {\\n    68→\\t\\tif _, err := InstallGitHook(true, isLocalDev()); err != nil {\\n    69→\\t\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n    70→\\t\\t}\\n    71→\\t}\\n    72→\\treturn nil\\n    73→}\\n    74→\\n    75→// IsAncestorOf checks if commit is an ancestor of (or equal to) target.\\n    76→// Returns true if target can reach commit by following parent links.\\n    77→// Limits search to 1000 commits to avoid excessive traversal.\\n    78→func IsAncestorOf(repo *git.Repository, commit, target plumbing.Hash) bool {\\n    79→\\tif commit == target {\\n    80→\\t\\treturn true\\n    81→\\t}\\n    82→\\n    83→\\titer, err := repo.Log(&git.LogOptions{From: target})\\n    84→\\tif err != nil {\\n    85→\\t\\treturn false\\n    86→\\t}\\n    87→\\tdefer iter.Close()\\n    88→\\n    89→\\tfound := false\\n    90→\\tcount := 0\\n    91→\\t_ = iter.ForEach(func(c *object.Commit) error { //nolint:errcheck // Best-effort search, errors are non-fatal\\n    92→\\t\\tcount++\\n    93→\\t\\tif count > 1000 {\\n    94→\\t\\t\\treturn errStop\\n    95→\\t\\t}\\n    96→\\t\\tif c.Hash == commit {\\n    97→\\t\\t\\tfound = true\\n    98→\\t\\t\\treturn errStop\\n    99→\\t\\t}\\n   100→\\t\\treturn nil\\n   101→\\t})\\n   102→\\n   103→\\treturn found\\n   104→}\\n   105→\\n   106→// ListCheckpoints returns all checkpoints from the entire/checkpoints/v1 branch.\\n   107→// Scans sharded paths: <id[:2]>/<id[2:]>/ directories containing metadata.json.\\n   108→func ListCheckpoints() ([]CheckpointInfo, error) {\\n   109→\\trepo, err := OpenRepository()\\n   110→\\tif err != nil {\\n   111→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   112→\\t}\\n   113→\\n   114→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   115→\\tref, err := repo.Reference(refName, true)\\n   116→\\tif err != nil {\\n   117→\\t\\t//nolint:nilerr // No sessions branch yet is expected, return empty list\\n   118→\\t\\treturn []CheckpointInfo{}, nil\\n   119→\\t}\\n   120→\\n   121→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   122→\\tif err != nil {\\n   123→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   124→\\t}\\n   125→\\n   126→\\ttree, err := commit.Tree()\\n   127→\\tif err != nil {\\n   128→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   129→\\t}\\n   130→\\n   131→\\tvar checkpoints []CheckpointInfo\\n   132→\\n   133→\\t// Scan sharded structure: <2-char-prefix>/<remaining-id>/metadata.json\\n   134→\\t// The tree has 2-character directories (hex buckets)\\n   135→\\tfor _, bucketEntry := range tree.Entries {\\n   136→\\t\\tif bucketEntry.Mode != filemode.Dir {\\n   137→\\t\\t\\tcontinue\\n   138→\\t\\t}\\n   139→\\t\\t// Bucket should be 2 hex chars\\n   140→\\t\\tif len(bucketEntry.Name) != 2 {\\n   141→\\t\\t\\tcontinue\\n   142→\\t\\t}\\n   143→\\n   144→\\t\\tbucketTree, treeErr := repo.TreeObject(bucketEntry.Hash)\\n   145→\\t\\tif treeErr != nil {\\n   146→\\t\\t\\tcontinue\\n   147→\\t\\t}\\n   148→\\n   149→\\t\\t// Each entry in the bucket is the remaining part of the checkpoint ID\\n   150→\\t\\tfor _, checkpointEntry := range bucketTree.Entries {\\n   151→\\t\\t\\tif checkpointEntry.Mode != filemode.Dir {\\n   152→\\t\\t\\t\\tcontinue\\n   153→\\t\\t\\t}\\n   154→\\n   155→\\t\\t\\tcheckpointTree, cpTreeErr := repo.TreeObject(checkpointEntry.Hash)\\n   156→\\t\\t\\tif cpTreeErr != nil {\\n   157→\\t\\t\\t\\tcontinue\\n   158→\\t\\t\\t}\\n   159→\\n   160→\\t\\t\\t// Reconstruct checkpoint ID: <bucket><remaining>\\n   161→\\t\\t\\tcheckpointIDStr := bucketEntry.Name + checkpointEntry.Name\\n   162→\\t\\t\\tcheckpointID, cpErr := id.NewCheckpointID(checkpointIDStr)\\n   163→\\t\\t\\tif cpErr != nil {\\n   164→\\t\\t\\t\\t// Skip invalid checkpoint IDs\\n   165→\\t\\t\\t\\tcontinue\\n   166→\\t\\t\\t}\\n   167→\\n   168→\\t\\t\\tinfo := CheckpointInfo{\\n   169→\\t\\t\\t\\tCheckpointID: checkpointID,\\n   170→\\t\\t\\t}\\n   171→\\n   172→\\t\\t\\t// Get details from metadata file (CheckpointSummary format)\\n   173→\\t\\t\\tif metadataFile, fileErr := checkpointTree.File(paths.MetadataFileName); fileErr == nil {\\n   174→\\t\\t\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n   175→\\t\\t\\t\\t\\tvar summary checkpoint.CheckpointSummary\\n   176→\\t\\t\\t\\t\\tif json.Unmarshal([]byte(content), &summary) == nil && len(summary.Sessions) > 0 {\\n   177→\\t\\t\\t\\t\\t\\tinfo.CheckpointsCount = summary.CheckpointsCount\\n   178→\\t\\t\\t\\t\\t\\tinfo.FilesTouched = summary.FilesTouched\\n   179→\\t\\t\\t\\t\\t\\tinfo.SessionCount = len(summary.Sessions)\\n   180→\\n   181→\\t\\t\\t\\t\\t\\t// Read session-level metadata for Agent, SessionID, CreatedAt, SessionIDs\\n   182→\\t\\t\\t\\t\\t\\tfor i, sessionPaths := range summary.Sessions {\\n   183→\\t\\t\\t\\t\\t\\t\\tif sessionPaths.Metadata != \\\"\\\" {\\n   184→\\t\\t\\t\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n   185→\\t\\t\\t\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n   186→\\t\\t\\t\\t\\t\\t\\t\\tsessionMetadataPath := strings.TrimPrefix(sessionPaths.Metadata, \\\"/\\\")\\n   187→\\t\\t\\t\\t\\t\\t\\t\\tif sessionFile, sErr := tree.File(sessionMetadataPath); sErr == nil {\\n   188→\\t\\t\\t\\t\\t\\t\\t\\t\\tif sessionContent, scErr := sessionFile.Contents(); scErr == nil {\\n   189→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata checkpoint.CommittedMetadata\\n   190→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   191→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionIDs = append(info.SessionIDs, sessionMetadata.SessionID)\\n   192→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t// Use first session's metadata for Agent, SessionID, CreatedAt\\n   193→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif i == 0 {\\n   194→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   195→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   196→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   197→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.IsTask = sessionMetadata.IsTask\\n   198→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.ToolUseID = sessionMetadata.ToolUseID\\n   199→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   200→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   201→\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   202→\\t\\t\\t\\t\\t\\t\\t\\t}\\n   203→\\t\\t\\t\\t\\t\\t\\t}\\n   204→\\t\\t\\t\\t\\t\\t}\\n   205→\\t\\t\\t\\t\\t}\\n   206→\\t\\t\\t\\t}\\n   207→\\t\\t\\t}\\n   208→\\n   209→\\t\\t\\tcheckpoints = append(checkpoints, info)\\n   210→\\t\\t}\\n   211→\\t}\\n   212→\\n   213→\\t// Sort by time (most recent first)\\n   214→\\tsort.Slice(checkpoints, func(i, j int) bool {\\n   215→\\t\\treturn checkpoints[i].CreatedAt.After(checkpoints[j].CreatedAt)\\n   216→\\t})\\n   217→\\n   218→\\treturn checkpoints, nil\\n   219→}\\n   220→\\n   221→const (\\n   222→\\tentireGitignore    = \\\".entire/.gitignore\\\"\\n   223→\\tentireDir          = \\\".entire\\\"\\n   224→\\tgitDir             = \\\".git\\\"\\n   225→\\tshadowBranchPrefix = \\\"entire/\\\"\\n   226→\\n   227→\\t// DefaultAgentType is the generic fallback agent type name\\n   228→\\tDefaultAgentType = agent.AgentTypeUnknown\\n   229→)\\n   230→\\n   231→// isProtectedPath returns true if relPath is inside a directory that should\\n   232→// never be modified or deleted during rewind or other destructive operations.\\n   233→// Protected directories include git internals, entire metadata, and all\\n   234→// registered agent config directories.\\n   235→func isProtectedPath(relPath string) bool {\\n   236→\\tfor _, dir := range protectedDirs() {\\n   237→\\t\\tif relPath == dir || strings.HasPrefix(relPath, dir+string(filepath.Separator)) {\\n   238→\\t\\t\\treturn true\\n   239→\\t\\t}\\n   240→\\t}\\n   241→\\treturn false\\n   242→}\\n   243→\\n   244→// protectedDirs returns the list of directories to protect. This combines\\n   245→// static infrastructure dirs with agent-reported dirs from the registry.\\n   246→// The result is cached via sync.Once since it's called per-file when filtering untracked files.\\n   247→//\\n   248→// NOTE: The cache is never invalidated. In production this is fine (the agent registry\\n   249→// is populated at init time and never changes). However, tests that mutate the agent\\n   250→// registry after the first call to protectedDirs/isProtectedPath will see stale results.\\n   251→// If you need to test isProtectedPath with a custom registry, either:\\n   252→//   - run those tests in a separate process, or\\n   253→//   - call resetProtectedDirsForTest() to clear the cache.\\n   254→func protectedDirs() []string {\\n   255→\\tprotectedDirsOnce.Do(func() {\\n   256→\\t\\tprotectedDirsCache = append([]string{gitDir, entireDir}, agent.AllProtectedDirs()...)\\n   257→\\t})\\n   258→\\treturn protectedDirsCache\\n   259→}\\n   260→\\n   261→var (\\n   262→\\tprotectedDirsOnce  sync.Once\\n   263→\\tprotectedDirsCache []string\\n   264→)\\n   265→\\n   266→// isSpecificAgentType returns true if the agent type is a known, specific value\\n   267→// (not empty and not the generic \\\"Agent\\\" fallback).\\n   268→func isSpecificAgentType(t agent.AgentType) bool {\\n   269→\\treturn t != \\\"\\\" && t != DefaultAgentType\\n   270→}\\n   271→\\n   272→// resolveAgentType picks the best agent type from the context and existing state.\\n   273→// Priority: existing state (if specific) > context value > default fallback.\\n   274→func resolveAgentType(ctxAgentType agent.AgentType, state *SessionState) agent.AgentType {\\n   275→\\tif state != nil && isSpecificAgentType(state.AgentType) {\\n   276→\\t\\treturn state.AgentType\\n   277→\\t}\\n   278→\\tif ctxAgentType != \\\"\\\" {\\n   279→\\t\\treturn ctxAgentType\\n   280→\\t}\\n   281→\\treturn DefaultAgentType\\n   282→}\\n   283→\\n   284→// ensureMetadataBranch creates the orphan entire/checkpoints/v1 branch if it doesn't exist.\\n   285→// This branch has no parent and starts with an empty tree.\\n   286→func EnsureMetadataBranch(repo *git.Repository) error {\\n   287→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   288→\\n   289→\\t// Check if branch already exists\\n   290→\\t_, err := repo.Reference(refName, true)\\n   291→\\tif err == nil {\\n   292→\\t\\t// Branch already exists\\n   293→\\t\\treturn nil\\n   294→\\t}\\n   295→\\n   296→\\t// Create empty tree (no files)\\n   297→\\temptyTree := &object.Tree{Entries: []object.TreeEntry{}}\\n   298→\\tobj := repo.Storer.NewEncodedObject()\\n   299→\\tif err := emptyTree.Encode(obj); err != nil {\\n   300→\\t\\treturn fmt.Errorf(\\\"failed to encode empty tree: %w\\\", err)\\n   301→\\t}\\n   302→\\temptyTreeHash, err := repo.Storer.SetEncodedObject(obj)\\n   303→\\tif err != nil {\\n   304→\\t\\treturn fmt.Errorf(\\\"failed to store empty tree: %w\\\", err)\\n   305→\\t}\\n   306→\\n   307→\\t// Create orphan commit (no parent)\\n   308→\\tnow := time.Now()\\n   309→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   310→\\tsig := object.Signature{\\n   311→\\t\\tName:  authorName,\\n   312→\\t\\tEmail: authorEmail,\\n   313→\\t\\tWhen:  now,\\n   314→\\t}\\n   315→\\n   316→\\tcommit := &object.Commit{\\n   317→\\t\\tTreeHash:  emptyTreeHash,\\n   318→\\t\\tAuthor:    sig,\\n   319→\\t\\tCommitter: sig,\\n   320→\\t\\tMessage:   \\\"Initialize metadata branch\\\\n\\\\nThis branch stores session metadata.\\\\n\\\",\\n   321→\\t}\\n   322→\\t// Note: No ParentHashes - this is an orphan commit\\n   323→\\n   324→\\tcommitObj := repo.Storer.NewEncodedObject()\\n   325→\\tif err := commit.Encode(commitObj); err != nil {\\n   326→\\t\\treturn fmt.Errorf(\\\"failed to encode orphan commit: %w\\\", err)\\n   327→\\t}\\n   328→\\tcommitHash, err := repo.Storer.SetEncodedObject(commitObj)\\n   329→\\tif err != nil {\\n   330→\\t\\treturn fmt.Errorf(\\\"failed to store orphan commit: %w\\\", err)\\n   331→\\t}\\n   332→\\n   333→\\t// Create branch reference\\n   334→\\tref := plumbing.NewHashReference(refName, commitHash)\\n   335→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   336→\\t\\treturn fmt.Errorf(\\\"failed to create metadata branch: %w\\\", err)\\n   337→\\t}\\n   338→\\n   339→\\tfmt.Fprintf(os.Stderr, \\\"✓ Created orphan branch '%s' for session metadata\\\\n\\\", paths.MetadataBranchName)\\n   340→\\treturn nil\\n   341→}\\n   342→\\n   343→// readCheckpointMetadata reads metadata.json from a checkpoint path on entire/checkpoints/v1.\\n   344→// With the new format, root metadata.json is a CheckpointSummary with Agents array.\\n   345→// This function reads the summary and extracts relevant fields into CheckpointInfo,\\n   346→// also reading session-level metadata for IsTask/ToolUseID fields.\\n   347→func ReadCheckpointMetadata(tree *object.Tree, checkpointPath string) (*CheckpointInfo, error) {\\n   348→\\tmetadataPath := checkpointPath + \\\"/metadata.json\\\"\\n   349→\\tfile, err := tree.File(metadataPath)\\n   350→\\tif err != nil {\\n   351→\\t\\treturn nil, fmt.Errorf(\\\"failed to find metadata at %s: %w\\\", metadataPath, err)\\n   352→\\t}\\n   353→\\n   354→\\tcontent, err := file.Contents()\\n   355→\\tif err != nil {\\n   356→\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata: %w\\\", err)\\n   357→\\t}\\n   358→\\n   359→\\t// Try to parse as CheckpointSummary first (new format)\\n   360→\\tvar summary checkpoint.CheckpointSummary\\n   361→\\tif err := json.Unmarshal([]byte(content), &summary); err == nil {\\n   362→\\t\\t// If we have sessions array, this is the new format\\n   363→\\t\\tif len(summary.Sessions) > 0 {\\n   364→\\t\\t\\tinfo := &CheckpointInfo{\\n   365→\\t\\t\\t\\tCheckpointID:     summary.CheckpointID,\\n   366→\\t\\t\\t\\tCheckpointsCount: summary.CheckpointsCount,\\n   367→\\t\\t\\t\\tFilesTouched:     summary.FilesTouched,\\n   368→\\t\\t\\t\\tSessionCount:     len(summary.Sessions),\\n   369→\\t\\t\\t}\\n   370→\\n   371→\\t\\t\\t// Read all sessions' metadata to populate SessionIDs and get other fields from first session\\n   372→\\t\\t\\tvar sessionIDs []string\\n   373→\\t\\t\\tfor i, sessionPaths := range summary.Sessions {\\n   374→\\t\\t\\t\\tif sessionPaths.Metadata != \\\"\\\" {\\n   375→\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n   376→\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n   377→\\t\\t\\t\\t\\tsessionMetadataPath := strings.TrimPrefix(sessionPaths.Metadata, \\\"/\\\")\\n   378→\\t\\t\\t\\t\\tif sessionFile, err := tree.File(sessionMetadataPath); err == nil {\\n   379→\\t\\t\\t\\t\\t\\tif sessionContent, err := sessionFile.Contents(); err == nil {\\n   380→\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata checkpoint.CommittedMetadata\\n   381→\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   382→\\t\\t\\t\\t\\t\\t\\t\\tsessionIDs = append(sessionIDs, sessionMetadata.SessionID)\\n   383→\\t\\t\\t\\t\\t\\t\\t\\t// Use first session for Agent, SessionID, CreatedAt, IsTask, ToolUseID\\n   384→\\t\\t\\t\\t\\t\\t\\t\\tif i == 0 {\\n   385→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   386→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   387→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   388→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.IsTask = sessionMetadata.IsTask\\n   389→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.ToolUseID = sessionMetadata.ToolUseID\\n   390→\\t\\t\\t\\t\\t\\t\\t\\t}\\n   391→\\t\\t\\t\\t\\t\\t\\t}\\n   392→\\t\\t\\t\\t\\t\\t}\\n   393→\\t\\t\\t\\t\\t}\\n   394→\\t\\t\\t\\t}\\n   395→\\t\\t\\t}\\n   396→\\t\\t\\tinfo.SessionIDs = sessionIDs\\n   397→\\n   398→\\t\\t\\treturn info, nil\\n   399→\\t\\t}\\n   400→\\t}\\n   401→\\n   402→\\t// Fall back to parsing as CheckpointInfo (old format or direct info)\\n   403→\\tvar metadata CheckpointInfo\\n   404→\\tif err := json.Unmarshal([]byte(content), &metadata); err != nil {\\n   405→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata: %w\\\", err)\\n   406→\\t}\\n   407→\\n   408→\\treturn &metadata, nil\\n   409→}\\n   410→\\n   411→// GetMetadataBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\n   412→func GetMetadataBranchTree(repo *git.Repository) (*object.Tree, error) {\\n   413→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   414→\\tref, err := repo.Reference(refName, true)\\n   415→\\tif err != nil {\\n   416→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch reference: %w\\\", err)\\n   417→\\t}\\n   418→\\n   419→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   420→\\tif err != nil {\\n   421→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch commit: %w\\\", err)\\n   422→\\t}\\n   423→\\n   424→\\ttree, err := commit.Tree()\\n   425→\\tif err != nil {\\n   426→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch tree: %w\\\", err)\\n   427→\\t}\\n   428→\\treturn tree, nil\\n   429→}\\n   430→\\n   431→// ExtractFirstPrompt extracts and truncates the first meaningful prompt from prompt content.\\n   432→// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\". Skips empty prompts and separator-only content.\\n   433→// Returns empty string if no valid prompt is found.\\n   434→func ExtractFirstPrompt(content string) string {\\n   435→\\tif content == \\\"\\\" {\\n   436→\\t\\treturn \\\"\\\"\\n   437→\\t}\\n   438→\\n   439→\\t// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\"\\n   440→\\t// Find the first non-empty prompt\\n   441→\\tprompts := strings.Split(content, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   442→\\tvar firstPrompt string\\n   443→\\tfor _, p := range prompts {\\n   444→\\t\\tcleaned := strings.TrimSpace(p)\\n   445→\\t\\t// Skip empty prompts or prompts that are just dashes/separators\\n   446→\\t\\tif cleaned == \\\"\\\" || isOnlySeparators(cleaned) {\\n   447→\\t\\t\\tcontinue\\n   448→\\t\\t}\\n   449→\\t\\tfirstPrompt = cleaned\\n   450→\\t\\tbreak\\n   451→\\t}\\n   452→\\n   453→\\tif firstPrompt == \\\"\\\" {\\n   454→\\t\\treturn \\\"\\\"\\n   455→\\t}\\n   456→\\n   457→\\treturn TruncateDescription(firstPrompt, MaxDescriptionLength)\\n   458→}\\n   459→\\n   460→// ReadSessionPromptFromTree reads the first meaningful prompt from a checkpoint's prompt.txt file in a git tree.\\n   461→// Returns an empty string if the prompt cannot be read.\\n   462→func ReadSessionPromptFromTree(tree *object.Tree, checkpointPath string) string {\\n   463→\\tpromptPath := checkpointPath + \\\"/\\\" + paths.PromptFileName\\n   464→\\tfile, err := tree.File(promptPath)\\n   465→\\tif err != nil {\\n   466→\\t\\treturn \\\"\\\"\\n   467→\\t}\\n   468→\\n   469→\\tcontent, err := file.Contents()\\n   470→\\tif err != nil {\\n   471→\\t\\treturn \\\"\\\"\\n   472→\\t}\\n   473→\\n   474→\\treturn ExtractFirstPrompt(content)\\n   475→}\\n   476→\\n   477→// ReadAgentTypeFromTree reads the agent type from a checkpoint's metadata.json file in a git tree.\\n   478→// If metadata.json doesn't exist (shadow branches), it falls back to detecting the agent\\n   479→// from the presence of agent-specific config files (.gemini/settings.json or .claude/).\\n   480→// Returns agent.AgentTypeUnknown if the agent type cannot be determined.\\n   481→func ReadAgentTypeFromTree(tree *object.Tree, checkpointPath string) agent.AgentType {\\n   482→\\t// First, try to read from metadata.json (present in condensed/committed checkpoints)\\n   483→\\tmetadataPath := checkpointPath + \\\"/\\\" + paths.MetadataFileName\\n   484→\\tif file, err := tree.File(metadataPath); err == nil {\\n   485→\\t\\tif content, err := file.Contents(); err == nil {\\n   486→\\t\\t\\tvar metadata checkpoint.CommittedMetadata\\n   487→\\t\\t\\tif err := json.Unmarshal([]byte(content), &metadata); err == nil && metadata.Agent != \\\"\\\" {\\n   488→\\t\\t\\t\\treturn metadata.Agent\\n   489→\\t\\t\\t}\\n   490→\\t\\t}\\n   491→\\t}\\n   492→\\n   493→\\t// Fall back to detecting agent from config files (shadow branches don't have metadata.json).\\n   494→\\t// Order: Gemini (most specific check), Claude (established default), OpenCode (newest/preview).\\n   495→\\tif _, err := tree.File(\\\".gemini/settings.json\\\"); err == nil {\\n   496→\\t\\treturn agent.AgentTypeGemini\\n   497→\\t}\\n   498→\\tif _, err := tree.Tree(\\\".claude\\\"); err == nil {\\n   499→\\t\\treturn agent.AgentTypeClaudeCode\\n   500→\\t}\\n   501→\\t// OpenCode: .opencode directory or opencode.json config\\n   502→\\tif _, err := tree.Tree(\\\".opencode\\\"); err == nil {\\n   503→\\t\\treturn agent.AgentTypeOpenCode\\n   504→\\t}\\n   505→\\tif _, err := tree.File(\\\"opencode.json\\\"); err == nil {\\n   506→\\t\\treturn agent.AgentTypeOpenCode\\n   507→\\t}\\n   508→\\n   509→\\treturn agent.AgentTypeUnknown\\n   510→}\\n   511→\\n   512→// isOnlySeparators checks if a string contains only dashes, spaces, and newlines.\\n   513→func isOnlySeparators(s string) bool {\\n   514→\\tfor _, r := range s {\\n   515→\\t\\tif r != '-' && r != ' ' && r != '\\\\n' && r != '\\\\r' && r != '\\\\t' {\\n   516→\\t\\t\\treturn false\\n   517→\\t\\t}\\n   518→\\t}\\n   519→\\treturn true\\n   520→}\\n   521→\\n   522→// ReadAllSessionPromptsFromTree reads the first prompt for all sessions in a multi-session checkpoint.\\n   523→// Returns a slice of prompts parallel to sessionIDs (oldest to newest).\\n   524→// For single-session checkpoints, returns a slice with just the root prompt.\\n   525→func ReadAllSessionPromptsFromTree(tree *object.Tree, checkpointPath string, sessionCount int, sessionIDs []string) []string {\\n   526→\\tif sessionCount <= 1 || len(sessionIDs) <= 1 {\\n   527→\\t\\t// Single session - just return the root prompt\\n   528→\\t\\tprompt := ReadSessionPromptFromTree(tree, checkpointPath)\\n   529→\\t\\tif prompt != \\\"\\\" {\\n   530→\\t\\t\\treturn []string{prompt}\\n   531→\\t\\t}\\n   532→\\t\\treturn nil\\n   533→\\t}\\n   534→\\n   535→\\t// Multi-session: read prompts from archived folders (0/, 1/, etc.) and root\\n   536→\\tprompts := make([]string, len(sessionIDs))\\n   537→\\n   538→\\t// Read archived session prompts (folders 0, 1, ... N-2)\\n   539→\\tfor i := range sessionCount - 1 {\\n   540→\\t\\tarchivedPath := fmt.Sprintf(\\\"%s/%d\\\", checkpointPath, i)\\n   541→\\t\\tprompts[i] = ReadSessionPromptFromTree(tree, archivedPath)\\n   542→\\t}\\n   543→\\n   544→\\t// Read the most recent session prompt (at root level)\\n   545→\\tprompts[len(prompts)-1] = ReadSessionPromptFromTree(tree, checkpointPath)\\n   546→\\n   547→\\treturn prompts\\n   548→}\\n   549→\\n   550→// GetRemoteMetadataBranchTree returns the tree object for origin/entire/checkpoints/v1.\\n   551→func GetRemoteMetadataBranchTree(repo *git.Repository) (*object.Tree, error) {\\n   552→\\trefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n   553→\\tref, err := repo.Reference(refName, true)\\n   554→\\tif err != nil {\\n   555→\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch reference: %w\\\", err)\\n   556→\\t}\\n   557→\\n   558→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   559→\\tif err != nil {\\n   560→\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch commit: %w\\\", err)\\n   561→\\t}\\n   562→\\n   563→\\ttree, err := commit.Tree()\\n   564→\\tif err != nil {\\n   565→\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch tree: %w\\\", err)\\n   566→\\t}\\n   567→\\treturn tree, nil\\n   568→}\\n   569→\\n   570→// OpenRepository opens the git repository with linked worktree support enabled.\\n   571→// It uses git.PlainOpenWithOptions with EnableDotGitCommonDir set to true,\\n   572→// which is required for proper operation in git worktrees created via 'git worktree add'.\\n   573→//\\n   574→// Without EnableDotGitCommonDir, go-git operations in worktrees can silently fail:\\n   575→// - Commits appear to succeed but are not persisted\\n   576→// - Refs are written to incorrect locations\\n   577→// - The worktree's HEAD/index don't get updated properly\\n   578→//\\n   579→// This happens because worktrees use .git as a file (pointing to the main repo)\\n   580→// rather than a directory, and go-git needs to route paths correctly between\\n   581→// shared (.git/) and per-worktree (.git/worktrees/<name>/) locations.\\n   582→//\\n   583→// The function first uses 'git rev-parse --show-toplevel' to find the repository\\n   584→// root, which works correctly even when called from a subdirectory within the repo.\\n   585→func OpenRepository() (*git.Repository, error) {\\n   586→\\trepoRoot, err := paths.WorktreeRoot()\\n   587→\\tif err != nil {\\n   588→\\t\\t// Fallback to current directory if git command fails\\n   589→\\t\\t// (e.g., if git is not installed or we're not in a repo)\\n   590→\\t\\trepoRoot = \\\".\\\"\\n   591→\\t}\\n   592→\\n   593→\\trepo, err := git.PlainOpenWithOptions(repoRoot, &git.PlainOpenOptions{\\n   594→\\t\\tEnableDotGitCommonDir: true,\\n   595→\\t})\\n   596→\\tif err != nil {\\n   597→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   598→\\t}\\n   599→\\treturn repo, nil\\n   600→}\\n   601→\\n   602→// IsInsideWorktree returns true if the current directory is inside a git worktree\\n   603→// (as opposed to the main repository). Worktrees have .git as a file pointing\\n   604→// to the main repo, while the main repo has .git as a directory.\\n   605→// This function works correctly from any subdirectory within the repository.\\n   606→func IsInsideWorktree() bool {\\n   607→\\t// First find the repository root\\n   608→\\trepoRoot, err := paths.WorktreeRoot()\\n   609→\\tif err != nil {\\n   610→\\t\\treturn false\\n   611→\\t}\\n   612→\\n   613→\\tgitPath := filepath.Join(repoRoot, gitDir)\\n   614→\\tgitInfo, err := os.Stat(gitPath)\\n   615→\\tif err != nil {\\n   616→\\t\\treturn false\\n   617→\\t}\\n   618→\\treturn !gitInfo.IsDir()\\n   619→}\\n   620→\\n   621→// GetMainRepoRoot returns the root directory of the main repository.\\n   622→// In the main repo, this is the worktree path (repo root).\\n   623→// In a worktree, this parses the .git file to find the main repo.\\n   624→// This function works correctly from any subdirectory within the repository.\\n   625→//\\n   626→// Per gitrepository-layout(5), a worktree's .git file is a \\\"gitfile\\\" containing\\n   627→// \\\"gitdir: <path>\\\" pointing to $GIT_DIR/worktrees/<id> in the main repository.\\n   628→// See: https://git-scm.com/docs/gitrepository-layout\\n   629→func GetMainRepoRoot() (string, error) {\\n   630→\\t// First find the worktree/repo root\\n   631→\\trepoRoot, err := paths.WorktreeRoot()\\n   632→\\tif err != nil {\\n   633→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get worktree path: %w\\\", err)\\n   634→\\t}\\n   635→\\n   636→\\tif !IsInsideWorktree() {\\n   637→\\t\\treturn repoRoot, nil\\n   638→\\t}\\n   639→\\n   640→\\t// Worktree .git file contains: \\\"gitdir: /path/to/main/.git/worktrees/<id>\\\"\\n   641→\\tgitFilePath := filepath.Join(repoRoot, gitDir)\\n   642→\\tcontent, err := os.ReadFile(gitFilePath) //nolint:gosec // G304: gitFilePath is constructed from repo root, not user input\\n   643→\\tif err != nil {\\n   644→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read .git file: %w\\\", err)\\n   645→\\t}\\n   646→\\n   647→\\tgitdir := strings.TrimSpace(string(content))\\n   648→\\tgitdir = strings.TrimPrefix(gitdir, \\\"gitdir: \\\")\\n   649→\\n   650→\\t// Extract main repo root: everything before \\\"/.git/\\\"\\n   651→\\tidx := strings.LastIndex(gitdir, \\\"/.git/\\\")\\n   652→\\tif idx < 0 {\\n   653→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"unexpected gitdir format: %s\\\", gitdir)\\n   654→\\t}\\n   655→\\treturn gitdir[:idx], nil\\n   656→}\\n   657→\\n   658→// GetGitCommonDir returns the path to the shared git directory.\\n   659→// In a regular checkout, this is .git/\\n   660→// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n   661→// Uses git rev-parse --git-common-dir for reliable handling of worktrees.\\n   662→func GetGitCommonDir() (string, error) {\\n   663→\\tctx := context.Background()\\n   664→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-common-dir\\\")\\n   665→\\tcmd.Dir = \\\".\\\"\\n   666→\\toutput, err := cmd.Output()\\n   667→\\tif err != nil {\\n   668→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   669→\\t}\\n   670→\\n   671→\\tcommonDir := strings.TrimSpace(string(output))\\n   672→\\n   673→\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\n   674→\\t// so we need to make it absolute if it isn't already\\n   675→\\tif !filepath.IsAbs(commonDir) {\\n   676→\\t\\tcommonDir = filepath.Join(\\\".\\\", commonDir)\\n   677→\\t}\\n   678→\\n   679→\\treturn filepath.Clean(commonDir), nil\\n   680→}\\n   681→\\n   682→// EnsureEntireGitignore ensures all required entries are in .entire/.gitignore\\n   683→// Works correctly from any subdirectory within the repository.\\n   684→func EnsureEntireGitignore() error {\\n   685→\\t// Get absolute path for the gitignore file\\n   686→\\tgitignoreAbs, err := paths.AbsPath(entireGitignore)\\n   687→\\tif err != nil {\\n   688→\\t\\tgitignoreAbs = entireGitignore // Fallback to relative\\n   689→\\t}\\n   690→\\n   691→\\t// Read existing content\\n   692→\\tvar content string\\n   693→\\tif data, err := os.ReadFile(gitignoreAbs); err == nil { //nolint:gosec // path is from AbsPath or constant\\n   694→\\t\\tcontent = string(data)\\n   695→\\t}\\n   696→\\n   697→\\t// All entries that should be in .entire/.gitignore\\n   698→\\trequiredEntries := []string{\\n   699→\\t\\t\\\"tmp/\\\",\\n   700→\\t\\t\\\"settings.local.json\\\",\\n   701→\\t\\t\\\"metadata/\\\",\\n   702→\\t\\t\\\"logs/\\\",\\n   703→\\t}\\n   704→\\n   705→\\t// Track what needs to be added\\n   706→\\tvar toAdd []string\\n   707→\\tfor _, entry := range requiredEntries {\\n   708→\\t\\tif !strings.Contains(content, entry) {\\n   709→\\t\\t\\ttoAdd = append(toAdd, entry)\\n   710→\\t\\t}\\n   711→\\t}\\n   712→\\n   713→\\t// Nothing to add\\n   714→\\tif len(toAdd) == 0 {\\n   715→\\t\\treturn nil\\n   716→\\t}\\n   717→\\n   718→\\t// Ensure .entire directory exists\\n   719→\\tif err := os.MkdirAll(filepath.Dir(gitignoreAbs), 0o750); err != nil {\\n   720→\\t\\treturn fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   721→\\t}\\n   722→\\n   723→\\t// Append missing entries to gitignore\\n   724→\\tvar sb strings.Builder\\n   725→\\tfor _, entry := range toAdd {\\n   726→\\t\\tsb.WriteString(entry + \\\"\\\\n\\\")\\n   727→\\t}\\n   728→\\tcontent += sb.String()\\n   729→\\n   730→\\tif err := os.WriteFile(gitignoreAbs, []byte(content), 0o644); err != nil { //nolint:gosec // path is from AbsPath or constant\\n   731→\\t\\treturn fmt.Errorf(\\\"failed to write gitignore: %w\\\", err)\\n   732→\\t}\\n   733→\\treturn nil\\n   734→}\\n   735→\\n   736→// checkCanRewindWithWarning checks working directory and returns a warning with diff stats.\\n   737→// Always returns canRewind=true but includes a warning message with +/- line stats for\\n   738→// uncommitted changes. Used by manual-commit strategy.\\n   739→func checkCanRewindWithWarning() (bool, string, error) {\\n   740→\\trepo, err := OpenRepository()\\n   741→\\tif err != nil {\\n   742→\\t\\t// Can't open repo - still allow rewind but without stats\\n   743→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if repo can't be opened\\n   744→\\t}\\n   745→\\n   746→\\tworktree, err := repo.Worktree()\\n   747→\\tif err != nil {\\n   748→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if worktree can't be accessed\\n   749→\\t}\\n   750→\\n   751→\\tstatus, err := worktree.Status()\\n   752→\\tif err != nil {\\n   753→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if status can't be retrieved\\n   754→\\t}\\n   755→\\n   756→\\tif status.IsClean() {\\n   757→\\t\\treturn true, \\\"\\\", nil\\n   758→\\t}\\n   759→\\n   760→\\t// Get HEAD commit tree for comparison - if we can't get it, just return without stats\\n   761→\\thead, err := repo.Head()\\n   762→\\tif err != nil {\\n   763→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even without HEAD (e.g., empty repo)\\n   764→\\t}\\n   765→\\n   766→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   767→\\tif err != nil {\\n   768→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if commit lookup fails\\n   769→\\t}\\n   770→\\n   771→\\theadTree, err := headCommit.Tree()\\n   772→\\tif err != nil {\\n   773→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if tree lookup fails\\n   774→\\t}\\n   775→\\n   776→\\ttype fileChange struct {\\n   777→\\t\\tstatus   string // \\\"modified\\\", \\\"added\\\", \\\"deleted\\\"\\n   778→\\t\\tadded    int\\n   779→\\t\\tremoved  int\\n   780→\\t\\tfilename string\\n   781→\\t}\\n   782→\\n   783→\\tvar changes []fileChange\\n   784→\\t// Use repo root, not cwd - git status returns paths relative to repo root\\n   785→\\trepoRoot, err := paths.WorktreeRoot()\\n   786→\\tif err != nil {\\n   787→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if worktree root lookup fails\\n   788→\\t}\\n   789→\\n   790→\\tfor file, st := range status {\\n   791→\\t\\t// Skip .entire directory\\n   792→\\t\\tif paths.IsInfrastructurePath(file) {\\n   793→\\t\\t\\tcontinue\\n   794→\\t\\t}\\n   795→\\n   796→\\t\\t// Skip untracked files\\n   797→\\t\\tif st.Worktree == git.Untracked {\\n   798→\\t\\t\\tcontinue\\n   799→\\t\\t}\\n   800→\\n   801→\\t\\tvar change fileChange\\n   802→\\t\\tchange.filename = file\\n   803→\\n   804→\\t\\tswitch {\\n   805→\\t\\tcase st.Staging == git.Added || st.Worktree == git.Added:\\n   806→\\t\\t\\tchange.status = \\\"added\\\"\\n   807→\\t\\t\\t// New file - count all lines as added\\n   808→\\t\\t\\tabsPath := filepath.Join(repoRoot, file)\\n   809→\\t\\t\\tif content, err := os.ReadFile(absPath); err == nil { //nolint:gosec // absPath is repo root + relative path from git status\\n   810→\\t\\t\\t\\tchange.added = countLines(content)\\n   811→\\t\\t\\t}\\n   812→\\t\\tcase st.Staging == git.Deleted || st.Worktree == git.Deleted:\\n   813→\\t\\t\\tchange.status = \\\"deleted\\\"\\n   814→\\t\\t\\t// Deleted file - count lines from HEAD as removed\\n   815→\\t\\t\\tif entry, err := headTree.File(file); err == nil {\\n   816→\\t\\t\\t\\tif content, err := entry.Contents(); err == nil {\\n   817→\\t\\t\\t\\t\\tchange.removed = countLines([]byte(content))\\n   818→\\t\\t\\t\\t}\\n   819→\\t\\t\\t}\\n   820→\\t\\tcase st.Staging == git.Modified || st.Worktree == git.Modified:\\n   821→\\t\\t\\tchange.status = \\\"modified\\\"\\n   822→\\t\\t\\t// Modified file - compute diff stats\\n   823→\\t\\t\\tvar headContent, workContent []byte\\n   824→\\t\\t\\tif entry, err := headTree.File(file); err == nil {\\n   825→\\t\\t\\t\\tif content, err := entry.Contents(); err == nil {\\n   826→\\t\\t\\t\\t\\theadContent = []byte(content)\\n   827→\\t\\t\\t\\t}\\n   828→\\t\\t\\t}\\n   829→\\t\\t\\tabsPath := filepath.Join(repoRoot, file)\\n   830→\\t\\t\\tif content, err := os.ReadFile(absPath); err == nil { //nolint:gosec // absPath is repo root + relative path from git status\\n   831→\\t\\t\\t\\tworkContent = content\\n   832→\\t\\t\\t}\\n   833→\\t\\t\\tif headContent != nil && workContent != nil {\\n   834→\\t\\t\\t\\tchange.added, change.removed = computeDiffStats(headContent, workContent)\\n   835→\\t\\t\\t}\\n   836→\\t\\tdefault:\\n   837→\\t\\t\\tcontinue\\n   838→\\t\\t}\\n   839→\\n   840→\\t\\tchanges = append(changes, change)\\n   841→\\t}\\n   842→\\n   843→\\tif len(changes) == 0 {\\n   844→\\t\\treturn true, \\\"\\\", nil\\n   845→\\t}\\n   846→\\n   847→\\t// Sort changes by filename for consistent output\\n   848→\\tsort.Slice(changes, func(i, j int) bool {\\n   849→\\t\\treturn changes[i].filename < changes[j].filename\\n   850→\\t})\\n   851→\\n   852→\\tvar msg strings.Builder\\n   853→\\tmsg.WriteString(\\\"The following uncommitted changes will be reverted:\\\\n\\\")\\n   854→\\n   855→\\ttotalAdded, totalRemoved := 0, 0\\n   856→\\tfor _, c := range changes {\\n   857→\\t\\ttotalAdded += c.added\\n   858→\\t\\ttotalRemoved += c.removed\\n   859→\\n   860→\\t\\tvar stats string\\n   861→\\t\\tswitch {\\n   862→\\t\\tcase c.added > 0 && c.removed > 0:\\n   863→\\t\\t\\tstats = fmt.Sprintf(\\\"+%d/-%d\\\", c.added, c.removed)\\n   864→\\t\\tcase c.added > 0:\\n   865→\\t\\t\\tstats = fmt.Sprintf(\\\"+%d\\\", c.added)\\n   866→\\t\\tcase c.removed > 0:\\n   867→\\t\\t\\tstats = fmt.Sprintf(\\\"-%d\\\", c.removed)\\n   868→\\t\\t}\\n   869→\\n   870→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  %-10s %s\\\", c.status+\\\":\\\", c.filename))\\n   871→\\t\\tif stats != \\\"\\\" {\\n   872→\\t\\t\\tmsg.WriteString(fmt.Sprintf(\\\" (%s)\\\", stats))\\n   873→\\t\\t}\\n   874→\\t\\tmsg.WriteString(\\\"\\\\n\\\")\\n   875→\\t}\\n   876→\\n   877→\\tif totalAdded > 0 || totalRemoved > 0 {\\n   878→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"\\\\nTotal: +%d/-%d lines\\\\n\\\", totalAdded, totalRemoved))\\n   879→\\t}\\n   880→\\n   881→\\treturn true, msg.String(), nil\\n   882→}\\n   883→\\n   884→// countLines counts the number of lines in content.\\n   885→func countLines(content []byte) int {\\n   886→\\tif len(content) == 0 {\\n   887→\\t\\treturn 0\\n   888→\\t}\\n   889→\\tcount := 1\\n   890→\\tfor _, b := range content {\\n   891→\\t\\tif b == '\\\\n' {\\n   892→\\t\\t\\tcount++\\n   893→\\t\\t}\\n   894→\\t}\\n   895→\\t// Don't count trailing newline as extra line\\n   896→\\tif len(content) > 0 && content[len(content)-1] == '\\\\n' {\\n   897→\\t\\tcount--\\n   898→\\t}\\n   899→\\treturn count\\n   900→}\\n   901→\\n   902→// computeDiffStats computes added and removed line counts between old and new content.\\n   903→// Uses a simple line-based diff algorithm.\\n   904→func computeDiffStats(oldContent, newContent []byte) (added, removed int) {\\n   905→\\toldLines := splitLines(oldContent)\\n   906→\\tnewLines := splitLines(newContent)\\n   907→\\n   908→\\t// Build a set of old lines with counts\\n   909→\\toldSet := make(map[string]int)\\n   910→\\tfor _, line := range oldLines {\\n   911→\\t\\toldSet[line]++\\n   912→\\t}\\n   913→\\n   914→\\t// Check which new lines are truly new\\n   915→\\tfor _, line := range newLines {\\n   916→\\t\\tif oldSet[line] > 0 {\\n   917→\\t\\t\\toldSet[line]--\\n   918→\\t\\t} else {\\n   919→\\t\\t\\tadded++\\n   920→\\t\\t}\\n   921→\\t}\\n   922→\\n   923→\\t// Remaining old lines are removed\\n   924→\\tfor _, count := range oldSet {\\n   925→\\t\\tremoved += count\\n   926→\\t}\\n   927→\\n   928→\\treturn added, removed\\n   929→}\\n   930→\\n   931→// splitLines splits content into lines, preserving empty lines.\\n   932→func splitLines(content []byte) []string {\\n   933→\\tif len(content) == 0 {\\n   934→\\t\\treturn nil\\n   935→\\t}\\n   936→\\ts := string(content)\\n   937→\\t// Remove trailing newline to avoid empty last element\\n   938→\\ts = strings.TrimSuffix(s, \\\"\\\\n\\\")\\n   939→\\treturn strings.Split(s, \\\"\\\\n\\\")\\n   940→}\\n   941→\\n   942→// fileExists checks if a file exists at the given path.\\n   943→func fileExists(path string) bool {\\n   944→\\t_, err := os.Stat(path)\\n   945→\\treturn err == nil\\n   946→}\\n   947→\\n   948→// StageFilesContext describes what type of staging operation this is (for messages).\\n   949→type StageFilesContext string\\n   950→\\n   951→const (\\n   952→\\t// StageForSession is used when staging files for a session checkpoint.\\n   953→\\tStageForSession StageFilesContext = \\\"session\\\"\\n   954→\\t// StageForTask is used when staging files for a task checkpoint.\\n   955→\\tStageForTask StageFilesContext = \\\"task\\\"\\n   956→)\\n   957→\\n   958→// StageFiles stages modified, new, and deleted files to the git worktree.\\n   959→//\\n   960→// This function handles three categories of file changes:\\n   961→//  1. Modified files: existing files that have been changed\\n   962→//  2. New files: files that were created during the session\\n   963→//  3. Deleted files: files that were removed during the session\\n   964→//\\n   965→// Error Handling Strategy:\\n   966→//   - Individual file staging errors are logged to stderr but don't fail the operation\\n   967→//   - This ensures that partial staging succeeds even if some files have issues\\n   968→//   - If a modified file no longer exists, it's treated as a deletion\\n   969→//\\n   970→// The stageCtx parameter is used for user-facing messages to indicate whether\\n   971→// this is staging for a session checkpoint or a task checkpoint.\\n   972→func StageFiles(worktree *git.Worktree, modified, newFiles, deleted []string, stageCtx StageFilesContext) {\\n   973→\\t// Get worktree root for resolving file paths\\n   974→\\t// This is critical because fileExists() uses os.Stat() which resolves relative to CWD,\\n   975→\\t// but worktree.Add/Remove resolve relative to repo root. If CWD != repo root,\\n   976→\\t// fileExists() could return false for existing files, causing worktree.Remove()\\n   977→\\t// to incorrectly delete them.\\n   978→\\trepoRoot := worktree.Filesystem.Root()\\n   979→\\n   980→\\t// Stage modified files\\n   981→\\tfor _, file := range modified {\\n   982→\\t\\t// Resolve path relative to repo root for existence check\\n   983→\\t\\tabsPath := filepath.Join(repoRoot, file)\\n   984→\\t\\tif fileExists(absPath) {\\n   985→\\t\\t\\tif _, err := worktree.Add(file); err != nil {\\n   986→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage %s: %v\\\\n\\\", file, err)\\n   987→\\t\\t\\t} else {\\n   988→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged: %s\\\\n\\\", file)\\n   989→\\t\\t\\t}\\n   990→\\t\\t} else {\\n   991→\\t\\t\\t// File was deleted - stage the deletion\\n   992→\\t\\t\\tif _, err := worktree.Remove(file); err != nil {\\n   993→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  File not found or deleted: %s\\\\n\\\", file)\\n   994→\\t\\t\\t}\\n   995→\\t\\t}\\n   996→\\t}\\n   997→\\n   998→\\t// Stage new files\\n   999→\\tif len(newFiles) > 0 {\\n  1000→\\t\\tfmt.Fprintf(os.Stderr, \\\"Staging %d new files created during %s:\\\\n\\\", len(newFiles), stageCtx)\\n  1001→\\t\\tfor _, file := range newFiles {\\n  1002→\\t\\t\\tif _, err := worktree.Add(file); err != nil {\\n  1003→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage %s: %v\\\\n\\\", file, err)\\n  1004→\\t\\t\\t} else {\\n  1005→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged new file: %s\\\\n\\\", file)\\n  1006→\\t\\t\\t}\\n  1007→\\t\\t}\\n  1008→\\t}\\n  1009→\\n  1010→\\t// Stage deleted files\\n  1011→\\tfor _, file := range deleted {\\n  1012→\\t\\tif _, err := worktree.Remove(file); err != nil {\\n  1013→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage deleted file %s: %v\\\\n\\\", file, err)\\n  1014→\\t\\t} else {\\n  1015→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged deleted file: %s\\\\n\\\", file)\\n  1016→\\t\\t}\\n  1017→\\t}\\n  1018→}\\n  1019→\\n  1020→// getTaskCheckpointFromTree retrieves a task checkpoint from a commit tree.\\n  1021→// Shared implementation for shadow and linear-shadow strategies.\\n  1022→func getTaskCheckpointFromTree(point RewindPoint) (*TaskCheckpoint, error) {\\n  1023→\\tif !point.IsTaskCheckpoint {\\n  1024→\\t\\treturn nil, ErrNotTaskCheckpoint\\n  1025→\\t}\\n  1026→\\n  1027→\\trepo, err := OpenRepository()\\n  1028→\\tif err != nil {\\n  1029→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n  1030→\\t}\\n  1031→\\n  1032→\\tcommitHash := plumbing.NewHash(point.ID)\\n  1033→\\tcommit, err := repo.CommitObject(commitHash)\\n  1034→\\tif err != nil {\\n  1035→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n  1036→\\t}\\n  1037→\\n  1038→\\ttree, err := commit.Tree()\\n  1039→\\tif err != nil {\\n  1040→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n  1041→\\t}\\n  1042→\\n  1043→\\t// Read checkpoint.json from the tree\\n  1044→\\tcheckpointPath := point.MetadataDir + \\\"/checkpoint.json\\\"\\n  1045→\\tfile, err := tree.File(checkpointPath)\\n  1046→\\tif err != nil {\\n  1047→\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", checkpointPath, err)\\n  1048→\\t}\\n  1049→\\n  1050→\\tcontent, err := file.Contents()\\n  1051→\\tif err != nil {\\n  1052→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n  1053→\\t}\\n  1054→\\n  1055→\\tvar checkpoint TaskCheckpoint\\n  1056→\\tif err := json.Unmarshal([]byte(content), &checkpoint); err != nil {\\n  1057→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse checkpoint: %w\\\", err)\\n  1058→\\t}\\n  1059→\\n  1060→\\treturn &checkpoint, nil\\n  1061→}\\n  1062→\\n  1063→// getTaskTranscriptFromTree retrieves a task transcript from a commit tree.\\n  1064→// Shared implementation for shadow and linear-shadow strategies.\\n  1065→func getTaskTranscriptFromTree(point RewindPoint) ([]byte, error) {\\n  1066→\\tif !point.IsTaskCheckpoint {\\n  1067→\\t\\treturn nil, ErrNotTaskCheckpoint\\n  1068→\\t}\\n  1069→\\n  1070→\\trepo, err := OpenRepository()\\n  1071→\\tif err != nil {\\n  1072→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n  1073→\\t}\\n  1074→\\n  1075→\\tcommitHash := plumbing.NewHash(point.ID)\\n  1076→\\tcommit, err := repo.CommitObject(commitHash)\\n  1077→\\tif err != nil {\\n  1078→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n  1079→\\t}\\n  1080→\\n  1081→\\ttree, err := commit.Tree()\\n  1082→\\tif err != nil {\\n  1083→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n  1084→\\t}\\n  1085→\\n  1086→\\t// MetadataDir format: .entire/metadata/<session>/tasks/<toolUseID>\\n  1087→\\t// Session transcript is at: .entire/metadata/<session>/<TranscriptFileName>\\n  1088→\\tsessionDir := filepath.Dir(filepath.Dir(point.MetadataDir))\\n  1089→\\n  1090→\\t// Try current format first, then legacy\\n  1091→\\ttranscriptPath := sessionDir + \\\"/\\\" + paths.TranscriptFileName\\n  1092→\\tfile, err := tree.File(transcriptPath)\\n  1093→\\tif err != nil {\\n  1094→\\t\\ttranscriptPath = sessionDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n  1095→\\t\\tfile, err = tree.File(transcriptPath)\\n  1096→\\t\\tif err != nil {\\n  1097→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find transcript: %w\\\", err)\\n  1098→\\t\\t}\\n  1099→\\t}\\n  1100→\\n  1101→\\tcontent, err := file.Contents()\\n  1102→\\tif err != nil {\\n  1103→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n  1104→\\t}\\n  1105→\\n  1106→\\treturn []byte(content), nil\\n  1107→}\\n  1108→\\n  1109→// ErrBranchNotFound is returned by DeleteBranchCLI when the branch does not exist.\\n  1110→var ErrBranchNotFound = errors.New(\\\"branch not found\\\")\\n  1111→\\n  1112→// DeleteBranchCLI deletes a git branch using the git CLI.\\n  1113→// Uses `git branch -D` instead of go-git's RemoveReference because go-git v5\\n  1114→// doesn't properly persist deletions when refs are packed (.git/packed-refs)\\n  1115→// or in a worktree context. This is the same class of go-git v5 bug that\\n  1116→// affects checkout and reset --hard (see HardResetWithProtection).\\n  1117→//\\n  1118→// Returns ErrBranchNotFound if the branch does not exist, allowing callers\\n  1119→// to use errors.Is for idempotent deletion patterns.\\n  1120→func DeleteBranchCLI(branchName string) error {\\n  1121→\\tctx := context.Background()\\n  1122→\\n  1123→\\t// Pre-check: verify the branch exists so callers get a structured error\\n  1124→\\t// instead of parsing git's output string (which varies across locales).\\n  1125→\\t// git show-ref exits 1 for \\\"not found\\\" and 128+ for fatal errors (corrupt\\n  1126→\\t// repo, permissions, not a git directory). Only map exit code 1 to\\n  1127→\\t// ErrBranchNotFound; propagate other failures as-is.\\n  1128→\\tcheck := exec.CommandContext(ctx, \\\"git\\\", \\\"show-ref\\\", \\\"--verify\\\", \\\"--quiet\\\", \\\"refs/heads/\\\"+branchName) //nolint:gosec // branchName comes from internal shadow branch naming\\n  1129→\\tif err := check.Run(); err != nil {\\n  1130→\\t\\tvar exitErr *exec.ExitError\\n  1131→\\t\\tif errors.As(err, &exitErr) && exitErr.ExitCode() == 1 {\\n  1132→\\t\\t\\treturn fmt.Errorf(\\\"%w: %s\\\", ErrBranchNotFound, branchName)\\n  1133→\\t\\t}\\n  1134→\\t\\treturn fmt.Errorf(\\\"failed to check branch %s: %w\\\", branchName, err)\\n  1135→\\t}\\n  1136→\\n  1137→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", branchName)\\n  1138→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1139→\\t\\treturn fmt.Errorf(\\\"failed to delete branch %s: %s: %w\\\", branchName, strings.TrimSpace(string(output)), err)\\n  1140→\\t}\\n  1141→\\treturn nil\\n  1142→}\\n  1143→\\n  1144→// branchExistsCLI checks if a branch exists using git CLI.\\n  1145→// Returns nil if the branch exists, or an error if it does not.\\n  1146→func branchExistsCLI(branchName string) error {\\n  1147→\\tctx := context.Background()\\n  1148→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"show-ref\\\", \\\"--verify\\\", \\\"--quiet\\\", \\\"refs/heads/\\\"+branchName) //nolint:gosec // branchName comes from internal shadow branch naming\\n  1149→\\tif err := cmd.Run(); err != nil {\\n  1150→\\t\\treturn fmt.Errorf(\\\"branch %s not found: %w\\\", branchName, err)\\n  1151→\\t}\\n  1152→\\treturn nil\\n  1153→}\\n  1154→\\n  1155→// HardResetWithProtection performs a git reset --hard to the specified commit.\\n  1156→// Uses the git CLI instead of go-git because go-git's HardReset incorrectly\\n  1157→// deletes untracked directories (like .entire/) even when they're in .gitignore.\\n  1158→// Returns the short commit ID (7 chars) on success for display purposes.\\n  1159→func HardResetWithProtection(commitHash plumbing.Hash) (shortID string, err error) {\\n  1160→\\tctx := context.Background()\\n  1161→\\thashStr := commitHash.String()\\n  1162→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"reset\\\", \\\"--hard\\\", hashStr) //nolint:gosec // hashStr is a plumbing.Hash, not user input\\n  1163→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1164→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"reset failed: %s: %w\\\", strings.TrimSpace(string(output)), err)\\n  1165→\\t}\\n  1166→\\n  1167→\\t// Return short commit ID for display\\n  1168→\\tshortID = hashStr\\n  1169→\\tif len(shortID) > 7 {\\n  1170→\\t\\tshortID = shortID[:7]\\n  1171→\\t}\\n  1172→\\treturn shortID, nil\\n  1173→}\\n  1174→\\n  1175→// collectUntrackedFiles collects untracked files in the working directory that are\\n  1176→// NOT ignored by .gitignore. This is used to capture the initial state when starting\\n  1177→// a session, ensuring untracked files present at session start are preserved during rewind.\\n  1178→// Uses \\\"git ls-files --others --exclude-standard -z\\\" to respect .gitignore rules,\\n  1179→// avoiding bloated session state from large ignored directories like node_modules/.\\n  1180→// Returns paths relative to the repository root.\\n  1181→func collectUntrackedFiles() ([]string, error) {\\n  1182→\\trepoRoot, err := paths.WorktreeRoot()\\n  1183→\\tif err != nil {\\n  1184→\\t\\trepoRoot = \\\".\\\"\\n  1185→\\t}\\n  1186→\\n  1187→\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"ls-files\\\", \\\"--others\\\", \\\"--exclude-standard\\\", \\\"-z\\\")\\n  1188→\\tcmd.Dir = repoRoot\\n  1189→\\toutput, err := cmd.Output()\\n  1190→\\tif err != nil {\\n  1191→\\t\\tvar exitErr *exec.ExitError\\n  1192→\\t\\tif errors.As(err, &exitErr) {\\n  1193→\\t\\t\\treturn nil, fmt.Errorf(\\\"git ls-files failed: %s: %w\\\", strings.TrimSpace(string(exitErr.Stderr)), err)\\n  1194→\\t\\t}\\n  1195→\\t\\treturn nil, fmt.Errorf(\\\"git ls-files failed: %w\\\", err)\\n  1196→\\t}\\n  1197→\\n  1198→\\traw := string(output)\\n  1199→\\tif raw == \\\"\\\" {\\n  1200→\\t\\treturn nil, nil\\n  1201→\\t}\\n  1202→\\n  1203→\\tvar files []string\\n  1204→\\tfor _, f := range strings.Split(raw, \\\"\\\\x00\\\") {\\n  1205→\\t\\t// Defense-in-depth: filter protected paths even though --exclude-standard should already handle them\\n  1206→\\t\\tif f != \\\"\\\" && !isProtectedPath(f) {\\n  1207→\\t\\t\\tfiles = append(files, f)\\n  1208→\\t\\t}\\n  1209→\\t}\\n  1210→\\treturn files, nil\\n  1211→}\\n  1212→\\n  1213→// ExtractSessionIDFromCommit extracts the session ID from a commit's trailers.\\n  1214→// It checks the Entire-Session trailer first, then falls back to extracting from\\n  1215→// the metadata directory path in the Entire-Metadata trailer.\\n  1216→// Returns empty string if no session ID is found.\\n  1217→func ExtractSessionIDFromCommit(commit *object.Commit) string {\\n  1218→\\t// Try Entire-Session trailer first\\n  1219→\\tif sessionID, found := trailers.ParseSession(commit.Message); found {\\n  1220→\\t\\treturn sessionID\\n  1221→\\t}\\n  1222→\\n  1223→\\t// Try extracting from metadata directory (last path component)\\n  1224→\\tif metadataDir, found := trailers.ParseMetadata(commit.Message); found {\\n  1225→\\t\\treturn filepath.Base(metadataDir)\\n  1226→\\t}\\n  1227→\\n  1228→\\treturn \\\"\\\"\\n  1229→}\\n  1230→\\n  1231→// NOTE: The following git tree helper functions have been moved to checkpoint/ package:\\n  1232→// - FlattenTree -> checkpoint.FlattenTree\\n  1233→// - CreateBlobFromContent -> checkpoint.CreateBlobFromContent\\n  1234→// - BuildTreeFromEntries -> checkpoint.BuildTreeFromEntries\\n  1235→// - sortTreeEntries (internal to checkpoint package)\\n  1236→// - treeNode, insertIntoTree, buildTreeObject (internal to checkpoint package)\\n  1237→//\\n  1238→// See push_common.go and session_test.go for usage examples.\\n  1239→\\n  1240→// createCommit creates a commit object\\n  1241→func createCommit(repo *git.Repository, treeHash, parentHash plumbing.Hash, message, authorName, authorEmail string) (plumbing.Hash, error) { //nolint:unparam // already present in codebase\\n  1242→\\tnow := time.Now()\\n  1243→\\tsig := object.Signature{\\n  1244→\\t\\tName:  authorName,\\n  1245→\\t\\tEmail: authorEmail,\\n  1246→\\t\\tWhen:  now,\\n  1247→\\t}\\n  1248→\\n  1249→\\tcommit := &object.Commit{\\n  1250→\\t\\tTreeHash:  treeHash,\\n  1251→\\t\\tAuthor:    sig,\\n  1252→\\t\\tCommitter: sig,\\n  1253→\\t\\tMessage:   message,\\n  1254→\\t}\\n  1255→\\n  1256→\\t// Add parent if not a new branch\\n  1257→\\tif parentHash != plumbing.ZeroHash {\\n  1258→\\t\\tcommit.ParentHashes = []plumbing.Hash{parentHash}\\n  1259→\\t}\\n  1260→\\n  1261→\\tobj := repo.Storer.NewEncodedObject()\\n  1262→\\tif err := commit.Encode(obj); err != nil {\\n  1263→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n  1264→\\t}\\n  1265→\\n  1266→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n  1267→\\tif err != nil {\\n  1268→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store commit: %w\\\", err)\\n  1269→\\t}\\n  1270→\\n  1271→\\treturn hash, nil\\n  1272→}\\n  1273→\\n  1274→// getSessionDescriptionFromTree reads the first line of prompt.txt or context.md from a git tree.\\n  1275→// This is the tree-based equivalent of getSessionDescription (which reads from filesystem).\\n  1276→//\\n  1277→// If metadataDir is provided, looks for files at metadataDir/prompt.txt or metadataDir/context.md.\\n  1278→// If metadataDir is empty, first tries the root of the tree (for when the tree is already\\n  1279→// the session directory), then falls back to\\n  1280→// searching for .entire/metadata/*/prompt.txt or context.md (for full worktree trees).\\n  1281→func getSessionDescriptionFromTree(tree *object.Tree, metadataDir string) string {\\n  1282→\\t// Helper to read first line from a file in tree\\n  1283→\\treadFirstLine := func(path string) string {\\n  1284→\\t\\tfile, err := tree.File(path)\\n  1285→\\t\\tif err != nil {\\n  1286→\\t\\t\\treturn \\\"\\\"\\n  1287→\\t\\t}\\n  1288→\\t\\tcontent, err := file.Contents()\\n  1289→\\t\\tif err != nil {\\n  1290→\\t\\t\\treturn \\\"\\\"\\n  1291→\\t\\t}\\n  1292→\\t\\tlines := strings.SplitN(content, \\\"\\\\n\\\", 2)\\n  1293→\\t\\tif len(lines) > 0 && lines[0] != \\\"\\\" {\\n  1294→\\t\\t\\tdesc := strings.TrimSpace(lines[0])\\n  1295→\\t\\t\\t// Remove markdown header prefix if present\\n  1296→\\t\\t\\treturn strings.TrimPrefix(desc, \\\"# \\\")\\n  1297→\\t\\t}\\n  1298→\\t\\treturn \\\"\\\"\\n  1299→\\t}\\n  1300→\\n  1301→\\t// If metadataDir is provided, look there directly\\n  1302→\\tif metadataDir != \\\"\\\" {\\n  1303→\\t\\tif desc := readFirstLine(metadataDir + \\\"/\\\" + paths.PromptFileName); desc != \\\"\\\" {\\n  1304→\\t\\t\\treturn desc\\n  1305→\\t\\t}\\n  1306→\\t\\tif desc := readFirstLine(metadataDir + \\\"/\\\" + paths.ContextFileName); desc != \\\"\\\" {\\n  1307→\\t\\t\\treturn desc\\n  1308→\\t\\t}\\n  1309→\\t\\treturn NoDescription\\n  1310→\\t}\\n  1311→\\n  1312→\\t// No metadataDir provided - first try looking at the root of the tree\\n  1313→\\t// (used when the tree is already the session directory)\\n  1314→\\tif desc := readFirstLine(paths.PromptFileName); desc != \\\"\\\" {\\n  1315→\\t\\treturn desc\\n  1316→\\t}\\n  1317→\\tif desc := readFirstLine(paths.ContextFileName); desc != \\\"\\\" {\\n  1318→\\t\\treturn desc\\n  1319→\\t}\\n  1320→\\n  1321→\\t// Fall back to searching for .entire/metadata/*/prompt.txt or context.md\\n  1322→\\t// (used when the tree is the full worktree)\\n  1323→\\tvar desc string\\n  1324→\\t//nolint:errcheck // We ignore errors here as we're just searching for a description\\n  1325→\\t_ = tree.Files().ForEach(func(f *object.File) error {\\n  1326→\\t\\tif desc != \\\"\\\" {\\n  1327→\\t\\t\\treturn nil // Already found description\\n  1328→\\t\\t}\\n  1329→\\t\\tname := f.Name\\n  1330→\\t\\tif strings.Contains(name, \\\".entire/metadata/\\\") {\\n  1331→\\t\\t\\tif strings.HasSuffix(name, \\\"/\\\"+paths.PromptFileName) || strings.HasSuffix(name, \\\"/\\\"+paths.ContextFileName) {\\n  1332→\\t\\t\\t\\tcontent, err := f.Contents()\\n  1333→\\t\\t\\t\\tif err != nil {\\n  1334→\\t\\t\\t\\t\\treturn nil //nolint:nilerr // Skip files we can't read, continue searching\\n  1335→\\t\\t\\t\\t}\\n  1336→\\t\\t\\t\\tlines := strings.SplitN(content, \\\"\\\\n\\\", 2)\\n  1337→\\t\\t\\t\\tif len(lines) > 0 && lines[0] != \\\"\\\" {\\n  1338→\\t\\t\\t\\t\\tdesc = strings.TrimSpace(lines[0])\\n  1339→\\t\\t\\t\\t\\tdesc = strings.TrimPrefix(desc, \\\"# \\\")\\n  1340→\\t\\t\\t\\t}\\n  1341→\\t\\t\\t}\\n  1342→\\t\\t}\\n  1343→\\t\\treturn nil\\n  1344→\\t})\\n  1345→\\n  1346→\\tif desc != \\\"\\\" {\\n  1347→\\t\\treturn desc\\n  1348→\\t}\\n  1349→\\treturn NoDescription\\n  1350→}\\n  1351→\\n  1352→// GetGitAuthorFromRepo retrieves the git user.name and user.email,\\n  1353→// checking both the repository-local config and the global ~/.gitconfig.\\n  1354→// Delegates to checkpoint.GetGitAuthorFromRepo — this wrapper exists so\\n  1355→// callers within the strategy package don't need a qualified import.\\n  1356→func GetGitAuthorFromRepo(repo *git.Repository) (name, email string) {\\n  1357→\\treturn checkpoint.GetGitAuthorFromRepo(repo)\\n  1358→}\\n  1359→\\n  1360→// GetCurrentBranchName returns the short name of the current branch if HEAD points to a branch.\\n  1361→// Returns an empty string if in detached HEAD state or if there's an error reading HEAD.\\n  1362→// This is used to capture branch metadata for checkpoints.\\n  1363→func GetCurrentBranchName(repo *git.Repository) string {\\n  1364→\\thead, err := repo.Head()\\n  1365→\\tif err != nil || !head.Name().IsBranch() {\\n  1366→\\t\\treturn \\\"\\\"\\n  1367→\\t}\\n  1368→\\treturn head.Name().Short()\\n  1369→}\\n  1370→\\n  1371→// getMainBranchHash returns the hash of the main branch (main or master).\\n  1372→// Returns ZeroHash if no main branch is found.\\n  1373→func GetMainBranchHash(repo *git.Repository) plumbing.Hash {\\n  1374→\\t// Try common main branch names\\n  1375→\\tfor _, branchName := range []string{branchMain, branchMaster} {\\n  1376→\\t\\t// Try local branch first\\n  1377→\\t\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n  1378→\\t\\tif err == nil {\\n  1379→\\t\\t\\treturn ref.Hash()\\n  1380→\\t\\t}\\n  1381→\\t\\t// Try remote tracking branch\\n  1382→\\t\\tref, err = repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", branchName), true)\\n  1383→\\t\\tif err == nil {\\n  1384→\\t\\t\\treturn ref.Hash()\\n  1385→\\t\\t}\\n  1386→\\t}\\n  1387→\\treturn plumbing.ZeroHash\\n  1388→}\\n  1389→\\n  1390→// GetDefaultBranchName returns the name of the default branch.\\n  1391→// First checks origin/HEAD, then falls back to checking if main/master exists.\\n  1392→// Returns empty string if unable to determine.\\n  1393→// NOTE: Duplicated from cli/git_operations.go - see ENT-129 for consolidation.\\n  1394→func GetDefaultBranchName(repo *git.Repository) string {\\n  1395→\\t// Try to get the symbolic reference for origin/HEAD\\n  1396→\\t// Use resolved=false to get the symbolic ref itself, then extract its target\\n  1397→\\tref, err := repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", \\\"HEAD\\\"), false)\\n  1398→\\tif err == nil && ref != nil && ref.Type() == plumbing.SymbolicReference {\\n  1399→\\t\\ttarget := ref.Target().String()\\n  1400→\\t\\tif branchName, found := strings.CutPrefix(target, \\\"refs/remotes/origin/\\\"); found {\\n  1401→\\t\\t\\treturn branchName\\n  1402→\\t\\t}\\n  1403→\\t}\\n  1404→\\n  1405→\\t// Fallback: check if origin/main or origin/master exists\\n  1406→\\tif _, err := repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", branchMain), true); err == nil {\\n  1407→\\t\\treturn branchMain\\n  1408→\\t}\\n  1409→\\tif _, err := repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", branchMaster), true); err == nil {\\n  1410→\\t\\treturn branchMaster\\n  1411→\\t}\\n  1412→\\n  1413→\\t// Final fallback: check local branches\\n  1414→\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(branchMain), true); err == nil {\\n  1415→\\t\\treturn branchMain\\n  1416→\\t}\\n  1417→\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(branchMaster), true); err == nil {\\n  1418→\\t\\treturn branchMaster\\n  1419→\\t}\\n  1420→\\n  1421→\\treturn \\\"\\\"\\n  1422→}\\n  1423→\\n  1424→// IsOnDefaultBranch checks if the repository HEAD is on the default branch.\\n  1425→// Returns (isOnDefault, currentBranchName).\\n  1426→// NOTE: Duplicated from cli/git_operations.go - see ENT-129 for consolidation.\\n  1427→func IsOnDefaultBranch(repo *git.Repository) (bool, string) {\\n  1428→\\tcurrentBranch := GetCurrentBranchName(repo)\\n  1429→\\tif currentBranch == \\\"\\\" {\\n  1430→\\t\\treturn false, \\\"\\\"\\n  1431→\\t}\\n  1432→\\n  1433→\\tdefaultBranch := GetDefaultBranchName(repo)\\n  1434→\\tif defaultBranch == \\\"\\\" {\\n  1435→\\t\\t// Can't determine default, check common names\\n  1436→\\t\\tif currentBranch == branchMain || currentBranch == branchMaster {\\n  1437→\\t\\t\\treturn true, currentBranch\\n  1438→\\t\\t}\\n  1439→\\t\\treturn false, currentBranch\\n  1440→\\t}\\n  1441→\\n  1442→\\treturn currentBranch == defaultBranch, currentBranch\\n  1443→}\\n  1444→\\n  1445→// prepareTranscriptIfNeeded calls PrepareTranscript for agents that implement\\n  1446→// the TranscriptPreparer interface. This ensures transcript files exist before\\n  1447→// they are read (e.g., OpenCode creates its transcript lazily via `opencode export`).\\n  1448→// Errors are silently ignored — this is best-effort for hook paths.\\n  1449→func prepareTranscriptIfNeeded(agentType agent.AgentType, transcriptPath string) {\\n  1450→\\tif transcriptPath == \\\"\\\" {\\n  1451→\\t\\treturn\\n  1452→\\t}\\n  1453→\\tag, err := agent.GetByAgentType(agentType)\\n  1454→\\tif err != nil {\\n  1455→\\t\\treturn\\n  1456→\\t}\\n  1457→\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n  1458→\\t\\t// Best-effort: callers handle missing files gracefully.\\n  1459→\\t\\t// Transcript may not be available yet (e.g., agent not installed).\\n  1460→\\t\\t_ = preparer.PrepareTranscript(transcriptPath) //nolint:errcheck // Best-effort in hook path\\n  1461→\\t}\\n  1462→}\\n  1463→\"}]},\"uuid\":\"2c5045ae-6cbc-45f5-a076-b841bfe7f83c\",\"timestamp\":\"2026-02-25T15:01:13.078Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/strategy/common.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"os/exec\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"sort\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"sync\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/filemode\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// Common branch name constants for default branch detection.\\nconst (\\n\\tbranchMain   = \\\"main\\\"\\n\\tbranchMaster = \\\"master\\\"\\n\\t// Strategy name constants\\n\\tStrategyNameManualCommit = \\\"manual-commit\\\"\\n)\\n\\n// errStop is a sentinel error used to break out of git log iteration.\\n// Shared across strategies that iterate through git commits.\\n// NOTE: A similar sentinel exists in checkpoint/temporary.go - this is intentional.\\n// Each package needs its own package-scoped sentinel for git log iteration patterns.\\nvar errStop = errors.New(\\\"stop iteration\\\")\\n\\n// IsEmptyRepository returns true if the repository has no commits yet.\\n// After git-init, HEAD points to an unborn branch (e.g., refs/heads/main)\\n// whose target does not yet exist. repo.Head() returns ErrReferenceNotFound\\n// in this case.\\nfunc IsEmptyRepository(repo *git.Repository) bool {\\n\\t_, err := repo.Head()\\n\\treturn errors.Is(err, plumbing.ErrReferenceNotFound)\\n}\\n\\n// EnsureSetup ensures the strategy is properly set up.\\nfunc EnsureSetup() error {\\n\\tif err := EnsureEntireGitignore(); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Ensure the entire/checkpoints/v1 orphan branch exists for permanent session storage\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n\\t}\\n\\tif err := EnsureMetadataBranch(repo); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n\\t}\\n\\n\\t// Install generic hooks (they delegate to strategy at runtime)\\n\\tif !IsGitHookInstalled() {\\n\\t\\tif _, err := InstallGitHook(true, isLocalDev()); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\treturn nil\\n}\\n\\n// IsAncestorOf checks if commit is an ancestor of (or equal to) target.\\n// Returns true if target can reach commit by following parent links.\\n// Limits search to 1000 commits to avoid excessive traversal.\\nfunc IsAncestorOf(repo *git.Repository, commit, target plumbing.Hash) bool {\\n\\tif commit == target {\\n\\t\\treturn true\\n\\t}\\n\\n\\titer, err := repo.Log(&git.LogOptions{From: target})\\n\\tif err != nil {\\n\\t\\treturn false\\n\\t}\\n\\tdefer iter.Close()\\n\\n\\tfound := false\\n\\tcount := 0\\n\\t_ = iter.ForEach(func(c *object.Commit) error { //nolint:errcheck // Best-effort search, errors are non-fatal\\n\\t\\tcount++\\n\\t\\tif count > 1000 {\\n\\t\\t\\treturn errStop\\n\\t\\t}\\n\\t\\tif c.Hash == commit {\\n\\t\\t\\tfound = true\\n\\t\\t\\treturn errStop\\n\\t\\t}\\n\\t\\treturn nil\\n\\t})\\n\\n\\treturn found\\n}\\n\\n// ListCheckpoints returns all checkpoints from the entire/checkpoints/v1 branch.\\n// Scans sharded paths: <id[:2]>/<id[2:]>/ directories containing metadata.json.\\nfunc ListCheckpoints() ([]CheckpointInfo, error) {\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n\\t}\\n\\n\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\t//nolint:nilerr // No sessions branch yet is expected, return empty list\\n\\t\\treturn []CheckpointInfo{}, nil\\n\\t}\\n\\n\\tcommit, err := repo.CommitObject(ref.Hash())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\tvar checkpoints []CheckpointInfo\\n\\n\\t// Scan sharded structure: <2-char-prefix>/<remaining-id>/metadata.json\\n\\t// The tree has 2-character directories (hex buckets)\\n\\tfor _, bucketEntry := range tree.Entries {\\n\\t\\tif bucketEntry.Mode != filemode.Dir {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\t// Bucket should be 2 hex chars\\n\\t\\tif len(bucketEntry.Name) != 2 {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tbucketTree, treeErr := repo.TreeObject(bucketEntry.Hash)\\n\\t\\tif treeErr != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Each entry in the bucket is the remaining part of the checkpoint ID\\n\\t\\tfor _, checkpointEntry := range bucketTree.Entries {\\n\\t\\t\\tif checkpointEntry.Mode != filemode.Dir {\\n\\t\\t\\t\\tcontinue\\n\\t\\t\\t}\\n\\n\\t\\t\\tcheckpointTree, cpTreeErr := repo.TreeObject(checkpointEntry.Hash)\\n\\t\\t\\tif cpTreeErr != nil {\\n\\t\\t\\t\\tcontinue\\n\\t\\t\\t}\\n\\n\\t\\t\\t// Reconstruct checkpoint ID: <bucket><remaining>\\n\\t\\t\\tcheckpointIDStr := bucketEntry.Name + checkpointEntry.Name\\n\\t\\t\\tcheckpointID, cpErr := id.NewCheckpointID(checkpointIDStr)\\n\\t\\t\\tif cpErr != nil {\\n\\t\\t\\t\\t// Skip invalid checkpoint IDs\\n\\t\\t\\t\\tcontinue\\n\\t\\t\\t}\\n\\n\\t\\t\\tinfo := CheckpointInfo{\\n\\t\\t\\t\\tCheckpointID: checkpointID,\\n\\t\\t\\t}\\n\\n\\t\\t\\t// Get details from metadata file (CheckpointSummary format)\\n\\t\\t\\tif metadataFile, fileErr := checkpointTree.File(paths.MetadataFileName); fileErr == nil {\\n\\t\\t\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n\\t\\t\\t\\t\\tvar summary checkpoint.CheckpointSummary\\n\\t\\t\\t\\t\\tif json.Unmarshal([]byte(content), &summary) == nil && len(summary.Sessions) > 0 {\\n\\t\\t\\t\\t\\t\\tinfo.CheckpointsCount = summary.CheckpointsCount\\n\\t\\t\\t\\t\\t\\tinfo.FilesTouched = summary.FilesTouched\\n\\t\\t\\t\\t\\t\\tinfo.SessionCount = len(summary.Sessions)\\n\\n\\t\\t\\t\\t\\t\\t// Read session-level metadata for Agent, SessionID, CreatedAt, SessionIDs\\n\\t\\t\\t\\t\\t\\tfor i, sessionPaths := range summary.Sessions {\\n\\t\\t\\t\\t\\t\\t\\tif sessionPaths.Metadata != \\\"\\\" {\\n\\t\\t\\t\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n\\t\\t\\t\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n\\t\\t\\t\\t\\t\\t\\t\\tsessionMetadataPath := strings.TrimPrefix(sessionPaths.Metadata, \\\"/\\\")\\n\\t\\t\\t\\t\\t\\t\\t\\tif sessionFile, sErr := tree.File(sessionMetadataPath); sErr == nil {\\n\\t\\t\\t\\t\\t\\t\\t\\t\\tif sessionContent, scErr := sessionFile.Contents(); scErr == nil {\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata checkpoint.CommittedMetadata\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionIDs = append(info.SessionIDs, sessionMetadata.SessionID)\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t// Use first session's metadata for Agent, SessionID, CreatedAt\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif i == 0 {\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.IsTask = sessionMetadata.IsTask\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.ToolUseID = sessionMetadata.ToolUseID\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\n\\t\\t\\tcheckpoints = append(checkpoints, info)\\n\\t\\t}\\n\\t}\\n\\n\\t// Sort by time (most recent first)\\n\\tsort.Slice(checkpoints, func(i, j int) bool {\\n\\t\\treturn checkpoints[i].CreatedAt.After(checkpoints[j].CreatedAt)\\n\\t})\\n\\n\\treturn checkpoints, nil\\n}\\n\\nconst (\\n\\tentireGitignore    = \\\".entire/.gitignore\\\"\\n\\tentireDir          = \\\".entire\\\"\\n\\tgitDir             = \\\".git\\\"\\n\\tshadowBranchPrefix = \\\"entire/\\\"\\n\\n\\t// DefaultAgentType is the generic fallback agent type name\\n\\tDefaultAgentType = agent.AgentTypeUnknown\\n)\\n\\n// isProtectedPath returns true if relPath is inside a directory that should\\n// never be modified or deleted during rewind or other destructive operations.\\n// Protected directories include git internals, entire metadata, and all\\n// registered agent config directories.\\nfunc isProtectedPath(relPath string) bool {\\n\\tfor _, dir := range protectedDirs() {\\n\\t\\tif relPath == dir || strings.HasPrefix(relPath, dir+string(filepath.Separator)) {\\n\\t\\t\\treturn true\\n\\t\\t}\\n\\t}\\n\\treturn false\\n}\\n\\n// protectedDirs returns the list of directories to protect. This combines\\n// static infrastructure dirs with agent-reported dirs from the registry.\\n// The result is cached via sync.Once since it's called per-file when filtering untracked files.\\n//\\n// NOTE: The cache is never invalidated. In production this is fine (the agent registry\\n// is populated at init time and never changes). However, tests that mutate the agent\\n// registry after the first call to protectedDirs/isProtectedPath will see stale results.\\n// If you need to test isProtectedPath with a custom registry, either:\\n//   - run those tests in a separate process, or\\n//   - call resetProtectedDirsForTest() to clear the cache.\\nfunc protectedDirs() []string {\\n\\tprotectedDirsOnce.Do(func() {\\n\\t\\tprotectedDirsCache = append([]string{gitDir, entireDir}, agent.AllProtectedDirs()...)\\n\\t})\\n\\treturn protectedDirsCache\\n}\\n\\nvar (\\n\\tprotectedDirsOnce  sync.Once\\n\\tprotectedDirsCache []string\\n)\\n\\n// isSpecificAgentType returns true if the agent type is a known, specific value\\n// (not empty and not the generic \\\"Agent\\\" fallback).\\nfunc isSpecificAgentType(t agent.AgentType) bool {\\n\\treturn t != \\\"\\\" && t != DefaultAgentType\\n}\\n\\n// resolveAgentType picks the best agent type from the context and existing state.\\n// Priority: existing state (if specific) > context value > default fallback.\\nfunc resolveAgentType(ctxAgentType agent.AgentType, state *SessionState) agent.AgentType {\\n\\tif state != nil && isSpecificAgentType(state.AgentType) {\\n\\t\\treturn state.AgentType\\n\\t}\\n\\tif ctxAgentType != \\\"\\\" {\\n\\t\\treturn ctxAgentType\\n\\t}\\n\\treturn DefaultAgentType\\n}\\n\\n// ensureMetadataBranch creates the orphan entire/checkpoints/v1 branch if it doesn't exist.\\n// This branch has no parent and starts with an empty tree.\\nfunc EnsureMetadataBranch(repo *git.Repository) error {\\n\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n\\n\\t// Check if branch already exists\\n\\t_, err := repo.Reference(refName, true)\\n\\tif err == nil {\\n\\t\\t// Branch already exists\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Create empty tree (no files)\\n\\temptyTree := &object.Tree{Entries: []object.TreeEntry{}}\\n\\tobj := repo.Storer.NewEncodedObject()\\n\\tif err := emptyTree.Encode(obj); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to encode empty tree: %w\\\", err)\\n\\t}\\n\\temptyTreeHash, err := repo.Storer.SetEncodedObject(obj)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to store empty tree: %w\\\", err)\\n\\t}\\n\\n\\t// Create orphan commit (no parent)\\n\\tnow := time.Now()\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n\\tsig := object.Signature{\\n\\t\\tName:  authorName,\\n\\t\\tEmail: authorEmail,\\n\\t\\tWhen:  now,\\n\\t}\\n\\n\\tcommit := &object.Commit{\\n\\t\\tTreeHash:  emptyTreeHash,\\n\\t\\tAuthor:    sig,\\n\\t\\tCommitter: sig,\\n\\t\\tMessage:   \\\"Initialize metadata branch\\\\n\\\\nThis branch stores session metadata.\\\\n\\\",\\n\\t}\\n\\t// Note: No ParentHashes - this is an orphan commit\\n\\n\\tcommitObj := repo.Storer.NewEncodedObject()\\n\\tif err := commit.Encode(commitObj); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to encode orphan commit: %w\\\", err)\\n\\t}\\n\\tcommitHash, err := repo.Storer.SetEncodedObject(commitObj)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to store orphan commit: %w\\\", err)\\n\\t}\\n\\n\\t// Create branch reference\\n\\tref := plumbing.NewHashReference(refName, commitHash)\\n\\tif err := repo.Storer.SetReference(ref); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create metadata branch: %w\\\", err)\\n\\t}\\n\\n\\tfmt.Fprintf(os.Stderr, \\\"✓ Created orphan branch '%s' for session metadata\\\\n\\\", paths.MetadataBranchName)\\n\\treturn nil\\n}\\n\\n// readCheckpointMetadata reads metadata.json from a checkpoint path on entire/checkpoints/v1.\\n// With the new format, root metadata.json is a CheckpointSummary with Agents array.\\n// This function reads the summary and extracts relevant fields into CheckpointInfo,\\n// also reading session-level metadata for IsTask/ToolUseID fields.\\nfunc ReadCheckpointMetadata(tree *object.Tree, checkpointPath string) (*CheckpointInfo, error) {\\n\\tmetadataPath := checkpointPath + \\\"/metadata.json\\\"\\n\\tfile, err := tree.File(metadataPath)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to find metadata at %s: %w\\\", metadataPath, err)\\n\\t}\\n\\n\\tcontent, err := file.Contents()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata: %w\\\", err)\\n\\t}\\n\\n\\t// Try to parse as CheckpointSummary first (new format)\\n\\tvar summary checkpoint.CheckpointSummary\\n\\tif err := json.Unmarshal([]byte(content), &summary); err == nil {\\n\\t\\t// If we have sessions array, this is the new format\\n\\t\\tif len(summary.Sessions) > 0 {\\n\\t\\t\\tinfo := &CheckpointInfo{\\n\\t\\t\\t\\tCheckpointID:     summary.CheckpointID,\\n\\t\\t\\t\\tCheckpointsCount: summary.CheckpointsCount,\\n\\t\\t\\t\\tFilesTouched:     summary.FilesTouched,\\n\\t\\t\\t\\tSessionCount:     len(summary.Sessions),\\n\\t\\t\\t}\\n\\n\\t\\t\\t// Read all sessions' metadata to populate SessionIDs and get other fields from first session\\n\\t\\t\\tvar sessionIDs []string\\n\\t\\t\\tfor i, sessionPaths := range summary.Sessions {\\n\\t\\t\\t\\tif sessionPaths.Metadata != \\\"\\\" {\\n\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n\\t\\t\\t\\t\\tsessionMetadataPath := strings.TrimPrefix(sessionPaths.Metadata, \\\"/\\\")\\n\\t\\t\\t\\t\\tif sessionFile, err := tree.File(sessionMetadataPath); err == nil {\\n\\t\\t\\t\\t\\t\\tif sessionContent, err := sessionFile.Contents(); err == nil {\\n\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata checkpoint.CommittedMetadata\\n\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n\\t\\t\\t\\t\\t\\t\\t\\tsessionIDs = append(sessionIDs, sessionMetadata.SessionID)\\n\\t\\t\\t\\t\\t\\t\\t\\t// Use first session for Agent, SessionID, CreatedAt, IsTask, ToolUseID\\n\\t\\t\\t\\t\\t\\t\\t\\tif i == 0 {\\n\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.IsTask = sessionMetadata.IsTask\\n\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.ToolUseID = sessionMetadata.ToolUseID\\n\\t\\t\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tinfo.SessionIDs = sessionIDs\\n\\n\\t\\t\\treturn info, nil\\n\\t\\t}\\n\\t}\\n\\n\\t// Fall back to parsing as CheckpointInfo (old format or direct info)\\n\\tvar metadata CheckpointInfo\\n\\tif err := json.Unmarshal([]byte(content), &metadata); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata: %w\\\", err)\\n\\t}\\n\\n\\treturn &metadata, nil\\n}\\n\\n// GetMetadataBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\nfunc GetMetadataBranchTree(repo *git.Repository) (*object.Tree, error) {\\n\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch reference: %w\\\", err)\\n\\t}\\n\\n\\tcommit, err := repo.CommitObject(ref.Hash())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch commit: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch tree: %w\\\", err)\\n\\t}\\n\\treturn tree, nil\\n}\\n\\n// ExtractFirstPrompt extracts and truncates the first meaningful prompt from prompt content.\\n// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\". Skips empty prompts and separator-only content.\\n// Returns empty string if no valid prompt is found.\\nfunc ExtractFirstPrompt(content string) string {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\n\\t// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\"\\n\\t// Find the first non-empty prompt\\n\\tprompts := strings.Split(content, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n\\tvar firstPrompt string\\n\\tfor _, p := range prompts {\\n\\t\\tcleaned := strings.TrimSpace(p)\\n\\t\\t// Skip empty prompts or prompts that are just dashes/separators\\n\\t\\tif cleaned == \\\"\\\" || isOnlySeparators(cleaned) {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tfirstPrompt = cleaned\\n\\t\\tbreak\\n\\t}\\n\\n\\tif firstPrompt == \\\"\\\" {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\n\\treturn TruncateDescription(firstPrompt, MaxDescriptionLength)\\n}\\n\\n// ReadSessionPromptFromTree reads the first meaningful prompt from a checkpoint's prompt.txt file in a git tree.\\n// Returns an empty string if the prompt cannot be read.\\nfunc ReadSessionPromptFromTree(tree *object.Tree, checkpointPath string) string {\\n\\tpromptPath := checkpointPath + \\\"/\\\" + paths.PromptFileName\\n\\tfile, err := tree.File(promptPath)\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\n\\tcontent, err := file.Contents()\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\n\\treturn ExtractFirstPrompt(content)\\n}\\n\\n// ReadAgentTypeFromTree reads the agent type from a checkpoint's metadata.json file in a git tree.\\n// If metadata.json doesn't exist (shadow branches), it falls back to detecting the agent\\n// from the presence of agent-specific config files (.gemini/settings.json or .claude/).\\n// Returns agent.AgentTypeUnknown if the agent type cannot be determined.\\nfunc ReadAgentTypeFromTree(tree *object.Tree, checkpointPath string) agent.AgentType {\\n\\t// First, try to read from metadata.json (present in condensed/committed checkpoints)\\n\\tmetadataPath := checkpointPath + \\\"/\\\" + paths.MetadataFileName\\n\\tif file, err := tree.File(metadataPath); err == nil {\\n\\t\\tif content, err := file.Contents(); err == nil {\\n\\t\\t\\tvar metadata checkpoint.CommittedMetadata\\n\\t\\t\\tif err := json.Unmarshal([]byte(content), &metadata); err == nil && metadata.Agent != \\\"\\\" {\\n\\t\\t\\t\\treturn metadata.Agent\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Fall back to detecting agent from config files (shadow branches don't have metadata.json).\\n\\t// Order: Gemini (most specific check), Claude (established default), OpenCode (newest/preview).\\n\\tif _, err := tree.File(\\\".gemini/settings.json\\\"); err == nil {\\n\\t\\treturn agent.AgentTypeGemini\\n\\t}\\n\\tif _, err := tree.Tree(\\\".claude\\\"); err == nil {\\n\\t\\treturn agent.AgentTypeClaudeCode\\n\\t}\\n\\t// OpenCode: .opencode directory or opencode.json config\\n\\tif _, err := tree.Tree(\\\".opencode\\\"); err == nil {\\n\\t\\treturn agent.AgentTypeOpenCode\\n\\t}\\n\\tif _, err := tree.File(\\\"opencode.json\\\"); err == nil {\\n\\t\\treturn agent.AgentTypeOpenCode\\n\\t}\\n\\n\\treturn agent.AgentTypeUnknown\\n}\\n\\n// isOnlySeparators checks if a string contains only dashes, spaces, and newlines.\\nfunc isOnlySeparators(s string) bool {\\n\\tfor _, r := range s {\\n\\t\\tif r != '-' && r != ' ' && r != '\\\\n' && r != '\\\\r' && r != '\\\\t' {\\n\\t\\t\\treturn false\\n\\t\\t}\\n\\t}\\n\\treturn true\\n}\\n\\n// ReadAllSessionPromptsFromTree reads the first prompt for all sessions in a multi-session checkpoint.\\n// Returns a slice of prompts parallel to sessionIDs (oldest to newest).\\n// For single-session checkpoints, returns a slice with just the root prompt.\\nfunc ReadAllSessionPromptsFromTree(tree *object.Tree, checkpointPath string, sessionCount int, sessionIDs []string) []string {\\n\\tif sessionCount <= 1 || len(sessionIDs) <= 1 {\\n\\t\\t// Single session - just return the root prompt\\n\\t\\tprompt := ReadSessionPromptFromTree(tree, checkpointPath)\\n\\t\\tif prompt != \\\"\\\" {\\n\\t\\t\\treturn []string{prompt}\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Multi-session: read prompts from archived folders (0/, 1/, etc.) and root\\n\\tprompts := make([]string, len(sessionIDs))\\n\\n\\t// Read archived session prompts (folders 0, 1, ... N-2)\\n\\tfor i := range sessionCount - 1 {\\n\\t\\tarchivedPath := fmt.Sprintf(\\\"%s/%d\\\", checkpointPath, i)\\n\\t\\tprompts[i] = ReadSessionPromptFromTree(tree, archivedPath)\\n\\t}\\n\\n\\t// Read the most recent session prompt (at root level)\\n\\tprompts[len(prompts)-1] = ReadSessionPromptFromTree(tree, checkpointPath)\\n\\n\\treturn prompts\\n}\\n\\n// GetRemoteMetadataBranchTree returns the tree object for origin/entire/checkpoints/v1.\\nfunc GetRemoteMetadataBranchTree(repo *git.Repository) (*object.Tree, error) {\\n\\trefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch reference: %w\\\", err)\\n\\t}\\n\\n\\tcommit, err := repo.CommitObject(ref.Hash())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch commit: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch tree: %w\\\", err)\\n\\t}\\n\\treturn tree, nil\\n}\\n\\n// OpenRepository opens the git repository with linked worktree support enabled.\\n// It uses git.PlainOpenWithOptions with EnableDotGitCommonDir set to true,\\n// which is required for proper operation in git worktrees created via 'git worktree add'.\\n//\\n// Without EnableDotGitCommonDir, go-git operations in worktrees can silently fail:\\n// - Commits appear to succeed but are not persisted\\n// - Refs are written to incorrect locations\\n// - The worktree's HEAD/index don't get updated properly\\n//\\n// This happens because worktrees use .git as a file (pointing to the main repo)\\n// rather than a directory, and go-git needs to route paths correctly between\\n// shared (.git/) and per-worktree (.git/worktrees/<name>/) locations.\\n//\\n// The function first uses 'git rev-parse --show-toplevel' to find the repository\\n// root, which works correctly even when called from a subdirectory within the repo.\\nfunc OpenRepository() (*git.Repository, error) {\\n\\trepoRoot, err := paths.WorktreeRoot()\\n\\tif err != nil {\\n\\t\\t// Fallback to current directory if git command fails\\n\\t\\t// (e.g., if git is not installed or we're not in a repo)\\n\\t\\trepoRoot = \\\".\\\"\\n\\t}\\n\\n\\trepo, err := git.PlainOpenWithOptions(repoRoot, &git.PlainOpenOptions{\\n\\t\\tEnableDotGitCommonDir: true,\\n\\t})\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\treturn repo, nil\\n}\\n\\n// IsInsideWorktree returns true if the current directory is inside a git worktree\\n// (as opposed to the main repository). Worktrees have .git as a file pointing\\n// to the main repo, while the main repo has .git as a directory.\\n// This function works correctly from any subdirectory within the repository.\\nfunc IsInsideWorktree() bool {\\n\\t// First find the repository root\\n\\trepoRoot, err := paths.WorktreeRoot()\\n\\tif err != nil {\\n\\t\\treturn false\\n\\t}\\n\\n\\tgitPath := filepath.Join(repoRoot, gitDir)\\n\\tgitInfo, err := os.Stat(gitPath)\\n\\tif err != nil {\\n\\t\\treturn false\\n\\t}\\n\\treturn !gitInfo.IsDir()\\n}\\n\\n// GetMainRepoRoot returns the root directory of the main repository.\\n// In the main repo, this is the worktree path (repo root).\\n// In a worktree, this parses the .git file to find the main repo.\\n// This function works correctly from any subdirectory within the repository.\\n//\\n// Per gitrepository-layout(5), a worktree's .git file is a \\\"gitfile\\\" containing\\n// \\\"gitdir: <path>\\\" pointing to $GIT_DIR/worktrees/<id> in the main repository.\\n// See: https://git-scm.com/docs/gitrepository-layout\\nfunc GetMainRepoRoot() (string, error) {\\n\\t// First find the worktree/repo root\\n\\trepoRoot, err := paths.WorktreeRoot()\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get worktree path: %w\\\", err)\\n\\t}\\n\\n\\tif !IsInsideWorktree() {\\n\\t\\treturn repoRoot, nil\\n\\t}\\n\\n\\t// Worktree .git file contains: \\\"gitdir: /path/to/main/.git/worktrees/<id>\\\"\\n\\tgitFilePath := filepath.Join(repoRoot, gitDir)\\n\\tcontent, err := os.ReadFile(gitFilePath) //nolint:gosec // G304: gitFilePath is constructed from repo root, not user input\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read .git file: %w\\\", err)\\n\\t}\\n\\n\\tgitdir := strings.TrimSpace(string(content))\\n\\tgitdir = strings.TrimPrefix(gitdir, \\\"gitdir: \\\")\\n\\n\\t// Extract main repo root: everything before \\\"/.git/\\\"\\n\\tidx := strings.LastIndex(gitdir, \\\"/.git/\\\")\\n\\tif idx < 0 {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"unexpected gitdir format: %s\\\", gitdir)\\n\\t}\\n\\treturn gitdir[:idx], nil\\n}\\n\\n// GetGitCommonDir returns the path to the shared git directory.\\n// In a regular checkout, this is .git/\\n// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n// Uses git rev-parse --git-common-dir for reliable handling of worktrees.\\nfunc GetGitCommonDir() (string, error) {\\n\\tctx := context.Background()\\n\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-common-dir\\\")\\n\\tcmd.Dir = \\\".\\\"\\n\\toutput, err := cmd.Output()\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n\\t}\\n\\n\\tcommonDir := strings.TrimSpace(string(output))\\n\\n\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\n\\t// so we need to make it absolute if it isn't already\\n\\tif !filepath.IsAbs(commonDir) {\\n\\t\\tcommonDir = filepath.Join(\\\".\\\", commonDir)\\n\\t}\\n\\n\\treturn filepath.Clean(commonDir), nil\\n}\\n\\n// EnsureEntireGitignore ensures all required entries are in .entire/.gitignore\\n// Works correctly from any subdirectory within the repository.\\nfunc EnsureEntireGitignore() error {\\n\\t// Get absolute path for the gitignore file\\n\\tgitignoreAbs, err := paths.AbsPath(entireGitignore)\\n\\tif err != nil {\\n\\t\\tgitignoreAbs = entireGitignore // Fallback to relative\\n\\t}\\n\\n\\t// Read existing content\\n\\tvar content string\\n\\tif data, err := os.ReadFile(gitignoreAbs); err == nil { //nolint:gosec // path is from AbsPath or constant\\n\\t\\tcontent = string(data)\\n\\t}\\n\\n\\t// All entries that should be in .entire/.gitignore\\n\\trequiredEntries := []string{\\n\\t\\t\\\"tmp/\\\",\\n\\t\\t\\\"settings.local.json\\\",\\n\\t\\t\\\"metadata/\\\",\\n\\t\\t\\\"logs/\\\",\\n\\t}\\n\\n\\t// Track what needs to be added\\n\\tvar toAdd []string\\n\\tfor _, entry := range requiredEntries {\\n\\t\\tif !strings.Contains(content, entry) {\\n\\t\\t\\ttoAdd = append(toAdd, entry)\\n\\t\\t}\\n\\t}\\n\\n\\t// Nothing to add\\n\\tif len(toAdd) == 0 {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Ensure .entire directory exists\\n\\tif err := os.MkdirAll(filepath.Dir(gitignoreAbs), 0o750); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n\\t}\\n\\n\\t// Append missing entries to gitignore\\n\\tvar sb strings.Builder\\n\\tfor _, entry := range toAdd {\\n\\t\\tsb.WriteString(entry + \\\"\\\\n\\\")\\n\\t}\\n\\tcontent += sb.String()\\n\\n\\tif err := os.WriteFile(gitignoreAbs, []byte(content), 0o644); err != nil { //nolint:gosec // path is from AbsPath or constant\\n\\t\\treturn fmt.Errorf(\\\"failed to write gitignore: %w\\\", err)\\n\\t}\\n\\treturn nil\\n}\\n\\n// checkCanRewindWithWarning checks working directory and returns a warning with diff stats.\\n// Always returns canRewind=true but includes a warning message with +/- line stats for\\n// uncommitted changes. Used by manual-commit strategy.\\nfunc checkCanRewindWithWarning() (bool, string, error) {\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\t// Can't open repo - still allow rewind but without stats\\n\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if repo can't be opened\\n\\t}\\n\\n\\tworktree, err := repo.Worktree()\\n\\tif err != nil {\\n\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if worktree can't be accessed\\n\\t}\\n\\n\\tstatus, err := worktree.Status()\\n\\tif err != nil {\\n\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if status can't be retrieved\\n\\t}\\n\\n\\tif status.IsClean() {\\n\\t\\treturn true, \\\"\\\", nil\\n\\t}\\n\\n\\t// Get HEAD commit tree for comparison - if we can't get it, just return without stats\\n\\thead, err := repo.Head()\\n\\tif err != nil {\\n\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even without HEAD (e.g., empty repo)\\n\\t}\\n\\n\\theadCommit, err := repo.CommitObject(head.Hash())\\n\\tif err != nil {\\n\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if commit lookup fails\\n\\t}\\n\\n\\theadTree, err := headCommit.Tree()\\n\\tif err != nil {\\n\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if tree lookup fails\\n\\t}\\n\\n\\ttype fileChange struct {\\n\\t\\tstatus   string // \\\"modified\\\", \\\"added\\\", \\\"deleted\\\"\\n\\t\\tadded    int\\n\\t\\tremoved  int\\n\\t\\tfilename string\\n\\t}\\n\\n\\tvar changes []fileChange\\n\\t// Use repo root, not cwd - git status returns paths relative to repo root\\n\\trepoRoot, err := paths.WorktreeRoot()\\n\\tif err != nil {\\n\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if worktree root lookup fails\\n\\t}\\n\\n\\tfor file, st := range status {\\n\\t\\t// Skip .entire directory\\n\\t\\tif paths.IsInfrastructurePath(file) {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Skip untracked files\\n\\t\\tif st.Worktree == git.Untracked {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tvar change fileChange\\n\\t\\tchange.filename = file\\n\\n\\t\\tswitch {\\n\\t\\tcase st.Staging == git.Added || st.Worktree == git.Added:\\n\\t\\t\\tchange.status = \\\"added\\\"\\n\\t\\t\\t// New file - count all lines as added\\n\\t\\t\\tabsPath := filepath.Join(repoRoot, file)\\n\\t\\t\\tif content, err := os.ReadFile(absPath); err == nil { //nolint:gosec // absPath is repo root + relative path from git status\\n\\t\\t\\t\\tchange.added = countLines(content)\\n\\t\\t\\t}\\n\\t\\tcase st.Staging == git.Deleted || st.Worktree == git.Deleted:\\n\\t\\t\\tchange.status = \\\"deleted\\\"\\n\\t\\t\\t// Deleted file - count lines from HEAD as removed\\n\\t\\t\\tif entry, err := headTree.File(file); err == nil {\\n\\t\\t\\t\\tif content, err := entry.Contents(); err == nil {\\n\\t\\t\\t\\t\\tchange.removed = countLines([]byte(content))\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\tcase st.Staging == git.Modified || st.Worktree == git.Modified:\\n\\t\\t\\tchange.status = \\\"modified\\\"\\n\\t\\t\\t// Modified file - compute diff stats\\n\\t\\t\\tvar headContent, workContent []byte\\n\\t\\t\\tif entry, err := headTree.File(file); err == nil {\\n\\t\\t\\t\\tif content, err := entry.Contents(); err == nil {\\n\\t\\t\\t\\t\\theadContent = []byte(content)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tabsPath := filepath.Join(repoRoot, file)\\n\\t\\t\\tif content, err := os.ReadFile(absPath); err == nil { //nolint:gosec // absPath is repo root + relative path from git status\\n\\t\\t\\t\\tworkContent = content\\n\\t\\t\\t}\\n\\t\\t\\tif headContent != nil && workContent != nil {\\n\\t\\t\\t\\tchange.added, change.removed = computeDiffStats(headContent, workContent)\\n\\t\\t\\t}\\n\\t\\tdefault:\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tchanges = append(changes, change)\\n\\t}\\n\\n\\tif len(changes) == 0 {\\n\\t\\treturn true, \\\"\\\", nil\\n\\t}\\n\\n\\t// Sort changes by filename for consistent output\\n\\tsort.Slice(changes, func(i, j int) bool {\\n\\t\\treturn changes[i].filename < changes[j].filename\\n\\t})\\n\\n\\tvar msg strings.Builder\\n\\tmsg.WriteString(\\\"The following uncommitted changes will be reverted:\\\\n\\\")\\n\\n\\ttotalAdded, totalRemoved := 0, 0\\n\\tfor _, c := range changes {\\n\\t\\ttotalAdded += c.added\\n\\t\\ttotalRemoved += c.removed\\n\\n\\t\\tvar stats string\\n\\t\\tswitch {\\n\\t\\tcase c.added > 0 && c.removed > 0:\\n\\t\\t\\tstats = fmt.Sprintf(\\\"+%d/-%d\\\", c.added, c.removed)\\n\\t\\tcase c.added > 0:\\n\\t\\t\\tstats = fmt.Sprintf(\\\"+%d\\\", c.added)\\n\\t\\tcase c.removed > 0:\\n\\t\\t\\tstats = fmt.Sprintf(\\\"-%d\\\", c.removed)\\n\\t\\t}\\n\\n\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  %-10s %s\\\", c.status+\\\":\\\", c.filename))\\n\\t\\tif stats != \\\"\\\" {\\n\\t\\t\\tmsg.WriteString(fmt.Sprintf(\\\" (%s)\\\", stats))\\n\\t\\t}\\n\\t\\tmsg.WriteString(\\\"\\\\n\\\")\\n\\t}\\n\\n\\tif totalAdded > 0 || totalRemoved > 0 {\\n\\t\\tmsg.WriteString(fmt.Sprintf(\\\"\\\\nTotal: +%d/-%d lines\\\\n\\\", totalAdded, totalRemoved))\\n\\t}\\n\\n\\treturn true, msg.String(), nil\\n}\\n\\n// countLines counts the number of lines in content.\\nfunc countLines(content []byte) int {\\n\\tif len(content) == 0 {\\n\\t\\treturn 0\\n\\t}\\n\\tcount := 1\\n\\tfor _, b := range content {\\n\\t\\tif b == '\\\\n' {\\n\\t\\t\\tcount++\\n\\t\\t}\\n\\t}\\n\\t// Don't count trailing newline as extra line\\n\\tif len(content) > 0 && content[len(content)-1] == '\\\\n' {\\n\\t\\tcount--\\n\\t}\\n\\treturn count\\n}\\n\\n// computeDiffStats computes added and removed line counts between old and new content.\\n// Uses a simple line-based diff algorithm.\\nfunc computeDiffStats(oldContent, newContent []byte) (added, removed int) {\\n\\toldLines := splitLines(oldContent)\\n\\tnewLines := splitLines(newContent)\\n\\n\\t// Build a set of old lines with counts\\n\\toldSet := make(map[string]int)\\n\\tfor _, line := range oldLines {\\n\\t\\toldSet[line]++\\n\\t}\\n\\n\\t// Check which new lines are truly new\\n\\tfor _, line := range newLines {\\n\\t\\tif oldSet[line] > 0 {\\n\\t\\t\\toldSet[line]--\\n\\t\\t} else {\\n\\t\\t\\tadded++\\n\\t\\t}\\n\\t}\\n\\n\\t// Remaining old lines are removed\\n\\tfor _, count := range oldSet {\\n\\t\\tremoved += count\\n\\t}\\n\\n\\treturn added, removed\\n}\\n\\n// splitLines splits content into lines, preserving empty lines.\\nfunc splitLines(content []byte) []string {\\n\\tif len(content) == 0 {\\n\\t\\treturn nil\\n\\t}\\n\\ts := string(content)\\n\\t// Remove trailing newline to avoid empty last element\\n\\ts = strings.TrimSuffix(s, \\\"\\\\n\\\")\\n\\treturn strings.Split(s, \\\"\\\\n\\\")\\n}\\n\\n// fileExists checks if a file exists at the given path.\\nfunc fileExists(path string) bool {\\n\\t_, err := os.Stat(path)\\n\\treturn err == nil\\n}\\n\\n// StageFilesContext describes what type of staging operation this is (for messages).\\ntype StageFilesContext string\\n\\nconst (\\n\\t// StageForSession is used when staging files for a session checkpoint.\\n\\tStageForSession StageFilesContext = \\\"session\\\"\\n\\t// StageForTask is used when staging files for a task checkpoint.\\n\\tStageForTask StageFilesContext = \\\"task\\\"\\n)\\n\\n// StageFiles stages modified, new, and deleted files to the git worktree.\\n//\\n// This function handles three categories of file changes:\\n//  1. Modified files: existing files that have been changed\\n//  2. New files: files that were created during the session\\n//  3. Deleted files: files that were removed during the session\\n//\\n// Error Handling Strategy:\\n//   - Individual file staging errors are logged to stderr but don't fail the operation\\n//   - This ensures that partial staging succeeds even if some files have issues\\n//   - If a modified file no longer exists, it's treated as a deletion\\n//\\n// The stageCtx parameter is used for user-facing messages to indicate whether\\n// this is staging for a session checkpoint or a task checkpoint.\\nfunc StageFiles(worktree *git.Worktree, modified, newFiles, deleted []string, stageCtx StageFilesContext) {\\n\\t// Get worktree root for resolving file paths\\n\\t// This is critical because fileExists() uses os.Stat() which resolves relative to CWD,\\n\\t// but worktree.Add/Remove resolve relative to repo root. If CWD != repo root,\\n\\t// fileExists() could return false for existing files, causing worktree.Remove()\\n\\t// to incorrectly delete them.\\n\\trepoRoot := worktree.Filesystem.Root()\\n\\n\\t// Stage modified files\\n\\tfor _, file := range modified {\\n\\t\\t// Resolve path relative to repo root for existence check\\n\\t\\tabsPath := filepath.Join(repoRoot, file)\\n\\t\\tif fileExists(absPath) {\\n\\t\\t\\tif _, err := worktree.Add(file); err != nil {\\n\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage %s: %v\\\\n\\\", file, err)\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged: %s\\\\n\\\", file)\\n\\t\\t\\t}\\n\\t\\t} else {\\n\\t\\t\\t// File was deleted - stage the deletion\\n\\t\\t\\tif _, err := worktree.Remove(file); err != nil {\\n\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  File not found or deleted: %s\\\\n\\\", file)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Stage new files\\n\\tif len(newFiles) > 0 {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Staging %d new files created during %s:\\\\n\\\", len(newFiles), stageCtx)\\n\\t\\tfor _, file := range newFiles {\\n\\t\\t\\tif _, err := worktree.Add(file); err != nil {\\n\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage %s: %v\\\\n\\\", file, err)\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged new file: %s\\\\n\\\", file)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Stage deleted files\\n\\tfor _, file := range deleted {\\n\\t\\tif _, err := worktree.Remove(file); err != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage deleted file %s: %v\\\\n\\\", file, err)\\n\\t\\t} else {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged deleted file: %s\\\\n\\\", file)\\n\\t\\t}\\n\\t}\\n}\\n\\n// getTaskCheckpointFromTree retrieves a task checkpoint from a commit tree.\\n// Shared implementation for shadow and linear-shadow strategies.\\nfunc getTaskCheckpointFromTree(point RewindPoint) (*TaskCheckpoint, error) {\\n\\tif !point.IsTaskCheckpoint {\\n\\t\\treturn nil, ErrNotTaskCheckpoint\\n\\t}\\n\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\tcommitHash := plumbing.NewHash(point.ID)\\n\\tcommit, err := repo.CommitObject(commitHash)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n\\t}\\n\\n\\t// Read checkpoint.json from the tree\\n\\tcheckpointPath := point.MetadataDir + \\\"/checkpoint.json\\\"\\n\\tfile, err := tree.File(checkpointPath)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", checkpointPath, err)\\n\\t}\\n\\n\\tcontent, err := file.Contents()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\n\\tvar checkpoint TaskCheckpoint\\n\\tif err := json.Unmarshal([]byte(content), &checkpoint); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to parse checkpoint: %w\\\", err)\\n\\t}\\n\\n\\treturn &checkpoint, nil\\n}\\n\\n// getTaskTranscriptFromTree retrieves a task transcript from a commit tree.\\n// Shared implementation for shadow and linear-shadow strategies.\\nfunc getTaskTranscriptFromTree(point RewindPoint) ([]byte, error) {\\n\\tif !point.IsTaskCheckpoint {\\n\\t\\treturn nil, ErrNotTaskCheckpoint\\n\\t}\\n\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\tcommitHash := plumbing.NewHash(point.ID)\\n\\tcommit, err := repo.CommitObject(commitHash)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n\\t}\\n\\n\\t// MetadataDir format: .entire/metadata/<session>/tasks/<toolUseID>\\n\\t// Session transcript is at: .entire/metadata/<session>/<TranscriptFileName>\\n\\tsessionDir := filepath.Dir(filepath.Dir(point.MetadataDir))\\n\\n\\t// Try current format first, then legacy\\n\\ttranscriptPath := sessionDir + \\\"/\\\" + paths.TranscriptFileName\\n\\tfile, err := tree.File(transcriptPath)\\n\\tif err != nil {\\n\\t\\ttranscriptPath = sessionDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n\\t\\tfile, err = tree.File(transcriptPath)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find transcript: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\tcontent, err := file.Contents()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n\\t}\\n\\n\\treturn []byte(content), nil\\n}\\n\\n// ErrBranchNotFound is returned by DeleteBranchCLI when the branch does not exist.\\nvar ErrBranchNotFound = errors.New(\\\"branch not found\\\")\\n\\n// DeleteBranchCLI deletes a git branch using the git CLI.\\n// Uses `git branch -D` instead of go-git's RemoveReference because go-git v5\\n// doesn't properly persist deletions when refs are packed (.git/packed-refs)\\n// or in a worktree context. This is the same class of go-git v5 bug that\\n// affects checkout and reset --hard (see HardResetWithProtection).\\n//\\n// Returns ErrBranchNotFound if the branch does not exist, allowing callers\\n// to use errors.Is for idempotent deletion patterns.\\nfunc DeleteBranchCLI(branchName string) error {\\n\\tctx := context.Background()\\n\\n\\t// Pre-check: verify the branch exists so callers get a structured error\\n\\t// instead of parsing git's output string (which varies across locales).\\n\\t// git show-ref exits 1 for \\\"not found\\\" and 128+ for fatal errors (corrupt\\n\\t// repo, permissions, not a git directory). Only map exit code 1 to\\n\\t// ErrBranchNotFound; propagate other failures as-is.\\n\\tcheck := exec.CommandContext(ctx, \\\"git\\\", \\\"show-ref\\\", \\\"--verify\\\", \\\"--quiet\\\", \\\"refs/heads/\\\"+branchName) //nolint:gosec // branchName comes from internal shadow branch naming\\n\\tif err := check.Run(); err != nil {\\n\\t\\tvar exitErr *exec.ExitError\\n\\t\\tif errors.As(err, &exitErr) && exitErr.ExitCode() == 1 {\\n\\t\\t\\treturn fmt.Errorf(\\\"%w: %s\\\", ErrBranchNotFound, branchName)\\n\\t\\t}\\n\\t\\treturn fmt.Errorf(\\\"failed to check branch %s: %w\\\", branchName, err)\\n\\t}\\n\\n\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", branchName)\\n\\tif output, err := cmd.CombinedOutput(); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to delete branch %s: %s: %w\\\", branchName, strings.TrimSpace(string(output)), err)\\n\\t}\\n\\treturn nil\\n}\\n\\n// branchExistsCLI checks if a branch exists using git CLI.\\n// Returns nil if the branch exists, or an error if it does not.\\nfunc branchExistsCLI(branchName string) error {\\n\\tctx := context.Background()\\n\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"show-ref\\\", \\\"--verify\\\", \\\"--quiet\\\", \\\"refs/heads/\\\"+branchName) //nolint:gosec // branchName comes from internal shadow branch naming\\n\\tif err := cmd.Run(); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"branch %s not found: %w\\\", branchName, err)\\n\\t}\\n\\treturn nil\\n}\\n\\n// HardResetWithProtection performs a git reset --hard to the specified commit.\\n// Uses the git CLI instead of go-git because go-git's HardReset incorrectly\\n// deletes untracked directories (like .entire/) even when they're in .gitignore.\\n// Returns the short commit ID (7 chars) on success for display purposes.\\nfunc HardResetWithProtection(commitHash plumbing.Hash) (shortID string, err error) {\\n\\tctx := context.Background()\\n\\thashStr := commitHash.String()\\n\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"reset\\\", \\\"--hard\\\", hashStr) //nolint:gosec // hashStr is a plumbing.Hash, not user input\\n\\tif output, err := cmd.CombinedOutput(); err != nil {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"reset failed: %s: %w\\\", strings.TrimSpace(string(output)), err)\\n\\t}\\n\\n\\t// Return short commit ID for display\\n\\tshortID = hashStr\\n\\tif len(shortID) > 7 {\\n\\t\\tshortID = shortID[:7]\\n\\t}\\n\\treturn shortID, nil\\n}\\n\\n// collectUntrackedFiles collects untracked files in the working directory that are\\n// NOT ignored by .gitignore. This is used to capture the initial state when starting\\n// a session, ensuring untracked files present at session start are preserved during rewind.\\n// Uses \\\"git ls-files --others --exclude-standard -z\\\" to respect .gitignore rules,\\n// avoiding bloated session state from large ignored directories like node_modules/.\\n// Returns paths relative to the repository root.\\nfunc collectUntrackedFiles() ([]string, error) {\\n\\trepoRoot, err := paths.WorktreeRoot()\\n\\tif err != nil {\\n\\t\\trepoRoot = \\\".\\\"\\n\\t}\\n\\n\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"ls-files\\\", \\\"--others\\\", \\\"--exclude-standard\\\", \\\"-z\\\")\\n\\tcmd.Dir = repoRoot\\n\\toutput, err := cmd.Output()\\n\\tif err != nil {\\n\\t\\tvar exitErr *exec.ExitError\\n\\t\\tif errors.As(err, &exitErr) {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"git ls-files failed: %s: %w\\\", strings.TrimSpace(string(exitErr.Stderr)), err)\\n\\t\\t}\\n\\t\\treturn nil, fmt.Errorf(\\\"git ls-files failed: %w\\\", err)\\n\\t}\\n\\n\\traw := string(output)\\n\\tif raw == \\\"\\\" {\\n\\t\\treturn nil, nil\\n\\t}\\n\\n\\tvar files []string\\n\\tfor _, f := range strings.Split(raw, \\\"\\\\x00\\\") {\\n\\t\\t// Defense-in-depth: filter protected paths even though --exclude-standard should already handle them\\n\\t\\tif f != \\\"\\\" && !isProtectedPath(f) {\\n\\t\\t\\tfiles = append(files, f)\\n\\t\\t}\\n\\t}\\n\\treturn files, nil\\n}\\n\\n// ExtractSessionIDFromCommit extracts the session ID from a commit's trailers.\\n// It checks the Entire-Session trailer first, then falls back to extracting from\\n// the metadata directory path in the Entire-Metadata trailer.\\n// Returns empty string if no session ID is found.\\nfunc ExtractSessionIDFromCommit(commit *object.Commit) string {\\n\\t// Try Entire-Session trailer first\\n\\tif sessionID, found := trailers.ParseSession(commit.Message); found {\\n\\t\\treturn sessionID\\n\\t}\\n\\n\\t// Try extracting from metadata directory (last path component)\\n\\tif metadataDir, found := trailers.ParseMetadata(commit.Message); found {\\n\\t\\treturn filepath.Base(metadataDir)\\n\\t}\\n\\n\\treturn \\\"\\\"\\n}\\n\\n// NOTE: The following git tree helper functions have been moved to checkpoint/ package:\\n// - FlattenTree -> checkpoint.FlattenTree\\n// - CreateBlobFromContent -> checkpoint.CreateBlobFromContent\\n// - BuildTreeFromEntries -> checkpoint.BuildTreeFromEntries\\n// - sortTreeEntries (internal to checkpoint package)\\n// - treeNode, insertIntoTree, buildTreeObject (internal to checkpoint package)\\n//\\n// See push_common.go and session_test.go for usage examples.\\n\\n// createCommit creates a commit object\\nfunc createCommit(repo *git.Repository, treeHash, parentHash plumbing.Hash, message, authorName, authorEmail string) (plumbing.Hash, error) { //nolint:unparam // already present in codebase\\n\\tnow := time.Now()\\n\\tsig := object.Signature{\\n\\t\\tName:  authorName,\\n\\t\\tEmail: authorEmail,\\n\\t\\tWhen:  now,\\n\\t}\\n\\n\\tcommit := &object.Commit{\\n\\t\\tTreeHash:  treeHash,\\n\\t\\tAuthor:    sig,\\n\\t\\tCommitter: sig,\\n\\t\\tMessage:   message,\\n\\t}\\n\\n\\t// Add parent if not a new branch\\n\\tif parentHash != plumbing.ZeroHash {\\n\\t\\tcommit.ParentHashes = []plumbing.Hash{parentHash}\\n\\t}\\n\\n\\tobj := repo.Storer.NewEncodedObject()\\n\\tif err := commit.Encode(obj); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n\\t}\\n\\n\\thash, err := repo.Storer.SetEncodedObject(obj)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store commit: %w\\\", err)\\n\\t}\\n\\n\\treturn hash, nil\\n}\\n\\n// getSessionDescriptionFromTree reads the first line of prompt.txt or context.md from a git tree.\\n// This is the tree-based equivalent of getSessionDescription (which reads from filesystem).\\n//\\n// If metadataDir is provided, looks for files at metadataDir/prompt.txt or metadataDir/context.md.\\n// If metadataDir is empty, first tries the root of the tree (for when the tree is already\\n// the session directory), then falls back to\\n// searching for .entire/metadata/*/prompt.txt or context.md (for full worktree trees).\\nfunc getSessionDescriptionFromTree(tree *object.Tree, metadataDir string) string {\\n\\t// Helper to read first line from a file in tree\\n\\treadFirstLine := func(path string) string {\\n\\t\\tfile, err := tree.File(path)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn \\\"\\\"\\n\\t\\t}\\n\\t\\tcontent, err := file.Contents()\\n\\t\\tif err != nil {\\n\\t\\t\\treturn \\\"\\\"\\n\\t\\t}\\n\\t\\tlines := strings.SplitN(content, \\\"\\\\n\\\", 2)\\n\\t\\tif len(lines) > 0 && lines[0] != \\\"\\\" {\\n\\t\\t\\tdesc := strings.TrimSpace(lines[0])\\n\\t\\t\\t// Remove markdown header prefix if present\\n\\t\\t\\treturn strings.TrimPrefix(desc, \\\"# \\\")\\n\\t\\t}\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\n\\t// If metadataDir is provided, look there directly\\n\\tif metadataDir != \\\"\\\" {\\n\\t\\tif desc := readFirstLine(metadataDir + \\\"/\\\" + paths.PromptFileName); desc != \\\"\\\" {\\n\\t\\t\\treturn desc\\n\\t\\t}\\n\\t\\tif desc := readFirstLine(metadataDir + \\\"/\\\" + paths.ContextFileName); desc != \\\"\\\" {\\n\\t\\t\\treturn desc\\n\\t\\t}\\n\\t\\treturn NoDescription\\n\\t}\\n\\n\\t// No metadataDir provided - first try looking at the root of the tree\\n\\t// (used when the tree is already the session directory)\\n\\tif desc := readFirstLine(paths.PromptFileName); desc != \\\"\\\" {\\n\\t\\treturn desc\\n\\t}\\n\\tif desc := readFirstLine(paths.ContextFileName); desc != \\\"\\\" {\\n\\t\\treturn desc\\n\\t}\\n\\n\\t// Fall back to searching for .entire/metadata/*/prompt.txt or context.md\\n\\t// (used when the tree is the full worktree)\\n\\tvar desc string\\n\\t//nolint:errcheck // We ignore errors here as we're just searching for a description\\n\\t_ = tree.Files().ForEach(func(f *object.File) error {\\n\\t\\tif desc != \\\"\\\" {\\n\\t\\t\\treturn nil // Already found description\\n\\t\\t}\\n\\t\\tname := f.Name\\n\\t\\tif strings.Contains(name, \\\".entire/metadata/\\\") {\\n\\t\\t\\tif strings.HasSuffix(name, \\\"/\\\"+paths.PromptFileName) || strings.HasSuffix(name, \\\"/\\\"+paths.ContextFileName) {\\n\\t\\t\\t\\tcontent, err := f.Contents()\\n\\t\\t\\t\\tif err != nil {\\n\\t\\t\\t\\t\\treturn nil //nolint:nilerr // Skip files we can't read, continue searching\\n\\t\\t\\t\\t}\\n\\t\\t\\t\\tlines := strings.SplitN(content, \\\"\\\\n\\\", 2)\\n\\t\\t\\t\\tif len(lines) > 0 && lines[0] != \\\"\\\" {\\n\\t\\t\\t\\t\\tdesc = strings.TrimSpace(lines[0])\\n\\t\\t\\t\\t\\tdesc = strings.TrimPrefix(desc, \\\"# \\\")\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\t\\treturn nil\\n\\t})\\n\\n\\tif desc != \\\"\\\" {\\n\\t\\treturn desc\\n\\t}\\n\\treturn NoDescription\\n}\\n\\n// GetGitAuthorFromRepo retrieves the git user.name and user.email,\\n// checking both the repository-local config and the global ~/.gitconfig.\\n// Delegates to checkpoint.GetGitAuthorFromRepo — this wrapper exists so\\n// callers within the strategy package don't need a qualified import.\\nfunc GetGitAuthorFromRepo(repo *git.Repository) (name, email string) {\\n\\treturn checkpoint.GetGitAuthorFromRepo(repo)\\n}\\n\\n// GetCurrentBranchName returns the short name of the current branch if HEAD points to a branch.\\n// Returns an empty string if in detached HEAD state or if there's an error reading HEAD.\\n// This is used to capture branch metadata for checkpoints.\\nfunc GetCurrentBranchName(repo *git.Repository) string {\\n\\thead, err := repo.Head()\\n\\tif err != nil || !head.Name().IsBranch() {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\treturn head.Name().Short()\\n}\\n\\n// getMainBranchHash returns the hash of the main branch (main or master).\\n// Returns ZeroHash if no main branch is found.\\nfunc GetMainBranchHash(repo *git.Repository) plumbing.Hash {\\n\\t// Try common main branch names\\n\\tfor _, branchName := range []string{branchMain, branchMaster} {\\n\\t\\t// Try local branch first\\n\\t\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n\\t\\tif err == nil {\\n\\t\\t\\treturn ref.Hash()\\n\\t\\t}\\n\\t\\t// Try remote tracking branch\\n\\t\\tref, err = repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", branchName), true)\\n\\t\\tif err == nil {\\n\\t\\t\\treturn ref.Hash()\\n\\t\\t}\\n\\t}\\n\\treturn plumbing.ZeroHash\\n}\\n\\n// GetDefaultBranchName returns the name of the default branch.\\n// First checks origin/HEAD, then falls back to checking if main/master exists.\\n// Returns empty string if unable to determine.\\n// NOTE: Duplicated from cli/git_operations.go - see ENT-129 for consolidation.\\nfunc GetDefaultBranchName(repo *git.Repository) string {\\n\\t// Try to get the symbolic reference for origin/HEAD\\n\\t// Use resolved=false to get the symbolic ref itself, then extract its target\\n\\tref, err := repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", \\\"HEAD\\\"), false)\\n\\tif err == nil && ref != nil && ref.Type() == plumbing.SymbolicReference {\\n\\t\\ttarget := ref.Target().String()\\n\\t\\tif branchName, found := strings.CutPrefix(target, \\\"refs/remotes/origin/\\\"); found {\\n\\t\\t\\treturn branchName\\n\\t\\t}\\n\\t}\\n\\n\\t// Fallback: check if origin/main or origin/master exists\\n\\tif _, err := repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", branchMain), true); err == nil {\\n\\t\\treturn branchMain\\n\\t}\\n\\tif _, err := repo.Reference(plumbing.NewRemoteReferenceName(\\\"origin\\\", branchMaster), true); err == nil {\\n\\t\\treturn branchMaster\\n\\t}\\n\\n\\t// Final fallback: check local branches\\n\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(branchMain), true); err == nil {\\n\\t\\treturn branchMain\\n\\t}\\n\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(branchMaster), true); err == nil {\\n\\t\\treturn branchMaster\\n\\t}\\n\\n\\treturn \\\"\\\"\\n}\\n\\n// IsOnDefaultBranch checks if the repository HEAD is on the default branch.\\n// Returns (isOnDefault, currentBranchName).\\n// NOTE: Duplicated from cli/git_operations.go - see ENT-129 for consolidation.\\nfunc IsOnDefaultBranch(repo *git.Repository) (bool, string) {\\n\\tcurrentBranch := GetCurrentBranchName(repo)\\n\\tif currentBranch == \\\"\\\" {\\n\\t\\treturn false, \\\"\\\"\\n\\t}\\n\\n\\tdefaultBranch := GetDefaultBranchName(repo)\\n\\tif defaultBranch == \\\"\\\" {\\n\\t\\t// Can't determine default, check common names\\n\\t\\tif currentBranch == branchMain || currentBranch == branchMaster {\\n\\t\\t\\treturn true, currentBranch\\n\\t\\t}\\n\\t\\treturn false, currentBranch\\n\\t}\\n\\n\\treturn currentBranch == defaultBranch, currentBranch\\n}\\n\\n// prepareTranscriptIfNeeded calls PrepareTranscript for agents that implement\\n// the TranscriptPreparer interface. This ensures transcript files exist before\\n// they are read (e.g., OpenCode creates its transcript lazily via `opencode export`).\\n// Errors are silently ignored — this is best-effort for hook paths.\\nfunc prepareTranscriptIfNeeded(agentType agent.AgentType, transcriptPath string) {\\n\\tif transcriptPath == \\\"\\\" {\\n\\t\\treturn\\n\\t}\\n\\tag, err := agent.GetByAgentType(agentType)\\n\\tif err != nil {\\n\\t\\treturn\\n\\t}\\n\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n\\t\\t// Best-effort: callers handle missing files gracefully.\\n\\t\\t// Transcript may not be available yet (e.g., agent not installed).\\n\\t\\t_ = preparer.PrepareTranscript(transcriptPath) //nolint:errcheck // Best-effort in hook path\\n\\t}\\n}\\n\",\"numLines\":1463,\"startLine\":1,\"totalLines\":1463}},\"sourceToolAssistantUUID\":\"145cd6cb-0a9b-43e1-a485-4f172e83945d\"}\n{\"parentUuid\":\"2c5045ae-6cbc-45f5-a076-b841bfe7f83c\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/soph/