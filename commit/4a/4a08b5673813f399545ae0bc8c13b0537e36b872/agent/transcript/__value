rker, cmdPrefix),\\n   203→\\t\\t},\\n   204→\\t}\\n   205→}\\n   206→\\n   207→// InstallGitHook installs generic git hooks that delegate to `entire hook` commands.\\n   208→// These hooks work with any strategy - the strategy is determined at runtime.\\n   209→// If silent is true, no output is printed (except backup notifications, which always print).\\n   210→// localDev controls whether hooks use \\\"go run\\\" (true) or the \\\"entire\\\" binary (false).\\n   211→// Returns the number of hooks that were installed (0 if all already up to date).\\n   212→func InstallGitHook(silent bool, localDev bool) (int, error) {\\n   213→\\thooksDir, err := GetHooksDir()\\n   214→\\tif err != nil {\\n   215→\\t\\treturn 0, err\\n   216→\\t}\\n   217→\\n   218→\\tif err := os.MkdirAll(hooksDir, 0o755); err != nil { //nolint:gosec // Git hooks require executable permissions\\n   219→\\t\\treturn 0, fmt.Errorf(\\\"failed to create hooks directory: %w\\\", err)\\n   220→\\t}\\n   221→\\n   222→\\tspecs := buildHookSpecs(hookCmdPrefix(localDev))\\n   223→\\tinstalledCount := 0\\n   224→\\n   225→\\tfor _, spec := range specs {\\n   226→\\t\\thookPath := filepath.Join(hooksDir, spec.name)\\n   227→\\t\\tbackupPath := hookPath + backupSuffix\\n   228→\\t\\tbackupExists := fileExists(backupPath)\\n   229→\\n   230→\\t\\t// Back up existing non-Entire hooks\\n   231→\\t\\texisting, existingErr := os.ReadFile(hookPath) //nolint:gosec // path is controlled\\n   232→\\t\\tif existingErr == nil && !strings.Contains(string(existing), entireHookMarker) {\\n   233→\\t\\t\\tif !backupExists {\\n   234→\\t\\t\\t\\tif err := os.Rename(hookPath, backupPath); err != nil {\\n   235→\\t\\t\\t\\t\\treturn installedCount, fmt.Errorf(\\\"failed to back up %s: %w\\\", spec.name, err)\\n   236→\\t\\t\\t\\t}\\n   237→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Backed up existing %s to %s%s\\\\n\\\", spec.name, spec.name, backupSuffix)\\n   238→\\t\\t\\t} else {\\n   239→\\t\\t\\t\\tfmt.Fprintf(os.St