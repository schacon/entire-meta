ing telemetry field: %w\\\", err)\\n   187→\\t\\t}\\n   188→\\t\\tsettings.Telemetry = &t\\n   189→\\t}\\n   190→\\n   191→\\treturn nil\\n   192→}\\n   193→\\n   194→// IsSetUp returns true if Entire has been set up in the current repository.\\n   195→// This checks if .entire/settings.json exists.\\n   196→// Use this to avoid creating files/directories in repos where Entire was never enabled.\\n   197→func IsSetUp() bool {\\n   198→\\tsettingsFileAbs, err := paths.AbsPath(EntireSettingsFile)\\n   199→\\tif err != nil {\\n   200→\\t\\treturn false\\n   201→\\t}\\n   202→\\t_, err = os.Stat(settingsFileAbs)\\n   203→\\treturn err == nil\\n   204→}\\n   205→\\n   206→// IsSetUpAndEnabled returns true if Entire is both set up and enabled.\\n   207→// This checks if .entire/settings.json exists AND has enabled: true.\\n   208→// Use this for hooks that should be no-ops when Entire is not active.\\n   209→func IsSetUpAndEnabled() bool {\\n   210→\\tif !IsSetUp() {\\n   211→\\t\\treturn false\\n   212→\\t}\\n   213→\\ts, err := Load()\\n   214→\\tif err != nil {\\n   215→\\t\\treturn false\\n   216→\\t}\\n   217→\\treturn s.Enabled\\n   218→}\\n   219→\\n   220→// IsSummarizeEnabled checks if auto-summarize is enabled in settings.\\n   221→// Returns false by default if settings cannot be loaded or the key is missing.\\n   222→func IsSummarizeEnabled() bool {\\n   223→\\tsettings, err := Load()\\n   224→\\tif err != nil {\\n   225→\\t\\treturn false\\n   226→\\t}\\n   227→\\treturn settings.IsSummarizeEnabled()\\n   228→}\\n   229→\\n   230→// IsSummarizeEnabled checks if auto-summarize is enabled in this settings instance.\\n   231→func (s *EntireSettings) IsSummarizeEnabled() bool {\\n   232→\\tif s.StrategyOptions == nil {\\n   233→\\t\\treturn false\\n   234→\\t}\\n   235→\\tsummarizeOpts, ok := s.StrategyOptions[\\\"summarize\\\"].(map[string]any)\\n   236→\\tif !ok {\\n   237→\\t\\treturn false\\n   238→\\t}\\n   239→\\tenabled, ok := summarizeOpts[\\\"enabled\\\"