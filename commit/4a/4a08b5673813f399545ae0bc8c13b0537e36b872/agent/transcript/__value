 *cobra.Command {\\n    30→\\tvar localDev bool\\n    31→\\tvar ignoreUntracked bool\\n    32→\\tvar useLocalSettings bool\\n    33→\\tvar useProjectSettings bool\\n    34→\\tvar agentName string\\n    35→\\tvar forceHooks bool\\n    36→\\tvar skipPushSessions bool\\n    37→\\tvar telemetry bool\\n    38→\\n    39→\\tcmd := &cobra.Command{\\n    40→\\t\\tUse:   \\\"enable\\\",\\n    41→\\t\\tShort: \\\"Enable Entire in current project\\\",\\n    42→\\t\\tLong: `Enable Entire with session tracking for your AI agent workflows.\\n    43→\\n    44→Uses the manual-commit strategy, which creates session checkpoints without\\n    45→modifying your active branch.`,\\n    46→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    47→\\t\\t\\t// Check if we're in a git repository first - this is a prerequisite error,\\n    48→\\t\\t\\t// not a usage error, so we silence Cobra's output and use SilentError\\n    49→\\t\\t\\t// to prevent duplicate error output in main.go\\n    50→\\t\\t\\tif _, err := paths.WorktreeRoot(); err != nil {\\n    51→\\t\\t\\t\\tfmt.Fprintln(cmd.ErrOrStderr(), \\\"Not a git repository. Please run 'entire enable' from within a git repository.\\\")\\n    52→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n    53→\\t\\t\\t}\\n    54→\\n    55→\\t\\t\\tif err := validateSetupFlags(useLocalSettings, useProjectSettings); err != nil {\\n    56→\\t\\t\\t\\treturn err\\n    57→\\t\\t\\t}\\n    58→\\n    59→\\t\\t\\t// Warn if repo has no commits yet\\n    60→\\t\\t\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n    61→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Note: This repository has no commits yet. Entire will be configured, but\\\")\\n    62→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"session checkpoints won't work until you create your first commit.\\\")\\n    63→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout())\\n    64→\\t\\t\\t}\\n    65→\\n    66→\\t\\t\\t// Non-interactive mode if --agent flag is provided\\n    67→\\t\\t\\tif cmd.Flags().Changed(\\\"agent\\\") && agentName == \\\"\\\" {\\n    68→\\t\\t\\t\\tprintMissingAgentError(cmd.ErrOrStderr())\\n    69→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n    70→\\t\\t\\t}\\n    71→\\n    72→\\t\\t\\tif agentName != \\\"\\\" {\\n    73→\\t\\t\\t\\tag, err := agent.Get(agent.AgentName(agentName))\\n    74→\\t\\t\\t\\tif err != nil {\\n    75→\\t\\t\\t\\t\\tprintWrongAgentError(cmd.ErrOrStderr(), agentName)\\n    76→\\t\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"wrong agent name\\\"))\\n    77→\\t\\t\\t\\t}\\n    78→\\t\\t\\t\\t// --agent is a targeted operation: set up this specific agent without\\n    79→\\t\\t\\t\\t// affecting other agents. Unlike the interactive path, it does not\\n    80→\\t\\t\\t\\t// uninstall hooks for other previously-enabled agents.\\n    81→\\t\\t\\t\\treturn setupAgentHooksNonInteractive(cmd.OutOrStdout(), ag, localDev, forceHooks, skipPushSessions, telemetry)\\n    82→\\t\\t\\t}\\n    83→\\t\\t\\t// Detect or prompt for agents\\n    84→\\t\\t\\tagents, err := detectOrSelectAgent(cmd.OutOrStdout(), nil)\\n    85→\\t\\t\\tif err != nil {\\n    86→\\t\\t\\t\\treturn fmt.Errorf(\\\"agent selection failed: %w\\\", err)\\n    87→\\t\\t\\t}\\n    88→\\n    89→\\t\\t\\treturn runEnableInteractive(cmd.OutOrStdout(), agents, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry)\\n    90→\\t\\t},\\n    91→\\t}\\n    92→\\n    93→\\tcmd.Flags().BoolVar(&localDev, \\\"local-dev\\\", false, \\\"Use go run instead of entire binary for hooks\\\")\\n    94→\\tcmd.Flags().MarkHidden(\\\"local-dev\\\") //nolint:errcheck,gosec // flag is defined above\\n    95→\\tcmd.Flags().BoolVar(&ignoreUntracked, \\\"ignore-untracked\\\", false, \\\"Commit all new files without tracking pre-existing untracked files\\\")\\n    96→\\tcmd.Flags().MarkHidden(\\\"ignore-untracked\\\") //nolint:errcheck,gosec // flag is defined above\\n    97→\\tcmd.Flags().BoolVar(&useLocalSettings, \\\"local\\\", false, \\\"Write settings to .entire/settings.local.json instead of .entire/settings.json\\\")\\n    98→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Write settings to .entire/settings.json even if it already exists\\\")\\n    99→\\tcmd.Flags().StringVar(&agentName, \\\"agent\\\", \\\"\\\", \\\"Agent to set up hooks for (e.g., claude-code, gemini, opencode). Enables non-interactive mode.\\\")\\n   100→\\tcmd.Flags().BoolVarP(&forceHooks, \\\"force\\\", \\\"f\\\", false, \\\"Force reinstall hooks (removes existing Entire hooks first)\\\")\\n   101→\\tcmd.Flags().BoolVar(&skipPushSessions, \\\"skip-push-sessions\\\", false, \\\"Disable automatic pushing of session logs on git push\\\")\\n   102→\\tcmd.Flags().BoolVar(&telemetry, \\\"telemetry\\\", true, \\\"Enable anonymous usage analytics\\\")\\n   103→\\n   104→\\t// Provide a helpful error when --agent is used without a value\\n   105→\\tdefaultFlagErr := cmd.FlagErrorFunc()\\n   106→\\tcmd.SetFlagErrorFunc(func(c *cobra.Command, err error) error {\\n   107→\\t\\tvar valErr *pflag.ValueRequiredError\\n   108→\\t\\tif errors.As(err, &valErr) && valErr.GetSpecifiedName() == \\\"agent\\\" {\\n   109→\\t\\t\\tprintMissingAgentError(c.ErrOrStderr())\\n   110→\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n   111→\\t\\t}\\n   112→\\t\\treturn defaultFlagErr(c, err)\\n   113→\\t})\\n   114→\\n   115→\\t// Add subcommands for automation/testing\\n   116→\\tcmd.AddCommand(newSetupGitHookCmd())\\n   117→\\n   118→\\treturn cmd\\n   119→}\\n   120→\\n   121→func newDisableCmd() *cobra.Command {\\n   122→\\tvar useProjectSettings bool\\n   123→\\tvar uninstall bool\\n   124→\\tvar force bool\\n   125→\\n   126→\\tcmd := &cobra.Command{\\n   127→\\t\\tUse:   \\\"disable\\\",\\n   128→\\t\\tShort: \\\"Disable Entire in current project\\\",\\n   129→\\t\\tLong: `Disable Entire integrations in the current project.\\n   130→\\n   131→By default, this command will disable Entire. Hooks will exit silently and commands will\\n   132→show a disabled message.\\n   133→\\n   134→To completely remove Entire integrations from this repository, use --uninstall:\\n   135→  - .entire/ directory (settings, logs, metadata)\\n   136→  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\n   137→  - Session state files (.git/entire-sessions/)\\n   138→  - Shadow branches (entire/<hash>)\\n   139→  - Agent hooks`,\\n   140→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   141→\\t\\t\\tif uninstall {\\n   142→\\t\\t\\t\\treturn runUninstall(cmd.OutOrStdout(), cmd.ErrOrStderr(), force)\\n   143→\\t\\t\\t}\\n   144→\\t\\t\\treturn runDisable(cmd.OutOrStdout(), useProjectSettings)\\n   145→\\t\\t},\\n   146→\\t}\\n   147→\\n   148→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Update .entire/settings.json instead of .entire/settings.local.json\\\")\\n   149→\\tcmd.Flags().BoolVar(&uninstall, \\\"uninstall\\\", false, \\\"Completely remove Entire from this repository\\\")\\n   150→\\tcmd.Flags().BoolVar(&force, \\\"force\\\", false, \\\"Skip confirmation prompt (use with --uninstall)\\\")\\n   151→\\n   152→\\treturn cmd\\n   153→}\\n   154→\\n   155→// runEnableInteractive runs the interactive enable flow.\\n   156→// agents must be provided by the caller (via detectOrSelectAgent).\\n   157→func runEnableInteractive(w io.Writer, agents []agent.Agent, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry bool) error {\\n   158→\\t// Uninstall hooks for agents that were previously active but are no longer selected\\n   159→\\tif err := uninstallDeselectedAgentHooks(w, agents); err != nil {\\n   160→\\t\\treturn fmt.Errorf(\\\"failed to clean up deselected agents: %w\\\", err)\\n   161→\\t}\\n   162→\\n   163→\\t// Setup agent hooks for all selected agents\\n   164→\\tfor _, ag := range agents {\\n   165→\\t\\tif _, err := setupAgentHooks(ag, localDev, forceHooks); err != nil {\\n   166→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   167→\\t\\t}\\n   168→\\t}\\n   169→\\n   170→\\t// Setup .entire directory\\n   171→\\tif _, err := setupEntireDirectory(); err != nil {\\n   172→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   173→\\t}\\n   174→\\n   175→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   176→\\tsettings, err := LoadEntireSettings()\\n   177→\\tif err != nil {\\n   178→\\t\\t// If we can't load, start with defaults\\n   179→\\t\\tsettings = &EntireSettings{}\\n   180→\\t}\\n   181→\\t// Update the specific fields\\n   182→\\tsettings.LocalDev = localDev\\n   183→\\tsettings.Enabled = true\\n   184→\\n   185→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   186→\\tif skipPushSessions {\\n   187→\\t\\tif settings.StrategyOptions == nil {\\n   188→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   189→\\t\\t}\\n   190→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   191→\\t}\\n   192→\\n   193→\\t// Determine which settings file to write to\\n   194→\\t// First run always creates settings.json (no prompt)\\n   195→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   196→\\tif err != nil {\\n   197→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   198→\\t}\\n   199→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   200→\\n   201→\\tif showNotification {\\n   202→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   203→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   204→\\t}\\n   205→\\n   206→\\t// Helper to save settings to the appropriate file\\n   207→\\tsaveSettings := func() error {\\n   208→\\t\\tif shouldUseLocal {\\n   209→\\t\\t\\treturn SaveEntireSettingsLocal(settings)\\n   210→\\t\\t}\\n   211→\\t\\treturn SaveEntireSettings(settings)\\n   212→\\t}\\n   213→\\n   214→\\t// Save settings before telemetry prompt so config is persisted even if the user cancels\\n   215→\\tif err := saveSettings(); err != nil {\\n   216→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   217→\\t}\\n   218→\\n   219→\\tif _, err := strategy.InstallGitHook(true, localDev); err != nil {\\n   220→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   221→\\t}\\n   222→\\tstrategy.CheckAndWarnHookManagers(w, localDev)\\n   223→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   224→\\n   225→\\tconfigDisplay := configDisplayProject\\n   226→\\tif shouldUseLocal {\\n   227→\\t\\tconfigDisplay = configDisplayLocal\\n   228→\\t}\\n   229→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   230→\\n   231→\\t// Ask about telemetry consent (only if not already asked)\\n   232→\\tfmt.Fprintln(w)\\n   233→\\tif err := promptTelemetryConsent(settings, telemetry); err != nil {\\n   234→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   235→\\t}\\n   236→\\t// Save again to persist telemetry choice\\n   237→\\tif err := saveSettings(); err != nil {\\n   238→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   239→\\t}\\n   240→\\n   241→\\tif err := strategy.EnsureSetup(); err != nil {\\n   242→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   243→\\t}\\n   244→\\n   245→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   246→\\n   247→\\treturn nil\\n   248→}\\n   249→\\n   250→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   251→func runEnable(w io.Writer) error {\\n   252→\\tsettings, err := LoadEntireSettings()\\n   253→\\tif err != nil {\\n   254→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   255→\\t}\\n   256→\\n   257→\\tsettings.Enabled = true\\n   258→\\tif err := SaveEntireSettings(settings); err != nil {\\n   259→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   260→\\t}\\n   261→\\n   262→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   263→\\treturn nil\\n   264→}\\n   265→\\n   266→func runDisable(w io.Writer, useProjectSettings bool) error {\\n   267→\\tsettings, err := LoadEntireSettings()\\n   268→\\tif err != nil {\\n   269→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   270→\\t}\\n   271→\\n   272→\\tsettings.Enabled = false\\n   273→\\n   274→\\t// If --project flag is specified, always write to project settings\\n   275→\\tif useProjectSettings {\\n   276→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   277→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   278→\\t\\t}\\n   279→\\t} else {\\n   280→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   281→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   282→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   283→\\t\\t}\\n   284→\\t}\\n   285→\\n   286→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   287→\\treturn nil\\n   288→}\\n   289→\\n   290→// DisabledMessage is the message shown when Entire is disabled\\n   291→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   292→\\n   293→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   294→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   295→// On error reading settings, defaults to enabled (returns false).\\n   296→func checkDisabledGuard(w io.Writer) bool {\\n   297→\\tenabled, err := IsEnabled()\\n   298→\\tif err != nil {\\n   299→\\t\\t// Default to enabled on error\\n   300→\\t\\treturn false\\n   301→\\t}\\n   302→\\tif !enabled {\\n   303→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   304→\\t\\treturn true\\n   305→\\t}\\n   306→\\treturn false\\n   307→}\\n   308→\\n   309→// uninstallDeselectedAgentHooks removes hooks for agents that were previously\\n   310→// installed but are not in the selected list. This handles the case where a user\\n   311→// re-runs `entire enable` and deselects an agent.\\n   312→func uninstallDeselectedAgentHooks(w io.Writer, selectedAgents []agent.Agent) error {\\n   313→\\tinstalledNames := GetAgentsWithHooksInstalled()\\n   314→\\tif len(installedNames) == 0 {\\n   315→\\t\\treturn nil\\n   316→\\t}\\n   317→\\n   318→\\tselectedSet := make(map[agent.AgentName]struct{}, len(selectedAgents))\\n   319→\\tfor _, ag := range selectedAgents {\\n   320→\\t\\tselectedSet[ag.Name()] = struct{}{}\\n   321→\\t}\\n   322→\\n   323→\\tvar errs []error\\n   324→\\tfor _, name := range installedNames {\\n   325→\\t\\tif _, selected := selectedSet[name]; selected {\\n   326→\\t\\t\\tcontinue\\n   327→\\t\\t}\\n   328→\\t\\tag, err := agent.Get(name)\\n   329→\\t\\tif err != nil {\\n   330→\\t\\t\\tcontinue\\n   331→\\t\\t}\\n   332→\\t\\thookAgent, ok := ag.(agent.HookSupport)\\n   333→\\t\\tif !ok {\\n   334→\\t\\t\\tcontinue\\n   335→\\t\\t}\\n   336→\\t\\tif err := hookAgent.UninstallHooks(); err != nil {\\n   337→\\t\\t\\terrs = append(errs, fmt.Errorf(\\\"failed to uninstall %s hooks: %w\\\", ag.Type(), err))\\n   338→\\t\\t} else {\\n   339→\\t\\t\\tfmt.Fprintf(w, \\\"Removed %s hooks\\\\n\\\", ag.Type())\\n   340→\\t\\t}\\n   341→\\t}\\n   342→\\treturn errors.Join(errs...)\\n   343→}\\n   344→\\n   345→// setupAgentHooks sets up hooks for a given agent.\\n   346→// Returns the number of hooks installed (0 if already installed).\\n   347→func setupAgentHooks(ag agent.Agent, localDev, forceHooks bool) (int, error) {\\n   348→\\thookAgent, ok := ag.(agent.HookSupport)\\n   349→\\tif !ok {\\n   350→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   351→\\t}\\n   352→\\n   353→\\tcount, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   354→\\tif err != nil {\\n   355→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   356→\\t}\\n   357→\\n   358→\\treturn count, nil\\n   359→}\\n   360→\\n   361→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   362→// Returns the detected/selected agents and any error.\\n   363→//\\n   364→// On first run (no hooks installed):\\n   365→//   - Single detected agent: used automatically\\n   366→//   - Multiple/no detected agents: interactive multi-select prompt\\n   367→//\\n   368→// On re-run (hooks already installed):\\n   369→//   - Always shows the interactive multi-select\\n   370→//   - Pre-selects only agents that have hooks installed (respects prior deselection)\\n   371→//\\n   372→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   373→// It receives available agent names and returns the selected names.\\n   374→func detectOrSelectAgent(w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   375→\\t// Check for agents with hooks already installed (re-run detection)\\n   376→\\tinstalledAgentNames := GetAgentsWithHooksInstalled()\\n   377→\\thasInstalledHooks := len(installedAgentNames) > 0\\n   378→\\n   379→\\t// Try auto-detection\\n   380→\\tdetected := agent.DetectAll()\\n   381→\\n   382→\\t// First run: use existing auto-detect shortcuts\\n   383→\\tif !hasInstalledHooks {\\n   384→\\t\\tswitch {\\n   385→\\t\\tcase len(detected) == 1:\\n   386→\\t\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   387→\\t\\t\\treturn detected, nil\\n   388→\\n   389→\\t\\tcase len(detected) > 1:\\n   390→\\t\\t\\tagentTypes := make([]string, 0, len(detected))\\n   391→\\t\\t\\tfor _, ag := range detected {\\n   392→\\t\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   393→\\t\\t\\t}\\n   394→\\t\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   395→\\t\\t\\tfmt.Fprintln(w)\\n   396→\\t\\t}\\n   397→\\t}\\n   398→\\n   399→\\t// Check if we can prompt interactively\\n   400→\\tif !canPromptInteractively() {\\n   401→\\t\\tif hasInstalledHooks {\\n   402→\\t\\t\\t// Re-run without TTY — keep currently installed agents\\n   403→\\t\\t\\tagents := make([]agent.Agent, 0, len(installedAgentNames))\\n   404→\\t\\t\\tfor _, name := range installedAgentNames {\\n   405→\\t\\t\\t\\tag, err := agent.Get(name)\\n   406→\\t\\t\\t\\tif err != nil {\\n   407→\\t\\t\\t\\t\\tcontinue\\n   408→\\t\\t\\t\\t}\\n   409→\\t\\t\\t\\tagents = append(agents, ag)\\n   410→\\t\\t\\t}\\n   411→\\t\\t\\treturn agents, nil\\n   412→\\t\\t}\\n   413→\\t\\tif len(detected) > 0 {\\n   414→\\t\\t\\treturn detected, nil\\n   415→\\t\\t}\\n   416→\\t\\tdefaultAgent := agent.Default()\\n   417→\\t\\tif defaultAgent == nil {\\n   418→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   419→\\t\\t}\\n   420→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   421→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   422→\\t}\\n   423→\\n   424→\\tif !hasInstalledHooks && len(detected) == 0 {\\n   425→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., .claude, .gemini, or .opencode directory).\\\")\\n   426→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   427→\\t\\tfmt.Fprintln(w)\\n   428→\\t}\\n   429→\\n   430→\\t// Build pre-selection set.\\n   431→\\t// On re-run: only pre-select agents with hooks installed (respect prior deselection).\\n   432→\\t// On first run: pre-select all detected agents.\\n   433→\\tpreSelectedSet := make(map[agent.AgentName]struct{})\\n   434→\\tif hasInstalledHooks {\\n   435→\\t\\tfor _, name := range installedAgentNames {\\n   436→\\t\\t\\tpreSelectedSet[name] = struct{}{}\\n   437→\\t\\t}\\n   438→\\t} else {\\n   439→\\t\\tfor _, ag := range detected {\\n   440→\\t\\t\\tpreSelectedSet[ag.Name()] = struct{}{}\\n   441→\\t\\t}\\n   442→\\t}\\n   443→\\n   444→\\t// Build options from registered agents\\n   445→\\tagentNames := agent.List()\\n   446→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   447→\\tfor _, name := range agentNames {\\n   448→\\t\\tag, err := agent.Get(name)\\n   449→\\t\\tif err != nil {\\n   450→\\t\\t\\tcontinue\\n   451→\\t\\t}\\n   452→\\t\\t// Only show agents that support hooks\\n   453→\\t\\tif _, ok := ag.(agent.HookSupport); !ok {\\n   454→\\t\\t\\tcontinue\\n   455→\\t\\t}\\n   456→\\t\\topt := huh.NewOption(string(ag.Type()), string(name))\\n   457→\\t\\tif _, isPreSelected := preSelectedSet[name]; isPreSelected {\\n   458→\\t\\t\\topt = opt.Selected(true)\\n   459→\\t\\t}\\n   460→\\t\\toptions = append(options, opt)\\n   461→\\t}\\n   462→\\n   463→\\tif len(options) == 0 {\\n   464→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   465→\\t}\\n   466→\\n   467→\\t// Collect available agent names for the selector\\n   468→\\tavailableNames := make([]string, 0, len(options))\\n   469→\\tfor _, opt := range options {\\n   470→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   471→\\t}\\n   472→\\n   473→\\tvar selectedAgentNames []string\\n   474→\\tif selectFn != nil {\\n   475→\\t\\tvar err error\\n   476→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   477→\\t\\tif err != nil {\\n   478→\\t\\t\\treturn nil, err\\n   479→\\t\\t}\\n   480→\\t\\tif len(selectedAgentNames) == 0 {\\n   481→\\t\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   482→\\t\\t}\\n   483→\\t} else {\\n   484→\\t\\tform := NewAccessibleForm(\\n   485→\\t\\t\\thuh.NewGroup(\\n   486→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   487→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   488→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   489→\\t\\t\\t\\t\\tOptions(options...).\\n   490→\\t\\t\\t\\t\\tValidate(func(selected []string) error {\\n   491→\\t\\t\\t\\t\\t\\tif len(selected) == 0 {\\n   492→\\t\\t\\t\\t\\t\\t\\treturn errors.New(\\\"please select at least one agent\\\")\\n   493→\\t\\t\\t\\t\\t\\t}\\n   494→\\t\\t\\t\\t\\t\\treturn nil\\n   495→\\t\\t\\t\\t\\t}).\\n   496→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   497→\\t\\t\\t),\\n   498→\\t\\t)\\n   499→\\t\\tif err := form.Run(); err != nil {\\n   500→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   501→\\t\\t}\\n   502→\\t}\\n   503→\\n   504→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   505→\\tfor _, name := range selectedAgentNames {\\n   506→\\t\\tselectedAgent, err := agent.Get(agent.AgentName(name))\\n   507→\\t\\tif err != nil {\\n   508→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   509→\\t\\t}\\n   510→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   511→\\t}\\n   512→\\n   513→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   514→\\tfor _, ag := range selectedAgents {\\n   515→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   516→\\t}\\n   517→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   518→\\treturn selectedAgents, nil\\n   519→}\\n   520→\\n   521→// canPromptInteractively checks if we can show interactive prompts.\\n   522→// Returns false when running in CI, tests, or other non-interactive environments.\\n   523→func canPromptInteractively() bool {\\n   524→\\t// Check for test environment\\n   525→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   526→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   527→\\t}\\n   528→\\n   529→\\t// Check if /dev/tty is available\\n   530→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   531→\\tif err != nil {\\n   532→\\t\\treturn false\\n   533→\\t}\\n   534→\\t_ = tty.Close()\\n   535→\\treturn true\\n   536→}\\n   537→\\n   538→// printAgentError writes an error message followed by available agents and usage.\\n   539→func printAgentError(w io.Writer, message string) {\\n   540→\\tagents := agent.List()\\n   541→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   542→\\tfmt.Fprintln(w)\\n   543→\\tfor _, a := range agents {\\n   544→\\t\\tsuffix := \\\"\\\"\\n   545→\\t\\tif a == agent.DefaultAgentName {\\n   546→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   547→\\t\\t}\\n   548→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   549→\\t}\\n   550→\\tfmt.Fprintln(w)\\n   551→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   552→}\\n   553→\\n   554→// printMissingAgentError writes a helpful error listing available agents.\\n   555→func printMissingAgentError(w io.Writer) {\\n   556→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   557→}\\n   558→\\n   559→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   560→func printWrongAgentError(w io.Writer, name string) {\\n   561→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   562→}\\n   563→\\n   564→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   565→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   566→func setupAgentHooksNonInteractive(w io.Writer, ag agent.Agent, localDev, forceHooks, skipPushSessions, telemetry bool) error {\\n   567→\\tagentName := ag.Name()\\n   568→\\t// Check if agent supports hooks\\n   569→\\thookAgent, ok := ag.(agent.HookSupport)\\n   570→\\tif !ok {\\n   571→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   572→\\t}\\n   573→\\n   574→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   575→\\n   576→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   577→\\tinstalledHooks, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   578→\\tif err != nil {\\n   579→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   580→\\t}\\n   581→\\n   582→\\t// Setup .entire directory\\n   583→\\tif _, err := setupEntireDirectory(); err != nil {\\n   584→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   585→\\t}\\n   586→\\n   587→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   588→\\tsettings, err := LoadEntireSettings()\\n   589→\\tif err != nil {\\n   590→\\t\\t// If we can't load, start with defaults\\n   591→\\t\\tsettings = &EntireSettings{}\\n   592→\\t}\\n   593→\\tsettings.Enabled = true\\n   594→\\tif localDev {\\n   595→\\t\\tsettings.LocalDev = localDev\\n   596→\\t}\\n   597→\\n   598→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   599→\\tif skipPushSessions {\\n   600→\\t\\tif settings.StrategyOptions == nil {\\n   601→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   602→\\t\\t}\\n   603→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   604→\\t}\\n   605→\\n   606→\\t// Handle telemetry for non-interactive mode\\n   607→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   608→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   609→\\t\\tf := false\\n   610→\\t\\tsettings.Telemetry = &f\\n   611→\\t}\\n   612→\\n   613→\\tif err := SaveEntireSettings(settings); err != nil {\\n   614→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   615→\\t}\\n   616→\\n   617→\\tif _, err := strategy.InstallGitHook(true, localDev); err != nil {\\n   618→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   619→\\t}\\n   620→\\tstrategy.CheckAndWarnHookManagers(w, localDev)\\n   621→\\n   622→\\tif installedHooks == 0 {\\n   623→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   624→\\t\\tif ag.IsPreview() {\\n   625→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   626→\\t\\t}\\n   627→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   628→\\t} else {\\n   629→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   630→\\t\\tif ag.IsPreview() {\\n   631→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   632→\\t\\t}\\n   633→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   634→\\t}\\n   635→\\n   636→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   637→\\n   638→\\tif err := strategy.EnsureSetup(); err != nil {\\n   639→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   640→\\t}\\n   641→\\n   642→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   643→\\n   644→\\treturn nil\\n   645→}\\n   646→\\n   647→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   648→func validateSetupFlags(useLocal, useProject bool) error {\\n   649→\\tif useLocal && useProject {\\n   650→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   651→\\t}\\n   652→\\treturn nil\\n   653→}\\n   654→\\n   655→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   656→// - Whether settings.json already exists\\n   657→// - The --local and --project flags\\n   658→// Returns (useLocal, showNotification).\\n   659→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   660→\\t// Explicit --local flag always uses local settings\\n   661→\\tif useLocal {\\n   662→\\t\\treturn true, false\\n   663→\\t}\\n   664→\\n   665→\\t// Explicit --project flag always uses project settings\\n   666→\\tif useProject {\\n   667→\\t\\treturn false, false\\n   668→\\t}\\n   669→\\n   670→\\t// No flags specified - check if settings file exists\\n   671→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   672→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   673→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   674→\\t\\treturn true, true\\n   675→\\t}\\n   676→\\n   677→\\t// Settings file doesn't exist - create it\\n   678→\\treturn false, false\\n   679→}\\n   680→\\n   681→// setupEntireDirectory creates the .entire directory and gitignore.\\n   682→// Returns true if the directory was created, false if it already existed.\\n   683→func setupEntireDirectory() (bool, error) { //nolint:unparam // already present in codebase\\n   684→\\t// Get absolute path for the .entire directory\\n   685→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   686→\\tif err != nil {\\n   687→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   688→\\t}\\n   689→\\n   690→\\t// Check if directory already exists\\n   691→\\tcreated := false\\n   692→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   693→\\t\\tcreated = true\\n   694→\\t}\\n   695→\\n   696→\\t// Create .entire directory\\n   697→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   698→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   699→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   700→\\t}\\n   701→\\n   702→\\t// Create/update .gitignore with all required entries\\n   703→\\tif err := strategy.EnsureEntireGitignore(); err != nil {\\n   704→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   705→\\t}\\n   706→\\n   707→\\treturn created, nil\\n   708→}\\n   709→\\n   710→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   711→func setupGitHook() error {\\n   712→\\ts, err := settings.Load()\\n   713→\\tlocalDev := err == nil && s.LocalDev\\n   714→\\tif _, err := strategy.InstallGitHook(false, localDev); err != nil {\\n   715→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   716→\\t}\\n   717→\\tstrategy.CheckAndWarnHookManagers(os.Stderr, localDev)\\n   718→\\treturn nil\\n   719→}\\n   720→\\n   721→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   722→func newSetupGitHookCmd() *cobra.Command {\\n   723→\\tcmd := &cobra.Command{\\n   724→\\t\\tUse:    \\\"git-hook\\\",\\n   725→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   726→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   727→\\t\\tRunE: func(_ *cobra.Command, _ []string) error {\\n   728→\\t\\t\\treturn setupGitHook()\\n   729→\\t\\t},\\n   730→\\t}\\n   731→\\n   732→\\treturn cmd\\n   733→}\\n   734→\\n   735→func newCurlBashPostInstallCmd() *cobra.Command {\\n   736→\\treturn &cobra.Command{\\n   737→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   738→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   739→\\t\\tHidden: true,\\n   740→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   741→\\t\\t\\tw := cmd.OutOrStdout()\\n   742→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   743→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   744→\\t\\t\\t}\\n   745→\\t\\t\\treturn nil\\n   746→\\t\\t},\\n   747→\\t}\\n   748→}\\n   749→\\n   750→// shellCompletionComment is the comment preceding the completion line\\n   751→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   752→\\n   753→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   754→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   755→\\n   756→// shellCompletionTarget returns the rc file path and completion lines for the\\n   757→// user's current shell.\\n   758→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   759→\\thome, err := os.UserHomeDir()\\n   760→\\tif err != nil {\\n   761→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   762→\\t}\\n   763→\\n   764→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   765→\\tswitch {\\n   766→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   767→\\t\\treturn \\\"Zsh\\\",\\n   768→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   769→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   770→\\t\\t\\tnil\\n   771→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   772→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   773→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   774→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   775→\\t\\t}\\n   776→\\t\\treturn \\\"Bash\\\",\\n   777→\\t\\t\\tbashRC,\\n   778→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   779→\\t\\t\\tnil\\n   780→\\tcase strings.Contains(shell, \\\"fish\\\"):\\n   781→\\t\\treturn \\\"Fish\\\",\\n   782→\\t\\t\\tfilepath.Join(home, \\\".config\\\", \\\"fish\\\", \\\"config.fish\\\"),\\n   783→\\t\\t\\t\\\"entire completion fish | source\\\",\\n   784→\\t\\t\\tnil\\n   785→\\tdefault:\\n   786→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   787→\\t}\\n   788→}\\n   789→\\n   790→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   791→// Only prompts if completion is not already configured.\\n   792→func promptShellCompletion(w io.Writer) error {\\n   793→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   794→\\tif err != nil {\\n   795→\\t\\tif errors.Is(err, errUnsupportedShell) {\\n   796→\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion not available for your shell. Supported: zsh, bash, fish.\\\\n\\\")\\n   797→\\t\\t\\treturn nil\\n   798→\\t\\t}\\n   799→\\t\\treturn fmt.Errorf(\\\"shell completion: %w\\\", err)\\n   800→\\t}\\n   801→\\n   802→\\tif isCompletionConfigured(rcFile) {\\n   803→\\t\\tfmt.Fprintf(w, \\\"✓ Shell completion already configured in %s\\\\n\\\", rcFile)\\n   804→\\t\\treturn nil\\n   805→\\t}\\