ich can cause globally ignored files to appear as untracked.\\n  1051→// See: https://github.com/entireio/cli/pull/129\\n  1052→//\\n  1053→// changedFilesResult contains both changed and deleted files from git status.\\n  1054→type changedFilesResult struct {\\n  1055→\\tChanged []string // Files to include (modified, added, untracked, renamed, etc.)\\n  1056→\\tDeleted []string // Files that were deleted (need to be excluded from checkpoint tree)\\n  1057→}\\n  1058→\\n  1059→// collectChangedFiles returns all changed files from git status for the first checkpoint.\\n  1060→//\\n  1061→// For the first checkpoint, we need to capture:\\n  1062→// - Modified tracked files (user's uncommitted changes)\\n  1063→// - Untracked non-ignored files (new files not yet added to git)\\n  1064→// - Renamed/copied files (both source removal and destination)\\n  1065→// - Deleted files (to exclude from checkpoint tree)\\n  1066→//\\n  1067→// The base tree from HEAD already contains all unchanged tracked files.\\n  1068→//\\n  1069→// Uses `git status --porcelain -z` for reliable parsing of filenames with special characters.\\n  1070→func collectChangedFiles(ctx context.Context, repo *git.Repository) (changedFilesResult, error) {\\n  1071→\\t// Get repo root directory for running git command\\n  1072→\\twt, err := repo.Worktree()\\n  1073→\\tif err != nil {\\n  1074→\\t\\treturn changedFilesResult{}, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n  1075→\\t}\\n  1076→\\trepoRoot := wt.Filesystem.Root()\\n  1077→\\n  1078→\\t// Use -z for NUL-separated output (handles quoted filenames with spaces/special chars)\\n  1079→\\t// Use -uall to list individual untracked files instead of collapsed directories.\\n  1080→\\t// Note: CLAUDE.md warns against -uall for user-facing display, but we need the full list\\n  1081→\\t// for checkpointing.\\n  1082→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"status\\\", \\\"--porcelain\\\", \\\"-z\\\", \\\"-uall\\\")\\n  1083→\\tcmd.D