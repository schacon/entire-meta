   171→//\\n   172→// This is used in PrepareCommitMsg for carry-forward scenarios.\\n   173→func stagedFilesOverlapWithContent(repo *git.Repository, shadowTree *object.Tree, stagedFiles, filesTouched []string) bool {\\n   174→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   175→\\n   176→\\t// Build set of filesTouched for quick lookup\\n   177→\\ttouchedSet := make(map[string]bool)\\n   178→\\tfor _, f := range filesTouched {\\n   179→\\t\\ttouchedSet[f] = true\\n   180→\\t}\\n   181→\\n   182→\\t// Get HEAD tree to determine if files are being modified or newly created\\n   183→\\thead, err := repo.Head()\\n   184→\\tif err != nil {\\n   185→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get HEAD, falling back to filename check\\\",\\n   186→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   187→\\t\\t)\\n   188→\\t\\treturn hasOverlappingFiles(stagedFiles, filesTouched)\\n   189→\\t}\\n   190→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   191→\\tif err != nil {\\n   192→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get HEAD commit, falling back to filename check\\\",\\n   193→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   194→\\t\\t)\\n   195→\\t\\treturn hasOverlappingFiles(stagedFiles, filesTouched)\\n   196→\\t}\\n   197→\\theadTree, err := headCommit.Tree()\\n   198→\\tif err != nil {\\n   199→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get HEAD tree, falling back to filename check\\\",\\n   200→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   201→\\t\\t)\\n   202→\\t\\treturn hasOverlappingFiles(stagedFiles, filesTouched)\\n   203→\\t}\\n   204→\\n   205→\\t// Get the git index to access staged file hashes\\n   206→\\tidx, err := repo.Storer.Index()\\n   207→\\tif err != nil {\\n   208→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get index, falling back to filename check\\\",\\n   209→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   210→\\t\\t)\\n   211→\\t\\treturn hasOverlappingFiles(stagedFiles, filesTouched)\\n   212→\\t}\\n   213→\\n   214→\\t// Build a map of index entries for O(1) lookup (avoid O(n*m) nested loop)\\n   215→\\tindexEntries := make(map[string]plumbing.Hash, len(idx.Entries))\\n   216→\\tfor _, entry := range idx.Entries {\\n   217→\\t\\tindexEntries[entry.Name] = entry.Hash\\n   218→\\t}\\n   219→\\n   220→\\t// Check each staged file\\n   221→\\tfor _, stagedPath := range stagedFiles {\\n   222→\\t\\tif !touchedSet[stagedPath] {\\n   223→\\t\\t\\tcontinue // Not in filesTouched, skip\\n   224→\\t\\t}\\n   225→\\n   226→\\t\\t// Check if this is a modified file (exists in HEAD) or new file\\n   227→\\t\\t_, headErr := headTree.File(stagedPath)\\n   228→\\t\\tisModified := headErr == nil\\n   229→\\n   230→\\t\\t// Modified files always count as overlap (user edited session's work)\\n   231→\\t\\t// This includes deletions - if file exists in HEAD and is being deleted,\\n   232→\\t\\t// that's the agent's work being committed.\\n   233→\\t\\tif isModified {\\n   234→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: modified file counts as overlap\\\",\\n   235→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   236→\\t\\t\\t)\\n   237→\\t\\t\\treturn true\\n   238→\\t\\t}\\n   239→\\n   240→\\t\\t// For new files, check content against shadow branch\\n   241→\\t\\tstagedHash, found := indexEntries[stagedPath]\\n   242→\\t\\tif !found {\\n   243→\\t\\t\\tcontinue // Not in index (shouldn't happen but be safe)\\n   244→\\t\\t}\\n   245→\\n   246→\\t\\t// Get file from shadow branch tree\\n   247→\\t\\tshadowFile, err := shadowTree.File(stagedPath)\\n   248→\\t\\tif err != nil {\\n   249→\\t\\t\\t// File not in shadow branch - can't verify content overlap.\\n   250→\\t\\t\\t// Don't assume overlap just because it's in filesTouched.\\n   251→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: 