   654→\\tshardB7, _ := storeTree(repo, []object.TreeEntry{\\n   655→\\t\\t{Name: \\\"ckpt3\\\", Mode: filemode.Dir, Hash: ckpt3},\\n   656→\\t})\\n   657→\\trootTree, _ := storeTree(repo, []object.TreeEntry{\\n   658→\\t\\t{Name: \\\"a3\\\", Mode: filemode.Dir, Hash: shardA3},\\n   659→\\t\\t{Name: \\\"b7\\\", Mode: filemode.Dir, Hash: shardB7},\\n   660→\\t})\\n   661→\\n   662→\\t// Now add a new checkpoint at a3/newckpt/ using tree surgery\\n   663→\\tnewBlob := storeBlob(t, repo, \\\"new-checkpoint\\\")\\n   664→\\tsurgeryResult, err := UpdateSubtree(repo, rootTree, []string{\\\"a3\\\", \\\"newckpt\\\"}, []object.TreeEntry{\\n   665→\\t\\t{Name: \\\"meta.json\\\", Mode: filemode.Regular, Hash: newBlob},\\n   666→\\t}, UpdateSubtreeOptions{})\\n   667→\\tif err != nil {\\n   668→\\t\\tt.Fatalf(\\\"UpdateSubtree() error = %v\\\", err)\\n   669→\\t}\\n   670→\\n   671→\\t// Do the same with FlattenTree + BuildTreeFromEntries\\n   672→\\ttree, err := repo.TreeObject(rootTree)\\n   673→\\tif err != nil {\\n   674→\\t\\tt.Fatalf(\\\"failed to read root tree: %v\\\", err)\\n   675→\\t}\\n   676→\\tflatEntries := make(map[string]object.TreeEntry)\\n   677→\\tif err := FlattenTree(repo, tree, \\\"\\\", flatEntries); err != nil {\\n   678→\\t\\tt.Fatalf(\\\"FlattenTree() error = %v\\\", err)\\n   679→\\t}\\n   680→\\tflatEntries[\\\"a3/newckpt/meta.json\\\"] = object.TreeEntry{\\n   681→\\t\\tName: \\\"meta.json\\\",\\n   682→\\t\\tMode: filemode.Regular,\\n   683→\\t\\tHash: newBlob,\\n   684→\\t}\\n   685→\\tflatResult, err := BuildTreeFromEntries(repo, flatEntries)\\n   686→\\tif err != nil {\\n   687→\\t\\tt.Fatalf(\\\"BuildTreeFromEntries() error = %v\\\", err)\\n   688→\\t}\\n   689→\\n   690→\\t// Both approaches should produce the exact same tree hash\\n   691→\\tif surgeryResult != flatResult {\\n   692→\\t\\tt.Errorf(\\\"tree surgery result (%s) != flatten+rebuild result (%s)\\\", surgeryResult, flatResult)\\n   693→\\n   694→\\t\\t// Debug: show both trees\\n 