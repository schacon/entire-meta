c4d5e6f7\\\", \\\"0\\\"]).\\n// newEntries are the files/dirs to place at the leaf directory.\\n//\\n// Returns the new root tree hash.\\nfunc UpdateSubtree(\\n\\trepo *git.Repository,\\n\\trootTreeHash plumbing.Hash,\\n\\tpathSegments []string,\\n\\tnewEntries []object.TreeEntry,\\n\\topts UpdateSubtreeOptions,\\n) (plumbing.Hash, error) {\\n\\tif len(pathSegments) == 0 {\\n\\t\\treturn buildLeafTree(repo, rootTreeHash, newEntries, opts)\\n\\t}\\n\\n\\t// Read the current tree at this level\\n\\tvar currentEntries []object.TreeEntry\\n\\tif rootTreeHash != plumbing.ZeroHash {\\n\\t\\ttree, err := repo.TreeObject(rootTreeHash)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to read tree: %w\\\", err)\\n\\t\\t}\\n\\t\\tcurrentEntries = tree.Entries\\n\\t}\\n\\n\\ttargetDir := pathSegments[0]\\n\\tremainingPath := pathSegments[1:]\\n\\n\\t// Find the existing subtree entry for targetDir\\n\\tvar existingSubtreeHash plumbing.Hash\\n\\tfound := false\\n\\tfor _, entry := range currentEntries {\\n\\t\\tif entry.Name == targetDir && entry.Mode == filemode.Dir {\\n\\t\\t\\texistingSubtreeHash = entry.Hash\\n\\t\\t\\tfound = true\\n\\t\\t\\tbreak\\n\\t\\t}\\n\\t}\\n\\n\\t// Recurse into the subtree\\n\\tnewSubtreeHash, err := UpdateSubtree(repo, existingSubtreeHash, remainingPath, newEntries, opts)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, err\\n\\t}\\n\\n\\t// Build a new tree at this level with the updated subtree entry\\n\\tupdatedEntries := make([]object.TreeEntry, 0, len(currentEntries)+1)\\n\\treplaced := false\\n\\tfor _, entry := range currentEntries {\\n\\t\\tif entry.Name == targetDir {\\n\\t\\t\\tupdatedEntries = append(updatedEntries, object.TreeEntry{\\n\\t\\t\\t\\tName: targetDir,\\n\\t\\t\\t\\tMode: filemode.Dir,\\n\\t\\t\\t\\tHash: newSubtreeHash,\\n\\t\\t\\t})\\n\\t\\t\\treplaced = true\\n\\t\\t} else {\\n\\t\\t\\tupdatedEntries = append(updatedEntries, entry)\\n\\t\\t}\\n\\t}\\n\\tif !found && !replaced {\\n\\t\\tupdatedEntries = append(updatedEntries, object.TreeEntry{\\n\\t\\t\\tName: targetDir,\\n\\t\\t\\tMode: filemode.Dir,\\n\\t\\t\\tHash: newSubtreeHash,\\n\\t\\t})\\n\\t}\\n\\n\\tsortTreeEntries(updatedEntries)\\n\\treturn storeTree(repo, updatedEntries)\\n}\\n\\n// buildLeafTree builds the tree at the leaf of the path.\\nfunc buildLeafTree(repo *git.Repository, existingTreeHash plumbing.Hash, newEntries []object.TreeEntry, opts UpdateSubtreeOptions) (plumbing.Hash, error) {\\n\\tif opts.MergeMode == ReplaceAll || existingTreeHash == plumbing.ZeroHash {\\n\\t\\tsortTreeEntries(newEntries)\\n\\t\\treturn storeTree(repo, newEntries)\\n\\t}\\n\\n\\t// MergeKeepExisting: read existing tree, merge\\n\\texistingTree, err := repo.TreeObject(existingTreeHash)\\n\\tif err != nil {\\n\\t\\tsortTreeEntries(newEntries)\\n\\t\\treturn storeTree(repo, newEntries)\\n\\t}\\n\\n\\t// Build lookup of new entries by name\\n\\tnewByName := make(map[string]object.TreeEntry, len(newEntries))\\n\\tfor _, e := range newEntries {\\n\\t\\tnewByName[e.Name] = e\\n\\t}\\n\\n\\t// Build delete set\\n\\tdeleteSet := make(map[string]bool, len(opts.DeleteNames))\\n\\tfor _, name := range opts.DeleteNames {\\n\\t\\tdeleteSet[name] = true\\n\\t}\\n\\n\\t// Merge: keep existing unless overwritten or deleted\\n\\tmerged := make([]object.TreeEntry, 0, len(existingTree.Entries)+len(newEntries))\\n\\tfor _, existing := range existingTree.Entries {\\n\\t\\tif deleteSet[existing.Name] {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tif replacement, ok := newByName[existing.Name]; ok {\\n\\t\\t\\tmerged = append(merged, replacement)\\n\\t\\t\\tdelete(newByName, existing.Name)\\n\\t\\t} else {\\n\\t\\t\\tmerged = append(merged, existing)\\n\\t\\t}\\n\\t}\\n\\t// Add remaining new entries\\n\\tfor _, e := range newEntries {\\n\\t\\tif _, stillNew := newByName[e.Name]; stillNew {\\n\\t\\t\\tmerged = append(merged, e)\\n\\t\\t}\\n\\t}\\n\\n\\tsortTreeEntries(merged)\\n\\treturn storeTree(repo, merged)\\n}\\n\\n// storeTree creates a git tree object from entries and stores it in the repo.\\nfunc storeTree(repo *git.Repository, entries []object.TreeEntry) (plumbing.Hash, error) {\\n\\ttree := &object.Tree{Entries: entries}\\n\\tobj := repo.Storer.NewEncodedObject()\\n\\tif err := tree.Encode(obj); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode tree: %w\\\", err)\\n\\t}\\n\\thash, err := repo.Storer.SetEncodedObject(obj)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store tree: %w\\\", err)\\n\\t}\\n\\treturn hash, nil\\n}\\n\\n// ApplyTreeChanges applies multiple file-level changes to a tree efficiently.\\n// Changes are grouped by directory and applied in a single recursive pass.\\n// Unchanged subdirectories retain their hashes.\\nfunc ApplyTreeChanges(\\n\\trepo *git.Repository,\\n\\trootTreeHash plumbing.Hash,\\n\\tchanges []TreeChange,\\n) (plumbing.Hash, error) {\\n\\tif len(changes) == 0 {\\n\\t\\treturn rootTreeHash, nil\\n\\t}\\n\\n\\t// Read the current root tree\\n\\tvar currentEntries []object.TreeEntry\\n\\tif rootTreeHash != plumbing.ZeroHash {\\n\\t\\ttree, err := repo.TreeObject(rootTreeHash)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to read tree: %w\\\", err)\\n\\t\\t}\\n\\t\\tcurrentEntries = make([]object.TreeEntry, len(tree.Entries))\\n\\t\\tcopy(currentEntries, tree.Entries)\\n\\t}\\n\\n\\t// Group changes by first path segment\\n\\ttype dirChanges struct {\\n\\t\\tsubChanges []TreeChange // Changes within this subdirectory (paths stripped of first segment)\\n\\t\\tfileChange *TreeChange  // Direct file change at this level\\n\\t}\\n\\tgrouped := make(map[string]*dirChanges)\\n\\n\\tfor i := range changes {\\n\\t\\tc := changes[i]\\n\\t\\tdir, rest := splitFirstSegment(c.Path)\\n\\t\\tif grouped[dir] == nil {\\n\\t\\t\\tgrouped[dir] = &dirChanges{}\\n\\t\\t}\\n\\t\\tif rest == \\\"\\\" {\\n\\t\\t\\t// File at this level\\n\\t\\t\\tcc := c\\n\\t\\t\\tgrouped[dir].fileChange = &cc\\n\\t\\t} else {\\n\\t\\t\\t// In a subdirectory\\n\\t\\t\\tgrouped[dir].subChanges = append(grouped[dir].subChanges, TreeChange{\\n\\t\\t\\t\\tPath:  rest,\\n\\t\\t\\t\\tEntry: c.Entry,\\n\\t\\t\\t})\\n\\t\\t}\\n\\t}\\n\\n\\t// Build entry map for quick lookup\\n\\tentryMap := make(map[string]object.TreeEntry, len(currentEntries))\\n\\tentryOrder := make([]string, 0, len(currentEntries))\\n\\tfor _, e := range currentEntries {\\n\\t\\tentryMap[e.Name] = e\\n\\t\\tentryOrder = append(entryOrder, e.Name)\\n\\t}\\n\\n\\t// Process each group\\n\\tfor name, dc := range grouped {\\n\\t\\tif dc.fileChange != nil {\\n\\t\\t\\tif dc.fileChange.Entry == nil {\\n\\t\\t\\t\\t// Delete\\n\\t\\t\\t\\tdelete(entryMap, name)\\n\\t\\t\\t} else {\\n\\t\\t\\t\\t// Add/update file\\n\\t\\t\\t\\tif _, exists := entryMap[name]; !exists {\\n\\t\\t\\t\\t\\tentryOrder = append(entryOrder, name)\\n\\t\\t\\t\\t}\\n\\t\\t\\t\\tentryMap[name] = object.TreeEntry{\\n\\t\\t\\t\\t\\tName: name,\\n\\t\\t\\t\\t\\tMode: dc.fileChange.Entry.Mode,\\n\\t\\t\\t\\t\\tHash: dc.fileChange.Entry.Hash,\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\t\\tif len(dc.subChanges) > 0 {\\n\\t\\t\\t// Recurse into subdirectory\\n\\t\\t\\texistingHash := plumbing.ZeroHash\\n\\t\\t\\tif existing, ok := entryMap[name]; ok && existing.Mode == filemode.Dir {\\n\\t\\t\\t\\texistingHash = existing.Hash\\n\\t\\t\\t}\\n\\t\\t\\tnewSubHash, err := ApplyTreeChanges(repo, existingHash, dc.subChanges)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to apply changes in %s: %w\\\", name, err)\\n\\t\\t\\t}\\n\\t\\t\\tif _, exists := entryMap[name]; !exists {\\n\\t\\t\\t\\tentryOrder = append(entryOrder, name)\\n\\t\\t\\t}\\n\\t\\t\\tentryMap[name] = object.TreeEntry{\\n\\t\\t\\t\\tName: name,\\n\\t\\t\\t\\tMode: filemode.Dir,\\n\\t\\t\\t\\tHash: newSubHash,\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Convert back to slice\\n\\tresult := make([]object.TreeEntry, 0, len(entryMap))\\n\\tfor _, e := range entryMap {\\n\\t\\tresult = append(result, e)\\n\\t}\\n\\tsortTreeEntries(result)\\n\\treturn storeTree(repo, result)\\n}\\n\\n// splitFirstSegment splits a path into its first segment and the rest.\\n// e.g., \\\"a/b/c\\\" -> (\\\"a\\\", \\\"b/c\\\"), \\\"file.txt\\\" -> (\\\"file.txt\\\", \\\"\\\")\\nfunc splitFirstSegment(path string) (first, rest string) {\\n\\t// Use filepath-aware splitting to handle both / and platform separators\\n\\tparts := strings.SplitN(filepath.ToSlash(path), \\\"/\\\", 2)\\n\\tif len(parts) == 1 {\\n\\t\\treturn parts[0], \\\"\\\"\\n\\t}\\n\\treturn parts[0], parts[1]\\n}\\n\\n// getSessionsBranchRef returns the sessions branch reference hash and root tree hash\\n// without flattening the tree. This is the optimized replacement for getSessionsBranchEntries.\\nfunc (s *GitStore) getSessionsBranchRef() (plumbing.Hash, plumbing.Hash, error) {\\n\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n\\tref, err := s.repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get sessions branch reference: %w\\\", err)\\n\\t}\\n\\n\\tparentCommit, err := s.repo.CommitObject(ref.Hash())\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\treturn ref.Hash(), parentCommit.TreeHash, nil\\n}\\n\\n// readCheckpointTree reads the tree at a checkpoint's shard path (e.g., \\\"a3/b2c4d5e6f7\\\").\\n// Returns nil if the path doesn't exist (new checkpoint).\\nfunc (s *GitStore) readCheckpointTree(rootTreeHash plumbing.Hash, checkpointPath string) (*object.Tree, error) {\\n\\tif rootTreeHash == plumbing.ZeroHash {\\n\\t\\treturn nil, nil //nolint:nilnil // Empty tree means new checkpoint\\n\\t}\\n\\n\\trootTree, err := s.repo.TreeObject(rootTreeHash)\\n\\tif err != nil {\\n\\t\\treturn nil, nil //nolint:nilnil,nilerr // Can't read root tree, treat as new\\n\\t}\\n\\n\\ttree, err := rootTree.Tree(checkpointPath)\\n\\tif err != nil {\\n\\t\\treturn nil, nil //nolint:nilnil,nilerr // Path doesn't exist, treat as new\\n\\t}\\n\\treturn tree, nil\\n}\\n\\n// findSessionIndexFromTree finds the session index by reading session metadata\\n// directly from the checkpoint tree. Returns the index to use for this session.\\nfunc (s *GitStore) findSessionIndexFromTree(checkpointTree *object.Tree, existingSummary *CheckpointSummary, sessionID string) int {\\n\\tif existingSummary == nil || checkpointTree == nil {\\n\\t\\treturn 0\\n\\t}\\n\\n\\tfor i := range len(existingSummary.Sessions) {\\n\\t\\tsessionDir := fmt.Sprintf(\\\"%d\\\", i)\\n\\t\\tsessionTree, err := checkpointTree.Tree(sessionDir)\\n\\t\\tif err != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tmetaFile, err := sessionTree.File(paths.MetadataFileName)\\n\\t\\tif err != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tcontent, err := metaFile.Contents()\\n\\t\\tif err != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tvar meta CommittedMetadata\\n\\t\\tif jsonErr := json.Unmarshal([]byte(content), &meta); jsonErr == nil {\\n\\t\\t\\tif meta.SessionID == sessionID {\\n\\t\\t\\t\\treturn i\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\treturn len(existingSummary.Sessions)\\n}\\n\\n// reaggregateFromTree reads all session metadata from the checkpoint tree and\\n// reaggregates CheckpointsCount, FilesTouched, and TokenUsage.\\nfunc (s *GitStore) reaggregateFromTree(checkpointTree *object.Tree, sessionCount int) (int, []string, *agent.TokenUsage, error) {\\n\\tvar totalCount int\\n\\tvar allFiles []string\\n\\tvar totalTokens *agent.TokenUsage\\n\\n\\tfor i := range sessionCount {\\n\\t\\tsessionDir := fmt.Sprintf(\\\"%d\\\", i)\\n\\t\\tsessionTree, err := checkpointTree.Tree(sessionDir)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"session %d tree not found\\\", i)\\n\\t\\t}\\n\\t\\tmetaFile, err := sessionTree.File(paths.MetadataFileName)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"session %d metadata not found\\\", i)\\n\\t\\t}\\n\\t\\tcontent, err := metaFile.Contents()\\n\\t\\tif err != nil {\\n\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"failed to read session %d metadata: %w\\\", i, err)\\n\\t\\t}\\n\\t\\tvar meta CommittedMetadata\\n\\t\\tif jsonErr := json.Unmarshal([]byte(content), &meta); jsonErr != nil {\\n\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"failed to parse session %d metadata: %w\\\", i, jsonErr)\\n\\t\\t}\\n\\t\\ttotalCount += meta.CheckpointsCount\\n\\t\\tallFiles = mergeFilesTouched(allFiles, meta.FilesTouched)\\n\\t\\ttotalTokens = aggregateTokenUsage(totalTokens, meta.TokenUsage)\\n\\t}\\n\\n\\treturn totalCount, allFiles, totalTokens, nil\\n}\\n\\n// readSummaryFromTree reads the CheckpointSummary from a checkpoint tree.\\nfunc (s *GitStore) readSummaryFromTree(checkpointTree *object.Tree) (*CheckpointSummary, error) {\\n\\tif checkpointTree == nil {\\n\\t\\treturn nil, nil //nolint:nilnil // No tree means no summary\\n\\t}\\n\\tmetaFile, err := checkpointTree.File(paths.MetadataFileName)\\n\\tif err != nil {\\n\\t\\treturn nil, nil //nolint:nilnil,nilerr // No metadata file\\n\\t}\\n\\tcontent, err := metaFile.Contents()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata.json: %w\\\", err)\\n\\t}\\n\\tvar summary CheckpointSummary\\n\\tif jsonErr := json.Unmarshal([]byte(content), &summary); jsonErr != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata.json: %w\\\", jsonErr)\\n\\t}\\n\\treturn &summary, nil\\n}\\n\\n// buildSessionSubtreeEntries builds the tree entries for a session subdirectory.\\n// Returns entries that should be placed inside the session's numbered directory.\\nfunc (s *GitStore) buildSessionSubtreeEntries(opts WriteCommittedOptions) ([]object.TreeEntry, SessionFilePaths, error) {\\n\\tvar entries []object.TreeEntry\\n\\tfilePaths := SessionFilePaths{}\\n\\n\\t// Write transcript\\n\\ttranscriptEntries, err := s.buildTranscriptEntries(opts)\\n\\tif err != nil {\\n\\t\\treturn nil, filePaths, err\\n\\t}\\n\\tentries = append(entries, transcriptEntries...)\\n\\tif len(transcriptEntries) > 0 {\\n\\t\\tfilePaths.Transcript = \\\"/\\\" + paths.TranscriptFileName\\n\\t\\tfilePaths.ContentHash = \\\"/\\\" + paths.ContentHashFileName\\n\\t}\\n\\n\\t// Write prompts\\n\\tif len(opts.Prompts) > 0 {\\n\\t\\tpromptContent := redact.String(strings.Join(opts.Prompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\"))\\n\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(promptContent))\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, filePaths, err\\n\\t\\t}\\n\\t\\tentries = append(entries, object.TreeEntry{\\n\\t\\t\\tName: paths.PromptFileName,\\n\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\tHash: blobHash,\\n\\t\\t})\\n\\t\\tfilePaths.Prompt = \\\"/\\\" + paths.PromptFileName\\n\\t}\\n\\n\\t// Write context\\n\\tif len(opts.Context) > 0 {\\n\\t\\tblobHash, err := CreateBlobFromContent(s.repo, redact.Bytes(opts.Context))\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, filePaths, err\\n\\t\\t}\\n\\t\\tentries = append(entries, object.TreeEntry{\\n\\t\\t\\tName: paths.ContextFileName,\\n\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\tHash: blobHash,\\n\\t\\t})\\n\\t\\tfilePaths.Context = \\\"/\\\" + paths.ContextFileName\\n\\t}\\n\\n\\t// Write session metadata\\n\\tsessionMetadata := CommittedMetadata{\\n\\t\\tCheckpointID:                opts.CheckpointID,\\n\\t\\tSessionID:                   opts.SessionID,\\n\\t\\tStrategy:                    opts.Strategy,\\n\\t\\tCreatedAt:                   time.Now().UTC(),\\n\\t\\tBranch:                      opts.Branch,\\n\\t\\tCheckpointsCount:            opts.CheckpointsCount,\\n\\t\\tFilesTouched:                opts.FilesTouched,\\n\\t\\tAgent:                       opts.Agent,\\n\\t\\tTurnID:                      opts.TurnID,\\n\\t\\tIsTask:                      opts.IsTask,\\n\\t\\tToolUseID:                   opts.ToolUseID,\\n\\t\\tTranscriptIde