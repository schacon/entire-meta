umbing.ZeroHash && treeHash == lastTreeHash {\\n   116→\\t\\treturn WriteTemporaryResult{\\n   117→\\t\\t\\tCommitHash: parentHash,\\n   118→\\t\\t\\tSkipped:    true,\\n   119→\\t\\t}, nil\\n   120→\\t}\\n   121→\\n   122→\\t// Create checkpoint commit with trailers\\n   123→\\tcommitMsg := trailers.FormatShadowCommit(opts.CommitMessage, opts.MetadataDir, opts.SessionID)\\n   124→\\n   125→\\tcommitHash, err := s.createCommit(treeHash, parentHash, commitMsg, opts.AuthorName, opts.AuthorEmail)\\n   126→\\tif err != nil {\\n   127→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   128→\\t}\\n   129→\\n   130→\\t// Update branch reference\\n   131→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   132→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n   133→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n   134→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to update branch reference: %w\\\", err)\\n   135→\\t}\\n   136→\\n   137→\\treturn WriteTemporaryResult{\\n   138→\\t\\tCommitHash: commitHash,\\n   139→\\t\\tSkipped:    false,\\n   140→\\t}, nil\\n   141→}\\n   142→\\n   143→// ReadTemporary reads the latest checkpoint from a shadow branch.\\n   144→// Returns nil if the shadow branch doesn't exist.\\n   145→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   146→func (s *GitStore) ReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error) {\\n   147→\\t_ = ctx // Reserved for future use\\n   148→\\n   149→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   150→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   151→\\n   152→\\tref, err := s.repo.Reference(refName, true)\\n   153→\\tif err != nil {\\n   154→\\t\\treturn nil, nil //nolint:nilnil,nilerr // Branch not found is an expected case\\n   155→\\t}\\n   156→\\n   157→\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n   158→\\tif err != nil {\\n   159→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   160→\\t}\\n   161→\\n   162→\\t// Extract session ID and metadata dir from commit trailers\\n   163→\\tsessionID, _ := trailers.ParseSession(commit.Message)\\n   164→\\tmetadataDir, _ := trailers.ParseMetadata(commit.Message)\\n   165→\\n   166→\\treturn &ReadTemporaryResult{\\n   167→\\t\\tCommitHash:  ref.Hash(),\\n   168→\\t\\tTreeHash:    commit.TreeHash,\\n   169→\\t\\tSessionID:   sessionID,\\n   170→\\t\\tMetadataDir: metadataDir,\\n   171→\\t\\tTimestamp:   commit.Author.When,\\n   172→\\t}, nil\\n   173→}\\n   174→\\n   175→// ListTemporary lists all shadow branches with their checkpoint info.\\n   176→func (s *GitStore) ListTemporary(ctx context.Context) ([]TemporaryInfo, error) {\\n   177→\\t_ = ctx // Reserved for future use\\n   178→\\n   179→\\titer, err := s.repo.Branches()\\n   180→\\tif err != nil {\\n   181→\\t\\treturn nil, fmt.Errorf(\\\"failed to list branches: %w\\\", err)\\n   182→\\t}\\n   183→\\n   184→\\tvar results []TemporaryInfo\\n   185→\\terr = iter.ForEach(func(ref *plumbing.Reference) error {\\n   186→\\t\\tbranchName := ref.Name().Short()\\n   187→\\t\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n   188→\\t\\t\\treturn nil\\n   189→\\t\\t}\\n   190→\\n   191→\\t\\t// Skip the sessions branch\\n   192→\\t\\tif branchName == paths.MetadataBranchName {\\n   193→\\t\\t\\treturn nil\\n   194→\\t\\t}\\n   195→\\n   196→\\t\\tcommit, commitErr := s.repo.CommitObject(ref.Hash())\\n   197→\\t\\tif commitErr != nil {\\n   198→\\t\\t\\t//nolint:nilerr // Skip branches we can't read (non-fatal)\\n   199→\\t\\t\\treturn nil\\n   200→\\t\\t}\\n   201→\\n   202→\\t\\tsessionID, _ := trailers.ParseSession(commit.Message)\\n   203→\\n   204→\\t\\t// Extract base commit from branch name (handles new \\\"entire/<commit>-<worktreeHash>\\\" format)\\n   205→\\t\\tbaseCommit, _, _ := ParseShadowBranchName(branchName)\\n   206→\\n   207→\\t\\tresults = append(results, TemporaryInfo{\\n   208→\\t\\t\\tBranchName:   branchName,\\n   209→\\t\\t\\tBaseCommit:   baseCommit,\\n   210→\\t\\t\\tLatestCommit: ref.Hash(),\\n   211→\\t\\t\\tSessionID:    sessionID,\\n   212→\\t\\t\\tTimestamp:    commit.Author.When,\\n   213→\\t\\t})\\n   214→\\n   215→\\t\\treturn nil\\n   216→\\t})\\n   217→\\n   218→\\tif err != nil {\\n   219→\\t\\treturn nil, fmt.Errorf(\\\"failed to iterate branches: %w\\\", err)\\n   220→\\t}\\n   221→\\n   222→\\treturn results, nil\\n   223→}\\n   224→\\n   225→// WriteTemporaryTask writes a task checkpoint to a shadow branch.\\n   226→// Task checkpoints include both code changes and task-specific metadata.\\n   227→// Returns the commit hash of the created checkpoint.\\n   228→func (s *GitStore) WriteTemporaryTask(ctx context.Context, opts WriteTemporaryTaskOptions) (plumbing.Hash, error) {\\n   229→\\t_ = ctx // Reserved for future use\\n   230→\\n   231→\\t// Validate base commit - required for shadow branch naming\\n   232→\\tif opts.BaseCommit == \\\"\\\" {\\n   233→\\t\\treturn plumbing.ZeroHash, errors.New(\\\"BaseCommit is required for task checkpoint\\\")\\n   234→\\t}\\n   235→\\n   236→\\t// Validate identifiers to prevent path traversal and malformed data\\n   237→\\tif err := validation.ValidateSessionID(opts.SessionID); err != nil {\\n   238→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n   239→\\t}\\n   240→\\tif err := validation.ValidateToolUseID(opts.ToolUseID); err != nil {\\n   241→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n   242→\\t}\\n   243→\\tif err := validation.ValidateAgentID(opts.AgentID); err != nil {\\n   244→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n   245→\\t}\\n   246→\\n   247→\\t// Get shadow branch name\\n   248→\\tshadowBranchName := ShadowBranchNameForCommit(opts.BaseCommit, opts.WorktreeID)\\n   249→\\n   250→\\t// Get or create shadow branch\\n   251→\\tparentHash, baseTreeHash, err := s.getOrCreateShadowBranch(shadowBranchName)\\n   252→\\tif err != nil {\\n   253→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get shadow branch: %w\\\", err)\\n   254→\\t}\\n   255→\\n   256→\\t// Collect all files to include in the commit\\n   257→\\tallFiles := make([]string, 0, len(opts.ModifiedFiles)+len(opts.NewFiles))\\n   258→\\tallFiles = append(allFiles, opts.ModifiedFiles...)\\n   259→\\tallFiles = append(allFiles, opts.NewFiles...)\\n   260→\\n   261→\\t// Build new tree with code changes (no metadata dir yet)\\n   262→\\tnewTreeHash, err := s.buildTreeWithChanges(baseTreeHash, allFiles, opts.DeletedFiles, \\\"\\\", \\\"\\\")\\n   263→\\tif err != nil {\\n   264→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n   265→\\t}\\n   266→\\n   267→\\t// Add task metadata to tree\\n   268→\\tnewTreeHash, err = s.addTaskMetadataToTree(newTreeHash, opts)\\n   269→\\tif err != nil {\\n   270→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to add task metadata: %w\\\", err)\\n   271→\\t}\\n   272→\\n   273→\\t// Create the commit\\n   274→\\tcommitHash, err := s.createCommit(newTreeHash, parentHash, opts.CommitMessage, opts.AuthorName, opts.AuthorEmail)\\n   275→\\tif err != nil {\\n   276→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   277→\\t}\\n   278→\\n   279→\\t// Update shadow branch reference\\n   280→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   281→\\tref := plumbing.NewHashReference(refName, commitHash)\\n   282→\\tif err := s.repo.Storer.SetReference(ref); err != nil {\\n   283→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to update shadow branch reference: %w\\\", err)\\n   284→\\t}\\n   285→\\n   286→\\treturn commitHash, nil\\n   287→}\\n   288→\\n   289→// addTaskMetadataToTree adds task checkpoint metadata to a git tree.\\n   290→// When IsIncremental is true, only adds the incremental checkpoint file.\\n   291→func (s *GitStore) addTaskMetadataToTree(baseTreeHash plumbing.Hash, opts WriteTemporaryTaskOptions) (plumbing.Hash, error) {\\n   292→\\t// Get base tree and flatten it\\n   293→\\tbaseTree, err := s.repo.TreeObject(baseTreeHash)\\n   294→\\tif err != nil {\\n   295→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get base tree: %w\\\", err)\\n   296→\\t}\\n   297→\\n   298→\\tentries := make(map[string]object.TreeEntry)\\n   299→\\tif err := FlattenTree(s.repo, baseTree, \\\"\\\", entries); err != nil {\\n   300→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten tree: %w\\\", err)\\n   301→\\t}\\n   302→\\n   303→\\t// Compute metadata paths\\n   304→\\tsessionMetadataDir := paths.EntireMetadataDir + \\\"/\\\" + opts.SessionID\\n   305→\\ttaskMetadataDir := sessionMetadataDir + \\\"/tasks/\\\" + opts.ToolUseID\\n   306→\\n   307→\\tif opts.IsIncremental {\\n   308→\\t\\t// Incremental checkpoint: only add the checkpoint file\\n   309→\\t\\t// Use proper JSON marshaling to handle nil/empty IncrementalData correctly\\n   310→\\t\\tvar incData []byte\\n   311→\\t\\tif opts.IncrementalData != nil {\\n   312→\\t\\t\\tincData, err = redact.JSONLBytes(opts.IncrementalData)\\n   313→\\t\\t\\tif err != nil {\\n   314→\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to redact incremental checkpoint: %w\\\", err)\\n   315→\\t\\t\\t}\\n   316→\\t\\t}\\n   317→\\t\\tincrementalCheckpoint := struct {\\n   318→\\t\\t\\tType      string          `json:\\\"type\\\"`\\n   319→\\t\\t\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   320→\\t\\t\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n   321→\\t\\t\\tData      json.RawMessage `json:\\\"data\\\"`\\n   322→\\t\\t}{\\n   323→\\t\\t\\tType:      opts.IncrementalType,\\n   324→\\t\\t\\tToolUseID: opts.ToolUseID,\\n   325→\\t\\t\\tTimestamp: time.