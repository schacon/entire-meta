.md) don't persist on overwrite.\\n   300→\\tfor key := range entries {\\n   301→\\t\\tif strings.HasPrefix(key, sessionPath) {\\n   302→\\t\\t\\tdelete(entries, key)\\n   303→\\t\\t}\\n   304→\\t}\\n   305→\\n   306→\\t// Write transcript\\n   307→\\tif err := s.writeTranscript(opts, sessionPath, entries); err != nil {\\n   308→\\t\\treturn filePaths, err\\n   309→\\t}\\n   310→\\tfilePaths.Transcript = \\\"/\\\" + sessionPath + paths.TranscriptFileName\\n   311→\\tfilePaths.ContentHash = \\\"/\\\" + sessionPath + paths.ContentHashFileName\\n   312→\\n   313→\\t// Write prompts\\n   314→\\tif len(opts.Prompts) > 0 {\\n   315→\\t\\tpromptContent := redact.String(strings.Join(opts.Prompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\"))\\n   316→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(promptContent))\\n   317→\\t\\tif err != nil {\\n   318→\\t\\t\\treturn filePaths, err\\n   319→\\t\\t}\\n   320→\\t\\tentries[sessionPath+paths.PromptFileName] = object.TreeEntry{\\n   321→\\t\\t\\tName: sessionPath + paths.PromptFileName,\\n   322→\\t\\t\\tMode: filemode.Regular,\\n   323→\\t\\t\\tHash: blobHash,\\n   324→\\t\\t}\\n   325→\\t\\tfilePaths.Prompt = \\\"/\\\" + sessionPath + paths.PromptFileName\\n   326→\\t}\\n   327→\\n   328→\\t// Write context\\n   329→\\tif len(opts.Context) > 0 {\\n   330→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, redact.Bytes(opts.Context))\\n   331→\\t\\tif err != nil {\\n   332→\\t\\t\\treturn filePaths, err\\n   333→\\t\\t}\\n   334→\\t\\tentries[sessionPath+paths.ContextFileName] = object.TreeEntry{\\n   335→\\t\\t\\tName: sessionPath + paths.ContextFileName,\\n   336→\\t\\t\\tMode: filemode.Regular,\\n   337→\\t\\t\\tHash: blobHash,\\n   338→\\t\\t}\\n   339→\\t\\tfilePaths.Context = \\\"/\\\" + sessionPath + paths.ContextFileName\\n   340→\\t}\\n   341→\\n   342→\\t// Write session-level metadata.json (CommittedMetadata with all fields including initial_attribution)\\n   343→\\tsessionMetadata := CommittedMetadata{\\n   344→\\t\\tCheckpointID:                opts.CheckpointID,\\n   345→\\t\\tSessionID:                   opts.SessionID,\\n   346→\\t\\tStrategy:                    opts.Strategy,\\n   347→\\t\\tCreatedAt:                   time.Now().UTC(),\\n   348→\\t\\tBranch:                      opts.Branch,\\n   349→\\t\\tCheckpointsCount:            opts.CheckpointsCount,\\n   350→\\t\\tFilesTouched:                opts.FilesTouched,\\n   351→\\t\\tAgent:                       opts.Agent,\\n   352→\\t\\tTurnID:                      opts.TurnID,\\n   353→\\t\\tIsTask:                      opts.IsTask,\\n   354→\\t\\tToolUseID:                   opts.ToolUseID,\\n   355→\\t\\tTranscriptIdentifierAtStart: opts.TranscriptIdentifierAtStart,\\n   356→\\t\\tCheckpointTranscriptStart:   opts.CheckpointTranscriptStart,\\n   357→\\t\\tTranscriptLinesAtStart:      opts.CheckpointTranscriptStart, // Deprecated: kept for backward compat\\n   358→\\t\\tTokenUsage:                  opts.TokenUsage,\\n   359→\\t\\tInitialAttribution:          opts.InitialAttribution,\\n   360→\\t\\tSummary:                     redactSummary(opts.Summary),\\n   361→\\t\\tCLIVersion:                  buildinfo.Version,\\n   362→\\t}\\n   363→\\n   364→\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(sessionMetadata, \\\"\\\", \\\"  \\\")\\n   365→\\tif err != nil {\\n   366→\\t\\treturn filePaths, fmt.Errorf(\\\"failed to marshal session metadata: %w\\\", err)\\n   367→\\t}\\n   368→\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n   369→\\tif err != nil {\\n   370→\\t\\treturn filePaths, err\\n   371→\\t}\\n   372→\\tentries[sessionPath+paths.MetadataFileName] = object.TreeEntry{\\n   373→\\t\\tName: sessionPath + paths.MetadataFileName,\\n   374→\\t\\tMode: filemode.Regular,\\n   375→\\t\\tHash: metadataHash,\\n   376→\\t}\\n   377→\\tfilePaths.Metadata = \\\"/\\\" + sessionPath + paths.MetadataFileName\\n   378→\\n   379→\\treturn filePaths, nil\\n   380→}\\n   381→\\n   382→// writeCheckpointSummary writes the root-level CheckpointSummary with aggregated statistics.\\n   383→// sessions is the complete sessions array (already built by the caller).\\n   384→func (s *GitStore) writeCheckpointSummary(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry, sessions []SessionFilePaths) error {\\n   385→\\tcheckpointsCount, filesTouched, tokenUsage, err :=\\n   386→\\t\\ts.reaggregateFromEntries(basePath, len(sessions), entries)\\n   387→\\tif err != nil {\\n   388→\\t\\treturn fmt.Errorf(\\\"failed to aggregate session stats: %w\\\", err)\\n   389→\\t}\\n   390→\\n   391→\\tsummary := CheckpointSummary{\\n   392→\\t\\tCheckpointID:     opts.CheckpointID,\\n   393→\\t\\tCLIVersion:       buildinfo.Version,\\n   394→\\t\\tStrategy:         opts.Strategy,\\n   395→\\t\\tBranch:           opts.Branch,\\n   396→\\t\\tCheckpointsCount: checkpointsCount,\\n   397→\\t\\tFilesTouched:     filesTouched,\\n   398→\\t\\tSessions:         sessions,\\n   399→\\t\\tTokenUsage:       tokenUsage,\\n   400→\\t}\\n   401→\\n   402→\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(summary, \\\"\\\", \\\"  \\\")\\n   403→\\tif err != nil {\\n   404→\\t\\treturn fmt.Errorf(\\\"failed to marshal checkpoint summary: %w\\\", err)\\n   405→\\t}\\n   406→\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n   407→\\tif err != nil {\\n   408→\\t\\treturn err\\n   409→\\t}\\n   410→\\tentries[basePath+paths.MetadataFileName] = object.TreeEntry{\\n   411→\\t\\tName: basePath + paths.MetadataFileName,\\n   412→\\t\\tMode: filemode.Regular,\\n   413→\\t\\tHash: metadataHash,\\n   414→\\t}\\n   415→\\treturn nil\\n   416→}\\n   417→\\n   418→// findSessionIndex returns the index of an existing session with the given ID,\\n   419→// or the next available index if not found. This prevents duplicate session entries.\\n   420→func (s *GitStore) findSessionIndex(basePath string, existingSummary *CheckpointSummary, entries map[string]object.TreeEntry, sessionID string) int {\\n   421→\\tif existingSummary == nil {\\n   422→\\t\\treturn 0\\n   423→\\t}\\n   424→\\tfor i := range len(existingSummary.Sessions) {\\n   425→\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n   426→\\t\\tif entry, exists := entries[path]; exists {\\n   427→\\t\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n   428→\\t\\t\\tif err != nil {\\n   429→\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to read session metadata during dedup check\\\",\\n   430→\\t\\t\\t\\t\\tslog.Int(\\\"session_index\\\", i),\\n   431→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   432→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   433→\\t\\t\\t\\t)\\n   434→\\t\\t\\t\\tcontinue\\n   435→\\t\\t\\t}\\n   436→\\t\\t\\tif meta.SessionID == sessionID {\\n   437→\\t\\t\\t\\treturn i\\n   438→\\t\\t\\t}\\n   439→\\t\\t}\\n   440→\\t}\\n   441→\\treturn len(existingSummary.Sessions)\\n   442→}\\n   443→\\n   444→// reaggregateFromEntries reads all session metadata from the entries map and\\n   445→// reaggregates CheckpointsCount, FilesTouched, and TokenUsage.\\n   446→func (s *GitStore) reaggregateFromEntries(basePath string, sessionCount int, entries map[string]object.TreeEntry) (int, []string, *agent.TokenUsage, error) {\\n   447→\\tvar totalCount int\\n   448→\\tvar allFiles []string\\n   449→\\tvar totalTokens *agent.TokenUsage\\n   450→\\n   451→\\tfor i := range sessionCount {\\n   452→\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n   453→\\t\\tentry, exists := entries[path]\\n   454→\\t\\tif !exists {\\n   455→\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"session %d metadata not found at %s\\\", i, path)\\n   456→\\t\\t}\\n   457→\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n   458→\\t\\tif err != nil {\\n   459→\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"failed to read session %d metadata: %w\\\", i, err)\\n   460→\\t\\t}\\n   461→\\t\\ttotalCount += meta.CheckpointsCount\\n   462→\\t\\tallFiles = mergeFilesTouched(allFiles, meta.FilesTouched)\\n   463→\\t\\ttotalTokens = aggregateTokenUsage(totalTokens, meta.TokenUsage)\\n   464→\\t}\\n   465→\\n   466→\\treturn totalCount, allFiles, totalTokens, nil\\n   467→}\\n   468→\\n   469→// readJSONFromBlob reads JSON from a blob hash and decodes it to the given type.\\n   470→func readJSONFromBlob[T any](repo *git.Repository, hash plumbing.Hash) (*T, error) {\\n   471→\\tblob, err := repo.BlobObject(hash)\\n   472→\\tif err != nil {\\n   473→\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob: %w\\\", err)\\n   474→\\t}\\n   475→\\n   476→\\treader, err := blob.Reader()\\n   477→\\tif err != nil {\\n   478→\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob reader: %w\\\", err)\\n   479→\\t}\\n   480→\\tdefer reader.Close()\\n   481→\\n   482→\\tvar result T\\n   483→\\tif err := json.NewDecoder(reader).Decode(&result); err != nil {\\n   484→\\t\\treturn nil, fmt.Errorf(\\\"failed to decode: %w\\\", err)\\n   485→\\t}\\n   486→\\n   487→\\treturn &result, nil\\n   488→}\\n   489→\\n   490→// readSummaryFromBlob reads CheckpointSummary from a blob hash.\\n   491→func (s *GitStore) readSummaryFromBlob(hash plumbing.Hash) (*CheckpointSummary, error) {\\n   492→\\treturn readJSONFromBlob[CheckpointSummary](s.repo, hash)\\n   493→}\\n   494→\\n   495→// aggregateTokenUsage sums two TokenUsage structs.\\n   496→// Returns nil if both inputs are nil.\\n   497→func aggregateTokenUsage(a, b *agent.TokenUsage) *agent.TokenUsage {\\n   498→\\tif a == nil && b == nil {\\n   499→\\t\\treturn nil\\n   500→\\t}\\n   501→\\tresult := &agent.TokenUsage{}\\n   502→\\tif a != nil {\\n   503→\\t\\tresult.InputTokens = a.InputTokens\\n   504→\\t\\tresult.CacheCreationTokens = a.CacheCreationTokens\\n   505→\\t\\tresult.CacheReadTokens = a.CacheReadTokens\\n   506→\\t\\tresult.OutputTokens = a.OutputTokens\\n   507→\\t\\tresult.APICallCount = a.APICallCount\\n   508→\\t}\\n   509→\\tif b != nil {\\n   510→\\t\\tresult.InputTokens += b.InputTokens\\n   511→\\t\\tresult.CacheCreationTokens += b.CacheCreationTokens\\n   512→\\t\\tresult.CacheReadTokens += b.CacheReadTokens\\n   513→\\t\\tresult.OutputTokens += b.OutputTokens\\n   514→\\t\\tresult.APICallCount += b.APICallCount\\n   515→\\t}\\n   516→\\treturn result\\n   517→}\\n   518→\\n   519→// writeTranscript writes the transcript file from in-memory content or file path.\\n   520→// If the transcript exceeds MaxChunkSize, it's split into multiple chunk files.\\n   521→func (s *GitStore) writeTranscript(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry) error {\\n   522→\\ttranscript := opts.Transcript\\n   523→\\tif len(transcript) == 0 && opts.TranscriptPath != \\\"\\\" {\\n   524→\\t\\tvar readErr error\\n   525→\\t\\ttranscript, readErr = os.ReadFile(opts.TranscriptPath)\\n   526→\\t\\tif readErr != nil {\\n   527→\\t\\t\\t// Non-fatal: transcript may not exist yet\\n   528→\\t\\t\\ttranscript = nil\\n   529→\\t\\t}\\n   530→\\t}\\n   531→\\tif len(transcript) == 0 {\\n   532→\\t\\treturn nil\\n   533→\\t}\\n   534→\\n   535→\\t// Redact secrets before chunking so content hash reflects redacted content\\n   536→\\ttranscript, err := redact.JSONLBytes(transcript)\\n   537→\\tif err != nil {\\n   538→\\t\\treturn fmt.Errorf(\\\"failed to redact transcript secrets: %w\\\", err)\\n   539→\\t}\\n   540→\\n   541→\\t// Chunk the transcript if it's too large\\n   542→\\tchunks, err := agent.ChunkTranscript(transcript, opts.Agent)\\n   543→\\tif err != nil {\\n   544→\\t\\treturn fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n   545→\\t}\\n   546→\\n   547→\\t// Write chunk files\\n   548→\\tfor i, chunk := range chunks {\\n   549→\\t\\tchunkPath := basePath + agent.ChunkFileName(paths.TranscriptFileName, i)\\n   550→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, chunk)\\n   551→\\t\\tif err != nil {\\n   552→\\t\\t\\treturn err\\n   553→\\t\\t}\\n   554→\\t\\tentries[chunkPath] = object.TreeEntry{\\n   555→\\t\\t\\tName: chunkPath,\\n   556→\\t\\t\\tMode: filemode.Regular,\\n   557→\\t\\t\\tHash: blobHash,\\n   558→\\t\\t}\\n   559→\\t}\\n   560→\\n   561→\\t// Content hash for deduplication (hash of full transcript)\\n   562→\\tcontentHash := fmt.Sprintf(\\\"sha256:%x\\\", sha256.Sum256(transcript))\\n   563→\\thashBlob, err := CreateBlobFromContent(s.repo, []byte(contentHash))\\n   564→\\tif err != nil {\\n   565→\\t\\treturn err\\n   566→\\t}\\n   567→\\tentries[basePath+paths.ContentHashFileName] = object.TreeEntry{\\n   568→\\t\\tName: basePath + paths.ContentHashFileName,\\n   569→\\t\\tMode: filemode.Regular,\\n   570→\\t\\tHash: hashBlob,\\n   571→\\t}\\n   572→\\treturn nil\\n   573→}\\n   574→\\n   575→// mergeFilesTouched combines two file lists, removing duplicates.\\n   576→func mergeFilesTouched(existing, additional []string) []string {\\n   577→\\tseen := make(map[string]bool)\\n   578→\\tvar result []string\\n   579→\\n   580→\\tfor _, f := range existing {\\n   581→\\t\\tif !seen[f] {\\n   582→\\t\\t\\tseen[f] = true\\n   583→\\t\\t\\tresult = append(result, f)\\n   584→\\t\\t}\\n   585→\\t}\\n   586→\\tfor _, f := range additional {\\n   587→\\t\\tif !seen[f] {\\n   588→\\t\\t\\tseen[f] = true\\n   589→\\t\\t\\tresult = append(result, f)\\n   590→\\t\\t}\\n   591→\\t}\\n   592→\\n   593→\\tsort.Strings(result)\\n   594→\\treturn result\\n   595→}\\n   596→\\n   597→// redactSummary returns a copy of the summary with text fields redacted.\\n   598→// Structural fields (Path, Line, EndLine) are preserved.\\n   599→// NOTE: When adding new text fields to Summary, LearningsSummary, or CodeLearning,\\n   600→// update this function to include them in redaction.\\n   601→func redactSummary(s *Summary) *Summary {\\n   602→\\tif s == nil {\\n   603→\\t\\treturn nil\\n   604→\\t}\\n   605→\\treturn &Summary{\\n   606→\\t\\tIntent:    redact.String(s.Intent),\\n   607→\\t\\tOutcome:   redact.String(s.Outcome),\\n   608→\\t\\tFriction:  redactStringSlice(s.Friction),\\n   609→\\t\\tOpenItems: redactStringSlice(s.OpenItems),\\n   610→\\t\\tLearnings: LearningsSummary{\\n   611→\\t\\t\\tRepo:     redactStringSlice(s.Learnings.Repo),\\n   612→\\t\\t\\tWorkflow: redactStringSlice(s.Learnings.Workflow),\\n   613→\\t\\t\\tCode:     redactCodeLearnings(s.Learnings.Code),\\n   614→\\t\\t},\\n   615→\\t}\\n   616→}\\n   617→\\n   618→// redactStringSlice applies redact.String to each element.\\n   619→func redactStringSlice(ss []string) []string {\\n   620→\\tif ss == nil {\\n   621→\\t\\treturn nil\\n   622→\\t}\\n   623→\\tout := make([]string, len(ss))\\n   624→\\tfor i, s := range ss {\\n   625→\\t\\tout[i] = redact.String(s)\\n   626→\\t}\\n   627→\\treturn out\\n   628→}\\n   629→\\n   630→// redactCodeLearnings redacts only the Finding field, preserving Path/Line/EndLine.\\n   631→func redactCodeLearnings(cls []CodeLearning) []CodeLearning {\\n   632→\\tif cls == nil {\\n   633→\\t\\treturn nil\\n   634→\\t}\\n   635→\\tout := make([]CodeLearning, len(cls))\\n   636→\\tfor i, cl := range cls {\\n   637→\\t\\tout[i] = CodeLearning{\\n   638→\\t\\t\\tPath:    cl.Path,\\n   639→\\t\\t\\tLine:    cl.Line,\\n   640→\\t\\t\\tEndLine: cl.EndLine,\\n   641→\\t\\t\\tFinding: redact.String(cl.Finding),\\n   642→\\t\\t}\\n   643→\\t}\\n   644→\\treturn out\\n   645→}\\n   646→\\n   647→// readMetadataFromBlob reads CommittedMetadata from a blob hash.\\n   648→func (s *GitStore) readMetadataFromBlob(hash plumbing.Hash) (*CommittedMetadata, error) {\\n   649→\\treturn readJSONFromBlob[CommittedMetadata](s.repo, hash)\\n   650→}\\n   651→\\n   652→// buildCommitMessage constructs the commit message with proper trailers.\\n   653→// The commit subject is always \\\"Checkpoint: <id>\\\" for consistency.\\n   654→// If CommitSubject is provided (e.g., for task checkpoints), it's included in the body.\\n   655→func (s *GitStore) buildCommitMessage(opts WriteCommittedOptions, taskMetadataPath string) string {\\n   656→\\tvar commitMsg strings.Builder\\n   657→\\n   658→\\t// Subject line is always the checkpoint ID for consistent formatting\\n   659→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"Checkpoint: %s\\\\n\\\\n\\\", opts.CheckpointID))\\n   660→\\n   661→\\t// Include custom description in body if provided (e.g., task checkpoint details)\\n   662→\\tif opts.CommitSubject != \\\"\\\" {\\n   663→\\t\\tcommitMsg.WriteString(opts.CommitSubject + \\\"\\\\n\\\\n\\\")\\n   664→\\t}\\n   665→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.SessionTrailerKey, opts.SessionID))\\n   666→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.StrategyTrailerKey, opts.Strategy))\\n   667→\\tif opts.Agent != \\\"\\\" {\\n   668→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.AgentTrailerKey, opts.Agent))\\n   669→\\t}\\n   670→\\tif opts.EphemeralBranch != \\\"\\\" {\\n   671→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.EphemeralBranchTrailerKey, opts.EphemeralBranch))\\n   672→\\t}\\n   673→\\tif taskMetadataPath != \\\"\\\" {\\n   674→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.MetadataTaskTrailerKey, taskMetadataPath))\\n   675→\\t}\\n   676→\\n   677→\\treturn commitMsg.String()\\n   678→}\\n   679→\\n   680→// incrementalCheckpointData represents an incremental checkpoint during subagent execution.\\n   681→// This mirrors strategy.SubagentCheckpoint but avoids import cycles.\\n   682→type incrementalCheckpointData struct {\\n   683→\\tType      string          `json:\\\"type\\\"`\\n   684→\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   685→\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n   686→\\tData      json.RawMessage `json:\\\"data\\\"`\\n   687→}\\n   688→\\n   689→// taskCheckpointData represents a final task checkpoint.\\n   690→// This mirrors strategy.TaskCheckpoint but avoids import cycles.\\n   691→type taskCheckpointData struct {\\n   692→\\tSessionID      string `json:\\\"session_id\\\"`\\n   693→\\tToolUseID      string `json:\\\"tool_use_id\\\"`\\n   694→\\tCheckpointUUID string `json:\\\"checkpoint_uuid\\\"`\\n   695→\\tAgentID        string `json:\\\"agent_id,omitempty\\\"`\\n   696→}\\n   697→\\n   698→// ReadCommitted reads a committed checkpoint's summary by ID from the entire/checkpoints/v1 branch.\\n   699→// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n   700→// Use ReadSessionContent to read actual transcript/prompts/context.\\n   701→// Returns nil, nil if the checkpoint doesn't exist.\\n   702→//\\n   703→// The storage format uses numbered subdirectories for each session (0-based):\\n   704→//\\n   705→//\\t<checkpoint-id>/\\n   706→//\\t├── metadata.json      # CheckpointSummary with sessions map\\n   707→//\\t├── 0/                 # First session\\n   708→//\\t│   ├── metadata.json  # Session-specific metadata\\n   709→//\\t│   └── full.jsonl     # Transcript\\n   710→//\\t├── 1/                 # Second session\\n   711→//\\t└── ...\\n   712→func (s *GitStore) ReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error) {\\n   713→\\t_ = ctx // Reserved for future use\\n   714→\\n   715→\\ttree, err := s.getSessionsBranchTree()\\n   716→\\tif err != nil {\\n   717→\\t\\treturn nil, nil //nolint:nilnil,nilerr // No sessions branch means no checkpoint exists\\n   718→\\t}\\n   719→\\n   720→\\tcheckpointPath := checkpointID.Path()\\n   721→\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n   722→\\tif err != nil {\\n   723→\\t\\treturn nil, nil //nolint:nilnil,nilerr // Checkpoint directory not found\\n   724→\\t}\\n   725→\\n   726→\\t// Read root metadata.json as CheckpointSummary\\n   727→\\tmetadataFile, err := checkpointTree.File(paths.MetadataFileName)\\n   728→\\tif err != nil {\\n   729→\\t\\treturn nil, nil //nolint:nilnil,nilerr // metadata.json not found\\n   730→\\t}\\n   731→\\n   732→\\tcontent, err := metadataFile.Contents()\\n   733→\\tif err != nil {\\n   734→\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata.json: %w\\\", err)\\n   735→\\t}\\n   736→\\n   737→\\tvar summary CheckpointSummary\\n   738→\\tif err := json.Unmarshal([]byte(content), &summary); err != nil {\\n   739→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata.json: %w\\\", err)\\n   740→\\t}\\n   741→\\n   742→\\treturn &summary, nil\\n   743→}\\n   744→\\n   745→// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n   746→// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n   747→// Returns the session's metadata, transcript, prompts, and context.\\n   748→// Returns an error if the checkpoint or session doesn't exist.\\n   749→func (s *GitStore) ReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error) {\\n   750→\\t_ = ctx // Reserved for future use\\n   751→\\n   752→\\ttree, err := s.getSessionsBranchTree()\\n   753→\\tif err != nil {\\n   754→\\t\\treturn nil, ErrCheckpointNotFound\\n   755→\\t}\\n   756→\\n   757→\\tcheckpointPath := checkpointID.Path()\\n   758→\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n   759→\\tif err != nil {\\n   760→\\t\\treturn nil, ErrCheckpointNotFound\\n   761→\\t}\\n   762→\\n   763→\\t// Get the session subdirectory\\n   764→\\tsessionDir := strconv.Itoa(sessionIndex)\\n   765→\\tsessionTree, err := checkpointTree.Tree(sessionDir)\\n   766→\\tif err != nil {\\n   767→\\t\\treturn nil, fmt.Errorf(\\\"session %d not found: %w\\\", sessionIndex, err)\\n   768→\\t}\\n   769→\\n   770→\\tresult := &SessionContent{}\\n   771→\\n   772→\\t// Read session-specific metadata\\n   773→\\tvar agentType agent.AgentType\\n   774→\\tif metadataFile, fileErr := sessionTree.File(paths.MetadataFileName); fileErr == nil {\\n   775→\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n   776→\\t\\t\\tif jsonErr := json.Unmarshal([]byte(content), &result.Metadata); jsonErr == nil {\\n   777→\\t\\t\\t\\tagentType = result.Metadata.Agent\\n   778→\\t\\t\\t}\\n   779→\\t\\t}\\n   780→\\t}\\n   781→\\n   782→\\t// Read transcript\\n   783→\\tif transcript, transcriptErr := readTranscriptFromTree(sessionTree, agentType); transcriptErr == nil && transcript != nil {\\n   784→\\t\\tresult.Transcript = transcript\\n   785→\\t}\\n   786→\\n   787→\\t// Read prompts\\n   788→\\tif file, fileErr := sessionTree.File(paths.PromptFileName); fileErr == nil {\\n   789→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   790→\\t\\t\\tresult.Prompts = content\\n   791→\\t\\t}\\n   792→\\t}\\n   793→\\n   794→\\t// Read context\\n   795→\\tif file, fileErr := sessionTree.File(paths.ContextFileName); fileErr == nil {\\n   796→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   797→\\t\\t\\tresult.Context = content\\n   798→\\t\\t}\\n   799→\\t}\\n   800→\\n   801→\\treturn result, nil\\n   802→}\\n   803→\\n   804→// ReadLatestSessionContent is a convenience method that reads the latest session's content.\\n   805→// This is equivalent to ReadSessionContent(ctx, checkpointID, len(summary.Sessions)-1).\\n   806→func (s *GitStore) ReadLatestSessionContent(ctx context.Context, checkpointID id.CheckpointID) (*SessionContent, error) {\\n   807→\\tsummary, err := s.ReadCommitted(ctx, checkpointID)\\n   808→\\tif err != nil {\\n   809→\\t\\treturn nil, err\\n   810→\\t}\\n   811→\\tif summary == nil {\\n   812→\\t\\treturn nil, ErrCheckpointNotFound\\n   813→\\t}\\n   814→\\tif len(summary.Sessions) == 0 {\\n   815→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint has no sessions: %s\\\", checkpointID)\\n   816→\\t}\\n   817→\\n   818→\\tlatestIndex := len(summary.Sessions) - 1\\n   819→\\treturn s.ReadSessionContent(ctx, checkpointID, latestIndex)\\n   820→}\\n   821→\\n   822→// ReadSessionContentByID reads a session's content by its session ID.\\n   823→// This is useful when you have the session ID but don't know its index within the checkpoint.\\n   824→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   825→// Returns an error if no session with the given ID exists in the checkpoint.\\n   826→func (s *GitStore) ReadSessionContentByID(ctx context.Context, checkpointID id.CheckpointID, sessionID string) (*SessionContent, error) {\\n   827→\\tsummary, err := s.ReadCommitted(ctx, checkpointID)\\n   828→\\tif err != nil {\\n   829→\\t\\treturn nil, err\\n   830→\\t}\\n   831→\\tif summary == nil {\\n   832→\\t\\treturn nil, ErrCheckpointNotFound\\n   833→\\t}\\n   834→\\n   835→\\t// Iterate through sessions to find the one with matching session ID\\n   836→\\tfor i := range len(summary.Sessions) {\\n   837→\\t\\tcontent, readErr := s.ReadSessionContent(ctx, checkpointID, i)\\n   838→\\t\\tif readErr != nil {\\n   839→\\t\\t\\tcontinue\\n   840→\\t\\t}\\n   841→\\t\\tif content != nil && content.Metadata.SessionID == sessionID {\\n   842→\\t\\t\\treturn content, nil\\n   843→\\t\\t}\\n   844→\\t}\\n   845→\\n   846→\\treturn nil, fmt.Errorf(\\\"session %q not found in checkpoint %s\\\", sessionID, checkpointID)\\n   847→}\\n   848→\\n   849→// ListCommitted lists all committed checkpoints from the entire/checkpoints/v1 branch.\\n   850→// Scans sharded paths: <id[:2]>/<id[2:]>/ directories containing metadata.json.\\n   851→//\\n   852→\\n   853→func (s *GitStore) ListCommitted(ctx context.Context) ([]CommittedInfo, error) {\\n   854→\\t_ = ctx // Reserved for future use\\n   855→\\n   856→\\ttree, err := s.getSessionsBranchTree()\\n   857→\\tif err != nil {\\n   858→\\t\\treturn []CommittedInfo{}, nil //nolint:nilerr // No sessions branch means empty list\\n   859→\\t}\\n   860→\\n   861→\\tvar checkpoints []CommittedInfo\\n   862→\\n   863→\\t// Scan sharded structure: <2-char-prefix>/<remaining-id>/metadata.json\\n   864→\\tfor _, bucketEntry := range tree.Entries {\\n   865→\\t\\tif bucketEntry.Mode != filemode.Dir {\\n   866→\\t\\t\\tcontinue\\n   867→\\t\\t}\\n   868→\\t\\t// Bucket should be 2 hex chars\\n   869→\\t\\tif len(bucketEntry.Name) != 2 {\\n   870→\\t\\t\\tcontinue\\n   871→\\t\\t}\\n   872→\\n   873→\\t\\tbucketTree, treeErr := s.repo.TreeObject(bucketEntry.Hash)\\n   874→\\t\\tif treeErr != nil {\\n   875→\\t\\t\\tcontinue\\n   876→\\t\\t}\\n   877→\\n   878→\\t\\t// Each entry in the bucket is the remaining part of the checkpoint ID\\n   879→\\t\\tfor _, checkpointEntry := range bucketTree.Entries {\\n   880→\\t\\t\\tif checkpointEntry.Mode != filemode.Dir {\\n   881→\\t\\t\\t\\tcontinue\\n   882→\\t\\t\\t}\\n   883→\\n   884→\\t\\t\\tcheckpointTree, cpTreeErr := s.repo.TreeObject(checkpointEntry.Hash)\\n   885→\\t\\t\\tif cpTreeErr != nil {\\n   886→\\t\\t\\t\\tcontinue\\n   887→\\t\\t\\t}\\n   888→\\n   889→\\t\\t\\t// Reconstruct checkpoint ID: <bucket><remaining>\\n   890→\\t\\t\\tcheckpointIDStr := bucketEntry.Name + checkpointEntry.Name\\n   891→\\t\\t\\tcheckpointID, cpIDErr := id.NewCheckpointID(checkpointIDStr)\\n   892→\\t\\t\\tif cpIDErr != nil {\\n   893→\\t\\t\\t\\t// Skip invalid checkpoint IDs (shouldn't happen with our own data)\\n   894→\\t\\t\\t\\tcontinue\\n   895→\\t\\t\\t}\\n   896→\\n   897→\\t\\t\\tinfo := CommittedInfo{\\n   898→\\t\\t\\t\\tCheckpointID: checkpointID,\\n   899→\\t\\t\\t}\\n   900→\\n   901→\\t\\t\\t// Get details from root metadata file (CheckpointSummary format)\\n   902→\\t\\t\\tif metadataFile, fileErr := checkpointTree.File(paths.MetadataFileName); fileErr == nil {\\n   903→\\t\\t\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n   904→\\t\\t\\t\\t\\tvar summary CheckpointSummary\\n   905→\\t\\t\\t\\t\\tif err := json.Unmarshal([]byte(content), &summary); err == nil {\\n   906→\\t\\t\\t\\t\\t\\tinfo.CheckpointsCount = summary.CheckpointsCount\\n   907→\\t\\t\\t\\t\\t\\tinfo.FilesTouched = summary.FilesTouched\\n   908→\\t\\t\\t\\t\\t\\tinfo.SessionCount = len(summary.Sessions)\\n   909→\\n   910→\\t\\t\\t\\t\\t\\t// Read session metadata from latest session to get Agent, SessionID, CreatedAt\\n   911→\\t\\t\\t\\t\\t\\tif len(summary.Sessions) > 0 {\\n   912→\\t\\t\\t\\t\\t\\t\\tlatestIndex := len(summary.Sessions) - 1\\n   913→\\t\\t\\t\\t\\t\\t\\tlatestDir := strconv.Itoa(latestIndex)\\n   914→\\t\\t\\t\\t\\t\\t\\tif sessionTree, treeErr := checkpointTree.Tree(latestDir); treeErr == nil {\\n   915→\\t\\t\\t\\t\\t\\t\\t\\tif sessionMetadataFile, smErr := sessionTree.File(paths.MetadataFileName); smErr == nil {\\n   916→\\t\\t\\t\\t\\t\\t\\t\\t\\tif sessionContent, scErr := sessionMetadataFile.Contents(); scErr == nil {\\n   917→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata CommittedMetadata\\n   918→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   919→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   920→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   921→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   922→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   923→\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   924→\\t\\t\\t\\t\\t\\t\\t\\t}\\n   925→\\t\\t\\t\\t\\t\\t\\t}\\n   926→\\t\\t\\t\\t\\t\\t}\\n   927→\\t\\t\\t\\t\\t}\\n   928→\\t\\t\\t\\t}\\n   929→\\t\\t\\t}\\n   930→\\n   931→\\t\\t\\tcheckpoints = append(checkpoints, info)\\n   932→\\t\\t}\\n   933→\\t}\\n   934→\\n   935→\\t// Sort by time (most recent first)\\n   936→\\tsort.Slice(checkpoints, func(i, j int) bool {\\n   937→\\t\\treturn checkpoints[i].CreatedAt.After(checkpoints[j].CreatedAt)\\n   938→\\t})\\n   939→\\n   940→\\treturn checkpoints, nil\\n   941→}\\n   942→\\n   943→// GetTranscript retrieves the transcript for a specific checkpoint ID.\\n   944→// Returns the latest session's transcript.\\n   945→func (s *GitStore) GetTranscript(ctx context.Context, checkpointID id.CheckpointID) ([]byte, error) {\\n   946→\\tcontent, err := s.ReadLatestSessionContent(ctx, checkpointID)\\n   947→\\tif err != nil {\\n   948→\\t\\treturn nil, err\\n   949→\\t}\\n   950→\\tif len(content.Transcript) == 0 {\\n   951→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   952→\\t}\\n   953→\\treturn content.Transcript, nil\\n   954→}\\n   955→\\n   956→// GetSessionLog retrieves the session transcript and session ID for a checkpoint.\\n   957→// This is the primary method for looking up session logs by checkpoint ID.\\n   958→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   959→// Returns ErrNoTranscript if the checkpoint exists but has no transcript.\\n   960→func (s *GitStore) GetSessionLog(cpID id.CheckpointID) ([]byte, string, error) {\\n   961→\\tcontent, err := s.ReadLatestSessionContent(context.Background(), cpID)\\n   962→\\tif err != nil {\\n   963→\\t\\tif errors.Is(err, ErrCheckpointNotFound) {\\n   964→\\t\\t\\treturn nil, \\\"\\\", ErrCheckpointNotFound\\n   965→\\t\\t}\\n   966→\\t\\treturn nil, \\\"\\\", fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   967→\\t}\\n   968→\\tif len(content.Transcript) == 0 {\\n   969→\\t\\treturn nil, \\\"\\\", ErrNoTranscript\\n   970→\\t}\\n   971→\\treturn content.Transcript, content.Metadata.SessionID, nil\\n   972→}\\n   973→\\n   974→// LookupSessionLog is a convenience function that opens the repository and retrieves\\n   975→// a session log by checkpoint ID. This is the primary entry point for callers that\\n   976→// don't already have a GitStore instance.\\n   977→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   978→// Returns ErrNoTranscript if the checkpoint exists but has no transcript.\\n   979→func LookupSessionLog(cpID id.CheckpointID) ([]byte, string, error) {\\n   980→\\trepo, err := git.PlainOpenWithOptions(\\\".\\\", &git.PlainOpenOptions{DetectDotGit: true})\\n   981→\\tif err != nil {\\n   982→\\t\\treturn nil, \\\"\\\", fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   983→\\t}\\n   984→\\tstore := NewGitStore(repo)\\n   985→\\treturn store.GetSessionLog(cpID)\\n   986→}\\n   987→\\n   988→// UpdateSummary updates the summary field in the latest session's metadata.\\n   989→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   990→func (s *GitStore) UpdateSummary(ctx context.Context, checkpointID id.CheckpointID, summary *Summary) error {\\n   991→\\t_ = ctx // Reserved for future use\\n   992→\\n   993→\\t// Ensure sessions branch exists\\n   994→\\tif err := s.ensureSessionsBranch(); err != nil {\\n   995→\\t\\treturn fmt.Errorf(\\\"failed to ensure sessions branch: %w\\\", err)\\n   996→\\t}\\n   997→\\n   998→\\t// Get current branch tip and flatten tree\\n   999→\\tref, entries, err := s.getSessionsBranchEntries()\\n  1000→\\tif err != nil {\\n  1001→\\t\\treturn err\\n  1002→\\t}\\n  1003→\\n  1004→\\t// Read root CheckpointSummary to find the latest session\\n  1005→\\tbasePath := checkpointID.Path() + \\\"/\\\"\\n  1006→\\trootMetadataPath := basePath + paths.MetadataFileName\\n  1007→\\tentry, exists := entries[rootMetadataPath]\\n  1008→\\tif !exists {\\n  1009→\\t\\treturn ErrCheckpointNotFound\\n  1010→\\t}\\n  1011→\\n  1012→\\tcheckpointSummary, err := s.readSummaryFromBlob(entry.Hash)\\n  1013→\\tif err != nil {\\n  1014→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint summary: %w\\\", err)\\n  1015→\\t}\\n  1016→\\n  1017→\\t// Find the latest session's metadata path (0-based indexing)\\n  1018→\\tlatestIndex := len(checkpointSummary.Sessions) - 1\\n  1019→\\tsessionMetadataPath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, latestIndex, paths.MetadataFileName)\\n  1020→\\tsessionEntry, exists := entries[sessionMetadataPath]\\n  1021→\\tif !exists {\\n  1022→\\t\\treturn fmt.Errorf(\\\"session metadata not found at %s\\\", sessionMetadataPath)\\n  1023→\\t}\\n  1024→\\n  1025→\\t// Read and update session metadata\\n  1026→\\texistingMetadata, err := s.readMetadataFromBlob(sessionEntry.Hash)\\n  1027→\\tif err != nil {\\n  1028→\\t\\treturn fmt.Errorf(\\\"failed to read session metadata: %w\\\", err)\\n  1029→\\t}\\n  1030→\\n  1031→\\t// Update the summary\\n  1032→\\texistingMetadata.Summary = redactSummary(summary)\\n  1033→\\n  1034→\\t// Write updated session metadata\\n  1035→\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(existingMetadata, \\\"\\\", \\\"  \\\")\\n  1036→\\tif err != nil {\\n  1037→\\t\\treturn fmt.Errorf(\\\"failed to marshal metadata: %w\\\", err)\\n  1038→\\t}\\n  1039→\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n  1040→\\tif err != nil {\\n  1041→\\t\\treturn fmt.Errorf(\\\"failed to create metadata blob: %w\\\", err)\\n  1042→\\t}\\n  1043→\\tentries[sessionMetadataPath] = object.TreeEntry{\\n  1044→\\t\\tName: sessionMetadataPath,\\n  1045→\\t\\tMode: filemode.Regular,\\n  1046→\\t\\tHash: metadataHash,\\n  1047→\\t}\\n  1048→\\n  1049→\\t// Build and commit\\n  1050→\\tnewTreeHash, err := BuildTreeFromEntries(s.repo, entries)\\n  1051→\\tif err != nil {\\n  1052→\\t\\treturn err\\n  1053→\\t}\\n  1054→\\n  1055→\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n  1056→\\tcommitMsg := fmt.Sprintf(\\\"Update summary for checkpoint %s (session: %s)\\\", checkpointID, existingMetadata.SessionID)\\n  1057→\\tnewCommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, authorName, authorEmail)\\n  1058→\\tif err != nil {\\n  1059→\\t\\treturn err\\n  1060→\\t}\\n  1061→\\n  1062→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1063→\\tnewRef := plumbing.NewHashReference(refName, newCommitHash)\\n  1064→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1065→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1066→\\t}\\n  1067→\\n  1068→\\treturn nil\\n  1069→}\\n  1070→\\n  1071→// UpdateCommitted replaces the transcript, prompts, and context for an existing\\n  1072→// committed checkpoint. Uses replace semantics: the full session transcript is\\n  1073→// written, replacing whatever was stored at initial condensation time.\\n  1074→//\\n  1075→// This is called at stop time to finalize all checkpoints from the current turn\\n  1076→// with the complete session transcript (from prompt to stop event).\\n  1077→//\\n  1078→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n  1079→func (s *GitStore) UpdateCommitted(ctx context.Context, opts UpdateCommittedOptions) error {\\n  1080→\\tif opts.CheckpointID.IsEmpty() {\\n  1081→\\t\\treturn errors.New(\\\"invalid update options: checkpoint ID is required\\\")\\n  1082→\\t}\\n  1083→\\n  1084→\\t// Ensure sessions branch exists\\n  1085→\\tif err := s.ensureSessionsBranch(); err != nil {\\n  1086→\\t\\treturn fmt.Errorf(\\\"failed to ensure sessions branch: %w\\\", err)\\n  1087→\\t}\\n  1088→\\n  1089→\\t// Get current branch tip and flatten tree\\n  1090→\\tref, entries, err := s.getSessionsBranchEntries()\\n  1091→\\tif err != nil {\\n  1092→\\t\\treturn err\\n  1093→\\t}\\n  1094→\\n  1095→\\t// Read root CheckpointSummary to find the session slot\\n  1096→\\tbasePath := opts.CheckpointID.Path() + \\\"/\\\"\\n  1097→\\trootMetadataPath := basePath + paths.MetadataFileName\\n  1098→\\tentry, exists := entries[rootMetadataPath]\\n  1099→\\tif !exists {\\n  1100→\\t\\treturn ErrCheckpointNotFound\\n  1101→\\t}\\n  1102→\\n  1103→\\tcheckpointSummary, err := s.readSummaryFromBlob(entry.Hash)\\n  1104→\\tif err != nil {\\n  1105→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint summary: %w\\\", err)\\n  1106→\\t}\\n  1107→\\tif len(checkpointSummary.Sessions) == 0 {\\n  1108→\\t\\treturn ErrCheckpointNotFound\\n  1109→\\t}\\n  1110→\\n  1111→\\t// Find session index matching opts.SessionID\\n  1112→\\tsessionIndex := -1\\n  1113→\\tfor i := range len(checkpointSummary.Sessions) {\\n  1114→\\t\\tmetaPath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n  1115→\\t\\tif metaEntry, metaExists := entries[metaPath]; metaExists {\\n  1116→\\t\\t\\tmeta, metaErr := s.readMetadataFromBlob(metaEntry.Hash)\\n  1117→\\t\\t\\tif metaErr == nil && meta.SessionID == opts.SessionID {\\n  1118→\\t\\t\\t\\tsessionIndex = i\\n  1119→\\t\\t\\t\\tbreak\\n  1120→\\t\\t\\t}\\n  1121→\\t\\t}\\n  1122→\\t}\\n  1123→\\tif sessionIndex == -1 {\\n  1124→\\t\\t// Fall back to latest session; log so mismatches are diagnosable.\\n  1125→\\t\\tsessionIndex = len(checkpointSummary.Sessions) - 1\\n  1126→\\t\\tlogging.Debug(ctx, \\\"UpdateCommitted: session ID not found, falling back to latest\\\",\\n  1127→\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n  1128→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", string(opts.CheckpointID)),\\n  1129→\\t\\t\\tslog.Int(\\\"fallback_index\\\", sessionIndex),\\n  1130→\\t\\t)\\n  1131→\\t}\\n  1132→\\n  1133→\\tsessionPath := fmt.Sprintf(\\\"%s%d/\\\", basePath, sessionIndex)\\n  1134→\\n  1135→\\t// Replace transcript (full replace, not append)\\n  1136→\\t// Apply redaction as safety net (caller should redact, but we ensure it here)\\n  1137→\\tif len(opts.Transcript) > 0 {\\n  1138→\\t\\ttranscript, err := redact.JSONLBytes(opts.Transcript)\\n  1139→\\t\\tif err != nil {\\n  1140→\\t\\t\\treturn fmt.Errorf(\\\"failed to redact transcript secrets: %w\\\", err)\\n  1141→\\t\\t}\\n  1142→\\t\\tif err := s.replaceTranscript(transcript, opts.Agent, sessionPath, entries); err != nil {\\n  1143→\\t\\t\\treturn fmt.Errorf(\\\"failed to replace transcript: %w\\\", err)\\n  1144→\\t\\t}\\n  1145→\\t}\\n  1146→\\n  1147→\\t// Replace prompts (apply redaction as safety net)\\n  1148→\\tif len(opts.Prompts) > 0 {\\n  1149→\\t\\tpromptContent := redact.String(strings.Join(opts.Prompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\"))\\n  1150→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(promptContent))\\n  1151→\\t\\tif err != nil {\\n  1152→\\t\\t\\treturn fmt.Errorf(\\\"failed to create prompt blob: %w\\\", err)\\n  1153→\\t\\t}\\n  1154→\\t\\tentries[sessionPath+paths.PromptFileName] = object.TreeEntry{\\n  1155→\\t\\t\\tName: sessionPath + paths.PromptFileName,\\n  1156→\\t\\t\\tMode: filemode.Regular,\\n  1157→\\t\\t\\tHash: blobHash,\\n  1158→\\t\\t}\\n  1159→\\t}\\n  1160→\\n  1161→\\t// Replace context (apply redaction as safety net)\\n  1162→\\tif len(opts.Context) > 0 {\\n  1163→\\t\\tcontextBlob, err := CreateBlobFromContent(s.repo, redact.Bytes(opts.Context))\\n  1164→\\t\\tif err != nil {\\n  1165→\\t\\t\\treturn fmt.Errorf(\\\"failed to create context blob: %w\\\", err)\\n  1166→\\t\\t}\\n  1167→\\t\\tentries[sessionPath+paths.ContextFileName] = object.TreeEntry{\\n  1168→\\t\\t\\tName: sessionPath + paths.ContextFileName,\\n  1169→\\t\\t\\tMode: filemode.Regular,\\n  1170→\\t\\t\\tHash: contextBlob,\\n  1171→\\t\\t}\\n  1172→\\t}\\n  1173→\\n  1174→\\t// Build and commit\\n  1175→\\tnewTreeHash, err := BuildTreeFromEntries(s.repo, entries)\\n  1176→\\tif err != nil {\\n  1177→\\t\\treturn err\\n  1178→\\t}\\n  1179→\\n  1180→\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n  1181→\\tcommitMsg := fmt.Sprintf(\\\"Finalize transcript for Checkpoint: %s\\\", opts.CheckpointID)\\n  1182→\\tnewCommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, authorName, authorEmail)\\n  1183→\\tif err != nil {\\n  1184→\\t\\treturn err\\n  1185→\\t}\\n  1186→\\n  1187→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1188→\\tnewRef := plumbing.NewHashReference(refName, newCommitHash)\\n  1189→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1190→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1191→\\t}\\n  1192→\\n  1193→\\treturn nil\\n  1194→}\\n  1195→\\n  1196→// replaceTranscript writes the full transcript content, replacing any existing transcript.\\n  1197→// Also removes any chunk files from a previous write and updates the content hash.\\n  1198→func (s *GitStore) replaceTranscript(transcript []byte, agentType agent.AgentType, sessionPath string, entries map[string]object.TreeEntry) error {\\n  1199→\\t// Remove existing transcript files (base + any chunks)\\n  1200→\\ttranscriptBase := sessionPath + paths.TranscriptFileName\\n  1201→\\tfor key := range entries {\\n  1202→\\t\\tif key == transcriptBase || strings.HasPrefix(key, transcriptBase+\\\".\\\") {\\n  1203→\\t\\t\\tdelete(entries, key)\\n  1204→\\t\\t}\\n  1205→\\t}\\n  1206→\\n  1207→\\t// Chunk the transcript (matches writeTranscript behavior)\\n  1208→\\tchunks, err := agent.ChunkTranscript(transcript, agentType)\\n  1209→\\tif err != nil {\\n  1210→\\t\\treturn fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n  1211→\\t}\\n  1212→\\n  1213→\\t// Write chunk files\\n  1214→\\tfor i, chunk := range chunks {\\n  1215→\\t\\tchunkPath := sessionPath + agent.ChunkFileName(paths.TranscriptFileName, i)\\n  1216→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, chunk)\\n  1217→\\t\\tif err != nil {\\n  1218→\\t\\t\\treturn fmt.Errorf(\\\"failed to create transcript blob: %w\\\", err)\\n  1219→\\t\\t}\\n  1220→\\t\\tentries[chunkPath] = object.TreeEntry{\\n  1221→\\t\\t\\tName: chunkPath,\\n  1222→\\t\\t\\tMode: filemode.Regular,\\n  1223→\\t\\t\\tHash: blobHash,\\n  1224→\\t\\t}\\n  1225→\\t}\\n  1226→\\n  1227→\\t// Update content hash\\n  1228→\\tcontentHash := fmt.Sprintf(\\\"sha256:%x\\\", sha256.Sum256(transcript))\\n  1229→\\thashBlob, err := CreateBlobFromContent(s.repo, []byte(contentHash))\\n  1230→\\tif err != nil {\\n  1231→\\t\\treturn fmt.Errorf(\\\"failed to create content hash blob: %w\\\", err)\\n  1232→\\t}\\n  1233→\\thashPath := sessionPath + paths.ContentHashFileName\\n  1234→\\tentries[hashPath] = object.TreeEntry{\\n  1235→\\t\\tName: hashPath,\\n  1236→\\t\\tMode: filemode.Regular,\\n  1237→\\t\\tHash: hashBlob,\\n  1238→\\t}\\n  1239→\\n  1240→\\treturn nil\\n  1241→}\\n  1242→\\n  1243→// ensureSessionsBranch ensures the entire/checkpoints/v1 branch exists.\\n  1244→func (s *GitStore) ensureSessionsBranch() error {\\n  1245→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1246→\\t_, err := s.repo.Reference(refName, true)\\n  1247→\\tif err == nil {\\n  1248→\\t\\treturn nil // Branch exists\\n  1249→\\t}\\n  1250→\\n  1251→\\t// Create orphan branch with empty tree\\n  1252→\\temptyTreeHash, err := BuildTreeFromEntries(s.repo, make(map[string]object.TreeEntry))\\n  1253→\\tif err != nil {\\n  1254→\\t\\treturn err\\n  1255→\\t}\\n  1256→\\n  1257→\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n  1258→\\tcommitHash, err := s.createCommit(emptyTreeHash, plumbing.ZeroHash, \\\"Initialize sessions branch\\\", authorName, authorEmail)\\n  1259→\\tif err != nil {\\n  1260→\\t\\treturn err\\n  1261→\\t}\\n  1262→\\n  1263→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n  1264→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1265→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1266→\\t}\\n  1267→\\treturn nil\\n  1268→}\\n  1269→\\n  1270→// getSessionsBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\n  1271→// Falls back to origin/entire/checkpoints/v1 if the local branch doesn't exist.\\n  1272→func (s *GitStore) getSessionsBranchTree() (*object.Tree, error) {\\n  1273→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1274→\\tref, err := s.repo.Reference(refName, true)\\n  1275→\\tif err != nil {\\n  1276→\\t\\t// Local branch doesn't exist, try remote-tracking branch\\n  1277→\\t\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n  1278→\\t\\tref, err = s.repo.Reference(remoteRefName, true)\\n  1279→\\t\\tif err != nil {\\n  1280→\\t\\t\\treturn nil, fmt.Errorf(\\\"sessions branch not found: %w\\\", err)\\n  1281→\\t\\t}\\n  1282→\\t}\\n  1283→\\n  1284→\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n  1285→\\tif err != nil {\\n  1286→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n  1287→\\t}\\n  1288→\\n  1289→\\ttree, err := commit.Tree()\\n  1290→\\tif err != nil {\\n  1291→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n  1292→\\t}\\n  1293→\\n  1294→\\treturn tree, nil\\n  1295→}\\n  1296→\\n  1297→// CreateBlobFromContent creates a blob object from in-memory content.\\n  1298→// Exported for use by strategy package (session_test.go)\\n  1299→func CreateBlobFromContent(repo *git.Repository, content []byte) (plumbing.Hash, error) {\\n  1300→\\tobj := repo.Storer.NewEncodedObject()\\n  1301→\\tobj.SetType(plumbing.BlobObject)\\n  1302→\\tobj.SetSize(int64(len(content)))\\n  1303→\\n  1304→\\twriter, err := obj.Writer()\\n  1305→\\tif err != nil {\\n  1306→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get object writer: %w\\\", err)\\n  1307→\\t}\\n  1308→\\n  1309→\\t_, err = writer.Write(content)\\n  1310→\\tif err != nil {\\n  1311→\\t\\t_ = writer.Close()\\n  1312→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write blob content: %w\\\", err)\\n  1313→\\t}\\n  1314→\\tif err := writer.Close(); err != nil {\\n  1315→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to close blob writer: %w\\\", err)\\n  1316→\\t}\\n  1317→\\n  1318→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n  1319→\\tif err != nil {\\n  1320→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store blob object: %w\\\", err)\\n  1321→\\t}\\n  1322→\\treturn hash, nil\\n  1323→}\\n  1324→\\n  1325→// copyMetadataDir copies all files from a directory to the checkpoint path.\\n  1326→// Used to include additional metadata files like task checkpoints, subagent transcripts, etc.\\n  1327→func (s *GitStore) copyMetadataDir(metadataDir, basePath string, entries map[string]object.TreeEntry) error {\\n  1328→\\terr := filepath.Walk(metadataDir, func(path string, info os.FileInfo, err error) error {\\n  1329→\\t\\tif err != nil {\\n  1330→\\t\\t\\treturn err\\n  1331→\\t\\t}\\n  1332→\\n  1333→\\t\\t// Skip symlinks to prevent reading files outside the metadata directory.\\n  1334→\\t\\t// A symlink could point to sensitive files (e.g., /etc/passwd) which would\\n  1335→\\t\\t// then be captured in the checkpoint and stored in git history.\\n  1336→\\t\\t// NOTE: filepath.Walk uses os.Stat (follows symlinks), so info.Mode() never\\n  1337→\\t\\t// reports ModeSymlink. We use os.Lstat to check the entry itself.\\n  1338→\\t\\t// This check MUST come before IsDir() because Walk follows symlinked\\n  1339→\\t\\t// directories and would recurse into them otherwise.\\n  1340→\\t\\tlinfo, lstatErr := os.Lstat(path)\\n  1341→\\t\\tif lstatErr != nil {\\n  1342→\\t\\t\\treturn fmt.Errorf(\\\"failed to lstat %s: %w\\\", path, lstatErr)\\n  1343→\\t\\t}\\n  1344→\\t\\tif linfo.Mode()&os.ModeSymlink != 0 {\\n  1345→\\t\\t\\tif info.IsDir() {\\n  1346→\\t\\t\\t\\treturn filepath.SkipDir\\n  1347→\\t\\t\\t}\\n  1348→\\t\\t\\treturn nil\\n  1349→\\t\\t}\\n  1350→\\n  1351→\\t\\tif info.IsDir() {\\n  1352→\\t\\t\\treturn nil\\n  1353→\\t\\t}\\n  1354→\\n  1355→\\t\\t// Get relative path within metadata dir\\n  1356→\\t\\trelPath, err := filepath.Rel(metadataDir, path)\\n  1357→\\t\\tif err != nil {\\n  1358→\\t\\t\\treturn fmt.Errorf(\\\"failed to get relative path for %s: %w\\\", path, err)\\n  1359→\\t\\t}\\n  1360→\\n  1361→\\t\\t// Prevent path traversal via symlinks pointing outside the metadata dir\\n  1362→\\t\\tif strings.HasPrefix(relPath, \\\"..\\\") {\\n  1363→\\t\\t\\treturn fmt.Errorf(\\\"path traversal detected: %s\\\", relPath)\\n  1364→\\t\\t}\\n  1365→\\n  1366→\\t\\t// Create blob from file with secrets redaction\\n  1367→\\t\\tblobHash, mode, err := createRedactedBlobFromFile(s.repo, path, relPath)\\n  1368→\\t\\tif err != nil {\\n  1369→\\t\\t\\treturn fmt.Errorf(\\\"failed to create blob for %s: %w\\\", path, err)\\n  1370→\\t\\t}\\n  1371→\\n  1372→\\t\\t// Store at checkpoint path (use forward slashes for git tree compatibility on Windows)\\n  1373→\\t\\tfullPath := basePath + filepath.ToSlash(relPath)\\n  1374→\\t\\tentries[fullPath] = object.TreeEntry{\\n  1375→\\t\\t\\tName: fullPath,\\n  1376→\\t\\t\\tMode: mode,\\n  1377→\\t\\t\\tHash: blobHash,\\n  1378→\\t\\t}\\n  1379→\\n  1380→\\t\\treturn nil\\n  1381→\\t})\\n  1382→\\tif err != nil {\\n  1383→\\t\\treturn fmt.Errorf(\\\"failed to walk metadata directory: %w\\\", err)\\n  1384→\\t}\\n  1385→\\treturn nil\\n  1386→}\\n  1387→\\n  1388→// createRedactedBlobFromFile reads a file, applies secrets redaction, and creates a git blob.\\n  1389→// JSONL files get JSONL-aware redaction; all other files get plain string redaction.\\n  1390→func createRedactedBlobFromFile(repo *git.Repository, filePath, treePath string) (plumbing.Hash, filemode.FileMode, error) {\\n  1391→\\tinfo, err := os.Stat(filePath)\\n  1392→\\tif err != nil {\\n  1393→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to stat file: %w\\\", err)\\n  1394→\\t}\\n  1395→\\n  1396→\\tmode := filemode.Regular\\n  1397→\\tif info.Mode()&0o111 != 0 {\\n  1398→\\t\\tmode = filemode.Executable\\n  1399→\\t}\\n  1400→\\n  1401→\\tcontent, err := os.ReadFile(filePath) //nolint:gosec // filePath comes from walking the metadata directory\\n  1402→\\tif err != nil {\\n  1403→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to read file: %w\\\", err)\\n  1404→\\t}\\n  1405→\\n  1406→\\t// Skip redaction for binary files — they can't contain text secrets and\\n  1407→\\t// running string replacement on them would corrupt the data.\\n  1408→\\tisBin, binErr := binary.IsBinary(bytes.NewReader(content))\\n  1409→\\tif binErr != nil || isBin {\\n  1410→\\t\\thash, err := CreateBlobFromContent(repo, content)\\n  1411→\\t\\tif err != nil {\\n  1412→\\t\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to create blob: %w\\\", err)\\n  1413→\\t\\t}\\n  1414→\\t\\treturn hash, mode, nil\\n  1415→\\t}\\n  1416→\\n  1417→\\tif strings.HasSuffix(treePath, \\\".jsonl\\\") {\\n  1418→\\t\\tredacted, jsonlErr := redact.JSONLBytes(content)\\n  1419→\\t\\tif jsonlErr != nil {\\n  1420→\\t\\t\\tredacted = redact.Bytes(content)\\n  1421→\\t\\t}\\n  1422→\\t\\tcontent = redacted\\n  1423→\\t} else {\\n  1424→\\t\\tcontent = redact.Bytes(content)\\n  1425→\\t}\\n  1426→\\n  1427→\\thash, err := CreateBlobFromContent(repo, content)\\n  1428→\\tif err != nil {\\n  1429→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to create blob: %w\\\", err)\\n  1430→\\t}\\n  1431→\\treturn hash, mode, nil\\n  1432→}\\n  1433→\\n  1434→// GetGitAuthorFromRepo retrieves the git user.name and user.email,\\n  1435→// checking both the repository-local config and the global ~/.gitconfig.\\n  1436→func GetGitAuthorFromRepo(repo *git.Repository) (name, email string) {\\n  1437→\\t// Get repository config (includes local settings)\\n  1438→\\tcfg, err := repo.Config()\\n  1439→\\tif err == nil {\\n  1440→\\t\\tname = cfg.User.Name\\n  1441→\\t\\temail = cfg.User.Email\\n  1442→\\t}\\n  1443→\\n  1444→\\t// If not found in local config, try global config\\n  1445→\\tif name == \\\"\\\" || email == \\\"\\\" {\\n  1446→\\t\\tglobalCfg, err := config.LoadConfig(config.GlobalScope)\\n  1447→\\t\\tif err == nil {\\n  1448→\\t\\t\\tif name == \\\"\\\" {\\n  1449→\\t\\t\\t\\tname = globalCfg.User.Name\\n  1450→\\t\\t\\t}\\n  1451→\\t\\t\\tif email == \\\"\\\" {\\n  1452→\\t\\t\\t\\temail = globalCfg.User.Email\\n  1453→\\t\\t\\t}\\n  1454→\\t\\t}\\n  1455→\\t}\\n  1456→\\n  1457→\\t// Provide sensible defaults if git user is not configured\\n  1458→\\tif name == \\\"\\\" {\\n  1459→\\t\\tname = \\\"Unknown\\\"\\n  1460→\\t}\\n  1461→\\tif email == \\\"\\\" {\\n  1462→\\t\\temail = \\\"unknown@local\\\"\\n  1463→\\t}\\n  1464→\\n  1465→\\treturn name, email\\n  1466→}\\n  1467→\\n  1468→// readTranscriptFromTree reads a transcript from a git tree, handling both chunked and non-chunked formats.\\n  1469→// It checks for chunk files first (.001, .002, etc.), then falls back to the base file.\\n  1470→// The agentType is used for reassembling chunks in the correct format.\\n  1471→func readTranscriptFromTree(tree *object.Tree, agentType agent.AgentType) ([]byte, error) {\\n  1472→\\t// Collect all transcript-related files\\n  1473→\\tvar chunkFiles []string\\n  1474→\\tvar hasBaseFile bool\\n  1475→\\n  1476→\\tfor _, entry := range tree.Entries {\\n  1477→\\t\\tif entry.Name == paths.TranscriptFileName || entry.Name == paths.TranscriptFileNameLegacy {\\n  1478→\\t\\t\\thasBaseFile = true\\n  1479→\\t\\t}\\n  1480→\\t\\t// Check for chunk files (full.jsonl.001, full.jsonl.002, etc.)\\n  1481→\\t\\tif strings.HasPrefix(entry.Name, paths.TranscriptFileName+\\\".\\\") {\\n  1482→\\t\\t\\tidx := agent.ParseChunkIndex(entry.Name, paths.TranscriptFileName)\\n  1483→\\t\\t\\tif idx > 0 {\\n  1484→\\t\\t\\t\\tchunkFiles = append(chunkFiles, entry.Name)\\n  1485→\\t\\t\\t}\\n  1486→\\t\\t}\\n  1487→\\t}\\n  1488→\\n  1489→\\t// If we have chunk files, read and reassemble them\\n  1490→\\tif len(chunkFiles) > 0 {\\n  1491→\\t\\t// Sort chunk files by index\\n  1492→\\t\\tchunkFiles = agent.SortChunkFiles(chunkFiles, paths.TranscriptFileName)\\n  1493→\\n  1494→\\t\\t// Check if base file should be included as chunk 0.\\n  1495→\\t\\t// NOTE: This assumes the chunking convention where the unsuffixed file\\n  1496→\\t\\t// (full.jsonl) is chunk 0, and numbered files (.001, .002) are chunks 1+.\\n  1497→\\t\\tif hasBaseFile {\\n  1498→\\t\\t\\tchunkFiles = append([]string{paths.TranscriptFileName}, chunkFiles...)\\n  1499→\\t\\t}\\n  1500→\\n  1501→\\t\\tvar chunks [][]byte\\n  1502→\\t\\tfor _, chunkFile := range chunkFiles {\\n  1503→\\t\\t\\tfile, err := tree.File(chunkFile)\\n  1504→\\t\\t\\tif err != nil {\\n  1505→\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to read transcript chunk file from tree\\\",\\n  1506→\\t\\t\\t\\t\\tslog.String(\\\"chunk_file\\\", chunkFile),\\n  1507→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1508→\\t\\t\\t\\t)\\n  1509→\\t\\t\\t\\tcontinue\\n  1510→\\t\\t\\t}\\n  1511→\\t\\t\\tcontent, err := file.Contents()\\n  1512→\\t\\t\\tif err != nil {\\n  1513→\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to read transcript chunk contents\\\",\\n  1514→\\t\\t\\t\\t\\tslog.String(\\\"chunk_file\\\", chunkFile),\\n  1515→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1516→\\t\\t\\t\\t)\\n  1517→\\t\\t\\t\\tcontinue\\n  1518→\\t\\t\\t}\\n  1519→\\t\\t\\tchunks = append(chunks, []byte(content))\\n  1520→\\t\\t}\\n  1521→\\n  1522→\\t\\tif len(chunks) > 0 {\\n  1523→\\t\\t\\tresult, err := agent.ReassembleTranscript(chunks, agentType)\\n  1524→\\t\\t\\tif err != nil {\\n  1525→\\t\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to reassemble transcript: %w\\\", err)\\n  1526→\\t\\t\\t}\\n  1527→\\t\\t\\treturn result, nil\\n  1528→\\t\\t}\\n  1529→\\t}\\n  1530→\\n  1531→\\t// Fall back to reading base file (non-chunked or backwards compatibility)\\n  1532→\\tif file, err := tree.File(paths.TranscriptFileName); err == nil {\\n  1533→\\t\\tif content, err := file.Contents(); err == nil {\\n  1534→\\t\\t\\treturn []byte(content), nil\\n  1535→\\t\\t}\\n  1536→\\t}\\n  1537→\\n  1538→\\t// Try legacy filename\\n  1539→\\tif file, err := tree.File(paths.TranscriptFileNameLegacy); err == nil {\\n  1540→\\t\\tif content, err := file.Contents(); err == nil {\\n  1541→\\t\\t\\treturn []byte(content), nil\\n  1542→\\t\\t}\\n  1543→\\t}\\n  1544→\\n  1545→\\treturn nil, nil\\n  1546→}\\n  1547→\\n  1548→// Author contains author information for a checkpoint.\\n  1549→type Author struct {\\n  1550→\\tName  string\\n  1551→\\tEmail string\\n  1552→}\\n  1553→\\n  1554→// GetCheckpointAuthor retrieves the author of a checkpoint from the entire/checkpoints/v1 commit history.\\n  1555→// Returns the author of the commit that introduced this checkpoint's metadata.json file.\\n  1556→// Returns empty Author if the checkpoint is not found or the sessions branch doesn't exist.\\n  1557→func (s *GitStore) GetCheckpointAuthor(ctx context.Context, checkpointID id.CheckpointID) (Author, error) {\\n  1558→\\t_ = ctx // Reserved for future use\\n  1559→\\n  1560→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1561→\\tref, err := s.repo.Reference(refName, true)\\n  1562→\\tif err != nil {\\n  1563→\\t\\treturn Author{}, nil\\n  1564→\\t}\\n  1565→\\n  1566→\\t// Path to the checkpoint's metadata file\\n  1567→\\tmetadataPath := checkpointID.Path() + \\\"/\\\" + paths.MetadataFileName\\n  1568→\\n  1569→\\t// Walk commit history looking for the commit that introduced this file\\n  1570→\\titer, err := s.repo.Log(&git.LogOptions{\\n  1571→\\t\\tFrom:  ref.Hash(),\\n  1572→\\t\\tOrder: git.LogOrderCommitterTime,\\n  1573→\\t})\\n  1574→\\tif err != nil {\\n  1575→\\t\\treturn Author{}, nil\\n  1576→\\t}\\n  1577→\\tdefer iter.Close()\\n  1578→\\n  1579→\\tvar author Author\\n  1580→\\tvar foundCommit *object.Commit\\n  1581→\\n  1582→\\terr = iter.ForEach(func(c *object.Commit) error {\\n  1583→\\t\\ttree, treeErr := c.Tree()\\n  1584→\\t\\tif treeErr != nil {\\n  1585→\\t\\t\\treturn nil //nolint:nilerr // Skip commits we can't read, continue searching\\n  1586→\\t\\t}\\n  1587→\\n  1588→\\t\\t_, fileErr := tree.File(metadataPath)\\n  1589→\\t\\tif fileErr != nil {\\n  1590→\\t\\t\\t// File doesn't exist in this commit - we've gone past the creation point\\n  1591→\\t\\t\\tif foundCommit != nil {\\n  1592→\\t\\t\\t\\treturn errStopIteration\\n  1593→\\t\\t\\t}\\n  1594→\\t\\t\\treturn nil\\n  1595→\\t\\t}\\n  1596→\\n  1597→\\t\\t// File exists - track it (oldest one with file is the creator)\\n  1598→\\t\\tfoundCommit = c\\n  1599→\\t\\tauthor = Author{\\n  1600→\\t\\t\\tName:  c.Author.Name,\\n  1601→\\t\\t\\tEmail: c.Author.Email,\\n  1602→\\t\\t}\\n  1603→\\t\\treturn nil\\n  1604→\\t})\\n  1605→\\n  1606→\\t// Ignore errStopIteration - it's just for early exit\\n  1607→\\tif err != nil && !errors.Is(err, errStopIteration) {\\n  1608→\\t\\treturn Author{}, nil\\n  1609→\\t}\\n  1610→\\n  1611→\\treturn author, nil\\n  1612→}\\n  1613→\"}]},\"uuid\":\"02585fe9-e28c-49ff-85c3-e1c3a6e001e9\",\"timestamp\":\"2026-02-24T22:23:18.116Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/evisdrenova/code/entire/devenv/cli/cmd/entire/cli/checkpoint/committed.go\",\"content\":\"package checkpoint\\n\\nimport (\\n\\t\\\"bytes\\\"\\n\\t\\\"context\\\"\\n\\t\\\"crypto/sha256\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"sort\\\"\\n\\t\\\"strconv\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/buildinfo\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n\\t\\\"github.com/entireio/cli/redact\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/config\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/filemode\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n\\t\\\"github.com/go-git/go-git/v5/utils/binary\\\"\\n)\\n\\n// errStopIteration is used to stop commit iteration early in GetCheckpointAuthor.\\nvar errStopIteration = errors.New(\\\"stop iteration\\\")\\n\\n// WriteCommitted writes a committed checkpoint to the entire/checkpoints/v1 branch.\\n// Checkpoints are stored at sharded paths: <id[:2]>/<id[2:]>/\\n//\\n// For task checkpoints (IsTask=true), additional files are written under tasks/<tool-use-id>/:\\n//   - For incremental checkpoints: checkpoints/NNN-<tool-use-id>.json\\n//   - For final checkpoints: checkpoint.json and agent-<agent-id>.jsonl\\nfunc (s *GitStore) WriteCommitted(ctx context.Context, opts WriteCommittedOptions) error {\\n\\t_ = ctx // Reserved for future use\\n\\n\\t// Validate identifiers to prevent path traversal and malformed data\\n\\tif opts.CheckpointID.IsEmpty() {\\n\\t\\treturn errors.New(\\\"invalid checkpoint options: checkpoint ID is required\\\")\\n\\t}\\n\\tif err := validation.ValidateSessionID(opts.SessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid checkpoint options: %w\\\", err)\\n\\t}\\n\\tif err := validation.ValidateToolUseID(opts.ToolUseID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid checkpoint options: %w\\\", err)\\n\\t}\\n\\tif err := validation.ValidateAgentID(opts.AgentID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid checkpoint options: %w\\\", err)\\n\\t}\\n\\n\\t// Ensure sessions branch exists\\n\\tif err := s.ensureSessionsBranch(); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to ensure sessions branch: %w\\\", err)\\n\\t}\\n\\n\\t// Get current branch tip and flatten tree\\n\\tref, entries, err := s.getSessionsBranchEntries()\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Use sharded path: <id[:2]>/<id[2:]>/\\n\\tbasePath := opts.CheckpointID.Path() + \\\"/\\\"\\n\\n\\t// Track task metadata path for commit trailer\\n\\tvar taskMetadataPath string\\n\\n\\t// Handle task checkpoints\\n\\tif opts.IsTask && opts.ToolUseID != \\\"\\\" {\\n\\t\\ttaskMetadataPath, err = s.writeTaskCheckpointEntries(opts, basePath, entries)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn err\\n\\t\\t}\\n\\t}\\n\\n\\t// Write standard checkpoint entries (transcript, prompts, context, metadata)\\n\\tif err := s.writeStandardCheckpointEntries(opts, basePath, entries); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Build and commit\\n\\tnewTreeHash, err := BuildTreeFromEntries(s.repo, entries)\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\tcommitMsg := s.buildCommitMessage(opts, taskMetadataPath)\\n\\tnewCommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, opts.AuthorName, opts.AuthorEmail)\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n\\tnewRef := plumbing.NewHashReference(refName, newCommitHash)\\n\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// getSessionsBranchEntries returns the sessions branch reference and flattened tree entries.\\nfunc (s *GitStore) getSessionsBranchEntries() (*plumbing.Reference, map[string]object.TreeEntry, error) {\\n\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n\\tref, err := s.repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\treturn nil, nil, fmt.Errorf(\\\"failed to get sessions branch reference: %w\\\", err)\\n\\t}\\n\\n\\tparentCommit, err := s.repo.CommitObject(ref.Hash())\\n\\tif err != nil {\\n\\t\\treturn nil, nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\tbaseTree, err := parentCommit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\tentries := make(map[string]object.TreeEntry)\\n\\tif err := FlattenTree(s.repo, baseTree, \\\"\\\", entries); err != nil {\\n\\t\\treturn nil, nil, err\\n\\t}\\n\\n\\treturn ref, entries, nil\\n}\\n\\n// writeTaskCheckpointEntries writes task-specific checkpoint entries and returns the task metadata path.\\nfunc (s *GitStore) writeTaskCheckpointEntries(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry) (string, error) {\\n\\ttaskPath := basePath + \\\"tasks/\\\" + opts.ToolUseID + \\\"/\\\"\\n\\n\\tif opts.IsIncremental {\\n\\t\\treturn s.writeIncrementalTaskCheckpoint(opts, taskPath, entries)\\n\\t}\\n\\treturn s.writeFinalTaskCheckpoint(opts, taskPath, entries)\\n}\\n\\n// writeIncrementalTaskCheckpoint writes an incremental checkpoint file during task execution.\\nfunc (s *GitStore) writeIncrementalTaskCheckpoint(opts WriteCommittedOptions, taskPath string, entries map[string]object.TreeEntry) (string, error) {\\n\\tincData, err := redact.JSONLBytes(opts.IncrementalData)\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to redact incremental checkpoint: %w\\\", err)\\n\\t}\\n\\tcheckpoint := incrementalCheckpointData{\\n\\t\\tType:      opts.IncrementalType,\\n\\t\\tToolUseID: opts.ToolUseID,\\n\\t\\tTimestamp: time.Now().UTC(),\\n\\t\\tData:      incData,\\n\\t}\\n\\tcpData, err := jsonutil.MarshalIndentWithNewline(checkpoint, \\\"\\\", \\\"  \\\")\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to marshal incremental checkpoint: %w\\\", err)\\n\\t}\\n\\tcpBlobHash, err := CreateBlobFromContent(s.repo, cpData)\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create incremental checkpoint blob: %w\\\", err)\\n\\t}\\n\\n\\tcpFilename := fmt.Sprintf(\\\"%03d-%s.json\\\", opts.IncrementalSequence, opts.ToolUseID)\\n\\tcpPath := taskPath + \\\"checkpoints/\\\" + cpFilename\\n\\tentries[cpPath] = object.TreeEntry{\\n\\t\\tName: cpPath,\\n\\t\\tMode: filemode.Regular,\\n\\t\\tHash: cpBlobHash,\\n\\t}\\n\\treturn cpPath, nil\\n}\\n\\n// writeFinalTaskCheckpoint writes the final checkpoint.json and subagent transcript.\\nfunc (s *GitStore) writeFinalTaskCheckpoint(opts WriteCommittedOptions, taskPath string, entries map[string]object.TreeEntry) (string, error) {\\n\\tcheckpoint := taskCheckpointData{\\n\\t\\tSessionID:      opts.SessionID,\\n\\t\\tToolUseID:      opts.ToolUseID,\\n\\t\\tCheckpointUUID: opts.CheckpointUUID,\\n\\t\\tAgentID:        opts.AgentID,\\n\\t}\\n\\tcheckpointData, err := jsonutil.MarshalIndentWithNewline(checkpoint, \\\"\\\", \\\"  \\\")\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to marshal task checkpoint: %w\\\", err)\\n\\t}\\n\\tblobHash, err := CreateBlobFromContent(s.repo, checkpointData)\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create task checkpoint blob: %w\\\", err)\\n\\t}\\n\\n\\tcheckpointFile := taskPath + \\\"checkpoint.json\\\"\\n\\tentries[checkpointFile] = object.TreeEntry{\\n\\t\\tName: checkpointFile,\\n\\t\\tMode: filemode.Regular,\\n\\t\\tHash: blobHash,\\n\\t}\\n\\n\\t// Write subagent transcript if available\\n\\tif opts.SubagentTranscriptPath != \\\"\\\" && opts.AgentID != \\\"\\\" {\\n\\t\\tagentContent, readErr := os.ReadFile(opts.SubagentTranscriptPath)\\n\\t\\tif readErr == nil {\\n\\t\\t\\t// Try JSONL-aware redaction first; fall back to plain string redaction\\n\\t\\t\\t// if the content is not valid JSONL (avoids silently dropping the transcript).\\n\\t\\t\\tredacted, jsonlErr := redact.JSONLBytes(agentContent)\\n\\t\\t\\tif jsonlErr != nil {\\n\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"subagent transcript is not valid JSONL, falling back to plain redaction\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"path\\\", opts.SubagentTranscriptPath),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", jsonlErr.Error()),\\n\\t\\t\\t\\t)\\n\\t\\t\\t\\tredacted = redact.Bytes(agentContent)\\n\\t\\t\\t}\\n\\t\\t\\tagentContent = redacted\\n\\n\\t\\t\\tagentBlobHash, agentBlobErr := CreateBlobFromContent(s.repo, agentContent)\\n\\t\\t\\tif agentBlobErr == nil {\\n\\t\\t\\t\\tagentPath := taskPath + \\\"agent-\\\" + opts.AgentID + \\\".jsonl\\\"\\n\\t\\t\\t\\tentries[agentPath] = object.TreeEntry{\\n\\t\\t\\t\\t\\tName: agentPath,\\n\\t\\t\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\t\\t\\tHash: agentBlobHash,\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Return task path without trailing slash\\n\\treturn taskPath[:len(taskPath)-1], nil\\n}\\n\\n// writeStandardCheckpointEntries writes session files to numbered subdirectories and\\n// maintains a CheckpointSummary at the root level with aggregated statistics.\\n//\\n// Structure:\\n//\\n//\\tbasePath/\\n//\\t├── metadata.json         # CheckpointSummary (aggregated stats)\\n//\\t├── 1/                    # First session\\n//\\t│   ├── metadata.json     # CommittedMetadata (session-specific, includes initial_attribution)\\n//\\t│   ├── full.jsonl\\n//\\t│   ├── prompt.txt\\n//\\t│   ├── context.md\\n//\\t│   └── content_hash.txt\\n//\\t├── 2/                    # Second session\\n//\\t└── ...\\nfunc (s *GitStore) writeStandardCheckpointEntries(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry) error {\\n\\t// Read existing summary to get current session count\\n\\tvar existingSummary *CheckpointSummary\\n\\tmetadataPath := basePath + paths.MetadataFileName\\n\\tif entry, exists := entries[metadataPath]; exists {\\n\\t\\texisting, err := s.readSummaryFromBlob(entry.Hash)\\n\\t\\tif err == nil {\\n\\t\\t\\texistingSummary = existing\\n\\t\\t}\\n\\t}\\n\\n\\t// Determine session index: reuse existing slot if session ID matches, otherwise append\\n\\tsessionIndex := s.findSessionIndex(basePath, existingSummary, entries, opts.SessionID)\\n\\n\\t// Write session files to numbered subdirectory\\n\\tsessionPath := fmt.Sprintf(\\\"%s%d/\\\", basePath, sessionIndex)\\n\\tsessionFilePaths, err := s.writeSessionToSubdirectory(opts, sessionPath, entries)\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Copy additional metadata files from directory if specified (to session subdirectory)\\n\\tif opts.MetadataDir != \\\"\\\" {\\n\\t\\tif err := s.copyMetadataDir(opts.MetadataDir, sessionPath, entries); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to copy metadata directory: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// Build the sessions array\\n\\tvar sessions []SessionFilePaths\\n\\tif existingSummary != nil {\\n\\t\\tsessions = make([]SessionFilePaths, max(len(existingSummary.Sessions), sessionIndex+1))\\n\\t\\tcopy(sessions, existingSummary.Sessions)\\n\\t} else {\\n\\t\\tsessions = make([]SessionFilePaths, 1)\\n\\t}\\n\\tsessions[sessionIndex] = sessionFilePaths\\n\\n\\t// Update root metadata.json with CheckpointSummary\\n\\treturn s.writeCheckpointSummary(opts, basePath, entries, sessions)\\n}\\n\\n// writeSessionToSubdirectory writes a single session's files to a numbered subdirectory.\\n// Returns the absolute file paths from the git tree root for the sessions map.\\nfunc (s *GitStore) writeSessionToSubdirectory(opts WriteCommittedOptions, sessionPath string, entries map[string]object.TreeEntry) (SessionFilePaths, error) {\\n\\tfilePaths := SessionFilePaths{}\\n\\n\\t// Clear any existing entries at this path so stale files from a previous\\n\\t// write (e.g. prompt.txt, context.md) don't persist on overwrite.\\n\\tfor key := range entries {\\n\\t\\tif strings.HasPrefix(key, sessionPath) {\\n\\t\\t\\tdelete(entries, key)\\n\\t\\t}\\n\\t}\\n\\n\\t// Write transcript\\n\\tif err := s.writeTranscript(opts, sessionPath, entries); err != nil {\\n\\t\\treturn filePaths, err\\n\\t}\\n\\tfilePaths.Transcript = \\\"/\\\" + sessionPath + paths.TranscriptFileName\\n\\tfilePaths.ContentHash = \\\"/\\\" + sessionPath + paths.ContentHashFileName\\n\\n\\t// Write prompts\\n\\tif len(opts.Prompts) > 0 {\\n\\t\\tpromptContent := redact.String(strings.Join(opts.Prompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\"))\\n\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(promptContent))\\n\\t\\tif err != nil {\\n\\t\\t\\treturn filePaths, err\\n\\t\\t}\\n\\t\\tentries[sessionPath+paths.PromptFileName] = object.TreeEntry{\\n\\t\\t\\tName: sessionPath + paths.PromptFileName,\\n\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\tHash: blobHash,\\n\\t\\t}\\n\\t\\tfilePaths.Prompt = \\\"/\\\" + sessionPath + paths.PromptFileName\\n\\t}\\n\\n\\t// Write context\\n\\tif len(opts.Context) > 0 {\\n\\t\\tblobHash, err := CreateBlobFromContent(s.repo, redact.Bytes(opts.Context))\\n\\t\\tif err != nil {\\n\\t\\t\\treturn filePaths, err\\n\\t\\t}\\n\\t\\tentries[sessionPath+paths.ContextFileName] = object.TreeEntry{\\n\\t\\t\\tName: sessionPath + paths.ContextFileName,\\n\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\tHash: blobHash,\\n\\t\\t}\\n\\t\\tfilePaths.Context = \\\"/\\\" + sessionPath + paths.ContextFileName\\n\\t}\\n\\n\\t// Write session-level metadata.json (CommittedMetadata with all fields including initial_attribution)\\n\\tsessionMetadata := CommittedMetadata{\\n\\t\\tCheckpointID:                opts.CheckpointID,\\n\\t\\tSessionID:                   opts.SessionID,\\n\\t\\tStrategy:                    opts.Strategy,\\n\\t\\tCreatedAt:                   time.Now().UTC(),\\n\\t\\tBranch:                      opts.Branch,\\n\\t\\tCheckpointsCount:            opts.CheckpointsCount,\\n\\t\\tFilesTouched:                opts.FilesTouched,\\n\\t\\tAgent:                       opts.Agent,\\n\\t\\tTurnID:                      opts.TurnID,\\n\\t\\tIsTask:                      opts.IsTask,\\n\\t\\tToolUseID:                   opts.ToolUseID,\\n\\t\\tTranscriptIdentifierAtStart: opts.TranscriptIdentifierAtStart,\\n\\t\\tCheckpointTranscriptStart:   opts.CheckpointTranscriptStart,\\n\\t\\tTranscriptLinesAtStart:      opts.CheckpointTranscriptStart, // Deprecated: kept for backward compat\\n\\t\\tTokenUsage:                  opts.TokenUsage,\\n\\t\\tInitialAttribution:          opts.InitialAttribution,\\n\\t\\tSummary:                     redactSummary(opts.Summary),\\n\\t\\tCLIVersion:                  buildinfo.Version,\\n\\t}\\n\\n\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(sessionMetadata, \\\"\\\", \\\"  \\\")\\n\\tif err != nil {\\n\\t\\treturn filePaths, fmt.Errorf(\\\"failed to marshal session metadata: %w\\\", err)\\n\\t}\\n\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n\\tif err != nil {\\n\\t\\treturn filePaths, err\\n\\t}\\n\\tentries[sessionPath+paths.MetadataFileName] = object.TreeEntry{\\n\\t\\tName: sessionPath + paths.MetadataFileName,\\n\\t\\tMode: filemode.Regular,\\n\\t\\tHash: metadataHash,\\n\\t}\\n\\tfilePaths.Metadata = \\\"/\\\" + sessionPath + paths.MetadataFileName\\n\\n\\treturn filePaths, nil\\n}\\n\\n// writeCheckpointSummary writes the root-level CheckpointSummary with aggregated statistics.\\n// sessions is the complete sessions array (already built by the caller).\\nfunc (s *GitStore) writeCheckpointSummary(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry, sessions []SessionFilePaths) error {\\n\\tcheckpointsCount, filesTouched, tokenUsage, err :=\\n\\t\\ts.reaggregateFromEntries(basePath, len(sessions), entries)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to aggregate session stats: %w\\\", err)\\n\\t}\\n\\n\\tsummary := CheckpointSummary{\\n\\t\\tCheckpointID:     opts.CheckpointID,\\n\\t\\tCLIVersion:       buildinfo.Version,\\n\\t\\tStrategy:         opts.Strategy,\\n\\t\\tBranch:           opts.Branch,\\n\\t\\tCheckpointsCount: checkpointsCount,\\n\\t\\tFilesTouched:     filesTouched,\\n\\t\\tSessions:         sessions,\\n\\t\\tTokenUsage:       tokenUsage,\\n\\t}\\n\\n\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(summary, \\\"\\\", \\\"  \\\")\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to marshal checkpoint summary: %w\\\", err)\\n\\t}\\n\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\tentries[basePath+paths.MetadataFileName] = object.TreeEntry{\\n\\t\\tName: basePath + paths.MetadataFileName,\\n\\t\\tMode: filemode.Regular,\\n\\t\\tHash: metadataHash,\\n\\t}\\n\\treturn nil\\n}\\n\\n// findSessionIndex returns the index of an existing session with the given ID,\\n// or the next available index if not found. This prevents duplicate session entries.\\nfunc (s *GitStore) findSessionIndex(basePath string, existingSummary *CheckpointSummary, entries map[string]object.TreeEntry, sessionID string) int {\\n\\tif existingSummary == nil {\\n\\t\\treturn 0\\n\\t}\\n\\tfor i := range len(existingSummary.Sessions) {\\n\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n\\t\\tif entry, exists := entries[path]; exists {\\n\\t\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to read session metadata during dedup check\\\",\\n\\t\\t\\t\\t\\tslog.Int(\\\"session_index\\\", i),\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n\\t\\t\\t\\t)\\n\\t\\t\\t\\tcontinue\\n\\t\\t\\t}\\n\\t\\t\\tif meta.SessionID == sessionID {\\n\\t\\t\\t\\treturn i\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\treturn len(existingSummary.Sessions)\\n}\\n\\n// reaggregateFromEntries reads all session metadata from the entries map and\\n// reaggregates CheckpointsCount, FilesTouched, and TokenUsage.\\nfunc (s *GitStore) reaggregateFromEntries(basePath string, sessionCount int, entries map[string]object.TreeEntry) (int, []string, *agent.TokenUsage, error) {\\n\\tvar totalCount int\\n\\tvar allFiles []string\\n\\tvar totalTokens *agent.TokenUsage\\n\\n\\tfor i := range sessionCount {\\n\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n\\t\\tentry, exists := entries[path]\\n\\t\\tif !exists {\\n\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"session %d metadata not found at %s\\\", i, path)\\n\\t\\t}\\n\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"failed to read session %d metadata: %w\\\", i, err)\\n\\t\\t}\\n\\t\\ttotalCount += meta.CheckpointsCount\\n\\t\\tallFiles = mergeFilesTouched(allFiles, meta.FilesTouched)\\n\\t\\ttotalTokens = aggregateTokenUsage(totalTokens, meta.TokenUsage)\\n\\t}\\n\\n\\treturn totalCount, allFiles, totalTokens, nil\\n}\\n\\n// readJSONFromBlob reads JSON from a blob hash and decodes it to the given type.\\nfunc readJSONFromBlob[T any](repo *git.Repository, hash plumbing.Hash) (*T, error) {\\n\\tblob, err := repo.BlobObject(hash)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob: %w\\\", err)\\n\\t}\\n\\n\\treader, err := blob.Reader()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob reader: %w\\\", err)\\n\\t}\\n\\tdefer reader.Close()\\n\\n\\tvar result T\\n\\tif err := json.NewDecoder(reader).Decode(&result); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to decode: %w\\\", err)\\n\\t}\\n\\n\\treturn &result, nil\\n}\\n\\n// readSummaryFromBlob reads CheckpointSummary from a blob hash.\\nfunc (s *GitStore) readSummaryFromBlob(hash plumbing.Hash) (*CheckpointSummary, error) {\\n\\treturn readJSONFromBlob[CheckpointSummary](s.repo, hash)\\n}\\n\\n// aggregateTokenUsage sums two TokenUsage structs.\\n// Returns nil if both inputs are nil.\\nfunc aggregateTokenUsage(a, b *agent.TokenUsage) *agent.TokenUsage {\\n\\tif a == nil && b == nil {\\n\\t\\treturn nil\\n\\t}\\n\\tresult := &agent.TokenUsage{}\\n\\tif a != nil {\\n\\t\\tresult.InputTokens = a.InputTokens\\n\\t\\tresult.CacheCreationTokens = a.CacheCreationTokens\\n\\t\\tresult.CacheReadTokens = a.CacheReadTokens\\n\\t\\tresult.OutputTokens = a.OutputTokens\\n\\t\\tresult.APICallCount = a.APICallCount\\n\\t}\\n\\tif b != nil {\\n\\t\\tresult.InputTokens += b.InputTokens\\n\\t\\tresult.CacheCreationTokens += b.CacheCreationTokens\\n\\t\\tresult.CacheReadTokens += b.CacheReadTokens\\n\\t\\tresult.OutputTokens += b.OutputTokens\\n\\t\\tresult.APICallCount += b.APICallCount\\n\\t}\\n\\treturn result\\n}\\n\\n// writeTranscript writes the transcript file from in-memory content or file path.\\n// If the transcript exceeds MaxChunkSize, it's split into multiple chunk files.\\nfunc (s *GitStore) writeTranscript(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry) error {\\n\\ttranscript := opts.Transcript\\n\\tif len(transcript) == 0 && opts.TranscriptPath != \\\"\\\" {\\n\\t\\tvar readErr error\\n\\t\\ttranscript, readErr = os.ReadFile(opts.TranscriptPath)\\n\\t\\tif readErr != nil {\\n\\t\\t\\t// Non-fatal: transcript may not exist yet\\n\\t\\t\\ttranscript = nil\\n\\t\\t}\\n\\t}\\n\\tif len(transcript) == 0 {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Redact secrets before chunking so content hash reflects redacted content\\n\\ttranscript, err := redact.JSONLBytes(transcript)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to redact transcript secrets: %w\\\", err)\\n\\t}\\n\\n\\t// Chunk the transcript if it's too large\\n\\tchunks, err := agent.ChunkTranscript(transcript, opts.Agent)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n\\t}\\n\\n\\t// Write chunk files\\n\\tfor i, chunk := range chunks {\\n\\t\\tchunkPath := basePath + agent.ChunkFileName(paths.TranscriptFileName, i)\\n\\t\\tblobHash, err := CreateBlobFromContent(s.repo, chunk)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn err\\n\\t\\t}\\n\\t\\tentries[chunkPath] = object.TreeEntry{\\n\\t\\t\\tName: chunkPath,\\n\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\tHash: blobHash,\\n\\t\\t}\\n\\t}\\n\\n\\t// Content hash for deduplication (hash of full transcript)\\n\\tcontentHash := fmt.Sprintf(\\\"sha256:%x\\\", sha256.Sum256(transcript))\\n\\thashBlob, err := CreateBlobFromContent(s.repo, []byte(contentHash))\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\tentries[basePath+paths.ContentHashFileName] = object.TreeEntry{\\n\\t\\tName: basePath + paths.ContentHashFileName,\\n\\t\\tMode: filemode.Regular,\\n\\t\\tHash: hashBlob,\\n\\t}\\n\\treturn nil\\n}\\n\\n// mergeFilesTouched combines two file lists, removing duplicates.\\nfunc mergeFilesTouched(existing, additional []string) []string {\\n\\tseen := make(map[string]bool)\\n\\tvar result []string\\n\\n\\tfor _, f := range existing {\\n\\t\\tif !seen[f] {\\n\\t\\t\\tseen[f] = true\\n\\t\\t\\tresult = append(result, f)\\n\\t\\t}\\n\\t}\\n\\tfor _, f := range additional {\\n\\t\\tif !seen[f] {\\n\\t\\t\\tseen[f] = true\\n\\t\\t\\tresult = append(result, f)\\n\\t\\t}\\n\\t}\\n\\n\\tsort.Strings(result)\\n\\treturn result\\n}\\n\\n// redactSummary returns a copy of the summary with text fields redacted.\\n// Structural fields (Path, Line, EndLine) are preserved.\\n// NOTE: When adding new text fields to Summary, LearningsSummary, or CodeLearning,\\n// update this function to include them in redaction.\\nfunc redactSummary(s *Summary) *Summary {\\n\\tif s == nil {\\n\\t\\treturn nil\\n\\t}\\n\\treturn &Summary{\\n\\t\\tIntent:    redact.String(s.Intent),\\n\\t\\tOutcome:   redact.String(s.Outcome),\\n\\t\\tFriction:  redactStringSlice(s.Friction),\\n\\t\\tOpenItems: redactStringSlice(s.OpenItems),\\n\\t\\tLearnings: LearningsSummary{\\n\\t\\t\\tRepo:     redactStringSlice(s.Learnings.Repo),\\n\\t\\t\\tWorkflow: redactStringSlice(s.Learnings.Workflow),\\n\\t\\t\\tCode:     redactCodeLearnings(s.Learnings.Code),\\n\\t\\t},\\n\\t}\\n}\\n\\n// redactStringSlice applies redact.String to each element.\\nfunc redactStringSlice(ss []string) []string {\\n\\tif ss == nil {\\n\\t\\treturn nil\\n\\t}\\n\\tout := make([]string, len(ss))\\n\\tfor i, s := range ss {\\n\\t\\tout[i] = redact.String(s)\\n\\t}\\n\\treturn out\\n}\\n\\n// redactCodeLearnings redacts only the Finding field, preserving Path/Line/EndLine.\\nfunc redactCodeLearnings(cls []CodeLearning) []CodeLearning {\\n\\tif cls == nil {\\n\\t\\treturn nil\\n\\t}\\n\\tout := make([]CodeLearning, len(cls))\\n\\tfor i, cl := range cls {\\n\\t\\tout[i] = CodeLearning{\\n\\t\\t\\tPath:    cl.Path,\\n\\t\\t\\tLine:    cl.Line,\\n\\t\\t\\tEndLine: cl.EndLine,\\n\\t\\t\\tFinding: redact.String(cl.Finding),\\n\\t\\t}\\n\\t}\\n\\treturn out\\n}\\n\\n// readMetadataFromBlob reads CommittedMetadata from a blob hash.\\nfunc (s *GitStore) readMetadataFromBlob(hash plumbing.Hash) (*CommittedMetadata, error) {\\n\\treturn readJSONFromBlob[CommittedMetadata](s.repo, hash)\\n}\\n\\n// buildCommitMessage constructs the commit message with proper trailers.\\n// The commit subject is always \\\"Checkpoint: <id>\\\" for consistency.\\n// If CommitSubject is provided (e.g., for task checkpoints), it's included in the body.\\nfunc (s *GitStore) buildCommitMessage(opts WriteCommittedOptions, taskMetadataPath string) string {\\n\\tvar commitMsg strings.Builder\\n\\n\\t// Subject line is always the checkpoint ID for consistent formatting\\n\\tcommitMsg.WriteString(fmt.Sprintf(\\\"Checkpoint: %s\\\\n\\\\n\\\", opts.CheckpointID))\\n\\n\\t// Include custom description in body if provided (e.g., task checkpoint details)\\n\\tif opts.CommitSubject != \\\"\\\" {\\n\\t\\tcommitMsg.WriteString(opts.CommitSubject + \\\"\\\\n\\\\n\\\")\\n\\t}\\n\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.SessionTrailerKey, opts.SessionID))\\n\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.StrategyTrailerKey, opts.Strategy))\\n\\tif opts.Agent != \\\"\\\" {\\n\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.AgentTrailerKey, opts.Agent))\\n\\t}\\n\\tif opts.EphemeralBranch != \\\"\\\" {\\n\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.EphemeralBranchTrailerKey, opts.EphemeralBranch))\\n\\t}\\n\\tif taskMetadataPath != \\\"\\\" {\\n\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.MetadataTaskTrailerKey, taskMetadataPath))\\n\\t}\\n\\n\\treturn commitMsg.String()\\n}\\n\\n// incrementalCheckpointData represents an incremental checkpoint during subagent execution.\\n// This mirrors strategy.SubagentCheckpoint but avoids import cycles.\\ntype incrementalCheckpointData struct {\\n\\tType      string          `json:\\\"type\\\"`\\n\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n\\tData      json.RawMessage `json:\\\"data\\\"`\\n}\\n\\n// taskCheckpointData represents a final task checkpoint.\\n// This mirrors strategy.TaskCheckpoint but avoids import cycles.\\ntype taskCheckpointData struct {\\n\\tSessionID      string `json:\\\"session_id\\\"`\\n\\tToolUseID      string `json:\\\"tool_use_id\\\"`\\n\\tCheckpointUUID string `json:\\\"checkpoint_uuid\\\"`\\n\\tAgentID        string `json:\\\"agent_id,omitempty\\\"`\\n}\\n\\n// ReadCommitted reads a committed checkpoint's summary by ID from the entire/checkpoints/v1 branch.\\n// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n// Use ReadSessionContent to read actual transcript/prompts/context.\\n// Returns nil, nil if the checkpoint doesn't exist.\\n//\\n// The storage format uses numbered subdirectories for each session (0-based):\\n//\\n//\\t<checkpoint-id>/\\n//\\t├── metadata.json      # CheckpointSummary with sessions map\\n//\\t├── 0/                 # First session\\n//\\t│   ├── metadata.json  # Session-specific metadata\\n//\\t│   └── full.jsonl     # Transcript\\n//\\t├── 1/                 # Second session\\n//\\t└── ...\\nfunc (s *GitStore) ReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error) {\\n\\t_ = ctx // Reserved for future use\\n\\n\\ttree, err := s.getSessionsBranchTree()\\n\\tif err != nil {\\n\\t\\treturn nil, nil //nolint:nilnil,nilerr // No sessions branch means no checkpoint exists\\n\\t}\\n\\n\\tcheckpointPath := checkpointID.Path()\\n\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n\\tif err != nil {\\n\\t\\treturn nil, nil //nolint:nilnil,nilerr // Checkpoint directory not found\\n\\t}\\n\\n\\t// Read root metadata.json as CheckpointSummary\\n\\tmetadataFile, err := checkpointTree.File(paths.MetadataFileName)\\n\\tif err != nil {\\n\\t\\treturn nil, nil //nolint:nilnil,nilerr // metadata.json not found\\n\\t}\\n\\n\\tcontent, err := metadataFile.Contents()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata.json: %w\\\", err)\\n\\t}\\n\\n\\tvar summary CheckpointSummary\\n\\tif err := json.Unmarshal([]byte(content), &summary); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata.json: %w\\\", err)\\n\\t}\\n\\n\\treturn &summary, nil\\n}\\n\\n// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n// Returns the session's metadata, transcript, prompts, and context.\\n// Returns an error if the checkpoint or session doesn't exist.\\nfunc (s *GitStore) ReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error) {\\n\\t_ = ctx // Reserved for future use\\n\\n\\ttree, err := s.getSessionsBranchTree()\\n\\tif err != nil {\\n\\t\\treturn nil, ErrCheckpointNotFound\\n\\t}\\n\\n\\tcheckpointPath := checkpointID.Path()\\n\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n\\tif err != nil {\\n\\t\\treturn nil, ErrCheckpointNotFound\\n\\t}\\n\\n\\t// Get the session subdirectory\\n\\tsessionDir := strconv.Itoa(sessionIndex)\\n\\tsessionTree, err := checkpointTree.Tree(sessionDir)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"session %d not found: %w\\\", sessionIndex, err)\\n\\t}\\n\\n\\tresult := &SessionContent{}\\n\\n\\t// Read session-specific metadata\\n\\tvar agentType agent.AgentType\\n\\tif metadataFile, fileErr := sessionTree.File(paths.MetadataFileName); fileErr == nil {\\n\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n\\t\\t\\tif jsonErr := json.Unmarshal([]byte(content), &result.Metadata); jsonErr == nil {\\n\\t\\t\\t\\tagentType = result.Metadata.Agent\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Read transcript\\n\\tif transcript, transcriptErr := readTranscriptFromTree(sessionTree, agentType); transcriptErr == nil && transcript != nil {\\n\\t\\tresult.Transcript = transcript\\n\\t}\\n\\n\\t// Read prompts\\n\\tif file, fileErr := sessionTree.File(paths.PromptFileName); fileErr == nil {\\n\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\tresult.Prompts = content\\n\\t\\t}\\n\\t}\\n\\n\\t// Read context\\n\\tif file, fileErr := sessionTree.File(paths.ContextFileName); fileErr == nil {\\n\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\tresult.Context = content\\n\\t\\t}\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// ReadLatestSessionContent is a convenience method that reads the latest session's content.\\n// This is equivalent to ReadSessionContent(ctx, checkpointID, len(summary.Sessions)-1).\\nfunc (s *GitStore) ReadLatestSessionContent(ctx context.Context, checkpointID id.CheckpointID) (*SessionContent, error) {\\n\\tsummary, err := s.ReadCommitted(ctx, checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\tif summary == nil {\\n\\t\\treturn nil, ErrCheckpointNotFound\\n\\t}\\n\\tif len(summary.Sessions) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint has no sessions: %s\\\", checkpointID)\\n\\t}\\n\\n\\tlatestIndex := len(summary.Sessions) - 1\\n\\treturn s.ReadSessionContent(ctx, checkpointID, latestIndex)\\n}\\n\\n// ReadSessionContentByID reads a session's content by its session ID.\\n// This is useful when you have the session ID but don't know its index within the checkpoint.\\n// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n// Returns an error if no session with the given ID exists in the checkpoint.\\nfunc (s *GitStore) ReadSessionContentByID(ctx context.Context, checkpointID id.CheckpointID, sessionID string) (*SessionContent, error) {\\n\\tsummary, err := s.ReadCommitted(ctx, checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\tif summary == nil {\\n\\t\\treturn nil, ErrCheckpointNotFound\\n\\t}\\n\\n\\t// Iterate through sessions to find the one with matching session ID\\n\\tfor i := range len(summary.Sessions) {\\n\\t\\tcontent, readErr := s.ReadSessionContent(ctx, checkpointID, i)\\n\\t\\tif readErr != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tif content != nil && content.Metadata.SessionID == sessionID {\\n\\t\\t\\treturn content, nil\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil, fmt.Errorf(\\\"session %q not found in checkpoint %s\\\", sessionID, checkpointID)\\n}\\n\\n// ListCommitted lists all committed checkpoints from the entire/checkpoints/v1 branch.\\n// Scans sharded paths: <id[:2]>/<id[2:]>/ directories containing metadata.json.\\n//\\n\\nfunc (s *GitStore) ListCommitted(ctx context.Context) ([]CommittedInfo, error) {\\n\\t_ = ctx // Reserved for future use\\n\\n\\ttree, err := s.getSessionsBranchTree()\\n\\tif err != nil {\\n\\t\\treturn []CommittedInfo{}, nil //nolint:nilerr // No sessions branch means empty list\\n\\t}\\n\\n\\tvar checkpoints []CommittedInfo\\n\\n\\t// Scan sharded structure: <2-char-prefix>/<remaining-id>/metadata.json\\n\\tfor _, bucketEntry := range tree.Entries {\\n\\t\\tif bucketEntry.Mode != filemode.Dir {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\t// Bucket should be 2 hex chars\\n\\t\\tif len(bucketEntry.Name) != 2 {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tbucketTree, treeErr := s.repo.TreeObject(bucketEntry.Hash)\\n\\t\\tif treeErr != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Each entry in the bucket is the remaining part of the checkpoint ID\\n\\t\\tfor _, checkpointEntry := range bucketTree.Entries {\\n\\t\\t\\tif checkpointEntry.Mode != filemode.Dir {\\n\\t\\t\\t\\tcontinue\\n\\t\\t\\t}\\n\\n\\t\\t\\tcheckpointTree, cpTreeErr := s.repo.TreeObject(checkpointEntry.Hash)\\n\\t\\t\\tif cpTreeErr != nil {\\n\\t\\t\\t\\tcontinue\\n\\t\\t\\t}\\n\\n\\t\\t\\t// Reconstruct checkpoint ID: <bucket><remaining>\\n\\t\\t\\tcheckpointIDStr := bucketEntry.Name + checkpointEntry.Name\\n\\t\\t\\tcheckpointID, cpIDErr := id.NewCheckpointID(checkpointIDStr)\\n\\t\\t\\tif cpIDErr != nil {\\n\\t\\t\\t\\t// Skip invalid checkpoint IDs (shouldn't happen with our own data)\\n\\t\\t\\t\\tcontinue\\n\\t\\t\\t}\\n\\n\\t\\t\\tinfo := CommittedInfo{\\n\\t\\t\\t\\tCheckpointID: checkpointID,\\n\\t\\t\\t}\\n\\n\\t\\t\\t// Get details from root metadata file (CheckpointSummary format)\\n\\t\\t\\tif metadataFile, fileErr := checkpointTree.File(paths.MetadataFileName); fileErr == nil {\\n\\t\\t\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n\\t\\t\\t\\t\\tvar summary CheckpointSummary\\n\\t\\t\\t\\t\\tif err := json.Unmarshal([]byte(content), &summary); err == nil {\\n\\t\\t\\t\\t\\t\\tinfo.CheckpointsCount = summary.CheckpointsCount\\n\\t\\t\\t\\t\\t\\tinfo.FilesTouched = summary.FilesTouched\\n\\t\\t\\t\\t\\t\\tinfo.SessionCount = len(summary.Sessions)\\n\\n\\t\\t\\t\\t\\t\\t// Read session metadata from latest session to get Agent, SessionID, CreatedAt\\n\\t\\t\\t\\t\\t\\tif len(summary.Sessions) > 0 {\\n\\t\\t\\t\\t\\t\\t\\tlatestIndex := len(summary.Sessions) - 1\\n\\t\\t\\t\\t\\t\\t\\tlatestDir := strconv.Itoa(latestIndex)\\n\\t\\t\\t\\t\\t\\t\\tif sessionTree, treeErr := checkpointTree.Tree(latestDir); treeErr == nil {\\n\\t\\t\\t\\t\\t\\t\\t\\tif sessionMetadataFile, smErr := sessionTree.File(paths.MetadataFileName); smErr == nil {\\n\\t\\t\\t\\t\\t\\t\\t\\t\\tif sessionContent, scErr := sessionMetadataFile.Contents(); scErr == nil {\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata CommittedMetadata\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\n\\t\\t\\tcheckpoints = append(checkpoints, info)\\n\\t\\t}\\n\\t}\\n\\n\\t// Sort by time (most recent first)\\n\\tsort.Slice(checkpoints, func(i, j int) bool {\\n\\t\\treturn checkpoints[i].CreatedAt.After(checkpoints[j].CreatedAt)\\n\\t})\\n\\n\\treturn checkpoints, nil\\n}\\n\\n// GetTranscript retrieves the transcript for a specific checkpoint ID.\\n// Returns the latest session's transcript.\\nfunc (s *GitStore) GetTranscript(ctx context.Context, checkpointID id.CheckpointID) ([]byte, error) {\\n\\tcontent, err := s.ReadLatestSessionContent(ctx, checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\treturn content.Transcript, nil\\n}\\n\\n// GetSessionLog retrieves the session transcript and session ID for a checkpoint.\\n// This is the primary method for looking up session logs by checkpoint ID.\\n// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n// Returns ErrNoTranscript if the checkpoint exists but has no transcript.\\nfunc (s *GitStore) GetSessionLog(cpID id.CheckpointID) ([]byte, string, error) {\\n\\tcontent, err := s.ReadLatestSessionContent(context.Background(), cpID)\\n\\tif err != nil {\\n\\t\\tif errors.Is(err, ErrCheckpointNotFound) {\\n\\t\\t\\treturn nil, \\\"\\\", ErrCheckpointNotFound\\n\\t\\t}\\n\\t\\treturn nil, \\\"\\\", fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, \\\"\\\", ErrNoTranscript\\n\\t}\\n\\treturn content.Transcript, content.Metadata.SessionID, nil\\n}\\n\\n// LookupSessionLog is a convenience function that opens the repository and retrieves\\n// a session log by checkpoint ID. This is the primary entry point for callers that\\n// don't already have a GitStore instance.\\n// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n// Returns ErrNoTranscript if the checkpoint exists but has no transcript.\\nfunc LookupSessionLog(cpID id.CheckpointID) ([]byte, string, error) {\\n\\trepo, err := git.PlainOpenWithOptions(\\\".\\\", &git.PlainOpenOptions{DetectDotGit: true})\\n\\tif err != nil {\\n\\t\\treturn nil, \\\"\\\", fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n\\t}\\n\\tstore := NewGitStore(repo)\\n\\treturn store.GetSessionLog(cpID)\\n}\\n\\n// UpdateSummary updates the summary field in the latest session's metadata.\\n// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\nfunc (s *GitStore) UpdateSummary(ctx context.Context, checkpointID id.CheckpointID, summary *Summary) error {\\n\\t_ = ctx // Reserved for future use\\n\\n\\t// Ensure sessions branch exists\\n\\tif err := s.ensureSessionsBranch(); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to ensure sessions branch: %w\\\", err)\\n\\t}\\n\\n\\t// Get current branch tip and flatten tree\\n\\tref, entries, err := s.getSessionsBranchEntries()\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Read root CheckpointSummary to find the latest session\\n\\tbasePath := checkpointID.Path() + \\\"/\\\"\\n\\trootMetadataPath := basePath + paths.MetadataFileName\\n\\tentry, exists := entries[rootMetadataPath]\\n\\tif !exists {\\n\\t\\treturn ErrCheckpointNotFound\\n\\t}\\n\\n\\tcheckpointSummary, err := s.readSummaryFromBlob(entry.Hash)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint summary: %w\\\", err)\\n\\t}\\n\\n\\t// Find the latest session's metadata path (0-based indexing)\\n\\tlatestIndex := len(checkpointSummary.Sessions) - 1\\n\\tsessionMetadataPath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, latestIndex, paths.MetadataFileName)\\n\\tsessionEntry, exists := entries[sessionMetadataPath]\\n\\tif !exists {\\n\\t\\treturn fmt.Errorf(\\\"session metadata not found at %s\\\", sessionMetadataPath)\\n\\t}\\n\\n\\t// Read and update session metadata\\n\\texistingMetadata, err := s.readMetadataFromBlob(sessionEntry.Hash)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to read session metadata: %w\\\", err)\\n\\t}\\n\\n\\t// Update the summary\\n\\texistingMetadata.Summary = redactSummary(summary)\\n\\n\\t// Write updated session metadata\\n\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(existingMetadata, \\\"\\\", \\\"  \\\")\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to marshal metadata: %w\\\", err)\\n\\t}\\n\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create metadata blob: %w\\\", err)\\n\\t}\\n\\tentries[sessionMetadataPath] = object.TreeEntry{\\n\\t\\tName: sessionMetadataPath,\\n\\t\\tMode: filemode.Regular,\\n\\t\\tHash: metadataHash,\\n\\t}\\n\\n\\t// Build and commit\\n\\tnewTreeHash, err := BuildTreeFromEntries(s.repo, entries)\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n\\tcommitMsg := fmt.Sprintf(\\\"Update summary for checkpoint %s (session: %s)\\\", checkpointID, existingMetadata.SessionID)\\n\\tnewCommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, authorName, authorEmail)\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n\\tnewRef := plumbing.NewHashReference(refName, newCommitHash)\\n\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// UpdateCommitted replaces the transcript, prompts, and context for an existing\\n// committed checkpoint. Uses replace semantics: the full session transcript is\\n// written, replacing whatever was stored at initial condensation time.\\n//\\n// This is called at stop time to finalize all checkpoints from the current turn\\n// with the complete session transcript (from prompt to stop event).\\n//\\n// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\nfunc (s *GitStore) UpdateCommitted(ctx context.Context, opts UpdateCommittedOptions) error {\\n\\tif opts.CheckpointID.IsEmpty() {\\n\\t\\treturn errors.New(\\\"invalid update options: checkpoint ID is required\\\")\\n\\t}\\n\\n\\t// Ensure sessions branch exists\\n\\tif err := s.ensureSessionsBranch(); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to ensure sessions branch: %w\\\", err)\\n\\t}\\n\\n\\t// Get current branch tip and flatten tree\\n\\tref, entries, err := s.getSessionsBranchEntries()\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Read root CheckpointSummary to find the session slot\\n\\tbasePath := opts.CheckpointID.Path() + \\\"/\\\"\\n\\trootMetadataPath := basePath + paths.MetadataFileName\\n\\tentry, exists := entries[rootMetadataPath]\\n\\tif !exists {\\n\\t\\treturn ErrCheckpointNotFound\\n\\t}\\n\\n\\tcheckpointSummary, err := s.readSummaryFromBlob(entry.Hash)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint summary: %w\\\", err)\\n\\t}\\n\\tif len(checkpointSummary.Sessions) == 0 {\\n\\t\\treturn ErrCheckpointNotFound\\n\\t}\\n\\n\\t// Find session index matching opts.SessionID\\n\\tsessionIndex := -1\\n\\tfor i := range len(checkpointSummary.Sessions) {\\n\\t\\tmetaPath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n\\t\\tif metaEntry, metaExists := entries[metaPath]; metaExists {\\n\\t\\t\\tmeta, metaErr := s.readMetadataFromBlob(metaEntry.Hash)\\n\\t\\t\\tif metaErr == nil && meta.SessionID == opts.SessionID {\\n\\t\\t\\t\\tsessionIndex = i\\n\\t\\t\\t\\tbreak\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\tif sessionIndex == -1 {\\n\\t\\t// Fall back to latest session; log so mismatches are diagnosable.\\n\\t\\tsessionIndex = len(checkpointSummary.Sessions) - 1\\n\\t\\tlogging.Debug(ctx, \\\"UpdateCommitted: session ID not found, falling back to latest\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n\\t\\t\\tslog.String(\\\"checkpoint_id\\\", string(opts.CheckpointID)),\\n\\t\\t\\tslog.Int(\\\"fallback_index\\\", sessionIndex),\\n\\t\\t)\\n\\t}\\n\\n\\tsessionPath := fmt.Sprintf(\\\"%s%d/\\\", basePath, sessionIndex)\\n\\n\\t// Replace transcript (full replace, not append)\\n\\t// Apply redaction as safety net (caller should redact, but we ensure it here)\\n\\tif len(opts.Transcript) > 0 {\\n\\t\\ttranscript, err := redact.JSONLBytes(opts.Transcript)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to redact transcript secrets: %w\\\", err)\\n\\t\\t}\\n\\t\\tif err := s.replaceTranscript(transcript, opts.Agent, sessionPath, entries); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to replace transcript: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// Replace prompts (apply redaction as safety net)\\n\\tif len(opts.Prompts) > 0 {\\n\\t\\tpromptContent := redact.String(strings.Join(opts.Prompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\"))\\n\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(promptContent))\\n\\t\\tif err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to create prompt blob: %w\\\", err)\\n\\t\\t}\\n\\t\\tentries[sessionPath+paths.PromptFileName] = object.TreeEntry{\\n\\t\\t\\tName: sessionPath + paths.PromptFileName,\\n\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\tHash: blobHash,\\n\\t\\t}\\n\\t}\\n\\n\\t// Replace context (apply redaction as safety net)\\n\\tif len(opts.Context) > 0 {\\n\\t\\tcontextBlob, err := CreateBlobFromContent(s.repo, redact.Bytes(opts.Context))\\n\\t\\tif err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to create context blob: %w\\\", err)\\n\\t\\t}\\n\\t\\tentries[sessionPath+paths.ContextFileName] = object.TreeEntry{\\n\\t\\t\\tName: sessionPath + paths.ContextFileName,\\n\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\tHash: contextBlob,\\n\\t\\t}\\n\\t}\\n\\n\\t// Build and commit\\n\\tnewTreeHash, err := BuildTreeFromEntries(s.repo, entries)\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n\\tcommitMsg := fmt.Sprintf(\\\"Finalize transcript for Checkpoint: %s\\\", opts.CheckpointID)\\n\\tnewCommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, authorName, authorEmail)\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n\\tnewRef := plumbing.NewHashReference(refName, newCommitHash)\\n\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// replaceTranscript writes the full transcript content, replacing any existing transcript.\\n// Also removes any chunk files from a previous write and updates the content hash.\\nfunc (s *GitStore) replaceTranscript(transcript []byte, agentType agent.AgentType, sessionPath string, entries map[string]object.TreeEntry) error {\\n\\t// Remove existing transcript files (base + any chunks)\\n\\ttranscriptBase := sessionPath + paths.TranscriptFileName\\n\\tfor key := range entries {\\n\\t\\tif key == transcriptBase || strings.HasPrefix(key, transcriptBase+\\\".\\\") {\\n\\t\\t\\tdelete(entries, key)\\n\\t\\t}\\n\\t}\\n\\n\\t// Chunk the transcript (matches writeTranscript behavior)\\n\\tchunks, err := agent.ChunkTranscript(transcript, agentType)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n\\t}\\n\\n\\t// Write chunk files\\n\\tfor i, chunk := range chunks {\\n\\t\\tchunkPath := sessionPath + agent.ChunkFileName(paths.TranscriptFileName, i)\\n\\t\\tblobHash, err := CreateBlobFromContent(s.repo, chunk)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to create transcript blob: %w\\\", err)\\n\\t\\t}\\n\\t\\tentries[chunkPath] = object.TreeEntry{\\n\\t\\t\\tName: chunkPath,\\n\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\tHash: blobHash,\\n\\t\\t}\\n\\t}\\n\\n\\t// Update content hash\\n\\tcontentHash := fmt.Sprintf(\\\"sha256:%x\\\", sha256.Sum256(transcript))\\n\\thashBlob, err := CreateBlobFromContent(s.repo, []byte(contentHash))\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create content hash blob: %w\\\", err)\\n\\t}\\n\\thashPath := sessionPath + paths.ContentHashFileName\\n\\tentries[hashPath] = object.TreeEntry{\\n\\t\\tName: hashPath,\\n\\t\\tMode: filemode.Regular,\\n\\t\\tHash: hashBlob,\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// ensureSessionsBranch ensures the entire/checkpoints/v1 branch exists.\\nfunc (s *GitStore) ensureSessionsBranch() error {\\n\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n\\t_, err := s.repo.Reference(refName, true)\\n\\tif err == nil {\\n\\t\\treturn nil // Branch exists\\n\\t}\\n\\n\\t// Create orphan branch with empty tree\\n\\temptyTreeHash, err := BuildTreeFromEntries(s.repo, make(map[string]object.TreeEntry))\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n\\tcommitHash, err := s.createCommit(emptyTreeHash, plumbing.ZeroHash, \\\"Initialize sessions branch\\\", authorName, authorEmail)\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n\\t}\\n\\treturn nil\\n}\\n\\n// getSessionsBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\n// Falls back to origin/entire/checkpoints/v1 if the local branch doesn't exist.\\nfunc (s *GitStore) getSessionsBranchTree() (*object.Tree, error) {\\n\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n\\tref, err := s.repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\t// Local branch doesn't exist, try remote-tracking branch\\n\\t\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n\\t\\tref, err = s.repo.Reference(remoteRefName, true)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"sessions branch not found: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\treturn tree, nil\\n}\\n\\n// CreateBlobFromContent creates a blob object from in-memory content.\\n// Exported for use by strategy package (session_test.go)\\nfunc CreateBlobFromContent(repo *git.Repository, content []byte) (plumbing.Hash, error) {\\n\\tobj := repo.Storer.NewEncodedObject()\\n\\tobj.SetType(plumbing.BlobObject)\\n\\tobj.SetSize(int64(len(content)))\\n\\n\\twriter, err := obj.Writer()\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get object writer: %w\\\", err)\\n\\t}\\n\\n\\t_, err = writer.Write(content)\\n\\tif err != nil {\\n\\t\\t_ = writer.Close()\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write blob content: %w\\\", err)\\n\\t}\\n\\tif err := writer.Close(); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to close blob writer: %w\\\", err)\\n\\t}\\n\\n\\thash, err := repo.Storer.SetEncodedObject(obj)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store blob object: %w\\\", err)\\n\\t}\\n\\treturn hash, nil\\n}\\n\\n// copyMetadataDir copies all files from a directory to the checkpoint path.\\n// Used to include additional metadata files like task checkpoints, subagent transcripts, etc.\\nfunc (s *GitStore) copyMetadataDir(metadataDir, basePath string, entries map[string]object.TreeEntry) error {\\n\\terr := filepath.Walk(metadataDir, func(path string, info os.FileInfo, err error) error {\\n\\t\\tif err != nil {\\n\\t\\t\\treturn err\\n\\t\\t}\\n\\n\\t\\t// Skip symlinks to prevent reading files outside the metadata directory.\\n\\t\\t// A symlink could point to sensitive files (e.g., /etc/passwd) which would\\n\\t\\t// then be captured in the checkpoint and stored in git history.\\n\\t\\t// NOTE: filepath.Walk uses os.Stat (follows symlinks), so info.Mode() ne