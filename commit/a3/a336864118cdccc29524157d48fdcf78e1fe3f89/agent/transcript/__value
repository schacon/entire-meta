6→\\n    47→// Type indicates the storage location and lifecycle of a checkpoint.\\n    48→type Type int\\n    49→\\n    50→const (\\n    51→\\t// Temporary checkpoints contain full state (code + metadata) and are stored\\n    52→\\t// on shadow branches (entire/<commit-hash>). Used for intra-session rewind.\\n    53→\\tTemporary Type = iota\\n    54→\\n    55→\\t// Committed checkpoints contain metadata + commit reference and are stored\\n    56→\\t// on the entire/checkpoints/v1 branch. They are the permanent record.\\n    57→\\tCommitted\\n    58→)\\n    59→\\n    60→// Store provides low-level primitives for reading and writing checkpoints.\\n    61→// This is used by strategies to implement their storage approach.\\n    62→//\\n    63→// The interface matches the GitStore implementation signatures directly:\\n    64→// - WriteTemporary takes WriteTemporaryOptions and returns a result with commit hash and skip status\\n    65→// - ReadTemporary takes baseCommit (not sessionID) since shadow branches are keyed by commit\\n    66→// - List methods return implementation-specific info types for richer data\\n    67→type Store interface {\\n    68→\\t// WriteTemporary writes a temporary checkpoint (full state) to a shadow branch.\\n    69→\\t// Shadow branches are named entire/<base-commit-short-hash>.\\n    70→\\t// Returns a result containing the commit hash and whether the checkpoint was skipped.\\n    71→\\t// Checkpoints are skipped (deduplicated) when the tree hash matches the previous checkpoint.\\n    72→\\tWriteTemporary(ctx context.Context, opts WriteTemporaryOptions) (WriteTemporaryResult, error)\\n    73→\\n    74→\\t// ReadTemporary reads the latest checkpoint from a shadow branch.\\n    75→\\t// baseCommit is the commit hash the session is based on.\\n    76→\\t// worktreeID is the internal git worktree identifier (empty for main worktree).\\n    77→\\t// Returns nil, nil if the shadow branch doesn't exist.\\n    78→\\tReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error)\\n    79→\\n    80→\\t// ListTemporary lists all shadow branches with their checkpoint info.\\n    81→\\tListTemporary(ctx context.Context) ([]TemporaryInfo, error)\\n    82→\\n    83→\\t// WriteCommitted writes a committed checkpoint to the entire/checkpoints/v1 branch.\\n    84→\\t// Checkpoints are stored at sharded paths: <id[:2]>/<id[2:]>/\\n    85→\\tWriteCommitted(ctx context.Context, opts WriteCommittedOptions) error\\n    86→\\n    87→\\t// ReadCommitted reads a committed checkpoint's summary by ID.\\n    88→\\t// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n    89→\\t// Use ReadSessionContent to read actual transcript/prompts/context.\\n    90→\\t// Returns nil, nil if the checkpoint does not exist.\\n    91→\\tReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error)\\n    92→\\n    93→\\t// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n    94→\\t// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n    95→\\t// Returns the session's metadata, transcript, prompts, and context.\\n    96→\\tReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error)\\n    97→\\n    98→\\t// ReadSessionContentByID reads a session's content by its session ID.\\n    99→\\t// Useful when you have the session ID but don't know its index within the checkpoint.\\n   100→\\tReadSessionContentByID(ctx context.Context, checkpointID id.CheckpointID, sessionID string) (*SessionContent, error)\\n   101→\\n   102→\\t// ListCommitted lists all committed checkpoints.\\n   103→\\tListCommitted(ctx context.Context) ([]CommittedInfo, error)\\n   104→\\n   105→\\t// UpdateCommitted replaces the transcript, prompts, and context for an existing\\n   106→\\t// committed checkpoint. Used at stop time to finalize checkpoints with the full\\n   107→\\t// session transcript (prompt to stop event).\\n   108→\\t// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   109→\\tUpdateCommitted(ctx context.Context, opts UpdateCommittedOptions) error\\n   110→}\\n   111→\\n   112→// WriteTemporaryResult contains the result of writing a temporary checkpoint.\\n   113→type WriteTemporaryResult struct {\\n   114→\\t// CommitHash is the hash of the created or existing checkpoint commit\\n   115→\\tCommitHash plumbing.Hash\\n   116→\\n   117→\\t// Skipped is true if the checkpoint was skipped due to no changes\\n   118→\\t// (tree hash matched the previous checkpoint)\\n   119→\\tSkipped bool\\n   120→}\\n   121→\\n   122→// WriteTemporaryOptions contains options for writing a temporary checkpoint.\\n   123→type WriteTemporaryOptions struct {\\n   124→\\t// SessionID is the session identifier\\n   125→\\tSessionID string\\n   126→\\n   127→\\t// BaseCommit is the commit hash this session is based on\\n   128→\\tBaseCommit string\\n   129→\\n   130→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n   131→\\t// Used to create worktree-specific shadow branch names\\n   132→\\tWorktreeID string\\n   133→\\n   134→\\t// ModifiedFiles are files that have been modified (relative paths)\\n   135→\\tModifiedFiles []string\\n   136→\\n   137→\\t// NewFiles are files that have been created (relative paths)\\n   138→\\tNewFiles []string\\n   139→\\n   140→\\t// DeletedFiles are files that have been deleted (relative paths)\\n   141→\\tDeletedFiles []string\\n   142→\\n   143→\\t// MetadataDir is the relative path to the metadata directory\\n   144→\\tMetadataDir string\\n   145→\\n   146→\\t// MetadataDirAbs is the absolute path to the metadata directory\\n   147→\\tMetadataDirAbs string\\n   148→\\n   149→\\t// CommitMessage is the commit subject line\\n   150→\\tCommitMessage string\\n   151→\\n   152→\\t// AuthorName is the name to use for commits\\n   153→\\tAuthorName string\\n   154→\\n   155→\\t// AuthorEmail is the email to use for commits\\n   156→\\tAuthorEmail string\\n   157→\\n   158→\\t// IsFirstCheckpoint indicates if this is the first checkpoint of the session\\n   159→\\t// When true, all working directory files are captured (not just modified)\\n   160→\\tIsFirstCheckpoint bool\\n   161→}\\n   162→\\n   163→// ReadTemporaryResult contains the result of reading a temporary checkpoint.\\n   164→type ReadTemporaryResult struct {\\n   165→\\t// CommitHash is the hash of the checkpoint commit\\n   166→\\tCommitHash plumbing.Hash\\n   167→\\n   168→\\t// TreeHash is the hash of the tree containing the checkpoint state\\n   169→\\tTreeHash plumbing.Hash\\n   170→\\n   171→\\t// SessionID is the session identifier from the commit trailer\\n   172→\\tSessionID string\\n   173→\\n   174→\\t// MetadataDir is the metadata directory path from the commit trailer\\n   175→\\tMetadataDir string\\n   176→\\n   177→\\t// Timestamp is when the checkpoint was created\\n   178→\\tTimestamp time.Time\\n   179→}\\n   180→\\n   181→// TemporaryInfo contains summary information about a shadow branch.\\n   182→type TemporaryInfo struct {\\n   183→\\t// BranchName is the full branch name (e.g., \\\"entire/abc1234\\\")\\n   184→\\tBranchName string\\n   185→\\n   186→\\t// BaseCommit is the short commit hash this branch is based on\\n   187→\\tBaseCommit string\\n   188→\\n   189→\\t// LatestCommit is the hash of the latest commit on the branch\\n   190→\\tLatestCommit plumbing.Hash\\n   191→\\n   192→\\t// SessionID is the session identifier from the latest commit\\n   193→\\tSessionID string\\n   194→\\n   195→\\t// Timestamp is when the latest checkpoint was created\\n   196→\\tTimestamp time.Time\\n   197→}\\n   198→\\n   199→// WriteCommittedOptions contains options for writing a committed checkpoint.\\n   200→type WriteCommittedOptions struct {\\n   201→\\t// CheckpointID is the stable 12-hex-char identifier\\n   202→\\tCheckpointID id.CheckpointID\\n   203→\\n   204→\\t// SessionID is the session identifier\\n   205→\\tSessionID string\\n   206→\\n   207→\\t// Strategy is the name of the strategy that created this checkpoint\\n   208→\\tStrategy string\\n   209→\\n   210→\\t// Branch is the branch name where the checkpoint was created (empty if detached HEAD)\\n   211→\\tBranch string\\n   212→\\n   213→\\t// Transcript is the session transcript content (full.jsonl)\\n   214→\\tTranscript []byte\\n   215→\\n   216→\\t// Prompts contains user prompts from the session\\n   217→\\tPrompts []string\\n   218→\\n   219→\\t// Context is the generated context.md content\\n   220→\\tContext []byte\\n   221→\\n   222→\\t// FilesTouched are files modified during the session\\n   223→\\tFilesTouched []string\\n   224→\\n   225→\\t// CheckpointsCount is the number of checkpoints in this session\\n   226→\\tCheckpointsCount int\\n   227→\\n   228→\\t// EphemeralBranch is the shadow branch name (for manual-commit strategy)\\n   229→\\tEphemeralBranch string\\n   230→\\n   231→\\t// AuthorName is the name to use for commits\\n   232→\\tAuthorName string\\n   233→\\n   234→\\t// AuthorEmail is the email to use for commits\\n   235→\\tAuthorEmail string\\n   236→\\n   237→\\t// MetadataDir is a directory containing additional metadata files to copy\\n   238→\\t// If set, all files in this directory will be copied to the checkpoint path\\n   239→\\t// This is useful for copying task metadata files, subagent transcripts, etc.\\n   240→\\tMetadataDir string\\n   241→\\n   242→\\t// Task checkpoint fields (for auto-commit strategy task checkpoints)\\n   243→\\tIsTask    bool   // Whether this is a task checkpoint\\n   244→\\tToolUseID string // Tool use ID for task checkpoints\\n   245→\\n   246→\\t// Additional task checkpoint fields for subagent checkpoints\\n   247→\\tAgentID                string // Subagent identifier\\n   248→\\tCheckpointUUID         string // UUID for transcript truncation when rewinding\\n   249→\\tTranscriptPath         string // Path to session transcript file (alternative to in-memory Transcript)\\n   250→\\tSubagentTranscriptPath string // Path to subagent's transcript file\\n   251→\\n   252→\\t// Incremental checkpoint fields\\n   253→\\tIsIncremental       bool   // Whether this is an incremental checkpoint\\n   254→\\tIncrementalSequence int    // Checkpoint sequence number\\n   255→\\tIncrementalType     string // Tool type that triggered this checkpoint\\n   256→\\tIncrementalData     []byte // Tool input payload for this checkpoint\\n   257→\\n   258→\\t// Commit message fields (used for task checkpoints)\\n   259→\\tCommitSubject string // Subject line for the metadata commit (overrides default)\\n   260→\\n   261→\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   262→\\tAgent agent.AgentType\\n   263→\\n   264→\\t// TurnID correlates checkpoints from the same agent turn.\\n   265→\\tTurnID string\\n   266→\\n   267→\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n   268→\\tTranscriptIdentifierAtStart string // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n   269→\\tCheckpointTranscriptStart   int    // Transcript line offset at start of this checkpoint's data\\n   270→\\n   271→\\t// CheckpointTranscriptStart is written to both CommittedMetadata.CheckpointTranscriptStart\\n   272→\\t// and the deprecated CommittedMetadata.TranscriptLinesAtStart for backward compatibility.\\n   273→\\n   274→\\t// TokenUsage contains the token usage for this checkpoint\\n   275→\\tTokenUsage *agent.TokenUsage\\n   276→\\n   277→\\t// InitialAttribution is line-level attribution calculated at commit time\\n   278→\\t// comparing checkpoint tree (agent work) to committed tree (may include human edits)\\n   279→\\tInitialAttribution *InitialAttribution\\n   280→\\n   281→\\t// Summary is an optional AI-generated summary for this checkpoint.\\n   282→\\t// This field may be nil when:\\n   283→\\t//   - summarization is disabled in settings\\n   284→\\t//   - summary generation failed (non-blocking, logged as warning)\\n   285→\\t//   - the transcript was empty or too short to summarize\\n   286→\\t//   - the checkpoint predates the summarization feature\\n   287→\\tSummary *Summary\\n   288→}\\n   289→\\n   290→// UpdateCommittedOptions contains options for updating an existing committed checkpoint.\\n   291→// Uses replace semantics: the transcript, prompts, and context are fully replaced,\\n   292→// not appended. At stop time we have the complete session transcript and want every\\n   293→// checkpoint to contain it identically.\\n   294→type UpdateCommittedOptions struct {\\n   295→\\t// CheckpointID identifies the checkpoint to update\\n   296→\\tCheckpointID id.CheckpointID\\n   297→\\n   298→\\t// SessionID identifies which session slot to update within the checkpoint\\n   299→\\tSessionID string\\n   300→\\n   301→\\t// Transcript is the full session transcript (replaces existing)\\n   302→\\tTranscript []byte\\n   303→\\n   304→\\t// Prompts contains all user prompts (replaces existing)\\n   305→\\tPrompts []string\\n   306→\\n   307→\\t// Context is the updated context.md content (replaces existing)\\n   308→\\tContext []byte\\n   309→\\n   310→\\t// Agent identifies the agent type (needed for transcript chunking)\\n   311→\\tAgent agent.AgentType\\n   312→}\\n   313→\\n   314→// CommittedInfo contains summary information about a committed checkpoint.\\n   315→type CommittedInfo struct {\\n   316→\\t// CheckpointID is the stable 12-hex-char identifier\\n   317→\\tCheckpointID id.CheckpointID\\n   318→\\n   319→\\t// SessionID is the session identifier (most recent session for multi-session checkpoints)\\n   320→\\tSessionID string\\n   321→\\n   322→\\t// CreatedAt is when the checkpoint was created\\n   323→\\tCreatedAt time.Time\\n   324→\\n   325→\\t// CheckpointsCount is the total number of checkpoints across all sessions\\n   326→\\tCheckpointsCount int\\n   327→\\n   328→\\t// FilesTouched are files modified during all sessions\\n   329→\\tFilesTouched []string\\n   330→\\n   331→\\t// Agent identifies the agent that created this checkpoint\\n   332→\\tAgent agent.AgentType\\n   333→\\n   334→\\t// IsTask indicates if this is a task checkpoint\\n   335→\\tIsTask bool\\n   336→\\n   337→\\t// ToolUseID is the tool use ID for task checkpoints\\n   338→\\tToolUseID string\\n   339→\\n   340→\\t// Multi-session support\\n   341→\\tSessionCount int      // Number of sessions (1 if single session)\\n   342→\\tSessionIDs   []string // All session IDs that contributed\\n   343→}\\n   344→\\n   345→// SessionContent contains the actual content for a session.\\n   346→// This is used when reading full session data (transcript, prompts, context)\\n   347→// as opposed to just the metadata/summary.\\n   348→type SessionContent struct {\\n   349→\\t// Metadata contains the session-specific metadata\\n   350→\\tMetadata CommittedMetadata\\n   351→\\n   352→\\t// Transcript is the session transcript content\\n   353→\\tTranscript []byte\\n   354→\\n   355→\\t// Prompts contains user prompts from this session\\n   356→\\tPrompts string\\n   357→\\n   358→\\t// Context is the context.md content\\n   359→\\tContext string\\n   360→}\\n   361→\\n   362→// CommittedMetadata contains the metadata stored in metadata.json for each checkpoint.\\n   363→type CommittedMetadata struct {\\n   364→\\tCLIVersion       string          `json:\\\"cli_version,omitempty\\\"`\\n   365→\\tCheckpointID     id.CheckpointID `json:\\\"checkpoint_id\\\"`\\n   366→\\tSessionID        string          `json:\\\"session_id\\\"`\\n   367→\\tStrategy         string          `json:\\\"strategy\\\"`\\n   368→\\tCreatedAt        time.Time       `json:\\\"created_at\\\"`\\n   369→\\tBranch           string          `json:\\\"branch,omitempty\\\"` // Branch where checkpoint was created (empty if detached HEAD)\\n   370→\\tCheckpointsCount int             `json:\\\"checkpoints_count\\\"`\\n   371→\\tFilesTouched     []string        `json:\\\"files_touched\\\"`\\n   372→\\n   373→\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   374→\\tAgent agent.AgentType `json:\\\"agent,omitempty\\\"`\\n   375→\\n   376→\\t// TurnID correlates checkpoints from the same agent turn.\\n   377→\\t// When a turn's work spans multiple commits, each gets its own checkpoint\\n   378→\\t// but they share the same TurnID for future aggregation/deduplication.\\n   379→\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n   380→\\n   381→\\t// Task checkpoint fields (only populated for task checkpoints)\\n   382→\\tIsTask    bool   `json:\\\"is_task,omitempty\\\"`\\n   383→\\tToolUseID string `json:\\\"tool_use_id,omitempty\\\"`\\n   384→\\n   385→\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n   386→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"` // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n   387→\\tCheckpointTranscriptStart   int    `json:\\\"checkpoint_transcript_start,omitempty\\\"`    // Transcript line offset at start of this checkpoint's data\\n   388→\\n   389→\\t// Deprecated: Use CheckpointTranscriptStart instead. Written for backward compatibility with older CLI versions.\\n   390→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   391→\\n   392→\\t// Token usage for this checkpoint\\n   393→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   394→\\n   395→\\t// AI-generated summary of the checkpoint\\n   396→\\tSummary *Summary `json:\\\"summary,omitempty\\\"`\\n   397→\\n   398→\\t// InitialAttribution is line-level attribution calculated at commit time\\n   399→\\tInitialAttribution *InitialAttribution `json:\\\"initial_attribution,omitempty\\\"`\\n   400→}\\n   401→\\n   402→// GetTranscriptStart returns the transcript line offset at which this checkpoint's data begins.\\n   403→// Returns 0 for new checkpoints (start from beginning). For data written by older CLI versions,\\n   404→// falls back to the deprecated TranscriptLinesAtStart field.\\n   405→func (m CommittedMetadata) GetTranscriptStart() int {\\n   406→\\tif m.CheckpointTranscriptStart > 0 {\\n   407→\\t\\treturn m.CheckpointTranscriptStart\\n   408→\\t}\\n   409→\\treturn m.TranscriptLinesAtStart\\n   410→}\\n   411→\\n   412→// SessionFilePaths contains the absolute paths to session files from the git tree root.\\n   413→// Paths include the full checkpoint path prefix (e.g., \\\"/a1/b2c3d4e5f6/1/metadata.json\\\").\\n   414→// Used in CheckpointSummary.Sessions to map session IDs to their file locations.\\n   415→type SessionFilePaths struct {\\n   416→\\tMetadata    string `json:\\\"metadata\\\"`\\n   417→\\tTranscript  string `json:\\\"transcript\\\"`\\n   418→\\tContext     string `json:\\\"context\\\"`\\n   419→\\tContentHash string `json:\\\"content_hash\\\"`\\n   420→\\tPrompt      string `json:\\\"prompt\\\"`\\n   421→}\\n   422→\\n   423→// CheckpointSummary is the root-level metadata.json for a checkpoint.\\n   424→// It contains aggregated statistics from all sessions and a map of session IDs\\n   425→// to their file paths. Session-specific data (including initial_attribution)\\n   426→// is stored in the session's subdirectory metadata.json.\\n   427→//\\n   428→// Structure on entire/checkpoints/v1 branch:\\n   429→//\\n   430→//\\t<checkpoint-id[:2]>/<checkpoint-id[2:]>/\\n   431→//\\t├── metadata.json         # This CheckpointSummary\\n   432→//\\t├── 1/                    # First session\\n   433→//\\t│   ├── metadata.json     # Session-specific CommittedMetadata\\n   434→//\\t│   ├── full.jsonl\\n   435→//\\t│   ├── prompt.txt\\n   436→//\\t│   ├── context.md\\n   437→//\\t│   └── content_hash.txt\\n   438→//\\t├── 2/                    # Second session\\n   439→//\\t└── 3/                    # Third session...\\n   440→//\\n   441→//nolint:revive // Named CheckpointSummary to avoid conflict with existing Summary struct\\n   442→type CheckpointSummary struct {\\n   443→\\tCLIVersion       string             `json:\\\"cli_version,omitempty\\\"`\\n   444→\\tCheckpointID     id.CheckpointID    `json:\\\"checkpoint_id\\\"`\\n   445→\\tStrategy         string             `json:\\\"strategy\\\"`\\n   446→\\tBranch           string             `json:\\\"branch,omitempty\\\"`\\n   447→\\tCheckpointsCount int                `json:\\\"checkpoints_count\\\"`\\n   448→\\tFilesTouched     []string           `json:\\\"files_touched\\\"`\\n   449→\\tSessions         []SessionFilePaths `json:\\\"sessions\\\"`\\n   450→\\tTokenUsage       *agent.TokenUsage  `json:\\\"token_usage,omitempty\\\"`\\n   451→}\\n   452→\\n   453→// Summary contains AI-generated summary of a checkpoint.\\n   454→type Summary struct {\\n   455→\\tIntent    string           `json:\\\"intent\\\"`     // What user wanted to accomplish\\n   456→\\tOutcome   string           `json:\\\"outcome\\\"`    // What was achieved\\n   457→\\tLearnings LearningsSummary `json:\\\"learnings\\\"`  // Categorized learnings\\n   458→\\tFriction  []string         `json:\\\"friction\\\"`   // Problems/annoyances encountered\\n   459→\\tOpenItems []string         `json:\\\"open_items\\\"` // Tech debt, unfinished work\\n   460→}\\n   461→\\n   462→// LearningsSummary contains learnings grouped by scope.\\n   463→type LearningsSummary struct {\\n   464→\\tRepo     []string       `json:\\\"repo\\\"`     // Codebase-specific patterns/conventions\\n   465→\\tCode     []CodeLearning `json:\\\"code\\\"`     // File/module specific findings\\n   466→\\tWorkflow []string       `json:\\\"workflow\\\"` // General dev practices\\n   467→}\\n   468→\\n   469→// CodeLearning captures a learning tied to a specific code location.\\n   470→type CodeLearning struct {\\n   471→\\tPath    string `json:\\\"path\\\"`               // File path\\n   472→\\tLine    int    `json:\\\"line,omitempty\\\"`     // Start line number\\n   473→\\tEndLine int    `json:\\\"end_line,omitempty\\\"` // End line for ranges (optional)\\n   474→\\tFinding string `json:\\\"finding\\\"`            // What was learned\\n   475→}\\n   476→\\n   477→// InitialAttribution captures line-level attribution metrics at commit time.\\n   478→// This is a point-in-time snapshot comparing the checkpoint tree (agent work)\\n   479→// against the committed tree (may include human edits).\\n   480→//\\n   481→// Attribution Metrics:\\n   482→//   - TotalCommitted measures \\\"net additions\\\" (lines added that remain in the commit)\\n   483→//   - AgentPercentage represents \\\"of the new code added, what percentage came from the agent\\\"\\n   484→//   - Deletion work is tracked separately in HumanRemoved (not included in percentage)\\n   485→//\\n   486→// Deletion-Only Commits:\\n   487→// For commits with only deletions (no additions), TotalCommitted will be 0 and\\n   488→// AgentPercentage will be 0. This is by design - the percentage metric is only\\n   489→// meaningful for commits that add code. Deletion contributions are captured in\\n   490→// the HumanRemoved field but don't affect the attribution percentage.\\n   491→type InitialAttribution struct {\\n   492→\\tCalculatedAt    time.Time `json:\\\"calculated_at\\\"`\\n   493→\\tAgentLines      int       `json:\\\"agent_lines\\\"`      // Lines added by agent (base → shadow diff)\\n   494→\\tHumanAdded      int       `json:\\\"human_added\\\"`      // Lines added by human (excluding modifications)\\n   495→\\tHumanModified   int       `json:\\\"human_modified\\\"`   // Lines modified by human (estimate: min(added, removed))\\n   496→\\tHumanRemoved    int       `json:\\\"human_removed\\\"`    // Lines removed by human (excluding modifications)\\n   497→\\tTotalCommitted  int       `json:\\\"total_committed\\\"`  // Net additions in commit (agent + human new lines, not total file size)\\n   498→\\tAgentPercentage float64   `json:\\\"agent_percentage\\\"` // agent_lines / total_committed * 100 (0 for deletion-only commits)\\n   499→}\\n   500→\\n   501→// Info provides summary information for listing checkpoints.\\n   502→// This is the generic checkpoint info type.\\n   503→type Info struct {\\n   504→\\t// ID is the checkpoint identifier\\n   505→\\tID string\\n   506→\\n   507→\\t// SessionID identifies the session\\n   508→\\tSessionID string\\n   509→\\n   510→\\t// Type indicates temporary or committed\\n   511→\\tType Type\\n   512→\\n   513→\\t// CreatedAt is when the checkpoint was created\\n   514→\\tCreatedAt time.Time\\n   515→\\n   516→\\t// Message is a summary description\\n   517→\\tMessage string\\n   518→}\\n   519→\\n   520→// WriteTemporaryTaskOptions contains options for writing a task checkpoint.\\n   521→// Task checkpoints are created when a subagent completes and contain both\\n   522→// code changes and task-specific metadata.\\n   523→type WriteTemporaryTaskOptions struct {\\n   524→\\t// SessionID is the session identifier\\n   525→\\tSessionID string\\n   526→\\n   527→\\t// BaseCommit is the commit hash this session is based on\\n   528→\\tBaseCommit string\\n   529→\\n   530→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n   531→\\t// Used to create worktree-specific shadow branch names\\n   532→\\tWorktreeID string\\n   533→\\n   534→\\t// ToolUseID is the unique identifier for this Task tool invocation\\n   535→\\tToolUseID string\\n   536→\\n   537→\\t// AgentID is the subagent identifier\\n   538→\\tAgentID string\\n   539→\\n   540→\\t// ModifiedFiles are files that have been modified (relative paths)\\n   541→\\tModifiedFiles []string\\n   542→\\n   543→\\t// NewFiles are files that have been created (relative paths)\\n   544→\\tNewFiles []string\\n   545→\\n   546→\\t// DeletedFiles are files that have been deleted (relative paths)\\n   547→\\tDeletedFiles []string\\n   548→\\n   549→\\t// TranscriptPath is the path to the main session transcript\\n   550→\\tTranscriptPath string\\n   551→\\n   552→\\t// SubagentTranscriptPath is the path to the subagent's transcript\\n   553→\\tSubagentTranscriptPath string\\n   554→\\n   555→\\t// CheckpointUUID is the UUID for transcript truncation when rewinding\\n   556→\\tCheckpointUUID string\\n   557→\\n   558→\\t// CommitMessage is the commit message (already formatted)\\n   559→\\tCommitMessage string\\n   560→\\n   561→\\t// AuthorName is the name to use for commits\\n   562→\\tAuthorName string\\n   563→\\n   564→\\t// AuthorEmail is the email to use for commits\\n   565→\\tAuthorEmail string\\n   566→\\n   567→\\t// IsIncremental indicates this is an incremental checkpoint\\n   568→\\tIsIncremental bool\\n   569→\\n   570→\\t// IncrementalSequence is the checkpoint sequence number\\n   571→\\tIncrementalSequence int\\n   572→\\n   573→\\t// IncrementalType is the tool that triggered this checkpoint\\n   574→\\tIncrementalType string\\n   575→\\n   576→\\t// IncrementalData is the tool_input payload for this checkpoint\\n   577→\\tIncrementalData []byte\\n   578→}\\n   579→\\n   580→// TemporaryCheckpointInfo contains information about a single commit on a shadow branch.\\n   581→// Used by ListTemporaryCheckpoints to provide rewind point data.\\n   582→type TemporaryCheckpointInfo struct {\\n   583→\\t// CommitHash is the hash of the checkpoint commit\\n   584→\\tCommitHash plumbing.Hash\\n   585→\\n   586→\\t// Message is the first line of the commit message\\n   587→\\tMessage string\\n   588→\\n   589→\\t// SessionID is the session identifier from the Entire-Session trailer\\n   590→\\tSessionID string\\n   591→\\n   592→\\t// MetadataDir is the metadata directory path from trailers\\n   593→\\tMetadataDir string\\n   594→\\n   595→\\t// IsTaskCheckpoint indicates if this is a task checkpoint\\n   596→\\tIsTaskCheckpoint bool\\n   597→\\n   598→\\t// ToolUseID is the tool use ID for task checkpoints\\n   599→\\tToolUseID string\\n   600→\\n   601→\\t// Timestamp is when the checkpoint was created\\n   602→\\tTimestamp time.Time\\n   603→}\\n   604→\"}]},\"uuid\":\"c08563b1-8f50-473d-a85e-49e9e3db3e9d\",\"timestamp\":\"2026-02-24T22:23:19.541Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/evisdrenova/code/entire/devenv/cli/cmd/entire/cli/checkpoint/checkpoint.go\",\"content\":\"// Package checkpoint provides types and interfaces for checkpoint storage.\\n//\\n// A Checkpoint captures a point-in-time within a session, containing either\\n// full state (Temporary) or metadata with a commit reference (Committed).\\n//\\n// See docs/architecture/sessions-and-checkpoints.md for the full domain model.\\npackage checkpoint\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n)\\n\\n// Errors returned by checkpoint operations.\\nvar (\\n\\t// ErrCheckpointNotFound is returned when a checkpoint ID doesn't exist.\\n\\tErrCheckpointNotFound = errors.New(\\\"checkpoint not found\\\")\\n\\n\\t// ErrNoTranscript is returned when a checkpoint exists but has no transcript.\\n\\tErrNoTranscript = errors.New(\\\"no transcript found for checkpoint\\\")\\n)\\n\\n// Checkpoint represents a save point within a session.\\ntype Checkpoint struct {\\n\\t// ID is the unique checkpoint identifier\\n\\tID string\\n\\n\\t// SessionID is the session this checkpoint belongs to\\n\\tSessionID string\\n\\n\\t// Timestamp is when this checkpoint was created\\n\\tTimestamp time.Time\\n\\n\\t// Type indicates temporary (full state) or committed (metadata only)\\n\\tType Type\\n\\n\\t// Message is a human-readable description of the checkpoint\\n\\tMessage string\\n}\\n\\n// Type indicates the storage location and lifecycle of a checkpoint.\\ntype Type int\\n\\nconst (\\n\\t// Temporary checkpoints contain full state (code + metadata) and are stored\\n\\t// on shadow branches (entire/<commit-hash>). Used for intra-session rewind.\\n\\tTemporary Type = iota\\n\\n\\t// Committed checkpoints contain metadata + commit reference and are stored\\n\\t// on the entire/checkpoints/v1 branch. They are the permanent record.\\n\\tCommitted\\n)\\n\\n// Store provides low-level primitives for reading and writing checkpoints.\\n// This is used by strategies to implement their storage approach.\\n//\\n// The interface matches the GitStore implementation signatures directly:\\n// - WriteTemporary takes WriteTemporaryOptions and returns a result with commit hash and skip status\\n// - ReadTemporary takes baseCommit (not sessionID) since shadow branches are keyed by commit\\n// - List methods return implementation-specific info types for richer data\\ntype Store interface {\\n\\t// WriteTemporary writes a temporary checkpoint (full state) to a shadow branch.\\n\\t// Shadow branches are named entire/<base-commit-short-hash>.\\n\\t// Returns a result containing the commit hash and whether the checkpoint was skipped.\\n\\t// Checkpoints are skipped (deduplicated) when the tree hash matches the previous checkpoint.\\n\\tWriteTemporary(ctx context.Context, opts WriteTemporaryOptions) (WriteTemporaryResult, error)\\n\\n\\t// ReadTemporary reads the latest checkpoint from a shadow branch.\\n\\t// baseCommit is the commit hash the session is based on.\\n\\t// worktreeID is the internal git worktree identifier (empty for main worktree).\\n\\t// Returns nil, nil if the shadow branch doesn't exist.\\n\\tReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error)\\n\\n\\t// ListTemporary lists all shadow branches with their checkpoint info.\\n\\tListTemporary(ctx context.Context) ([]TemporaryInfo, error)\\n\\n\\t// WriteCommitted writes a committed checkpoint to the entire/checkpoints/v1 branch.\\n\\t// Checkpoints are stored at sharded paths: <id[:2]>/<id[2:]>/\\n\\tWriteCommitted(ctx context.Context, opts WriteCommittedOptions) error\\n\\n\\t// ReadCommitted reads a committed checkpoint's summary by ID.\\n\\t// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n\\t// Use ReadSessionContent to read actual transcript/prompts/context.\\n\\t// Returns nil, nil if the checkpoint does not exist.\\n\\tReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error)\\n\\n\\t// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n\\t// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n\\t// Returns the session's metadata, transcript, prompts, and context.\\n\\tReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error)\\n\\n\\t// ReadSessionContentByID reads a session's content by its session ID.\\n\\t// Useful when you have the session ID but don't know its index within the checkpoint.\\n\\tReadSessionContentByID(ctx context.Context, checkpointID id.CheckpointID, sessionID string) (*SessionContent, error)\\n\\n\\t// ListCommitted lists all committed checkpoints.\\n\\tListCommitted(ctx context.Context) ([]CommittedInfo, error)\\n\\n\\t// UpdateCommitted replaces the transcript, prompts, and context for an existing\\n\\t// committed checkpoint. Used at stop time to finalize checkpoints with the full\\n\\t// session transcript (prompt to stop event).\\n\\t// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n\\tUpdateCommitted(ctx context.Context, opts UpdateCommittedOptions) error\\n}\\n\\n// WriteTemporaryResult contains the result of writing a temporary checkpoint.\\ntype WriteTemporaryResult struct {\\n\\t// CommitHash is the hash of the created or existing checkpoint commit\\n\\tCommitHash plumbing.Hash\\n\\n\\t// Skipped is true if the checkpoint was skipped due to no changes\\n\\t// (tree hash matched the previous checkpoint)\\n\\tSkipped bool\\n}\\n\\n// WriteTemporaryOptions contains options for writing a temporary checkpoint.\\ntype WriteTemporaryOptions struct {\\n\\t// SessionID is the session identifier\\n\\tSessionID string\\n\\n\\t// BaseCommit is the commit hash this session is based on\\n\\tBaseCommit string\\n\\n\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n\\t// Used to create worktree-specific shadow branch names\\n\\tWorktreeID string\\n\\n\\t// ModifiedFiles are files that have been modified (relative paths)\\n\\tModifiedFiles []string\\n\\n\\t// NewFiles are files that have been created (relative paths)\\n\\tNewFiles []string\\n\\n\\t// DeletedFiles are files that have been deleted (relative paths)\\n\\tDeletedFiles []string\\n\\n\\t// MetadataDir is the relative path to the metadata directory\\n\\tMetadataDir string\\n\\n\\t// MetadataDirAbs is the absolute path to the metadata directory\\n\\tMetadataDirAbs string\\n\\n\\t// CommitMessage is the commit subject line\\n\\tCommitMessage string\\n\\n\\t// AuthorName is the name to use for commits\\n\\tAuthorName string\\n\\n\\t// AuthorEmail is the email to use for commits\\n\\tAuthorEmail string\\n\\n\\t// IsFirstCheckpoint indicates if this is the first checkpoint of the session\\n\\t// When true, all working directory files are captured (not just modified)\\n\\tIsFirstCheckpoint bool\\n}\\n\\n// ReadTemporaryResult contains the result of reading a temporary checkpoint.\\ntype ReadTemporaryResult struct {\\n\\t// CommitHash is the hash of the checkpoint commit\\n\\tCommitHash plumbing.Hash\\n\\n\\t// TreeHash is the hash of the tree containing the checkpoint state\\n\\tTreeHash plumbing.Hash\\n\\n\\t// SessionID is the session identifier from the commit trailer\\n\\tSessionID string\\n\\n\\t// MetadataDir is the metadata directory path from the commit trailer\\n\\tMetadataDir string\\n\\n\\t// Timestamp is when the checkpoint was created\\n\\tTimestamp time.Time\\n}\\n\\n// TemporaryInfo contains summary information about a shadow branch.\\ntype TemporaryInfo struct {\\n\\t// BranchName is the full branch name (e.g., \\\"entire/abc1234\\\")\\n\\tBranchName string\\n\\n\\t// BaseCommit is the short commit hash this branch is based on\\n\\tBaseCommit string\\n\\n\\t// LatestCommit is the hash of the latest commit on the branch\\n\\tLatestCommit plumbing.Hash\\n\\n\\t// SessionID is the session identifier from the latest commit\\n\\tSessionID string\\n\\n\\t// Timestamp is when the latest checkpoint was created\\n\\tTimestamp time.Time\\n}\\n\\n// WriteCommittedOptions contains options for writing a committed checkpoint.\\ntype WriteCommittedOptions struct {\\n\\t// CheckpointID is the stable 12-hex-char identifier\\n\\tCheckpointID id.CheckpointID\\n\\n\\t// SessionID is the session identifier\\n\\tSessionID string\\n\\n\\t// Strategy is the name of the strategy that created this checkpoint\\n\\tStrategy string\\n\\n\\t// Branch is the branch name where the checkpoint was created (empty if detached HEAD)\\n\\tBranch string\\n\\n\\t// Transcript is the session transcript content (full.jsonl)\\n\\tTranscript []byte\\n\\n\\t// Prompts contains user prompts from the session\\n\\tPrompts []string\\n\\n\\t// Context is the generated context.md content\\n\\tContext []byte\\n\\n\\t// FilesTouched are files modified during the session\\n\\tFilesTouched []string\\n\\n\\t// CheckpointsCount is the number of checkpoints in this session\\n\\tCheckpointsCount int\\n\\n\\t// EphemeralBranch is the shadow branch name (for manual-commit strategy)\\n\\tEphemeralBranch string\\n\\n\\t// AuthorName is the name to use for commits\\n\\tAuthorName string\\n\\n\\t// AuthorEmail is the email to use for commits\\n\\tAuthorEmail string\\n\\n\\t// MetadataDir is a directory containing additional metadata files to copy\\n\\t// If set, all files in this directory will be copied to the checkpoint path\\n\\t// This is useful for copying task metadata files, subagent transcripts, etc.\\n\\tMetadataDir string\\n\\n\\t// Task checkpoint fields (for auto-commit strategy task checkpoints)\\n\\tIsTask    bool   // Whether this is a task checkpoint\\n\\tToolUseID string // Tool use ID for task checkpoints\\n\\n\\t// Additional task checkpoint fields for subagent checkpoints\\n\\tAgentID                string // Subagent identifier\\n\\tCheckpointUUID         string // UUID for transcript truncation when rewinding\\n\\tTranscriptPath         string // Path to session transcript file (alternative to in-memory Transcript)\\n\\tSubagentTranscriptPath string // Path to subagent's transcript file\\n\\n\\t// Incremental checkpoint fields\\n\\tIsIncremental       bool   // Whether this is an incremental checkpoint\\n\\tIncrementalSequence int    // Checkpoint sequence number\\n\\tIncrementalType     string // Tool type that triggered this checkpoint\\n\\tIncrementalData     []byte // Tool input payload for this checkpoint\\n\\n\\t// Commit message fields (used for task checkpoints)\\n\\tCommitSubject string // Subject line for the metadata commit (overrides default)\\n\\n\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n\\tAgent agent.AgentType\\n\\n\\t// TurnID correlates checkpoints from the same agent turn.\\n\\tTurnID string\\n\\n\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n\\tTranscriptIdentifierAtStart string // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n\\tCheckpointTranscriptStart   int    // Transcript line offset at start of this checkpoint's data\\n\\n\\t// CheckpointTranscriptStart is written to both CommittedMetadata.CheckpointTranscriptStart\\n\\t// and the deprecated CommittedMetadata.TranscriptLinesAtStart for backward compatibility.\\n\\n\\t// TokenUsage contains the token usage for this checkpoint\\n\\tTokenUsage *agent.TokenUsage\\n\\n\\t// InitialAttribution is line-level attribution calculated at commit time\\n\\t// comparing checkpoint tree (agent work) to committed tree (may include human edits)\\n\\tInitialAttribution *InitialAttribution\\n\\n\\t// Summary is an optional AI-generated summary for this checkpoint.\\n\\t// This field may be nil when:\\n\\t//   - summarization is disabled in settings\\n\\t//   - summary generation failed (non-blocking, logged as warning)\\n\\t//   - the transcript was empty or too short to summarize\\n\\t//   - the checkpoint predates the summarization feature\\n\\tSummary *Summary\\n}\\n\\n// UpdateCommittedOptions contains options for updating an existing committed checkpoint.\\n// Uses replace semantics: the transcript, prompts, and context are fully replaced,\\n// not appended. At stop time we have the complete session transcript and want every\\n// checkpoint to contain it identically.\\ntype UpdateCommittedOptions struct {\\n\\t// CheckpointID identifies the checkpoint to update\\n\\tCheckpointID id.CheckpointID\\n\\n\\t// SessionID identifies which session slot to update within the checkpoint\\n\\tSessionID string\\n\\n\\t// Transcript is the full session transcript (replaces existing)\\n\\tTranscript []byte\\n\\n\\t// Prompts contains all user prompts (replaces existing)\\n\\tPrompts []string\\n\\n\\t// Context is the updated context.md content (replaces existing)\\n\\tContext []byte\\n\\n\\t// Agent identifies the agent type (needed for transcript chunking)\\n\\tAgent agent.AgentType\\n}\\n\\n// CommittedInfo contains summary information about a committed checkpoint.\\ntype CommittedInfo struct {\\n\\t// CheckpointID is the stable 12-hex-char identifier\\n\\tCheckpointID id.CheckpointID\\n\\n\\t// SessionID is the session identifier (most recent session for multi-session checkpoints)\\n\\tSessionID string\\n\\n\\t// CreatedAt is when the checkpoint was created\\n\\tCreatedAt time.Time\\n\\n\\t// CheckpointsCount is the total number of checkpoints across all sessions\\n\\tCheckpointsCount int\\n\\n\\t// FilesTouched are files modified during all sessions\\n\\tFilesTouched []string\\n\\n\\t// Agent identifies the agent that created this checkpoint\\n\\tAgent agent.AgentType\\n\\n\\t// IsTask indicates if this is a task checkpoint\\n\\tIsTask bool\\n\\n\\t// ToolUseID is the tool use ID for task checkpoints\\n\\tToolUseID string\\n\\n\\t// Multi-session support\\n\\tSessionCount int      // Number of sessions (1 if single session)\\n\\tSessionIDs   []string // All session IDs that contributed\\n}\\n\\n// SessionContent contains the actual content for a session.\\n// This is used when reading full session data (transcript, prompts, context)\\n// as opposed to just the metadata/summary.\\ntype SessionContent struct {\\n\\t// Metadata contains the session-specific metadata\\n\\tMetadata CommittedMetadata\\n\\n\\t// Transcript is the session transcript content\\n\\tTranscript []byte\\n\\n\\t// Prompts contains user prompts from this session\\n\\tPrompts string\\n\\n\\t// Context is the context.md content\\n\\tContext string\\n}\\n\\n// CommittedMetadata contains the metadata stored in metadata.json for each checkpoint.\\ntype CommittedMetadata struct {\\n\\tCLIVersion       string          `json:\\\"cli_version,omitempty\\\"`\\n\\tCheckpointID     id.CheckpointID `json:\\\"checkpoint_id\\\"`\\n\\tSessionID        string          `json:\\\"session_id\\\"`\\n\\tStrategy         string          `json:\\\"strategy\\\"`\\n\\tCreatedAt        time.Time       `json:\\\"created_at\\\"`\\n\\tBranch           string          `json:\\\"branch,omitempty\\\"` // Branch where checkpoint was created (empty if detached HEAD)\\n\\tCheckpointsCount int             `json:\\\"checkpoints_count\\\"`\\n\\tFilesTouched     []string        `json:\\\"files_touched\\\"`\\n\\n\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n\\tAgent agent.AgentType `json:\\\"agent,omitempty\\\"`\\n\\n\\t// TurnID correlates checkpoints from the same agent turn.\\n\\t// When a turn's work spans multiple commits, each gets its own checkpoint\\n\\t// but they share the same TurnID for future aggregation/deduplication.\\n\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n\\n\\t// Task checkpoint fields (only populated for task checkpoints)\\n\\tIsTask    bool   `json:\\\"is_task,omitempty\\\"`\\n\\tToolUseID string `json:\\\"tool_use_id,omitempty\\\"`\\n\\n\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"` // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n\\tCheckpointTranscriptStart   int    `json:\\\"checkpoint_transcript_start,omitempty\\\"`    // Transcript line offset at start of this checkpoint's data\\n\\n\\t// Deprecated: Use CheckpointTranscriptStart instead. Written for backward compatibility with older CLI versions.\\n\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n\\n\\t// Token usage for this checkpoint\\n\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n\\n\\t// AI-generated summary of the checkpoint\\n\\tSummary *Summary `json:\\\"summary,omitempty\\\"`\\n\\n\\t// InitialAttribution is line-level attribution calculated at commit time\\n\\tInitialAttribution *InitialAttribution `json:\\\"initial_attribution,omitempty\\\"`\\n}\\n\\n// GetTranscriptStart returns the transcript line offset at which this checkpoint's data begins.\\n// Returns 0 for new checkpoints (start from beginning). For data written by older CLI versions,\\n// falls back to the deprecated TranscriptLinesAtStart field.\\nfunc (m CommittedMetadata) GetTranscriptStart() int {\\n\\tif m.CheckpointTranscriptStart > 0 {\\n\\t\\treturn m.CheckpointTranscriptStart\\n\\t}\\n\\treturn m.TranscriptLinesAtStart\\n}\\n\\n// SessionFilePaths contains the absolute paths to session files from the git tree root.\\n// Paths include the full checkpoint path prefix (e.g., \\\"/a1/b2c3d4e5f6/1/metadata.json\\\").\\n// Used in CheckpointSummary.Sessions to map session IDs to their file locations.\\ntype SessionFilePaths struct {\\n\\tMetadata    string `json:\\\"metadata\\\"`\\n\\tTranscript  string `json:\\\"transcript\\\"`\\n\\tContext     string `json:\\\"context\\\"`\\n\\tContentHash string `json:\\\"content_hash\\\"`\\n\\tPrompt      string `json:\\\"prompt\\\"`\\n}\\n\\n// CheckpointSummary is the root-level metadata.json for a checkpoint.\\n// It contains aggregated statistics from all sessions and a map of session IDs\\n// to their file paths. Session-specific data (including initial_attribution)\\n// is stored in the session's subdirectory metadata.json.\\n//\\n// Structure on entire/checkpoints/v1 branch:\\n//\\n//\\t<checkpoint-id[:2]>/<checkpoint-id[2:]>/\\n//\\t├── metadata.json         # This CheckpointSummary\\n//\\t├── 1/                    # First session\\n//\\t│   ├── metadata.json     # Session-specific CommittedMetadata\\n//\\t│   ├── full.jsonl\\n//\\t│   ├── prompt.txt\\n//\\t│   ├── context.md\\n//\\t│   └── content_hash.txt\\n//\\t├── 2/                    # Second session\\n//\\t└── 3/                    # Third session...\\n//\\n//nolint:revive // Named CheckpointSummary to avoid conflict with existing Summary struct\\ntype CheckpointSummary struct {\\n\\tCLIVersion       string             `json:\\\"cli_version,omitempty\\\"`\\n\\tCheckpointID     id.CheckpointID    `json:\\\"checkpoint_id\\\"`\\n\\tStrategy         string             `json:\\\"strategy\\\"`\\n\\tBranch           string             `json:\\\"branch,omitempty\\\"`\\n\\tCheckpointsCount int                `json:\\\"checkpoints_count\\\"`\\n\\tFilesTouched     []string           `json:\\\"files_touched\\\"`\\n\\tSessions         []SessionFilePaths `json:\\\"sessions\\\"`\\n\\tTokenUsage       *agent.TokenUsage  `json:\\\"token_usage,omitempty\\\"`\\n}\\n\\n// Summary contains AI-generated summary of a checkpoint.\\ntype Summary struct {\\n\\tIntent    string           `json:\\\"intent\\\"`     // What user wanted to accomplish\\n\\tOutcome   string           `json:\\\"outcome\\\"`    // What was achieved\\n\\tLearnings LearningsSummary `json:\\\"learnings\\\"`  // Categorized learnings\\n\\tFriction  []string         `json:\\\"friction\\\"`   // Problems/annoyances encountered\\n\\tOpenItems []string         `json:\\\"open_items\\\"` // Tech debt, unfinished work\\n}\\n\\n// LearningsSummary contains learnings grouped by scope.\\ntype LearningsSummary struct {\\n\\tRepo     []string       `json:\\\"repo\\\"`     // Codebase-specific patterns/conventions\\n\\tCode     []CodeLearning `json:\\\"code\\\"`     // File/module specific findings\\n\\tWorkflow []string       `json:\\\"workflow\\\"` // General dev practices\\n}\\n\\n// CodeLearning captures a learning tied to a specific code location.\\ntype CodeLearning struct {\\n\\tPath    string `json:\\\"path\\\"`               // File path\\n\\tLine    int    `json:\\\"line,omitempty\\\"`     // Start line number\\n\\tEndLine int    `json:\\\"end_line,omitempty\\\"` // End line for ranges (optional)\\n\\tFinding string `json:\\\"finding\\\"`            // What was learned\\n}\\n\\n// InitialAttribution captures line-level attribution metrics at commit time.\\n// This is a point-in-time snapshot comparing the checkpoint tree (agent work)\\n// against the committed tree (may include human edits).\\n//\\n// Attribution Metrics:\\n//   - TotalCommitted measures \\\"net additions\\\" (lines added that remain in the commit)\\n//   - AgentPercentage represents \\\"of the new code added, what percentage came from the agent\\\"\\n//   - Deletion work is tracked separately in HumanRemoved (not included in percentage)\\n//\\n// Deletion-Only Commits:\\n// For commits with only deletions (no additions), TotalCommitted will be 0 and\\n// AgentPercentage will be 0. This is by design - the percentage metric is only\\n// meaningful for commits that add code. Deletion contributions are captured in\\n// the HumanRemoved field but don't affect the attribution percentage.\\ntype InitialAttribution struct {\\n\\tCalculatedAt    time.Time `json:\\\"calculated_at\\\"`\\n\\tAgentLines      int       `json:\\\"agent_lines\\\"`      // Lines added by agent (base → shadow diff)\\n\\tHumanAdded      int       `json:\\\"human_added\\\"`      // Lines added by human (excluding modifications)\\n\\tHumanModified   int       `json:\\\"human_modified\\\"`   // Lines modified by human (estimate: min(added, removed))\\n\\tHumanRemoved    int       `json:\\\"human_removed\\\"`    // Lines removed by human (excluding modifications)\\n\\tTotalCommitted  int       `json:\\\"total_committed\\\"`  // Net additions in commit (agent + human new lines, not total file size)\\n\\tAgentPercentage float64   `json:\\\"agent_percentage\\\"` // agent_lines / total_committed * 100 (0 for deletion-only commits)\\n}\\n\\n// Info provides summary information for listing checkpoints.\\n// This is the generic checkpoint info type.\\ntype Info struct {\\n\\t// ID is the checkpoint identifier\\n\\tID string\\n\\n\\t// SessionID identifies the session\\n\\tSessionID string\\n\\n\\t// Type indicates temporary or committed\\n\\tType Type\\n\\n\\t// CreatedAt is when the checkpoint was created\\n\\tCreatedAt time.Time\\n\\n\\t// Message is a summary description\\n\\tMessage string\\n}\\n\\n// WriteTemporaryTaskOptions contains options for writing a task checkpoint.\\n// Task checkpoints are created when a subagent completes and contain both\\n// code changes and task-specific metadata.\\ntype WriteTemporaryTaskOptions struct {\\n\\t// SessionID is the session identifier\\n\\tSessionID string\\n\\n\\t// BaseCommit is the commit hash this session is based on\\n\\tBaseCommit string\\n\\n\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n\\t// Used to create worktree-specific shadow branch names\\n\\tWorktreeID string\\n\\n\\t// ToolUseID is the unique identifier for this Task tool invocation\\n\\tToolUseID string\\n\\n\\t// AgentID is the subagent identifier\\n\\tAgentID string\\n\\n\\t// ModifiedFiles are files that have been modified (relative paths)\\n\\tModifiedFiles []string\\n\\n\\t// NewFiles are files that have been created (relative paths)\\n\\tNewFiles []string\\n\\n\\t// DeletedFiles are files that have been deleted (relative paths)\\n\\tDeletedFiles []string\\n\\n\\t// TranscriptPath is the path to the main session transcript\\n\\tTranscriptPath string\\n\\n\\t// SubagentTranscriptPath is the path to the subagent's transcript\\n\\tSubagentTranscriptPath string\\n\\n\\t// CheckpointUUID is the UUID for transcript truncation when rewinding\\n\\tCheckpointUUID string\\n\\n\\t// CommitMessage is the commit message (already formatted)\\n\\tCommitMessage string\\n\\n\\t// AuthorName is the name to use for commits\\n\\tAuthorName string\\n\\n\\t// AuthorEmail is the email to use for commits\\n\\tAuthorEmail string\\n\\n\\t// IsIncremental indicates this is an incremental checkpoint\\n\\tIsIncremental bool\\n\\n\\t// IncrementalSequence is the checkpoint sequence number\\n\\tIncrementalSequence int\\n\\n\\t// IncrementalType is the tool that triggered this checkpoint\\n\\tIncrementalType string\\n\\n\\t// IncrementalData is the tool_input payload for this checkpoint\\n\\tIncrementalData []byte\\n}\\n\\n// TemporaryCheckpointInfo contains information about a single commit on a shadow branch.\\n// Used by ListTemporaryCheckpoints to provide rewind point data.\\ntype TemporaryCheckpointInfo struct {\\n\\t// CommitHash is the hash of the checkpoint commit\\n\\tCommitHash plumbing.Hash\\n\\n\\t// Message is the first line of the commit message\\n\\tMessage string\\n\\n\\t// SessionID is the session identifier from the Entire-Session trailer\\n\\tSess