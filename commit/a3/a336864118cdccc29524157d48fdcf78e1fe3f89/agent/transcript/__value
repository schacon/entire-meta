rr != nil {\\n    37→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    38→\\t}\\n    39→\\n    40→\\tcommitted, err := store.ListCommitted(context.Background())\\n    41→\\tif err != nil {\\n    42→\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n    43→\\t}\\n    44→\\n    45→\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n    46→\\tresult := make([]CheckpointInfo, 0, len(committed))\\n    47→\\tfor _, c := range committed {\\n    48→\\t\\tresult = append(result, CheckpointInfo{\\n    49→\\t\\t\\tCheckpointID:     c.CheckpointID,\\n    50→\\t\\t\\tSessionID:        c.SessionID,\\n    51→\\t\\t\\tCreatedAt:        c.CreatedAt,\\n    52→\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n    53→\\t\\t\\tFilesTouched:     c.FilesTouched,\\n    54→\\t\\t\\tAgent:            c.Agent,\\n    55→\\t\\t\\tIsTask:           c.IsTask,\\n    56→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    57→\\t\\t\\tSessionCount:     c.SessionCount,\\n    58→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    59→\\t\\t})\\n    60→\\t}\\n    61→\\n    62→\\treturn result, nil\\n    63→}\\n    64→\\n    65→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    66→func (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n    67→\\tall, err := s.listCheckpoints()\\n    68→\\tif err != nil {\\n    69→\\t\\treturn nil, err\\n    70→\\t}\\n    71→\\n    72→\\tvar result []CheckpointInfo\\n    73→\\tfor _, cp := range all {\\n    74→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    75→\\t\\t\\tresult = append(result, cp)\\n    76→\\t\\t}\\n    77→\\t}\\n    78→\\n    79→\\tif len(result) == 0 {\\n    80→\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n    81→\\t}\\n    82→\\n    83→\\treturn result, nil\\n    84→}\\n    85→\\n    86→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    87→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    88→func (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n    89→\\tstore, err := s.getCheckpointStore()\\n    90→\\tif err != nil {\\n    91→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    92→\\t}\\n    93→\\n    94→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n    95→\\tif err != nil {\\n    96→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    97→\\t}\\n    98→\\tif content == nil {\\n    99→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n   100→\\t}\\n   101→\\tif len(content.Transcript) == 0 {\\n   102→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   103→\\t}\\n   104→\\n   105→\\treturn content.Transcript, nil\\n   106→}\\n   107→\\n   108→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   109→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   110→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   111→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   112→//\\n   113→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   114→// In this case, data is extracted from the live transcript instead.\\n   115→func (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n   116→\\t// Get shadow branch (may not exist for mid-session commits)\\n   117→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   118→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   119→\\tref, err := repo.Reference(refName, true)\\n   120→\\thasShadowBranch := err == nil\\n   121→\\n   122→\\tvar sessionData *ExtractedSessionData\\n   123→\\tif hasShadowBranch {\\n   124→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   125→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   126→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   127→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   128→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   129→\\t\\t// last turn had no code changes).\\n   130→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   131→\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n   132→\\t\\tif err != nil {\\n   133→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n   134→\\t\\t}\\n   135→\\t} else {\\n   136→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   137→\\t\\t// Extract data directly from live transcript.\\n   138→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   139→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   140→\\t\\t}\\n   141→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   142→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   143→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   144→\\t\\tif state.Phase.IsActive() {\\n   145→\\t\\t\\tprepareTranscriptIfNeeded(state.AgentType, state.TranscriptPath)\\n   146→\\t\\t}\\n   147→\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n   148→\\t\\tif err != nil {\\n   149→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n   150→\\t\\t}\\n   151→\\t}\\n   152→\\n   153→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   154→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   155→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   156→\\tif len(committedFiles) > 0 {\\n   157→\\t\\t// Track if we had files before filtering to distinguish between:\\n   158→\\t\\t// - Session had files but none were committed (don't fallback)\\n   159→\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n   160→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   161→\\n   162→\\t\\tif hadFilesBeforeFiltering {\\n   163→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   164→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   165→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   166→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   167→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   168→\\t\\t\\t\\t}\\n   169→\\t\\t\\t}\\n   170→\\t\\t\\tsessionData.FilesTouched = filtered\\n   171→\\t\\t}\\n   172→\\n   173→\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n   174→\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n   175→\\t\\t// the session had files that simply didn't overlap with the commit - that\\n   176→\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n   177→\\t\\t// overwritten with unrelated committed files.\\n   178→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   179→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   180→\\t\\t\\tfor f := range committedFiles {\\n   181→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   182→\\t\\t\\t}\\n   183→\\t\\t}\\n   184→\\t}\\n   185→\\n   186→\\t// Get checkpoint store\\n   187→\\tstore, err := s.getCheckpointStore()\\n   188→\\tif err != nil {\\n   189→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   190→\\t}\\n   191→\\n   192→\\t// Get author info\\n   193→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   194→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   195→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   196→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   197→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n   198→\\t// Get current branch name\\n   199→\\tbranchName := GetCurrentBranchName(repo)\\n   200→\\n   201→\\t// Generate summary if enabled\\n   202→\\tvar summary *cpkg.Summary\\n   203→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   204→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   205→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   206→\\n   207→\\t\\t// Scope transcript to this checkpoint's portion.\\n   208→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   209→\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n   210→\\t\\tvar scopedTranscript []byte\\n   211→\\t\\tswitch state.AgentType {\\n   212→\\t\\tcase agent.AgentTypeGemini:\\n   213→\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   214→\\t\\t\\tif sliceErr != nil {\\n   215→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n   216→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   217→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   218→\\t\\t\\t}\\n   219→\\t\\t\\tscopedTranscript = scoped\\n   220→\\t\\tcase agent.AgentTypeOpenCode:\\n   221→\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   222→\\t\\t\\tif sliceErr != nil {\\n   223→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n   224→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   225→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   226→\\t\\t\\t}\\n   227→\\t\\t\\tscopedTranscript = scoped\\n   228→\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeUnknown:\\n   229→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   230→\\t\\t}\\n   231→\\t\\tif len(scopedTranscript) > 0 {\\n   232→\\t\\t\\tvar err error\\n   233→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   234→\\t\\t\\tif err != nil {\\n   235→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   236→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   237→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   238→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   239→\\t\\t\\t} else {\\n   240→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   241→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   242→\\t\\t\\t}\\n   243→\\t\\t}\\n   244→\\t}\\n   245→\\n   246→\\t// Write checkpoint metadata using the checkpoint store\\n   247→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   248→\\t\\tCheckpointID:                checkpointID,\\n   249→\\t\\tSessionID:                   state.SessionID,\\n   250→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   251→\\t\\tBranch:                      branchName,\\n   252→\\t\\tTranscript:                  sessionData.Transcript,\\n   253→\\t\\tPrompts:                     sessionData.Prompts,\\n   254→\\t\\tContext:                     sessionData.Context,\\n   255→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   256→\\t\\tCheckpointsCount:            state.StepCount,\\n   257→\\t\\tEphemeralBranch:             shadowBranchName,\\n   258→\\t\\tAuthorName:                  authorName,\\n   259→\\t\\tAuthorEmail:                 authorEmail,\\n   260→\\t\\tAgent:                       state.AgentType,\\n   261→\\t\\tTurnID:                      state.TurnID,\\n   262→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   263→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   264→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   265→\\t\\tInitialAttribution:          attribution,\\n   266→\\t\\tSummary:                     summary,\\n   267→\\t}); err != nil {\\n   268→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   269→\\t}\\n   270→\\n   271→\\treturn &CondenseResult{\\n   272→\\t\\tCheckpointID:         checkpointID,\\n   273→\\t\\tSessionID:            state.SessionID,\\n   274→\\t\\tCheckpointsCount:     state.StepCount,\\n   275→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   276→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   277→\\t}, nil\\n   278→}\\n   279→\\n   280→func calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n   281→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   282→\\t// This uses user edits captured at each prompt start (before agent works),\\n   283→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   284→\\t//\\n   285→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   286→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   287→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   288→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   289→\\n   290→\\theadRef, headErr := repo.Head()\\n   291→\\tif headErr != nil {\\n   292→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   293→\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   294→\\t\\treturn nil\\n   295→\\t}\\n   296→\\n   297→\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   298→\\tif commitErr != nil {\\n   299→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   300→\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   301→\\t\\treturn nil\\n   302→\\t}\\n   303→\\n   304→\\theadTree, treeErr := headCommit.Tree()\\n   305→\\tif treeErr != nil {\\n   306→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   307→\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   308→\\t\\treturn nil\\n   309→\\t}\\n   310→\\n   311→\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n   312→\\tvar shadowTree *object.Tree\\n   313→\\tif shadowRef != nil {\\n   314→\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   315→\\t\\tif shadowErr != nil {\\n   316→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   317→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   318→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   319→\\t\\t\\treturn nil\\n   320→\\t\\t}\\n   321→\\t\\tvar shadowTreeErr error\\n   322→\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   323→\\t\\tif shadowTreeErr != nil {\\n   324→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   325→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   326→\\t\\t\\treturn nil\\n   327→\\t\\t}\\n   328→\\t} else {\\n   329→\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   330→\\t\\t// because the agent's work is the commit itself.\\n   331→\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   332→\\t\\tshadowTree = headTree\\n   333→\\t}\\n   334→\\n   335→\\t// Get base tree (state before session started)\\n   336→\\tvar baseTree *object.Tree\\n   337→\\tattrBase := state.AttributionBaseCommit\\n   338→\\tif attrBase == \\\"\\\" {\\n   339→\\t\\tattrBase = state.BaseCommit // backward compat\\n   340→\\t}\\n   341→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   342→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   343→\\t\\t\\tbaseTree = tree\\n   344→\\t\\t} else {\\n   345→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   346→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   347→\\t\\t}\\n   348→\\t} else {\\n   349→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   350→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   351→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   352→\\t}\\n   353→\\n   354→\\t// Log accumulated prompt attributions for debugging\\n   355→\\tvar totalUserAdded, totalUserRemoved int\\n   356→\\tfor i, pa := range state.PromptAttributions {\\n   357→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   358→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   359→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   360→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   361→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   362→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   363→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   364→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   365→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   366→\\t}\\n   367→\\n   368→\\tattribution := CalculateAttributionWithAccumulated(\\n   369→\\t\\tbaseTree,\\n   370→\\t\\tshadowTree,\\n   371→\\t\\theadTree,\\n   372→\\t\\tsessionData.FilesTouched,\\n   373→\\t\\tstate.PromptAttributions,\\n   374→\\t)\\n   375→\\n   376→\\tif attribution != nil {\\n   377→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   378→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   379→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   380→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   381→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   382→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   383→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   384→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   385→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   386→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   387→\\t}\\n   388→\\n   389→\\treturn attribution\\n   390→}\\n   391→\\n   392→// extractSessionData extracts session data from the shadow branch.\\n   393→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   394→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   395→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   396→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   397→// continued growing — the shadow branch copy would be stale.\\n   398→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   399→func (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n   400→\\tcommit, err := repo.CommitObject(shadowRef)\\n   401→\\tif err != nil {\\n   402→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   403→\\t}\\n   404→\\n   405→\\ttree, err := commit.Tree()\\n   406→\\tif err != nil {\\n   407→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   408→\\t}\\n   409→\\n   410→\\tdata := &ExtractedSessionData{}\\n   411→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   412→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   413→\\n   414→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   415→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   416→\\t// (SaveStep is only called when there are file modifications).\\n   417→\\tvar fullTranscript string\\n   418→\\tif liveTranscriptPath != \\\"\\\" {\\n   419→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   420→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   421→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   422→\\t\\tif isActive {\\n   423→\\t\\t\\tprepareTranscriptIfNeeded(agentType, liveTranscriptPath)\\n   424→\\t\\t}\\n   425→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   426→\\t\\t\\tfullTranscript = string(liveData)\\n   427→\\t\\t}\\n   428→\\t}\\n   429→\\tif fullTranscript == \\\"\\\" {\\n   430→\\t\\t// Fall back to shadow branch copy\\n   431→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   432→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   433→\\t\\t\\t\\tfullTranscript = content\\n   434→\\t\\t\\t}\\n   435→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   436→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   437→\\t\\t\\t\\tfullTranscript = content\\n   438→\\t\\t\\t}\\n   439→\\t\\t}\\n   440→\\t}\\n   441→\\n   442→\\t// Process transcript based on agent type\\n   443→\\tif fullTranscript != \\\"\\\" {\\n   444→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   445→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   446→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   447→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   448→\\t}\\n   449→\\n   450→\\t// Use tracked files from session state (not all files in tree)\\n   451→\\tdata.FilesTouched = filesTouched\\n   452→\\n   453→\\t// Calculate token usage from the extracted transcript portion\\n   454→\\tif len(data.Transcript) > 0 {\\n   455→\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n   456→\\t}\\n   457→\\n   458→\\treturn data, nil\\n   459→}\\n   460→\\n   461→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   462→// This is used for mid-session commits where no shadow branch exists yet.\\n   463→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n   464→\\tdata := &ExtractedSessionData{}\\n   465→\\n   466→\\t// Read the live transcript\\n   467→\\tif state.TranscriptPath == \\\"\\\" {\\n   468→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   469→\\t}\\n   470→\\n   471→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   472→\\tif err != nil {\\n   473→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   474→\\t}\\n   475→\\n   476→\\tif len(liveData) == 0 {\\n   477→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   478→\\t}\\n   479→\\n   480→\\tfullTranscript := string(liveData)\\n   481→\\tdata.Transcript = liveData\\n   482→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   483→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   484→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   485→\\n   486→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   487→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   488→\\tif len(state.FilesTouched) > 0 {\\n   489→\\t\\tdata.FilesTouched = state.FilesTouched\\n   490→\\t} else {\\n   491→\\t\\t// Use the shared helper which includes subagent transcripts\\n   492→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n   493→\\t}\\n   494→\\n   495→\\t// Calculate token usage from the extracted transcript portion\\n   496→\\tif len(data.Transcript) > 0 {\\n   497→\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n   498→\\t}\\n   499→\\n   500→\\treturn data, nil\\n   501→}\\n   502→\\n   503→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   504→// For Claude Code and JSONL-based agents, this counts lines.\\n   505→// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n   506→// Returns 0 if the content is empty or malformed.\\n   507→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   508→\\tif content == \\\"\\\" {\\n   509→\\t\\treturn 0\\n   510→\\t}\\n   511→\\n   512→\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n   513→\\tif agentType == agent.AgentTypeOpenCode {\\n   514→\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n   515→\\t\\tif err == nil && session != nil {\\n   516→\\t\\t\\treturn len(session.Messages)\\n   517→\\t\\t}\\n   518→\\t\\treturn 0\\n   519→\\t}\\n   520→\\n   521→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   522→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   523→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   524→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   525→\\t\\t\\treturn len(transcript.Messages)\\n   526→\\t\\t}\\n   527→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   528→\\t\\tif agentType == agent.AgentTypeGemini {\\n   529→\\t\\t\\treturn 0\\n   530→\\t\\t}\\n   531→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   532→\\t}\\n   533→\\n   534→\\t// Claude Code and other JSONL-based agents\\n   535→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   536→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   537→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   538→\\t\\tallLines = allLines[:len(allLines)-1]\\n   539→\\t}\\n   540→\\treturn len(allLines)\\n   541→}\\n   542→\\n   543→// extractUserPrompts extracts all user prompts from transcript content.\\n   544→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   545→func extractUserPrompts(agentType agent.AgentType, content string) []string {\\n   546→\\tif content == \\\"\\\" {\\n   547→\\t\\treturn nil\\n   548→\\t}\\n   549→\\n   550→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   551→\\tif agentType == agent.AgentTypeOpenCode {\\n   552→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   553→\\t\\tif err == nil && len(prompts) > 0 {\\n   554→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   555→\\t\\t\\tfor _, prompt := range prompts {\\n   556→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   557→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   558→\\t\\t\\t\\t}\\n   559→\\t\\t\\t}\\n   560→\\t\\t\\treturn cleaned\\n   561→\\t\\t}\\n   562→\\t\\treturn nil\\n   563→\\t}\\n   564→\\n   565→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   566→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   567→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   568→\\t\\tif err == nil && len(prompts) > 0 {\\n   569→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   570→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   571→\\t\\t\\tfor _, prompt := range prompts {\\n   572→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   573→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   574→\\t\\t\\t\\t}\\n   575→\\t\\t\\t}\\n   576→\\t\\t\\treturn cleaned\\n   577→\\t\\t}\\n   578→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   579→\\t\\tif agentType == agent.AgentTypeGemini {\\n   580→\\t\\t\\treturn nil\\n   581→\\t\\t}\\n   582→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   583→\\t}\\n   584→\\n   585→\\t// Claude Code and other JSONL-based agents\\n   586→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   587→}\\n   588→\\n   589→// calculateTokenUsage calculates token usage from raw transcript data.\\n   590→// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n   591→// where the current checkpoint began, allowing calculation for only the portion\\n   592→// of the transcript since the last checkpoint.\\n   593→func calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n   594→\\tif len(data) == 0 {\\n   595→\\t\\treturn &agent.TokenUsage{}\\n   596→\\t}\\n   597→\\n   598→\\t// OpenCode uses JSONL with token info on assistant messages (different schema from Claude Code)\\n   599→\\tif agentType == agent.AgentTypeOpenCode {\\n   600→\\t\\treturn opencode.CalculateTokenUsageFromBytes(data, startOffset)\\n   601→\\t}\\n   602→\\n   603→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   604→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   605→\\t\\t// Attempt to parse as Gemini JSON\\n   606→\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n   607→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   608→\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n   609→\\t\\t}\\n   610→\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n   611→\\t\\tif agentType == agent.AgentTypeGemini {\\n   612→\\t\\t\\treturn &agent.TokenUsage{}\\n   613→\\t\\t}\\n   614→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   615→\\t}\\n   616→\\n   617→\\t// Claude Code and other JSONL-based agents\\n   618→\\tlines, err := transcript.ParseFromBytes(data)\\n   619→\\tif err != nil || len(lines) == 0 {\\n   620→\\t\\treturn &agent.TokenUsage{}\\n   621→\\t}\\n   622→\\t// Slice transcript lines to only include checkpoint portion\\n   623→\\tif startOffset > 0 && startOffset < len(lines) {\\n   624→\\t\\tlines = lines[startOffset:]\\n   625→\\t}\\n   626→\\treturn claudecode.CalculateTokenUsage(lines)\\n   627→}\\n   628→\\n   629→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   630→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   631→func extractUserPromptsFromLines(lines []string) []string {\\n   632→\\tvar prompts []string\\n   633→\\tfor _, line := range lines {\\n   634→\\t\\tline = strings.TrimSpace(line)\\n   635→\\t\\tif line == \\\"\\\" {\\n   636→\\t\\t\\tcontinue\\n   637→\\t\\t}\\n   638→\\n   639→\\t\\tvar entry map[string]interface{}\\n   640→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   641→\\t\\t\\tcontinue\\n   642→\\t\\t}\\n   643→\\n   644→\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n   645→\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n   646→\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n   647→\\t\\t\\tcontinue\\n   648→\\t\\t}\\n   649→\\n   650→\\t\\t// Extract message content\\n   651→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   652→\\t\\tif !ok {\\n   653→\\t\\t\\tcontinue\\n   654→\\t\\t}\\n   655→\\n   656→\\t\\t// Handle string content\\n   657→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   658→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   659→\\t\\t\\tif cleaned != \\\"\\\" {\\n   660→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   661→\\t\\t\\t}\\n   662→\\t\\t\\tcontinue\\n   663→\\t\\t}\\n   664→\\n   665→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   666→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   667→\\t\\t\\tvar texts []string\\n   668→\\t\\t\\tfor _, item := range arr {\\n   669→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   670→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   671→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   672→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   673→\\t\\t\\t\\t\\t\\t}\\n   674→\\t\\t\\t\\t\\t}\\n   675→\\t\\t\\t\\t}\\n   676→\\t\\t\\t}\\n   677→\\t\\t\\tif len(texts) > 0 {\\n   678→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   679→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   680→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   681→\\t\\t\\t\\t}\\n   682→\\t\\t\\t}\\n   683→\\t\\t}\\n   684→\\t}\\n   685→\\treturn prompts\\n   686→}\\n   687→\\n   688→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   689→func generateContextFromPrompts(prompts []string) []byte {\\n   690→\\tif len(prompts) == 0 {\\n   691→\\t\\treturn nil\\n   692→\\t}\\n   693→\\n   694→\\tvar buf strings.Builder\\n   695→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   696→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   697→\\n   698→\\tfor i, prompt := range prompts {\\n   699→\\t\\t// Truncate very long prompts for readability.\\n   700→\\t\\t// Use rune-based truncation to avoid splitting multi-byte UTF-8 characters (e.g. CJK).\\n   701→\\t\\tdisplayPrompt := stringutil.TruncateRunes(prompt, 500, \\\"...\\\")\\n   702→\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n   703→\\t\\tbuf.WriteString(displayPrompt)\\n   704→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   705→\\t}\\n   706→\\n   707→\\treturn []byte(buf.String())\\n   708→}\\n   709→\\n   710→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   711→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   712→func (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n   713→\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n   714→\\n   715→\\t// Load session state\\n   716→\\tstate, err := s.loadSessionState(sessionID)\\n   717→\\tif err != nil {\\n   718→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   719→\\t}\\n   720→\\tif state == nil {\\n   721→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   722→\\t}\\n   723→\\n   724→\\t// Open repository\\n   725→\\trepo, err := OpenRepository()\\n   726→\\tif err != nil {\\n   727→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   728→\\t}\\n   729→\\n   730→\\t// Generate a checkpoint ID\\n   731→\\tcheckpointID, err := id.Generate()\\n   732→\\tif err != nil {\\n   733→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   734→\\t}\\n   735→\\n   736→\\t// Check if shadow branch exists (required for condensation)\\n   737→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   738→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   739→\\t_, refErr := repo.Reference(refName, true)\\n   740→\\thasShadowBranch := refErr == nil\\n   741→\\n   742→\\tif !hasShadowBranch {\\n   743→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   744→\\t\\t// Just clean up the state file.\\n   745→\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n   746→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   747→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   748→\\t\\t)\\n   749→\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n   750→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   751→\\t\\t}\\n   752→\\t\\treturn nil\\n   753→\\t}\\n   754→\\n   755→\\t// Condense the session\\n   756→\\tresult, err := s.CondenseSession(repo, checkpointID, state, nil)\\n   757→\\tif err != nil {\\n   758→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   759→\\t}\\n   760→\\n   761→\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n   762→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   763→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   764→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   765→\\t)\\n   766→\\n   767→\\t// Update session state: reset step count and transition to idle\\n   768→\\tstate.StepCount = 0\\n   769→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   770→\\tstate.Phase = session.PhaseIdle\\n   771→\\tstate.LastCheckpointID = checkpointID\\n   772→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   773→\\tstate.PromptAttributions = nil\\n   774→\\tstate.PendingPromptAttribution = nil\\n   775→\\n   776→\\tif err := s.saveSessionState(state); err != nil {\\n   777→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   778→\\t}\\n   779→\\n   780→\\t// Clean up shadow branch if no other sessions need it\\n   781→\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n   782→\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n   783→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   784→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   785→\\t\\t)\\n   786→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   787→\\t}\\n   788→\\n   789→\\treturn nil\\n   790→}\\n   791→\\n   792→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   793→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(_ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   794→\\t// List all session states to check if any other session uses this shadow branch\\n   795→\\tallStates, err := s.listAllSessionStates()\\n   796→\\tif err != nil {\\n   797→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   798→\\t}\\n   799→\\n   800→\\tfor _, state := range allStates {\\n   801→\\t\\tif state.SessionID == excludeSessionID {\\n   802→\\t\\t\\tcontinue\\n   803→\\t\\t}\\n   804→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   805→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   806→\\t\\t\\t// Another session still needs this shadow branch\\n   807→\\t\\t\\treturn nil\\n   808→\\t\\t}\\n   809→\\t}\\n   810→\\n   811→\\t// No other sessions need it, delete the shadow branch via CLI\\n   812→\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n   813→\\tif err := DeleteBranchCLI(shadowBranchName); err != nil {\\n   814→\\t\\t// Branch already gone is not an error\\n   815→\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n   816→\\t\\t\\treturn nil\\n   817→\\t\\t}\\n   818→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n   819→\\t}\\n   820→\\treturn nil\\n   821→}\\n   822→\"}]},\"uuid\":\"3a825d5c-df43-4b90-addb-ab186dc6c5cd\",\"timestamp\":\"2026-02-24T22:23:25.413Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/evisdrenova/code/entire/devenv/cli/cmd/entire/cli/strategy/manual_commit_condensation.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/opencode\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/stringutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// listCheckpoints returns all checkpoints from the metadata branch.\\n// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) listCheckpoints() ([]CheckpointInfo, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcommitted, err := store.ListCommitted(context.Background())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n\\t}\\n\\n\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n\\tresult := make([]CheckpointInfo, 0, len(committed))\\n\\tfor _, c := range committed {\\n\\t\\tresult = append(result, CheckpointInfo{\\n\\t\\t\\tCheckpointID:     c.CheckpointID,\\n\\t\\t\\tSessionID:        c.SessionID,\\n\\t\\t\\tCreatedAt:        c.CreatedAt,\\n\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n\\t\\t\\tFilesTouched:     c.FilesTouched,\\n\\t\\t\\tAgent:            c.Agent,\\n\\t\\t\\tIsTask:           c.IsTask,\\n\\t\\t\\tToolUseID:        c.ToolUseID,\\n\\t\\t\\tSessionCount:     c.SessionCount,\\n\\t\\t\\tSessionIDs:       c.SessionIDs,\\n\\t\\t})\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointsForSession returns all checkpoints for a session ID.\\nfunc (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n\\tall, err := s.listCheckpoints()\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tvar result []CheckpointInfo\\n\\tfor _, cp := range all {\\n\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n\\t\\t\\tresult = append(result, cp)\\n\\t\\t}\\n\\t}\\n\\n\\tif len(result) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// CondenseSession condenses a session's shadow branch to permanent storage.\\n// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n//\\n// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n// In this case, data is extracted from the live transcript instead.\\nfunc (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n\\t// Get shadow branch (may not exist for mid-session commits)\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\thasShadowBranch := err == nil\\n\\n\\tvar sessionData *ExtractedSessionData\\n\\tif hasShadowBranch {\\n\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n\\t\\t// last turn had no code changes).\\n\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n\\t\\t// Extract data directly from live transcript.\\n\\t\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n\\t\\t}\\n\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n\\t\\tif state.Phase.IsActive() {\\n\\t\\t\\tprepareTranscriptIfNeeded(state.AgentType, state.TranscriptPath)\\n\\t\\t}\\n\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n\\t// committed in this specific commit. This ensures each checkpoint represents\\n\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n\\tif len(committedFiles) > 0 {\\n\\t\\t// Track if we had files before filtering to distinguish between:\\n\\t\\t// - Session had files but none were committed (don't fallback)\\n\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n\\n\\t\\tif hadFilesBeforeFiltering {\\n\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tsessionData.FilesTouched = filtered\\n\\t\\t}\\n\\n\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n\\t\\t// the session had files that simply didn't overlap with the commit - that\\n\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n\\t\\t// overwritten with unrelated committed files.\\n\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n\\t\\t\\tfor f := range committedFiles {\\n\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Get checkpoint store\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get author info\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Generate summary if enabled\\n\\tvar summary *cpkg.Summary\\n\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n\\n\\t\\t// Scope transcript to this checkpoint's portion.\\n\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n\\t\\tvar scopedTranscript []byte\\n\\t\\tswitch state.AgentType {\\n\\t\\tcase agent.AgentTypeGemini:\\n\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t\\tif sliceErr != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n\\t\\t\\t}\\n\\t\\t\\tscopedTranscript = scoped\\n\\t\\tcase agent.AgentTypeOpenCode:\\n\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t\\tif sliceErr != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n\\t\\t\\t}\\n\\t\\t\\tscopedTranscript = scoped\\n\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeUnknown:\\n\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t}\\n\\t\\tif len(scopedTranscript) > 0 {\\n\\t\\t\\tvar err error\\n\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t\\t// Continue without summary - non-blocking\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write checkpoint metadata using the checkpoint store\\n\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n\\t\\tCheckpointID:                checkpointID,\\n\\t\\tSessionID:                   state.SessionID,\\n\\t\\tStrategy:                    StrategyNameManualCommit,\\n\\t\\tBranch:                      branchName,\\n\\t\\tTranscript:                  sessionData.Transcript,\\n\\t\\tPrompts:                     sessionData.Prompts,\\n\\t\\tContext:                     sessionData.Context,\\n\\t\\tFilesTouched:                sessionData.FilesTouched,\\n\\t\\tCheckpointsCount:            state.StepCount,\\n\\t\\tEphemeralBranch:             shadowBranchName,\\n\\t\\tAuthorName:                  authorName,\\n\\t\\tAuthorEmail:                 authorEmail,\\n\\t\\tAgent:                       state.AgentType,\\n\\t\\tTurnID:                      state.TurnID,\\n\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n\\t\\tInitialAttribution:          attribution,\\n\\t\\tSummary:                     summary,\\n\\t}); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n\\t}\\n\\n\\treturn &CondenseResult{\\n\\t\\tCheckpointID:         checkpointID,\\n\\t\\tSessionID:            state.SessionID,\\n\\t\\tCheckpointsCount:     state.StepCount,\\n\\t\\tFilesTouched:         sessionData.FilesTouched,\\n\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n\\t}, nil\\n}\\n\\nfunc calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n\\t// Calculate initial attribution using accumulated prompt attribution data.\\n\\t// This uses user edits captured at each prompt start (before agent works),\\n\\t// plus any user edits after the final checkpoint (shadow → head).\\n\\t//\\n\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\n\\theadRef, headErr := repo.Head()\\n\\tif headErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n\\tif commitErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\theadTree, treeErr := headCommit.Tree()\\n\\tif treeErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n\\tvar shadowTree *object.Tree\\n\\tif shadowRef != nil {\\n\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n\\t\\tif shadowErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\tvar shadowTreeErr error\\n\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n\\t\\tif shadowTreeErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n\\t\\t// because the agent's work is the commit itself.\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n\\t\\tshadowTree = headTree\\n\\t}\\n\\n\\t// Get base tree (state before session started)\\n\\tvar baseTree *object.Tree\\n\\tattrBase := state.AttributionBaseCommit\\n\\tif attrBase == \\\"\\\" {\\n\\t\\tattrBase = state.BaseCommit // backward compat\\n\\t}\\n\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n\\t\\t\\tbaseTree = tree\\n\\t\\t} else {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n\\t\\t}\\n\\t} else {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n\\t}\\n\\n\\t// Log accumulated prompt attributions for debugging\\n\\tvar totalUserAdded, totalUserRemoved int\\n\\tfor i, pa := range state.PromptAttributions {\\n\\t\\ttotalUserAdded += pa.UserLinesAdded\\n\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"index\\\", i))\\n\\t}\\n\\n\\tattribution := CalculateAttributionWithAccumulated(\\n\\t\\tbaseTree,\\n\\t\\tshadowTree,\\n\\t\\theadTree,\\n\\t\\tsessionData.FilesTouched,\\n\\t\\tstate.PromptAttributions,\\n\\t)\\n\\n\\tif attribution != nil {\\n\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n\\t}\\n\\n\\treturn attribution\\n}\\n\\n// extractSessionData extracts session data from the shadow branch.\\n// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n// continued growing — the shadow branch copy would be stale.\\n// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\nfunc (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n\\tcommit, err := repo.CommitObject(shadowRef)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\tdata := &ExtractedSessionData{}\\n\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\n\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n\\t// (SaveStep is only called when there are file modifications).\\n\\tvar fullTranscript string\\n\\tif liveTranscriptPath != \\\"\\\" {\\n\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n\\t\\tif isActive {\\n\\t\\t\\tprepareTranscriptIfNeeded(agentType, liveTranscriptPath)\\n\\t\\t}\\n\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n\\t\\t\\tfullTranscript = string(liveData)\\n\\t\\t}\\n\\t}\\n\\tif fullTranscript == \\\"\\\" {\\n\\t\\t// Fall back to shadow branch copy\\n\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Process transcript based on agent type\\n\\tif fullTranscript != \\\"\\\" {\\n\\t\\tdata.Transcript = []byte(fullTranscript)\\n\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\t}\\n\\n\\t// Use tracked files from session state (not all files in tree)\\n\\tdata.FilesTouched = filesTouched\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n// This is used for mid-session commits where no shadow branch exists yet.\\nfunc (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n\\tdata := &ExtractedSessionData{}\\n\\n\\t// Read the live transcript\\n\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n\\t}\\n\\n\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n\\t}\\n\\n\\tif len(liveData) == 0 {\\n\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n\\t}\\n\\n\\tfullTranscript := string(liveData)\\n\\tdata.Transcript = liveData\\n\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\n\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n\\t// (no SaveStep/Stop has been called yet to populate it)\\n\\tif len(state.FilesTouched) > 0 {\\n\\t\\tdata.FilesTouched = state.FilesTouched\\n\\t} else {\\n\\t\\t// Use the shared helper which includes subagent transcripts\\n\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n\\t}\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n// For Claude Code and JSONL-based agents, this counts lines.\\n// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n// Returns 0 if the content is empty or malformed.\\nfunc countTranscriptItems(agentType agent.AgentType, content string) int {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn 0\\n\\t}\\n\\n\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n\\tif agentType == agent.AgentTypeOpenCode {\\n\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n\\t\\tif err == nil && session != nil {\\n\\t\\t\\treturn len(session.Messages)\\n\\t\\t}\\n\\t\\treturn 0\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n\\t\\t\\treturn len(transcript.Messages)\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn 0\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n\\t\\tallLines = allLines[:len(allLines)-1]\\n\\t}\\n\\treturn len(allLines)\\n}\\n\\n// extractUserPrompts extracts all user prompts from transcript content.\\n// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\nfunc extractUserPrompts(agentType agent.AgentType, content string) []string {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n\\tif agentType == agent.AgentTypeOpenCode {\\n\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n\\t\\tif err == nil && len(prompts) > 0 {\\n\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n\\t\\t\\tfor _, prompt := range prompts {\\n\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\treturn cleaned\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n\\t\\tif err == nil && len(prompts) > 0 {\\n\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n\\t\\t\\tfor _, prompt := range prompts {\\n\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\treturn cleaned\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n}\\n\\n// calculateTokenUsage calculates token usage from raw transcript data.\\n// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n// where the current checkpoint began, allowing calculation for only the portion\\n// of the transcript since the last checkpoint.\\nfunc calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n\\tif len(data) == 0 {\\n\\t\\treturn &agent.TokenUsage{}\\n\\t}\\n\\n\\t// OpenCode uses JSONL with token info on assistant messages (different schema from Claude Code)\\n\\tif agentType == agent.AgentTypeOpenCode {\\n\\t\\treturn opencode.CalculateTokenUsageFromBytes(data, startOffset)\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\t// Attempt to parse as Gemini JSON\\n\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn &agent.TokenUsage{}\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\tlines, err := transcript.ParseFromBytes(data)\\n\\tif err != nil || len(lines) == 0 {\\n\\t\\treturn &agent.TokenUsage{}\\n\\t}\\n\\t// Slice transcript lines to only include checkpoint portion\\n\\tif startOffset > 0 && startOffset < len(lines) {\\n\\t\\tlines = lines[startOffset:]\\n\\t}\\n\\treturn claudecode.CalculateTokenUsage(lines)\\n}\\n\\n// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\nfunc extractUserPromptsFromLines(lines []string) []string {\\n\\tvar prompts []string\\n\\tfor _, line := range lines {\\n\\t\\tline = strings.TrimSpace(line)\\n\\t\\tif line == \\\"\\\" {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tvar entry map[string]interface{}\\n\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Extract message content\\n\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n\\t\\tif !ok {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Handle string content\\n\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n\\t\\t\\tif cleaned != \\\"\\\" {\\n\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n\\t\\t\\t}\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n\\t\\t\\tvar texts []string\\n\\t\\t\\tfor _, item := range arr {\\n\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tif len(texts) > 0 {\\n\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\treturn prompts\\n}\\n\\n// generateContextFromPrompts generates context.md content from a list of prompts.\\nfunc generateContextFromPrompts(prompts []string) []byte {\\n\\tif len(prompts) == 0 {\\n\\t\\treturn nil\\n\\t}\\n\\n\\tvar buf strings.Builder\\n\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n\\n\\tfor i, prompt := range prompts {\\n\\t\\t// Truncate very long prompts for readability.\\n\\t\\t// Use rune-based truncation to avoid splitting multi-byte UTF-8 characters (e.g. CJK).\\n\\t\\tdisplayPrompt := stringutil.TruncateRunes(prompt, 500, \\\"...\\\")\\n\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n\\t\\tbuf.WriteString(displayPrompt)\\n\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n\\t}\\n\\n\\treturn []byte(buf.String())\\n}\\n\\n// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\nfunc (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n\\n\\t// Load session state\\n\\tstate, err := s.loadSessionState(sessionID)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n\\t}\\n\\tif state == nil {\\n\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n\\t}\\n\\n\\t// Open repository\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\t// Generate a checkpoint ID\\n\\tcheckpointID, err := id.Generate()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n\\t}\\n\\n\\t// Check if shadow branch exists (required for condensation)\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\t_, refErr := repo.Reference(refName, true)\\n\\thasShadowBranch := refErr == nil\\n\\n\\tif !hasShadowBranch {\\n\\t\\t// No shadow branch means no checkpoint data to condense.\\n\\t\\t// Just clean up the state file.\\n\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n\\t\\t)\\n\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Condense the session\\n\\tresult, err := s.CondenseSession(repo, checkpointID, state, nil)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n\\t}\\n\\n\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n\\t)\\n\\n\\t// Update session state: reset step count and transition to idle\\n\\tstate.StepCount = 0\\n\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n\\tstate.Phase = session.PhaseIdle\\n\\tstate.LastCheckpointID = checkpointID\\n\\tstate.AttributionBaseCommit = state.BaseCommit\\n\\tstate.PromptAttributions = nil\\n\\tstate.PendingPromptAttribution = nil\\n\\n\\tif err := s.saveSessionState(state); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n\\t}\\n\\n\\t// Clean up shadow branch if no other sessions need it\\n\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n\\t\\t)\\n\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\nfunc (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(_ *git.Repository, shadowBranc