ommit: \\\"abc1234\\\",\\n   181→\\t\\tStartedAt:  time.Now(),\\n   182→\\t\\tStepCount:  1,\\n   183→\\t}\\n   184→\\tstate2 := &SessionState{\\n   185→\\t\\tSessionID:  \\\"session-2\\\",\\n   186→\\t\\tBaseCommit: \\\"abc1234\\\",\\n   187→\\t\\tStartedAt:  time.Now(),\\n   188→\\t\\tStepCount:  2,\\n   189→\\t}\\n   190→\\n   191→\\tif err := s.saveSessionState(state1); err != nil {\\n   192→\\t\\tt.Fatalf(\\\"saveSessionState() error = %v\\\", err)\\n   193→\\t}\\n   194→\\tif err := s.saveSessionState(state2); err != nil {\\n   195→\\t\\tt.Fatalf(\\\"saveSessionState() error = %v\\\", err)\\n   196→\\t}\\n   197→\\n   198→\\t// List all states\\n   199→\\tstates, err := s.listAllSessionStates()\\n   200→\\tif err != nil {\\n   201→\\t\\tt.Fatalf(\\\"listAllSessionStates() error = %v\\\", err)\\n   202→\\t}\\n   203→\\n   204→\\tif len(states) != 2 {\\n   205→\\t\\tt.Errorf(\\\"listAllSessionStates() returned %d states, want 2\\\", len(states))\\n   206→\\t}\\n   207→}\\n   208→\\n   209→// TestShadowStrategy_ListAllSessionStates_CleansUpStaleSessions tests that\\n   210→// listAllSessionStates cleans up stale sessions whose shadow branch no longer exists.\\n   211→// Stale sessions include: pre-state-machine sessions (empty phase), IDLE/ENDED sessions\\n   212→// that were never condensed. Active sessions and sessions with LastCheckpointID are kept.\\n   213→func TestShadowStrategy_ListAllSessionStates_CleansUpStaleSessions(t *testing.T) {\\n   214→\\tdir := t.TempDir()\\n   215→\\t_, err := git.PlainInit(dir, false)\\n   216→\\tif err != nil {\\n   217→\\t\\tt.Fatalf(\\\"failed to init git repo: %v\\\", err)\\n   218→\\t}\\n   219→\\n   220→\\tt.Chdir(dir)\\n   221→\\n   222→\\ts := &ManualCommitStrategy{}\\n   223→\\tnow := time.Now()\\n   224→\\n   225→\\t// None of these sessions have shadow branches → cleanup logic applies.\\n   226→\\n   227→\\t// Session 1: Pre-state-machine session (empty phase, no checkpoint ID)\\n   228→\\t// Should be cleaned up.\\n