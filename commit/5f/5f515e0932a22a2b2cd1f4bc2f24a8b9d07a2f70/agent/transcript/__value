ranscriptStart)\\n   623→\\n   624→\\t// ========================================\\n   625→\\t// Phase 2: Simulate agent resume + crash (ACTIVE with hasNew=true)\\n   626→\\t// Set ACTIVE and reset CheckpointTranscriptStart to simulate:\\n   627→\\t// - Agent was resumed (ACTIVE)\\n   628→\\t// - Did more work (transcript grew, but not saved to checkpoint yet)\\n   629→\\t// - Then crashed (stuck ACTIVE with hasNew=true)\\n   630→\\t// ========================================\\n   631→\\tt.Log(\\\"Phase 2: Simulating agent resume then crash (ACTIVE with hasNew=true)\\\")\\n   632→\\n   633→\\tstate1.Phase = session.PhaseActive\\n   634→\\tstate1.CheckpointTranscriptStart = 0 // Force hasNew=true (transcript > 0)\\n   635→\\tif err := env.WriteSessionState(session1.ID, state1); err != nil {\\n   636→\\t\\tt.Fatalf(\\\"WriteSessionState for session1 failed: %v\\\", err)\\n   637→\\t}\\n   638→\\n   639→\\t// Record state for comparison\\n   640→\\tsession1StepCount := state1.StepCount\\n   641→\\tt.Logf(\\\"Session1 (stale ACTIVE) StepCount: %d, CheckpointTranscriptStart: %d (forced to 0 for hasNew=true)\\\",\\n   642→\\t\\tsession1StepCount, state1.CheckpointTranscriptStart)\\n   643→\\n   644→\\t// ========================================\\n   645→\\t// Phase 2b: Make an unrelated commit to move HEAD forward\\n   646→\\t// This ensures Session 1 and Session 2 have DIFFERENT shadow branches\\n   647→\\t// (different BaseCommit), isolating their condensation behavior.\\n   648→\\t// ========================================\\n   649→\\tt.Log(\\\"Phase 2b: Making unrelated commit to separate shadow branches\\\")\\n   650→\\tenv.WriteFile(\\\"unrelated.txt\\\", \\\"unrelated content\\\")\\n   651→\\tenv.GitAdd(\\\"unrelated.txt\\\")\\n   652→\\tenv.GitCommit(\\\"Unrelated commit to move HEAD\\\")\\n   653→\\n   654→\\t// ========================================\\n   655→\\t// Phase 3: New session 2 creates unrelated file\\n   656→\\t// ========================================\\n   657→\\tt.Log(\\\"Phase 3: Session 2 creates file2.txt (unrelated to session 1)\\\")\\n   658→\\n   659→\\tsession2 := env.NewSession()\\n   660→\\tif err := env.SimulateUserPromptSubmit(session2.ID); err != nil {\\n   661→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit for session2 failed: %v\\\", err)\\n   662→\\t}\\n   663→\\n   664→\\tenv.WriteFile(\\\"file2.txt\\\", \\\"content from session 2\\\")\\n   665→\\tsession2.CreateTranscript(\\n   666→\\t\\t\\\"Create file2\\\",\\n   667→\\t\\t[]FileChange{{Path: \\\"file2.txt\\\", Content: \\\"content from session 2\\\"}},\\n   668→\\t)\\n   669→\\tif err := env.SimulateStop(session2.ID, session2.TranscriptPath); err != nil {\\n   670→\\t\\tt.Fatalf(\\\"SimulateStop for session2 failed: %v\\\", err)\\n   671→\\t}\\n   672→\\n   673→\\t// Set session2 to ACTIVE\\n   674→\\tstate2, err := env.GetSessionState(session2.ID)\\n   675→\\tif err != nil {\\n   676→\\t\\tt.Fatalf(\\\"GetSessionState for session2 failed: %v\\\", err)\\n   677→\\t}\\n   678→\\tstate2.Phase = session.PhaseActive\\n   679→\\tif err := env.WriteSessionState(session2.ID, state2); err != nil {\\n   680→\\t\\tt.Fatalf(\\\"WriteSessionState for session2 failed: %v\\\", err)\\n   681→\\t}\\n   682→\\n   683→\\t// ========================================\\n   684→\\t// Phase 4: Commit file2.txt (unrelated to session 1)\\n   685→\\t// ========================================\\n   686→\\tt.Log(\\\"Phase 4: Committing file2.txt from session 2\\\")\\n   687→\\n   688→\\tenv.GitAdd(\\\"file2.txt\\\")\\n   689→\\tenv.GitCommitWithShadowHooks(\\\"Add file2 from session 2\\\", \\\"file2.txt\\\")\\n   690→\\n   691→\\tfinalHead := env.GetHeadHash()\\n   692→\\tt.Logf(\\\"Final HEAD: %s\\\", finalHead[:7])\\n   693→\\n   694→\\t// ========================================\\n   695→\\t// Phase 5: Verify stale session 1 was NOT condensed\\n   696→\\t// ========================================\\n   697→\\tt.Log(\\\"Phase 5: Verifying stale session 1 was NOT condensed\\\")\\n   698→\\n   699→\\tstate1After, err := env.GetSessionState(session1.ID)\\n   700→\\tif err != nil {\\n   701→\\t\\tt.Fatalf(\\\"GetSessionState for session1 after session2 commit failed: %v\\\", err)\\n   702→\\t}\\n   703→\\n   704→\\t// StepCount should be unchanged (condensation resets it)\\n   705→\\tif state1After.StepCount != session1StepCount {\\n   706→\\t\\tt.Errorf(\\\"Stale session 1 StepCount changed! Expected %d, got %d (was incorrectly condensed)\\\",\\n   707→\\t\\t\\tsession1StepCount, state1After.StepCount)\\n   708→\\t}\\n   709→\\n   710→\\t// Note: BaseCommit WILL be updated for ACTIVE sessions (even stale ones) because\\n   711→\\t// updateBaseCommitIfChanged only skips IDLE/ENDED sessions. This is fine - the\\n   712→\\t// key fix is the overlap check that prevents condensation, not BaseCommit updates.\\n   713→\\t// A stale ACTIVE session that gets resumed later needs to know the current HEAD.\\n   714→\\n   715→\\t// FilesTouched should still have file1.txt (not cleared by condensation)\\n   716→\\thasFile1 := false\\n   717→\\tfor _, f := range state1After.FilesTouched {\\n   718→\\t\\tif f == \\\"file1.txt\\\" {\\n   719→\\t\\t\\thasFile1 = true\\n   720→\\t\\t\\tbreak\\n   721→\\t\\t}\\n   722→\\t}\\n   723→\\tif !hasFile1 {\\n   724→\\t\\tt.Errorf(\\\"Stale session 1 FilesTouched was cleared! Expected file1.txt, got: %v\\\",\\n   725→\\t\\t\\tstate1After.FilesTouched)\\n   726→\\t}\\n   727→\\n   728→\\t// ========================================\\n   729→\\t// Phase 6: Verify session 2 WAS condensed\\n   730→\\t// ========================================\\n   731→\\tt.Log(\\\"Phase 6: Verifying session 2 WAS condensed\\\")\\n   732→\\n   733→\\tstate2After, err := env.GetSessionState(session2.ID)\\n   734→\\tif err != nil {\\n   735→\\t\\tt.Fatalf(\\\"GetSessionState for session2 after commit failed: %v\\\", err)\\n   736→\\t}\\n   737→\\n   738→\\tif state2After.BaseCommit != finalHead {\\n   739→\\t\\tt.Errorf(\\\"Session