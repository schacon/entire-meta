{\\n    84→\\t\\tt.Fatalf(\\\"failed to init git repo: %v\\\", err)\\n    85→\\t}\\n    86→\\n    87→\\tt.Chdir(dir)\\n    88→\\n    89→\\ts := &ManualCommitStrategy{}\\n    90→\\n    91→\\tstate := &SessionState{\\n    92→\\t\\tSessionID:  \\\"test-session-123\\\",\\n    93→\\t\\tBaseCommit: \\\"abc123def456\\\",\\n    94→\\t\\tStartedAt:  time.Now(),\\n    95→\\t\\tStepCount:  5,\\n    96→\\t}\\n    97→\\n    98→\\t// Save state\\n    99→\\terr = s.saveSessionState(state)\\n   100→\\tif err != nil {\\n   101→\\t\\tt.Fatalf(\\\"saveSessionState() error = %v\\\", err)\\n   102→\\t}\\n   103→\\n   104→\\t// Verify file exists\\n   105→\\tstateFile := filepath.Join(\\\".git\\\", \\\"entire-sessions\\\", \\\"test-session-123.json\\\")\\n   106→\\tif _, err := os.Stat(stateFile); os.IsNotExist(err) {\\n   107→\\t\\tt.Error(\\\"session state file not created\\\")\\n   108→\\t}\\n   109→\\n   110→\\t// Load state\\n   111→\\tloaded, err := s.loadSessionState(\\\"test-session-123\\\")\\n   112→\\tif err != nil {\\n   113→\\t\\tt.Fatalf(\\\"loadSessionState() error = %v\\\", err)\\n   114→\\t}\\n   115→\\tif loaded == nil {\\n   116→\\t\\tt.Fatal(\\\"loadSessionState() returned nil\\\")\\n   117→\\t}\\n   118→\\n   119→\\tif loaded.SessionID != state.SessionID {\\n   120→\\t\\tt.Errorf(\\\"SessionID = %q, want %q\\\", loaded.SessionID, state.SessionID)\\n   121→\\t}\\n   122→\\tif loaded.BaseCommit != state.BaseCommit {\\n   123→\\t\\tt.Errorf(\\\"BaseCommit = %q, want %q\\\", loaded.BaseCommit, state.BaseCommit)\\n   124→\\t}\\n   125→\\tif loaded.StepCount != state.StepCount {\\n   126→\\t\\tt.Errorf(\\\"StepCount = %d, want %d\\\", loaded.StepCount, state.StepCount)\\n   127→\\t}\\n   128→}\\n   129→\\n   130→func TestShadowStrategy_SessionState_LoadNonExistent(t *testing.T) {\\n   131→\\tdir := t.TempDir()\\n   132→\\t_, err := git.PlainInit(dir, false)\\n   133→\\tif err != nil {\\n   134→\\t\\tt.Fatalf(\\\"failed to init git repo: %v\\\", err)\\n   135→\\t}\\n   136→\