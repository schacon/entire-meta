===============\\n   546→\\tt.Log(\\\"Phase 8: Verifying session 1 WAS condensed when its carry-forward file was committed\\\")\\n   547→\\n   548→\\tstate1Final, err := env.GetSessionState(session1.ID)\\n   549→\\tif err != nil {\\n   550→\\t\\tt.Fatalf(\\\"GetSessionState for session1 after file2 commit failed: %v\\\", err)\\n   551→\\t}\\n   552→\\n   553→\\t// StepCount should be reset to 0 (condensation happened)\\n   554→\\tif state1Final.StepCount != 0 {\\n   555→\\t\\tt.Errorf(\\\"Session 1 StepCount should be 0 after condensation, got %d\\\", state1Final.StepCount)\\n   556→\\t}\\n   557→\\n   558→\\t// FilesTouched should be empty (carry-forward consumed)\\n   559→\\tif len(state1Final.FilesTouched) != 0 {\\n   560→\\t\\tt.Errorf(\\\"Session 1 FilesTouched should be empty after condensation, got: %v\\\", state1Final.FilesTouched)\\n   561→\\t}\\n   562→\\n   563→\\tt.Log(\\\"Test completed successfully:\\\")\\n   564→\\tt.Log(\\\"  - Session 1 NOT condensed into session 2's commit (file6.txt)\\\")\\n   565→\\tt.Log(\\\"  - Session 1 WAS condensed when its own file (file2.txt) was committed\\\")\\n   566→}\\n   567→\\n   568→// TestStaleActiveSession_NotCondensedIntoUnrelatedCommit verifies that a stale\\n   569→// ACTIVE session (agent resumed then killed) is NOT condensed into an unrelated\\n   570→// commit from a different session.\\n   571→//\\n   572→// This is a regression test for the bug where ACTIVE sessions would always be\\n   573→// condensed (hasNew=true) without checking file overlap.\\n   574→//\\n   575→// Scenario:\\n   576→// 1. Session 1 creates file1.txt, Stop hook fires (checkpoint saved)\\n   577→// 2. Session 1 is resumed (back to ACTIVE), does more work\\n   578→// 3. Agent is killed (stays ACTIVE, new work not committed)\\n   579→// 4. New session 2 creates file2.txt (unrelated)\\n   580→// 5. Session 2 commits file2.txt\\n   581→// 6. Verify: Session 1 was NOT condensed (its files weren't in the commit)\\n   582→func TestStaleActi