s *PrePromptState) normalizePrePromptState() {\\n    69→\\t// Migrate the oldest field to the intermediate field first\\n    70→\\tif s.StepTranscriptStart == 0 && s.LastTranscriptLineCount > 0 {\\n    71→\\t\\ts.StepTranscriptStart = s.LastTranscriptLineCount\\n    72→\\t}\\n    73→\\ts.LastTranscriptLineCount = 0\\n    74→\\n    75→\\t// Migrate all deprecated fields to the unified TranscriptOffset\\n    76→\\tif s.TranscriptOffset == 0 {\\n    77→\\t\\tif s.StepTranscriptStart > 0 {\\n    78→\\t\\t\\ts.TranscriptOffset = s.StepTranscriptStart\\n    79→\\t\\t} else if s.StartMessageIndex > 0 {\\n    80→\\t\\t\\ts.TranscriptOffset = s.StartMessageIndex\\n    81→\\t\\t}\\n    82→\\t}\\n    83→\\ts.StepTranscriptStart = 0\\n    84→\\ts.StartMessageIndex = 0\\n    85→}\\n    86→\\n    87→// CapturePrePromptState captures current untracked files and transcript position before a prompt\\n    88→// and saves them to a state file.\\n    89→//\\n    90→// The agent parameter is used to determine the transcript position via TranscriptAnalyzer.\\n    91→// If the agent does not implement TranscriptAnalyzer, the transcript offset will be 0.\\n    92→// The sessionRef parameter is optional — if empty, transcript position won't be captured.\\n    93→//\\n    94→// Works correctly from any subdirectory within the repository.\\n    95→func CapturePrePromptState(ctx context.Context, ag agent.Agent, sessionID, sessionRef string) error {\\n    96→\\tif sessionID == \\\"\\\" {\\n    97→\\t\\tsessionID = unknownSessionID\\n    98→\\t}\\n    99→\\n   100→\\t// Get absolute path for tmp directory\\n   101→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   102→\\tif err != nil {\\n   103→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   104→\\t}\\n   105→\\n   106→\\t// Create tmp directory if it doesn't exist\\n   107→\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   108→\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n