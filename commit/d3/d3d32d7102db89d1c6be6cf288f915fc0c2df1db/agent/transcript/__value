.Fprintf(errW, \\\"Warning: failed to remove agent hooks: %v\\\\n\\\", err)\\n  1006→\\t}\\n  1007→\\n  1008→\\t// 2. Remove git hooks\\n  1009→\\tremoved, err := strategy.RemoveGitHook(ctx)\\n  1010→\\tif err != nil {\\n  1011→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove git hooks: %v\\\\n\\\", err)\\n  1012→\\t} else if removed > 0 {\\n  1013→\\t\\tfmt.Fprintf(w, \\\"  Removed git hooks (%d)\\\\n\\\", removed)\\n  1014→\\t}\\n  1015→\\n  1016→\\t// 3. Remove session state files\\n  1017→\\tstatesRemoved, err := removeAllSessionStates(ctx)\\n  1018→\\tif err != nil {\\n  1019→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove session states: %v\\\\n\\\", err)\\n  1020→\\t} else if statesRemoved > 0 {\\n  1021→\\t\\tfmt.Fprintf(w, \\\"  Removed session states (%d)\\\\n\\\", statesRemoved)\\n  1022→\\t}\\n  1023→\\n  1024→\\t// 4. Remove .entire/ directory\\n  1025→\\tif err := removeEntireDirectory(ctx); err != nil {\\n  1026→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove .entire directory: %v\\\\n\\\", err)\\n  1027→\\t} else if entireDirExists {\\n  1028→\\t\\tfmt.Fprintln(w, \\\"  Removed .entire directory\\\")\\n  1029→\\t}\\n  1030→\\n  1031→\\t// 5. Remove shadow branches\\n  1032→\\tbranchesRemoved, err := removeAllShadowBranches(ctx)\\n  1033→\\tif err != nil {\\n  1034→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove shadow branches: %v\\\\n\\\", err)\\n  1035→\\t} else if branchesRemoved > 0 {\\n  1036→\\t\\tfmt.Fprintf(w, \\\"  Removed %d shadow branches\\\\n\\\", branchesRemoved)\\n  1037→\\t}\\n  1038→\\n  1039→\\tfmt.Fprintln(w, \\\"\\\\nEntire CLI uninstalled successfully.\\\")\\n  1040→\\treturn nil\\n  1041→}\\n  1042→\\n  1043→// countSessionStates returns the number of active session state files.\\n  1044→func countSessionStates(ctx context.Context) int {\\n  1045→\\tstore, err := session.NewStateStore(ctx)\\n  1046→\\tif err != nil {\\n  1047→\\t\\treturn 0\\n  1048→\\t}\\n  1049→\\tstates, err := store.List(ctx)\\n  1050→