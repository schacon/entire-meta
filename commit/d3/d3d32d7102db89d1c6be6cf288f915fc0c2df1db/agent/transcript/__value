ments the generic lifecycle event dispatcher.\\n     2→// It routes normalized events from any agent to the appropriate framework actions.\\n     3→//\\n     4→// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n     5→// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n     6→// the dispatcher handles all orchestration: state transitions, strategy calls,\\n     7→// file change detection, metadata generation.\\n     8→package cli\\n     9→\\n    10→import (\\n    11→\\t\\\"context\\\"\\n    12→\\t\\\"errors\\\"\\n    13→\\t\\\"fmt\\\"\\n    14→\\t\\\"log/slog\\\"\\n    15→\\t\\\"os\\\"\\n    16→\\t\\\"path/filepath\\\"\\n    17→\\t\\\"strings\\\"\\n    18→\\t\\\"time\\\"\\n    19→\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    22→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    23→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    25→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    26→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    27→)\\n    28→\\n    29→// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n    30→// Returns nil if the event was handled successfully.\\n    31→func DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    32→\\tif ag == nil {\\n    33→\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    34→\\t}\\n    35→\\tif event == nil {\\n    36→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    37→\\t}\\n    38→\\n    39→\\tswitch event.Type {\\n    40→\\tcase agent.SessionStart:\\n    41→\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n    42→\\tcase agent.TurnStart:\\n    43→\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n    44→\\tcase agent.TurnEnd:\\n    45→\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n    46→\\tcase agent.Compaction:\\n    47→\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n    48→\\tcase agent.SessionEnd:\\n    49→\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n    50→\\tcase agent.SubagentStart:\\n    51→\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n    52→\\tcase agent.SubagentEnd:\\n    53→\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n    54→\\tdefault:\\n    55→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    56→\\t}\\n    57→}\\n    58→\\n    59→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    60→// fires state machine transition.\\n    61→func handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    62→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n    63→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    64→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    65→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    66→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    67→\\t\\tslog.String(\\\"model\\\", event.Model),\\n    68→\\t)\\n    69→\\n    70→\\tif event.SessionID == \\\"\\\" {\\n    71→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    72→\\t}\\n    73→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    74→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    75→\\t}\\n    76→\\n    77→\\t// Build informational message\\n    78→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    79→\\n    80→\\t// Check for concurrent sessions and append count if any\\n    81→\\tstrat := GetStrategy(ctx)\\n    82→\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n    83→\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    84→\\t}\\n    85→\\n    86→\\t// Output informational message if the agent supports hook responses.\\n    87→\\t// Claude Code reads JSON from stdout; agents that don't implement\\n    88→\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n    89→\\tif event.ResponseMessage != \\\"\\\" {\\n    90→\\t\\tmessage = event.ResponseMessage\\n    91→\\t}\\n    92→\\tif writer, ok := ag.(agent.HookResponseWriter); ok {\\n    93→\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n    94→\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n    95→\\t\\t}\\n    96→\\t}\\n    97→\\n    98→\\t// Fire EventSessionStart for the current session (if state exists).\\n    99→\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n   100→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n   101→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   102→\\t} else if state != nil {\\n   103→\\t\\tpersistEventMetadataToState(event, state)\\n   104→\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   105→\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n   106→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   107→\\t\\t}\\n   108→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   109→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n   110→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   111→\\t\\t}\\n   112→\\t}\\n   113→\\n   114→\\treturn nil\\n   115→}\\n   116→\\n   117→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   118→// ensures strategy setup, initializes session.\\n   119→func handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   120→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   121→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   122→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   123→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   124→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   125→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   126→\\t)\\n   127→\\n   128→\\tsessionID := event.SessionID\\n   129→\\tif sessionID == \\\"\\\" {\\n   130→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   131→\\t}\\n   132→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   133→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   134→\\t}\\n   135→\\n   136→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   137→\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n   138→\\t\\treturn err\\n   139→\\t}\\n   140→\\n   141→\\t// Ensure strategy setup and initialize session\\n   142→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   143→\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n   144→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   145→\\t}\\n   146→\\n   147→\\tstrat := GetStrategy(ctx)\\n   148→\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt, event.Model); err != nil {\\n   149→\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n   150→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   151→\\t}\\n   152→\\n   153→\\treturn nil\\n   154→}\\n   155→\\n   156→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   157→// detects file changes, saves step + checkpoint, transitions phase.\\n   158→//\\n   159→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   160→func handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   161→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   162→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   163→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   164→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   165→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   166→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   167→\\t)\\n   168→\\n   169→\\tsessionID := event.SessionID\\n   170→\\tif sessionID == \\\"\\\" {\\n   171→\\t\\tsessionID = unknownSessionID\\n   172→\\t}\\n   173→\\n   174→\\ttranscriptRef := event.SessionRef\\n   175→\\tif transcriptRef == \\\"\\\" {\\n   176→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   177→\\t}\\n   178→\\n   179→\\t// If agent implements TranscriptPreparer, materialize the transcript file.\\n   180→\\t// This must run BEFORE fileExists: agents like OpenCode lazily fetch transcripts\\n   181→\\t// via `opencode export`, so the file doesn't exist until PrepareTranscript creates it.\\n   182→\\t// Claude Code's PrepareTranscript just flushes (always succeeds). Agents without\\n   183→\\t// TranscriptPreparer (Gemini, Droid) are unaffected.\\n   184→\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n   185→\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n   186→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n   187→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   188→\\t\\t}\\n   189→\\t}\\n   190→\\n   191→\\tif !fileExists(transcriptRef) {\\n   192→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   193→\\t}\\n   194→\\n   195→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   196→\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n   197→\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n   198→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   199→\\t}\\n   200→\\n   201→\\t// Create session metadata directory\\n   202→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   203→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   204→\\tif err != nil {\\n   205→\\t\\tsessionDirAbs = sessionDir\\n   206→\\t}\\n   207→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   208→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   209→\\t}\\n   210→\\n   211→\\t// Copy transcript to session directory\\n   212→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   213→\\tif err != nil {\\n   214→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   215→\\t}\\n   216→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   217→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   218→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   219→\\t}\\n   220→\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n   221→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n   222→\\n   223→\\t// Load pre-prompt state (captured on TurnStart)\\n   224→\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n   225→\\tif err != nil {\\n   226→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n   227→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   228→\\t}\\n   229→\\n   230→\\t// Determine transcript offset\\n   231→\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n   232→\\n   233→\\t// Compute subagents directory for agents that support subagent extraction.\\n   234→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   235→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   236→\\n   237→\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n   238→\\tvar allPrompts []string\\n   239→\\tvar summary string\\n   240→\\tvar modifiedFiles []string\\n   241→\\n   242→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   243→\\t\\t// Extract prompts\\n   244→\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n   245→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract prompts\\\",\\n   246→\\t\\t\\t\\tslog.String(\\\"error\\\", promptErr.Error()))\\n   247→\\t\\t} else {\\n   248→\\t\\t\\tallPrompts = prompts\\n   249→\\t\\t}\\n   250→\\n   251→\\t\\t// Extract summary\\n   252→\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n   253→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract summary\\\",\\n   254→\\t\\t\\t\\tslog.String(\\\"error\\\", sumErr.Error()))\\n   255→\\t\\t} else {\\n   256→\\t\\t\\tsummary = s\\n   257→\\t\\t}\\n   258→\\n   259→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   260→\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n   261→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n   262→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n   263→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   264→\\t\\t\\t} else {\\n   265→\\t\\t\\t\\tmodifiedFiles = files\\n   266→\\t\\t\\t}\\n   267→\\t\\t} else {\\n   268→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   269→\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   270→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n   271→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   272→\\t\\t\\t} else {\\n   273→\\t\\t\\t\\tmodifiedFiles = files\\n   274→\\t\\t\\t}\\n   275→\\t\\t}\\n   276→\\t}\\n   277→\\n   278→\\t// Write prompts file\\n   279→\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   280→\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   281→\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   282→\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   283→\\t}\\n   284→\\tlogging.Debug(logCtx, \\\"extracted prompts\\\",\\n   285→\\t\\tslog.Int(\\\"count\\\", len(allPrompts)),\\n   286→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.PromptFileName))\\n   287→\\n   288→\\t// Write summary file\\n   289→\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   290→\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   291→\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   292→\\t}\\n   293→\\tlogging.Debug(logCtx, \\\"extracted summary\\\",\\n   294→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName))\\n   295→\\n   296→\\t// Generate commit message from last prompt\\n   297→\\tlastPrompt := \\\"\\\"\\n   298→\\tif len(allPrompts) > 0 {\\n   299→\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   300→\\t}\\n   301→\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n   302→\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n   303→\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n   304→\\n   305→\\t// Get worktree root for path normalization\\n   306→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   307→\\tif err != nil {\\n   308→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   309→\\t}\\n   310→\\n   311→\\tvar preUntrackedFiles []string\\n   312→\\tif preState != nil {\\n   313→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n   314→\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n   315→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   316→\\t}\\n   317→\\n   318→\\t// Detect file changes via git status\\n   319→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   320→\\tif err != nil {\\n   321→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   322→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   323→\\t}\\n   324→\\n   325→\\t// Filter and normalize all paths\\n   326→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   327→\\tvar relNewFiles, relDeletedFiles []string\\n   328→\\tif changes != nil {\\n   329→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   330→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   331→\\n   332→\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n   333→\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n   334→\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n   335→\\t\\t// Git status catches any tracked file with working-tree changes.\\n   336→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   337→\\t}\\n   338→\\n   339→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   340→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   341→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   342→\\t// if it exists in HEAD with the same content as the working tree.\\n   343→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   344→\\n   345→\\t// Check if there are any changes\\n   346→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   347→\\tif totalChanges == 0 {\\n   348→\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n   349→\\t\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n   350→\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   351→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   352→\\t\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   353→\\t\\t}\\n   354→\\t\\treturn nil\\n   355→\\t}\\n   356→\\n   357→\\t// Log file changes\\n   358→\\tlogFileChanges(ctx, relModifiedFiles, relNewFiles, relDeletedFiles)\\n   359→\\n   360→\\t// Create context file\\n   361→\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n   362→\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n   363→\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n   364→\\t}\\n   365→\\tlogging.Debug(logCtx, \\\"created context file\\\",\\n   366→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.ContextFileName))\\n   367→\\n   368→\\t// Get git author\\n   369→\\tauthor, err := GetGitAuthor(ctx)\\n   370→\\tif err != nil {\\n   371→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   372→\\t}\\n   373→\\n   374→\\t// Get strategy and agent type\\n   375→\\tstrat := GetStrategy(ctx)\\n   376→\\tagentType := ag.Type()\\n   377→\\n   378→\\t// Get transcript position/identifier from pre-prompt state\\n   379→\\tvar transcriptIdentifierAtStart string\\n   380→\\tvar transcriptLinesAtStart int\\n   381→\\tif preState != nil {\\n   382→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   383→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   384→\\t}\\n   385→\\n   386→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   387→\\ttokenUsage := agent.CalculateTokenUsage(ctx, ag, transcriptData, transcriptLinesAtStart, subagentsDir)\\n   388→\\n   389→\\t// Build fully-populated step context and delegate to strategy\\n   390→\\tstepCtx := strategy.StepContext{\\n   391→\\t\\tSessionID:                sessionID,\\n   392→\\t\\tModifiedFiles:            relModifiedFiles,\\n   393→\\t\\tNewFiles:                 relNewFiles,\\n   394→\\t\\tDeletedFiles:             relDeletedFiles,\\n   395→\\t\\tMetadataDir:              sessionDir,\\n   396→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   397→\\t\\tCommitMessage:            commitMessage,\\n   398→\\t\\tTranscriptPath:           transcriptRef,\\n   399→\\t\\tAuthorName:               author.Name,\\n   400→\\t\\tAuthorEmail:              author.Email,\\n   401→\\t\\tAgentType:                agentType,\\n   402→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   403→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   404→\\t\\tTokenUsage:               tokenUsage,\\n   405→\\t}\\n   406→\\n   407→\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   408→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   409→\\t}\\n   410→\\n   411→\\t// Transition session phase and cleanup\\n   412→\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n   413→\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   414→\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   415→\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   416→\\t}\\n   417→\\n   418→\\treturn nil\\n   419→}\\n   420→\\n   421→// handleLifecycleCompaction handles context compaction: saves current progress\\n   422→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   423→// Also resets the transcript offset since the transcript may be truncated.\\n   424→func handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   425→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   426→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   427→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   428→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   429→\\t)\\n   430→\\n   431→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   432→\\tsessionID := event.SessionID\\n   433→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   434→\\tif loadErr != nil {\\n   435→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for compaction\\\",\\n   436→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   437→\\t}\\n   438→\\tif sessionState != nil {\\n   439→\\t\\tif transErr := strategy.TransitionAndLog(ctx, sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   440→\\t\\t\\tlogging.Warn(logCtx, \\\"compaction transition failed\\\",\\n   441→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   442→\\t\\t}\\n   443→\\n   444→\\t\\tif saveErr := strategy.SaveSessionState(ctx, sessionState); saveErr != nil {\\n   445→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to save session state after compaction\\\",\\n   446→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   447→\\t\\t}\\n   448→\\t}\\n   449→\\n   450→\\tlogging.Info(logCtx, \\\"context compaction detected\\\")\\n   451→\\treturn nil\\n   452→}\\n   453→\\n   454→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   455→func handleLifecycleSessionEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   456→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   457→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   458→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   459→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   460→\\t)\\n   461→\\n   462→\\tif event.SessionID == \\\"\\\" {\\n   463→\\t\\treturn nil // No session to update\\n   464→\\t}\\n   465→\\n   466→\\t// Note: We intentionally don't clean up cached transcripts here.\\n   467→\\t// Post-session commits (carry-forward in ENDED phase) may still need\\n   468→\\t// the transcript to extract file changes. Cleanup is handled by\\n   469→\\t// `entire clean` or when the session state is fully removed.\\n   470→\\n   471→\\tif err := markSessionEnded(ctx, event.SessionID); err != nil {\\n   472→\\t\\tlogging.Warn(logCtx, \\\"failed to mark session ended\\\",\\n   473→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   474→\\t}\\n   475→\\treturn nil\\n   476→}\\n   477→\\n   478→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   479→func handleLifecycleSubagentStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   480→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   481→\\tlogging.Info(logCtx, \\\"subagent started\\\",\\n   482→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   483→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   484→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   485→\\t\\tslog.String(\\\"transcript\\\", event.SessionRef),\\n   486→\\t)\\n   487→\\n   488→\\t// Capture pre-task state\\n   489→\\tif err := CapturePreTaskState(ctx, event.ToolUseID); err != nil {\\n   490→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   491→\\t}\\n   492→\\n   493→\\treturn nil\\n   494→}\\n   495→\\n   496→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   497→func handleLifecycleSubagentEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   498→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   499→\\tif event.SubagentType == \\\"\\\" && event.TaskDescription == \\\"\\\" {\\n   500→\\t\\t// Extract subagent type and description from tool input\\n   501→\\t\\tevent.SubagentType, event.TaskDescription = ParseSubagentTypeAndDescription(event.ToolInput)\\n   502→\\t}\\n   503→\\n   504→\\t// Determine subagent transcript path\\n   505→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   506→\\tvar subagentTranscriptPath string\\n   507→\\tif event.SubagentID != \\\"\\\" {\\n   508→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   509→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   510→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   511→\\t\\t}\\n   512→\\t}\\n   513→\\n   514→\\t// Log context\\n   515→\\tsubagentEndAttrs := []any{\\n   516→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   517→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   518→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   519→\\t}\\n   520→\\tif event.SubagentID != \\\"\\\" {\\n   521→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"agent_id\\\", event.SubagentID))\\n   522→\\t}\\n   523→\\tif subagentTranscriptPath != \\\"\\\" {\\n   524→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"subagent_transcript\\\", subagentTranscriptPath))\\n   525→\\t}\\n   526→\\tlogging.Info(logCtx, \\\"subagent completed\\\", subagentEndAttrs...)\\n   527→\\n   528→\\t// Extract modified files from subagent transcript\\n   529→\\tvar modifiedFiles []string\\n   530→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   531→\\t\\ttranscriptToScan := event.SessionRef\\n   532→\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n   533→\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n   534→\\t\\t}\\n   535→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n   536→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files from subagent\\\",\\n   537→\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   538→\\t\\t} else {\\n   539→\\t\\t\\tmodifiedFiles = files\\n   540→\\t\\t}\\n   541→\\t}\\n   542→\\n   543→\\t// Load pre-task state and detect file changes\\n   544→\\tpreState, err := LoadPreTaskState(ctx, event.ToolUseID)\\n   545→\\tif err != nil {\\n   546→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-task state\\\",\\n   547→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   548→\\t}\\n   549→\\tvar preUntrackedFiles []string\\n   550→\\tif preState != nil {\\n   551→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   552→\\t}\\n   553→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   554→\\tif err != nil {\\n   555→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   556→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   557→\\t}\\n   558→\\n   559→\\t// Get worktree root and normalize paths\\n   560→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   561→\\tif err != nil {\\n   562→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   563→\\t}\\n   564→\\n   565→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   566→\\tvar relNewFiles, relDeletedFiles []string\\n   567→\\tif changes != nil {\\n   568→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   569→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   570→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   571→\\t}\\n   572→\\n   573→\\t// If no changes, skip\\n   574→\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n   575→\\t\\tlogging.Info(logCtx, \\\"no file changes detected, skipping task checkpoint\\\")\\n   576→\\t\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   577→\\t\\treturn nil\\n   578→\\t}\\n   579→\\n   580→\\t// Find checkpoint UUID from main transcript (best-effort)\\n   581→\\tvar checkpointUUID string\\n   582→\\t// Use the existing CLI-level checkpoint UUID finder\\n   583→\\tmainLines, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n   584→\\tif mainLines != nil {\\n   585→\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n   586→\\t}\\n   587→\\n   588→\\t// Get git author\\n   589→\\tauthor, err := GetGitAuthor(ctx)\\n   590→\\tif err != nil {\\n   591→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   592→\\t}\\n   593→\\n   594→\\t// Build task checkpoint context\\n   595→\\tstrat := GetStrategy(ctx)\\n   596→\\tagentType := ag.Type()\\n   597→\\n   598→\\ttaskStepCtx := strategy.TaskStepContext{\\n   599→\\t\\tSessionID:              event.SessionID,\\n   600→\\t\\tToolUseID:              event.ToolUseID,\\n   601→\\t\\tAgentID:                event.SubagentID,\\n   602→\\t\\tModifiedFiles:          relModifiedFiles,\\n   603→\\t\\tNewFiles:               relNewFiles,\\n   604→\\t\\tDeletedFiles:           relDeletedFiles,\\n   605→\\t\\tTranscriptPath:         event.SessionRef,\\n   606→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   607→\\t\\tCheckpointUUID:         checkpointUUID,\\n   608→\\t\\tAuthorName:             author.Name,\\n   609→\\t\\tAuthorEmail:            author.Email,\\n   610→\\t\\tSubagentType:           event.SubagentType,\\n   611→\\t\\tTaskDescription:        event.TaskDescription,\\n   612→\\t\\tAgentType:              agentType,\\n   613→\\t}\\n   614→\\n   615→\\tif err := strat.SaveTaskStep(ctx, taskStepCtx); err != nil {\\n   616→\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n   617→\\t}\\n   618→\\n   619→\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   620→\\treturn nil\\n   621→}\\n   622→\\n   623→// --- Helper functions ---\\n   624→\\n   625→// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n   626→// Prefers pre-prompt state, falls back to session state.\\n   627→func resolveTranscriptOffset(ctx context.Context, preState *PrePromptState, sessionID string) int {\\n   628→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   629→\\tif preState != nil && preState.TranscriptOffset > 0 {\\n   630→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state found, parsing transcript from offset\\\",\\n   631→\\t\\t\\tslog.Int(\\\"offset\\\", preState.TranscriptOffset))\\n   632→\\t\\treturn preState.TranscriptOffset\\n   633→\\t}\\n   634→\\n   635→\\t// Fall back to session state\\n   636→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   637→\\tif loadErr != nil {\\n   638→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state\\\",\\n   639→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   640→\\t\\treturn 0\\n   641→\\t}\\n   642→\\tif sessionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n   643→\\t\\tlogging.Debug(logCtx, \\\"session state found, parsing transcript from offset\\\",\\n   644→\\t\\t\\tslog.Int(\\\"offset\\\", sessionState.CheckpointTranscriptStart))\\n   645→\\t\\treturn sessionState.CheckpointTranscriptStart\\n   646→\\t}\\n   647→\\n   648→\\treturn 0\\n   649→}\\n   650→\\n   651→// createContextFile creates a context.md file for the session checkpoint.\\n   652→// This is a unified version that works for all agents.\\n   653→func createContextFile(contextFile, commitMessage, sessionID string, prompts []string, summary string) error {\\n   654→\\tvar sb strings.Builder\\n   655→\\n   656→\\tsb.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   657→\\tfmt.Fprintf(&sb, \\\"Session ID: %s\\\\n\\\", sessionID)\\n   658→\\tfmt.Fprintf(&sb, \\\"Commit Message: %s\\\\n\\\\n\\\", commitMessage)\\n   659→\\n   660→\\tif len(prompts) > 0 {\\n   661→\\t\\tsb.WriteString(\\\"## Prompts\\\\n\\\\n\\\")\\n   662→\\t\\tfor i, p := range prompts {\\n   663→\\t\\t\\tfmt.Fprintf(&sb, \\\"### Prompt %d\\\\n\\\\n%s\\\\n\\\\n\\\", i+1, p)\\n   664→\\t\\t}\\n   665→\\t}\\n   666→\\n   667→\\tif summary != \\\"\\\" {\\n   668→\\t\\tsb.WriteString(\\\"## Summary\\\\n\\\\n\\\")\\n   669→\\t\\tsb.WriteString(summary)\\n   670→\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   671→\\t}\\n   672→\\n   673→\\tif err := os.WriteFile(contextFile, []byte(sb.String()), 0o600); err != nil {\\n   674→\\t\\treturn fmt.Errorf(\\\"failed to write context file: %w\\\", err)\\n   675→\\t}\\n   676→\\treturn nil\\n   677→}\\n   678→\\n   679→// parseTranscriptForCheckpointUUID is a thin wrapper around transcript parsing for checkpoint UUID lookup.\\n   680→// Returns parsed transcript lines for use with FindCheckpointUUID.\\n   681→func parseTranscriptForCheckpointUUID(transcriptPath string) ([]transcriptLine, error) {\\n   682→\\tlines, err := transcript.ParseFromFileAtLine(transcriptPath, 0)\\n   683→\\tif err != nil {\\n   684→\\t\\treturn nil, fmt.Errorf(\\\"parsing transcript for checkpoint UUID: %w\\\", err)\\n   685→\\t}\\n   686→\\treturn lines, nil\\n   687→}\\n   688→\\n   689→// transitionSessionTurnEnd transitions the session phase to IDLE and dispatches turn-end actions.\\n   690→func transitionSessionTurnEnd(ctx context.Context, sessionID string, event *agent.Event) {\\n   691→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   692→\\tturnState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   693→\\tif loadErr != nil {\\n   694→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for turn end\\\",\\n   695→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   696→\\t\\treturn\\n   697→\\t}\\n   698→\\tif turnState == nil {\\n   699→\\t\\treturn\\n   700→\\t}\\n   701→\\n   702→\\tpersistEventMetadataToState(event, turnState)\\n   703→\\n   704→\\tif err := strategy.TransitionAndLog(ctx, turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   705→\\t\\tlogging.Warn(logCtx, \\\"turn-end transition failed\\\",\\n   706→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   707→\\t}\\n   708→\\n   709→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   710→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   711→\\tstrat := GetStrategy(ctx)\\n   712→\\tif err := strat.HandleTurnEnd(ctx, turnState); err != nil {\\n   713→\\t\\tlogging.Warn(logCtx, \\\"turn-end action dispatch failed\\\",\\n   714→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   715→\\t}\\n   716→\\n   717→\\tif updateErr := strategy.SaveSessionState(ctx, turnState); updateErr != nil {\\n   718→\\t\\tlogging.Warn(logCtx, \\\"failed to update session phase on turn end\\\",\\n   719→\\t\\t\\tslog.String(\\\"error\\\", updateErr.Error()))\\n   720→\\t}\\n   721→}\\n   722→\\n   723→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   724→func markSessionEnded(ctx context.Context, sessionID string) error {\\n   725→\\tstate, err := strategy.LoadSessionState(ctx, sessionID)\\n   726→\\tif err != nil {\\n   727→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   728→\\t}\\n   729→\\tif state == nil {\\n   730→\\t\\treturn nil // No state file, nothing to update\\n   731→\\t}\\n   732→\\n   733→\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStop, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   734→\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"lifecycle\\\"), \\\"session stop transition failed\\\",\\n   735→\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   736→\\t}\\n   737→\\n   738→\\tnow := time.Now()\\n   739→\\tstate.EndedAt = &now\\n   740→\\n   741→\\tif err := strategy.SaveSessionState(ctx, state); err != nil {\\n   742→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   743→\\t}\\n   744→\\treturn nil\\n   745→}\\n   746→\\n   747→// logFileChanges logs the files modified, created, and deleted during a session.\\n   748→func logFileChanges(ctx context.Context, modified, newFiles, deleted []string) {\\n   749→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   750→\\tlogging.Debug(logCtx, \\\"files changed during session\\\",\\n   751→\\t\\tslog.Int(\\\"modified\\\", len(modified)),\\n   752→\\t\\tslog.Int(\\\"new\\\", len(newFiles)),\\n   753→\\t\\tslog.Int(\\\"deleted\\\", len(deleted)))\\n   754→}\\n   755→\\n   756→func persistEventMetadataToState(event *agent.Event, state *strategy.SessionState) {\\n   757→\\t// Update ModelName if provided (model is known by turn-end even on first turn)\\n   758→\\tif event.Model != \\\"\\\" {\\n   759→\\t\\tstate.ModelName = event.Model\\n   760→\\t}\\n   761→}\\n   762→\"}]},\"uuid\":\"777fc6e8-9fd3-4dd8-93e2-dd4c388c3a18\",\"timestamp\":\"2026-03-04T15:40:13.896Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/nodo/work/cli/cmd/entire/cli/lifecycle.go\",\"content\":\"// lifecycle.go implements the generic lifecycle event dispatcher.\\n// It routes normalized events from any agent to the appropriate framework actions.\\n//\\n// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n// the dispatcher handles all orchestration: state transitions, strategy calls,\\n// file change detection, metadata generation.\\npackage cli\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n)\\n\\n// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n// Returns nil if the event was handled successfully.\\nfunc DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tif ag == nil {\\n\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n\\t}\\n\\tif event == nil {\\n\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n\\t}\\n\\n\\tswitch event.Type {\\n\\tcase agent.SessionStart:\\n\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n\\tcase agent.TurnStart:\\n\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n\\tcase agent.TurnEnd:\\n\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n\\tcase agent.Compaction:\\n\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n\\tcase agent.SessionEnd:\\n\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n\\tcase agent.SubagentStart:\\n\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n\\tcase agent.SubagentEnd:\\n\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n\\tdefault:\\n\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n\\t}\\n}\\n\\n// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n// fires state machine transition.\\nfunc handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"session-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t\\tslog.String(\\\"model\\\", event.Model),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Build informational message\\n\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n\\n\\t// Check for concurrent sessions and append count if any\\n\\tstrat := GetStrategy(ctx)\\n\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n\\t}\\n\\n\\t// Output informational message if the agent supports hook responses.\\n\\t// Claude Code reads JSON from stdout; agents that don't implement\\n\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n\\tif event.ResponseMessage != \\\"\\\" {\\n\\t\\tmessage = event.ResponseMessage\\n\\t}\\n\\tif writer, ok := ag.(agent.HookResponseWriter); ok {\\n\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// Fire EventSessionStart for the current session (if state exists).\\n\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n\\t} else if state != nil {\\n\\t\\tpersistEventMetadataToState(event, state)\\n\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n\\t\\t}\\n\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n// ensures strategy setup, initializes session.\\nfunc handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t\\tslog.String(\\\"model\\\", event.Model),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Ensure strategy setup and initialize session\\n\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\tstrat := GetStrategy(ctx)\\n\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt, event.Model); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n// detects file changes, saves step + checkpoint, transitions phase.\\n//\\n//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\nfunc handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t\\tslog.String(\\\"model\\\", event.Model),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\tsessionID = unknownSessionID\\n\\t}\\n\\n\\ttranscriptRef := event.SessionRef\\n\\tif transcriptRef == \\\"\\\" {\\n\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n\\t}\\n\\n\\t// If agent implements TranscriptPreparer, materialize the transcript file.\\n\\t// This must run BEFORE fileExists: agents like OpenCode lazily fetch transcripts\\n\\t// via `opencode export`, so the file doesn't exist until PrepareTranscript creates it.\\n\\t// Claude Code's PrepareTranscript just flushes (always succeeds). Agents without\\n\\t// TranscriptPreparer (Gemini, Droid) are unaffected.\\n\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\tif !fileExists(transcriptRef) {\\n\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n\\t}\\n\\n\\t// Early check: bail out quickly if the repo has no commits yet.\\n\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n\\t}\\n\\n\\t// Create session metadata directory\\n\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n\\tif err != nil {\\n\\t\\tsessionDirAbs = sessionDir\\n\\t}\\n\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n\\t}\\n\\n\\t// Copy transcript to session directory\\n\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n\\t}\\n\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n\\n\\t// Load pre-prompt state (captured on TurnStart)\\n\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\t// Determine transcript offset\\n\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n\\n\\t// Compute subagents directory for agents that support subagent extraction.\\n\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n\\n\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n\\tvar allPrompts []string\\n\\tvar summary string\\n\\tvar modifiedFiles []string\\n\\n\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n\\t\\t// Extract prompts\\n\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract prompts\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", promptErr.Error()))\\n\\t\\t} else {\\n\\t\\t\\tallPrompts = prompts\\n\\t\\t}\\n\\n\\t\\t// Extract summary\\n\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract summary\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", sumErr.Error()))\\n\\t\\t} else {\\n\\t\\t\\tsummary = s\\n\\t\\t}\\n\\n\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t}\\n\\t\\t} else {\\n\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write prompts file\\n\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"extracted prompts\\\",\\n\\t\\tslog.Int(\\\"count\\\", len(allPrompts)),\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.PromptFileName))\\n\\n\\t// Write summary file\\n\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"extracted summary\\\",\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName))\\n\\n\\t// Generate commit message from last prompt\\n\\tlastPrompt := \\\"\\\"\\n\\tif len(allPrompts) > 0 {\\n\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n\\t}\\n\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n\\n\\t// Get worktree root for path normalization\\n\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n\\t}\\n\\n\\tvar preUntrackedFiles []string\\n\\tif preState != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n\\t}\\n\\n\\t// Detect file changes via git status\\n\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\t// Filter and normalize all paths\\n\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n\\tvar relNewFiles, relDeletedFiles []string\\n\\tif changes != nil {\\n\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n\\n\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n\\t\\t// Git status catches any tracked file with working-tree changes.\\n\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n\\t}\\n\\n\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n\\t// if it exists in HEAD with the same content as the working tree.\\n\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n\\n\\t// Check if there are any changes\\n\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n\\tif totalChanges == 0 {\\n\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n\\t\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Log file changes\\n\\tlogFileChanges(ctx, relModifiedFiles, relNewFiles, relDeletedFiles)\\n\\n\\t// Create context file\\n\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"created context file\\\",\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.ContextFileName))\\n\\n\\t// Get git author\\n\\tauthor, err := GetGitAuthor(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n\\t}\\n\\n\\t// Get strategy and agent type\\n\\tstrat := GetStrategy(ctx)\\n\\tagentType := ag.Type()\\n\\n\\t// Get transcript position/identifier from pre-prompt state\\n\\tvar transcriptIdentifierAtStart string\\n\\tvar transcriptLinesAtStart int\\n\\tif preState != nil {\\n\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n\\t}\\n\\n\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n\\ttokenUsage := agent.CalculateTokenUsage(ctx, ag, transcriptData, transcriptLinesAtStart, subagentsDir)\\n\\n\\t// Build fully-populated step context and delegate to strategy\\n\\tstepCtx := strategy.StepContext{\\n\\t\\tSessionID:                sessionID,\\n\\t\\tModifiedFiles:            relModifiedFiles,\\n\\t\\tNewFiles:                 relNewFiles,\\n\\t\\tDeletedFiles:             relDeletedFiles,\\n\\t\\tMetadataDir:              sessionDir,\\n\\t\\tMetadataDirAbs:           sessionDirAbs,\\n\\t\\tCommitMessage:            commitMessage,\\n\\t\\tTranscriptPath:           transcriptRef,\\n\\t\\tAuthorName:               author.Name,\\n\\t\\tAuthorEmail:              author.Email,\\n\\t\\tAgentType:                agentType,\\n\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n\\t\\tTokenUsage:               tokenUsage,\\n\\t}\\n\\n\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n\\t}\\n\\n\\t// Transition session phase and cleanup\\n\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleCompaction handles context compaction: saves current progress\\n// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n// Also resets the transcript offset since the transcript may be truncated.\\nfunc handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"compaction\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t)\\n\\n\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n\\tsessionID := event.SessionID\\n\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n\\tif loadErr != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for compaction\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n\\t}\\n\\tif sessionState != nil {\\n\\t\\tif transErr := strategy.TransitionAndLog(ctx, sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"compaction transition failed\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n\\t\\t}\\n\\n\\t\\tif saveErr := strategy.SaveSessionState(ctx, sessionState); saveErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to save session state after compaction\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\tlogging.Info(logCtx, \\\"context compaction detected\\\")\\n\\treturn nil\\n}\\n\\n// handleLifecycleSessionEnd handles session end: marks the session as ended.\\nfunc handleLifecycleSessionEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"session-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" {\\n\\t\\treturn nil // No session to update\\n\\t}\\n\\n\\t// Note: We intentionally don't clean up cached transcripts here.\\n\\t// Post-session commits (carry-forward in ENDED phase) may still need\\n\\t// the transcript to extract file changes. Cleanup is handled by\\n\\t// `entire clean` or when the session state is fully removed.\\n\\n\\tif err := markSessionEnded(ctx, event.SessionID); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to mark session ended\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\treturn nil\\n}\\n\\n// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\nfunc handleLifecycleSubagentStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"subagent started\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n\\t\\tslog.String(\\\"transcript\\\", event.SessionRef),\\n\\t)\\n\\n\\t// Capture pre-task state\\n\\tif err := CapturePreTaskState(ctx, event.ToolUseID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\nfunc handleLifecycleSubagentEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tif event.SubagentType == \\\"\\\" && event.TaskDescription == \\\"\\\" {\\n\\t\\t// Extract subagent type and description from tool input\\n\\t\\tevent.SubagentType, event.TaskDescription = ParseSubagentTypeAndDescription(event.ToolInput)\\n\\t}\\n\\n\\t// Determine subagent transcript path\