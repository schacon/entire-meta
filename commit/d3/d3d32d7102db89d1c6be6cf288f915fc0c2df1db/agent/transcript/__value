= true\\n   195→\\t}\\n   196→\\tif opts.AbsoluteGitHookPath {\\n   197→\\t\\tsettings.AbsoluteGitHookPath = true\\n   198→\\t}\\n   199→\\n   200→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   201→\\tif opts.SkipPushSessions {\\n   202→\\t\\tif settings.StrategyOptions == nil {\\n   203→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   204→\\t\\t}\\n   205→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   206→\\t}\\n   207→\\n   208→\\t// Determine which settings file to write to\\n   209→\\t// First run always creates settings.json (no prompt)\\n   210→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   211→\\tif err != nil {\\n   212→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   213→\\t}\\n   214→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, opts.UseLocalSettings, opts.UseProjectSettings)\\n   215→\\n   216→\\tif showNotification {\\n   217→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   218→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   219→\\t}\\n   220→\\n   221→\\t// Save settings to the appropriate file.\\n   222→\\tsaveSettings := func() error {\\n   223→\\t\\tif shouldUseLocal {\\n   224→\\t\\t\\treturn SaveEntireSettingsLocal(ctx, settings)\\n   225→\\t\\t}\\n   226→\\t\\treturn SaveEntireSettings(ctx, settings)\\n   227→\\t}\\n   228→\\tif err := saveSettings(); err != nil {\\n   229→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   230→\\t}\\n   231→\\n   232→\\t// Use settings values (merged from existing config + flags) for hook installation\\n   233→\\t// This ensures re-running `entire enable` without flags preserves existing settings\\n   234→\\tif _, err := strategy.InstallGitHook(ctx, true, settings.LocalDev, settings.AbsoluteGitHookPath); err != nil {\\n   235→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   236→\\t}\\n   237→\\tstrategy.CheckAndWarnHookManagers(ctx, w, settings.LocalDev, settings.AbsoluteGitHookPath)\\n   238→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   239→\\n   240→\\tconfigDisplay := configDisplayProject\\n   241→\\tif shouldUseLocal {\\n   242→\\t\\tconfigDisplay = configDisplayLocal\\n   243→\\t}\\n   244→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   245→\\n   246→\\t// Ask about telemetry consent (only if not already asked)\\n   247→\\tfmt.Fprintln(w)\\n   248→\\tif err := promptTelemetryConsent(settings, opts.Telemetry); err != nil {\\n   249→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   250→\\t}\\n   251→\\t// Save again to persist telemetry choice\\n   252→\\tif err := saveSettings(); err != nil {\\n   253→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   254→\\t}\\n   255→\\n   256→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   257→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   258→\\t}\\n   259→\\n   260→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   261→\\n   262→\\treturn nil\\n   263→}\\n   264→\\n   265→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   266→func runEnable(ctx context.Context, w io.Writer) error {\\n   267→\\tsettings, err := LoadEntireSettings(ctx)\\n   268→\\tif err != nil {\\n   269→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   270→\\t}\\n   271→\\n   272→\\tsettings.Enabled = true\\n   273→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   274→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   275→\\t}\\n   276→\\n   277→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   278→\\treturn nil\\n   279→}\\n   280→\\n   281→func runDisable(ctx context.Context, w io.Writer, useProjectSettings bool) error {\\n   282→\\tsettings, err := LoadEntireSettings(ctx)\\n   283→\\tif err != nil {\\n   284→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   285→\\t}\\n   286→\\n   287→\\tsettings.Enabled = false\\n   288→\\n   289→\\t// If --project flag is specified, always write to project settings\\n   290→\\tif useProjectSettings {\\n   291→\\t\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   292→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   293→\\t\\t}\\n   294→\\t} else {\\n   295→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   296→\\t\\tif err := SaveEntireSettingsLocal(ctx, settings); err != nil {\\n   297→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   298→\\t\\t}\\n   299→\\t}\\n   300→\\n   301→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   302→\\treturn nil\\n   303→}\\n   304→\\n   305→// DisabledMessage is the message shown when Entire is disabled\\n   306→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   307→\\n   308→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   309→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   310→// On error reading settings, defaults to enabled (returns false).\\n   311→func checkDisabledGuard(ctx context.Context, w io.Writer) bool {\\n   312→\\tenabled, err := IsEnabled(ctx)\\n   313→\\tif err != nil {\\n   314→\\t\\t// Default to enabled on error\\n   315→\\t\\treturn false\\n   316→\\t}\\n   317→\\tif !enabled {\\n   318→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   319→\\t\\treturn true\\n   320→\\t}\\n   321→\\treturn false\\n   322→}\\n   323→\\n   324→// uninstallDeselectedAgentHooks removes hooks for agents that were previously\\n   325→// installed but are not in the selected list. This handles the case where a user\\n   326→// re-runs `entire enable` and deselects an agent.\\n   327→func uninstallDeselectedAgentHooks(ctx context.Context, w io.Writer, selectedAgents []agent.Agent) error {\\n   328→\\tinstalledNames := GetAgentsWithHooksInstalled(ctx)\\n   329→\\tif len(installedNames) == 0 {\\n   330→\\t\\treturn nil\\n   331→\\t}\\n   332→\\n   333→\\tselectedSet := make(map[types.AgentName]struct{}, len(selectedAgents))\\n   334→\\tfor _, ag := range selectedAgents {\\n   335→\\t\\tselectedSet[ag.Name()] = struct{}{}\\n   336→\\t}\\n   337→\\n   338→\\tvar errs []error\\n   339→\\tfor _, name := range installedNames {\\n   340→\\t\\tif _, selected := selectedSet[name]; selected {\\n   341→\\t\\t\\tcontinue\\n   342→\\t\\t}\\n   343→\\t\\tag, err := agent.Get(name)\\n   344→\\t\\tif err != nil {\\n   345→\\t\\t\\tcontinue\\n   346→\\t\\t}\\n   347→\\t\\thookAgent, ok := ag.(agent.HookSupport)\\n   348→\\t\\tif !ok {\\n   349→\\t\\t\\tcontinue\\n   350→\\t\\t}\\n   351→\\t\\tif err := hookAgent.UninstallHooks(ctx); err != nil {\\n   352→\\t\\t\\terrs = append(errs, fmt.Errorf(\\\"failed to uninstall %s hooks: %w\\\", ag.Type(), err))\\n   353→\\t\\t} else {\\n   354→\\t\\t\\tfmt.Fprintf(w, \\\"Removed %s hooks\\\\n\\\", ag.Type())\\n   355→\\t\\t}\\n   356→\\t}\\n   357→\\treturn errors.Join(errs...)\\n   358→}\\n   359→\\n   360→// setupAgentHooks sets up hooks for a given agent.\\n   361→// Returns the number of hooks installed (0 if already installed).\\n   362→func setupAgentHooks(ctx context.Context, ag agent.Agent, localDev, forceHooks bool) (int, error) {\\n   363→\\thookAgent, ok := ag.(agent.HookSupport)\\n   364→\\tif !ok {\\n   365→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   366→\\t}\\n   367→\\n   368→\\tcount, err := hookAgent.InstallHooks(ctx, localDev, forceHooks)\\n   369→\\tif err != nil {\\n   370→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   371→\\t}\\n   372→\\n   373→\\treturn count, nil\\n   374→}\\n   375→\\n   376→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   377→// Returns the detected/selected agents and any error.\\n   378→//\\n   379→// On first run (no hooks installed):\\n   380→//   - Single detected agent: used automatically\\n   381→//   - Multiple/no detected agents: interactive multi-select prompt\\n   382→//\\n   383→// On re-run (hooks already installed):\\n   384→//   - Always shows the interactive multi-select\\n   385→//   - Pre-selects only agents that have hooks installed (respects prior deselection)\\n   386→//\\n   387→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   388→// It receives available agent names and returns the selected names.\\n   389→func detectOrSelectAgent(ctx context.Context, w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   390→\\t// Check for agents with hooks already installed (re-run detection)\\n   391→\\tinstalledAgentNames := GetAgentsWithHooksInstalled(ctx)\\n   392→\\thasInstalledHooks := len(installedAgentNames) > 0\\n   393→\\n   394→\\t// Try auto-detection\\n   395→\\tdetected := agent.DetectAll(ctx)\\n   396→\\n   397→\\t// First run: use existing auto-detect shortcuts\\n   398→\\tif !hasInstalledHooks {\\n   399→\\t\\tswitch {\\n   400→\\t\\tcase len(detected) == 1:\\n   401→\\t\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   402→\\t\\t\\treturn detected, nil\\n   403→\\n   404→\\t\\tcase len(detected) > 1:\\n   405→\\t\\t\\tagentTypes := make([]string, 0, len(detected))\\n   406→\\t\\t\\tfor _, ag := range detected {\\n   407→\\t\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   408→\\t\\t\\t}\\n   409→\\t\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   410→\\t\\t\\tfmt.Fprintln(w)\\n   411→\\t\\t}\\n   412→\\t}\\n   413→\\n   414→\\t// Check if we can prompt interactively\\n   415→\\tif !canPromptInteractively() {\\n   416→\\t\\tif hasInstalledHooks {\\n   417→\\t\\t\\t// Re-run without TTY — keep currently installed agents\\n   418→\\t\\t\\tagents := make([]agent.Agent, 0, len(installedAgentNames))\\n   419→\\t\\t\\tfor _, name := range installedAgentNames {\\n   420→\\t\\t\\t\\tag, err := agent.Get(name)\\n   421→\\t\\t\\t\\tif err != nil {\\n   422→\\t\\t\\t\\t\\tcontinue\\n   423→\\t\\t\\t\\t}\\n   424→\\t\\t\\t\\tagents = append(agents, ag)\\n   425→\\t\\t\\t}\\n   426→\\t\\t\\treturn agents, nil\\n   427→\\t\\t}\\n   428→\\t\\tif len(detected) > 0 {\\n   429→\\t\\t\\treturn detected, nil\\n   430→\\t\\t}\\n   431→\\t\\tdefaultAgent := agent.Default()\\n   432→\\t\\tif defaultAgent == nil {\\n   433→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   434→\\t\\t}\\n   435→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   436→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   437→\\t}\\n   438→\\n   439→\\tif !hasInstalledHooks && len(detected) == 0 {\\n   440→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., \\\"+strings.Join(agent.StringList(), \\\", \\\")+\\\").\\\")\\n   441→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   442→\\t\\tfmt.Fprintln(w)\\n   443→\\t}\\n   444→\\n   445→\\t// Build pre-selection set.\\n   446→\\t// On re-run: only pre-select agents with hooks installed (respect prior deselection).\\n   447→\\t// On first run: pre-select all detected agents.\\n   448→\\tpreSelectedSet := make(map[types.AgentName]struct{})\\n   449→\\tif hasInstalledHooks {\\n   450→\\t\\tfor _, name := range installedAgentNames {\\n   451→\\t\\t\\tpreSelectedSet[name] = struct{}{}\\n   452→\\t\\t}\\n   453→\\t} else {\\n   454→\\t\\tfor _, ag := range detected {\\n   455→\\t\\t\\tpreSelectedSet[ag.Name()] = struct{}{}\\n   456→\\t\\t}\\n   457→\\t}\\n   458→\\n   459→\\t// Build options from registered agents\\n   460→\\tagentNames := agent.List()\\n   461→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   462→\\tfor _, name := range agentNames {\\n   463→\\t\\tag, err := agent.Get(name)\\n   464→\\t\\tif err != nil {\\n   465→\\t\\t\\tcontinue\\n   466→\\t\\t}\\n   467→\\t\\t// Only show agents that support hooks\\n   468→\\t\\tif _, ok := ag.(agent.HookSupport); !ok {\\n   469→\\t\\t\\tcontinue\\n   470→\\t\\t}\\n   471→\\t\\topt := huh.NewOption(string(ag.Type()), string(name))\\n   472→\\t\\tif _, isPreSelected := preSelectedSet[name]; isPreSelected {\\n   473→\\t\\t\\topt = opt.Selected(true)\\n   474→\\t\\t}\\n   475→\\t\\toptions = append(options, opt)\\n   476→\\t}\\n   477→\\n   478→\\tif len(options) == 0 {\\n   479→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   480→\\t}\\n   481→\\n   482→\\t// Collect available agent names for the selector\\n   483→\\tavailableNames := make([]string, 0, len(options))\\n   484→\\tfor _, opt := range options {\\n   485→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   486→\\t}\\n   487→\\n   488→\\tvar selectedAgentNames []string\\n   489→\\tif selectFn != nil {\\n   490→\\t\\tvar err error\\n   491→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   492→\\t\\tif err != nil {\\n   493→\\t\\t\\treturn nil, err\\n   494→\\t\\t}\\n   495→\\t\\tif len(selectedAgentNames) == 0 {\\n   496→\\t\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   497→\\t\\t}\\n   498→\\t} else {\\n   499→\\t\\tform := NewAccessibleForm(\\n   500→\\t\\t\\thuh.NewGroup(\\n   501→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   502→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   503→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   504→\\t\\t\\t\\t\\tOptions(options...).\\n   505→\\t\\t\\t\\t\\tValidate(func(selected []string) error {\\n   506→\\t\\t\\t\\t\\t\\tif len(selected) == 0 {\\n   507→\\t\\t\\t\\t\\t\\t\\treturn errors.New(\\\"please select at least one agent\\\")\\n   508→\\t\\t\\t\\t\\t\\t}\\n   509→\\t\\t\\t\\t\\t\\treturn nil\\n   510→\\t\\t\\t\\t\\t}).\\n   511→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   512→\\t\\t\\t),\\n   513→\\t\\t)\\n   514→\\t\\tif err := form.Run(); err != nil {\\n   515→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   516→\\t\\t}\\n   517→\\t}\\n   518→\\n   519→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   520→\\tfor _, name := range selectedAgentNames {\\n   521→\\t\\tselectedAgent, err := agent.Get(types.AgentName(name))\\n   522→\\t\\tif err != nil {\\n   523→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   524→\\t\\t}\\n   525→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   526→\\t}\\n   527→\\n   528→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   529→\\tfor _, ag := range selectedAgents {\\n   530→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   531→\\t}\\n   532→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   533→\\treturn selectedAgents, nil\\n   534→}\\n   535→\\n   536→// canPromptInteractively checks if we can show interactive prompts.\\n   537→// Returns false when running in CI, tests, or other non-interactive environments.\\n   538→func canPromptInteractively() bool {\\n   539→\\t// Check for test environment\\n   540→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   541→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   542→\\t}\\n   543→\\n   544→\\t// Check if /dev/tty is available\\n   545→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   546→\\tif err != nil {\\n   547→\\t\\treturn false\\n   548→\\t}\\n   549→\\t_ = tty.Close()\\n   550→\\treturn true\\n   551→}\\n   552→\\n   553→// printAgentError writes an error message followed by available agents and usage.\\n   554→func printAgentError(w io.Writer, message string) {\\n   555→\\tagents := agent.List()\\n   556→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   557→\\tfmt.Fprintln(w)\\n   558→\\tfor _, a := range agents {\\n   559→\\t\\tsuffix := \\\"\\\"\\n   560→\\t\\tif a == agent.DefaultAgentName {\\n   561→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   562→\\t\\t}\\n   563→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   564→\\t}\\n   565→\\tfmt.Fprintln(w)\\n   566→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   567→}\\n   568→\\n   569→// printMissingAgentError writes a helpful error listing available agents.\\n   570→func printMissingAgentError(w io.Writer) {\\n   571→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   572→}\\n   573→\\n   574→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   575→func printWrongAgentError(w io.Writer, name string) {\\n   576→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   577→}\\n   578→\\n   579→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   580→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   581→func setupAgentHooksNonInteractive(ctx context.Context, w io.Writer, ag agent.Agent, opts EnableOptions) error {\\n   582→\\tagentName := ag.Name()\\n   583→\\t// Check if agent supports hooks\\n   584→\\thookAgent, ok := ag.(agent.HookSupport)\\n   585→\\tif !ok {\\n   586→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   587→\\t}\\n   588→\\n   589→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   590→\\n   591→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   592→\\tinstalledHooks, err := hookAgent.InstallHooks(ctx, opts.LocalDev, opts.ForceHooks)\\n   593→\\tif err != nil {\\n   594→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   595→\\t}\\n   596→\\n   597→\\t// Setup .entire directory\\n   598→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   599→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   600→\\t}\\n   601→\\n   602→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   603→\\tsettings, err := LoadEntireSettings(ctx)\\n   604→\\tif err != nil {\\n   605→\\t\\t// If we can't load, start with defaults\\n   606→\\t\\tsettings = &EntireSettings{}\\n   607→\\t}\\n   608→\\tsettings.Enabled = true\\n   609→\\tif opts.LocalDev {\\n   610→\\t\\tsettings.LocalDev = true\\n   611→\\t}\\n   612→\\tif opts.AbsoluteGitHookPath {\\n   613→\\t\\tsettings.AbsoluteGitHookPath = true\\n   614→\\t}\\n   615→\\n   616→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   617→\\tif opts.SkipPushSessions {\\n   618→\\t\\tif settings.StrategyOptions == nil {\\n   619→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   620→\\t\\t}\\n   621→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   622→\\t}\\n   623→\\n   624→\\t// Handle telemetry for non-interactive mode\\n   625→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   626→\\tif !opts.Telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   627→\\t\\tf := false\\n   628→\\t\\tsettings.Telemetry = &f\\n   629→\\t}\\n   630→\\n   631→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   632→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   633→\\t}\\n   634→\\n   635→\\t// Use settings values (merged from existing config + flags) for hook installation\\n   636→\\t// This ensures re-running `entire enable --agent X` without flags preserves existing settings\\n   637→\\tif _, err := strategy.InstallGitHook(ctx, true, settings.LocalDev, settings.AbsoluteGitHookPath); err != nil {\\n   638→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   639→\\t}\\n   640→\\tstrategy.CheckAndWarnHookManagers(ctx, w, settings.LocalDev, settings.AbsoluteGitHookPath)\\n   641→\\n   642→\\tif installedHooks == 0 {\\n   643→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   644→\\t\\tif ag.IsPreview() {\\n   645→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   646→\\t\\t}\\n   647→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   648→\\t} else {\\n   649→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   650→\\t\\tif ag.IsPreview() {\\n   651→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   652→\\t\\t}\\n   653→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   654→\\t}\\n   655→\\n   656→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   657→\\n   658→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   659→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   660→\\t}\\n   661→\\n   662→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   663→\\n   664→\\treturn nil\\n   665→}\\n   666→\\n   667→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   668→func validateSetupFlags(useLocal, useProject bool) error {\\n   669→\\tif useLocal && useProject {\\n   670→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   671→\\t}\\n   672→\\treturn nil\\n   673→}\\n   674→\\n   675→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   676→// - Whether settings.json already exists\\n   677→// - The --local and --project flags\\n   678→// Returns (useLocal, showNotification).\\n   679→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   680→\\t// Explicit --local flag always uses local settings\\n   681→\\tif useLocal {\\n   682→\\t\\treturn true, false\\n   683→\\t}\\n   684→\\n   685→\\t// Explicit --project flag always uses project settings\\n   686→\\tif useProject {\\n   687→\\t\\treturn false, false\\n   688→\\t}\\n   689→\\n   690→\\t// No flags specified - check if settings file exists\\n   691→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   692→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   693→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   694→\\t\\treturn true, true\\n   695→\\t}\\n   696→\\n   697→\\t// Settings file doesn't exist - create it\\n   698→\\treturn false, false\\n   699→}\\n   700→\\n   701→// setupEntireDirectory creates the .entire directory and gitignore.\\n   702→// Returns true if the directory was created, false if it already existed.\\n   703→func setupEntireDirectory(ctx context.Context) (bool, error) { //nolint:unparam // already present in codebase\\n   704→\\t// Get absolute path for the .entire directory\\n   705→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   706→\\tif err != nil {\\n   707→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   708→\\t}\\n   709→\\n   710→\\t// Check if directory already exists\\n   711→\\tcreated := false\\n   712→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   713→\\t\\tcreated = true\\n   714→\\t}\\n   715→\\n   716→\\t// Create .entire directory\\n   717→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   718→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   719→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   720→\\t}\\n   721→\\n   722→\\t// Create/update .gitignore with all required entries\\n   723→\\tif err := strategy.EnsureEntireGitignore(ctx); err != nil {\\n   724→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   725→\\t}\\n   726→\\n   727→\\treturn created, nil\\n   728→}\\n   729→\\n   730→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   731→func setupGitHook(ctx context.Context) error {\\n   732→\\ts, err := settings.Load(ctx)\\n   733→\\tlocalDev := err == nil && s.LocalDev\\n   734→\\tabsoluteHookPath := err == nil && s.AbsoluteGitHookPath\\n   735→\\tif _, err := strategy.InstallGitHook(ctx, false, localDev, absoluteHookPath); err != nil {\\n   736→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   737→\\t}\\n   738→\\tstrategy.CheckAndWarnHookManagers(ctx, os.Stderr, localDev, absoluteHookPath)\\n   739→\\treturn nil\\n   740→}\\n   741→\\n   742→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   743→func newSetupGitHookCmd() *cobra.Command {\\n   744→\\tcmd := &cobra.Command{\\n   745→\\t\\tUse:    \\\"git-hook\\\",\\n   746→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   747→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   748→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   749→\\t\\t\\treturn setupGitHook(cmd.Context())\\n   750→\\t\\t},\\n   751→\\t}\\n   752→\\n   753→\\treturn cmd\\n   754→}\\n   755→\\n   756→func newCurlBashPostInstallCmd() *cobra.Command {\\n   757→\\treturn &cobra.Command{\\n   758→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   759→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   760→\\t\\tHidden: true,\\n   761→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   762→\\t\\t\\tw := cmd.OutOrStdout()\\n   763→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   764→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   765→\\t\\t\\t}\\n   766→\\t\\t\\treturn nil\\n   767→\\t\\t},\\n   768→\\t}\\n   769→}\\n   770→\\n   771→// shellCompletionComment is the comment preceding the completion line\\n   772→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   773→\\n   774→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   775→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   776→\\n   777→// shellCompletionTarget returns the rc file path and completion lines for the\\n   778→// user's current shell.\\n   779→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   780→\\thome, err := os.UserHomeDir()\\n   781→\\tif err != nil {\\n   782→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   783→\\t}\\n   784→\\n   785→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   786→\\tswitch {\\n   787→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   788→\\t\\treturn \\\"Zsh\\\",\\n   789→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   790→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   791→\\t\\t\\tnil\\n   792→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   793→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   794→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   795→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   796→\\t\\t}\\n   797→\\t\\treturn \\\"Bash\\\",\\n   798→\\t\\t\\tbashRC,\\n   799→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   800→\\t\\t\\tnil\\n   801→\\tcase strings.Contains(shell, \\\"fish\\\"):\\n   802→\\t\\treturn \\\"Fish\\\",\\n   803→\\t\\t\\tfilepath.Join(home, \\\".config\\\", \\\"fish\\\", \\\"config.fish\\\"),\\n   804→\\t\\t\\t\\\"entire completion fish | source\\\",\\n   805→\\t\\t\\tnil\\n   806→\\tdefault:\\n   807→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   808→\\t}\\n   809→}\\n   810→\\n   811→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   812→// Only prompts if completion is not already configured.\\n   813→func promptShellCompletion(w io.Writer) error {\\n   814→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   815→\\tif err != nil {\\n   816→\\t\\tif errors.Is(err, errUnsupportedShell) {\\n   817→\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion not available for your shell. Supported: zsh, bash, fish.\\\\n\\\")\\n   818→\\t\\t\\treturn nil\\n   819→\\t\\t}\\n   820→\\t\\treturn fmt.Errorf(\\\"shell completion: %w\\\", err)\\n   821→\\t}\\n   822→\\n   823→\\tif isCompletionConfigured(rcFile) {\\n   824→\\t\\tfmt.Fprintf(w, \\\"✓ Shell completion already configured in %s\\\\n\\\", rcFile)\\n   825→\\t\\treturn nil\\n   826→\\t}\\n   827→\\n   828→\\tvar selected string\\n   829→\\tform := NewAccessibleForm(\\n   830→\\t\\thuh.NewGroup(\\n   831→\\t\\t\\thuh.NewSelect[string]().\\n   832→\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Enable shell completion? (detected: %s)\\\", shellName)).\\n   833→\\t\\t\\t\\tOptions(\\n   834→\\t\\t\\t\\t\\thuh.NewOption(\\\"Yes\\\", \\\"yes\\\"),\\n   835→\\t\\t\\t\\t\\thuh.NewOption(\\\"No\\\", \\\"no\\\"),\\n   836→\\t\\t\\t\\t).\\n   837→\\t\\t\\t\\tValue(&selected),\\n   838→\\t\\t),\\n   839→\\t)\\n   840→\\n   841→\\tif err := form.Run(); err != nil {\\n   842→\\t\\t//nolint:nilerr // User cancelled - not a fatal error, just skip\\n   843→\\t\\treturn nil\\n   844→\\t}\\n   845→\\n   846→\\tif selected != \\\"yes\\\" {\\n   847→\\t\\treturn nil\\n   848→\\t}\\n   849→\\n   850→\\tif err := appendShellCompletion(rcFile, completionLine); err != nil {\\n   851→\\t\\treturn fmt.Errorf(\\\"failed to update %s: %w\\\", rcFile, err)\\n   852→\\t}\\n   853→\\n   854→\\tfmt.Fprintf(w, \\\"✓ Shell completion added to %s\\\\n\\\", rcFile)\\n   855→\\tfmt.Fprintln(w, \\\"  Restart your shell to activate\\\")\\n   856→\\n   857→\\treturn nil\\n   858→}\\n   859→\\n   860→// isCompletionConfigured checks if shell completion is already in the rc file.\\n   861→func isCompletionConfigured(rcFile string) bool {\\n   862→\\t//nolint:gosec // G304: rcFile is constructed from home dir + known filename, not user input\\n   863→\\tcontent, err := os.ReadFile(rcFile)\\n   864→\\tif err != nil {\\n   865→\\t\\treturn false // File doesn't exist or can't read, treat as not configured\\n   866→\\t}\\n   867→\\treturn strings.Contains(string(content), \\\"entire completion\\\")\\n   868→}\\n   869→\\n   870→// appendShellCompletion adds the completion line to the rc file.\\n   871→func appendShellCompletion(rcFile, completionLine string) error {\\n   872→\\tif err := os.MkdirAll(filepath.Dir(rcFile), 0o700); err != nil {\\n   873→\\t\\treturn fmt.Errorf(\\\"creating directory: %w\\\", err)\\n   874→\\t}\\n   875→\\t//nolint:gosec // G302: Shell rc files need 0644 for user readability\\n   876→\\tf, err := os.OpenFile(rcFile, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0o644)\\n   877→\\tif err != nil {\\n   878→\\t\\treturn fmt.Errorf(\\\"opening file: %w\\\", err)\\n   879→\\t}\\n   880→\\tdefer f.Close()\\n   881→\\n   882→\\t_, err = f.WriteString(\\\"\\\\n\\\" + shellCompletionComment + \\\"\\\\n\\\" + completionLine + \\\"\\\\n\\\")\\n   883→\\tif err != nil {\\n   884→\\t\\treturn fmt.Errorf(\\\"writing completion: %w\\\", err)\\n   885→\\t}\\n   886→\\treturn nil\\n   887→}\\n   888→\\n   889→// promptTelemetryConsent asks the user if they want to enable telemetry.\\n   890→// It modifies settings.Telemetry based on the user's choice or flags.\\n   891→// The caller is responsible for saving settings.\\n   892→func promptTelemetryConsent(settings *EntireSettings, telemetryFlag bool) error {\\n   893→\\t// Handle --telemetry=false flag first (always overrides existing setting)\\n   894→\\tif !telemetryFlag {\\n   895→\\t\\tf := false\\n   896→\\t\\tsettings.Telemetry = &f\\n   897→\\t\\treturn nil\\n   898→\\t}\\n   899→\\n   900→\\t// Skip if already asked\\n   901→\\tif settings.Telemetry != nil {\\n   902→\\t\\treturn nil\\n   903→\\t}\\n   904→\\n   905→\\t// Skip if env var disables telemetry (record as disabled)\\n   906→\\tif os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   907→\\t\\tf := false\\n   908→\\t\\tsettings.Telemetry = &f\\n   909→\\t\\treturn nil\\n   910→\\t}\\n   911→\\n   912→\\tconsent := true // Default to Yes\\n   913→\\tform := NewAccessibleForm(\\n   914→\\t\\thuh.NewGroup(\\n   915→\\t\\t\\thuh.NewConfirm().\\n   916→\\t\\t\\t\\tTitle(\\\"Help improve Entire CLI?\\\").\\n   917→\\t\\t\\t\\tDescription(\\\"Share anonymous usage data. No code or personal info collected.\\\").\\n   918→\\t\\t\\t\\tAffirmative(\\\"Yes\\\").\\n   919→\\t\\t\\t\\tNegative(\\\"No\\\").\\n   920→\\t\\t\\t\\tValue(&consent),\\n   921→\\t\\t),\\n   922→\\t)\\n   923→\\n   924→\\tif err := form.Run(); err != nil {\\n   925→\\t\\treturn fmt.Errorf(\\\"telemetry prompt: %w\\\", err)\\n   926→\\t}\\n   927→\\n   928→\\tsettings.Telemetry = &consent\\n   929→\\treturn nil\\n   930→}\\n   931→\\n   932→// runUninstall completely removes Entire from the repository.\\n   933→func runUninstall(ctx context.Context, w, errW io.Writer, force bool) error {\\n   934→\\t// Check if we're in a git repository\\n   935→\\tif _, err := paths.WorktreeRoot(ctx); err != nil {\\n   936→\\t\\tfmt.Fprintln(errW, \\\"Not a git repository. Nothing to uninstall.\\\")\\n   937→\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n   938→\\t}\\n   939→\\n   940→\\t// Gather counts for display\\n   941→\\tsessionStateCount := countSessionStates(ctx)\\n   942→\\tshadowBranchCount := countShadowBranches(ctx)\\n   943→\\tgitHooksInstalled := strategy.IsGitHookInstalled(ctx)\\n   944→\\tagentsWithInstalledHooks := GetAgentsWithHooksInstalled(ctx)\\n   945→\\tentireDirExists := checkEntireDirExists(ctx)\\n   946→\\n   947→\\t// Check if there's anything to uninstall\\n   948→\\tif !entireDirExists && !gitHooksInstalled && sessionStateCount == 0 &&\\n   949→\\t\\tshadowBranchCount == 0 && len(agentsWithInstalledHooks) == 0 {\\n   950→\\t\\tfmt.Fprintln(w, \\\"Entire is not installed in this repository.\\\")\\n   951→\\t\\treturn nil\\n   952→\\t}\\n   953→\\n   954→\\t// Show confirmation prompt unless --force\\n   955→\\tif !force {\\n   956→\\t\\tfmt.Fprintln(w, \\\"\\\\nThis will completely remove Entire from this repository:\\\")\\n   957→\\t\\tif entireDirExists {\\n   958→\\t\\t\\tfmt.Fprintln(w, \\\"  - .entire/ directory\\\")\\n   