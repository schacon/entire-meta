tings, nil\\n   111→}\\n   112→\\n   113→// LoadFromFile loads settings from a specific file path without merging local overrides.\\n   114→// Returns default settings if the file doesn't exist.\\n   115→// Use this when you need to display individual settings files separately.\\n   116→func LoadFromFile(filePath string) (*EntireSettings, error) {\\n   117→\\treturn loadFromFile(filePath)\\n   118→}\\n   119→\\n   120→// loadFromFile loads settings from a specific file path.\\n   121→// Returns default settings if the file doesn't exist.\\n   122→func loadFromFile(filePath string) (*EntireSettings, error) {\\n   123→\\tsettings := &EntireSettings{\\n   124→\\t\\tEnabled: true, // Default to enabled\\n   125→\\t}\\n   126→\\n   127→\\tdata, err := os.ReadFile(filePath) //nolint:gosec // path is from caller\\n   128→\\tif err != nil {\\n   129→\\t\\tif os.IsNotExist(err) {\\n   130→\\t\\t\\treturn settings, nil\\n   131→\\t\\t}\\n   132→\\t\\treturn nil, fmt.Errorf(\\\"%w\\\", err)\\n   133→\\t}\\n   134→\\n   135→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   136→\\tdec.DisallowUnknownFields()\\n   137→\\tif err := dec.Decode(settings); err != nil {\\n   138→\\t\\treturn nil, fmt.Errorf(\\\"parsing settings file: %w\\\", err)\\n   139→\\t}\\n   140→\\n   141→\\t// Validate commit_linking if set\\n   142→\\tif settings.CommitLinking != \\\"\\\" && settings.CommitLinking != CommitLinkingAlways && settings.CommitLinking != CommitLinkingPrompt {\\n   143→\\t\\treturn nil, fmt.Errorf(\\\"invalid commit_linking value %q: must be %q or %q\\\", settings.CommitLinking, CommitLinkingAlways, CommitLinkingPrompt)\\n   144→\\t}\\n   145→\\n   146→\\treturn settings, nil\\n   147→}\\n   148→\\n   149→// mergeJSON merges JSON data into existing settings.\\n   150→// Only non-zero values from the JSON override existing settings.\\n   151→func mergeJSON(settings *EntireSettings, data []byte) error {\\n   152→\\t// First, validate that there are no unknown keys using strict dec