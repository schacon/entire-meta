mpt = \\\"prompt\\\"\\n    31→)\\n    32→\\n    33→// EntireSettings represents the .entire/settings.json configuration\\n    34→type EntireSettings struct {\\n    35→\\n    36→\\t// Enabled indicates whether Entire is active. When false, CLI commands\\n    37→\\t// show a disabled message and hooks exit silently. Defaults to true.\\n    38→\\tEnabled bool `json:\\\"enabled\\\"`\\n    39→\\n    40→\\t// LocalDev indicates whether to use \\\"go run\\\" instead of the \\\"entire\\\" binary\\n    41→\\t// This is used for development when the binary is not installed\\n    42→\\tLocalDev bool `json:\\\"local_dev,omitempty\\\"`\\n    43→\\n    44→\\t// LogLevel sets the logging verbosity (debug, info, warn, error).\\n    45→\\t// Can be overridden by ENTIRE_LOG_LEVEL environment variable.\\n    46→\\t// Defaults to \\\"info\\\".\\n    47→\\tLogLevel string `json:\\\"log_level,omitempty\\\"`\\n    48→\\n    49→\\t// StrategyOptions contains strategy-specific configuration\\n    50→\\tStrategyOptions map[string]any `json:\\\"strategy_options,omitempty\\\"`\\n    51→\\n    52→\\t// Telemetry controls anonymous usage analytics.\\n    53→\\t// nil = not asked yet (show prompt), true = opted in, false = opted out\\n    54→\\tTelemetry *bool `json:\\\"telemetry,omitempty\\\"`\\n    55→\\n    56→\\t// CommitLinking controls how commits are linked to agent sessions.\\n    57→\\t// \\\"always\\\" = auto-link without prompting, \\\"prompt\\\" = ask on each commit.\\n    58→\\t// Defaults to \\\"prompt\\\" (preserves existing user behavior).\\n    59→\\tCommitLinking string `json:\\\"commit_linking,omitempty\\\"`\\n    60→\\n    61→\\t// Deprecated: no longer used. Exists to tolerate old settings files\\n    62→\\t// that still contain \\\"strategy\\\": \\\"auto-commit\\\" or similar.\\n    63→\\tStrategy string `json:\\\"strategy,omitempty\\\"`\\n    64→}\\n    65→\\n    66→// GetCommitLinking returns the effective commit linking mode.\\n    67→// Returns the explicit value if set,