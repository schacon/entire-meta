entError(errors.New(\\\"wrong agent name\\\"))\\n    78→\\t\\t\\t\\t}\\n    79→\\t\\t\\t\\t// --agent is a targeted operation: set up this specific agent without\\n    80→\\t\\t\\t\\t// affecting other agents. Unlike the interactive path, it does not\\n    81→\\t\\t\\t\\t// uninstall hooks for other previously-enabled agents.\\n    82→\\t\\t\\t\\treturn setupAgentHooksNonInteractive(ctx, cmd.OutOrStdout(), ag, localDev, forceHooks, skipPushSessions, telemetry)\\n    83→\\t\\t\\t}\\n    84→\\t\\t\\t// Detect or prompt for agents\\n    85→\\t\\t\\tagents, err := detectOrSelectAgent(ctx, cmd.OutOrStdout(), nil)\\n    86→\\t\\t\\tif err != nil {\\n    87→\\t\\t\\t\\treturn fmt.Errorf(\\\"agent selection failed: %w\\\", err)\\n    88→\\t\\t\\t}\\n    89→\\n    90→\\t\\t\\treturn runEnableInteractive(ctx, cmd.OutOrStdout(), agents, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry)\\n    91→\\t\\t},\\n    92→\\t}\\n    93→\\tcmd.Flags().StringVar(&agentName, \\\"agent\\\", \\\"\\\", \\\"Agent to set up hooks for (e.g., \\\"+strings.Join(agent.StringList(), \\\", \\\")+\\\"). Enables non-interactive mode.\\\")\\n    94→\\tcmd.Flags().BoolVar(&localDev, \\\"local-dev\\\", false, \\\"Use go run instead of entire binary for hooks\\\")\\n    95→\\tcmd.Flags().MarkHidden(\\\"local-dev\\\") //nolint:errcheck,gosec // flag is defined above\\n    96→\\tcmd.Flags().BoolVar(&ignoreUntracked, \\\"ignore-untracked\\\", false, \\\"Commit all new files without tracking pre-existing untracked files\\\")\\n    97→\\tcmd.Flags().MarkHidden(\\\"ignore-untracked\\\") //nolint:errcheck,gosec // flag is defined above\\n    98→\\tcmd.Flags().BoolVar(&useLocalSettings, \\\"local\\\", false, \\\"Write settings to .entire/settings.local.json instead of .entire/settings.json\\\")\\n    99→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Write settings to .entire/settings.json even if it already exists\\\")\\n   100→\\tcmd.Flags().BoolVarP(&forceHooks, \\\"force\\\", \\\"f\\\", false, \\\"Force reinstall hooks (removes existing Entire hooks first)\\\")\\n   101→\\tcmd.Flags().BoolVar(&skipPushSessions, \\\"skip-push-sessions\\\", false, \\\"Disable automatic pushing of session logs on git push\\\")\\n   102→\\tcmd.Flags().BoolVar(&telemetry, \\\"telemetry\\\", true, \\\"Enable anonymous usage analytics\\\")\\n   103→\\n   104→\\t// Provide a helpful error when --agent is used without a value\\n   105→\\tdefaultFlagErr := cmd.FlagErrorFunc()\\n   106→\\tcmd.SetFlagErrorFunc(func(c *cobra.Command, err error) error {\\n   107→\\t\\tvar valErr *pflag.ValueRequiredError\\n   108→\\t\\tif errors.As(err, &valErr) && valErr.GetSpecifiedName() == \\\"agent\\\" {\\n   109→\\t\\t\\tprintMissingAgentError(c.ErrOrStderr())\\n   110→\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n   111→\\t\\t}\\n   112→\\t\\treturn defaultFlagErr(c, err)\\n   113→\\t})\\n   114→\\n   115→\\t// Add subcommands for automation/testing\\n   116→\\tcmd.AddCommand(newSetupGitHookCmd())\\n   117→\\n   118→\\treturn cmd\\n   119→}\\n   120→\\n   121→func newDisableCmd() *cobra.Command {\\n   122→\\tvar useProjectSettings bool\\n   123→\\tvar uninstall bool\\n   124→\\tvar force bool\\n   125→\\n   126→\\tcmd := &cobra.Command{\\n   127→\\t\\tUse:   \\\"disable\\\",\\n   128→\\t\\tShort: \\\"Disable Entire in current project\\\",\\n   129→\\t\\tLong: `Disable Entire integrations in the current project.\\n   130→\\n   131→By default, this command will disable Entire. Hooks will exit silently and commands will\\n   132→show a disabled message.\\n   133→\\n   134→To completely remove Entire integrations from this repository, use --uninstall:\\n   135→  - .entire/ directory (settings, logs, metadata)\\n   136→  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\n   137→  - Session state files (.git/entire-sessions/)\\n   138→  - Shadow branches (entire/<hash>)\\n   139→  - Agent hooks`,\\n   140→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   141→\\t\\t\\tctx := cmd.Context()\\n   142→\\t\\t\\tif uninstall {\\n   143→\\t\\t\\t\\treturn runUninstall(ctx, cmd.OutOrStdout(), cmd.ErrOrStderr(), force)\\n   144→\\t\\t\\t}\\n   145→\\t\\t\\treturn runDisable(ctx, cmd.OutOrStdout(), useProjectSettings)\\n   146→\\t\\t},\\n   147→\\t}\\n   148→\\n   149→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Update .entire/settings.json instead of .entire/settings.local.json\\\")\\n   150→\\tcmd.Flags().BoolVar(&uninstall, \\\"uninstall\\\", false, \\\"Completely remove Entire from this repository\\\")\\n   151→\\tcmd.Flags().BoolVar(&force, \\\"force\\\", false, \\\"Skip confirmation prompt (use with --uninstall)\\\")\\n   152→\\n   153→\\treturn cmd\\n   154→}\\n   155→\\n   156→// runEnableInteractive runs the interactive enable flow.\\n   157→// agents must be provided by the caller (via detectOrSelectAgent).\\n   158→func runEnableInteractive(ctx context.Context, w io.Writer, agents []agent.Agent, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry bool) error {\\n   159→\\t// Uninstall hooks for agents that were previously active but are no longer selected\\n   160→\\tif err := uninstallDeselectedAgentHooks(ctx, w, agents); err != nil {\\n   161→\\t\\treturn fmt.Errorf(\\\"failed to clean up deselected agents: %w\\\", err)\\n   162→\\t}\\n   163→\\n   164→\\t// Setup agent hooks for all selected agents\\n   165→\\tfor _, ag := range agents {\\n   166→\\t\\tif _, err := setupAgentHooks(ctx, ag, localDev, forceHooks); err != nil {\\n   167→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   168→\\t\\t}\\n   169→\\t}\\n   170→\\n   171→\\t// Check if this is a first-time setup before creating directories/loading settings.\\n   172→\\t// settings.IsSetUp checks if .entire/settings.json exists on disk.\\n   173→\\tisFirstSetup := !settings.IsSetUp(ctx)\\n   174→\\n   175→\\t// Setup .entire directory\\n   176→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   177→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   178→\\t}\\n   179→\\n   180→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   181→\\tsettings, err := LoadEntireSettings(ctx)\\n   182→\\tif err != nil {\\n   183→\\t\\t// If we can't load, start with defaults\\n   184→\\t\\tsettings = &EntireSettings{}\\n   185→\\t}\\n   186→\\t// Update the specific fields\\n   187→\\tsettings.LocalDev = localDev\\n   188→\\tsettings.Enabled = true\\n   189→\\t// Set commit_linking and clean up deprecated strategy field.\\n   190→\\t// New installations get \\\"always\\\" (auto-link); existing repos get \\\"prompt\\\" written\\n   191→\\t// explicitly so the settings file reflects the current spec.\\n   192→\\tif settings.CommitLinking == \\\"\\\" {\\n   193→\\t\\tif isFirstSetup {\\n   194→\\t\\t\\tsettings.CommitLinking = CommitLinkingAlways\\n   195→\\t\\t} else {\\n   196→\\t\\t\\tsettings.CommitLinking = CommitLinkingPrompt\\n   197→\\t\\t}\\n   198→\\t}\\n   199→\\tsettings.Strategy = \\\"\\\" //nolint:staticcheck // Intentionally clearing deprecated field during setup\\n   200→\\n   201→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   202→\\tif skipPushSessions {\\n   203→\\t\\tif settings.StrategyOptions == nil {\\n   204→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   205→\\t\\t}\\n   206→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   207→\\t}\\n   208→\\n   209→\\t// Determine which settings file to write to\\n   210→\\t// First run always creates settings.json (no prompt)\\n   211→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   212→\\tif err != nil {\\n   213→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   214→\\t}\\n   215→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   216→\\n   217→\\tif showNotification {\\n   218→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   219→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   220→\\t}\\n   221→\\n   222→\\t// Save settings to the appropriate file.\\n   223→\\t// commit_linking and strategy cleanup always go to settings.json (the project file)\\n   224→\\t// so there's a single source of truth that users edit.\\n   225→\\tif shouldUseLocal {\\n   226→\\t\\t// Save user-specific overrides to local (without commit_linking — that belongs in project settings)\\n   227→\\t\\tlocalSettings := *settings\\n   228→\\t\\tlocalSettings.CommitLinking = \\\"\\\"\\n   229→\\t\\tlocalSettings.Strategy = \\\"\\\" //nolint:staticcheck // Clear deprecated field from local too\\n   230→\\t\\tif err := SaveEntireSettingsLocal(ctx, &localSettings); err != nil {\\n   231→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   232→\\t\\t}\\n   233→\\t\\t// Migrate project settings.json: clear deprecated strategy, write commit_linking\\n   234→\\t\\tif err := migrateProjectSettings(ctx); err != nil {\\n   235→\\t\\t\\treturn fmt.Errorf(\\\"failed to migrate project settings: %w\\\", err)\\n   236→\\t\\t}\\n   237→\\t} else {\\n   238→\\t\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   239→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   240→\\t\\t}\\n   241→\\t}\\n   242→\\n   243→\\tif _, err := strategy.InstallGitHook(ctx, true, localDev); err != nil {\\n   244→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   245→\\t}\\n   246→\\tstrategy.CheckAndWarnHookManagers(ctx, w, localDev)\\n   247→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   248→\\n   249→\\tconfigDisplay := configDisplayProject\\n   250→\\tif shouldUseLocal {\\n   251→\\t\\tconfigDisplay = configDisplayLocal\\n   252→\\t}\\n   253→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   254→\\n   255→\\t// Ask about telemetry consent (only if not already asked)\\n   256→\\tfmt.Fprintln(w)\\n   257→\\tif err := promptTelemetryConsent(settings, telemetry); err != nil {\\n   258→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   259→\\t}\\n   260→\\t// Save again to persist telemetry choice\\n   261→\\tif shouldUseLocal {\\n   262→\\t\\tlocalSettings := *settings\\n   263→\\t\\tlocalSettings.CommitLinking = \\\"\\\"\\n   264→\\t\\tlocalSettings.Strategy = \\\"\\\" //nolint:staticcheck // Keep deprecated field out of local\\n   265→\\t\\tif err := SaveEntireSettingsLocal(ctx, &localSettings); err != nil {\\n   266→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   267→\\t\\t}\\n   268→\\t} else {\\n   269→\\t\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   270→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   271→\\t\\t}\\n   272→\\t}\\n   273→\\n   274→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   275→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   276→\\t}\\n   277→\\n   278→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   279→\\n   280→\\treturn nil\\n   281→}\\n   282→\\n   283→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   284→func runEnable(ctx context.Context, w io.Writer) error {\\n   285→\\tsettings, err := LoadEntireSettings(ctx)\\n   286→\\tif err != nil {\\n   287→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   288→\\t}\\n   289→\\n   290→\\tsettings.Enabled = true\\n   291→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   292→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   293→\\t}\\n   294→\\n   295→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   296→\\treturn nil\\n   297→}\\n   298→\\n   299→func runDisable(ctx context.Context, w io.Writer, useProjectSettings bool) error {\\n   300→\\tsettings, err := LoadEntireSettings(ctx)\\n   301→\\tif err != nil {\\n   302→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   303→\\t}\\n   304→\\n   305→\\tsettings.Enabled = false\\n   306→\\n   307→\\t// If --project flag is specified, always write to project settings\\n   308→\\tif useProjectSettings {\\n   309→\\t\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   310→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   311→\\t\\t}\\n   312→\\t} else {\\n   313→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   314→\\t\\tif err := SaveEntireSettingsLocal(ctx, settings); err != nil {\\n   315→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   316→\\t\\t}\\n   317→\\t}\\n   318→\\n   319→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   320→\\treturn nil\\n   321→}\\n   322→\\n   323→// DisabledMessage is the message shown when Entire is disabled\\n   324→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   325→\\n   326→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   327→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   328→// On error reading settings, defaults to enabled (returns false).\\n   329→func checkDisabledGuard(ctx context.Context, w io.Writer) bool {\\n   330→\\tenabled, err := IsEnabled(ctx)\\n   331→\\tif err != nil {\\n   332→\\t\\t// Default to enabled on error\\n   333→\\t\\treturn false\\n   334→\\t}\\n   335→\\tif !enabled {\\n   336→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   337→\\t\\treturn true\\n   338→\\t}\\n   339→\\treturn false\\n   340→}\\n   341→\\n   342→// uninstallDeselectedAgentHooks removes hooks for agents that were previously\\n   343→// installed but are not in the selected list. This handles the case where a user\\n   344→// re-runs `entire enable` and deselects an agent.\\n   345→func uninstallDeselectedAgentHooks(ctx context.Context, w io.Writer, selectedAgents []agent.Agent) error {\\n   346→\\tinstalledNames := GetAgentsWithHooksInstalled(ctx)\\n   347→\\tif len(installedNames) == 0 {\\n   348→\\t\\treturn nil\\n   349→\\t}\\n   350→\\n   351→\\tselectedSet := make(map[agent.AgentName]struct{}, len(selectedAgents))\\n   352→\\tfor _, ag := range selectedAgents {\\n   353→\\t\\tselectedSet[ag.Name()] = struct{}{}\\n   354→\\t}\\n   355→\\n   356→\\tvar errs []error\\n   357→\\tfor _, name := range installedNames {\\n   358→\\t\\tif _, selected := selectedSet[name]; selected {\\n   359→\\t\\t\\tcontinue\\n   360→\\t\\t}\\n   361→\\t\\tag, err := agent.Get(name)\\n   362→\\t\\tif err != nil {\\n   363→\\t\\t\\tcontinue\\n   364→\\t\\t}\\n   365→\\t\\thookAgent, ok := ag.(agent.HookSupport)\\n   366→\\t\\tif !ok {\\n   367→\\t\\t\\tcontinue\\n   368→\\t\\t}\\n   369→\\t\\tif err := hookAgent.UninstallHooks(ctx); err != nil {\\n   370→\\t\\t\\terrs = append(errs, fmt.Errorf(\\\"failed to uninstall %s hooks: %w\\\", ag.Type(), err))\\n   371→\\t\\t} else {\\n   372→\\t\\t\\tfmt.Fprintf(w, \\\"Removed %s hooks\\\\n\\\", ag.Type())\\n   373→\\t\\t}\\n   374→\\t}\\n   375→\\treturn errors.Join(errs...)\\n   376→}\\n   377→\\n   378→// setupAgentHooks sets up hooks for a given agent.\\n   379→// Returns the number of hooks installed (0 if already installed).\\n   380→func setupAgentHooks(ctx context.Context, ag agent.Agent, localDev, forceHooks bool) (int, error) {\\n   381→\\thookAgent, ok := ag.(agent.HookSupport)\\n   382→\\tif !ok {\\n   383→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   384→\\t}\\n   385→\\n   386→\\tcount, err := hookAgent.InstallHooks(ctx, localDev, forceHooks)\\n   387→\\tif err != nil {\\n   388→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   389→\\t}\\n   390→\\n   391→\\treturn count, nil\\n   392→}\\n   393→\\n   394→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   395→// Returns the detected/selected agents and any error.\\n   396→//\\n   397→// On first run (no hooks installed):\\n   398→//   - Single detected agent: used automatically\\n   399→//   - Multiple/no detected agents: interactive multi-select prompt\\n   400→//\\n   401→// On re-run (hooks already installed):\\n   402→//   - Always shows the interactive multi-select\\n   403→//   - Pre-selects only agents that have hooks installed (respects prior deselection)\\n   404→//\\n   405→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   406→// It receives available agent names and returns the selected names.\\n   407→func detectOrSelectAgent(ctx context.Context, w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   408→\\t// Check for agents with hooks already installed (re-run detection)\\n   409→\\tinstalledAgentNames := GetAgentsWithHooksInstalled(ctx)\\n   410→\\thasInstalledHooks := len(installedAgentNames) > 0\\n   411→\\n   412→\\t// Try auto-detection\\n   413→\\tdetected := agent.DetectAll(ctx)\\n   414→\\n   415→\\t// First run: use existing auto-detect shortcuts\\n   416→\\tif !hasInstalledHooks {\\n   417→\\t\\tswitch {\\n   418→\\t\\tcase len(detected) == 1:\\n   419→\\t\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   420→\\t\\t\\treturn detected, nil\\n   421→\\n   422→\\t\\tcase len(detected) > 1:\\n   423→\\t\\t\\tagentTypes := make([]string, 0, len(detected))\\n   424→\\t\\t\\tfor _, ag := range detected {\\n   425→\\t\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   426→\\t\\t\\t}\\n   427→\\t\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   428→\\t\\t\\tfmt.Fprintln(w)\\n   429→\\t\\t}\\n   430→\\t}\\n   431→\\n   432→\\t// Check if we can prompt interactively\\n   433→\\tif !canPromptInteractively() {\\n   434→\\t\\tif hasInstalledHooks {\\n   435→\\t\\t\\t// Re-run without TTY — keep currently installed agents\\n   436→\\t\\t\\tagents := make([]agent.Agent, 0, len(installedAgentNames))\\n   437→\\t\\t\\tfor _, name := range installedAgentNames {\\n   438→\\t\\t\\t\\tag, err := agent.Get(name)\\n   439→\\t\\t\\t\\tif err != nil {\\n   440→\\t\\t\\t\\t\\tcontinue\\n   441→\\t\\t\\t\\t}\\n   442→\\t\\t\\t\\tagents = append(agents, ag)\\n   443→\\t\\t\\t}\\n   444→\\t\\t\\treturn agents, nil\\n   445→\\t\\t}\\n   446→\\t\\tif len(detected) > 0 {\\n   447→\\t\\t\\treturn detected, nil\\n   448→\\t\\t}\\n   449→\\t\\tdefaultAgent := agent.Default()\\n   450→\\t\\tif defaultAgent == nil {\\n   451→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   452→\\t\\t}\\n   453→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   454→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   455→\\t}\\n   456→\\n   457→\\tif !hasInstalledHooks && len(detected) == 0 {\\n   458→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., \\\"+strings.Join(agent.StringList(), \\\", \\\")+\\\").\\\")\\n   459→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   460→\\t\\tfmt.Fprintln(w)\\n   461→\\t}\\n   462→\\n   463→\\t// Build pre-selection set.\\n   464→\\t// On re-run: only pre-select agents with hooks installed (respect prior deselection).\\n   465→\\t// On first run: pre-select all detected agents.\\n   466→\\tpreSelectedSet := make(map[agent.AgentName]struct{})\\n   467→\\tif hasInstalledHooks {\\n   468→\\t\\tfor _, name := range installedAgentNames {\\n   469→\\t\\t\\tpreSelectedSet[name] = struct{}{}\\n   470→\\t\\t}\\n   471→\\t} else {\\n   472→\\t\\tfor _, ag := range detected {\\n   473→\\t\\t\\tpreSelectedSet[ag.Name()] = struct{}{}\\n   474→\\t\\t}\\n   475→\\t}\\n   476→\\n   477→\\t// Build options from registered agents\\n   478→\\tagentNames := agent.List()\\n   479→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   480→\\tfor _, name := range agentNames {\\n   481→\\t\\tag, err := agent.Get(name)\\n   482→\\t\\tif err != nil {\\n   483→\\t\\t\\tcontinue\\n   484→\\t\\t}\\n   485→\\t\\t// Only show agents that support hooks\\n   486→\\t\\tif _, ok := ag.(agent.HookSupport); !ok {\\n   487→\\t\\t\\tcontinue\\n   488→\\t\\t}\\n   489→\\t\\topt := huh.NewOption(string(ag.Type()), string(name))\\n   490→\\t\\tif _, isPreSelected := preSelectedSet[name]; isPreSelected {\\n   491→\\t\\t\\topt = opt.Selected(true)\\n   492→\\t\\t}\\n   493→\\t\\toptions = append(options, opt)\\n   494→\\t}\\n   495→\\n   496→\\tif len(options) == 0 {\\n   497→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   498→\\t}\\n   499→\\n   500→\\t// Collect available agent names for the selector\\n   501→\\tavailableNames := make([]string, 0, len(options))\\n   502→\\tfor _, opt := range options {\\n   503→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   504→\\t}\\n   505→\\n   506→\\tvar selectedAgentNames []string\\n   507→\\tif selectFn != nil {\\n   508→\\t\\tvar err error\\n   509→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   510→\\t\\tif err != nil {\\n   511→\\t\\t\\treturn nil, err\\n   512→\\t\\t}\\n   513→\\t\\tif len(selectedAgentNames) == 0 {\\n   514→\\t\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   515→\\t\\t}\\n   516→\\t} else {\\n   517→\\t\\tform := NewAccessibleForm(\\n   518→\\t\\t\\thuh.NewGroup(\\n   519→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   520→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   521→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   522→\\t\\t\\t\\t\\tOptions(options...).\\n   523→\\t\\t\\t\\t\\tValidate(func(selected []string) error {\\n   524→\\t\\t\\t\\t\\t\\tif len(selected) == 0 {\\n   525→\\t\\t\\t\\t\\t\\t\\treturn errors.New(\\\"please select at least one agent\\\")\\n   526→\\t\\t\\t\\t\\t\\t}\\n   527→\\t\\t\\t\\t\\t\\treturn nil\\n   528→\\t\\t\\t\\t\\t}).\\n   529→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   530→\\t\\t\\t),\\n   531→\\t\\t)\\n   532→\\t\\tif err := form.Run(); err != nil {\\n   533→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   534→\\t\\t}\\n   535→\\t}\\n   536→\\n   537→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   538→\\tfor _, name := range selectedAgentNames {\\n   539→\\t\\tselectedAgent, err := agent.Get(agent.AgentName(name))\\n   540→\\t\\tif err != nil {\\n   541→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   542→\\t\\t}\\n   543→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   544→\\t}\\n   545→\\n   546→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   547→\\tfor _, ag := range selectedAgents {\\n   548→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   549→\\t}\\n   550→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   551→\\treturn selectedAgents, nil\\n   552→}\\n   553→\\n   554→// canPromptInteractively checks if we can show interactive prompts.\\n   555→// Returns false when running in CI, tests, or other non-interactive environments.\\n   556→func canPromptInteractively() bool {\\n   557→\\t// Check for test environment\\n   558→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   559→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   560→\\t}\\n   561→\\n   562→\\t// Check if /dev/tty is available\\n   563→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   564→\\tif err != nil {\\n   565→\\t\\treturn false\\n   566→\\t}\\n   567→\\t_ = tty.Close()\\n   568→\\treturn true\\n   569→}\\n   570→\\n   571→// printAgentError writes an error message followed by available agents and usage.\\n   572→func printAgentError(w io.Writer, message string) {\\n   573→\\tagents := agent.List()\\n   574→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   575→\\tfmt.Fprintln(w)\\n   576→\\tfor _, a := range agents {\\n   577→\\t\\tsuffix := \\\"\\\"\\n   578→\\t\\tif a == agent.DefaultAgentName {\\n   579→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   580→\\t\\t}\\n   581→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   582→\\t}\\n   583→\\tfmt.Fprintln(w)\\n   584→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   585→}\\n   586→\\n   587→// printMissingAgentError writes a helpful error listing available agents.\\n   588→func printMissingAgentError(w io.Writer) {\\n   589→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   590→}\\n   591→\\n   592→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   593→func printWrongAgentError(w io.Writer, name string) {\\n   594→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   595→}\\n   596→\\n   597→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   598→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   599→func setupAgentHooksNonInteractive(ctx context.Context, w io.Writer, ag agent.Agent, localDev, forceHooks, skipPushSessions, telemetry bool) error {\\n   600→\\tagentName := ag.Name()\\n   601→\\t// Check if agent supports hooks\\n   602→\\thookAgent, ok := ag.(agent.HookSupport)\\n   603→\\tif !ok {\\n   604→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   605→\\t}\\n   606→\\n   607→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   608→\\n   609→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   610→\\tinstalledHooks, err := hookAgent.InstallHooks(ctx, localDev, forceHooks)\\n   611→\\tif err != nil {\\n   612→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   613→\\t}\\n   614→\\n   615→\\t// Check if this is a first-time setup BEFORE creating .entire directory\\n   616→\\tisFirstSetup := !settings.IsSetUp(ctx)\\n   617→\\n   618→\\t// Setup .entire directory\\n   619→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   620→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   621→\\t}\\n   622→\\n   623→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   624→\\tsettings, err := LoadEntireSettings(ctx)\\n   625→\\tif err != nil {\\n   626→\\t\\t// If we can't load, start with defaults\\n   627→\\t\\tsettings = &EntireSettings{}\\n   628→\\t}\\n   629→\\tsettings.Enabled = true\\n   630→\\tif localDev {\\n   631→\\t\\tsettings.LocalDev = localDev\\n   632→\\t}\\n   633→\\t// Set commit_linking and clean up deprecated strategy field.\\n   634→\\tif settings.CommitLinking == \\\"\\\" {\\n   635→\\t\\tif isFirstSetup {\\n   636→\\t\\t\\tsettings.CommitLinking = CommitLinkingAlways\\n   637→\\t\\t} else {\\n   638→\\t\\t\\tsettings.CommitLinking = CommitLinkingPrompt\\n   639→\\t\\t}\\n   640→\\t}\\n   641→\\tsettings.Strategy = \\\"\\\" //nolint:staticcheck // Intentionally clearing deprecated field during setup\\n   642→\\n   643→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   644→\\tif skipPushSessions {\\n   645→\\t\\tif settings.StrategyOptions == nil {\\n   646→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   647→\\t\\t}\\n   648→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   649→\\t}\\n   650→\\n   651→\\t// Handle telemetry for non-interactive mode\\n   652→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   653→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   654→\\t\\tf := false\\n   655→\\t\\tsettings.Telemetry = &f\\n   656→\\t}\\n   657→\\n   658→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   659→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   660→\\t}\\n   661→\\n   662→\\tif _, err := strategy.InstallGitHook(ctx, true, localDev); err != nil {\\n   663→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   664→\\t}\\n   665→\\tstrategy.CheckAndWarnHookManagers(ctx, w, localDev)\\n   666→\\n   667→\\tif installedHooks == 0 {\\n   668→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   669→\\t\\tif ag.IsPreview() {\\n   670→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   671→\\t\\t}\\n   672→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   673→\\t} else {\\n   674→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   675→\\t\\tif ag.IsPreview() {\\n   676→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   677→\\t\\t}\\n   678→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   679→\\t}\\n   680→\\n   681→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   682→\\n   683→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   684→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   685→\\t}\\n   686→\\n   687→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   688→\\n   689→\\treturn nil\\n   690→}\\n   691→\\n   692→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   693→func validateSetupFlags(useLocal, useProject bool) error {\\n   694→\\tif useLocal && useProject {\\n   695→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   696→\\t}\\n   697→\\treturn nil\\n   698→}\\n   699→\\n   700→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   701→// - Whether settings.json already exists\\n   702→// - The --local and --project flags\\n   703→// Returns (useLocal, showNotification).\\n   704→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   705→\\t// Explicit --local flag always uses local settings\\n   706→\\tif useLocal {\\n   707→\\t\\treturn true, false\\n   708→\\t}\\n   709→\\n   710→\\t// Explicit --project flag always uses project settings\\n   711→\\tif useProject {\\n   712→\\t\\treturn false, false\\n   713→\\t}\\n   714→\\n   715→\\t// No flags specified - check if settings file exists\\n   716→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   717→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   718→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   719→\\t\\treturn true, true\\n   720→\\t}\\n   721→\\n   722→\\t// Settings file doesn't exist - create it\\n   723→\\treturn false, false\\n   724→}\\n   725→\\n   726→// migrateProjectSettings loads the project settings.json directly,\\n   727→// clears the deprecated strategy field, sets commit_linking if missing,\\n   728→// and saves it back. This is needed when the main save goes to\\n   729→// settings.local.json — the project file still needs cleanup.\\n   730→func migrateProjectSettings(ctx context.Context) error {\\n   731→\\tsettingsFileAbs, err := paths.AbsPath(ctx, settings.EntireSettingsFile)\\n   732→\\tif err != nil {\\n   733→\\t\\treturn fmt.Errorf(\\\"resolving settings path: %w\\\", err)\\n   734→\\t}\\n   735→\\tprojectSettings, err := settings.LoadFromFile(settingsFileAbs)\\n   736→\\tif err != nil {\\n   737→\\t\\treturn fmt.Errorf(\\\"loading project settings: %w\\\", err)\\n   738→\\t}\\n   739→\\tprojectSettings.Strategy = \\\"\\\" //nolint:staticcheck // Intentionally clearing deprecated field\\n   740→\\tif projectSettings.CommitLinking == \\\"\\\" {\\n   741→\\t\\tprojectSettings.CommitLinking = settings.CommitLinkingPrompt\\n   742→\\t}\\n   743→\\tif err := settings.Save(ctx, projectSettings); err != nil {\\n   744→\\t\\treturn fmt.Errorf(\\\"saving project settings: %w\\\", err)\\n   745→\\t}\\n   746→\\treturn nil\\n   747→}\\n   748→\\n   749→// setupEntireDirectory creates the .entire directory and gitignore.\\n   750→// Returns true if the directory was created, false if it already existed.\\n   751→func setupEntireDirectory(ctx context.Context) (bool, error) { //nolint:unparam // already present in codebase\\n   752→\\t// Get absolute path for the .entire directory\\n   753→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   754→\\tif err != nil {\\n   755→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   756→\\t}\\n   757→\\n   758→\\t// Check if directory already exists\\n   759→\\tcreated := false\\n   760→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   761→\\t\\tcreated = true\\n   762→\\t}\\n   763→\\n   764→\\t// Create .entire directory\\n   765→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   766→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   767→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   768→\\t}\\n   769→\\n   770→\\t// Create/update .gitignore with all required entries\\n   771→\\tif err := strategy.EnsureEntireGitignore(ctx); err != nil {\\n   772→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   773→\\t}\\n   774→\\n   775→\\treturn created, nil\\n   776→}\\n   777→\\n   778→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   779→func setupGitHook(ctx context.Context) error {\\n   780→\\ts, err := settings.Load(ctx)\\n   781→\\tlocalDev := err == nil && s.LocalDev\\n   782→\\tif _, err := strategy.InstallGitHook(ctx, false, localDev); err != nil {\\n   783→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   784→\\t}\\n   785→\\tstrategy.CheckAndWarnHookManagers(ctx, os.Stderr, localDev)\\n   786→\\treturn nil\\n   787→}\\n   788→\\n   789→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   790→func newSetupGitHookCmd() *cobra.Command {\\n   791→\\tcmd := &cobra.Command{\\n   792→\\t\\tUse:    \\\"git-hook\\\",\\n   793→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   794→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   795→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   796→\\t\\t\\treturn setupGitHook(cmd.Context())\\n   797→\\t\\t},\\n   798→\\t}\\n   799→\\n   800→\\treturn cmd\\n   801→}\\n   802→\\n   803→func newCurlBashPostInstallCmd() *cobra.Command {\\n   804→\\treturn &cobra.Command{\\n   805→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   806→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   807→\\t\\tHidden: true,\\n   808→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   809→\\t\\t\\tw := cmd.OutOrStdout()\\n   810→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   811→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   812→\\t\\t\\t}\\n   813→\\t\\t\\treturn nil\\n   814→\\t\\t},\\n   815→\\t}\\n   816→}\\n   817→\\n   818→// shellCompletionComment is the comment preceding the completion line\\n   819→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   820→\\n   821→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   822→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   823→\\n   824→// shellCompletionTarget returns the rc file path and completion lines for the\\n   825→// user's current shell.\\n   826→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   827→\\thome, err := os.UserHomeDir()\\n   828→\\tif err != nil {\\n   829→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   830→\\t}\\n   831→\\n   832→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   833→\\tswitch {\\n   834→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   835→\\t\\treturn \\\"Zsh\\\",\\n   836→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   837→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   838→\\t\\t\\tnil\\n   839→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   840→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   841→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   842→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   843→\\t\\t}\\n   844→\\t\\treturn \\\"Bash\\\",\\n   845→\\t\\t\\tbashRC,\\n   846→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   847→\\t\\t\\tnil\\n   848→\\tcase strings.Contains(shell, \\\"fish\\\"):\\n   849→\\t\\treturn \\\"Fish\\\",\\n   850→\\t\\t\\tfilepath.Join(home, \\\".config\\\", \\\"fish\\\", \\\"config.fish\\\"),\\n   851→\\t\\t\\t\\\"entire completion fish | source\\\",\\n   852→\\t\\t\\tnil\\n   853→\\tdefault:\\n   854→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   855→\\t}\\n   856→}\\n   857→\\n   858→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   859→// Only prompts if completion is not already configured.\\n   860→func promptShellCompletion(w io.Writer) error {\\n   861→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   862→\\tif err != nil {\\n   863→\\t\\tif errors.Is(err, errUnsupportedShell) {\\n   864→\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion not available for your shell. Supported: zsh, bash, fish.\\\\n\\\")\\n   865→\\t\\t\\treturn nil\\n   866→\\t\\t}\\n   867→\\t\\treturn fmt.Errorf(\\\"shell completion: %w\\\", err)\\n   868→\\t}\\n   869→\\n   870→\\tif isCompletionConfigured(rcFile) {\\n   871→\\t\\tfmt.Fprintf(w, \\\"✓ Shell completion already configured in %s\\\\n\\\", rcFile)\\n   872→\\t\\treturn nil\\n   873→\\t}\\n   874→\\n   875→\\tvar selected string\\n   876→\\tform := NewAccessibleForm(\\n   877→\\t\\thuh.NewGroup(\\n   878→\\t\\t\\thuh.NewSelect[string]().\\n   879→\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Enable shell completion? (detected: %s)