 agent agents.Agent) *RepoState {\\n    38→\\tt.Helper()\\n    39→\\n    40→\\tkeepRepos := os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\"\\n    41→\\n    42→\\t// Always use os.MkdirTemp instead of t.TempDir(). Go's t.TempDir()\\n    43→\\t// creates nested subdirectories (TestName.../001/) whose structure\\n    44→\\t// confuses some agents' (e.g. opencode) working-directory resolution.\\n    45→\\tdir, err := os.MkdirTemp(\\\"\\\", \\\"e2e-repo-*\\\")\\n    46→\\tif err != nil {\\n    47→\\t\\tt.Fatalf(\\\"create temp dir: %v\\\", err)\\n    48→\\t}\\n    49→\\tif keepRepos {\\n    50→\\t\\tt.Logf(\\\"E2E_KEEP_REPOS: repo will be preserved at %s\\\", dir)\\n    51→\\t} else {\\n    52→\\t\\tt.Cleanup(func() { os.RemoveAll(dir) })\\n    53→\\t}\\n    54→\\n    55→\\t// Resolve symlinks (macOS: /var -> /private/var) so paths match\\n    56→\\t// what agent CLIs see when they resolve their own CWD.\\n    57→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n    58→\\t\\tdir = resolved\\n    59→\\t}\\n    60→\\n    61→\\tGit(t, dir, \\\"init\\\")\\n    62→\\tGit(t, dir, \\\"config\\\", \\\"user.name\\\", \\\"E2E Test\\\")\\n    63→\\tGit(t, dir, \\\"config\\\", \\\"user.email\\\", \\\"e2e@test.local\\\")\\n    64→\\tGit(t, dir, \\\"commit\\\", \\\"--allow-empty\\\", \\\"-m\\\", \\\"initial commit\\\")\\n    65→\\n    66→\\tentire.Enable(t, dir, agent.EntireAgent())\\n    67→\\tPatchSettings(t, dir, map[string]any{\\\"log_level\\\": \\\"debug\\\"})\\n    68→\\n    69→\\t// OpenCode's non-interactive mode auto-rejects external_directory permission\\n    70→\\t// since there's no user to prompt. Write a config to allow it.\\n    71→\\tif agent.Name() == \\\"opencode\\\" {\\n    72→\\t\\tcfg := `{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}}`\\n    73→\\t\\tif key := os.Getenv(\\\"ANTHROPIC_API_KEY\\\"); key != \\\"\\\" {\\n    74→\\t\\t\\tcfg = fmt.Sprintf(`{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}, \\\"provider\\\": {\\\"anthropic\\\": {\\\"options\\\": {\\\"apiKey\\\": %q}}}}`, key)\\n    75→\\t\\t}\\n    76→\\t\\tif err := os.WriteFile(filepath.Join(dir, \\\"opencode.json\\\"), []byte(cfg+\\\"\\\\n\\\"), 0o644); err != nil {\\n    77→\\t\\t\\tt.Fatalf(\\\"write opencode.json: %v\\\", err)\\n    78→\\t\\t}\\n    79→\\t}\\n    80→\\n    81→\\t// Create artifact dir eagerly so console.log is written to disk\\n    82→\\t// incrementally. Even if the test is killed by a global timeout,\\n    83→\\t// partial output survives.\\n    84→\\tartDir := artifactDir(t)\\n    85→\\tconsoleLog, err := os.Create(filepath.Join(artDir, \\\"console.log\\\"))\\n    86→\\tif err != nil {\\n    87→\\t\\tt.Fatalf(\\\"create console.log: %v\\\", err)\\n    88→\\t}\\n    89→\\n    90→\\tstate := &RepoState{\\n    91→\\t\\tAgent:            agent,\\n    92→\\t\\tDir:              dir,\\n    93→\\t\\tArtifactDir:      artDir,\\n    94→\\t\\tHeadBefore:       GitOutput(t, dir, \\\"rev-parse\\\", \\\"HEAD\\\"),\\n    95→\\t\\tCheckpointBefore: GitOutput(t, dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\"),\\n    96→\\t\\tConsoleLog:       consoleLog,\\n    97→\\t}\\n    98→\\n    99→\\tt.Cleanup(func() {\\n   100→\\t\\t_ = consoleLog.Close()\\n   101→\\t\\tCaptureArtifacts(t, state)\\n   102→\\t})\\n   103→\\n   104→\\treturn state\\n   105→}\\n   106→\\n   107→// ForEachAgent runs fn as a parallel subtest for every registered agent.\\n   108→// It handles repo setup, concurrency gating, context timeout, and cleanup.\\n   109→// The timeout is scaled by each agent's TimeoutMultiplier.\\n   110→func ForEachAgent(t *testing.T, timeout time.Duration, fn func(t *testing.T, s *RepoState, ctx context.Context)) {\\n   111→\\tt.Helper()\\n   112→\\tt.Parallel()\\n   113→\\tall := agents.All()\\n   114→\\tif len(all) == 0 {\\n   115→\\t\\tt.Skip(\\\"no agents registered (check E2E_AGENT filter)\\\")\\n   116→\\t}\\n   117→\\tfor _, agent := range all {\\n   118→\\t\\tt.Run(agent.Name(), func(t *testing.T) {\\n   119→\\t\\t\\ts := SetupRepo(t, agent)\\n   120→\\n   121→\\t\\t\\t// Use the global test deadline for slot wait so we don't\\n   122→\\t\\t\\t// skip prematurely — only bail if the whole binary is dying.\\n   123→\\t\\t\\tslotCtx := context.Background()\\n   124→\\t\\t\\tif deadline, ok := t.Deadline(); ok {\\n   125→\\t\\t\\t\\tvar cancel context.CancelFunc\\n   126→\\t\\t\\t\\tslotCtx, cancel = context.WithDeadline(slotCtx, deadline)\\n   127→\\t\\t\\t\\tdefer cancel()\\n   128→\\t\\t\\t}\\n   129→\\t\\t\\tif err := agents.AcquireSlot(slotCtx, agent); err != nil {\\n   130→\\t\\t\\t\\tt.Fatalf(\\\"timed out waiting for agent slot: %v\\\", err)\\n   131→\\t\\t\\t}\\n   132→\\t\\t\\tdefer agents.ReleaseSlot(agent)\\n   133→\\n   134→\\t\\t\\t// Per-test timeout starts after slot is acquired, scaled\\n   135→\\t\\t\\t// by the agent's multiplier (e.g. 2.5× for gemini).\\n   136→\\t\\t\\tscaled := time.Duration(float64(timeout) * agent.TimeoutMultiplier())\\n   137→\\t\\t\\tctx, cancel := context.WithTimeout(context.Background(), scaled)\\n   138→\\t\\t\\tdefer cancel()\\n   139→\\t\\t\\tfn(t, s, ctx)\\n   140→\\t\\t})\\n   141→\\t}\\n   142→}\\n   143→\\n   144→// RunPrompt runs an agent prompt, logs the command and output to ConsoleLog,\\n   145→// and returns the result. If the agent reports a transient API error, the\\n   146→// prompt is retried once after a short delay. The caller should still check err.\\n   147→func (s *RepoState) RunPrompt(t *testing.T, ctx context.Context, prompt string, opts ...agents.Option) (agents.Output, error) {\\n   148→\\tt.Helper()\\n   149→\\tout, err := s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n   150→\\ts.logPromptResult(out)\\n   151→\\n   152→\\tif err != nil && s.Agent.IsTransientError(out, err) {\\n   153→\\t\\tt.Logf(\\\"transient API error detected, retrying in 5s: %v\\\", err)\\n   154→\\t\\ts.ConsoleLog.WriteString(\\\"> [retry] transient error, waiting 5s...\\\\n\\\")\\n   155→\\t\\tselect {\\n   156→\\t\\tcase <-time.After(5 * time.Second):\\n   157→\\t\\tcase <-ctx.Done():\\n   158→\\t\\t\\treturn out, err\\n   159→\\t\\t}\\n   160→\\t\\tout, err = s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n   161→\\t\\ts.logPromptResult(out)\\n   162→\\t}\\n   163→\\n   164→\\treturn out, err\\n   165→}\\n   166→\\n   167→func (s *RepoState) logPromptResult(out agents.Output) {\\n   168→\\ts.ConsoleLog.WriteString(\\\"> \\\" + out.Command + \\\"\\\\n\\\")\\n   169→\\ts.ConsoleLog.WriteString(\\\"stdout:\\\\n\\\" + out.Stdout + \\\"\\\\n\\\")\\n   170→\\ts.ConsoleLog.WriteString(\\\"stderr:\\\\n\\\" + out.Stderr + \\\"\\\\n\\\")\\n   171→}\\n   172→\\n   173→// Git runs a git command in the repo and logs it to ConsoleLog.\\n   174→func (s *RepoState) Git(t *testing.T, args ...string) {\\n   175→\\tt.Helper()\\n   176→\\ts.ConsoleLog.WriteString(\\\"> git \\\" + strings.Join(args, \\\" \\\") + \\\"\\\\n\\\")\\n   177→\\tGit(t, s.Dir, args...)\\n   178→}\\n   179→\\n   180→// StartSession starts an interactive session and registers it for pane\\n   181→// capture in artifacts. Returns nil if the agent does not support interactive\\n   182→// mode. The session is closed automatically during test cleanup.\\n   183→func (s *RepoState) StartSession(t *testing.T, ctx context.Context) agents.Session {\\n   184→\\tt.Helper()\\n   185→\\tsession, err := s.Agent.StartSession(ctx, s.Dir)\\n   186→\\tif err != nil {\\n   187→\\t\\tt.Fatalf(\\\"start session: %v\\\", err)\\n   188→\\t}\\n   189→\\tif session == nil {\\n   190→\\t\\treturn nil\\n   191→\\t}\\n   192→\\ts.session = session\\n   193→\\treturn session\\n   194→}\\n   195→\\n   196→// WaitFor waits for a pattern in the interactive session's pane and logs the\\n   197→// pane content to ConsoleLog after the wait completes (success or failure).\\n   198→func (s *RepoState) WaitFor(t *testing.T, session agents.Session, pattern string, timeout time.Duration) {\\n   199→\\tt.Helper()\\n   200→\\tcontent, err := session.WaitFor(pattern, timeout)\\n   201→\\tfmt.Fprintf(s.ConsoleLog, \\\"> pane after WaitFor(%q):\\\\n%s\\\\n\\\", pattern, content)\\n   202→\\tif err != nil {\\n   203→\\t\\tt.Fatalf(\\\"WaitFor(%q): %v\\\", pattern, err)\\n   204→\\t}\\n   205→}\\n   206→\\n   207→// Send sends input to an interactive session and logs it to ConsoleLog.\\n   208→// Fails the test on error.\\n   209→func (s *RepoState) Send(t *testing.T, session agents.Session, input string) {\\n   210→\\tt.Helper()\\n   211→\\ts.ConsoleLog.WriteString(\\\"> send: \\\" + input + \\\"\\\\n\\\")\\n   212→\\tif err := session.Send(input); err != nil {\\n   213→\\t\\tt.Fatalf(\\\"send failed: %v\\\", err)\\n   214→\\t}\\n   215→}\\n   216→\\n   217→// PatchSettings merges extra keys into .entire/settings.json.\\n   218→func PatchSettings(t *testing.T, dir string, extra map[string]any) {\\n   219→\\tt.Helper()\\n   220→\\tpath := filepath.Join(dir, \\\".entire\\\", \\\"settings.json\\\")\\n   221→\\tdata, err := os.ReadFile(path)\\n   222→\\tif err != nil {\\n   223→\\t\\tt.Fatalf(\\\"read settings: %v\\\", err)\\n   224→\\t}\\n   225→\\tvar settings map[string]any\\n   226→\\tif err := json.Unmarshal(data, &settings); err != nil {\\n   227→\\t\\tt.Fatalf(\\\"parse settings: %v\\\", err)\\n   228→\\t}\\n   229→\\tfor k, v := range extra {\\n   230→\\t\\tsettings[k] = v\\n   231→\\t}\\n   232→\\tout, err := json.MarshalIndent(settings, \\\"\\\", \\\"  \\\")\\n   233→\\tif err != nil {\\n   234→\\t\\tt.Fatalf(\\\"marshal settings: %v\\\", err)\\n   235→\\t}\\n   236→\\tif err := os.WriteFile(path, out, 0o644); err != nil {\\n   237→\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n   238→\\t}\\n   239→}\\n   240→\\n   241→// Git runs a git command in the given directory and fails the test if it\\n   242→// returns a non-zero exit code.\\n   243→func Git(t *testing.T, dir string, args ...string) {\\n   244→\\tt.Helper()\\n   245→\\n   246→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   247→\\tif dir != \\\"\\\" {\\n   248→\\t\\tcmd.Dir = dir\\n   249→\\t}\\n   250→\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   251→\\n   252→\\tout, err := cmd.CombinedOutput()\\n   253→\\tif err != nil {\\n   254→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n   255→\\t}\\n   256→}\\n   257→\\n   258→// GitOutput runs a git command in the given directory, returns its trimmed\\n   259→// stdout, and fails the test on error.\\n   260→func GitOutput(t *testing.T, dir string, args ...string) string {\\n   261→\\tt.Helper()\\n   262→\\n   263→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   264→\\tif dir != \\\"\\\" {\\n   265→\\t\\tcmd.Dir = dir\\n   266→\\t}\\n   267→\\n   268→\\tout, err := cmd.Output()\\n   269→\\tif err != nil {\\n   270→\\t\\tvar stderr string\\n   271→\\t\\tee := &exec.ExitError{}\\n   272→\\t\\tif errors.As(err, &ee) {\\n   273→\\t\\t\\tstderr = string(ee.Stderr)\\n   274→\\t\\t}\\n   275→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, stderr)\\n   276→\\t}\\n   277→\\n   278→\\treturn strings.TrimSpace(string(out))\\n   279→}\\n   280→\\n   281→// NewCheckpointCommits returns the SHAs of commits added to the\\n   282→// entire/checkpoints/v1 branch since the test was set up, oldest first.\\n   283→func NewCheckpointCommits(t *testing.T, s *RepoState) []string {\\n   284→\\tt.Helper()\\n   285→\\n   286→\\tlog := GitOutput(t, s.Dir, \\\"log\\\", \\\"--reverse\\\", \\\"--format=%H\\\", s.CheckpointBefore+\\\"..entire/checkpoints/v1\\\")\\n   287→\\tif log == \\\"\\\" {\\n   288→\\t\\treturn nil\\n   289→\\t}\\n   290→\\treturn strings.Split(log, \\\"\\\\n\\\")\\n   291→}\\n   292→\\n   293→// CheckpointIDs lists all checkpoint IDs from the tree at the tip of the\\n   294→// checkpoint branch. It parses the two-level directory structure\\n   295→// ({prefix}/{suffix}/metadata.json) and returns the concatenated IDs.\\n   296→func CheckpointIDs(t *testing.T, dir string) []string {\\n   297→\\tt.Helper()\\n   298→\\tout := gitOutputSafe(dir, \\\"ls-tree\\\", \\\"-r\\\", \\\"--name-only\\\", \\\"entire/checkpoints/v1\\\")\\n   299→\\tif out == \\\"\\\" {\\n   300→\\t\\treturn nil\\n   301→\\t}\\n   302→\\tseen := map[string]bool{}\\n   303→\\tvar ids []string\\n   304→\\tfor _, line := range strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\") {\\n   305→\\t\\t// Match {prefix}/{suffix}/metadata.json (top-level, not session-level)\\n   306→\\t\\tparts := strings.Split(line, \\\"/\\\")\\n   307→\\t\\tif len(parts) == 3 && parts[2] == \\\"metadata.json\\\" {\\n   308→\\t\\t\\tid := parts[0] + parts[1]\\n   309→\\t\\t\\tif !seen[id] {\\n   310→\\t\\t\\t\\tseen[id] = true\\n   311→\\t\\t\\t\\tids = append(ids, id)\\n   312→\\t\\t\\t}\\n   313→\\t\\t}\\n   314→\\t}\\n   315→\\treturn ids\\n   316→}\\n   317→\\n   318→// ReadCheckpointMetadata reads the checkpoint-level metadata.json from the\\n   319→// tip of the checkpoint branch for the given checkpoint ID.\\n   320→func ReadCheckpointMetadata(t *testing.T, dir string, checkpointID string) CheckpointMetadata {\\n   321→\\tt.Helper()\\n   322→\\n   323→\\tpath := CheckpointPath(checkpointID) + \\\"/metadata.json\\\"\\n   324→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   325→\\n   326→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   327→\\n   328→\\tvar meta CheckpointMetadata\\n   329→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   330→\\t\\tt.Fatalf(\\\"unmarshal checkpoint metadata from %s: %v\\\", blob, err)\\n   331→\\t}\\n   332→\\n   333→\\treturn meta\\n   334→}\\n   335→\\n   336→// ReadSessionMetadata reads a session's metadata.json from the tip of the\\n   337→// checkpoint branch for the given checkpoint ID and session index.\\n   338→func ReadSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int) SessionMetadata {\\n   339→\\tt.Helper()\\n   340→\\n   341→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   342→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   343→\\n   344→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   345→\\n   346→\\tvar meta SessionMetadata\\n   347→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   348→\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   349→\\t}\\n   350→\\n   351→\\treturn meta\\n   352→}\\n   353→\\n   354→// WaitForSessionMetadata polls until session metadata exists on the checkpoint\\n   355→// branch for the given checkpoint ID and session index, then returns it.\\n   356→// This handles the race where the checkpoint branch advances before session\\n   357→// metadata is fully committed.\\n   358→func WaitForSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int, timeout time.Duration) SessionMetadata {\\n   359→\\tt.Helper()\\n   360→\\n   361→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   362→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   363→\\n   364→\\tdeadline := time.Now().Add(timeout)\\n   365→\\tfor time.Now().Before(deadline) {\\n   366→\\t\\traw := gitOutputSafe(dir, \\\"show\\\", blob)\\n   367→\\t\\tif raw != \\\"\\\" {\\n   368→\\t\\t\\tvar meta SessionMetadata\\n   369→\\t\\t\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   370→\\t\\t\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   371→\\t\\t\\t}\\n   372→\\t\\t\\treturn meta\\n   373→\\t\\t}\\n   374→\\t\\ttime.Sleep(500 * time.Millisecond)\\n   375→\\t}\\n   376→\\tt.Fatalf(\\\"session metadata %s did not appear within %s\\\", blob, timeout)\\n   377→\\treturn SessionMetadata{}\\n   378→}\\n   379→\\n   380→// SetupBareRemote creates a bare git repo, adds it as \\\"origin\\\", and pushes\\n   381→// the initial commit. Returns the bare repo path.\\n   382→func SetupBareRemote(t *testing.T, s *RepoState) string {\\n   383→\\tt.Helper()\\n   384→\\n   385→\\tvar bareDir string\\n   386→\\tif os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\" {\\n   387→\\t\\tvar err error\\n   388→\\t\\tbareDir, err = os.MkdirTemp(\\\"\\\", \\\"e2e-bare-*\\\")\\n   389→\\t\\tif err != nil {\\n   390→\\t\\t\\tt.Fatalf(\\\"create bare remote dir: %v\\\", err)\\n   391→\\t\\t}\\n   392→\\t\\tt.Logf(\\\"E2E_KEEP_REPOS: bare remote will be preserved at %s\\\", bareDir)\\n   393→\\t} else {\\n   394→\\t\\tbareDir = t.TempDir()\\n   395→\\t}\\n   396→\\n   397→\\tGit(t, bareDir, \\\"init\\\", \\\"--bare\\\")\\n   398→\\tGit(t, s.Dir, \\\"remote\\\", \\\"add\\\", \\\"origin\\\", bareDir)\\n   399→\\tGit(t, s.Dir, \\\"push\\\", \\\"-u\\\", \\\"origin\\\", \\\"HEAD\\\")\\n   400→\\treturn bareDir\\n   401→}\\n   402→\\n   403→// GitOutputErr runs a git command and returns (output, error) without\\n   404→// failing the test. For commands expected to fail.\\n   405→func GitOutputErr(dir string, args ...string) (string, error) {\\n   406→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   407→\\tif dir != \\\"\\\" {\\n   408→\\t\\tcmd.Dir = dir\\n   409→\\t}\\n   410→\\tout, err := cmd.CombinedOutput()\\n   411→\\treturn strings.TrimSpace(string(out)), err\\n   412→}\\n   413→\\n   414→// GetCheckpointTrailer extracts the Entire-Checkpoint trailer value from a\\n   415→// code commit. Returns the trimmed trailer value, or an empty string if the\\n   416→// trailer is not present.\\n   417→func GetCheckpointTrailer(t *testing.T, dir string, ref string) string {\\n   418→\\tt.Helper()\\n   419→\\n   420→\\treturn GitOutput(t, dir, \\\"log\\\", \\\"-1\\\", \\\"--format=%(trailers:key=Entire-Checkpoint,valueonly)\\\", ref)\\n   421→}\\n   422→\"}]},\"uuid\":\"c64fac77-9682-4e82-9e27-468bbb9234b6\",\"timestamp\":\"2026-02-26T01:06:44.751Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Search the e2e/ directory and mise 