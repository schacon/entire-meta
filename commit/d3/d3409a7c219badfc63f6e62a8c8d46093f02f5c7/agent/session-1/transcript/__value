ub.com\\\", \\\"*.npmjs.org\\\"],\\n      \\\"allowUnixSockets\\\": [\\\"~/.ssh/agent-socket\\\"],\\n      \\\"allowAllUnixSockets\\\": false,\\n      \\\"allowLocalBinding\\\": false,\\n      \\\"allowManagedDomainsOnly\\\": false,\\n      \\\"httpProxyPort\\\": 8080,\\n      \\\"socksProxyPort\\\": 8081\\n    }\\n  }\\n}\\n```\\n\\n## Complete Configuration Example\\n\\n```json\\n{\\n  \\\"sandbox\\\": {\\n    \\\"enabled\\\": true,\\n    \\\"autoAllowBashIfSandboxed\\\": true,\\n    \\\"excludedCommands\\\": [\\\"docker\\\"],\\n    \\\"allowUnsandboxedCommands\\\": false,\\n    \\\"network\\\": {\\n      \\\"allowedDomains\\\": [\\\"github.com\\\", \\\"*.npmjs.org\\\", \\\"registry.yarnpkg.com\\\"],\\n      \\\"allowUnixSockets\\\": [\\\"/var/run/docker.sock\\\"],\\n      \\\"allowLocalBinding\\\": true\\n    }\\n  },\\n  \\\"permissions\\\": {\\n    \\\"deny\\\": [\\n      \\\"Read(.envrc)\\\",\\n      \\\"Read(~/.aws/**)\\\"\\n    ]\\n  }\\n}\\n```\\n\\n## For CI/Non-Interactive Use\\n\\nTo enable sandboxing programmatically:\\n\\n1. **Set via environment** (if using SDK mode):\\n   - Configure `settings.json` in `.claude/` directory\\n   - Pass via `CLAUDE_CONFIG_DIR` environment variable\\n\\n2. **CLI approach**:\\n   ```bash\\n   # Settings apply to all sessions reading from this config\\n   export CLAUDE_CONFIG_DIR=/path/to/config\\n   claude-code [command]\\n   ```\\n\\n3. **Managed settings** (for enterprise/CI):\\n   - Place `managed-settings.json` in system directories\\n   - macOS: `/Library/Application Support/ClaudeCode/`\\n   - Linux/WSL: `/etc/claude-code/`\\n   - Windows: `C:\\\\Program Files\\\\ClaudeCode\\\\`\\n\\n## Important Notes\\n\\n- **Filesystem/network restrictions use permission rules**, not sandbox settings alone\\n- **`allowUnsandboxedCommands: false`** completely disables the `dangerouslyDisableSandbox` escape hatch (useful for strict enterprise policies)\\n- **Linux/WSL**: Use `enableWeakerNestedSandbox: true` for unprivileged Docker environments (reduces security)\\n- **Managed settings** can enforce sandboxing organization-wide and prevent users from disabling it\"}]},\"uuid\":\"3e14f39c-8816-49b3-9535-e2bc72715e3b\",\"timestamp\":\"2026-02-26T01:17:50.360Z\",\"toolUseResult\":{\"bytes\":116294,\"code\":200,\"codeText\":\"OK\",\"result\":\"# Sandbox Settings in Claude Code\\n\\n## Overview\\nSandboxing isolates bash commands from your filesystem and network. It's available on **macOS, Linux, and WSL2**.\\n\\n## Key Settings\\n\\n### Enable Sandboxing\\n\\nIn `settings.json`:\\n\\n```json\\n{\\n  \\\"sandbox\\\": {\\n    \\\"enabled\\\": true,\\n    \\\"autoAllowBashIfSandboxed\\\": true\\n  }\\n}\\n```\\n\\n**Default**: `false` (disabled)\\n\\n## What the Sandbox Restricts\\n\\nThe sandbox provides **filesystem and network isolation**:\\n\\n- **Filesystem**: Controlled via `Read` and `Edit` permission rules\\n- **Network**: Controlled via `WebFetch` permission rules and network-specific settings\\n\\n**Important**: Sandboxing does NOT automatically restrict access. You must configure permissions separately.\\n\\n## Core Sandbox Settings\\n\\n| Setting | Description | Example |\\n|---------|-------------|---------|\\n| `enabled` | Enable bash sandboxing | `true` |\\n| `autoAllowBashIfSandboxed` | Auto-approve bash when sandboxed (default: `true`) | `true` |\\n| `excludedCommands` | Commands that run OUTSIDE sandbox | `[\\\"git\\\", \\\"docker\\\"]` |\\n| `allowUnsandboxedCommands` | Allow `dangerouslyDisableSandbox` parameter (default: `true`) | `false` |\\n\\n## Network Configuration\\n\\n```json\\n{\\n  \\\"sandbox\\\": {\\n    \\\"network\\\": {\\n      \\\"allowedDomains\\\": [\\\"github.com\\\", \\\"*.npmjs.org\\\"],\\n      \\\"allowUnixSockets\\\": [\\\"~/.ssh/agent-socket\\\"],\\n      \\\"allowAllUnixSockets\\\": false,\\n      \\\"allowLocalBinding\\\": false,\\n      \\\"allowManagedDomainsOnly\\\": false,\\n      \\\"httpProxyPort\\\": 8080,\\n      \\\"socksProxyPort\\\": 8081\\n