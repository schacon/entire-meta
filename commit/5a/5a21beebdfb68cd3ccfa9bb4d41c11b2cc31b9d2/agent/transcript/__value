leClaudeCodePostTodoFromReader(os.Stdin)\\n    27→}\\n    28→\\n    29→// handleClaudeCodePostTodoFromReader is the testable version that accepts an io.Reader.\\n    30→func handleClaudeCodePostTodoFromReader(reader io.Reader) error {\\n    31→\\tinput, err := parseSubagentCheckpointHookInput(reader)\\n    32→\\tif err != nil {\\n    33→\\t\\treturn fmt.Errorf(\\\"failed to parse PostToolUse[TodoWrite] input: %w\\\", err)\\n    34→\\t}\\n    35→\\n    36→\\t// Get agent for logging context\\n    37→\\tag, err := GetCurrentHookAgent()\\n    38→\\tif err != nil {\\n    39→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n    40→\\t}\\n    41→\\n    42→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"hooks\\\"), ag.Name())\\n    43→\\tlogging.Info(logCtx, \\\"post-todo\\\",\\n    44→\\t\\tslog.String(\\\"hook\\\", \\\"post-todo\\\"),\\n    45→\\t\\tslog.String(\\\"hook_type\\\", \\\"subagent\\\"),\\n    46→\\t\\tslog.String(\\\"model_session_id\\\", input.SessionID),\\n    47→\\t\\tslog.String(\\\"transcript_path\\\", input.TranscriptPath),\\n    48→\\t\\tslog.String(\\\"tool_use_id\\\", input.ToolUseID),\\n    49→\\t)\\n    50→\\n    51→\\t// Check if we're in a subagent context by looking for an active pre-task file\\n    52→\\ttaskToolUseID, found := FindActivePreTaskFile()\\n    53→\\tif !found {\\n    54→\\t\\t// Not in subagent context - this is a main agent TodoWrite, skip\\n    55→\\t\\treturn nil\\n    56→\\t}\\n    57→\\n    58→\\t// Skip on default branch to avoid polluting main/master history\\n    59→\\tif skip, branchName := ShouldSkipOnDefaultBranch(); skip {\\n    60→\\t\\tfmt.Fprintf(os.Stderr, \\\"Entire: skipping incremental checkpoint on branch '%s'\\\\n\\\", branchName)\\n    61→\\t\\treturn nil\\n    62→\\t}\\n    63→\\n    64→\\t// Detect file changes since last checkpoint\\n    65→\\tchanges, err := DetectFileChanges(nil)\\n    66→\\tif err != nil {\\n    67→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: fa