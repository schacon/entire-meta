\\tcount++\\n   140→\\t}\\n   141→\\tif !hookCommandExists(sessionEnd, sessionEndCmd) {\\n   142→\\t\\tsessionEnd = addHookToMatcher(sessionEnd, \\\"\\\", sessionEndCmd)\\n   143→\\t\\tcount++\\n   144→\\t}\\n   145→\\tif !hookCommandExists(stop, stopCmd) {\\n   146→\\t\\tstop = addHookToMatcher(stop, \\\"\\\", stopCmd)\\n   147→\\t\\tcount++\\n   148→\\t}\\n   149→\\tif !hookCommandExists(userPromptSubmit, userPromptSubmitCmd) {\\n   150→\\t\\tuserPromptSubmit = addHookToMatcher(userPromptSubmit, \\\"\\\", userPromptSubmitCmd)\\n   151→\\t\\tcount++\\n   152→\\t}\\n   153→\\tif !hookCommandExistsWithMatcher(preToolUse, \\\"Task\\\", preTaskCmd) {\\n   154→\\t\\tpreToolUse = addHookToMatcher(preToolUse, \\\"Task\\\", preTaskCmd)\\n   155→\\t\\tcount++\\n   156→\\t}\\n   157→\\tif !hookCommandExistsWithMatcher(postToolUse, \\\"Task\\\", postTaskCmd) {\\n   158→\\t\\tpostToolUse = addHookToMatcher(postToolUse, \\\"Task\\\", postTaskCmd)\\n   159→\\t\\tcount++\\n   160→\\t}\\n   161→\\tif !hookCommandExistsWithMatcher(postToolUse, \\\"TodoWrite\\\", postTodoCmd) {\\n   162→\\t\\tpostToolUse = addHookToMatcher(postToolUse, \\\"TodoWrite\\\", postTodoCmd)\\n   163→\\t\\tcount++\\n   164→\\t}\\n   165→\\n   166→\\t// Add permissions.deny rule if not present\\n   167→\\tpermissionsChanged := false\\n   168→\\tvar denyRules []string\\n   169→\\tif denyRaw, ok := rawPermissions[\\\"deny\\\"]; ok {\\n   170→\\t\\tif err := json.Unmarshal(denyRaw, &denyRules); err != nil {\\n   171→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse permissions.deny in settings.json: %w\\\", err)\\n   172→\\t\\t}\\n   173→\\t}\\n   174→\\tif !slices.Contains(denyRules, metadataDenyRule) {\\n   175→\\t\\tdenyRules = append(denyRules, metadataDenyRule)\\n   176→\\t\\tdenyJSON, err := json.Marshal(denyRules)\\n   177→\\t\\tif err != nil {\\n   178→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal permissions.deny: %w\\\", err)\\n   179→\\t\\t}\\n   180→\\t\\trawPermissions[\\\"deny\\\"] = denyJSO