→// This nil-vs-empty distinction lets DetectFileChanges know whether to skip new-file detection.\\n    51→// When the receiver is non-nil but UntrackedFiles is nil (e.g., old state files deserialized with\\n    52→// \\\"untracked_files\\\": null), returns an empty non-nil slice so that all current untracked files\\n    53→// are correctly treated as new.\\n    54→func (s *PrePromptState) PreUntrackedFiles() []string {\\n    55→\\tif s == nil {\\n    56→\\t\\treturn nil\\n    57→\\t}\\n    58→\\tif s.UntrackedFiles == nil {\\n    59→\\t\\treturn []string{}\\n    60→\\t}\\n    61→\\treturn s.UntrackedFiles\\n    62→}\\n    63→\\n    64→// normalizePrePromptState migrates deprecated fields after loading from JSON.\\n    65→func (s *PrePromptState) normalizePrePromptState() {\\n    66→\\t// Migrate the oldest field to the intermediate field first\\n    67→\\tif s.StepTranscriptStart == 0 && s.LastTranscriptLineCount > 0 {\\n    68→\\t\\ts.StepTranscriptStart = s.LastTranscriptLineCount\\n    69→\\t}\\n    70→\\ts.LastTranscriptLineCount = 0\\n    71→\\n    72→\\t// Migrate all deprecated fields to the unified TranscriptOffset\\n    73→\\tif s.TranscriptOffset == 0 {\\n    74→\\t\\tif s.StepTranscriptStart > 0 {\\n    75→\\t\\t\\ts.TranscriptOffset = s.StepTranscriptStart\\n    76→\\t\\t} else if s.StartMessageIndex > 0 {\\n    77→\\t\\t\\ts.TranscriptOffset = s.StartMessageIndex\\n    78→\\t\\t}\\n    79→\\t}\\n    80→\\ts.StepTranscriptStart = 0\\n    81→\\ts.StartMessageIndex = 0\\n    82→}\\n    83→\\n    84→// CapturePrePromptState captures current untracked files and transcript position before a prompt\\n    85→// and saves them to a state file.\\n    86→//\\n    87→// The agent parameter is used to determine the transcript position via TranscriptAnalyzer.\\n    88→// If the agent does not implement TranscriptAnalyzer, the transcript offset will be 0.\\n    89→// The sessionRef parameter is optional — if empty, transcript position won't be captured.\\n    90→//\\