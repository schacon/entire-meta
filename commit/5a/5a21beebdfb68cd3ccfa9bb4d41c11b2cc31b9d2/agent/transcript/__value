\t\\\"testing\\\"\\n    16→\\t\\\"time\\\"\\n    17→\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n    22→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    23→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n    25→\\n    26→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    27→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    28→\\t\\\"github.com/go-git/go-git/v5/plumbing/format/config\\\"\\n    29→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    30→)\\n    31→\\n    32→// testBinaryPath holds the path to the CLI binary built once in TestMain.\\n    33→// All tests share this binary to avoid repeated builds.\\n    34→var testBinaryPath string\\n    35→\\n    36→// getTestBinary returns the path to the shared test binary.\\n    37→// It panics if TestMain hasn't run (testBinaryPath is empty).\\n    38→func getTestBinary() string {\\n    39→\\tif testBinaryPath == \\\"\\\" {\\n    40→\\t\\tpanic(\\\"testBinaryPath not set - TestMain must run before tests\\\")\\n    41→\\t}\\n    42→\\treturn testBinaryPath\\n    43→}\\n    44→\\n    45→// TestEnv manages an isolated test environment for integration tests.\\n    46→type TestEnv struct {\\n    47→\\tT                  *testing.T\\n    48→\\tRepoDir            string\\n    49→\\tClaudeProjectDir   string\\n    50→\\tGeminiProjectDir   string\\n    51→\\tOpenCodeProjectDir string\\n    52→\\tSessionCounter     int\\n    53→}\\n    54→\\n    55→// NewTestEnv creates a new isolated test environment.\\n    56→// It creates temp directories for the git repo and agent project files.\\n    57→// Note: Does NOT change working directory to allow parallel test execution.\\n    58→// Note: Does NOT use t.Setenv to allow parallel test execution - CLI commands\\n    59→// receive the env var via cmd.Env instead.\\n    60→func NewTestEnv(t *testing.T) *TestEnv {\\n    61→\\tt.Helper()\\n    62→\\n    63→\\t// Resolve symlinks on macOS where /var -> /private/var\\n    64→\\t// This ensures the CLI subprocess and test use consistent paths\\n    65→\\trepoDir := t.TempDir()\\n    66→\\tif resolved, err := filepath.EvalSymlinks(repoDir); err == nil {\\n    67→\\t\\trepoDir = resolved\\n    68→\\t}\\n    69→\\tclaudeProjectDir := t.TempDir()\\n    70→\\tif resolved, err := filepath.EvalSymlinks(claudeProjectDir); err == nil {\\n    71→\\t\\tclaudeProjectDir = resolved\\n    72→\\t}\\n    73→\\tgeminiProjectDir := t.TempDir()\\n    74→\\tif resolved, err := filepath.EvalSymlinks(geminiProjectDir); err == nil {\\n    75→\\t\\tgeminiProjectDir = resolved\\n    76→\\t}\\n    77→\\topenCodeProjectDir := t.TempDir()\\n    78→\\tif resolved, err := filepath.EvalSymlinks(openCodeProjectDir); err == nil {\\n    79→\\t\\topenCodeProjectDir = resolved\\n    80→\\t}\\n    81→\\n    82→\\tenv := &TestEnv{\\n    83→\\t\\tT:                  t,\\n    84→\\t\\tRepoDir:            repoDir,\\n    85→\\t\\tClaudeProjectDir:   claudeProjectDir,\\n    86→\\t\\tGeminiProjectDir:   geminiProjectDir,\\n    87→\\t\\tOpenCodeProjectDir: openCodeProjectDir,\\n    88→\\t}\\n    89→\\n    90→\\t// Note: Don't use t.Setenv here - it's incompatible with t.Parallel()\\n    91→\\t// CLI commands receive ENTIRE_TEST_*_PROJECT_DIR via cmd.Env instead\\n    92→\\n    93→\\treturn env\\n    94→}\\n    95→\\n    96→// Cleanup is a no-op retained for backwards compatibility.\\n    97→//\\n    98→// Previously this method restored the working directory after NewTestEnv changed it.\\n    99→// With the refactor to remove os.Chdir from NewTestEnv:\\n   100→// - Temp directories are now cleaned up automatically by t.TempDir()\\n   101→// - Working directory is never changed, so no restoration is needed\\n   102→//\\n   103→// This method is kept to avoid breaking existing tests that call defer env.Cleanup().\\n   104→// New tests should not call this method as it serves no purpose.\\n   105→//\\n   106→// Deprecated: This method is a no-op and will be removed in a future version.\\n   107→func (env *TestEnv) Cleanup() {\\n   108→\\t// No-op - temp dirs are cleaned up by t.TempDir()\\n   109→}\\n   110→\\n   111→// cliEnv returns the environment variables for CLI execution.\\n   112→// Includes Claude, Gemini, and OpenCode project dirs so tests work for any agent.\\n   113→func (env *TestEnv) cliEnv() []string {\\n   114→\\treturn append(os.Environ(),\\n   115→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+env.ClaudeProjectDir,\\n   116→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+env.GeminiProjectDir,\\n   117→\\t\\t\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR=\\\"+env.OpenCodeProjectDir,\\n   118→\\t\\t\\\"ENTIRE_TEST_TTY=0\\\", // Prevent interactive prompts from blocking in tests\\n   119→\\t)\\n   120→}\\n   121→\\n   122→// RunCLI runs the entire CLI with the given arguments and returns stdout.\\n   123→func (env *TestEnv) RunCLI(args ...string) string {\\n   124→\\tenv.T.Helper()\\n   125→\\toutput, err := env.RunCLIWithError(args...)\\n   126→\\tif err != nil {\\n   127→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   128→\\t}\\n   129→\\treturn output\\n   130→}\\n   131→\\n   132→// RunCLIWithError runs the entire CLI and returns output and error.\\n   133→func (env *TestEnv) RunCLIWithError(args ...string) (string, error) {\\n   134→\\tenv.T.Helper()\\n   135→\\n   136→\\t// Run CLI using the shared binary\\n   137→\\tcmd := exec.Command(getTestBinary(), args...)\\n   138→\\tcmd.Dir = env.RepoDir\\n   139→\\tcmd.Env = env.cliEnv()\\n   140→\\n   141→\\toutput, err := cmd.CombinedOutput()\\n   142→\\treturn string(output), err\\n   143→}\\n   144→\\n   145→// RunCLIWithStdin runs the CLI with stdin input.\\n   146→func (env *TestEnv) RunCLIWithStdin(stdin string, args ...string) string {\\n   147→\\tenv.T.Helper()\\n   148→\\n   149→\\t// Run CLI with stdin using the shared binary\\n   150→\\tcmd := exec.Command(getTestBinary(), args...)\\n   151→\\tcmd.Dir = env.RepoDir\\n   152→\\tcmd.Env = env.cliEnv()\\n   153→\\tcmd.Stdin = strings.NewReader(stdin)\\n   154→\\n   155→\\toutput, err := cmd.CombinedOutput()\\n   156→\\tif err != nil {\\n   157→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   158→\\t}\\n   159→\\treturn string(output)\\n   160→}\\n   161→\\n   162→// NewRepoEnv creates a TestEnv with an initialized git repo and Entire.\\n   163→// This is a convenience factory for tests that need a basic repo setup.\\n   164→func NewRepoEnv(t *testing.T, strategy string) *TestEnv {\\n   165→\\tt.Helper()\\n   166→\\tenv := NewTestEnv(t)\\n   167→\\tenv.InitRepo()\\n   168→\\tenv.InitEntire(strategy)\\n   169→\\treturn env\\n   170→}\\n   171→\\n   172→// NewRepoWithCommit creates a TestEnv with a git repo, Entire, and an initial commit.\\n   173→// The initial commit contains a README.md and .gitignore (excluding .entire/).\\n   174→func NewRepoWithCommit(t *testing.T, strategy string) *TestEnv {\\n   175→\\tt.Helper()\\n   176→\\tenv := NewRepoEnv(t, strategy)\\n   177→\\tenv.WriteFile(\\\".gitignore\\\", \\\".entire/\\\\n\\\")\\n   178→\\tenv.WriteFile(\\\"README.md\\\", \\\"# Test Repository\\\")\\n   179→\\tenv.GitAdd(\\\".gitignore\\\")\\n   180→\\tenv.GitAdd(\\\"README.md\\\")\\n   181→\\tenv.GitCommit(\\\"Initial commit\\\")\\n   182→\\treturn env\\n   183→}\\n   184→\\n   185→// NewFeatureBranchEnv creates a TestEnv ready for session testing.\\n   186→// It initializes the repo, creates an initial commit on main,\\n   187→// and checks out a feature branch. This is the most common setup\\n   188→// for session and rewind tests since Entire tracking skips main/master.\\n   189→func NewFeatureBranchEnv(t *testing.T, strategyName string) *TestEnv {\\n   190→\\tt.Helper()\\n   191→\\tenv := NewRepoWithCommit(t, strategyName)\\n   192→\\tenv.GitCheckoutNewBranch(\\\"feature/test-branch\\\")\\n   193→\\treturn env\\n   194→}\\n   195→\\n   196→// AllStrategies returns all strategy names for parameterized tests.\\n   197→func AllStrategies() []string {\\n   198→\\treturn []string{\\n   199→\\t\\tstrategy.StrategyNameAutoCommit,\\n   200→\\t\\tstrategy.StrategyNameManualCommit,\\n   201→\\t}\\n   202→}\\n   203→\\n   204→// RunForAllStrategies runs a test function for each strategy in parallel.\\n   205→// This reduces boilerplate for tests that need to verify behavior across all strategies.\\n   206→// Each subtest gets its own TestEnv with a feature branch ready for testing.\\n   207→func RunForAllStrategies(t *testing.T, testFn func(t *testing.T, env *TestEnv, strategyName string)) {\\n   208→\\tt.Helper()\\n   209→\\tfor _, strat := range AllStrategies() {\\n   210→\\t\\tstrat := strat // capture for parallel\\n   211→\\t\\tt.Run(strat, func(t *testing.T) {\\n   212→\\t\\t\\tt.Parallel()\\n   213→\\t\\t\\tenv := NewFeatureBranchEnv(t, strat)\\n   214→\\t\\t\\ttestFn(t, env, strat)\\n   215→\\t\\t})\\n   216→\\t}\\n   217→}\\n   218→\\n   219→// RunForAllStrategiesWithRepoEnv runs a test function for each strategy in parallel,\\n   220→// using NewRepoWithCommit instead of NewFeatureBranchEnv. Use this for tests\\n   221→// that need to test behavior on the main branch.\\n   222→func RunForAllStrategiesWithRepoEnv(t *testing.T, testFn func(t *testing.T, env *TestEnv, strategyName string)) {\\n   223→\\tt.Helper()\\n   224→\\tfor _, strat := range AllStrategies() {\\n   225→\\t\\tstrat := strat // capture for parallel\\n   226→\\t\\tt.Run(strat, func(t *testing.T) {\\n   227→\\t\\t\\tt.Parallel()\\n   228→\\t\\t\\tenv := NewRepoWithCommit(t, strat)\\n   229→\\t\\t\\ttestFn(t, env, strat)\\n   230→\\t\\t})\\n   231→\\t}\\n   232→}\\n   233→\\n   234→// RunForAllStrategiesWithBasicEnv runs a test function for each strategy in parallel,\\n   235→// using NewRepoEnv (git repo + entire init, no commits). Use this for tests\\n   236→// that need to verify basic initialization behavior.\\n   237→func RunForAllStrategiesWithBasicEnv(t *testing.T, testFn func(t *testing.T, env *TestEnv, strategyName string)) {\\n   238→\\tt.Helper()\\n   239→\\tfor _, strat := range AllStrategies() {\\n   240→\\t\\tstrat := strat // capture for parallel\\n   241→\\t\\tt.Run(strat, func(t *testing.T) {\\n   242→\\t\\t\\tt.Parallel()\\n   243→\\t\\t\\tenv := NewRepoEnv(t, strat)\\n   244→\\t\\t\\ttestFn(t, env, strat)\\n   245→\\t\\t})\\n   246→\\t}\\n   247→}\\n   248→\\n   249→// RunForStrategiesSequential runs a test function for specific strategies sequentially.\\n   250→// Use this for tests that cannot be parallelized (e.g., tests using os.Chdir).\\n   251→// The strategies parameter allows testing a subset of strategies.\\n   252→func RunForStrategiesSequential(t *testing.T, strategies []string, testFn func(t *testing.T, strategyName string)) {\\n   253→\\tt.Helper()\\n   254→\\tfor _, strat := range strategies {\\n   255→\\t\\tt.Run(strat, func(t *testing.T) {\\n   256→\\t\\t\\ttestFn(t, strat)\\n   257→\\t\\t})\\n   258→\\t}\\n   259→}\\n   260→\\n   261→// InitRepo initializes a git repository in the test environment.\\n   262→func (env *TestEnv) InitRepo() {\\n   263→\\tenv.T.Helper()\\n   264→\\n   265→\\trepo, err := git.PlainInit(env.RepoDir, false)\\n   266→\\tif err != nil {\\n   267→\\t\\tenv.T.Fatalf(\\\"failed to init git repo: %v\\\", err)\\n   268→\\t}\\n   269→\\n   270→\\t// Configure git user for commits\\n   271→\\tcfg, err := repo.Config()\\n   272→\\tif err != nil {\\n   273→\\t\\tenv.T.Fatalf(\\\"failed to get repo config: %v\\\", err)\\n   274→\\t}\\n   275→\\tcfg.User.Name = \\\"Test User\\\"\\n   276→\\tcfg.User.Email = \\\"test@example.com\\\"\\n   277→\\n   278→\\t// Disable GPG signing for test commits (prevents failures if user has commit.gpgsign=true globally)\\n   279→\\tif cfg.Raw == nil {\\n   280→\\t\\tcfg.Raw = config.New()\\n   281→\\t}\\n   282→\\tcfg.Raw.Section(\\\"commit\\\").SetOption(\\\"gpgsign\\\", \\\"false\\\")\\n   283→\\n   284→\\tif err := repo.SetConfig(cfg); err != nil {\\n   285→\\t\\tenv.T.Fatalf(\\\"failed to set repo config: %v\\\", err)\\n   286→\\t}\\n   287→}\\n   288→\\n   289→// InitEntire initializes the .entire directory with the specified strategy.\\n   290→func (env *TestEnv) InitEntire(strategyName string) {\\n   291→\\tenv.InitEntireWithOptions(strategyName, nil)\\n   292→}\\n   293→\\n   294→// InitEntireWithOptions initializes the .entire directory with the specified strategy and options.\\n   295→func (env *TestEnv) InitEntireWithOptions(strategyName string, strategyOptions map[string]any) {\\n   296→\\tenv.T.Helper()\\n   297→\\tenv.initEntireInternal(strategyName, strategyOptions)\\n   298→}\\n   299→\\n   300→// InitEntireWithAgent initializes an Entire test environment with a specific agent.\\n   301→// The agent name is for test documentation only — the CLI resolves the agent from\\n   302→// hook commands and checkpoint metadata, not from settings.json.\\n   303→func (env *TestEnv) InitEntireWithAgent(strategyName string, _ agent.AgentName) {\\n   304→\\tenv.T.Helper()\\n   305→\\tenv.initEntireInternal(strategyName, nil)\\n   306→}\\n   307→\\n   308→// InitEntireWithAgentAndOptions initializes Entire with the specified strategy, agent, and options.\\n   309→func (env *TestEnv) InitEntireWithAgentAndOptions(strategyName string, _ agent.AgentName, strategyOptions map[string]any) {\\n   310→\\tenv.T.Helper()\\n   311→\\tenv.initEntireInternal(strategyName, strategyOptions)\\n   312→}\\n   313→\\n   314→// initEntireInternal is the common implementation for InitEntire variants.\\n   315→func (env *TestEnv) initEntireInternal(strategyName string, strategyOptions map[string]any) {\\n   316→\\tenv.T.Helper()\\n   317→\\n   318→\\t// Create .entire directory structure\\n   319→\\tentireDir := filepath.Join(env.RepoDir, \\\".entire\\\")\\n   320→\\tif err := os.MkdirAll(entireDir, 0o755); err != nil {\\n   321→\\t\\tenv.T.Fatalf(\\\"failed to create .entire directory: %v\\\", err)\\n   322→\\t}\\n   323→\\n   324→\\t// Create tmp directory\\n   325→\\ttmpDir := filepath.Join(entireDir, \\\"tmp\\\")\\n   326→\\tif err := os.MkdirAll(tmpDir, 0o755); err != nil {\\n   327→\\t\\tenv.T.Fatalf(\\\"failed to create .entire/tmp directory: %v\\\", err)\\n   328→\\t}\\n   329→\\n   330→\\t// Write settings.json\\n   331→\\t// Note: The agent name is NOT stored in settings.json — the CLI determines\\n   332→\\t// the agent from installed hooks (detect presence) or checkpoint metadata.\\n   333→\\t// The settings parser uses DisallowUnknownFields(), so only recognized fields are allowed.\\n   334→\\tsettings := map[string]any{\\n   335→\\t\\t\\\"strategy\\\":  strategyName,\\n   336→\\t\\t\\\"local_dev\\\": true, // Note: git-triggered hooks won't work (path is relative); tests call hooks via getTestBinary() instead\\n   337→\\t}\\n   338→\\tif strategyOptions != nil {\\n   339→\\t\\tsettings[\\\"strategy_options\\\"] = strategyOptions\\n   340→\\t}\\n   341→\\tdata, err := jsonutil.MarshalIndentWithNewline(settings, \\\"\\\", \\\"  \\\")\\n   342→\\tif err != nil {\\n   343→\\t\\tenv.T.Fatalf(\\\"failed to marshal settings: %v\\\", err)\\n   344→\\t}\\n   345→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   346→\\tif err := os.WriteFile(settingsPath, data, 0o644); err != nil {\\n   347→\\t\\tenv.T.Fatalf(\\\"failed to write %s: %v\\\", paths.SettingsFileName, err)\\n   348→\\t}\\n   349→}\\n   350→\\n   351→// WriteFile creates a file with the given content in the test repo.\\n   352→// It creates parent directories as needed.\\n   353→func (env *TestEnv) WriteFile(path, content string) {\\n   354→\\tenv.T.Helper()\\n   355→\\n   356→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   357→\\n   358→\\t// Create parent directories\\n   359→\\tdir := filepath.Dir(fullPath)\\n   360→\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   361→\\t\\tenv.T.Fatalf(\\\"failed to create directory %s: %v\\\", dir, err)\\n   362→\\t}\\n   363→\\n   364→\\tif err := os.WriteFile(fullPath, []byte(content), 0o644); err != nil {\\n   365→\\t\\tenv.T.Fatalf(\\\"failed to write file %s: %v\\\", path, err)\\n   366→\\t}\\n   367→}\\n   368→\\n   369→// ReadFile reads a file from the test repo.\\n   370→func (env *TestEnv) ReadFile(path string) string {\\n   371→\\tenv.T.Helper()\\n   372→\\n   373→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   374→\\tdata, err := os.ReadFile(fullPath)\\n   375→\\tif err != nil {\\n   376→\\t\\tenv.T.Fatalf(\\\"failed to read file %s: %v\\\", path, err)\\n   377→\\t}\\n   378→\\treturn string(data)\\n   379→}\\n   380→\\n   381→// ReadFileAbsolute reads a file using an absolute path.\\n   382→func (env *TestEnv) ReadFileAbsolute(path string) string {\\n   383→\\tenv.T.Helper()\\n   384→\\n   385→\\tdata, err := os.ReadFile(path)\\n   386→\\tif err != nil {\\n   387→\\t\\tenv.T.Fatalf(\\\"failed to read file %s: %v\\\", path, err)\\n   388→\\t}\\n   389→\\treturn string(data)\\n   390→}\\n   391→\\n   392→// FileExists checks if a file exists in the test repo.\\n   393→func (env *TestEnv) FileExists(path string) bool {\\n   394→\\tenv.T.Helper()\\n   395→\\n   396→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   397→\\t_, err := os.Stat(fullPath)\\n   398→\\treturn err == nil\\n   399→}\\n   400→\\n   401→// GitAdd stages files for commit.\\n   402→func (env *TestEnv) GitAdd(paths ...string) {\\n   403→\\tenv.T.Helper()\\n   404→\\n   405→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   406→\\tif err != nil {\\n   407→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   408→\\t}\\n   409→\\n   410→\\tworktree, err := repo.Worktree()\\n   411→\\tif err != nil {\\n   412→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   4