/ Used for identifier-based transcript scoping (UUID for Claude, message ID for Gemini).\\n   123→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"`\\n   124→\\n   125→\\t// TranscriptPath is the path to the live transcript file (for mid-session commit detection)\\n   126→\\tTranscriptPath string `json:\\\"transcript_path,omitempty\\\"`\\n   127→\\n   128→\\t// FirstPrompt is the first user prompt that started this session (truncated for display)\\n   129→\\tFirstPrompt string `json:\\\"first_prompt,omitempty\\\"`\\n   130→\\n   131→\\t// PromptAttributions tracks user and agent line changes at each prompt start.\\n   132→\\t// This enables accurate attribution by capturing user edits between checkpoints.\\n   133→\\tPromptAttributions []PromptAttribution `json:\\\"prompt_attributions,omitempty\\\"`\\n   134→\\n   135→\\t// PendingPromptAttribution holds attribution calculated at prompt start (before agent runs).\\n   136→\\t// This is moved to PromptAttributions when SaveStep is called.\\n   137→\\tPendingPromptAttribution *PromptAttribution `json:\\\"pending_prompt_attribution,omitempty\\\"`\\n   138→}\\n   139→\\n   140→// PromptAttribution captures line-level attribution data at the start of each prompt.\\n   141→// By recording what changed since the last checkpoint BEFORE the agent works,\\n   142→// we can accurately separate user edits from agent contributions.\\n   143→type PromptAttribution struct {\\n   144→\\t// CheckpointNumber is which checkpoint this was recorded before (1-indexed)\\n   145→\\tCheckpointNumber int `json:\\\"checkpoint_number\\\"`\\n   146→\\n   147→\\t// UserLinesAdded is lines added by user since the last checkpoint\\n   148→\\tUserLinesAdded int `json:\\\"user_lines_added\\\"`\\n   149→\\n   150→\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   151→\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   152→\\n   153→\\t// AgentLinesAdded is total agent l