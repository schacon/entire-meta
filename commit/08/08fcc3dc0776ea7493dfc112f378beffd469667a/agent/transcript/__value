 hookPerfRepoURL = \\\"https://github.com/entireio/cli.git\\\"\\n    28→\\n    29→// TestCommitHookPerformance measures the real overhead of Entire's commit hooks\\n    30→// by comparing a control commit (no Entire) against a commit with hooks active.\\n    31→//\\n    32→// It uses a full-history clone of entireio/cli (single branch) with seeded\\n    33→// branches and packed refs so that go-git operates on a realistic object\\n    34→// database. Each session is generated with a unique base commit (drawn from\\n    35→// real repo history) so that listAllSessionStates scans different shadow\\n    36→// branch names — matching production behavior where sessions span many commits.\\n    37→//\\n    38→// Prerequisites:\\n    39→//   - GitHub access (gh auth login) for cloning the private repo\\n    40→//\\n    41→// Run: go test -v -run TestCommitHookPerformance -tags hookperf -timeout 15m ./cmd/entire/cli/strategy/\\n    42→func TestCommitHookPerformance(t *testing.T) {\\n    43→\\t// Clone once, reuse across scenarios via cheap local clones.\\n    44→\\tcacheDir := cloneSourceRepo(t)\\n    45→\\n    46→\\tscenarios := []struct {\\n    47→\\t\\tname   string\\n    48→\\t\\tended  int\\n    49→\\t\\tidle   int\\n    50→\\t\\tactive int\\n    51→\\t}{\\n    52→\\t\\t{\\\"100sessions\\\", 88, 11, 1},\\n    53→\\t\\t{\\\"200sessions\\\", 176, 22, 2},\\n    54→\\t\\t{\\\"500sessions\\\", 440, 55, 5},\\n    55→\\t}\\n    56→\\n    57→\\ttype result struct {\\n    58→\\t\\tname       string\\n    59→\\t\\ttotal      int\\n    60→\\t\\tcontrol    time.Duration\\n    61→\\t\\tprepare    time.Duration\\n    62→\\t\\tpostCommit time.Duration\\n    63→\\t}\\n    64→\\tresults := make([]result, 0, len(scenarios))\\n    65→\\n    66→\\tfor _, sc := range scenarios {\\n    67→\\t\\tt.Run(sc.name, func(t *testing.T) {\\n    68→\\t\\t\\ttotalSessions := sc.ended + sc.idle + sc.active\\n    69→\\n    70→\\t\\t\\tdir := localClone(t, cacheDir)\\n    71→\\t\\t\\tt.Chdir(dir)\\n    72→\\t\\t\\tpaths.ClearWorktreeRootCache()\\n    73→\\t\\t\\tsession.ClearGitCommonDirCache()\\n    74→\\n    75→\\t\\t\\t// Seed 200 branches + pack refs for realistic ref scanning overhead.\\n    76→\\t\\t\\tseedBranches(t, dir, 200)\\n    77→\\t\\t\\tgitRun(t, dir, \\\"pack-refs\\\", \\\"--all\\\")\\n    78→\\n    79→\\t\\t\\t// --- CONTROL: commit without Entire ---\\n    80→\\t\\t\\tcontrolDur := timeControlCommit(t, dir)\\n    81→\\n    82→\\t\\t\\t// Reset back to pre-commit state so the test commit is identical.\\n    83→\\t\\t\\tgitRun(t, dir, \\\"reset\\\", \\\"HEAD~1\\\")\\n    84→\\t\\t\\tgitRun(t, dir, \\\"add\\\", \\\"perf_control.txt\\\")\\n    85→\\n    86→\\t\\t\\t// --- TEST: commit with Entire hooks ---\\n    87→\\t\\t\\tcreateHookPerfSettings(t, dir)\\n    88→\\n    89→\\t\\t\\t// Collect diverse base commits from real repo history so each\\n    90→\\t\\t\\t// ENDED session has a different shadow branch name.\\n    91→\\t\\t\\tbaseCommits := collectBaseCommits(t, dir, totalSessions)\\n    92→\\t\\t\\tseedHookPerfSessions(t, dir, baseCommits, sc.ended, sc.idle, sc.active)\\n    93→\\n    94→\\t\\t\\t// Simulate TTY path with commit_linking=always.\\n    95→\\t\\t\\tt.Setenv(\\\"ENTIRE_TEST_TTY\\\", \\\"1\\\")\\n    96→\\t\\t\\tpaths.ClearWorktreeRootCache()\\n    97→\\t\\t\\tsession.ClearGitCommonDirCache()\\n    98→\\n    99→\\t\\t\\tcommitMsgFile := filepath.Join(dir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n   100→\\t\\t\\tif err := os.WriteFile(commitMsgFile, []byte(\\\"implement feature\\\\n\\\"), 0o644); err != nil {\\n   101→\\t\\t\\t\\tt.Fatalf(\\\"write commit msg: %v\\\", err)\\n   102→\\t\\t\\t}\\n   103→\\n   104→\\t\\t\\ts1 := &ManualCommitStrategy{}\\n   105→\\t\\t\\tprepStart := time.Now()\\n   106→\\t\\t\\tif err := s1.PrepareCommitMsg(context.Background(), commitMsgFile, \\\"message\\\"); err != nil {\\n   107→\\t\\t\\t\\tt.Fatalf(\\\"PrepareCommitMsg: %v\\\", err)\\n   108→\\t\\t\\t}\\n   109→\\t\\t\\tprepDur := time.Since(prepStart)\\n   110→\\n   111→\\t\\t\\t// Read back commit message; inject trailer if content-aware check skipped it.\\n   112→\\t\\t\\tmsgBytes, err := os.ReadFile(commitMsgFile) //nolint:gosec // test file\\n   113→\\t\\t\\tif err != nil {\\n   114→\\t\\t\\t\\tt.Fatalf(\\\"read commit msg: %v\\\", err)\\n   115→\\t\\t\\t}\\n   116→\\t\\t\\tcommitMsg := string(msgBytes)\\n   117→\\n   118→\\t\\t\\tif _, found := trailers.ParseCheckpoint(commitMsg); !found {\\n   119→\\t\\t\\t\\tcpID, genErr := id.Generate()\\n   120→\\t\\t\\t\\tif genErr != nil {\\n   121→\\t\\t\\t\\t\\tt.Fatalf(\\\"generate checkpoint ID: %v\\\", genErr)\\n   122→\\t\\t\\t\\t}\\n   123→\\t\\t\\t\\tcommitMsg = fmt.Sprintf(\\\"%s\\\\n%s: %s\\\\n\\\",\\n   124→\\t\\t\\t\\t\\tstrings.TrimRight(commitMsg, \\\"\\\\n\\\"),\\n   125→\\t\\t\\t\\t\\ttrailers.CheckpointTrailerKey, cpID)\\n   126→\\t\\t\\t\\tt.Logf(\\\"  Injected trailer (PrepareCommitMsg skipped content-aware check)\\\")\\n   127→\\t\\t\\t}\\n   128→\\n   129→\\t\\t\\tgitRun(t, dir, \\\"commit\\\", \\\"-m\\\", commitMsg)\\n   130→\\n   131→\\t\\t\\t// Time PostCommit.\\n   132→\\t\\t\\tpaths.ClearWorktreeRootCache()\\n   133→\\t\\t\\tsession.ClearGitCommonDirCache()\\n   134→\\n   135→\\t\\t\\ts2 := &ManualCommitStrategy{}\\n   136→\\t\\t\\tpostStart := time.Now()\\n   137→\\t\\t\\tif err := s2.PostCommit(context.Background()); err != nil {\\n   138→\\t\\t\\t\\tt.Fatalf(\\\"PostCommit: %v\\\", err)\\n   139→\\t\\t\\t}\\n   140→\\t\\t\\tpostDur := time.Since(postStart)\\n   141→\\n   142→\\t\\t\\toverhead := (prepDur + postDur) - controlDur\\n   143→\\t\\t\\tif overhead < 0 {\\n   144→\\t\\t\\t\\toverhead = 0\\n   145→\\t\\t\\t}\\n   146→\\n   147→\\t\\t\\tt.Logf(\\\"=== %s ===\\\", sc.name)\\n   148→\\t\\t\\tt.Logf(\\\"  Sessions:         %d (ended=%d, idle=%d, active=%d)\\\", totalSessions, sc.ended, sc.idle, sc.active)\\n   149→\\t\\t\\tt.Logf(\\\"  Base commits:     %d unique\\\", len(baseCommits))\\n   150→\\t\\t\\tt.Logf(\\\"  Control commit:   %s\\\", controlDur.Round(time.Millisecond))\\n   151→\\t\\t\\tt.Logf(\\\"  PrepareCommitMsg: %s\\\", prepDur.Round(time.Millisecond))\\n   152→\\t\\t\\tt.Logf(\\\"  PostCommit:       %s\\\", postDur.Round(time.Millisecond))\\n   153→\\t\\t\\tt.Logf(\\\"  TOTAL HOOKS:      %s\\\", (prepDur + postDur).Round(time.Millisecond))\\n   154→\\t\\t\\tt.Logf(\\\"  OVERHEAD:         %s\\\", overhead.Round(time.Millisecond))\\n   155→\\n   156→\\t\\t\\tresults = append(results, result{\\n   157→\\t\\t\\t\\tname:       sc.name,\\n   158→\\t\\t\\t\\ttotal:      totalSessions,\\n   159→\\t\\t\\t\\tcontrol:    controlDur,\\n   160→\\t\\t\\t\\tprepare:    prepDur,\\n   161→\\t\\t\\t\\tpostCommit: postDur,\\n   162→\\t\\t\\t})\\n   163→\\t\\t})\\n   164→\\t}\\n   165→\\n   166→\\t// Print comparison table.\\n   167→\\tt.Log(\\\"\\\")\\n   168→\\tt.Log(\\\"========== COMMIT HOOK PERFORMANCE ==========\\\")\\n   169→\\tt.Logf(\\\"%-14s | %8s | %10s | %10s | %12s | %12s | %10s\\\",\\n   170→\\t\\t\\\"Scenario\\\", \\\"Sessions\\\", \\\"Control\\\", \\\"Prepare\\\", \\\"PostCommit\\\", \\\"Total+Hooks\\\", \\\"Overhead\\\")\\n   171→\\tt.Log(strings.Repeat(\\\"-\\\", 95))\\n   172→\\tfor _, r := range results {\\n   173→\\t\\ttotal := r.prepare + r.postCommit\\n   174→\\t\\toverhead := total - r.control\\n   175→\\t\\tif overhead < 0 {\\n   176→\\t\\t\\toverhead = 0\\n   177→\\t\\t}\\n   178→\\t\\tt.Logf(\\\"%-14s | %8d | %10s | %10s | %12s | %12s | %10s\\\",\\n   179→\\t\\t\\tr.name,\\n   180→\\t\\t\\tr.total,\\n   181→\\t\\t\\tr.control.Round(time.Millisecond),\\n   182→\\t\\t\\tr.prepare.Round(time.Millisecond),\\n   183→\\t\\t\\tr.postCommit.Round(time.Millisecond),\\n   184→\\t\\t\\ttotal.Round(time.Millisecond),\\n   185→\\t\\t\\toverhead.Round(time.Millisecond),\\n   186→\\t\\t)\\n   187→\\t}\\n   188→}\\n   189→\\n   190→// collectBaseCommits walks the repo's commit history and returns up to `need`\\n   191→// unique commit hashes. These are used as BaseCommit values so each session\\n   192→// references a different shadow branch name — matching production behavior\\n   193→// where sessions span many different commits over time.\\n   194→func collectBaseCommits(t *testing.T, dir string, need int) []string {\\n   195→\\tt.Helper()\\n   196→\\n   197→\\trepo, err := git.PlainOpen(dir)\\n   198→\\tif err != nil {\\n   199→\\t\\tt.Fatalf(\\\"open repo for base commits: %v\\\", err)\\n   200→\\t}\\n   201→\\thead, err := repo.Head()\\n   202→\\tif err != nil {\\n   203→\\t\\tt.Fatalf(\\\"head for base commits: %v\\\", err)\\n   204→\\t}\\n   205→\\n   206→\\tvar commits []string\\n   207→\\titer, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   208→\\tif err != nil {\\n   209→\\t\\tt.Fatalf(\\\"log for base commits: %v\\\", err)\\n   210→\\t}\\n   211→\\tdefer iter.Close()\\n   212→\\n   213→\\terr = iter.ForEach(func(c *object.Commit) error {\\n   214→\\t\\tif len(commits) >= need {\\n   215→\\t\\t\\treturn fmt.Errorf(\\\"done\\\") //nolint:goerr113 // sentinel to stop iteration\\n   216→\\t\\t}\\n   217→\\t\\tcommits = append(commits, c.Hash.String())\\n   218→\\t\\treturn nil\\n   219→\\t})\\n   220→\\t// \\\"done\\\" sentinel is expected; real errors are not.\\n   221→\\tif err != nil && err.Error() != \\\"done\\\" {\\n   222→\\t\\tt.Fatalf(\\\"walk commits: %v\\\", err)\\n   223→\\t}\\n   224→\\n   225→\\tt.Logf(\\\"  Collected %d base commits from history (requested %d)\\\", len(commits), need)\\n   226→\\treturn commits\\n   227→}\\n   228→\\n   229→// timeControlCommit stages a file and times a bare `git commit` with no Entire\\n   230→// hooks/settings present. Returns the wall-clock duration.\\n   231→func timeControlCommit(t *testing.T, dir string) time.Duration {\\n   232→\\tt.Helper()\\n   233→\\n   234→\\tcontrolFile := filepath.Join(dir, \\\"perf_control.txt\\\")\\n   235→\\tif err := os.WriteFile(controlFile, []byte(\\\"control commit content\\\\n\\\"), 0o644); err != nil {\\n   236→\\t\\tt.Fatalf(\\\"write control file: %v\\\", err)\\n   237→\\t}\\n   238→\\tgitRun(t, dir, \\\"add\\\", \\\"perf_control.txt\\\")\\n   239→\\n   240→\\tstart := time.Now()\\n   241→\\tgitRun(t, dir, \\\"commit\\\", \\\"-m\\\", \\\"control commit (no Entire)\\\")\\n   242→\\treturn time.Since(start)\\n   243→}\\n   244→\\n   245→// seedBranches creates N branches pointing at HEAD via go-git to simulate\\n   246→// a repo with many refs (affects ref scanning performance).\\n   247→func seedBranches(t *testing.T, dir string, count int) {\\n   248→\\tt.Helper()\\n   249→\\n   250→\\trepo, err := git.PlainOpen(dir)\\n   251→\\tif err != nil {\\n   252→\\t\\tt.Fatalf(\\\"open repo for branch seeding: %v\\\", err)\\n   253→\\t}\\n   254→\\thead, err := repo.Head()\\n   255→\\tif err != nil {\\n   256→\\t\\tt.Fatalf(\\\"head for branch seeding: %v\\\", err)\\n   257→\\t}\\n   258→\\theadHash := head.Hash()\\n   259→\\n   260→\\tfor i := range count {\\n   261→\\t\\tname := fmt.Sprintf(\\\"feature/perf-branch-%03d\\\", i)\\n   262→\\t\\tref := plumbing.NewHashReference(plumbing.NewBranchReferenceName(name), headHash)\\n   263→\\t\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   264→\\t\\t\\tt.Fatalf(\\\"create branch %s: %v\\\", name, err)\\n   265→\\t\\t}\\n   266→\\t}\\n   267→\\tt.Logf(\\\"  Seeded %d branches\\\", count)\\n   268→}\\n   269→\\n   270→// cloneSourceRepo does a one-time full-history clone of entireio/cli into a temp\\n   271→// directory. Returns the path to use as a local clone source for each scenario.\\n   272→//\\n   273→// Uses --single-branch to limit network transfer to one branch while still\\n   274→// fetching the full commit history and object database. This gives us a\\n   275→// realistic packfile (~50-100MB) instead of a shallow clone's ~900KB, which\\n   276→// matters because go-git object resolution (tree.File, commit.Tree, file.Contents)\\n   277→// performance depends on packfile size and index complexity.\\n   278→func cloneSourceRepo(t *testing.T) string {\\n   279→\\tt.Helper()\\n   280→\\n   281→\\tdir := t.TempDir()\\n   282→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n   283→\\t\\tdir = resolved\\n   284→\\t}\\n   285→\\n   286→\\tt.Logf(\\\"Cloning %s (full history, single branch) ...\\\", hookPerfRepoURL)\\n   287→\\tstart := time.Now()\\n   288→\\n   289→\\t//nolint:gosec // test-only, URL is a constant\\n   290→\\tcmd := exec.Command(\\\"git\\\", \\\"clone\\\", \\\"--single-branch\\\", hookPerfRepoURL, dir)\\n   291→\\tout, err := cmd.CombinedOutput()\\n   292→\\tif err != nil {\\n   293→\\t\\tt.Fatalf(\\\"git clone failed: %v\\\\n%s\\\", err, out)\\n   294→\\t}\\n   295→\\tt.Logf(\\\"Source clone completed in %s\\\", time.Since(start).Round(time.Millisecond))\\n   296→\\n   297→\\treturn dir\\n   298→}\\n   299→\\n   300→// localClone creates a fast local clone from the cached source repo.\\n   301→func localClone(t *testing.T, sourceDir string) string {\\n   302→\\tt.Helper()\\n   303→\\n   304→\\tdir := t.TempDir()\\n   305→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n   306→\\t\\tdir = resolved\\n   307→\\t}\\n   308→\\n   309→\\t//nolint:gosec // test-only, sourceDir is from t.TempDir()\\n   310→\\tcmd := exec.Command(\\\"git\\\", \\\"clone\\\", \\\"--local\\\", sourceDir, dir)\\n   311→\\tout, err := cmd.CombinedOutput()\\n   312→\\tif err != nil {\\n   313→\\t\\tt.Fatalf(\\\"local clone failed: %v\\\\n%s\\\", err, out)\\n   314→\\t}\\n   315→\\n   316→\\treturn dir\\n   317→}\\n   318→\\n   319→// gitRun executes a git command in the given directory and fails the test on error.\\n   320→func gitRun(t *testing.T, dir string, args ...string) {\\n   321→\\tt.Helper()\\n   322→\\t//nolint:gosec // test-only helper\\n   323→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   324→\\tcmd.Dir = dir\\n   325→\\tout, err := cmd.CombinedOutput()\\n   326→\\tif err != nil {\\n   327→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n   328→\\t}\\n   329→}\\n   330→\\n   331→// createHookPerfSettings writes .entire/settings.json with commit_linking=always\\n   332→// so PrepareCommitMsg auto-links without prompting.\\n   333→func createHookPerfSettings(t *testing.T, dir string) {\\n   334→\\tt.Helper()\\n   335→\\tentireDir := filepath.Join(dir, \\\".entire\\\")\\n   336→\\tif err := os.MkdirAll(entireDir, 0o755); err != nil {\\n   337→\\t\\tt.Fatalf(\\\"mkdir .entire: %v\\\", err)\\n   338→\\t}\\n   339→\\tsettings := `{\\\"enabled\\\": true, \\\"strategy\\\": \\\"manual-commit\\\", \\\"commit_linking\\\": \\\"always\\\"}`\\n   340→\\tif err := os.WriteFile(filepath.Join(entireDir, \\\"settings.json\\\"), []byte(settings), 0o644); err != nil {\\n   341→\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n   342→\\t}\\n   343→}\\n   344→\\n   345→// Sample file lists for varied FilesTouched per session (used by IDLE/ACTIVE\\n   346→// which need actual files on disk via seedSessionWithShadowBranch).\\n   347→var perfFileSets = [][]string{\\n   348→\\t{\\\"main.go\\\", \\\"go.mod\\\"},\\n   349→\\t{\\\"cmd/entire/main.go\\\", \\\"cmd/entire/cli/root.go\\\"},\\n   350→\\t{\\\"go.sum\\\", \\\"README.md\\\", \\\"Makefile\\\"},\\n   351→\\t{\\\"cmd/entire/cli/strategy/common.go\\\"},\\n   352→\\t{\\\"cmd/entire/cli/session/state.go\\\", \\\"cmd/entire/cli/session/phase.go\\\"},\\n   353→\\t{\\\"cmd/entire/cli/paths/paths.go\\\", \\\"cmd/entire/cli/paths/worktree.go\\\", \\\"go.mod\\\"},\\n   354→\\t{\\\"cmd/entire/cli/agent/claude.go\\\"},\\n   355→\\t{\\\"docs/architecture/README.md\\\", \\\"CLAUDE.md\\\"},\\n   356→}\\n   357→\\n   358→// perfLargeFileSets provides realistic file path lists matching production\\n   359→// session sizes (30-80 files). Real sessions have 30-350+ files touched.\\n   360→// Each set includes \\\"perf_control.txt\\\" so PrepareCommitMsg's staged-file\\n   361→// overlap detection finds a match between staged files and FilesTouched.\\n   362→var perfLargeFileSets = func() [][]string {\\n   363→\\tdirs := []string{\\n   364→\\t\\t\\\"cmd/entire/cli/strategy\\\",\\n   365→\\t\\t\\\"cmd/entire/cli/session\\\",\\n   366→\\t\\t\\\"cmd/entire/cli/checkpoint\\\",\\n   367→\\t\\t\\\"cmd/entire/cli/agent/claudecode\\\",\\n   368→\\t\\t\\\"cmd/entire/cli/agent/geminicli\\\",\\n   369→\\t\\t\\\"cmd/entire/cli/paths\\\",\\n   370→\\t\\t\\\"cmd/entire/cli/logging\\\",\\n   371→\\t\\t\\\"cmd/entire/cli/settings\\\",\\n   372→\\t\\t\\\"cmd/entire/cli\\\",\\n   373→\\t\\t\\\"docs/architecture\\\",\\n   374→\\t}\\n   375→\\tvar sets [][]string\\n   376→\\tfor setIdx := range 8 {\\n   377→\\t\\tsize := 30 + (setIdx * 7) // 30, 37, 44, 51, 58, 65, 72, 79\\n   378→\\t\\tfiles := []string{\\\"perf_control.txt\\\"}\\n   379→\\t\\tfor i := range size {\\n   380→\\t\\t\\tdir := dirs[i%len(dirs)]\\n   381→\\t\\t\\tsuffix := \\\"\\\"\\n   382→\\t\\t\\tif i%3 == 1 {\\n   383→\\t\\t\\t\\tsuffix = \\\"_test\\\"\\n   384→\\t\\t\\t}\\n   385→\\t\\t\\tfiles = append(files, fmt.Sprintf(\\\"%s/gen_%d%s.go\\\", dir, i, suffix))\\n   386→\\t\\t}\\n   387→\\t\\tsets = append(sets, files)\\n   388→\\t}\\n   389→\\treturn sets\\n   390→}()\\n   391→\\n   392→// Sample prompts for varied FirstPrompt per session.\\n   393→var perfPrompts = []string{\\n   394→\\t\\\"implement the login feature\\\",\\n   395→\\t\\\"fix the bug in checkout flow\\\",\\n   396→\\t\\\"refactor the session management\\\",\\n   397→\\t\\\"add unit tests for the strategy package\\\",\\n   398→\\t\\\"update the documentation for hooks\\\",\\n   399→\\t\\\"optimize the database queries\\\",\\n   400→\\t\\\"add dark mode support\\\",\\n   401→\\t\\\"migrate to the new API version\\\",\\n   402→\\t\\\"fix the memory leak in the worker pool\\\",\\n   403→\\t\\\"add retry logic for failed API calls\\\",\\n   404→\\t\\\"implement webhook support\\\",\\n   405→\\t\\\"clean up unused imports and dead code\\\",\\n   406→}\\n   407→\\n   408→// seedHookPerfSessions creates fully unique session state files.\\n   409→// Each session gets a unique base commit (from repo history), varied FilesTouched,\\n   410→// and unique prompts — avoiding template duplication artifacts.\\n   411→//\\n   412→// Phase distribution matches real-world observations from .git/entire-sessions/:\\n   413→//\\n   414→//\\tENDED sessions (75%): shadow branch ref + data, NO LastCheckpointID.\\n   415→//\\t    These exercise the expensive hot path: ref lookup → commit → tree →\\n   416→//\\t    transcript/overlap check → condensation during PostCommit.\\n   417→//\\tENDED sessions (25%): state file with LastCheckpointID (already committed, cheap).\\n   418→//\\tIDLE sessions:  state file + shadow branch checkpoint via SaveStep.\\n   419→//\\tACTIVE sessions: state file + shadow branch + live transcript file.\\n   420→func seedHookPerfSessions(t *testing.T, dir string, baseCommits []string, ended, idle, active int) {\\n   421→\\tt.Helper()\\n   422→\\n   423→\\tctx := context.Background()\\n   424→\\n   425→\\theadCommit := baseCommits[0] // HEAD is always first\\n   426→\\n   427→\\tworktreeID, err := paths.GetWorktreeID(dir)\\n   428→\\tif err != nil {\\n   429→\\t\\tt.Fatalf(\\\"worktree ID: %v\\\", err)\\n   430→\\t}\\n   431→\\n   432→\\tstateDir := filepath.Join(dir, \\\".git\\\", session.SessionStateDirName)\\n   433→\\tif err := os.MkdirAll(stateDir, 0o755); err != nil {\\n   434→\\t\\tt.Fatalf(\\\"mkdir state dir: %v\\\", err)\\n   435→\\t}\\n   436→\\tstore := session.NewStateStoreWithDir(stateDir)\\n   437→\\n   438→\\tagentTypes := []agent.AgentType{\\n   439→\\t\\tagent.AgentTypeClaudeCode,\\n   440→\\t\\tagent.AgentTypeClaudeCode,\\n   441→\\t\\tagent.AgentTypeClaudeCode,\\n   442→\\t\\tagent.AgentTypeGemini,\\n   443→\\t\\tagent.AgentTypeOpenCode,\\n   444→\\t}\\n   445→\\n   446→\\ts := &ManualCommitStrategy{}\\n   447→\\n   448→\\t// --- Seed ENDED sessions ---\\n   449→\\t// Real-world distribution (from .git/entire-sessions/ analysis):\\n   450→\\t//   ~75% have shadow branches with data but no LastCheckpointID (not yet committed)\\n   451→\\t//   ~25% have LastCheckpointID set and no shadow branch (already committed)\\n   452→\\t//\\n   453→\\t// The 75% exercise the expensive hot path per session:\\n   454→\\t//   listAllSessionStates: packed-refs linear scan to resolve shadow branch ref\\n   455→\\t//   sessionHasNewContent: ref → commit → tree → transcript/overlap check\\n   456→\\t//   PostCommit condensation: write metadata to entire/checkpoints/v1 branch\\n   457→\\tendedWithShadow := ended * 3 / 4\\n   458→\\tendedWithoutShadow := ended - endedWithShadow\\n   459→\\n   460→\\tvar shadowCommitHash plumbing.Hash\\n   461→\\tif endedWithShadow > 0 {\\n   462→\\t\\t// Create one template session via SaveStep to establish a shadow branch\\n   463→\\t\\t// with a commit/tree containing proper transcript data.\\n   464→\\t\\ttemplateID := \\\"perf-ended-0\\\"\\n   465→\\t\\tseedSessionWithShadowBranch(t, s, dir, templateID, session.PhaseEnded, perfFileSets[0])\\n   466→\\n   467→\\t\\t// Get the shadow branch commit hash to create alias refs.\\n   468→\\t\\trepo, openErr := git.PlainOpen(dir)\\n   469→\\t\\tif openErr != nil {\\n   470→\\t\\t\\tt.Fatalf(\\\"open repo for shadow refs: %v\\\", openErr)\\n   471→\\t\\t}\\n   472→\\t\\tshadowName := checkpoint.ShadowBranchNameForCommit(headCommit, worktreeID)\\n   473→\\t\\tref, refErr := repo.Reference(plumbing.NewBranchReferenceName(shadowName), true)\\n   474→\\t\\tif refErr != nil {\\n   475→\\t\\t\\tt.Fatalf(\\\"find template shadow branch %q: %v\\\", shadowName, refErr)\\n   476→\\t\\t}\\n   477→\\t\\tshadowCommitHash = ref.Hash()\\n   478→\\n   479→\\t\\t// Enrich template session with realistic FilesTouched.\\n   480→\\t\\ttState, loadErr := s.loadSessionState(ctx, templateID)\\n   481→\\t\\tif loadErr != nil {\\n   482→\\t\\t\\tt.Fatalf(\\\"load template state: %v\\\", loadErr)\\n   483→\\t\\t}\\n   484→\\t\\ttState.AgentType = agentTypes[0]\\n   485→\\t\\ttState.FirstPrompt = perfPrompts[0]\\n   486→\\t\\ttState.FilesTouched = perfLargeFileSets[0]\\n   487→\\t\\tif saveErr := s.saveSessionState(ctx, tState); saveErr != nil {\\n   488→\\t\\t\\tt.Fatalf(\\\"save template state: %v\\\", saveErr)\\n   489→\\t\\t}\\n   490→\\n   491→\\t\\t// Remaining shadow-branch sessions: create alias refs + state files.\\n   492→\\t\\t// Each gets a unique base commit → unique shadow branch name → different\\n   493→\\t\\t// packed-refs lookup per session (go-git has no ref caching).\\n   494→\\t\\tfor i := 1; i < endedWithShadow; i++ {\\n   495→\\t\\t\\tsessionID := fmt.Sprintf(\\\"perf-ended-%d\\\", i)\\n   496→\\t\\t\\tbaseIdx := (i + 1) % len(baseCommits)\\n   497→\\t\\t\\tbase := baseCommits[baseIdx]\\n   498→\\n   499→\\t\\t\\t// Create shadow branch ref pointing to template's commit.\\n   500→\\t\\t\\t// The hook code resolves this ref, gets the commit/tree, then\\n   501→\\t\\t\\t// checks for transcript or FilesTouched overlap — exercising\\n   502→\\t\\t\\t// the full expensive code path.\\n   503→\\t\\t\\taliasName := checkpoint.ShadowBranchNameForCommit(base, worktreeID)\\n   504→\\t\\t\\taliasRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(aliasName), shadowCommitHash)\\n   505→\\t\\t\\tif setErr := repo.Storer.SetReference(aliasRef); setErr != nil {\\n   506→\\t\\t\\t\\tt.Fatalf(\\\"create shadow alias %d: %v\\\", i, setErr)\\n   507→\\t\\t\\t}\\n   508→\\n   509→\\t\\t\\tnow := time.Now()\\n   510→\\t\\t\\tstate := &session.State{\\n   511→\\t\\t\\t\\tSessionID:    sessionID,\\n   512→\\t\\t\\t\\tCLIVersion:   \\\"dev\\\",\\n   513→\\t\\t\\t\\tBaseCommit:   base,\\n   514→\\t\\t\\t\\tWorktreePath: dir,\\n   515→\\t\\t\\t\\tWorktreeID:   worktreeID,\\n   516→\\t\\t\\t\\tPhase:        session.PhaseEnded,\\n   517→\\t\\t\\t\\tStartedAt:    now.Add(-time.Duration(i+1) * time.Hour),\\n   518→\\t\\t\\t\\t// No LastCheckpointID — exercises the expensive sessionHasNewContent path\\n   519→\\t\\t\\t\\tStepCount:           (i % 5) + 1,\\n   520→\\t\\t\\t\\tFilesTouched:        perfLargeFileSets[i%len(perfLargeFileSets)],\\n   521→\\t\\t\\t\\tLastInteractionTime: &now,\\n   522→\\t\\t\\t\\tAgentType:           agentTypes[i%len(agentTypes)],\\n   523→\\t\\t\\t\\tFirstPrompt:         perfPrompts[i%len(perfPrompts)],\\n   524→\\t\\t\\t}\\n   525→\\t\\t\\tif saveErr := store.Save(ctx, state); saveErr != nil {\\n   526→\\t\\t\\t\\tt.Fatalf(\\\"save ended-shadow state %d: %v\\\", i, saveErr)\\n   527→\\t\\t\\t}\\n   528→\\t\\t}\\n   529→\\t}\\n   530→\\n   531→\\t// Already-committed ENDED sessions (25%): state file only, no shadow branch.\\n   532→\\t// These have LastCheckpointID set — cheap path during hooks.\\n   533→\\tfor i := range endedWithoutShadow {\\n   534→\\t\\tidx := endedWithShadow + i\\n   535→\\t\\tsessionID := fmt.Sprintf(\\\"perf-ended-%d\\\", idx)\\n   536→\\t\\tcpID := mustGenerateCheckpointID(t)\\n   537→\\t\\tnow := time.Now()\\n   538→\\t\\tbaseIdx := (idx + 1) % len(baseCommits)\\n   539→\\t\\tbase := baseCommits[baseIdx]\\n   540→\\n   541→\\t\\tstate := &session.State{\\n   542→\\t\\t\\tSessionID:           sessionID,\\n   543→\\t\\t\\tCLIVersion:          \\\"dev\\\",\\n   544→\\t\\t\\tBaseCommit:          base,\\n   545→\\t\\t\\tWorktreePath:        dir,\\n   546→\\t\\t\\tWorktreeID:          worktreeID,\\n   547→\\t\\t\\tPhase:               session.PhaseEnded,\\n   548→\\t\\t\\tStartedAt:           now.Add(-time.Duration(idx+1) * time.Hour),\\n   549→\\t\\t\\tLastCheckpointID:    cpID,\\n   550→\\t\\t\\tStepCount:           (idx % 5) + 1,\\n   551→\\t\\t\\tFilesTouched:        perfLargeFileSets[idx%len(perfLargeFileSets)],\\n   552→\\t\\t\\tLastInteractionTime: &now,\\n   553→\\t\\t\\tAgentType:           agentTypes[idx%len(agentTypes)],\\n   554→\\t\\t\\tFirstPrompt:         perfPrompts[idx%len(perfPrompts)],\\n   555→\\t\\t}\\n   556→\\t\\tif saveErr := store.Save(ctx, state); saveErr != nil {\\n   557→\\t\\t\\tt.Fatalf(\\\"save ended-committed state %d: %v\\\", i, saveErr)\\n   558→\\t\\t}\\n   559→\\t}\\n   560→\\n   561→\\t// --- Seed IDLE sessions (with shadow branches) ---\\n   562→\\t// IDLE sessions have the current HEAD as base commit (they're recent).\\n   563→\\tfor i := range idle {\\n   564→\\t\\tsessionID := fmt.Sprintf(\\\"perf-idle-%d\\\", i)\\n   565→\\t\\tfiles := perfFileSets[i%len(perfFileSets)]\\n   566→\\t\\tseedSessionWithShadowBranch(t, s, dir, sessionID, session.PhaseIdle, files)\\n   567→\\n   568→\\t\\t// Enrich state with unique data.\\n   569→\\t\\tstate, loadErr := s.loadSessionState(ctx, sessionID)\\n   570→\\t\\tif loadErr != nil {\\n   571→\\t\\t\\tt.Fatalf(\\\"load idle state %d: %v\\\", i, loadErr)\\n   572→\\t\\t}\\n   573→\\t\\tstate.AgentType = agentTypes[i%len(agentTypes)]\\n   574→\\t\\tstate.FirstPrompt = perfPrompts[i%len(perfPrompts)]\\n   575→\\t\\tstate.StepCount = (i % 3) + 1\\n   576→\\t\\tif saveErr := s.saveSessionState(ctx, state); saveErr != nil {\\n   577→\\t\\t\\tt.Fatalf(\\\"save idle state %d: %v\\\", i, saveErr)\\n   578→\\t\\t}\\n   579→\\t}\\n   580→\\n   581→\\t// --- Seed ACTIVE sessions (shadow branch + live transcript) ---\\n   582→\\tfor i := range active {\\n   583→\\t\\tsessionID := fmt.Sprintf(\\\"perf-active-%d\\\", i)\\n   584→\\t\\tfiles := perfFileSets[i%len(perfFileSets)]\\n   585→\\t\\tseedSessionWithShadowBranch(t, s, dir, sessionID, session.PhaseActive, files)\\n   586→\\n   587→\\t\\t// Create a live transcript file with varied content.\\n   588→\\t\\tclaudeProjectDir := filepath.Join(dir, \\\".claude\\\", \\\"projects\\\", \\\"test\\\", \\\"sessions\\\")\\n   589→\\t\\tif mkdirErr := os.MkdirAll(claudeProjectDir, 0o755); mkdirErr != nil {\\n   590→\\t\\t\\tt.Fatalf(\\\"mkdir claude sessions: %v\\\", mkdirErr)\\n   591→\\t\\t}\\n   592→\\t\\tprompt := perfPrompts[i%len(perfPrompts)]\\n   593→\\t\\ttranscript := fmt.Sprintf(`{\\\"type\\\":\\\"human\\\",\\\"message\\\":{\\\"content\\\":\\\"%s\\\"}}\\n   594→{\\\"type\\\":\\\"assistant\\\",\\\"message\\\":{\\\"content\\\":\\\"I'll work on that for you. Let me start by examining the codebase.\\\"}}\\n   595→{\\\"type\\\":\\\"tool_use\\\",\\\"name\\\":\\\"read\\\",\\\"input\\\":{\\\"path\\\":\\\"%s\\\"}}\\n   596→{\\\"type\\\":\\\"tool_use\\\",\\\"name\\\":\\\"write\\\",\\\"input\\\":{\\\"path\\\":\\\"%s\\\",\\\"content\\\":\\\"package main\\\\n// modified by session %d\\\\nfunc main() {}\\\\n\\\"}}\\n   597→`, prompt, files[0], files[0], i)\\n   598→\\t\\ttranscriptFile := filepath.Join(claudeProjectDir, sessionID+\\\".jsonl\\\")\\n   599→\\t\\tif writeErr := os.WriteFile(transcriptFile, []byte(transcript), 0o644); writeErr != nil {\\n   600→\\t\\t\\tt.Fatalf(\\\"write live transcript: %v\\\", writeErr)\\n   601→\\t\\t}\\n   602→\\n   603→\\t\\tstate, loadErr := s.loadSessionState(ctx, sessionID)\\n   604→\\t\\tif loadErr != nil {\\n   605→\\t\\t\\tt.Fatalf(\\\"load active state %d: %v\\\", i, loadErr)\\n   606→\\t\\t}\\n   607→\\t\\tstate.AgentType = agentTypes[i%len(agentTypes)]\\n   608→\\t\\tstate.FirstPrompt = prompt\\n   609→\\t\\tstate.TranscriptPath = transcriptFile\\n   610→\\t\\tif saveErr := s.saveSessionState(ctx, state); saveErr != nil {\\n   611→\\t\\t\\tt.Fatalf(\\\"save active state %d: %v\\\", i, saveErr)\\n   612→\\t\\t}\\n   613→\\t}\\n   614→\\n   615→\\t// Count unique base commits actually used.\\n   616→\\tseen := make(map[string]struct{})\\n   617→\\tstates, err := store.List(ctx)\\n   618→\\tif err != nil {\\n   619→\\t\\tt.Fatalf(\\\"list states: %v\\\", err)\\n   620→\\t}\\n   621→\\tfor _, st := range states {\\n   622→\\t\\tseen[st.BaseCommit] = struct{}{}\\n   623→\\t}\\n   624→\\n   625→\\tt.Logf(\\\"  Seeded %d sessions (ended=%d [%d shadow, %d committed], idle=%d, active=%d), %d unique base commits\\\",\\n   626→\\t\\tlen(states), ended, endedWithShadow, endedWithoutShadow, idle, active, len(seen))\\n   627→}\\n   628→\\n   629→// seedSessionWithShadowBranch creates a session with a shadow branch checkpoint\\n   630→// using SaveStep, then sets the desired phase.\\n   631→func seedSessionWithShadowBranch(t *testing.T, s *ManualCommitStrategy, dir, sessionID string, phase session.Phase, modifiedFiles []string) {\\n   632→\\tt.Helper()\\n   633→\\tctx := context.Background()\\n   634→\\n   635→\\tfor _, f := range modifiedFiles {\\n   636→\\t\\tabs := filepath.Join(dir, f)\\n   637→\\t\\tif err := os.MkdirAll(filepath.Dir(abs), 0o755); err != nil {\\n   638→\\t\\t\\tt.Fatalf(\\\"mkdir for %s: %v\\\", f, err)\\n   639→\\t\\t}\\n   640→\\t\\tcontent := fmt.Sprintf(\\\"package main\\\\n// modified by agent %s\\\\nfunc f() {}\\\\n\\\", sessionID)\\n   641→\\t\\tif err := os.WriteFile(abs, []byte(content), 0o644); err != nil {\\n   642→\\t\\t\\tt.Fatalf(\\\"write %s: %v\\\", f, err)\\n   643→\\t\\t}\\n   644→\\t}\\n   645→\\n   646→\\tmetadataDir := \\\".entire/metadata/\\\" + sessionID\\n   647→\\tmetadataDirAbs := filepath.Join(dir, metadataDir)\\n   648→\\tif err := os.MkdirAll(metadataDirAbs, 0o755); err != nil {\\n   649→\\t\\tt.Fatalf(\\\"mkdir metadata: %v\\\", err)\\n   650→\\t}\\n   651→\\ttranscript := `{\\\"type\\\":\\\"human\\\",\\\"message\\\":{\\\"content\\\":\\\"implement feature\\\"}}\\n   652→{\\\"type\\\":\\\"assistant\\\",\\\"message\\\":{\\\"content\\\":\\\"I'll implement that for you.\\\"}}\\n   653→`\\n   654→\\tif err := os.WriteFile(filepath.Join(metadataDirAbs, paths.TranscriptFileName), []byte(transcript), 0o644); err != nil {\\n   655→\\t\\tt.Fatalf(\\\"write transcript: %v\\\", err)\\n   656→\\t}\\n   657→\\n   658→\\tpaths.ClearWorktreeRootCache()\\n   659→\\n   660→\\tif err := s.SaveStep(ctx, StepContext{\\n   661→\\t\\tSessionID:      sessionID,\\n   662→\\t\\tModifiedFiles:  modifiedFiles,\\n   663→\\t\\tNewFiles:       []string{},\\n   664→\\t\\tDeletedFiles:   []string{},\\n   665→\\t\\tMetadataDir:    metadataDir,\\n   666→\\t\\tMetadataDirAbs: metadataDirAbs,\\n   667→\\t\\tCommitMessage:  \\\"Checkpoint 1\\\",\\n   668→\\t\\tAuthorName:     \\\"Perf\\\",\\n   669→\\t\\tAuthorEmail:    \\\"perf@test.com\\\",\\n   670→\\t}); err != nil {\\n   671→\\t\\tt.Fatalf(\\\"SaveStep %s: %v\\\", sessionID, err)\\n   672→\\t}\\n   673→\\n   674→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   675→\\tif err != nil {\\n   676→\\t\\tt.Fatalf(\\\"load state %s: %v\\\", sessionID, err)\\n   677→\\t}\\n   678→\\tstate.Phase = phase\\n   679→\\tstate.FilesTouched = modifiedFiles\\n   680→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   681→\\t\\tt.Fatalf(\\\"save state %s: %v\\\", sessionID, err)\\n   682→\\t}\\n   683→}\\n   684→\\n   685→func mustGenerateCheckpointID(t *testing.T) id.CheckpointID {\\n   686→\\tt.Helper()\\n   687→\\tcpID, err := id.Generate()\\n   688→\\tif err != nil {\\n   689→\\t\\tt.Fatalf(\\\"generate checkpoint ID: %v\\\", err)\\n   690→\\t}\\n   691→\\treturn cpID\\n   692→}\\n   693→\"}]},\"uuid\":\"5e478b2a-6cfe-4d98-a34d-c26ec9bb99c8\",\"timestamp\":\"2026-02-28T00:25:31.420Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/evisdrenova/code/entire/devenv/cli/cmd/entire/cli/strategy/commit_hook_perf_test.go\",\"content\":\"//go:build hookperf\\n\\npackage strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"os/exec\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"testing\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\nconst hookPerfRepoURL = \\\"https://github.com/entireio/cli.git\\\"\\n\\n// TestCommitHookPerformance measures the real overhead of Entire's commit hooks\\n// by comparing a control commit (no Entire) against a commit with hooks active.\\n//\\n// It uses a full-history clone of entireio/cli (single branch) with seeded\\n// branches and packed refs so that go-git operates on a realistic object\\n// database. Each session is generated with a unique base commit (drawn from\\n// real repo history) so that listAllSessionStates scans different shadow\\n// branch names — matching production behavior where sessions span many commits.\\n//\\n// Prerequisites:\\n//   - GitHub access (gh auth login) for cloning the private repo\\n//\\n// Run: go test -v -run TestCommitHookPerformance -tags hookperf -timeout 15m ./cmd/entire/cli/strategy/\\nfunc TestCommitHookPerformance(t *testing.T) {\\n\\t// Clone once, reuse across scenarios via cheap local clones.\\n\\tcacheDir := cloneSourceRepo(t)\\n\\n\\tscenarios := []struct {\\n\\t\\tname   string\\n\\t\\tended  int\\n\\t\\tidle   int\\n\\t\\tactive int\\n\\t}{\\n\\t\\t{\\\"100sessions\\\", 88, 11, 1},\\n\\t\\t{\\\"200sessions\\\", 176, 22, 2},\\n\\t\\t{\\\"500sessions\\\", 440, 55, 5},\\n\\t}\\n\\n\\ttype result struct {\\n\\t\\tname       string\\n\\t\\ttotal      int\\n\\t\\tcontrol    time.Duration\\n\\t\\tprepare    time.Duration\\n\\t\\tpostCommit time.Duration\\n\\t}\\n\\tresults := make([]result, 0, len(scenarios))\\n\\n\\tfor _, sc := range scenarios {\\n\\t\\tt.Run(sc.name, func(t *testing.T) {\\n\\t\\t\\ttotalSessions := sc.ended + sc.idle + sc.active\\n\\n\\t\\t\\tdir := localClone(t, cacheDir)\\n\\t\\t\\tt.Chdir(dir)\\n\\t\\t\\tpaths.ClearWorktreeRootCache()\\n\\t\\t\\tsession.ClearGitCommonDirCache()\\n\\n\\t\\t\\t// Seed 200 branches + pack refs for realistic ref scanning overhead.\\n\\t\\t\\tseedBranches(t, dir, 200)\\n\\t\\t\\tgitRun(t, dir, \\\"pack-refs\\\", \\\"--all\\\")\\n\\n\\t\\t\\t// --- CONTROL: commit without Entire ---\\n\\t\\t\\tcontrolDur := timeControlCommit(t, dir)\\n\\n\\t\\t\\t// Reset back to pre-commit state so the test commit is identical.\\n\\t\\t\\tgitRun(t, dir, \\\"reset\\\", \\\"HEAD~1\\\")\\n\\t\\t\\tgitRun(t, dir, \\\"add\\\", \\\"perf_control.txt\\\")\\n\\n\\t\\t\\t// --- TEST: commit with Entire hooks ---\\n\\t\\t\\tcreateHookPerfSettings(t, dir)\\n\\n\\t\\t\\t// Collect diverse base commits from real repo history so each\\n\\t\\t\\t// ENDED session has a different shadow branch name.\\n\\t\\t\\tbaseCommits := collectBaseCommits(t, dir, totalSessions)\\n\\t\\t\\tseedHookPerfSessions(t, dir, baseCommits, sc.ended, sc.idle, sc.active)\\n\\n\\t\\t\\t// Simulate TTY path with commit_linking=always.\\n\\t\\t\\tt.Setenv(\\\"ENTIRE_TEST_TTY\\\", \\\"1\\\")\\n\\t\\t\\tpaths.ClearWorktreeRootCache()\\n\\t\\t\\tsession.ClearGitCommonDirCache()\\n\\n\\t\\t\\tcommitMsgFile := filepath.Join(dir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n\\t\\t\\tif err := os.WriteFile(commitMsgFile, []byte(\\\"implement feature\\\\n\\\"), 0o644); err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"write commit msg: %v\\\", err)\\n\\t\\t\\t}\\n\\n\\t\\t\\ts1 := &ManualCommitStrategy{}\\n\\t\\t\\tprepStart := time.Now()\\n\\t\\t\\tif err := s1.PrepareCommitMsg(context.Background(), commitMsgFile, \\\"message\\\"); err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"PrepareCommitMsg: %v\\\", err)\\n\\t\\t\\t}\\n\\t\\t\\tprepDur := time.Since(prepStart)\\n\\n\\t\\t\\t// Read back commit message; inject trailer if content-aware check skipped it.\\n\\t\\t\\tmsgBytes, err := os.ReadFile(commitMsgFile) //nolint:gosec // test file\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"read commit msg: %v\\\", err)\\n\\t\\t\\t}\\n\\t\\t\\tcommitMsg := string(msgBytes)\\n\\n\\t\\t\\tif _, found := trailers.ParseCheckpoint(commitMsg); !found {\\n\\t\\t\\t\\tcpID, genErr := id.Generate()\\n\\t\\t\\t\\tif genErr != nil {\\n\\t\\t\\t\\t\\tt.Fatalf(\\\"generate checkpoint ID: %v\\\", genErr)\\n\\t\\t\\t\\t}\\n\\t\\t\\t\\tcommitMsg = fmt.Sprintf(\\\"%s\\\\n%s: %s\\\\n\\\",\\n\\t\\t\\t\\t\\tstrings.TrimRight(commitMsg, \\\"\\\\n\\\"),\\n\\t\\t\\t\\t\\ttrailers.CheckpointTrailerKey, cpID)\\n\\t\\t\\t\\tt.Logf(\\\"  Injected trailer (PrepareCommitMsg skipped content-aware check)\\\")\\n\\t\\t\\t}\\n\\n\\t\\t\\tgitRun(t, dir, \\\"commit\\\", \\\"-m\\\", commitMsg)\\n\\n\\t\\t\\t// Time PostCommit.\\n\\t\\t\\tpaths.ClearWorktreeRootCache()\\n\\t\\t\\tsession.ClearGitCommonDirCache()\\n\\n\\t\\t\\ts2 := &ManualCommitStrategy{}\\n\\t\\t\\tpostStart := time.Now()\\n\\t\\t\\tif err := s2.PostCommit(context.Background()); err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"PostCommit: %v\\\", err)\\n\\t\\t\\t}\\n\\t\\t\\tpostDur := time.Since(postStart)\\n\\n\\t\\t\\toverhead := (prepDur + postDur) - controlDur\\n\\t\\t\\tif overhead < 0 {\\n\\t\\t\\t\\toverhead = 0\\n\\t\\t\\t}\\n\\n\\t\\t\\tt.Logf(\\\"=== %s ===\\\", sc.name)\\n\\t\\t\\tt.Logf(\\\"  Sessions:         %d (ended=%d, idle=%d, active=%d)\\\", totalSessions, sc.ended, sc.idle, sc.active)\\n\\t\\t\\tt.Logf(\\\"  Base commits:     %d unique\\\", len(baseCommits))\\n\\t\\t\\tt.Logf(\\\"  Control commit:   %s\\\", controlDur.Round(time.Millisecond))\\n\\t\\t\\tt.Logf(\\\"  PrepareCommitMsg: %s\\\", prepDur.Round(time.Millisecond))\\n\\t\\t\\tt.Logf(\\\"  PostCommit:       %s\\\", postDur.Round(time.Millisecond))\\n\\t\\t\\tt.Logf(\\\"  TOTAL HOOKS:      %s\\\", (prepDur + postDur).Round(time.Millisecond))\\n\\t\\t\\tt.Logf(\\\"  OVERHEAD:         %s\\\", overhead.Round(time.Millisecond))\\n\\n\\t\\t\\tresults = append(results, result{\\n\\t\\t\\t\\tname:       sc.name,\\n\\t\\t\\t\\ttotal:      totalSessions,\\n\\t\\t\\t\\tcontrol:    controlDur,\\n\\t\\t\\t\\tprepare:    prepDur,\\n\\t\\t\\t\\tpostCommit: postDur,\\n\\t\\t\\t})\\n\\t\\t})\\n\\t}\\n\\n\\t// Print comparison table.\\n\\tt.Log(\\\"\\\")\\n\\tt.Log(\\\"========== COMMIT HOOK PERFORMANCE ==========\\\")\\n\\tt.Logf(\\\"%-14s | %8s | %10s | %10s | %12s | %12s | %10s\\\",\\n\\t\\t\\\"Scenario\\\", \\\"Sessions\\\", \\\"Control\\\", \\\"Prepare\\\", \\\"PostCommit\\\", \\\"Total+Hooks\\\", \\\"Overhead\\\")\\n\\tt.Log(strings.Repeat(\\\"-\\\", 95))\\n\\tfor _, r := range results {\\n\\t\\ttotal := r.prepare + r.postCommit\\n\\t\\toverhead := total - r.control\\n\\t\\tif overhead < 0 {\\n\\t\\t\\toverhead = 0\\n\\t\\t}\\n\\t\\tt.Logf(\\\"%-14s | %8d | %10s | %10s | %12s | %12s | %10s\\\",\\n\\t\\t\\tr.name,\\n\\t\\t\\tr.total,\\n\\t\\t\\tr.control.Round(time.Millisecond),\\n\\t\\t\\tr.prepare.Round(time.Millisecond),\\n\\t\\t\\tr.postCommit.Round(time.Millisecond),\\n\\t\\t\\ttotal.Round(time.Millisecond),\\n\\t\\t\\toverhead.Round(time.Millisecond),\\n\\t\\t)\\n\\t}\\n}\\n\\n// collectBaseCommits walks the repo's commit history and returns up to `need`\\n// unique commit hashes. These are used as BaseCommit values so each session\\n// references a different shadow branch name — matching production behavior\\n// where sessions span many different commits over time.\\nfunc collectBaseCommits(t *testing.T, dir string, need int) []string {\\n\\tt.Helper()\\n\\n\\trepo, err := git.PlainOpen(dir)\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"open repo for base commits: %v\\\", err)\\n\\t}\\n\\thead, err := repo.Head()\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"head for base commits: %v\\\", err)\\n\\t}\\n\\n\\tvar commits []string\\n\\titer, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"log for base commits: %v\\\", err)\\n\\t}\\n\\tdefer iter.Close()\\n\\n\\terr = iter.ForEach(func(c *object.Commit) error {\\n\\t\\tif len(commits) >= need {\\n\\t\\t\\treturn fmt.Errorf(\\\"done\\\") //nolint:goerr113 // sentinel to stop iteration\\n\\t\\t}\\n\\t\\tcommits = append(commits, c.Hash.String())\\n\\t\\treturn nil\\n\\t})\\n\\t// \\\"done\\\" sentinel is expected; real errors are not.\\n\\tif err != nil && err.Error() != \\\"done\\\" {\\n\\t\\tt.Fatalf(\\\"walk commits: %v\\\", err)\\n\\t}\\n\\n\\tt.Logf(\\\"  Collected %d base commits from history (requested %d)\\\", len(commits), need)\\n\\treturn commits\\n}\\n\\n// timeControlCommit stages a file and times a bare `git commit` with no Entire\\n// hooks/settings present. Returns the wall-clock duration.\\nfunc timeControlCommit(t *testing.T, dir string) time.Duration {\\n\\tt.Helper()\\n\\n\\tcontrolFile := filepath.Join(dir, \\\"perf_control.txt\\\")\\n\\tif err := os.WriteFile(controlFile, []byte(\\\"control commit content\\\\n\\\"), 0o644); err != nil {\\n\\t\\tt.Fatalf(\\\"write control file: %v\\\", err)\\n\\t}\\n\\tgitRun(t, dir, \\\"add\\\", \\\"perf_control.txt\\\")\\n\\n\\tstart := time.Now()\\n\\tgitRun(t, dir, \\\"commit\\\", \\\"-m\\\", \\\"control commit (no Entire)\\\")\\n\\treturn time.Since(start)\\n}\\n\\n// seedBranches creates N branches pointing at HEAD via go-git to simulate\\n// a repo with many refs (affects ref scanning performance).\\nfunc seedBranches(t *testing.T, dir string, count int) {\\n\\tt.Helper()\\n\\n\\trepo, err := git.PlainOpen(dir)\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"open repo for branch seeding: %v\\\", err)\\n\\t}\\n\\thead, err := repo.Head()\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"head for branch seeding: %v\\\", err)\\n\\t}\\n\\theadHash := head.Hash()\\n\\n\\tfor i := range count {\\n\\t\\tname := fmt.Sprintf(\\\"feature/perf-branch-%03d\\\", i)\\n\\t\\tref := plumbing.NewHashReference(plumbing.NewBranchReferenceName(name), headHash)\\n\\t\\tif err := repo.Storer.SetReference(ref); err != nil {\\n\\t\\t\\tt.Fatalf(\\\"create branch %s: %v\\\", name, err)\\n\\t\\t}\\n\\t}\\n\\tt.Logf(\\\"  Seeded %d branches\\\", count)\\n}\\n\\n// cloneSourceRepo does a one-time full-history clone of entireio/cli into a temp\\n// directory. Returns the path to use as a local clone source for each scenario.\\n//\\n// Uses --single-branch to limit network transfer to one branch while still\\n// fetching the full commit history and object database. This gives us a\\n// realistic packfile (~50-100MB) instead of a shallow clone's ~900KB, which\\n// matters because go-git object resolution (tree.File, commit.Tree, file.Contents)\\n// performance depends on packfile size and index complexity.\\nfunc cloneSourceRepo(t *testing.T) string {\\n\\tt.Helper()\\n\\n\\tdir := t.TempDir()\\n\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n\\t\\tdir = resolved\\n\\t}\\n\\n\\tt.Logf(\\\"Cloning %s (full history, single branch) ...\\\", hookPerfRepoURL)\\n\\tstart := time.Now()\\n\\n\\t//nolint:gosec // test-only, URL is a constant\\n\\tcmd := exec.Command(\\\"git\\\", \\\"clone\\\", \\\"--single-branch\\\", hookPerfRepoURL, dir)\\n\\tout, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"git clone failed: %v\\\\n%s\\\", err, out)\\n\\t}\\n\\tt.Logf(\\\"Source clone completed in %s\\\", time.Since(start).Round(time.Millisecond))\\n\\n\\treturn dir\\n}\\n\\n// localClone creates a fast local clone from the cached source repo.\\nfunc localClone(t *testing.T, sourceDir string) string {\\n\\tt.Helper()\\n\\n\\tdir := t.TempDir()\\n\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n\\t\\tdir = resolved\\n\\t}\\n\\n\\t//nolint:gosec // test-only, sourceDir is from t.TempDir()\\n\\tcmd := exec.Command(\\\"git\\\", \\\"clone\\\", \\\"--local\\\", sourceDir, dir)\\n\\tout, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"local clone failed: %v\\\\n%s\\\", err, out)\\n\\t}\\n\\n\\treturn dir\\n}\\n\\n// gitRun executes a git command in the given directory and fails the test on error.\\nfunc gitRun(t *testing.T, dir string, args ...string) {\\n\\tt.Helper()\\n\\t//nolint:gosec // test-only helper\\n\\tcmd := exec.Command(\\\"git\\\", args...)\\n\\tcmd.Dir = dir\\n\\tout, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n\\t}\\n}\\n\\n// createHookPerfSettings writes .entire/settings.json with commit_linking=always\\n// so PrepareCommitMsg auto-links without prompting.\\nfunc createHookPerfSettings(t *testing.T, dir string) {\\n\\tt.Helper()\\n\\tentireDir := filepath.Join(dir, \\\".entire\\\")\\n\\tif err := os.MkdirAll(entireDir, 0o755); err != nil {\\n\\t\\tt.Fatalf(\\\"mkdir .entire: %v\\\", err)\\n\\t}\\n\\tsettings := `{\\\"enabled\\\": true, \\\"strategy\\\": \\\"manual-commit\\\", \\\"commit_linking\\\": \\\"always\\\"}`\\n\\tif err := os.WriteFile(filepath.Join(entireDir, \\\"settings.json\\\"), []byte(settings), 0o644); err != nil {\\n\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n\\t}\\n}\\n\\n// Sample file lists for varied FilesTouched per session (used by IDLE/ACTIVE\\n// which need actual files on disk via seedSessionWithShadowBranch).\\nvar perfFileSets = [][]string{\\n\\t{\\\"main.go\\\", \\\"go.mod\\\"},\\n\\t{\\\"cmd/entire/main.go\\\", \\\"cmd/entire/cli/root.go\\\"},\\n\\t{\\\"go.sum\\\", \\\"README.md\\\", \\\"Makefile\\\"},\\n\\t{\\\"cmd/entire/cli/strategy/common.go\\\"},\\n\\t{\\\"cmd/entire/cli/session/state.go\\\", \\\"cmd/entire/cli/session/phase.go\\\"},\\n\\t{\\\"cmd/entire/cli/paths/paths.go\\\", \\\"cmd/entire/cli/paths/worktree.go\\\", \\\"go.mod\\\"},\\n\\t{\\\"cmd/entire/cli/agent/claude.go\\\"},\\n\\t{\\\"docs/architecture/README.md\\\", \\\"CLAUDE.md\\\"},\\n}\\n\\n// perfLargeFileSets provides realistic file path lists matching production\\n// session sizes (30-80 files). Real sessions have 30-350+ files touched.\\n// Each set includes \\\"perf_control.txt\\\" so PrepareCommitMsg's staged-file\\n// overlap detection finds a match between staged files and FilesTouched.\\nvar perfLargeFileSets = func() [][]string {\\n\\tdirs := []string{\\n\\t\\t\\\"cmd/entire/cli/strategy\\\",\\n\\t\\t\\\"cmd/entire/cli/session\\\",\\n\\t\\t\\\"cmd/entire/cli/checkpoint\\\",\\n\\t\\t\\\"cmd/entire/cli/agent/claudecode\\\",\\n\\t\\t\\\"cmd/entire/cli/agent/geminicli\\\",\\n\\t\\t\\\"cmd/entire/cli/paths\\\",\\n\\t\\t\\\"cmd/entire/cli/logging\\\",\\n\\t\\t\\\"cmd/entire/cli/settings\\\",\\n\\t\\t\\\"cmd/entire/cli\\\",\\n\\t\\t\\\"docs/architecture\\\",\\n\\t}\\n\\tvar sets [][]string\\n\\tfor setIdx := range 8 {\\n\\t\\tsize := 30 + (setIdx * 7) // 30, 37, 44, 51, 58, 65, 72, 79\\n\\t\\tfiles := []string{\\\"perf_control.txt\\\"}\\n\\t\\tfor i := range size {\\n\\t\\t\\tdir := dirs[i%len(dirs)]\\n\\t\\t\\tsuffix := \\\"\\\"\\n\\t\\t\\tif i%3 == 1 {\\n\\t\\t\\t\\tsuffix = \\\"_test\\\"\\n\\t\\t\\t}\\n\\t\\t\\tfiles = append(files, fmt.Sprintf(\\\"%s/gen_%d%s.go\\\", dir, i, suffix))\\n\\t\\t}\\n\\t\\tsets = append(sets, files)\\n\\t}\\n\\treturn sets\\n}()\\n\\n// Sample prompts for varied FirstPrompt per session.\\nvar perfPrompts = []string{\\n\\t\\\"implement the login feature\\\",\\n\\t\\\"fix the bug in checkout flow\\\",\\n\\t\\\"refactor the session management\\\",\\n\\t\\\"add unit tests for the strategy package\\\",\\n\\t\\\"update the documentation for hooks\\\",\\n\\t\\\"optimize the database queries\\\",\\n\\t\\\"add dark mode support\\\",\\n\\t\\\"migrate to the new API version\\\",\\n\\t\\\"fix the memory leak in the worker pool\\\",\\n\\t\\\"add retry logic for failed API calls\\\",\\n\\t\\\"implement webhook support\\\",\\n\\t\\\"clean up unused imports and dead code\\\",\\n}\\n\\n// seedHookPerfSessions creates fully unique session state files.\\n// Each session gets a unique base commit (from repo history), varied FilesTouched,\\n// and unique prompts — avoiding template duplication artifacts.\\n//\\n// Phase distribution matches real-world observations from .git/entire-sessions/:\\n//\\n//\\tENDED sessions (75%): shadow branch ref + data, NO LastCheckpointID.\\n//\\t    These exercise the expensive hot path: ref lookup → commit → tree →\\n//\\t    transcript/overlap check → condensation during PostCommit.\\n//\\tENDED sessions (25%): state file with LastCheckpointID (already committed, cheap).\\n//\\tIDLE sessions:  state file + shadow branch checkpoint via SaveStep.\\n//\\tACTIVE sessions: state file + shadow branch + live transcript file.\\nfunc seedHookPerfSessions(t *testing.T, dir string, baseCommits []string, ended, idle, activ