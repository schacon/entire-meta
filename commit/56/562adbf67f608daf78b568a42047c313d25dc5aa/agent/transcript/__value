   456→\\tvar firstPrompt string\\n   457→\\tfor _, p := range prompts {\\n   458→\\t\\tcleaned := strings.TrimSpace(p)\\n   459→\\t\\t// Skip empty prompts or prompts that are just dashes/separators\\n   460→\\t\\tif cleaned == \\\"\\\" || isOnlySeparators(cleaned) {\\n   461→\\t\\t\\tcontinue\\n   462→\\t\\t}\\n   463→\\t\\tfirstPrompt = cleaned\\n   464→\\t\\tbreak\\n   465→\\t}\\n   466→\\n   467→\\tif firstPrompt == \\\"\\\" {\\n   468→\\t\\treturn \\\"\\\"\\n   469→\\t}\\n   470→\\n   471→\\treturn TruncateDescription(firstPrompt, MaxDescriptionLength)\\n   472→}\\n   473→\\n   474→// ReadSessionPromptFromTree reads the first meaningful prompt from a checkpoint's prompt.txt file in a git tree.\\n   475→// Returns an empty string if the prompt cannot be read.\\n   476→func ReadSessionPromptFromTree(tree *object.Tree, checkpointPath string) string {\\n   477→\\tpromptPath := checkpointPath + \\\"/\\\" + paths.PromptFileName\\n   478→\\tfile, err := tree.File(promptPath)\\n   479→\\tif err != nil {\\n   480→\\t\\treturn \\\"\\\"\\n   481→\\t}\\n   482→\\n   483→\\tcontent, err := file.Contents()\\n   484→\\tif err != nil {\\n   485→\\t\\treturn \\\"\\\"\\n   486→\\t}\\n   487→\\n   488→\\treturn ExtractFirstPrompt(content)\\n   489→}\\n   490→\\n   491→// ReadAgentTypeFromTree reads the agent type from a checkpoint's metadata.json file in a git tree.\\n   492→// If metadata.json doesn't exist (shadow branches), it falls back to detecting the agent\\n   493→// from the presence of agent-specific config files (.gemini/settings.json or .claude/).\\n   494→// Returns agent.AgentTypeUnknown if the agent type cannot be determined.\\n   495→func ReadAgentTypeFromTree(tree *object.Tree, checkpointPath string) types.AgentType {\\n   496→\\t// First, try to read from metadata.json (present in condensed/committed checkpoints)\\n   497→\\tmetadataPath := checkpointPath + \\\"/\\\" + paths.MetadataFileName\\n   498→\\tif file, err := tree.File(metadataPath); err == nil {\\n  