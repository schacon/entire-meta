 2→//\\n     3→// A Checkpoint captures a point-in-time within a session, containing either\\n     4→// full state (Temporary) or metadata with a commit reference (Committed).\\n     5→//\\n     6→// See docs/architecture/sessions-and-checkpoints.md for the full domain model.\\n     7→package checkpoint\\n     8→\\n     9→import (\\n    10→\\t\\\"context\\\"\\n    11→\\t\\\"errors\\\"\\n    12→\\t\\\"time\\\"\\n    13→\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    17→\\n    18→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    19→)\\n    20→\\n    21→// Errors returned by checkpoint operations.\\n    22→var (\\n    23→\\t// ErrCheckpointNotFound is returned when a checkpoint ID doesn't exist.\\n    24→\\tErrCheckpointNotFound = errors.New(\\\"checkpoint not found\\\")\\n    25→\\n    26→\\t// ErrNoTranscript is returned when a checkpoint exists but has no transcript.\\n    27→\\tErrNoTranscript = errors.New(\\\"no transcript found for checkpoint\\\")\\n    28→)\\n    29→\\n    30→// Checkpoint represents a save point within a session.\\n    31→type Checkpoint struct {\\n    32→\\t// ID is the unique checkpoint identifier\\n    33→\\tID string\\n    34→\\n    35→\\t// SessionID is the session this checkpoint belongs to\\n    36→\\tSessionID string\\n    37→\\n    38→\\t// Timestamp is when this checkpoint was created\\n    39→\\tTimestamp time.Time\\n    40→\\n    41→\\t// Type indicates temporary (full state) or committed (metadata only)\\n    42→\\tType Type\\n    43→\\n    44→\\t// Message is a human-readable description of the checkpoint\\n    45→\\tMessage string\\n    46→}\\n    47→\\n    48→// Type indicates the storage location and lifecycle of a checkpoint.\\n    49→type Type int\\n    50→\\n    51→const (\\n    52→\\t// Temporary checkpoints contain full state (code + metadata) and are stored\\n    53→\\t// on shadow branches (entire/<commit-hash>). Used for intra-session rewind.\\n    54→\\tTemporary Type = iota\\n    55→\\n    56→\\t// Committed checkpoints contain metadata + commit reference and are stored\\n    57→\\t// on the entire/checkpoints/v1 branch. They are the permanent record.\\n    58→\\tCommitted\\n    59→)\\n    60→\\n    61→// Store provides low-level primitives for reading and writing checkpoints.\\n    62→// This is used by strategies to implement their storage approach.\\n    63→//\\n    64→// The interface matches the GitStore implementation signatures directly:\\n    65→// - WriteTemporary takes WriteTemporaryOptions and returns a result with commit hash and skip status\\n    66→// - ReadTemporary takes baseCommit (not sessionID) since shadow branches are keyed by commit\\n    67→// - List methods return implementation-specific info types for richer data\\n    68→type Store interface {\\n    69→\\t// WriteTemporary writes a temporary checkpoint (full state) to a shadow branch.\\n    70→\\t// Shadow branches are named entire/<base-commit-short-hash>.\\n    71→\\t// Returns a result containing the commit hash and whether the checkpoint was skipped.\\n    72→\\t// Checkpoints are skipped (deduplicated) when the tree hash matches the previous checkpoint.\\n    73→\\tWriteTemporary(ctx context.Context, opts WriteTemporaryOptions) (WriteTemporaryResult, error)\\n    74→\\n    75→\\t// ReadTemporary reads the latest checkpoint from a shadow branch.\\n    76→\\t// baseCommit is the commit hash the session is based on.\\n    77→\\t// worktreeID is the internal git worktree identifier (empty for main worktree).\\n    78→\\t// Returns nil, nil if the shadow branch doesn't exist.\\n    79→\\tReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error)\\n    80→\\n    81→\\t// ListTemporary lists all shadow branches with their checkpoint info.\\n    82→\\tListTemporary(ctx context.Context) ([]TemporaryInfo, error)\\n    83→\\n    84→\\t// WriteCommitted writes a committed checkpoint to the entire/checkpoints/v1 branch.\\n    85→\\t// Checkpoints are stored at sharded paths: <id[:2]>/<id[2:]>/\\n    86→\\tWriteCommitted(ctx context.Context, opts WriteCommittedOptions) error\\n    87→\\n    88→\\t// ReadCommitted reads a committed checkpoint's summary by ID.\\n    89→\\t// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n    90→\\t// Use ReadSessionContent to read actual transcript/prompts/context.\\n    91→\\t// Returns nil, nil if the checkpoint does not exist.\\n    92→\\tReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error)\\n    93→\\n    94→\\t// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n    95→\\t// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n    96→\\t// Returns the session's metadata, transcript, prompts, and context.\\n    97→\\tReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error)\\n    98→\\n    99→\\t// ReadSessionContentByID reads a session's content by its session ID.\\n   100→\\t// Useful when you have the session ID but don't know its index within the checkpoint.\\n   101→\\tReadSessionContentByID(ctx context.Context, checkpointID id.CheckpointID, sessionID string) (*SessionContent, error)\\n   102→\\n   103→\\t// ListCommitted lists all committed checkpoints.\\n   104→\\tListCommitted(ctx context.Context) ([]CommittedInfo, error)\\n   105→\\n   106→\\t// UpdateCommitted replaces the transcript, prompts, and context for an existing\\n   107→\\t// committed checkpoint. Used at stop time to finalize checkpoints with the full\\n   108→\\t// session transcript (prompt to stop event).\\n   109→\\t// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   110→\\tUpdateCommitted(ctx context.Context, opts UpdateCommittedOptions) error\\n   111→}\\n   112→\\n   113→// WriteTemporaryResult contains the result of writing a temporary checkpoint.\\n   114→type WriteTemporaryResult struct {\\n   115→\\t// CommitHash is the hash of the created or existing checkpoint commit\\n   116→\\tCommitHash plumbing.Hash\\n   117→\\n   118→\\t// Skipped is true if the checkpoint was skipped due to no changes\\n   119→\\t// (tree hash matched the previous checkpoint)\\n   120→\\tSkipped bool\\n   121→}\\n   122→\\n   123→// WriteTemporaryOptions contains options for writing a temporary checkpoint.\\n   124→type WriteTemporaryOptions struct {\\n   125→\\t// SessionID is the session identifier\\n   126→\\tSessionID string\\n   127→\\n   128→\\t// BaseCommit is the commit hash this session is based on\\n   129→\\tBaseCommit string\\n   130→\\n   131→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n   132→\\t// Used to create worktree-specific shadow branch names\\n   133→\\tWorktreeID string\\n   134→\\n   135→\\t// ModifiedFiles are files that have been modified (relative paths)\\n   136→\\tModifiedFiles []string\\n   137→\\n   138→\\t// NewFiles are files that have been created (relative paths)\\n   139→\\tNewFiles []string\\n   140→\\n   141→\\t// DeletedFiles are files that have been deleted (relative paths)\\n   142→\\tDeletedFiles []string\\n   143→\\n   144→\\t// MetadataDir is the relative path to the metadata directory\\n   145→\\tMetadataDir string\\n   146→\\n   147→\\t// MetadataDirAbs is the absolute path to the metadata directory\\n   148→\\tMetadataDirAbs string\\n   149→\\n   150→\\t// CommitMessage is the commit subject line\\n   151→\\tCommitMessage string\\n   152→\\n   153→\\t// AuthorName is the name to use for commits\\n   154→\\tAuthorName string\\n   155→\\n   156→\\t// AuthorEmail is the email to use for commits\\n   157→\\tAuthorEmail string\\n   158→\\n   159→\\t// IsFirstCheckpoint indicates if this is the first checkpoint of the session\\n   160→\\t// When true, all working directory files are captured (not just modified)\\n   161→\\tIsFirstCheckpoint bool\\n   162→}\\n   163→\\n   164→// ReadTemporaryResult contains the result of reading a temporary checkpoint.\\n   165→type ReadTemporaryResult struct {\\n   166→\\t// CommitHash is the hash of the checkpoint commit\\n   167→\\tCommitHash plumbing.Hash\\n   168→\\n   169→\\t// TreeHash is the hash of the tree containing the checkpoint state\\n   170→\\tTreeHash plumbing.Hash\\n   171→\\n   172→\\t// SessionID is the session identifier from the commit trailer\\n   173→\\tSessionID string\\n   174→\\n   175→\\t// MetadataDir is the metadata directory path from the commit trailer\\n   176→\\tMetadataDir string\\n   177→\\n   178→\\t// Timestamp is when the checkpoint was created\\n   179→\\tTimestamp time.Time\\n   180→}\\n   181→\\n   182→// TemporaryInfo contains summary information about a shadow branch.\\n   183→type TemporaryInfo struct {\\n   184→\\t// BranchName is the full branch name (e.g., \\\"entire/abc1234\\\")\\n   185→\\tBranchName string\\n   186→\\n   187→\\t// BaseCommit is the short commit hash this branch is based on\\n   188→\\tBaseCommit string\\n   189→\\n   190→\\t// LatestCommit is the hash of the latest commit on the branch\\n   191→\\tLatestCommit plumbing.Hash\\n   192→\\n   193→\\t// SessionID is the session identifier from the latest commit\\n   194→\\tSessionID string\\n   195→\\n   196→\\t// Timestamp is when the latest checkpoint was created\\n   197→\\tTimestamp time.Time\\n   198→}\\n   199→\\n   200→// WriteCommittedOptions contains options for writing a committed checkpoint.\\n   201→type WriteCommittedOptions struct {\\n   202→\\t// CheckpointID is the stable 12-hex-char identifier\\n   203→\\tCheckpointID id.CheckpointID\\n   204→\\n   205→\\t// SessionID is the session identifier\\n   206→\\tSessionID string\\n   207→\\n   208→\\t// Strategy is the name of the strategy that created this checkpoint\\n   209→\\tStrategy string\\n   210→\\n   211→\\t// Branch is the branch name where the checkpoint was created (empty if detached HEAD)\\n   212→\\tBranch string\\n   213→\\n   214→\\t// Transcript is the session transcript content (full.jsonl)\\n   215→\\tTranscript []byte\\n   216→\\n   217→\\t// Prompts contains user prompts from the session\\n   218→\\tPrompts []string\\n   219→\\n   220→\\t// Context is the generated context.md content\\n   221→\\tContext []byte\\n   222→\\n   223→\\t// FilesTouched are files modified during the session\\n   224→\\tFilesTouched []string\\n   225→\\n   226→\\t// CheckpointsCount is the number of checkpoints in this session\\n   227→\\tCheckpointsCount int\\n   228→\\n   229→\\t// EphemeralBranch is the shadow branch name (for manual-commit strategy)\\n   230→\\tEphemeralBranch string\\n   231→\\n   232→\\t// AuthorName is the name to use for commits\\n   233→\\tAuthorName string\\n   234→\\n   235→\\t// AuthorEmail is the email to use for commits\\n   236→\\tAuthorEmail string\\n   237→\\n   238→\\t// MetadataDir is a directory containing additional metadata files to copy\\n   239→\\t// If set, all files in this directory will be copied to the checkpoint path\\n   240→\\t// This is useful for copying task metadata files, subagent transcripts, etc.\\n   241→\\tMetadataDir string\\n   242→\\n   243→\\t// Task checkpoint fields (for task/subagent checkpoints)\\n   244→\\tIsTask    bool   // Whether this is a task checkpoint\\n   245→\\tToolUseID string // Tool use ID for task checkpoints\\n   246→\\n   247→\\t// Additional task checkpoint fields for subagent checkpoints\\n   248→\\tAgentID                string // Subagent identifier\\n   249→\\tCheckpointUUID         string // UUID for transcript truncation when rewinding\\n   250→\\tTranscriptPath         string // Path to session transcript file (alternative to in-memory Transcript)\\n   251→\\tSubagentTranscriptPath string // Path to subagent's transcript file\\n   252→\\n   253→\\t// Incremental checkpoint fields\\n   254→\\tIsIncremental       bool   // Whether this is an incremental checkpoint\\n   255→\\tIncrementalSequence int    // Checkpoint sequence number\\n   256→\\tIncrementalType     string // Tool type that triggered this checkpoint\\n   257→\\tIncrementalData     []byte // Tool input payload for this checkpoint\\n   258→\\n   259→\\t// Commit message fields (used for task checkpoints)\\n   260→\\tCommitSubject string // Subject line for the metadata commit (overrides default)\\n   261→\\n   262→\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   263→\\tAgent types.AgentType\\n   264→\\n   265→\\t// TurnID correlates checkpoints from the same agent turn.\\n   266→\\tTurnID string\\n   267→\\n   268→\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n   269→\\tTranscriptIdentifierAtStart string // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n   270→\\tCheckpointTranscriptStart   int    // Transcript line offset at start of this checkpoint's data\\n   271→\\n   272→\\t// CheckpointTranscriptStart is written to both CommittedMetadata.CheckpointTranscriptStart\\n   273→\\t// and the deprecated CommittedMetadata.TranscriptLinesAtStart for backward compatibility.\\n   274→\\n   275→\\t// TokenUsage contains the token usage for this checkpoint\\n   276→\\tTokenUsage *agent.TokenUsage\\n   277→\\n   278→\\t// InitialAttribution is line-level attribution calculated at commit time\\n   279→\\t// comparing checkpoint tree (agent work) to committed tree (may include human edits)\\n   280→\\tInitialAttribution *InitialAttribution\\n   281→\\n   282→\\t// Summary is an optional AI-generated summary for this checkpoint.\\n   283→\\t// This field may be nil when:\\n   284→\\t//   - summarization is disabled in settings\\n   285→\\t//   - summary generation failed (non-blocking, logged as warning)\\n   286→\\t//   - the transcript was empty or too short to summarize\\n   287→\\t//   - the checkpoint predates the summarization feature\\n   288→\\tSummary *Summary\\n   289→}\\n   290→\\n   291→// UpdateCommittedOptions contains options for updating an existing committed checkpoint.\\n   292→// Uses replace semantics: the transcript, prompts, and context are fully replaced,\\n   293→// not appended. At stop time we have the complete session transcript and want every\\n   294→// checkpoint to contain it identically.\\n   295→type UpdateCommittedOptions struct {\\n   296→\\t// CheckpointID identifies the checkpoint to update\\n   297→\\tCheckpointID id.CheckpointID\\n   298→\\n   299→\\t// SessionID identifies which session slot to update within the checkpoint\\n   300→\\tSessionID string\\n   301→\\n   302→\\t// Transcript is the full session transcript (replaces existing)\\n   303→\\tTranscript []byte\\n   304→\\n   305→\\t// Prompts contains all user prompts (replaces existing)\\n   306→\\tPrompts []string\\n   307→\\n   308→\\t// Context is the updated context.md content (replaces existing)\\n   309→\\tContext []byte\\n   310→\\n   311→\\t// Agent identifies the agent type (needed for transcript chunking)\\n   312→\\tAgent types.AgentType\\n   313→}\\n   314→\\n   315→// CommittedInfo contains summary information about a committed checkpoint.\\n   316→type CommittedInfo struct {\\n   317→\\t// CheckpointID is the stable 12-hex-char identifier\\n   318→\\tCheckpointID id.CheckpointID\\n   319→\\n   320→\\t// SessionID is the session identifier (most recent session for multi-session checkpoints)\\n   321→\\tSessionID string\\n   322→\\n   323→\\t// CreatedAt is when the checkpoint was created\\n   324→\\tCreatedAt time.Time\\n   325→\\n   326→\\t// CheckpointsCount is the total number of checkpoints across all sessions\\n   327→\\tCheckpointsCount int\\n   328→\\n   329→\\t// FilesTouched are files modified during all sessions\\n   330→\\tFilesTouched []string\\n   331→\\n   332→\\t// Agent identifies the agent that created this checkpoint\\n   333→\\tAgent types.AgentType\\n   334→\\n   335→\\t// IsTask indicates if this is a task checkpoint\\n   336→\\tIsTask bool\\n   337→\\n   338→\\t// ToolUseID is the tool use ID for task checkpoints\\n   339→\\tToolUseID string\\n   340→\\n   341→\\t// Multi-session support\\n   342→\\tSessionCount int      // Number of sessions (1 if single session)\\n   343→\\tSessionIDs   []string // All session IDs that contributed\\n   344→}\\n   345→\\n   346→// SessionContent contains the actual content for a session.\\n   347→// This is used when reading full session data (transcript, prompts, context)\\n   348→// as opposed to just the metadata/summary.\\n   349→type SessionContent struct {\\n   350→\\t// Metadata contains the session-specific metadata\\n   351→\\tMetadata CommittedMetadata\\n   352→\\n   353→\\t// Transcript is the session transcript content\\n   354→\\tTranscript []byte\\n   355→\\n   356→\\t// Prompts contains user prompts from this session\\n   357→\\tPrompts string\\n   358→\\n   359→\\t// Context is the context.md content\\n   360→\\tContext string\\n   361→}\\n   362→\\n   363→// CommittedMetadata contains the metadata stored in metadata.json for each checkpoint.\\n   364→type CommittedMetadata struct {\\n   365→\\tCLIVersion       string          `json:\\\"cli_version,omitempty\\\"`\\n   366→\\tCheckpointID     id.CheckpointID `json:\\\"checkpoint_id\\\"`\\n   367→\\tSessionID        string          `json:\\\"session_id\\\"`\\n   368→\\tStrategy         string          `json:\\\"strategy\\\"`\\n   369→\\tCreatedAt        time.Time       `json:\\\"created_at\\\"`\\n   370→\\tBranch           string          `json:\\\"branch,omitempty\\\"` // Branch where checkpoint was created (empty if detached HEAD)\\n   371→\\tCheckpointsCount int             `json:\\\"checkpoints_count\\\"`\\n   372→\\tFilesTouched     []string        `json:\\\"files_touched\\\"`\\n   373→\\n   374→\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   375→\\tAgent types.AgentType `json:\\\"agent,omitempty\\\"`\\n   376→\\n   377→\\t// TurnID correlates checkpoints from the same agent turn.\\n   378→\\t// When a turn's work spans multiple commits, each gets its own checkpoint\\n   379→\\t// but they share the same TurnID for future aggregation/deduplication.\\n   380→\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n   381→\\n   382→\\t// Task checkpoint fields (only populated for task checkpoints)\\n   383→\\tIsTask    bool   `json:\\\"is_task,omitempty\\\"`\\n   384→\\tToolUseID string `json:\\\"tool_use_id,omitempty\\\"`\\n   385→\\n   386→\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n   387→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"` // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n   388→\\tCheckpointTranscriptStart   int    `json:\\\"checkpoint_transcript_start,omitempty\\\"`    // Transcript line offset at start of this checkpoint's data\\n   389→\\n   390→\\t// Deprecated: Use CheckpointTranscriptStart instead. Written for backward compatibility with older CLI versions.\\n   391→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   392→\\n   393→\\t// Token usage for this checkpoint\\n   394→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   395→\\n   396→\\t// AI-generated summary of the checkpoint\\n   397→\\tSummary *Summary `json:\\\"summary,omitempty\\\"`\\n   398→\\n   399→\\t// InitialAttribution is line-level attribution calculated at commit time\\n   400→\\tInitialAttribution *InitialAttribution `json:\\\"initial_attribution,omitempty\\\"`\\n   401→}\\n   402→\\n   403→// GetTranscriptStart returns the transcript line offset at which this checkpoint's data begins.\\n   404→// Returns 0 for new checkpoints (start from beginning). For data written by older CLI versions,\\n   405→// falls back to the deprecated TranscriptLinesAtStart field.\\n   406→func (m CommittedMetadata) GetTranscriptStart() int {\\n   407→\\tif m.CheckpointTranscriptStart > 0 {\\n   408→\\t\\treturn m.CheckpointTranscriptStart\\n   409→\\t}\\n   410→\\treturn m.TranscriptLinesAtStart\\n   411→}\\n   412→\\n   413→// SessionFilePaths contains the absolute paths to session files from the git tree root.\\n   414→// Paths include the full checkpoint path prefix (e.g., \\\"/a1/b2c3d4e5f6/1/metadata.json\\\").\\n   415→// Used in CheckpointSummary.Sessions to map session IDs to their file locations.\\n   416→type SessionFilePaths struct {\\n   417→\\tMetadata    string `json:\\\"metadata\\\"`\\n   418→\\tTranscript  string `json:\\\"transcript\\\"`\\n   419→\\tContext     string `json:\\\"context\\\"`\\n   420→\\tContentHash string `json:\\\"content_hash\\\"`\\n   421→\\tPrompt      string `json:\\\"prompt\\\"`\\n   422→}\\n   423→\\n   424→// CheckpointSummary is the root-level metadata.json for a checkpoint.\\n   425→// It contains aggregated statistics from all sessions and a map of session IDs\\n   426→// to their file paths. Session-specific data (including initial_attribution)\\n   427→// is stored in the session's subdirectory metadata.json.\\n   428→//\\n   429→// Structure on entire/checkpoints/v1 branch:\\n   430→//\\n   431→//\\t<checkpoint-id[:2]>/<checkpoint-id[2:]>/\\n   432→//\\t├── metadata.json         # This CheckpointSummary\\n   433→//\\t├── 1/                    # First session\\n   434→//\\t│   ├── metadata.json     # Session-specific CommittedMetadata\\n   435→//\\t│   ├── full.jsonl\\n   436→//\\t│   ├── prompt.txt\\n   437→//\\t│   ├── context.md\\n   438→//\\t│   └── content_hash.txt\\n   439→//\\t├── 2/                    # Second session\\n   440→//\\t└── 3/                    # Third session...\\n   441→//\\n   442→//nolint:revive // Named CheckpointSummary to avoid conflict with existing Summary struct\\n   443→type CheckpointSummary struct {\\n   444→\\tCLIVersion       string             `json:\\\"cli_version,omitempty\\\"`\\n   445→\\tCheckpointID     id.CheckpointID    `json:\\\"checkpoint_id\\\"`\\n   446→\\tStrategy         string             `json:\\\"strategy\\\"`\\n   447→\\tBranch           string             `json:\\\"branch,omitempty\\\"`\\n   448→\\tCheckpointsCount int                `json:\\\"checkpoints_count\\\"`\\n   449→\\tFilesTouched     []string           `json:\\\"files_touched\\\"`\\n   450→\\tSessions         []SessionFilePaths `json:\\\"sessions\\\"`\\n   451→\\tTokenUsage       *agent.TokenUsage  `json:\\\"token_usage,omitempty\\\"`\\n   452→}\\n   453→\\n   454→// Summary contains AI-generated summary of a checkpoint.\\n   455→type Summary struct {\\n   456→\\tIntent    string           `json:\\\"intent\\\"`     // What user wanted to accomplish\\n   457→\\tOutcome   string           `json:\\\"outcome\\\"`    // What was achieved\\n   458→\\tLearnings LearningsSummary `json:\\\"learnings\\\"`  // Categorized learnings\\n   459→\\tFriction  []string         `json:\\\"friction\\\"`   // Problems/annoyances encountered\\n   460→\\tOpenItems []string         `json:\\\"open_items\\\"` // Tech debt, unfinished work\\n   461→}\\n   462→\\n   463→// LearningsSummary contains learnings grouped by scope.\\n   464→type LearningsSummary struct {\\n   465→\\tRepo     []string       `json:\\\"repo\\\"`     // Codebase-specific patterns/conventions\\n   466→\\tCode     []CodeLearning `json:\\\"code\\\"`     // File/module specific findings\\n   467→\\tWorkflow []string       `json:\\\"workflow\\\"` // General dev practices\\n   468→}\\n   469→\\n   470→// CodeLearning captures a learning tied to a specific code location.\\n   471→type CodeLearning struct {\\n   472→\\tPath    string `json:\\\"path\\\"`               // File path\\n   473→\\tLine    int    `json:\\\"line,omitempty\\\"`     // Start line number\\n   474→\\tEndLine int    `json:\\\"end_line,omitempty\\\"` // End line for ranges (optional)\\n   475→\\tFinding string `json:\\\"finding\\\"`            // What was learned\\n   476→}\\n   477→\\n   478→// InitialAttribution captures line-level attribution metrics at commit time.\\n   479→// This is a point-in-time snapshot comparing the checkpoint tree (agent work)\\n   480→// against the committed tree (may include human edits).\\n   481→//\\n   482→// Attribution Metrics:\\n   483→//   - TotalCommitted measures \\\"net additions\\\" (lines added that remain in the commit)\\n   484→//   - AgentPercentage represents \\\"of the new code added, what percentage came from the agent\\\"\\n   485→//   - Deletion work is tracked separately in HumanRemoved (not included in percentage)\\n   486→//\\n   487→// Deletion-Only Commits:\\n   488→// For commits with only deletions (no additions), TotalCommitted will be 0 and\\n   489→// AgentPercentage will be 0. This is by design - the percentage metric is only\\n   490→// meaningful for commits that add code. Deletion contributions are captured in\\n   491→// the HumanRemoved field but don't affect the attribution percentage.\\n   492→type InitialAttribution struct {\\n   493→\\tCalculatedAt    time.Time `json:\\\"calculated_at\\\"`\\n   494→\\tAgentLines      int       `json:\\\"agent_lines\\\"`      // Lines added by agent (base → shadow diff)\\n   495→\\tHumanAdded      int       `json:\\\"human_added\\\"`      // Lines added by human (excluding modifications)\\n   496→\\tHumanModified   int       `json:\\\"human_modified\\\"`   // Lines modified by human (estimate: min(added, removed))\\n   497→\\tHumanRemoved    int       `json:\\\"human_removed\\\"`    // Lines removed by human (excluding modifications)\\n   498→\\tTotalCommitted  int       `json:\\\"total_committed\\\"`  // Net additions in commit (agent + human new lines, not total file size)\\n   499→\\tAgentPercentage float64   `json:\\\"agent_percentage\\\"` // agent_lines / total_committed * 100 (0 for deletion-only commits)\\n   500→}\\n   501→\\n   502→// Info provides summary information for listing checkpoints.\\n   503→// This is the generic checkpoint info type.\\n   504→type Info struct {\\n   505→\\t// ID is the checkpoint identifier\\n   506→\\tID string\\n   507→\\n   508→\\t// SessionID identifies the session\\n   509→\\tSessionID string\\n   510→\\n   511→\\t// Type indicates temporary or committed\\n   512→\\tType Type\\n   513→\\n   514→\\t// CreatedAt is when the checkpoint was created\\n   515→\\tCreatedAt time.Time\\n   516→\\n   517→\\t// Message is a summary description\\n   518→\\tMessage string\\n   519→}\\n   520→\\n   521→// WriteTemporaryTaskOptions contains options for writing a task checkpoint.\\n   522→// Task checkpoints are created when a subagent completes and contain both\\n   523→// code changes and task-specific metadata.\\n   524→type WriteTemporaryTaskOptions struct {\\n   525→\\t// SessionID is the session identifier\\n   526→\\tSessionID string\\n   527→\\n   528→\\t// BaseCommit is the commit hash this session is based on\\n   529→\\tBaseCommit string\\n   530→\\n   531→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n   532→\\t// Used to create worktree-specific shadow branch names\\n   533→\\tWorktreeID string\\n   534→\\n   535→\\t// ToolUseID is the unique identifier for this Task tool invocation\\n   536→\\tToolUseID string\\n   537→\\n   538→\\t// AgentID is the subagent identifier\\n   539→\\tAgentID string\\n   540→\\n   541→\\t// ModifiedFiles are files that have been modified (relative paths)\\n   542→\\tModifiedFiles []string\\n   543→\\n   544→\\t// NewFiles are files that have been created (relative paths)\\n   545→\\tNewFiles []string\\n   546→\\n   547→\\t// DeletedFiles are files that have been deleted (relative paths)\\n   548→\\tDeletedFiles []string\\n   549→\\n   550→\\t// TranscriptPath is the path to the main session transcript\\n   551→\\tTranscriptPath string\\n   552→\\n   553→\\t// SubagentTranscriptPath is the path to the subagent's transcript\\n   554→\\tSubagentTranscriptPath string\\n   555→\\n   556→\\t// CheckpointUUID is the UUID for transcript truncation when rewinding\\n   557→\\tCheckpointUUID string\\n   558→\\n   559→\\t// CommitMessage is the commit message (already formatted)\\n   560→\\tCommitMessage string\\n   561→\\n   562→\\t// AuthorName is the name to use for commits\\n   563→\\tAuthorName string\\n   564→\\n   565→\\t// AuthorEmail is the email to use for commits\\n   566→\\tAuthorEmail string\\n   567→\\n   568→\\t// IsIncremental indicates this is an incremental checkpoint\\n   569→\\tIsIncremental bool\\n   570→\\n   571→\\t// IncrementalSequence is the checkpoint sequence number\\n   572→\\tIncrementalSequence int\\n   573→\\n   574→\\t// IncrementalType is the tool that triggered this checkpoint\\n   575→\\tIncrementalType string\\n   576→\\n   577→\\t// IncrementalData is the tool_input payload for this checkpoint\\n   578→\\tIncrementalData []byte\\n   579→}\\n   580→\\n   581→// TemporaryCheckpointInfo contains information about a single commit on a shadow branch.\\n   582→// Used by ListTemporaryCheckpoints to provide rewind point data.\\n   583→type TemporaryCheckpointInfo struct {\\n   584→\\t// CommitHash is the hash of the checkpoint commit\\n   585→\\tCommitHash plumbing.Hash\\n   586→\\n   587→\\t// Message is the first line of the commit message\\n   588→\\tMessage string\\n   589→\\n   590→\\t// SessionID is the session identifier from the Entire-Session trailer\\n   591→\\tSessionID string\\n   592→\\n   593→\\t// MetadataDir is the metadata directory path from trailers\\n   594→\\tMetadataDir string\\n   595→\\n   596→\\t// IsTaskCheckpoint indicates if this is a task checkpoint\\n   597→\\tIsTaskCheckpoint bool\\n   598→\\n   599→\\t// ToolUseID is the tool use ID for task checkpoints\\n   600→\\tToolUseID string\\n   601→\\n   602→\\t// Timestamp is when the checkpoint was created\\n   603→\\tTimestamp time.Time\\n   604→}\\n   605→\"}]},\"uuid\":\"6d46373e-a6a4-44ef-8121-7ed1fe8685d9\",\"timestamp\":\"2026-02-27T22:37:30.214Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/pfleidi/entire/cli/.worktrees/explain-hang-performance/cmd/entire/cli/checkpoint/checkpoint.go\",\"content\":\"// Package checkpoint provides types and interfaces for checkpoint storage.\\n//\\n// A Checkpoint captures a point-in-time within a session, containing either\\n// full state (Temporary) or metadata with a commit reference (Committed).\\n//\\n// See docs/architecture/sessions-and-checkpoints.md for the full domain model.\\npackage checkpoint\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n)\\n\\n// Errors returned by checkpoint operations.\\nvar (\\n\\t// ErrCheckpointNotFound is returned when a checkpoint ID doesn't exist.\\n\\tErrCheckpointNotFound = errors.New(\\\"checkpoint not found\\\")\\n\\n\\t// ErrNoTranscript is returned when a checkpoint exists but has no transcript.\\n\\tErrNoTranscript = errors.New(\\\"no transcript found for checkpoint\\\")\\n)\\n\\n// Checkpoint represents a save point within a session.\\ntype Checkpoint struct {\\n\\t// ID is the unique checkpoint identifier\\n\\tID string\\n\\n\\t// SessionID is the session this checkpoint belongs to\\n\\tSessionID string\\n\\n\\t// Timestamp is when this checkpoint was created\\n\\tTimestamp time.Time\\n\\n\\t// Type indicates temporary (full state) or committed (metadata only)\\n\\tType Type\\n\\n\\t// Message is a human-readable description of the checkpoint\\n\\tMessage string\\n}\\n\\n// Type indicates the storage location and lifecycle of a checkpoint.\\ntype Type int\\n\\nconst (\\n\\t// Temporary checkpoints contain full state (code + metadata) and are stored\\n\\t// on shadow branches (entire/<commit-hash>). Used for intra-session rewind.\\n\\tTemporary Type = iota\\n\\n\\t// Committed checkpoints contain metadata + commit reference and are stored\\n\\t// on the entire/checkpoints/v1 branch. They are the permanent record.\\n\\tCommitted\\n)\\n\\n// Store provides low-level primitives for reading and writing checkpoints.\\n// This is used by strategies to implement their storage approach.\\n//\\n// The interface matches the GitStore implementation signatures directly:\\n// - WriteTemporary takes WriteTemporaryOptions and returns a result with commit hash and skip status\\n// - ReadTemporary takes baseCommit (not sessionID) since shadow branches are keyed by commit\\n// - List methods return implementation-specific info types for richer data\\ntype Store interface {\\n\\t// WriteTemporary writes a temporary checkpoint (full state) to a shadow branch.\\n\\t// Shadow branches are named entire/<base-commit-short-hash>.\\n\\t// Returns a result containing the commit hash and whether the checkpoint was skipped.\\n\\t// Checkpoints are skipped (deduplicated) when the tree hash matches the previous checkpoint.\\n\\tWriteTemporary(ctx context.Context, opts WriteTemporaryOptions) (WriteTemporaryResult, error)\\n\\n\\t// ReadTemporary reads the latest checkpoint from a shadow branch.\\n\\t// baseCommit is the commit hash the session is based on.\\n\\t// worktreeID is the internal git worktree identifier (empty for main worktree).\\n\\t// Returns nil, nil if the shadow branch doesn't exist.\\n\\tReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error)\\n\\n\\t// ListTemporary lists all shadow branches with their checkpoint info.\\n\\tListTemporary(ctx context.Context) ([]TemporaryInfo, error)\\n\\n\\t// WriteCommitted writes a committed checkpoint to the entire/checkpoints/v1 branch.\\n\\t// Checkpoints are stored at sharded paths: <id[:2]>/<id[2:]>/\\n\\tWriteCommitted(ctx context.Context, opts WriteCommittedOptions) error\\n\\n\\t// ReadCommitted reads a committed checkpoint's summary by ID.\\n\\t// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n\\t// Use ReadSessionContent to read actual transcript/prompts/context.\\n\\t// Returns nil, nil if the checkpoint does not exist.\\n\\tReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error)\\n\\n\\t// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n\\t// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n\\t// Returns the session's metadata, transcript, prompts, and context.\\n\\tReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error)\\n\\n\\t// ReadSessionContentByID reads a session's content by its session ID.\\n\\t// Useful when you have the session ID but don't know its index within the checkpoint.\\n\\tReadSessionContentByID(ctx context.Context, checkpointID id.CheckpointID, sessionID string) (*SessionContent, error)\\n\\n\\t// ListCommitted lists all committed checkpoints.\\n\\tListCommitted(ctx context.Context) ([]CommittedInfo, error)\\n\\n\\t// UpdateCommitted replaces the transcript, prompts, and context for an existing\\n\\t// committed checkpoint. Used at stop time to finalize checkpoints with the full\\n\\t// session transcript (prompt to stop event).\\n\\t// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n\\tUpdateCommitted(ctx context.Context, opts UpdateCommittedOptions) error\\n}\\n\\n// WriteTemporaryResult contains the result of writing a temporary checkpoint.\\ntype WriteTemporaryResult struct {\\n\\t// CommitHash is the hash of the created or existing checkpoint commit\\n\\tCommitHash plumbing.Hash\\n\\n\\t// Skipped is true if the checkpoint was skipped due to no changes\\n\\t// (tree hash matched the previous checkpoint)\\n\\tSkipped bool\\n}\\n\\n// WriteTemporaryOptions contains options for writing a temporary checkpoint.\\ntype WriteTemporaryOptions struct {\\n\\t// SessionID is the session identifier\\n\\tSessionID string\\n\\n\\t// BaseCommit is the commit hash this session is based on\\n\\tBaseCommit string\\n\\n\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n\\t// Used to create worktree-specific shadow branch names\\n\\tWorktreeID string\\n\\n\\t// ModifiedFiles are files that have been modified (relative paths)\\n\\tModifiedFiles []string\\n\\n\\t// NewFiles are files that have been created (relative paths)\\n\\tNewFiles []string\\n\\n\\t// DeletedFiles are files that have been deleted (relative paths)\\n\\tDeletedFiles []string\\n\\n\\t// MetadataDir is the relative path to the metadata directory\\n\\tMetadataDir string\\n\\n\\t// MetadataDirAbs is the absolute path to the metadata directory\\n\\tMetadataDirAbs string\\n\\n\\t// CommitMessage is the commit subject line\\n\\tCommitMessage string\\n\\n\\t// AuthorName is the name to use for commits\\n\\tAuthorName string\\n\\n\\t// AuthorEmail is the email to use for commits\\n\\tAuthorEmail string\\n\\n\\t// IsFirstCheckpoint indicates if this is the first checkpoint of the session\\n\\t// When true, all working directory files are captured (not just modified)\\n\\tIsFirstCheckpoint bool\\n}\\n\\n// ReadTemporaryResult contains the result of reading a temporary checkpoint.\\ntype ReadTemporaryResult struct {\\n\\t// CommitHash is the hash of the checkpoint commit\\n\\tCommitHash plumbing.Hash\\n\\n\\t// TreeHash is the hash of the tree containing the checkpoint state\\n\\tTreeHash plumbing.Hash\\n\\n\\t// SessionID is the session identifier from the commit trailer\\n\\tSessionID string\\n\\n\\t// MetadataDir is the metadata directory path from the commit trailer\\n\\tMetadataDir string\\n\\n\\t// Timestamp is when the checkpoint was created\\n\\tTimestamp time.Time\\n}\\n\\n// TemporaryInfo contains summary information about a shadow branch.\\ntype TemporaryInfo struct {\\n\\t// BranchName is the full branch name (e.g., \\\"entire/abc1234\\\")\\n\\tBranchName string\\n\\n\\t// BaseCommit is the short commit hash this branch is based on\\n\\tBaseCommit string\\n\\n\\t// LatestCommit is the hash of the latest commit on the branch\\n\\tLatestCommit plumbing.Hash\\n\\n\\t// SessionID is the session identifier from the latest commit\\n\\tSessionID string\\n\\n\\t// Timestamp is when the latest checkpoint was created\\n\\tTimestamp time.Time\\n}\\n\\n// WriteCommittedOptions contains options for writing a committed checkpoint.\\ntype WriteCommittedOptions struct {\\n\\t// CheckpointID is the stable 12-hex-char identifier\\n\\tCheckpointID id.CheckpointID\\n\\n\\t// SessionID is the session identifier\\n\\tSessionID string\\n\\n\\t// Strategy is the name of the strategy that created this checkpoint\\n\\tStrategy string\\n\\n\\t// Branch is the branch name where the checkpoint was created (empty if detached HEAD)\\n\\tBranch string\\n\\n\\t// Transcript is the session transcript content (full.jsonl)\\n\\tTranscript []byte\\n\\n\\t// Prompts contains user prompts from the session\\n\\tPrompts []string\\n\\n\\t// Context is the generated context.md content\\n\\tContext []byte\\n\\n\\t// FilesTouched are files modified during the session\\n\\tFilesTouched []string\\n\\n\\t// CheckpointsCount is the number of checkpoints in this session\\n\\tCheckpointsCount int\\n\\n\\t// EphemeralBranch is the shadow branch name (for manual-commit strategy)\\n\\tEphemeralBranch string\\n\\n\\t// AuthorName is the name to use for commits\\n\\tAuthorName string\\n\\n\\t// AuthorEmail is the email to use for commits\\n\\tAuthorEmail string\\n\\n\\t// MetadataDir is a directory containing additional metadata files to copy\\n\\t// If set, all files in this directory will be copied to the checkpoint path\\n\\t// This is useful for copying task metadata files, subagent transcripts, etc.\\n\\tMetadataDir string\\n\\n\\t// Task checkpoint fields (for task/subagent checkpoints)\\n\\tIsTask    bool   // Whether this is a task checkpoint\\n\\tToolUseID string // Tool use ID for task checkpoints\\n\\n\\t// Additional task checkpoint fields for subagent checkpoints\\n\\tAgentID                string // Subagent identifier\\n\\tCheckpointUUID         string // UUID for transcript truncation when rewinding\\n\\tTranscriptPath         string // Path to session transcript file (alternative to in-memory Transcript)\\n\\tSubagentTranscriptPath string // Path to subagent's transcript file\\n\\n\\t// Incremental checkpoint fields\\n\\tIsIncremental       bool   // Whether this is an incremental checkpoint\\n\\tIncrementalSequence int    // Checkpoint sequence number\\n\\tIncrementalType     string // Tool type that triggered this checkpoint\\n\\tIncrementalData     []byte // Tool input payload for this checkpoint\\n\\n\\t// Commit message fields (used for task checkpoints)\\n\\tCommitSubject string // Subject line for the metadata commit (overrides default)\\n\\n\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n\\tAgent types.AgentType\\n\\n\\t// TurnID correlates checkpoints from the same agent turn.\\n\\tTurnID string\\n\\n\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n\\tTranscriptIdentifierAtStart string // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n\\tCheckpointTranscriptStart   int    // Transcript line offset at start of this checkpoint's data\\n\\n\\t// CheckpointTranscriptStart is written to both CommittedMetadata.CheckpointTranscriptStart\\n\\t// and the deprecated CommittedMetadata.TranscriptLinesAtStart for backward compatibility.\\n\\n\\t// TokenUsage contains the token usage for this checkpoint\\n\\tTokenUsage *agent.TokenUsage\\n\\n\\t// InitialAttribution is line-level attribution calculated at commit time\\n\\t// comparing checkpoint tree (agent work) to committed tree (may include human edits)\\n\\tInitialAttribution *InitialAttribution\\n\\n\\t// Summary is an optional AI-generated summary for this checkpoint.\\n\\t// This field may be nil when:\\n\\t//   - summarization is disabled in settings\\n\\t//   - summary generation failed (non-blocking, logged as warning)\\n\\t//   - the transcript was empty or too short to summarize\\n\\t//   - the checkpoint predates the summarization feature\\n\\tSummary *Summary\\n}\\n\\n// UpdateCommittedOptions contains options for updating an existing committed checkpoint.\\n// Uses replace semantics: the transcript, prompts, and context are fully replaced,\\n// not appended. At stop time we have the complete session transcript and want every\\n// checkpoint to contain it identically.\\ntype UpdateCommittedOptions struct {\\n\\t// CheckpointID identifies the checkpoint to update\\n\\tCheckpointID id.CheckpointID\\n\\n\\t// SessionID identifies which session slot to update within the checkpoint\\n\\tSessionID string\\n\\n\\t// Transcript is the full session transcript (replaces existing)\\n\\tTranscript []byte\\n\\n\\t// Prompts contains all user prompts (replaces existing)\\n\\tPrompts []string\\n\\n\\t// Context is the updated context.md content (replaces existing)\\n\\tContext []byte\\n\\n\\t// Agent identifies the agent type (needed for transcript chunking)\\n\\tAgent types.AgentType\\n}\\n\\n// CommittedInfo contains summary information about a committed checkpoint.\\ntype CommittedInfo struct {\\n\\t// CheckpointID is the stable 12-hex-char identifier\\n\\tCheckpointID id.CheckpointID\\n\\n\\t// SessionID is the session identifier (most recent session for multi-session checkpoints)\\n\\tSessionID string\\n\\n\\t// CreatedAt is when the checkpoint was created\\n\\tCreatedAt time.Time\\n\\n\\t// CheckpointsCount is the total number of checkpoints across all sessions\\n\\tCheckpointsCount int\\n\\n\\t// FilesTouched are files modified during all sessions\\n\\tFilesTouched []string\\n\\n\\t// Agent identifies the agent that created this checkpoint\\n\\tAgent types.AgentType\\n\\n\\t// IsTask indicates if this is a task checkpoint\\n\\tIsTask bool\\n\\n\\t// ToolUseID is the tool use ID for task checkpoints\\n\\tToolUseID string\\n\\n\\t// Multi-session support\\n\\tSessionCount int      // Number of sessions (1 if single session)\\n\\tSessionIDs   []string // All session IDs that contributed\\n}\\n\\n// SessionContent contains the actual content for a session.\\n// This is used when reading full session data (transcript, prompts, context)\\n// as opposed to just the metadata/summary.\\ntype SessionContent struct {\\n\\t// Metadata contains the session-specific metadata\\n\\tMetadata CommittedMetadata\\n\\n\\t// Transcript is the session transcript content\\n\\tTranscript []byte\\n\\n\\t// Prompts contains user prompts from this session\\n\\tPrompts string\\n\\n\\t// Context is the context.md content\\n\\tContext string\\n}\\n\\n// CommittedMetadata contains the metadata stored in metadata.json for each checkpoint.\\ntype CommittedMetadata struct {\\n\\tCLIVersion       string          `json:\\\"cli_version,omitempty\\\"`\\n\\tCheckpointID     id.CheckpointID `json:\\\"checkpoint_id\\\"`\\n\\tSessionID        string          `json:\\\"session_id\\\"`\\n\\tStrategy         string          `json:\\\"strategy\\\"`\\n\\tCreatedAt        time.Time       `json:\\\"created_at\\\"`\\n\\tBranch           string          `json:\\\"branch,omitempty\\\"` // Branch where checkpoint was created (empty if detached HEAD)\\n\\tCheckpointsCount int             `json:\\\"checkpoints_count\\\"`\\n\\tFilesTouched     []string        `json:\\\"files_touched\\\"`\\n\\n\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n\\tAgent types.AgentType `json:\\\"agent,omitempty\\\"`\\n\\n\\t// TurnID correlates checkpoints from the same agent turn.\\n\\t// When a turn's work spans multiple commits, each gets its own checkpoint\\n\\t// but they share the same TurnID for future aggregation/deduplication.\\n\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n\\n\\t// Task checkpoint fields (only populated for task checkpoints)\\n\\tIsTask    bool   `json:\\\"is_task,omitempty\\\"`\\n\\tToolUseID string `json:\\\"tool_use_id,omitempty\\\"`\\n\\n\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"` // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n\\tCheckpointTranscriptStart   int    `json:\\\"checkpoint_transcript_start,omitempty\\\"`    // Transcript line offset at start of this checkpoint's data\\n\\n\\t// Deprecated: Use CheckpointTranscriptStart instead. Written for backward compatibility with older CLI versions.\\n\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n\\n\\t// Token usage for this checkpoint\\n\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n\\n\\t// AI-generated summary of the checkpoint\\n\\tSummary *Summary `json:\\\"summary,omitempty\\\"`\\n\\n\\t// InitialAttribution is line-level attribution calculated at commit time\\n\\tInitialAttribution *InitialAttribution `json:\\\"initial_attribution,omitempty\\\"`\\n}\\n\\n// GetTranscriptStart returns the transcript line offset at which this checkpoint's data begins.\\n// Returns 0 for new checkpoints (start from beginning). For data written by older CLI versions,\\n// falls back to the deprecated TranscriptLinesAtStart field.\\nfunc (m CommittedMetadata) GetTranscriptStart() int {\\n\\tif m.CheckpointTranscriptStart > 0 {\\n\\t\\treturn m.CheckpointTranscriptStart\\n\\t}\\n\\treturn m.TranscriptLinesAtStart\\n}\\n\\n// SessionFilePaths contains the absolute paths to session files from the git tree root.\\n// Paths include the full checkpoint path prefix (e.g., \\\"/a1/b2c3d4e5f6/1/metadata.json\\\").\\n// Used in CheckpointSummary.Sessions to map session IDs to their file locations.\\ntype SessionFilePaths struct {\\n\\tMetadata    string `json:\\\"metadata\\\"`\\n\\tTranscript  string `json:\\\"transcript\\\"`\\n\\tContext     string `json:\\\"context\\\"`\\n\\tContentHash string `json:\\\"content_hash\\\"`\\n\\tPrompt      string `json:\\\"prompt\\\"`\\n}\\n\\n// CheckpointSummary is the root-level metadata.json for a checkpoint.\\n// It contains aggregated statistics from all sessions and a map of session IDs\\n// to their file paths. Session-specific data (including initial_attribution)\\n// is stored in the session's subdirectory metadata.json.\\n//\\n// Structure on entire/checkpoints/v1 branch:\\n//\\n//\\t<checkpoint-id[:2]>/<checkpoint-id[2:]>/\\n//\\t├── metadata.json         # This CheckpointSummary\\n//\\t├── 1/                    # First session\\n//\\t│   ├── metadata.json     # Session-specific CommittedMetadata\\n//\\t│   ├── full.jsonl\\n//\\t│   ├── prompt.txt\\n//\\t│   ├── context.md\\n//\\t│   └── content_hash.txt\\n//\\t├── 2/                    # Second session\\n//\\t└── 3/                    # Third session...\\n//\\n//nolint:revive // Named CheckpointSummary to avoid conflict with existing Summary struct\\ntype CheckpointSummary struct {\\n\\tCLIVersion       string             `json:\\\"cli_version,omitempty\\\"`\\n\\tCheckpointID     id.CheckpointID    `json:\\\"checkpoint_id\\\"`\\n\\tStrategy         string             `json:\\\"strategy\\\"`\\n\\tBranch           string             `json:\\\"branch,omitempty\\\"`\\n\\tCheckpointsCount int                `json:\\\"checkpoints_count\\\"`\\n\\tFilesTouched     []string           `json:\\\"files_touched\\\"`\\n\\tSessions         []SessionFilePaths `json:\\\"sessions\\\"`\\n\\tTokenUsage       *agent.TokenUsage  `json:\\\"token_usage,omitempty\\\"`\\n}\\n\\n// Summary contains AI-generated summary of a checkpoint.\\ntype Summary struct {\\n\\tIntent    string           `json:\\\"intent\\\"`     // What user wanted to accomplish\\n\\tOutcome   string           `json:\\\"outcome\\\"`    // What was achieved\\n\\tLearnings LearningsSummary `json:\\\"learnings\\\"`  // Categorized learnings\\n\\tFriction  []string         `json:\\\"friction\\\"`   // Problems/annoyances encountered\\n\\tOpenItems []string         `json:\\\"open_items\\\"` // Tech debt, unfinished work\\n}\\n\\n// LearningsSummary contains learnings grouped by scope.\\ntype LearningsSummary struct {\\n\\tRepo     []string       `json:\\\"repo\\\"`     // Codebase-specific patterns/conventions\\n\\tCode     []CodeLearning `json:\\\"code\\\"`     // File/module specific findings\\n\\tWorkflow []string       `json:\\\"workflow\\\"` // General dev practices\\n}\\n\\n// CodeLearning captures a learning tied to a specific code location.\\ntype CodeLearning struct {\\n\\tPath    string `json:\\\"path\\\"`               // File path\\n\\tLine    int    `json:\\\"line,omitempty\\\"`     // Start line number\\n\\tEndLine int    `json:\\\"end_line,omitempty\\\"` // End line for ranges (optional)\\n\\tFinding string `json:\\\"finding\\\"`            // What was learned\\n}\\n\\n// InitialAttribution captures line-level attribution metrics at commit time.\\n// This is a point-in-time snapshot comparing the checkpoint tree (agent work)\\n// against the committed tree (may include human edits).\\n//\\n// Attribution Metrics:\\n//   - TotalCommitted measures \\\"net additions\\\" (lines added that remain in the commit)\\n//   - AgentPercentage represents \\\"of the new code added, what percentage came from the agent\\\"\\n//   - Deletion work is tracked separately in HumanRemoved (not included in percentage)\\n//\\n// Deletion-Only Commits:\\n// For commits with only deletions (no additions), TotalCommitted will be 0 and\\n// AgentPercentage will be 0. This is by design - the percentage metric is only\\n// meaningful for commits that add code. Deletion contributions are captured in\\n// the HumanRemoved field but don't affect the attribution percentage.\\ntype InitialAttribution struct {\\n\\tCalculatedAt    time.Time `json:\\\"calculated_at\\\"`\\n\\tAgentLines      int       `json:\\\"agent_lines\\\"`      // Lines added by agent (base → shadow diff)\\n\\tHumanAdded      int       `json:\\\"human_added\\\"`      // Lines added by human (excluding modifications)\\n\\tHumanModified   int       `json:\\\"human_modified\\\"`   // Lines modified by human (estimate: min(added, removed))\\n\\tHumanRemoved    int       `json:\\\"human_removed\\\"`    // Lines removed by human (excluding modifications)\\n\\tTotalCommitted  int       `json:\\\"total_committed\\\"`  // Net additions in commit (agent + human new lines, not total file size)\\n\\tAgentPercentage float64   `json:\\\"agent_percentage\\\"` // agent_lines / total_committed * 100 (0 for deletion-only commits)\\n}\\n\\n// Info provides summary information for listing checkpoints.\\n// This is the generic checkpoint info type.\\ntype Info struct {\\n\\t// ID is the checkpoint identifier\\n\\tID string\\n\\n\\t// SessionID identifies the session\\n\\tSessionID string\\n\\n\\t// Type indicates temporary or committed\\n\\tType Type\\n\\n\\t// CreatedAt is when the checkpoint was created\\n\\tCreatedAt time.Time\\n\\n\\t// Message is a summary description\\n\\tMessage string\\n}\\n\\n// WriteTemporaryTaskOptions contains options for writing a task checkpoint.\\n// Task checkpoints are created when a subagent completes and contain both\\n// code changes and task-specific metadata.\\ntype WriteTemporaryTaskOptions struct {\\n\\t// SessionID is the session identifier\\n\\tSessionID string\\n\\n\\t// BaseCommit is the commit hash this session is based on\\n\\tBaseCommit string\\n\\n\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n\\t// Used to create worktree-specific shadow branch names\\n\\tWorktreeID string\\n\\n\\t// ToolUseID is 