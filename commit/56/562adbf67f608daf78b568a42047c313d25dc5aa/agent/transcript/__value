n   847→// ReadLatestSessionContent is a convenience method that reads the latest session's content.\\n   848→// This is equivalent to ReadSessionContent(ctx, checkpointID, len(summary.Sessions)-1).\\n   849→func (s *GitStore) ReadLatestSessionContent(ctx context.Context, checkpointID id.CheckpointID) (*SessionContent, error) {\\n   850→\\tsummary, err := s.ReadCommitted(ctx, checkpointID)\\n   851→\\tif err != nil {\\n   852→\\t\\treturn nil, err\\n   853→\\t}\\n   854→\\tif summary == nil {\\n   855→\\t\\treturn nil, ErrCheckpointNotFound\\n   856→\\t}\\n   857→\\tif len(summary.Sessions) == 0 {\\n   858→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint has no sessions: %s\\\", checkpointID)\\n   859→\\t}\\n   860→\\n   861→\\tlatestIndex := len(summary.Sessions) - 1\\n   862→\\treturn s.ReadSessionContent(ctx, checkpointID, latestIndex)\\n   863→}\\n   864→\\n   865→// ReadSessionContentByID reads a session's content by its session ID.\\n   866→// This is useful when you have the session ID but don't know its index within the checkpoint.\\n   867→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   868→// Returns an error if no session with the given ID exists in the checkpoint.\\n   869→func (s *GitStore) ReadSessionContentByID(ctx context.Context, checkpointID id.CheckpointID, sessionID string) (*SessionContent, error) {\\n   870→\\tsummary, err := s.ReadCommitted(ctx, checkpointID)\\n   871→\\tif err != nil {\\n   872→\\t\\treturn nil, err\\n   873→\\t}\\n   874→\\tif summary == nil {\\n   875→\\t\\treturn nil, ErrCheckpointNotFound\\n   876→\\t}\\n   877→\\n   878→\\t// Iterate through sessions to find the one with matching session ID\\n   879→\\tfor i := range len(summary.Sessions) {\\n   880→\\t\\tcontent, readErr := s.ReadSessionContent(ctx, checkpointID, i)\\n   881→\\t\\tif readErr != nil {\\n   882→\\t\\t\\tcontinue\\n   883→\\t\\t}\\n   884→\\t\\tif content != nil && content.Metadata.SessionID == sessionID {\\n   885→\\t\\t\\treturn content, nil\\n   886→\\t\\t}\\n   887→\\t}\\n   888→\\n   889→\\treturn nil, fmt.Errorf(\\\"session %q not found in checkpoint %s\\\", sessionID, checkpointID)\\n   890→}\\n   891→\\n   892→// ListCommitted lists all committed checkpoints from the entire/checkpoints/v1 branch.\\n   893→// Scans sharded paths: <id[:2]>/<id[2:]>/ directories containing metadata.json.\\n   894→//\\n   895→\\n   896→func (s *GitStore) ListCommitted(ctx context.Context) ([]CommittedInfo, error) {\\n   897→\\tif err := ctx.Err(); err != nil {\\n   898→\\t\\treturn nil, err //nolint:wrapcheck // Propagating context cancellation\\n   899→\\t}\\n   900→\\n   901→\\ttree, err := s.getSessionsBranchTree()\\n   902→\\tif err != nil {\\n   903→\\t\\treturn []CommittedInfo{}, nil //nolint:nilerr // No sessions branch means empty list\\n   904→\\t}\\n   905→\\n   906→\\tvar checkpoints []CommittedInfo\\n   907→\\n   908→\\t// Scan sharded structure: <2-char-prefix>/<remaining-id>/metadata.json\\n   909→\\tfor _, bucketEntry := range tree.Entries {\\n   910→\\t\\tif bucketEntry.Mode != filemode.Dir {\\n   911→\\t\\t\\tcontinue\\n   912→\\t\\t}\\n   913→\\t\\t// Bucket should be 2 hex chars\\n   914→\\t\\tif len(bucketEntry.Name) != 2 {\\n   915→\\t\\t\\tcontinue\\n   916→\\t\\t}\\n   917→\\n   918→\\t\\tbucketTree, treeErr := s.repo.TreeObject(bucketEntry.Hash)\\n   919→\\t\\tif treeErr != nil {\\n   920→\\t\\t\\tcontinue\\n   921→\\t\\t}\\n   922→\\n   923→\\t\\t// Each entry in the bucket is the remaining part of the checkpoint ID\\n   924→\\t\\tfor _, checkpointEntry := range bucketTree.Entries {\\n   925→\\t\\t\\tif checkpointEntry.Mode != filemode.Dir {\\n   926→\\t\\t\\t\\tcontinue\\n   927→\\t\\t\\t}\\n   928→\\n   929→\\t\\t\\tcheckpointTree, cpTreeErr := s.repo.TreeObject(checkpointEntry.Hash)\\n   930→\\t\\t\\tif cpTreeErr != nil {\\n   931→\\t\\t\\t\\tcontinue\\n   932→\\t\\t\\t}\\n   933→\\n   934→\\t\\t\\t// Reconstruct checkpoint ID: <bucket><remaining>\\n   935→\\t\\t\\tcheckpointIDStr := 