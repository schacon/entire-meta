ed checkpoints for lookup\\n   938→\\tcommittedInfos, err := store.ListCommitted(ctx)\\n   939→\\tif err != nil {\\n   940→\\t\\tcommittedInfos = nil // Continue without committed checkpoints\\n   941→\\t}\\n   942→\\n   943→\\t// Build map of checkpoint ID -> committed info\\n   944→\\tcommittedByID := make(map[id.CheckpointID]checkpoint.CommittedInfo)\\n   945→\\tfor _, info := range committedInfos {\\n   946→\\t\\tif !info.CheckpointID.IsEmpty() {\\n   947→\\t\\t\\tcommittedByID[info.CheckpointID] = info\\n   948→\\t\\t}\\n   949→\\t}\\n   950→\\n   951→\\thead, err := repo.Head()\\n   952→\\tif err != nil {\\n   953→\\t\\t// Unborn HEAD (no commits yet) - return empty list instead of erroring\\n   954→\\t\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n   955→\\t\\t\\treturn []strategy.RewindPoint{}, nil\\n   956→\\t\\t}\\n   957→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   958→\\t}\\n   959→\\n   960→\\t// Check if we're on the default branch (needed for getReachableTemporaryCheckpoints)\\n   961→\\tisOnDefault, _ := strategy.IsOnDefaultBranch(repo)\\n   962→\\n   963→\\t// Fetch metadata branch tree once for reading session prompts (cheap tree lookups).\\n   964→\\t// This avoids calling ReadLatestSessionContent per checkpoint which reads+parses\\n   965→\\t// the full JSONL transcript — extremely slow with hundreds of checkpoints.\\n   966→\\tmetadataTree, _ := strategy.GetMetadataBranchTree(repo) //nolint:errcheck // Best-effort, continue without prompts\\n   967→\\n   968→\\tvar points []strategy.RewindPoint\\n   969→\\n   970→\\tcollectCheckpoint := func(c *object.Commit) {\\n   971→\\t\\tcpID, found := trailers.ParseCheckpoint(c.Message)\\n   972→\\t\\tif !found {\\n   973→\\t\\t\\treturn\\n   974→\\t\\t}\\n   975→\\t\\tcpInfo, found := committedByID[cpID]\\n   976→\\t\\tif !found {\\n   977→\\t\\t\\treturn\\n   978→\\t\\t}\\n   979→\\n   980→\\t\\tmessage := strings.Split(c.Message, \\\"\\\\n\\\")[0]\\n   981→\\t\\tpoint 