edEntries); err != nil {\\n   299→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten tip tree: %w\\\", err)\\n   300→\\t\\t}\\n   301→\\t\\tfor path, entry := range added {\\n   302→\\t\\t\\tmergedEntries[path] = entry\\n   303→\\t\\t}\\n   304→\\t\\tfor _, path := range deleted {\\n   305→\\t\\t\\tdelete(mergedEntries, path)\\n   306→\\t\\t}\\n   307→\\n   308→\\t\\tmergedTreeHash, err := checkpoint.BuildTreeFromEntries(repo, mergedEntries)\\n   309→\\t\\tif err != nil {\\n   310→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to build merged tree: %w\\\", err)\\n   311→\\t\\t}\\n   312→\\n   313→\\t\\t// Create new commit on top of current tip, preserving original message/author\\n   314→\\t\\tnewHash, err := createCherryPickCommit(repo, mergedTreeHash, currentTip, commit)\\n   315→\\t\\tif err != nil {\\n   316→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create cherry-pick commit: %w\\\", err)\\n   317→\\t\\t}\\n   318→\\n   319→\\t\\tcurrentTip = newHash\\n   320→\\t}\\n   321→\\n   322→\\treturn currentTip, nil\\n   323→}\\n   324→\\n   325→// createCherryPickCommit creates a new commit on top of parent, preserving the\\n   326→// original commit's message and author.\\n   327→func createCherryPickCommit(repo *git.Repository, treeHash, parent plumbing.Hash, original *object.Commit) (plumbing.Hash, error) {\\n   328→\\tcommitterName, committerEmail := GetGitAuthorFromRepo(repo)\\n   329→\\tnow := time.Now()\\n   330→\\n   331→\\tcommit := &object.Commit{\\n   332→\\t\\tTreeHash:     treeHash,\\n   333→\\t\\tParentHashes: []plumbing.Hash{parent},\\n   334→\\t\\tAuthor:       original.Author,\\n   335→\\t\\tCommitter: object.Signature{\\n   336→\\t\\t\\tName:  committerName,\\n   337→\\t\\t\\tEmail: committerEmail,\\n   338→\\t\\t\\tWhen:  now,\\n   339→\\t\\t},\\n   340→\\t\\tMessage: original.Message,\\n   341→\\t}\\n   342→\\n   343→\\tobj := repo.Storer.NewEncodedObject()\\n   344→\\tif err := commit.Encode(obj); err !