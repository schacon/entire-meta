6→\\t\\\"fmt\\\"\\n     7→\\t\\\"os\\\"\\n     8→\\t\\\"os/exec\\\"\\n     9→\\t\\\"sync\\\"\\n    10→\\t\\\"time\\\"\\n    11→\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    14→\\n    15→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    16→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    17→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    18→)\\n    19→\\n    20→// disconnectedOnce ensures the disconnection warning runs at most once per process.\\n    21→var disconnectedOnce sync.Once //nolint:gochecknoglobals // intentional per-process gate\\n    22→\\n    23→// IsMetadataDisconnected checks whether local and remote entire/checkpoints/v1\\n    24→// branches exist but share no common ancestor (the \\\"empty-orphan bug\\\").\\n    25→// Returns (false, nil) if either branch is missing, they point to the same hash,\\n    26→// or they share a common ancestor (normal divergence handled by push merge).\\n    27→// Returns (true, nil) only when both exist and are truly disconnected.\\n    28→func IsMetadataDisconnected(ctx context.Context, repo *git.Repository) (bool, error) {\\n    29→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n    30→\\tlocalRef, err := repo.Reference(refName, true)\\n    31→\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n    32→\\t\\treturn false, nil\\n    33→\\t}\\n    34→\\tif err != nil {\\n    35→\\t\\treturn false, fmt.Errorf(\\\"failed to check local metadata branch: %w\\\", err)\\n    36→\\t}\\n    37→\\n    38→\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n    39→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n    40→\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n    41→\\t\\treturn false, nil\\n    42→\\t}\\n    43→\\tif err != nil {\\n    44→\\t\\treturn false, fmt.Errorf(\\\"failed to check remote metadata branch: %w\\\", err)\\n    45→\\t}\\n    46→\\n    47→\\tif localRef.Hash() == remoteRef.Hash() {\\n    48→\\t\\treturn false, nil\\n    49→\\t}\\n    50→\\n    51→\\trepoPath, err := getRepoPath(repo)\\n    52→\\tif err != nil {\\n    53→\\t\\treturn false, err\\n    54→\\t}\\n    55→\\n    56→\\treturn isDisconnected(ctx, repoPath, localRef.Hash().String(), remoteRef.Hash().String())\\n    57→}\\n    58→\\n    59→// WarnIfMetadataDisconnected checks (once per process) whether the metadata\\n    60→// branch is disconnected and prints a warning to stderr if so.\\n    61→// It does NOT fix the problem — users are directed to 'entire doctor'.\\n    62→func WarnIfMetadataDisconnected() {\\n    63→\\tdisconnectedOnce.Do(func() {\\n    64→\\t\\tctx := context.Background()\\n    65→\\t\\trepo, err := OpenRepository(ctx)\\n    66→\\t\\tif err != nil {\\n    67→\\t\\t\\treturn\\n    68→\\t\\t}\\n    69→\\t\\tdisconnected, err := IsMetadataDisconnected(ctx, repo)\\n    70→\\t\\tif err != nil || !disconnected {\\n    71→\\t\\t\\treturn\\n    72→\\t\\t}\\n    73→\\t\\tfmt.Fprintln(os.Stderr, \\\"[entire] Warning: Local and remote session metadata branches are disconnected.\\\")\\n    74→\\t\\tfmt.Fprintln(os.Stderr, \\\"[entire] Some checkpoints from remote may not be visible. Run 'entire doctor' to fix.\\\")\\n    75→\\t})\\n    76→}\\n    77→\\n    78→// ReconcileDisconnectedMetadataBranch detects and repairs disconnected local/remote\\n    79→// entire/checkpoints/v1 branches. Disconnected means no common ancestor, which\\n    80→// only happens due to the empty-orphan bug. Diverged (shared ancestor) is normal\\n    81→// and handled by the push path's tree merge.\\n    82→//\\n    83→// Repair strategy: cherry-pick local commits onto remote tip, preserving all data.\\n    84→// Checkpoint shards use unique paths (<id[:2]>/<id[2:]>/), so cherry-picks always\\n    85→// apply cleanly.\\n    86→func ReconcileDisconnectedMetadataBranch(ctx context.Context, repo *git.Repository) error {\\n    87→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n    88→\\n    89→\\t// Check local branch\\n    90→\\tlocalRef, err := repo.Reference(refName, true)\\n    91→\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n    92→\\t\\treturn nil // No local branch — nothing to reconcile\\n    93→\\t}\\n    94→\\tif err != nil {\\n    95→\\t\\treturn fmt.Errorf(\\\"failed to check local metadata branch: %w\\\", err)\\n    96→\\t}\\n    97→\\n    98→\\t// Check remote-tracking branch\\n    99→\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n   100→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n   101→\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n   102→\\t\\treturn nil // No remote branch — nothing to reconcile\\n   103→\\t}\\n   104→\\tif err != nil {\\n   105→\\t\\treturn fmt.Errorf(\\\"failed to check remote metadata branch: %w\\\", err)\\n   106→\\t}\\n   107→\\n   108→\\tlocalHash := localRef.Hash()\\n   109→\\tremoteHash := remoteRef.Hash()\\n   110→\\n   111→\\t// Same hash — nothing to do\\n   112→\\tif localHash == remoteHash {\\n   113→\\t\\treturn nil\\n   114→\\t}\\n   115→\\n   116→\\t// Check if disconnected using git merge-base\\n   117→\\trepoPath, err := getRepoPath(repo)\\n   118→\\tif err != nil {\\n   119→\\t\\treturn err\\n   120→\\t}\\n   121→\\n   122→\\tdisconnected, err := isDisconnected(ctx, repoPath, localHash.String(), remoteHash.String())\\n   123→\\tif err != nil {\\n   124→\\t\\treturn fmt.Errorf(\\\"failed to check metadata branch ancestry: %w\\\", err)\\n   125→\\t}\\n   126→\\tif !disconnected {\\n   127→\\t\\t// Shared ancestry (diverged or ancestor) — not our problem\\n   128→\\t\\treturn nil\\n   129→\\t}\\n   130→\\n   131→\\t// Disconnected — cherry-pick local commits onto remote tip\\n   132→\\tfmt.Fprintln(os.Stderr, \\\"[entire] Detected disconnected session metadata (local and remote share no common ancestor)\\\")\\n   133→\\n   134→\\t// Collect local commits oldest-first\\n   135→\\tlocalCommits, err := collectCommitChain(repo, localHash)\\n   136→\\tif err != nil {\\n   137→\\t\\treturn fmt.Errorf(\\\"failed to collect local commits: %w\\\", err)\\n   138→\\t}\\n   139→\\n   140→\\t// Filter out empty-tree commits (the orphan bug commit)\\n   141→\\tvar dataCommits []*object.Commit\\n   142→\\tfor _, c := range localCommits {\\n   143→\\t\\ttree, treeErr := c.Tree()\\n   144→\\t\\tif treeErr != nil {\\n   145→\\t\\t\\treturn fmt.Errorf(\\\"failed to read tree for commit %s: %w\\\", c.Hash.String()[:7], treeErr)\\n   146→\\t\\t}\\n   147→\\t\\tif len(tree.Entries) > 0 {\\n   148→\\t\\t\\tdataCommits = append(dataCommits, c)\\n   149→\\t\\t}\\n   150→\\t}\\n   151→\\n   152→\\tif len(dataCommits) == 0 {\\n   153→\\t\\t// Local only had empty orphan — just point to remote\\n   154→\\t\\tref := plumbing.NewHashReference(refName, remoteHash)\\n   155→\\t\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   156→\\t\\t\\treturn fmt.Errorf(\\\"failed to reset metadata branch to remote: %w\\\", err)\\n   157→\\t\\t}\\n   158→\\t\\tfmt.Fprintln(os.Stderr, \\\"[entire] Done — local had no checkpoint data, reset to remote\\\")\\n   159→\\t\\treturn nil\\n   160→\\t}\\n   161→\\n   162→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Cherry-picking %d local checkpoint(s) onto remote...\\\\n\\\", len(dataCommits))\\n   163→\\n   164→\\tnewTip, err := cherryPickOnto(repo, remoteHash, dataCommits)\\n   165→\\tif err != nil {\\n   166→\\t\\treturn fmt.Errorf(\\\"failed to cherry-pick local commits onto remote: %w\\\", err)\\n   167→\\t}\\n   168→\\n   169→\\t// Update local branch ref\\n   170→\\tref := plumbing.NewHashReference(refName, newTip)\\n   171→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   172→\\t\\treturn fmt.Errorf(\\\"failed to update metadata branch: %w\\\", err)\\n   173→\\t}\\n   174→\\n   175→\\tfmt.Fprintln(os.Stderr, \\\"[entire] Done — all local and remote checkpoints preserved\\\")\\n   176→\\treturn nil\\n   177→}\\n   178→\\n   179→// isDisconnected checks if two commits have no common ancestor using git merge-base.\\n   180→// Returns (true, nil) if disconnected, (false, nil) if they share ancestry,\\n   181→// or (false, error) if git merge-base failed for another reason.\\n   182→//\\n   183→// git merge-base exit codes:\\n   184→//   - 0: common ancestor found (shared ancestry)\\n   185→//   - 1: no common ancestor (disconnected)\\n   186→//   - 128+: error (corrupt repo, invalid hash, etc.)\\n   187→func isDisconnected(ctx context.Context, repoPath, hashA, hashB string) (bool, error) {\\n   188→\\tctx, cancel := context.WithTimeout(ctx, 10*time.Second)\\n   189→\\tdefer cancel()\\n   190→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"merge-base\\\", hashA, hashB)\\n   191→\\tcmd.Dir = repoPath\\n   192→\\tif err := cmd.Run(); err != nil {\\n   193→\\t\\tvar exitErr *exec.ExitError\\n   194→\\t\\tif errors.As(err, &exitErr) && exitErr.ExitCode() == 1 {\\n   195→\\t\\t\\treturn true, nil // No common ancestor — disconnected\\n   196→\\t\\t}\\n   197→\\t\\treturn false, fmt.Errorf(\\\"git merge-base failed: %w\\\", err)\\n   198→\\t}\\n   199→\\treturn false, nil // Shared ancestry\\n   200→}\\n   201→\\n   202→// collectCommitChain walks from tip to root following first parent, returns oldest-first.\\n   203→func collectCommitChain(repo *git.Repository, tip plumbing.Hash) ([]*object.Commit, error) {\\n   204→\\tvar chain []*object.Commit\\n   205→\\tcurrent := tip\\n   206→\\n   207→\\treachedRoot := false\\n   208→\\tfor range MaxCommitTraversalDepth {\\n   209→\\t\\tcommit, err := repo.CommitObject(current)\\n   210→\\t\\tif err != nil {\\n   211→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit %s: %w\\\", current, err)\\n   212→\\t\\t}\\n   213→\\t\\tchain = append(chain, commit)\\n   214→\\n   215→\\t\\tif len(commit.ParentHashes) == 0 {\\n   216→\\t\\t\\treachedRoot = true\\n   217→\\t\\t\\tbreak\\n   218→\\t\\t}\\n   219→\\t\\tcurrent = commit.ParentHashes[0]\\n   220→\\t}\\n   221→\\n   222→\\tif !reachedRoot {\\n   223→\\t\\treturn nil, fmt.Errorf(\\\"commit chain exceeded %d commits without reaching root; aborting reconciliation\\\", MaxCommitTraversalDepth)\\n   224→\\t}\\n   225→\\n   226→\\t// Reverse to oldest-first\\n   227→\\tfor i, j := 0, len(chain)-1; i < j; i, j = i+1, j-1 {\\n   228→\\t\\tchain[i], chain[j] = chain[j], chain[i]\\n   229→\\t}\\n   230→\\n   231→\\treturn chain, nil\\n   232→}\\n   233→\\n   234→// cherryPickOnto applies each commit's delta onto base, building a linear chain.\\n   235→// For each commit, it computes the full diff from its parent (additions, modifications,\\n   236→// and deletions), then applies that delta onto the current tip's tree.\\n   237→func cherryPickOnto(repo *git.Repository, base plumbing.Hash, commits []*object.Commit) (plumbing.Hash, error) {\\n   238→\\tcurrentTip := base\\n   239→\\n   240→\\tfor _, commit := range commits {\\n   241→\\t\\t// Get the commit's tree entries\\n   242→\\t\\tcommitTree, err := commit.Tree()\\n   243→\\t\\tif err != nil {\\n   244→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get tree for commit %s: %w\\\", commit.Hash, err)\\n   245→\\t\\t}\\n   246→\\n   247→\\t\\tcommitEntries := make(map[string]object.TreeEntry)\\n   248→\\t\\tif err := checkpoint.FlattenTree(repo, commitTree, \\\"\\\", commitEntries); err != nil {\\n   249→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten commit tree: %w\\\", err)\\n   250→\\t\\t}\\n   251→\\n   252→\\t\\t// Get parent's tree entries (empty if root commit)\\n   253→\\t\\tparentEntries := make(map[string]object.TreeEntry)\\n   254→\\t\\tif len(commit.ParentHashes) > 0 {\\n   255→\\t\\t\\tparentCommit, pErr := repo.CommitObject(commit.ParentHashes[0])\\n   256→\\t\\t\\tif pErr != nil {\\n   257→\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get parent commit %s: %w\\\", commit.ParentHashes[0], pErr)\\n   258→\\