 10→\\t\\\"strings\\\"\\n    11→\\t\\\"time\\\"\\n    12→\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    15→\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n    19→\\n    20→\\t\\\"github.com/charmbracelet/huh\\\"\\n    21→\\t\\\"github.com/go-git/go-git/v6\\\"\\n    22→\\t\\\"github.com/go-git/go-git/v6/plumbing\\\"\\n    23→\\t\\\"github.com/go-git/go-git/v6/plumbing/filemode\\\"\\n    24→\\t\\\"github.com/go-git/go-git/v6/plumbing/object\\\"\\n    25→)\\n    26→\\n    27→// GetRewindPoints returns available rewind points.\\n    28→// Uses checkpoint.GitStore.ListTemporaryCheckpoints for reading from shadow branches.\\n    29→func (s *ManualCommitStrategy) GetRewindPoints(ctx context.Context, limit int) ([]RewindPoint, error) {\\n    30→\\trepo, err := OpenRepository(ctx)\\n    31→\\tif err != nil {\\n    32→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n    33→\\t}\\n    34→\\n    35→\\t// Get checkpoint store\\n    36→\\tstore, err := s.getCheckpointStore()\\n    37→\\tif err != nil {\\n    38→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    39→\\t}\\n    40→\\n    41→\\t// Get current HEAD to find matching shadow branch\\n    42→\\thead, err := repo.Head()\\n    43→\\tif err != nil {\\n    44→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n    45→\\t}\\n    46→\\n    47→\\t// Find sessions for current HEAD\\n    48→\\tsessions, err := s.findSessionsForCommit(ctx, head.Hash().String())\\n    49→\\tif err != nil {\\n    50→\\t\\t// Log error but continue to check for logs-only points\\n    51→\\t\\tsessions = nil\\n    52→\\t}\\n    53→\\n    54→\\tvar allPoints []RewindPoint\\n    55→\\n    56→\\t// Collect checkpoint points from active sessions using checkpoint.GitStore\\n    57→\\t// Cache session prompts by session ID to avoid re-reading the same prompt file\\n    58→\\tsessionPrompts := make(map[string]string)\\n    59→\\n    60→\\tfor _, state := range sessions {\\n    61→\\t\\tcheckpoints, err := store.ListTemporaryCheckpoints(ctx, state.BaseCommit, state.WorktreeID, state.SessionID, limit)\\n    62→\\t\\tif err != nil {\\n    63→\\t\\t\\tcontinue // Error reading checkpoints, skip this session\\n    64→\\t\\t}\\n    65→\\n    66→\\t\\tfor _, cp := range checkpoints {\\n    67→\\t\\t\\t// Get session prompt (cached by session ID)\\n    68→\\t\\t\\tsessionPrompt, ok := sessionPrompts[cp.SessionID]\\n    69→\\t\\t\\tif !ok {\\n    70→\\t\\t\\t\\tsessionPrompt = readSessionPrompt(repo, cp.CommitHash, cp.MetadataDir)\\n    71→\\t\\t\\t\\tsessionPrompts[cp.SessionID] = sessionPrompt\\n    72→\\t\\t\\t}\\n    73→\\n    74→\\t\\t\\tallPoints = append(allPoints, RewindPoint{\\n    75→\\t\\t\\t\\tID:               cp.CommitHash.String(),\\n    76→\\t\\t\\t\\tMessage:          cp.Message,\\n    77→\\t\\t\\t\\tMetadataDir:      cp.MetadataDir,\\n    78→\\t\\t\\t\\tDate:             cp.Timestamp,\\n    79→\\t\\t\\t\\tIsTaskCheckpoint: cp.IsTaskCheckpoint,\\n    80→\\t\\t\\t\\tToolUseID:        cp.ToolUseID,\\n    81→\\t\\t\\t\\tSessionID:        cp.SessionID,\\n    82→\\t\\t\\t\\tSessionPrompt:    sessionPrompt,\\n    83→\\t\\t\\t\\tAgent:            state.AgentType,\\n    84→\\t\\t\\t})\\n    85→\\t\\t}\\n    86→\\t}\\n    87→\\n    88→\\t// Sort by date, most recent first\\n    89→\\tsort.Slice(allPoints, func(i, j int) bool {\\n    90→\\t\\treturn allPoints[i].Date.After(allPoints[j].Date)\\n    91→\\t})\\n    92→\\n    93→\\tif len(allPoints) > limit {\\n    94→\\t\\tallPoints = allPoints[:limit]\\n    95→\\t}\\n    96→\\n    97→\\t// Also include logs-only points from commit history\\n    98→\\tlogsOnlyPoints, err := s.GetLogsOnlyRewindPoints(ctx, limit)\\n    99→\\tif err == nil && len(logsOnlyPoints) > 0 {\\n   100→\\t\\t// Build set of existing point IDs for deduplication\\n   101→\\t\\texistingIDs := make(map[string]bool)\\n   102→\\t\\tfor _, p := range allPoints {\\n   103→\\t\\t\\texistingIDs[p.ID] = true\\n   104→\\t\\t}\\n   105→\\n   106→\\t\\t// Add logs-only points that aren't already in the list\\n   107→\\t\\tfor _, p := range logsOnlyPoints {\\n   108→\\t\\t\\tif !existingIDs[p.ID] {\\n   109→\\t\\t\\t\\tallPoints = append(allPoints, p)\\n   110→\\t\\t\\t}\\n   111→\\t\\t}\\n   112→\\n   113→\\t\\t// Re-sort by date\\n   114→\\t\\tsort.Slice(allPoints, func(i, j int) bool {\\n   115→\\t\\t\\treturn allPoints[i].Date.After(allPoints[j].Date)\\n   116→\\t\\t})\\n   117→\\n   118→\\t\\t// Re-trim to limit\\n   119→\\t\\tif len(allPoints) > limit {\\n   120→\\t\\t\\tallPoints = allPoints[:limit]\\n   121→\\t\\t}\\n   122→\\t}\\n   123→\\n   124→\\treturn allPoints, nil\\n   125→}\\n   126→\\n   127→// GetLogsOnlyRewindPoints finds commits in the current branch's history that have\\n   128→// condensed session logs on the entire/checkpoints/v1 branch. These are commits that\\n   129→// were created with session data but the shadow branch has been condensed.\\n   130→//\\n   131→// The function works by:\\n   132→// 1. Getting all checkpoints from the entire/checkpoints/v1 branch\\n   133→// 2. Building a map of checkpoint ID -> checkpoint info\\n   134→// 3. Scanning the current branch history for commits with Entire-Checkpoint trailers\\n   135→// 4. Matching by checkpoint ID (stable across amend/rebase)\\n   136→func (s *ManualCommitStrategy) GetLogsOnlyRewindPoints(ctx context.Context, limit int) ([]RewindPoint, error) {\\n   137→\\trepo, err := OpenRepository(ctx)\\n   138→\\tif err != nil {\\n   139→\\t\\treturn nil, err\\n   140→\\t}\\n   141→\\n   142→\\t// Get all checkpoints from entire/checkpoints/v1 branch\\n   143→\\tcheckpoints, err := s.listCheckpoints(ctx)\\n   144→\\tif err != nil {\\n   145→\\t\\t// No checkpoints yet is fine\\n   146→\\t\\treturn nil, nil //nolint:nilerr // Expected when no checkpoints exist\\n   147→\\t}\\n   148→\\n   149→\\tif len(checkpoints) == 0 {\\n   150→\\t\\treturn nil, nil\\n   151→\\t}\\n   152→\\n   153→\\t// Build map of checkpoint ID -> checkpoint info\\n   154→\\t// Checkpoint ID is the stable link from Entire-Checkpoint trailer\\n   155→\\tcheckpointInfoMap := make(map[id.CheckpointID]CheckpointInfo)\\n   156→\\tfor _, cp := range checkpoints {\\n   157→\\t\\tif !cp.CheckpointID.IsEmpty() {\\n   158→\\t\\t\\tcheckpointInfoMap[cp.CheckpointID] = cp\\n   159→\\t\\t}\\n   160→\\t}\\n   161→\\n   162→\\t// Get metadata branch tree for reading session prompts (best-effort, ignore errors)\\n   163→\\tmetadataTree, _ := GetMetadataBranchTree(repo) //nolint:errcheck // Best-effort for session prompts\\n   164→\\n   165→\\thead, err := repo.Head()\\n   166→\\tif err != nil {\\n   167→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   168→\\t}\\n   169→\\n   170→\\t// Use LogOptions with Order=LogOrderCommitterTime to traverse all parents of merge commits.\\n   171→\\titer, err := repo.Log(&git.LogOptions{\\n   172→\\t\\tFrom:  head.Hash(),\\n   173→\\t\\tOrder: git.LogOrderCommitterTime,\\n   174→\\t})\\n   175→\\tif err != nil {\\n   176→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   177→\\t}\\n   178→\\n   179→\\tvar points []RewindPoint\\n   180→\\tcount := 0\\n   181→\\n   182→\\terr = iter.ForEach(func(c *object.Commit) error {\\n   183→\\t\\tif err := ctx.Err(); err != nil {\\n   184→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   185→\\t\\t}\\n   186→\\t\\tif count >= logsOnlyScanLimit {\\n   187→\\t\\t\\treturn errStop\\n   188→\\t\\t}\\n   189→\\t\\tcount++\\n   190→\\n   191→\\t\\t// Extract all checkpoint IDs from Entire-Checkpoint trailers.\\n   192→\\t\\t// Squash merge commits may contain multiple trailers from the original commits.\\n   193→\\t\\tallCpIDs := trailers.ParseAllCheckpoints(c.Message)\\n   194→\\t\\tif len(allCpIDs) == 0 {\\n   195→\\t\\t\\treturn nil\\n   196→\\t\\t}\\n   197→\\n   198→\\t\\t// Resolve to the latest checkpoint by creation time (consistent with `entire resume`).\\n   199→\\t\\tcpInfo, found := ResolveLatestCheckpointFromMap(allCpIDs, checkpointInfoMap)\\n   200→\\t\\tif !found {\\n   201→\\t\\t\\treturn nil\\n   202→\\t\\t}\\n   203→\\n   204→\\t\\t// Create logs-only rewind point\\n   205→\\t\\tmessage := strings.Split(c.Message, \\\"\\\\n\\\")[0]\\n   206→\\n   207→\\t\\t// Read session prompts from metadata tree\\n   208→\\t\\tvar sessionPrompt string\\n   209→\\t\\tvar sessionPrompts []string\\n   210→\\t\\tif metadataTree != nil {\\n   211→\\t\\t\\tcheckpointPath := paths.CheckpointPath(cpInfo.CheckpointID) //nolint:staticcheck // already present in codebase\\n   212→\\t\\t\\t// For multi-session checkpoints, read all prompts\\n   213→\\t\\t\\tif cpInfo.SessionCount > 1 && len(cpInfo.SessionIDs) > 1 {\\n   214→\\t\\t\\t\\tsessionPrompts = ReadAllSessionPromptsFromTree(metadataTree, checkpointPath, cpInfo.SessionCount, cpInfo.SessionIDs)\\n   215→\\t\\t\\t\\t// Use the last (most recent) prompt as the main session prompt\\n   216→\\t\\t\\t\\tif len(sessionPrompts) > 0 {\\n   217→\\t\\t\\t\\t\\tsessionPrompt = sessionPrompts[len(sessionPrompts)-1]\\n   218→\\t\\t\\t\\t}\\n   219→\\t\\t\\t} else {\\n   220→\\t\\t\\t\\tsessionPrompt = ReadSessionPromptFromTree(metadataTree, checkpointPath)\\n   221→\\t\\t\\t\\tif sessionPrompt != \\\"\\\" {\\n   222→\\t\\t\\t\\t\\tsessionPrompts = []string{sessionPrompt}\\n   223→\\t\\t\\t\\t}\\n   224→\\t\\t\\t}\\n   225→\\t\\t}\\n   226→\\n   227→\\t\\tpoints = append(points, RewindPoint{\\n   228→\\t\\t\\tID:             c.Hash.String(),\\n   229→\\t\\t\\tMessage:        message,\\n   230→\\t\\t\\tDate:           c.Author.When,\\n   231→\\t\\t\\tIsLogsOnly:     true,\\n   232→\\t\\t\\tCheckpointID:   cpInfo.CheckpointID,\\n   233→\\t\\t\\tAgent:          cpInfo.Agent,\\n   234→\\t\\t\\tSessionID:      cpInfo.SessionID,\\n   235→\\t\\t\\tSessionPrompt:  sessionPrompt,\\n   236→\\t\\t\\tSessionCount:   cpInfo.SessionCount,\\n   237→\\t\\t\\tSessionIDs:     cpInfo.SessionIDs,\\n   238→\\t\\t\\tSessionPrompts: sessionPrompts,\\n   239→\\t\\t})\\n   240→\\n   241→\\t\\treturn nil\\n   242→\\t})\\n   243→\\n   244→\\tif err != nil && !errors.Is(err, errStop) {\\n   245→\\t\\treturn nil, fmt.Errorf(\\\"error iterating commits: %w\\\", err)\\n   246→\\t}\\n   247→\\n   248→\\tif len(points) > limit {\\n   249→\\t\\tpoints = points[:limit]\\n   250→\\t}\\n   251→\\n   252→\\treturn points, nil\\n   253→}\\n   254→\\n   255→// ResolveLatestCheckpointFromMap picks the checkpoint with the latest CreatedAt\\n   256→// from a list of checkpoint IDs. Filters to IDs present in infoMap, then picks\\n   257→// the one with the most recent CreatedAt.\\n   258→func ResolveLatestCheckpointFromMap(cpIDs []id.CheckpointID, infoMap map[id.CheckpointID]CheckpointInfo) (CheckpointInfo, bool) {\\n   259→\\tvar found bool\\n   260→\\tvar latest CheckpointInfo\\n   261→\\tfor _, cpID := range cpIDs {\\n   262→\\t\\tinfo, ok := infoMap[cpID]\\n   263→\\t\\tif !ok {\\n   264→\\t\\t\\tcontinue\\n   265→\\t\\t}\\n   266→\\t\\tif !found || info.CreatedAt.After(latest.CreatedAt) {\\n   267→\\t\\t\\tlatest = info\\n   268→\\t\\t\\tfound = true\\n   269→\\t\\t}\\n   270→\\t}\\n   271→\\treturn latest, found\\n   272→}\\n   273→\\n   274→// Rewind restores the working directory to a checkpoint.\\n   275→//\\n   276→\\n   277→func (s *ManualCommitStrategy) Rewind(ctx context.Context, point RewindPoint) error {\\n   278→\\trepo, err := OpenRepository(ctx)\\n   279→\\tif err != nil {\\n   280→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   281→\\t}\\n   282→\\n   283→\\t// Get the checkpoint commit\\n   284→\\tcommitHash := plumbing.NewHash(point.ID)\\n   285→\\tcommit, err := repo.CommitObject(commitHash)\\n   286→\\tif err != nil {\\n   287→\\t\\treturn fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   288→\\t}\\n   289→\\n   290→\\ttree, err := commit.Tree()\\n   291→\\tif err != nil {\\n   292→\\t\\treturn fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n   293→\\t}\\n   294→\\n   295→\\t// Reset the shadow branch to the rewound checkpoint\\n   296→\\t// This ensures the next checkpoint will only include prompts from this point forward\\n   297→\\tif err := s.resetShadowBranchToCheckpoint(ctx, repo, commit); err != nil {\\n   298→\\t\\t// Log warning but don't fail - file restoration is the primary operation\\n   299→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to reset shadow branch: %v\\\\n\\\", err)\\n   300→\\t}\\n   301→\\n   302→\\t// Load session state to get untracked files that existed at session start\\n   303→\\tsessionID, hasSessionTrailer := trailers.ParseSession(commit.Message)\\n   304→\\tvar preservedUntrackedFiles map[string]bool\\n   305→\\tif hasSessionTrailer {\\n   306→\\t\\tstate, stateErr := s.loadSessionState(ctx, sessionID)\\n   307→\\t\\tif stateErr == nil && state != nil && len(state.UntrackedFilesAtStart) > 0 {\\n   308→\\t\\t\\tpreservedUntrackedFiles = make(map[string]bool)\\n   309→\\t\\t\\tfor _, f := range state.UntrackedFilesAtStart {\\n   310→\\t\\t\\t\\tpreservedUntrackedFiles[f] = true\\n   311→\\t\\t\\t}\\n   312→\\t\\t}\\n   313→\\t}\\n   314→\\n   315→\\t// Build set of files in the checkpoint tree (excluding metadata)\\n   316→\\tcheckpointFiles := make(map[string]bool)\\n   317→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   318→\\t\\tif err := ctx.Err(); err != nil {\\n   319→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   320→\\t\\t}\\n   321→\\t\\tif !strings.HasPrefix(f.Name, entireDir) {\\n   322→\\t\\t\\tcheckpointFiles[f.Name] = true\\n   323→\\t\\t}\\n   324→\\t\\treturn nil\\n   325→\\t})\\n   326→\\tif err != nil {\\n   327→\\t\\treturn fmt.Errorf(\\\"failed to list checkpoint files: %w\\\", err)\\n   328→\\t}\\n   329→\\n   330→\\t// Get HEAD tree to identify tracked files\\n   331→\\thead, err := repo.Head()\\n   332→\\tif err != nil {\\n   333→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   334→\\t}\\n   335→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   336→\\tif err != nil {\\n   337→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   338→\\t}\\n   339→\\theadTree, err := headCommit.Tree()\\n   340→\\tif err != nil {\\n   341→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD tree: %w\\\", err)\\n   342→\\t}\\n   343→\\n   344→\\t// Build set of files tracked in HEAD\\n   345→\\ttrackedFiles := make(map[string]bool)\\n   346→\\t//nolint:errcheck // Error is not critical for rewind\\n   347→\\t_ = headTree.Files().ForEach(func(f *object.File) error {\\n   348→\\t\\tif err := ctx.Err(); err != nil {\\n   349→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   350→\\t\\t}\\n   351→\\t\\ttrackedFiles[f.Name] = true\\n   352→\\t\\treturn nil\\n   353→\\t})\\n   354→\\n   355→\\t// Get repository root to walk from there\\n   356→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   357→\\tif err != nil {\\n   358→\\t\\trepoRoot = \\\".\\\" // Fallback to current directory\\n   359→\\t}\\n   360→\\n   361→\\t// Find and delete untracked files that aren't in the checkpoint.\\n   362→\\t// Uses git ls-files to only consider non-ignored files, avoiding walks through\\n   363→\\t// large ignored directories like node_modules/.\\n   364→\\tuntrackedNow, err := collectUntrackedFiles(ctx)\\n   365→\\tif err != nil {\\n   366→\\t\\t// Non-fatal - continue with restoration\\n   367→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: error listing untracked files: %v\\\\n\\\", err)\\n   368→\\t}\\n   369→\\tfor _, relPath := range untrackedNow {\\n   370→\\t\\t// If file is in checkpoint, it will be restored\\n   371→\\t\\tif checkpointFiles[relPath] {\\n   372→\\t\\t\\tcontinue\\n   373→\\t\\t}\\n   374→\\n   375→\\t\\t// If file is tracked in HEAD, don't delete (user's committed work)\\n   376→\\t\\tif trackedFiles[relPath] {\\n   377→\\t\\t\\tcontinue\\n   378→\\t\\t}\\n   379→\\n   380→\\t\\t// If file existed at session start, preserve it (untracked user files)\\n   381→\\t\\tif preservedUntrackedFiles[relPath] {\\n   382→\\t\\t\\tcontinue\\n   383→\\t\\t}\\n   384→\\n   385→\\t\\t// File is untracked and not in checkpoint - delete it\\n   386→\\t\\tabsPath := filepath.Join(repoRoot, relPath)\\n   387→\\t\\tif removeErr := os.Remove(absPath); removeErr == nil {\\n   388→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Deleted: %s\\\\n\\\", relPath)\\n   389→\\t\\t}\\n   390→\\t}\\n   391→\\n   392→\\t// Restore files from checkpoint\\n   393→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   394→\\t\\tif err := ctx.Err(); err != nil {\\n   395→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   396→\\t\\t}\\n   397→\\t\\t// Skip metadata directories - these are for checkpoint storage, not working dir\\n   398→\\t\\tif strings.HasPrefix(f.Name, entireDir) {\\n   399→\\t\\t\\treturn nil\\n   400→\\t\\t}\\n   401→\\n   402→\\t\\tcontents, err := f.Contents()\\n   403→\\t\\tif err != nil {\\n   404→\\t\\t\\treturn fmt.Errorf(\\\"failed to read file %s: %w\\\", f.Name, err)\\n   405→\\t\\t}\\n   406→\\n   407→\\t\\t// Resolve absolute path using repoRoot since f.Name is repo-relative\\n   408→\\t\\tabsPath := filepath.Join(repoRoot, f.Name)\\n   409→\\n   410→\\t\\t// Ensure directory exists\\n   411→\\t\\tdir := filepath.Dir(absPath)\\n   412→\\t\\tif dir != \\\".\\\" {\\n   413→\\t\\t\\t//nolint:gosec // G301: Need 0o755 for user directories during rewind\\n   414→\\t\\t\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   415→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to create directory %s: %w\\\", dir, err)\\n   416→\\t\\t\\t}\\n   417→\\t\\t}\\n   418→\\n   419→\\t\\t// Write file with appropriate permissions\\n   420→\\t\\tvar perm os.FileMode = 0o644\\n   421→\\t\\tif f.Mode == filemode.Executable {\\n   422→\\t\\t\\tperm = 0o755\\n   423→\\t\\t}\\n   424→\\t\\tif err := os.WriteFile(absPath, []byte(contents), perm); err != nil {\\n   425→\\t\\t\\treturn fmt.Errorf(\\\"failed to write file %s: %w\\\", f.Name, err)\\n   426→\\t\\t}\\n   427→\\n   428→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Restored: %s\\\\n\\\", f.Name)\\n   429→\\t\\treturn nil\\n   430→\\t})\\n   431→\\tif err != nil {\\n   432→\\t\\treturn fmt.Errorf(\\\"failed to iterate tree files: %w\\\", err)\\n   433→\\t}\\n   434→\\n   435→\\tfmt.Println()\\n   436→\\tif len(point.ID) >= 7 {\\n   437→\\t\\tfmt.Printf(\\\"Restored files from shadow commit %s\\\\n\\\", point.ID[:7])\\n   438→\\t} else {\\n   439→\\t\\tfmt.Printf(\\\"Restored files from shadow commit %s\\\\n\\\", point.ID)\\n   440→\\t}\\n   441→\\tfmt.Println()\\n   442→\\n   443→\\treturn nil\\n   444→}\\n   445→\\n   446→// resetShadowBranchToCheckpoint resets the shadow branch HEAD to the given checkpoint.\\n   447→// This ensures that when the user commits after rewinding, the next checkpoint will only\\n   448→// include prompts from the rewound point, not prompts from later checkpoints.\\n   449→func (s *ManualCommitStrategy) resetShadowBranchToCheckpoint(ctx context.Context, repo *git.Repository, commit *object.Commit) error {\\n   450→\\t// Extract session ID from the checkpoint commit's Entire-Session trailer\\n   451→\\tsessionID, found := trailers.ParseSession(commit.Message)\\n   452→\\tif !found {\\n   453→\\t\\treturn errors.New(\\\"checkpoint has no Entire-Session trailer\\\")\\n   454→\\t}\\n   455→\\n   456→\\t// Load session state to get the shadow branch name\\n   457→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   458→\\tif err != nil {\\n   459→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   460→\\t}\\n   461→\\tif state == nil {\\n   462→\\t\\treturn fmt.Errorf(\\\"session %s not found\\\", sessionID)\\n   463→\\t}\\n   464→\\n   465→\\t// Reset the shadow branch to the checkpoint commit\\n   466→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   467→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   468→\\n   469→\\t// Update the reference to point to the checkpoint commit\\n   470→\\tref := plumbing.NewHashReference(refName, commit.Hash)\\n   471→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   472→\\t\\treturn fmt.Errorf(\\\"failed to update shadow branch: %w\\\", err)\\n   473→\\t}\\n   474→\\n   475→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Reset shadow branch %s to checkpoint %s\\\\n\\\", shadowBranchName, commit.Hash.String()[:7])\\n   476→\\treturn nil\\n   477→}\\n   478→\\n   479→// CanRewind checks if rewinding is possible.\\n   480→// For manual-commit strategy, rewind restores files from a checkpoint - uncommitted changes are expected\\n   481→// and will be replaced by the checkpoint contents. Returns true with a warning message showing\\n   482→// what changes will be reverted.\\n   483→func (s *ManualCommitStrategy) CanRewind(ctx context.Context) (bool, string, error) {\\n   484→\\treturn checkCanRewindWithWarning(ctx)\\n   485→}\\n   486→\\n   487→// PreviewRewind returns what will happen if rewinding to the given point.\\n   488→// This allows showing warnings about untracked files that will be deleted.\\n   489→func (s *ManualCommitStrategy) PreviewRewind(ctx context.Context, point RewindPoint) (*RewindPreview, error) {\\n   490→\\t// Logs-only points don't modify the working directory\\n   491→\\tif point.IsLogsOnly {\\n   492→\\t\\treturn &RewindPreview{}, nil\\n   493→\\t}\\n   494→\\n   495→\\trepo, err := OpenRepository(ctx)\\n   496→\\tif err != nil {\\n   497→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   498→\\t}\\n   499→\\n   500→\\t// Get the checkpoint commit\\n   501→\\tcommitHash := plumbing.NewHash(point.ID)\\n   502→\\tcommit, err := repo.CommitObject(commitHash)\\n   503→\\tif err != nil {\\n   504→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   505→\\t}\\n   506→\\n   507→\\ttree, err := commit.Tree()\\n   508→\\tif err != nil {\\n   509→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n   510→\\t}\\n   511→\\n   512→\\t// Load session state to get untracked files that existed at session start\\n   513→\\tsessionID, hasSessionTrailer := trailers.ParseSession(commit.Message)\\n   514→\\tvar preservedUntrackedFiles map[string]bool\\n   515→\\tif hasSessionTrailer {\\n   516→\\t\\tstate, stateErr := s.loadSessionState(ctx, sessionID)\\n   517→\\t\\tif stateErr == nil && state != nil && len(state.UntrackedFilesAtStart) > 0 {\\n   518→\\t\\t\\tpreservedUntrackedFiles = make(map[string]bool)\\n   519→\\t\\t\\tfor _, f := range state.UntrackedFilesAtStart {\\n   520→\\t\\t\\t\\tpreservedUntrackedFiles[f] = true\\n   521→\\t\\t\\t}\\n   522→\\t\\t}\\n   523→\\t}\\n   524→\\n   525→\\t// Build set of files in the checkpoint tree (excluding metadata)\\n   526→\\tcheckpointFiles := make(map[string]bool)\\n   527→\\tvar filesToRestore []string\\n   528→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   529→\\t\\tif err := ctx.Err(); err != nil {\\n   530→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   531→\\t\\t}\\n   532→\\t\\tif !strings.HasPrefix(f.Name, entireDir) {\\n   533→\\t\\t\\tcheckpointFiles[f.Name] = true\\n   534→\\t\\t\\tfilesToRestore = append(filesToRestore, f.Name)\\n   535→\\t\\t}\\n   536→\\t\\treturn nil\\n   537→\\t})\\n   538→\\tif err != nil {\\n   539→\\t\\treturn nil, fmt.Errorf(\\\"failed to list checkpoint files: %w\\\", err)\\n   540→\\t}\\n   541→\\n   542→\\t// Get HEAD tree to identify tracked files\\n   543→\\thead, err := repo.Head()\\n   544→\\tif err != nil {\\n   545→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   546→\\t}\\n   547→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   548→\\tif err != nil {\\n   549→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   550→\\t}\\n   551→\\theadTree, err := headCommit.Tree()\\n   552→\\tif err != nil {\\n   553→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD tree: %w\\\", err)\\n   554→\\t}\\n   555→\\n   556→\\t// Build set of files tracked in HEAD\\n   557→\\ttrackedFiles := make(map[string]bool)\\n   558→\\t//nolint:errcheck // Error is not critical for preview\\n   559→\\t_ = headTree.Files().ForEach(func(f *object.File) error {\\n   560→\\t\\tif err := ctx.Err(); err != nil {\\n   561→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   562→\\t\\t}\\n   563→\\t\\ttrackedFiles[f.Name] = true\\n   564→\\t\\treturn nil\\n   565→\\t})\\n   566→\\n   567→\\t// Find untracked files that would be deleted.\\n   568→\\t// Uses git ls-files to only consider non-ignored files.\\n   569→\\tvar filesToDelete []string\\n   570→\\tuntrackedNow, untrackedErr := collectUntrackedFiles(ctx)\\n   571→\\tif untrackedErr != nil {\\n   572→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: could not list untracked files for preview: %v\\\\n\\\", untrackedErr)\\n   573→\\t\\treturn &RewindPreview{\\n   574→\\t\\t\\tFilesToRestore: filesToRestore,\\n   575→\\t\\t\\tFilesToDelete:  filesToDelete,\\n   576→\\t\\t}, nil\\n   577→\\t}\\n   578→\\tfor _, relPath := range untrackedNow {\\n   579→\\t\\tif checkpointFiles[relPath] {\\n   580→\\t\\t\\tcontinue\\n   581→\\t\\t}\\n   582→\\t\\tif trackedFiles[relPath] {\\n   583→\\t\\t\\tcontinue\\n   584→\\t\\t}\\n   585→\\t\\tif preservedUntrackedFiles[relPath] {\\n   586→\\t\\t\\tcontinue\\n   587→\\t\\t}\\n   588→\\t\\tfilesToDelete = append(filesToDelete, relPath)\\n   589→\\t}\\n   590→\\n   591→\\t// Sort for consistent output\\n   592→\\tsort.Strings(filesToRestore)\\n   593→\\tsort.Strings(filesToDelete)\\n   594→\\n   595→\\treturn &RewindPreview{\\n   596→\\t\\tFilesToRestore: filesToRestore,\\n   597→\\t\\tFilesToDelete:  filesToDelete,\\n   598→\\t}, nil\\n   599→}\\n   600→\\n   601→// RestoreLogsOnly restores session logs from a logs-only rewind point.\\n   602→// This fetches the transcript from entire/checkpoints/v1 and writes it to the agent's session directory.\\n   603→// Does not modify the working directory.\\n   604→// When multiple sessions were condensed to the same checkpoint, ALL sessions are restored.\\n   605→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   606→// Returns info about each restored session so callers can print correct per-session resume commands.\\n   607→func (s *ManualCommitStrategy) RestoreLogsOnly(ctx context.Context, point RewindPoint, force bool) ([]RestoredSession, error) {\\n   608→\\tif !point.IsLogsOnly {\\n   609→\\t\\treturn nil, errors.New(\\\"not a logs-only rewind point\\\")\\n   610→\\t}\\n   611→\\n   612→\\tif point.CheckpointID.IsEmpty() {\\n   613→\\t\\treturn nil, errors.New(\\\"missing checkpoint ID\\\")\\n   614→\\t}\\n   615→\\n   616→\\t// Get checkpoint store\\n   617→\\tstore, err := s.getCheckpointStore()\\n   618→\\tif err != nil {\\n   619→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   620→\\t}\\n   621→\\n   622→\\t// Read checkpoint summary to get session count\\n   623→\\tsummary, err := store.ReadCommitted(ctx, point.CheckpointID)\\n   624→\\tif err != nil {\\n   625→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   626→\\t}\\n   627→\\tif summary == nil {\\n   628→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", point.CheckpointID)\\n   629→\\t}\\n   630→\\n   631→\\t// Get worktree root for agent session directory lookup\\n   632→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   633→\\tif err != nil {\\n   634→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   635→\\t}\\n   636→\\n   637→\\t// Check for newer local logs if not forcing\\n   638→\\tif !force {\\n   639→\\t\\tsessions := s.classifySessionsForRestore(ctx, repoRoot, store, point.CheckpointID, summary)\\n   640→\\t\\thasConflicts := false\\n   641→\\t\\tfor _, sess := range sessions {\\n   642→\\t\\t\\tif sess.Status == StatusLocalNewer {\\n   643→\\t\\t\\t\\thasConflicts = true\\n   644→\\t\\t\\t\\tbreak\\n   645→\\t\\t\\t}\\n   646→\\t\\t}\\n   647→\\t\\tif hasConflicts {\\n   648→\\t\\t\\tshouldOverwrite, promptErr := PromptOverwriteNewerLogs(sessions)\\n   649→\\t\\t\\tif promptErr != nil {\\n   650→\\t\\t\\t\\treturn nil, promptErr\\n   651→\\t\\t\\t}\\n   652→\\t\\t\\tif !shouldOverwrite {\\n   653→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled. Local session logs preserved.\\\\n\\\")\\n   654→\\t\\t\\t\\treturn nil, nil\\n   655→\\t\\t\\t}\\n   656→\\t\\t}\\n   657→\\t}\\n   658→\\n   659→\\t// Count sessions to restore\\n   660→\\ttotalSessions := len(summary.Sessions)\\n   661→\\tif totalSessions > 1 {\\n   662→\\t\\tfmt.Fprintf(os.Stderr, \\\"Restoring %d sessions from checkpoint:\\\\n\\\", totalSessions)\\n   663→\\t}\\n   664→\\n   665→\\t// Restore all sessions (oldest to newest, using 0-based indexing)\\n   666→\\tvar restored []RestoredSession\\n   667→\\tfor i := range totalSessions {\\n   668→\\t\\tcontent, readErr := store.ReadSessionContent(ctx, point.CheckpointID, i)\\n   669→\\t\\tif readErr != nil {\\n   670→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: failed to read session %d: %v\\\\n\\\", i, readErr)\\n   671→\\t\\t\\tcontinue\\n   672→\\t\\t}\\n   673→\\t\\tif content == nil || len(content.Transcript) == 0 {\\n   674→\\t\\t\\tcontinue\\n   675→\\t\\t}\\n   676→\\n   677→\\t\\tsessionID := content.Metadata.SessionID\\n   678→\\t\\tif sessionID == \\\"\\\" {\\n   679→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d has no session ID, skipping\\\\n\\\", i)\\n   680→\\t\\t\\tcontinue\\n   681→\\t\\t}\\n   682→\\n   683→\\t\\t// Resolve per-session agent from metadata — skip if agent is unknown\\n   684→\\t\\tif content.Metadata.Agent == \\\"\\\" {\\n   685→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d (%s) has no agent metadata, skipping (cannot determine target directory)\\\\n\\\", i, sessionID)\\n   686→\\t\\t\\tcontinue\\n   687→\\t\\t}\\n   688→\\t\\tsessionAgent, agErr := ResolveAgentForRewind(content.Metadata.Agent)\\n   689→\\t\\tif agErr != nil {\\n   690→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d (%s) has unknown agent %q, skipping\\\\n\\\", i, sessionID, content.Metadata.Agent)\\n   691→\\t\\t\\tcontinue\\n   692→\\t\\t}\\n   693→\\n   694→\\t\\t// Compute transcript path from current repo location for cross-machine portability.\\n   695→\\t\\tsessionAgentDir, dirErr := sessionAgent.GetSessionDir(repoRoot)\\n   696→\\t\\tif dirErr != nil {\\n   697→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: failed to get session dir for session %d: %v\\\\n\\\", i, dirErr)\\n   698→\\t\\t\\tcontinue\\n   699→\\t\\t}\\n   700→\\t\\tsessionFile := sessionAgent.ResolveSessionFile(sessionAgentDir, sessionID)\\n   701→\\n   702→\\t\\t// Get first prompt for display\\n   703→\\t\\tpromptPreview := ExtractFirstPrompt(content.Prompts)\\n   704→\\n   705→\\t\\tif totalSessions > 1 {\\n   706→\\t\\t\\tisLatest := i == totalSessions-1\\n   707→\\t\\t\\tif promptPreview != \\\"\\\" {\\n   708→\\t\\t\\t\\tif isLatest {\\n   709→\\t\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Session %d (latest): %s\\\\n\\\", i+1, promptPreview)\\n   710→\\t\\t\\t\\t} else {\\n   711→\\t\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Session %d: %s\\\\n\\\", i+1, promptPreview)\\n   712→\\t\\t\\t\\t}\\n   713→\\t\\t\\t}\\n   714→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"    Writing to: %s\\\\n\\\", sessionFile)\\n   715→\\t\\t} else {\\n   716→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Writing transcript to: %s\\\\n\\\", sessionFile)\\n   717→\\t\\t}\\n   718→\\n   719→\\t\\t// Ensure parent directory exists (