ute per-session agent directories.\\n   811→// Sessions without agent metadata are skipped (cannot determine target directory).\\n   812→func (s *ManualCommitStrategy) classifySessionsForRestore(ctx context.Context, repoRoot string, store cpkg.Store, checkpointID id.CheckpointID, summary *cpkg.CheckpointSummary) []SessionRestoreInfo {\\n   813→\\tvar sessions []SessionRestoreInfo\\n   814→\\n   815→\\ttotalSessions := len(summary.Sessions)\\n   816→\\t// Check all sessions (0-based indexing)\\n   817→\\tfor i := range totalSessions {\\n   818→\\t\\tcontent, err := store.ReadSessionContent(ctx, checkpointID, i)\\n   819→\\t\\tif err != nil || content == nil || len(content.Transcript) == 0 {\\n   820→\\t\\t\\tcontinue\\n   821→\\t\\t}\\n   822→\\n   823→\\t\\tsessionID := content.Metadata.SessionID\\n   824→\\t\\tif sessionID == \\\"\\\" || content.Metadata.Agent == \\\"\\\" {\\n   825→\\t\\t\\tcontinue\\n   826→\\t\\t}\\n   827→\\n   828→\\t\\tsessionAgent, agErr := ResolveAgentForRewind(content.Metadata.Agent)\\n   829→\\t\\tif agErr != nil {\\n   830→\\t\\t\\tcontinue\\n   831→\\t\\t}\\n   832→\\n   833→\\t\\t// Compute transcript path from current repo location for cross-machine portability.\\n   834→\\t\\tsessionAgentDir, dirErr := sessionAgent.GetSessionDir(repoRoot)\\n   835→\\t\\tif dirErr != nil {\\n   836→\\t\\t\\tcontinue\\n   837→\\t\\t}\\n   838→\\t\\tlocalPath := sessionAgent.ResolveSessionFile(sessionAgentDir, sessionID)\\n   839→\\n   840→\\t\\tlocalTime := paths.GetLastTimestampFromFile(localPath)\\n   841→\\t\\tcheckpointTime := paths.GetLastTimestampFromBytes(content.Transcript)\\n   842→\\t\\tstatus := ClassifyTimestamps(localTime, checkpointTime)\\n   843→\\n   844→\\t\\tsessions = append(sessions, SessionRestoreInfo{\\n   845→\\t\\t\\tSessionID:      sessionID,\\n   846→\\t\\t\\tPrompt:         ExtractFirstPrompt(content.Prompts),\\n   847→\\t\\t\\tStatus:         status,\\n   848→\\t\\t\\tLocalTime:      localTime,\\n   849→\\t\\t\\tCheckpointTi