n   945→\\t\\t}\\n   946→\\t}\\n   947→\\n   948→\\t// Get the commit\\n   949→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   950→\\tif err != nil {\\n   951→\\t\\treturn \\\"\\\", false\\n   952→\\t}\\n   953→\\n   954→\\t// Get the tree\\n   955→\\ttree, err := commit.Tree()\\n   956→\\tif err != nil {\\n   957→\\t\\treturn \\\"\\\", false\\n   958→\\t}\\n   959→\\n   960→\\t// Get the file\\n   961→\\tfile, err := tree.File(filePath)\\n   962→\\tif err != nil {\\n   963→\\t\\treturn \\\"\\\", false\\n   964→\\t}\\n   965→\\n   966→\\t// Get the content\\n   967→\\tcontent, err := file.Contents()\\n   968→\\tif err != nil {\\n   969→\\t\\treturn \\\"\\\", false\\n   970→\\t}\\n   971→\\n   972→\\treturn content, true\\n   973→}\\n   974→\\n   975→// CheckpointValidation contains expected values for checkpoint validation.\\n   976→type CheckpointValidation struct {\\n   977→\\t// CheckpointID is the expected checkpoint ID\\n   978→\\tCheckpointID string\\n   979→\\n   980→\\t// Strategy is the expected strategy name (optional)\\n   981→\\tStrategy string\\n   982→\\n   983→\\t// FilesTouched are the expected files in files_touched (optional)\\n   984→\\tFilesTouched []string\\n   985→\\n   986→\\t// ExpectedPrompts are strings that should appear in prompt.txt (optional)\\n   987→\\tExpectedPrompts []string\\n   988→\\n   989→\\t// ExpectedTranscriptContent are strings that should appear in full.jsonl (optional)\\n   990→\\tExpectedTranscriptContent []string\\n   991→}\\n   992→\\n   993→// ValidateCheckpoint performs comprehensive validation of a checkpoint on the metadata branch.\\n   994→func (env *TestEnv) ValidateCheckpoint(v CheckpointValidation) {\\n   995→\\tenv.T.Helper()\\n   996→\\n   997→\\tmetadataBranch := \\\"entire/checkpoints/v1\\\"\\n   998→\\n   999→\\t// Compute sharded path: <id[:2]>/<id[2:]>/\\n  1000→\\tif len(v.CheckpointID) < 3 {\\n  1001→\\t\\tenv.T.Fatalf(\\\"Checkpoint ID too short: %s\\\", v.CheckpointID)\\n  1002→\\t}\\n  1003→\\t