r)\\n   527→\\t}\\n   528→\\n   529→\\thead, err := repo.Head()\\n   530→\\tif err != nil {\\n   531→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   532→\\t}\\n   533→\\n   534→\\treturn head.Hash().String()\\n   535→}\\n   536→\\n   537→// RewindPoint mirrors the rewind --list JSON output.\\n   538→type RewindPoint struct {\\n   539→\\tID               string    `json:\\\"id\\\"`\\n   540→\\tMessage          string    `json:\\\"message\\\"`\\n   541→\\tMetadataDir      string    `json:\\\"metadata_dir\\\"`\\n   542→\\tDate             time.Time `json:\\\"date\\\"`\\n   543→\\tIsTaskCheckpoint bool      `json:\\\"is_task_checkpoint\\\"`\\n   544→\\tToolUseID        string    `json:\\\"tool_use_id\\\"`\\n   545→\\tIsLogsOnly       bool      `json:\\\"is_logs_only\\\"`\\n   546→\\tCondensationID   string    `json:\\\"condensation_id\\\"`\\n   547→}\\n   548→\\n   549→// GetRewindPoints returns available rewind points using the CLI.\\n   550→func (env *TestEnv) GetRewindPoints() []RewindPoint {\\n   551→\\tenv.T.Helper()\\n   552→\\n   553→\\t//nolint:gosec,noctx // test code, args are static, no context needed\\n   554→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--list\\\")\\n   555→\\tcmd.Dir = env.RepoDir\\n   556→\\n   557→\\toutput, err := cmd.CombinedOutput()\\n   558→\\tif err != nil {\\n   559→\\t\\tenv.T.Fatalf(\\\"rewind --list failed: %v\\\\nOutput: %s\\\", err, output)\\n   560→\\t}\\n   561→\\n   562→\\t// Parse JSON output\\n   563→\\tvar jsonPoints []struct {\\n   564→\\t\\tID               string `json:\\\"id\\\"`\\n   565→\\t\\tMessage          string `json:\\\"message\\\"`\\n   566→\\t\\tMetadataDir      string `json:\\\"metadata_dir\\\"`\\n   567→\\t\\tDate             string `json:\\\"date\\\"`\\n   568→\\t\\tIsTaskCheckpoint bool   `json:\\\"is_task_checkpoint\\\"`\\n   569→\\t\\tToolUseID        string `json:\\\"tool_use_id\\\"`\\n   570→\\t\\tIsLogsOnly       bool   `json:\\\"is_logs_only\\\"`\\n   571→\\t\\tCondensationID   string `json:\\\"condensation_id\\\"`\\n   572→\\t}\\n   573→\\n   574→\\tif err := json.Unmarshal(output, &jsonPoints); err != nil {\\n   575→\\t\\tenv.T.Fatalf(\\\"failed to parse rewind points: %v\\\\nOutput: %s\\\", err, output)\\n   576→\\t}\\n   577→\\n   578→\\tpoints := make([]RewindPoint, len(jsonPoints))\\n   579→\\tfor i, jp := range jsonPoints {\\n   580→\\t\\t//nolint:errcheck // date parsing failure is acceptable, defaults to zero time\\n   581→\\t\\tdate, _ := time.Parse(time.RFC3339, jp.Date)\\n   582→\\t\\tpoints[i] = RewindPoint{\\n   583→\\t\\t\\tID:               jp.ID,\\n   584→\\t\\t\\tMessage:          jp.Message,\\n   585→\\t\\t\\tMetadataDir:      jp.MetadataDir,\\n   586→\\t\\t\\tDate:             date,\\n   587→\\t\\t\\tIsTaskCheckpoint: jp.IsTaskCheckpoint,\\n   588→\\t\\t\\tToolUseID:        jp.ToolUseID,\\n   589→\\t\\t\\tIsLogsOnly:       jp.IsLogsOnly,\\n   590→\\t\\t\\tCondensationID:   jp.CondensationID,\\n   591→\\t\\t}\\n   592→\\t}\\n   593→\\n   594→\\treturn points\\n   595→}\\n   596→\\n   597→// Rewind performs a rewind to the specified commit ID using the CLI.\\n   598→func (env *TestEnv) Rewind(commitID string) error {\\n   599→\\tenv.T.Helper()\\n   600→\\n   601→\\t//nolint:gosec,noctx // test code, commitID is from test setup, no context needed\\n   602→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID)\\n   603→\\tcmd.Dir = env.RepoDir\\n   604→\\n   605→\\toutput, err := cmd.CombinedOutput()\\n   606→\\tif err != nil {\\n   607→\\t\\treturn errors.New(\\\"rewind failed: \\\" + string(output))\\n   608→\\t}\\n   609→\\n   610→\\tenv.T.Logf(\\\"Rewind output: %s\\\", output)\\n   611→\\treturn nil\\n   612→}\\n   613→\\n   614→// BranchExists checks if a branch exists in the repository.\\n   615→func (env *TestEnv) BranchExists(branchName string) bool {\\n   616→\\tenv.T.Helper()\\n   617→\\n   618→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   619→\\tif err != nil {\\n   620→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   621→\\t}\\n   622→\\n   623→\\trefs, err := repo.References()\\n   624→\\tif err != nil {\\n   625→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   626→\\t}\\n   627→\\n   628→\\tfound := false\\n   629→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   630→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   631→\\t\\tif ref.Name().Short() == branchName {\\n   632→\\t\\t\\tfound = true\\n   633→\\t\\t}\\n   634→\\t\\treturn nil\\n   635→\\t})\\n   636→\\n   637→\\treturn found\\n   638→}\\n   639→\\n   640→// ListBranchesWithPrefix returns all branches that start with the given prefix.\\n   641→func (env *TestEnv) ListBranchesWithPrefix(prefix string) []string {\\n   642→\\tenv.T.Helper()\\n   643→\\n   644→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   645→\\tif err != nil {\\n   646→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   647→\\t}\\n   648→\\n   649→\\trefs, err := repo.References()\\n   650→\\tif err != nil {\\n   651→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   652→\\t}\\n   653→\\n   654→\\tvar branches []string\\n   655→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   656→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   657→\\t\\tname := ref.Name().Short()\\n   658→\\t\\tif strings.HasPrefix(name, prefix) {\\n   659→\\t\\t\\tbranches = append(branches, name)\\n   660→\\t\\t}\\n   661→\\t\\treturn nil\\n   662→\\t})\\n   663→\\n   664→\\treturn branches\\n   665→}\\n   666→\\n   667→// GetCommitMessage returns the commit message for the given commit hash.\\n   668→func (env *TestEnv) GetCommitMessage(hash string) string {\\n   669→\\tenv.T.Helper()\\n   670→\\n   671→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   672→\\tif err != nil {\\n   673→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   674→\\t}\\n   675→\\n   676→