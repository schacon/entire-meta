ched,\\n    54→\\t\\t\\tAgent:            c.Agent,\\n    55→\\t\\t\\tIsTask:           c.IsTask,\\n    56→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    57→\\t\\t\\tSessionCount:     c.SessionCount,\\n    58→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    59→\\t\\t})\\n    60→\\t}\\n    61→\\n    62→\\treturn result, nil\\n    63→}\\n    64→\\n    65→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    66→func (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n    67→\\tall, err := s.listCheckpoints()\\n    68→\\tif err != nil {\\n    69→\\t\\treturn nil, err\\n    70→\\t}\\n    71→\\n    72→\\tvar result []CheckpointInfo\\n    73→\\tfor _, cp := range all {\\n    74→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    75→\\t\\t\\tresult = append(result, cp)\\n    76→\\t\\t}\\n    77→\\t}\\n    78→\\n    79→\\tif len(result) == 0 {\\n    80→\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n    81→\\t}\\n    82→\\n    83→\\treturn result, nil\\n    84→}\\n    85→\\n    86→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    87→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    88→func (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n    89→\\tstore, err := s.getCheckpointStore()\\n    90→\\tif err != nil {\\n    91→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    92→\\t}\\n    93→\\n    94→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n    95→\\tif err != nil {\\n    96→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    97→\\t}\\n    98→\\tif content == nil {\\n    99→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n   100→\\t}\\n   101→\\tif len(content.Transcript) == 0 {\\n   102→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   103→\\t}\\n   104→\\n   105→\\treturn content.Transcript, nil\\n   106→}\\n   107→\\n   108→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   109→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   110→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   111→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   112→//\\n   113→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   114→// In this case, data is extracted from the live transcript instead.\\n   115→func (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n   116→\\t// Get shadow branch (may not exist for mid-session commits)\\n   117→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   118→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   119→\\tref, err := repo.Reference(refName, true)\\n   120→\\thasShadowBranch := err == nil\\n   121→\\n   122→\\tvar sessionData *ExtractedSessionData\\n   123→\\tif hasShadowBranch {\\n   124→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   125→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   126→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   127→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   128→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   129→\\t\\t// last turn had no code changes).\\n   130→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   131→\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n   132→\\t\\tif err != nil {\\n   133→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n   134→\\t\\t}\\n   135→\\t} else {\\n   136→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   137→\\t\\t// Extract data directly from live transcript.\\n   138→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   139→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   140→\\t\\t}\\n   141→\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n   142→\\t\\tif err != nil {\\n   143→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n   144→\\t\\t}\\n   145→\\t}\\n   146→\\n   147→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   148→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   149→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   150→\\tif len(committedFiles) > 0 {\\n   151→\\t\\t// Track if we had files before filtering to distinguish between:\\n   152→\\t\\t// - Session had files but none were committed (don't fallback)\\n   153→\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n   154→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   155→\\n   156→\\t\\tif hadFilesBeforeFiltering {\\n   157→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   158→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   159→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   160→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   161→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   162→\\t\\t\\t\\t}\\n   163→\\t\\t\\t}\\n   164→\\t\\t\\tsessionData.FilesTouched = filtered\\n   165→\\t\\t}\\n   166→\\n   167→\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n   168→\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n   169→\\t\\t// the session had files that simply didn't overlap with the commit - that\\n   170→\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n   171→\\t\\t// overwritten with unrelated committed files.\\n   172→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   173→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   174→\\t\\t\\tfor f := range committedFiles {\\n   175→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   176→\\t\\t\\t}\\n   177→\\t\\t}\\n   178→\\t}\\n   179→\\n   180→\\t// Get checkpoint store\\n   181→\\tstore, err := s.getCheckpointStore()\\n   182→\\tif err != nil {\\n   183→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   184→\\t}\\n   185→\\n   186→\\t// Get author info\\n   187→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   188→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   189→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   190→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   191→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n   192→\\t// Get current branch name\\n   193→\\tbranchName := GetCurrentBranchName(repo)\\n   194→\\n   195→\\t// Generate summary if enabled\\n   196→\\tvar summary *cpkg.Summary\\n   197→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   198→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   199→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   200→\\n   201→\\t\\t// Scope transcript to this checkpoint's portion.\\n   202→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   203→\\t\\t// For Gemini (JSON), CheckpointTranscriptStart is a message index.\\n   204→\\t\\tvar scopedTranscript []byte\\n   205→\\t\\tif state.AgentType == agent.AgentTypeGemini {\\n   206→\\t\\t\\tscopedTranscript = geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   207→\\t\\t} else {\\n   208→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   209→\\t\\t}\\n   210→\\t\\tif len(scopedTranscript) > 0 {\\n   211→\\t\\t\\tvar err error\\n   212→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   213→\\t\\t\\tif err != nil {\\n   214→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   215→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   216→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   217→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   218→\\t\\t\\t} else {\\n   219→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   220→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   221→\\t\\t\\t}\\n   222→\\t\\t}\\n   223→\\t}\\n   224→\\n   225→\\t// Write checkpoint metadata using the checkpoint store\\n   226→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   227→\\t\\tCheckpointID:                checkpointID,\\n   228→\\t\\tSessionID:                   state.SessionID,\\n   229→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   230→\\t\\tBranch:                      branchName,\\n   231→\\t\\tTranscript:                  sessionData.Transcript,\\n   232→\\t\\tPrompts:                     sessionData.Prompts,\\n   233→\\t\\tContext:                     sessionData.Conte