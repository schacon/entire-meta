n  1028→\\t// 1. Transcript has grown since last condensation (new prompts/responses)\\n  1029→\\t// 2. FilesTouched has files not yet committed (carry-forward scenario)\\n  1030→\\t//\\n  1031→\\t// For PrepareCommitMsg context, we verify staged files overlap with session's files\\n  1032→\\t// using content-aware matching to detect reverted files.\\n  1033→\\t// For PostCommit context, getStagedFiles() is empty (files already committed),\\n  1034→\\t// so we return true and let the caller do the overlap check via filesOverlapWithContent.\\n  1035→\\n  1036→\\thasTranscriptGrowth := transcriptLines > state.CheckpointTranscriptStart\\n  1037→\\thasUncommittedFiles := len(state.FilesTouched) > 0\\n  1038→\\n  1039→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: transcript check\\\",\\n  1040→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1041→\\t\\tslog.Int(\\\"transcript_lines\\\", transcriptLines),\\n  1042→\\t\\tslog.Int(\\\"checkpoint_transcript_start\\\", state.CheckpointTranscriptStart),\\n  1043→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1044→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1045→\\t)\\n  1046→\\n  1047→\\tif !hasTranscriptGrowth && !hasUncommittedFiles {\\n  1048→\\t\\treturn false, nil // No new content and no carry-forward files\\n  1049→\\t}\\n  1050→\\n  1051→\\t// Check if staged files overlap with session's files with content-aware matching.\\n  1052→\\t// This is primarily for PrepareCommitMsg; in PostCommit, stagedFiles is empty.\\n  1053→\\tstagedFiles := getStagedFiles(repo)\\n  1054→\\tif len(stagedFiles) > 0 {\\n  1055→\\t\\tresult := stagedFilesOverlapWithContent(repo, tree, stagedFiles, state.FilesTouched)\\n  1056→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: staged files overlap check\\\",\\n  1057→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1058→\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1059→\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n  1060→\\t\\t)\\n  1061→\\t\\treturn result, nil\\n  1062→\\t}\\n  1063→\\n  1064→\\t// No staged files - either PostCommit context or edge case.\\n  1065→\\t// Return transcript growth status. For PostCommit with hasTranscriptFile=true,\\n  1066→\\t// if there's no transcript growth, the session hasn't done new work since last checkpoint.\\n  1067→\\t// (Carry-forward creates a shadow branch WITHOUT transcript, handled in the block above.)\\n  1068→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no staged files, returning transcript growth\\\",\\n  1069→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1070→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1071→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1072→\\t)\\n  1073→\\treturn hasTranscriptGrowth, nil\\n  1074→}\\n  1075→\\n  1076→// sessionHasNewContentFromLiveTranscript checks if a session has new content\\n  1077→// by examining the live transcript file. This is used when no shadow branch exists\\n  1078→// (i.e., no Stop has happened yet) but the agent may have done work.\\n  1079→//\\n  1080→// Returns true if:\\n  1081→//  1. The transcript has grown since the last condensation, AND\\n  1082→//  2. The new transcript portion contains file modifications, AND\\n  1083→//  3. At least one modified file overlaps with the currently staged files\\n  1084→//\\n  1085→// The overlap check ensures we don't add checkpoint trailers to commits that are\\n  1086→// unrelated to the agent's recent changes.\\n  1087→//\\n  1088→// This handles the scenario where the agent commits mid-session before Stop.\\n  1089→func (s *ManualCommitStrategy) sessionHasNewContentFromLiveTranscript(repo *git.Repository, state *SessionState) (bool, error) {\\n  1090→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1091→\\n  1092→\\tmodifiedFiles, ok := s.extractNewModifiedFilesFromLiveTranscript(state)\\n  1093→\\tif !ok || len(modifiedFiles) == 0 {\\n  1094→\\t\\treturn false, nil\\n  1095→\\t}\\n  1096→\\n  1097→\\tlogging.Debug(logCtx, \\\"live transcript check: found file modifications\\\",\\n  1098→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1099→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1100→\\t)\\n  1101→\\n  1102→\\t// Check if any modified files overlap with currently staged files\\n  1103→\\t// This ensures we only add checkpoint trailers to commits that include\\n  1104→\\t// files the agent actually modified\\n  1105→\\tstagedFiles := getStagedFiles(repo)\\n  1106→\\n  1107→\\tlogging.Debug(logCtx, \\\"live transcript check: comparing staged vs modified\\\",\\n  1108→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1109→\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1110→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1111→\\t)\\n  1112→\\n  1113→\\tif !hasOverlappingFiles(stagedFiles, modifiedFiles) {\\n  1114→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no overlap between staged and modified files\\\",\\n  1115→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1116→\\t\\t)\\n  1117→\\t\\treturn false, nil // No overlap - staged files are unrelated to agent's work\\n  1118→\\t}\\n  1119→\\n  1120→\\treturn true, nil\\n  1121→}\\n  1122→\\n  1123→// extractFilesFromLiveTranscript extracts modified file paths from the live transcript.\\n  1124→// Returns empty slice if extraction fails (fail-open behavior for hooks).\\n  1125→// Extracts files from the transcript starting at CheckpointTranscriptStart, which gives\\n  1126→// files touched since the last condensation — used for carry-forward computation.\\n  1127→func (s *ManualCommitStrategy) extractFilesFromLiveTranscript(state *SessionState) []string {\\n  1128→\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n  1129→}\\n  1130→\\n  1131→// extractNewModifiedFilesFromLiveTranscript extracts modified files from the live\\n  1132→// transcript that are NEW since the last condensation. Returns the normalized file list\\n  1133→// and whether the extraction succeeded. Used by sessionHasNewContentFromLiveTranscript\\n  1134→// to detect agent work.\\n  1135→func (s *ManualCommitStrategy) extractNewModifiedFilesFromLiveTranscript(state *SessionState) ([]string, bool) {\\n  1136→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1137→\\n  1138→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1139→\\t\\treturn nil, false\\n  1140→\\t}\\n  1141→\\n  1142→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1143→\\tif err != nil {\\n  1144→\\t\\treturn nil, false\\n  1145→\\t}\\n  1146→\\n  1147→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1148→\\tif !ok {\\n  1149→\\t\\treturn nil, false\\n  1150→\\t}\\n  1151→\\n  1152→\\t// Check if transcript has grown since last condensation\\n  1153→\\tcurrentPos, err := analyzer.GetTranscriptPosition(state.TranscriptPath)\\n  1154→\\tif err != nil {\\n  1155→\\t\\treturn nil, false\\n  1156→\\t}\\n  1157→\\tif currentPos <= state.CheckpointTranscriptStart {\\n  1158→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no new content\\\",\\n  1159→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1160→\\t\\t\\tslog.Int(\\\"current_pos\\\", currentPos),\\n  1161→\\t\\t\\tslog.Int(\\\"start_offset\\\", state.CheckpointTranscriptStart),\\n  1162→\\t\\t)\\n  1163→\\t\\treturn nil, true // No new content, but extraction succeeded\\n  1164→\\t}\\n  1165→\\n  1166→\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart), true\\n  1167→}\\n  1168→\\n  1169→// extractModifiedFilesFromLiveTranscript extracts modified files from the live transcript\\n  1170→// (including subagent transcripts) starting from the given offset, and normalizes them\\n  1171→// to repo-relative paths. Returns the normalized file list.\\n  1172→func (s *ManualCommitStrategy) extractModifiedFilesFromLiveTranscript(state *SessionState, offset int) []string {\\n  1173→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1174→\\n  1175→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1176→\\t\\treturn nil\\n  1177→\\t}\\n  1178→\\n  1179→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1180→\\tif err != nil {\\n  1181→\\t\\treturn nil\\n  1182→\\t}\\n  1183→\\n  1184→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1185→\\tif !ok {\\n  1186→\\t\\treturn nil\\n  1187→\\t}\\n  1188→\\n  1189→\\tvar modifiedFiles []string\\n  1190→\\n  1191→\\t// For Claude Code, use ExtractAllModifiedFiles which parses the main transcript\\n  1192→\\t// AND subagent transcripts in a single pass, avoiding redundant parsing.\\n  1193→\\tif state.AgentType == agent.AgentTypeClaudeCode {\\n  1194→\\t\\tsubagentsDir := filepath.Join(filepath.Dir(state.TranscriptPath), state.SessionID, \\\"subagents\\\")\\n  1195→\\t\\tallFiles, extractErr := claudecode.ExtractAllModifiedFiles(state.TranscriptPath, offset, subagentsDir)\\n  1196→\\t\\tif extractErr != nil {\\n  1197→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: extraction failed\\\",\\n  1198→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1199→\\t\\t\\t\\tslog.String(\\\"error\\\", extractErr.Error()),\\n  1200→\\t\\t\\t)\\n  1201→\\t\\t} else {\\n  1202→\\t\\t\\tmodifiedFiles = allFiles\\n  1203→\\t\\t}\\n  1204→\\t} else {\\n  1205→\\t\\tfiles, _, err := analyzer.ExtractModifiedFilesFromOffset(state.TranscriptPath, offset)\\n  1206→\\t\\tif err != nil {\\n  1207→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: main transcript extraction failed\\\",\\n  1208→\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1209→\\t\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1210→\\t\\t\\t)\\n  1211→\\t\\t} else {\\n  1212→\\t\\t\\tmodifiedFiles = files\\n  1213→\\t\\t}\\n  1214→\\t}\\n  1215→\\n  1216→\\tif len(modifiedFiles) == 0 {\\n  1217→\\t\\treturn nil\\n  1218→\\t}\\n  1219→\\n  1220→\\t// Normalize to repo-relative paths.\\n  1221→\\t// Transcript tool_use entries contain absolute paths (e.g., /Users/alex/project/src/main.go)\\n  1222→\\t// but getStagedFiles/committedFiles use repo-relative paths (e.g., src/main.go).\\n  1223→\\tbasePath := state.WorktreePath\\n  1224→\\tif basePath == \\\"\\\" {\\n  1225→\\t\\tif wp, wpErr := GetWorktreePath(); wpErr == nil {\\n  1226→\\t\\t\\tbasePath = wp\\n  1227→\\t\\t}\\n  1228→\\t}\\n  1229→\\tif basePath != \\\"\\\" {\\n  1230→\\t\\tnormalized := make([]string, 0, len(modifiedFiles))\\n  1231→\\t\\tfor _, f := range modifiedFiles {\\n  1232→\\t\\t\\tif rel := paths.ToRelativePath(f, basePath); rel != \\\"\\\" {\\n  1233→\\t\\t\\t\\tnormalized = append(normalized, rel)\\n  1234→\\t\\t\\t} else {\\n  1235→\\t\\t\\t\\tnormalized = append(normalized, f)\\n  1236→\\t\\t\\t}\\n  1237→\\t\\t}\\n  1238→\\t\\tmodifiedFiles = normalized\\n  1239→\\t}\\n  1240→\\n  1241→\\treturn modifiedFiles\\n  1242→}\\n  1243→\\n  1244→// addTrailerForAgentCommit handles the fast path when an agent is committing\\n  1245→// (ACTIVE session + no TTY). Generates a checkpoint ID and adds the trailer\\n  1246→// directly, bypassing content detection and interactive prompts.\\n  1247→func (s *ManualCommitStrategy) addTrailerForAgentCommit(logCtx context.Context, commitMsgFile string, state *SessionState, source string) error {\\n  1248→\\tcpID, err := id.Generate()\\n  1249→\\tif err != nil {\\n  1250→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1251→\\t}\\n  1252→\\n  1253→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n  1254→\\tif err != nil {\\n  1255→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1256→\\t}\\n  1257→\\n  1258→\\tmessage := string(content)\\n  1259→\\n  1260→\\t// Don't add if trailer already exists\\n  1261→\\tif _, found := trailers.ParseCheckpoint(message); found {\\n  1262→\\t\\treturn nil\\n  1263→\\t}\\n  1264→\\n  1265→\\tmessage = addCheckpointTrailer(message, cpID)\\n  1266→\\n  1267→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: agent commit trailer added\\\",\\n  1268→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n  1269→\\t\\tslog.String(\\\"source\\\", source),\\n  1270→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n  1271→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1272→\\t)\\n  1273→\\n  1274→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n  1275→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1276→\\t}\\n  1277→\\treturn nil\\n  1278→}\\n  1279→\\n  1280→// addCheckpointTrailer adds the Entire-Checkpoint trailer to a commit message.\\n  1281→// Handles proper trailer formatting (blank line before trailers if needed).\\n  1282→func addCheckpointTrailer(message string, checkpointID id.CheckpointID) string {\\n  1283→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1284→\\n  1285→\\t// If message already ends with trailers (lines starting with key:), just append\\n  1286→\\t// Otherwise, add a blank line first\\n  1287→\\tlines := strings.Split(strings.TrimRight(message, \\\"\\\\n\\\"), \\\"\\\\n\\\")\\n  1288→\\n  1289→\\t// Check if the message already ends with a trailer paragraph.\\n  1290→\\t// Git trailers must be in a separate paragraph (preceded by a blank line).\\n  1291→\\t// A single-paragraph message (e.g., just a subject line) cannot have trailers,\\n  1292→\\t// even if the subject contains \\\": \\\" (like conventional commits: \\\"docs: Add foo\\\").\\n  1293→\\t//\\n  1294→\\t// Scan from the bottom: find the last paragraph of non-comment content,\\n  1295→\\t// then check if it looks like trailers AND has a blank line above it.\\n  1296→\\thasTrailers := false\\n  1297→\\ti := len(lines) - 1\\n  1298→\\n  1299→\\t// Skip trailing comment lines\\n  1300→\\tfor i >= 0 && strings.HasPrefix(strings.TrimSpace(lines[i]), \\\"#\\\") {\\n  1301→\\t\\ti--\\n  1302→\\t}\\n  1303→\\n  1304→\\t// Check if the last non-comment line looks like a trailer\\n  1305→\\tif i >= 0 {\\n  1306→\\t\\tline := strings.TrimSpace(lines[i])\\n  1307→\\t\\tif line != \\\"\\\" && strings.Contains(line, \\\": \\\") {\\n  1308→\\t\\t\\t// Found a trailer-like line. Now scan upward past the trailer block\\n  1309→\\t\\t\\t// to verify there's a blank line (paragraph separator) above it.\\n  1310→\\t\\t\\tfor i > 0 {\\n  1311→\\t\\t\\t\\ti--\\n  1312→\\t\\t\\t\\tabove := strings.TrimSpace(lines[i])\\n  1313→\\t\\t\\t\\tif strings.HasPrefix(above, \\\"#\\\") {\\n  1314→\\t\\t\\t\\t\\tcontinue\\n  1315→\\t\\t\\t\\t}\\n  1316→\\t\\t\\t\\tif above == \\\"\\\" {\\n  1317→\\t\\t\\t\\t\\t// Blank line found above trailer block — real trailers\\n  1318→\\t\\t\\t\\t\\thasTrailers = true\\n  1319→\\t\\t\\t\\t\\tbreak\\n  1320→\\t\\t\\t\\t}\\n  1321→\\t\\t\\t\\tif !strings.Contains(above, \\\": \\\") {\\n  1322→\\t\\t\\t\\t\\t// Non-trailer, non-blank line — this is message body, not trailers\\n  1323→\\t\\t\\t\\t\\tbreak\\n  1324→\\t\\t\\t\\t}\\n  1325→\\t\\t\\t\\t// Another trailer-like line, keep scanning upward\\n  1326→\\t\\t\\t}\\n  1327→\\t\\t}\\n  1328→\\t}\\n  1329→\\n  1330→\\tif hasTrailers {\\n  1331→\\t\\t// Append trailer directly\\n  1332→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1333→\\t}\\n  1334→\\n  1335→\\t// Add blank line before trailer\\n  1336→\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1337→}\\n  1338→\\n  1339→// addCheckpointTrailerWithComment adds the Entire-Checkpoint trailer with an explanatory comment.\\n  1340→// The trailer is placed above the git comment block but below the user's message area,\\n  1341→// with a comment explaining that the user can remove it if they don't want to link the commit\\n  1342→// to the agent session. If prompt is non-empty, it's shown as context.\\n  1343→func addCheckpointTrailerWithComment(message string, checkpointID id.CheckpointID, agentName, prompt string) string {\\n  1344→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1345→\\tcommentLines := []string{\\n  1346→\\t\\t\\\"# Remove the Entire-Checkpoint trailer above if you don't want to link this commit to \\\" + agentName + \\\" session context.\\\",\\n  1347→\\t}\\n  1348→\\tif prompt != \\\"\\\" {\\n  1349→\\t\\tcommentLines = append(commentLines, \\\"# Last Prompt: \\\"+prompt)\\n  1350→\\t}\\n  1351→\\tcommentLines = append(commentLines, \\\"# The trailer will be added to your next commit based on this branch.\\\")\\n  1352→\\tcomment := strings.Join(commentLines, \\\"\\\\n\\\")\\n  1353→\\n  1354→\\tlines := strings.Split(message, \\\"\\\\n\\\")\\n  1355→\\n  1356→\\t// Find where the git comment block starts (first # line)\\n  1357→\\tcommentStart := -1\\n  1358→\\tfor i, line := range lines {\\n  1359→\\t\\tif strings.HasPrefix(line, \\\"#\\\") {\\n  1360→\\t\\t\\tcommentStart = i\\n  1361→\\t\\t\\tbreak\\n  1362→\\t\\t}\\n  1363→\\t}\\n  1364→\\n  1365→\\tif commentStart == -1 {\\n  1366→\\t\\t// No git comments, append trailer at the end\\n  1367→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\"\\n  1368→\\t}\\n  1369→\\n  1370→\\t// Split into user content and git comments\\n  1371→\\tuserContent := strings.Join(lines[:commentStart], \\\"\\\\n\\\")\\n  1372→\\tgitComments := strings.Join(lines[commentStart:], \\\"\\\\n\\\")\\n  1373→\\n  1374→\\t// Build result: user content, blank line, trailer, comment, blank line, git comments\\n  1375→\\tuserContent = strings.TrimRight(userContent, \\\"\\\\n\\\")\\n  1376→\\tif userContent == \\\"\\\" {\\n  1377→\\t\\t// No user content yet - leave space for them to type, then trailer\\n  1378→\\t\\t// Two newlines: first for user's message line, second for blank separator\\n  1379→\\t\\treturn \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1380→\\t}\\n  1381→\\treturn userContent + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1382→}\\n  1383→\\n  1384→// InitializeSession creates session state for a new session or updates an existing one.\\n  1385→// This implements the optional SessionInitializer interface.\\n  1386→// Called during UserPromptSubmit to allow git hooks to detect active sessions.\\n  1387→//\\n  1388→// If the session already exists and HEAD has moved (e.g., user committed), updates\\n  1389→// BaseCommit to the new HEAD so future checkpoints go to the correct shadow branch.\\n  1390→//\\n  1391→// If there's an existing shadow branch with commits from a different session ID,\\n  1392→// returns a SessionIDConflictError to prevent orphaning existing session work.\\n  1393→//\\n  1394→// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n  1395→// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n  1396→// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\n  1397→func (s *ManualCommitStrategy) InitializeSession(sessionID string, agentType agent.AgentType, transcriptPath string, userPrompt string) error {\\n  1398→\\trepo, err := OpenRepository()\\n  1399→\\tif err != nil {\\n  1400→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n  1401→\\t}\\n  1402→\\n  1403→\\t// Check if session already exists\\n  1404→\\tstate, err := s.loadSessionState(sessionID)\\n  1405→\\tif err != nil {\\n  1406→\\t\\treturn fmt.Errorf(\\\"failed to check session state: %w\\\", err)\\n  1407→\\t}\\n  1408→\\n  1409→\\tif state != nil && state.BaseCommit != \\\"\\\" {\\n  1410→\\t\\t// Session is fully initialized — apply phase transition for TurnStart.\\n  1411→\\t\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1412→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1413→\\t\\t}\\n  1414→\\n  1415→\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n  1416→\\t\\tturnID, err := id.Generate()\\n  1417→\\t\\tif err != nil {\\n  1418→\\t\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n  1419→\\t\\t}\\n  1420→\\t\\tstate.TurnID = turnID.String()\\n  1421→\\n  1422→\\t\\t// Backfill AgentType if empty or set to the generic default \\\"Agent\\\"\\n  1423→\\t\\tif !isSpecificAgentType(state.AgentType) && agentType != \\\"\\\" {\\n  1424→\\t\\t\\tstate.AgentType = agentType\\n  1425→\\t\\t}\\n  1426→\\n  1427→\\t\\t// Backfill FirstPrompt if empty (for sessions created before the first_prompt field was added)\\n  1428→\\t\\tif state.FirstPrompt == \\\"\\\" && userPrompt != \\\"\\\" {\\n  1429→\\t\\t\\tstate.FirstPrompt = truncatePromptForStorage(userPrompt)\\n  1430→\\t\\t}\\n  1431→\\n  1432→\\t\\t// Update transcript path if provided (may change on session resume)\\n  1433→\\t\\tif transcriptPath != \\\"\\\" && state.TranscriptPath != transcriptPath {\\n  1434→\\t\\t\\tstate.TranscriptPath = transcriptPath\\n  1435→\\t\\t}\\n  1436→\\n  1437→\\t\\t// Clear checkpoint IDs on every new prompt.\\n  1438→\\t\\t// LastCheckpointID is set during PostCommit, cleared at new prompt.\\n  1439→\\t\\t// TurnCheckpointIDs tracks mid-turn checkpoints for stop-time finalization.\\n  1440→\\t\\tstate.LastCheckpointID = \\\"\\\"\\n  1441→\\t\\tstate.TurnCheckpointIDs = nil\\n  1442→\\n  1443→\\t\\t// Calculate attribution at prompt start (BEFORE agent makes any changes)\\n  1444→\\t\\t// This captures user edits since the last checkpoint (or base commit for first prompt).\\n  1445→\\t\\t// IMPORTANT: Always calculate attribution, even for the first checkpoint, to capture\\n  1446→\\t\\t// user edits made before the first prompt. The inner CalculatePromptAttribution handles\\n  1447→\\t\\t// nil lastCheckpointTree by falling back to baseTree.\\n  1448→\\t\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n  1449→\\t\\tstate.PendingPromptAttribution = &promptAttr\\n  1450→\\n  1451→\\t\\t// Check if HEAD has moved (user pulled/rebased or committed)\\n  1452→\\t\\t// migrateShadowBranchIfNeeded handles renaming the shadow branch and updating state.BaseCommit\\n  1453→\\t\\tif _, err := s.migrateShadowBranchIfNeeded(repo, state); err != nil {\\n  1454→\\t\\t\\treturn fmt.Errorf(\\\"failed to check/migrate shadow branch: %w\\\", err)\\n  1455→\\t\\t}\\n  1456→\\n  1457→\\t\\tif err := s.saveSessionState(state); err != nil {\\n  1458→\\t\\t\\treturn fmt.Errorf(\\\"failed to update session state: %w\\\", err)\\n  1459→\\t\\t}\\n  1460→\\t\\treturn nil\\n  1461→\\t}\\n  1462→\\t// If state exists but BaseCommit is empty, it's a partial state from concurrent warning\\n  1463→\\t// Continue below to properly initialize it\\n  1464→\\n  1465→\\t// Initialize new session\\n  1466→\\tstate, err = s.initializeSession(repo, sessionID, agentType, transcriptPath, userPrompt)\\n  1467→\\tif err != nil {\\n  1468→\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n  1469→\\t}\\n  1470→\\n  1471→\\t// Apply phase transition: new session starts as ACTIVE.\\n  1472→\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1473→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1474→\\t}\\n  1475→\\n  1476→\\t// Calculate attribution for pre-prompt edits\\n  1477→\\t// This captures any user edits made before the first