n    85→\\n    86→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    87→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    88→func (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n    89→\\tstore, err := s.getCheckpointStore()\\n    90→\\tif err != nil {\\n    91→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    92→\\t}\\n    93→\\n    94→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n    95→\\tif err != nil {\\n    96→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    97→\\t}\\n    98→\\tif content == nil {\\n    99→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n   100→\\t}\\n   101→\\tif len(content.Transcript) == 0 {\\n   102→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   103→\\t}\\n   104→\\n   105→\\treturn content.Transcript, nil\\n   106→}\\n   107→\\n   108→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   109→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   110→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   111→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   112→//\\n   113→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   114→// In this case, data is extracted from the live transcript instead.\\n   115→func (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n   116→\\t// Get shadow branch (may not exist for mid-session commits)\\n   117→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   118→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   119→\\tref, err := repo.Reference(refName, true)\\n   120→\\thasShadowBranch := err == nil\\n   121→\\n   122→\\tvar sessionData *ExtractedSessionData\\n   123→\\tif hasShadowBranch {\\n   124→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   125→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   126→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   127→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   128→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   129→\\t\\t// last turn had no code changes).\\n   130→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   131→\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n   132→\\t\\tif err != nil {\\n   133→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n   134→\\t\\t}\\n   135→\\t} else {\\n   136→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   137→\\t\\t// Extract data directly from live transcript.\\n   138→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   139→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   140→\\t\\t}\\n   141→\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n   142→\\t\\tif err != nil {\\n   143→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n   144→\\t\\t}\\n   145→\\t}\\n   146→\\n   147→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   148→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   149→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   150→\\tif len(committedFiles) > 0 {\\n   151→\\t\\t// Track if we had files before filtering to distinguish between:\\n   152→\\t\\t// - Session had files but none were committed (don't fallback)\\n   153→\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n   154→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   155→\\n   156→\\t\\tif hadFilesBeforeFiltering {\\n   157→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   158→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   159→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   160→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   161→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   162→\\t\\t\\t\\t}\\n   163→\\t\\t\\t}\\n   164→\\t\\t\\tsessionData.FilesTouched = filtered\\n   165→\\t\\t}\\n   166→\\n   167→\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n   168→\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n   169→\\t\\t// the session had files that simply didn't overlap with the commit - that\\n   170→\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n   171→\\t\\t// overwritten with unrelated committed files.\\n   172→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   173→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   174→\\t\\t\\tfor f := range committedFiles {\\n   175→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   176→\\t\\t\\t}\\n   177→\\t\\t}\\n   178→\\t}\\n   179→\\n   180→\\t// Get checkpoint store\\n   181→\\tstore, err := s.getCheckpointStore()\\n   182→\\tif err != nil {\\n   183→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   184→\\t}\\n   185→\\n   186→\\t// Get author info\\n   187→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   188→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   189→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   190→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   191→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n   192→\\t// Get current branch name\\n   193→\\tbranchName := GetCurrentBranchName(repo)\\n   194→\\n   195→\\t// Generate summary if enabled\\n   196→\\tvar summary *cpkg.Summary\\n   197→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   198→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   199→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   200→\\n   201→\\t\\t// Scope transcript to this checkpoint's portion.\\n   202→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   203→\\t\\t// For Gemini (JSON), CheckpointTranscriptStart is a message index.\\n   204→\\t\\tvar scopedTranscript []byte\\n   205→\\t\\tif state.AgentType == agent.AgentTypeGemini {\\n   206→\\t\\t\\tscopedTranscript = geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   207→\\t\\t} else {\\n   208→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   209→\\t\\t}\\n   210→\\t\\tif len(scopedTranscript) > 0 {\\n   211→\\t\\t\\tvar err error\\n   212→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   213→\\t\\t\\tif err != nil {\\n   214→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   215→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   216→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   217→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   218→\\t\\t\\t} else {\\n   219→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   220→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   221→\\t\\t\\t}\\n   222→\\t\\t}\\n   223→\\t}\\n   224→\\n   225→\\t// Write checkpoint metadata using the checkpoint store\\n   226→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   227→\\t\\tCheckpointID:                checkpointID,\\n   228→\\t\\tSessionID:                   state.SessionID,\\n   229→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   230→\\t\\tBranch:                      branchName,\\n   231→\\t\\tTranscript:                  sessionData.Transcript,\\n   232→\\t\\tPrompts:                     sessionData.Prompts,\\n   233→\\t\\tContext:                     sessionData.Context,\\n   234→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   235→\\t\\tCheckpointsCount:            state.StepCount,\\n   236→\\t\\tEphemeralBranch:             shadowBranchName,\\n   237→\\t\\tAuthorName:                  authorName,\\n   238→\\t\\tAuthorEmail:                 authorEmail,\\n   239→\\t\\tAgent:                       state.AgentType,\\n   240→\\t\\tTurnID:                      state.TurnID,\\n   241→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   242→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   243→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   244→\\t\\tExportData:                  sessionData.ExportData,\\n   245→\\t\\tInitialAttribution:          attribution,\\n   246→\\t\\tSummary:                     summary,\\n   247→\\t}); err != nil {\\n   248→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   249→\\t}\\n   250→\\n   251→\\treturn &CondenseResult{\\n   252→\\t\\tCheckpointID:         checkpointID,\\n   253→\\t\\tSessionID:            state.SessionID,\\n   254→\\t\\tCheckpointsCount:     state.StepCount,\\n   255→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   256→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   257→\\t}, nil\\n   258→}\\n   259→\\n   260→func calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n   261→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   262→\\t// This uses user edits captured at each prompt start (before agent works),\\n   263→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   264→\\t//\\n   265→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   266→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   267→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   268→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   269→\\n   270→\\theadRef, headErr := repo.Head()\\n   271→\\tif headErr != nil {\\n   272→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   273→\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   274→\\t\\treturn nil\\n   275→\\t}\\n   276→\\n   277→\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   278→\\tif commitErr != nil {\\n   279→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   280→\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   281→\\t\\treturn nil\\n   282→\\t}\\n   283→\\n   284→\\theadTree, treeErr := headCommit.Tree()\\n   285→\\tif treeErr != nil {\\n   286→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   287→\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   288→\\t\\treturn nil\\n   289→\\t}\\n   290→\\n   291→\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n   292→\\tvar shadowTree *object.Tree\\n   293→\\tif shadowRef != nil {\\n   294→\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   295→\\t\\tif shadowErr != nil {\\n   296→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   297→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   298→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   299→\\t\\t\\treturn nil\\n   300→\\t\\t}\\n   301→\\t\\tvar shadowTreeErr error\\n   302→\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   303→\\t\\tif shadowTreeErr != nil {\\n   304→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   305→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   306→\\t\\t\\treturn nil\\n   307→\\t\\t}\\n   308→\\t} else {\\n   309→\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   310→\\t\\t// because the agent's work is the commit itself.\\n   311→\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   312→\\t\\tshadowTree = headTree\\n   313→\\t}\\n   314→\\n   315→\\t// Get base tree (state before session started)\\n   316→\\tvar baseTree *object.Tree\\n   317→\\tattrBase := state.AttributionBaseCommit\\n   318→\\tif attrBase == \\\"\\\" {\\n   319→\\t\\tattrBase = state.BaseCommit // backward compat\\n   320→\\t}\\n   321→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   322→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   323→\\t\\t\\tbaseTree = tree\\n   324→\\t\\t} else {\\n   325→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   326→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   327→\\t\\t}\\n   328→\\t} else {\\n   329→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   330→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   331→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   332→\\t}\\n   333→\\n   334→\\t// Log accumulated prompt attributions for debugging\\n   335→\\tvar totalUserAdded, totalUserRemoved int\\n   336→\\tfor i, pa := range state.PromptAttributions {\\n   337→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   338→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   339→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   340→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   341→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   342→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   343→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   344→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   345→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   346→\\t}\\n   347→\\n   348→\\tattribution := CalculateAttributionWithAccumulated(\\n   349→\\t\\tbaseTree,\\n   350→\\t\\tshadowTree,\\n   351→\\t\\theadTree,\\n   352→\\t\\tsessionData.FilesTouched,\\n   353→\\t\\tstate.PromptAttributions,\\n   354→\\t)\\n   355→\\n   356→\\tif attribution != nil {\\n   357→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   358→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   359→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   360→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   361→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   362→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   363→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   364→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   365→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   366→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   367→\\t}\\n   368→\\n   369→\\treturn attribution\\n   370→}\\n   371→\\n   372→// extractSessionData extracts session data from the shadow branch.\\n   373→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   374→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   375→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   376→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   377→// continued growing — the shadow branch copy would be stale.\\n   378→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   379→func (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n   380→\\tcommit, err := repo.CommitObject(shadowRef)\\n   381→\\tif err != nil {\\n   382→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   383→\\t}\\n   384→\\n   385→\\ttree, err := commit.Tree()\\n   386→\\tif err != nil {\\n   387→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   388→\\t}\\n   389→\\n   390→\\tdata := &ExtractedSessionData{}\\n   391→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   392→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   393→\\n   394→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   395→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   396→\\t// (SaveStep is only called when there are file modifications).\\n   397→\\tvar fullTranscript string\\n   398→\\tif liveTranscriptPath != \\\"\\\" {\\n   399→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   400→\\t\\t\\tfullTranscript = string(liveData)\\n   401→\\t\\t}\\n   402→\\t}\\n   403→\\tif fullTranscript == \\\"\\\" {\\n   404→\\t\\t// Fall back to shadow branch copy\\n   405→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   406→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   407→\\t\\t\\t\\tfullTranscript = content\\n   408→\\t\\t\\t}\\n   409→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   410→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   411→\\t\\t\\t\\tfullTranscript = content\\n   412→\\t\\t\\t}\\n   413→\\t\\t}\\n   414→\\t}\\n   415→\\n   416→\\t// Process transcript based on agent type\\n   417→\\tif fullTranscript != \\\"\\\" {\\n   418→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   419→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   420→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   421→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   422→\\t}\\n   423→\\n   424→\\t// Use tracked files from session state (not all files in tree)\\n   425→\\tdata.FilesTouched = filesTouched\\n   426→\\n   427→\\t// Read export data from local metadata directory (e.g., OpenCode SQLite export).\\n   428→\\t// This is written by lifecycle.go during TurnEnd and must be stored in the\\n   429→\\t// committed checkpoint so resume/rewind can re-import the session.\\n   430→\\texportRelPath := metadataDir + \\\"/\\\" + paths.ExportDataFileName\\n   431→\\tif exportAbsPath, absErr := paths.AbsPath(exportRelPath); absErr == nil {\\n   432→\\t\\tif exportBytes, readErr := os.ReadFile(exportAbsPath); readErr == nil && len(exportBytes) > 0 { //nolint:gosec // path from session metadata\\n   433→\\t\\t\\tdata.ExportData = exportBytes\\n   434→\\t\\t}\\n   435→\\t}\\n   436→\\n   437→\\t// Calculate token usage from the extracted transcript portion\\n   438→\\tif len(data.Transcript) > 0 {\\n   439→\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n   440→\\t}\\n   441→\\n   442→\\treturn data, nil\\n   443→}\\n   444→\\n   445→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   446→// This is used for mid-session commits where no shadow branch exists yet.\\n   447→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n   448→\\tdata := &ExtractedSessionData{}\\n   449→\\n   450→\\t// Read the live transcript\\n   451→\\tif state.TranscriptPath == \\\"\\\" {\\n   452→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   453→\\t}\\n   454→\\n   455→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   456→\\tif err != nil {\\n   457→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   458→\\t}\\n   459→\\n   460→\\tif len(liveData) == 0 {\\n   461→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   462→\\t}\\n   463→\\n   464→\\tfullTranscript := string(liveData)\\n   465→\\tdata.Transcript = liveData\\n   466→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   467→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   468→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   469→\\n   470→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   471→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   472→\\tif len(state.FilesTouched) > 0 {\\n   473→\\t\\tdata.FilesTouched = state.FilesTouched\\n   474→\\t} else {\\n   475→\\t\\t// Use the shared helper which includes subagent transcripts\\n   476→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n   477→\\t}\\n   478→\\n   479→\\t// Read export data from local metadata directory\\n   480→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(state.SessionID)\\n   481→\\texportRelPath := metadataDir + \\\"/\\\" + paths.ExportDataFileName\\n   482→\\tif exportAbsPath, absErr := paths.AbsPath(exportRelPath); absErr == nil {\\n   483→\\t\\tif exportBytes, readErr := os.ReadFile(exportAbsPath); readErr == nil && len(exportBytes) > 0 { //nolint:gosec // path from session metadata\\n   484→\\t\\t\\tdata.ExportData = exportBytes\\n   485→\\t\\t}\\n   486→\\t}\\n   487→\\n   488→\\t// Calculate token usage from the extracted transcript portion\\n   489→\\tif len(data.Transcript) > 0 {\\n   490→\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n   491→\\t}\\n   492→\\n   493→\\treturn data, nil\\n   494→}\\n   495→\\n   496→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   497→// For Claude Code and JSONL-based agents, this counts lines.\\n   498→// For Gemini CLI and JSON-based agents, this counts messages.\\n   499→// Returns 0 if the content is empty or malformed.\\n   500→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   501→\\tif content == \\\"\\\" {\\n   502→\\t\\treturn 0\\n   503→\\t}\\n   504→\\n   505→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   506→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   507→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   508→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   509→\\t\\t\\treturn len(transcript.Messages)\\n   510→\\t\\t}\\n   511→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   512→\\t\\tif agentType == agent.AgentTypeGemini {\\n   513→\\t\\t\\treturn 0\\n   514→\\t\\t}\\n   515→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   516→\\t}\\n   517→\\n   518→\\t// Claude Code and other JSONL-based agents\\n   519→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   520→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   521→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   522→\\t\\tallLines = allLines[:len(allLines)-1]\\n   523→\\t}\\n   524→\\treturn len(allLines)\\n   525→}\\n   526→\\n   527→// extractUserPrompts extracts all user prompts from transcript content.\\n   528→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   529→func extractUserPrompts(agentType agent.AgentType, content string) []string {\\n   530→\\tif content == \\\"\\\" {\\n   531→\\t\\treturn nil\\n   532→\\t}\\n   533→\\n   534→\\t// Droid has its own envelope format — use its parser to normalize first\\n   535→\\tif agentType == agent.AgentTypeFactoryAIDroid {\\n   536→\\t\\tlines, err := factoryaidroid.ParseDroidTranscriptFromBytes([]byte(content))\\n   537→\\t\\tif err != nil {\\n   538→\\t\\t\\treturn nil\\n   539→\\t\\t}\\n   540→\\t\\tvar prompts []string\\n   541→\\t\\tfor _, line := range lines {\\n   542→\\t\\t\\tif line.Type != transcript.TypeUser {\\n   543→\\t\\t\\t\\tcontinue\\n   544→\\t\\t\\t}\\n   545→\\t\\t\\tif text := transcript.ExtractUserContent(line.Message); text != \\\"\\\" {\\n   546→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(text); stripped != \\\"\\\" {\\n   547→\\t\\t\\t\\t\\tprompts = append(prompts, stripped)\\n   548→\\t\\t\\t\\t}\\n   549→\\t\\t\\t}\\n   550→\\t\\t}\\n   551→\\t\\treturn prompts\\n   552→\\t}\\n   553→\\n   554→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   555→\\tif agentType == agent.AgentTypeOpenCode {\\n   556→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   557→\\t\\tif err == nil && len(prompts) > 0 {\\n   558→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   559→\\t\\t\\tfor _, prompt := range prompts {\\n   560→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   561→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   562→\\t\\t\\t\\t}\\n   563→\\t\\t\\t}\\n   564→\\t\\t\\treturn cleaned\\n   565→\\t\\t}\\n   566→\\t\\treturn nil\\n   567→\\t}\\n   568→\\n   569→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   570→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   571→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   572→\\t\\tif err == nil && len(prompts) > 0 {\\n   573→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   574→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   575→\\t\\t\\tfor _, prompt := range prompts {\\n   576→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   577→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   578→\\t\\t\\t\\t}\\n   579→\\t\\t\\t}\\n   580→\\t\\t\\treturn cleaned\\n   581→\\t\\t}\\n   582→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   583→\\t\\tif agentType == agent.AgentTypeGemini {\\n   584→\\t\\t\\treturn nil\\n   585→\\t\\t}\\n   586→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   587→\\t}\\n   588→\\n   589→\\t// Claude Code and other JSONL-based agents\\n   590→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   591→}\\n   592→\\n   593→// calculateTokenUsage calculates token usage from raw transcript data.\\n   594→// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n   595→// where the current checkpoint began, allowing calculation for only the portion\\n   596→// of the transcript since the last checkpoint.\\n   597→func calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n   598→\\tif len(data) == 0 {\\n   599→\\t\\treturn &agent.TokenUsage{}\\n   600→\\t}\\n   601→\\n   602→\\t// Droid has its own envelope format — use its parser to normalize first\\n   603→\\tif agentType == agent.AgentTypeFactoryAIDroid {\\n   604→\\t\\tlines, err := factoryaidroid.ParseDroidTranscriptFromBytes(data)\\n   605→\\t\\tif err != nil || len(lines) == 0 {\\n   606→\\t\\t\\treturn &agent.TokenUsage{}\\n   607→\\t\\t}\\n   608→\\t\\tif startOffset > 0 && startOffset < len(lines) {\\n   609→\\t\\t\\tlines = lines[startOffset:]\\n   610→\\t\\t}\\n   611→\\t\\treturn factoryaidroid.CalculateTokenUsage(lines)\\n   612→\\t}\\n   613→\\t// OpenCode uses JSONL with token info on assistant messages (different schema from Claude Code)\\n   614→\\tif agentType == agent.AgentTypeOpenCode {\\n   615→\\t\\treturn opencode.CalculateTokenUsageFromBytes(data, startOffset)\\n   616→\\t}\\n   617→\\n   618→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   619→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   620→\\t\\t// Attempt to parse as Gemini JSON\\n   621→\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n   622→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   623→\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n   624→\\t\\t}\\n   625→\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n   626→\\t\\tif agentType == agent.AgentTypeGemini {\\n   627→\\t\\t\\treturn &agent.TokenUsage{}\\n   628→\\t\\t}\\n   629→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   630→\\t}\\n   631→\\n   632→\\t// Claude Code and other JSONL-based agents\\n   633→\\tlines, err := transcript.ParseFromBytes(data)\\n   634→\\tif err != nil || len(lines) == 0 {\\n   635→\\t\\treturn &agent.TokenUsage{}\\n   636→\\t}\\n   637→\\t// Slice transcript lines to only include checkpoint portion\\n   638→\\tif startOffset > 0 && startOffset < len(lines) {\\n   639→\\t\\tlines = lines[startOffset:]\\n   640→\\t}\\n   641→\\treturn claudecode.CalculateTokenUsage(lines)\\n   642→}\\n   643→\\n   644→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   645→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   646→func extractUserPromptsFromLines(lines []string) []string {\\n   647→\\tvar prompts []string\\n   648→\\tfor _, line := range lines {\\n   649→\\t\\tline = strings.TrimSpace(line)\\n   650→\\t\\tif line == \\\"\\\" {\\n   651→\\t\\t\\tcontinue\\n   652→\\t\\t}\\n   653→\\n   654→\\t\\tvar entry map[string]interface{}\\n   655→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   656→\\t\\t\\tcontinue\\n   657→\\t\\t}\\n   658→\\n   659→\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n   660→\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n   661→\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n   662→\\t\\t\\tcontinue\\n   663→\\t\\t}\\n   664→\\n   665→\\t\\t// Extract message content\\n   666→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   667→\\t\\tif !ok {\\n   668→\\t\\t\\tcontinue\\n   669→\\t\\t}\\n   670→\\n   671→\\t\\t// Handle string content\\n   672→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   673→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   674→\\t\\t\\tif cleaned != \\\"\\\" {\\n   675→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   676→\\t\\t\\t}\\n   677→\\t\\t\\tcontinue\\n   678→\\t\\t}\\n   679→\\n   680→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   681→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   682→\\t\\t\\tvar texts []string\\n   683→\\t\\t\\tfor _, item := range arr {\\n   684→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   685→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   686→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   687→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   688→\\t\\t\\t\\t\\t\\t}\\n   689→\\t\\t\\t\\t\\t}\\n   690→\\t\\t\\t\\t}\\n   691→\\t\\t\\t}\\n   692→\\t\\t\\tif len(texts) > 0 {\\n   693→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   694→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   695→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   696→\\t\\t\\t\\t}\\n   697→\\t\\t\\t}\\n   698→\\t\\t}\\n   699→\\t}\\n   700→\\treturn prompts\\n   701→}\\n   702→\\n   703→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   704→func generateContextFromPrompts(prompts []string) []byte {\\n   705→\\tif len(prompts) == 0 {\\n   706→\\t\\treturn nil\\n   707→\\t}\\n   708→\\n   709→\\tvar buf strings.Builder\\n   710→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   711→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   712→\\n   713→\\tfor i, prompt := range prompts {\\n   714→\\t\\t// Truncate very long prompts for readability\\n   715→\\t\\tdisplayPrompt := prompt\\n   716→\\t\\tif len(displayPrompt) > 500 {\\n   717→\\t\\t\\tdisplayPrompt = displayPrompt[:500] + \\\"...\\\"\\n   718→\\t\\t}\\n   719→\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n   720→\\t\\tbuf.WriteString(displayPrompt)\\n   721→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   722→\\t}\\n   723→\\n   724→\\treturn []byte(buf.String())\\n   725→}\\n   726→\\n   727→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   728→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   729→func (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n   730→\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n   731→\\n   732→\\t// Load session state\\n   733→\\tstate, err := s.loadSessionState(sessionID)\\n   734→\\tif err != nil {\\n   735→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   736→\\t}\\n   737→\\tif state == nil {\\n   738→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   739→\\t}\\n   740→\\n   741→\\t// Open repository\\n   742→\\trepo, err := OpenRepository()\\n   743→\\tif err != nil {\\n   744→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   745→\\t}\\n   746→\\n   747→\\t// Generate a checkpoint ID\\n   748→\\tcheckpointID, err := id.Generate()\\n   749→\\tif err != nil {\\n   750→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   751→\\t}\\n   752→\\n   753→\\t// Check if shadow branch exists (required for condensation)\\n   754→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   755→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   756→\\t_, refErr := repo.Reference(refName, true)\\n   757→\\thasShadowBranch := refErr == nil\\n   758→\\n   759→\\tif !hasShadowBranch {\\n   760→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   761→\\t\\t// Just clean up the state file.\\n   762→\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n   763→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   764→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   765→\\t\\t)\\n   766→\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n   767→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   768→\\t\\t}\\n   769→\\t\\treturn nil\\n   770→\\t}\\n   771→\\n   772→\\t// Condense the session\\n   773→\\tresult, err := s.CondenseSession(repo, checkpointID, state, nil)\\n   774→\\tif err != nil {\\n   775→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   776→\\t}\\n   777→\\n   778→\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n   779→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   780→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   781→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   782→\\t)\\n   783→\\n   784→\\t// Update session state: reset step count and transition to idle\\n   785→\\tstate.StepCount = 0\\n   786→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   787→\\tstate.Phase = session.PhaseIdle\\n   788→\\tstate.LastCheckpointID = checkpointID\\n   789→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   790→\\tstate.PromptAttributions = nil\\n   791→\\tstate.PendingPromptAttribution = nil\\n   792→\\n   793→\\tif err := s.saveSessionState(state); err != nil {\\n   794→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   795→\\t}\\n   796→\\n   797→\\t// Clean up shadow branch if no other sessions need it\\n   798→\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n   799→\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n   800→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   801→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   802→\\t\\t)\\n   803→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   804→\\t}\\n   805→\\n   806→\\treturn nil\\n   807→}\\n   808→\\n   809→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   810→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(_ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   811→\\t// List all session states to check if any other session uses this shadow branch\\n   812→\\tallStates, err := s.listAllSessionStates()\\n   813→\\tif err != nil {\\n   814→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   815→\\t}\\n   816→\\n   817→\\tfor _, state := range allStates {\\n   818→\\t\\tif state.SessionID == excludeSessionID {\\n   819→\\t\\t\\tcontinue\\n   820→\\t\\t}\\n   821→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   822→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   823→\\t\\t\\t// Another session still needs this shadow branch\\n   824→\\t\\t\\treturn nil\\n   825→\\t\\t}\\n   826→\\t}\\n   827→\\n   828→\\t// No other sessions need it, delete the shadow branch via CLI\\n   829→\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n   830→\\tif err := DeleteBranchCLI(shadowBranchName); err != nil {\\n   831→\\t\\t// Branch already gone is not an error\\n   832→\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n   833→\\t\\t\\treturn nil\\n   834→\\t\\t}\\n   835→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n   836→\\t}\\n   837→\\treturn nil\\n   838→}\\n   839→\"}]},\"uuid\":\"69dd5318-6cb7-408d-9978-f920947cb067\",\"timestamp\":\"2026-02-21T00:24:08.190Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alisha/Projects/wt/factoryai-agent/cmd/entire/cli/strategy/manual_commit_condensation.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/factoryaidroid\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/opencode\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// listCheckpoints returns all checkpoints from the metadata branch.\\n// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) listCheckpoints() ([]CheckpointInfo, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcommitted, err := store.ListCommitted(context.Background())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n\\t}\\n\\n\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n\\tresult := make([]CheckpointInfo, 0, len(committed))\\n\\tfor _, c := range committed {\\n\\t\\tresult = append(result, CheckpointInfo{\\n\\t\\t\\tCheckpointID:     c.CheckpointID,\\n\\t\\t\\tSessionID:        c.SessionID,\\n\\t\\t\\tCreatedAt:        c.CreatedAt,\\n\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n\\t\\t\\tFilesTouched:     c.FilesTouched,\\n\\t\\t\\tAgent:            c.Agent,\\n\\t\\t\\tIsTask:           c.IsTask,\\n\\t\\t\\tToolUseID:        c.ToolUseID,\\n\\t\\t\\tSessionCount:     c.SessionCount,\\n\\t\\t\\tSessionIDs:       c.SessionIDs,\\n\\t\\t})\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointsForSession returns all checkpoints for a session ID.\\nfunc (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n\\tall, err := s.listCheckpoints()\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tvar result []CheckpointInfo\\n\\tfor _, cp := range all {\\n\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n\\t\\t\\tresult = append(result, cp)\\n\\t\\t}\\n\\t}\\n\\n\\tif len(result) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// CondenseSession condenses a session's shadow branch to permanent storage.\\n// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n//\\n// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n// In this case, data is extracted from the live transcript instead.\\nfunc (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n\\t// Get shadow branch (may not exist for mid-session commits)\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\thasShadowBranch := err == nil\\n\\n\\tvar sessionData *ExtractedSessionData\\n\\tif hasShadowBranch {\\n\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n\\t\\t// last turn had no code changes).\\n\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n\\t\\t// Extract data directly from live transcript.\\n\\t\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n\\t\\t}\\n\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n\\t// committed in this specific commit. This ensures each checkpoint represents\\n\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n\\tif len(committedFiles) > 0 {\\n\\t\\t// Track if we had files before filtering to distinguish between:\\n\\t\\t// - Session had files but none were committed (don't fallback)\\n\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n\\n\\t\\tif hadFilesBeforeFiltering {\\n\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tsessionData.FilesTouched = filtered\\n\\t\\t}\\n\\n\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n\\t\\t// the session had files that simply didn't overlap with the commit - that\\n\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n\\t\\t// overwritten with unrelated committed files.\\n\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n\\t\\t\\tfor f := range committedFiles {\\n\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Get checkpoint store\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get author info\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Generate summary if enabled\\n\\tvar summary *cpkg.Summary\\n\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n\\n\\t\\t// Scope transcript to this checkpoint's portion.\\n\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n\\t\\t// For Gemini (JSON), CheckpointTranscriptStart is a message index.\\n\\t\\tvar scopedTranscript []byte\\n\\t\\tif state.AgentType == agent.AgentTypeGemini {\\n\\t\\t\\tscopedTranscript = geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t} else {\\n\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t}\\n\\t\\tif len(scopedTranscript) > 0 {\\n\\t\\t\\tvar err error\\n\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t\\t// Continue without summary - non-blocking\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write checkpoint metadata using the checkpoint store\\n\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n\\t\\tCheckpointID:                checkpointID,\\n\\t\\tSessionID:                   state.SessionID,\\n\\t\\tStrategy:                    StrategyNameManualCommit,\\n\\t\\tBranch:                      branchName,\\n\\t\\tTranscript:                  sessionData.Transcript,\\n\\t\\tPrompts:                     sessionData.Prompts,\\n\\t\\tContext:                     sessionData.Context,\\n\\t\\tFilesTouched:                sessionData.FilesTouched,\\n\\t\\tCheckpointsCount:            state.StepCount,\\n\\t\\tEphemeralBranch:             shadowBranchName,\\n\\t\\tAuthorName:                  authorName,\\n\\t\\tAuthorEmail:                 authorEmail,\\n\\t\\tAgent:                       state.AgentType,\\n\\t\\tTurnID:                      state.TurnID,\\n\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n\\t\\tExportData:                  sessionData.ExportData,\\n\\t\\tInitialAttribution:          attribution,\\n\\t\\tSummary:                     summary,\\n\\t}); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n\\t}\\n\\n\\treturn &CondenseResult{\\n\\t\\tCheckpointID:         checkpointID,\\n\\t\\tSessionID:            state.SessionID,\\n\\t\\tCheckpointsCount:     state.StepCount,\\n\\t\\tFilesTouched:         sessionData.FilesTouched,\\n\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n\\t}, nil\\n}\\n\\nfunc calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n\\t// Calculate initial attribution using accumulated prompt attribution data.\\n\\t// This uses user edits captured at each prompt start (before agent works),\\n\\t// plus any user edits after the final checkpoint (shadow → head).\\n\\t//\\n\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\n\\theadRef, headErr := repo.Head()\\n\\tif headErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n\\tif commitErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\theadTree, treeErr := headCommit.Tree()\\n\\tif treeErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n\\tvar shadowTree *object.Tree\\n\\tif shadowRef != nil {\\n\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n\\t\\tif shadowErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\tvar shadowTreeErr error\\n\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n\\t\\tif shadowTreeErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n\\t\\t// because the agent's work is the commit itself.\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n\\t\\tshadowTree = headTree\\n\\t}\\n\\n\\t// Get base tree (state before session started)\\n\\tvar baseTree *object.Tree\\n\\tattrBase := state.AttributionBaseCommit\\n\\tif attrBase == \\\"\\\" {\\n\\t\\tattrBase = state.BaseCommit // backward compat\\n\\t}\\n\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n\\t\\t\\tbaseTree = tree\\n\\t\\t} else {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n\\t\\t}\\n\\t} else {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n\\t}\\n\\n\\t// Log accumulated prompt attributions for debugging\\n\\tvar totalUserAdded, totalUserRemoved int\\n\\tfor i, pa := range state.PromptAttributions {\\n\\t\\ttotalUserAdded += pa.UserLinesAdded\\n\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"index\\\", i))\\n\\t}\\n\\n\\tattribution := CalculateAttributionWithAccumulated(\\n\\t\\tbaseTree,\\n\\t\\tshadowTree,\\n\\t\\theadTree,\\n\\t\\tsessionData.FilesTouched,\\n\\t\\tstate.PromptAttributions,\\n\\t)\\n\\n\\tif attribution != nil {\\n\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n\\t}\\n\\n\\treturn attribution\\n}\\n\\n// extractSessionData extracts session data from the shadow branch.\\n// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n// continued growing — the shadow branch copy would be stale.\\n// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\nfunc (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n\\tcommit, err := repo.CommitObject(shadowRef)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\tdata := &ExtractedSessionData{}\\n\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\n\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n\\t// (SaveStep is only called when there are file modifications).\\n\\tvar fullTranscript string\\n\\tif liveTranscriptPath != \\\"\\\" {\\n\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n\\t\\t\\tfullTranscript = string(liveData)\\n\\t\\t}\\n\\t}\\n\\tif fullTranscript == \\\"\\\" {\\n\\t\\t// Fall back to shadow branch copy\\n\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Process transcript based on agent type\\n\\tif fullTranscript != \\\"\\\" {\\n\\t\\tdata.Transcript = []byte(fullTranscript)\\n\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\t}\\n\\n\\t// Use tracked files from session state (not all files in tree)\\n\\tdata.FilesTouched = filesTouched\\n\\n\\t// Read export data from local metadata directory (e.g., OpenCode SQLite export).\\n\\t// This is written by lifecycle.go during TurnEnd and must be stored in the\\n\\t// committed checkpoint so resume/rewind can re-import the session.\\n\\texportRelPath := metadataDir + \\\"/\\\" + paths.ExportDataFileName\\n\\tif exportAbsPath, absErr := paths.AbsPath(exportRelPath); absErr == nil {\\n\\t\\tif exportBytes, readErr := os.ReadFile(exportAbsPath); readErr == nil && len(exportBytes) > 0 { //nolint:gosec // path from session metadata\\n\\t\\t\\tdata.ExportData = exportBytes\\n\\t\\t}\\n\\t}\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcri