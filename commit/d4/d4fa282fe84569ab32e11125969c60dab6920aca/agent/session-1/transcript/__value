ire-Checkpoint trailer found in history\\\")\\n   722→\\t}\\n   723→\\n   724→\\treturn checkpointID, nil\\n   725→}\\n   726→\\n   727→// GetLatestCheckpointID returns the checkpoint ID from HEAD commit, or empty string if none.\\n   728→// This is a convenience wrapper that doesn't fail the test on missing checkpoint.\\n   729→func (env *TestEnv) GetLatestCheckpointID() string {\\n   730→\\tenv.T.Helper()\\n   731→\\n   732→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   733→\\tif err != nil {\\n   734→\\t\\treturn \\\"\\\"\\n   735→\\t}\\n   736→\\n   737→\\thead, err := repo.Head()\\n   738→\\tif err != nil {\\n   739→\\t\\treturn \\\"\\\"\\n   740→\\t}\\n   741→\\n   742→\\tcommit, err := repo.CommitObject(head.Hash())\\n   743→\\tif err != nil {\\n   744→\\t\\treturn \\\"\\\"\\n   745→\\t}\\n   746→\\n   747→\\t// Look for Entire-Checkpoint trailer in HEAD commit only\\n   748→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n   749→\\t\\tline = strings.TrimSpace(line)\\n   750→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   751→\\t\\t\\treturn strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   752→\\t\\t}\\n   753→\\t}\\n   754→\\treturn \\\"\\\"\\n   755→}\\n   756→\\n   757→// safeIDPrefix returns first 12 chars of ID or the full ID if shorter.\\n   758→// Use this when logging checkpoint IDs to avoid index out of bounds panic.\\n   759→func safeIDPrefix(id string) string {\\n   760→\\tif len(id) >= 12 {\\n   761→\\t\\treturn id[:12]\\n   762→\\t}\\n   763→\\treturn id\\n   764→}\\n   765→\\n   766→// RunCLI runs the entire CLI with the given arguments and returns stdout.\\n   767→func (env *TestEnv) RunCLI(args ...string) string {\\n   768→\\tenv.T.Helper()\\n   769→\\toutput, err := env.RunCLIWithError(args...)\\n   770→\\tif err != nil {\\n   771→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   772→\\t}\\n   773→\\treturn output\\n  