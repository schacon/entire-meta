:\\\"id\\\"`\\n   559→\\t\\tMessage          string `json:\\\"message\\\"`\\n   560→\\t\\tMetadataDir      string `json:\\\"metadata_dir\\\"`\\n   561→\\t\\tDate             string `json:\\\"date\\\"`\\n   562→\\t\\tIsTaskCheckpoint bool   `json:\\\"is_task_checkpoint\\\"`\\n   563→\\t\\tToolUseID        string `json:\\\"tool_use_id\\\"`\\n   564→\\t\\tIsLogsOnly       bool   `json:\\\"is_logs_only\\\"`\\n   565→\\t\\tCondensationID   string `json:\\\"condensation_id\\\"`\\n   566→\\t}\\n   567→\\n   568→\\tif err := json.Unmarshal(output, &jsonPoints); err != nil {\\n   569→\\t\\tenv.T.Fatalf(\\\"failed to parse rewind points: %v\\\\nOutput: %s\\\", err, output)\\n   570→\\t}\\n   571→\\n   572→\\tpoints := make([]RewindPoint, len(jsonPoints))\\n   573→\\tfor i, jp := range jsonPoints {\\n   574→\\t\\t//nolint:errcheck // date parsing failure is acceptable, defaults to zero time\\n   575→\\t\\tdate, _ := time.Parse(time.RFC3339, jp.Date)\\n   576→\\t\\tpoints[i] = RewindPoint{\\n   577→\\t\\t\\tID:               jp.ID,\\n   578→\\t\\t\\tMessage:          jp.Message,\\n   579→\\t\\t\\tMetadataDir:      jp.MetadataDir,\\n   580→\\t\\t\\tDate:             date,\\n   581→\\t\\t\\tIsTaskCheckpoint: jp.IsTaskCheckpoint,\\n   582→\\t\\t\\tToolUseID:        jp.ToolUseID,\\n   583→\\t\\t\\tIsLogsOnly:       jp.IsLogsOnly,\\n   584→\\t\\t\\tCondensationID:   jp.CondensationID,\\n   585→\\t\\t}\\n   586→\\t}\\n   587→\\n   588→\\treturn points\\n   589→}\\n   590→\\n   591→// Rewind performs a rewind to the specified commit ID using the CLI.\\n   592→func (env *TestEnv) Rewind(commitID string) error {\\n   593→\\tenv.T.Helper()\\n   594→\\n   595→\\t//nolint:gosec,noctx // test code, commitID is from test setup, no context needed\\n   596→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID)\\n   597→\\tcmd.Dir = env.RepoDir\\n   598→\\n   599→\\toutput, err := cmd.CombinedOutput()\\n   600→\\tif err != nil {\\n   601→\\t\\treturn errors.New(\\\"rewind failed: \\\" + string(output))\\n   602→\\t}\\n   603→\\n   604→\\tenv.T.Logf(\\\"Rewind output: %s\\\", output)\\n   605→\\treturn nil\\n   606→}\\n   607→\\n   608→// BranchExists checks if a branch exists in the repository.\\n   609→func (env *TestEnv) BranchExists(branchName string) bool {\\n   610→\\tenv.T.Helper()\\n   611→\\n   612→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   613→\\tif err != nil {\\n   614→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   615→\\t}\\n   616→\\n   617→\\trefs, err := repo.References()\\n   618→\\tif err != nil {\\n   619→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   620→\\t}\\n   621→\\n   622→\\tfound := false\\n   623→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   624→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   625→\\t\\tif ref.Name().Short() == branchName {\\n   626→\\t\\t\\tfound = true\\n   627→\\t\\t}\\n   628→\\t\\treturn nil\\n   629→\\t})\\n   630→\\n   631→\\treturn found\\n   632→}\\n   633→\\n   634→// ListBranchesWithPrefix returns all branches that start with the given prefix.\\n   635→func (env *TestEnv) ListBranchesWithPrefix(prefix string) []string {\\n   636→\\tenv.T.Helper()\\n   637→\\n   638→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   639→\\tif err != nil {\\n   640→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   641→\\t}\\n   642→\\n   643→\\trefs, err := repo.References()\\n   644→\\tif err != nil {\\n   645→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   646→\\t}\\n   647→\\n   648→\\tvar branches []string\\n   649→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   650→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   651→\\t\\tname := ref.Name().Short()\\n   652→\\t\\tif strings.HasPrefix(name, prefix) {\\n   653→\\t\\t\\tbranches = append(branches, name)\\n   654→\\t\\t}\\n   655→\\t\\treturn nil\\n   656→\\t})\\n   657→\\n   658→\\treturn branches\\n   659→}\\n   660→\\n   661→// GetCommitMessage returns the commit message for the given commit hash.\\n   662→func (env *TestEnv) GetCommitMessage(hash string) string {\\n   663→\\tenv.T.Helper()\\n   664→\\n   665→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   666→\\tif err != nil {\\n   667→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   668→\\t}\\n   669→\\n   670→\\tcommitHash := plumbing.NewHash(hash)\\n   671→\\tcommit, err := repo.CommitObject(commitHash)\\n   672→\\tif err != nil {\\n   673→\\t\\tenv.T.Fatalf(\\\"failed to get commit %s: %v\\\", hash, err)\\n   674→\\t}\\n   675→\\n   676→\\treturn commit.Message\\n   677→}\\n   678→\\n   679→// GetLatestCheckpointIDFromHistory walks backwards from HEAD and returns\\n   680→// the checkpoint ID from the first commit with an Entire-Checkpoint trailer.\\n   681→// Returns an error if no checkpoint trailer is found in any commit.\\n   682→func (env *TestEnv) GetLatestCheckpointIDFromHistory() (string, error) {\\n   683→\\tenv.T.Helper()\\n   684→\\n   685→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   686→\\tif err != nil {\\n   687→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   688→\\t}\\n   689→\\n   690→\\thead, err := repo.Head()\\n   691→\\tif err != nil {\\n   692→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   693→\\t}\\n   694→\\n   695→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   696→\\tif err != nil {\\n   697→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   698→\\t}\\n   699→\\n   700→\\tvar checkpointID string\\n   701→\\t//nolint:errcheck,gosec // ForEach callback returns error to stop iteration, not a real error\\n   702→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   703→\\t\\t// Look for Entire-Checkpoint trailer\\n   704→\\t\\tfor _, line := range strings.Split(c.Message, \\\"\\\\n\\\") {\\n   705→\\t\\t\\tline = strings.TrimSpace(line)\\n   706→\\t\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   707→\\t\\t\\t\\tcheckpointID = strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   708→\\t\\t\\t\\treturn errors.New(\\\"stop iteration\\\")\\n   709→\\t\\t\\t}\\n   710→\\t\\t}\\n   711→\\t\\treturn nil\\n   712→\\t})\\n   713→\\n   714→\\tif checkpointID == \\\"\\\" {\\n   715→\\t\\treturn \\\"\\\", errors.New(\\\"no commit with Entire-Checkpoint trailer found in history\\\")\\n   716→\\t}\\n   717→\\n   718→\\treturn checkpointID, nil\\n   719→}\\n   720→\\n   721→// GetLatestCheckpointID returns the checkpoint ID from HEAD commit, or empty string if none.\\n   722→// This is a convenience wrapper that doesn't fail the test on missing checkpoint.\\n   723→func (env *TestEnv) GetLatestCheckpointID() string {\\n   724→\\tenv.T.Helper()\\n   725→\\n   726→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   727→\\tif err != nil {\\n   728→\\t\\treturn \\\"\\\"\\n   729→\\t}\\n   730→\\n   731→\\thead, err := repo.Head()\\n   732→\\tif err != nil {\\n   733→\\t\\treturn \\\"\\\"\\n   734→\\t}\\n   735→\\n   736→\\tcommit, err := repo.CommitObject(head.Hash())\\n   737→\\tif err != nil {\\n   738→\\t\\treturn \\\"\\\"\\n   739→\\t}\\n   740→\\n   741→\\t// Look for Entire-Checkpoint trailer in HEAD commit only\\n   742→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n   743→\\t\\tline = strings.TrimSpace(line)\\n   744→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   745→\\t\\t\\treturn strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   746→\\t\\t}\\n   747→\\t}\\n   748→\\treturn \\\"\\\"\\n   749→}\\n   750→\\n   751→// safeIDPrefix returns first 12 chars of ID or the full ID if shorter.\\n   752→// Use this when logging checkpoint IDs to avoid index out of bounds panic.\\n   753→func safeIDPrefix(id string) string {\\n   754→\\tif len(id) >= 12 {\\n   755→\\t\\treturn id[:12]\\n   756→\\t}\\n   757→\\treturn id\\n   758→}\\n   759→\\n   760→// RunCLI runs the entire CLI with the given arguments and returns stdout.\\n   761→func (env *TestEnv) RunCLI(args ...string) string {\\n   762→\\tenv.T.Helper()\\n   763→\\toutput, err := env.RunCLIWithError(args...)\\n   764→\\tif err != nil {\\n   765→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   766→\\t}\\n   767→\\treturn output\\n   768→}\\n   769→\\n   770→// RunCLIWithError runs the entire CLI and returns output and error.\\n   771→func (env *TestEnv) RunCLIWithError(args ...string) (string, error) {\\n   772→\\tenv.T.Helper()\\n   773→\\n   774→\\t//nolint:gosec,noctx // test code, args are from test setup, no context needed\\n   775→\\tcmd := exec.Command(getTestBinary(), args...)\\n   776→\\tcmd.Dir = env.RepoDir\\n   777→\\n   778→\\toutput, err := cmd.CombinedOutput()\\n   779→\\treturn string(output), err\\n   780→}\\n   781→\\n   782→// RunAgent runs the agent with the given prompt and returns the result.\\n   783→func (env *TestEnv) RunAgent(prompt string) (*AgentResult, error) {\\n   784→\\tenv.T.Helper()\\n   785→\\tresult, err := env.Agent.RunPrompt(context.Background(), env.RepoDir, prompt)\\n   786→\\tif err != nil && result != nil {\\n   787→\\t\\tenv.T.Logf(\\\"Agent failed with exit code %d\\\", result.ExitCode)\\n   788→\\t\\tif result.Stderr != \\\"\\\" {\\n   789→\\t\\t\\tenv.T.Logf(\\\"Agent stderr: %s\\\", result.Stderr)\\n   790→\\t\\t}\\n   791→\\t\\tif result.Stdout != \\\"\\\" {\\n   792→\\t\\t\\tenv.T.Logf(\\\"Agent stdout: %s\\\", result.Stdout)\\n   793→\\t\\t}\\n   794→\\t}\\n   795→\\t//nolint:wrapcheck // test helper, caller handles error\\n   796→\\treturn result, err\\n   797→}\\n   798→\\n   799→// RunAgentWithTools runs the agent with specific tools enabled.\\n   800→func (env *TestEnv) RunAgentWithTools(prompt string, tools []string) (*AgentResult, error) {\\n   801→\\tenv.T.Helper()\\n   802→\\tresult, err := env.Agent.RunPromptWith