\"`\\n    42→}\\n    43→\\n    44→// GenerateTrailTitle generates a title and description for a trail using the agent's\\n    45→// text generation capability. Returns (nil, nil) if the agent doesn't support text generation.\\n    46→func GenerateTrailTitle(ctx context.Context, transcriptBytes []byte, filesTouched []string, agentType types.AgentType) (*TrailTitleResult, error) {\\n    47→\\t// Get the active agent and check if it implements TextGenerator\\n    48→\\tag, err := agent.GetByAgentType(agentType)\\n    49→\\tif err != nil {\\n    50→\\t\\treturn nil, fmt.Errorf(\\\"agent not found: %w\\\", err)\\n    51→\\t}\\n    52→\\tgen, ok := ag.(agent.TextGenerator)\\n    53→\\tif !ok {\\n    54→\\t\\t// Agent does not support text generation: treat as non-fatal and return no result.\\n    55→\\t\\treturn nil, nil //nolint:nilnil // nil result signals \\\"not supported\\\", not an error\\n    56→\\t}\\n    57→\\n    58→\\t// Build condensed transcript (reuse existing infrastructure)\\n    59→\\tcondensed, err := BuildCondensedTranscriptFromBytes(transcriptBytes, agentType)\\n    60→\\tif err != nil {\\n    61→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    62→\\t}\\n    63→\\tif len(condensed) == 0 {\\n    64→\\t\\treturn nil, errors.New(\\\"transcript has no content\\\")\\n    65→\\t}\\n    66→\\n    67→\\tinput := Input{Transcript: condensed, FilesTouched: filesTouched}\\n    68→\\ttranscriptText := FormatCondensedTranscript(input)\\n    69→\\n    70→\\t// Build prompt and call agent's TextGenerator\\n    71→\\tprompt := fmt.Sprintf(trailTitlePromptTemplate, transcriptText)\\n    72→\\trawResult, err := gen.GenerateText(ctx, prompt, trailTitleModel)\\n    73→\\tif err != nil {\\n    74→\\t\\treturn nil, fmt.Errorf(\\\"text generation failed: %w\\\", err)\\n    75→\\t}\\n    76→\\n    77→\\t// Parse JSON response (handle markdown code blocks)\\n    78→\\tcleaned := extractJSONFromMarkdown(rawResult)\\n    79→\\tvar result TrailTitleResult\\n    80→\\tif err := json.Unmarshal([]byte(cleaned), &result); err != nil {\\n    81→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse trail title JSON: %w\\\", err)\\n    82→\\t}\\n    83→\\n    84→\\treturn &result, nil\\n    85→}\\n    86→\"}]},\"uuid\":\"adf57ea2-0ae5-4597-b4d3-3879c02a8d16\",\"timestamp\":\"2026-03-02T18:56:03.558Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a258ce91cb9bf4e9a\"},\"toolUseID\":\"agent_msg_013SqVoGhD5W7KdcSuLUSJBs\",\"parentToolUseID\":\"toolu_012wSJxF8Rt76XfgX6X6N1qk\",\"uuid\":\"0eeecc28-7c09-45ae-8326-44f9df75d782\",\"timestamp\":\"2026-03-02T18:56:03.567Z\"}\n{\"parentUuid\":\"0eeecc28-7c09-45ae-8326-44f9df75d782\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli\",\"sessionId\":\"888c4468-79b3-4d0f-b445-223ef1f2bb09\",\"version\":\"2.1.63\",\"gitBranch\":\"feat/trails\",\"slug\":\"snuggly-sauteeing-meadow\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-02T18:56:04.115Z\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01LdqhPh25rfX6NQcNTMKQSE\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01KiQMtCJCEaT7AjiaZKh8AP\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/agent/claudecode/generate.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":15115,\"cache_read_input_tokens\":21430,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":15115},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYemDB69ZFbbhRJvN18Ke\",\"uuid\":\"ef74e542-4493-45f2-9e1f-1af8d5700539\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a258ce91cb9bf4e9a\"},\"toolUseID\"