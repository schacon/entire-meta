\n   921→\\t\\thasNew:                 hasNew,\\n   922→\\t\\tfilesTouchedBefore:     filesTouchedBefore,\\n   923→\\t\\theadTree:               headTree,\\n   924→\\t\\tparentTree:             parentTree,\\n   925→\\t\\tshadowRef:              shadowRef,\\n   926→\\t\\tshadowTree:             shadowTree,\\n   927→\\t}\\n   928→\\n   929→\\tif err := TransitionAndLog(ctx, state, session.EventGitCommit, *transitionCtx, handler); err != nil {\\n   930→\\t\\tlogging.Warn(logCtx, \\\"post-commit action handler error\\\",\\n   931→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   932→\\t}\\n   933→\\n   934→\\t// Record checkpoint ID for ACTIVE sessions so HandleTurnEnd can finalize\\n   935→\\t// with full transcript. IDLE/ENDED sessions already have complete transcripts.\\n   936→\\t// NOTE: This check runs AFTER TransitionAndLog updated the phase. It relies on\\n   937→\\t// ACTIVE + GitCommit → ACTIVE (phase stays ACTIVE). If that state machine\\n   938→\\t// transition ever changed, this guard would silently stop recording IDs.\\n   939→\\tif handler.condensed && state.Phase.IsActive() {\\n   940→\\t\\tstate.TurnCheckpointIDs = append(state.TurnCheckpointIDs, checkpointID.String())\\n   941→\\t}\\n   942→\\n   943→\\t// Carry forward remaining uncommitted files so the next commit gets its\\n   944→\\t// own checkpoint ID. This applies to ALL phases — if a user splits their\\n   945→\\t// commit across two `git commit` invocations, each gets a 1:1 checkpoint.\\n   946→\\t// Uses content-aware comparison: if user did `git add -p` and committed\\n   947→\\t// partial changes, the file still has remaining agent changes to carry forward.\\n   948→\\tif handler.condensed {\\n   949→\\t\\tremainingFiles := filesWithRemainingAgentChanges(ctx, repo, shadowBranchName, commit, filesTouchedBefore, committedFileSet, overlapOpts{\\n   950→\\t\\t\\theadTree:   headTree,\\n   951→\\t\\t\\tshadowTree: shadowTree,\\n   952→\\t\\t})\\n   953→\\t\\tstate.FilesTouched = remainingFiles\\n   954→\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward decision (content-aware)\\\",\\n   955→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   956→\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   957→\\t\\t\\tslog.Int(\\\"committed_files\\\", len(committedFileSet)),\\n   958→\\t\\t\\tslog.Int(\\\"remaining_files\\\", len(remainingFiles)),\\n   959→\\t\\t\\tslog.Any(\\\"remaining\\\", remainingFiles),\\n   960→\\t\\t\\tslog.Any(\\\"committed_files\\\", committedFileSet),\\n   961→\\t\\t)\\n   962→\\t\\tif len(remainingFiles) > 0 {\\n   963→\\t\\t\\ts.carryForwardToNewShadowBranch(ctx, repo, state, remainingFiles)\\n   964→\\t\\t}\\n   965→\\t}\\n   966→\\n   967→\\t// Mark ENDED sessions as fully condensed when no carry-forward remains.\\n   968→\\t// PostCommit will skip these sessions entirely on future commits.\\n   969→\\t// They persist only for LastCheckpointID (amend trailer restoration).\\n   970→\\tif handler.condensed && state.Phase == session.PhaseEnded && len(state.FilesTouched) == 0 {\\n   971→\\t\\tstate.FullyCondensed = true\\n   972→\\t}\\n   973→\\n   974→\\t// Save the updated state\\n   975→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   976→\\t\\tlogging.Warn(logCtx, \\\"failed to update session state\\\",\\n   977→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   978→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   979→\\t}\\n   980→\\n   981→\\t// Only preserve shadow branch for active sessions that were NOT condensed.\\n   982→\\t// Condensed sessions already have their data on entire/checkpoints/v1.\\n   983→\\tif state.Phase.IsActive() && !handler.condensed {\"}]},\"uuid\":\"b9cd34f7-506c-4fab-815f-dac3e9accc09\",\"timestamp\":\"2026-03-02T18:56:37.486Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a258ce91cb9bf4e9a\"},\"toolUseID\":\"agent_msg_013SqVoGhD5W7KdcSuLUSJBs\",\"parentToolUseID\":\"toolu_012wSJxF