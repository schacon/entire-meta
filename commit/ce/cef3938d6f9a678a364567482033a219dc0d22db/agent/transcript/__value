ssion, filesWithRemainingAgentChanges, and calculateSessionAttributions.\\n   852→\\tvar shadowRef *plumbing.Reference\\n   853→\\tvar shadowTree *object.Tree\\n   854→\\tif ref, refErr := repo.Reference(plumbing.NewBranchReferenceName(shadowBranchName), true); refErr == nil {\\n   855→\\t\\tshadowRef = ref\\n   856→\\t\\tif sc, scErr := repo.CommitObject(ref.Hash()); scErr == nil {\\n   857→\\t\\t\\tif st, stErr := sc.Tree(); stErr == nil {\\n   858→\\t\\t\\t\\tshadowTree = st\\n   859→\\t\\t\\t}\\n   860→\\t\\t}\\n   861→\\t}\\n   862→\\n   863→\\t// Check for new content (needed for TransitionContext and condensation).\\n   864→\\t// Fail-open: if content check errors, assume new content exists so we\\n   865→\\t// don't silently skip data that should have been condensed.\\n   866→\\t//\\n   867→\\t// For ACTIVE sessions: the commit has a checkpoint trailer (verified above),\\n   868→\\t// meaning PrepareCommitMsg already determined this commit is session-related.\\n   869→\\t// The trailer is only added when either:\\n   870→\\t//   - No TTY (agent/subagent committing) — added unconditionally\\n   871→\\t//   - TTY (human committing) — added after content detection confirmed agent work\\n   872→\\t// In both cases, PrepareCommitMsg already validated this commit. We trust\\n   873→\\t// that decision here. Transcript-based re-validation is unreliable because\\n   874→\\t// subagent transcripts may not be available yet (subagent still running).\\n   875→\\tvar hasNew bool\\n   876→\\tif state.Phase.IsActive() {\\n   877→\\t\\thasNew = true\\n   878→\\t} else {\\n   879→\\t\\tvar contentErr error\\n   880→\\t\\thasNew, contentErr = s.sessionHasNewContent(ctx, repo, state, contentCheckOpts{shadowTree: shadowTree})\\n   881→\\t\\tif contentErr != nil {\\n   882→\\t\\t\\thasNew = true\\n   883→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: error checking session content, assuming new content\\\",\\n   884→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\