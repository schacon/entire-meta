            *object.Commit\\n   583→\\tnewHead                string\\n   584→\\tshadowBranchName       string\\n   585→\\tshadowBranchesToDelete map[string]struct{}\\n   586→\\tcommittedFileSet       map[string]struct{}\\n   587→\\thasNew                 bool\\n   588→\\tfilesTouchedBefore     []string\\n   589→\\n   590→\\t// Cached git objects — resolved once per PostCommit invocation to avoid\\n   591→\\t// redundant reads across filesOverlapWithContent, filesWithRemainingAgentChanges,\\n   592→\\t// CondenseSession, and calculateSessionAttributions.\\n   593→\\theadTree   *object.Tree        // HEAD commit tree (shared across all sessions)\\n   594→\\tparentTree *object.Tree        // HEAD's first parent tree (shared, nil for initial commits)\\n   595→\\tshadowRef  *plumbing.Reference // Per-session shadow branch ref (nil if branch doesn't exist)\\n   596→\\tshadowTree *object.Tree        // Per-session shadow commit tree (nil if branch doesn't exist)\\n   597→\\n   598→\\t// Output: set by handler methods, read by caller after TransitionAndLog.\\n   599→\\tcondensed bool\\n   600→}\\n   601→\\n   602→func (h *postCommitActionHandler) HandleCondense(state *session.State) error {\\n   603→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   604→\\tshouldCondense := h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   605→\\n   606→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondense decision\\\",\\n   607→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   608→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   609→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\"}]},\"uuid\":\"68b1e232-ece3-43b0-ad29-0ccf07d1e072\",\"timestamp\":\"2026-03-02T18:56:31.407Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a258ce91cb9bf4e9a\"},\"toolUseID\":\"agent_msg_013SqVoGhD5W7KdcSuLUSJBs\",\"parentToolUseID\":\"toolu_012wSJxF8Rt76XfgX6X6N1qk\",\"uuid\":\"2faebc5a-2fd5-4c2a-9eb8-ce8823bcb6ce\",\"tim