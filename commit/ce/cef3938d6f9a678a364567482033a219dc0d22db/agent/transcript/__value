  178→\\tvar title, body, base, branch, status string\\n   179→\\tvar checkout bool\\n   180→\\n   181→\\tcmd := &cobra.Command{\\n   182→\\t\\tUse:   \\\"create\\\",\\n   183→\\t\\tShort: \\\"Create a trail for the current or a new branch\\\",\\n   184→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   185→\\t\\t\\treturn runTrailCreate(cmd.OutOrStdout(), cmd.ErrOrStderr(), title, body, base, branch, status, checkout)\\n   186→\\t\\t},\\n   187→\\t}\\n   188→\\n   189→\\tcmd.Flags().StringVar(&title, \\\"title\\\", \\\"\\\", \\\"Trail title\\\")\\n   190→\\tcmd.Flags().StringVar(&body, \\\"body\\\", \\\"\\\", \\\"Trail body\\\")\\n   191→\\tcmd.Flags().StringVar(&base, \\\"base\\\", \\\"\\\", \\\"Base branch (defaults to detected default branch)\\\")\\n   192→\\tcmd.Flags().StringVar(&branch, \\\"branch\\\", \\\"\\\", \\\"Branch for the trail (defaults to current branch)\\\")\\n   193→\\tcmd.Flags().StringVar(&status, \\\"status\\\", \\\"\\\", \\\"Initial status (defaults to draft)\\\")\\n   194→\\tcmd.Flags().BoolVar(&checkout, \\\"checkout\\\", false, \\\"Check out the branch after creating it\\\")\\n   195→\\n   196→\\treturn cmd\\n   197→}\\n   198→\\n   199→//nolint:cyclop // sequential steps for creating a trail — splitting would obscure the flow\\n   200→func runTrailCreate(w, errW io.Writer, title, body, base, branch, statusStr string, checkout bool) error {\\n   201→\\trepo, err := strategy.OpenRepository(context.Background())\\n   202→\\tif err != nil {\\n   203→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   204→\\t}\\n   205→\\n   206→\\t// Determine base branch\\n   207→\\tif base == \\\"\\\" {\\n   208→\\t\\tbase = strategy.GetDefaultBranchName(repo)\\n   209→\\t\\tif base == \\\"\\\" {\\n   210→\\t\\t\\tbase = defaultBaseBranch\\n   211→\\t\\t}\\n   212→\\t}\\n   213→\\n   214→\\t_, currentBranch, _ := IsOnDefaultBranch(context.Background()) //nolint:errcheck // best-effort detection\\n   215→\\tinteractive := !hasFlag(\\\"title\\\") && !hasFlag(\\\"branch\\\")\\n   216→\\n   217→\\tif interactive {\\n   218→\\t\\t// Interactive flow: title → body → branch (derived) → status\\n   219→\\t\\tif err := runTrailCreateInteractive(&title, &body, &branch, &statusStr); err != nil {\\n   220→\\t\\t\\treturn err\\n   221→\\t\\t}\\n   222→\\t} else {\\n   223→\\t\\t// Non-interactive: derive missing values from provided flags\\n   224→\\t\\tif branch == \\\"\\\" {\\n   225→\\t\\t\\tif hasFlag(\\\"title\\\") {\\n   226→\\t\\t\\t\\tbranch = slugifyTitle(title)\\n   227→\\t\\t\\t} else {\\n   228→\\t\\t\\t\\tbranch = currentBranch\\n   229→\\t\\t\\t}\\n   230→\\t\\t}\\n   231→\\t\\tif title == \\\"\\\" {\\n   232→\\t\\t\\ttitle = trail.HumanizeBranchName(branch)\\n   233→\\t\\t}\\n   234→\\t}\\n   235→\\tif branch == \\\"\\\" {\\n   236→\\t\\treturn errors.New(\\\"branch name is required\\\")\\n   237→\\t}\\n   238→\\n   239→\\t// Create the branch if it doesn't exist\\n   240→\\tneedsCreation := branchNeedsCreation(repo, branch)\\n   241→\\tif needsCreation {\\n   242→\\t\\tif err := createBranch(repo, branch); err != nil {\\n   243→\\t\\t\\treturn fmt.Errorf(\\\"failed to create branch %q: %w\\\", branch, err)\\n   244→\\t\\t}\\n   245→\\t\\tfmt.Fprintf(w, \\\"Created branch %s\\\\n\\\", branch)\\n   246→\\t} else if currentBranch != branch {\\n   247→\\t\\tfmt.Fprintf(errW, \\\"Note: trail will be created for branch %q (not the current branch)\\\\n\\\", branch)\\n   248→\\t}\\n   249→\\n   250→\\t// Check if trail already exists for this branch\\n   251→\\tstore := trail.NewStore(repo)\\n   252→\\texisting, err := store.FindByBranch(branch)\\n   253→\\tif err == nil && existing != nil {\\n   254→\\t\\tfmt.Fprintf(w, \\\"Trail already exists for branch %q (ID: %s)\\\\n\\\", branch, existing.TrailID)\\n   255→\\t\\treturn nil\\n   256→\\t}\\n   257→\\n   258→\\t// Determine status\\n   259→\\tvar trailStatus trail.Status\\n   260→\\tif statusStr != \\\"\\\" {\\n   261→\\t\\ttrailStatus = trail.Status(statusStr)\\n   262→\\t\\tif !trailStatus.IsValid() {\\n   263→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusStr, formatValidStatuses())\\n   264→\\t\\t}\\n   265→\\t} else {\\n   266→\\t\\ttrailStatus = trail.StatusDraft\\n   267→\\t}\\n   268→\\n   269→\\t// Generate trail ID\\n   270→\\ttrailID, err := trail.GenerateID()\\n   271→\\tif err != nil {\\n   272→\\t\\treturn fmt.Errorf(\\\"failed to generate trail ID: %w\\\", err)\\n   273→\\t}\\n   274→\\n   275→\\t// Get author (GitHub username, falls back to git user.name)\\n   276→\\tauthorName := getTrailAuthor(repo)\\n   277→\\n   278→\\tnow := time.Now()\\n   279→\\tmetadata := &trail.Metadata{\\n   280→\\t\\tTrailID:   trailID,\\n   281→\\t\\tBranch:    branch,\\n   282→\\t\\tBase:      base,\\n   283→\\t\\tTitle:     title,\\n   284→\\t\\tBody:      body,\\n   285→\\t\\tStatus:    trailStatus,\\n   286→\\t\\tAuthor:    authorName,\\n   287→\\t\\tAssignees: []string{},\\n   288→\\t\\tLabels:    []string{},\\n   289→\\t\\tCreatedAt: now,\\n   290→\\t\\tUpdatedAt: now,\\n   291→\\t}\\n   292→\\n   293→\\tif err := store.Write(metadata, nil, nil); err != nil {\\n   294→\\t\\treturn fmt.Errorf(\\\"failed to create trail: %w\\\", err)\\n   295→\\t}\\n   296→\\n   297→\\tfmt.Fprintf(w, \\\"Created trail %q for branch %s (ID: %s)\\\\n\\\", title, branch, trailID)\\n   298→\\n   299→\\t// Push the branch and trail data to origin\\n   300→\\tif needsCreation {\\n   301→\\t\\tif err := pushBranchToOrigin(branch); err != nil {\\n   302→\\t\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to push branch: %v\\\\n\\\", err)\\n   303→\\t\\t} else {\\n   304→\\t\\t\\tfmt.Fprintf(w, \\\"Pushed branch %s to origin\\\\n\\\", branch)\\n   305→\\t\\t}\\n   306→\\t}\\n   307→\\tif err := strategy.PushTrailsBranch(context.Background(), \\\"origin\\\"); err != nil {\\n   308→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to push trail data: %v\\\\n\\\", err)\\n   309→\\t}\\n   310→\\n   311→\\t// Checkout the branch if requested or prompted\\n   312→\\tif needsCreation && currentBranch != branch {\\n   313→\\t\\tshouldCheckout := checkout\\n   314→\\t\\tif !shouldCheckout && !hasFlag(\\\"checkout\\\") {\\n   315→\\t\\t\\t// Interactive: ask whether to checkout\\n   316→\\t\\t\\tform := NewAccessibleForm(\\n   317→\\t\\t\\t\\thuh.NewGroup(\\n   318→\\t\\t\\t\\t\\thuh.NewConfirm().\\n   319→\\t\\t\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Check out branch %s?\\\", branch)).\\n   320→\\t\\t\\t\\t\\t\\tValue(&shouldCheckout),\\n   321→\\t\\t\\t\\t),\\n   322→\\t\\t\\t)\\n   323→\\t\\t\\tif formErr := form.Run(); formErr == nil && shouldCheckout {\\n   324→\\t\\t\\t\\tcheckout = true\\n   325→\\t\\t\\t}\\n   326→\\t\\t}\\n   327→\\t\\tif checkout {\\n   328→\\t\\t\\tif err := CheckoutBranch(context.Background(), branch); err != nil {\\n   329→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to checkout branch %q: %w\\\", branch, err)\\n   330→\\t\\t\\t}\\n   331→\\t\\t\\tfmt.Fprintf(w, \\\"Switched to branch %s\\\\n\\\", branch)\\n   332→\\t\\t}\\n   333→\\t}\\n   334→\\n   335→\\treturn nil\\n   336→}\\n   337→\\n   338→func newTrailUpdateCmd() *cobra.Command {\\n   339→\\tvar statusStr, title, body, branch string\\n   340→\\tvar labelAdd, labelRemove []string\\n   341→\\n   342→\\tcmd := &cobra.Command{\\n   343→\\t\\tUse:   \\\"update\\\",\\n   344→\\t\\tShort: \\\"Update trail metadata\\\",\\n   345→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   346→\\t\\t\\treturn runTrailUpdate(cmd.OutOrStdout(), statusStr, title, body, branch, labelAdd, labelRemove)\\n   347→\\t\\t},\\n   348→\\t}\\n   349→\\n   350→\\tcmd.Flags().StringVar(&statusStr, \\\"status\\\", \\\"\\\", \\\"Update status\\\")\\n   351→\\tcmd.Flags().StringVar(&title, \\\"title\\\", \\\"\\\", \\\"Update title\\\")\\n   352→\\tcmd.Flags().StringVar(&body, \\\"body\\\", \\\"\\\", \\\"Update body\\\")\\n   353→\\tcmd.Flags().StringVar(&branch, \\\"branch\\\", \\\"\\\", \\\"Branch to update trail for (defaults to current)\\\")\\n   354→\\tcmd.Flags().StringSliceVar(&labelAdd, \\\"add-label\\\", nil, \\\"Add label(s)\\\")\\n   355→\\tcmd.Flags().StringSliceVar(&labelRemove, \\\"remove-label\\\", nil, \\\"Remove label(s)\\\")\\n   356→\\n   357→\\treturn cmd\\n   358→}\\n   359→\\n   360→func runTrailUpdate(w io.Writer, statusStr, title, body, branch string, labelAdd, labelRemove []string) error {\\n   361→\\trepo, err := strategy.OpenRepository(context.Background())\\n   362→\\tif err != nil {\\n   363→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   364→\\t}\\n   365→\\n   366→\\t// Determine branch\\n   367→\\tif branch == \\\"\\\" {\\n   368→\\t\\tbranch, err = GetCurrentBranch(context.Background())\\n   369→\\t\\tif err != nil {\\n   370→\\t\\t\\treturn fmt.Errorf(\\\"failed to determine current branch: %w\\\", err)\\n   371→\\t\\t}\\n   372→\\t}\\n   373→\\n   374→\\tstore := trail.NewStore(repo)\\n   375→\\tmetadata, err := store.FindByBranch(branch)\\n   376→\\tif err != nil {\\n   377→\\t\\treturn fmt.Errorf(\\\"failed to find trail: %w\\\", err)\\n   378→\\t}\\n   379→\\tif metadata == nil {\\n   380→\\t\\treturn fmt.Errorf(\\\"no trail found for branch %q\\\", branch)\\n   381→\\t}\\n   382→\\n   383→\\t// Interactive mode when no flags are provided\\n   384→\\tnoFlags := statusStr == \\\"\\\" && title == \\\"\\\" && body == \\\"\\\" && labelAdd == nil && labelRemove == nil\\n   385→\\tif noFlags {\\n   386→\\t\\t// Build status options with current value as default.\\n   387→\\t\\t// Exclude \\\"done\\\" and \\\"closed\\\" unless the trail is already in that status\\n   388→\\t\\t// (otherwise the select would silently reset to the first option).\\n   389→\\t\\tvar statusOptions []huh.Option[string]\\n   390→\\t\\tfor _, s := range trail.ValidStatuses() {\\n   391→\\t\\t\\tif (s == trail.StatusDone || s == trail.StatusClosed) && s != metadata.Status {\\n   392→\\t\\t\\t\\tcontinue\\n   393→\\t\\t\\t}\\n   394→\\t\\t\\tlabel := string(s)\\n   395→\\t\\t\\tif s == metadata.Status {\\n   396→\\t\\t\\t\\tlabel += \\\" (current)\\\"\\n   397→\\t\\t\\t}\\n   398→\\t\\t\\tstatusOptions = append(statusOptions, huh.NewOption(label, string(s)))\\n   399→\\t\\t}\\n   400→\\t\\tstatusStr = string(metadata.Status)\\n   401→\\t\\ttitle = metadata.Title\\n   402→\\t\\tbody = metadata.Body\\n   403→\\n   404→\\t\\tform := NewAccessibleForm(\\n   405→\\t\\t\\thuh.NewGroup(\\n   406→\\t\\t\\t\\thuh.NewSelect[string]().\\n   407→\\t\\t\\t\\t\\tTitle(\\\"Status\\\").\\n   408→\\t\\t\\t\\t\\tOptions(statusOptions...).\\n   409→\\t\\t\\t\\t\\tValue(&statusStr),\\n   410→\\t\\t\\t\\thuh.NewInput().\\n   411→\\t\\t\\t\\t\\tTitle(\\\"Title\\\").\\n   412→\\t\\t\\t\\t\\tValue(&title),\\n   413→\\t\\t\\t\\thuh.NewText().\\n   414→\\t\\t\\t\\t\\tTitle(\\\"Body\\\").\\n   415→\\t\\t\\t\\t\\tValue(&body),\\n   416→\\t\\t\\t),\\n   417→\\t\\t)\\n   418→\\t\\tif formErr := form.Run(); formErr != nil {\\n   419→\\t\\t\\treturn fmt.Errorf(\\\"form cancelled: %w\\\", formErr)\\n   420→\\t\\t}\\n   421→\\t}\\n   422→\\n   423→\\t// Validate status if provided\\n   424→\\tif statusStr != \\\"\\\" {\\n   425→\\t\\tstatus := trail.Status(statusStr)\\n   426→\\t\\tif !status.IsValid() {\\n   427→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusStr, formatValidStatuses())\\n   428→\\t\\t}\\n   429→\\t}\\n   430→\\n   431→\\terr = store.Update(metadata.TrailID, func(m *trail.Metadata) {\\n   432→\\t\\tif statusStr != \\\"\\\" {\\n   433→\\t\\t\\tm.Status = trail.Status(statusStr)\\n   434→\\t\\t}\\n   435→\\t\\tif title != \\\"\\\" {\\n   436→\\t\\t\\tm.Title = title\\n   437→\\t\\t}\\n   438→\\t\\tif body != \\\"\\\" {\\n   439→\\t\\t\\tm.Body = body\\n   440→\\t\\t}\\n   441→\\t\\tfor _, l := range labelAdd {\\n   442→\\t\\t\\tif !containsString(m.Labels, l) {\\n   443→\\t\\t\\t\\tm.Labels = append(m.Labels, l)\\n   444→\\t\\t\\t}\\n   445→\\t\\t}\\n   446→\\t\\tfor _, l := range labelRemove {\\n   447→\\t\\t\\tm.Labels = removeString(m.Labels, l)\\n   448→\\t\\t}\\n   449→\\t})\\n   450→\\tif err != nil {\\n   451→\\t\\treturn fmt.Errorf(\\\"failed to update trail: %w\\\", err)\\n   452→\\t}\\n   453→\\n   454→\\tfmt.Fprintf(w, \\\"Updated trail for branch %s\\\\n\\\", branch)\\n   455→\\treturn nil\\n   456→}\\n   457→\\n   458→// defaultBaseBranch is the fallback base branch name when it cannot be determined.\\n   459→const defaultBaseBranch = \\\"main\\\"\\n   460→\\n   461→// hasFlag is a simple helper that checks os.Args for --flag presence.\\n   462→// Used to distinguish between \\\"flag not provided\\\" and \\\"flag provided with empty value\\\".\\n   463→func hasFlag(name string) bool {\\n   464→\\tfor _, arg := range os.Args {\\n   465→\\t\\tif arg == \\\"--\\\"+name || strings.HasPrefix(arg, \\\"--\\\"+name+\\\"=\\\") {\\n   466→\\t\\t\\treturn true\\n   467→\\t\\t}\\n   468→\\t}\\n   469→\\treturn false\\n   470→}\\n   471→\\n   472→func truncate(s string, maxLen int) string {\\n   473→\\tif len(s) <= maxLen {\\n   474→\\t\\treturn s\\n   475→\\t}\\n   476→\\tif maxLen <= 3 {\\n   477→\\t\\treturn s[:maxLen]\\n   478→\\t}\\n   479→\\treturn s[:maxLen-3] + \\\"...\\\"\\n   480→}\\n   481→\\n   482→func formatValidStatuses() string {\\n   483→\\tstatuses := trail.ValidStatuses()\\n   484→\\tnames := make([]string, len(statuses))\\n   485→\\tfor i, s := range statuses {\\n   486→\\t\\tnames[i] = string(s)\\n   487→\\t}\\n   488→\\treturn strings.Join(names, \\\", \\\")\\n   489→}\\n   490→\\n   491→func containsString(slice []string, s string) bool {\\n   492→\\tfor _, v := range slice {\\n   493→\\t\\tif v == s {\\n   494→\\t\\t\\treturn true\\n   495→\\t\\t}\\n   496→\\t}\\n   497→\\treturn false\\n   498→}\\n   499→\\n   500→func removeString(slice []string, s string) []string {\\n   501→\\tvar result []string\\n   502→\\tfor _, v := range slice {\\n   503→\\t\\tif v != s {\\n   504→\\t\\t\\tresult = append(result, v)\\n   505→\\t\\t}\\n   506→\\t}\\n   507→\\treturn result\\n   508→}\\n   509→\\n   510→// runTrailCreateInteractive runs the interactive form for trail creation.\\n   511→// Prompts for title, body, branch (derived from title), and status.\\n   512→func runTrailCreateInteractive(title, body, branch, statusStr *string) error {\\n   513→\\t// Step 1: Title and body\\n   514→\\tform := NewAccessibleForm(\\n   515→\\t\\thuh.NewGroup(\\n   516→\\t\\t\\thuh.NewInput().\\n   517→\\t\\t\\t\\tTitle(\\\"Trail title\\\").\\n   518→\\t\\t\\t\\tPlaceholder(\\\"What are you working on?\\\").\\n   519→\\t\\t\\t\\tValue(title),\\n   520→\\t\\t\\thuh.NewText().\\n   521→\\t\\t\\t\\tTitle(\\\"Body (optional)\\\").\\n   522→\\t\\t\\t\\tValue(body),\\n   523→\\t\\t),\\n   524→\\t)\\n   525→\\tif err := form.Run(); err != nil {\\n   526→\\t\\treturn fmt.Errorf(\\\"form cancelled: %w\\\", err)\\n   527→\\t}\\n   528→\\t*title = strings.TrimSpace(*title)\\n   529→\\tif *title == \\\"\\\" {\\n   530→\\t\\treturn errors.New(\\\"trail title is required\\\")\\n   531→\\t}\\n   532→\\n   533→\\t// Step 2: Branch (derived from title) and status\\n   534→\\tsuggested := slugifyTitle(*title)\\n   535→\\t*branch = suggested\\n   536→\\n   537→\\t// Build status options, excluding done/closed\\n   538→\\tvar statusOptions []huh.Option[string]\\n   539→\\tfor _, s := range trail.ValidStatuses() {\\n   540→\\t\\tif s == trail.StatusDone || s == trail.StatusClosed {\\n   541→\\t\\t\\tcontinue\\n   542→\\t\\t}\\n   543→\\t\\tstatusOptions = append(statusOptions, huh.NewOption(string(s), string(s)))\\n   544→\\t}\\n   545→\\tif *statusStr == \\\"\\\" {\\n   546→\\t\\t*statusStr = string(trail.StatusDraft)\\n   547→\\t}\\n   548→\\n   549→\\tform = NewAccessibleForm(\\n   550→\\t\\thuh.NewGroup(\\n   551→\\t\\t\\thuh.NewInput().\\n   552→\\t\\t\\t\\tTitle(\\\"Branch name\\\").\\n   553→\\t\\t\\t\\tPlaceholder(suggested).\\n   554→\\t\\t\\t\\tValue(branch),\\n   555→\\t\\t\\thuh.NewSelect[string]().\\n   556→\\t\\t\\t\\tTitle(\\\"Sta