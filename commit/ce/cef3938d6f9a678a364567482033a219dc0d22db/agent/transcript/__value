tent\":[{\"tool_use_id\":\"toolu_01LnYqQkCEaMxChf9aYiMmGH\",\"type\":\"tool_result\",\"content\":\"   710→// During rebase/cherry-pick/revert operations, phase transitions are skipped entirely.\\n   711→//\\n   712→\\n   713→func (s *ManualCommitStrategy) PostCommit(ctx context.Context) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   714→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   715→\\n   716→\\trepo, err := OpenRepository(ctx)\\n   717→\\tif err != nil {\\n   718→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   719→\\t}\\n   720→\\n   721→\\t// Get HEAD commit to check for trailer\\n   722→\\thead, err := repo.Head()\\n   723→\\tif err != nil {\\n   724→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   725→\\t}\\n   726→\\n   727→\\tcommit, err := repo.CommitObject(head.Hash())\\n   728→\\tif err != nil {\\n   729→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   730→\\t}\\n   731→\\n   732→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   733→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   734→\\tif !found {\\n   735→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   736→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   737→\\t\\ts.postCommitUpdateBaseCommitOnly(ctx, head)\\n   738→\\t\\treturn nil\\n   739→\\t}\\n   740→\\n   741→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   742→\\tif err != nil {\\n   743→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   744→\\t}\\n   745→\\n   746→\\t// Find all active sessions for this worktree\\n   747→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   748→\\tif err != nil || len(sessions) == 0 {\\n   749→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   750→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   751→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   752→\\t\\t)\\n   753→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   754→\\t}\\n   755→\\n   756→\\t// Build transition context\\n   757→\\tisRebase := isGitSequenceOperation(ctx)\\n   758→\\ttransitionCtx := session.TransitionContext{\\n   759→\\t\\tIsRebaseInProgress: isRebase,\\n   760→\\t}\\n   761→\\n   762→\\tif isRebase {\\n   763→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   764→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   765→\\t\\t)\\n   766→\\t}\\n   767→\\n   768→\\t// Track shadow branch names and whether they can be deleted\\n   769→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   770→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   771→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   772→\\n   773→\\tnewHead := head.Hash().String()\\n   774→\\n   775→\\t// Pre-resolve HEAD tree and parent tree once for the entire PostCommit.\\n   776→\\t// These are immutable within this hook invocation and used by multiple\\n   777→\\t// per-session functions (filesChangedInCommit, filesOverlapWithContent,\\n   778→\\t// filesWithRemainingAgentChanges, calculateSessionAttributions).\\n   779→\\tvar headTree *object.Tree\\n   780→\\tif t, err := commit.Tree(); err == nil {\\n   781→\\t\\theadTree = t\\n   782→\\t}\\n   783→\\tvar parentTree *object.Tree\\n   784→\\tif commit.NumParents() > 0 {\\n   785→\\t\\tif parent, err := commit.Parent(0); err == nil {\\n   786→\\t\\t\\tif t, err := parent.Tree(); err == nil {\\n   787→\\t\\t\\t\\tparentTree = t\\n   788→\\t\\t\\t}\\n   789→\\t\\t}\\n   790→\\t}\\n   791→\\n   792→\\tcommittedFileSet := filesChangedInCommit(commit, headTree, parentTree)\\n   793→\\n   794→\\tfor _, state := range sessions {\\n   795→\\t\\t// Skip fully-condensed ended sessions — no work remains.\\n   796→\\t\\t// These sessions only persist for LastCheckpointID (amend trailer reuse).\\n   797→\\t\\tif state.FullyCondensed && state.Phase == session.PhaseEnded {\\n   798→\\t\\t\\tcontinue\\n   799→\\t\\t}\\n   800→\\t\\ts.postCommitProcessSession(ctx, repo, state, &transitionCtx, checkpointID,\\n   801→\\t\\t\\thead, commit, newHead, headTree, parentTree, committedFileSet,\\n   802→\\t\\t\\tshadowBranchesToDelete, uncondensedActiveOnBranch)\\n   803→\\t}\\n   804→\\n   805→\\t// Clean up shadow branches — only delete when ALL sessions on the branch are non-active\\n   806→\\t// or were condensed during this PostCommit.\\n   807→\\tfor shadowBranchName := range shadowBranchesToDelete {\\n   808→\\t\\tif uncondensedActiveOnBranch[shadowBranchName] {\\n   809→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: preserving shadow branch (active session exists)\\\",\\n   810→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   811→\\t\\t\\t)\\n   812→\\t\\t\\tcontinue\\n   813→\\t\\t}\\n   814→\\t\\tif err := deleteShadowBranch(ctx, repo, shadowBranchName); err != nil {\\n   815→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to clean up shadow branch\\\",\\n   816→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   817→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   818→\\t\\t} else {\\n   819→\\t\\t\\tlogging.Info(logCtx, \\\"shadow branch deleted\\\",\\n   820→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   821→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   822→\\t\\t\\t)\\n   823→\\t\\t}\\n   824→\\t}\\n   825→\\n   826→\\treturn nil\\n   827→}\\n   828→\\n   829→// postCommitProcessSession handles a single session within the PostCommit loop.\\n   830→// Pre-resolved git objects (headTree, parentTree) are shared across all sessions;\\n   831→// per-session shadow ref/tree are resolved once here and threaded through su