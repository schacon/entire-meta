g.ZeroHash, \\\"Initialize trails branch\\\", authorName, authorEmail)\\n    54→\\tif err != nil {\\n    55→\\t\\treturn fmt.Errorf(\\\"failed to create initial commit: %w\\\", err)\\n    56→\\t}\\n    57→\\n    58→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n    59→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n    60→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n    61→\\t}\\n    62→\\treturn nil\\n    63→}\\n    64→\\n    65→// Write writes trail metadata, discussion, and checkpoints to the entire/trails branch.\\n    66→// If checkpoints is nil, an empty checkpoints list is written.\\n    67→func (s *Store) Write(metadata *Metadata, discussion *Discussion, checkpoints *Checkpoints) error {\\n    68→\\tif metadata.TrailID.IsEmpty() {\\n    69→\\t\\treturn errors.New(\\\"trail ID is required\\\")\\n    70→\\t}\\n    71→\\n    72→\\tif err := s.EnsureBranch(); err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\\"failed to ensure trails branch: %w\\\", err)\\n    74→\\t}\\n    75→\\n    76→\\t// Get current branch tree\\n    77→\\tref, entries, err := s.getBranchEntries()\\n    78→\\tif err != nil {\\n    79→\\t\\treturn fmt.Errorf(\\\"failed to get branch entries: %w\\\", err)\\n    80→\\t}\\n    81→\\n    82→\\t// Build sharded path\\n    83→\\tbasePath := metadata.TrailID.Path() + \\\"/\\\"\\n    84→\\n    85→\\t// Create metadata blob\\n    86→\\tmetadataJSON, err := json.MarshalIndent(metadata, \\\"\\\", \\\"  \\\")\\n    87→\\tif err != nil {\\n    88→\\t\\treturn fmt.Errorf(\\\"failed to marshal metadata: %w\\\", err)\\n    89→\\t}\\n    90→\\tmetadataBlob, err := checkpoint.CreateBlobFromContent(s.repo, metadataJSON)\\n    91→\\tif err != nil {\\n    92→\\t\\treturn fmt.Errorf(\\\"failed to create metadata blob: %w\\\", err)\\n    93→\\t}\\n    94→\\tentries[basePath+metadataFile] = object.TreeEntry{\\n    95→\\t\\tName: basePath + metadataFile,\\n    96→\\t\\tMode: filemode.Regular,\\n    97→\\t\\tHash: metadataBlob,\\n    98→\\t}\\n    99→\\n   100→\\t// Create discussion blob\\n   101→\\tif discussion == nil {\\n   102→\\t\\tdiscussion = &Discussion{Comments: []Comment{}}\\n   103→\\t}\\n   104→\\tdiscussionJSON, err := json.MarshalIndent(discussion, \\\"\\\", \\\"  \\\")\\n   105→\\tif err != nil {\\n   106→\\t\\treturn fmt.Errorf(\\\"failed to marshal discussion: %w\\\", err)\\n   107→\\t}\\n   108→\\tdiscussionBlob, err := checkpoint.CreateBlobFromContent(s.repo, discussionJSON)\\n   109→\\tif err != nil {\\n   110→\\t\\treturn fmt.Errorf(\\\"failed to create discussion blob: %w\\\", err)\\n   111→\\t}\\n   112→\\tentries[basePath+discussionFile] = object.TreeEntry{\\n   113→\\t\\tName: basePath + discussionFile,\\n   114→\\t\\tMode: filemode.Regular,\\n   115→\\t\\tHash: discussionBlob,\\n   116→\\t}\\n   117→\\n   118→\\t// Create checkpoints blob\\n   119→\\tif checkpoints == nil {\\n   120→\\t\\tcheckpoints = &Checkpoints{Checkpoints: []CheckpointRef{}}\\n   121→\\t}\\n   122→\\tcheckpointsJSON, err := json.MarshalIndent(checkpoints, \\\"\\\", \\\"  \\\")\\n   123→\\tif err != nil {\\n   124→\\t\\treturn fmt.Errorf(\\\"failed to marshal checkpoints: %w\\\", err)\\n   125→\\t}\\n   126→\\tcheckpointsBlob, err := checkpoint.CreateBlobFromContent(s.repo, checkpointsJSON)\\n   127→\\tif err != nil {\\n   128→\\t\\treturn fmt.Errorf(\\\"failed to create checkpoints blob: %w\\\", err)\\n   129→\\t}\\n   130→\\tentries[basePath+checkpointsFile] = object.TreeEntry{\\n   131→\\t\\tName: basePath + checkpointsFile,\\n   132→\\t\\tMode: filemode.Regular,\\n   133→\\t\\tHash: checkpointsBlob,\\n   134→\\t}\\n   135→\\n   136→\\t// Build tree and commit\\n   137→\\tnewTreeHash, err := checkpoint.BuildTreeFromEntries(s.repo, entries)\\n   138→\\tif err != nil {\\n   139→\\t\\treturn fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n   140→\\t}\\n   141→\\n   142→\\tauthorName, authorEmail := checkpoint.GetGitAuthorFromRepo(s.repo)\\n   143→\\tcommitMsg := fmt.Sprintf(\\\"Trail: %s (%s)\\\", metadata.Title, metadata.TrailID)\\n   144→\\tcommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, authorName, authorEmail)\\n   145→\\tif err != nil {\\n   146→\\t\\treturn fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   147→\\t}\\n   148→\\n   149→\\t// Update branch ref\\n   150→\\tnewRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(paths.TrailsBranchName), commitHash)\\n   151→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n   152→\\t\\treturn fmt.Errorf(\\\"failed to update branch reference: %w\\\", err)\\n   153→\\t}\\n   154→\\n   155→\\treturn nil\\n   156→}\\n   157→\\n   158→// Read reads a trail by its ID from the entire/trails branch.\\n   159→func (s *Store) Read(trailID ID) (*Metadata, *Discussion, *Checkpoints, error) {\\n   160→\\ttree, err := s.getBranchTree()\\n   161→\\tif err != nil {\\n   162→\\t\\treturn nil, nil, nil, err\\n   163→\\t}\\n   164→\\n   165→\\tbasePath := trailID.Path() + \\\"/\\\"\\n   166→\\n   167→\\t// Read metadata\\n   168→\\tmetadataEntry, err := tree.FindEntry(basePath + metadataFile)\\n   169→\\tif err != nil {\\n   170→\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"trail %s not found: %w\\\", trailID, err)\\n   171→\\t}\\n   172→\\tmetadataBlob, err := s.repo.BlobObject(metadataEntry.Hash)\\n   173→\\tif err != nil {\\n   174→\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"failed to read metadata blob: %w\\\", err)\\n   175→\\t}\\n   176→\\tmetadataReader, err := metadataBlob.Reader()\\n   177→\\tif err != nil {\\n   178→\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"failed to open metadata reader: %w\\\", err)\\n   179→\\t}\\n   180→\\tdefer metadataReader.Close()\\n   181→\\n   182→\\tvar metadata Metadata\\n   183→\\tif err := json.NewDecoder(metadataReader).Decode(&metadata); err != nil {\\n   184→\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"failed to decode metadata: %w\\\", err)\\n   185→\\t}\\n   186→\\n   187→\\t// Read discussion (optional, may not exist yet)\\n   188→\\tvar discussion Discussion\\n   189→\\tdiscussionEntry, err := tree.FindEntry(basePath + discussionFile)\\n   190→\\tif err == nil {\\n   191→\\t\\tdiscussionBlob, blobErr := s.repo.BlobObject(discussionEntry.Hash)\\n   192→\\t\\tif blobErr == nil {\\n   193→\\t\\t\\tdiscussionReader, readerErr := discussionBlob.Reader()\\n   194→\\t\\t\\tif readerErr == nil {\\n   195→\\t\\t\\t\\t//nolint:errcheck,gosec // best-effort decode of optional discussion\\n   196→\\t\\t\\t\\tjson.NewDecoder(discussionReader).Decode(&discussion)\\n   197→\\t\\t\\t\\t_ = discussionReader.Close()\\n   198→\\t\\t\\t}\\n   199→\\t\\t}\\n   200→\\t}\\n   201→\\n   202→\\t// Read checkpoints (optional, may not exist yet)\\n   203→\\tvar checkpoints Checkpoints\\n   204→\\tcheckpointsEntry, err := tree.FindEntry(basePath + checkpointsFile)\\n   205→\\tif err == nil {\\n   206→\\t\\tcheckpointsBlob, blobErr := s.repo.BlobObject(checkpointsEntry.Hash)\\n   207→\\t\\tif blobErr == nil {\\n   208→\\t\\t\\tcheckpointsReader, readerErr := checkpointsBlob.Reader()\\n   209→\\t\\t\\tif readerErr == nil {\\n   210→\\t\\t\\t\\t//nolint:errcheck,gosec // best-effort decode of optional checkpoints\\n   211→\\t\\t\\t\\tjson.NewDecoder(checkpointsReader).Decode(&checkpoints)\\n   212→\\t\\t\\t\\t_ = checkpointsReader.Close()\\n   213→\\t\\t\\t}\\n   214→\\t\\t}\\n   215→\\t}\\n   216→\\n   217→\\treturn &metadata, &discussion, &checkpoints, nil\\n   218→}\\n   219→\\n   220→// FindByBranch finds a trail for the given branch name.\\n   221→// Returns (nil, nil) if no trail exists for the branch.\\n   222→func (s *Store) FindByBranch(branchName string) (*Metadata, error) {\\n   223→\\ttrails, err := s.List()\\n   224→\\tif err != nil {\\n   225→\\t\\treturn nil, err\\n   226→\\t}\\n   227→\\n   228→\\tfor _, t := range trails {\\n   229→\\t\\tif t.Branch == branchName {\\n   230→\\t\\t\\treturn t, nil\\n   231→\\t\\t}\\n   232→\\t}\\n   233→\\treturn nil, nil //nolint:nilnil // nil, nil means \\\"not found\\\" — callers check both\\n   234→}\\n   235→\\n   236→// List returns all trail metadata from the entire/trails branch.\\n   237→func (s *Store) List() ([]*Metadata, error) {\\n   238→\\ttree, err := s.getBranchTree()\\n   239→\\tif err != nil {\\n   240→\\t\\t// Branch doesn't exist yet — no trails\\n   241→\\t\\treturn nil, nil //nolint:nilerr // Expected when no trails exist yet\\n   242→\\t}\\n   243→\\n   244→\\tvar trails []*Metadata\\n   245→\\tentries := make(map[string]object.TreeEntry)\\n   246→\\tif err := checkpoint.FlattenTree(s.repo, tree, \\\"\\\", entries); err != nil {\\n   247→\\t\\treturn nil, fmt.Errorf(\\\"failed to flatten tree: %w\\\", err)\\n   248→\\t}\\n   249→\\n   250→\\t// Find all metadata.json files\\n   251→\\tfor path, entry := range entries {\\n   252→\\t\\tif !strings.HasSuffix(path, \\\"/\\\"+metadataFile) {\\n   253→\\t\\t\\tcontinue\\n   254→\\t\\t}\\n   255→\\n   256→\\t\\tblob, err := s.repo.BlobObject(entry.Hash)\\n   257→\\t\\tif err != nil {\\n   258→\\t\\t\\tcontinue\\n   259→\\t\\t}\\n   260→\\t\\treader, err := blob.Reader()\\n   261→\\t\\tif err != nil {\\n   262→\\t\\t\\tcontinue\\n   263→\\t\\t}\\n   264→\\n   265→\\t\\tvar metadata Metadata\\n   266→\\t\\tdecodeErr := json.NewDecoder(reader).Decode(&metadata)\\n   267→\\t\\t_ = reader.Close()\\n   268→\\t\\tif decodeErr != nil {\\n   269→\\t\\t\\tcontinue\\n   270→\\t\\t}\\n   271→\\n   272→\\t\\ttrails = append(trails, &metadata)\\n   273→\\t}\\n   274→\\n   275→\\treturn trails, nil\\n   276→}\\n   277→\\n   278→// Update updates an existing trail's metadata. It reads the current metadata,\\n   279→// applies the provided update function, and writes it back.\\n   280→func (s *Store) Update(trailID ID, updateFn func(*Metadata)) error {\\n   281→\\tmetadata, discussion, checkpoints, err := s.Read(trailID)\\n   282→\\tif err != nil {\\n   283→\\t\\treturn fmt.Errorf(\\\"failed to read trail for update: %w\\\", err)\\n   284→\\t}\\n   285→\\n   286→\\tupdateFn(metadata)\\n   287→\\tmetadata.UpdatedAt = time.Now()\\n   288→\\n   289→\\treturn s.Write(metadata, discussion, checkpoints)\\n   290→}\\n   291→\\n   292→// AddCheckpoint prepends a checkpoint reference to a trail's checkpoints list (newest first).\\n   293→func (s *Store) AddCheckpoint(trailID ID, ref CheckpointRef) error {\\n   294→\\tmetadata, discussion, checkpoints, err := s.Read(trailID)\\n   295→\\tif err != nil {\\n   296→\\t\\treturn fmt.Errorf(\\\"failed to read trail for checkpoint update: %w\\\", err)\\n   297→\\t}\\n   298→\\n   299→\\tif checkpoints == nil {\\n   300→\\t\\tcheckpoints = &Checkpoints{Checkpoints: []CheckpointRef{}}\\n   301→\\t}\\n   302→\\n   303→\\t// Prepend new ref (newest first) without always allocating a new slice.\\n   304→\\t// Grow the slice by one, shift existing elements right, and insert at index 0.\\n   305→\\tcheckpoints.Checkpoints = append(checkpoints.Checkpoints, CheckpointRef{})\\n   306→\\tcopy(checkpoints.Checkpoints[1:], checkpoints.Checkpoints[:len(checkpoints.Checkpoints)-1])\\n   307→\\tcheckpoints.Checkpoints[0] = ref\\n   308→\\n   309→\\treturn s.Write(metadata, discussion, checkpoints)\\n   310→}\\n   311→\\n   312→// Delete removes a trail from the entire/trails branch.\\n   313→func (s *Store) Delete(trailID ID) error {\\n   314→\\tref, entries, err := s.getBranchEntries()\\n   315→\\tif err != nil {\\n   316→\\t\\treturn fmt.Errorf(\\\"failed to get branch entries: %w\\\", err)\\n   317→\\t}\\n   318→\\n   319→\\tbasePath := trailID.Path() + \\\"/\\\"\\n   320→\\n   321→\\t// Remove entries for this trail\\n   322→\\tfound := false\\n   323→\\tfor path := range entries {\\n   324→\\t\\tif strings.HasPrefix(path, basePath) {\\n   325→\\t\\t\\tdelete(entries, path)\\n   326→\\t\\t\\tfound = true\\n   327→\\t\\t}\\n   328→\\t}\\n   329→\\tif !found {\\n   330→\\t\\treturn fmt.Errorf(\\\"trail %s not found\\\", trailID)\\n   331→\\t}\\n   332→\\n   333→\\t// Build tree and commit\\n   334→\\tnewTreeHash, err := checkpoint.BuildTreeFromEntries(s.repo, entries)\\n   335→\\tif err != nil {\\n   336→\\t\\treturn fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n   337→\\t}\\n   338→\\n   339→\\tauthorName, authorEmail := checkpoint.GetGitAuthorFromRepo(s.repo)\\n   340→\\tcommitMsg := fmt.Sprintf(\\\"Delete trail: %s\\\", trailID)\\n   341→\\tcommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, authorName, authorEmail)\\n   342→\\tif err != nil {\\n   343→\\t\\treturn fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   344→\\t}\\n   345→\\n   346→\\tnewRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(paths.TrailsBranchName), commitHash)\\n   347→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n   348→\\t\\treturn fmt.Errorf(\\\"failed to update branch reference: %w\\\", err)\\n   349→\\t}\\n   350→\\n   351→\\treturn nil\\n   352→}\\n   353→\\n   354→// getBranchTree returns the tree for the entire/trails branch HEAD.\\n   355→func (s *Store) getBranchTree() (*object.Tree, error) {\\n   356→\\trefName := plumbing.NewBranchReferenceName(paths.TrailsBranchName)\\n   357→\\tref, err := s.repo.Reference(refName, true)\\n   358→\\tif err != nil {\\n   359→\\t\\t// Try remote tracking branch\\n   360→\\t\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.TrailsBranchName)\\n   361→\\t\\tref, err = s.repo.Reference(remoteRefName, true)\\n   362→\\t\\tif err != nil {\\n   363→\\t\\t\\treturn nil, fmt.Errorf(\\\"trails branch not found: %w\\\", err)\\n   364→\\t\\t}\\n   365→\\t}\\n   366→\\n   367→\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n   368→\\tif err != nil {\\n   369→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   370→\\t}\\n   371→\\n   372→\\ttree, err := commit.Tree()\\n   373→\\tif err != nil {\\n   374→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n   375→\\t}\\n   376→\\n   377→\\treturn tree, nil\\n   378→}\\n   37