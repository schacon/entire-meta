nRepository(ctx)\\n    24→\\tif err != nil {\\n    25→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n    26→\\t}\\n    27→\\n    28→\\t// Check if branch exists locally\\n    29→\\tbranchRef := plumbing.NewBranchReferenceName(branchName)\\n    30→\\tlocalRef, err := repo.Reference(branchRef, true)\\n    31→\\tif err != nil {\\n    32→\\t\\t// No branch, nothing to push\\n    33→\\t\\treturn nil //nolint:nilerr // Expected when no sessions exist yet\\n    34→\\t}\\n    35→\\n    36→\\t// Check if there's actually something to push (local differs from remote)\\n    37→\\tif !hasUnpushedSessionsCommon(repo, remote, localRef.Hash(), branchName) {\\n    38→\\t\\t// Nothing to push - skip silently\\n    39→\\t\\treturn nil\\n    40→\\t}\\n    41→\\n    42→\\treturn doPushBranch(ctx, remote, branchName)\\n    43→}\\n    44→\\n    45→// hasUnpushedSessionsCommon checks if the local branch differs from the remote.\\n    46→// Returns true if there's any difference that needs syncing (local ahead, remote ahead, or diverged).\\n    47→func hasUnpushedSessionsCommon(repo *git.Repository, remote string, localHash plumbing.Hash, branchName string) bool {\\n    48→\\t// Check for remote tracking ref: refs/remotes/<remote>/<branch>\\n    49→\\tremoteRefName := plumbing.NewRemoteReferenceName(remote, branchName)\\n    50→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n    51→\\tif err != nil {\\n    52→\\t\\t// Remote branch doesn't exist yet - we have content to push\\n    53→\\t\\treturn true\\n    54→\\t}\\n    55→\\n    56→\\t// If local and remote point to same commit, nothing to sync\\n    57→\\t// This is the only case where we skip - any difference needs handling\\n    58→\\treturn localHash != remoteRef.Hash()\\n    59→}\\n    60→\\n    61→// doPushBranch pushes the given branch to the remote with fetch+merge recovery.\\n    62→func doPushBranch(ctx context.Context, remote, branchName string) error {\\n    63→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Pushing %s to %s...\\\\n\\\", branchName, remote)\\n    64→\\n    65→\\t// Try pushing first\\n    66→\\tif err := tryPushSessionsCommon(ctx, remote, branchName); err == nil {\\n    67→\\t\\treturn nil\\n    68→\\t}\\n    69→\\n    70→\\t// Push failed - likely non-fast-forward. Try to fetch and merge.\\n    71→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Syncing %s with remote...\\\\n\\\", branchName)\\n    72→\\n    73→\\tif err := fetchAndMergeSessionsCommon(ctx, remote, branchName); err != nil {\\n    74→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: couldn't sync %s: %v\\\\n\\\", branchName, err)\\n    75→\\t\\tprintCheckpointRemoteHint(remote)\\n    76→\\t\\treturn nil // Don't fail the main push\\n    77→\\t}\\n    78→\\n    79→\\t// Try pushing again after merge\\n    80→\\tif err := tryPushSessionsCommon(ctx, remote, branchName); err != nil {\\n    81→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to push %s after sync: %v\\\\n\\\", branchName, err)\\n    82→\\t\\tprintCheckpointRemoteHint(remote)\\n    83→\\t}\\n    84→\\n    85→\\treturn nil\\n    86→}\\n    87→\\n    88→// printCheckpointRemoteHint prints a hint when a push to the checkpoint remote fails.\\n    89→// Only prints when the remote is the dedicated checkpoint remote (not the default).\\n    90→func printCheckpointRemoteHint(remote string) {\\n    91→\\tif remote != checkpointRemoteName {\\n    92→\\t\\treturn\\n    93→\\t}\\n    94→\\tfmt.Fprintln(os.Stderr, \\\"[entire] A checkpoint remote is configured in .entire/settings.json but could not be reached.\\\")\\n    95→\\tfmt.Fprintln(os.Stderr, \\\"[entire] Checkpoints are saved locally but not synced. Ensure you have access to the checkpoint remote.\\\")\\n    96→}\\n    97→\\n    98→// tryPushSessionsCommon attempts to push the sessions branch.\\n    99→func tryPushSessionsCommon(ctx context.Context, remote, branchName string) error {\\n   100→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   101→\\tdefer cancel()\\n   102→\\n   103→\\t// Use --no-verify to prevent recursive hook calls\\n   104→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"push\\\", \\\"--no-verify\\\", remote, branchName)\\n   105→\\tcmd.Stdin = nil // Disconnect stdin to prevent hanging in hook context\\n   106→\\n   107→\\toutput, err := cmd.CombinedOutput()\\n   108→\\tif err != nil {\\n   109→\\t\\t// Check if it's a non-fast-forward error (we can try to recover)\\n   110→\\t\\tif strings.Contains(string(output), \\\"non-fast-forward\\\") ||\\n   111→\\t\\t\\tstrings.Contains(string(output), \\\"rejected\\\") {\\n   112→\\t\\t\\treturn errors.New(\\\"non-fast-forward\\\")\\n   113→\\t\\t}\\n   114→\\t\\treturn fmt.Errorf(\\\"push failed: %s\\\", output)\\n   115→\\t}\\n   116→\\treturn nil\\n   117→}\\n   118→\\n   119→// fetchAndMergeSessionsCommon fetches remote sessions and merges into local using go-git.\\n   120→// Since session logs are append-only (unique cond-* directories), we just combine trees.\\n   121→func fetchAndMergeSessionsCommon(ctx context.Context, remote, branchName string) error {\\n   122→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   123→\\tdefer cancel()\\n   124→\\n   125→\\t// Use git CLI for fetch (go-git's fetch can be tricky with auth)\\n   126→\\trefSpec := fmt.Sprintf(\\\"+refs/heads/%s:refs/remotes/%s/%s\\\", branchName, remote, branchName)\\n   127→\\tfetchCmd := exec.CommandContext(ctx, \\\"git\\\", \\\"fetch\\\", remote, refSpec)\\n   128→\\tfetchCmd.Stdin = nil\\n   129→\\tif output, err := fetchCmd.CombinedOutput(); err != nil {\\n   130→\\t\\treturn fmt.Errorf(\\\"fetch failed: %s\\\", output)\\n   131→\\t}\\n   132→\\n   133→\\trepo, err := OpenRepository(ctx)\\n   134→\\tif err != nil {\\n   135→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   136→\\t}\\n   137→\\n   138→\\t// Reconcile disconnected metadata branches before merging trees.\\n   139→\\t// The fetch above updated the remote-tracking ref, so reconciliation\\n   140→\\t// can compare fresh local vs remote. If disconnected (empty-orphan bug),\\n   141→\\t// this cherry-picks local commits onto remote tip, updating the local ref.\\n   142→\\t// If reconciliation fails, abort — proceeding to tree merge on disconnected\\n   143→\\t// branches would silently combine unrelated histories.\\n   144→\\tif reconcileErr := ReconcileDisconnectedMetadataBranch(ctx, repo, os.Stderr); reconcileErr != nil {\\n   145→\\t\\treturn fmt.Errorf(\\\"metadata reconciliation failed: %w\\\", reconcileErr)\\n   146→\\t}\\n   147→\\n   148→\\t// Get local branch (re-read after potential reconciliation update)\\n   149→\\tlocalRef, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   150→\\tif err != nil {\\n   151→\\t\\treturn fmt.Errorf(\\\"failed to get local ref: %w\\\", err)\\n   152→\\t}\\n   153→\\tlocalCommit, err := repo.CommitObject(localRef.Hash())\\n   154→\\tif err != nil {\\n   155→\\t\\treturn fmt.Errorf(\\\"failed to get local commit: %w\\\", err)\\n   156→\\t}\\n   157→\\tlocalTree, err := localCommit.Tree()\\n   158→\\tif err != nil {\\n   159→\\t\\treturn fmt.Errorf(\\\"failed to get local tree: %w\\\", err)\\n   160→\\t}\\n   161→\\n   162→\\t// Get remote tracking ref (updated by the fetch above)\\n   163→\\tremoteRefName := plumbing.NewRemoteReferenceName(remote, branchName)\\n   164→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n   165→\\tif err != nil {\\n   166→\\t\\treturn fmt.Errorf(\\\"failed to get remote ref: %w\\\", err)\\n   167→\\t}\\n   168→\\tremoteCommit, err := repo.CommitObject(remoteRef.Hash())\\n   169→\\tif err != nil {\\n   170→\\t\\treturn fmt.Errorf(\\\"failed to get remote commit: %w\\\", err)\\n   171→\\t}\\n   172→\\tremoteTree, err := remoteCommit.Tree()\\n   173→\\tif err != nil {\\n   174→\\t\\treturn fmt.Errorf(\\\"failed to get remote tree: %w\\\", err)\\n   175→\\t}\\n   176→\\n   177→\\t// Flatten both trees and combine entries\\n   178→\\t// Session logs have unique cond-* directories, so no conflicts expected\\n   179→\\tentries := make(map[string]object.TreeEntry)\\n   180→\\tif err := checkpoint.FlattenTree(repo, localTree, \\\"\\\", entries); err != nil {\\n   181→\\t\\treturn fmt.Errorf(\\\"failed to flatten local tree: %w\\\", err)\\n   182→\\t}\\n   183→\\tif err := checkpoint.FlattenTree(repo, remoteTree, \\\"\\\", entries); err != nil {\\n   184→\\t\\treturn fmt.Errorf(\\\"failed to flatten remote tree: %w\\\", err)\\n   185→\\t}\\n   186→\\n   187→\\t// Build merged tree\\n   188→\\tmergedTreeHash, err := checkpoint.BuildTreeFromEntries(repo, entries)\\n   189→\\tif err != nil {\\n   190→\\t\\treturn fmt.Errorf(\\\"failed to build merged tree: %w\\\", err)\\n   191→\\t}\\n   192→\\n   193→\\t// Create merge commit with both parents\\n   194→\\tmergeCommitHash, err := createMergeCommitCommon(repo, mergedTreeHash,\\n   195→\\t\\t[]plumbing.Hash{localRef.Hash(), remoteRef.Hash()},\\n   196→\\t\\t\\\"Merge remote session logs\\\")\\n   197→\\tif err != nil {\\n   198→\\t\\treturn fmt.Errorf(\\\"failed to create merge commit: %w\\\", err)\\n   199→\\t}\\n   200→\\n   201→\\t// Update branch ref\\n   202→\\tnewRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(branchName), mergeCommitHash)\\n   203→\\tif err := repo.Storer.SetReference(newRef); err != nil {\\n   204→\\t\\treturn fmt.Errorf(\\\"failed to update branch ref: %w\\\", err)\\n   205→\\t}\\n   206→\\n   207→\\treturn nil\\n   208→}\\n   209→\\n   210→// PushTrailsBranch pushes the entire/trails/v1 branch to the remote.\\n   211→// Trails are always pushed regardless of the push_sessions setting.\\n   212→func PushTrailsBranch(ctx context.Context, remote string) error {\\n   213→\\treturn pushBranchIfNeeded(ctx, remote, paths.TrailsBranchName)\\n   214→}\\n   215→\\n   216→// createMergeCommitCommon creates a merge commit with multiple parents.\\n   217→func createMergeCommitCommon(repo *git.Repository, treeHash plumbing.Hash, parents []plumbing.Hash, message string) (plumbing.Hash, error) {\\n   218→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   219→\\tnow := time.Now()\\n   220→\\tsig := object.Signature{\\n   221→\\t\\tName:  authorName,\\n   222→\\t\\tEmail: authorEmail,\\n   223→\\t\\tWhen:  now,\\n   224→\\t}\\n   225→\\n   226→\\tcommit := &object.Commit{\\n   227→\\t\\tTreeHash:     treeHash,\\n   228→\\t\\tParentHashes: parents,\\n   229→\\t\\tAuthor:       sig,\\n   230→\\t\\tCommitter:    sig,\\n   231→\\t\\tMessage:      message,\\n   232→\\t}\\n   233→\\n   234→\\tobj := repo.Storer.NewEncodedObject()\\n   235→\\tif err := commit.Encode(obj); err != nil {\\n   236→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n   237→\\t}\\n   238→\\n   239→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n   240→\\tif err != nil {\\n   241→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store commit: %w\\\", err)\\n   242→\\t}\\n   243→\\n   244→\\treturn hash, nil\\n   245→}\\n   246→\"}]},\"uuid\":\"22645466-bfe3-4e6d-afe3-bac65d798ad8\",\"timestamp\":\"2026-03-11T12:14:04.350Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a215861cdf29eb6be\"},\"toolUseID\":\"agent_msg_01DJ68p67KEWsEw8TpHkZ1HA\",\"parentToolUseID\":\"toolu_014xq2sFnrZdVH2AHmSrfmjV\",\"uuid\":\"37d4f81b-ba99-43a3-98a7-dc9b98b5c720\",\"timestamp\":\"2026-03-11T12:14:04.960Z\"}\n{\"parentUuid\":\"37d4f81b-ba99-43a3-98a7-dc9b98b5c720\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli\",\"sessionId\":\"d79106a5-a980-46f7-b56d-1c2701ed4a9d\",\"version\":\"2.1.72\",\"gitBranch\":\"soph/add-support-for-different-remote-for-checkpoints\",\"slug\":\"refactored-shimmying-meteor\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-11T12:14:05.008Z\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_011mFKtqp8r8f57U1j1NxGAG\",\"type\":\"message\",\"role\":\"assistant\",\"