\n    47→//\\n    48→// The push itself handles failures gracefully (doPushBranch warns and continues),\\n    49→// so no reachability check is needed here.\\n    50→func resolvePushSettings(ctx context.Context, pushRemoteName string) pushSettings {\\n    51→\\ts, err := settings.Load(ctx)\\n    52→\\tif err != nil {\\n    53→\\t\\treturn pushSettings{remote: pushRemoteName}\\n    54→\\t}\\n    55→\\n    56→\\tps := pushSettings{\\n    57→\\t\\tremote:       pushRemoteName,\\n    58→\\t\\tpushDisabled: s.IsPushSessionsDisabled(),\\n    59→\\t}\\n    60→\\n    61→\\tconfig := s.GetCheckpointRemote()\\n    62→\\tif config == nil {\\n    63→\\t\\treturn ps\\n    64→\\t}\\n    65→\\n    66→\\t// Get the push remote URL for protocol detection and fork detection\\n    67→\\tpushRemoteURL, err := getRemoteURL(ctx, pushRemoteName)\\n    68→\\tif err != nil {\\n    69→\\t\\tlogging.Debug(ctx, \\\"checkpoint-remote: could not get push remote URL, skipping\\\",\\n    70→\\t\\t\\tslog.String(\\\"remote\\\", pushRemoteName),\\n    71→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    72→\\t\\t)\\n    73→\\t\\treturn ps\\n    74→\\t}\\n    75→\\n    76→\\t// Fork detection: compare owners\\n    77→\\tpushOwner := extractOwnerFromRemoteURL(pushRemoteURL)\\n    78→\\tcheckpointOwner := config.Owner()\\n    79→\\tif pushOwner != \\\"\\\" && checkpointOwner != \\\"\\\" && !strings.EqualFold(pushOwner, checkpointOwner) {\\n    80→\\t\\tlogging.Debug(ctx, \\\"checkpoint-remote: push remote owner differs from checkpoint remote owner, skipping (fork detected)\\\",\\n    81→\\t\\t\\tslog.String(\\\"push_owner\\\", pushOwner),\\n    82→\\t\\t\\tslog.String(\\\"checkpoint_owner\\\", checkpointOwner),\\n    83→\\t\\t)\\n    84→\\t\\treturn ps\\n    85→\\t}\\n    86→\\n    87→\\t// Derive checkpoint URL using same protocol as push remote\\n    88→\\tcheckpointURL, err := deriveCheckpointURL(pushRemoteURL, config)\\n    89→\\tif err != nil {\\n    90→\\t\\tlogging.Warn(ctx, \\\"checkpoint