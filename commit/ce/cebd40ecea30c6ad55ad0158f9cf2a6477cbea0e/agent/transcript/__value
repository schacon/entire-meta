local settings override file (not committed)\\n    23→\\tEntireSettingsLocalFile = \\\".entire/settings.local.json\\\"\\n    24→)\\n    25→\\n    26→// Commit linking mode constants.\\n    27→const (\\n    28→\\t// CommitLinkingAlways auto-links commits to sessions without prompting.\\n    29→\\tCommitLinkingAlways = \\\"always\\\"\\n    30→\\t// CommitLinkingPrompt prompts the user on each commit (default for existing users).\\n    31→\\tCommitLinkingPrompt = \\\"prompt\\\"\\n    32→)\\n    33→\\n    34→// EntireSettings represents the .entire/settings.json configuration\\n    35→type EntireSettings struct {\\n    36→\\n    37→\\t// Enabled indicates whether Entire is active. When false, CLI commands\\n    38→\\t// show a disabled message and hooks exit silently. Defaults to true.\\n    39→\\tEnabled bool `json:\\\"enabled\\\"`\\n    40→\\n    41→\\t// LocalDev indicates whether to use \\\"go run\\\" instead of the \\\"entire\\\" binary\\n    42→\\t// This is used for development when the binary is not installed\\n    43→\\tLocalDev bool `json:\\\"local_dev,omitempty\\\"`\\n    44→\\n    45→\\t// LogLevel sets the logging verbosity (debug, info, warn, error).\\n    46→\\t// Can be overridden by ENTIRE_LOG_LEVEL environment variable.\\n    47→\\t// Defaults to \\\"info\\\".\\n    48→\\tLogLevel string `json:\\\"log_level,omitempty\\\"`\\n    49→\\n    50→\\t// StrategyOptions contains strategy-specific configuration\\n    51→\\tStrategyOptions map[string]any `json:\\\"strategy_options,omitempty\\\"`\\n    52→\\n    53→\\t// AbsoluteGitHookPath embeds the full binary path in git hooks instead of\\n    54→\\t// bare \\\"entire\\\". This is needed for GUI git clients (Xcode, Tower, etc.)\\n    55→\\t// that don't source shell profiles and can't find \\\"entire\\\" on PATH.\\n    56→\\tAbsoluteGitHookPath bool `json:\\\"absolute_git_hook_path,omitempty\\\"`\\n    57→\\n    58→\\t// Telemetry controls anonymous usage analytics.\\n    59→\\t// nil = not asked yet (show pr