== 0 {\\n   456→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., \\\"+strings.Join(agent.StringList(), \\\", \\\")+\\\").\\\")\\n   457→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   458→\\t\\tfmt.Fprintln(w)\\n   459→\\t}\\n   460→\\n   461→\\t// Build pre-selection set.\\n   462→\\t// On re-run: only pre-select agents with hooks installed (respect prior deselection).\\n   463→\\t// On first run: pre-select all detected agents.\\n   464→\\tpreSelectedSet := make(map[types.AgentName]struct{})\\n   465→\\tif hasInstalledHooks {\\n   466→\\t\\tfor _, name := range installedAgentNames {\\n   467→\\t\\t\\tpreSelectedSet[name] = struct{}{}\\n   468→\\t\\t}\\n   469→\\t} else {\\n   470→\\t\\tfor _, ag := range detected {\\n   471→\\t\\t\\tpreSelectedSet[ag.Name()] = struct{}{}\\n   472→\\t\\t}\\n   473→\\t}\\n   474→\\n   475→\\t// Build options from registered agents\\n   476→\\tagentNames := agent.List()\\n   477→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   478→\\tfor _, name := range agentNames {\\n   479→\\t\\tag, err := agent.Get(name)\\n   480→\\t\\tif err != nil {\\n   481→\\t\\t\\tcontinue\\n   482→\\t\\t}\\n   483→\\t\\t// Only show agents that support hooks\\n   484→\\t\\tif _, ok := agent.AsHookSupport(ag); !ok {\\n   485→\\t\\t\\tcontinue\\n   486→\\t\\t}\\n   487→\\t\\t// Skip test-only agents (e.g., Vogon canary)\\n   488→\\t\\tif to, ok := ag.(agent.TestOnly); ok && to.IsTestOnly() {\\n   489→\\t\\t\\tcontinue\\n   490→\\t\\t}\\n   491→\\t\\topt := huh.NewOption(string(ag.Type()), string(name))\\n   492→\\t\\tif _, isPreSelected := preSelectedSet[name]; isPreSelected {\\n   493→\\t\\t\\topt = opt.Selected(true)\\n   494→\\t\\t}\\n   495→\\t\\toptions = append(options, opt)\\n   496→\\t}\\n   497→\\n   498→\\tif len(options) == 0 {\\n   499→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   500→\\t}\\n   501→\\n   502→\\t// Collect available agent names for the selector\\n   503→\\tavailableNames := make([]string, 0, len(options))\\n   504→\\tfor _, opt := range options {\\n   505→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   506→\\t}\\n   507→\\n   508→\\tvar selectedAgentNames []string\\n   509→\\tif selectFn != nil {\\n   510→\\t\\tvar err error\\n   511→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   512→\\t\\tif err != nil {\\n   513→\\t\\t\\treturn nil, err\\n   514→\\t\\t}\\n   515→\\t\\tif len(selectedAgentNames) == 0 {\\n   516→\\t\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   517→\\t\\t}\\n   518→\\t} else {\\n   519→\\t\\tform := NewAccessibleForm(\\n   520→\\t\\t\\thuh.NewGroup(\\n   521→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   522→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   523→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   524→\\t\\t\\t\\t\\tOptions(options...).\\n   525→\\t\\t\\t\\t\\tValidate(func(selected []string) error {\\n   526→\\t\\t\\t\\t\\t\\tif len(selected) == 0 {\\n   527→\\t\\t\\t\\t\\t\\t\\treturn errors.New(\\\"please select at least one agent\\\")\\n   528→\\t\\t\\t\\t\\t\\t}\\n   529→\\t\\t\\t\\t\\t\\treturn nil\\n   530→\\t\\t\\t\\t\\t}).\\n   531→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   532→\\t\\t\\t),\\n   533→\\t\\t)\\n   534→\\t\\tif err := form.Run(); err != nil {\\n   535→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   536→\\t\\t}\\n   537→\\t}\\n   538→\\n   539→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   540→\\tfor _, name := range selectedAgentNames {\\n   541→\\t\\tselectedAgent, err := agent.Get(types.AgentName(name))\\n   542→\\t\\tif err != nil {\\n   543→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   544→\\t\\t}\\n   545→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   546→\\t}\\n   547→\\n   548→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   549→\\tfor _, ag := range selectedAgents {\\n   550→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   551→\\t}\\n   552→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   553→\\treturn selectedAgents, nil\\n   554→}\\n   555→\\n   556→// canPromptInteractively checks if we can show interactive prompts.\\n   557→// Returns false when running in CI, tests, or other non-interactive environments.\\n   558→func canPromptInteractively() bool {\\n   559→\\t// Check for test environment\\n   560→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   561→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   562→\\t}\\n   563→\\n   564→\\t// Check if /dev/tty is available\\n   565→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   566→\\tif err != nil {\\n   567→\\t\\treturn false\\n   568→\\t}\\n   569→\\t_ = tty.Close()\\n   570→\\treturn true\\n   571→}\\n   572→\\n   573→// printAgentError writes an error message followed by available agents and usage.\\n   574→func printAgentError(w io.Writer, message string) {\\n   575→\\tagents := agent.List()\\n   576→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   577→\\tfmt.Fprintln(w)\\n   578→\\tfor _, a := range agents {\\n   579→\\t\\tsuffix := \\\"\\\"\\n   580→\\t\\tif a == agent.DefaultAgentName {\\n   581→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   582→\\t\\t}\\n   583→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   584→\\t}\\n   585→\\tfmt.Fprintln(w)\\n   586→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   587→}\\n   588→\\n   589→// printMissingAgentError writes a helpful error listing available agents.\\n   590→func printMissingAgentError(w io.Writer) {\\n   591→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   592→}\\n   593→\\n   594→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   595→func printWrongAgentError(w io.Writer, name string) {\\n   596→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   597→}\\n   598→\\n   599→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   600→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   601→func setupAgentHooksNonInteractive(ctx context.Context, w io.Writer, ag agent.Agent, opts EnableOptions) error {\\n   602→\\tagentName := ag.Name()\\n   603→\\t// Check if agent supports hooks\\n   604→\\thookAgent, ok := agent.AsHookSupport(ag)\\n   605→\\tif !ok {\\n   606→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   607→\\t}\\n   608→\\n   609→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   610→\\n   611→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   612→\\tinstalledHooks, err := hookAgent.InstallHooks(ctx, opts.LocalDev, opts.ForceHooks)\\n   613→\\tif err != nil {\\n   614→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   615→\\t}\\n   616→\\n   617→\\t// Setup .entire directory\\n   618→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   619→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   620→\\t}\\n   621→\\n   622→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   623→\\tsettings, err := LoadEntireSettings(ctx)\\n   624→\\tif err != nil {\\n   625→\\t\\t// If we can't load, start with defaults\\n   626→\\t\\tsettings = &EntireSettings{}\\n   627→\\t}\\n   628→\\tsettings.Enabled = true\\n   629→\\tif opts.LocalDev {\\n   630→\\t\\tsettings.LocalDev = true\\n   631→\\t}\\n   632→\\tif opts.AbsoluteGitHookPath {\\n   633→\\t\\tsettings.AbsoluteGitHookPath = true\\n   634→\\t}\\n   635→\\n   636→\\topts.applyStrategyOptions(settings)\\n   637→\\n   638→\\t// Handle telemetry for non-interactive mode\\n   639→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   640→\\tif !opts.Telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   641→\\t\\tf := false\\n   642→\\t\\tsettings.Telemetry = &f\\n   643→\\t}\\n   644→\\n   645→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   646→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   647→\\t}\\n   648→\\n   649→\\t// Use settings values (merged from existing config + flags) for hook installation\\n   650→\\t// This ensures re-running `entire enable --agent X` without flags preserves existing settings\\n   651→\\tif _, err := strategy.InstallGitHook(ctx, true, settings.LocalDev, settings.AbsoluteGitHookPath); err != nil {\\n   652→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   653→\\t}\\n   654→\\tstrategy.CheckAndWarnHookManagers(ctx, w, settings.LocalDev, settings.AbsoluteGitHookPath)\\n   655→\\n   656→\\tif installedHooks == 0 {\\n   657→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   658→\\t\\tif ag.IsPreview() {\\n   659→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   660→\\t\\t}\\n   661→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   662→\\t} else {\\n   663→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   664→\\t\\tif ag.IsPreview() {\\n   665→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   666→\\t\\t}\\n   667→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   668→\\t}\\n   669→\\n   670→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   671→\\n   672→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   673→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   674→\\t}\\n   675→\\n   676→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   677→\\n   678→\\treturn nil\\n   679→}\\n   680→\\n   681→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   682→func validateSetupFlags(useLocal, useProject bool) error {\\n   683→\\tif useLocal && useProject {\\n   684→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   685→\\t}\\n   686→\\treturn nil\\n   687→}\\n   688→\\n   689→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   690→// - Whether settings.json already exists\\n   691→// - The --local and --project flags\\n   692→// Returns (useLocal, showNotification).\\n   693→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   694→\\t// Explicit --local flag always uses local settings\\n   695→\\tif useLocal {\\n   696→\\t\\treturn true, false\\n   697→\\t}\\n   698→\\n   699→\\t// Explicit --project flag always uses project settings\\n   700→\\tif useProject {\\n   701→\\t\\treturn false, false\\n   702→\\t}\\n   703→\\n   704→\\t// No flags specified - check if settings file exists\\n   705→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   706→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   707→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   708→\\t\\treturn true, true\\n   709→\\t}\\n   710→\\n   711→\\t// Settings file doesn't exist - create it\\n   712→\\treturn false, false\\n   713→}\\n   714→\\n   715→// setupEntireDirectory creates the .entire directory and gitignore.\\n   716→// Returns true if the directory was created, false if it already existed.\\n   717→func setupEntireDirectory(ctx context.Context) (bool, error) { //nolint:unparam // already present in codebase\\n   718→\\t// Get absolute path for the .entire directory\\n   719→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   720→\\tif err != nil {\\n   721→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   722→\\t}\\n   723→\\n   724→\\t// Check if directory already exists\\n   725→\\tcreated := false\\n   726→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   727→\\t\\tcreated = true\\n   728→\\t}\\n   729→\\n   730→\\t// Create .entire directory\\n   731→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   732→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   733→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   734→\\t}\\n   735→\\n   736→\\t// Create/update .gitignore with all required entries\\n   737→\\tif err := strategy.EnsureEntireGitignore(ctx); err != nil {\\n   738→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   739→\\t}\\n   740→\\n   741→\\treturn created, nil\\n   742→}\\n   743→\\n   744→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   745→func setupGitHook(ctx context.Context) error {\\n   746→\\ts, err := settings.Load(ctx)\\n   747→\\tlocalDev := err == nil && s.LocalDev\\n   748→\\tabsoluteHookPath := err == nil && s.AbsoluteGitHookPath\\n   749→\\tif _, err := strategy.InstallGitHook(ctx, false, localDev, absoluteHookPath); err != nil {\\n   750→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   751→\\t}\\n   752→\\tstrategy.CheckAndWarnHookManagers(ctx, os.Stderr, localDev, absoluteHookPath)\\n   753→\\treturn nil\\n   754→}\\n   755→\\n   756→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   757→func newSetupGitHookCmd() *cobra.Command {\\n   758→\\tcmd := &cobra.Command{\\n   759→\\t\\tUse:    \\\"git-hook\\\",\\n   760→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   761→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   762→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   763→\\t\\t\\treturn setupGitHook(cmd.Context())\\n   764→\\t\\t},\\n   765→\\t}\\n   766→\\n   767→\\treturn cmd\\n   768→}\\n   769→\\n   770→func newCurlBashPostInstallCmd() *cobra.Command {\\n   771→\\treturn &cobra.Command{\\n   772→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   773→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   774→\\t\\tHidden: true,\\n   775→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   776→\\t\\t\\tw := cmd.OutOrStdout()\\n   777→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   778→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   779→\\t\\t\\t}\\n   780→\\t\\t\\treturn nil\\n   781→\\t\\t},\\n   782→\\t}\\n   783→}\\n   784→\\n   785→// shellCompletionComment is the comment preceding the completion line\\n   786→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   787→\\n   788→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   789→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   790→\\n   791→// shellCompletionTarget returns the rc file path and completion lines for the\\n   792→// user's current shell.\\n   793→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   794→\\thome, err := os.UserHomeDir()\\n   795→\\tif err != nil {\\n   796→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   797→\\t}\\n   798→\\n   799→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   800→\\tswitch {\\n   801→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   802→\\t\\treturn \\\"Zsh\\\",\\n   803→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   804→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   805→\\t\\t\\tnil\\n   806→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   807→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   808→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   809→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   810→\\t\\t}\\n   811→\\t\\treturn \\\"Bash\\\",\\n   812→\\t\\t\\tbashRC,\\n   813→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   814→\\t\\t\\tnil\\n   815→\\tcase strings.Contains(shell, \\\"fish\\\"):\\n   816→\\t\\treturn \\\"Fish\\\",\\n   817→\\t\\t\\tfilepath.Join(home, \\\".config\\\", \\\"fish\\\", \\\"config.fish\\\"),\\n   818→\\t\\t\\t\\\"entire completion fish | source\\\",\\n   819→\\t\\t\\tnil\\n   820→\\tdefault:\\n   821→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   822→\\t}\\n   823→}\\n   824→\\n   825→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   826→// Only prompts if completion is not already configured.\\n   827→func promptShellCompletion(w io.Writer) error {\\n   828→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   829→\\tif err != nil {\\n   830→\\t\\tif errors.Is(err, errUnsupportedShell) {\\n   831→\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion not available for your shell. Supported: zsh, bash, fish.\\\\n\\\")\\n   832→\\t\\t\\treturn nil\\n   833→\\t\\t}\\n   834→\\t\\treturn fmt.Errorf(\\\"shell completion: %w\\\", err)\\n   835→\\t}\\n   836→\\n   837→\\tif isCompletionConfigured(rcFile) {\\n   838→\\t\\tfmt.Fprintf(w, \\\"✓ Shell completion already configured in %s\\\\n\\\", rcFile)\\n   839→\\t\\treturn nil\\n   840→\\t}\\n   841→\\n   842→\\tvar selected string\\n   843→\\tform := NewAccessibleForm(\\n   844→\\t\\thuh.NewGroup(\\n   845→\\t\\t\\thuh.NewSelect[string]().\\n   846→\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Enable shell completion? (detected: %s)\\\", shellName)).\\n   847→\\t\\t\\t\\tOptions(\\n   848→\\t\\t\\t\\t\\thuh.NewOption(\\\"Yes\\\", \\\"yes\\\"),\\n   849→\\t\\t\\t\\t\\thuh.NewOption(\\\"No\\\", \\\"no\\\"),\\n   850→\\t\\t\\t\\t).\\n   851→\\t\\t\\t\\tValue(&selected),\\n   852→\\t\\t),\\n   853→\\t)\\n   854→\\n   855→\\tif err := form.Run(); err != nil {\\n   856→\\t\\t//nolint:nilerr // User cancelled - not a fatal error, just skip\\n   857→\\t\\treturn nil\\n   858→\\t}\\n   859→\\n   860→\\tif selected != \\\"yes\\\" {\\n   861→\\t\\treturn nil\\n   862→\\t}\\n   863→\\n   864→\\tif err := appendShellCompletion(rcFile, completionLine); err != nil {\\n   865→\\t\\treturn fmt.Errorf(\\\"failed to update %s: %w\\\", rcFile, err)\\n   866→\\t}\\n   867→\\n   868→\\tfmt.Fprintf(w, \\\"✓ Shell completion added to %s\\\\n\\\", rcFile)\\n   869→\\tfmt.Fprintln(w, \\\"  Restart your shell to activate\\\")\\n   870→\\n   871→\\treturn nil\\n   872→}\\n   873→\\n   874→// isCompletionConfigured checks if shell completion is already in the rc file.\\n   875→func isCompletionConfigured(rcFile string) bool {\\n   876→\\t//nolint:gosec // G304: rcFile is constructed from home dir + known filename, not user input\\n   877→\\tcontent, err := os.ReadFile(rcFile)\\n   878→\\tif err != nil {\\n   879→\\t\\treturn false // File doesn't exist or can't read, treat as not configured\\n   880→\\t}\\n   881→\\treturn strings.Contains(string(content), \\\"entire completion\\\")\\n   882→}\\n   883→\\n   884→// appendShellCompletion adds the completion line to the rc file.\\n   885→func appendShellCompletion(rcFile, completionLine string) error {\\n   886→\\tif err := os.MkdirAll(filepath.Dir(rcFile), 0o700); err != nil {\\n   887→\\t\\treturn fmt.Errorf(\\\"creating directory: %w\\\", err)\\n   888→\\t}\\n   889→\\t//nolint:gosec // G302: Shell rc files need 0644 for user readability\\n   890→\\tf, err := os.OpenFile(rcFile, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0o644)\\n   891→\\tif err != nil {\\n   892→\\t\\treturn fmt.Errorf(\\\"opening file: %w\\\", err)\\n   893→\\t}\\n   894→\\tdefer f.Close()\\n   895→\\n   896→\\t_, err = f.WriteString(\\\"\\\\n\\\" + shellCompletionComment + \\\"\\\\n\\\" + completionLine + \\\"\\\\n\\\")\\n   897→\\tif err != nil {\\n   898→\\t\\treturn fmt.Errorf(\\\"writing completion: %w\\\", err)\\n   899→\\t}\\n   900→\\treturn nil\\n   901→}\\n   902→\\n   903→// promptTelemetryConsent asks the user if they want to enable telemetry.\\n   904→// It modifies settings.Telemetry based on the user's choice or flags.\\n   905