== nil {\\n   285→\\t\\treturn nil // Branch exists locally, skip fetch\\n   286→\\t}\\n   287→\\n   288→\\t// Branch doesn't exist locally - try to fetch it from the URL.\\n   289→\\t// Fetch to a temp ref to avoid polluting the remote-tracking namespace.\\n   290→\\tfetchCtx, cancel := context.WithTimeout(ctx, checkpointRemoteFetchTimeout)\\n   291→\\tdefer cancel()\\n   292→\\n   293→\\ttmpRef := \\\"refs/entire-fetch-tmp/\\\" + branchName\\n   294→\\trefSpec := fmt.Sprintf(\\\"+refs/heads/%s:%s\\\", branchName, tmpRef)\\n   295→\\tfetchCmd := exec.CommandContext(fetchCtx, \\\"git\\\", \\\"fetch\\\", \\\"--no-tags\\\", remoteURL, refSpec)\\n   296→\\tfetchCmd.Stdin = nil\\n   297→\\tfetchCmd.Env = append(os.Environ(),\\n   298→\\t\\t\\\"GIT_TERMINAL_PROMPT=0\\\", // Prevent interactive auth prompts\\n   299→\\t)\\n   300→\\tif err := fetchCmd.Run(); err != nil {\\n   301→\\t\\t// Fetch failed - remote may be unreachable or branch doesn't exist there yet.\\n   302→\\t\\t// Not fatal: push will create it on the remote when it succeeds.\\n   303→\\t\\treturn nil\\n   304→\\t}\\n   305→\\n   306→\\t// Fetch succeeded - create local branch from the fetched ref\\n   307→\\tfetchedRef, err := repo.Reference(plumbing.ReferenceName(tmpRef), true)\\n   308→\\tif err != nil {\\n   309→\\t\\t// Fetch succeeded but ref not found - branch may not exist on remote\\n   310→\\t\\treturn nil\\n   311→\\t}\\n   312→\\n   313→\\tnewRef := plumbing.NewHashReference(branchRef, fetchedRef.Hash())\\n   314→\\tif err := repo.Storer.SetReference(newRef); err != nil {\\n   315→\\t\\treturn fmt.Errorf(\\\"failed to create local branch from fetched ref: %w\\\", err)\\n   316→\\t}\\n   317→\\n   318→\\t// Clean up the temp ref (best-effort, not critical if it fails)\\n   319→\\t_ = repo.Storer.RemoveReference(plumbing.ReferenceName(tmpRef)) //nolint:errcheck // cleanup is best-effort\\n   320→\\n   321→\\tlogging.Info(ctx, \\\"checkpoint-remote: fetched branch from URL\\\",\\n   322→\\t\\tslo