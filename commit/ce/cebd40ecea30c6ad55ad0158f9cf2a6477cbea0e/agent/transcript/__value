cmd/entire/cli/paths\\\"\\n    16→)\\n    17→\\n    18→const (\\n    19→\\t// EntireSettingsFile is the path to the Entire settings file\\n    20→\\tEntireSettingsFile = \\\".entire/settings.json\\\"\\n    21→\\t// EntireSettingsLocalFile is the path to the local settings override file (not committed)\\n    22→\\tEntireSettingsLocalFile = \\\".entire/settings.local.json\\\"\\n    23→)\\n    24→\\n    25→// Commit linking mode constants.\\n    26→const (\\n    27→\\t// CommitLinkingAlways auto-links commits to sessions without prompting.\\n    28→\\tCommitLinkingAlways = \\\"always\\\"\\n    29→\\t// CommitLinkingPrompt prompts the user on each commit (default for existing users).\\n    30→\\tCommitLinkingPrompt = \\\"prompt\\\"\\n    31→)\\n    32→\\n    33→// EntireSettings represents the .entire/settings.json configuration\\n    34→type EntireSettings struct {\\n    35→\\n    36→\\t// Enabled indicates whether Entire is active. When false, CLI commands\\n    37→\\t// show a disabled message and hooks exit silently. Defaults to true.\\n    38→\\tEnabled bool `json:\\\"enabled\\\"`\\n    39→\\n    40→\\t// LocalDev indicates whether to use \\\"go run\\\" instead of the \\\"entire\\\" binary\\n    41→\\t// This is used for development when the binary is not installed\\n    42→\\tLocalDev bool `json:\\\"local_dev,omitempty\\\"`\\n    43→\\n    44→\\t// LogLevel sets the logging verbosity (debug, info, warn, error).\\n    45→\\t// Can be overridden by ENTIRE_LOG_LEVEL environment variable.\\n    46→\\t// Defaults to \\\"info\\\".\\n    47→\\tLogLevel string `json:\\\"log_level,omitempty\\\"`\\n    48→\\n    49→\\t// StrategyOptions contains strategy-specific configuration\\n    50→\\tStrategyOptions map[string]any `json:\\\"strategy_options,omitempty\\\"`\\n    51→\\n    52→\\t// AbsoluteGitHookPath embeds the full binary path in git hooks instead of\\n    53→\\t// bare \\\"entire\\\". This is needed for GUI git clients (Xcode, Tower, etc.)\\n    54→\\t// that don't source shell profiles and can't find \\\"entire\\\" on PATH.\\n    55→\\tAbsoluteGitHookPath bool `json:\\\"absolute_git_hook_path,omitempty\\\"`\\n    56→\\n    57→\\t// Telemetry controls anonymous usage analytics.\\n    58→\\t// nil = not asked yet (show prompt), true = opted in, false = opted out\\n    59→\\tTelemetry *bool `json:\\\"telemetry,omitempty\\\"`\\n    60→\\n    61→\\t// CommitLinking controls how commits are linked to agent sessions.\\n    62→\\t// \\\"always\\\" = auto-link without prompting, \\\"prompt\\\" = ask on each commit.\\n    63→\\t// Defaults to \\\"prompt\\\" (preserves existing user behavior).\\n    64→\\tCommitLinking string `json:\\\"commit_linking,omitempty\\\"`\\n    65→\\n    66→\\t// ExternalAgents enables discovery and registration of external agent\\n    67→\\t// plugins (entire-agent-* binaries on $PATH). Defaults to false.\\n    68→\\tExternalAgents bool `json:\\\"external_agents,omitempty\\\"`\\n    69→\\n    70→\\t// Deprecated: no longer used. Exists to tolerate old settings files\\n    71→\\t// that still contain \\\"strategy\\\": \\\"auto-commit\\\" or similar.\\n    72→\\tStrategy string `json:\\\"strategy,omitempty\\\"`\\n    73→}\\n    74→\\n    75→// GetCommitLinking returns the effective commit linking mode.\\n    76→// Returns the explicit value if set, otherwise defaults to \\\"prompt\\\"\\n    77→// to preserve existing user behavior.\\n    78→func (s *EntireSettings) GetCommitLinking() string {\\n    79→\\tif s.CommitLinking != \\\"\\\" {\\n    80→\\t\\treturn s.CommitLinking\\n    81→\\t}\\n    82→\\treturn CommitLinkingPrompt\\n    83→}\\n    84→\\n    85→// Load loads the Entire settings from .entire/settings.json,\\n    86→// then applies any overrides from .entire/settings.local.json if it exists.\\n    87→// Returns default settings if neither file exists.\\n    88→// Works correctly from any subdirectory within the repository.\\n    89→func Load(ctx context.Context) (*EntireSettings, error) {\\n    90→\\t// Get absolute paths for settings files\\n    91→\\tsettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsFile)\\n    92→\\tif err != nil {\\n    93→\\t\\tsettingsFileAbs = EntireSettingsFile // Fallback to relative\\n    94→\\t}\\n    95→\\tlocalSettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsLocalFile)\\n    96→\\tif err != nil {\\n    97→\\t\\tlocalSettingsFileAbs = EntireSettingsLocalFile // Fallback to relative\\n    98→\\t}\\n    99→\\n   100→\\t// Load base settings\\n   101→\\tsettings, err := loadFromFile(settingsFileAbs)\\n   102→\\tif err != nil {\\n   103→\\t\\treturn nil, fmt.Errorf(\\\"reading settings file: %w\\\", err)\\n   104→\\t}\\n   105→\\n   106→\\t// Apply local overrides if they exist\\n   107→\\tlocalData, err := os.ReadFile(localSettingsFileAbs) //nolint:gosec // path is from AbsPath or constant\\n   108→\\tif err != nil {\\n   109→\\t\\tif !os.IsNotExist(err) {\\n   110→\\t\\t\\treturn nil, fmt.Errorf(\\\"reading local settings file: %w\\\", err)\\n   111→\\t\\t}\\n   112→\\t\\t// Local file doesn't exist, continue without overrides\\n   113→\\t} else {\\n   114→\\t\\tif err := mergeJSON(settings, localData); err != nil {\\n   115→\\t\\t\\treturn nil, fmt.Errorf(\\\"merging local settings: %w\\\", err)\\n   116→\\t\\t}\\n   117→\\t}\\n   118→\\n   119→\\treturn settings, nil\\n   120→}\\n   121→\\n   122→// LoadFromFile loads settings from a specific file path without merging local overrides.\\n   123→// Returns default settings if the file doesn't exist.\\n   124→// Use this when you need to display individual settings files separately.\\n   125→func LoadFromFile(filePath string) (*EntireSettings, error) {\\n   126→\\treturn loadFromFile(filePath)\\n   127→}\\n   128→\\n   129→// loadFromFile loads settings from a specific file path.\\n   130→// Returns default settings if the file doesn't exist.\\n   131→func loadFromFile(filePath string) (*EntireSettings, error) {\\n   132→\\tsettings := &EntireSettings{\\n   133→\\t\\tEnabled