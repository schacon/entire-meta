29→// This is used to generate trailers for linking commits to their AI session.\\n    30→type SessionInfo struct {\\n    31→\\t// SessionID is the session identifier extracted from the latest commit's metadata\\n    32→\\tSessionID string\\n    33→\\n    34→\\t// Reference is a strategy-specific reference string.\\n    35→\\t// For manual-commit strategy: \\\"entire/abc1234\\\" (the shadow branch name)\\n    36→\\t// Empty for commit strategy (metadata is in the same commit).\\n    37→\\tReference string\\n    38→\\n    39→\\t// CommitHash is the full SHA of the commit containing the session metadata.\\n    40→\\t// Empty for commit strategy.\\n    41→\\tCommitHash string\\n    42→}\\n    43→\\n    44→// RewindPoint represents a point to which the user can rewind.\\n    45→// This abstraction allows different strategies to use different\\n    46→// identifiers (commit hashes, branch names, stash refs, etc.)\\n    47→type RewindPoint struct {\\n    48→\\t// ID is the unique identifier for this rewind point\\n    49→\\t// (commit hash, branch name, stash ref, etc.)\\n    50→\\tID string\\n    51→\\n    52→\\t// Message is the human-readable description/summary\\n    53→\\tMessage string\\n    54→\\n    55→\\t// MetadataDir is the path to the metadata directory\\n    56→\\tMetadataDir string\\n    57→\\n    58→\\t// Date is when this rewind point was created\\n    59→\\tDate time.Time\\n    60→\\n    61→\\t// IsTaskCheckpoint indicates if this is a task checkpoint (vs a session checkpoint)\\n    62→\\tIsTaskCheckpoint bool\\n    63→\\n    64→\\t// ToolUseID is the tool use ID for task checkpoints (empty for session checkpoints)\\n    65→\\tToolUseID string\\n    66→\\n    67→\\t// IsLogsOnly indicates this is a commit with session logs but no shadow branch state.\\n    68→\\t// The logs can be restored from entire/checkpoints/v1, but file state requires git checkout.\\n    69→\\tIsLogsOnly bool\\n    70→\\n    71→\\t// CheckpointID is the stable 12-hex-char identifier