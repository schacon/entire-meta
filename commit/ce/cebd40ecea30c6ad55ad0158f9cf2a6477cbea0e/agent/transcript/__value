repo.Reference(branchRef, true)\\n    34→\\tif err != nil {\\n    35→\\t\\t// No branch, nothing to push\\n    36→\\t\\treturn nil //nolint:nilerr // Expected when no sessions exist yet\\n    37→\\t}\\n    38→\\n    39→\\t// Only check remote tracking refs when target is a remote name (not a URL).\\n    40→\\t// URLs don't have tracking refs, so we always attempt the push and let git handle it.\\n    41→\\tif !isURL(target) && !hasUnpushedSessionsCommon(repo, target, localRef.Hash(), branchName) {\\n    42→\\t\\treturn nil\\n    43→\\t}\\n    44→\\n    45→\\treturn doPushBranch(ctx, target, branchName)\\n    46→}\\n    47→\\n    48→// hasUnpushedSessionsCommon checks if the local branch differs from the remote.\\n    49→// Returns true if there's any difference that needs syncing (local ahead, remote ahead, or diverged).\\n    50→func hasUnpushedSessionsCommon(repo *git.Repository, remote string, localHash plumbing.Hash, branchName string) bool {\\n    51→\\t// Check for remote tracking ref: refs/remotes/<remote>/<branch>\\n    52→\\tremoteRefName := plumbing.NewRemoteReferenceName(remote, branchName)\\n    53→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n    54→\\tif err != nil {\\n    55→\\t\\t// Remote branch doesn't exist yet - we have content to push\\n    56→\\t\\treturn true\\n    57→\\t}\\n    58→\\n    59→\\t// If local and remote point to same commit, nothing to sync\\n    60→\\t// This is the only case where we skip - any difference needs handling\\n    61→\\treturn localHash != remoteRef.Hash()\\n    62→}\\n    63→\\n    64→// doPushBranch pushes the given branch to the target with fetch+merge recovery.\\n    65→// The target can be a remote name or a URL.\\n    66→func doPushBranch(ctx context.Context, target, branchName string) error {\\n    67→\\tdisplayTarget := target\\n    68→\\tif isURL(target) {\\n    69→\\t\\tdisplayTarget = \\\"checkpoint remote\\\"\\n    70→\\t}\\n    71→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Pushing %s to %s...\\\\n\\\", branchName, displayTarget)\\n    72→\\n    73→\\t// Try pushing first\\n    74→\\tif err := tryPushSessionsCommon(ctx, target, branchName); err == nil {\\n    75→\\t\\treturn nil\\n    76→\\t}\\n    77→\\n    78→\\t// Push failed - likely non-fast-forward. Try to fetch and merge.\\n    79→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Syncing %s with remote...\\\\n\\\", branchName)\\n    80→\\n    81→\\tif err := fetchAndMergeSessionsCommon(ctx, target, branchName); err != nil {\\n    82→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: couldn't sync %s: %v\\\\n\\\", branchName, err)\\n    83→\\t\\tprintCheckpointRemoteHint(target)\\n    84→\\t\\treturn nil // Don't fail the main push\\n    85→\\t}\\n    86→\\n    87→\\t// Try pushing again after merge\\n    88→\\tif err := tryPushSessionsCommon(ctx, target, branchName); err != nil {\\n    89→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to push %s after sync: %v\\\\n\\\", branchName, err)\\n    90→\\t\\tprintCheckpointRemoteHint(target)\\n    91→\\t}\\n    92→\\n    93→\\treturn nil\\n    94→}\\n    95→\\n    96→// printCheckpointRemoteHint prints a hint when a push to a checkpoint URL fails.\\n    97→// Only prints when the target is a URL (not the user's default remote).\\n    98→func printCheckpointRemoteHint(target string) {\\n    99→\\tif !isURL(target) {\\n   100→\\t\\treturn\\n   101→\\t}\\n   102→\\tfmt.Fprintln(os.Stderr, \\\"[entire] A checkpoint remote is configured in Entire settings (.entire/settings.json or .entire/settings.local.json) but could not be reached.\\\")\\n   103→\\tfmt.Fprintln(os.Stderr, \\\"[entire] Checkpoints are saved locally but not synced. Ensure you have access to the checkpoint remote.\\\")\\n   104→}\\n   105→\\n   106→// tryPushSessionsCommon attempts to push the sessions branch.\\n   107→func tryPushSessionsCommon(ctx context.Context, remote, branchName string) error {\\n   108→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   109→\\tdefer cancel()\\n   110→\\n   111→\\t// Use --no-verify to prevent recursive hook calls\\n   112→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"push\\\", \\\"--no-verify\\\", remote, branchName)\\n   113→\\tcmd.Stdin = nil // Disconnect stdin to prevent hanging in hook context\\n   114→\\n   115→\\toutput, err := cmd.CombinedOutput()\\n   116→\\tif err != nil {\\n   117→\\t\\t// Check if it's a non-fast-forward error (we can try to recover)\\n   118→\\t\\tif strings.Contains(string(output), \\\"non-fast-forward\\\") ||\\n   119→\\t\\t\\tstrings.Contains(string(output), \\\"rejected\\\") {\\n   120→\\t\\t\\treturn errors.New(\\\"non-fast-forward\\\")\\n   121→\\t\\t}\\n   122→\\t\\treturn fmt.Errorf(\\\"push failed: %s\\\", output)\\n   123→\\t}\\n   124→\\treturn nil\\n   125→}\\n   126→\\n   127→// fetchAndMergeSessionsCommon fetches remote sessions and merges into local using go-git.\\n   128→// Since session logs are append-only (unique cond-* directories), we just combine trees.\\n   129→// The target can be a remote name or a URL.\\n   130→func fetchAndMergeSessionsCommon(ctx context.Context, target, branchName string) error {\\n   131→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   132→\\tdefer cancel()\\n   133→\\n   134→\\t// Determine fetch refspec. When target is a URL, use a temp ref;\\n   135→\\t// when it's a remote name, use the standard remote-tracking ref.\\n   136→\\tvar fetchedRefName plumbing.ReferenceName\\n   137→\\tvar refSpec string\\n   138→\\tif isURL(target) {\\n   139→\\t\\ttmpRef := \\\"refs/entire-fetch-tmp/\\\" + branchName\\n   140→\\t\\trefSpec = fmt.Sprintf(\\\"+refs/heads/%s:%s\\\", branchName, tmpRef)\\n   141→\\t\\tfetchedRefName = plumbing.ReferenceName(tmpRef)\\n   142→\\t} else {\\n   143→\\t\\trefSpec = fmt.Sprintf(\\\"+refs/heads/%s:refs/remotes/%s/%s\\\", branchName, target, branchName)\\n   144→\\t\\tfetchedRefName = plumbing.NewRemoteReferenceName(target, branchName)\\n   145→\\t}\\n   146→\\n   147→\\t// Use git CLI for fetch (go-git's fetch can be tricky with auth)\\n   148→\\tfetchCmd := exec.CommandContext(ctx, \\\"git\\\", \\\"fetch\\\", target, refSpec)\\n   149→\\tfetchCmd.Stdin = nil\\n   150→\\tif output, err := fetchCmd.CombinedOutput(); err != nil {\\n   151→\\t\\treturn fmt.Errorf(\\\"fetch failed: %s\\\", output)\\n   152→\\t}\\n   153→\\n   154→\\trepo, err := OpenRepository(ctx)\\n   155→\\tif err != nil {\\n   156→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   157→\\t}\\n   158→\\n   159→\\t// Reconcile disconnected metadata branches before merging trees.\\n   160→\\t// The fetch above updated the remote-tracking ref, so reconciliation\\n   161→\\t// can compare fresh local vs remote. If disconnected (empty-orphan bug),\\n   162→\\t// this cherry-picks local commits onto remote tip, updating the local ref.\\n   163→\\t// If reconciliation fails, abort — proceeding to tree merge on disconnected\\n   164→\\t// branches would silently combine unrelated histories.\\n   165→\\tif reconcileErr := ReconcileDisconnectedMetadataBranch(ctx, repo, os.Stderr); reconcileErr != nil {\\n   166→\\t\\treturn fmt.Errorf(\\\"metadata reconciliation failed: %w\\\", reconcileErr)\\n   167→\\t}\\n   168→\\n   169→\\t// Get local branch (re-read after potential reconciliation update)\\n   170→\\tlocalRef, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   171→\\tif err != nil {\\n   172→\\t\\treturn fmt.Errorf(\\\"failed to get local ref: %w\\\", err)\\n   173→\\t}\\n   174→\\tlocalCommit, err := repo.CommitObject(localRef.Hash())\\n   175→\\tif err != nil {\\n   176→\\t\\treturn fmt.Errorf(\\\"failed to get local commit: %w\\\", err)\\n   177→\\t}\\n   178→\\tlocalTree, err := localCommit.Tree()\\n   179→\\tif err != nil {\\n   180→\\t\\treturn fmt.Errorf(\\\"failed to get local tree: %w\\\", err)\\n   181→\\t}\\n   182→\\n   183→\\t// Get fetched ref (remote-tracking or temp ref, updated by the fetch above)\\n   184→\\tremoteRef