  178→\\t\\tif err := json.Unmarshal(enabledRaw, &e); err != nil {\\n   179→\\t\\t\\treturn fmt.Errorf(\\\"parsing enabled field: %w\\\", err)\\n   180→\\t\\t}\\n   181→\\t\\tsettings.Enabled = e\\n   182→\\t}\\n   183→\\n   184→\\t// Override local_dev if present\\n   185→\\tif localDevRaw, ok := raw[\\\"local_dev\\\"]; ok {\\n   186→\\t\\tvar ld bool\\n   187→\\t\\tif err := json.Unmarshal(localDevRaw, &ld); err != nil {\\n   188→\\t\\t\\treturn fmt.Errorf(\\\"parsing local_dev field: %w\\\", err)\\n   189→\\t\\t}\\n   190→\\t\\tsettings.LocalDev = ld\\n   191→\\t}\\n   192→\\n   193→\\t// Override absolute_git_hook_path if present\\n   194→\\tif ahpRaw, ok := raw[\\\"absolute_git_hook_path\\\"]; ok {\\n   195→\\t\\tvar ahp bool\\n   196→\\t\\tif err := json.Unmarshal(ahpRaw, &ahp); err != nil {\\n   197→\\t\\t\\treturn fmt.Errorf(\\\"parsing absolute_git_hook_path field: %w\\\", err)\\n   198→\\t\\t}\\n   199→\\t\\tsettings.AbsoluteGitHookPath = ahp\\n   200→\\t}\\n   201→\\n   202→\\t// Override log_level if present and non-empty\\n   203→\\tif logLevelRaw, ok := raw[\\\"log_level\\\"]; ok {\\n   204→\\t\\tvar ll string\\n   205→\\t\\tif err := json.Unmarshal(logLevelRaw, &ll); err != nil {\\n   206→\\t\\t\\treturn fmt.Errorf(\\\"parsing log_level field: %w\\\", err)\\n   207→\\t\\t}\\n   208→\\t\\tif ll != \\\"\\\" {\\n   209→\\t\\t\\tsettings.LogLevel = ll\\n   210→\\t\\t}\\n   211→\\t}\\n   212→\\n   213→\\t// Merge strategy_options if present\\n   214→\\tif optionsRaw, ok := raw[\\\"strategy_options\\\"]; ok {\\n   215→\\t\\tvar opts map[string]any\\n   216→\\t\\tif err := json.Unmarshal(optionsRaw, &opts); err != nil {\\n   217→\\t\\t\\treturn fmt.Errorf(\\\"parsing strategy_options field: %w\\\", err)\\n   218→\\t\\t}\\n   219→\\t\\tif settings.StrategyOptions == nil {\\n   220→\\t\\t\\tsettings.StrategyOptions = opts\\n   221→\\t\\t} else {\\n   222→\\t\\t\\tfor k, v := range opts {\\n   223→\\t\\t\\t\\tsettings.StrategyOptions[k] = v\\n   224→\\t\\t\\t}\\n   225→\\t\\t}\\n   226→\\t}\\n   227→\\n   228→\\t// Override telemetry if present\\n   229→\\tif telemetryRaw, ok := raw[\\\"telemetry\\\"]; ok {\\n   230→\\t\\tvar t bool\\n   231→\\t\\tif err := json.Unmarshal(telemetryRaw, &t); err != nil {\\n   232→\\t\\t\\treturn fmt.Errorf(\\\"parsing telemetry field: %w\\\", err)\\n   233→\\t\\t}\\n   234→\\t\\tsettings.Telemetry = &t\\n   235→\\t}\\n   236→\\n   237→\\t// Override commit_linking if present and non-empty\\n   238→\\tif commitLinkingRaw, ok := raw[\\\"commit_linking\\\"]; ok {\\n   239→\\t\\tvar cl string\\n   240→\\t\\tif err := json.Unmarshal(commitLinkingRaw, &cl); err != nil {\\n   241→\\t\\t\\treturn fmt.Errorf(\\\"parsing commit_linking field: %w\\\", err)\\n   242→\\t\\t}\\n   243→\\t\\tif cl != \\\"\\\" {\\n   244→\\t\\t\\tswitch cl {\\n   245→\\t\\t\\tcase CommitLinkingAlways, CommitLinkingPrompt:\\n   246→\\t\\t\\t\\tsettings.CommitLinking = cl\\n   247→\\t\\t\\tdefault:\\n   248→\\t\\t\\t\\treturn fmt.Errorf(\\\"invalid commit_linking value %q: must be %q or %q\\\", cl, CommitLinkingAlways, CommitLinkingPrompt)\\n   249→\\t\\t\\t}\\n   250→\\t\\t}\\n   251→\\t}\\n   252→\\n   253→\\t// Override external_agents if present\\n   254→\\tif externalAgentsRaw, ok := raw[\\\"external_agents\\\"]; ok {\\n   255→\\t\\tvar ea bool\\n   256→\\t\\tif err := json.Unmarshal(externalAgentsRaw, &ea); err != nil {\\n   257→\\t\\t\\treturn fmt.Errorf(\\\"parsing external_agents field: %w\\\", err)\\n   258→\\t\\t}\\n   259→\\t\\tsettings.ExternalAgents = ea\\n   260→\\t}\\n   261→\\n   262→\\treturn nil\\n   263→}\\n   264→\\n   265→// IsSetUp returns true if Entire has been set up in the current repository.\\n   266→// This checks if .entire/settings.json exists.\\n   267→// Use this to avoid creating files/directories in repos where Entire was never enabled.\\n   268→func IsSetUp(ctx context.Context) bool {\\n   269→\\tsettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsFile)\\n   270→\\tif err != nil {\\n   271→\\t\\treturn false\\n   272→\\t}\\n   273→\\t_, err = os.Stat(settingsFileAbs)\\n   274→\\treturn err == nil\\n   275→}\\n   276→\\n   277→// IsSetUpAndEnabled returns true if Entire is both set up and enabled.\\n   278→// This checks if .entire/settings.json exists AND has enabled: true.\\n   279→// Use this for hooks that should be no-ops when Entire is not active.\\n   280→func IsSetUpAndEnabled(ctx context.Context) bool {\\n   281→\\tif !IsSetUp(ctx) {\\n   282→\\t\\treturn false\\n   283→\\t}\\n   284→\\ts, err := Load(ctx)\\n   285→\\tif err != nil {\\n   286→\\t\\treturn false\\n   287→\\t}\\n   288→\\treturn s.Enabled\\n   289→}\\n   290→\\n   291→// IsSummarizeEnabled checks if auto-summarize is enabled in settings.\\n   292→// Returns false by default if settings cannot be loaded or the key is missing.\\n   293→func IsSummarizeEnabled(ctx context.Context) bool {\\n   294→\\tsettings, err := Load(ctx)\\n   295→\\tif err != nil {\\n   296→\\t\\treturn false\\n   297→\\t}\\n   298→\\treturn settings.IsSummarizeEnabled()\\n   299→}\\n   300→\\n   301→// IsSummarizeEnabled checks if auto-summarize is enabled in this settings instance.\\n   302→func (s *EntireSettings) IsSummarizeEnabled() bool {\\n   303→\\tif s.StrategyOptions == nil {\\n   304→\\t\\treturn false\\n   305→\\t}\\n   306→\\tsummarizeOpts, ok := s.StrategyOptions[\\\"summarize\\\"].(map[string]any)\\n   307→\\tif !ok {\\n   308→\\t\\treturn false\\n   309→\\t}\\n   310→\\tenabled, ok := summarizeOpts[\\\"enabled\\\"].(bool)\\n   311→\\tif !ok {\\n   312→\\t\\treturn false\\n   313→\\t}\\n   314→\\treturn enabled\\n   315→}\\n   316→\\n   317→// GetCheckpointRemote returns the configured checkpoint remote URL.\\n   318→// This is a full git remote URL (SSH or HTTPS) used for pushing/fetching\\n   319→// the entire/checkpoints/v1 and entire/trails/v1 branches to a separate remote.\\n   320→// Returns empty string if not configured or invalid type.\\n   321→func (s *EntireSettings) GetCheckpointRemote() string {\\n   322→\\tif s.StrategyOptions == nil {\\n   323→\\t\\treturn \\\"\\\"\\n   324→\\t}\\n   325→\\tval, ok := s.StrategyOptions[\\\"checkpoint_remote\\\"]\\n   326→\\tif !ok {\\n   327→\\t\\treturn \\\"\\\"\\n   328→\\t}\\n   329→\\tstr, ok := val.(string)\\n   330→\\tif !ok || str == \\\"\\\" {\\n   331→\\t\\treturn \\\"\\\"\\n   332→\\t}\\n   333→\\treturn str\\n   334→}\\n   335→\\n   336→// IsPushSessionsDisabled checks if push_sessions is disabled in settings.\\n   337→// Returns true if push_sessions is explicitly set to false.\\n   338→func (s *EntireSettings) IsPushSessionsDisabled() bool {\\n   339→\\tif s.StrategyOptions == nil {\\n   340→\\t\\treturn false\\n   341→\\t}\\n   342→\\tval, exists := s.StrategyOptions[\\\"push_sessions\\\"]\\n   343→\\tif !exists {\\n   344→\\t\\treturn false\\n   345→\\t}\\n   346→\\tif boolVal, ok := val.(bool); ok {\\n   347→\\t\\treturn !boolVal // disabled = !push_sessions\\n   348→\\t}\\n   349→\\treturn false\\n   350→}\\n   351→\\n   352→// IsExternalAgentsEnabled checks if external agent discovery is enabled in settings.\\n   353→// Returns false by default if settings cannot be loaded or the key is missing.\\n   354→func IsExternalAgentsEnabled(ctx context.Context) bool {\\n   355→\\ts, err := Load(ctx)\\n   356→\\tif err != nil {\\n   357→\\t\\treturn false\\n   358→\\t}\\n   359→\\treturn s.ExternalAgents\\n   360→}\\n   361→\\n   362→// Save saves the settings to .entire/settings.json.\\n   363→func Save(ctx context.Context, settings *EntireSettings) error {\\n   364→\\treturn saveToFile(ctx, settings, EntireSettingsFile)\\n   365→}\\n   366→\\n   367→// SaveLocal saves the settings to .entire/settings.local.json.\\n   368→func SaveLocal(ctx context.Context, settings *EntireSettings) error {\\n   369→\\treturn saveToFile(ctx, settings, EntireSettingsLocalFile)\\n   370→}\\n   371→\\n   372→// saveToFile saves settings to the specified file path.\\n   373→func saveToFile(ctx context.Context, settings *EntireSettings, filePath string) error {\\n   374→\\t// Get absolute path for the file\\n   375→\\tfilePathAbs, err := paths.AbsPath(ctx, filePath)\\n   376→\\tif err != nil {\\n   377→\\t\\tfilePathAbs = filePath // Fallback to relative\\n   378→\\t}\\n   379→\\n   380→\\t// Ensure directory exists\\n   381→\\tdir := filepath.Dir(filePathAbs)\\n   382→\\tif err := os.MkdirAll(dir, 0o750); err != nil {\\n   383→\\t\\treturn fmt.Errorf(\\\"creating settings directory: %w\\\", err)\\n   384→\\t}\\n   385→\\n   386→\\tdata, err := jsonutil.MarshalIndentWithNewline(settings, \\\"\\\", \\\"  \\\")\\n   387→\\tif err != nil {\\n   388→\\t\\treturn fmt.Errorf(\\\"marshaling settings: %w\\\", err)\\n   389→\\t}\\n   390→\\n   391→\\t//nolint:gosec // G306: settings file is config, not secrets; 0o644 is appropriate\\n   392→\\tif err := os.WriteFile(filePathAbs, data, 0o644); err != nil {\\n   393→\\t\\treturn fmt.Errorf(\\\"writing settings file: %w\\\", err)\\n   394→\\t}\\n   395→\\treturn nil\\n   396→}\\n   397→\"}]},\"uuid\":\"4d3bb6af-bf39-40ee-ba92-bba3e189d0d5\",\"timestamp\":\"2026-03-11T12:03:17.574Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/settings/settings.go\",\"content\":\"// Package settings provides configuration loading for Entire.\\n// This package is separate from cli to allow strategy package to import it\\n// without creating an import cycle (cli imports strategy).\\npackage settings\\n\\nimport (\\n\\t\\\"bytes\\\"\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n)\\n\\nconst (\\n\\t// EntireSettingsFile is the path to the Entire settings file\\n\\tEntireSettingsFile = \\\".entire/settings.json\\\"\\n\\t// EntireSettingsLocalFile is the path to the local settings override file (not committed)\\n\\tEntireSettingsLocalFile = \\\".entire/settings.local.json\\\"\\n)\\n\\n// Commit linking mode constants.\\nconst (\\n\\t// CommitLinkingAlways auto-links commits to sessions without prompting.\\n\\tCommitLinkingAlways = \\\"always\\\"\\n\\t// CommitLinkingPrompt prompts the user on each commit (default for existing users).\\n\\tCommitLinkingPrompt = \\\"prompt\\\"\\n)\\n\\n// EntireSettings represents the .entire/settings.json configuration\\ntype EntireSettings struct {\\n\\n\\t// Enabled indicates whether Entire is active. When false, CLI commands\\n\\t// show a disabled message and hooks exit silently. Defaults to true.\\n\\tEnabled bool `json:\\\"enabled\\\"`\\n\\n\\t// LocalDev indicates whether to use \\\"go run\\\" instead of the \\\"entire\\\" binary\\n\\t// This is used for development when the binary is not installed\\n\\tLocalDev bool `json:\\\"local_dev,omitempty\\\"`\\n\\n\\t// LogLevel sets the logging verbosity (debug, info, warn, error).\\n\\t// Can be overridden by ENTIRE_LOG_LEVEL environment variable.\\n\\t// Defaults to \\\"info\\\".\\n\\tLogLevel string `json:\\\"log_level,omitempty\\\"`\\n\\n\\t// StrategyOptions contains strategy-specific configuration\\n\\tStrategyOptions map[string]any `json:\\\"strategy_options,omitempty\\\"`\\n\\n\\t// AbsoluteGitHookPath embeds the full binary path in git hooks instead of\\n\\t// bare \\\"entire\\\". This is needed for GUI git clients (Xcode, Tower, etc.)\\n\\t// that don't source shell profiles and can't find \\\"entire\\\" on PATH.\\n\\tAbsoluteGitHookPath bool `json:\\\"absolute_git_hook_path,omitempty\\\"`\\n\\n\\t// Telemetry controls anonymous usage analytics.\\n\\t// nil = not asked yet (show prompt), true = opted in, false = opted out\\n\\tTelemetry *bool `json:\\\"telemetry,omitempty\\\"`\\n\\n\\t// CommitLinking controls how commits are linked to agent sessions.\\n\\t// \\\"always\\\" = auto-link without prompting, \\\"prompt\\\" = ask on each commit.\\n\\t// Defaults to \\\"prompt\\\" (preserves existing user behavior).\\n\\tCommitLinking string `json:\\\"commit_linking,omitempty\\\"`\\n\\n\\t// ExternalAgents enables discovery and registration of external agent\\n\\t// plugins (entire-agent-* binaries on $PATH). Defaults to false.\\n\\tExternalAgents bool `json:\\\"external_agents,omitempty\\\"`\\n\\n\\t// Deprecated: no longer used. Exists to tolerate old settings files\\n\\t// that still contain \\\"strategy\\\": \\\"auto-commit\\\" or similar.\\n\\tStrategy string `json:\\\"strategy,omitempty\\\"`\\n}\\n\\n// GetCommitLinking returns the effective commit linking mode.\\n// Returns the explicit value if set, otherwise defaults to \\\"prompt\\\"\\n// to preserve existing user behavior.\\nfunc (s *EntireSettings) GetCommitLinking() string {\\n\\tif s.CommitLinking != \\\"\\\" {\\n\\t\\treturn s.CommitLinking\\n\\t}\\n\\treturn CommitLinkingPrompt\\n}\\n\\n// Load loads the Entire settings from .entire/settings.json,\\n// then applies any overrides from .entire/settings.local.json if it exists.\\n// Returns default settings if neither file exists.\\n// Works correctly from any subdirectory within the repository.\\nfunc Load(ctx context.Context) (*EntireSettings, error) {\\n\\t// Get absolute paths for settings files\\n\\tsettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsFile)\\n\\tif err != nil {\\n\\t\\tsettingsFileAbs = EntireSettingsFile // Fallback to relative\\n\\t}\\n\\tlocalSettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsLocalFile)\\n\\tif err != nil {\\n\\t\\tlocalSettingsFileAbs = EntireSettingsLocalFile // Fallback to relative\\n\\t}\\n\\n\\t// Load base settings\\n\\tsettings, err := loadFromFile(settingsFileAbs)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"reading settings file: %w\\\", err)\\n\\t}\\n\\n\\t// Apply local overrides if they exist\\n\\tlocalData, err := os.ReadFile(localSettingsFileAbs) //nolint:gosec // path is from AbsPath or constant\\n\\tif err != nil {\\n\\t\\tif !os.IsNotExist(err) {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"reading local settings file: %w\\\", err)\\n\\t\\t}\\n\\t\\t// Local file doesn't exist, continue without overrides\\n\\t} else {\\n\\t\\tif err := mergeJSON(settings, localData); err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"merging local settings: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\treturn settings, nil\\n}\\n\\n// LoadFromFile loads settings from a specific file path without merging local overrides.\\n// Returns default settings if the file doesn't exist.\\n// Use this when you need to display individual settings files separately.\\nfunc LoadFromFile(filePath string) (*EntireSettings, error) {\\n\\treturn loadFromFile(filePath)\\n}\\n\\n// loadFromFile loads settings from a specific file path.\\n// Returns default settings if the file doesn't exist.\\nfunc loadFromFile(filePath string) (*EntireSettings, error) {\\n\\tsettings := &EntireSettings{\\n\\t\\tEnabled: true, // Default to enabled\\n\\t}\\n\\n\\tdata, err := os.ReadFile(filePath) //nolint:gosec // path is from caller\\n\\tif err != nil {\\n\\t\\tif os.IsNotExist(err) {\\n\\t\\t\\treturn settings, nil\\n\\t\\t}\\n\\t\\treturn nil, fmt.Errorf(\\\"%w\\\", err)\\n\\t}\\n\\n\\tdec := json.NewDecoder(bytes.NewReader(data))\\n\\tdec.DisallowUnknownFields()\\n\\tif err := dec.Decode(settings); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"parsing settings file: %w\\\", err)\\n\\t}\\n\\n\\t// Validate commit_linking if set\\n\\tif settings.CommitLinking != \\\"\\\" && settings.CommitLinking != CommitLinkingAlways && settings.CommitLinking != CommitLinkingPrompt {\\n\\t\\treturn nil, fmt.Errorf(\\\"invalid commit_linking value %q: must be %q or %q\\\", settings.CommitLinking, CommitLinkingAlways, CommitLinkingPrompt)\\n\\t}\\n\\n\\treturn settings, nil\\n}\\n\\n// mergeJSON merges JSON data into existing settings.\\n// Only non-zero values from the JSON override existing settings.\\nfunc mergeJSON(settings *EntireSettings, data []byte) error {\\n\\t// First, validate that th