  239→\\t// AgentType is the human-readable agent name (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   240→\\tAgentType types.AgentType\\n   241→}\\n   242→\\n   243→// TaskCheckpoint contains the checkpoint information written to checkpoint.json\\n   244→type TaskCheckpoint struct {\\n   245→\\tSessionID      string `json:\\\"session_id\\\"`\\n   246→\\tToolUseID      string `json:\\\"tool_use_id\\\"`\\n   247→\\tCheckpointUUID string `json:\\\"checkpoint_uuid\\\"`\\n   248→\\tAgentID        string `json:\\\"agent_id,omitempty\\\"`\\n   249→}\\n   250→\\n   251→// SubagentCheckpoint represents an intermediate checkpoint created during subagent execution.\\n   252→// These are created by PostToolUse hooks for tools like TodoWrite, Edit, Write.\\n   253→type SubagentCheckpoint struct {\\n   254→\\tType      string          `json:\\\"type\\\"`        // Tool name: \\\"TodoWrite\\\", \\\"Edit\\\", \\\"Write\\\"\\n   255→\\tToolUseID string          `json:\\\"tool_use_id\\\"` // The tool use ID that created this checkpoint\\n   256→\\tTimestamp time.Time       `json:\\\"timestamp\\\"`   // When the checkpoint was created\\n   257→\\tData      json.RawMessage `json:\\\"data\\\"`        // Type-specific payload (tool_input)\\n   258→}\\n   259→\\n   260→// TaskMetadataDir returns the path to a task's metadata directory\\n   261→// within the session metadata directory.\\n   262→func TaskMetadataDir(sessionMetadataDir, toolUseID string) string {\\n   263→\\treturn sessionMetadataDir + \\\"/tasks/\\\" + toolUseID\\n   264→}\\n   265→\\n   266→// ReadTaskCheckpoint reads the checkpoint.json file from a task metadata directory.\\n   267→// This is used during rewind to get the checkpoint UUID for transcript truncation.\\n   268→func ReadTaskCheckpoint(taskMetadataDir string) (*TaskCheckpoint, error) {\\n   269→\\tcheckpointFile := taskMetadataDir + \\\"/checkpoint.json\\\"\\n   270→\\n   271→\\tdata, err := os.ReadFile(checkpointFile) //nolint:gosec // Reading from controlle