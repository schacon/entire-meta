ssh\\\"\\n    26→\\tprotocolHTTPS = \\\"https\\\"\\n    27→)\\n    28→\\n    29→// pushSettings holds the resolved push configuration from a single settings load.\\n    30→type pushSettings struct {\\n    31→\\t// remote is the git remote name to use for pushing (the user's push remote).\\n    32→\\tremote string\\n    33→\\t// checkpointURL is the derived URL for pushing checkpoint branches.\\n    34→\\t// When set, checkpoint/trails branches are pushed directly to this URL\\n    35→\\t// instead of the remote name. Empty means use the remote name.\\n    36→\\tcheckpointURL string\\n    37→\\t// pushDisabled is true if push_sessions is explicitly set to false.\\n    38→\\tpushDisabled bool\\n    39→}\\n    40→\\n    41→// pushTarget returns the target to use for git push/fetch commands for checkpoint branches.\\n    42→// If a checkpoint URL is configured, returns that; otherwise returns the remote name.\\n    43→func (ps *pushSettings) pushTarget() string {\\n    44→\\tif ps.checkpointURL != \\\"\\\" {\\n    45→\\t\\treturn ps.checkpointURL\\n    46→\\t}\\n    47→\\treturn ps.remote\\n    48→}\\n    49→\\n    50→// hasCheckpointURL returns true if a dedicated checkpoint URL is configured.\\n    51→func (ps *pushSettings) hasCheckpointURL() bool {\\n    52→\\treturn ps.checkpointURL != \\\"\\\"\\n    53→}\\n    54→\\n    55→// resolvePushSettings loads settings once and returns the resolved push config.\\n    56→// If a structured checkpoint_remote is configured (e.g., {\\\"provider\\\": \\\"github\\\", \\\"repo\\\": \\\"org/repo\\\"}):\\n    57→//   - Derives the checkpoint URL from the push remote's protocol (SSH vs HTTPS)\\n    58→//   - Skips if the push remote owner differs from the checkpoint repo owner (fork detection)\\n    59→//   - If a checkpoint branch doesn't exist locally, attempts to fetch it from the URL\\n    60→//\\n    61→// The push itself handles failures gracefully (doPushBranch warns and continues),\\n    62→// so no reachability check is needed here.\\n    63→func resolvePushSettings(ctx context.Context, pushRemoteName string) pushSettings {\\n    64→\\ts, err := settings.Load(ctx)\\n    65→\\tif err != nil {\\n    66→\\t\\treturn pushSettings{remote: pushRemoteName}\\n    67→\\t}\\n    68→\\n    69→\\tps := pushSettings{\\n    70→\\t\\tremote:       pushRemoteName,\\n    71→\\t\\tpushDisabled: s.IsPushSessionsDisabled(),\\n    72→\\t}\\n    73→\\n    74→\\tconfig := s.GetCheckpointRemote()\\n    75→\\tif config == nil {\\n    76→\\t\\treturn ps\\n    77→\\t}\\n    78→\\n    79→\\t// Get the push remote URL for protocol detection and fork detection\\n    80→\\tpushRemoteURL, err := getRemoteURL(ctx, pushRemoteName)\\n    81→\\tif err != nil {\\n    82→\\t\\tlogging.Debug(ctx, \\\"checkpoint-remote: could not get push remote URL, skipping\\\",\\n    83→\\t\\t\\tslog.String(\\\"remote\\\", pushRemoteName),\\n    84→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    85→\\t\\t)\\n    86→\\t\\treturn ps\\n    87→\\t}\\n    88→\\n    89→\\t// Fork detection: compare owners\\n    90→\\tpushOwner := extractOwnerFromRemoteURL(pushRemoteURL)\\n    91→\\tcheckpointOwner := config.Owner()\\n    92→\\tif pushOwner != \\\"\\\" && checkpointOwner != \\\"\\\" && !strings.EqualFold(pushOwner, checkpointOwner) {\\n    93→\\t\\tlogging.Debug(ctx, \\\"checkpoint-remote: push remote owner differs from checkpoint remote owner, skipping (fork detected)\\\",\\n    94→\\t\\t\\tslog.String(\\\"push_owner\\\", pushOwner),\\n    95→\\t\\t\\tslog.String(\\\"checkpoint_owner\\\", checkpointOwner),\\n    96→\\t\\t)\\n    97→\\t\\treturn ps\\n    98→\\t}\\n    99→\\n   100→\\t// Derive checkpoint URL using same protocol as push remote\\n   101→\\tcheckpointURL, err := deriveCheckpointURL(pushRemoteURL, config)\\n   102→\\tif err != nil {\\n   103→\\t\\tlogging.Warn(ctx, \\\"checkpoint-remote: could not derive URL from push remote\\\",\\n   104→\\t\\t\\tslog.String(\\\"remote\\\", pushRemoteName),\\n   105→\\t\\t\\tslog.String(\\\"repo\\\", config.Repo),\\n   106→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   107→\\t\\t)\\n   108→\\t\\treturn ps\\n   109→\\t}\\n   110→\\n   111→\\tps.checkpointURL = checkpointURL\\n   112→\\n   113→\\t// If checkpoint branches don't exist locally, try to fetch them from the URL.\\n   114→\\t// This is a one-time operation per branch — once the branch exists locally,\\n   115→\\t// subsequent pushes skip the fetch entirely.\\n   116→\\tfor _, branchName := range []string{paths.MetadataBranchName, paths.TrailsBranchName} {\\n   117→\\t\\tif err := fetchBranchIfMissing(ctx, checkpointURL, branchName); err != nil {\\n   118→\\t\\t\\tlogging.Warn(ctx, \\\"checkpoint-remote: failed to fetch branch\\\",\\n   119→\\t\\t\\t\\tslog.String(\\\"branch\\\", branchName),\\n   120→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   121→\\t\\t\\t)\\n   122→\\t\\t}\\n   123→\\t}\\n   124→\\n   125→\\treturn ps\\n   126→}\\n   127→\\n   128→// gitRemoteInfo holds parsed components of a git remote URL.\\n   129→type gitRemoteInfo struct {\\n   130→\\tprotocol string // \\\"ssh\\\" or \\\"https\\\"\\n   131→\\thost     string // e.g., \\\"github.com\\\"\\n   132→\\towner    string // e.g., \\\"org\\\"\\n   133→\\trepo     string // e.g., \\\"my-repo\\\" (without .git)\\n   134→}\\n   135→\\n   136→// parseGitRemoteURL parses a git remote URL into its components.\\n   137→// Supports:\\n   138→//   - SSH SCP format: git@github.com:org/repo.git\\n   139→//   - HTTPS format: https://github.com/org/repo.git\\n   140→//   - SSH protocol format: ssh://git@github.com/org/repo.git\\n   141→func parseGitRemoteURL(rawURL string) (*gitRemoteInfo, error) {\\n   142→\\trawURL = strings.TrimSpace(rawURL)\\n   143→\\n   144→\\t// SSH SCP format: git@github.com:org/repo.git\\n   145→\\tif strings.Contains(rawURL, \\\":\\\") && !strings.Contains(rawURL, \\\"://\\\") {\\n   146→\\t\\t// Split on the first \\\":\\\"\\n   147→\\t\\tparts := strings.SplitN(rawURL, \\\":\\\", 2)\\n   148→\\t\\tif len(parts) != 2 {\\n   149→\\t\\t\\treturn nil, fmt.Errorf(\\\"invalid SSH URL: %s\\\", redactURL(rawURL))\\n   150→\\t\\t}\\n   151→\\t\\thostPart := parts[0] // e.g., \\\"git@github.com\\\"\\n   152→\\t\\tpathPart := parts[1] // e.g., \\\"org/repo.git\\\"\\n   153→\\n   154→\\t\\thost := hostPart\\n   155→\\t\\tif idx := strings.Index(host, \\\"@\\\"); idx >= 0 {\\n   156→\\t\\t\\thost = host[idx+1:]\\n   157→\\t\\t}\\n   158→\\n   159→\\t\\towner, repo, err := splitOwnerRepo(pathPart)\\n   160→\\t\\tif err != nil {\\n   161→\\t\\t\\treturn nil, err\\n   162→\\t\\t}\\n   163→\\n   164→\\t\\treturn &gitRemoteInfo{protocol: protocolSSH, host: host, owner: owner, repo: repo}, nil\\n   165→\\t}\\n   166→\\n   167→\\t// URL format: https://github.com/org/repo.git or ssh://git@github.com/org/repo.git\\n   168→\\tu, err := url.Parse(rawURL)\\n   169→\\tif err != nil {\\n   170→\\t\\treturn nil, fmt.Errorf(\\\"invalid URL: %s\\\", redactURL(rawURL))\\n   171→\\t}\\n   172→\\n   173→\\tprotocol := u.Scheme\\n   174→\\tif protocol == \\\"\\\" {\\n   175→\\t\\treturn nil, fmt.Errorf(\\\"no protocol in URL: %s\\\", redactURL(rawURL))\\n   176→\\t}\\n   177→\\thost := u.Hostname()\\n   178→\\n   179→\\t// Path is like /org/repo.git — trim leading slash\\n   180→\\tpathPart := strings.TrimPrefix(u.Path, \\\"/\\\")\\n   181→\\towner, repo, err := splitOwnerRepo(pathPart)\\n   182→\\tif err != nil {\\n   183→\\t\\treturn nil, err\\n   184→\\t}\\n   185→\\n   186→\\treturn &gitRemoteInfo{protocol: protocol, host: host, owner: owner, repo: repo}, nil\\n   187→}\\n   188→\\n   189→// splitOwnerRepo splits \\\"org/repo.git\\\" into owner and repo (without .git suffix).\\n   190→func splitOwnerRepo(path string) (string, string, error) {\\n   191→\\tpath = strings.TrimSuffix(path, \\\".git\\\")\\n   192→\\tparts := strings.SplitN(path, \\\"/\\\", 2)\\n   193→\\tif len(parts) != 2 || parts[0] == \\\"\\\" || parts[1] == \\\"\\\" {\\n   194→\\t\\treturn \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot parse owner/repo from path: %s\\\", path)\\n   195→\\t}\\n   196→\\treturn parts[0], parts[1], nil\\n   197→}\\n   198→\\n   199→// deriveCheckpointURL constructs a checkpoint remote URL using the same protocol\\n   200→// as the push remote. For example, if push remote uses SSH, the checkpoint URL\\n   201→// will also use SSH.\\n   202→func deriveCheckpointURL(pushRemoteURL string, config *settings.CheckpointRemoteConfig) (string, error) {\\n   203→\\tinfo, err := parseGitRemoteURL(pushRemoteURL)\\n   204→\\tif err != nil {\\n   205→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"cannot parse push remote URL: %w\\\", err)\\n   206→\\t}\\n   207→\\n   208→\\tswitch info.protocol {\\n   209→\\tcase protocolSSH:\\n   210→\\t\\t// SCP format: git@host:owner/repo.git\\n   211→\\t\\treturn fmt.Sprintf(\\\"git@%s:%s.git\\\", info.host, config.Repo), nil\\n   212→\\tcase protocolHTTPS:\\n   213→\\t\\treturn fmt.Sprintf(\\\"https://%s/%s.git\\\", info.host, config.Repo), nil\\n   214→\\tdefault:\\n   215→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"unsupported protocol %q in push remote\\\", info.protocol)\\n   216→\\t}\\n   217→}\\n   218→\\n   219→// extractOwnerFromRemoteURL extracts the owner from a git remote URL.\\n   220→// Returns empty string if the URL cannot be parsed.\\n   221→func extractOwnerFromRemoteURL(rawURL string) string {\\n   222→\\tinfo, err := parseGitRemoteURL(rawURL)\\n   223→\\tif err != nil {\\n   224→\\t\\treturn \\\"\\\"\\n   225→\\t}\\n   226→\\treturn info.owner\\n   227→}\\n   228→\\n   229→// getRemoteURL returns the URL configured for a git remote.\\n   230→func getRemoteURL(ctx context.Context, remoteName string) (string, error) {\\n   231→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"remote\\\", \\\"get-url\\\", remoteName)\\n   232→\\toutput, err := cmd.Output()\\n   233→\\tif err != nil {\\n   234→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"remote %q not found\\\", remoteName)\\n   235→\\t}\\n   236→\\treturn strings.TrimSpace(string(output)), nil\\n   237→}\\n   238→\\n   239→// redactURL removes credentials from a URL for safe logging.\\n   240→// Handles both HTTPS URLs with embedded credentials and general URLs.\\n   241→func redactURL(rawURL string) string {\\n   242→\\tu, err := url.Parse(rawURL)\\n   243→\\tif err != nil {\\n   244→\\t\\t// For non-URL formats (SSH SCP), just return the host portion\\n   245→\\t\\tif idx := strings.Index(rawURL, \\\"@\\\"); idx >= 0 {\\n   246→\\t\\t\\tif colonIdx := strings.Index(rawURL[idx:], \\\":\\\"); colonIdx >= 0 {\\n   247→\\t\\t\\t\\treturn rawURL[idx+1:idx+colonIdx] + \\\":***\\\"\\n   248→\\t\\t\\t}\\n   249→\\t\\t}\\n   250→\\t\\treturn \\\"<unparseable>\\\"\\n   251→\\t}\\n   252→\\tu.User = nil\\n   253→\\tu.RawQuery = \\\"\\\"\\n   254→\\thost := u.Host\\n   255→\\tpath := u.Path\\n   256→\\treturn u.Scheme + \\\"://\\\" + host + path\\n   257→}\\n   258→\\n   259→// fetchBranchIfMissing fetches a branch from a URL only if it doesn't exist locally.\\n   260→// This avoids network calls on every push — once the branch exists locally, this is a no-op.\\n   261→// Fetch failures are silently swallowed (returns nil): the push will handle creating the\\n   262→// branch on the remote. Only fatal errors (opening repo, creating local branch) are returned.\\n   263→func fetchBranchIfMissing(ctx context.Context, remoteURL, branchName string) error {\\n   264→\\trepo, err := OpenRepository(ctx)\\n   265→\\tif err != nil {\\n   266→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   267→\\t}\\n   268→\\n   269→\\t// Check if branch already exists locally - if so, nothing to do\\n   270→\\tbranchRef := plumbing.NewBranchReferenceName(branchName)\\n   271→\\tif _, err := repo.Reference(branchRef, true); err == nil {\\n   272→\\t\\treturn nil // Branch exists locally, skip fetch\\n   273→\\t}\\n   274→\\n   275→\\t// Branch doesn't exist locally - try to fetch it from the URL.\\n   276→\\t// Fetch to a temp ref to avoid polluting the remote-tracking namespace.\\n   277→\\tfetchCtx, cancel := context.WithTimeout(ctx, checkpointRemoteFetchTimeout)\\n   278→\\tdefer cancel()\\n   279→\\n   280→\\ttmpRef := \\\"refs/entire-fetch-tmp/\\\" + branchName\\n   281→\\trefSpec := fmt.Sprintf(\\\"+refs/heads/%s:%s\\\", branchName, tmpRef)\\n   282→\\tfetchCmd := exec.CommandContext(fetchCtx, \\\"git\\\", \\\"fetch\\\", \\\"--no-tags\\\", remoteURL, refSpec)\\n   283→\\tfetchCmd.Stdin = nil\\n   284→\\tfetchCmd.Env = append(os.Environ(),\\n   285→\\t\\t\\\"GIT_TERMINAL_PROMPT=0\\\", // Prevent interactive auth prompts\\n   286→\\t)\\n   287→\\tif err := fetchCmd.Run(); err != nil {\\n   288→\\t\\t// Fetch failed - remote may be unreachable or branch doesn't exist there yet.\\n   289→\\t\\t// Not fatal: push will create it on the remote when it succeeds.\\n   290→\\t\\treturn nil\\n   291→\\t}\\n   292→\\n   293→\\t// Fetch succeeded - create local branch from the fetched ref\\n   294→\\tfetchedRef, err := repo.Reference(plumbing.ReferenceName(tmpRef), true)\\n   295→\\tif err != nil {\\n   296→\\t\\t// Fetch succeeded but ref not found - branch may not exist on remote\\n   297→\\t\\treturn nil\\n   298→\\t}\\n   299→\\n   300→\\tnewRef := plumbing.NewHashReference(branchRef, fetchedRef.Hash())\\n   301→\\tif err := repo.Storer.SetReference(newRef); err != nil {\\n   302→\\t\\treturn fmt.Errorf(\\\"failed to create local branch from fetched ref: %w\\\", err)\\n   303→\\t}\\n   304→\\n   305→\\t// Clean up the temp ref (best-effort, not critical if it fails)\\n   306→\\t_ = repo.Storer.RemoveReference(plumbing.ReferenceName(tmpRef)) //nolint:errcheck // cleanup is best-effort\\n   307→\\n   308→\\tlogging.Info(ctx, \\\"checkpoint-remote: fetched branch from URL\\\",\\n   309→\\t\\tslog.String(\\\"branch\\\", branchName),\\n   310→\\t)\\n   311→\\treturn nil\\n   312→}\\n   313→\"}]},\"uuid\":\"aed15dfb-29b6-4a61-9e60-b0c8f4a9174d\",\"timestamp\":\"2026-03-11T22:15:54.631Z\"},\"type\":\"agent_progress\",\"p