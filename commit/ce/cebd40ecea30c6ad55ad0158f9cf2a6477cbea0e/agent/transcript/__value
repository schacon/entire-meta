failed to update branch ref: %w\\\", err)\\n   225→\\t}\\n   226→\\n   227→\\t// Clean up temp ref if we used one (best-effort, not critical if it fails)\\n   228→\\tif isURL(target) {\\n   229→\\t\\t_ = repo.Storer.RemoveReference(fetchedRefName) //nolint:errcheck // cleanup is best-effort\\n   230→\\t}\\n   231→\\n   232→\\treturn nil\\n   233→}\\n   234→\\n   235→// isURL returns true if the target looks like a URL rather than a git remote name.\\n   236→func isURL(target string) bool {\\n   237→\\treturn strings.Contains(target, \\\"://\\\") || strings.Contains(target, \\\"@\\\")\\n   238→}\\n   239→\\n   240→// PushTrailsBranch pushes the entire/trails/v1 branch to the remote.\\n   241→// Trails are always pushed regardless of the push_sessions setting.\\n   242→func PushTrailsBranch(ctx context.Context, remote string) error {\\n   243→\\treturn pushBranchIfNeeded(ctx, remote, paths.TrailsBranchName)\\n   244→}\\n   245→\\n   246→// createMergeCommitCommon creates a merge commit with multiple parents.\\n   247→func createMergeCommitCommon(repo *git.Repository, treeHash plumbing.Hash, parents []plumbing.Hash, message string) (plumbing.Hash, error) {\\n   248→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   249→\\tnow := time.Now()\\n   250→\\tsig := object.Signature{\\n   251→\\t\\tName:  authorName,\\n   252→\\t\\tEmail: authorEmail,\\n   253→\\t\\tWhen:  now,\\n   254→\\t}\\n   255→\\n   256→\\tcommit := &object.Commit{\\n   257→\\t\\tTreeHash:     treeHash,\\n   258→\\t\\tParentHashes: parents,\\n   259→\\t\\tAuthor:       sig,\\n   260→\\t\\tCommitter:    sig,\\n   261→\\t\\tMessage:      message,\\n   262→\\t}\\n   263→\\n   264→\\tobj := repo.Storer.NewEncodedObject()\\n   265→\\tif err := commit.Encode(obj); err != nil {\\n   266→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n   267→\\t}\\n   268→\\n   269→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n   270→\\tif err != nil {\\n   271→\\t\\tretur