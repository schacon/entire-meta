SettingsFile is the path to the Entire settings file\\n    21→\\tEntireSettingsFile = \\\".entire/settings.json\\\"\\n    22→\\t// EntireSettingsLocalFile is the path to the local settings override file (not committed)\\n    23→\\tEntireSettingsLocalFile = \\\".entire/settings.local.json\\\"\\n    24→)\\n    25→\\n    26→// Commit linking mode constants.\\n    27→const (\\n    28→\\t// CommitLinkingAlways auto-links commits to sessions without prompting.\\n    29→\\tCommitLinkingAlways = \\\"always\\\"\\n    30→\\t// CommitLinkingPrompt prompts the user on each commit (default for existing users).\\n    31→\\tCommitLinkingPrompt = \\\"prompt\\\"\\n    32→)\\n    33→\\n    34→// EntireSettings represents the .entire/settings.json configuration\\n    35→type EntireSettings struct {\\n    36→\\n    37→\\t// Enabled indicates whether Entire is active. When false, CLI commands\\n    38→\\t// show a disabled message and hooks exit silently. Defaults to true.\\n    39→\\tEnabled bool `json:\\\"enabled\\\"`\\n    40→\\n    41→\\t// LocalDev indicates whether to use \\\"go run\\\" instead of the \\\"entire\\\" binary\\n    42→\\t// This is used for development when the binary is not installed\\n    43→\\tLocalDev bool `json:\\\"local_dev,omitempty\\\"`\\n    44→\\n    45→\\t// LogLevel sets the logging verbosity (debug, info, warn, error).\\n    46→\\t// Can be overridden by ENTIRE_LOG_LEVEL environment variable.\\n    47→\\t// Defaults to \\\"info\\\".\\n    48→\\tLogLevel string `json:\\\"log_level,omitempty\\\"`\\n    49→\\n    50→\\t// StrategyOptions contains strategy-specific configuration\\n    51→\\tStrategyOptions map[string]any `json:\\\"strategy_options,omitempty\\\"`\\n    52→\\n    53→\\t// AbsoluteGitHookPath embeds the full binary path in git hooks instead of\\n    54→\\t// bare \\\"entire\\\". This is needed for GUI git clients (Xcode, Tower, etc.)\\n    55→\\t// that don't source shell profiles and can't find \\\"entire\\\" on PATH.\\n    56→\\tAbsoluteGitHookPath bool `json:\\\"absolute_git_hook_path,omitempty\\\"`\\n    57→\\n    58→\\t// Telemetry controls anonymous usage analytics.\\n    59→\\t// nil = not asked yet (show prompt), true = opted in, false = opted out\\n    60→\\tTelemetry *bool `json:\\\"telemetry,omitempty\\\"`\\n    61→\\n    62→\\t// CommitLinking controls how commits are linked to agent sessions.\\n    63→\\t// \\\"always\\\" = auto-link without prompting, \\\"prompt\\\" = ask on each commit.\\n    64→\\t// Defaults to \\\"prompt\\\" (preserves existing user behavior).\\n    65→\\tCommitLinking string `json:\\\"commit_linking,omitempty\\\"`\\n    66→\\n    67→\\t// ExternalAgents enables discovery and registration of external agent\\n    68→\\t// plugins (entire-agent-* binaries on $PATH). Defaults to false.\\n    69→\\tExternalAgents bool `json:\\\"external_agents,omitempty\\\"`\\n    70→\\n    71→\\t// Deprecated: no longer used. Exists to tolerate old settings files\\n    72→\\t// that still contain \\\"strategy\\\": \\\"auto-commit\\\" or similar.\\n    73→\\tStrategy string `json:\\\"strategy,omitempty\\\"`\\n    74→}\\n    75→\\n    76→// GetCommitLinking returns the effective commit linking mode.\\n    77→// Returns the explicit value if set, otherwise defaults to \\\"prompt\\\"\\n    78→// to preserve existing user behavior.\\n    79→func (s *EntireSettings) GetCommitLinking() string {\\n    80→\\tif s.CommitLinking != \\\"\\\" {\\n    81→\\t\\treturn s.CommitLinking\\n    82→\\t}\\n    83→\\treturn CommitLinkingPrompt\\n    84→}\\n    85→\\n    86→// Load loads the Entire settings from .entire/settings.json,\\n    87→// then applies any overrides from .entire/settings.local.json if it exists.\\n    88→// Returns default settings if neither file exists.\\n    89→// Works correctly from any subdirectory within the repository.\\n    90→func Load(ctx context.Context) (*EntireSettings, error) {\\n    91→\\t// Get absolute paths for settings files\\n    92→\\tsettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsFile)\\n    93→\\tif err != nil {\\n    94→\\t\\tsettingsFileAbs = EntireSettingsFile // Fallback to relative\\n    95→\\t}\\n    96→\\tlocalSettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsLocalFile)\\n    97→\\tif err != nil {\\n    98→\\t\\tlocalSettingsFileAbs = EntireSettingsLocalFile // Fallback to relative\\n    99→\\t}\\n   100→\\n   101→\\t// Load base settings\\n   102→\\tsettings, err := loadFromFile(settingsFileAbs)\\n   103→\\tif err != nil {\\n   104→\\t\\treturn nil, fmt.Errorf(\\\"reading settings file: %w\\\", err)\\n   105→\\t}\\n   106→\\n   107→\\t// Apply local overrides if they exist\\n   108→\\tlocalData, err := os.ReadFile(localSettingsFileAbs) //nolint:gosec // path is from AbsPath or constant\\n   109→\\tif err != nil {\\n   110→\\t\\tif !os.IsNotExist(err) {\\n   111→\\t\\t\\treturn nil, fmt.Errorf(\\\"reading local settings file: %w\\\", err)\\n   112→\\t\\t}\\n   113→\\t\\t// Local file doesn't exist, continue without overrides\\n   114→\\t} else {\\n   115→\\t\\tif err := mergeJSON(settings, localData); err != nil {\\n   116→\\t\\t\\treturn nil, fmt.Errorf(\\\"merging local settings: %w\\\", err)\\n   117→\\t\\t}\\n   118→\\t}\\n   119→\\n   120→\\treturn settings, nil\\n   121→}\\n   122→\\n   123→// LoadFromFile loads settings from a specific file path without merging local overrides.\\n   124→// Returns default settings if the file doesn't exist.\\n   125→// Use this when you need to display individual settings files separately.\\n   126→func LoadFromFile(filePath string) (*EntireSettings, error) {\\n   127→\\treturn loadFromFile(filePath)\\n   128→}\\n   129→\\n   130→// loadFromFile loads settings from a specific file path.\\n   131→// Returns default settings if the file doesn't exist.\\n   132→func loadFromFile(filePath string) (*EntireSettings, error) {\\n   133→\\tsettings := &EntireSettings{\\n   134→\\t\\tEnabled: true, // Default to enabled\\n   135→\\t}\\n   136→\\n   137→\\tdata, err := os.ReadFile(filePath) //nolint:gosec // path is from caller\\n   138→\\tif err != nil {\\n   139→\\t\\tif os.IsNotExist(err) {\\n   140→\\t\\t\\treturn settings, nil\\n   141→\\t\\t}\\n   142→\\t\\treturn nil, fmt.Errorf(\\\"%w\\\", err)\\n   143→\\t}\\n   144→\\n   145→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   146→\\tdec.DisallowUnknownFields()\\n   147→\\tif err := dec.Decode(settings); err != nil {\\n   148→\\t\\treturn nil, fmt.Errorf(\\\"parsing settings file: %w\\\", err)\\n   149→\\t}\\n   150→\\n   151→\\t// Validate commit_linking if set\\n   152→\\tif settings.CommitLinking != \\\"\\\" && settings.CommitLinking != CommitLinkingAlways && settings.CommitLinking != CommitLinkingPrompt {\\n   153→\\t\\treturn nil, fmt.Errorf(\\\"invalid commit_linking value %q: must be %q or %q\\\", settings.CommitLinking, CommitLinkingAlways, CommitLinkingPrompt)\\n   154→\\t}\\n   155→\\n   156→\\treturn settings, nil\\n   157→}\\n   158→\\n   159→// mergeJSON merges JSON data into existing settings.\\n   160→// Only non-zero values from the JSON override existing settings.\\n   161→func mergeJSON(settings *EntireSettings, data []byte) error {\\n   162→\\t// First, validate that there are no unknown keys using strict decoding\\n   163→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   164→\\tdec.DisallowUnknownFields()\\n   165→\\tvar temp EntireSettings\\n   166→\\tif err := dec.Decode(&temp); err != nil {\\n   167→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   168→\\t}\\n   169→\\n   170→\\t// Parse into a map to check which fields are present\\n   171→\\tvar raw map[string]json.RawMessage\\n   172→\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   173→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   174→\\t}\\n   175→\\n   176→\\t// Override enabled if present\\n   177→\\tif enabledRaw, ok := raw[\\\"enabled\\\"]; ok {\\n   178→\\t\\tvar e bool\\n   179→\\t\\tif err := json.Unmarshal(enabledRaw, &e); err != nil {\\n   180→\\t\\t\\treturn fmt.Errorf(\\\"parsing enabled field: %w\\\", err)\\n   181→\\t\\t}\\n   182→\\t\\tsettings.Enabled = e\\n   183→\\t}\\n   184→\\n   185→\\t// Override local_dev if present\\n   186→\\tif localDevRaw, ok := raw[\\\"local_dev\\\"]; ok {\\n   187→\\t\\tvar ld bool\\n   188→\\t\\tif err := json.Unmarshal(localDevRaw, &ld); err != nil {\\n   189→\\t\\t\\treturn fmt.Errorf(\\\"parsing local_dev field: %w\\\", err)\\n   190→\\t\\t}\\n   191→\\t\\tsettings.LocalDev = ld\\n   192→\\t}\\n   193→\\n   194→\\t// Override absolute_git_hook_path if present\\n   195→\\tif ahpRaw, ok := raw[\\\"absolute_git_hook_path\\\"]; ok {\\n   196→\\t\\tvar ahp bool\\n   197→\\t\\tif err := json.Unmarshal(ahpRaw, &ahp); err != nil {\\n   198→\\t\\t\\treturn fmt.Errorf(\\\"parsing absolute_git_hook_path field: %w\\\", err)\\n   199→\\t\\t}\\n   200→\\t\\tsettings.AbsoluteGitHookPath = ahp\\n   201→\\t}\\n   202→\\n   203→\\t// Override log_level if present and non-empty\\n   204→\\tif logLevelRaw, ok := raw[\\\"log_level\\\"]; ok {\\n   205→\\t\\tvar ll string\\n   206→\\t\\tif err := json.Unmarshal(logLevelRaw, &ll); err != nil {\\n   207→\\t\\t\\treturn fmt.Errorf(\\\"parsing log_level field: %w\\\", err)\\n   208→\\t\\t}\\n   209→\\t\\tif ll != \\\"\\\" {\\n   210→\\t\\t\\tsettings.LogLevel = ll\\n   211→\\t\\t}\\n   212→\\t}\\n   213→\\n   214→\\t// Merge strategy_options if present\\n   215→\\tif optionsRaw, ok := raw[\\\"strategy_options\\\"]; ok {\\n   216→\\t\\tvar opts map[string]any\\n   217→\\t\\tif err := json.Unmarshal(optionsRaw, &opts); err != nil {\\n   218→\\t\\t\\treturn fmt.Errorf(\\\"parsing strategy_options field: %w\\\", err)\\n   219→\\t\\t}\\n   220→\\t\\tif settings.StrategyOptions == nil {\\n   221→\\t\\t\\tsettings.StrategyOptions = opts\\n   222→\\t\\t} else {\\n   223→\\t\\t\\tfor k, v := range opts {\\n   224→\\t\\t\\t\\tsettings.StrategyOptions[k] = v\\n   225→\\t\\t\\t}\\n   226→\\t\\t}\\n   227→\\t}\\n   228→\\n   229→\\t// Override telemetry if presen