tialize git repo with test user config\\ntestutil.WriteFile(t, tmpDir, \\\"f.txt\\\", \\\"init\\\")  // Create files\\ntestutil.GitAdd(t, tmpDir, \\\"f.txt\\\")    // Stage files\\ntestutil.GitCommit(t, tmpDir, \\\"init\\\")  // Commit with test user\\nt.Chdir(tmpDir)                        // Change to repo directory\\n```\\n\\n**What `testutil.InitRepo` does:**\\n- Initializes a git repo using `go-git/v6`\\n- Sets git user config: `user.name = \\\"Test User\\\"`, `user.email = \\\"test@example.com\\\"`\\n- Disables GPG signing: `commit.gpgsign = false`\\n- Prevents test git config from interfering with system config\\n\\n**Environment isolation:**\\n- Use `testutil.GitIsolatedEnv()` when running git CLI commands via `exec.Command`\\n- This filters out `GIT_CONFIG_GLOBAL` and `GIT_CONFIG_SYSTEM`, sets them to `/dev/null`\\n\\n### 2. **Setting Up Remote Repositories**\\n\\nFrom `checkpoint_remote_test.go`:\\n\\n```go\\nctx := context.Background()\\n\\n// Create \\\"remote\\\" repo\\nremoteDir := t.TempDir()\\ntestutil.InitRepo(t, remoteDir)\\ntestutil.WriteFile(t, remoteDir, \\\"f.txt\\\", \\\"init\\\")\\ntestutil.GitAdd(t, remoteDir, \\\"f.txt\\\")\\ntestutil.GitCommit(t, remoteDir, \\\"init\\\")\\n\\n// Add git remote using CLI\\ncmd := exec.CommandContext(ctx, \\\"git\\\", \\\"remote\\\", \\\"add\\\", \\\"origin\\\", \\\"https://github.com/org/main-repo.git\\\")\\ncmd.Dir = localDir\\ncmd.Env = testutil.GitIsolatedEnv()\\nrequire.NoError(t, cmd.Run())\\n\\n// Fetch from remote\\nrequire.NoError(t, fetchBranchIfMissing(ctx, remoteDir, \\\"entire/checkpoints/v1\\\"))\\n```\\n\\n### 3. **Creating Branches**\\n\\n**Orphan branches (for metadata branches):**\\n```go\\nctx := context.Background()\\n\\n// Create orphan branch\\ncmd := exec.CommandContext(ctx, \\\"git\\\", \\\"checkout\\\", \\\"--orphan\\\", \\\"entire/checkpoints/v1\\\")\\ncmd.Dir = remoteDir\\ncmd.Env = testutil.GitIsolatedEnv()\\nrequire.NoError(t, cmd.Run())\\n\\n// Clean existing files\\ncmd = exec.