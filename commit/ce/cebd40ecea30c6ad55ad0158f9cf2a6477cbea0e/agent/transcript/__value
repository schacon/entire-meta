", \\\"git@host & echo\\\", true},\\n    35→\\t\\t{\\\"dollar\\\", \\\"git@host/$HOME\\\", true},\\n    36→\\t\\t{\\\"backtick\\\", \\\"git@host/`whoami`\\\", true},\\n    37→\\t\\t{\\\"backslash\\\", \\\"git@host\\\\\\\\path\\\", true},\\n    38→\\t}\\n    39→\\n    40→\\tfor _, tt := range tests {\\n    41→\\t\\tt.Run(tt.name, func(t *testing.T) {\\n    42→\\t\\t\\tt.Parallel()\\n    43→\\t\\t\\terr := validateRemoteURL(tt.url)\\n    44→\\t\\t\\tif tt.wantErr {\\n    45→\\t\\t\\t\\tassert.Error(t, err)\\n    46→\\t\\t\\t} else {\\n    47→\\t\\t\\t\\tassert.NoError(t, err)\\n    48→\\t\\t\\t}\\n    49→\\t\\t})\\n    50→\\t}\\n    51→}\\n    52→\\n    53→// Not parallel: uses t.Chdir()\\n    54→func TestEnsureGitRemote_CreatesNew(t *testing.T) {\\n    55→\\ttmpDir := t.TempDir()\\n    56→\\ttestutil.InitRepo(t, tmpDir)\\n    57→\\ttestutil.WriteFile(t, tmpDir, \\\"f.txt\\\", \\\"init\\\")\\n    58→\\ttestutil.GitAdd(t, tmpDir, \\\"f.txt\\\")\\n    59→\\ttestutil.GitCommit(t, tmpDir, \\\"init\\\")\\n    60→\\tt.Chdir(tmpDir)\\n    61→\\n    62→\\tctx := t.Context()\\n    63→\\terr := ensureGitRemote(ctx, \\\"test-remote\\\", \\\"https://example.com/repo.git\\\")\\n    64→\\trequire.NoError(t, err)\\n    65→\\n    66→\\t// Verify the remote was created\\n    67→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"remote\\\", \\\"get-url\\\", \\\"test-remote\\\")\\n    68→\\tcmd.Dir = tmpDir\\n    69→\\toutput, err := cmd.Output()\\n    70→\\trequire.NoError(t, err)\\n    71→\\tassert.Contains(t, string(output), \\\"https://example.com/repo.git\\\")\\n    72→}\\n    73→\\n    74→// Not parallel: uses t.Chdir()\\n    75→func TestEnsureGitRemote_UpdatesExisting(t *testing.T) {\\n    76→\\ttmpDir := t.TempDir()\\n    77→\\ttestutil.InitRepo(t, tmpDir)\\n    78→\\ttestutil.WriteFile(t, tmpDir, \\\"f.txt\\\", \\\"init\\\")\\n    79→\\ttestutil.GitAdd(t, tmpDir, \\\"f.txt\\\")\\n    80→\\ttestutil.GitCommit(t, tmpDir, \\\"init\\\")\\n    81→\\tt.Chdir(tmpDir)\\n    82→\\n    