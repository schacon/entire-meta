\t\\\"github.com/spf13/cobra\\\"\\n    22→\\t\\\"github.com/spf13/pflag\\\"\\n    23→)\\n    24→\\n    25→// Config path display strings\\n    26→const (\\n    27→\\tconfigDisplayProject = \\\".entire/settings.json\\\"\\n    28→\\tconfigDisplayLocal   = \\\".entire/settings.local.json\\\"\\n    29→)\\n    30→\\n    31→// EnableOptions holds the flags for `entire enable`.\\n    32→type EnableOptions struct {\\n    33→\\tLocalDev            bool\\n    34→\\tUseLocalSettings    bool\\n    35→\\tUseProjectSettings  bool\\n    36→\\tForceHooks          bool\\n    37→\\tSkipPushSessions    bool\\n    38→\\tCheckpointRemote    string\\n    39→\\tTelemetry           bool\\n    40→\\tAbsoluteGitHookPath bool\\n    41→}\\n    42→\\n    43→// applyStrategyOptions sets strategy_options on settings from CLI flags.\\n    44→func (opts *EnableOptions) applyStrategyOptions(settings *EntireSettings) {\\n    45→\\tif opts.SkipPushSessions {\\n    46→\\t\\tif settings.StrategyOptions == nil {\\n    47→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n    48→\\t\\t}\\n    49→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n    50→\\t}\\n    51→\\tif opts.CheckpointRemote != \\\"\\\" {\\n    52→\\t\\tprovider, repo, err := parseCheckpointRemoteFlag(opts.CheckpointRemote)\\n    53→\\t\\tif err != nil {\\n    54→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: invalid --checkpoint-remote format: %v\\\\n\\\", err)\\n    55→\\t\\t} else {\\n    56→\\t\\t\\tif settings.StrategyOptions == nil {\\n    57→\\t\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n    58→\\t\\t\\t}\\n    59→\\t\\t\\tsettings.StrategyOptions[\\\"checkpoint_remote\\\"] = map[string]any{\\n    60→\\t\\t\\t\\t\\\"provider\\\": provider,\\n    61→\\t\\t\\t\\t\\\"repo\\\":     repo,\\n    62→\\t\\t\\t}\\n    63→\\t\\t}\\n    64→\\t}\\n    65→}\\n    66→\\n    67→// parseCheckpointRemoteFlag parses a \\\"provider:owner/repo\\\" string into its components.\\n    68→// Supported providers: \\\"github\\\".\\n    69→func parseCheckpointRemoteFlag(value string) (provider, repo string, err error) {\\n    70→\\tparts := strings.SplitN(value, \\\":\\\", 2)\\n    71→\\tif len(parts) != 2 || parts[0] == \\\"\\\" || parts[1] == \\\"\\\" {\\n    72→\\t\\treturn \\\"\\\", \\\"\\\", fmt.Errorf(\\\"expected format provider:owner/repo (e.g., github:org/checkpoints-repo), got %q\\\", value)\\n    73→\\t}\\n    74→\\n    75→\\tprovider = parts[0]\\n    76→\\trepo = parts[1]\\n    77→\\n    78→\\tswitch provider {\\n    79→\\tcase \\\"github\\\":\\n    80→\\t\\t// valid\\n    81→\\tdefault:\\n    82→\\t\\treturn \\\"\\\", \\\"\\\", fmt.Errorf(\\\"unsupported provider %q (supported: github)\\\", provider)\\n    83→\\t}\\n    84→\\n    85→\\trepoParts := strings.SplitN(repo, \\\"/\\\", 2)\\n    86→\\tif len(repoParts) != 2 || repoParts[0] == \\\"\\\" || repoParts[1] == \\\"\\\" {\\n    87→\\t\\treturn \\\"\\\", \\\"\\\", fmt.Errorf(\\\"repo must be in owner/name format, got %q\\\", repo)\\n    88→\\t}\\n    89→\\n    90→\\treturn provider, repo, nil\\n    91→}\\n    92→\\n    93→func newEnableCmd() *cobra.Command {\\n    94→\\tvar opts EnableOptions\\n    95→\\tvar ignoreUntracked bool\\n    96→\\tvar agentName string\\n    97→\\n    98→\\tcmd := &cobra.Command{\\n    99→\\t\\tUse:   \\\"enable\\\",\\n   100→\\t\\tShort: \\\"Enable Entire in current project\\\",\\n   101→\\t\\tLong: `Enable Entire with session tracking for your AI agent workflows.\\n   102→\\n   103→Uses the manual-commit strategy, which creates session checkpoints without\\n   104→modifying your active branch.`,\\n   105→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   106→\\t\\t\\tctx := cmd.Context()\\n   107→\\t\\t\\t// Check if we're in a git repository first - this is a prerequisite error,\\n   108→\\t\\t\\t// not a usage error, so we silence Cobra's output and use SilentError\\n   109→\\t\\t\\t// to prevent duplicate error output in main.go\\n   110→\\t\\t\\tif _, err := paths.WorktreeRoot(ctx); err != nil {\\n   111→\\t\\t\\t\\tfmt.Fprintln(cmd.ErrOrStderr(), \\\"Not a git repository. Please run 'entire enable' from within a git repository.\\\")\\n   112→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n   113→\\t\\t\\t}\\n   114→\\n   115→\\t\\t\\tif err := validateSetupFlags(opts.UseLocalSettings, opts.UseProjectSettings); err != nil {\\n   116→\\t\\t\\t\\treturn err\\n   117→\\t\\t\\t}\\n   118→\\n   119→\\t\\t\\t// Discover external agent plugins so they appear in agent selection.\\n   120→\\t\\t\\texternal.DiscoverAndRegister(ctx)\\n   121→\\n   122→\\t\\t\\t// Warn if repo has no commits yet\\n   123→\\t\\t\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n   124→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Note: This repository has no commits yet. Entire will be configured, but\\\")\\n   125→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"session checkpoints won't work until you create your first commit.\\\")\\n   126→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout())\\n   127→\\t\\t\\t}\\n   128→\\n   129→\\t\\t\\t// Non-interactive mode if --agent flag is provided\\n   130→\\t\\t\\tif cmd.Flags().Changed(\\\"agent\\\") && agentName == \\\"\\\" {\\n   131→\\t\\t\\t\\tprintMissingAgentError(cmd.ErrOrStderr())\\n   132→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n   133→\\t\\t\\t}\\n   134→\\n   135→\\t\\t\\tif agentName != \\\"\\\" {\\n   136→\\t\\t\\t\\tag, err := agent.Get(types.AgentName(agentName))\\n   137→\\t\\t\\t\\tif err != nil {\\n   138→\\t\\t\\t\\t\\tprintWrongAgentError(cmd.ErrOrStderr(), agentName)\\n   139→\\t\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"wrong agent name\\\"))\\n   140→\\t\\t\\t\\t}\\n   141→\\t\\t\\t\\t// --agent is a targeted operation: set up this specific agent without\\n   142→\\t\\t\\t\\t// affecting other agents. Unlike the interactive path, it does not\\n   143→\\t\\t\\t\\t// uninstall hooks for other previously-enabled agents.\\n   144→\\t\\t\\t\\treturn setupAgentHooksNonInteractive(ctx, cmd.OutOrStdout(), ag, opts)\\n   145→\\t\\t\\t}\\n   146→\\t\\t\\t// Detect or prompt for agents\\n   147→\\t\\t\\tagents, err := detectOrSelectAgent(ctx, cmd.OutOrStdout(), nil)\\n   148→\\t\\t\\tif err != nil {\\n   149→\\t\\t\\t\\treturn fmt.Errorf(\\\"agent selection failed: %w\\\", err)\\n   150→\\t\\t\\t}\\n   151→\\n   152→\\t\\t\\treturn runEnableInteractive(ctx, cmd.OutOrStdout(), agents, opts)\\n   153→\\t\\t},\\n   154→\\t}\\n   155→\\n   156→\\tcmd.Flags().BoolVar(&opts.LocalDev, \\\"local-dev\\\", false, \\\"Use go run instead of entire binary for hooks\\\")\\n   157→\\tcmd.Flags().MarkHidden(\\\"local-dev\\\") //nolint:errcheck,gosec // flag is defined above\\n   158→\\tcmd.Flags().BoolVar(&ignoreUntracked, \\\"ignore-untracked\\\", false, \\\"Commit all new files without tracking pre-existing untracked files\\\")\\n   159→\\tcmd.Flags().MarkHidden(\\\"ignore-untracked\\\") //nolint:errcheck,gosec // flag is defined above\\n   160→\\tcmd.Flags().BoolVar(&opts.UseLocalSettings, \\\"local\\\", false, \\\"Write settings to .entire/settings.local.json instead of .entire/settings.json\\\")\\n   161→\\tcmd.Flags().BoolVar(&opts.UseProjectSettings, \\\"project\\\", false, \\\"Write settings to .entire/settings.json even if it already exists\\\")\\n   162→\\tcmd.Flags().StringVar(&agentName, \\\"agent\\\", \\\"\\\", \\\"Agent to set up hooks for (e.g., \\\"+strings.Join(agent.StringList(), \\\", \\\")+\\\"). Enables non-interactive mode.\\\")\\n   163→\\tcmd.Flags().BoolVarP(&opts.ForceHooks, \\\"force\\\", \\\"f\\\", false, \\\"Force reinstall hooks (removes existing Entire hooks first)\\\")\\n   164→\\tcmd.Flags().BoolVar(&opts.SkipPushSessions, \\\"skip-push-sessions\\\", false, \\\"Disable automatic pushing of session logs on git push\\\")\\n   165→\\tcmd.Flags().StringVar(&opts.CheckpointRemote, \\\"checkpoint-remote\\\", \\\"\\\", \\\"Checkpoint remote in provider:owner/repo format (e.g., github:org/checkpoints-repo)\\\")\\n   166→\\tcmd.Flags().BoolVar(&opts.Telemetry, \\\"telemetry\\\", true, \\\"Enable anonymous usage analytics\\\")\\n   167→\\tcmd.Flags().BoolVar(&opts.AbsoluteGitHookPath, \\\"absolute-git-hook-path\\\", false, \\\"Embed full binary path in git hooks (for GUI git clients that don't source shell profiles)\\\")\\n   168→\\n   169→\\t// Provide a helpful error when --agent is used without a value\\n   170→\\tdefaultFlagErr := cmd.FlagErrorFunc()\\n   171→\\tcmd.SetFlagErrorFunc(func(c *cobra.Command, err error) error {\\n   172→\\t\\tvar valErr *pflag.ValueRequiredError\\n   173→\\t\\tif errors.As(err, &valErr) && valErr.GetSpecifiedName() == \\\"agent\\\" {\\n   174→\\t\\t\\tprintMissingAgentError(c.ErrOrStderr())\\n   175→\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n   176→\\t\\t}\\n   177→\\t\\treturn defaultFlagErr(c, err)\\n   178→\\t})\\n   179→\\n   180→\\t// Add subcommands for automation/testing\\n   181→\\tcmd.AddCommand(newSetupGitHookCmd())\\n   182→\\n   183→\\treturn cmd\\n   184→}\\n   185→\\n   186→func newDisableCmd() *cobra.Command {\\n   187→\\tvar useProjectSettings bool\\n   188→\\tvar uninstall bool\\n   189→\\tvar force bool\\n   190→\\n   191→\\tcmd := &cobra.Command{\\n   192→\\t\\tUse:   \\\"disable\\\",\\n   193→\\t\\tShort: \\\"Disable Entire in current project\\\",\\n   194→\\t\\tLong: `Disable Entire integrations in the current project.\\n   195→\\n   196→By default, this command will disable Entire. Hooks will exit silently and commands will\\n   197→show a disabled message.\\n   198→\\n   199→To completely remove Entire integrations from this repository, use --uninstall:\\n   200→  - .entire/ directory (settings, logs, metadata)\\n   201→  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\n   202→  - Session state files (.git/entire-sessions/)\\n   203→  - Shadow branches (entire/<hash>)\\n   204→  - Agent hooks`,\\n   205→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   206→\\t\\t\\tctx := cmd.Context()\\n   207→\\t\\t\\tif uninstall {\\n   208→\\t\\t\\t\\treturn runUninstall(ctx, cmd.OutOrStdout(), cmd.ErrOrStderr(), force)\\n   209→\\t\\t\\t}\\n   210→\\t\\t\\treturn runDisable(ctx, cmd.OutOrStdout(), useProjectSettings)\\n   211→\\t\\t},\\n   212→\\t}\\n   213→\\n   214→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Update .entire/settings.json instead of .entire/settings.local.json\\\")\\n   215→\\tcmd.Flags().BoolVar(&uninstall, \\\"uninstall\\\", false, \\\"Completely remove Entire from this repository\\\")\\n   216→\\tcmd.Flags().BoolVar(&force, \\\"force\\\", false, \\\"Skip confirmation prompt (use with --uninstall)\\\")\\n   217→\\n   218→\\treturn cmd\\n   219→}\\n   220→\\n   221→// runEnableInteractive runs the interactive enable flow.\\n   222→// agents must be provided by the caller (via detectOrSelectAgent).\\n   223→func runEnableInteractive(ctx context.Context, w io.Writer, agents []agent.Agent, opts EnableOptions) error {\\n   224→\\t// Uninstall hooks for agents that were previously active but are no longer selected\\n   225→\\tif err := uninstallDeselectedAgentHooks(ctx, w, agents); err != nil {\\n   226→\\t\\treturn fmt.Errorf(\\\"failed to clean up deselected agents: %w\\\", err)\\n   227→\\t}\\n   228→\\n   229→\\t// Setup agent hooks for all selected agents\\n   230→\\tfor _, ag := range agents {\\n   231→\\t\\tif _, err := setupAgentHooks(ctx, ag, opts.LocalDev, opts.ForceHooks); err != nil {\\n   232→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   233→\\t\\t}\\n   234→\\t}\\n   235→\\n   236→\\t// Setup .entire directory\\n   237→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   238→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   239→\\t}\\n   240→\\n   241→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   242→\\tsettings, err := LoadEntireSettings(ctx)\\n   243→\\tif err != nil {\\n   244→\\t\\t// If we can't load, start with defaults\\n   245→\\t\\tsettings = &EntireSettings{}\\n   246→\\t}\\n   247→\\t// Update the specific fields\\n   248→\\tsettings.Enabled = true\\n   249→\\tif opts.LocalDev {\\n   250→\\t\\tsettings.LocalDev = true\\n   251→\\t}\\n   252→\\tif opts.AbsoluteGitHookPath {\\n   253→\\t\\tsettings.AbsoluteGitHookPath = true\\n   254→\\t}\\n   255→\\n   256→\\topts.applyStrategyOptions(settings)\\n   257→\\n   258→\\t// Determine which settings file to write to\\n   259→\\t// First run always creates settings.json (no prompt)\\n   260→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   261→\\tif err != nil {\\n   262→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   263→\\t}\\n   264→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, opts.UseLocalSettings, opts.UseProjectSettings)\\n   265→\\n   266→\\tif showNotification {\\n   267→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   268→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   269→\\t}\\n   270→\\n   271→\\t// Save settings to the appropriate file.\\n   272→\\tsaveSettings := func() error {\\n   273→\\t\\tif shouldUseLocal {\\n   274→\\t\\t\\treturn SaveEntireSettingsLocal(ctx, settings)\\n   275→\\t\\t}\\n   276→\\t\\treturn SaveEntireSettings(ctx, settings)\\n   277→\\t}\\n   278→\\tif err := saveSettings(); err != nil {\\n   279→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   280→\\t}\\n   281→\\n   282→\\t// Use settings values (merged from existing config + flags) for hook installation\\n   283→\\t// This ensures re-running `entire enable` without flags preserves existing settings\\n   284→\\tif _, err := strategy.InstallGitHook(ctx, true, settings.LocalDev, settings.AbsoluteGitHookPath); err != nil {\\n   285→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   286→\\t}\\n   287→\\tstrategy.CheckAndWarnHookManagers(ctx, w, settings.LocalDev, settings.AbsoluteGitHookPath)\\n   288→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   289→\\n   290→\\tconfigDisplay := configDisplayProject\\n   291→\\tif shouldUseLocal {\\n   292→\\t\\tconfigDisplay = configDisplayLocal\\n   293→\\t}\\n   294→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   295→\\n   296→\\t// Ask about telemetry consent (only if not already asked)\\n   297→\\tfmt.Fprintln(w)\\n   298→\\tif err := promptTelemetryConsent(settings, opts.Telemetry); err != nil {\\n   299→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   300→\\t}\\n   301→\\t// Save again to persist telemetry choice\\n   302→\\tif err := saveSettings(); err != nil {\\n   303→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   304→\\t}\\n   305→\\n   306→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   307→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   308→\\t}\\n   309→\\n   310→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   311→\\n   312→\\treturn nil\\n   313→}\\n   314→\\n   315→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   316→func runEnable(ctx context.Context, w io.Writer) error {\\n   317→\\tsettings, err := LoadEntireSettings(ctx)\\n   318→\\tif err != nil {\\n   319→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   320→\\t}\\n   321→\\n   322→\\tsettings.Enabled = true\\n   323→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   324→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   325→\\t}\\n   326→\\n   327→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   328→\\treturn nil\\n   329→}\\n   330→\\n   331→func runDisable(ctx context.Context, w io.Writer, useProjectSettings bool) error {\\n   332→\\tsettings, err := LoadEntireSettings(ctx)\\n   333→\\tif err != nil {\\n   334→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   335→\\t}\\n   336→\\n   337→\\tsettings.Enabled = false\\n   338→\\n   339→\\t// If --project flag is specified, always write to project settings\\n   340→\\tif useProjectSettings {\\n   341→\\t\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   342→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   343→\\t\\t}\\n   344→\\t} else {\\n   345→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   346→\\t\\tif err := SaveEntireSettingsLocal(ctx, settings); err != nil {\\n   347→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   348→\\t\\t}\\n   349→\\t}\\n   350→\\n   351→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   352→\\treturn nil\\n   353→}\\n   354→\\n   355→// DisabledMessage is the message shown when Entire is disabled\\n   356→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   357→\\n   358→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   359→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   360→// On error reading settings, defaults to enabled (returns false).\\n   361→func checkDisabledGuard(ctx context.Context, w io.Writer) bool {\\n   362→\\tenabled, err := IsEnabled(ctx)\\n   363→\\tif err != nil {\\n   364→\\t\\t// Default to enabled on error\\n   365→\\t\\treturn false\\n   366→\\t}\\n   367→\\tif !enabled {\\n   368→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   369→\\t\\treturn true\\n   370→\\t}\\n   371→\\treturn false\\n   372→}\\n   373→\\n   374→// uninstallDeselectedAgentHooks removes hooks for agents that were previously\\n   375→// installed but are not in the selected list. This handles the case where a user\\n   376→// re-runs `entire enable` and deselects an agent.\\n   377→func uninstallDeselectedAgentHooks(ctx context.Context, w io.Writer, selectedAgents []agent.Agent) error {\\n   378→\\tinstalledNames := GetAgentsWithHooksInstalled(ctx)\\n   379→\\tif len(installedNames) == 0 {\\n   380→\\t\\treturn nil\\n   381→\\t}\\n   382→\\n   383→\\tselectedSet := make(map[types.AgentName]struct{}, len(selectedAgents))\\n   384→\\tfor _, ag := range selectedAgents {\\n   385→\\t\\tselectedSet[ag.Name()] = struct{}{}\\n   386→\\t}\\n   387→\\n   388→\\tvar errs []error\\n   389→\\tfor _, name := range installedNames {\\n   390→\\t\\tif _, selected := selectedSet[name]; selected {\\n   391→\\t\\t\\tcontinue\\n   392→\\t\\t}\\n   393→\\t\\tag, err := agent.Get(name)\\n   394→\\t\\tif err != nil {\\n   395→\\t\\t\\tcontinue\\n   396→\\t\\t}\\n   397→\\t\\thookAgent, ok := agent.AsHookSupport(ag)\\n   398→\\t\\tif !ok {\\n   399→\\t\\t\\tcontinue\\n   400→\\t\\t}\\n   401→\\t\\tif err := hookAgent.UninstallHooks(ctx); err != nil {\\n   402→\\t\\t\\terrs = append(errs, fmt.Errorf(\\\"failed to uninstall %s hooks: %w\\\", ag.Type(), err))\\n   403→\\t\\t} else {\\n   404→\\t\\t\\tfmt.Fprintf(w, \\\"Removed %s hooks\\\\n\\\", ag.Type())\\n   405→\\t\\t}\\n   406→\\t}\\n   407→\\treturn errors.Join(errs...)\\n   408→}\\n   409→\\n   410→// setupAgentHooks sets up hooks for a given agent.\\n   411→// Returns the number of hooks installed (0 if already installed).\\n   412→func setupAgentHooks(ctx context.Context, ag agent.Agent, localDev, forceHooks bool) (int, error) {\\n   413→\\thookAgent, ok := agent.AsHookSupport(ag)\\n   414→\\tif !ok {\\n   415→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   416→\\t}\\n   417→\\n   418→\\tcount, err := hookAgent.InstallHooks(ctx, localDev, forceHooks)\\n   419→\\tif err != nil {\\n   420→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   421→\\t}\\n   422→\\n   423→\\treturn count, nil\\n   424→}\\n   425→\\n   426→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   427→// Returns the detected/selected agents and any error.\\n   428→//\\n   429→// On first run (no hooks installed):\\n   430→//   - Single detected agent: used automatically\\n   431→//   - Multiple/no detected agents: interactive multi-select prompt\\n   432→//\\n   433→// On re-run (hooks already installed):\\n   434→//   - Always shows the interactive multi-select\\n   435→//   - Pre-selects only agents that have hooks installed (respects prior deselection)\\n   436→//\\n   437→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   438→// It receives available agent names and returns the selected names.\\n   439→func detectOrSelectAgent(ctx context.Context, w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   440→\\t// Check for agents with hooks already installed (re-run detection)\\n   441→\\tinstalledAgentNames := GetAgentsWithHooksInstalled(ctx)\\n   442→\\thasInstalledHooks := len(installedAgentNames) > 0\\n   443→\\n   444→\\t// Try auto-detection\\n   445→\\tdetected := agent.DetectAll(ctx)\\n   446→\\n   447→\\t// First run: use existing auto-detect shortcuts\\n   448→\\tif !hasInstalledHooks {\\n   449→\\t\\tswitch {\\n   450→\\t\\tcase len(detected) == 1:\\n   451→\\t\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   452→\\t\\t\\treturn detected, nil\\n   453→\\n   454→\\t\\tcase len(detected) > 1:\\n   455→\\t\\t\\tagentTypes := make([]string, 0, len(detected))\\n   456→\\t\\t\\tfor _, ag := range detected {\\n   457→\\t\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   458→\\t\\t\\t}\\n   459→\\t\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   460→\\t\\t\\tfmt.Fprintln(w)\\n   461→\\t\\t}\\n   462→\\t}\\n   463→\\n   464→\\t// Check if we can prompt interactively\\n   465→\\tif !canPromptInteractively() {\\n   466→\\t\\tif hasInstalledHooks {\\n   467→\\t\\t\\t// Re-run without TTY — keep currently installed agents\\n   468→\\t\\t\\tagents := make([]agent.Agent, 0, len(installedAgentNames))\\n   469→\\t\\t\\tfor _, name := range installedAgentNames {\\n   470→\\t\\t\\t\\tag, err := agent.Get(name)\\n   471→\\t\\t\\t\\tif err != nil {\\n   472→\\t\\t\\t\\t\\tcontinue\\n   473→\\t\\t\\t\\t}\\n   474→\\t\\t\\t\\tagents = append(agents, ag)\\n   475→\\t\\t\\t}\\n   476→\\t\\t\\treturn agents, nil\\n   477→\\t\\t}\\n   478→\\t\\tif len(detected) > 0 {\\n   479→\\t\\t\\treturn detected, nil\\n   480→\\t\\t}\\n   481→\\t\\tdefaultAgent := agent.Default()\\n   482→\\t\\tif defaultAgent == nil {\\n   483→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   484→\\t\\t}\\n   485→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   486→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   487→\\t}\\n   488→\\n   489→\\tif !hasInstalledHooks && len(detected) == 0 {\\n   490→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., \\\"+strings.Join(agent.StringList(), \\\", \\\")+\\\").\\\")\\n   491→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   492→\\t\\tfmt.Fprintln(w)\\n   493→\\t}\\n   494→\\n   495→\\t// Build pre-selection set.\\n   496→\\t// On re-run: only pre-select agents with hooks installed (respect prior deselection).\\n   497→\\t// On first run: pre-select all detected agents.\\n   498→\\tpreSelectedSet := make(map[types.AgentName]struct{})\\n   499→\\tif hasInstalledHooks {\\n   500→\\t\\tfor _, name := range installedAgentNames {\\n   501→\\t\\t\\tpreSelectedSet[name] = struct{}{}\\n   502→\\t\\t}\\n   503→\\t} else {\\n   504→\\t\\tfor _, ag := range detected {\\n   505→\\t\\t\\tpreSelectedSet[ag.Name()] = struct{}{}\\n   506→\\t\\t}\\n   507→\\t}\\n   508→\\n   509→\\t// Build options from registered agents\\n   510→\\tagentNames := agent.List()\\n   511→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   512→\\tfor _, name := range agentNames {\\n   513→\\t\\tag, err := agent.Get(name)\\n   514→\\t\\tif err != nil {\\n   515→\\t\\t\\tcontinue\\n   516→\\t\\t}\\n   517→\\t\\t// Only show agents that support hooks\\n   518→\\t\\tif _, ok := agent.AsHookSupport(ag); !ok {\\n   519→\\t\\t\\tcontinue\\n   520→\\t\\t}\\n   521→\\t\\t// Skip test-only agents (e.g., Vogon canary)\\n   522→\\t\\tif to, ok := ag.(agent.TestOnly); ok && to.IsTestOnly() {\\n   523→\\t\\t\\tcontinue\\n   524→\\t\\t}\\n   525→\\t\\topt := huh.NewOption(string(ag.Type()), string(name))\\n   526→\\t\\tif _, isPreSelected := preSelectedSet[name]; isPreSelected {\\n   527→\\t\\t\\topt = opt.Selected(true)\\n   528→\\t\\t}\\n   529→\\t\\toptions = append(options, opt)\\n   530→\\t}\\n   531→\\n   532→\\tif len(options) == 0 {\\n   533→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   534→\\t}\\n   535→\\n   536→\\t// Collect available agent names for the selector\\n   537→\\tavailableNames := make([]string, 0, len(options))\\n   538→\\tfor _, opt := range options {\\n   539→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   540→\\t}\\n   541→\\n   542→\\tvar selectedAgentNames []string\\n   543→\\tif selectFn != nil {\\n   544→\\t\\tvar err error\\n   545→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   546→\\t\\tif err != nil {\\n   547→\\t\\t\\treturn nil, err\\n   548→\\t\\t}\\n   549→\\t\\tif len(selectedAgentNames) == 0 {\\n   550→\\t\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   551→\\t\\t}\\n   552→\\t} else {\\n   553→\\t\\tform := NewAccessibleForm(\\n   554→\\t\\t\\thuh.NewGroup(\\n   555→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   556→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   557→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   558→\\t\\t\\t\\t\\tOptions(options...).\\n   559→\\t\\t\\t\\t\\tValidate(func(selected []string) error {\\n   560→\\t\\t\\t\\t\\t\\tif len(selected) == 0 {\\n   561→\\t\\t\\t\\t\\t\\t\\treturn errors.New(\\\"please select at least one agent\\\")\\n   562→\\t\\t\\t\\t\\t\\t}\\n   563→\\t\\t\\t\\t\\t\\treturn nil\\n   564→\\t\\t\\t\\t\\t}).\\n   565→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   566→\\t\\t\\t),\\n   567→\\t\\t)\\n   568→\\t\\tif err := form.Run(); err != nil {\\n   569→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   570→\\t\\t}\\n   571→\\t}\\n   572→\\n   573→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   574→\\tfor _, name := range selectedAgentNames {\\n   575→\\t\\tselectedAgent, err := agent.Get(types.AgentName(name))\\n   576→\\t\\tif err != nil {\\n   577→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   578→\\t\\t}\\n   579→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   580→\\t}\\n   581→\\n   582→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   583→\\tfor _, ag := range selectedAgents {\\n   584→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   585→\\t}\\n   586→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   587→\\treturn selectedAgents, nil\\n   588→}\\n   589→\\n   590→// canPromptInteractively checks if we can show interactive prompts.\\n   591→// Returns false when running in CI, tests, or other non-interactive environments.\\n   592→func canPromptInteractively() bool {\\n   593→\\t// Check for test environment\\n   594→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   595→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   596→\\t}\\n   597→\\n   598→\\t// Check if /dev/tty is available\\n   599→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   600→\\tif err != nil {\\n   601→\\t\\treturn false\\n   602→\\t}\\n   603→\\t_ = tty.Close()\\n   604→\\treturn true\\n   605→}\\n   606→\\n   607→// printAgentError writes an error message followed by available agents and usage.\\n   608→func printAgentError(w io.Writer, message string) {\\n   609→\\tagents := agent.List()\\n   610→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   611→\\tfmt.Fprintln(w)\\n   612→\\tfor _, a := range agents {\\n   613→\\t\\tsuffix := \\\"\\\"\\n   614→\\t\\tif a == agent.DefaultAgentName {\\n   615→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   616→\\t\\t}\\n   617→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   618→\\t}\\n   619→\\tfmt.Fprintln(w)\\n   620→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   621→}\\n   622→\\n   623→// printMissingAgentError writes a helpful error listing available agents.\\n   624→func printMissingAgentError(w io.Writer) {\\n   625→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   626→}\\n   627→\\n   628→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   629→func printWrongAgentError(w io.Writer, name string) {\\n   630→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   631→}\\n   632→\\n   633→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   634→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   635→func setupAgentHooksNonInteractive(ctx context.Context, w io.Writer, ag agent.Agent, opts EnableOptions) error {\\n   636→\\tagentName := ag.Name()\\n   637→\\t// Check if agent supports hooks\\n   638→\\thookAgent, ok := agent.AsHookSupport(ag)\\n   639→\\tif !ok {\\n   640→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   641→\\t}\\n   642→\\n   643→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   644→\\n   645→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   646→\\tinstalledHooks, err := hookAgent.InstallHooks(ctx, opts.LocalDev, opts.ForceHooks)\\n   647→\\tif err != nil {\\n   648→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   649→\\t}\\n   650→\\n   651→\\t// Setup .entire directory\\n   652→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   653→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   654→\\t}\\n   655→\\n   656→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   657→\\tsettings, err := LoadEntireSettings(ctx)\\n   658→\\tif err != nil {\\n   659→\\t\\t// If we can't load, start with defaults\\n   660→\\t\\tsettings = &EntireSettings{}\\n   661→\\t}\\n   662→\\tsettings.Enabled = true\\n   663→\\tif opts.LocalDev {\\n   664→\\t\\tsettings.LocalDev = true\\n   665→\\t}\\n   666→\\tif opts.AbsoluteGitHookPath {\\n   667→\\t\\tsettings.AbsoluteGitHookPath = true\\n   668→\\t}\\n   669→\\n   670→\\topts.applyStrategyOptions(settings)\\n   671→\\n   672→\\t// Handle telemetry for non-interactive mode\\n   673→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   674→\\tif !opts.Telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   675→\\t\\tf := false\\n   676→\\t\\tsettings.Telemetry = &f\\n   677→\\t}\\n   678→\\n   679→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   680→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   681→\\t}\\n   682→\\n   683→\\t// Use settings values (merged from existing config + flags) for hook installation\\n   684→\\t// This ensures re-running `entire enable --agent X` without flags preserves existing settings\\n   685→\\tif _, err := strategy.InstallGitHook(ctx, true, settings.LocalDev, settings.AbsoluteGitHookPath); err != nil {\\n   686→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   687→\\t}\\n   688→\\tstrategy.CheckAndWarnHookManagers(ctx, w, settings.LocalDev, settings.AbsoluteGitHookPath)\\n   689→\\n   690→\\tif installedHooks == 0 {\\n   691→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   692→\\t\\tif ag.IsPreview() {\\n   693→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   694→\\t\\t}\\n   695→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   696→\\t} else {\\n   697→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   698→\\t\\tif ag.IsPreview() {\\n   699→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   700→\\t\\t}\\n   701→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   702→\\t}\\n   703→\\n   704→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   705→\\n   706→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   707→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   708→\\t}\\n   709→\\n   710→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   711→\\n   712→\\treturn nil\\n   713→}\\n   714→\\n   715→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   716→func validateSetupFlags(useLocal, useProject bool) error {\\n   717→\\tif useLocal && useProject {\\n   718→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   719→\\t}\\n   720→\\treturn nil\\n   721→}\\n   722→\\n   723→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   724→// - Whether settings.json already exists\\n   725→// - The --local and --project flags\\n   726→// Returns (useLocal, showNotification).\\n   727→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   728→\\t// Explicit --local flag always uses local settings\\n   729→\\tif useLocal {\\n   730→\\t\\treturn true, false\\n   731→\\t}\\n   732→\\n   733→\\t// Explicit --project flag always uses project settings\\n   734→\\tif useProject {\\n   735→\\t\\treturn false, false\\n   736→\\t}\\n   737→\\n   738→\\t// No flags specified - check if settings file exists\\n   739→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   740→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   741→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   742→\\t\\treturn true, true\\n   743→\\t}\\n   744→\\n   745→\\t// Settings file doesn't exist - create it\\n   746→\\treturn false, false\\n   747→}\\n   748→\\n   749→// setupEntireDirectory creates the .entire directory and gitignore.\\n   750→// Returns true if the directory was created, false if it already existed.\\n   751→func setupEntireDirectory(ctx context.Context) (bool, error) { //nolint:unparam // already present in codebase\\n   752→\\t// Get absolute path for the .entire directory\\n   753→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   754→\\tif err != nil {\\n   755→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   756→\\t}\\n   757→\\n   758→\\t// Check if directory already exists\\n   759→\\tcreated := false\\n   760→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   761→\\t\\tcreated = true\\n   762→\\t}\\n   763→\\n   764→\\t// Create .entire directory\\n   765→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   766→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   767→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   768→\\t}\\n   769→\\n   770→\\t// Create/update .gitignore with all required entries\\n   771→\\tif err := strategy.EnsureEntireGitignore(ctx); err != nil {\\n   772→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   773→\\t}\\n   774→\\n   775→\\treturn created, nil\\n   776→}\\n   777→\\n   778→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   779→func setupGitHook(ctx context.Context) error {\\n   780→\\ts, err := settings.Load(ctx)\\n   781→\\tlocalDev := err == nil && s.LocalDev\\n   782→\\tabsoluteHookPath := err == nil && s.AbsoluteGitHookPath\\n   783→\\tif _, err := strategy.InstallGitHook(ctx, false,