ings) GetCheckpointRemote() *CheckpointRemoteConfig {\\n         if s.StrategyOptions == nil { return nil }\\n         val, ok := s.StrategyOptions[\\\"checkpoint_remote\\\"]\\n         if !ok { return nil }\\n         m, ok := val.(map[string]any)\\n         if !ok { return nil }\\n         provider, providerOK := m[\\\"provider\\\"].(string)\\n         repo, repoOK := m[\\\"repo\\\"].(string)\\n         if !providerOK || !repoOK || provider == \\\"\\\" || repo == \\\"\\\" { return nil }\\n         if !strings.Contains(repo, \\\"/\\\") { return nil }\\n         return &CheckpointRemoteConfig{Provider: provider, Repo: repo}\\n     }\\n     ```\\n\\n   - **`cmd/entire/cli/settings/settings_checkpoint_remote_test.go`**\\n     - Completely rewritten for structured format testing\\n     - Tests: NotConfigured, EmptyStrategyOptions, StructuredGithub, MissingProvider, MissingRepo, RepoWithoutSlash, LegacyStringIgnored, WrongType, JSONRoundTrip, CoexistsWithPushSessions, CheckpointRemoteConfig_Owner\\n\\n   - **`cmd/entire/cli/setup.go`**\\n     - Added `parseCheckpointRemoteFlag()` to parse `github:org/repo` format\\n     - Updated `applyStrategyOptions()` to store structured map instead of raw string\\n     - Updated flag description\\n     ```go\\n     func parseCheckpointRemoteFlag(value string) (provider, repo string, err error) {\\n         parts := strings.SplitN(value, \\\":\\\", 2)\\n         if len(parts) != 2 || parts[0] == \\\"\\\" || parts[1] == \\\"\\\" {\\n             return \\\"\\\", \\\"\\\", fmt.Errorf(\\\"expected format provider:owner/repo (e.g., github:org/checkpoints-repo), got %q\\\", value)\\n         }\\n         provider = parts[0]\\n         repo = parts[1]\\n         switch provider {\\n         case \\\"github\\\": // valid\\n         default:\\n             return \\\"\\\", \\\"\\\", fmt.Errorf(\\\"unsupported provider %q (supported: github)\\\", provider)\\n         }\\n         repoParts := strings.SplitN(repo, \\\"/\\\", 2)\\n         if l