,\\n    66→\\t\\tShort: \\\"Enable Entire in current project\\\",\\n    67→\\t\\tLong: `Enable Entire with session tracking for your AI agent workflows.\\n    68→\\n    69→Uses the manual-commit strategy, which creates session checkpoints without\\n    70→modifying your active branch.`,\\n    71→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    72→\\t\\t\\tctx := cmd.Context()\\n    73→\\t\\t\\t// Check if we're in a git repository first - this is a prerequisite error,\\n    74→\\t\\t\\t// not a usage error, so we silence Cobra's output and use SilentError\\n    75→\\t\\t\\t// to prevent duplicate error output in main.go\\n    76→\\t\\t\\tif _, err := paths.WorktreeRoot(ctx); err != nil {\\n    77→\\t\\t\\t\\tfmt.Fprintln(cmd.ErrOrStderr(), \\\"Not a git repository. Please run 'entire enable' from within a git repository.\\\")\\n    78→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n    79→\\t\\t\\t}\\n    80→\\n    81→\\t\\t\\tif err := validateSetupFlags(opts.UseLocalSettings, opts.UseProjectSettings); err != nil {\\n    82→\\t\\t\\t\\treturn err\\n    83→\\t\\t\\t}\\n    84→\\n    85→\\t\\t\\t// Discover external agent plugins so they appear in agent selection.\\n    86→\\t\\t\\texternal.DiscoverAndRegister(ctx)\\n    87→\\n    88→\\t\\t\\t// Warn if repo has no commits yet\\n    89→\\t\\t\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n    90→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Note: This repository has no commits yet. Entire will be configured, but\\\")\\n    91→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"session checkpoints won't work until you create your first commit.\\\")\\n    92→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout())\\n    93→\\t\\t\\t}\\n    94→\\n    95→\\t\\t\\t// Non-interactive mode if --agent flag is provided\\n    96→\\t\\t\\tif cmd.Flags().Changed(\\\"agent\\\") && agentName == \\\"\\\" {\\n    97→\\t\\t\\t\\tprintMissingAgentError(cmd.ErrOrStderr())\\n    98→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n    99→\\t\\t\\t}\\n   100→\\n   101→\\t\\t\\tif agentName != \\\"\\\" {\\n   102→\\t\\t\\t\\tag, err := agent.Get(types.AgentName(agentName))\\n   103→\\t\\t\\t\\tif err != nil {\\n   104→\\t\\t\\t\\t\\tprintWrongAgentError(cmd.ErrOrStderr(), agentName)\\n   105→\\t\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"wrong agent name\\\"))\\n   106→\\t\\t\\t\\t}\\n   107→\\t\\t\\t\\t// --agent is a targeted operation: set up this specific agent without\\n   108→\\t\\t\\t\\t// affecting other agents. Unlike the interactive path, it does not\\n   109→\\t\\t\\t\\t// uninstall hooks for other previously-enabled agents.\\n   110→\\t\\t\\t\\treturn setupAgentHooksNonInteractive(ctx, cmd.OutOrStdout(), ag, opts)\\n   111→\\t\\t\\t}\\n   112→\\t\\t\\t// Detect or prompt for agents\\n   113→\\t\\t\\tagents, err := detectOrSelectAgent(ctx, cmd.OutOrStdout(), nil)\\n   114→\\t\\t\\tif err != nil {\\n   115→\\t\\t\\t\\treturn fmt.Errorf(\\\"agent selection failed: %w\\\", err)\\n   116→\\t\\t\\t}\\n   117→\\n   118→\\t\\t\\treturn runEnableInteractive(ctx, cmd.OutOrStdout(), agents, opts)\\n   119→\\t\\t},\\n   120→\\t}\\n   121→\\n   122→\\tcmd.Flags().BoolVar(&opts.LocalDev, \\\"local-dev\\\", false, \\\"Use go run instead of entire binary for hooks\\\")\\n   123→\\tcmd.Flags().MarkHidden(\\\"local-dev\\\") //nolint:errcheck,gosec // flag is defined above\\n   124→\\tcmd.Flags().BoolVar(&ignoreUntracked, \\\"ignore-untracked\\\", false, \\\"Commit all new files without tracking pre-existing untracked files\\\")\\n   125→\\tcmd.Flags().MarkHidden(\\\"ignore-untracked\\\") //nolint:errcheck,gosec // flag is defined above\\n   126→\\tcmd.Flags().BoolVar(&opts.UseLocalSettings, \\\"local\\\", false, \\\"Write settings to .entire/settings.local.json instead of .entire/settings.json\\\")\\n   127→\\tcmd.Flags().BoolVar(&opts.UseProjectSettings, \\\"project\\\", false, \\\"Write settings to .entire/settings.json even if it already exists\\\")\\n   128→\\tcmd.Flags().StringVar(&agentName, \\\"agent\\\", \\\"\\\", \\\"Agent to set up hooks for (e.g., \\\"+strings.Join(agent.StringList(), \\\", \\\")+\\\"). Enables non-interactive mode.\\\")\\n   129→\\tcmd.Flags().BoolVarP(&opts.ForceHooks, \\\"force\\\", \\\"f\\\", false, \\\"Force reinstall hooks (removes existing Entire hooks first)\\\")\\n   130→\\tcmd.Flags().BoolVar(&opts.SkipPushSessions, \\\"skip-push-sessions\\\", false, \\\"Disable automatic pushing of session logs on git push\\\")\\n   131→\\tcmd.Flags().StringVar(&opts.CheckpointRemote, \\\"checkpoint-remote\\\", \\\"\\\", \\\"Git remote URL (SSH or HTTPS) to push checkpoint branches to a separate remote\\\")\\n   132→\\tcmd.Flags().BoolVar(&opts.Telemetry, \\\"telemetry\\\", true, \\\"Enable anonymous usage analytics\\\")\\n   133→\\tcmd.Flags().BoolVar(&opts.AbsoluteGitHookPath, \\\"absolute-git-hook-path\\\", false, \\\"Embed full binary path in git hooks (for GUI git clients that don't source shell profiles)\\\")\\n   134→\\n   135→\\t// Provide a helpful error when --agent is used without a value\\n   136→\\tdefaultFlagErr := cmd.FlagErrorFunc()\\n   137→\\tcmd.SetFlagErrorFunc(func(c *cobra.Command, err error) error {\\n   138→\\t\\tvar valErr *pflag.ValueRequiredError\\n   139→\\t\\tif errors.As(err, &valErr) && valErr.GetSpecifiedName() == \\\"agent\\\" {\\n   140→\\t\\t\\tprintMissingAgentError(c.ErrOrStderr())\\n   141→\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n   142→\\t\\t}\\n   143→\\t\\treturn defaultFlagErr(c, err)\\n   144→\\t})\\n   145→\\n   146→\\t// Add subcommands for automation/testing\\n   147→\\tcmd.AddCommand(newSetupGitHookCmd())\\n   148→\\n   149→\\treturn cmd\\n   150→}\\n   151→\\n   152→func newDisableCmd() *cobra.Command {\\n   153→\\tvar useProjectSettings bool\\n   154→\\tvar uninstall bool\\n   155→\\tvar force bool\\n   156→\\n   157→\\tcmd := &cobra.Command{\\n   158→\\t\\tUse:   \\\"disable\\\",\\n   159→\\t\\tShort: \\\"Disable Entire in current project\\\",\\n   160→\\t\\tLong: `Disable Entire integrations in the current project.\\n   161→\\n   162→By default, this command will disable Entire. Hooks will exit silently and commands will\\n   163→show a disabled message.\\n   164→\\n   165→To completely remove Entire integrations from this repository, use --uninstall:\\n   166→  - .entire/ directory (settings, logs, metadata)\\n   167→  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\n   168→  - Session state files (.git/entire-sessions/)\\n   169→  - Shadow branches (entire/<hash>)\\n   170→  - Agent hooks`,\\n   171→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   172→\\t\\t\\tctx := cmd.Context()\\n   173→\\t\\t\\tif uninstall {\\n   174→\\t\\t\\t\\treturn runUninstall(ctx, cmd.OutOrStdout(), cmd.ErrOrStderr(), force)\\n   175→\\t\\t\\t}\\n   176→\\t\\t\\treturn runDisable(ctx, cmd.OutOrStdout(), useProjectSettings)\\n   177→\\t\\t},\\n   178→\\t}\\n   179→\\n   180→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Update .entire/settings.json instead of .entire/settings.local.json\\\")\\n   181→\\tcmd.Flags().BoolVar(&uninstall, \\\"uninstall\\\", false, \\\"Completely remove Entire from this repository\\\")\\n   182→\\tcmd.Flags().BoolVar(&force, \\\"force\\\", false, \\\"Skip confirmation prompt (use with --uninstall)\\\")\\n   183→\\n   184→\\treturn cmd\\n   185→}\\n   186→\\n   187→// runEnableInteractive runs the interactive enable flow.\\n   188→// agents must be provided by the caller (via detectOrSelectAgent).\\n   189→func runEnableInteractive(ctx context.Context, w io.Writer, agents []agent.Agent, opts EnableOptions) error {\\n   190→\\t// Uninstall hooks for agents that were previously active but are no longer selected\\n   191→\\tif err := uninstallDeselectedAgentHooks(ctx, w, agents); err != nil {\\n   192→\\t\\treturn fmt.Errorf(\\\"failed to clean up deselected agents: %w\\\", err)\\n   193→\\t}\\n   194→\\n   195→\\t// Setup agent hooks for all selected agents\\n   196→\\tfor _, ag := range agents {\\n   197→\\t\\tif _, err := setupAgentHooks(ctx, ag, opts.LocalDev, opts.ForceHooks); err != nil {\\n   198→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   199→\\t\\t}\\n   200→\\t}\\n   201→\\n   202→\\t// Setup .entire directory\\n   203→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   204→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   205→\\t}\\n   206→\\n   207→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   208→\\tsettings, err := LoadEntireSettings(ctx)\\n   209→\\tif err != nil {\\n   210→\\t\\t// If we can't load, start with defaults\\n   211→\\t\\tsettings = &EntireSettings{}\\n   212→\\t}\\n   213→\\t// Update the specific fields\\n   214→\\tsettings.Enabled = true\\n   215→\\tif opts.LocalDev {\\n   216→\\t\\tsettings.LocalDev = true\\n   217→\\t}\\n   218→\\tif opts.AbsoluteGitHookPath {\\n   219→\\t\\tsettings.AbsoluteGitHookPath = true\\n   220→\\t}\\n   221→\\n   222→\\topts.applyStrategyOptions(settings)\\n   223→\\n   224→\\t// Determine which settings file to write to\\n   225→\\t// First run always creates settings.json (no prompt)\\n   226→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   227→\\tif err != nil {\\n   228→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   229→\\t}\\n   230→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, opts.UseLocalSettings, opts.UseProjectSettings)\\n   231→\\n   232→\\tif showNotification {\\n   233→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   234→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   235→\\t}\\n   236→\\n   237→\\t// Save settings to the appropriate file.\\n   238→\\tsaveSettings := func() error {\\n   239→\\t\\tif shouldUseLocal {\\n   240→\\t\\t\\treturn SaveEntireSettingsLocal(ctx, settings)\\n   241→\\t\\t}\\n   242→\\t\\treturn SaveEntireSettings(ctx, settings)\\n   243→\\t}\\n   244→\\tif err := saveSettings(); err != nil {\\n   245→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   246→\\t}\\n   247→\\n   248→\\t// Use settings values (merged from existing config + flags) for hook installation\\n   249→\\t// This ensures re-running `entire enable` without flags preserves existing settings\\n   250→\\tif _, err := strategy.InstallGitHook(ctx, true, settings.LocalDev, settings.AbsoluteGitHookPath); err != nil {\\n   251→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   252→\\t}\\n   253→\\tstrategy.CheckAndWarnHookManagers(ctx, w, settings.LocalDev, settings.AbsoluteGitHookPath)\\n   254→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   255→\\n   256→\\tconfigDisplay := configDisplayProject\\n   257→\\tif shouldUseLocal {\\n   258→\\t\\tconfigDisplay = configDisplayLocal\\n   259→\\t}\\n   260→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   261→\\n   262→\\t// Ask about telemetry consent (only if not already asked)\\n   263→\\tfmt.Fprintln(w)\\n   264→\\tif err := promptTelemetryConsent(settings, opts.Telemetry); err != nil {\\n   265→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   266→\\t}\\n   267→\\t// Save again to persist telemetry choice\\n   268→\\tif err := saveSettings(); err != nil {\\n   269→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   270→\\t}\\n   271→\\n   272→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   273→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   274→\\t}\\n   275→\\n   276→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   277→\\n   278→\\treturn nil\\n   279→}\\n   280→\\n   281→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   282→func runEnable(ctx context.Context, w io.Writer) error {\\n   283→\\tsettings, err := LoadEntireSettings(ctx)\\n   284→\\tif err != nil {\\n   285→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   286→\\t}\\n   287→\\n   288→\\tsettings.Enabled = true\\n   289→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   290→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   291→\\t}\\n   292→\\n   293→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   294→\\treturn nil\\n   295→}\\n   296→\\n   297→func runDisable(ctx context.Context, w io.Writer, useProjectSettings bool) error {\\n   298→\\tsettings, err := LoadEntireSettings(ctx)\\n   299→\\tif err != nil {\\n   300→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   301→\\t}\\n   302→\\n   303→\\tsettings.Enabled = false\\n   304→\\n   305→\\t// If --project flag is specified, always write to project settings\\n   306→\\tif useProjectSettings {\\n   307→\\t\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   308→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   309→\\t\\t}\\n   310→\\t} else {\\n   311→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   312→\\t\\tif err := SaveEntireSettingsLocal(ctx, settings); err != nil {\\n   313→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   314→\\t\\t}\\n   315→\\t}\\n   316→\\n   317→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   318→\\treturn nil\\n   319→}\\n   320→\\n   321→// DisabledMessage is the message shown when Entire is disabled\\n   322→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   323→\\n   324→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   325→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   326→// On error reading settings, defaults to enabled (returns false).\\n   327→func checkDisabledGuard(ctx context.Context, w io.Writer) bool {\\n   328→\\tenabled, err := IsEnabled(ctx)\\n   329→\\tif err != nil {\\n   330→\\t\\t// Default to enabled on error\\n   331→\\t\\treturn false\\n   332→\\t}\\n   333→\\tif !enabled {\\n   334→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   335→\\t\\treturn true\\n   336→\\t}\\n   337→\\treturn false\\n   338→}\\n   339→\\n   340→// uninstallDeselectedAgentHooks removes hooks for agents that were previously\\n   341→// installed but are not in the selected list. This handles the case where a user\\n   342→// re-runs `entire enable` and deselects an agent.\\n   343→func uninstallDeselectedAgentHooks(ctx context.Context, w io.Writer, selectedAgents []agent.Agent) error {\\n   344→\\tinstalledNames := GetAgentsWithHooksInstalled(ctx)\\n   345→\\tif len(installedNames) == 0 {\\n   346→\\t\\treturn nil\\n   347→\\t}\\n   348→\\n   349→\\tselectedSet := make(map[types.AgentName]struct{}, len(selectedAgents))\\n   350→\\tfor _, ag := range selectedAgents {\\n   351→\\t\\tselectedSet[ag.Name()] = struct{}{}\\n   352→\\t}\\n   353→\\n   354→\\tvar errs []error\\n   355→\\tfor _, name := range installedNames {\\n   356→\\t\\tif _, selected := selectedSet[name]; selected {\\n   357→\\t\\t\\tcontinue\\n   358→\\t\\t}\\n   359→\\t\\tag, err := agent.Get(name)\\n   360→\\t\\tif err != nil {\\n   361→\\t\\t\\tcontinue\\n   362→\\t\\t}\\n   363→\\t\\thookAgent, ok := agent.AsHookSupport(ag)\\n   364→\\t\\tif !ok {\\n   365→\\t\\t\\tcontinue\\n   366→\\t\\t}\\n   367→\\t\\tif err := hookAgent.UninstallHooks(ctx); err != nil {\\n   368→\\t\\t\\terrs = append(errs, fmt.Errorf(\\\"failed to uninstall %s hooks: %w\\\", ag.Type(), err))\\n   369→\\t\\t} else {\\n   370→\\t\\t\\tfmt.Fprintf(w, \\\"Removed %s hooks\\\\n\\\", ag.Type())\\n   371→\\t\\t}\\n   372→\\t}\\n   373→\\treturn errors.Join(errs...)\\n   374→}\\n   375→\\n   376→// setupAgentHooks sets up hooks for a given agent.\\n   377→// Returns the number of hooks installed (0 if already installed).\\n   378→func setupAgentHooks(ctx context.Context, ag agent.Agent, localDev, forceHooks bool) (int, error) {\\n   379→\\thookAgent, ok := agent.AsHookSupport(ag)\\n   380→\\tif !ok {\\n   381→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   382→\\t}\\n   383→\\n   384→\\tcount, err := hookAgent.InstallHooks(ctx, localDev, forceHooks)\\n   385→\\tif err != nil {\\n   386→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   387→\\t}\\n   388→\\n   389→\\treturn count, nil\\n   390→}\\n   391→\\n   392→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   393→// Returns the detected/selected agents and any error.\\n   394→//\\n   395→// On first run (no hooks installed):\\n   396→//   - Single detected agent: used automatically\\n   397→//   - Multiple/no detected agents: interactive multi-select prompt\\n   398→//\\n   399→// On re-run (hooks already installed):\\n   400→//   - Always shows the interactive multi-select\\n   401→//   - Pre-selects only agents that have hooks installed (respects prior deselection)\\n   402→//\\n   403→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   404→// It receives available agent names and returns the selected names.\\n   405→func detectOrSelectAgent(ctx context.Context, w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   406→\\t// Check for agents with hooks already installed (re-run detection)\\n   407→\\tinstalledAgentNames := GetAgentsWithHooksInstalled(ctx)\\n   408→\\thasInstalledHooks := len(installedAgentNames) > 0\\n   409→\\n   410→\\t// Try auto-detection\\n   411→\\tdetected := agent.DetectAll(ctx)\\n   412→\\n   413→\\t// First run: use existing auto-detect shortcuts\\n   414→\\tif !hasInstalledHooks {\\n   415→\\t\\tswitch {\\n   416→\\t\\tcase len(detected) == 1:\\n   417→\\t\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   418→\\t\\t\\treturn detected, nil\\n   419→\\n   420→\\t\\tcase len(detected) > 1:\\n   421→\\t\\t\\tagentTypes := make([]string, 0, len(detected))\\n   422→\\t\\t\\tfor _, ag := range detected {\\n   423→\\t\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   424→\\t\\t\\t}\\n   425→\\t\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   426→\\t\\t\\tfmt.Fprintln(w)\\n   427→\\t\\t}\\n   428→\\t}\\n   429→\\n   430→\\t// Check if we can prompt interactively\\n   431→\\tif !canPromptInteractively() {\\n   432→\\t\\tif hasInstalledHooks {\\n   433→\\t\\t\\t// Re-run without TTY — keep currently installed agents\\n   434→\\t\\t\\tagents := make([]agent.Agent, 0, len(installedAgentNames))\\n   435→\\t\\t\\tfor _, name := range installedAgentNames {\\n   436→\\t\\t\\t\\tag, err := agent.Get(name)\\n   437→\\t\\t\\t\\tif err != nil {\\n   438→\\t\\t\\t\\t\\tcontinue\\n   439→\\t\\t\\t\\t}\\n   440→\\t\\t\\t\\tagents = append(agents, ag)\\n   441→\\t\\t\\t}\\n   442→\\t\\t\\treturn agents, nil\\n   443→\\t\\t}\\n   444→\\t\\tif len(detected) > 0 {\\n   445→\\t\\t\\treturn detected, nil\\n   446→\\t\\t}\\n   447→\\t\\tdefaultAgent := agent.Default()\\n   448→\\t\\tif defaultAgent == nil {\\n   449→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   450→\\t\\t}\\n   451→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   452→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   453→\\t}\\n   454→\\n   455→\\tif !hasInstalledHooks && len(detected) == 0 {\\n   456→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., \\\"+strings.Join(agent.StringList(), \\\", \\\")+\\\").\\\")\\n   457→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   458→\\t\\tfmt.Fprintln(w)\\n   459→\\t}\\n   460→\\n   461→\\t// Build pre-selection set.\\n   462→\\t// On re-run: only pre-select agents with hooks installed (respect prior deselection).\\n   463→\\t// On first run: pre-select all detected agents.\\n   464→\\tpreSelectedSet := make(map[types.AgentName]struct{})\\n   465→\\tif hasInstalledHooks {\\n   466→\\t\\tfor _, name := range installedAgentNames {\\n   467→\\t\\t\\tpreSelectedSet[name] = struct{}{}\\n   468→\\t\\t}\\n   469→\\t} else {\\n   470→\\t\\tfor _, ag := range detected {\\n   471→\\t\\t\\tpreSelectedSet[ag.Name()] = struct{}{}\\n   472→\\t\\t}\\n   473→\\t}\\n   474→\\n   475→\\t// Build options from registered agents\\n   476→\\tagentNames := agent.List()\\n   477→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   478→\\tfor _, name := range agentNames {\\n   479→\\t\\tag, err := agent.Get(name)\\n   480→\\t\\tif err != nil {\\n   481→\\t\\t\\tcontinue\\n   482→\\t\\t}\\n   483→\\t\\t// Only show agents that support hooks\\n   484→\\t\\tif _, ok := agent.AsHookSupport(ag); !ok {\\n   485→\\t\\t\\tcontinue\\n   486→\\t\\t}\\n   487→\\t\\t// Skip test-only agents (e.g., Vogon canary)\\n   488→\\t\\tif to, ok := ag.(agent.TestOnly); ok && to.IsTestOnly() {\\n   489→\\t\\t\\tcontinue\\n   490→\\t\\t}\\n   491→\\t\\topt := huh.NewOption(string(ag.Type()), string(name))\\n   492→\\t\\tif _, isPreSelected := preSelectedSet[name]; isPreSelected {\\n   493→\\t\\t\\topt = opt.Selected(true)\\n   494→\\t\\t}\\n   495→\\t\\toptions = append(options, opt)\\n   496→\\t}\\n   497→\\n   498→\\tif len(options) == 0 {\\n   499→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   500→\\t}\\n   501→\\n   502→\\t// Collect available agent names for the selector\\n   503→\\tavailableNames := make([]string, 0, len(options))\\n   504→\\tfor _, opt := range options {\\n   505→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   506→\\t}\\n   507→\\n   508→\\tvar selectedAgentNames []string\\n   509→\\tif selectFn != nil {\\n   510→\\t\\tvar err error\\n   511→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   512→\\t\\tif err != nil {\\n   513→\\t\\t\\treturn nil, err\\n   514→\\t\\t}\\n   515→\\t\\tif len(selectedAgentNames) == 0 {\\n   516→\\t\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   517→\\t\\t}\\n   518→\\t} else {\\n   519→\\t\\tform := NewAccessibleForm(\\n   520→\\t\\t\\thuh.NewGroup(\\n   521→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   522→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   523→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   524→\\t\\t\\t\\t\\tOptions(options...).\\n   525→\\t\\t\\t\\t\\tValidate(func(selected []string) error {\\n   526→\\t\\t\\t\\t\\t\\tif len(selected) == 0 {\\n   527→\\t\\t\\t\\t\\t\\t\\treturn errors.New(\\\"please select at least one agent\\\")\\n   528→\\t\\t\\t\\t\\t\\t}\\n   529→\\t\\t\\t\\t\\t\\treturn nil\\n   530→\\t\\t\\t\\t\\t}).\\n   531→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   532→\\t\\t\\t),\\n   533→\\t\\t)\\n   534→\\t\\tif err := form.Run(); err != nil {\\n   535→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   536→\\t\\t}\\n   537→\\t}\\n   538→\\n   539→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   540→\\tfor _, name := range selectedAgentNames {\\n   541→\\t\\tselectedAgent, err := agent.Get(types.AgentName(name))\\n   542→\\t\\tif err != nil {\\n   543→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   544→\\t\\t}\\n   545→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   546→\\t}\\n   547→\\n   548→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   549→\\tfor _, ag := range selectedAgents {\\n   550→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   551→\\t}\\n   552→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   553→\\treturn selectedAgents, nil\\n   554→}\\n   555→\\n   556→// canPromptInteractively checks if we can show interactive prompts.\\n   557→// Returns false when running in CI, tests, or other non-interactive environments.\\n   558→func canPromptInteractively() bool {\\n   559→\\t// Check for test environment\\n   560→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   561→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   562→\\t}\\n   563→\\n   564→\\t// Check if /dev/tty is available\\n   565→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   566→\\tif err != nil {\\n   567→\\t\\treturn false\\n   568→\\t}\\n   569→\\t_ = tty.Close()\\n   570→\\treturn true\\n   571→}\\n   572→\\n   573→// printAgentError writes an error message followed by available agents and usage.\\n   574→func printAgentError(w io.Writer, message string) {\\n   575→\\tagents := agent.List()\\n   576→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   577→\\tfmt.Fprintln(w)\\n   578→\\tfor _, a := range agents {\\n   579→\\t\\tsuffix := \\\"\\\"\\n   580→\\t\\tif a == agent.DefaultAgentName {\\n   581→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   582→\\t\\t}\\n   583→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   584→\\t}\\n   585→\\tfmt.Fprintln(w)\\n   586→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   587→}\\n   588→\\n   589→// printMissingAgentError writes a helpful error listing available agents.\\n   590→func printMissingAgentError(w io.Writer) {\\n   591→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   592→}\\n   593→\\n   594→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   595→func printWrongAgentError(w io.Writer, name string) {\\n   596→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   597→}\\n   598→\\n   599→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   600→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   601→func setupAgentHooksNonInteractive(ctx context.Context, w io.Writer, ag agent.Agent, opts EnableOptions) error {\\n   602→\\tagentName := ag.Name()\\n   603→\\t// Check if agent supports hooks\\n   604→\\thookAgent, ok := agent.AsHookSupport(ag)\\n   605→\\tif !ok {\\n   606→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   607→\\t}\\n   608→\\n   609→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   610→\\n   611→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   612→\\tinstalledHooks, err := hookAgent.InstallHooks(ctx, opts.LocalDev, opts.ForceHooks)\\n   613→\\tif err != nil {\\n   614→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   615→\\t}\\n   616→\\n   617→\\t// Setup .entire directory\\n   618→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   619→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   620→\\t}\\n   621→\\n   622→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   623→\\tsettings, err := LoadEntireSettings(ctx)\\n   624→\\tif err != nil {\\n   625→\\t\\t// If we can't load, start with defaults\\n   626→\\t\\tsettings = &EntireSettings{}\\n   627→\\t}\\n   628→\\tsettings.Enabled = true\\n   629→\\tif opts.LocalDev {\\n   630→\\t\\tsettings.LocalDev = true\\n   631→\\t}\\n   632→\\tif opts.AbsoluteGitHookPath {\\n   633→\\t\\tsettings.AbsoluteGitHookPath = true\\n   634→\\t}\\n   635→\\n   636→\\topts.applyStrategyOptions(settings)\\n   637→\\n   638→\\t// Handle telemetry for non-interactive mode\\n   639→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   640→\\tif !opts.Telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   641→\\t\\tf := false\\n   642→\\t\\tsettings.Telemetry = &f\\n   643→\\t}\\n   644→\\n   645→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   646→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   647→\\t}\\n   648→\\n   649→\\t// Use settings values (merged from existing config + flags) for hook installation\\n   650→\\t// This ensures re-running `entire enable --agent X` without flags preserves existing settings\\n   651→\\tif _, err := strategy.InstallGitHook(ctx, true, settings.LocalDev, settings.AbsoluteGitHookPath); err != nil {\\n   652→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   653→\\t}\\n   654→\\tstrategy.CheckAndWarnHookManagers(ctx, w, settings.LocalDev, settings.AbsoluteGitHookPath)\\n   655→\\n   656→\\tif installedHooks == 0 {\\n   657→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   658→\\t\\tif ag.IsPreview() {\\n   659→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   660→\\t\\t}\\n   661→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   662→\\t} else {\\n   663→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   664→\\t\\tif ag.IsPreview() {\\n   665→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   666→\\t\\t}\\n   667→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   668→\\t}\\n   669→\\n   670→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   671→\\n   672→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   673→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   674→\\t}\\n   675→\\n   676→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   677→\\n   678→\\treturn nil\\n   679→}\\n   680→\\n   681→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   682→func validateSetupFlags(useLocal, useProject bool) error {\\n   683→\\tif useLocal && useProject {\\n   684→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   685→\\t}\\n   686→\\treturn nil\\n   687→}\\n   688→\\n   689→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   690→// - Whether settings.json already exists\\n   691→// - The --local and --project flags\\n   692→// Returns (useLocal, showNotification).\\n   693→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   694→\\t// Explicit --local flag always uses local settings\\n   695→\\tif useLocal {\\n   696→\\t\\treturn true, false\\n   697→\\t}\\n   698→\\n   699→\\t// Explicit --project flag always uses project settings\\n   700→\\tif useProject {\\n   701→\\t\\treturn false, false\\n   702→\\t}\\n   703→\\n   704→\\t// No flags specified - check if settings file exists\\n   705→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   706→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   707→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   708→\\t\\treturn true, true\\n   709→\\t}\\n   710→\\n   711→\\t// Settings file doesn't exist - create it\\n   712→\\treturn false, false\\n   713→}\\n   714→\\n   715→// setupEntireDirectory creates the .entire directory and gitignore.\\n   716→// Returns true if the directory was created, false if it already existed.\\n   717→func setupEntireDirectory(ctx context.Context) (bool, error) { //nolint:unparam // already present in codebase\\n   718→\\t// Get absolute path for the .entire directory\\n   719→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   720→\\tif err != nil {\\n   721→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   722→\\t}\\n   723→\\n   724→\\t// Check if directory already exists\\n   725→\\tcreated := false\\n   726→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   727→\\t\\tcreated = true\\n   728→\\t}\\n   729→\\n   730→\\t// Create .entire directory\\n   731→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   732→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   733→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   734→\