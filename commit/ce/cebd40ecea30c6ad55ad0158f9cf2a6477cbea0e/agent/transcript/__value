les\\n    72→\\t// that still contain \\\"strategy\\\": \\\"auto-commit\\\" or similar.\\n    73→\\tStrategy string `json:\\\"strategy,omitempty\\\"`\\n    74→}\\n    75→\\n    76→// GetCommitLinking returns the effective commit linking mode.\\n    77→// Returns the explicit value if set, otherwise defaults to \\\"prompt\\\"\\n    78→// to preserve existing user behavior.\\n    79→func (s *EntireSettings) GetCommitLinking() string {\\n    80→\\tif s.CommitLinking != \\\"\\\" {\\n    81→\\t\\treturn s.CommitLinking\\n    82→\\t}\\n    83→\\treturn CommitLinkingPrompt\\n    84→}\\n    85→\\n    86→// Load loads the Entire settings from .entire/settings.json,\\n    87→// then applies any overrides from .entire/settings.local.json if it exists.\\n    88→// Returns default settings if neither file exists.\\n    89→// Works correctly from any subdirectory within the repository.\\n    90→func Load(ctx context.Context) (*EntireSettings, error) {\\n    91→\\t// Get absolute paths for settings files\\n    92→\\tsettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsFile)\\n    93→\\tif err != nil {\\n    94→\\t\\tsettingsFileAbs = EntireSettingsFile // Fallback to relative\\n    95→\\t}\\n    96→\\tlocalSettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsLocalFile)\\n    97→\\tif err != nil {\\n    98→\\t\\tlocalSettingsFileAbs = EntireSettingsLocalFile // Fallback to relative\\n    99→\\t}\\n   100→\\n   101→\\t// Load base settings\\n   102→\\tsettings, err := loadFromFile(settingsFileAbs)\\n   103→\\tif err != nil {\\n   104→\\t\\treturn nil, fmt.Errorf(\\\"reading settings file: %w\\\", err)\\n   105→\\t}\\n   106→\\n   107→\\t// Apply local overrides if they exist\\n   108→\\tlocalData, err := os.ReadFile(localSettingsFileAbs) //nolint:gosec // path is from AbsPath or constant\\n   109→\\tif err != nil {\\n   110→\\t\\tif !os.IsNotExist(err) {\\n   111→\\t\\t\\treturn nil, fmt.Errorf(\\\"reading local settings file: %w\\\", err)\\n   112→\\t\\t}\\n   113→\\t\\t// Local file doesn't exist, continue without overrides\\n   114→\\t} else {\\n   115→\\t\\tif err := mergeJSON(settings, localData); err != nil {\\n   116→\\t\\t\\treturn nil, fmt.Errorf(\\\"merging local settings: %w\\\", err)\\n   117→\\t\\t}\\n   118→\\t}\\n   119→\\n   120→\\treturn settings, nil\\n   121→}\\n   122→\\n   123→// LoadFromFile loads settings from a specific file path without merging local overrides.\\n   124→// Returns default settings if the file doesn't exist.\\n   125→// Use this when you need to display individual settings files separately.\\n   126→func LoadFromFile(filePath string) (*EntireSettings, error) {\\n   127→\\treturn loadFromFile(filePath)\\n   128→}\\n   129→\\n   130→// loadFromFile loads settings from a specific file path.\\n   131→// Returns default settings if the file doesn't exist.\\n   132→func loadFromFile(filePath string) (*EntireSettings, error) {\\n   133→\\tsettings := &EntireSettings{\\n   134→\\t\\tEnabled: true, // Default to enabled\\n   135→\\t}\\n   136→\\n   137→\\tdata, err := os.ReadFile(filePath) //nolint:gosec // path is from caller\\n   138→\\tif err != nil {\\n   139→\\t\\tif os.IsNotExist(err) {\\n   140→\\t\\t\\treturn settings, nil\\n   141→\\t\\t}\\n   142→\\t\\treturn nil, fmt.Errorf(\\\"%w\\\", err)\\n   143→\\t}\\n   144→\\n   145→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   146→\\tdec.DisallowUnknownFields()\\n   147→\\tif err := dec.Decode(settings); err != nil {\\n   148→\\t\\treturn nil, fmt.Errorf(\\\"parsing settings file: %w\\\", err)\\n   149→\\t}\\n   150→\\n   151→\\t// Validate commit_linking if set\\n   152→\\tif settings.CommitLinking != \\\"\\\" && settings.CommitLinking != CommitLinkingAlways && settings.CommitLinking != CommitLinkingPrompt {\\n   153→\\t\\treturn nil, fmt.Errorf(\\\"invalid commit_linking value %q: must be %q or %q\\\", settings.CommitLinking, CommitLinkingAlways, CommitLinkingPrompt)\\n   154→\\t}\\n   155→\\n   156→\\treturn settings, nil\\n   157→}\\n   158→\\n   159→// mergeJSON merges JSON data into existing settings.\\n   160→// Only non-zero values from the JSON override existing settings.\\n   161→func mergeJSON(settings *EntireSettings, data []byte) error {\\n   162→\\t// First, validate that there are no unknown keys using strict decoding\\n   163→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   164→\\tdec.DisallowUnknownFields()\\n   165→\\tvar temp EntireSettings\\n   166→\\tif err := dec.Decode(&temp); err != nil {\\n   167→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   168→\\t}\\n   169→\\n   170→\\t// Parse into a map to check which fields are present\\n   171→\\tvar raw map[string]json.RawMessage\\n   172→\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   173→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   174→\\t}\\n   175→\\n   176→\\t// Override enabled if present\\n   177→\\tif enabledRaw, ok := raw[\\\"enabled\\\"]; ok {\\n   178→\\t\\tvar e bool\\n   179→\\t\\tif err := json.Unmarshal(enabledRaw, &e); err != nil {\\n   180→\\t\\t\\treturn fmt.Errorf(\\\"parsing enabled field: %w\\\", err)\\n   181→\\t\\t}\\n   182→\\t\\tsettings.Enabled = e\\n   183→\\t}\\n   184→\\n   185→\\t// Override local_dev if present\\n   186→\\tif localDevRaw, ok := raw[\\\"local_dev\\\"]; ok {\\n   187→\\t\\tvar ld bool\\n   188→\\t\\tif err := json.Unmarshal(localDevRaw, &ld); err != nil {\\n   189→\\t\\t\\treturn fmt.Errorf(\\\"parsing local_dev field: %w\\\", err)\\n   190→\\t\\t}\\n   191→\\t\\tsettings.LocalDev = ld\\n   192→\\t}\\n   193→\\n   194→\\t// Override absolute_git_hook_path if present\\n   195→\\tif ahpRaw, ok := raw[\\\"absolute_git_hook_path\\\"]; ok {\\n   196→\\t\\tvar ahp bool\\n   197→\\t\\tif err := json.Unmarshal(ahpRaw, &ahp); err != nil {\\n   198→\\t\\t\\treturn fmt.Errorf(\\\"parsing absolute_git_hook_path field: %w\\\", err)\\n   199→\\t\\t}\\n   200→\\t\\tsettings.AbsoluteGitHookPath = ahp\\n   201→\\t}\\n   202→\\n   203→\\t// Override log_level if present and non-empty\\n   204→\\tif logLevelRaw, ok := raw[\\\"log_level\\\"]; ok {\\n   205→\\t\\tvar ll string\\n   206→\\t\\tif err := json.Unmarshal(logLevelRaw, &ll); err != nil {\\n   207→\\t\\t\\treturn fmt.Errorf(\\\"parsing log_level field: %w\\\", err)\\n   208→\\t\\t}\\n   209→\\t\\tif ll != \\\"\\\" {\\n   210→\\t\\t\\tsettings.LogLevel = ll\\n   211→\\t\\t}\\n   212→\\t}\\n   213→\\n   214→\\t// Merge strategy_options if present\\n   215→\\tif optionsRaw, ok := raw[\\\"strategy_options\\\"]; ok {\\n   216→\\t\\tvar opts map[string]any\\n   217→\\t\\tif err := json.Unmarshal(optionsRaw, &opts); err != nil {\\n   218→\\t\\t\\treturn fmt.Errorf(\\\"parsing strategy_options field: %w\\\", err)\\n   219→\\t\\t}\\n   220→\\t\\tif settings.StrategyOptions == nil {\\n   221→\\t\\t\\tsettings.StrategyOptions = opts\\n   222→\\t\\t} else {\\n   223→\\t\\t\\tfor k, v := range opts {\\n   224→\\t\\t\\t\\tsettings.StrategyOptions[k] = v\\n   225→\\t\\t\\t}\\n   226→\\t\\t}\\n   227→\\t}\\n   228→\\n   229→\\t// Override telemetry if present\\n   230→\\tif telemetryRaw, ok := raw[\\\"telemetry\\\"]; ok {\\n   231→\\t\\tvar t bool\\n   232→\\t\\tif err := json.Unmarshal(telemetryRaw, &t); err != nil {\\n   233→\\t\\t\\treturn fmt.Errorf(\\\"parsing telemetry field: %w\\\", err)\\n   234→\\t\\t}\\n   235→\\t\\tsettings.Telemetry = &t\\n   236→\\t}\\n   237→\\n   238→\\t// Override commit_linking if present and non-empty\\n   239→\\tif commitLinkingRaw, ok := raw[\\\"commit_linking\\\"]; ok {\\n   240→\\t\\tvar cl string\\n   241→\\t\\tif err := json.Unmarshal(commitLinkingRaw, &cl); err != nil {\\n   242→\\t\\t\\treturn fmt.Errorf(\\\"parsing commit_linking field: %w\\\", err)\\n   243→\\t\\t}\\n   244→\\t\\tif cl != \\\"\\\" {\\n   245→\\t\\t\\tswitch cl {\\n   246→\\t\\t\\tcase CommitLinkingAlways, CommitLinkingPrompt:\\n   247→\\t\\t\\t\\tsettings.CommitLinking = cl\\n   248→\\t\\t\\tdefault:\\n   249→\\t\\t\\t\\treturn fmt.Errorf(\\\"invalid commit_linking value %q: must be %q or %q\\\", cl, CommitLinkingAlways, CommitLinkingPrompt)\\n   250→\\t\\t\\t}\\n   251→\\t\\t}\\n   252→\\t}\\n   253→\\n   254→\\t// Override external_agents if present\\n   255→\\tif externalAgentsRaw, ok := raw[\\\"external_agents\\\"]; ok {\\n   256→\\t\\tvar ea bool\\n   257→\\t\\tif err := json.Unmarshal(externalAgentsRaw, &ea); err != nil {\\n   258→\\t\\t\\treturn fmt.Errorf(\\\"parsing external_agents field: %w\\\", err)\\n   259→\\t\\t}\\n   260→\\t\\tsettings.ExternalAgents = ea\\n   261→\\t}\\n   262→\\n   263→\\treturn nil\\n   264→}\\n   265→\\n   266→// IsSetUp returns true if Entire has been set up in the current repository.\\n   267→// This checks if .entire/settings.json exists.\\n   268→// Use this to avoid creating files/directories in repos where Entire was never enabled.\\n   269→func IsSetUp(ctx context.Context) bool {\\n   270→\\tsettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsFile)\\n   271→\\tif err != nil {\\n   272→\\t\\treturn false\\n   273→\\t}\\n   274→\\t_, err = os.Stat(settingsFileAbs)\\n   275→\\treturn err == nil\\n   276→}\\n   277→\\n   278→// IsSetUpAndEnabled returns true if Entire is both set up and enabled.\\n   279→// This checks if .entire/settings.json exists AND has enabled: true.\\n   280→// Use this for hooks that should be no-ops when Entire is not active.\\n   281→func IsSetUpAndEnabled(ctx context.Context) bool {\\n   282→\\tif !IsSetUp(ctx) {\\n   283→\\t\\treturn false\\n   284→\\t}\\n   285→\\ts, err := Load(ctx)\\n   286→\\tif err != nil {\\n   287→\\t\\treturn false\\n   288→\\t}\\n   289→\\treturn s.Enabled\\n   290→}\\n   291→\\n   292→// IsSummarizeEnabled checks if auto-summarize is enabled in settings.\\n   293→// Returns false by default if settings cannot be loaded or the key is missing.\\n   294→func IsSummarizeEnabled(ctx context.Context) bool {\\n   295→\\tsettings, err := Load(ctx)\\n   296→\\tif err != nil {\\n   297→\\t\\treturn false\\n   298→\\t}\\n   299→\\treturn settings.IsSummarizeEnabled()\\n   300→}\\n   301→\\n   302→// IsSummarizeEnabled checks if auto-summarize is enabled in this settings instance.\\n   303→func (s *EntireSettings) IsSummarizeEnabled() bool {\\n   304→\\tif s.StrategyOptions == nil {\\n   305→\\t\\treturn false\\n   306→\\t}\\n   307→\\tsummarizeOpts, ok := s.StrategyOptions[\\\"summarize\\\"].(map[string]any)\\n   308→\\tif !ok {\\n   309→\\t\\treturn false\\n   310→\\t}\\n   311→\\tenabled, ok := summarizeOpts[\\\"enabled\\\"].(bool)\\n   312→\\tif !ok {\\n   313→\\t\\treturn false\\n   314→\\t}\\n   315→\\treturn enabled\\n   316→}\\n   317→\\n   318→// CheckpointRemoteConfig holds the structured checkpoint remote configuration.\\n   319→// Stored in strategy_options.checkpoint_remote as {\\\"provider\\\": \\\"github\\\", \\\"repo\\\": \\\"org/repo\\\"}.\\n   320→type CheckpointRemoteConfig struct {\\n   321→\\tProvider string // e.g., \\\"github\\\"\\n   322→\\tRepo     string // e.g., \\\"org/checkpoints-repo\\\"\\n   323→}\\n   324→\\n   325→// Owner returns the owner portion of the repo field (before the slash).\\n   326→// Returns empty string if the repo field doesn't contain a slash.\\n   327→func (c *CheckpointRemoteConfig) Owner() string {\\n   328→\\tparts := strings.SplitN(c.Repo, \\\"/\\\", 2)\\n   329→\\tif len(parts) < 2 {\\n   330→\\t\\treturn \\\"\\\"\\n   331→\\t}\\n   332→\\treturn parts[0]\\n   333→}\\n   334→\\n   335→// GetCheckpointRemote returns the configured checkpoint remote.\\n   336→// Expects a structured object: {\\\"provider\\\": \\\"github\\\", \\\"repo\\\": \\\"org/repo\\\"}.\\n   337→// Returns nil if not configured, wrong type, or missing required fields.\\n   338→func (s *EntireSettings) GetCheckpointRemote() *CheckpointRemoteConfig {\\n   339→\\tif s.StrategyOptions == nil {\\n   340→\\t\\treturn nil\\n   341→\\t}\\n   342→\\tval, ok := s.StrategyOptions[\\\"checkpoint_remote\\\"]\\n   343→\\tif !ok {\\n   344→\\t\\treturn nil\\n   345→\\t}\\n   346→\\tm, ok := val.(map[string]any)\\n   347→\\tif !ok {\\n   348→\\t\\treturn nil\\n   349→\\t}\\n   350→\\tprovider, providerOK := m[\\\"provider\\\"].(string)\\n   351→\\trepo, repoOK := m[\\\"repo\\\"].(string)\\n   352→\\tif !providerOK || !repoOK || provider == \\\"\\\" || repo == \\\"\\\" {\\n   353→\\t\\treturn nil\\n   354→\\t}\\n   355→\\tif !strings.Contains(repo, \\\"/\\\") {\\n   356→\\t\\treturn nil\\n   357→\\t}\\n   358→\\treturn &CheckpointRemoteConfig{Provider: provider, Repo: repo}\\n   359→}\\n   360→\\n   361→// IsPushSessionsDisabled checks if push_sessions is disabled in settings.\\n   362→// Returns true if push_sessions is explicitly set to false.\\n   363→func (s *EntireSettings) IsPushSessionsDisabled() bool {\\n   364→\\tif s.StrategyOptions == nil {\\n   365→\\t\\treturn false\\n   366→\\t}\\n   367→\\tval, exists := s.StrategyOptions[\\\"push_sessions\\\"]\\n   368→\\tif !exists {\\n   369→\\t\\treturn false\\n   370→\\t}\\n   371→\\tif boolVal, ok := val.(bool); ok {\\n   372→\\t\\treturn !boolVal // disabled = !push_sessions\\n   373→\\t}\\n   374→\\treturn false\\n   375→}\\n   376→\\n   377→// IsExternalAgentsEnabled checks if external agent discovery is enabled in settings.\\n   378→// Returns false by default if settings cannot be loaded or the key is missing.\\n   379→func IsExternalAgentsEnabled(ctx context.Context) bool {\\n   380→\\ts, err := Load(ctx)\\n   381→\\tif err != nil {\\n   382→\\t\\treturn false\\n   383→\\t}\\n   384→\\treturn s.ExternalAgents\\n   385→}\\n   386→\\n   387→// Save saves the settings to .entire/settings.json.\\n   388→func Save(ctx context.Context, settings *EntireSettings) error {\\n   389→\\treturn saveToFile(ctx, settings, EntireSettingsFile)\\n   390→}\\n   391→\\n   392→// SaveLocal saves the settings to .entire/settings.local.json.\\n   393→func SaveLocal(ctx context.Context, settings *EntireSettings) error {\\n   394→\\treturn saveToFile(ctx, settings, EntireSettingsLocalFile)\\n   395→}\\n   396→\\n   397→// saveToFil