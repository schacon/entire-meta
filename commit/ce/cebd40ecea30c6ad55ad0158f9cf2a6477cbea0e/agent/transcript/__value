4→\\t}\\n   205→\\treturn parts[0], parts[1], nil\\n   206→}\\n   207→\\n   208→// deriveCheckpointURL constructs a checkpoint remote URL using the same protocol\\n   209→// as the push remote. For example, if push remote uses SSH, the checkpoint URL\\n   210→// will also use SSH.\\n   211→func deriveCheckpointURL(pushRemoteURL string, config *settings.CheckpointRemoteConfig) (string, error) {\\n   212→\\tinfo, err := parseGitRemoteURL(pushRemoteURL)\\n   213→\\tif err != nil {\\n   214→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"cannot parse push remote URL: %w\\\", err)\\n   215→\\t}\\n   216→\\treturn deriveCheckpointURLFromInfo(info, config)\\n   217→}\\n   218→\\n   219→// deriveCheckpointURLFromInfo constructs a checkpoint URL from already-parsed remote info.\\n   220→func deriveCheckpointURLFromInfo(info *gitRemoteInfo, config *settings.CheckpointRemoteConfig) (string, error) {\\n   221→\\tswitch info.protocol {\\n   222→\\tcase protocolSSH:\\n   223→\\t\\t// SCP format: git@host:owner/repo.git\\n   224→\\t\\treturn fmt.Sprintf(\\\"git@%s:%s.git\\\", info.host, config.Repo), nil\\n   225→\\tcase protocolHTTPS:\\n   226→\\t\\treturn fmt.Sprintf(\\\"https://%s/%s.git\\\", info.host, config.Repo), nil\\n   227→\\tdefault:\\n   228→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"unsupported protocol %q in push remote\\\", info.protocol)\\n   229→\\t}\\n   230→}\\n   231→\\n   232→// extractOwnerFromRemoteURL extracts the owner from a git remote URL.\\n   233→// Returns empty string if the URL cannot be parsed.\\n   234→func extractOwnerFromRemoteURL(rawURL string) string {\\n   235→\\tinfo, err := parseGitRemoteURL(rawURL)\\n   236→\\tif err != nil {\\n   237→\\t\\treturn \\\"\\\"\\n   238→\\t}\\n   239→\\treturn info.owner\\n   240→}\\n   241→\\n   242→// getRemoteURL returns the URL configured for a git remote.\\n   243→func getRemoteURL(ctx context.Context, remoteName string) (string, error) {\\n   244→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"remote\\\", \\\"get-ur