→\\t}\\n   354→\\t_, err := git.PlainInit(dir, false)\\n   355→\\trequire.NoError(t, err)\\n   356→\\tt.Chdir(dir)\\n   357→\\tClearGitCommonDirCache()\\n   358→\\treturn dir\\n   359→}\\n   360→\\n   361→func TestGetGitCommonDir_ReturnsValidPath(t *testing.T) {\\n   362→\\tdir := initTestRepo(t)\\n   363→\\n   364→\\tcommonDir, err := getGitCommonDir(context.Background())\\n   365→\\trequire.NoError(t, err)\\n   366→\\n   367→\\t// getGitCommonDir returns a relative path from cwd; resolve it to absolute for comparison\\n   368→\\tabsCommonDir, err := filepath.Abs(commonDir)\\n   369→\\trequire.NoError(t, err)\\n   370→\\tassert.Equal(t, filepath.Join(dir, \\\".git\\\"), absCommonDir)\\n   371→\\n   372→\\t// The path should actually exist\\n   373→\\tinfo, err := os.Stat(commonDir)\\n   374→\\trequire.NoError(t, err)\\n   375→\\tassert.True(t, info.IsDir())\\n   376→}\\n   377→\\n   378→func TestGetGitCommonDir_CachesResult(t *testing.T) {\\n   379→\\tinitTestRepo(t)\\n   380→\\n   381→\\t// First call populates cache\\n   382→\\tfirst, err := getGitCommonDir(context.Background())\\n   383→\\trequire.NoError(t, err)\\n   384→\\n   385→\\t// Second call should return the same result (from cache)\\n   386→\\tsecond, err := getGitCommonDir(context.Background())\\n   387→\\trequire.NoError(t, err)\\n   388→\\n   389→\\tassert.Equal(t, first, second)\\n   390→}\\n   391→\\n   392→func TestGetGitCommonDir_ClearCache(t *testing.T) {\\n   393→\\tinitTestRepo(t)\\n   394→\\n   395→\\t// Populate cache\\n   396→\\t_, err := getGitCommonDir(context.Background())\\n   397→\\trequire.NoError(t, err)\\n   398→\\n   399→\\t// Verify cache is populated\\n   400→\\tgitCommonDirMu.RLock()\\n   401→\\tassert.NotEmpty(t, gitCommonDirCache)\\n   402→\\tgitCommonDirMu.RUnlock()\\n   403→\\n   404→\\t// Clear and verify\\n   405→\\tClearGitCommonDirCache()\\n   406→\\n   407→\\tgitCommonDirMu.RLock()\\n   408→\\tassert.Empty(t, gitCommonDirCache)\\n   409→\\tassert.Empty(t, gitCommonDirC