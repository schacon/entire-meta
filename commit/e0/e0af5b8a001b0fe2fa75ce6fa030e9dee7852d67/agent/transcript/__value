→\\t\\tmaxSkew      = 2 * time.Second\\n   201→\\t)\\n   202→\\n   203→\\tlogCtx := logging.WithComponent(ctx, \\\"agent.claudecode\\\")\\n   204→\\n   205→\\t// Fast path: skip the poll loop when the sentinel can't possibly appear.\\n   206→\\t// - File doesn't exist: nothing to poll.\\n   207→\\t// - File is stale (unmodified for 2+ min): agent isn't running anymore.\\n   208→\\t//   This avoids 3s timeouts per stale \\\"active\\\" session (e.g., agent crashed\\n   209→\\t//   without firing stop hook).\\n   210→\\tconst staleThreshold = 2 * time.Minute\\n   211→\\tinfo, err := os.Stat(transcriptPath)\\n   212→\\tif err != nil {\\n   213→\\t\\t// Most likely the file doesn't exist; other errors (permission, etc.)\\n   214→\\t\\t// would also prevent polling, so skip the wait either way.\\n   215→\\t\\treturn\\n   216→\\t}\\n   217→\\tfileAge := time.Since(info.ModTime())\\n   218→\\tif fileAge > staleThreshold {\\n   219→\\t\\tlogging.Debug(logCtx, \\\"transcript file is stale, skipping sentinel wait\\\",\\n   220→\\t\\t\\tslog.Duration(\\\"file_age\\\", fileAge),\\n   221→\\t\\t)\\n   222→\\t\\treturn\\n   223→\\t}\\n   224→\\n   225→\\tdeadline := time.Now().Add(maxWait)\\n   226→\\tfor time.Now().Before(deadline) {\\n   227→\\t\\tif checkStopSentinel(transcriptPath, tailBytes, hookStartTime, maxSkew) {\\n   228→\\t\\t\\tlogging.Debug(logCtx, \\\"transcript flush sentinel found\\\",\\n   229→\\t\\t\\t\\tslog.Duration(\\\"wait\\\", time.Since(hookStartTime)),\\n   230→\\t\\t\\t)\\n   231→\\t\\t\\treturn\\n   232→\\t\\t}\\n   233→\\t\\ttime.Sleep(pollInterval)\\n   234→\\t}\\n   235→\\tlogging.Warn(logCtx, \\\"transcript flush sentinel not found within timeout, proceeding\\\",\\n   236→\\t\\tslog.Duration(\\\"timeout\\\", maxWait),\\n   237→\\t)\\n   238→}\\n   239→\\n   240→// checkStopSentinel reads the tail of the transcript file and looks for the sentinel.\\n   241→func checkStopSentinel(path string, tailBytes int64, hookStartTime time.Time, maxSkew time.Durat