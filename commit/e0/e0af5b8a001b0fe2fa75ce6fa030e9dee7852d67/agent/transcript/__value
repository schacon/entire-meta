→}\\n   778→\\n   779→// parseTranscriptForCheckpointUUID is a thin wrapper around transcript parsing for checkpoint UUID lookup.\\n   780→// Returns parsed transcript lines for use with FindCheckpointUUID.\\n   781→func parseTranscriptForCheckpointUUID(transcriptPath string) ([]transcriptLine, error) {\\n   782→\\tlines, err := transcript.ParseFromFileAtLine(transcriptPath, 0)\\n   783→\\tif err != nil {\\n   784→\\t\\treturn nil, fmt.Errorf(\\\"parsing transcript for checkpoint UUID: %w\\\", err)\\n   785→\\t}\\n   786→\\treturn lines, nil\\n   787→}\\n   788→\\n   789→// transitionSessionTurnEnd transitions the session phase to IDLE and dispatches turn-end actions.\\n   790→func transitionSessionTurnEnd(ctx context.Context, sessionID string, event *agent.Event) {\\n   791→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   792→\\tturnState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   793→\\tif loadErr != nil {\\n   794→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for turn end\\\",\\n   795→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   796→\\t\\treturn\\n   797→\\t}\\n   798→\\tif turnState == nil {\\n   799→\\t\\treturn\\n   800→\\t}\\n   801→\\n   802→\\tpersistEventMetadataToState(event, turnState)\\n   803→\\n   804→\\tif err := strategy.TransitionAndLog(ctx, turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   805→\\t\\tlogging.Warn(logCtx, \\\"turn-end transition failed\\\",\\n   806→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   807→\\t}\\n   808→\\n   809→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   810→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   811→\\tstrat := GetStrategy(ctx)\\n   812→\\tif err := strat.HandleTurnEnd(ctx, turnState); err != nil {\\n   813→\\t\\tlogging.Warn(logCtx, \\\"turn-end action dispatch failed\\\",\\n   814→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   815→\\t}\\n   816→\\n   817→\\tif updateErr := strategy.SaveSessionState(ctx, turnState); updateErr != nil {\\n   818→\\t\\tlogging.Warn(logCtx, \\\"failed to update session phase on turn end\\\",\\n   819→\\t\\t\\tslog.String(\\\"error\\\", updateErr.Error()))\\n   820→\\t}\\n   821→}\\n   822→\\n   823→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   824→// If event is non-nil, hook-provided metrics are persisted to state before saving.\\n   825→func markSessionEnded(ctx context.Context, event *agent.Event, sessionID string) error {\\n   826→\\tstate, err := strategy.LoadSessionState(ctx, sessionID)\\n   827→\\tif err != nil {\\n   828→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   829→\\t}\\n   830→\\tif state == nil {\\n   831→\\t\\treturn nil // No state file, nothing to update\\n   832→\\t}\\n   833→\\n   834→\\tif event != nil {\\n   835→\\t\\tpersistEventMetadataToState(event, state)\\n   836→\\t}\\n   837→\\n   838→\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStop, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   839→\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"lifecycle\\\"), \\\"session stop transition failed\\\",\\n   840→\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   841→\\t}\\n   842→\\n   843→\\tnow := time.Now()\\n   844→\\tstate.EndedAt = &now\\n   845→\\n   846→\\tif err := strategy.SaveSessionState(ctx, state); err != nil {\\n   847→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   848→\\t}\\n   849→\\treturn nil\\n   850→}\\n   851→\\n   852→// logFileChanges logs the files modified, created, and deleted during a session.\\n   853→func logFileChanges(ctx context.Context, modified, newFiles, deleted []string) {\\n   854→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   855→\\tlogging.Debug(logCtx, \\\"files changed during session\\\",\\n   856→\\t\\tslog.Int(\\\"modified\\\", len(modified)),\\n   857→\\t\\tslog.Int(\\\"new\\\", len(newFiles)),\\n   858→\\t\\tslog.Int(\\\"deleted\\\", len(deleted)))\\n   859→}\\n   860→\\n   861→func persistEventMetadataToState(event *agent.Event, state *strategy.SessionState) {\\n   862→\\t// Update ModelName if provided (model is known by turn-end even on first turn)\\n   863→\\tif event.Model != \\\"\\\" {\\n   864→\\t\\tstate.ModelName = event.Model\\n   865→\\t}\\n   866→\\n   867→\\t// Persist hook-provided session metrics (e.g., from Cursor hooks)\\n   868→\\tif event.DurationMs > 0 {\\n   869→\\t\\tstate.SessionDurationMs = event.DurationMs\\n   870→\\t}\\n   871→\\t// Use hook-reported turn count if available (take max); otherwise\\n   872→\\t// increment on each TurnEnd event to count turns ourselves.\\n   873→\\tif event.TurnCount > 0 {\\n   874→\\t\\tif event.TurnCount > state.SessionTurnCount {\\n   875→\\t\\t\\tstate.SessionTurnCount = event.TurnCount\\n   876→\\t\\t}\\n   877→\\t} else if event.Type == agent.TurnEnd {\\n   878→\\t\\tstate.SessionTurnCount++\\n   879→\\t}\\n   880→\\tif event.ContextTokens > 0 {\\n   881→\\t\\tstate.ContextTokens = event.ContextTokens\\n   882→\\t}\\n   883→\\tif event.ContextWindowSize > 0 {\\n   884→\\t\\tstate.ContextWindowSize = event.ContextWindowSize\\n   885→\\t}\\n   886→}\\n   887→\"}]},\"uuid\":\"7159bd7b-a0b0-4b24-8d03-def4635c41a3\",\"timestamp\":\"2026-03-06T11:16:37.941Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"abd50e26f16d90c3e\"},\"toolUseID\":\"agent_msg_01BsT38Gx3vhXAvrcbgSQwMa\",\"parentToolUseID\":\"toolu_0131RLMC7tbZsezgEjPvo5SY\",\"uuid\":\"f6c17de8-325c-4755-9721-4b43ec3f4123\",\"timestamp\":\"2026-03-06T11:16:37.998Z\"}\n{\"parentUuid\":\"f6c17de8-325c-4755-9721-4b43ec3f4123\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/3\",\"sessionId\":\"dea70cd3-7d26-4a70-bb09-351dff609a65\",\"version\":\"2.1.70\",\"gitBranch\":\"refactoring-tr