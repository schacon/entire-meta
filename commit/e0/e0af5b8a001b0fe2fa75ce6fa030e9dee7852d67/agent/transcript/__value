in io.Reader) (*agent.Event, error) {\\n   100→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   101→\\tif err != nil {\\n   102→\\t\\treturn nil, err\\n   103→\\t}\\n   104→\\treturn &agent.Event{\\n   105→\\t\\tType:       agent.SessionStart,\\n   106→\\t\\tSessionID:  raw.SessionID,\\n   107→\\t\\tSessionRef: raw.TranscriptPath,\\n   108→\\t\\tModel:      raw.Model,\\n   109→\\t\\tTimestamp:  time.Now(),\\n   110→\\t}, nil\\n   111→}\\n   112→\\n   113→func (c *ClaudeCodeAgent) parseTurnStart(stdin io.Reader) (*agent.Event, error) {\\n   114→\\traw, err := agent.ReadAndParseHookInput[userPromptSubmitRaw](stdin)\\n   115→\\tif err != nil {\\n   116→\\t\\treturn nil, err\\n   117→\\t}\\n   118→\\treturn &agent.Event{\\n   119→\\t\\tType:       agent.TurnStart,\\n   120→\\t\\tSessionID:  raw.SessionID,\\n   121→\\t\\tSessionRef: raw.TranscriptPath,\\n   122→\\t\\tPrompt:     raw.Prompt,\\n   123→\\t\\tTimestamp:  time.Now(),\\n   124→\\t}, nil\\n   125→}\\n   126→\\n   127→func (c *ClaudeCodeAgent) parseTurnEnd(stdin io.Reader) (*agent.Event, error) {\\n   128→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   129→\\tif err != nil {\\n   130→\\t\\treturn nil, err\\n   131→\\t}\\n   132→\\treturn &agent.Event{\\n   133→\\t\\tType:       agent.TurnEnd,\\n   134→\\t\\tSessionID:  raw.SessionID,\\n   135→\\t\\tSessionRef: raw.TranscriptPath,\\n   136→\\t\\tTimestamp:  time.Now(),\\n   137→\\t}, nil\\n   138→}\\n   139→\\n   140→func (c *ClaudeCodeAgent) parseSessionEnd(stdin io.Reader) (*agent.Event, error) {\\n   141→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   142→\\tif err != nil {\\n   143→\\t\\treturn nil, err\\n   144→\\t}\\n   145→\\treturn &agent.Event{\\n   146→\\t\\tType:       agent.SessionEnd,\\n   147→\\t\\tSessionID:  raw.SessionID,\\n   148→\\t\\tSessionRef: raw.TranscriptPath,\\n   149→\\t\\tTimestamp:  time.Now(),\\n   150→\\t}, nil\\n   151→}\\n   152→\\n   153→func (c *ClaudeCodeAgent)