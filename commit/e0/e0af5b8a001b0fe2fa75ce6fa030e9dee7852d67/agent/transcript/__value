ny agent to the appropriate framework actions.\\n     3→//\\n     4→// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n     5→// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n     6→// the dispatcher handles all orchestration: state transitions, strategy calls,\\n     7→// file change detection, metadata generation.\\n     8→package cli\\n     9→\\n    10→import (\\n    11→\\t\\\"context\\\"\\n    12→\\t\\\"errors\\\"\\n    13→\\t\\\"fmt\\\"\\n    14→\\t\\\"log/slog\\\"\\n    15→\\t\\\"os\\\"\\n    16→\\t\\\"path/filepath\\\"\\n    17→\\t\\\"time\\\"\\n    18→\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    22→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    23→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    25→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    26→\\t\\\"github.com/entireio/cli/perf\\\"\\n    27→)\\n    28→\\n    29→// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n    30→// Returns nil if the event was handled successfully.\\n    31→func DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    32→\\tif ag == nil {\\n    33→\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    34→\\t}\\n    35→\\tif event == nil {\\n    36→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    37→\\t}\\n    38→\\n    39→\\tswitch event.Type {\\n    40→\\tcase agent.SessionStart:\\n    41→\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n    42→\\tcase agent.TurnStart:\\n    43→\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n    44→\\tcase agent.TurnEnd:\\n    45→\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n    46→\\tcase agent.Compaction:\\n    47→\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n    48→\\tcase agent.SessionEnd:\\n    49→\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n    50→\\tcase agent.SubagentStart:\\n    51→\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n    52→\\tcase agent.SubagentEnd:\\n    53→\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n    54→\\tcase agent.ModelUpdate:\\n    55→\\t\\treturn handleLifecycleModelUpdate(ctx, ag, event)\\n    56→\\tcase agent.FileEdit:\\n    57→\\t\\treturn handleLifecycleFileEdit(ctx, ag, event)\\n    58→\\tdefault:\\n    59→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    60→\\t}\\n    61→}\\n    62→\\n    63→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    64→// fires state machine transition.\\n    65→func handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    66→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n    67→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    68→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    69→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    70→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    71→\\t\\tslog.String(\\\"model\\\", event.Model),\\n    72→\\t)\\n    73→\\n    74→\\tif event.SessionID == \\\"\\\" {\\n    75→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    76→\\t}\\n    77→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    78→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    79→\\t}\\n    80→\\n    81→\\t// Build informational message\\n    82→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    83→\\n    84→\\t// Check for concurrent sessions and append count if any\\n    85→\\t_, countSessionsSpan := perf.Start(ctx, \\\"count_active_sessions\\\")\\n    86→\\tstrat := GetStrategy(ctx)\\n    87→\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n    88→\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    89→\\t}\\n    90→\\tcountSessionsSpan.End()\\n    91→\\n    92→\\t// Output informational message if the agent supports hook responses.\\n    93→\\t// Claude Code reads JSON from stdout; agents that don't implement\\n    94→\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n    95→\\t_, hookResponseSpan := perf.Start(ctx, \\\"write_hook_response\\\")\\n    96→\\tif event.ResponseMessage != \\\"\\\" {\\n    97→\\t\\tmessage = event.ResponseMessage\\n    98→\\t}\\n    99→\\tif writer, ok := agent.AsHookResponseWriter(ag); ok {\\n   100→\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n   101→\\t\\t\\thookResponseSpan.RecordError(err)\\n   102→\\t\\t\\thookResponseSpan.End()\\n   103→\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n   104→\\t\\t}\\n   105→\\t}\\n   106→\\thookResponseSpan.End()\\n   107→\\n   108→\\t// Store model hint if the agent provided model info on SessionStart\\n   109→\\tif event.Model != \\\"\\\" {\\n   110→\\t\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n   111→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint on session start\\\",\\n   112→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   113→\\t\\t}\\n   114→\\t}\\n   115→\\n   116→\\t// Fire EventSessionStart for the current session (if state exists).\\n   117→\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n   118→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n   119→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   120→\\t} else if state != nil {\\n   121→\\t\\tpersistEventMetadataToState(event, state)\\n   122→\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   123→\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n   124→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   125→\\t\\t}\\n   126→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   127→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n   128→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   129→\\t\\t}\\n   130→\\t}\\n   131→\\n   132→\\treturn nil\\n   133→}\\n   134→\\n   135→// handleLifecycleModelUpdate persists the model name for the current session.\\n   136→//\\n   137→// If the session state file already exists (e.g., Gemini's BeforeModel fires\\n   138→// after TurnStart), the model is written directly to state.ModelName — no hint\\n   139→// file needed. Otherwise falls back to StoreModelHint for cross-process\\n   140→// persistence (see its doc comment for the full rationale).\\n   141→func handleLifecycleModelUpdate(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   142→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   143→\\tlogging.Info(logCtx, \\\"model-update\\\",\\n   144→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   145→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   146→\\t)\\n   147→\\n   148→\\tif event.SessionID == \\\"\\\" || event.Model == \\\"\\\" {\\n   149→\\t\\treturn nil\\n   150→\\t}\\n   151→\\n   152→\\t// Prefer writing directly to session state when it exists\\n   153→\\tstate, loadErr := strategy.LoadSessionState(ctx, event.SessionID)\\n   154→\\tif loadErr != nil {\\n   155→\\t\\tlogging.Debug(logCtx, \\\"could not load session state for model update, using hint file\\\",\\n   156→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   157→\\t}\\n   158→\\tif loadErr == nil && state != nil {\\n   159→\\t\\tstate.ModelName = event.Model\\n   160→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   161→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state with model\\\",\\n   162→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   163→\\t\\t}\\n   164→\\t\\treturn nil\\n   165→\\t}\\n   166→\\n   167→\\t// State doesn't exist yet (or failed to load) — use hint file (see StoreModelHint doc)\\n   168→\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n   169→\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint\\\",\\n   170→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   171→\\t}\\n   172→\\n   173→\\treturn nil\\n   174→}\\n   175→\\n   176→// handleLifecycleFileEdit appends a file path to the session's tracking file.\\n   177→// This is intentionally lightweight — no JSON state loading, just a file append.\\n   178→func handleLifecycleFileEdit(ctx context.Context, _ agent.Agent, event *agent.Event) error {\\n   179→\\tif event.SessionID == \\\"\\\" || event.FilePath == \\\"\\\" {\\n   180→\\t\\treturn nil\\n   181→\\t}\\n   182→\\n   183→\\t// Normalize to repo-relative path\\n   184→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   185→\\tif err != nil {\\n   186→\\t\\treturn nil //nolint:nilerr // can't normalize path outside git repo, skip silently\\n   187→\\t}\\n   188→\\n   189→\\trelPath := paths.ToRelativePath(event.FilePath, repoRoot)\\n   190→\\tif relPath == \\\"\\\" {\\n   191→\\t\\treturn nil // path outside repo, skip\\n   192→\\t}\\n   193→\\n   194→\\tstore, err := session.NewStateStore(ctx)\\n   195→\\tif err != nil {\\n   196→\\t\\treturn nil //nolint:nilerr // can't access state store, skip silently\\n   197→\\t}\\n   198→\\n   199→\\tif appendErr := store.AppendFileTouched(ctx, event.SessionID, relPath); appendErr != nil {\\n   200→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   201→\\t\\tlogging.Warn(logCtx, \\\"failed to track file edit\\\",\\n   202→\\t\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   203→\\t\\t\\tslog.String(\\\"file_path\\\", relPath),\\n   204→\\t\\t\\tslog.String(\\\"error\\\", appendErr.Error()),\\n   205→\\t\\t)\\n   206→\\t}\\n   207→\\n   208→\\treturn nil\\n   209→}\\n   210→\\n   211→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   212→// ensures strategy setup, initializes session.\\n   213→func handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   214→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   215→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   216→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   217→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   218→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   219→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   220→\\t)\\n   221→\\n   222→\\tsessionID := event.SessionID\\n   223→\\tif sessionID == \\\"\\\" {\\n   224→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   225→\\t}\\n   226→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   227→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   228→\\t}\\n   229→\\n   230→\\t// Fill model from hint file if the agent didn't provide it on this hook\\n   231→\\tif event.Model == \\\"\\\" {\\n   232→\\t\\tif hint := strategy.LoadModelHint(ctx, sessionID); hint != \\\"\\\" {\\n   233→\\t\\t\\tevent.Model = hint\\n   234→\\t\\t\\tlogging.Debug(logCtx, \\\"loaded model from hint file\\\",\\n   235→\\t\\t\\t\\tslog.String(\\\"model\\\", hint))\\n   236→\\t\\t}\\n   237→\\t}\\n   238→\\n   239→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   240→\\t_, captureSpan := perf.Start(ctx, \\\"capture_pre_prompt_state\\\")\\n   241→\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n   242→\\t\\tcaptureSpan.RecordError(err)\\n   243→\\t\\tcaptureSpan.End()\\n   244→\\t\\treturn err\\n   245→\\t}\\n   246→\\tcaptureSpan.End()\\n   247→\\n   248→\\t// Append prompt to prompt.txt on filesystem so it's available for\\n   249→\\t// mid-turn commits (before SaveStep writes it to the shadow branch).\\n   250→\\t// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\" to support multiple turns.\\n   251→\\tif event.Prompt != \\\"\\\" {\\n   252→\\t\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   253→\\t\\tif sessionDirAbs, absErr := paths.AbsPath(ctx, sessionDir); absErr == nil {\\n   254→\\t\\t\\tif mkErr := os.MkdirAll(sessionDirAbs, 0o750); mkErr == nil {\\n   255→\\t\\t\\t\\tpromptPath := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   256→\\t\\t\\t\\texisting, readErr := os.ReadFile(promptPath) //nolint:gosec // session metadata path\\n   257→\\t\\t\\t\\tvar content string\\n   258→\\t\\t\\t\\tif readErr == nil && len(existing) > 0 {\\n   259→\\t\\t\\t\\t\\tcontent = string(existing) + \\\"\\\\n\\\\n---\\\\n\\\\n\\\" + event.Prompt\\n   260→\\t\\t\\t\\t} else {\\n   261→\\t\\t\\t\\t\\tcontent = event.Prompt\\n   262→\\t\\t\\t\\t}\\n   263→\\t\\t\\t\\tif writeErr := os.WriteFile(promptPath, []byte(content), 0o600); writeErr != nil {\\n   264→\\t\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to write prompt.txt\\\",\\n   265→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", writeErr.Error()))\\n   266→\\t\\t\\t\\t}\\n   267→\\t\\t\\t}\\n   268→\\t\\t}\\n   269→\\t}\\n   270→\\n   271→\\t// Ensure strategy setup and initialize session\\n   272→\\t_, initSpan := perf.Start(ctx, \\\"init_session\\\")\\n   273→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   274→\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n   275→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   276→\\t}\\n   277→\\n   278→\\tstrat := GetStrategy(ctx)\\n   279→\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt, event.Model); err != nil {\\n   280→\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n   281→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   282→\\t}\\n   283→\\tinitSpan.End()\\n   284→\\n   285→\\treturn nil\\n   286→}\\n   287→\\n   288→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   289→// detects file changes, saves step + checkpoint, transitions phase.\\n   290→//\\n   291→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   292→func handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   293→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   294→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   295→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   296→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   297→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   298→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   299→\\t)\\n   300→\\n   301→\\tsessionID := event.SessionID\\n   302→\\tif sessionID == \\\"\\\" {\\n   303→\\t\\tsessionID = unknownSessionID\\n   304→\\t}\\n   305→\\n   306→\\t// Fill model from hint file if the agent didn't provide it on this hook\\n   307→\\tif event.Model == \\\"\\\" && sessionID != unknownSessionID {\\n   308→\\t\\tif hint := strategy.LoadModelHint(ctx, sessionID); hint != \\\"\\\" {\\n   309→\\t\\t\\tevent.Model = hint\\n   310→\\t\\t\\tlogging.Debug(logCtx, \\\"loaded model from hint file\\\",\\n   311→\\t\\t\\t\\tslog.String(\\\"model\\\", hint))\\n   312→\\t\\t}\\n   313→\\t}\\n   314→\\n   315→\\ttranscriptRef := event.SessionRef\\n   316→\\tif transcriptRef == \\\"\\\" {\\n   317→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   318→\\t}\\n   319→\\n   320→\\t// If agent implements TranscriptPreparer, materialize the transcript file.\\n   321→\\t// This must run BEFORE fileExists: agents like OpenCode lazily fetch transcripts\\n   322→\\t// via `opencode export`, so the file doesn't exist until PrepareTranscript creates it.\\n   323→\\t// Claude Code's PrepareTranscript just flushes (always succeeds). Agents without\\n   324→\\t// TranscriptPreparer (Gemini, Droid) are unaffected.\\n   325→\\t_, prepareSpan := perf.Start(ctx, \\\"prepare_and_validate_transcript\\\")\\n   326→\\tif preparer, ok := agent.AsTranscriptPreparer(ag); ok {\\n   327→\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n   328→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n   329→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   330→\\t\\t}\\n   331→\\t}\\n   332→\\n   333→\\tif !fileExists(transcriptRef) {\\n   334→\\t\\tprepareSpan.RecordError(fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef))\\n   335→\\t\\tprepareSpan.End()\\n   336→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   337→\\t}\\n   338→\\n   339→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   340→\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n   341→\\t\\tprepareSpan.RecordError(strategy.ErrEmptyRepository)\\n   342→\\t\\tprepareSpan.End()\\n   343→\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n   344→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   345→\\t}\\n   346→\\tprepareSpan.End()\\n   347→\\n   348→\\t// Create session metadata directory\\n   349→\\t_, copySpan := perf.Start(ctx, \\\"copy_transcript\\\")\\n   350→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   351→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   352→\\tif err != nil {\\n   353→\\t\\tsessionDirAbs = sessionDir\\n   354→\\t}\\n   355→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   356→\\t\\tcopySpan.RecordError(err)\\n   357→\\t\\tcopySpan.End()\\n   358→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   359→\\t}\\n   360→\\n   361→\\t// Copy transcript to session directory\\n   362→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   363→\\tif err != nil {\\n   364→\\t\\tcopySpan.RecordError(err)\\n   365→\\t\\tcopySpan.End()\\n   366→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   367→\\t}\\n   368→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   369→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   370→\\t\\tcopySpan.RecordError(err)\\n   371→\\t\\tcopySpan.End()\\n   372→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   373→\\t}\\n   374→\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n   375→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n   376→\\tcopySpan.End()\\n   377→\\n   378→\\t// Load pre-prompt state (captured on TurnStart)\\n   379→\\t_, extractSpan := perf.Start(ctx, \\\"extract_metadata\\\")\\n   380→\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n   381→\\tif err != nil {\\n   382→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n   383→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   384→\\t}\\n   385→\\n   386→\\t// Determine transcript offset\\n   387→\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n   388→\\n   389→\\t// Compute subagents directory for agents that support subagent extraction.\\n   390→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   391→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   392→\\n   393→\\t// Extract metadata via agent interface (modified files)\\n   394→\\tvar modifiedFiles []string\\n   395→\\n   396→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok {\\n   397→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   398→\\t\\tif subagentExtractor, subOk := agent.AsSubagentAwareExtractor(ag); subOk {\\n   399→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n   400→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n   401→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   402→\\t\\t\\t} else {\\n   403→\\t\\t\\t\\tmodifiedFiles = files\\n   404→\\t\\t\\t}\\n   405→\\t\\t} else {\\n   406→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   407→\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   408→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n   409→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   410→\\t\\t\\t} else {\\n   411→\\t\\t\\t\\tmodifiedFiles = files\\n   412→\\t\\t\\t}\\n   413→\\t\\t}\\n   414→\\t}\\n   415→\\textractSpan.End()\\n   416→\\n   417→\\t// Generate commit message from last prompt (read from session state, set at TurnStart)\\n   418→\\t_, commitMsgSpan := perf.Start(ctx, \\\"generate_commit_message\\\")\\n   419→\\tlastPrompt := \\\"\\\"\\n   420→\\tif sessionState, stateErr := strategy.LoadSessionState(ctx, sessionID); stateErr == nil && sessionState != nil {\\n   421→\\t\\tlastPrompt = sessionState.LastPrompt\\n   422→\\t}\\n   423→\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n   424→\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n   425→\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n   426→\\tcommitMsgSpan.End()\\n   427→\\n   428→\\t// Get worktree root for path normalization\\n   429→\\t_, detectSpan := perf.Start(ctx, \\\"detect_file_changes\\\")\\n   430→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   431→\\tif err != nil {\\n   432→\\t\\tdetectSpan.RecordError(err)\\n   433→\\t\\tdetectSpan.End()\\n   434→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   435→\\t}\\n   436→\\n   437→\\tvar preUntrackedFiles []string\\n   438→\\tif preState != nil {\\n   439→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n   440→\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n   441→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   442→\\t}\\n   443→\\n   444→\\t// Detect file changes via git status\\n   445→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   446→\\tif err != nil {\\n   447→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   448→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   449→\\t}\\n   450→\\tdetectSpan.End()\\n   451→\\n   452→\\t// Filter and normalize all paths\\n   453→\\t_, normalizeSpan := perf.Start(ctx, \\\"filter_and_normalize_paths\\\")\\n   454→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   455→\\tvar relNewFiles, relDeletedFiles []string\\n   456→\\tif changes != nil {\\n   457→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   458→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   459→\\n   460→\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n   461→\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n   462→\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n   463→\\t\\t// Git status catches any tracked file with working-tree changes.\\n   464→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   465→\\t}\\n   466→\\n   467→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   468→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   469→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   470→\\t// if it exists in HEAD with the same content as the working tree.\\n   471→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   472→\\tnormalizeSpan.End()\\n   473→\\n   474→\\t// Check if there are any changes\\n   475→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   476→\\tif totalChanges == 0 {\\n   477→\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n   478→\\t\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n   479→\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   480→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   481→\\t\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   482→\\t\\t}\\n   483→\\t\\treturn nil\\n   484→\\t}\\n   485→\\n   486→\\t// Log file changes\\n   487→\\tlogFileChanges(ctx, relModifiedFiles, relNewFiles, relDeletedFiles)\\n   488→\\n   489→\\t// Get git author\\n   490→\\tauthor, err := GetGitAuthor(ctx)\\n   491→\\tif err != nil {\\n   492→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   493→\\t}\\n   494→\\n   495→\\t// Get strategy and agent type\\n   496→\\tstrat := GetStrategy(ctx)\\n   497→\\tagentType := ag.Type()\\n   498→\\n   499→\\t// Get transcript position/identifier from pre-prompt state\\n   500→\\tvar transcriptIdentifierAtStart string\\n   501→\\tvar transcriptLinesAtStart int\\n   502→\\tif preState != nil {\\n   503→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   504→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   505→\\t}\\n   506→\\n   507→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   508→\\ttokenUsage := agent.CalculateTokenUsage(ctx, ag, transcriptData, transcriptLinesAtStart, subagentsDir)\\n   509→\\n   510→\\t// Build fully-populated step context and delegate to strategy\\n   511→\\tstepCtx := strategy.StepContext{\\n   512→\\t\\tSessionID:                sessionID,\\n   513→\\t\\tModifiedFiles:            relModifiedFiles,\\n   514→\\t\\tNewFiles:                 relNewFiles,\\n   515→\\t\\tDeletedFiles:             relDeletedFiles,\\n   516→\\t\\tMetadataDir:              sessionDir,\\n   517→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   518→\\t\\tCommitMessage:            commitMessage,\\n   519→\\t\\tTranscriptPath:           transcriptRef,\\n   520→\\t\\tAuthorName:               author.Name,\\n   521→\\t\\tAuthorEmail:              author.Email,\\n   522→\\t\\tAgentType:                agentType,\\n   523→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   524→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   525→\\t\\tTokenUsage:               tokenUsage,\\n   526→\\t}\\n   527→\\n   528→\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   529→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   530→\\t}\\n   531→\\n   532→\\t// Transition session phase and cleanup\\n   533→\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n   534→\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   535→\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   536→\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   537→\\t}\\n   538→\\n   539→\\treturn nil\\n   540→}\\n   541→\\n   542→// handleLifecycleCompaction handles context compaction: saves current progress\\n   543→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   544→// Also resets the transcript offset since the transcript may be truncated.\\n   545→func handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   546→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   547→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   548→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   549→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   550→\\t)\\n   551→\\n   552→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   553→\\tsessionID := event.SessionID\\n   554→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   555→\\tif loadErr != nil {\\n   556→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for compaction\\\",\\n   557→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   558→\\t}\\n   559→\\tif sessionState != nil {\\n   560→\\t\\tpersistEventMetadataToState(event, sessionState)\\n   561→\\n   562→\\t\\tif transErr := strategy.TransitionAndLog(ctx, sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   563→\\t\\t\\tlogging.Warn(logCtx, \\\"compaction transition failed\\\",\\n   564→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   565→\\t\\t}\\n   566→\\n   567→\\t\\tif saveErr := strategy.SaveSessionState(ctx, sessionState); saveErr != nil {\\n   568→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to save session state after compaction\\\",\\n   569→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   570→\\t\\t}\\n   571→\\t}\\n   572→\\n   573→\\tlogging.Info(logCtx, \\\"context compaction detected\\\")\\n   574→\\treturn nil\\n   575→}\\n   576→\\n   577→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   578→func handleLifecycleSessionEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   579→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   580→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   581→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   582→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   583→\\t)\\n   584→\\n   585→\\tif event.SessionID == \\\"\\\" {\\n   586→\\t\\treturn nil // No session to update\\n   587→\\t}\\n   588→\\n   589→\\t// Note: We intentionally don't clean up cached transcripts here.\\n   590→\\t// Post-session commits (carry-forward in ENDED phase) may still need\\n   591→\\t// the transcript to extract file changes. Cleanup is handled by\\n   592→\\t// `entire clean` or when the session state is fully removed.\\n   593→\\n   594→\\tif err := markSessionEnded(ctx, event, event.SessionID); err != nil {\\n   595→\\t\\tlogging.Warn(logCtx, \\\"failed to mark session ended\\\",\\n   596→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   597→\\t}\\n   598→\\treturn nil\\n   599→}\\n   600→\\n   601→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   602→func handleLifecycleSubagentStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   603→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   604→\\tlogging.Info(logCtx, \\\"subagent started\\\",\\n   605→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   606→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   607→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   608→\\t\\tslog.String(\\\"transcript\\\", event.SessionRef),\\n   609→\\t)\\n   610→\\n   611→\\t// Capture pre-task state\\n   612→\\tif err := CapturePreTaskState(ctx, event.ToolUseID); err != nil {\\n   613→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   614→\\t}\\n   615→\\n   616→\\treturn nil\\n   617→}\\n   618→\\n   619→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   620→func handleLifecycleSubagentEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   621→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   622→\\tif event.SubagentType == \\\"\\\" && event.TaskDescription == \\\"\\\" {\\n   623→\\t\\t// Extract subagent type and description from tool input\\n   624→\\t\\tevent.SubagentType, event.TaskDescription = ParseSubagentTypeAndDescription(event.ToolInput)\\n   625→\\t}\\n   626→\\n   627→\\t// Determine subagent transcript path\\n   628→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   629→\\tvar subagentTranscriptPath string\\n   630→\\tif event.SubagentID != \\\"\\\" {\\n   631→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   632→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   633→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   634→\\t\\t}\\n   635→\\t}\\n   636→\\n   637→\\t// Log context\\n   638→\\tsubagentEndAttrs := []any{\\n   639→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   640→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   641→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   642→\\t}\\n   643→\\tif event.SubagentID != \\\"\\\" {\\n   644→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"agent_id\\\", event.SubagentID))\\n   645→\\t}\\n   646→\\tif subagentTranscriptPath != \\\"\\\" {\\n   647→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"subagent_transcript\\\", subagentTranscriptPath))\\n   648→\\t}\\n   649→\\tlogging.Info(logCtx, \\\"subagent completed\\\", subagentEndAttrs...)\\n   650→\\n   651→\\t// Extract modified files from hook payload and/or subagent transcript\\n   652→\\tvar modifiedFiles []string\\n   653→\\tmodifiedFiles = append(modifiedFiles, event.ModifiedFiles...)\\n   654→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok {\\n   655→\\t\\ttranscriptToScan := event.SessionRef\\n   656→\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n   657→\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n   658→\\t\\t}\\n   659→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n   660→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files from subagent\\\",\\n   661→\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   662→\\t\\t} else {\\n   663→\\t\\t\\tmodifiedFiles = mergeUnique(modifiedFiles, files)\\n   664→\\t\\t}\\n   665→\\t}\\n   666→\\n   667→\\t// Load pre-task state and detect file changes.\\n   668→\\t// If no pre-task state exists (agent doesn't support pre-task hook), fall back\\n   669→\\t// to the session's pre-prompt state. Without either, DetectFileChanges receives\\n   670→\\t// nil and treats ALL untracked files as new — which would create spurious task\\n   671→\\t// checkpoints for pre-existing untracked files (e.g., .github/hooks/entire.json).\\n   672→\\tpreState, err := LoadPreTaskState(ctx, event.ToolUseID)\\n   673→\\tif err != nil {\\n   674→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-task state\\\",\\n   675→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   676→\\t}\\n   677→\\tvar preUntrackedFiles []string\\n   678→\\tif preState != nil {\\n   679→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   680→\\t}\\n   681→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   682→\\tif err != nil {\\n   683→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   684→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   685→\\t}\\n   686→\\n   687→\\t// Get worktree root and normalize paths\\n   688→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   689→\\tif err != nil {\\n   690→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   691→\\t}\\n   692→\\n   693→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   694→\\tvar relNewFiles, relDeletedFiles []string\\n   695→\\tif changes != nil {\\n   696→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   697→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   698→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   699→\\t}\\n   700→\\n   701→\\t// If no changes, skip\\n   702→\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n   703→\\t\\tlogging.Info(logCtx, \\\"no file changes detected, skipping task checkpoint\\\")\\n   704→\\t\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   705→\\t\\treturn nil\\n   706→\\t}\\n   707→\\n   708→\\t// Find checkpoint UUID from main transcript (best-effort)\\n   709→\\tvar checkpointUUID string\\n   710→\\t// Use the existing CLI-level checkpoint UUID finder\\n   711→\\tmainLines, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n   712→\\tif mainLines != nil {\\n   713→\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n   714→\\t}\\n   715→\\n   716→\\t// Get git author\\n   717→\\tauthor, err := GetGitAuthor(ctx)\\n   718→\\tif err != nil {\\n   719→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   720→\\t}\\n   721→\\n   722→\\t// Build task checkpoint context\\n   723→\\tstrat := GetStrategy(ctx)\\n   724→\\tagentType := ag.Type()\\n   725→\\n   726→\\ttaskStepCtx := strategy.TaskStepContext{\\n   727→\\t\\tSessionID:              event.SessionID,\\n   728→\\t\\tToolUseID:              event.ToolUseID,\\n   729→\\t\\tAgentID:                event.SubagentID,\\n   730→\\t\\tModifiedFiles:          relModifiedFiles,\\n   731→\\t\\tNewFiles:               relNewFiles,\\n   732→\\t\\tDeletedFiles:           relDeletedFiles,\\n   733→\\t\\tTranscriptPath:         event.SessionRef,\\n   734→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   735→\\t\\tCheckpointUUID:         checkpointUUID,\\n   736→\\t\