directly (not via lifecycle dispatcher).\\n     4→package cli\\n     5→\\n     6→import (\\n     7→\\t\\\"errors\\\"\\n     8→\\t\\\"fmt\\\"\\n     9→\\t\\\"log/slog\\\"\\n    10→\\n    11→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    18→\\t\\\"github.com/entireio/cli/perf\\\"\\n    19→\\n    20→\\t\\\"github.com/spf13/cobra\\\"\\n    21→)\\n    22→\\n    23→// agentHookLogCleanup stores the cleanup function for agent hook logging.\\n    24→// Set by PersistentPreRunE, called by PersistentPostRunE.\\n    25→var agentHookLogCleanup func()\\n    26→\\n    27→// currentHookAgentName stores the agent name for the currently executing hook.\\n    28→// Set by newAgentHookVerbCmdWithLogging before calling the handler.\\n    29→// This allows handlers to know which agent invoked the hook without guessing.\\n    30→var currentHookAgentName types.AgentName\\n    31→\\n    32→// GetCurrentHookAgent returns the agent for the currently executing hook.\\n    33→// Returns the agent based on the hook command structure (e.g., \\\"entire hooks claude-code ...\\\")\\n    34→// rather than guessing from directory presence.\\n    35→// Falls back to GetAgent() if not in a hook context.\\n    36→func GetCurrentHookAgent() (agent.Agent, error) {\\n    37→\\tif currentHookAgentName == \\\"\\\" {\\n    38→\\t\\treturn nil, errors.New(\\\"not in a hook context: agent name not set\\\")\\n    39→\\t}\\n    40→\\n    41→\\tag, err := agent.Get(currentHookAgentName)\\n    42→\\tif err != nil {\\n    43→\\t\\treturn nil, fmt.Errorf(\\\"getting hook agent %q: %w\\\", currentHookAgentName, err)\\n    44→\\t}\\n    45→\\treturn ag, nil\\n    46→}\\n    47→\\n    48→// newAgentHooksCmd creates a hooks subcommand for an agent that implements HookSupport.\\n    49→// It dynamically creates subcommands for each hook the agent supports.\\n    50→func newAgentHooksCmd(agentName types.AgentName, handler agent.HookSupport) *cobra.Command {\\n    51→\\tcmd := &cobra.Command{\\n    52→\\t\\tUse:    string(agentName),\\n    53→\\t\\tShort:  handler.Description() + \\\" hook handlers\\\",\\n    54→\\t\\tHidden: true,\\n    55→\\t\\tPersistentPreRunE: func(cmd *cobra.Command, _ []string) error {\\n    56→\\t\\t\\tagentHookLogCleanup = initHookLogging(cmd.Context())\\n    57→\\t\\t\\treturn nil\\n    58→\\t\\t},\\n    59→\\t\\tPersistentPostRunE: func(_ *cobra.Command, _ []string) error {\\n    60→\\t\\t\\tif agentHookLogCleanup != nil {\\n    61→\\t\\t\\t\\tagentHookLogCleanup()\\n    62→\\t\\t\\t}\\n    63→\\t\\t\\treturn nil\\n    64→\\t\\t},\\n    65→\\t}\\n    66→\\n    67→\\tfor _, hookName := range handler.HookNames() {\\n    68→\\t\\tcmd.AddCommand(newAgentHookVerbCmdWithLogging(agentName, hookName))\\n    69→\\t}\\n    70→\\n    71→\\treturn cmd\\n    72→}\\n    73→\\n    74→// getHookType returns the hook type based on the hook name.\\n    75→// Returns \\\"subagent\\\" for task-related hooks (pre-task, post-task, post-todo),\\n    76→// \\\"tool\\\" for tool-related hooks (before-tool, after-tool),\\n    77→// \\\"agent\\\" for all other agent hooks.\\n    78→func getHookType(hookName string) string {\\n    79→\\tswitch hookName {\\n    80→\\tcase claudecode.HookNamePreTask, claudecode.HookNamePostTask, claudecode.HookNamePostTodo:\\n    81→\\t\\treturn \\\"subagent\\\"\\n    82→\\tcase geminicli.HookNameBeforeTool, geminicli.HookNameAfterTool,\\n    83→\\t\\tclaudecode.HookNamePostFileEdit:\\n    84→\\t\\treturn \\\"tool\\\"\\n    85→\\tdefault:\\n    86→\\t\\treturn \\\"agent\\\"\\n    87→\\t}\\n    88→}\\n    89→\\n    90→// exec