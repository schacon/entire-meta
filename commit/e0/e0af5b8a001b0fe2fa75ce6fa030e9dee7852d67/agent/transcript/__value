n    49→\\t\\tt.Parallel()\\n    50→\\t\\tstate := &State{\\n    51→\\t\\t\\tTranscriptLinesAtStart: 42,\\n    52→\\t\\t}\\n    53→\\t\\tstate.NormalizeAfterLoad(context.Background())\\n    54→\\t\\tassert.Equal(t, 42, state.CheckpointTranscriptStart)\\n    55→\\t\\tassert.Equal(t, 0, state.TranscriptLinesAtStart)\\n    56→\\t})\\n    57→\\n    58→\\tt.Run(\\\"CondensedTranscriptLines_takes_precedence_over_TranscriptLinesAtStart\\\", func(t *testing.T) {\\n    59→\\t\\tt.Parallel()\\n    60→\\t\\tstate := &State{\\n    61→\\t\\t\\tCondensedTranscriptLines: 150,\\n    62→\\t\\t\\tTranscriptLinesAtStart:   42,\\n    63→\\t\\t}\\n    64→\\t\\tstate.NormalizeAfterLoad(context.Background())\\n    65→\\t\\tassert.Equal(t, 150, state.CheckpointTranscriptStart)\\n    66→\\t\\tassert.Equal(t, 0, state.CondensedTranscriptLines)\\n    67→\\t\\tassert.Equal(t, 0, state.TranscriptLinesAtStart)\\n    68→\\t})\\n    69→\\n    70→\\tt.Run(\\\"CheckpointTranscriptStart_not_overridden_by_TranscriptLinesAtStart\\\", func(t *testing.T) {\\n    71→\\t\\tt.Parallel()\\n    72→\\t\\tstate := &State{\\n    73→\\t\\t\\tCheckpointTranscriptStart: 200,\\n    74→\\t\\t\\tTranscriptLinesAtStart:    42,\\n    75→\\t\\t}\\n    76→\\t\\tstate.NormalizeAfterLoad(context.Background())\\n    77→\\t\\tassert.Equal(t, 200, state.CheckpointTranscriptStart)\\n    78→\\t\\tassert.Equal(t, 0, state.TranscriptLinesAtStart)\\n    79→\\t})\\n    80→}\\n    81→\\n    82→func TestState_NormalizeAfterLoad_JSONRoundTrip(t *testing.T) {\\n    83→\\ttests := []struct {\\n    84→\\t\\tname     string\\n    85→\\t\\tjson     string\\n    86→\\t\\twantCTS  int // CheckpointTranscriptStart\\n    87→\\t\\twantStep int // StepCount\\n    88→\\t}{\\n    89→\\t\\t{\\n    90→\\t\\t\\tname:     \\\"migrates old condensed_transcript_lines\\\",\\n    91→\\t\\t\\tjson:     `{\\\"session_id\\\":\\\"s1\\\",\\\"condensed_transcript_lines\\\":42,\\\"checkpoint_count\\\":5}`,\\n    92→\\t\\t\\twantCTS:  42,\\n    93→\\t\\t\\twantStep: 5,\\n    94→\\t\\t},\\n    95→\\t\\t{\\n    96→\\t\\t\\tname:    \\\"migrates old transcript_lines_at_start\\\",\\n    97→\\t\\t\\tjson:    `{\\\"session_id\\\":\\\"s1\\\",\\\"transcript_lines_at_start\\\":75}`,\\n    98→\\t\\t\\twantCTS: 75,\\n    99→\\t\\t},\\n   100→\\t\\t{\\n   101→\\t\\t\\tname:    \\\"preserves new field over old\\\",\\n   102→\\t\\t\\tjson:    `{\\\"session_id\\\":\\\"s1\\\",\\\"condensed_transcript_lines\\\":10,\\\"checkpoint_transcript_start\\\":50}`,\\n   103→\\t\\t\\twantCTS: 50,\\n   104→\\t\\t},\\n   105→\\t\\t{\\n   106→\\t\\t\\tname:     \\\"handles clean new format\\\",\\n   107→\\t\\t\\tjson:     `{\\\"session_id\\\":\\\"s1\\\",\\\"checkpoint_transcript_start\\\":25,\\\"checkpoint_count\\\":3}`,\\n   108→\\t\\t\\twantCTS:  25,\\n   109→\\t\\t\\twantStep: 3,\\n   110→\\t\\t},\\n   111→\\t}\\n   112→\\n   113→\\tfor _, tt := range tests {\\n   114→\\t\\tt.Run(tt.name, func(t *testing.T) {\\n   115→\\t\\t\\tvar state State\\n   116→\\t\\t\\trequire.NoError(t, json.Unmarshal([]byte(tt.json), &state))\\n   117→\\t\\t\\tstate.NormalizeAfterLoad(context.Background())\\n   118→\\n   119→\\t\\t\\tassert.Equal(t, tt.wantCTS, state.CheckpointTranscriptStart)\\n   120→\\t\\t\\tassert.Equal(t, tt.wantStep, state.StepCount)\\n   121→\\t\\t\\tassert.Equal(t, 0, state.CondensedTranscriptLines, \\\"deprecated field should be cleared\\\")\\n   122→\\t\\t\\tassert.Equal(t, 0, state.TranscriptLinesAtStart, \\\"deprecated field should be cleared\\\")\\n   123→\\t\\t})\\n   124→\\t}\\n   125→}\\n   126→\\n   127→func TestState_IsStale(t *testing.T) {\\n   128→\\tt.Parallel()\\n   129→\\n   130→\\tt.Run(\\\"nil_LastInteractionTime_falls_back_to_StartedAt\\\", func(t *testing.T) {\\n   131→\\t\\tt.Parallel()\\n   132→\\t\\t// Started 48 days ago, no interaction time — should be stale\\n   133→\\t\\tstate := &State{\\n   134→\\t\\t\\tStartedAt:           time.Now().Add(-48 * 24 * time.Hour),\\n   135→\\t\\t\\tLastInteractionTime: nil,\\n   136→\\t\\t}\\n   137→\\t\\tassert.True(t, state.IsStale())\\n   138→\\t})\\n   139→\\n   140→\\tt.Run(\\\"nil_LastInteractionTime_recent_start_is_not_stale\\\", func(t *testing.T) {\\n   141→\\t\\tt.Parallel()\\n   142→\\t\\t// Started 1 hour ago, no interaction time — not stale\\n   143→\\t\\tstate := &State{\\n   144→\\t\\t\\tStartedAt:           time.Now().Add(-1 * time.Hour),\\n   145→\\t\\t\\tLastInteractionTime: nil,\\n   146→\\t\\t}\\n   147→\\t\\tassert.False(t, state.IsStale())\\n   148→\\t})\\n   149→\\n   150→\\tt.Run(\\\"recently_interacted_is_not_stale\\\", func(t *testing.T) {\\n   151→\\t\\tt.Parallel()\\n   152→\\t\\trecent := time.Now().Add(-1 * time.Hour)\\n   153→\\t\\tstate := &State{LastInteractionTime: &recent}\\n   154→\\t\\tassert.False(t, state.IsStale())\\n   155→\\t})\\n   156→\\n   157→\\tt.Run(\\\"old_interaction_is_stale\\\", func(t *testing.T) {\\n   158→\\t\\tt.Parallel()\\n   159→\\t\\told := time.Now().Add(-14 * 24 * time.Hour)\\n   160→\\t\\tstate := &State{LastInteractionTime: &old}\\n   161→\\t\\tassert.True(t, state.IsStale())\\n   162→\\t})\\n   163→\\n   164→\\tt.Run(\\\"just_under_threshold_is_not_stale\\\", func(t *testing.T) {\\n   165→\\t\\tt.Parallel()\\n   166→\\t\\trecent := time.Now().Add(-1 * (StaleSessionThreshold - time.Hour))\\n   167→\\t\\tstate := &State{LastInteractionTime: &recent}\\n   168→\\t\\tassert.False(t, state.IsStale())\\n   169→\\t})\\n   170→\\n   171→\\tt.Run(\\\"nil_LastInteractionTime_just_under_threshold_is_not_stale\\\", func(t *testing.T) {\\n   172→\\t\\tt.Parallel()\\n   173→\\t\\tstate := &State{\\n   174→\\t\\t\\tStartedAt:           time.Now().Add(-1 * (StaleSessionThreshold - time.Hour)),\\n   175→\\t\\t\\tLastInteractionTime: nil,\\n   176→\\t\\t}\\n   177→\\t\\tassert.False(t, state.IsStale())\\n   178→\\t})\\n   179→}\\n   180→\\n   181→func TestStateStore_Load_DeletesStaleSession(t *testing.T) {\\n   182→\\tt.Parallel()\\n   183→\\n   184→\\tstateDir := filepath.Join(t.TempDir(), \\\"entire-sessions\\\")\\n   185→\\trequire.NoError(t, os.MkdirAll(stateDir, 0o750))\\n   186→\\tstore := NewStateStoreWithDir(stateDir)\\n   187→\\tctx := context.Background()\\n   188→\\n   189→\\t// Create a stale session (ended >1wk ago)\\n   190→\\tstaleInteracted := time.Now().Add(-2 * 7 * 24 * time.Hour)\\n   191→\\tstale := &State{\\n   192→\\t\\tSessionID:           \\\"stale-session\\\",\\n   193→\\t\\tBaseCommit:          \\\"def456\\\",\\n   194→\\t\\tStartedAt:           time.Now().Add(-3 * 7 * 24 * time.Hour),\\n   195→\\t\\tLastInteractionTime: &staleInteracted,\\n   196→\\t}\\n   197→\\trequire.NoError(t, store.Save(ctx, stale))\\n   198→\\n   199→\\t// Verify file exists before load\\n   200→\\tstateFile := filepath.Join(stateDir, \\\"stale-session.json\\\")\\n   201→\\t_, err := os.Stat(stateFile)\\n   202→\\trequire.NoError(t, err, \\\"state file should exist before load\\\")\\n   203→\\n   204→\\t// Load should return (nil, nil) for stale session\\n   205→\\tloaded, err := store.Load(ctx, \\\"stale-session\\\")\\n   206→\\trequire.NoError(t, err, \\\"Load should not return error for stale session\\\")\\n   207→\\tassert.Nil(t, loaded, \\\"Load should return nil for stale session\\\")\\n   208→\\n   209→\\t// File should be deleted from disk\\n   210→\\t_, err = os.Stat(stateFile)\\n   211→\\tassert.True(t, os.IsNotExist(err), \\\"stale session file should be deleted after Load\\\")\\n   212→\\n   213→\\t// Create an active session (no LastInteractionTime) to verify non-stale sessions still work\\n   214→\\tactive := &State{\\n   215→\\t\\tSessionID:  \\\"active-session\\\",\\n   216→\\t\\tBaseCommit: \\\"abc123\\\",\\n   217→\\t\\tStartedAt:  time.Now(),\\n   218→\\t}\\n   219→\\trequire.NoError(t, store.Save(ctx, active))\\n   220→\\n   221→\\tloaded, err = store.Load(ctx, \\\"active-session\\\")\\n   222→\\trequire.NoError(t, err)\\n   223→\\tassert.NotNil(t, loaded, \\\"Load should return state for active session\\\")\\n   224→\\tassert.Equal(t, \\\"active-session\\\", loaded.SessionID)\\n   225→}\\n   226→\\n   227→func TestStateStore_Load_DeletesStaleSession_NilLastInteraction(t *testing.T) {\\n   228→\\tt.Parallel()\\n   229→\\n   230→\\tstateDir := filepath.Join(t.TempDir(), \\\"entire-sessions\\\")\\n   231→\\trequire.NoError(t, os.MkdirAll(stateDir, 0o750))\\n   232→\\tstore := NewStateStoreWithDir(stateDir)\\n   233→\\tctx := context.Background()\\n   234→\\n   235→\\t// Exact production scenario: session created before interaction tracking,\\n   236→\\t// so LastInteractionTime is nil and StartedAt is old.\\n   237→\\timmortal := &State{\\n   238→\\t\\tSessionID:           \\\"immortal-session\\\",\\n   239→\\t\\tBaseCommit:          \\\"abc123\\\",\\n   240→\\t\\tStartedAt:           time.Now().Add(-48 * 24 * time.Hour),\\n   241→\\t\\tLastInteractionTime: nil,\\n   242→\\t}\\n   243→\\trequire.NoError(t, store.Save(ctx, immortal))\\n   244→\\n   245→\\tstateFile := filepath.Join(stateDir, \\\"immortal-session.json\\\")\\n   246→\\t_, err := os.Stat(stateFile)\\n   247→\\trequire.NoError(t, err, \\\"state file should exist before load\\\")\\n   248→\\n   249→\\tloaded, err := store.Load(ctx, \\\"immortal-session\\\")\\n   250→\\trequire.NoError(t, err)\\n   251→\\tassert.Nil(t, loaded, \\\"Load should return nil for session with nil LastInteractionTime and old StartedAt\\\")\\n   252→\\n   253→\\t_, err = os.Stat(stateFile)\\n   254→\\tassert.True(t, os.IsNotExist(err), \\\"immortal session file should be deleted after Load\\\")\\n   255→}\\n   256→\\n   257→func TestStateStore_Clear_RemovesAllSessionFiles(t *testing.T) {\\n   258→\\tt.Parallel()\\n   259→\\n   260→\\tstateDir := filepath.Join(t.TempDir(), \\\"entire-sessions\\\")\\n   261→\\trequire.NoError(t, os.MkdirAll(stateDir, 0o750))\\n   262→\\tstore := NewStateStoreWithDir(stateDir)\\n   263→\\tctx := context.Background()\\n   264→\\n   265→\\t// Create a state file and a .model hint file\\n   266→\\tstate := &State{\\n   267→\\t\\tSessionID:  \\\"hint-session\\\",\\n   268→\\t\\tBaseCommit: \\\"abc123\\\",\\n   269→\\t\\tStartedAt:  time.Now(),\\n   270→\\t}\\n   271→\\trequire.NoError(t, store.Save(ctx, state))\\n   272→\\n   273→\\thintFile := filepath.Join(stateDir, \\\"hint-session.model\\\")\\n   274→\\trequire.NoError(t, os.WriteFile(hintFile, []byte(\\\"claude-sonnet-4-20250514\\\"), 0o600))\\n   275→\\n   276→\\t// Clear should remove all files for this session\\n   277→\\trequire.NoError(t, store.Clear(ctx, \\\"hint-session\\\"))\\n   278→\\n   279→\\tmatches, err := filepath.Glob(filepath.Join(stateDir, \\\"hint-session.*\\\"))\\n   280→\\trequire.NoError(t, err)\\n   281→\\tassert.Empty(t, matches, \\\"all session files should be removed\\\")\\n   282→}\\n   283→\\n   284→func TestStateStore_Clear_RemovesOrphanedHintFile(t *testing.T) {\\n   285→\\tt.Parallel()\\n   286→\\n   287→\\tstateDir := filepath.Join(t.TempDir(), \\\"entire-sessions\\\")\\n   288→\\trequire.NoError(t, os.MkdirAll(stateDir, 0o750))\\n   289→\\tstore := NewStateStoreWithDir(stateDir)\\n   290→\\tctx := context.Background()\\n   291→\\n   292→\\t// Only a .model hint file exists (no .json state file)\\n   293→\\thintFile := filepath.Join(stateDir, \\\"orphan-session.model\\\")\\n   294→\\trequire.NoError(t, os.WriteFile(hintFile, []byte(\\\"claude-opus-4-6\\\"), 0o600))\\n   295→\\n   296→\\t// Clear should succeed and remove the hint file\\n   297→\\trequire.NoError(t, store.Clear(ctx, \\\"orphan-session\\\"))\\n   298→\\n   299→\\tmatches, err := filepath.Glob(filepath.Join(stateDir, \\\"orphan-session.*\\\"))\\n   300→\\trequire.NoError(t, err)\\n   301→\\tassert.Empty(t, matches, \\\"orphaned hint file should be removed\\\")\\n   302→}\\n   303→\\n   304→func TestStateStore_List_DeletesStaleSession(t *testing.T) {\\n   305→\\tt.Parallel()\\n   306→\\n   307→\\tstateDir := filepath.Join(t.TempDir(), \\\"entire-sessions\\\")\\n   308→\\trequire.NoError(t, os.MkdirAll(stateDir, 0o750))\\n   309→\\tstore := NewStateStoreWithDir(st