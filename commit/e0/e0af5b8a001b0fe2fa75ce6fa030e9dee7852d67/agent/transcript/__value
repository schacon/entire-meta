torage path for a checkpoint ID.\\n    42→// Uses first 2 characters as shard (256 buckets), remaining as folder name.\\n    43→// Example: \\\"a3b2c4d5e6f7\\\" -> \\\"a3/b2c4d5e6f7\\\"\\n    44→//\\n    45→// Deprecated: Use checkpointID.Path() directly instead.\\n    46→func CheckpointPath(checkpointID id.CheckpointID) string {\\n    47→\\treturn checkpointID.Path()\\n    48→}\\n    49→\\n    50→// worktreeRootCache caches the worktree root to avoid repeated git commands.\\n    51→// The cache is keyed by the current working directory to handle directory changes.\\n    52→var (\\n    53→\\tworktreeRootMu       sync.RWMutex\\n    54→\\tworktreeRootCache    string\\n    55→\\tworktreeRootCacheDir string\\n    56→)\\n    57→\\n    58→// WorktreeRoot returns the git worktree root directory.\\n    59→// Uses 'git rev-parse --show-toplevel' which returns the working tree toplevel.\\n    60→// In a worktree this is the worktree root, not the main repository root.\\n    61→// The result is cached per working directory.\\n    62→// Returns an error if not inside a git repository.\\n    63→func WorktreeRoot(ctx context.Context) (string, error) {\\n    64→\\t// Get current working directory to check cache validity\\n    65→\\tcwd, err := os.Getwd() //nolint:forbidigo // already present in codebase\\n    66→\\tif err != nil {\\n    67→\\t\\tcwd = \\\"\\\"\\n    68→\\t}\\n    69→\\n    70→\\t// Check cache with read lock first\\n    71→\\tworktreeRootMu.RLock()\\n    72→\\tif worktreeRootCache != \\\"\\\" && worktreeRootCacheDir == cwd {\\n    73→\\t\\tcached := worktreeRootCache\\n    74→\\t\\tworktreeRootMu.RUnlock()\\n    75→\\t\\treturn cached, nil\\n    76→\\t}\\n    77→\\tworktreeRootMu.RUnlock()\\n    78→\\n    79→\\t// Cache miss - get worktree root and update cache with write lock\\n    80→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--show-toplevel\\\")\\n    81→\\toutput, err := cmd.Output()\\n    82→\\tif err != nil {\\n    83→\\t\\treturn