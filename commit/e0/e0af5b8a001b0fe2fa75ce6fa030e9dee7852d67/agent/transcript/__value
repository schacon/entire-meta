 180→\\t// AgentLinesAdded is total agent lines added so far (base → last checkpoint).\\n   181→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   182→\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   183→\\n   184→\\t// AgentLinesRemoved is total agent lines removed so far (base → last checkpoint).\\n   185→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   186→\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   187→\\n   188→\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   189→\\t// This enables distinguishing user self-modifications from agent modifications.\\n   190→\\t// See docs/architecture/attribution.md for details.\\n   191→\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   192→}\\n   193→\\n   194→// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   195→// Call this after deserializing a State from JSON.\\n   196→func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   197→\\t// Normalize legacy phase values. \\\"active_committed\\\" was removed with the\\n   198→\\t// 1:1 checkpoint model in favor of the state machine handling commits\\n   199→\\t// during ACTIVE phase with immediate condensation.\\n   200→\\tif s.Phase == \\\"active_committed\\\" {\\n   201→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   202→\\t\\tlogging.Info(logCtx, \\\"migrating legacy active_committed phase to active\\\",\\n   203→\\t\\t\\tslog.String(\\\"session_id\\\", s.SessionID),\\n   204→\\t\\t)\\n   205→\\t\\ts.Phase = PhaseActive\\n   206→\\t}\\n   207→\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n   208→\\ts.Phase = PhaseFromString(string(s.Phase))\\n   209→\\n   210→\\t// Migrate transcript fields: CheckpointTranscriptStart replaces both\\n   211→\\t// CondensedTranscriptLines and TranscriptLinesAtStart from older state files.\\n   212→\\tif s.CheckpointTranscriptStart == 0 {\\n   213→\\t\\tif s.CondensedTranscriptLines > 0 {\\n   214→\\t\\t\\ts.CheckpointTranscriptStart = s.CondensedTranscriptLines\\n   215→\\t\\t} else if s.TranscriptLinesAtStart > 0 {\\n   216→\\t\\t\\ts.CheckpointTranscriptStart = s.TranscriptLinesAtStart\\n   217→\\t\\t}\\n   218→\\t}\\n   219→\\t// Clear deprecated fields so they aren't re-persisted.\\n   220→\\t// Note: this is a one-way migration. If the state is re-saved, older CLI versions\\n   221→\\t// will see 0 for these fields and fall back to scoping from the transcript start.\\n   222→\\t// This is acceptable since CLI upgrades are monotonic and the worst case is\\n   223→\\t// redundant transcript content in a condensation, not data loss.\\n   224→\\ts.CondensedTranscriptLines = 0\\n   225→\\ts.TranscriptLinesAtStart = 0\\n   226→\\n   227→\\t// Backfill AttributionBaseCommit for sessions created before this field existed.\\n   228→\\t// Without this, a mid-turn commit would migrate BaseCommit and the fallback in\\n   229→\\t// calculateSessionAttributions would use the migrated value, producing zero attribution.\\n   230→\\tif s.AttributionBaseCommit == \\\"\\\" && s.BaseCommit != \\\"\\\" {\\n   231→\\t\\ts.AttributionBaseCommit = s.BaseCommit\\n   232→\\t}\\n   233→}\\n   234→\\n   235→// IsStale returns true when a session hasn't seen interaction for longer than\\n   236→// StaleSessionThreshold. Falls back to StartedAt when LastInteractionTime is\\n   237→// nil (sessions created before interaction tracking was added).\\n   238→func (s *State) IsStale() bool {\\n   239→\\tvar since time.Duration\\n   240→\\tif s.LastInteractionTime != nil {\\n   241→\\t\\tsince = time.Since(*s.LastInteractionTime)\\n   242→\\t} else {\\n   243→\\t\\tsince = time.Since(s.StartedAt)\\n   244→\\t}\\n   245→\\treturn since > StaleSessionThreshold\\n   246→}\\n   247→\\n   248→// StateStore provides low-level operations for managing session state files.\\n   249→//\\n   250→// StateStore is a primitive for session state persistence. It is NOT the same as\\n   251→// the Sessions interface - it only handles state files in .git/entire-sessions/,\\n   252→// not the full session data which includes checkpoint content.\\n   253→//\\n   254→// Use StateStore directly in strategies for performance-critical state operations.\\n   255→// Use the Sessions interface (when implemented) for high-level session management.\\n   256→type StateStore struct {\\n   257→\\t// stateDir is the directory where session state files are stored\\n   258→\\tstateDir string\\n   259→}\\n   260→\\n   261→// NewStateStore creates a new state store.\\n   262→// Uses the git common dir to store session state (shared across worktrees).\\n   263→func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   264→\\tcommonDir, err := getGitCommonDir(ctx)\\n   265→\\tif err != nil {\\n   266→\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   267→\\t}\\n   268→\\treturn &StateStore{\\n   269→\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   270→\\t}, nil\\n   271→}\\n   272→\\n   273→// NewStateStoreWithDir creates a new state store with a custom directory.\\n   274→// This is useful for testing.\\n   275→func NewStateStoreWithDir(stateDir string) *StateStore {\\n   276→\\treturn &StateStore{stateDir: stateDir}\\n   277→}\\n   278→\\n   279→// Load loads the session state for the given session ID.\\n   280→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   281→// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   282→func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   283→\\t// Validate session ID to prevent path traversal\\n   284→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   285→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   286→\\t}\\n   287→\\n   288→\\tstateFile := s.stateFilePath(sessionID)\\n   289→\\n   290→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is derived from sessionID\\n   291→\\tif os.IsNotExist(err) {\\n   292→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   293→\\t}\\n   294→\\tif err != nil {\\n   295→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   296→\\t}\\n   297→\\n   298→\\tvar state State\\n   299→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   300→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal session state: %w\\\", err)\\n   301→\\t}\\n   302→\\tstate.NormalizeAfterLoad(ctx)\\n   303→\\n   304→\\tif state.IsStale() {\\n   305→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   306→\\t\\tlogging.Debug(logCtx, \\\"deleting stale session state\\\",\\n   307→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   308→\\t\\t)\\n   309→\\t\\t_ = s.Clear(ctx, sessionID) //nolint:errcheck // best-effort cleanup of stale session\\n   310→\\t\\treturn nil, nil             //nolint:nilnil // stale session treated as not found\\n   311→\\t}\\n   312→\\n   313→\\treturn &state, nil\\n   314→}\\n   315→\\n   316→// Save saves the session state atomically.\\n   317→func (s *StateStore) Save(ctx context.Context, state *State) error {\\n   318→\\t_ = ctx // Reserved for future use\\n   319→\\n   320→\\t// Validate session ID to prevent path traversal\\n   321→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n   322→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   323→\\t}\\n   324→\\n   325→\\tif err := os.MkdirAll(s.stateDir, 0o750); err != nil {\\n   326→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   327→\\t}\\n   328→\\n   329→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   330→\\tif err != nil {\\n   331→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   332→\\t}\\n   333→\\n   334→\\tstateFile := s.stateFilePath(state.SessionID)\\n   335→\\n   336→\\t// Atomic write: write to temp file, then rename\\n   337→\\ttmpFile := stateFile + \\\".tmp\\\"\\n   338→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n   339→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   340→\\t}\\n   341→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n   342→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n   343→\\t}\\n   344→\\treturn nil\\n   345→}\\n   346→\\n   347→// Clear removes the session state file for the given session ID.\\n   348→func (s *StateStore) Clear(ctx context.Context, sessionID string) error {\\n   349→\\t_ = ctx // Reserved for future use\\n   350→\\n   351→\\t// Validate session ID to prevent path traversal\\n   352→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   353→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   354→\\t}\\n   355→\\n   356→\\t// Remove all files for this session (state .json, .model hint, any future hint files).\\n   357→\\tmatches, _ := filepath.Glob(filepath.Join(s.stateDir, sessionID+\\\".*\\\")) //nolint:errcheck // pattern is always valid\\n   358→\\tfor _, f := range matches {\\n   359→\\t\\t_ = os.Remove(f)\\n   360→\\t}\\n   361→\\n   362→\\treturn nil\\n   363→}\\n   364→\\n   365→// RemoveAll removes the entire session state directory.\\n   366→// This is used during uninstall to completely remove all session state.\\n   367→func (s *StateStore) RemoveAll() error {\\n   368→\\tif err := os.RemoveAll(s.stateDir); err != nil {\\n   369→\\t\\treturn fmt.Errorf(\\\"failed to remove session state directory: %w\\\", err)\\n   370→\\t}\\n   371→\\treturn nil\\n   372→}\\n   373→\\n   374→// List returns all session states.\\n   375→func (s *StateStore) List(ctx context.Context) ([]*State, error) {\\n   376→\\tentries, err := os.ReadDir(s.stateDir)\\n   377→\\tif os.IsNotExist(err) {\\n   378→\\t\\treturn nil, nil\\n   379→\\t}\\n   380→\\tif err != nil {\\n   381→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state directory: %w\\\", err)\\n   382→\\t}\\n   383→\\n   384→\\tvar states []*State\\n   385→\\tfor _, entry := range entries {\\n   386→\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   387→\\t\\t\\tcontinue\\n   388→\\t\\t}\\n   389→\\t\\tif strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   390→\\t\\t\\tcontinue // Skip temp files\\n   391→\\t\\t}\\n   392→\\n   393→\\t\\tsessionID := strings.TrimSuffix(entry.Name(), \\\".json\\\")\\n   394→\\t\\tstate, err := s.Load(ctx, sessionID)\\n   395→\\t\\tif err != nil {\\n   396→\\t\\t\\tcontinue // Skip corrupted state files\\n   397→\\t\\t}\\n   398→\\t\\tif state == nil {\\n   399→\\t\\t\\tcontinue // Not found or stale (Load handles cleanup)\\n   400→\\t\\t}\\n   401→\\n   402→\\t\\tstates = append(states, state)\\n   403→\\t}\\n   404→\\treturn states, nil\\n   405→}\\n   406→\\n   407→// stateFilePath returns the path to a session state file.\\n   408→func (s *StateStore) stateFilePath(sessionID string) string {\\n   409→\\treturn filepath.Join(s.stateDir, sessionID+\\\".json\\\")\\n   410→}\\n   411→\\n   412→// filesTouchedPath returns the path to the append-only file tracking file for a session.\\n   413→func (s *StateStore) filesTouchedPath(sessionID string) string {\\n   414→\\treturn filepath.Join(s.stateDir, sessionID+\\\".files\\\")\\n   415→}\\n   416→\\n   417→// AppendFileTouched appends a single file path to the session's tracking file.\\n   418→// The file is created if it doesn't exist. Paths are stored one per line.\\n   419→func (s *StateStore) AppendFileTouched(ctx context.Context, sessionID, filePath string) error {\\n   420→\\t_ = ctx // Reserved for future use\\n   421→\\n   422→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   423→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   424→\\t}\\n   425→\\n   426→\\tif err := os.MkdirAll(s.stateDir, 0o750); err != nil {\\n   427→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   428→\\t}\\n   429→\\n   430→\\tf, err := os.OpenFile(s.filesTouchedPath(sessionID), os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0o600)\\n   431→\\tif err != nil {\\n   432→\\t\\treturn fmt.Errorf(\\\"failed to open files touched tracking file: %w\\\", err)\\n   433→\\t}\\n   434→\\tdefer f.Close()\\n   435→\\n   436→\\tif _, err := fmt.Fprintln(f, filePath); err != nil {\\n   437→\\t\\treturn fmt.Errorf(\\\"failed to write to files touched tracking file: %w\\\", err)\\n   438→\\t}\\n   439→\\treturn nil\\n   440→}\\n   441→\\n   442→// ReadFilesTouched reads the session's file tracking file and returns a deduplicated,\\n   443→// sorted list of file paths. Returns (nil, nil) if the file doesn't exist or is empty.\\n   444→func (s *StateStore) ReadFilesTouched(ctx context.Context, sessionID string) ([]string, error) {\\n   445→\\t_ = ctx // Reserved for future use\\n   446→\\n   447→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   448→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   449→\\t}\\n   450→\\n   451→\\tdata, err := os.ReadFile(s.filesTouchedPath(sessionID))\\n   452→\\tif os.IsNotExist(err) {\\n   453→\\t\\treturn nil, nil\\n   454→\\t}\\n   455→\\tif err != nil {\\n   456→\\t\\treturn nil, fmt.Errorf(\\\"failed to read files touched tracking file: %w\\\", err)\\n   457→\\t}\\n   458→\\n   459→\\t// Deduplicate using a map\\n   460→\\tseen := make(map[string]struct{})\\n   461→\\tfor _, line := range strings.Split(string(data), \\\"\\\\n\\\") {\\n   462→\\t\\tline = strings.TrimSpace(line)\\n   463→\\t\\tif line != \\\"\\\" {\\n   464→\\t\\t\\tseen[line] = struct{}{}\\n   465→\\t\\t}\\n   466→\\t}\\n   467→\\n   468→\\tif len(seen) == 0 {\\n   469→\\t\\treturn nil, nil\\n   470→\\t}\\n   471→\\n   472→\\t// Collect and sort\\n   473→\\tresult := make([]string, 0, len(seen))\\n   474→\\tfor path := range seen {\\n   475→\\t\\tresult = append(result, path)\\n   476→\\t}\\n   477→\\tsort.Strings(result)\\n   478→\\treturn result, nil\\n   479→}\\n   480→\\n   481→// ClearFilesTouched removes the session's file tracking file.\\n   482→// Returns nil if the file doesn't exist (idempotent).\\n   483→func (s *StateStore) ClearFilesTouched(ctx context.Context, sessionID string) error {\\n   484→\\t_ = ctx // Reserved for future use\\n   485→\\n   486→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   487→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   488→\\t}\\n   489→\\n   490→\\terr := os.Remove(s.filesTouchedPath(sessionID))\\n   491→\\tif os.IsNotExist(err) {\\n   492→\\t\\treturn nil\\n   493→\\t}\\n   494→\\tif err != nil {\\n   495→\\t\\treturn fmt.Errorf(\\\"failed to remove files touched tracking file: %w\\\", err)\\n   496→\\t}\\n   497→\\treturn nil\\n   498→}\\n   499→\\n   500→// gitCommonDirCache caches the git common dir to avoid repeated subprocess calls.\\n   501→// Keyed by working directory to handle directory changes (same pattern as paths.WorktreeRoot).\\n   502→var (\\n   503→\\tgitCommonDirMu       sync.RWMutex\\n   504→\\tgitCommonDirCache    string\\n   505→\\tgitCommonDirCacheDir string\\n   506→)\\n   507→\\n   508→// ClearGitCommonDirCache clears the cached git common dir.\\n   509→// Useful for testing when changing directories.\\n   510→func ClearGitCommonDirCache() {\\n   511→\\tgitCommonDirMu.Lock()\\n   512→\\tgitCommonDirCache = \\\"\\\"\\n   513→\\tgitCommonDirCacheDir = \\\"\\\"\\n   514→\\tgitCommonDirMu.Unlock()\\n   515→}\\n   516→\\n   517→// getGitCommonDir returns the path to the shared git directory.\\n   518→// In a regular checkout, this is .git/\\n   519→// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n   520→// The result is cached per working directory.\\n   521→func getGitCommonDir(ctx context.Context) (string, error) {\\n   522→\\tcwd, err := os.Getwd() //nolint:forbidigo // used for cache key, not git-relative paths\\n   523→\\tif err != nil {\\n   524→\\t\\tcwd = \\\"\\\"\\n   525→\\t}\\n   526→\\n   527→\\t// Check cache with read lock first\\n   528→\\tgitCommonDirMu.RLock()\\n   529→\\tif gitCommonDirCache != \\\"\\\" && gitCommonDirCacheDir == cwd {\\n   530→\\t\\tcached := gitCommonDirCache\\n   531→\\t\\tgitCommonDirMu.RUnlock()\\n   532→\\t\\treturn cached, nil\\n   533→\\t}\\n   534→\\tgitCommonDirMu.RUnlock()\\n   535→\\n   536→\\t// Cache miss — resolve via git subprocess\\n   537→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-common-dir\\\")\\n   538→\\tcmd.Dir = \\\".\\\"\\n   539→\\toutput, err := cmd.Output()\\n   540→\\tif err != nil {\\n   541→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   542→\\t}\\n   543→\\n   544→\\tcommonDir := strings.TrimSpace(string(output))\\n   545→\\n   546→\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\n   547→\\t// so we need to make it absolute if it isn't already\\n   548→\\tif !filepath.IsAbs(commonDir) {\\n   549→\\t\\tcommonDir = filepath.Join(\\\".\\\", commonDir)\\n   550→\\t}\\n   551→\\tcommonDir = filepath.Clean(commonDir)\\n   552→\\n   553→\\tgitCommonDirMu.Lock()\\n   554→\\tgitCommonDirCache = commonDir\\n   555→\\tgitCommonDirCacheDir = cwd\\n   556→\\tgitCommonDirMu.Unlock()\\n   557→\\n   558→\\treturn commonDir, nil\\n   559→}\\n   560→\"}]},\"uuid\":\"b28e0b20-0848-48b2-b886-32820b0d0c87\",\"timestamp\":\"2026-03-06T11:16:36.341Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"abd50e26f16d90c3e\"},\"toolUseID\":\"agent_msg_01BsT38Gx3vhXAvrcbgSQwMa\",\"parentToolUseID\":\"toolu_0131RLMC7tbZsezgEjPvo5SY\",\"uuid\":\"9a42ceea-9942-4506-8592-dc5f70239894\",\"timestamp\":