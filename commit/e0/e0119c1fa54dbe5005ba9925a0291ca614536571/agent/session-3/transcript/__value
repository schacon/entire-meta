postCmd.CombinedOutput(); err != nil {\\n  1222→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n  1223→\\t}\\n  1224→}\\n  1225→\\n  1226→// ListBranchesWithPrefix returns all branches that start with the given prefix.\\n  1227→func (env *TestEnv) ListBranchesWithPrefix(prefix string) []string {\\n  1228→\\tenv.T.Helper()\\n  1229→\\n  1230→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1231→\\tif err != nil {\\n  1232→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1233→\\t}\\n  1234→\\n  1235→\\trefs, err := repo.References()\\n  1236→\\tif err != nil {\\n  1237→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n  1238→\\t}\\n  1239→\\n  1240→\\tvar branches []string\\n  1241→\\t_ = refs.ForEach(func(ref *plumbing.Reference) error {\\n  1242→\\t\\tname := ref.Name().Short()\\n  1243→\\t\\tif len(name) >= len(prefix) && name[:len(prefix)] == prefix {\\n  1244→\\t\\t\\tbranches = append(branches, name)\\n  1245→\\t\\t}\\n  1246→\\t\\treturn nil\\n  1247→\\t})\\n  1248→\\n  1249→\\treturn branches\\n  1250→}\\n  1251→\\n  1252→// GetLatestCheckpointID returns the most recent checkpoint ID from the entire/checkpoints/v1 branch.\\n  1253→// This is used by tests that previously extracted the checkpoint ID from commit message trailers.\\n  1254→// Now that active branch commits are clean (no trailers), we get the ID from the sessions branch.\\n  1255→// Fatals if the checkpoint ID cannot be found, with detailed context about what was found.\\n  1256→func (env *TestEnv) GetLatestCheckpointID() string {\\n  1257→\\tenv.T.Helper()\\n  1258→\\n  1259→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1260→\\tif err != nil {\\n  1261→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1262→\\t}\\n  1263→\\n  1264→\\t// Get the entire/checkpoints/v1 branch\\n  1265→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1266→\\tref, err := repo.Reference(refName, true)\\n  1267→\\tif err != nil {\\n  1268→\\t\\tenv.T.Fatalf(\\\"failed to get %s branch: %v\\\", paths.MetadataBranchName, err)\\n  1269→\\t}\\n  1270→\\n  1271→\\tcommit, err := repo.CommitObject(ref.Hash())\\n  1272→\\tif err != nil {\\n  1273→\\t\\tenv.T.Fatalf(\\\"failed to get commit: %v\\\", err)\\n  1274→\\t}\\n  1275→\\n  1276→\\t// Extract checkpoint ID from commit message\\n  1277→\\t// Format: \\\"Checkpoint: <12-hex-char-id>\\\\n\\\\nSession: ...\\\\nStrategy: ...\\\"\\n  1278→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n  1279→\\t\\tline = strings.TrimSpace(line)\\n  1280→\\t\\tif strings.HasPrefix(line, \\\"Checkpoint: \\\") {\\n  1281→\\t\\t\\treturn strings.TrimPrefix(line, \\\"Checkpoint: \\\")\\n  1282→\\t\\t}\\n  1283→\\t}\\n  1284→\\n  1285→\\tenv.T.Fatalf(\\\"could not find checkpoint ID in %s branch commit message:\\\\n%s\\\",\\n  1286→\\t\\tpaths.MetadataBranchName, commit.Message)\\n  1287→\\treturn \\\"\\\"\\n  1288→}\\n  1289→\\n  1290→// TryGetLatestCheckpointID returns the most recent checkpoint ID from the entire/checkpoints/v1 branch.\\n  1291→// Returns empty string if the branch doesn't exist or has no checkpoint commits yet.\\n  1292→// Use this when you need to check if a checkpoint exists without failing the test.\\n  1293→func (env *TestEnv) TryGetLatestCheckpointID() string {\\n  1294→\\tenv.T.Helper()\\n  1295→\\n  1296→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1297→\\tif err != nil {\\n  1298→\\t\\treturn \\\"\\\"\\n  1299→\\t}\\n  1300→\\n  1301→\\t// Get the entire/checkpoints/v1 branch\\n  1302→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1303→\\tref, err := repo.Reference(refName, true)\\n  1304→\\tif err != nil {\\n  1305→\\t\\treturn \\\"\\\"\\n  1306→\\t}\\n  1307→\\n  1308→\\tcommit, err := repo.CommitObject(ref.Hash())\\n  1309→\\tif err != nil {\\n  1310→\\t\\treturn \\\"\\\"\\n  1311→\\t}\\n  1312→\\n  1313→\\t// Extract checkpoint ID from commit message\\n  1314→\\t// Format: \\\"Checkpoint: <12-hex-char-id>\\\\n\\\\nSession: ...\\\\nStrategy: ...\\\"\\n  1315→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n  1316→\\t\\tline = strings.TrimSpace(line)\\n  1317→\\t\\tif strings.HasPrefix(line, \\\"Checkpoint: \\\") {\\n  1318→\\t\\t\\treturn strings.TrimPrefix(line, \\\"Checkpoint: \\\")\\n  1319→\\t\\t}\\n  1320→\\t}\\n  1321→\\n  1322→\\treturn \\\"\\\"\\n  1323→}\\n  1324→\\n  1325→// GetLatestCondensationID is an alias for GetLatestCheckpointID for backwards compatibility.\\n  1326→func (env *TestEnv) GetLatestCondensationID() string {\\n  1327→\\treturn env.GetLatestCheckpointID()\\n  1328→}\\n  1329→\\n  1330→// GetCheckpointIDFromCommitMessage extracts the Entire-Checkpoint trailer from a commit message.\\n  1331→// Returns empty string if no trailer found.\\n  1332→func (env *TestEnv) GetCheckpointIDFromCommitMessage(commitSHA string) string {\\n  1333→\\tenv.T.Helper()\\n  1334→\\n  1335→\\tmsg := env.GetCommitMessage(commitSHA)\\n  1336→\\tcpID, found := trailers.ParseCheckpoint(msg)\\n  1337→\\tif !found {\\n  1338→\\t\\treturn \\\"\\\"\\n  1339→\\t}\\n  1340→\\treturn cpID.String()\\n  1341→}\\n  1342→\\n  1343→// GetLatestCheckpointIDFromHistory walks backwards from HEAD on the active branch\\n  1344→// and returns the checkpoint ID from the first commit that has an Entire-Checkpoint trailer.\\n  1345→// This verifies that condensation actually happened (commit has trailer) without relying\\n  1346→// on timestamp-based matching.\\n  1347→func (env *TestEnv) GetLatestCheckpointIDFromHistory() string {\\n  1348→\\tenv.T.Helper()\\n  1349→\\n  1350→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1351→\\tif err != nil {\\n  1352→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1353→\\t}\\n  1354→\\n  1355→\\thead, err := repo.Head()\\n  1356→\\tif err != nil {\\n  1357→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n  1358→\\t}\\n  1359→\\n  1360→\\tcommitIter, err := repo.Log(&git.LogOptions{From: