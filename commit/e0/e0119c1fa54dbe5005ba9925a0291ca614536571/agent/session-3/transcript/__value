k:\\n    36→//   - ENTIRE_TEST_TTY=1 → simulate human (TTY available)\\n    37→//   - ENTIRE_TEST_TTY=0 → simulate agent (no TTY)\\n    38→func hasTTY() bool {\\n    39→\\tif v := os.Getenv(\\\"ENTIRE_TEST_TTY\\\"); v != \\\"\\\" {\\n    40→\\t\\treturn v == \\\"1\\\"\\n    41→\\t}\\n    42→\\n    43→\\t// Gemini CLI sets GEMINI_CLI=1 when running shell commands.\\n    44→\\t// Gemini subprocesses may have access to the user's TTY, but they can't\\n    45→\\t// actually respond to interactive prompts. Treat them as non-TTY.\\n    46→\\t// See: https://geminicli.com/docs/tools/shell/\\n    47→\\tif os.Getenv(\\\"GEMINI_CLI\\\") != \\\"\\\" {\\n    48→\\t\\treturn false\\n    49→\\t}\\n    50→\\n    51→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n    52→\\tif err != nil {\\n    53→\\t\\treturn false\\n    54→\\t}\\n    55→\\t_ = tty.Close()\\n    56→\\treturn true\\n    57→}\\n    58→\\n    59→// askConfirmTTY prompts the user for a yes/no confirmation via /dev/tty.\\n    60→// This works even when stdin is redirected (e.g., git commit -m).\\n    61→// Returns true for yes, false for no. If TTY is unavailable, returns the default.\\n    62→// If context is non-empty, it is displayed on a separate line before the prompt.\\n    63→func askConfirmTTY(prompt string, context string, defaultYes bool) bool {\\n    64→\\t// In test mode, don't try to interact with the real TTY — just use the default.\\n    65→\\t// ENTIRE_TEST_TTY=1 simulates \\\"a human is present\\\" for the hasTTY() check\\n    66→\\t// but we can't actually read from the TTY in tests.\\n    67→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n    68→\\t\\treturn defaultYes\\n    69→\\t}\\n    70→\\n    71→\\t// Gemini CLI sets GEMINI_CLI=1 when running shell commands (including git commit).\\n    72→\\t// The agent can't respond to TTY prompts, so use the default to avoid hanging.\\n    73→\\t// See: https://geminicli.com/docs/tools/shell/\\n    74→\\tif os.Getenv(\\\"GEMINI_CLI\\\") != \\\"\\\" {\\n    75→\\t\\treturn defaultYes\\n    76→\\t}\\n    77→\\n    78→\\t// Open /dev/tty for both reading and writing\\n    79→\\t// This is the controlling terminal, which works even when stdin/stderr are redirected\\n    80→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n    81→\\tif err != nil {\\n    82→\\t\\t// Can't open TTY (e.g., running in CI), use default\\n    83→\\t\\treturn defaultYes\\n    84→\\t}\\n    85→\\tdefer tty.Close()\\n    86→\\n    87→\\t// Show context if provided\\n    88→\\tif context != \\\"\\\" {\\n    89→\\t\\tfmt.Fprintf(tty, \\\"%s\\\\n\\\", context)\\n    90→\\t}\\n    91→\\n    92→\\t// Show prompt with default indicator\\n    93→\\t// Write to tty directly, not stderr, since git hooks may redirect stderr to /dev/null\\n    94→\\tvar hint string\\n    95→\\tif defaultYes {\\n    96→\\t\\thint = \\\"[Y/n]\\\"\\n    97→\\t} else {\\n    98→\\t\\thint = \\\"[y/N]\\\"\\n    99→\\t}\\n   100→\\tfmt.Fprintf(tty, \\\"%s %s \\\", prompt, hint)\\n   101→\\n   102→\\t// Read response\\n   103→\\treader := bufio.NewReader(tty)\\n   104→\\tresponse, err := reader.ReadString('\\\\n')\\n   105→\\tif err != nil {\\n   106→\\t\\treturn defaultYes\\n   107→\\t}\\n   108→\\n   109→\\tresponse = strings.TrimSpace(strings.ToLower(response))\\n   110→\\tswitch response {\\n   111→\\tcase \\\"y\\\", \\\"yes\\\":\\n   112→\\t\\treturn true\\n   113→\\tcase \\\"n\\\", \\\"no\\\":\\n   114→\\t\\treturn false\\n   115→\\tdefault:\\n   116→\\t\\t// Empty or invalid input - use default\\n   117→\\t\\treturn defaultYes\\n   118→\\t}\\n   119→}\\n   120→\\n   121→// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   122→// If the message contains only our trailer (no actual user content), strip it\\n   123→// so git will abort the commit due to empty message.\\n   124→//\\n   125→\\n   126→func (s *ManualCommitStrategy) CommitMsg(commitMsgFile string) error {\\n   127→\\tstart := time.Now()\\n   128→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   129→\\tdefer logging.LogDuration(logCtx, slog.LevelDebug, \\\"CommitMsg total\\\", start)\\n   130→\\n   131→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n   132→\\tif err != nil {\\n   133→\\t\\treturn nil\\n   134→\\t}\\n   135→\\n   136→\\tmessage := string(content)\\n   137→\\n   138→\\t// Check if our trailer is present (ParseCheckpoint validates format, so found==true means valid)\\n   139→\\tif _, found := trailers.ParseCheckpoint(message); !found {\\n   140→\\t\\t// No trailer, nothing to do\\n   141→\\t\\treturn nil\\n   142→\\t}\\n   143→\\n   144→\\t// Check if there's any user content (non-comment, non-trailer lines)\\n   145→\\tif !hasUserContent(message) {\\n   146→\\t\\t// No user content - strip the trailer so git aborts\\n   147→\\t\\tmessage = stripCheckpointTrailer(message)\\n   148→\\t\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   149→\\t\\t\\treturn nil\\n   150→\\t\\t}\\n   151→\\t}\\n   152→\\n   153→\\treturn nil\\n   154→}\\n   155→\\n   156→// hasUserContent checks if the message has any content besides comments and our trailer.\\n   157→func hasUserContent(message string) bool {\\n   158→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   159→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   160→\\t\\ttrimmed := strings.TrimSpace(line)\\n   161→\\t\\t// Skip empty lines\\n   162→\\t\\tif trimmed == \\\"\\\" {\\n   163→\\t\\t\\tcontinue\\n   164→\\t\\t}\\n   165→\\t\\t// Skip comment lines\\n   166→\\t\\tif strings.HasPrefix(trimmed, \\\"#\\\") {\\n   167→\\t\\t\\tcontinue\\n   168→\\t\\t}\\n   169→\\t\\t// Skip our trailer line\\n   170→\\t\\tif strings.HasPrefix(trimmed, trailerPrefix) {\\n   171→\\t\\t\\tcontinue\\n   172→\\t\\t}\\n   173→\\t\\t// Found user content\\n   174→\\t\\treturn true\\n   175→\\t}\\n   176→\\treturn false\\n   177→}\\n   178→\\n   179→// stripCheckpointTrailer removes the Entire-Checkpoint trailer line from the message.\\n   180→func stripCheckpointTrailer(message string) string {\\n   181→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   182→\\tvar result []string\\n   183→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   184→\\t\\tif !strings.HasPrefix(strings.TrimSpace(line), trailerPrefix) {\\n   185→\\t\\t\\tresult = append(result, line)\\n   186→\\t\\t}\\n   187→\\t}\\n   188→\\treturn strings.Join(result, \\\"\\\\n\\\")\\n   189→}\\n   190→\\n   191→// isGitSequenceOperation checks if git is currently in the middle of a rebase,\\n   192→// cherry-pick, or revert operation. During these operations, commits are being\\n   193→// replayed and should not be linked to agent sessions.\\n   194→//\\n   195→// Detects:\\n   196→//   - rebase: .git/rebase-merge/ or .git/rebase-apply/ directories\\n   197→//   - cherry-pick: .git/CHERRY_PICK_HEAD file\\n   198→//   - revert: .git/REVERT_HEAD file\\n   199→func isGitSequenceOperation() bool {\\n   200→\\t// Get git directory (handles worktrees and relative paths correctly)\\n   201→\\tgitDir, err := GetGitDir()\\n   202→\\tif err != nil {\\n   203→\\t\\treturn false // Can't determine, assume not in sequence operation\\n   204→\\t}\\n   205→\\n   206→\\t// Check for rebase state directories\\n   207→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-merge\\\")); err == nil {\\n   208→\\t\\treturn true\\n   209→\\t}\\n   210→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-apply\\\")); err == nil {\\n   211→\\t\\treturn true\\n   212→\\t}\\n   213→\\n   214→\\t// Check for cherry-pick and revert state files\\n   215→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"CHERRY_PICK_HEAD\\\")); err == nil {\\n   216→\\t\\treturn true\\n   217→\\t}\\n   218→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"REVERT_HEAD\\\")); err == nil {\\n   219→\\t\\treturn true\\n   220→\\t}\\n   221→\\n   222→\\treturn false\\n   223→}\\n   224→\\n   225→// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   226→// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   227→// Only adds a trailer if there's actually new session content to condense.\\n   228→// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   229→// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   230→// For amended commits, preserves the existing checkpoint ID.\\n   231→//\\n   232→// The source parameter indicates how the commit was initiated:\\n   233→//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   234→//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   235→//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   236→//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   237→//\\n   238→\\n   239→func (s *ManualCommitStrategy) PrepareCommitMsg(commitMsgFile string, source string) error {\\n   240→\\tstart := time.Now()\\n   241→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   242→\\tdefer logging.LogDuration(logCtx, slog.LevelDebug, \\\"PrepareCommitMsg total\\\", start)\\n   243→\\n   244→\\t// Skip during rebase, cherry-pick, or revert operations\\n   245→\\t// These are replaying existing commits and should not be linked to agent sessions\\n   246→\\tif isGitSequenceOperation() {\\n   247→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n   248→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   249→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   250→\\t\\t)\\n   251→\\t\\treturn nil\\n   252→\\t}\\n   253→\\n   254→\\t// Skip for merge and squash sources\\n   255→\\t// These are auto-generated messages - not from Claude sessions\\n   256→\\tswitch source {\\n   257→\\tcase \\\"merge\\\", \\\"squash\\\":\\n   258→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n   259→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   260→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   261→\\t\\t)\\n   262→\\t\\treturn nil\\n   263→\\t}\\n   264→\\n   265→\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   266→\\tif source == \\\"commit\\\" {\\n   267→\\t\\treturn s.handleAmendCommitMsg(logCtx, commitMsgFile)\\n   268→\\t}\\n   269→\\n   270→\\trepo, err := OpenRepository()\\n   271→\\tif err != nil {\\n   272→\\t\\treturn nil\\n   273→\\t}\\n   274→\\n   275→\\tworktreePath, err := GetWorktreePath()\\n   276→\\tif err != nil {\\n   277→\\t\\treturn nil\\n   278→\\t}\\n   279→\\n   280→\\t// Find all active sessions for this worktree\\n   281→\\t// We match by worktree (not BaseCommit) because the user may have made\\n   282→\\t// intermediate commits without entering new prompts, causing HEAD to diverge\\n   283→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   284→\\tif err != nil || len(sessions) == 0 {\\n   285→\\t\\t// No active sessions or error listing - silently skip (hooks must be resilient)\\n   286→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no active sessions\\\",\\n   287→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   288→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   289→\\t\\t)\\n   290→\\t\\treturn nil\\n   291→\\t}\\n   292→\\n   293→\\t// Fast path: when an agent is committing (ACTIVE session + no TTY), skip\\n   294→\\t// content detection and interactive prompts. The agent can't respond to TTY\\n   295→\\t// prompts and the content detection can miss mid-session work (no shadow\\n   296→\\t// branch yet, transcript analysis may fail). Generate a checkpoint ID and\\n   297→\\t// add the trailer directly.\\n   298→\\tif !hasTTY() {\\n   299→\\t\\tfor _, state := range sessions {\\n   300→\\t\\t\\tif state.Phase.IsActive() {\\n   301→\\t\\t\\t\\treturn s.addTrailerForAgentCommit(logCtx, commitMsgFile, state, source)\\n   302→\\t\\t\\t}\\n   303→\\t\\t}\\n   304→\\t}\\n   305→\\n   306→\\t// Check if any session has new content to condense\\n   307→\\tsessionsWithContent := s.filterSessionsWithNewContent(repo, sessions)\\n   308→\\n   309→\\tif len(sessionsWithContent) == 0 {\\n   310→\\t\\t// No new content — no trailer needed\\n   311→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no content to link\\\",\\n   312→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   313→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   314→\\t\\t\\tslog.Int(\\\"sessions_found\\\", len(sessions)),\\n   315→\\t\\t)\\n   316→\\t\\treturn nil\\n   317→\\t}\\n   318→\\n   319→\\t// Read current commit message\\n   320→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   321→\\tif err != nil {\\n   322→\\t\\treturn nil\\n   323→\\t}\\n   324→\\n   325→\\tmessage := string(content)\\n   326→\\n   327→\\t// Check if trailer already exists (ParseCheckpoint validates format, so found==true means valid)\\n   328→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   329→\\t\\t// Trailer already exists (e.g., amend) - keep it\\n   330→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: trailer already exists\\\",\\n   331→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   332→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   333→\\t\\t\\tslog.String(\\\"existing_checkpoint_id\\\", existingCpID.String()),\\n   334→\\t\\t)\\n   335→\\t\\treturn nil\\n   336→\\t}\\n   337→\\n   338→\\t// Generate a fresh checkpoint ID\\n   339→\\tcheckpointID, err := id.Generate()\\n   340→\\tif err != nil {\\n   341→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   342→\\t}\\n   343→\\n   344→\\t// Determine agent type and last prompt from session\\n   345→\\tagentType := DefaultAgentType // default for backward compatibility\\n   346→\\tvar lastPrompt string\\n   347→\\tif len(sessionsWithContent) > 0 {\\n   348→\\t\\tfirstSession := sessionsWithContent[0]\\n   349→\\t\\tif firstSession.AgentType != \\\"\\\" {\\n   350→\\t\\t\\tagentType = firstSession.AgentType\\n   351→\\t\\t}\\n   352→\\t\\tlastPrompt = s.getLastPrompt(repo, firstSession)\\n   353→\\t}\\n   354→\\n   355→\\t// Prepare prompt for display: collapse newlines/whitespace, then truncate (rune-safe)\\n   356→\\tdisplayPrompt := stringutil.TruncateRunes(stringutil.CollapseWhitespace(lastPrompt), 80, \\\"...\\\")\\n   357→\\n   358→\\t// Add trailer differently based on commit source\\n   359→\\tswitch source {\\n   360→\\tcase \\\"message\\\":\\n   361→\\t\\t// Using -m or -F: ask user interactively whether to add trailer\\n   362→\\t\\t// (comments won't be stripped by git in this mode)\\n   363→\\n   364→\\t\\t// Build context string for interactive prompt\\n   365→\\t\\tvar promptContext string\\n   366→\\t\\tif displayPrompt != \\\"\\\" {\\n   367→\\t\\t\\tpromptContext = \\\"You have an active \\\" + string(agentType) + \\\" session.\\\\nLast Prompt: \\\" + displayPrompt\\n   368→\\t\\t}\\n   369→\\n   370→\\t\\tif !askConfirmTTY(\\\"Link this commit to \\\"+string(agentType)+\\\" session context?\\\", promptContext, true) {\\n   371→\\t\\t\\t// User declined - don't add trailer\\n   372→\\t\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: user declined trailer\\\",\\n   373→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   374→\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n   375→\\t\\t\\t)\\n   376→\\t\\t\\treturn nil\\n   377→\\t\\t}\\n   378→\\t\\tmessage = addCheckpointTrailer(message, checkpointID)\\n   379→\\tdefault:\\n   380→\\t\\t// Normal editor flow: add trailer with explanatory comment (will be stripped by git)\\n   381→\\t\\tmessage = addCheckpointTrailerWithComment(message, checkpointID, string(agentType), displayPrompt)\\n   382→\\t}\\n   383→\\n   384→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: trailer added\\\",\\n   385→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   386→\\t\\tslog.String(\\\"source\\\", source),\\n   387→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   388→\\t)\\n   389→\\n   390→\\t// Write updated message back\\n   391→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   392→\\t\\treturn nil\\n   393→\\t}\\n   394→\\n   395→\\treturn nil\\n   396→}\\n   397→\\n   398→// handleAmendCommitMsg handles the prepare-commit-msg hook for amend operations\\n   399→// (source=\\\"commit\\\"). It preserves existing trailers or restores from LastCheckpointID.\\n   400→func (s *ManualCommitStrategy) handleAmendCommitMsg(logCtx context.Context, commitMsgFile string) error {\\n   401→\\tstart := time.Now()\\n   402→\\tdefer logging.LogDuration(logCtx, slog.LevelDebug, \\\"handleAmendCommitMsg total\\\", start)\\n   403→\\n   404→\\t// Read current commit message\\n   405→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   406→\\tif err != nil {\\n   407→\\t\\treturn nil\\n   408→\\t}\\n   409→\\n   410→\\tmessage := string(content)\\n   411→\\n   412→\\t// If message already has a trailer, keep it unchanged\\n   413→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   414→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend preserves existing trailer\\\",\\n   415→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   416→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", existingCpID.String()),\\n   417→\\t\\t)\\n   418→\\t\\treturn nil\\n   419→\\t}\\n   420→\\n   421→\\t// No trailer in message — check if any session has LastCheckpointID to restore\\n   422→\\tworktreePath, err := GetWorktreePath()\\n   423→\\tif err != nil {\\n   424→\\t\\treturn nil\\n   425→\\t}\\n   426→\\n   427→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   428→\\tif err != nil || len(sessions) == 0 {\\n   429→\\t\\treturn nil\\n   430→\\t}\\n   431→\\n   432→\\t// For amend, HEAD^ is the commit being amended, and HEAD is where we are now.\\n   433→\\t// We need to match sessions whose BaseCommit equals HEAD (the commit being amended\\n   434→\\t// was created from this base). This prevents stale sessions from injecting\\n   435→\\t// unrelated checkpoint IDs.\\n   436→\\trepo, repoErr := OpenRepository()\\n   437→\\tif repoErr != nil {\\n   438→\\t\\treturn nil\\n   439→\\t}\\n   440→\\thead, headErr := repo.Head()\\n   441→\\tif headErr != nil {\\n   442→\\t\\treturn nil\\n   443→\\t}\\n   444→\\tcurrentHead := head.Hash().String()\\n   445→\\n   446→\\t// Find first matching session with LastCheckpointID to restore.\\n   447→\\t// LastCheckpointID is set after condensation completes.\\n   448→\\tfor _, state := range sessions {\\n   449→\\t\\tif state.BaseCommit != currentHead {\\n   450→\\t\\t\\tcontinue\\n   451→\\t\\t}\\n   452→\\t\\tif state.LastCheckpointID.IsEmpty() {\\n   453→\\t\\t\\tcontinue\\n   454→\\t\\t}\\n   455→\\t\\tcpID := state.LastCheckpointID\\n   456→\\t\\tsource := \\\"LastCheckpointID\\\"\\n   457→\\n   458→\\t\\t// Restore the trailer\\n   459→\\t\\tmessage = addCheckpointTrailer(message, cpID)\\n   460→\\t\\tif writeErr := os.WriteFile(commitMsgFile, []byte(message), 0o600); writeErr != nil {\\n   461→\\t\\t\\treturn nil\\n   462→\\t\\t}\\n   463→\\n   464→\\t\\tlogging.Info(logCtx, \\\"prepare-commit-msg: restored trailer on amend\\\",\\n   465→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   466→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   467→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   468→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   469→\\t\\t)\\n   470→\\t\\treturn nil\\n   471→\\t}\\n   472→\\n   473→\\t// No checkpoint ID found - leave message unchanged\\n   474→\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend with no checkpoint to restore\\\",\\n   475→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   476→\\t)\\n   477→\\treturn nil\\n   478→}\\n   479→\\n   480→// PostCommit is called by the git post-commit hook after a commit is created.\\n   481→// Uses the session state machine to determine what action to take per session:\\n   482→//   - ACTIVE → condense immediately (each commit gets its own checkpoint)\\n   483→//   - IDLE → condense immediately\\n   484→//   - ENDED → condense if files touched, discard if empty\\n   485→//\\n   486→// After condensation for ACTIVE sessions, remaining uncommitted files are\\n   487→// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n   488→//\\n   489→// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n   490→// and were condensed during this PostCommit.\\n   491→\\n   492→// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n   493→// Each session in the loop gets its own handler with per-session context.\\n   494→// Handler methods use the *State parameter from ApplyTransition (same pointer\\n   495→// as the state being transitioned) rather than capturing state separately.\\n   496→type postCommitActionHandler struct {\\n   497→\\ts                      *ManualCommitStrategy\\n   498→\\tlogCtx                 context.Context\\n   499→\\trepo                   *git.Repository\\n   500→\\tcheckpointID           id.CheckpointID\\n   501→\\thead                   *plumbing.Reference\\n   502→\\tcommit                 *object.Commit\\n   503→\\tnewHead                string\\n   504→\\tshadowBranchName       string\\n   505→\\tshadowBranchesToDelete map[string]struct{}\\n   506→\\tcommittedFileSet       map[string]struct{}\\n   507→\\thasNew                 bool\\n   508→\\tfilesTouchedBefore     []string\\n   509→\\n   510→\\t// Output: set by handler methods, read by caller after TransitionAndLog.\\n   511→\\tcondensed bool\\n   512→}\\n   513→\\n   514→func (h *postCommitActionHandler) HandleCondense(state *session.State) error {\\n   515→\\tshouldCondense := h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   516→\\n   517→\\tlogging.Debug(h.logCtx, \\\"post-commit: HandleCondense decision\\\",\\n   518→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   519→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   520→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   521→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   522→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   523→\\t)\\n   524→\\n   525→\\tif shouldCondense {\\n   526→\\t\\th.condensed = h.s.condenseAndUpdateState(h.logCtx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet)\\n   527→\\t} else {\\n   528→\\t\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n   529→\\t}\\n   530→\\treturn nil\\n   531→}\\n   532→\\n   533→func (h *postCommitActionHandler) HandleCondenseIfFilesTouched(state *session.State) error {\\n   534→\\tshouldCondense := len(state.FilesTouched) > 0 && h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   535→\\n   536→\\tlogging.Debug(h.logCtx, \\\"post-commit: HandleCondenseIfFilesTouched decision\\\",\\n   537→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   538→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   539→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   540→\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n   541→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   542→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   543→\\t)\\n   544→\\n   545→\\tif shouldCondense {\\n   546→\\t\\th.condensed = h.s.condenseAndUpdateState(h.logCtx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet)\\n   547→\\t} else {\\n   548→\\t\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n   549→\\t}\\n   550→\\treturn nil\\n   551→}\\n   552→\\n   553→// shouldCondenseWithOverlapCheck returns true if the session should be condensed\\n   554→// into this commit. Requires both that hasNew is true AND that the session's files\\n   555→// overlap with the committed files with matching content.\\n   556→//\\n   557→// This prevents stale sessions (ACTIVE sessions where the agent was killed, or\\n   558→// ENDED/IDLE sessions with carry-forward files) from being condensed into every\\n   559→// unrelated commit.\\n   560→//\\n   561→// filesTouchedBefore is populated from:\\n   562→//   - state.FilesTouched for IDLE/ENDED sessions (set via SaveStep/SaveTaskStep -> mergeFilesTouched)\\n   563→//   - transcript extraction for ACTIVE sessions when FilesTouched is empty\\n   564→//\\n   565→// When filesTouchedBefore is empty:\\n   566→//   - For ACTIVE sessions: fail-open (trust hasNew) because the agent may be\\n   567→//     mid-turn before any files are saved to state.\\n   568→//   - For IDLE/ENDED sessions: return false because there are no files to\\n   569→//     overlap with the commit.\\n   570→func (h *postCommitActionHandler) shouldCondenseWithOverlapCheck(isActive bool) bool {\\n   571→\\tif !h.hasNew {\\n   572→\\t\\treturn false\\n   573→\\t}\\n   574→\\tif len(h.filesTouchedBefore) == 0 {\\n   575→\\t\\treturn isActive // ACTIVE: fail-open; IDLE/ENDED: no files = no overlap\\n   576→\\t}\\n   577→\\t// Only check files that were actually changed in this commit.\\n   578→\\t// Without this, files that exist in the tree but weren't changed\\n   579→\\t// would pass the \\\"modified file\\\" check in filesOverlapWithContent\\n   580→\\t// (because the file exists in the parent tree), causing stale\\n   581→\\t// sessions to be incorrectly condensed.\\n   582→\\tvar committedTouchedFiles []string\\n   583→\\tfor _, f := range h.filesTouchedBefore {\\n   584→\\t\\tif _, ok := h.committedFileSet[f]; ok {\\n   585→\\t\\t\\tcommittedTouchedFiles = append(committedTouchedFiles, f)\\n   586→\\t\\t}\\n   587→\\t}\\n   588→\\tif len(committedTouchedFiles) == 0 {\\n   589→\\t\\treturn false\\n   590→\\t}\\n   591→\\treturn filesOverlapWithContent(h.repo, h.shadowBranchName, h.commit, committedTouchedFiles)\\n   592→}\\n   593→\\n   594→func (h *postCommitActionHandler) HandleDiscardIfNoFiles(state *session.State) error {\\n   595→\\tif len(state.FilesTouched) == 0 {\\n   596→\\t\\tlogging.Debug(h.logCtx, \\\"post-commit: skipping empty ended session (no files to condense)\\\",\\n   597→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   598→\\t\\t)\\n   599→\\t}\\n   600→\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n   601→\\treturn nil\\n   602→}\\n   603→\\n   604→func (h *postCommitActionHandler) HandleWarnStaleSession(_ *session.State) error {\\n   605→\\t// Not produced by EventGitCommit; no-op for exhaustiveness.\\n   606→\\treturn nil\\n   607→}\\n   608→\\n   609→// During rebase/cherry-pick/revert operations, phase transitions are skipped entirely.\\n   610→//\\n   611→\\n   612→func (s *ManualCommitStrategy) PostCommit() error {\\n   613→\\tstart := time.Now()\\n   614→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   615→\\tdefer logging.LogDuration(logCtx, slog.LevelDebug, \\\"PostCommit total\\\", start)\\n   616→\\n   617→\\trepo, err := OpenRepository()\\n   618→\\tif err != nil {\\n   619→\\t\\treturn nil\\n   620→\\t}\\n   621→\\n   622→\\t// Get HEAD commit to check for trailer\\n   623→\\thead, err := repo.Head()\\n   624→\\tif err != nil {\\n   625→\\t\\treturn nil\\n   626→\\t}\\n   627→\\n   628→\\tcommit, err := repo.CommitObject(head.Hash())\\n   629→\\tif err != nil {\\n   630→\\t\\treturn nil\\n   631→\\t}\\n   632→\\n   633→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   634→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   635→\\tif !found {\\n   636→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   637→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   638→\\t\\ts.postCommitUpdateBaseCommitOnly(logCtx, head)\\n   639→\\t\\treturn nil\\n   640→\\t}\\n   641→\\n   642→\\tworktreePath, err := GetWorktreePath()\\n   643→\\tif err != nil {\\n   644→\\t\\treturn nil\\n   645→\\t}\\n   646→\\n   647→\\t// Find all active sessions for this worktree\\n   648→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   649→\\tif err != nil || len(sessions) == 0 {\\n   650→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   651→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   652→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   653→\\t\\t)\\n   654→\\t\\treturn nil\\n   655→\\t}\\n   656→\\n   657→\\t// Build transition context\\n   658→\\tisRebase := isGitSequenceOperation()\\n   659→\\ttransitionCtx := session.TransitionContext{\\n   660→\\t\\tIsRebaseInProgress: isRebase,\\n   661→\\t}\\n   662→\\n   663→\\tif isRebase {\\n   664→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   665→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   666→\\t\\t)\\n   667→\\t}\\n   668→\\n   669→\\t// Track shadow branch names and whether they can be deleted\\n   670→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   671→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   672→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   673→\\n   674→\\tnewHead := head.Hash().String()\\n   675→\\tcommittedFileSet := filesChangedInCommit(commit)\\n   676→\\n   677→\\tfor _, state := range sessions {\\n   678→\\t\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   679→\\n   680→\\t\\t// Check for new content (needed for TransitionContext and condensation).\\n   681→\\t\\t// Fail-open: if content check errors, assume new content exists so we\\n   682→\\t\\t// don't silently skip data that should have been condensed.\\n   683→\\t\\t//\\n   684→\\t\\t// For ACTIVE sessions: the commit has a checkpoint trailer (verified above),\\n   685→\\t\\t// meaning PrepareCommitMsg already determined this commit is session-related.\\n   686→\\t\\t// The trailer is only added when either:\\n   687→\\t\\t//   - No TTY (agent/subagent committing) — added unconditionally\\n   688→\\t\\t//   - TTY (human committing) — added after content detection confirmed agent work\\n   689→\\t\\t// In both cases, PrepareCommitMsg already validated this commit. We trust\\n   690→\\t\\t// that decision here. Transcript-based re-validation is unreliable because\\n   691→\\t\\t// subagent transcripts may not be available yet (subagent still running).\\n   692→\\t\\tvar hasNew bool\\n   693→\\t\\tif state.Phase.IsActive() {\\n   694→\\t\\t\\thasNew = true\\n   695→\\t\\t} else {\\n   696→\\t\\t\\tvar contentErr error\\n   697→\\t\\t\\thasNew, contentErr = s.sessionHasNewContent(repo, state)\\n   698→\\t\\t\\tif contentErr != nil {\\n   699→\\t\\t\\t\\thasNew = true\\n   700→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: error checking session content, assuming new content\\\",\\n   701→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   702→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", contentErr.Error()),\\n   703→\\t\\t\\t\\t)\\n   704→\\t\\t\\t}\\n   705→\\t\\t}\\n   706→\\t\\ttransitionCtx.HasFilesTouched = len(state.FilesTouched) > 0\\n   707→\\n   708→\\t\\t// Save FilesTouched BEFORE TransitionAndLog — the handler's condensation\\n   709→\\t\\t// clears it, but we need the original list for carry-forward computation.\\n   710→\\t\\t// For mid-session commits (ACTIVE, no shadow branch), state.FilesTouched may be empty\\n   711→\\t\\t// because no SaveStep/Stop has been called yet. Extract files from transcript.\\n   712→\\t\\tfilesTouchedBefore := make([]string, len(state.FilesTouched))\\n   713→\\t\\tcopy(filesTouchedBefore, state.FilesTouched)\\n   714→\\t\\tif len(filesTouchedBefore) == 0 && state.Phase.IsActive() && state.TranscriptPath != \\\"\\\" {\\n   715→\\t\\t\\tfilesTouchedBefore = s.extractFilesFromLiveTranscript(state)\\n   716→\\t\\t}\\n   717→\\n   718→\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward prep\\\",\\n   719→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   720→\\t\\t\\tslog.Bool(\\\"is_active\\\", state.Phase.IsActive()),\\n   721→\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n   722→\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   723→\\t\\t\\tslog.Any(\\\"files\\\", filesTouchedBefore),\\n   724→\\t\\t)\\n   725→\\n   726→\\t\\t// Run the state machine transition with handler for strategy-specific actions.\\n   727→\\t\\thandler := &postCommitActionHandler{\\n   728→\\t\\t\\ts:                      s,\\n   729→\\t\\t\\tlogCtx:                 logCtx,\\n   730→\\t\\t\\trepo:                   repo,\\n   731→\\t\\t\\tcheckpointID:           checkpointID,\\n   732→\\t\\t\\thead:                   head,\\n   733→\\t\\t\\tcommit:                 commit,\\n   734→\\t\\t\\tnewHead:                newHead,\\n   735→\\t\\t\\tshadowBranchName:       shadowBranchName,\\n   736→\\t\\t\\tshadowBranchesToDelete: shadowBranchesToDelete,\\n   737→\\t\\t\\tcommittedFileSet:       committedFileSet,\\n   738→\\t\\t\\thasNew:                 hasNew,\\n   739→\\t\\t\\tfilesTouchedBefore:     filesTouchedBefore,\\n   740→\\t\\t}\\n   741→\\n   742→\\t\\tif err := TransitionAndLog(state, session.EventGitCommit, transitionCtx, handler); err != nil {\\n   743→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: post-commit action handler error: %v\\\\n\\\", err)\\n   744→\\t\\t}\\n   745→\\n   746→\\t\\t// Record checkpoint ID for ACTIVE sessions so HandleTurnEnd can finalize\\n   747→\\t\\t// with full transcript. IDLE/ENDED sessions already have complete transcripts.\\n   748→\\t\\t// NOTE: This check runs AFTER TransitionAndLog updated the phase. It relies on\\n   749→\\t\\t// ACTIVE + GitCommit → ACTIVE (phase stays ACTIVE). If that state machine\\n   750→\\t\\t// transition ever changed, this guard would silently stop recording IDs.\\n   751→\\t\\tif handler.condensed && state.Phase.IsActive() {\\n   752→\\t\\t\\tstate.TurnCheckpointIDs = append(state.TurnCheckpointIDs, checkpointID.String())\\n   753→\\t\\t}\\n   754→\\n   755→\\t\\t// Carry forward remaining uncommitted files so the next commit gets its\\n   756→\\t\\t// own checkpoint ID. This applies to ALL phases — if a user splits their\\n   757→\\t\\t// commit across two `git commit` invocations, each gets a 1:1 checkpoint.\\n   758→\\t\\t// Uses content-aware comparison: if user did `git add -p` and committed\\n   759→\\t\\t// partial changes, the file still has remaining agent changes to carry forward.\\n   760→\\t\\tif handler.condensed {\\n   761→\\t\\t\\tremainingFiles := filesWithRemainingAgentChanges(repo, shadowBranchName, commit, filesTouchedBefore, committedFileSet)\\n   762→\\t\\t\\tstate.FilesTouched = remainingFiles\\n   763→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward decision (content-aware)\\\",\\n   764→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   765→\\t\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   766→\\t\\t\\t\\tslog.Int(\\\"committed_files\\\", len(committedFileSet)),\\n   767→\\t\\t\\t\\tslog.Int(\\\"remaining_files\\\", len(remainingFiles)),\\n   768→\\t\\t\\t\\tslog.Any(\\\"remaining\\\", remainingFiles),\\n   769→\\t\\t\\t\\tslog.Any(\\\"committed_files\\\", committedFileSet),\\n   770→\\t\\t\\t)\\n   771→\\t\\t\\tif len(remainingFiles) > 0 {\\n   772→\\t\\t\\t\\ts.carryForwardToNewShadowBranch(logCtx, repo, state, remainingFiles)\\n   773→\\t\\t\\t}\\n   774→\\t\\t}\\n   775→\\n   776→\\t\\t// Save the updated state\\n   777→\\t\\tif err := s.saveSessionState(state); err != nil {\\n   778→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to update session state: %v\\\\n\\\", err)\\n   779→\\t\\t}\\n   780→\\n   781→\\t\\t// Only preserve shadow branch for active sessions that were NOT condensed.\\n   782→\\t\\t// Condensed sessions already have their data on entire/checkpoints/v1.\\n   783→\\t\\tif state.Phase.IsActive() && !handler.condensed {\\n   784→\\t\\t\\tuncondensedActiveOnBranch[shadowBranchName] = true\\n   785→\\t\\t}\\n   786→\\t}\\n   787→\\n   788→\\t// Clean up shadow branches — only delete when ALL sessions on the branch are non-active\\n   789→\\t// or were condensed during this PostCommit.\\n   790→\\tfor shadowBranchName := range shadowBranchesToDelete {\\n   791→\\t\\tif uncondensedActiveOnBranch[shadowBranchName] {\\n   792→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: preserving shadow branch (active session exists)\\\",\\n   793→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   794→\\t\\t\\t)\\n   795→\\t\\t\\tcontinue\\n   796→\\t\\t}\\n   797→\\t\\tif err := deleteShadowBranch(repo, shadowBranchName); err != nil {\\n   798→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to clean up %s: %v\\\\n\\\", shadowBranchName, err)\\n   799→\\t\\t} else {\\n   800→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Cleaned up shadow branch: %s\\\\n\\\", shadowBranchName)\\n   801→\\t\\t\\tlogging.Info(logCtx, \\\"shadow branch deleted\\\",\\n   802→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   803→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   804→\\t\\t\\t)\\n   805→\\t\\t}\\n   806→\\t}\\n   807→\\n   808→\\treturn nil\\n   809→}\\n   810→\\n   811→// condenseAndUpdateState runs condensation for a session and updates