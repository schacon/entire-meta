\tif err != nil {\\n   208→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get index, falling back to filename check\\\",\\n   209→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   210→\\t\\t)\\n   211→\\t\\treturn hasOverlappingFiles(stagedFiles, filesTouched)\\n   212→\\t}\\n   213→\\n   214→\\t// Build a map of index entries for O(1) lookup (avoid O(n*m) nested loop)\\n   215→\\tindexEntries := make(map[string]plumbing.Hash, len(idx.Entries))\\n   216→\\tfor _, entry := range idx.Entries {\\n   217→\\t\\tindexEntries[entry.Name] = entry.Hash\\n   218→\\t}\\n   219→\\n   220→\\t// Check each staged file\\n   221→\\tfor _, stagedPath := range stagedFiles {\\n   222→\\t\\tif !touchedSet[stagedPath] {\\n   223→\\t\\t\\tcontinue // Not in filesTouched, skip\\n   224→\\t\\t}\\n   225→\\n   226→\\t\\t// Check if this is a modified file (exists in HEAD) or new file\\n   227→\\t\\t_, headErr := headTree.File(stagedPath)\\n   228→\\t\\tisModified := headErr == nil\\n   229→\\n   230→\\t\\t// Modified files always count as overlap (user edited session's work)\\n   231→\\t\\t// This includes deletions - if file exists in HEAD and is being deleted,\\n   232→\\t\\t// that's the agent's work being committed.\\n   233→\\t\\tif isModified {\\n   234→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: modified file counts as overlap\\\",\\n   235→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   236→\\t\\t\\t)\\n   237→\\t\\t\\treturn true\\n   238→\\t\\t}\\n   239→\\n   240→\\t\\t// For new files, check content against shadow branch\\n   241→\\t\\tstagedHash, found := indexEntries[stagedPath]\\n   242→\\t\\tif !found {\\n   243→\\t\\t\\tcontinue // Not in index (shouldn't happen but be safe)\\n   244→\\t\\t}\\n   245→\\n   246→\\t\\t// Get file from shadow branch tree\\n   247→\\t\\tshadowFile, err := shadowTree.File(stagedPath)\\n   248→\\t\\tif err != nil {\\n   249→\\t\\t\\t// File not in shadow branch - can't verify content overlap.\\n   250→\\t\\t\\t// Don't assume overlap just because it's in filesTouched.\\n   251→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: file not in shadow tree, skipping\\\",\\n   252→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   253→\\t\\t\\t)\\n   254→\\t\\t\\tcontinue\\n   255→\\t\\t}\\n   256→\\n   257→\\t\\t// Compare hashes - exact match means file is unchanged\\n   258→\\t\\tif stagedHash == shadowFile.Hash {\\n   259→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: new file content match found\\\",\\n   260→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   261→\\t\\t\\t\\tslog.String(\\\"hash\\\", stagedHash.String()),\\n   262→\\t\\t\\t)\\n   263→\\t\\t\\treturn true\\n   264→\\t\\t}\\n   265→\\n   266→\\t\\t// Hashes differ - check if there's significant content overlap.\\n   267→\\t\\t// This distinguishes partial staging (user kept some agent content) from\\n   268→\\t\\t// \\\"reverted and replaced\\\" (user wrote completely different content).\\n   269→\\t\\tshadowContent, shadowErr := shadowFile.Contents()\\n   270→\\t\\tif shadowErr != nil {\\n   271→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to read shadow content\\\",\\n   272→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   273→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   274→\\t\\t\\t)\\n   275→\\t\\t\\tcontinue\\n   276→\\t\\t}\\n   277→\\n   278→\\t\\t// Read staged content from object store\\n   279→\\t\\tstagedBlob, blobErr := repo.BlobObject(stagedHash)\\n   280→\\t\\tif blobErr != nil {\\n   281→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to read staged blob\\\",\\n   282→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   283→\\t\\t\\t\\tslog.String(\\\"error\\\", blobErr.Error()),\\n   284→\\t\\t\\t)\\n   285→\\t\\t\\tcontinue\\n   286→\\t\\t}\\n   287→\\t\\tstagedReader, readerErr := stagedBlob.Reader()\\n   288→\\t\\tif readerErr != nil {\\n   289→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get staged reader\\\",\\n   290→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   291→\\t\\t\\t\\tslog.String(\\\"error\\\", readerErr.Error()),\\n   292→\\t\\t\\t)\\n   293→\\t\\t\\tcontinue\\n   294→\\t\\t}\\n   295→\\t\\tstagedBytes, readErr := io.ReadAll(stagedReader)\\n   296→\\t\\t_ = stagedReader.Close() // Best effort close\\n   297→\\t\\tif readErr != nil {\\n   298→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to read staged content\\\",\\n   299→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   300→\\t\\t\\t\\tslog.String(\\\"error\\\", readErr.Error()),\\n   301→\\t\\t\\t)\\n   302→\\t\\t\\tcontinue\\n   303→\\t\\t}\\n   304→\\t\\tstagedContent := string(stagedBytes)\\n   305→\\n   306→\\t\\t// Check for significant content overlap\\n   307→\\t\\tif hasSignificantContentOverlap(stagedContent, shadowContent) {\\n   308→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: new file has partial overlap (partial staging)\\\",\\n   309→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   310→\\t\\t\\t)\\n   311→\\t\\t\\treturn true\\n   312→\\t\\t}\\n   313→\\n   314→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: new file has no significant overlap (reverted & replaced)\\\",\\n   315→\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   316→\\t\\t\\tslog.String(\\\"staged_hash\\\", stagedHash.String()),\\n   317→\\t\\t\\tslog.String(\\\"shadow_hash\\\", shadowFile.Hash.String()),\\n   318→\\t\\t)\\n   319→\\t}\\n   320→\\n   321→\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: no overlapping files found\\\",\\n   322→\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n   323→\\t\\tslog.Int(\\\"files_touched\\\", len(filesTouched)),\\n   324→\\t)\\n   325→\\treturn false\\n   326→}\\n   327→\\n   328→// hasOverlappingFiles checks if any file in stagedFiles appears in filesTouched.\\n   329→// This