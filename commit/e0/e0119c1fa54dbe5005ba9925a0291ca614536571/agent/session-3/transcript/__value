ion-related work by comparing\\n    17→// file content (not just filenames) against the shadow branch. This enables accurate\\n    18→// detection of the \\\"reverted and replaced\\\" scenario where a user:\\n    19→// 1. Reverts session changes (e.g., git checkout -- file.txt)\\n    20→// 2. Creates completely different content in the same file\\n    21→// 3. Commits the new content\\n    22→//\\n    23→// In this scenario, the commit should NOT get a checkpoint trailer because the\\n    24→// session's work was discarded, not incorporated.\\n    25→//\\n    26→// The key distinction:\\n    27→// - Modified files (exist in parent commit): Always count as overlap, regardless of\\n    28→//   content changes. The user is editing session's work.\\n    29→// - New files (don't exist in parent): Require content match against shadow branch.\\n    30→//   If content differs completely, the session's work was likely reverted & replaced.\\n    31→\\n    32→// filesOverlapWithContent checks if any file in filesTouched overlaps with the committed\\n    33→// content, using content-aware comparison to detect the \\\"reverted and replaced\\\" scenario.\\n    34→//\\n    35→// This is used in PostCommit to determine if a session has work in the commit.\\n    36→func filesOverlapWithContent(repo *git.Repository, shadowBranchName string, headCommit *object.Commit, filesTouched []string) bool {\\n    37→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n    38→\\n    39→\\t// Build set of filesTouched for quick lookup\\n    40→\\ttouchedSet := make(map[string]bool)\\n    41→\\tfor _, f := range filesTouched {\\n    42→\\t\\ttouchedSet[f] = true\\n    43→\\t}\\n    44→\\n    45→\\t// Get HEAD commit tree (the committed content)\\n    46→\\theadTree, err := headCommit.Tree()\\n    47→\\tif err != nil {\\n    48→\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: failed to get HEAD tree, falling back to filename check\\\",\\n    49→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    50→\\t\\t)\\n    51→\\t\\treturn len(filesTouched) > 0 // Fall back: assume overlap if any files touched\\n    52→\\t}\\n    53→\\n    54→\\t// Get shadow branch tree (the session's content)\\n    55→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n    56→\\tshadowRef, err := repo.Reference(refName, true)\\n    57→\\tif err != nil {\\n    58→\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: shadow branch not found, falling back to filename check\\\",\\n    59→\\t\\t\\tslog.String(\\\"branch\\\", shadowBranchName),\\n    60→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    61→\\t\\t)\\n    62→\\t\\treturn len(filesTouched) > 0 // Fall back: assume overlap if any files touched\\n    63→\\t}\\n    64→\\n    65→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n    66→\\tif err != nil {\\n    67→\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: failed to get shadow commit, falling back to filename check\\\",\\n    68→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    69→\\t\\t)\\n    70→\\t\\treturn len(filesTouched) > 0\\n    71→\\t}\\n    72→\\n    73→\\tshadowTree, err := shadowCommit.Tree()\\n    74→\\tif err != nil {\\n    75→\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: failed to get shadow tree, falling back to filename check\\\",\\n    76→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    77→\\t\\t)\\n    78→\\t\\treturn len(filesTouched) > 0\\n    79→\\t}\\n    80→\\n    81→\\t// Get the parent commit tree to determine if files are modified vs newly created.\\n    82→\\t// For modified files (exist in parent), we count as overlap regardless of content\\n    83→\\t// because the user is editing the session's work.\\n    84→\\t// For newly created files (don't exist in parent), we check content to detect\\n    85→\\t// the \\\"reverted and replaced\\\" scenario where user deleted session's work and\\n    86→\\t// created something completely different.\\n    87→\\tvar parentTree *object.Tree\\n    88→\\tif headCommit.NumParents() > 0 {\\n    89→\\t\\tif parent, err := headCommit.Parent(0); err == nil {\\n    90→\\t\\t\\tif pTree, err := parent.Tree(); err == nil {\\n    91→\\t\\t\\t\\tparentTree = pTree\\n    92→\\t\\t\\t}\\n    93→\\t\\t}\\n    94→\\t}\\n    95→\\n    96→\\t// Check each file in filesTouched\\n    97→\\tfor _, filePath := range filesTouched {\\n    98→\\t\\t// Get file from HEAD tree (the committed content)\\n    99→\\t\\theadFile, err := headTree.File(filePath)\\n   100→\\t\\tif err != nil {\\n   101→\\t\\t\\t// File not in HEAD commit. Check if this is a deletion (existed in parent).\\n   102→\\t\\t\\t// Deletions count as overlap because the agent's action (deleting the file)\\n   103→\\t\\t\\t// is being committed - we want the session context linked to this commit.\\n   104→\\t\\t\\tif parentTree != nil {\\n   105→\\t\\t\\t\\tif _, parentErr := parentTree.File(filePath); parentErr == nil {\\n   106→\\t\\t\\t\\t\\t// File existed in parent but not in HEAD - this is a deletion\\n   107→\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: deleted file counts as overlap\\\",\\n   108→\\t\\t\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   109→\\t\\t\\t\\t\\t)\\n   110→\\t\\t\\t\\t\\treturn true\\n   111→\\t\\t\\t\\t}\\n   112→\\t\\t\\t}\\n   113→\\t\\t\\t// File didn't exist in parent either - not a deletion, skip\\n   114→\\t\\t\\tcontinue\\n   115→\\t\\t}\\n   116→\\n   117→\\t\\t// Check if this is a modified file (exists in parent) or new file\\n   118→\\t\\tisModified := false\\n   119→\\t\\tif parentTree != nil {\\n   120→\\t\\t\\tif _, err := parentTree.File(filePath); err == nil {\\n   121→\\t\\t\\t\\tisModified = true\\n   122→\\t\\t\\t}\\n   123→\\t\\t}\\n   124→\\n   125→\\t\\t// Modified files always count as overlap (user edited session's work)\\n   126→\\t\\tif isModified {\\n   127→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: modified file counts as overlap\\\",\\n   128→\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   129→\\t\\t\\t)\\n   130→\\t\\t\\treturn true\\n   131→\\t\\t}\\n   132→\\n   133→\\t\\t// For new files, check content against shadow branch\\n   134→\\t\\tshadowFile, err := shadowTree.File(filePath)\\n   135→\\t\\tif err != nil {\\n   136→\\t\\t\\t// File not in shadow branch - this shouldn't happen but skip it\\n   137→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: file in filesTouched but not in shadow branch\\\",\\n   138→\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   139→\\t\\t\\t)\\n   140→\\t\\t\\tcontinue\\n   141→\\t\\t}\\n   142→\\n   143→\\t\\t// Compare by hash (blob hash) - exact content match required for new files\\n   144→\\t\\tif headFile.Hash == shadowFile.Hash {\\n   145→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: new file content match found\\\",\\n   146→\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   147→\\t\\t\\t\\tslog.String(\\\"hash\\\", headFile.Hash.String()),\\n   148→\\t\\t\\t)\\n   149→\\t\\t\\treturn true\\n   150→\\t\\t}\\n   151→\\n   152→\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: new file content mismatch (may be reverted & replaced)\\\",\\n   153→\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   154→\\t\\t\\tslog.String(\\\"head_hash\\\", headFile.Hash.String()),\\n   155→\\t\\t\\tslog.String(\\\"shadow_hash\\\", shadowFile.Hash.String()),\\n   156→\\t\\t)\\n   157→\\t}\\n   158→\\n   159→\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: no overlapping files found\\\",\\n   160→\\t\\tslog.Int(\\\"files_checked\\\", len(filesTouched)),\\n   161→\\t)\\n   162→\\treturn false\\n   163→}\\n   164→\\n   165→// stagedFilesOverlapWithContent checks if any staged file overlaps with filesTouched,\\n   166→// distinguishing between modified files (always overlap) and new files (check content).\\n   167→//\\n   168→// For modified files (already exist in HEAD), we count as overlap because the user\\n   169→// is