ate); err != nil {\\n   474→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse session state: %w\\\", err)\\n   475→\\t}\\n   476→\\treturn &state, nil\\n   477→}\\n   478→\\n   479→// WriteSessionState writes the session state for the given session ID.\\n   480→// This is useful for tests that need to manipulate session state directly.\\n   481→func (env *TestEnv) WriteSessionState(sessionID string, state *strategy.SessionState) error {\\n   482→\\tenv.T.Helper()\\n   483→\\n   484→\\tstateDir := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\")\\n   485→\\tif err := os.MkdirAll(stateDir, 0o755); err != nil {\\n   486→\\t\\treturn fmt.Errorf(\\\"failed to create session state dir: %w\\\", err)\\n   487→\\t}\\n   488→\\n   489→\\tstateFile := filepath.Join(stateDir, sessionID+\\\".json\\\")\\n   490→\\n   491→\\tdata, err := json.MarshalIndent(state, \\\"\\\", \\\"  \\\")\\n   492→\\tif err != nil {\\n   493→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   494→\\t}\\n   495→\\n   496→\\tif err := os.WriteFile(stateFile, data, 0o644); err != nil {\\n   497→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   498→\\t}\\n   499→\\treturn nil\\n   500→}\\n   501→\\n   502→// GeminiHookRunner executes Gemini CLI hooks in the test environment.\\n   503→type GeminiHookRunner struct {\\n   504→\\tRepoDir          string\\n   505→\\tGeminiProjectDir string\\n   506→\\tT                interface {\\n   507→\\t\\tHelper()\\n   508→\\t\\tFatalf(format string, args ...interface{})\\n   509→\\t\\tLogf(format string, args ...interface{})\\n   510→\\t}\\n   511→}\\n   512→\\n   513→// NewGeminiHookRunner creates a new Gemini hook runner for the given repo directory.\\n   514→func NewGeminiHookRunner(repoDir, geminiProjectDir string, t interface {\\n   515→\\tHelper()\\n   516→\\tFatalf(format string, args ...interface{})\\n   517→\\tLogf(format string, args ...interface{})\\n   518→}) *GeminiHookRunner {\\n   519→\\treturn &GeminiHookRunner{\\n   520→\\t\\tRepoDir:          repoDir,\\n   521→\\t\\tGeminiProjectDir: geminiProjectDir,\\n   522→\\t\\tT:                t,\\n   523→\\t}\\n   524→}\\n   525→\\n   526→// runGeminiHookWithInput runs a Gemini hook with the given input.\\n   527→func (r *GeminiHookRunner) runGeminiHookWithInput(hookName string, input interface{}) error {\\n   528→\\tr.T.Helper()\\n   529→\\n   530→\\tinputJSON, err := json.Marshal(input)\\n   531→\\tif err != nil {\\n   532→\\t\\treturn fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n   533→\\t}\\n   534→\\n   535→\\treturn r.runGeminiHookInRepoDir(hookName, inputJSON)\\n   536→}\\n   537→\\n   538→func (r *GeminiHookRunner) runGeminiHookInRepoDir(hookName string, inputJSON []byte) error {\\n   539→\\t// Run using the shared test binary\\n   540→\\t// Command structure: entire hooks gemini <hook-name>\\n   541→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n   542→\\tcmd.Dir = r.RepoDir\\n   543→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   544→\\tcmd.Env = append(os.Environ(),\\n   545→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n   546→\\t)\\n   547→\\n   548→\\toutput, err := cmd.CombinedOutput()\\n   549→\\tif err != nil {\\n   550→\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n   551→\\t\\t\\thookName, err, inputJSON, output)\\n   552→\\t}\\n   553→\\n   554→\\tr.T.Logf(\\\"Gemini hook %s output: %s\\\", hookName, output)\\n   555→\\treturn nil\\n   556→}\\n   557→\\n   558→// runGeminiHookWithOutput runs a Gemini hook and returns both stdout and stderr separately.\\n   559→func (r *GeminiHookRunner) runGeminiHookWithOutput(hookName string, inputJSON []byte) HookOutput {\\n   560→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n   561→\\tcmd.Dir = r.RepoDir\\n   562→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   563→\\tcmd.Env = append(os.Environ(),\\n   564→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n   565→\\t)\\n   566→\\n   567→\\tvar stdout, stderr bytes.Buffer\\n   568→\\tcmd.Stdout = &stdout\\n   569→\\tcmd.Stderr = &stderr\\n   570→\\n   571→\\terr := cmd.Run()\\n   572→\\treturn HookOutput{\\n   573→\\t\\tStdout: stdout.Bytes(),\\n   574→\\t\\tStderr: stderr.Bytes(),\\n   575→\\t\\tErr:    err,\\n   576→\\t}\\n   577→}\\n   578→\\n   579→// SimulateGeminiBeforeAgent simulates the BeforeAgent hook for Gemini CLI.\\n   580→// This is equivalent to Claude Code's UserPromptSubmit.\\n   581→func (r *GeminiHookRunner) SimulateGeminiBeforeAgent(sessionID string) error {\\n   582→\\tr.T.Helper()\\n   583→\\n   584→\\tinput := map[string]string{\\n   585→\\t\\t\\\"session_id\\\":      sessionID,\\n   586→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   587→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   588→\\t\\t\\\"hook_event_name\\\": \\\"BeforeAgent\\\",\\n   589→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   590→\\t\\t\\\"prompt\\\":          \\\"test prompt\\\",\\n   591→\\t}\\n   592→\\n   593→\\treturn r.runGeminiHookWithInput(\\\"before-agent\\\", input)\\n   594→}\\n   595→\\n   596→// SimulateGeminiBeforeAgentWithOutput simulates the BeforeAgent hook and returns the output.\\n   597→func (r *GeminiHookRunner) SimulateGeminiBeforeAgentWithOutput(sessionID string) HookOutput {\\n   598→\\tr.T.Helper()\\n   599→\\n   600→\\tinput := map[string]string{\\n   601→\\t\\t\\\"session_id\\\":      sessionID,\\n   602→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   603→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   604→\\t\\t\\\"hook_event_name\\\": \\\"BeforeAgent\\\",\\n   605→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   606→\\t\\t\\\"prompt\\\":          \\\"test prompt\\\",\\n   607→\\t}\\n   608→\\n   609→\\tinputJSON, err := json.Marshal(input)\\n   610→\\tif err != nil {\\n   611→\\t\\treturn HookOutput{Err: fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)}\\n   612→\\t}\\n   613→\\n   614→\\treturn r.runGeminiHookWithOutput(\\\"before-agent\\\", inputJSON)\\n   615→}\\n   616→\\n   617→// SimulateGeminiAfterAgent simulates the AfterAgent hook for Gemini CLI.\\n   618→// This is the primary checkpoint creation hook, equivalent to Claude Code's Stop hook.\\n   619→func (r *GeminiHookRunner) SimulateGeminiAfterAgent(sessionID, transcriptPath string) error {\\n   620→\\tr.T.Helper()\\n   621→\\n   622→\\tinput := map[string]string{\\n   623→\\t\\t\\\"session_id\\\":      sessionID,\\n   624→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   625→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   626→\\t\\t\\\"hook_event_name\\\": \\\"AfterAgent\\\",\\n   627→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   628→\\t}\\n   629→\\n   630→\\treturn r.runGeminiHookWithInput(\\\"after-agent\\\", input)\\n   631→}\\n   632→\\n   633→// SimulateGeminiSessionEnd simulates the SessionEnd hook for Gemini CLI.\\n   634→// This is a cleanup/fallback hook that fires on explicit exit.\\n   635→func (r *GeminiHookRunner) SimulateGeminiSessionEnd(sessionID, transcriptPath string) error {\\n   636→\\tr.T.Helper()\\n   637→\\n   638→\\tinput := map[string]string{\\n   639→\\t\\t\\\"session_id\\\":      sessionID,\\n   640→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   641→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   642→\\t\\t\\\"hook_event_name\\\": \\\"SessionEnd\\\",\\n   643→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   644→\\t\\t\\\"reason\\\":          \\\"exit\\\",\\n   645→\\t}\\n   646→\\n   647→\\treturn r.runGeminiHookWithInput(\\\"session-end\\\", input)\\n   648→}\\n   649→\\n   650→// GeminiSession represents a simulated Gemini CLI session.\\n   651→type GeminiSession struct {\\n   652→\\tID             string // Raw model session ID (e.g., \\\"gemini-session-1\\\")\\n   653→\\tTranscriptPath string\\n   654→\\tenv            *TestEnv\\n   655→}\\n   656→\\n   657→// NewGeminiS