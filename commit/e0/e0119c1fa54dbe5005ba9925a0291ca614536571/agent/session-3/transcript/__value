 PostTodoInput struct {\\n   336→\\tSessionID      string\\n   337→\\tTranscriptPath string\\n   338→\\tToolUseID      string // The TodoWrite tool use ID\\n   339→\\tTodos          []Todo // The todo list\\n   340→}\\n   341→\\n   342→// SimulatePostTodo simulates the PostToolUse[TodoWrite] hook.\\n   343→func (r *HookRunner) SimulatePostTodo(input PostTodoInput) error {\\n   344→\\tr.T.Helper()\\n   345→\\n   346→\\thookInput := map[string]interface{}{\\n   347→\\t\\t\\\"session_id\\\":      input.SessionID,\\n   348→\\t\\t\\\"transcript_path\\\": input.TranscriptPath,\\n   349→\\t\\t\\\"tool_name\\\":       \\\"TodoWrite\\\",\\n   350→\\t\\t\\\"tool_use_id\\\":     input.ToolUseID,\\n   351→\\t\\t\\\"tool_input\\\": map[string]interface{}{\\n   352→\\t\\t\\t\\\"todos\\\": input.Todos,\\n   353→\\t\\t},\\n   354→\\t\\t\\\"tool_response\\\": map[string]interface{}{},\\n   355→\\t}\\n   356→\\n   357→\\treturn r.runHookWithInput(\\\"post-todo\\\", hookInput)\\n   358→}\\n   359→\\n   360→// SimulatePostTodo is a convenience method on TestEnv.\\n   361→func (env *TestEnv) SimulatePostTodo(input PostTodoInput) error {\\n   362→\\tenv.T.Helper()\\n   363→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   364→\\treturn runner.SimulatePostTodo(input)\\n   365→}\\n   366→\\n   367→// ClearSessionState removes the session state file for the given session ID.\\n   368→// This simulates what happens when a user commits their changes (session is \\\"completed\\\").\\n   369→// Used in tests to allow sequential sessions to run without triggering concurrent session warnings.\\n   370→func (env *TestEnv) ClearSessionState(sessionID string) error {\\n   371→\\tenv.T.Helper()\\n   372→\\n   373→\\t// Session state is stored in .git/entire-sessions/<session-id>.json\\n   374→\\tstateFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\", sessionID+\\\".json\\\")\\n   375→\\n   376→\\tif err := os.Remove(stateFile); err != nil && !os.IsNotExist(err) {\\n   377→\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   378→\\t}\\n   379→\\treturn nil\\n   380→}\\n   381→\\n   382→// HookOutput contains the result of running a hook.\\n   383→type HookOutput struct {\\n   384→\\tStdout []byte\\n   385→\\tStderr []byte\\n   386→\\tErr    error\\n   387→}\\n   388→\\n   389→// runHookWithOutput runs a hook and returns both stdout and stderr separately.\\n   390→func (r *HookRunner) runHookWithOutput(hookName string, inputJSON []byte) HookOutput {\\n   391→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"claude-code\\\", hookName)\\n   392→\\tcmd.Dir = r.RepoDir\\n   393→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   394→\\tcmd.Env = append(os.Environ(),\\n   395→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+r.ClaudeProjectDir,\\n   396→\\t)\\n   397→\\n   398→\\tvar stdout, stderr bytes.Buffer\\n   399→\\tcmd.Stdout = &stdout\\n   400→\\tcmd.Stderr = &stderr\\n   401→\\n   402→\\terr := cmd.Run()\\n   403→\\treturn HookOutput{\\n   404→\\t\\tStdout: stdout.Bytes(),\\n   405→\\t\\tStderr: stderr.Bytes(),\\n   406→\\t\\tErr:    err,\\n   407→\\t}\\n   408→}\\n   409→\\n   410→// SimulateUserPromptSubmitWithOutput simulates the UserPromptSubmit hook and returns the output.\\n   411→func (r *HookRunner) SimulateUserPromptSubmitWithOutput(sessionID string) HookOutput {\\n   412→\\tr.T.Helper()\\n   413→\\n   414→\\tinput := map[string]string{\\n   415→\\t\\t\\\"session_id\\\":      sessionID,\\n   416→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   417→\\t}\\n   418→\\n   419→\\tinputJSON, err := json.Marshal(input)\\n   420→\\tif err != nil {\\n   421→\\t\\treturn HookOutput{Err: fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)}\\n   422→\\t}\\n   423→\\n   424→\\treturn r.runHookWithOutput(\\\"user-prompt-submit\\\", inputJSON)\\n   425→}\\n   426→\\n   427→// SimulateUserPromptSubmitWithOutput is a convenience method on TestEnv.\\n   428→func (env *TestEnv) SimulateUserPrompt