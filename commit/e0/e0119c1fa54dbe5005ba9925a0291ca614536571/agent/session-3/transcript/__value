me)\\n   373→\\tshadowRef, err := repo.Reference(refName, true)\\n   374→\\tif err != nil {\\n   375→\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: shadow branch not found, falling back to file subtraction\\\",\\n   376→\\t\\t\\tslog.String(\\\"branch\\\", shadowBranchName),\\n   377→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   378→\\t\\t)\\n   379→\\t\\treturn subtractFilesByName(filesTouched, committedFiles)\\n   380→\\t}\\n   381→\\n   382→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   383→\\tif err != nil {\\n   384→\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: failed to get shadow commit, falling back to file subtraction\\\",\\n   385→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   386→\\t\\t)\\n   387→\\t\\treturn subtractFilesByName(filesTouched, committedFiles)\\n   388→\\t}\\n   389→\\n   390→\\tshadowTree, err := shadowCommit.Tree()\\n   391→\\tif err != nil {\\n   392→\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: failed to get shadow tree, falling back to file subtraction\\\",\\n   393→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   394→\\t\\t)\\n   395→\\t\\treturn subtractFilesByName(filesTouched, committedFiles)\\n   396→\\t}\\n   397→\\n   398→\\tvar remaining []string\\n   399→\\n   400→\\tfor _, filePath := range filesTouched {\\n   401→\\t\\t// If file wasn't committed at all, it definitely has remaining changes\\n   402→\\t\\tif _, wasCommitted := committedFiles[filePath]; !wasCommitted {\\n   403→\\t\\t\\tremaining = append(remaining, filePath)\\n   404→\\t\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: file not committed, keeping\\\",\\n   405→\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   406→\\t\\t\\t)\\n   407→\\t\\t\\tcontinue\\n   408→\\t\\t}\\n   409→\\n   410→\\t\\t// File was committed - check if committed content matches shadow branch\\n   411→\\t\\tshadowFile, err := shadowTree.File(filePath)\\n   412→\\t\\tif err != nil {\\n   413→\\t\\t\\t// File not in shadow branch - nothing to carry forward for this file\\n   414→\\t\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: file not in shadow branch, skipping\\\",\\n   415→\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   416→\\t\\t\\t)\\n   417→\\t\\t\\tcontinue\\n   418→\\t\\t}\\n   419→\\n   420→\\t\\tcommitFile, err := commitTree.File(filePath)\\n   421→\\t\\tif err != nil {\\n   422→\\t\\t\\t// File not in commit tree (deleted?) - keep it if it's in shadow\\n   423→\\t\\t\\tremaining = append(remaining, filePath)\\n   424→\\t\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: file not in commit tree but in shadow, keeping\\\",\\n   425→\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   426→\\t\\t\\t)\\n   427→\\t\\t\\tcontinue\\n   428→\\t\\t}\\n   429→\\n   430→\\t\\t// Compare hashes - if different, there are still uncommitted agent changes\\n   431→\\t\\tif commitFile.Hash != shadowFile.Hash {\\n   432→\\t\\t\\tremaining = append(remaining, filePath)\\n   433→\\t\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: content mismatch, keeping for carry-forward\\\",\\n   434→\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   435→\\t\\t\\t\\tslog.String(\\\"commit_hash\\\", commitFile.Hash.String()[:7]),\\n   436→\\t\\t\\t\\tslog.String(\\\"shadow_hash\\\", shadowFile.Hash.String()[:7]),\\n   437→\\t\\t\\t)\\n   438→\\t\\t} else {\\n   439→\\t\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: content fully committed\\\",\\n   440→\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   441→\\t\\t\\t)\\n   442→\\t\\t}\\n   443→\\t}\\n   444→\\n   445→\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: result\\\",\\n   446→\\t\\tslog.Int(\\\"files_touched\\\", len(filesTouched)),\\n   447→\\t\\tslog.Int(\\\"committed_files\\\", len(committedFiles)),\\n   448→\\t\\tslog.Int(\\\"remaining_files\\\", len(remaining)),\\n   449→\\t)\\n   450→\\n   451→\\treturn remaining\\n   452→}\\n   453→\\n   454→// subtractFilesByName returns files from filesTouched that are NOT in committedFiles.\\n   455→// This is a fallback when content-aware comparison isn't possible.\\n   456→func subtractFilesByName(filesTouched []string, committedFiles map[string]struct{}) []string {\\n   457→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   458→\\tlogging.Debug(logCtx, \\\"subtractFilesByName: \\\",\\n   459→\\t\\tslog.Any(\\\"filesTouched\\\", filesTouched),\\n   460→\\t\\tslog.Any(\\\"committedFiles\\\", committedFiles),\\n   461→\\t)\\n   462→\\tvar remaining []string\\n   463→\\tfor _, f := range filesTouched {\\n   464→\\t\\tif _, committed := committedFiles[f]; !committed {\\n   465→\\t\\t\\tremaining = append(remaining, f)\\n   466→\\t\\t}\\n   467→\\t}\\n   468→\\treturn remaining\\n   469→}\\n   470→\\n   471→// hasSignificantContentOverlap checks if two file contents share significant lines.\\n   472→// This distinguishes partial staging (user kept some agent content) from\\n   473→// \\\"reverted and replaced\\\" (user wrote completely different content).\\n   474→//\\n   475→// For larger files, we require at least 2 matching lines because a single match\\n   476→// (like \\\"package main\\\") is likely common boilerplate. For small files (≤ 2\\n   477→// significant lines in either file), any single match counts as overlap since\\n   478→// there aren't many lines to match anyway.\\n   479→//\\n   480→// The function filters out trivial lines (short lines < 10 chars like braces,\\n   481→// empty lines, etc.) because these commonly appear in many files and don't\\n   482→// indicate meaningful overlap.\\n   483→func hasSignificantContentOverlap(stagedContent, shadowContent string) bool {\\n   484→\\t// Build set of significant lines from shadow (agent) content\\n   485→\\tshadowLines := extractSignificantLines(shadowContent)\\n   486→\\n   487→\\t// Build set of significant lines from staged (user) content\\n 