nt = 0\\n   842→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   843→\\n   844→\\t// Clear attribution tracking — condensation already used these values\\n   845→\\tstate.PromptAttributions = nil\\n   846→\\tstate.PendingPromptAttribution = nil\\n   847→\\tstate.FilesTouched = nil\\n   848→\\n   849→\\t// Save checkpoint ID so subsequent commits can reuse it (e.g., amend restores trailer)\\n   850→\\tstate.LastCheckpointID = checkpointID\\n   851→\\n   852→\\tshortID := state.SessionID\\n   853→\\tif len(shortID) > 8 {\\n   854→\\t\\tshortID = shortID[:8]\\n   855→\\t}\\n   856→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Condensed session %s: %s (%d checkpoints)\\\\n\\\",\\n   857→\\t\\tshortID, result.CheckpointID, result.CheckpointsCount)\\n   858→\\n   859→\\tlogging.Info(logCtx, \\\"session condensed\\\",\\n   860→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   861→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   862→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   863→\\t\\tslog.Int(\\\"transcript_lines\\\", result.TotalTranscriptLines),\\n   864→\\t)\\n   865→\\n   866→\\treturn true\\n   867→}\\n   868→\\n   869→// updateBaseCommitIfChanged updates BaseCommit to newHead if it changed.\\n   870→// Only updates ACTIVE sessions. IDLE/ENDED sessions should NOT have their\\n   871→// BaseCommit updated, as this would cause them to be incorrectly associated\\n   872→// with a new shadow branch and potentially condensed on future commits.\\n   873→func (s *ManualCommitStrategy) updateBaseCommitIfChanged(logCtx context.Context, state *SessionState, newHead string) {\\n   874→\\t// Only update ACTIVE sessions. IDLE/ENDED sessions are kept around for\\n   875→\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n   876→\\tif !state.Phase.IsActive() {\\n   877→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updateBaseCommitIfChanged skipped non-active session\\\",\\n   878→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   879→\\t\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   880→\\t\\t)\\n   881→\\t\\treturn\\n   882→\\t}\\n   883→\\tif state.BaseCommit != newHead {\\n   884→\\t\\tstate.BaseCommit = newHead\\n   885→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updated BaseCommit\\\",\\n   886→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   887→\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n   888→\\t\\t)\\n   889→\\t}\\n   890→}\\n   891→\\n   892→// postCommitUpdateBaseCommitOnly updates BaseCommit for all sessions on the current\\n   893→// worktree when a commit has no Entire-Checkpoint trailer. This prevents BaseCommit\\n   894→// from going stale, which would cause future PrepareCommitMsg calls to skip the\\n   895→// session (BaseCommit != currentHeadHash filter).\\n   896→//\\n   897→// Unlike the full PostCommit flow, this does NOT fire EventGitCommit or trigger\\n   898→// condensation — it only keeps BaseCommit in sync with HEAD.\\n   899→func (s *ManualCommitStrategy) postCommitUpdateBaseCommitOnly(logCtx context.Context, head *plumbing.Reference) {\\n   900→\\tworktreePath, err := GetWorktreePath()\\n   901→\\tif err != nil {\\n   902→\\t\\treturn // Silent failure — hooks must be resilient\\n   903→\\t}\\n   904→\\n   905→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   906→\\tif err != nil || len(sessions) == 0 {\\n   907→\\t\\treturn\\n   908→\\t}\\n   909→\\n   910→\\tnewHead := head.Hash().String()\\n   911→\\tfor _, state := range sessions {\\n   912→\\t\\t// Only update active sessions. Idle/ended sessions are kept around for\\n   913→\\t\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n   914→\\t\\tif !state.Phase.IsActive() {\\n   915→\\t\\t\\tcontinue\\n   916→\\t\\t}\\n   917→\\t\\tif state.BaseCommit != newHead {\\n   918→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit (no trailer): updating BaseCommit\\\",\\n   919→\\