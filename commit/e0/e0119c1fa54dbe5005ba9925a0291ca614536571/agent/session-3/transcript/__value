→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   975→\\t\\t)\\n   976→\\t\\treturn s.sessionHasNewContentFromLiveTranscript(repo, state)\\n   977→\\t}\\n   978→\\n   979→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   980→\\tif err != nil {\\n   981→\\t\\treturn false, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   982→\\t}\\n   983→\\n   984→\\ttree, err := commit.Tree()\\n   985→\\tif err != nil {\\n   986→\\t\\treturn false, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   987→\\t}\\n   988→\\n   989→\\t// Look for transcript file\\n   990→\\tmetadataDir := paths.EntireMetadataDir + \\\"/\\\" + state.SessionID\\n   991→\\tvar transcriptLines int\\n   992→\\tvar hasTranscriptFile bool\\n   993→\\n   994→\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   995→\\t\\thasTranscriptFile = true\\n   996→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   997→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n   998→\\t\\t}\\n   999→\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n  1000→\\t\\thasTranscriptFile = true\\n  1001→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n  1002→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n  1003→\\t\\t}\\n  1004→\\t}\\n  1005→\\n  1006→\\t// If shadow branch exists but has no transcript (e.g., carry-forward from mid-session commit),\\n  1007→\\t// check if the session has FilesTouched. Carry-forward sets FilesTouched with remaining files.\\n  1008→\\tif !hasTranscriptFile {\\n  1009→\\t\\tif len(state.FilesTouched) > 0 {\\n  1010→\\t\\t\\t// Shadow branch has files from carry-forward - check if staged files overlap\\n  1011→\\t\\t\\t// AND have matching content (content-aware check).\\n  1012→\\t\\t\\tstagedFiles := getStagedFiles(repo)\\n  1013→\\t\\t\\tif len(stagedFiles) > 0 {\\n  1014→\\t\\t\\t\\t// PrepareCommitMsg context: check staged files overlap with content\\n  1015→\\t\\t\\t\\tresult := stagedFilesOverlapWithContent(repo, tree, stagedFiles, state.FilesTouched)\\n  1016→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript, carry-forward with staged files\\\",\\n  1017→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1018→\\t\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n  1019→\\t\\t\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1020→\\t\\t\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n  1021→\\t\\t\\t\\t)\\n  1022→\\t\\t\\t\\treturn result, nil\\n  1023→\\t\\t\\t}\\n  1024→\\t\\t\\t// PostCommit context: no staged files, but we have carry-forward files.\\n  1025→\\t\\t\\t// Return true and let the caller do the overlap check with committed files.\\n  1026→\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript, carry-forward without staged files (post-commit context)\\\",\\n  1027→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1028→\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n  1029→\\t\\t\\t)\\n  1030→\\t\\t\\treturn true, nil\\n  1031→\\t\\t}\\n  1032→\\t\\t// No transcript and no FilesTouched - fall back to live transcript check\\n  1033→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript and no files touched, checking live transcript\\\",\\n  1034→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1035→\\t\\t)\\n  1036→\\t\\treturn s.sessionHasNewContentFromLiveTranscript(repo, state)\\n  1037→\\t}\\n  1038→\\n  1039→\\t// Check if there's new content to condense. Two cases:\\n  1040→\\t// 1. Transcript has grown since last condensation (new prompts/responses)\\n  1041→\\t// 2. FilesTouched has files not yet committed (carry-forward scenario)\\n  1042→\\t//\\n  1043→\\t// For PrepareCommitMsg context, we verify staged files overlap with session's files\\n  1044→\\t// using content-aware matching to detect reverted files.\\n  1045→\\t// For PostCommit context, getStagedFiles() is empty (files already committed),\\n  1046→\\t// so we return true and let the caller do the overlap check via filesOverlapWithContent.\\n  1047→\\n  1048→\\thasTranscriptGrowth := transcriptLines > state.CheckpointTranscriptStart\\n  1049→\\thasUncommittedFiles := len(state.FilesTouched) > 0\\n  1050→\\n  1051→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: transcript check\\\",\\n  1052→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1053→\\t\\tslog.Int(\\\"transcript_lines\\\", transcriptLines),\\n  1054→\\t\\tslog.Int(\\\"checkpoint_transcript_start\\\", state.CheckpointTranscriptStart),\\n  1055→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1056→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1057→\\t)\\n  1058→\\n  1059→\\tif !hasTranscriptGrowth && !hasUncommittedFiles {\\n  1060→\\t\\treturn false, nil // No new content and no carry-forward files\\n  1061→\\t}\\n  1062→\\n  1063→\\t// Check if staged files overlap with session's files with content-aware matching.\\n  1064→\\t// This is primarily for PrepareCommitMsg; in PostCommit, stagedFiles is empty.\\n  1065→\\tstagedFiles := getStagedFiles(repo)\\n  1066→\\tif len(stagedFiles) > 0 {\\n  1067→\\t\\tresult := stagedFilesOverlapWithContent(repo, tree, stagedFiles, state.FilesTouched)\\n  1068→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: staged files overlap check\\\",\\n  1069→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1070→\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1071→\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n  1072→\\t\\t)\\n  1073→\\t\\treturn result, nil\\n  1074→\\t}\\n  1075→\\n  1076→\\t// No staged files - either PostCommit context or edge case.\\n  1077→\\t// Return transcript growth status. For PostCommit with hasTranscriptFile=true,\\n  1078→\\t// if there's no transcript growth, the session hasn't done new work since last checkpoint.\\n  1079→\\t// (Carry-forward creates a shadow branch WITHOUT transcript, handled in the block above.)\\n  1080→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no staged files, returning transcript growth\\\",\\n  1081→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1082→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1083→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1084→\\t)\\n  1085→\\treturn hasTranscriptGrowth, nil\\n  1086→}\\n  1087→\\n  1088→// sessionHasNewContentFromLiveTranscript checks if a session has new content\\n  1089→// by examining the live transcript file. This is used when no shadow branch exists\\n  1090→// (i.e., no Stop has happened yet) but the agent may have done work.\\n  1091→//\\n  1092→// Returns true if:\\n  1093→//  1. The transcript has grown since the last condensation, AND\\n  1094→//  2. The new transcript portion contains file modifications, AND\\n  1095→//  3. At least one modified file overlaps with the currently staged files\\n  1096→//\\n  1097→// The overlap check ensures we don't add checkpoint trailers to commits that are\\n  1098→// unrelated to the agent's recent changes.\\n  1099→//\\n  1100→// This handles the scenario where the agent commits mid-session before Stop.\\n  1101→func (s *ManualCommitStrategy) sessionHasNewContentFromLiveTranscript(repo *git.Repository, state *SessionState) (bool, error) {\\n  1102→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1103→\\n  1104→\\tmodifiedFiles, ok := s.extractNewModifiedFilesFromLiveTranscript(state)\\n  1105→\\tif !ok || len(modifiedFiles) == 0 {\\n  1106→\\t\\treturn false, nil\\n  1107→\\t}\\n  1108→\\n  1109→\\tlogging.Debug(logCtx, \\\"live transcript check: found file modifications\\\",\\n  1110→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1111→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1112→\\t)\\n  1113→\\n  1114→\\t// Check if any modified files overlap with currently staged files\\n  1115→\\t// This ensures we only add checkpoint trailers to commits that include\\n  1116→\\t// files the agent actually modified\\n  1117→\\tstagedFiles := getStagedFiles(repo)\\n  1118→\\n  1119→\\tlogging.Debug(logCtx, \\\"live transcript check: comparing staged vs modified\\\",\\n  1120→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1121→\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1122→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1123→\\t)\\n  1124→\\n  1125→\\tif !hasOverlappingFiles(stagedFiles, modifiedFiles) {\\n  1126→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no overlap between staged and modified files\\\",\\n  1127→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1128→\\t\\t)\\n  1129→\\t\\treturn false, nil // No overlap - staged files are unrelated to agent's work\\n  1130→\\t}\\n  1131→\\n  1132→\\treturn true, nil\\n  1133→}\\n  1134→\\n  1135→// extractFilesFromLiveTranscript extracts modified file paths from the live transcript.\\n  1136→// Returns empty slice if extraction fails (fail-open behavior for hooks).\\n  1137→// Extracts files from the transcript starting at CheckpointTranscriptStart, which gives\\n  1138→// files touched since the last condensation — used for carry-forward computation.\\n  1139→func (s *ManualCommitStrategy) extractFilesFromLiveTranscript(state *SessionState) []string {\\n  1140→\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n  1141→}\\n  1142→\\n  1143→// extractNewModifiedFilesFromLiveTranscript extracts modified files from the live\\n  1144→// transcript that are NEW since the last condensation. Returns the normalized file list\\n  1145→// and whether the extraction succeeded. Used by sessionHasNewContentFromLiveTranscript\\n  1146→// to detect agent work.\\n  1147→func (s *ManualCommitStrategy) extractNewModifiedFilesFromLiveTranscript(state *SessionState) ([]string, bool) {\\n  1148→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1149→\\n  1150→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1151→\\t\\treturn nil, false\\n  1152→\\t}\\n  1153→\\n  1154→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1155→\\tif err != nil {\\n  1156→\\t\\treturn nil, false\\n  1157→\\t}\\n  1158→\\n  1159→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1160→\\tif !ok {\\n  1161→\\t\\treturn nil, false\\n  1162→\\t}\\n  1163→\\n  1164→\\t// Check if transcript has grown since last condensation\\n  1165→\\tcurrentPos, err := analyzer.GetTranscriptPosition(state.TranscriptPath)\\n  1166→\\tif err != nil {\\n  1167→\\t\\treturn nil, false\\n  1168→\\t}\\n  1169→\\tif currentPos <= state.CheckpointTranscriptStart {\\n  1170→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no new content\\\",\\n  1171→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1172→\\t\\t\\tslog.Int(\\\"current_pos\\\", currentPos),\\n  1173→\\t\\t\\tslog.Int(\\\"start_offset\\\", state.CheckpointTranscriptStart),\\n  1174→\\t\\t)\\n  1175→\\t\\treturn nil, true // No new content, but extraction succeeded\\n  1176→\\t}\\n  1177→\\n  1178→\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart), true\\n  1179→}\\n  1180→\\n  1181→// extractModifiedFilesFromLiveTranscript extracts modified files from the live transcript\\n  1182→// (including subagent transcripts) starting from the given offset, and normalizes them\\n  1183→// to repo-relative paths. Returns the normalized file list.\\n  1184→func (s *ManualCommitStrategy) extractModifiedFilesFromLiveTranscript(state *SessionState, offset int) []string {\\n  1185→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1186→\\n  1187→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1188→\\t\\treturn nil\\n  1189→\\t}\\n  1190→\\n  1191→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1192→\\tif err != nil {\\n  1193→\\t\\treturn nil\\n  1194→\\t}\\n  1195→\\n  1196→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1197→\\tif !ok {\\n  1198→\\t\\treturn nil\\n  1199→\\t}\\n  1200→\\n  1201→\\tvar modifiedFiles []string\\n  1202→\\n  1203→\\t// For Claude Code, use ExtractAllModifiedFiles which parses the main transcript\\n  1204→\\t// AND subagent transcripts in a single pass, avoiding redundant parsing.\\n  1205→\\tif state.AgentType == agent.AgentTypeClaudeCode {\\n  1206→\\t\\tsubagentsDir := filepath.Join(filepath.Dir(state.TranscriptPath), state.SessionID, \\\"subagents\\\")\\n  1207→\\t\\tallFiles, extractErr := claudecode.ExtractAllModifiedFiles(state.TranscriptPath, offset, subagentsDir)\\n  1208→\\t\\tif extractErr != nil {\\n  1209→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: extraction failed\\\",\\n  1210→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1211→\\t\\t\\t\\tslog.String(\\\"error\\\", extractErr.Error()),\\n  1212→\\t\\t\\t)\\n  1213→\\t\\t} else {\\n  1214→\\t\\t\\tmodifiedFiles = allFiles\\n  1215→\\t\\t}\\n  1216→\\t} else {\\n  1217→\\t\\tfiles, _, err := analyzer.ExtractModifiedFilesFromOffset(state.TranscriptPath, offset)\\n  1218→\\t\\tif err != nil {\\n  1219→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: main transcript extraction failed\\\",\\n  1220→\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1221→\\t\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1222→\\t\\t\\t)\\n  1223→\\t\\t} else {\\n  1224→\\t\\t\\tmodifiedFiles = files\\n  1225→\\t\\t}\\n  1226→\\t}\\n  1227→\\n  1228→\\tif len(modifiedFiles) == 0 {\\n  1229→\\t\\treturn nil\\n  1230→\\t}\\n  1231→\\n  1232→\\t// Normalize to repo-relative paths.\\n  1233→\\t// Transcript tool_use entries contain absolute paths (e.g., /Users/alex/project/src/main.go)\\n  1234→\\t// but getStagedFiles/committedFiles use repo-relative paths (e.g., src/main.go).\\n  1235→\\tbasePath := state.WorktreePath\\n  1236→\\tif basePath == \\\"\\\" {\\n  1237→\\t\\tif wp, wpErr := GetWorktreePath(); wpErr == nil {\\n  1238→\\t\\t\\tbasePath = wp\\n  1239→\\t\\t}\\n  1240→\\t}\\n  1241→\\tif basePath != \\\"\\\" {\\n  1242→\\t\\tnormalized := make([]string, 0, len(modifiedFiles))\\n  1243→\\t\\tfor _, f := range modifiedFiles {\\n  1244→\\t\\t\\tif rel := paths.ToRelativePath(f, basePath); rel != \\\"\\\" {\\n  1245→\\t\\t\\t\\tnormalized = append(normalized, rel)\\n  1246→\\t\\t\\t} else {\\n  1247→\\t\\t\\t\\tnormalized = append(normalized, f)\\n  1248→\\t\\t\\t}\\n  1249→\\t\\t}\\n  1250→\\t\\tmodifiedFiles = normalized\\n  1251→\\t}\\n  1252→\\n  1253→\\treturn modifiedFiles\\n  1254→}\\n  1255→\\n  1256→// addTrailerForAgentCommit handles the fast path when an agent is committing\\n  1257→// (ACTIVE session + no TTY). Generates a checkpoint ID and adds the trailer\\n  1258→// directly, bypassing content detection and interactive prompts.\\n  1259→//\\n  1260→//nolint:unparam // error return kept for consistency with hook methods that must return nil\\n  1261→func (s *ManualCommitStrategy) addTrailerForAgentCommit(logCtx context.Context, commitMsgFile string, state *SessionState, source string) error {\\n  1262→\\tcpID, err := id.Generate()\\n  1263→\\tif err != nil {\\n  1264→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1265→\\t}\\n  1266→\\n  1267→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n  1268→\\tif err != nil {\\n  1269→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1270→\\t}\\n  1271→\\n  1272→\\tmessage := string(content)\\n  1273→\\n  1274→\\t// Don't add if trailer already exists\\n  1275→\\tif _, found := trailers.ParseCheckpoint(message); found {\\n  1276→\\t\\treturn nil\\n  1277→\\t}\\n  1278→\\n  1279→\\tmessage = addCheckpointTrailer(message, cpID)\\n  1280→\\n  1281→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: agent commit trailer added\\\",\\n  1282→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n  1283→\\t\\tslog.String(\\\"source\\\", source),\\n  1284→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n  1285→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1286→\\t)\\n  1287→\\n  1288→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n  1289→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1290→\\t}\\n  1291→\\treturn nil\\n  1292→}\\n  1293→\\n  1294→// addCheckpointTrailer adds the Entire-Checkpoint trailer to a commit message.\\n  1295→// Handles proper trailer formatting (blank line before trailers if needed).\\n  1296→func addCheckpointTrailer(message string, checkpointID id.CheckpointID) string {\\n  1297→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1298→\\n  1299→\\t// If message already ends with trailers (lines starting with key:), just append\\n  1300→\\t// Otherwise, add a blank line first\\n  1301→\\tlines := strings.Split(strings.TrimRight(message, \\\"\\\\n\\\"), \\\"\\\\n\\\")\\n  1302→\\n  1303→\\t// Check if the message already ends with a trailer paragraph.\\n  1304→\\t// Git trailers must be in a separate paragraph (preceded by a blank line).\\n  1305→\\t// A single-paragraph message (e.g., just a subject line) cannot have trailers,\\n  1306→\\t// even if the subject contains \\\": \\\" (like conventional commits: \\\"docs: Add foo\\\").\\n  1307→\\t//\\n  1308→\\t// Scan from the bottom: find the last paragraph of non-comment content,\\n  1309→\\t// then check if it looks like trailers AND has a blank line above it.\\n  1310→\\thasTrailers := false\\n  1311→\\ti := len(lines) - 1\\n  1312→\\n  1313→\\t// Skip trailing comment lines\\n  1314→\\tfor i >= 0 && strings.HasPrefix(strings.TrimSpace(lines[i]), \\\"#\\\") {\\n  1315→\\t\\ti--\\n  1316→\\t}\\n  1317→\\n  1318→\\t// Check if the last non-comment line looks like a trailer\\n  1319→\\tif i >= 0 {\\n  1320→\\t\\tline := strings.TrimSpace(lines[i])\\n  1321→\\t\\tif line != \\\"\\\" && strings.Contains(line, \\\": \\\") {\\n  1322→\\t\\t\\t// Found a trailer-like line. Now scan upward past the trailer block\\n  1323→\\t\\t\\t// to verify there's a blank line (paragraph separator) above it.\\n  1324→\\t\\t\\tfor i > 0 {\\n  1325→\\t\\t\\t\\ti--\\n  1326→\\t\\t\\t\\tabove := strings.TrimSpace(lines[i])\\n  1327→\\t\\t\\t\\tif strings.HasPrefix(above, \\\"#\\\") {\\n  1328→\\t\\t\\t\\t\\tcontinue\\n  1329→\\t\\t\\t\\t}\\n  1330→\\t\\t\\t\\tif above == \\\"\\\" {\\n  1331→\\t\\t\\t\\t\\t// Blank line found above trailer block — real trailers\\n  1332→\\t\\t\\t\\t\\thasTrailers = true\\n  1333→\\t\\t\\t\\t\\tbreak\\n  1334→\\t\\t\\t\\t}\\n  1335→\\t\\t\\t\\tif !strings.Contains(above, \\\": \\\") {\\n  1336→\\t\\t\\t\\t\\t// Non-trailer, non-blank line — this is message body, not trailers\\n  1337→\\t\\t\\t\\t\\tbreak\\n  1338→\\t\\t\\t\\t}\\n  1339→\\t\\t\\t\\t// Another trailer-like line, keep scanning upward\\n  1340→\\t\\t\\t}\\n  1341→\\t\\t}\\n  1342→\\t}\\n  1343→\\n  1344→\\tif hasTrailers {\\n  1345→\\t\\t// Append trailer directly\\n  1346→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1347→\\t}\\n  1348→\\n  1349→\\t// Add blank line before trailer\\n  1350→\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1351→}\\n  1352→\\n  1353→// addCheckpointTrailerWithComment adds the Entire-Checkpoint trailer with an explanatory comment.\\n  1354→// The trailer is placed above the git comment block but below the user's message area,\\n  1355→// with a comment explaining that the user can remove it if they don't want to link the commit\\n  1356→// to the agent session. If prompt is non-empty, it's shown as context.\\n  1357→func addCheckpointTrailerWithComment(message string, checkpointID id.CheckpointID, agentName, prompt string) string {\\n  1358→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1359→\\tcommentLines := []string{\\n  1360→\\t\\t\\\"# Remove the Entire-Checkpoint trailer above if you don't want to link this commit to \\\" + agentName + \\\" session context.\\\",\\n  1361→\\t}\\n  1362→\\tif prompt != \\\"\\\" {\\n  1363→\\t\\tcommentLines = append(commentLines, \\\"# Last Prompt: \\\"+prompt)\\n  1364→\\t}\\n  1365→\\tcommentLines = append(commentLines, \\\"# The trailer will be added to your next commit based on this branch.\\\")\\n  1366→\\tcomment := strings.Join(commentLines, \\\"\\\\n\\\")\\n  1367→\\n  1368→\\tlines := strings.Split(message, \\\"\\\\n\\\")\\n  1369→\\n  1370→\\t// Find where the git comment block starts (first # line)\\n  1371→\\tcommentStart := -1\\n  1372→\\tfor i, line := range lines {\\n  1373→\\t\\tif strings.HasPrefix(line, \\\"#\\\") {\\n  1374→\\t\\t\\tcommentStart = i\\n  1375→\\t\\t\\tbreak\\n  1376→\\t\\t}\\n  1377→\\t}\\n  1378→\\n  1379→\\tif commentStart == -1 {\\n  1380→\\t\\t// No git comments, append trailer at the end\\n  1381→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\"\\n  1382→\\t}\\n  1383→\\n  1384→\\t// Split into user content and git comments\\n  1385→\\tuserContent := strings.Join(lines[:commentStart], \\\"\\\\n\\\")\\n  1386→\\tgitComments := strings.Join(lines[commentStart:], \\\"\\\\n\\\")\\n  1387→\\n  1388→\\t// Build result: user content, blank line, trailer, comment, blank line, git comments\\n  1389→\\tuserContent = strings.TrimRight(userContent, \\\"\\\\n\\\")\\n  1390→\\tif userContent == \\\"\\\" {\\n  1391→\\t\\t// No user content yet - leave space for them to type, then trailer\\n  1392→\\t\\t// Two newlines: first for user's message line, second for blank separator\\n  1393→\\t\\treturn \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1394→\\t}\\n  1395→\\treturn userContent + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1396→}\\n  1397→\\n  1398→// InitializeSession creates session state for a new session or updates an existing one.\\n  1399→// This implements the optional SessionInitializer interface.\\n  1400→// Called during UserPromptSubmit to allow git hooks to detect active sessions.\\n  1401→//\\n  1402→// If the session already exists and HEAD has moved (e.g., user committed), updates\\n  1403→// BaseCommit to the new HEAD so future checkpoints go to the correct shadow branch.\\n  1404→//\\n  1405→// If there's an existing shadow branch with commits from a different session ID,\\n  1406→// returns a SessionIDConflictError to prevent orphaning existing session work.\\n  1407→//\\n  1408→// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n  1409→// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n  1410→// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\n  1411→func (s *ManualCommitStrategy) InitializeSession(sessionID string, agentType agent.AgentType, transcriptPath string, userPrompt string) error {\\n  1412→\\trepo, err := OpenRepository()\\n  1413→\\tif err != nil {\\n  1414→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n  1415→\\t}\\n  1416→\\n  1417→\\t// Check if session already exists\\n  1418→\\tstate, err := s.loadSessionState(sessionID)\\n  1419→\\tif err != nil {\\n  1420→\\t\\treturn fmt.Errorf(\\\"failed to check session state: %w\\\", err)\\n  1421→\\t}\\n  1422→\\n  1423→\\tif state != nil && state.BaseCommit != \\\"\\\" {\\n  1424→\\t\\t// Session is fully initialized — apply phase transition for TurnStart.\\n  1425→\\t\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1426→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1427→\\t\\t}\\n  1428→\\n  1429→\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n  1430→\\t\\tturnID, err := id.Generate()\\n  1431→\\t\\tif err != nil {\\n  1432→\\t\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n  1433→\\t\\t}\\n  1434→\\t\\tstate.TurnID = turnID.String()\\n  1435→\\n  1436→\\t\\t// Backfill AgentType if empty or set to the generic default \\\"Agent\\\"\\n  1437→\\t\\tif !isSpecificAgentType(state.AgentType) && agentType != \\\"\\\" {\\n  1438→\\t\\t\\tstate.AgentType = agentType\\n  1439→\\t\\t}\\n  1440→\\n  1441→\\t\\t// Backfill FirstPrompt if empty (for sessions created before the first_prompt field was added)\\n  1442→\\t\\tif state.FirstPrompt == \\\"\\\" && userPrompt != \\\"\\\" {\\n  1443→\\t\\t\\tstate.FirstPrompt = truncatePromptForStorage(userPrompt)\\n  1444→\\t\\t}\\n  1445→\\n  1446→\\t\\t// Update transcript path if provided (may change on session resume)\\n  1447→\\t\\tif transcriptPath != \\\"\\\" && state.TranscriptPath != transcriptPath {\\n  1448→\\t\\t\\tstate.TranscriptPath = transcriptPath\\n  1449→\\t\\t}\\n  1450→\\n  1451→\\t\\t// Clear checkpoint IDs on every new prompt.\\n  1452→\\t\\t// LastCheckpointID is set during PostCommit, cleared at new prompt.\\n  1453→\\t\\t// TurnCheckpointIDs tracks mid-turn checkpoints for stop-time finalization.\\n  1454→\\t\\tstate.LastCheckpointID = \\\"\\\"\\n  1455→\\t\\tstate.TurnCheckpointIDs = nil\\n  1456→\\n  1457→\\t\\t// Calculate attribution at prompt start (BEFORE agent makes any changes)\\n  1458→\\t\\t// This captures user edits since the last checkpoint (or base commit for first prompt).\\n  1459→\\t\\t// IMPORTANT: Always calculate attribution, even for the first checkpoint, to capture\\n  1460→\\t\\t// user edits made before the first prompt. The inner CalculatePromptAttribution handles\\n  1461→\\t\\t// nil lastCheckpointTree by falling back to baseTree.\\n  1462→\\t\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n  1463→\\t\\tstate.PendingPromptAttribution = &promptAttr\\n  1464→\\n  1465→\\t\\t// Check if HEAD has moved (user pulled/rebased or committed)\\n  1466→\\t\\t// migrateShadowBranchIfNeeded handles renaming the shadow branch and updating state.BaseCommit\\n  1467→\\t\\tif _, err := s.migrateShadowBranchIfNeeded(repo, state); err != nil {\\n  1468→\\t\\t\\treturn fmt.Errorf(\\\"failed to check/migrate shadow branch: %w\\\", err)\\n  1469→\\t\\t}\\n  1470→\\n  1471→\\t\\tif err := s.saveSessionState(state); err != nil {\\n  1472→\\t\\t\\treturn fmt.Errorf(\\\"failed to update session state: %w\\\", err)\\n  1473→\\t\\t}\\n  1474→\\t\\treturn nil\\n  1475→\\t}\\n  1476→\\t// If state exists but BaseCommit is empty, it's a partial state from concurrent warning\\n  1477→\\t// Continue below to properly initialize it\\n  1478→\\n  1479→\\t// Initialize new session\\n  1480→\\tstate, err = s.initializeSession(repo, sessionID, agentType, transcriptPath, userPrompt)\\n  1481→\\tif err != nil {\\n  1482→\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n  1483→\\t}\\n  1484→\\n  1485→\\t// Apply phase transition: new session starts as ACTIVE.\\n  1486→\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1487→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1488→\\t}\\n  1489→\\n  1490→\\t// Calculate attribution for pre-prompt edits\\n  1491→\\t// This captures any user edits made before the first prompt\\n  1492→\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n  1493→\\tstate.PendingPromptAttribution = &promptAttr\\n  1494→\\tif err = s.saveSessionState(state); err != nil {\\n  1495→\\t\\treturn fmt.Errorf(\\\"failed to save attribution: %w\\\", err)\\n  1496→\\t}\\n  1497→\\n  1498→\\tfmt.Fprintf(os.Stderr, \\\"Initialized shadow session: %s\\\\n\\\", sessionID)\\n  1499→\\treturn nil\\n  1500→}\\n  1501→\\n  1502→// calculatePromptAttributionAtStart calculates attribution at prompt start (before agent runs).\\n  1503→// This captures user changes since the last checkpoint - no filtering needed since\\n  1504→// the agent hasn't made any changes yet.\\n  1505→//\\n  1506→// IMPORTANT: This reads from the worktree (not staging area) to match what WriteTemporary\\n  1507→// captures in checkpoints. If we read staged content but checkpoints capture worktree content,\\n  1508→// unstaged changes would be in the checkpoint but not counted in PromptAttribution, causing\\n  1509→// them to be incorrectly attributed to the agent later.\\n  1510→func (s *ManualCommitStrategy) calculatePromptAttributionAtStart(\\n  1511→\\trepo *git.Repository,\\n  1512→\\tstate *SessionState,\\n  1513→) PromptAttribution {\\n  1514→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n  1515→\\tnextCheckpointNum := state.StepCount + 1\\n  1516→\\tresult := PromptAttribution{CheckpointNumber: nextCheckpointNum}\\n  1517→\\n  1518→\\t// Get last checkpoint tree from shadow branch (if it exists)\\n  1519→\\t// For the first checkpoint, no shadow branch exists yet - this is fine,\\n  1520→\\t// CalculatePromptAttribution will use baseTree as the reference instead.\\n  1521→\\tvar lastCheckpointTree *object.Tree\\n  1522→\\tshadowBranchName := checkpoint.ShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n  1523→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1524→\\tref, err := repo.Reference(refName, true)\\n  1525→\\tif err != nil {\\n  1526→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: no shadow branch yet (first checkpoint)\\\",\\n  1527→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName))\\n  1528→\\t\\t// Continue with lastCheckpointTree = nil\\n  1529→\\t} else {\\n  1530→\\t\\tshadowCommit, err := repo.CommitObject(ref.Hash())\\n  1531→\\t\\tif err != nil {\\n  1532→\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: failed to get shadow commit\\\",\\n  1533→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", ref.Hash().String()),\\n  1534→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1535→\\t\\t\\t// Continue with lastCheckpointTree = nil\\n  1536→\\t\\t} else {\\n  1537→\\t\\t\\tlastCheckpointTree, err = shadowCommit.Tree()\\n  1538→\\t\\t\\tif err != nil {\\n  1539→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: failed to get shadow tree\\\",\\n  1540→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1541→\\t\\t\\t\\t// Continue with lastCheckpointTree = nil\\n  1542→\\t\\t\\t}\\n  1543→\\t\\t}\\n  1544→\\t}\\n  1545→\\n  1546→\\t// Get base tree for agent lines calculation\\n  1547→\\tvar baseTree *object.Tree\\n  1548→\\tif baseCommit, err := repo.CommitObject(plumbing.NewHash(state.BaseCommit)); err == nil {\\n  1549→\\t\\tif tree, treeErr := baseCommit.Tree(); treeErr == nil {\\n  1550→\\t\\t\\tbaseTree = tree\\n  1551→\\t\\t} else {\\n  1552→\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: base tree unavailable\\\",\\n  1553→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n  1554→\\t\\t}\\n  1555→\\t} else {\\n  1556→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: base commit unavailable\\\",\\n  1557→\\t\\t\\tslog.String(\\\"base_commit\\\", state.BaseCommit),\\n  1558→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1559→\\t}\\n  1560→\\n  1561→\\tworktree, err := repo.Worktree()\\n  1562→\\tif err != nil {\\n  1563→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution skipped: failed to get worktree\\\",\\n  1564→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1565→\\t\\treturn result\\n  1566→\\t}\\n  1567→\\n  1568→\\t// Get worktree status to find ALL changed files\\n  1569→\\tstatus, err := worktree.Status()\\n  1570→\\tif err != nil {\\n  1571→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution skipped: failed to get worktree status\\\",\\n  1572→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1573→\\t\\treturn result\\n  1574→\\t}\\n  1575→\\n  1576→\\tworktreeRoot := worktree.Filesystem.Root()\\n  1577→\\n  1578→\\t// Build map of changed files with their worktree content\\n  1579→\\t// IMPORTANT: We read from worktree (not staging area) to match what WriteTemporary\\n  1580→\\t// captures in checkpoints. This ensures attribution is consistent.\\n  1581→\\tchangedFiles := make(map[string]string)\\n  1582→\\tfor filePath, fileStatus := range status {\\n  1583→\\t\\t// Skip unmodified files\\n  1584→\\t\\tif fileStatus.Worktree == git.Unmodified && fileStatus.Staging == git.Unmodified {\\n  1585→\\t\\t\\tcontinue\\n  1586→\\t\\t}\\n  1587→\\t\\t// Skip .entire metadata directory (session data, not user code)\\n  1588→\\t\\tif strings.HasPrefix(filePath, paths.EntireMetadataDir+\\\"/\\\") || strings.HasPrefix(filePath, \\\".entire/\\\") {\\n  1589→\\t\\t\\tcontinue\\n  1590→\\t\\t}\\n  1591→\\n  1592→\\t\\t// Always read from worktree to match checkpoint behavior\\n  1593→\\t\\tfullPath := filepath.Join(worktreeRoot, filePath)\\n  1594→\\t\\tvar content string\\n  1595→\\t\\tif data, err := os.ReadFile(fullPath); err == nil { //nolint:gosec // filePath is from git worktree status\\n  1596→\\t\\t\\t// Use git's binary detection algorithm (matches getFileContent behavior).\\n  1597→\\t\\t\\t// Binary files are excluded from line-based attribution calculations.\\n  1598→\\t\\t\\tisBinary, binErr := binary.IsBinary(bytes.NewReader(data))\\n  1599→\\t\\t\\tif binErr == nil && !isBinary {\\n  1600→\\t\\t\\t\\tcontent = string(data)\\n  1601→\\t\\t\\t}\\n  1602→\\t\\t}\\n  1603→\\t\\t// else: file deleted, unreadable, or binary - content remains empty string\\n  1604→\\n  1605→\\t\\tchangedFiles[filePath] = content\\n  1606→\\t}\\n  1607→\\n  1608→\\t// Use CalculatePromptAttribution from manual_commit_attribution.go\\n  1609→\\tresult = CalculatePromptAttribution(baseTree, lastCheckpointTree, changedFiles, nextCheckpointNum)\\n  1610→\\n  1611→\\treturn result\\n  1612→}\\n  1613→\\n  1614→// getStagedFiles returns a list of files staged for commit.\\n  1615→func getStagedFiles(repo *git.Repository) []string {\\n  1616→\\tworktree, err := repo.Worktree()\\n  1617→\\tif err != nil {\\n  1618→\\t\\treturn nil\\n  1619→\\t}\\n  1620→\\n  1621→\\tstatus, err := worktree.Status()\\n  1622→\\tif err != nil {\\n  1623→\\t\\treturn nil\\n  1624→\\t}\\n  1625→\\n  1626→\\tvar staged []string\\n  1627→\\tfor path, fileStatus := range status {\\n  1628→\\t\\t// Check if file is staged (in index)\\n  1629→\\t\\tif fileStatus.Staging != git.Unmodified && fileStatus.Staging != git.Untracked {\\n  1630→\\t\\t\\tstaged = append(staged, path)\\n  1631→\\t\\t}\\n  1632→\\t}\\n  1633→\\treturn staged\\n  1634→}\\n  1635→\\n  1636→// getLastPrompt retrieves the most recent user prompt from a session's shadow branch.\\n  1637→// Returns empty string if no prompt can be retrieved.\\n  1638→func (s *ManualCommitStrategy) getLastPrompt(repo *git.Repository, state *SessionState) string {\\n  1639→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n  1640→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1641→\\tref, err := repo.Reference(refName, true)\\n  1642→\\tif err != nil {\\n  1643→\\t\\treturn \\\"\\\"\\n  1644→\\t}\\n  1645→\\n  1646→\\t// Extract session data to get prompts for commit message generation\\n  1647→\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini)\\n  1648→\\t// Pass 0 for checkpointTranscriptStart since we're extracting all prompts, not calculating token usage\\n  1649→\\tsessionData, err := s.extractSessionData(repo, ref.Hash(), state.SessionID, nil, state.AgentType, \\\"\\\", 0)\\n  1650→\\tif err != nil || len(sessionData.Prompts) == 0 {\\n  1651→\\t\\treturn \\\"\\\"\\n  1652→\\t}\\n  1653→\\n  1654→\\t// Return the last prompt (most recent work before commit)\\n  1655→\\treturn sessionData.Prompts[len(sessionData.Prompts)-1]\\n  1656→}\\n  1657→\\n  1658→// HandleTurnEnd dispatches strategy-specific actions emitted when an agent turn ends.\\n  1659→// The primary job is to finalize all checkpoints from this turn with the full transcript.\\n  1660→//\\n  1661→// During a turn, PostCommit writes provisional transcript data (whatever was available\\n  1662→// at commit time). HandleTurnEnd replaces that with the complete session transcript\\n  1663→// (from prompt to stop event), ensuring every checkpoint has the full context.\\n  1664→//\\n  1665→//nolint:unparam // error return required by interface but hooks must return nil\\n  1666→func (s *ManualCommitStrategy) HandleTurnEnd(state *SessionState) error {\\n  1667→\\t// Finalize all checkpoints from this turn with the full transcript.\\n  1668→\\t//\\n  1669→\\t// IMPORTANT: This is best-effort - errors are logged but don't fail the hook.\\n  1670→\\t// Failing here would prevent session cleanup and could leave state inconsistent.\\n  1671→\\t// The provisional transcript from PostCommit is already persisted, so the\\n  1672→\\t// checkpoint isn't lost - it just won't have the complete transcript.\\n  1673→\\terrCount := s.finalizeAllTurnCheckpoints(state)\\n  1674→\\tif errCount > 0 {\\n  1675→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1676→\\t\\tlogging.Warn(logCtx, \\\"HandleTurnEnd completed with errors (best-effort)\\\",\\n  1677→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1678→\\t\\t\\tslog.Int(\\\"error_count\\\", errCount),\\n  1679→\\t\\t)\\n  1680→\\t}\\n  1681→\\treturn nil\\n  1682→}\\n  1683→\\n  1684→// finalizeAllTurnCheckpoints replaces the provisional transcript in each checkpoint\\n  1685→// created during this turn with the full session transcript.\\n  1686→//\\n  1687→// This is called at turn end (stop hook). During the turn, PostCommit wrote whatever\\n  1688→// transcript was available at commit time. Now we have the complete transcript and\\n  1689→// replace it so every checkpoint has the full prompt-to-stop context.\\n  1690→//\\n  1691→// Returns the number of errors encountered (best-effort: continues processing on error).\\n  1692→func (s *ManualCommitStrategy) finalizeAllTurnCheckpoints(state *SessionState) int {\\n  1693→\\tif len(state.TurnCheckpointIDs) == 0 {\\n  1694→\\t\\treturn 0 // No mid-turn commits to finalize\\n  1695→\\t}\\n  1696→\\n  1697→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1698→\\n  1699→\\tlogging.Info(logCtx, \\\"finalizing turn checkpoints with full transcript\\\",\\n  1700→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1701→\\t\\tslog.Int(\\\"checkpoint_count\\\", len(state.TurnCheckpointIDs)),\\n  1702→\\t)\\n  1703→\\n  1704→\\terrCount := 0\\n  1705→\\n  1706→\\t// Read full transcript from live transcript file\\n  1707→\\tif state.TranscriptPath == \\\"\\\" {\\n  1708→\\t\\tlogging.Warn(logCtx, \\\"finalize: no transcript path, skipping\\\",\\n  1709→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1710→\\t\\t)\\n  1711→\\t\\tstate.TurnCheckpointIDs = nil\\n  1712→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1713→\\t}\\n  1714→\\n  1715→\\tfullTranscript, err := os.ReadFile(state.TranscriptPath)\\n  1716→\\tif err != nil || len(fullTranscript) == 0 {\\n  1717→\\t\\tmsg := \\\"finalize: empty transcript, skipping\\\"\\n  1718→\\t\\tif err != nil {\\n  1719→\\t\\t\\tmsg = \\\"finalize: failed to read transcript, skipping\\\"\\n  1720→\\t\\t}\\n  1721→\\t\\tlogging.Warn(logCtx, msg,\\n  1722→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1723→\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1724→\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1725→\\t\\t)\\n  1726→\\t\\tstate.TurnCheckpointIDs = nil\\n  1727→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1728→\\t}\\n  1729→\\n  1730→\\t// Extract prompts and context from the full transcript\\n  1731→\\tprompts := extractUserPrompts(state.AgentType, string(fullTranscript))\\n  1732→\\tcontextBytes := generateContextFromPrompts(prompts)\\n  1733→\\n  1734→\\t// Redact secrets before writing — matches WriteCommitted behavior.\\n  1735→\\t// The live transcript on disk contains raw content; redaction must happen\\n  1736→\\t// before anything is persisted to the metadata branch.\\n  1737→\\tfullTranscript, err = redact.JSONLBytes(fullTranscript)\\n  1738→\\tif err != nil {\\n  1739→\\t\\tlogging.Warn(logCtx, \\\"finalize: transcript redaction failed, skipping\\\",\\n  1740→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1741→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1742→\\t\\t)\\n  1743→\\t\\tstate.TurnCheckpointIDs = nil\\n  1744→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1745→\\t}\\n  1746→\\tfor i, p := range prompts {\\n  1747→\\t\\tprompts[i] = redact.String(p)\\n  1748→\\t}\\n  1749→\\tcontextBytes = redact.Bytes(contextBytes)\\n  1750→\\n  1751→\\t// Open repository and create checkpoint store\\n  1752→\\trepo, err := OpenRepository()\\n  1753→\\tif err != nil {\\n  1754→\\t\\tlogging.Warn(logCtx, \\\"finalize: failed to open repository\\\",\\n  1755→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1756→\\t\\t)\\n  1757→\\t\\tstate.TurnCheckpointIDs = nil\\n  1758→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1759→\\t}\\n  1760→\\tstore := checkpoint.NewGitStore(repo)\\n  1761→\\n  1762→\\t// Update each checkpoint with the full transcript\\n  1763→\\tfor _, cpIDStr := range state.TurnCheckpointIDs {\\n  1764→\\t\\tcpID, parseErr := id.NewCheckpointID(cpIDStr)\\n  1765→\\t\\tif parseErr != nil {\\n  1766→\\t\\t\\tlogging.Warn(logCtx, \\\"finalize: invalid checkpoint ID, skipping\\\",\\n  1767→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1768→\\t\\t\\t\\tslog.String(\\\"error\\\", parseErr.Error()),\\n  1769→\\t\\t\\t)\\n  1770→\\t\\t\\terrCount++\\n  1771→\\t\\t\\tcontinue\\n  1772→\\t\\t}\\n  1773→\\n  1774→\\t\\tupdateErr := store.UpdateCommitted(context.Background(), checkpoint.UpdateCommittedOptions{\\n  1775→\\t\\t\\tCheckpointID: cpID,\\n  1776→\\t\\t\\tSessionID:    state.SessionID,\\n  1777→\\t\\t\\tTranscript:   fullTranscript,\\n  1778→\\t\\t\\tPrompts:      prompts,\\n  1779→\\t\\t\\tContext:      contextBytes,\\n  1780→\\t\\t\\tAgent:        state.AgentType,\\n  1781→\\t\\t})\\n  1782→\\t\\tif updateErr != nil {\\n  1783→\\t\\t\\tlogging.Warn(logCtx, \\\"finalize: failed to update checkpoint\\\",\\n  1784→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1785→\\t\\t\\t\\tslog.String(\\\"error\\\", updateErr.Error()),\\n  1786→\\t\\t\\t)\\n  1787→\\t\\t\\terrCount++\\n  1788→\\t\\t\\tcontinue\\n  1789→\\t\\t}\\n  1790→\\n  1791→\\t\\tlogging.Info(logCtx, \\\"finalize: checkpoint updated with full transcript\\\",\\n  1792→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1793→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1794→\\t\\t)\\n  1795→\\t}\\n  1796→\\n  1797→\\t// Clear turn checkpoint IDs. Do NOT update CheckpointTranscriptStart here — it was\\n  1798→\\t// already set correctly by PostCommit: condenseAndUpdateState sets it to the total\\n  1799→\\t// transcript lines when condensing, and carryForwardToNewShadowBranch resets it to 0\\n  1800→\\t// when carry-forward is active. Overwriting here would break carry-forward by making\\n  1801→\\t// sessionHasNewContent think the transcript is fully consumed (no growth).\\n  1802→\\tstate.TurnCheckpointIDs = nil\\n  1803→\\n  1804→\\treturn errCount\\n  1805→}\\n  1806→\\n  1807→// filesChangedInCommit returns the set of files changed in a commit by diffing against its parent.\\n  1808→func filesChangedInCommit(commit *object.Commit) map[string]struct{} {\\n  1809→\\tresult := make(map[string]struct{})\\n  1810→\\n  1811→\\tcommitTree, err := commit.Tree()\\n  1812→\\tif err != nil {\\n  1813→\\t\\treturn result\\n  1814→\\t}\\n  1815→\\n  1816→\\tvar parentTree *object.Tree\\n  1817→\\tif commit.NumParents() > 0 {\\n  1818→\\t\\tparent, err := commit.Parent(0)\\n  1819→\\t\\tif err != nil {\\n  1820→\\t\\t\\treturn result\\n  1821→\\t\\t}\\n  1822→\\t\\tparentTree, err = parent.Tree()\\n  1823→\\t\\tif err != nil {\\n  1824→\\t\\t\\treturn result\\n  1825→\\t\\t}\\n  1826→\\t}\\n  1827→\\n  1828→\\tif parentTree == nil {\\n  1829→\\t\\t// Initial commit — all files are new\\n  1830→\\t\\tif iterErr := commitTree.Files().ForEach(func(f *object.File) error {\\n  1831→\\t\\t\\tresult[f.Name] = struct{}{}\\n  1832→\\t\\t\\treturn nil\\n  1833→\\t\\t}); iterErr != nil {\\n  1834→\\t\\t\\treturn result\\n  1835→\\t\\t}\\n  1836→\\t\\treturn result\\n  1837→\\t}\\n  1838→\\n  1839→\\tchanges, err := parentTree.Diff(commitTree)\\n  1840→\\tif err != nil {\\n  1841→\\t\\treturn result\\n  1842→\\t}\\n  1843→\\tfor _, change := range changes {\\n  1844→\\t\\tname := change.To.Name\\n  1845→\\t\\tif name == \\\"\\\" {\\n  1846→\\t\\t\\tname = change.From.Name\\n  1847→\\t\\t}\\n  1848→\\t\\tresult[name] = struct{}{}\\n  1849→\\t}\\n  1850→\\treturn result\\n  1851→}\\n  1852→\\n  1853→// subtractFiles returns files that are NOT in the exclude set.\\n  1854→func subtractFiles(files []string, exclude map[string]struct{}) []string {\\n  1855→\\tvar remaining []string\\n  1856→\\tfor _, f := range files {\\n  1857→\\t\\tif _, excluded := exclude[f]; !excluded {\\n  1858→\\t\\t\\tremaining = append(remaining, f)\\n  1859→\\t\\t}\\n  1860→\\t}\\n  1861→\\treturn remaining\\n  1862→}\\n  1863→\\n  1864→// carryForwardToNewShadowBranch creates a new shadow branch at the current HEAD\\n  1865→// containing the remaining uncommitted files and all session metadata.\\n  1866→// This enables the next commit to get its own unique checkpoint.\\n  1867→func (s *ManualCommitStrategy) carryForwardToNewShadowBranch(\\n  1868→\\tlogCtx context.Context,\\n  1869→\\trepo *git.Repository,\\n  1870→\\tstate *SessionState,\\n  1871→\\tremainingFiles []string,\\n  1872→) {\\n  1873→\\tstore := checkpoint.NewGitStore(repo)\\n  1874→\\n  1875→\\t// Don't include metadata directory in carry-forward. The carry-forward branch\\n  1876→\\t// only needs to preserve file content for comparison - not the transcript.\\n  1877→\\t// Including the transcript would cause sessionHasNewContent to always return true\\n  1878→\\t// because CheckpointTranscriptStart is reset to 0 for carry-forward.\\n  1879→\\tresult, err := store.WriteTemporary(context.Background(), checkpoint.WriteTemporaryOptions{\\n  1880→\\t\\tSessionID:         state.SessionID,\\n  1881→\\t\\tBaseCommit:        state.BaseCommit,\\n  1882→\\t\\tWorktreeID:        state.WorktreeID,\\n  1883→\\t\\tModifiedFiles:     remainingFiles,\\n  1884→\\t\\tMetadataDir:       \\\"\\\",\\n  1885→\\t\\tMetadataDirAbs:    \\\"\\\",\\n  1886→\\t\\tCommitMessage:     \\\"carry forward: uncommitted session files\\\",\\n  1887→\\t\\tIsFirstCheckpoint: false,\\n  1888→\\t})\\n  1889→\\tif err != nil {\\n  1890→\\t\\tlogging.Warn(logCtx, \\\"post-commit: carry-forward failed\\\",\\n  1891→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1892→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1893→\\t\\t)\\n  1894→\\t\\treturn\\n  1895→\\t}\\n  1896→\\tif result.Skipped {\\n  1897→\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward skipped (no changes)\\\",\\n  1898→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1899→\\t\\t)\\n  1900→\\t\\treturn\\n  1901→\\t}\\n  1902→\\n  1903→\\t// Update state for the carry-forward checkpoint.\\n  1904→\\t// CheckpointTranscriptStart = 0 is intentional: each checkpoint is self-