n:  time.Now(),\\n  1134→\\t\\t},\\n  1135→\\t})\\n  1136→\\tif err != nil {\\n  1137→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n  1138→\\t}\\n  1139→\\n  1140→\\t// Run post-commit hook - since trailer was removed, no condensation should happen\\n  1141→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n  1142→\\tpostCmd.Dir = env.RepoDir\\n  1143→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n  1144→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n  1145→\\t}\\n  1146→}\\n  1147→\\n  1148→// GitRm stages file deletions using git rm.\\n  1149→func (env *TestEnv) GitRm(paths ...string) {\\n  1150→\\tenv.T.Helper()\\n  1151→\\n  1152→\\targs := append([]string{\\\"rm\\\", \\\"--\\\"}, paths...)\\n  1153→\\tcmd := exec.Command(\\\"git\\\", args...)\\n  1154→\\tcmd.Dir = env.RepoDir\\n  1155→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1156→\\t\\tenv.T.Fatalf(\\\"git rm failed: %v\\\\nOutput: %s\\\", err, output)\\n  1157→\\t}\\n  1158→}\\n  1159→\\n  1160→// GitCommitStagedWithShadowHooks commits whatever is already staged (without adding files first),\\n  1161→// running the prepare-commit-msg and post-commit hooks like a real workflow.\\n  1162→// Use this after GitRm or when files are already staged.\\n  1163→func (env *TestEnv) GitCommitStagedWithShadowHooks(message string) {\\n  1164→\\tenv.T.Helper()\\n  1165→\\tenv.gitCommitStagedWithShadowHooks(message, true)\\n  1166→}\\n  1167→\\n  1168→// gitCommitStagedWithShadowHooks is the shared implementation for committing staged changes with hooks.\\n  1169→func (env *TestEnv) gitCommitStagedWithShadowHooks(message string, simulateTTY bool) {\\n  1170→\\tenv.T.Helper()\\n  1171→\\n  1172→\\t// Create a temp file for the commit message (prepare-commit-msg hook modifies this)\\n  1173→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n  1174→\\tif err := os.WriteFile(msgFile, []byte(message), 0