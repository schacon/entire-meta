, bool) {\\n   158→\\tfor _, line := range lines {\\n   159→\\t\\tif line.Type != \\\"user\\\" {\\n   160→\\t\\t\\tcontinue\\n   161→\\t\\t}\\n   162→\\n   163→\\t\\tvar msg userMessageWithToolResults\\n   164→\\t\\tif err := json.Unmarshal(line.Message, &msg); err != nil {\\n   165→\\t\\t\\tcontinue\\n   166→\\t\\t}\\n   167→\\n   168→\\t\\tfor _, block := range msg.Content {\\n   169→\\t\\t\\tif block.Type == \\\"tool_result\\\" && block.ToolUseID == toolUseID {\\n   170→\\t\\t\\t\\treturn line.UUID, true\\n   171→\\t\\t\\t}\\n   172→\\t\\t}\\n   173→\\t}\\n   174→\\treturn \\\"\\\", false\\n   175→}\\n   176→\\n   177→// CalculateTokenUsage calculates token usage from a Claude Code transcript.\\n   178→// This is specific to Claude/Anthropic's API format where each assistant message\\n   179→// contains a usage object with input_tokens, output_tokens, and cache tokens.\\n   180→//\\n   181→// Due to streaming, multiple transcript rows may share the same message.id.\\n   182→// We deduplicate by taking the row with the highest output_tokens for each message.id.\\n   183→func CalculateTokenUsage(transcript []TranscriptLine) *agent.TokenUsage {\\n   184→\\t// Map from message.id to the usage with highest output_tokens\\n   185→\\tusageByMessageID := make(map[string]messageUsage)\\n   186→\\n   187→\\tfor _, line := range transcript {\\n   188→\\t\\tif line.Type != \\\"assistant\\\" {\\n   189→\\t\\t\\tcontinue\\n   190→\\t\\t}\\n   191→\\n   192→\\t\\tvar msg messageWithUsage\\n   193→\\t\\tif err := json.Unmarshal(line.Message, &msg); err != nil {\\n   194→\\t\\t\\tcontinue\\n   195→\\t\\t}\\n   196→\\n   197→\\t\\tif msg.ID == \\\"\\\" {\\n   198→\\t\\t\\tcontinue\\n   199→\\t\\t}\\n   200→\\n   201→\\t\\t// Keep the entry with highest output_tokens (final streaming state)\\n   202→\\t\\texisting, exists := usageByMessageID[msg.ID]\\n   203→\\t\\tif !exists || msg.Usage.OutputTokens > existing.OutputTokens {\\n   204→\\t\\t\\tusageByMessageID[msg.ID] = msg.Usage\\