ittedInfo to strategy.CheckpointInfo\\n    45→\\tresult := make([]CheckpointInfo, 0, len(committed))\\n    46→\\tfor _, c := range committed {\\n    47→\\t\\tresult = append(result, CheckpointInfo{\\n    48→\\t\\t\\tCheckpointID:     c.CheckpointID,\\n    49→\\t\\t\\tSessionID:        c.SessionID,\\n    50→\\t\\t\\tCreatedAt:        c.CreatedAt,\\n    51→\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n    52→\\t\\t\\tFilesTouched:     c.FilesTouched,\\n    53→\\t\\t\\tAgent:            c.Agent,\\n    54→\\t\\t\\tIsTask:           c.IsTask,\\n    55→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    56→\\t\\t\\tSessionCount:     c.SessionCount,\\n    57→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    58→\\t\\t})\\n    59→\\t}\\n    60→\\n    61→\\treturn result, nil\\n    62→}\\n    63→\\n    64→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    65→func (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n    66→\\tall, err := s.listCheckpoints()\\n    67→\\tif err != nil {\\n    68→\\t\\treturn nil, err\\n    69→\\t}\\n    70→\\n    71→\\tvar result []CheckpointInfo\\n    72→\\tfor _, cp := range all {\\n    73→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    74→\\t\\t\\tresult = append(result, cp)\\n    75→\\t\\t}\\n    76→\\t}\\n    77→\\n    78→\\tif len(result) == 0 {\\n    79→\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n    80→\\t}\\n    81→\\n    82→\\treturn result, nil\\n    83→}\\n    84→\\n    85→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    86→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    87→func (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n    88→\\tstore, err := s.getCheckpointStore()\\n    89→\\tif err != nil {\\n    90→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    91→\\t}\\n    92→\\n    93→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n    94→\\tif err != nil {\\n    95→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    96→\\t}\\n    97→\\tif content == nil {\\n    98→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n    99→\\t}\\n   100→\\tif len(content.Transcript) == 0 {\\n   101→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   102→\\t}\\n   103→\\n   104→\\treturn content.Transcript, nil\\n   105→}\\n   106→\\n   107→// condenseOpts provides pre-resolved git objects to avoid redundant reads.\\n   108→type condenseOpts struct {\\n   109→\\tshadowRef *plumbing.Reference // Pre-resolved shadow branch ref (nil = resolve from repo)\\n   110→\\theadTree  *object.Tree        // Pre-resolved HEAD tree (passed through to calculateSessionAttributions)\\n   111→}\\n   112→\\n   113→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   114→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   115→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   116→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   117→//\\n   118→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   119→// In this case, data is extracted from the live transcript instead.\\n   120→func (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}, opts ...condenseOpts) (*CondenseResult, error) {\\n   121→\\tag, err := agent.GetByAgentType(state.AgentType)\\n   122→\\tif err != nil {\\n   123→\\t\\treturn nil, fmt.Errorf(\\\"resolving agent %q: %w\\\", state.AgentType, err)\\n   124→\\t}\\n   125→\\n   126→\\tvar o condenseOpts\\n   127→\\tif len(opts) > 0 {\\n   128→\\t\\to = opts[0]\\n   129→\\t}\\n   130→\\n   131→\\t// Get shadow branch — use pre-resolved ref if available, otherwise resolve from repo.\\n   132→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   133→\\tref := o.shadowRef\\n   134→\\tvar hasShadowBranch bool\\n   135→\\tif ref != nil {\\n   136→\\t\\thasShadowBranch = true\\n   137→\\t} else {\\n   138→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   139→\\t\\tvar err error\\n   140→\\t\\tref, err = repo.Reference(refName, true)\\n   141→\\t\\thasShadowBranch = err == nil\\n   142→\\t}\\n   143→\\n   144→\\tvar sessionData *ExtractedSessionData\\n   145→\\tif hasShadowBranch {\\n   146→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   147→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   148→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   149→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   150→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   151→\\t\\t// last turn had no code changes).\\n   152→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   153→\\t\\tvar extractErr error\\n   154→\\t\\tsessionData, extractErr = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n   155→\\t\\tif extractErr != nil {\\n   156→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", extractErr)\\n   157→\\t\\t}\\n   158→\\t} else {\\n   159→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   160→\\t\\t// Extract data directly from live transcript.\\n   161→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   162→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   163→\\t\\t}\\n   164→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   165→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   166→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   167→\\t\\tif state.Phase.IsActive() {\\n   168→\\t\\t\\tprepareTranscriptIfNeeded(ag, state.TranscriptPath)\\n   169→\\t\\t}\\n   170→\\t\\tvar extractErr error\\n   171→\\t\\tsessionData, extractErr = s.extractSessionDataFromLiveTranscript(state)\\n   172→\\t\\tif extractErr != nil {\\n   173→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", extractErr)\\n   174→\\t\\t}\\n   175→\\t}\\n   176→\\n   177→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   178→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   179→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   180→\\tif len(committedFiles) > 0 {\\n   181→\\t\\t// Track if we had files before filtering to distinguish between:\\n   182→\\t\\t// - Session had files but none were committed (don't fallback)\\n   183→\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n   184→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   185→\\n   186→\\t\\tif hadFilesBeforeFiltering {\\n   187→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   188→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   189→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   190→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   191→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   192→\\t\\t\\t\\t}\\n   193→\\t\\t\\t}\\n   194→\\t\\t\\tsessionData.FilesTouched = filtered\\n   195→\\t\\t}\\n   196→\\n   197→\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n   198→\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n   199→\\t\\t// the session had files that simply didn't overlap with the commit - that\\n   200→\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n   201→\\t\\t// overwritten with unrelated committed files.\\n   202→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   203→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   204→\\t\\t\\tfor f := range committedFiles {\\n   205→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   206→\\t\\t\\t}\\n   207→\\t\\t}\\n   208→\\t}\\n   209→\\n   210→\\t// Get checkpoint store\\n   211→\\tstore, err := s.getCheckpointStore()\\n   212→\\tif err != nil {\\n   213→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   214→\\t}\\n   215→\\n   216→\\t// Get author info\\n   217→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   218→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   219→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   220→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   221→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state, attributionOpts{\\n   222→\\t\\theadTree: o.headTree,\\n   223→\\t})\\n   224→\\t// Get current branch name\\n   225→\\tbranchName := GetCurrentBranchName(repo)\\n   226→\\n   227→\\t// Generate summary if enabled\\n   228→\\tvar summary *cpkg.Summary\\n   229→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   230→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   231→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   232→\\n   233→\\t\\t// Scope transcript to this checkpoint's portion.\\n   234→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   235→\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n   236→\\t\\tvar scopedTranscript []byte\\n   237→\\t\\tswitch state.AgentType {\\n   238→\\t\\tcase agent.AgentTypeGemini:\\n   239→\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   240→\\t\\t\\tif sliceErr != nil {\\n   241→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n   242→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   243→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   244→\\t\\t\\t}\\n   245→\\t\\t\\tscopedTranscript = scoped\\n   246→\\t\\tcase agent.AgentTypeOpenCode:\\n   247→\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   248→\\t\\t\\tif sliceErr != nil {\\n   249→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n   250→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   251→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   252→\\t\\t\\t}\\n   253→\\t\\t\\tscopedTranscript = scoped\\n   254→\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeUnknown:\\n   255→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   256→\\t\\t}\\n   257→\\t\\tif len(scopedTranscript) > 0 {\\n   258→\\t\\t\\tvar err error\\n   259→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   260→\\t\\t\\tif err != nil {\\n   261→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   262→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   263→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   264→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   265→\\t\\t\\t} else {\\n   266→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   267→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   268→\\t\\t\\t}\\n   269→\\t\\t}\\n   270→\\t}\\n   271→\\n   272→\\t// Write checkpoint metadata using the checkpoint store\\n   273→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   274→\\t\\tCheckpointID:                checkpointID,\\n   275→\\t\\tSessionID:                   state.SessionID,\\n   276→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   277→\\t\\tBranch:                      branchName,\\n   278→\\t\\tTranscript:                  sessionData.Transcript,\\n   279→\\t\\tPrompts:                     sessionData.Prompts,\\n   280→\\t\\tContext:                     sessionData.Context,\\n   281→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   282→\\t\\tCheckpointsCount:            state.StepCount,\\n   283→\\t\\tEphemeralBranch:             shadowBranchName,\\n   284→\\t\\tAuthorName:                  authorName,\\n   285→\\t\\tAuthorEmail:                 authorEmail,\\n   286→\\t\\tAgent:                       state.AgentType,\\n   287→\\t\\tTurnID:                      state.TurnID,\\n   288→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   289→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   290→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   291→\\t\\tInitialAttribution:          attribution,\\n   292→\\t\\tSummary:                     summary,\\n   293→\\t}); err != nil {\\n   294→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   295→\\t}\\n   296→\\n   297→\\treturn &CondenseResult{\\n   298→\\t\\tCheckpointID:         checkpointID,\\n   299→\\t\\tSessionID:            state.SessionID,\\n   300→\\t\\tCheckpointsCount:     state.StepCount,\\n   301→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   302→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   303→\\t}, nil\\n   304→}\\n   305→\\n   306→// attributionOpts provides pre-resolved git objects to avoid redundant reads.\\n   307→type attributionOpts struct {\\n   308→\\theadTree   *object.Tree // HEAD commit tree (already resolved by PostCommit)\\n   309→\\tshadowTree *object.Tree // Shadow branch tree (already resolved by PostCommit)\\n   310→}\\n   311→\\n   312→func calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState, opts ...attributionOpts) *cpkg.InitialAttribution {\\n   313→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   314→\\t// This uses user edits captured at each prompt start (before agent works),\\n   315→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   316→\\t//\\n   317→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   318→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   319→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   320→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   321→\\n   322→\\tvar o attributionOpts\\n   323→\\tif len(opts) > 0 {\\n   324→\\t\\to = opts[0]\\n   325→\\t}\\n   326→\\n   327→\\theadTree := o.headTree\\n   328→\\tif headTree == nil {\\n   329→\\t\\theadRef, headErr := repo.Head()\\n   330→\\t\\tif headErr != nil {\\n   331→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   332→\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   333→\\t\\t\\treturn nil\\n   334→\\t\\t}\\n   335→\\n   336→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   337→\\t\\tif commitErr != nil {\\n   338→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   339→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   340→\\t\\t\\treturn nil\\n   341→\\t\\t}\\n   342→\\n   343→\\t\\tvar treeErr error\\n   344→\\t\\theadTree, treeErr = headCommit.Tree()\\n   345→\\t\\tif treeErr != nil {\\n   346→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   347→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   348→\\t\\t\\treturn nil\\n   349→\\t\\t}\\n   350→\\t}\\n   351→\\n   352→\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n   353→\\tshadowTree := o.shadowTree\\n   354→\\tif shadowTree == nil {\\n   355→\\t\\tif shadowRef != nil {\\n   356→\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   357→\\t\\t\\tif shadowErr != nil {\\n   358→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   359→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   360→\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   361→\\t\\t\\t\\treturn nil\\n   362→\\t\\t\\t}\\n   363→\\t\\t\\tvar shadowTreeErr error\\n   364→\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   365→\\t\\t\\tif shadowTreeErr != nil {\\n   366→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   367→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   368→\\t\\t\\t\\treturn nil\\n   369→\\t\\t\\t}\\n   370→\\t\\t} else {\\n   371→\\t\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   372→\\t\\t\\t// because the agent's work is the commit itself.\\n   373→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   374→\\t\\t\\tshadowTree = headTree\\n   375→\\t\\t}\\n   376→\\t}\\n   377→\\n   378→\\t// Get base tree (state before session started)\\n   379→\\tvar baseTree *object.Tree\\n   380→\\tattrBase := state.AttributionBaseCommit\\n   381→\\tif attrBase == \\\"\\\" {\\n   382→\\t\\tattrBase = state.BaseCommit // backward compat\\n   383→\\t}\\n   384→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   385→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   386→\\t\\t\\tbaseTree = tree\\n   387→\\t\\t} else {\\n   388→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   389→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   390→\\t\\t}\\n   391→\\t} else {\\n   392→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   393→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   394→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   395→\\t}\\n   396→\\n   397→\\t// Log accumulated prompt attributions for debugging\\n   398→\\tvar totalUserAdded, totalUserRemoved int\\n   399→\\tfor i, pa := range state.PromptAttributions {\\n   400→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   401→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   402→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   403→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   404→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   405→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   406→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   407→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   408→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   409→\\t}\\n   410→\\n   411→\\tattribution := CalculateAttributionWithAccumulated(\\n   412→\\t\\tbaseTree,\\n   413→\\t\\tshadowTree,\\n   414→\\t\\theadTree,\\n   415→\\t\\tsessionData.FilesTouched,\\n   416→\\t\\tstate.PromptAttributions,\\n   417→\\t)\\n   418→\\n   419→\\tif attribution != nil {\\n   420→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   421→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   422→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   423→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   424→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   425→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   426→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   427→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   428→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   429→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   430→\\t}\\n   431→\\n   432→\\treturn attribution\\n   433→}\\n   434→\\n   435→// extractSessionData extracts session data from the shadow branch.\\n   436→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   437→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   438→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   439→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   440→// continued growing — the shadow branch copy would be stale.\\n   441→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   442→func (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n   443→\\tag, err := agent.GetByAgentType(agentType)\\n   444→\\tif err != nil {\\n   445→\\t\\treturn nil, fmt.Errorf(\\\"resolving agent %q: %w\\\", agentType, err)\\n   446→\\t}\\n   447→\\n   448→\\tcommit, err := repo.CommitObject(shadowRef)\\n   449→\\tif err != nil {\\n   450→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   451→\\t}\\n   452→\\n   453→\\ttree, err := commit.Tree()\\n   454→\\tif err != nil {\\n   455→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   456→\\t}\\n   457→\\n   458→\\tdata := &ExtractedSessionData{}\\n   459→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   460→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   461→\\n   462→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   463→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   464→\\t// (SaveStep is only called when there are file modifications).\\n   465→\\tvar fullTranscript string\\n   466→\\tif liveTranscriptPath != \\\"\\\" {\\n   467→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   468→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   469→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   470→\\t\\tif isActive {\\n   471→\\t\\t\\tprepareTranscriptIfNeeded(ag, liveTranscriptPath)\\n   472→\\t\\t}\\n   473→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   474→\\t\\t\\tfullTranscript = string(liveData)\\n   475→\\t\\t}\\n   476→\\t}\\n   477→\\tif fullTranscript == \\\"\\\" {\\n   478→\\t\\t// Fall back to shadow branch copy\\n   479→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   480→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   481→\\t\\t\\t\\tfullTranscript = content\\n   482→\\t\\t\\t}\\n   483→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   484→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   485→\\t\\t\\t\\tfullTranscript = content\\n   486→\\t\\t\\t}\\n   487→\\t\\t}\\n   488→\\t}\\n   489→\\n   490→\\t// Process transcript based on agent type\\n   491→\\tif fullTranscript != \\\"\\\" {\\n   492→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   493→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   494→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   495→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   496→\\t}\\n   497→\\n   498→\\t// Use tracked files from session state (not all files in tree)\\n   499→\\tdata.FilesTouched = filesTouched\\n   500→\\n   501→\\t// Calculate token usage from the extracted transcript portion\\n   502→\\tif len(data.Transcript) > 0 {\\n   503→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, checkpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   504→\\t}\\n   505→\\n   506→\\treturn data, nil\\n   507→}\\n   508→\\n   509→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   510→// This is used for mid-session commits where no shadow branch exists yet.\\n   511→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n   512→\\tdata := &ExtractedSessionData{}\\n   513→\\n   514→\\tag, err := agent.GetByAgentType(state.AgentType)\\n   515→\\tif err != nil {\\n   516→\\t\\treturn nil, fmt.Errorf(\\\"resolving agent %q: %w\\\", state.AgentType, err)\\n   517→\\t}\\n   518→\\n   519→\\t// Read the live transcript\\n   520→\\tif state.TranscriptPath == \\\"\\\" {\\n   521→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   522→\\t}\\n   523→\\n   524→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   525→\\tif err != nil {\\n   526→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   527→\\t}\\n   528→\\n   529→\\tif len(liveData) == 0 {\\n   530→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   531→\\t}\\n   532→\\n   533→\\tfullTranscript := string(liveData)\\n   534→\\tdata.Transcript = liveData\\n   535→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   536→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   537→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   538→\\n   539→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   540→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   541→\\tif len(state.FilesTouched) > 0 {\\n   542→\\t\\tdata.FilesTouched = state.FilesTouched\\n   543→\\t} else {\\n   544→\\t\\t// Use the shared helper which includes subagent transcripts\\n   545→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n   546→\\t}\\n   547→\\n   548→\\t// Calculate token usage from the extracted transcript portion\\n   549→\\tif len(data.Transcript) > 0 {\\n   550→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, state.CheckpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   551→\\t}\\n   552→\\n   553→\\treturn data, nil\\n   554→}\\n   555→\\n   556→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   557→// For Claude Code and JSONL-based agents, this counts lines.\\n   558→// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n   559→// Returns 0 if the content is empty or malformed.\\n   560→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   561→\\tif content == \\\"\\\" {\\n   562→\\t\\treturn 0\\n   563→\\t}\\n   564→\\n   565→\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n   566→\\tif agentType == agent.AgentTypeOpenCode {\\n   567→\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n   568→\\t\\tif err == nil && session != nil {\\n   569→\\t\\t\\treturn len(session.Messages)\\n   570→\\t\\t}\\n   571→\\t\\treturn 0\\n   572→\\t}\\n   573→\\n   574→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   575→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   576→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   577→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   578→\\t\\t\\treturn len(transcript.Messages)\\n   579→\\t\\t}\\n   580→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   581→\\t\\tif agentType == agent.AgentTypeGemini {\\n   582→\\t\\t\\treturn 0\\n   583→\\t\\t}\\n   584→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   585→\\t}\\n   586→\\n   587→\\t// Claude Code and other JSONL-based agents\\n   588→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   589→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   590→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   591→\\t\\tallLines = allLines[:len(allLines)-1]\\n   592→\\t}\\n   593→\\treturn len(allLines)\\n   594→}\\n   595→\\n   596→// extractUserPrompts extracts all user prompts from transcript content.\\n   597→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   598→func extractUserPrompts(agentType agent.AgentType, content string) []string {\\n   599→\\tif content == \\\"\\\" {\\n   600→\\t\\treturn nil\\n   601→\\t}\\n   602→\\n   603→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   604→\\tif agentType == agent.AgentTypeOpenCode {\\n   605→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   606→\\t\\tif err == nil && len(prompts) > 0 {\\n   607→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   608→\\t\\t\\tfor _, prompt := range prompts {\\n   609→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   610→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   611→\\t\\t\\t\\t}\\n   612→\\t\\t\\t}\\n   613→\\t\\t\\treturn cleaned\\n   614→\\t\\t}\\n   615→\\t\\treturn nil\\n   616→\\t}\\n   617→\\n   618→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   619→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   620→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   621→\\t\\tif err == nil && len(prompts) > 0 {\\n   622→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   623→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   624→\\t\\t\\tfor _, prompt := range prompts {\\n   625→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   626→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   627→\\t\\t\\t\\t}\\n   628→\\t\\t\\t}\\n   629→\\t\\t\\treturn cleaned\\n   630→\\t\\t}\\n   631→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   632→\\t\\tif agentType == agent.AgentTypeGemini {\\n   633→\\t\\t\\treturn nil\\n   634→\\t\\t}\\n   635→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   636→\\t}\\n   637→\\n   638→\\t// Claude Code and other JSONL-based agents\\n   639→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   640→}\\n   641→\\n   642→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   643→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   644→func extractUserPromptsFromLines(lines []string) []string {\\n   645→\\tvar prompts []string\\n   646→\\tfor _, line := range lines {\\n   647→\\t\\tline = strings.TrimSpace(line)\\n   648→\\t\\tif line == \\\"\\\" {\\n   649→\\t\\t\\tcontinue\\n   650→\\t\\t}\\n   651→\\n   652→\\t\\tvar entry map[string]interface{}\\n   653→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   654→\\t\\t\\tcontinue\\n   655→\\t\\t}\\n   656→\\n   657→\\t\\t// Check for user message:\\n   658→\\t\\t// - Claude Code uses \\\"type\\\": \\\"human\\\" or \\\"type\\\": \\\"user\\\"\\n   659→\\t\\t// - Cursor uses \\\"role\\\": \\\"user\\\"\\n   660→\\t\\tmsgType, _ := entry[\\\"type\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   661→\\t\\tmsgRole, _ := entry[\\\"role\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   662→\\t\\tisUser := msgType == \\\"human\\\" || msgType == \\\"user\\\" || msgRole == \\\"user\\\"\\n   663→\\t\\tif !isUser {\\n   664→\\t\\t\\tcontinue\\n   665→\\t\\t}\\n   666→\\n   667→\\t\\t// Extract message content\\n   668→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   669→\\t\\tif !ok {\\n   670→\\t\\t\\tcontinue\\n   671→\\t\\t}\\n   672→\\n   673→\\t\\t// Handle string content\\n   674→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   675→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   676→\\t\\t\\tif cleaned != \\\"\\\" {\\n   677→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   678→\\t\\t\\t}\\n   679→\\t\\t\\tcontinue\\n   680→\\t\\t}\\n   681→\\n   682→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   683→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   684→\\t\\t\\tvar texts []string\\n   685→\\t\\t\\tfor _, item := range arr {\\n   686→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   687→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   688→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   689→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   690→\\t\\t\\t\\t\\t\\t}\\n   691→\\t\\t\\t\\t\\t}\\n   692→\\t\\t\\t\\t}\\n   693→\\t\\t\\t}\\n   694→\\t\\t\\tif len(texts) > 0 {\\n   695→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   696→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   697→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   698→\\t\\t\\t\\t}\\n   699→\\t\\t\\t}\\n   700→\\t\\t}\\n   701→\\t}\\n   702→\\treturn prompts\\n   703→}\\n   704→\\n   705→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   706→func generateContextFromPrompts(prompts []string) []byte {\\n   707→\\tif len(prompts) == 0 {\\n   708→\\t\\treturn nil\\n   709→\\t}\\n   710→\\n   711→\\tvar buf strings.Builder\\n   712→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   713→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   714→\\n   715→\\tfor i, prompt := range prompts {\\n   716→\\t\\t// Truncate very long prompts for readability.\\n   717→\\t\\t// Use rune-based truncation to avoid splitting multi-byte UTF-8 characters (e.g. CJK).\\n   718→\\t\\tconst maxDisplayPromptRunes = 500\\n   719→\\t\\tdisplayPrompt := stringutil.TruncateRunes(prompt, maxDisplayPromptRunes, \\\"...\\\")\\n   720→\\t\\tfmt.Fprintf(&buf, \\\"### Prompt %d\\\\n\\\\n\\\", i+1)\\n   721→\\t\\tbuf.WriteString(displayPrompt)\\n   722→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   723→\\t}\\n   724→\\n   725→\\treturn []byte(buf.String())\\n   726→}\\n   727→\\n   728→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   729→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   730→func (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n   731→\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n   732→\\n   733→\\t// Load session state\\n   734→\\tstate, err := s.loadSessionState(sessionID)\\n   735→\\tif err != nil {\\n   736→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   737→\\t}\\n   738→\\tif state == nil {\\n   739→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   740→\\t}\\n   741→\\n   742→\\t// Open repository\\n   743→\\trepo, err := OpenRepository()\\n   744→\\tif err != nil {\\n   745→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   746→\\t}\\n   747→\\n   748→\\t// Generate a checkpoint ID\\n   749→\\tcheckpointID, err := id.Generate()\\n   750→\\tif err != nil {\\n   751→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   752→\\t}\\n   753→\\n   754→\\t// Check if shadow branch exists (required for condensation)\\n   755→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   756→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   757→\\t_, refErr := repo.Reference(refName, true)\\n   758→\\thasShadowBranch := refErr == nil\\n   759→\\n   760→\\tif !hasShadowBranch {\\n   761→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   762→\\t\\t// Just clean up the state file.\\n   763→\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n   764→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   765→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   766→\\t\\t)\\n   767→\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n   768→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   769→\\t\\t}\\n   770→\\t\\treturn nil\\n   771→\\t}\\n   772→\\n   773→\\t// Condense the session\\n   774→\\tresult, err := s.CondenseSession(repo, checkpointID, state, nil)\\n   775→\\tif err != nil {\\n   776→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   777→\\t}\\n   778→\\n   779→\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n   780→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   781→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   782→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   783→\\t)\\n   784→\\n   785→\\t// Update session state: reset step count and transition to idle\\n   786→\\tstate.StepCount = 0\\n   787→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   788→\\tstate.Phase = session.PhaseIdle\\n   789→\\tstate.LastCheckpointID = checkpointID\\n   790→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   791→\\tstate.PromptAttributions = nil\\n   792→\\tstate.PendingPromptAttribution = nil\\n   793→\\n   794→\\tif err := s.saveSessionState(state); err != nil {\\n   795→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   796→\\t}\\n   797→\\n   798→\\t// Clean up shadow branch if no other sessions need it\\n   799→\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n   800→\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n   801→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   802→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   803→\\t\\t)\\n   804→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   805→\\t}\\n   806→\\n   807→\\treturn nil\\n   808→}\\n   809→\\n   810→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   811→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(_ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   812→\\t// List all session states to check if any other session uses this shadow branch\\n   813→\\tallStates, err := s.listAllSessionStates()\\n   814→\\tif err != nil {\\n   815→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   816→\\t}\\n   817→\\n   818→\\tfor _, state := range allStates {\\n   819→\\t\\tif state.SessionID == excludeSessionID {\\n   820→\\t\\t\\tcontinue\\n   821→\\t\\t}\\n   822→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   823→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   824→\\t\\t\\t// Another session still needs this shadow branch\\n   825→\\t\\t\\treturn nil\\n   826→\\t\\t}\\n   827→\\t}\\n   828→\\n   829→\\t// No other sessions need it, delete the shadow branch via CLI\\n   830→\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n   831→\\tif err := DeleteBranchCLI(shadowBranchName); err != nil {\\n   832→\\t\\t// Branch already gone is not an error\\n   833→\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n   834→\\t\\t\\treturn nil\\n   835→\\t\\t}\\n   836→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n   837→\\t}\\n   838→\\treturn nil\\n   839→}\\n   840→\"}]},\"uuid\":\"3d925ba4-0a5e-4077-81ce-f0764a180e6a\",\"timestamp\":\"2026-02-26T01:45:42.928Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/gtrrz-victor/wks/cli/remove-auto-commit/cmd/entire/cli/strategy/manual_commit_condensation.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/opencode\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/stringutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// listCheckpoints returns all checkpoints from the metadata branch.\\n// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) listCheckpoints() ([]CheckpointInfo, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcommitted, err := store.ListCommitted(context.Background())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n\\t}\\n\\n\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n\\tresult := make([]CheckpointInfo, 0, len(committed))\\n\\tfor _, c := range committed {\\n\\t\\tresult = append(result, CheckpointInfo{\\n\\t\\t\\tCheckpointID:     c.CheckpointID,\\n\\t\\t\\tSessionID:        c.SessionID,\\n\\t\\t\\tCreatedAt:        c.CreatedAt,\\n\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n\\t\\t\\tFilesTouched:     c.FilesTouched,\\n\\t\\t\\tAgent:            c.Agent,\\n\\t\\t\\tIsTask:           c.IsTask,\\n\\t\\t\\tToolUseID:        c.ToolUseID,\\n\\t\\t\\tSessionCount:     c.SessionCount,\\n\\t\\t\\tSessionIDs:       c.SessionIDs,\\n\\t\\t})\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointsForSession returns all checkpoints for a session ID.\\nfunc (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n\\tall, err := s.listCheckpoints()\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tvar result []CheckpointInfo\\n\\tfor _, cp := range all {\\n\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n\\t\\t\\tresult = append(result, cp)\\n\\t\\t}\\n\\t}\\n\\n\\tif len(result) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// condenseOpts provides pre-resolved git objects to avoid redundant reads.\\ntype condenseOpts struct {\\n\\tshadowRef *plumbing.Reference // Pre-resolved shadow branch ref (nil = resolve from repo)\\n\\theadTree  *object.Tree        // Pre-resolved HEAD tree (passed through to calculateSessionAttributions)\\n}\\n\\n// CondenseSession condenses a session's shadow branch to permanent storage.\\n// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n//\\n// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n// In this case, data is extracted from the live transcript instead.\\nfunc (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}, opts ...condenseOpts) (*CondenseResult, error) {\\n\\tag, err := agent.GetByAgentType(state.AgentType)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"resolving agent %q: %w\\\", state.AgentType, err)\\n\\t}\\n\\n\\tvar o condenseOpts\\n\\tif len(opts) > 0 {\\n\\t\\to = opts[0]\\n\\t}\\n\\n\\t// Get shadow branch — use pre-resolved ref if available, otherwise resolve from repo.\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\tref := o.shadowRef\\n\\tvar hasShadowBranch bool\\n\\tif ref != nil {\\n\\t\\thasShadowBranch = true\\n\\t} else {\\n\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\t\\tvar err error\\n\\t\\tref, err = repo.Reference(refName, true)\\n\\t\\thasShadowBranch = err == nil\\n\\t}\\n\\n\\tvar sessionData *ExtractedSessionData\\n\\tif hasShadowBranch {\\n\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n\\t\\t// last turn had no code changes).\\n\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n\\t\\tvar extractErr error\\n\\t\\tsessionData, extractErr = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n\\t\\tif extractErr != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", extractErr)\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n\\t\\t// Extract data directly from live transcript.\\n\\t\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n\\t\\t}\\n\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n\\t\\tif state.Phase.IsActive() {\\n\\t\\t\\tprepareTranscriptIfNeeded(ag, state.TranscriptPath)\\n\\t\\t}\\n\\t\\tvar extractErr error\\n\\t\\tsessionData, extractErr = s.extractSessionDataFromLiveTranscript(state)\\n\\t\\tif extractErr != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", extractErr)\\n\\t\\t}\\n\\t}\\n\\n\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n\\t// committed in this specific commit. This ensures each checkpoint represents\\n\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n\\tif len(committedFiles) > 0 {\\n\\t\\t// Track if we had files before filtering to distinguish between:\\n\\t\\t// - Session had files but none were committed (don't fallback)\\n\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n\\n\\t\\tif hadFilesBeforeFiltering {\\n\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tsessionData.FilesTouched = filtered\\n\\t\\t}\\n\\n\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n\\t\\t// the session had files that simply didn't overlap with the commit - that\\n\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n\\t\\t// overwritten with unrelated committed files.\\n\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n\\t\\t\\tfor f := range committedFiles {\\n\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Get checkpoint store\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get author info\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state, attributionOpts{\\n\\t\\theadTree: o.headTree,\\n\\t})\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Generate summary if enabled\\n\\tvar summary *cpkg.Summary\\n\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n\\n\\t\\t// Scope transcript to this checkpoint's portion.\\n\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n\\t\\tvar scopedTranscript []byte\\n\\t\\tswitch state.AgentType {\\n\\t\\tcase agent.AgentTypeGemini:\\n\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t\\tif sliceErr != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n\\t\\t\\t}\\n\\t\\t\\tscopedTranscript = scoped\\n\\t\\tcase agent.AgentTypeOpenCode:\\n\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t\\tif sliceErr != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n\\t\\t\\t}\\n\\t\\t\\tscopedTranscript = scoped\\n\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeUnknown:\\n\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t}\\n\\t\\tif len(scopedTranscript) > 0 {\\n\\t\\t\\tvar err error\\n\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t\\t// Continue without summary - non-blocking\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write checkpoint metadata using the checkpoint store\\n\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n\\t\\tCheckpointID:                checkpointID,\\n\\t\\tSessionID:                   state.SessionID,\\n\\t\\tStrategy:                    StrategyNameManualCommit,\\n\\t\\tBranch:                      branchName,\\n\\t\\tTranscript:                  sessionData.Transcript,\\n\\t\\tPrompts:                     sessionData.Prompts,\\n\\t\\tContext:                     sessionData.Context,\\n\\t\\tFilesTouched:                sessionData.FilesTouched,\\n\\t\\tCheckpointsCount:            state.StepCount,\\n\\t\\tEphemeralBranch:             shadowBranchName,\\n\\t\\tAuthorName:                  authorName,\\n\\t\\tAuthorEmail:                 authorEmail,\\n\\t\\tAgent:                       state.AgentType,\\n\\t\\tTurnID:                      state.TurnID,\\n\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n\\t\\tInitialAttribution:          attribution,\\n\\t\\tSummary:                     summary,\\n\\t}); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n\\t}\\n\\n\\treturn &CondenseResult{\\n\\t\\tCheckpointID:         checkpointID,\\n\\t\\tSessionID:            state.SessionID,\\n\\t\\tCheckpointsCount:     state.StepCount,\\n\\t\\tFilesTouched:         sessionData.FilesTouched,\\n\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n\\t}, nil\\n}\\n\\n// attributionOpts provides pre-resolved git objects to avoid redundant reads.\\ntype attributionOpts struct {\\n\\theadTree   *object.Tree // HEAD commit tree (already resolved by PostCommit)\\n\\tshadowTree *object.Tree // Shadow branch tree (already resolved by PostCommit)\\n}\\n\\nfunc calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState, opts ...attributionOpts) *cpkg.InitialAttribution {\\n\\t// Calculate initial attribution using accumulated prompt attribution data.\\n\\t// This uses user edits captured at each prompt start (before agent works),\\n\\t// plus any user edits after the final checkpoint (shadow → head).\\n\\t//\\n\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n\\t// HEAD