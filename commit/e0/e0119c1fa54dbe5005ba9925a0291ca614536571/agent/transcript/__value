  303→}\\n   304→\\n   305→// extractAgentIDFromText extracts an agent ID from text containing \\\"agentId: <id>\\\".\\n   306→func extractAgentIDFromText(text string) string {\\n   307→\\tconst prefix = \\\"agentId: \\\"\\n   308→\\tidx := strings.Index(text, prefix)\\n   309→\\tif idx == -1 {\\n   310→\\t\\treturn \\\"\\\"\\n   311→\\t}\\n   312→\\n   313→\\t// Extract the ID (alphanumeric characters after the prefix)\\n   314→\\tstart := idx + len(prefix)\\n   315→\\tend := start\\n   316→\\tfor end < len(text) && (text[end] >= 'a' && text[end] <= 'z' ||\\n   317→\\t\\ttext[end] >= 'A' && text[end] <= 'Z' ||\\n   318→\\t\\ttext[end] >= '0' && text[end] <= '9') {\\n   319→\\t\\tend++\\n   320→\\t}\\n   321→\\n   322→\\tif end > start {\\n   323→\\t\\treturn text[start:end]\\n   324→\\t}\\n   325→\\treturn \\\"\\\"\\n   326→}\\n   327→\\n   328→// CalculateTotalTokenUsage calculates token usage for a turn, including subagents.\\n   329→// It parses the main transcript from startLine, extracts spawned agent IDs,\\n   330→// and calculates their token usage from transcripts in subagentsDir.\\n   331→func CalculateTotalTokenUsage(transcriptPath string, startLine int, subagentsDir string) (*agent.TokenUsage, error) {\\n   332→\\tif transcriptPath == \\\"\\\" {\\n   333→\\t\\treturn &agent.TokenUsage{}, nil\\n   334→\\t}\\n   335→\\n   336→\\t// Parse transcript ONCE\\n   337→\\tparsed, err := transcript.ParseFromFileAtLine(transcriptPath, startLine)\\n   338→\\tif err != nil {\\n   339→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   340→\\t}\\n   341→\\n   342→\\t// Calculate token usage from parsed transcript\\n   343→\\tmainUsage := CalculateTokenUsage(parsed)\\n   344→\\n   345→\\t// Extract spawned agent IDs from the same parsed transcript\\n   346→\\tagentIDs := ExtractSpawnedAgentIDs(parsed)\\n   347→\\n   348→\\t// Calculate subagent token usage\\n   349→\\tif len(agentIDs) > 0 {\\n   350→\\t\\tsubagentUsage := &agent.TokenUsage{}\