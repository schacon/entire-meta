ist of git hooks managed by Entire CLI.\\n    25→// This is useful for tests that need to manipulate hooks.\\n    26→func ManagedGitHookNames() []string {\\n    27→\\treturn gitHookNames\\n    28→}\\n    29→\\n    30→// hookSpec defines a git hook's name and content template (without chain call).\\n    31→type hookSpec struct {\\n    32→\\tname    string\\n    33→\\tcontent string\\n    34→}\\n    35→\\n    36→// GetGitDir returns the actual git directory path by delegating to git itself.\\n    37→// This handles both regular repositories and worktrees, and inherits git's\\n    38→// security validation for gitdir references.\\n    39→func GetGitDir() (string, error) {\\n    40→\\treturn getGitDirInPath(\\\".\\\")\\n    41→}\\n    42→\\n    43→// GetHooksDir returns the active hooks directory path.\\n    44→// This respects core.hooksPath and correctly resolves to the common hooks\\n    45→// directory when called from a linked worktree.\\n    46→func GetHooksDir() (string, error) {\\n    47→\\treturn getHooksDirInPath(\\\".\\\")\\n    48→}\\n    49→\\n    50→// getGitDirInPath returns the git directory for a repository at the given path.\\n    51→// It delegates to `git rev-parse --git-dir` to leverage git's own validation.\\n    52→func getGitDirInPath(dir string) (string, error) {\\n    53→\\tctx := context.Background()\\n    54→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-dir\\\")\\n    55→\\tcmd.Dir = dir\\n    56→\\toutput, err := cmd.Output()\\n    57→\\tif err != nil {\\n    58→\\t\\treturn \\\"\\\", errors.New(\\\"not a git repository\\\")\\n    59→\\t}\\n    60→\\n    61→\\tgitDir := strings.TrimSpace(string(output))\\n    62→\\n    63→\\t// git rev-parse --git-dir returns relative paths from the working directory,\\n    64→\\t// so we need to make it absolute if it isn't already\\n    65→\\tif !filepath.IsAbs(gitDir) {\\n    66→\\t\\tgitDir = filepath.Join(dir, gitDir)\\n    67→\\t}\\n    68→\\n    69→\\treturn filepath.Clean(gitDir), nil\\n    70→}\\n    71→\\n    72→// getHooksDirInPath returns the active hooks directory for a repository at the given path.\\n    73→// It delegates to `git rev-parse --git-path hooks` so Git resolves:\\n    74→// - linked-worktree common hooks directory\\n    75→// - core.hooksPath (relative or absolute)\\n    76→func getHooksDirInPath(dir string) (string, error) {\\n    77→\\tctx := context.Background()\\n    78→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-path\\\", \\\"hooks\\\")\\n    79→\\tcmd.Dir = dir\\n    80→\\toutput, err := cmd.Output()\\n    81→\\tif err != nil {\\n    82→\\t\\treturn \\\"\\\", errors.New(\\\"not a git repository\\\")\\n    83→\\t}\\n    84→\\n    85→\\thooksDir := strings.TrimSpace(string(output))\\n    86→\\tif !filepath.IsAbs(hooksDir) {\\n    87→\\t\\thooksDir = filepath.Join(dir, hooksDir)\\n    88→\\t}\\n    89→\\n    90→\\treturn filepath.Clean(hooksDir), nil\\n    91→}\\n    92→\\n    93→// IsGitHookInstalled checks if all generic Entire CLI hooks are installed.\\n    94→func IsGitHookInstalled() bool {\\n    95→\\thooksDir, err := GetHooksDir()\\n    96→\\tif err != nil {\\n    97→\\t\\treturn false\\n    98→\\t}\\n    99→\\treturn isGitHookInstalledInHooksDir(hooksDir)\\n   100→}\\n   101→\\n   102→// IsGitHookInstalledInDir checks if all Entire CLI hooks are installed in the given repo directory.\\n   103→// This is useful for tests that need to check hooks without changing the working directory.\\n   104→func IsGitHookInstalledInDir(repoDir string) bool {\\n   105→\\thooksDir, err := getHooksDirInPath(repoDir)\\n   106→\\tif err != nil {\\n   107→\\t\\treturn false\\n   108→\\t}\\n   109→\\treturn isGitHookInstalledInHooksDir(hooksDir)\\n   110→}\\n   111→\\n   112→// isGitHookInstalledInHooksDir checks if all hooks are installed in the given hooks directory.\\n   113→func isGitHookInstalledInHooksDir(hooksDir string) bool {\\n   114→\\tfor _, hook := range gitHookNames {\\n   115→\\t\\thookPath := filepath.Join(hooksDir, hook)\\n   116→\\t\\tdata, err := os.ReadFile(hookPath) //nolint:gosec // Path is constructed from constants\\n   117→\\t\\tif err != nil {\\n   118→\\t\\t\\treturn false\\n   119→\\t\\t}\\n   120→\\t\\tif !strings.Contains(string(data), entireHookMarker) {\\n   121→\\t\\t\\treturn false\\n   122→\\t\\t}\\n   123→\\t}\\n   124→\\treturn true\\n   125→}\\n   126→\\n   127→// buildHookSpecs returns the hook specifications for all managed hooks.\\n   128→func buildHookSpecs(cmdPrefix string) []hookSpec {\\n   129→\\treturn []hookSpec{\\n   130→\\t\\t{\\n   131→\\t\\t\\tname: \\\"prepare-commit-msg\\\",\\n   132→\\t\\t\\tcontent: fmt.Sprintf(`#!/bin/sh\\n   133→# %s\\n   134→%s hooks git prepare-commit-msg \\\"$1\\\" \\\"$2\\\" 2>/dev/null || true\\n   135→`, entireHookMarker, cmdPrefix),\\n   136→\\t\\t},\\n   137→\\t\\t{\\n   138→\\t\\t\\tname: \\\"commit-msg\\\",\\n   139→\\t\\t\\tcontent: fmt.Sprintf(`#!/bin/sh\\n   140→# %s\\n   141→# Commit-msg hook: strip trailer if no user content (allows aborting empty commits)\\n   142→%s hooks git commit-msg \\\"$1\\\" || exit 1\\n   143→`, entireHookMarker, cmdPrefix),\\n   144→\\t\\t},\\n   145→\\t\\t{\\n   146→\\t\\t\\tname: \\\"post-commit\\\",\\n   147→\\t\\t\\tcontent: fmt.Sprintf(`#!/bin/sh\\n   148→# %s\\n   149→# Post-commit hook: condense session data if commit has Entire-Checkpoint trailer\\n   150→%s hooks git post-commit 2>/dev/null || true\\n   151→`, entireHookMarker, cmdPrefix),\\n   152→\\t\\t},\\n   153→\\t\\t{\\n   154→\\t\\t\\tname: \\\"pre-push\\\",\\n   155→\\t\\t\\tcontent: fmt.Sprintf(`#!/bin/sh\\n   156→# %s\\n   157→# Pre-push hook: push session logs alongside user's push\\n   158→# $1 is the remote name (e.g., \\\"origin\\\")\\n   159→%s hooks git pre-push \\\"$1\\\" || true\\n   160→`, entireHookMarker, cmdPrefix),\\n   161→\\t\\t},\\n   162→\\t}\\n   163→}\\n   164→\\n   165→// InstallGitHook installs generic git hooks that delegate to `entire hook` commands.\\n   166→// These hooks work with any strategy - the strategy is determined at runtime.\\n   167→// If silent is true, no output is printed (except backup notifications, which always print).\\n   168→// Returns the number of hooks that were installed (0 if all already up to date).\\n   169→func InstallGitHook(silent bool) (int, error) {\\n   170→\\thooksDir, err := GetHooksDir()\\n   171→\\tif err != nil {\\n   172→\\t\\treturn 0, err\\n   173→\\t}\\n   174→\\n   175→\\tif err := os.MkdirAll(hooksDir, 0o755); err != nil { //nolint:gosec // Git hooks require executable permissions\\n   176→\\t\\treturn 0, fmt.Errorf(\\\"failed to create hooks directory: %w\\\", err)\\n   177→\\t}\\n   178→\\n   179→\\tspecs := buildHookSpecs(hookCmdPrefix())\\n   180→\\tinstalledCount := 0\\n   181→\\n   182→\\tfor _, spec := range specs {\\n   183→\\t\\thookPath := filepath.Join(hooksDir, spec.name)\\n   184→\\t\\tbackupPath := hookPath + backupSuffix\\n   185→\\t\\tbackupExists := fileExists(backupPath)\\n   186→\\n   187→\\t\\t// Back up existing non-Entire hooks\\n   188→\\t\\texisting, existingErr := os.ReadFile(hookPath) //nolint:gosec // path is controlled\\n   189→\\t\\tif existingErr == nil && !strings.Contains(string(existing), entireHookMarker) {\\n   190→\\t\\t\\tif !backupExists {\\n   191→\\t\\t\\t\\tif err := os.Rename(hookPath, backupPath); err != nil {\\n   192→\\t\\t\\t\\t\\treturn installedCount, fmt.Errorf(\\\"failed to back up %s: %w\\\", spec.name, err)\\n   193→\\t\\t\\t\\t}\\n   194→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Backed up existing %s to %s%s\\\\n\\\", spec.name, spec.name, backupSuffix)\\n   195→\\t\\t\\t} else {\\n   196→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: replacing %s (backup %s%s already exists from a previous install)\\\\n\\\", spec.name, spec.name, backupSuffix)\\n   197→\\t\\t\\t}\\n   198→\\t\\t\\tbackupExists = true\\n   199→\\t\\t}\\n   200→\\n   201→\\t\\t// Chain to backup if one exists\\n   202→\\t\\tcontent := spec.content\\n   203→\\t\\tif backupExists {\\n   204→\\t\\t\\tcontent = generateChainedContent(spec.content, spec.name)\\n   205→\\t\\t}\\n   206→\\n   207→\\t\\twritten, err := writeHookFile(hookPath, content)\\n   208→\\t\\tif err != nil {\\n   209→\\t\\t\\treturn installedCount, fmt.Errorf(\\\"failed to install %s hook: %w\\\", spec.name, err)\\n   210→\\t\\t}\\n   211→\\t\\tif written {\\n   212→\\t\\t\\tinstalledCount++\\n   213→\\t\\t}\\n   214→\\t}\\n   215→\\n   216→\\tif !silent {\\n   217→\\t\\tfmt.Println(\\\"✓ Installed git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\\")\\n   218→\\t\\tfmt.Println(\\\"  Hooks delegate to the current strategy at runtime\\\")\\n   219→\\t}\\n   220→\\n   221→\\treturn installedCount, nil\\n   222→}\\n   223→\\n   224→// writeHookFile writes a hook file if it doesn't exist or has different content.\\n   225→// Returns true if the file was written, false if it already had the same content.\\n   226→func writeHookFile(path, content string) (bool, error) {\\n   227→\\t// Check if file already exists with same content\\n   228→\\texisting, err := os.ReadFile(path) //nolint:gosec // path is controlled\\n   229→\\tif err == nil && string(existing) == content {\\n   230→\\t\\treturn false, nil // Already up to date\\n   231→\\t}\\n   232→\\n   233→\\t// Git hooks must be executable (0o755)\\n   234→\\tif err := os.WriteFile(path, []byte(content), 0o755); err != nil { //nolint:gosec // Git hooks require executable permissions\\n   235→\\t\\treturn false, fmt.Errorf(\\\"failed to write hook file %s: %w\\\", path, err)\\n   236→\\t}\\n   237→\\treturn true, nil\\n   238→}\\n   239→\\n   240→// RemoveGitHook removes all Entire CLI git hooks from the repository.\\n   241→// If a .pre-entire backup exists, it is restored.\\n   242→// Returns the number of hooks removed.\\n   243→func RemoveGitHook() (int, error) {\\n   244→\\thooksDir, err := GetHooksDir()\\n   245→\\tif err != nil {\\n   246→\\t\\treturn 0, err\\n   247→\\t}\\n   248→\\n   249→\\tremoved := 0\\n   250→\\tvar removeErrors []string\\n   251→\\n   252→\\tfor _, hook := range gitHookNames {\\n   253→\\t\\thookPath := filepath.Join(hooksDir, hook)\\n   254→\\t\\tbackupPath := hookPath + backupSuffix\\n   255→\\n   256→\\t\\t// Remove the hook if it contains our marker\\n   257→\\t\\tdata, err := os.ReadFile(hookPath) //nolint:gosec // path is controlled\\n   258→\\t\\thookIsOurs := err == nil && strings.Contains(string(data), entireHookMarker)\\n   259→\\t\\thookExists := err == nil\\n   260→\\n   261→\\t\\tif hookIsOurs {\\n   262→\\t\\t\\tif err := os.Remove(hookPath); err != nil {\\n   263→\\t\\t\\t\\tremoveErrors = append(removeErrors, fmt.Sprintf(\\\"%s: %v\\\", hook, err))\\n   264→\\t\\t\\t\\tcontinue\\n   265→\\t\\t\\t}\\n   266→\\t\\t\\tremoved++\\n   267→\\t\\t}\\n   268→\\n   269→\\t\\t// Restore .pre-entire backup if it exists\\n   270→\\t\\tif fileExists(backupPath) {\\n   271→\\t\\t\\tif hookExists && !hookIsOurs {\\n   272→\\t\\t\\t\\t// A non-Entire hook is present — don't overwrite it with the backup\\n   273→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: %s was modified since install; backup %s%s left in place\\\\n\\\", hook, hook, backupSuffix)\\n   274→\\t\\t\\t} else {\\n   275→\\t\\t\\t\\tif err := os.Rename(backupPath, hookPath); err != nil {\\n   276→\\t\\t\\t\\t\\tremoveErrors = append(removeErrors, fmt.Sprintf(\\\"restore %s%s: %v\\\", hook, backupSuffix, err))\\n   277→\\t\\t\\t\\t}\\n   278→\\t\\t\\t}\\n   279→\\t\\t}\\n   280→\\t}\\n   281→\\n   282→\\tif len(removeErrors) > 0 {\\n   283→\\t\\treturn removed, fmt.Errorf(\\\"failed to remove hooks: %s\\\", strings.Join(removeErrors, \\\"; \\\"))\\n   284→\\t}\\n   285→\\treturn removed, nil\\n   286→}\\n   287→\\n   288→// generateChainedContent appends a chain call to the base hook content,\\n   289→// so the pre-existing hook (backed up to .pre-entire) is called after our hook.\\n   290→func generateChainedContent(baseContent, hookName string) string {\\n   291→\\treturn baseContent + fmt.Sprintf(`%s\\n   292→_entire_hook_dir=\\\"$(dirname \\\"$0\\\")\\\"\\n   293→if [ -x \\\"$_entire_hook_dir/%s%s\\\" ]; then\\n   294→    \\\"$_entire_hook_dir/%s%s\\\" \\\"$@\\\"\\n   295→fi\\n   296→`, chainComment, hookName, backupSuffix, hookName, backupSuffix)\\n   297→}\\n   298→\\n   299→// hookCmdPrefix returns the command prefix for hook scripts and warning messages.\\n   300→// Returns \\\"go run ./cmd/entire/main.go\\\" when local_dev is enabled, \\\"entire\\\" otherwise.\\n   301→func hookCmdPrefix() string {\\n   302→\\tif isLocalDev() {\\n   303→\\t\\treturn \\\"go run ./cmd/entire/main.go\\\"\\n   304→\\t}\\n   305→\\treturn \\\"entire\\\"\\n   306→}\\n   307→\\n   308→// isLocalDev reads the local_dev setting from .entire/settings.json\\n   309→// Works correctly from any subdirectory within the repository.\\n   310→func isLocalDev() bool {\\n   311→\\ts, err := settings.Load()\\n   312→\\tif err != nil {\\n   313→\\t\\treturn false\\n   314→\\t}\\n   315→\\treturn s.LocalDev\\n   316→}\\n   317→\\n\\n<system-reminder>\\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\\n</system-reminder>\\n\"}]},\"uuid\":\"96f8f329-b423-48c8-b02b-02b97a4f2625\",\"timestamp\":\"2026-02-23T15:14:17.240Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli_worktree1/cmd/entire/cli/strategy/hooks.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"os/exec\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n)\\n\\n// Hook marker used to identify Entire CLI hooks\\nconst entireHookMarker = \\\"Entire CLI hooks\\\"\\n\\nconst backupSuffix = \\\".pre-entire\\\"\\nconst chainComment = \\\"# Chain: run pre-existing hook\\\"\\n\\n// gitHookNames are the git hooks managed by Entire CLI\\nvar gitHookNames = []string{\\\"prepare-commit-msg\\\", \\\"commit-msg\\\", \\\"post-commit\\\", \\\"pre-push\\\"}\\n\\n// ManagedGitHookNames returns the list of git hooks managed by Entire CLI.\\n// This is useful for tests that need to manipulate hooks.\\nfunc ManagedGitHookNames() []string {\\n\\treturn gitHookNames\\n}\\n\\n// hookSpec defines a git hook's name and content template (without chain call).\\ntype hookSpec struct {\\n\\tname    string\\n\\tcontent string\\n}\\n\\n// GetGitDir returns the actual git directory path by delegating to git itself.\\n// This handles both regular repositories and worktrees, and inherits git's\\n// security validation for gitdir references.\\nfunc GetGitDir() (string, error) {\\n\\treturn getGitDirInPath(\\\".\\\")\\n}\\n\\n// GetHooksDir returns the active hooks directory path.\\n// This respects core.hooksPath and correctly resolves to the common hooks\\n// directory when called from a linked worktree.\\nfunc GetHooksDir() (string, error) {\\n\\treturn getHooksDirInPath(\\\".\\\")\\n}\\n\\n// getGitDirInPath returns the git directory for a repository at the given path.\\n// It delegates to `git rev-parse --git-dir` to leverage git's own validation.\\nfunc getGitDirInPath(dir string) (string, error) {\\n\\tctx := context.Background()\\n\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-dir\\\")\\n\\tcmd.Dir = dir\\n\\toutput, err := cmd.Output()\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", errors.New(\\\"not a git repository\\\")\\n\\t}\\n\\n\\tgitDir := strings.TrimSpace(string(output))\\n\\n\\t// git rev-parse --git-dir returns relative paths from the working directory,\\n\\t// so we need to make it absolute if it isn't already\\n\\tif !filepath.IsAbs(gitDir) {\\n\\t\\tgitDir = filepath.Join(dir, gitDir)\\n\\t}\\n\\n\\treturn filepath.Clean(gitDir), nil\\n}\\n\\n// getHooksDirInPath returns the active hooks directory for a repository at the given path.\\n// It delegates to `git rev-parse --git-path hooks` so Git resolves:\\n// - linked-worktree common hooks directory\\n// - core.hooksPath (relative or absolute)\\nfunc getHooksDirInPath(dir string) (string, error) {\\n\\tctx := context.Background()\\n\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-path\\\", \\\"hooks\\\")\\n\\tcmd.Dir = dir\\n\\toutput, err := cmd.Output()\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", errors.New(\\\"not a git repository\\\")\\n\\t}\\n\\n\\thooksDir := strings.TrimSpace(string(output))\\n\\tif !filepath.IsAbs(hooksDir) {\\n\\t\\thooksDir = filepath.Join(dir, hooksDir)\\n\\t}\\n\\n\\treturn filepath.Clean(hooksDir), nil\\n}\\n\\n// IsGitHookInstalled checks if all generic Entire CLI hooks are installed.\\nfunc IsGitHookInstalled() bool {\\n\\thooksDir, err := GetHooksDir()\\n\\tif err != nil {\\n\\t\\treturn false\\n\\t}\\n\\treturn isGitHookInstalledInHooksDir(hooksDir)\\n}\\n\\n// IsGitHookInstalledInDir checks if all Entire CLI hooks are installed in the given repo directory.\\n// This is useful for tests that need to check hooks without changing the working directory.\\nfunc IsGitHookInstalledInDir(repoDir string) bool {\\n\\thooksDir, err := getHooksDirInPath(repoDir)\\n\\tif err != nil {\\n\\t\\treturn false\\n\\t}\\n\\treturn isGitHookInstalledInHooksDir(hooksDir)\\n}\\n\\n// isGitHookInstalledInHooksDir checks if all hooks are installed in the given hooks directory.\\nfunc isGitHookInstalledInHooksDir(hooksDir string) bool {\\n\\tfor _, hook := range gitHookNames {\\n\\t\\thookPath := filepath.Join(hooksDir, hook)\\n\\t\\tdata, err := os.ReadFile(hookPath) //nolint:gosec // Path is constructed from constants\\n\\t\\tif err != nil {\\n\\t\\t\\treturn false\\n\\t\\t}\\n\\t\\tif !strings.Contains(string(data), entireHookMa