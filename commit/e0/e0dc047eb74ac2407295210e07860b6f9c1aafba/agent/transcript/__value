le != nil {\\n   172→\\t\\t_ = logFile.Close()\\n   173→\\t\\tlogFile = nil\\n   174→\\t}\\n   175→}\\n   176→\\n   177→// getLogger returns the current logger, or a default stderr logger if not initialized.\\n   178→func getLogger() *slog.Logger {\\n   179→\\tmu.RLock()\\n   180→\\tdefer mu.RUnlock()\\n   181→\\n   182→\\tif logger == nil {\\n   183→\\t\\t// Return default stderr logger\\n   184→\\t\\treturn slog.Default()\\n   185→\\t}\\n   186→\\treturn logger\\n   187→}\\n   188→\\n   189→// getSessionID returns the current session ID (thread-safe).\\n   190→func getSessionID() string {\\n   191→\\tmu.RLock()\\n   192→\\tdefer mu.RUnlock()\\n   193→\\treturn currentSessionID\\n   194→}\\n   195→\\n   196→// createLogger creates a JSON logger writing to the given writer at the specified level.\\n   197→func createLogger(w io.Writer, level slog.Level) *slog.Logger {\\n   198→\\topts := &slog.HandlerOptions{\\n   199→\\t\\tLevel: level,\\n   200→\\t}\\n   201→\\thandler := slog.NewJSONHandler(w, opts)\\n   202→\\treturn slog.New(handler)\\n   203→}\\n   204→\\n   205→// parseLogLevel parses a log level string to slog.Level.\\n   206→// Returns slog.LevelInfo for empty or invalid values.\\n   207→func parseLogLevel(s string) slog.Level {\\n   208→\\tswitch strings.ToUpper(strings.TrimSpace(s)) {\\n   209→\\tcase \\\"DEBUG\\\":\\n   210→\\t\\treturn slog.LevelDebug\\n   211→\\tcase \\\"INFO\\\":\\n   212→\\t\\treturn slog.LevelInfo\\n   213→\\tcase \\\"WARN\\\", \\\"WARNING\\\":\\n   214→\\t\\treturn slog.LevelWarn\\n   215→\\tcase \\\"ERROR\\\":\\n   216→\\t\\treturn slog.LevelError\\n   217→\\tdefault:\\n   218→\\t\\treturn slog.LevelInfo\\n   219→\\t}\\n   220→}\\n   221→\\n   222→// isValidLogLevel checks if the given string is a valid log level.\\n   223→func isValidLogLevel(s string) bool {\\n   224→\\tswitch strings.ToUpper(strings.TrimSpace(s)) {\\n   225→\\tcase \\\"DEBUG\\\", \\\"INFO\\\", \\\"WARN\\\", \\\"WARNING\\\", \\\"ERROR\\\", \\\"\\\":\\n   226→\\t