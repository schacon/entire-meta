   178→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   179→// detects file changes, saves step + checkpoint, transitions phase.\\n   180→//\\n   181→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   182→func handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   183→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   184→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   185→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   186→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   187→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   188→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   189→\\t)\\n   190→\\n   191→\\tsessionID := event.SessionID\\n   192→\\tif sessionID == \\\"\\\" {\\n   193→\\t\\tsessionID = unknownSessionID\\n   194→\\t}\\n   195→\\n   196→\\ttranscriptRef := event.SessionRef\\n   197→\\tif transcriptRef == \\\"\\\" {\\n   198→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   199→\\t}\\n   200→\\n   201→\\t// If agent implements TranscriptPreparer, materialize the transcript file.\\n   202→\\t// This must run BEFORE fileExists: agents like OpenCode lazily fetch transcripts\\n   203→\\t// via `opencode export`, so the file doesn't exist until PrepareTranscript creates it.\\n   204→\\t// Claude Code's PrepareTranscript just flushes (always succeeds). Agents without\\n   205→\\t// TranscriptPreparer (Gemini, Droid) are unaffected.\\n   206→\\tif preparer, ok := agent.AsTranscriptPreparer(ag); ok {\\n   207→\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n   208→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n   209→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()