t// Determine transcript offset\\n   253→\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n   254→\\n   255→\\t// Compute subagents directory for agents that support subagent extraction.\\n   256→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   257→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   258→\\n   259→\\t// Extract metadata via agent interface (modified files)\\n   260→\\tvar modifiedFiles []string\\n   261→\\n   262→<<<<<<< HEAD\\n   263→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   264→=======\\n   265→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok {\\n   266→\\t\\t// Extract prompts\\n   267→\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n   268→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract prompts\\\",\\n   269→\\t\\t\\t\\tslog.String(\\\"error\\\", promptErr.Error()))\\n   270→\\t\\t} else {\\n   271→\\t\\t\\tallPrompts = prompts\\n   272→\\t\\t}\\n   273→\\n   274→\\t\\t// Extract summary\\n   275→\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n   276→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract summary\\\",\\n   277→\\t\\t\\t\\tslog.String(\\\"error\\\", sumErr.Error()))\\n   278→\\t\\t} else {\\n   279→\\t\\t\\tsummary = s\\n   280→\\t\\t}\\n   281→\\n   282→>>>>>>> f6141584 (Refactor Wrap for external agents)\\n   283→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   284→\\t\\tif subagentExtractor, subOk := agent.AsSubagentAwareExtractor(ag); subOk {\\n   285→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n   286→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n   287→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   288→\\t\\t\\t} else {\\n   289→\\t\\t\\t\\tmodifiedFiles = files\\n   290→\\t\\t\\t}\\n   291→\\t\\t} else {\\n   292→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   293→\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   294→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n   295→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   296→\\t\\t\\t} else {\\n   297→\\t\\t\\t\\tmodifiedFiles = files\\n   298→\\t\\t\\t}\\n   299→\\t\\t}\\n   300→\\t}\\n   301→\\n   302→\\t// Generate commit message from last prompt (read from session state, set at TurnStart)\\n   303→\\tlastPrompt := \\\"\\\"\\n   304→\\tif sessionState, stateErr := strategy.LoadSessionState(ctx, sessionID); stateErr == nil && sessionState != nil {\\n   305→\\t\\tlastPrompt = sessionState.LastPrompt\\n   306→\\t}\\n   307→\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n   308→\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n   309→\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n   310→\\n   311→\\t// Get worktree root for path normalization\\n   312→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   313→\\tif err != nil {\\n   314→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   315→\\t}\\n   316→\\n   317→\\tvar preUntrackedFiles []string\\n   318→\\tif preState != nil {\\n   319→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n   320→\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n   321→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   322→\\t}\\n   323→\\n   324→\\t// Detect file changes via git status\\n   325→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   326→\\tif err != nil {\\n   327→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   328→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   329→\\t}\\n   330→\\n   331→\\t// Filter and normalize all paths\\n   332→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   333→\\tvar relNewFiles, relDeletedFiles []string\\n   334→\\tif changes != nil {\\n   335→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   336→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   337→\\n   338→\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n   339→\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n   340→\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n   341→\\t\\t// Git status catches any tracked file with working-tree changes.\\n   342→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   343→\\t}\\n   344→\\n   345→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   346→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   347→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   348→\\t// if it exists in HEAD with the same content as the working tree.\\n   349→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   350→\\n   351→\\t// Check if there are any changes\\n   352→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   353→\\tif totalChanges == 0 {\\n   354→\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n   355→\\t\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n   356→\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   357→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   358→\\t\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   359→\\t\\t}\\n   360→\\t\\treturn nil\\n   361→\\t}\\n   362→\\n   363→\\t// Log file changes\\n   364→\\tlogFileChanges(ctx, relModifiedFiles, relNewFiles, relDeletedFiles)\\n   365→\\n   366→\\t// Get git author\\n   367→\\tauthor, err := GetGitAuthor(ctx)\\n   368→\\tif err != nil {\\n   369→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   370→\\t}\\n   371→\\n   372→\\t// Get strategy and agent type\\n   373→\\tstrat := GetStrategy(ctx)\\n   374→\\tagentType := ag.Type()\\n   375→\\n   376→\\t// Get transcript position/identifier from pre-prompt state\\n   377→\\tvar transcriptIdentifierAtStart string\\n   378→\\tvar transcriptLinesAtStart int\\n   379→\\tif preState != nil {\\n   380→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   381→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   382→\\t}\\n   383→\\n   384→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   385→\\ttokenUsage := agent.CalculateTokenUsage(ctx, ag, transcriptData, transcriptLinesAtStart, subagentsDir)\\n   386→\\n   387→\\t// Build fully-populated step context and delegate to strategy\\n   388→\\tstepCtx := strategy.StepContext{\\n   389→\\t\\tSessionID:                sessionID,\\n   390→\\t\\tModifiedFiles:            relModifiedFiles,\\n   391→\\t\\tNewFiles:                 relNewFiles,\\n   392→\\t\\tDeletedFiles:             relDeletedFiles,\\n   393→\\t\\tMetadataDir:              sessionDir,\\n   394→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   395→\\t\\tCommitMessage:            commitMessage,\\n   396→\\t\\tTranscriptPath:           transcriptRef,\\n   397→\\t\\tAuthorName:               author.Name,\\n   398→\\t\\tAuthorEmail:              author.Email,\\n   399→\\t\\tAgentType:                agentType,\\n   400→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   401→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   402→\\t\\tTokenUsage:               tokenUsage,\\n   403→\\t}\\n   404→\\n   405→\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   406→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   407→\\t}\\n   408→\\n   409→\\t// Transition session phase and cleanup\\n   410→\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n   411→\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   412→\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   413→\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   414→\\t}\\n   415→\\n   416→\\treturn nil\\n   417→}\\n   418→\\n   419→// handleLifecycleCompaction handles context compaction: saves current progress\\n   420→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   421→// Also resets the transcript offset since the transcript may be truncated.\\n   422→func handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   423→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   424→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   425→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   426→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   427→\\t)\\n   428→\\n   429→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   430→\\tsessionID := event.SessionID\\n   431→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   432→\\tif loadErr != nil {\\n   433→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for compaction\\\",\\n   434→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   435→\\t}\\n   436→\\tif sessionState != nil {\\n   437→\\t\\tif transErr := strategy.TransitionAndLog(ctx, sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   438→\\t\\t\\tlogging.Warn(logCtx, \\\"compaction transition failed\\\",\\n   439→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   440→\\t\\t}\\n   441→\\n   442→\\t\\tif saveErr := strategy.SaveSessionState(ctx, sessionState); saveErr != nil {\\n   443→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to save session state after compaction\\\",\\n   444→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   445→\\t\\t}\\n   446→\\t}\\n   447→\\n   448→\\tlogging.Info(logCtx, \\\"context compaction detected\\\")\\n   449→\\treturn nil\\n   450→}\\n   451→\\n   452→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   453→func handleLifecycleSessionEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   454→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   455→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   456→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   457→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   458→\\t)\\n   459→\\n   460→\\tif event.SessionID == \\\"\\\" {\\n   461→\\t\\treturn nil // No session to update\\n   462→\\t}\\n   463→\\n   464→\\t// Note: We intentionally don't clean up cached transcripts here.\\n   465→\\t// Post-session commits (carry-forward in ENDED phase) may still need\\n   466→\\t// the transcript to extract file changes. Cleanup is handled by\\n   467→\\t// `entire clean` or when the session state is fully removed.\\n   468→\\n   469→\\tif err := markSessionEnded(ctx, event.SessionID); err != nil {\\n   470→\\t\\tlogging.Warn(logCtx, \\\"failed to mark session ended\\\",\\n   471→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   472→\\t}\\n   473→\\treturn nil\\n   474→}\\n   475→\\n   476→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   477→func handleLifecycleSubagentStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   478→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   479→\\tlogging.Info(logCtx, \\\"subagent started\\\",\\n   480→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   481→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   482→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   483→\\t\\tslog.String(\\\"transcript\\\", event.SessionRef),\\n   484→\\t)\\n   485→\\n   486→\\t// Capture pre-task state\\n   487→\\tif err := CapturePreTaskState(ctx, event.ToolUseID); err != nil {\\n   488→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   489→\\t}\\n   490→\\n   491→\\treturn nil\\n   492→}\\n   493→\\n   494→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   495→func handleLifecycleSubagentEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   496→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   497→\\tif event.SubagentType == \\\"\\\" && event.TaskDescription == \\\"\\\" {\\n   498→\\t\\t// Extract subagent type and description from tool input\\n   499→\\t\\tevent.SubagentType, event.TaskDescription = ParseSubagentTypeAndDescription(event.ToolInput)\\n   500→\\t}\\n   501→\\n   502→\\t// Determine subagent transcript path\\n   503→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   504→\\tvar subagentTranscriptPath string\\n   505→\\tif event.SubagentID != \\\"\\\" {\\n   506→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   507→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   508→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   509→\\t\\t}\\n   510→\\t}\\n   511→\\n   512→\\t// Log context\\n   513→\\tsubagentEndAttrs := []any{\\n   514→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   515→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   516→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   517→\\t}\\n   518→\\tif event.SubagentID != \\\"\\\" {\\n   519→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"agent_id\\