   27→\\n    28→// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n    29→// Returns nil if the event was handled successfully.\\n    30→func DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    31→\\tif ag == nil {\\n    32→\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    33→\\t}\\n    34→\\tif event == nil {\\n    35→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    36→\\t}\\n    37→\\n    38→\\tswitch event.Type {\\n    39→\\tcase agent.SessionStart:\\n    40→\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n    41→\\tcase agent.TurnStart:\\n    42→\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n    43→\\tcase agent.TurnEnd:\\n    44→\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n    45→\\tcase agent.Compaction:\\n    46→\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n    47→\\tcase agent.SessionEnd:\\n    48→\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n    49→\\tcase agent.SubagentStart:\\n    50→\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n    51→\\tcase agent.SubagentEnd:\\n    52→\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n    53→\\tdefault:\\n    54→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    55→\\t}\\n    56→}\\n    57→\\n    58→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    59→// fires state machine transition.\\n    60→func handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    61→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n    62→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    63→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    64→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    65→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    66→\\t\\tslog.String(\\\"model\\\", event.Model),\\n    67→\\t)\\n    68→\\n    69→\\tif event.SessionID == \\\"\\\" {\\n    70→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    71→\\t}\\n    72→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    74→\\t}\\n    75→\\n    76→\\t// Build informational message\\n    77→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    78→\\n    79→\\t// Check for concurrent sessions and append count if any\\n    80→\\tstrat := GetStrategy(ctx)\\n    81→\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n    82→\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    83→\\t}\\n    84→\\n    85→\\t// Output informational message if the agent supports hook responses.\\n    86→\\t// Claude Code reads JSON from stdout; agents that don't implement\\n    87→\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n    88→\\tif event.ResponseMessage != \\\"\\\" {\\n    89→\\t\\tmessage = event.ResponseMessage\\n    90→\\t}\\n    91→\\tif writer, ok := agent.AsHookResponseWriter(ag); ok {\\n    92→\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n    93→\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n    94→\\t\\t}\\n    95→\\t}\\n    96→\\n    97→\\t// Fire EventSessionStart for the current session (if state exists).\\n    98→\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n    99→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n   100→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   101→\\t} else if state != nil {\\n   102→\\t\\tpersistEventMetadataToState(event, state)\\n   103→\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   104→\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n   105→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   106→\\t\\t}\\n   107→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   108→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n   109→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   110→\\t\\t}\\n   111→\\t}\\n   112→\\n   113→\\treturn nil\\n   114→}\\n   115→\\n   116→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   117→// ensures strategy setup, initializes session.\\n   118→func handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   119→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   120→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   121→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   122→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   123→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   124→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   125→\\t)\\n   126→\\n   127→\\tsessionID := event.SessionID\\n   128→\\tif sessionID == \\\"\\\" {\\n   129→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   130→\\t}\\n   131→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   132→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   133→\\t}\\n   134→\\n   135→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   136→\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n   137→\\t\\treturn err\\n   138→\\t}\\n   139→\\n   140→\\t// Append prompt to prompt.txt on fi