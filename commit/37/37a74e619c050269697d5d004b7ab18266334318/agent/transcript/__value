\\"\\\", \\\"  \\\")\\n   137‚Üí\\tif err != nil {\\n   138‚Üí\\t\\treturn fmt.Errorf(\\\"failed to marshal hosts data: %w\\\", err)\\n   139‚Üí\\t}\\n   140‚Üí\\n   141‚Üí\\t// Atomic write: create temp file, write, fsync, rename\\n   142‚Üí\\ttmpFile, err := os.CreateTemp(filepath.Dir(path), \\\".hosts.json.tmp.*\\\")\\n   143‚Üí\\tif err != nil {\\n   144‚Üí\\t\\treturn fmt.Errorf(\\\"failed to create temp file: %w\\\", err)\\n   145‚Üí\\t}\\n   146‚Üí\\ttmpPath := tmpFile.Name()\\n   147‚Üí\\n   148‚Üí\\t// Ensure cleanup of temp file on error\\n   149‚Üí\\tdefer func() {\\n   150‚Üí\\t\\tif tmpFile != nil {\\n   151‚Üí\\t\\t\\t_ = tmpFile.Close()\\n   152‚Üí\\t\\t\\t_ = os.Remove(tmpPath)\\n   153‚Üí\\t\\t}\\n   154‚Üí\\t}()\\n   155‚Üí\\n   156‚Üí\\t// Write data to temp file\\n   157‚Üí\\tif _, err := tmpFile.Write(data); err != nil {\\n   158‚Üí\\t\\treturn fmt.Errorf(\\\"failed to write to temp file: %w\\\", err)\\n   159‚Üí\\t}\\n   160‚Üí\\n   161‚Üí\\t// Fsync to ensure data is written to disk\\n   162‚Üí\\tif err := tmpFile.Sync(); err != nil {\\n   163‚Üí\\t\\treturn fmt.Errorf(\\\"failed to sync temp file: %w\\\", err)\\n   164‚Üí\\t}\\n   165‚Üí\\n   166‚Üí\\t// Close the temp file\\n   167‚Üí\\tif err := tmpFile.Close(); err != nil {\\n   168‚Üí\\t\\treturn fmt.Errorf(\\\"failed to close temp file: %w\\\", err)\\n   169‚Üí\\t}\\n   170‚Üí\\n   171‚Üí\\t// Set proper permissions\\n   172‚Üí\\tif err := os.Chmod(tmpPath, 0600); err != nil {\\n   173‚Üí\\t\\treturn fmt.Errorf(\\\"failed to set permissions on temp file: %w\\\", err)\\n   174‚Üí\\t}\\n   175‚Üí\\n   176‚Üí\\t// Atomic rename\\n   177‚Üí\\tif err := os.Rename(tmpPath, path); err != nil {\\n   178‚Üí\\t\\treturn fmt.Errorf(\\\"failed to rename temp file: %w\\\", err)\\n   179‚Üí\\t}\\n   180‚Üí\\n   181‚Üí\\t// Clear tmpFile to prevent cleanup in defer\\n   182‚Üí\\ttmpFile = nil\\n   183‚Üí\\n   184‚Üí\\treturn nil\\n   185‚Üí}\\n   186‚Üí\\n   187‚Üí// setActiveUser sets the active user for a host and adds them to the users list if not present\\n   188‚Üí// This should be called whenever a user successfully logs in\\n   189‚Üífunc setActiveUser(host, username, configDir string) error {\\n   190‚Üí\\thosts, err := loadHostsData(configDir)\\n   191‚Üí\\tif err != nil {\\n   192‚Üí\\t\\treturn err\\n   193‚Üí\\t}\\n   194‚Üí\\n   195‚Üí\\thostInfo := hosts[host]\\n   196‚Üí\\tif hostInfo == nil {\\n   197‚Üí\\t\\thostInfo = &HostInfo{\\n   198‚Üí\\t\\t\\tUsers: []string{},\\n   199‚Üí\\t\\t}\\n   200‚Üí\\t\\thosts[host] = hostInfo\\n   201‚Üí\\t}\\n   202‚Üí\\n   203‚Üí\\t// Set as active user\\n   204‚Üí\\thostInfo.ActiveUser = username\\n   205‚Üí\\n   206‚Üí\\t// Add to users list if not already present\\n   207‚Üí\\tuserExists := false\\n   208‚Üí\\tfor _, u := range hostInfo.Users {\\n   209‚Üí\\t\\tif u == username {\\n   210‚Üí\\t\\t\\tuserExists = true\\n   211‚Üí\\t\\t\\tbreak\\n   212‚Üí\\t\\t}\\n   213‚Üí\\t}\\n   214‚Üí\\tif !userExists {\\n   215‚Üí\\t\\thostInfo.Users = append(hostInfo.Users, username)\\n   216‚Üí\\t}\\n   217‚Üí\\n   218‚Üí\\treturn saveHostsData(hosts, configDir)\\n   219‚Üí}\\n   220‚Üí\\n   221‚Üí// removeUser removes a username for a hostname from the host data\\n   222‚Üí// Returns the new active user (empty string if no users remain)\\n   223‚Üífunc removeUser(host, username, configDir string) (string, error) {\\n   224‚Üí\\thosts, err := loadHostsData(configDir)\\n   225‚Üí\\tif err != nil {\\n   226‚Üí\\t\\treturn \\\"\\\", err\\n   227‚Üí\\t}\\n   228‚Üí\\n   229‚Üí\\thostInfo := hosts[host]\\n   230‚Üí\\tif hostInfo == nil {\\n   231‚Üí\\t\\treturn \\\"\\\", nil // Nothing to remove\\n   232‚Üí\\t}\\n   233‚Üí\\n   234‚Üí\\t// Remove from users list\\n   235‚Üí\\tvar filtered []string\\n   236‚Üí\\tfor _, u := range hostInfo.Users {\\n   237‚Üí\\t\\tif u != username {\\n   238‚Üí\\t\\t\\tfiltered = append(filtered, u)\\n   239‚Üí\\t\\t}\\n   240‚Üí\\t}\\n   241‚Üí\\thostInfo.Users = filtered\\n   242‚Üí\\n   243‚Üí\\tnewActiveUser := \\\"\\\"\\n   244‚Üí\\t// If the removed user was the active user, set active user to the next available user\\n   245‚Üí\\tif hostInfo.ActiveUser == username {\\n   246‚Üí\\t\\tif len(hostInfo.Users) > 0 {\\n   247‚Üí\\t\\t\\thostInfo.ActiveUser = hostInfo.Users[0]\\n   248‚Üí\\t\\t\\tnewActiveUser = hostInfo.ActiveUser\\n   249‚Üí\\t\\t} else {\\n   250‚Üí\\t\\t\\thostInfo.ActiveUser = \\\"\\\"\\n   251‚Üí\\t\\t}\\n   252‚Üí\\t}\\n   253‚Üí\\n   254‚Üí\\t// Remove host entry if no users left\\n   255‚Üí\\tif len(hostInfo.Users) == 0 {\\n   256‚Üí\\t\\tdelete(hosts, host)\\n   257‚Üí\\t}\\n   258‚Üí\\n   259‚Üí\\treturn newActiveUser, saveHostsData(hosts, configDir)\\n   260‚Üí}\\n   261‚Üí\\n   262‚Üí// listUsers returns all usernames for a hostname\\n   263‚Üífunc listUsers(host, configDir string) ([]string, error) {\\n   264‚Üí\\thosts, err := loadHostsData(configDir)\\n   265‚Üí\\tif err != nil {\\n   266‚Üí\\t\\treturn nil, err\\n   267‚Üí\\t}\\n   268‚Üí\\tif hostInfo := hosts[host]; hostInfo != nil {\\n   269‚Üí\\t\\treturn hostInfo.Users, nil\\n   270‚Üí\\t}\\n   271‚Üí\\treturn []string{}, nil\\n   272‚Üí}\\n   273‚Üí\\n   274‚Üí// getActiveUser returns the active username for a hostname, if one is set\\n   275‚Üífunc getActiveUser(host, configDir string) (string, error) {\\n   276‚Üí\\thosts, err := loadHostsData(configDir)\\n   277‚Üí\\tif err != nil {\\n   278‚Üí\\t\\treturn \\\"\\\", err\\n   279‚Üí\\t}\\n   280‚Üí\\tif hostInfo := hosts[host]; hostInfo != nil {\\n   281‚Üí\\t\\treturn hostInfo.ActiveUser, nil\\n   282‚Üí\\t}\\n   283‚Üí\\treturn \\\"\\\", nil\\n   284‚Üí}\\n   285‚Üí\\n   286‚Üí// promptSelectUser prompts the user to select from available usernames\\n   287‚Üífunc promptSelectUser(users []string) (string, error) {\\n   288‚Üí\\tif len(users) == 0 {\\n   289‚Üí\\t\\treturn \\\"\\\", errors.New(\\\"no users available\\\")\\n   290‚Üí\\t}\\n   291‚Üí\\n   292‚Üí\\tif len(users) == 1 {\\n   293‚Üí\\t\\treturn users[0], nil\\n   294‚Üí\\t}\\n   295‚Üí\\n   296‚Üí\\tfmt.Println(\\\"Available users:\\\")\\n   297‚Üí\\tfor i, user := range users {\\n   298‚Üí\\t\\tfmt.Printf(\\\"%d. %s\\\\n\\\", i+1, user)\\n   299‚Üí\\t}\\n   300‚Üí\\n   301‚Üí\\tfmt.Printf(\\\"Select user (1-%d): \\\", len(users))\\n   302‚Üí\\treader := bufio.NewReader(os.Stdin)\\n   303‚Üí\\tinput, err := reader.ReadString('\\\\n')\\n   304‚Üí\\tif err != nil {\\n   305‚Üí\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read input: %w\\\", err)\\n   306‚Üí\\t}\\n   307‚Üí\\n   308‚Üí\\tvar selection int\\n   309‚Üí\\tif _, err := fmt.Sscanf(strings.TrimSpace(input), \\\"%d\\\", &selection); err != nil {\\n   310‚Üí\\t\\treturn \\\"\\\", fmt.Errorf(\\\"invalid selection: %w\\\", err)\\n   311‚Üí\\t}\\n   312‚Üí\\n   313‚Üí\\tif selection < 1 || selection > len(users) {\\n   314‚Üí\\t\\treturn \\\"\\\", errors.New(\\\"selection out of range\\\")\\n   315‚Üí\\t}\\n   316‚Üí\\n   317‚Üí\\treturn users[selection-1], nil\\n   318‚Üí}\\n   319‚Üí\\n   320‚Üífunc newLoginCmd(cfg Config) *cobra.Command {\\n   321‚Üí\\treturn &cobra.Command{\\n   322‚Üí\\t\\tUse:   \\\"login <userName> <password>\\\",\\n   323‚Üí\\t\\tShort: \\\"Login with user name\\\",\\n   324‚Üí\\t\\tArgs:  cobra.ExactArgs(2),\\n   325‚Üí\\t\\tRunE: func(cmd *cobra.Command, args []string) error {\\n   326‚Üí\\t\\t\\tuserName := args[0]\\n   327‚Üí\\t\\t\\tpassword := args[1]\\n   328‚Üí\\t\\t\\tvar token string\\n   329‚Üí\\n   330‚Üí\\t\\t\\tif err := client.Connect(cfg.EntireHost, func(c *client.Client) error {\\n   331‚Üí\\t\\t\\t\\tvar err error\\n   332‚Üí\\t\\t\\t\\ttoken, err = c.Login(cmd.Context(), userName, password)\\n   333‚Üí\\t\\t\\t\\tif err != nil {\\n   334‚Üí\\t\\t\\t\\t\\treturn fmt.Errorf(\\\"login failed: %w\\\", err)\\n   335‚Üí\\t\\t\\t\\t}\\n   336‚Üí\\t\\t\\t\\treturn nil\\n   337‚Üí\\t\\t\\t}); err != nil {\\n   338‚Üí\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to login: %w\\\", err)\\n   339‚Üí\\t\\t\\t}\\n   340‚Üí\\n   341