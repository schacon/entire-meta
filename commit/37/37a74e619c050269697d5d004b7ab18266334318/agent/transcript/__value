id or expired code\\\" }, 400);\\n   132‚Üí  }\\n   133‚Üí\\n   134‚Üí  const userId = c.get(\\\"userId\\\");\\n   135‚Üí  if (decision === \\\"deny\\\") {\\n   136‚Üí    grant.status = \\\"denied\\\";\\n   137‚Üí  } else {\\n   138‚Üí    grant.status = \\\"approved\\\";\\n   139‚Üí    grant.approvedByUserId = userId;\\n   140‚Üí    // Token is generated at poll-time, not here ‚Äî avoids storing plaintext in KV\\n   141‚Üí  }\\n   142‚Üí\\n   143‚Üí  await saveDeviceGrant(c, deviceCode, grant);\\n   144‚Üí  await c.env.ENTIRE_CACHE.delete(userCodeKey(userCode));\\n   145‚Üí  return c.json({ success: true });\\n   146‚Üí}\\n   147‚Üí\\n   148‚Üíexport const cliAuthRoutes = new Hono<{\\n   149‚Üí  Bindings: Env;\\n   150‚Üí  Variables: Variables;\\n   151‚Üí}>();\\n   152‚Üí\\n   153‚Üíexport const oauthRoutes = new Hono<{\\n   154‚Üí  Bindings: Env;\\n   155‚Üí  Variables: Variables;\\n   156‚Üí}>();\\n   157‚Üí\\n   158‚ÜíoauthRoutes.post(\\\"/device/code\\\", rateLimitUnauthenticated, async (c) => {\\n   159‚Üí  const body = await c.req.parseBody();\\n   160‚Üí  const clientId = typeof body.client_id === \\\"string\\\" ? body.client_id : null;\\n   161‚Üí  const scope = typeof body.scope === \\\"string\\\" && body.scope.trim() ? body.scope : DEFAULT_SCOPE;\\n   162‚Üí\\n   163‚Üí  if (clientId !== CLI_CLIENT_ID) {\\n   164‚Üí    return oauthError(c, \\\"invalid_client\\\", 401);\\n   165‚Üí  }\\n   166‚Üí\\n   167‚Üí  const { deviceCode, grant } = await createDeviceGrant(c, clientId, scope);\\n   168‚Üí\\n   169‚Üí  const baseUri = verificationUri(c.env);\\n   170‚Üí  return c.json({\\n   171‚Üí    device_code: deviceCode,\\n   172‚Üí    user_code: grant.userCode,\\n   173‚Üí    verification_uri: baseUri,\\n   174‚Üí    verification_uri_complete: `${baseUri}?code=${encodeURIComponent(grant.userCode)}`,\\n   175‚Üí    expires_in: DEVICE_CODE_TTL_SECONDS,\\n   176‚Üí    interval: grant.interval,\\n   177‚Üí  });\\n   178‚Üí});\\n   179‚Üí\\n   180‚ÜíoauthRoutes.post(