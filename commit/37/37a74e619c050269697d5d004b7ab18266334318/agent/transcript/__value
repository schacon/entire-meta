uth:${deviceCode}`;\\n}\\n\\nfunction userCodeKey(userCode: string): string {\\n  return `cli_auth_code:${userCode}`;\\n}\\n\\nfunction isExpired(grant: DeviceGrant): boolean {\\n  return Date.now() > grant.expiresAt;\\n}\\n\\nasync function getDeviceGrant(c: { env: Env }, deviceCode: string): Promise<DeviceGrant | null> {\\n  return c.env.ENTIRE_CACHE.get<DeviceGrant>(deviceGrantKey(deviceCode), \\\"json\\\");\\n}\\n\\nasync function saveDeviceGrant(c: { env: Env }, deviceCode: string, grant: DeviceGrant): Promise<void> {\\n  const ttlSeconds = Math.max(1, Math.ceil((grant.expiresAt - Date.now()) / 1000));\\n  await c.env.ENTIRE_CACHE.put(deviceGrantKey(deviceCode), JSON.stringify(grant), {\\n    expirationTtl: ttlSeconds,\\n  });\\n}\\n\\nasync function createDeviceGrant(\\n  c: { env: Env },\\n  clientId: string,\\n  scope = DEFAULT_SCOPE,\\n): Promise<{ deviceCode: string; grant: DeviceGrant }> {\\n  const deviceCode = crypto.randomUUID();\\n  const grant: DeviceGrant = {\\n    clientId,\\n    userCode: generateUserCode(),\\n    scope,\\n    status: \\\"pending\\\",\\n    expiresAt: Date.now() + DEVICE_CODE_TTL_SECONDS * 1000,\\n    interval: DEVICE_POLL_INTERVAL_SECONDS,\\n  };\\n\\n  await Promise.all([\\n    saveDeviceGrant(c, deviceCode, grant),\\n    c.env.ENTIRE_CACHE.put(userCodeKey(grant.userCode), deviceCode, {\\n      expirationTtl: DEVICE_CODE_TTL_SECONDS,\\n    }),\\n  ]);\\n\\n  return { deviceCode, grant };\\n}\\n\\nasync function issueApiToken(c: { env: Env }, userId: string, scope: string): Promise<string> {\\n  const plainToken = generateApiToken();\\n  const tokenHash = await sha256Hex(plainToken);\\n  const now = new Date();\\n  const expiresAt = new Date(now.getTime() + API_TOKEN_TTL_SECONDS * 1000);\\n  const db = getDb(c.env);\\n\\n  await db.apiTokens.create({\\n    userId,\\n    tokenHash,\\n    name: `CLI login ${now.toISOString().split(\\\"T\\\")[0]}`,\\n    scope,\\n    expiresAt: expiresAt.toISOString(),\\n  });\\n\\n  return plainToken;\\n}\\n\\nfunction verificationUri(env: Env): string {\\n  return `${env.FRONTEND_BASE_URL}/cli/auth`;\\n}\\n\\nfunction oauthError(c: AppContext, error: string, status: 400 | 401 = 400) {\\n  return c.json({ error }, status);\\n}\\n\\nasync function handleDecision(\\n  c: AppContext,\\n  userCode: string | undefined,\\n  decision: \\\"approve\\\" | \\\"deny\\\" | undefined,\\n): Promise<Response> {\\n  if (!userCode) {\\n    return c.json({ error: \\\"Missing userCode\\\" }, 400);\\n  }\\n  if (decision !== \\\"approve\\\" && decision !== \\\"deny\\\") {\\n    return c.json({ error: \\\"Invalid or missing decision\\\" }, 400);\\n  }\\n\\n  const deviceCode = await c.env.ENTIRE_CACHE.get(userCodeKey(userCode));\\n  if (!deviceCode) {\\n    return c.json({ error: \\\"Invalid or expired code\\\" }, 400);\\n  }\\n\\n  const grant = await getDeviceGrant(c, deviceCode);\\n  if (!grant || isExpired(grant) || grant.status !== \\\"pending\\\") {\\n    return c.json({ error: \\\"Invalid or expired code\\\" }, 400);\\n  }\\n\\n  const userId = c.get(\\\"userId\\\");\\n  if (decision === \\\"deny\\\") {\\n    grant.status = \\\"denied\\\";\\n  } else {\\n    grant.status = \\\"approved\\\";\\n    grant.approvedByUserId = userId;\\n    // Token is generated at poll-time, not here ‚Äî avoids storing plaintext in KV\\n  }\\n\\n  await saveDeviceGrant(c, deviceCode, grant);\\n  await c.env.ENTIRE_CACHE.delete(userCodeKey(userCode));\\n  return c.json({ success: true });\\n}\\n\\nexport const cliAuthRoutes = new Hono<{\\n  Bindings: Env;\\n  Variables: Variables;\\n}>();\\n\\nexport const oauthRoutes = new Hono<{\\n  Bindings: Env;\\n  Variables: Variables;\\n}>();\\n\\noauthRoutes.post(\\\"/device/code\\\", rateLimitUnauthenticated, async (c) => {\\n  const body = await c.req.parseBody();\\n  const clientId = typeof body.client_id === \\\"string\\\" ? body.client_id : null;\\n  const scope = typeof body.scope === \\\"string\\\" && body.scope.trim() ? body.scope : DEFAULT_SCOPE;\\n\\n  if (clientId !== CLI_CLIENT_ID) {\\n    return oauthError(c, \\\"invalid_client\\\", 401);\\n  }\\n\\n  const { deviceCode, grant } = await createDeviceGrant(c, clientId, scope);\\n\\n  const baseUri = verificationUri(c.env);\\n  return c.json({\\n    device_code: deviceCode,\\n    user_code: grant.userCode,\\n    verification_uri: baseUri,\\n    verification_uri_complete: `${baseUri}?code=${encodeURIComponent(grant.userCode)}`,\\n    expires_in: DEVICE_CODE_TTL_SECONDS,\\n    interval: grant.interval,\\n  });\\n});\\n\\noauthRoutes.post(\\\"/token\\\", rateLimitUnauthenticated, async (c) => {\\n  const body = await c.req.parseBody();\\n  const grantType = typeof body.grant_type === \\\"string\\\" ? body.grant_type : null;\\n  const clientId = typeof body.client_id === \\\"string\\\" ? body.client_id : null;\\n  const deviceCode = typeof body.device_code === \\\"string\\\" ? body.device_code : null;\\n\\n  if (grantType !== \\\"urn:ietf:params:oauth:grant-type:device_code\\\") {\\n    return oauthError(c, \\\"unsupported_grant_type\\\");\\n  }\\n\\n  if (clientId !== CLI_CLIENT_ID) {\\n    return oauthError(c, \\\"invalid_client\\\", 401);\\n  }\\n\\n  if (!deviceCode) {\\n    return oauthError(c, \\\"invalid_grant\\\");\\n  }\\n\\n  const grant = await getDeviceGrant(c, deviceCode);\\n  if (!grant || isExpired(grant)) {\\n    return oauthError(c, \\\"expired_token\\\");\\n  }\\n\\n  if (grant.clientId !== clientId) {\\n    return oauthError(c, \\\"invalid_grant\\\");\\n  }\\n\\n  if (grant.status === \\\"consumed\\\") {\\n    return oauthError(c, \\\"invalid_grant\\\");\\n  }\\n\\n  const now = Date.now();\\n  if (grant.lastPolledAt && now - grant.lastPolledAt < grant.interval * 1000) {\\n    grant.lastPolledAt = now;\\n    grant.interval += DEVICE_POLL_INTERVAL_SECONDS;\\n    await saveDeviceGrant(c, deviceCode, grant);\\n    return oauthError(c, \\\"slow_down\\\");\\n  }\\n\\n  grant.lastPolledAt = now;\\n  await saveDeviceGrant(c, deviceCode, grant);\\n\