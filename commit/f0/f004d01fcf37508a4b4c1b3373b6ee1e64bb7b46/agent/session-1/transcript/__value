4→\\treturn out, err\\n   165→}\\n   166→\\n   167→func (s *RepoState) logPromptResult(out agents.Output) {\\n   168→\\ts.ConsoleLog.WriteString(\\\"> \\\" + out.Command + \\\"\\\\n\\\")\\n   169→\\ts.ConsoleLog.WriteString(\\\"stdout:\\\\n\\\" + out.Stdout + \\\"\\\\n\\\")\\n   170→\\ts.ConsoleLog.WriteString(\\\"stderr:\\\\n\\\" + out.Stderr + \\\"\\\\n\\\")\\n   171→}\\n   172→\\n   173→// Git runs a git command in the repo and logs it to ConsoleLog.\\n   174→func (s *RepoState) Git(t *testing.T, args ...string) {\\n   175→\\tt.Helper()\\n   176→\\ts.ConsoleLog.WriteString(\\\"> git \\\" + strings.Join(args, \\\" \\\") + \\\"\\\\n\\\")\\n   177→\\tGit(t, s.Dir, args...)\\n   178→}\\n   179→\\n   180→// StartSession starts an interactive session and registers it for pane\\n   181→// capture in artifacts. Returns nil if the agent does not support interactive\\n   182→// mode. The session is closed automatically during test cleanup.\\n   183→func (s *RepoState) StartSession(t *testing.T, ctx context.Context) agents.Session {\\n   184→\\tt.Helper()\\n   185→\\tsession, err := s.Agent.StartSession(ctx, s.Dir)\\n   186→\\tif err != nil {\\n   187→\\t\\tt.Fatalf(\\\"start session: %v\\\", err)\\n   188→\\t}\\n   189→\\tif session == nil {\\n   190→\\t\\treturn nil\\n   191→\\t}\\n   192→\\ts.session = session\\n   193→\\treturn session\\n   194→}\\n   195→\\n   196→// WaitFor waits for a pattern in the interactive session's pane and logs the\\n   197→// pane content to ConsoleLog after the wait completes (success or failure).\\n   198→func (s *RepoState) WaitFor(t *testing.T, session agents.Session, pattern string, timeout time.Duration) {\\n   199→\\tt.Helper()\\n   200→\\tcontent, err := session.WaitFor(pattern, timeout)\\n   201→\\tfmt.Fprintf(s.ConsoleLog, \\\"> pane after WaitFor(%q):\\\\n%s\\\\n\\\", pattern, content)\\n   202→\\tif err != nil {\\n   203→\\t\\tt.Fatalf(\\\"WaitFor(%q): %v\\\", pattern, err)\\n   204→\\t}\\n   205→}\\n   206→\\n   207→// Send sends