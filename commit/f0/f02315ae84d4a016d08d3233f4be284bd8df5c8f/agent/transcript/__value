opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}, \\\"provider\\\": {\\\"anthropic\\\": {\\\"options\\\": {\\\"apiKey\\\": %q}}}}`, key)\\n    83→\\t\\t}\\n    84→\\t\\tif err := os.WriteFile(filepath.Join(dir, \\\"opencode.json\\\"), []byte(cfg+\\\"\\\\n\\\"), 0o644); err != nil {\\n    85→\\t\\t\\tt.Fatalf(\\\"write opencode.json: %v\\\", err)\\n    86→\\t\\t}\\n    87→\\t}\\n    88→\\n    89→\\t// Create artifact dir eagerly so console.log is written to disk\\n    90→\\t// incrementally. Even if the test is killed by a global timeout,\\n    91→\\t// partial output survives.\\n    92→\\tartDir := artifactDir(t)\\n    93→\\tconsoleLog, err := os.Create(filepath.Join(artDir, \\\"console.log\\\"))\\n    94→\\tif err != nil {\\n    95→\\t\\tt.Fatalf(\\\"create console.log: %v\\\", err)\\n    96→\\t}\\n    97→\\n    98→\\tstate := &RepoState{\\n    99→\\t\\tAgent:            agent,\\n   100→\\t\\tDir:              dir,\\n   101→\\t\\tArtifactDir:      artDir,\\n   102→\\t\\tHeadBefore:       GitOutput(t, dir, \\\"rev-parse\\\", \\\"HEAD\\\"),\\n   103→\\t\\tCheckpointBefore: GitOutput(t, dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\"),\\n   104→\\t\\tConsoleLog:       consoleLog,\\n   105→\\t}\\n   106→\\n   107→\\tt.Cleanup(func() {\\n   108→\\t\\t_ = consoleLog.Close()\\n   109→\\t\\tif !state.skipArtifacts {\\n   110→\\t\\t\\tCaptureArtifacts(t, state)\\n   111→\\t\\t}\\n   112→\\t})\\n   113→\\n   114→\\treturn state\\n   115→}\\n   116→\\n   117→func configureDroidRepoSettings(repoDir string) error {\\n   118→\\thome, err := os.UserHomeDir()\\n   119→\\tif err != nil {\\n   120→\\t\\treturn fmt.Errorf(\\\"get home dir: %w\\\", err)\\n   121→\\t}\\n   122→\\n   123→\\tglobalSettingsPath := filepath.Join(home, \\\".factory\\\", \\\"settings.json\\\")\\n   124→\\trepoSettingsPath := filepath.Join(repoDir, droidRepoSettingsPath)\\n   125→\\n   126→\\tif err := mergeDroidCustomModels(globalSettingsPath, repoSettingsPath); err != nil {\\n   127→\\t\\treturn err\\n   128→\\t}\\n   129→\\tif err := ensureGitInfoExcludeContains(repoDir, droidRepoSettingsPath); err != nil {\\n   130→\\t\\treturn fmt.Errorf(\\\"exclude droid settings from git: %w\\\", err)\\n   131→\\t}\\n   132→\\treturn nil\\n   133→}\\n   134→\\n   135→func mergeDroidCustomModels(globalSettingsPath, repoSettingsPath string) error {\\n   136→\\tglobalSettings, err := loadJSONMap(globalSettingsPath, \\\"global droid settings\\\")\\n   137→\\tif err != nil {\\n   138→\\t\\treturn err\\n   139→\\t}\\n   140→\\n   141→\\tcustomModels, ok := globalSettings[\\\"customModels\\\"]\\n   142→\\tif !ok {\\n   143→\\t\\treturn fmt.Errorf(\\n   144→\\t\\t\\t\\\"global droid settings at %s missing customModels; repo-local %s shadows global settings\\\",\\n   145→\\t\\t\\tglobalSettingsPath,\\n   146→\\t\\t\\trepoSettingsPath,\\n   147→\\t\\t)\\n   148→\\t}\\n   149→\\n   150→\\tvar models []json.RawMessage\\n   151→\\tif err := json.Unmarshal(customModels, &models); err != nil {\\n   152→\\t\\treturn fmt.Errorf(\\\"parse customModels in %s: %w\\\", globalSettingsPath, err)\\n   153→\\t}\\n   154→\\tif len(models) == 0 {\\n   155→\\t\\treturn fmt.Errorf(\\\"global droid settings at %s has empty customModels\\\", globalSettingsPath)\\n   156→\\t}\\n   157→\\n   158→\\trepoSettings, err := loadJSONMap(repoSettingsPath, \\\"repo-local droid settings\\\")\\n   159→\\tif err != nil {\\n   160→\\t\\treturn err\\n   161→\\t}\\n   162→\\trepoSettings[\\\"customModels\\\"] = customModels\\n   163→\\n   164→\\tout, err := json.MarshalIndent(repoSettings, \\\"\\\", \\\"  \\\")\\n   165→\\tif err != nil {\\n   166→\\t\\treturn fmt.Errorf(\\\"marshal repo-local droid settings: %w\\\", err)\\n   167→\\t}\\n   168→\\tout = append(out, '\\\\n')\\n   169→\\n   170→\\tif err := os.WriteFile(repoSettingsPath, out, 0o600); err != nil {\\n   171→\\t\\treturn fmt.Errorf(\\\"write repo-local droid settings %s: %w\\\", repoSettingsPath, err)\\n   172→\\t}\\n   173→\\treturn nil\\n   174→}\\n   175→\\n   176→func loadJSONMap(path, description string) (map[string]json.RawMessage, error) {\\n   177→\\tdata, err := os.ReadFile(path)\\n   178→\\tif err != nil {\\n   179→\\t\\treturn nil, fmt.Errorf(\\\"read %s at %s: %w\\\", description, path, err)\\n   180→\\t}\\n   181→\\n   182→\\tvar parsed map[string]json.RawMessage\\n   183→\\tif err := json.Unmarshal(data, &parsed); err != nil {\\n   184→\\t\\treturn nil, fmt.Errorf(\\\"parse %s at %s: %w\\\", description, path, err)\\n   185→\\t}\\n   186→\\tif parsed == nil {\\n   187→\\t\\tparsed = make(map[string]json.RawMessage)\\n   188→\\t}\\n   189→\\treturn parsed, nil\\n   190→}\\n   191→\\n   192→func ensureGitInfoExcludeContains(repoDir, entry string) error {\\n   193→\\texcludePath := filepath.Join(repoDir, \\\".git\\\", \\\"info\\\", \\\"exclude\\\")\\n   194→\\n   195→\\tdata, err := os.ReadFile(excludePath)\\n   196→\\tif err != nil && !errors.Is(err, os.ErrNotExist) {\\n   197→\\t\\treturn fmt.Errorf(\\\"read %s: %w\\\", excludePath, err)\\n   198→\\t}\\n   199→\\n   200→\\tnormalized := strings.ReplaceAll(string(data), \\\"\\\\r\\\\n\\\", \\\"\\\\n\\\")\\n   201→\\tfor _, line := range strings.Split(normalized, \\\"\\\\n\\\") {\\n   202→\\t\\tif strings.TrimSpace(line) == entry {\\n   203→\\t\\t\\treturn nil\\n   204→\\t\\t}\\n   205→\\t}\\n   206→\\n   207→\\tvar b strings.Builder\\n   208→\\tif len(data) > 0 {\\n   209→\\t\\tb.Write(data)\\n   210→\\t\\tif data[len(data)-1] != '\\\\n' {\\n   211→\\t\\t\\tb.WriteByte('\\\\n')\\n   212→\\t\\t}\\n   213→\\t}\\n   214→\\tb.WriteString(entry)\\n   215→\\tb.WriteByte('\\\\n')\\n   216→\\n   217→\\tif err := os.MkdirAll(filepath.Dir(excludePath), 0o755); err != nil {\\n   218→\\t\\treturn fmt.Errorf(\\\"create %s: %w\\\", filepath.Dir(excludePath), err)\\n   219→\\t}\\n   220→\\tif err := os.WriteFile(excludePath, []byte(b.String()), 0o644); err != nil {\\n   221→\\t\\treturn fmt.Errorf(\\\"write %s: %w\\\", excludePath, err)\\n   222→\\t}\\n   223→\\treturn nil\\n   224→}\\n   225→\\n   226→// ForEachAgent runs fn as a parallel subtest for every registered agent.\\n   227→// It handles repo setup, concurrency gating, context timeout, and cleanup.\\n   228→// The timeout is scaled by each agent's TimeoutMultiplier.\\n   229→//\\n   230→// If RunPrompt detects a transient API error (e.g. rate limit, token refresh\\n   231→// failure), it panics with errScenarioRestart. ForEachAgent recovers from the\\n   232→// panic and restarts the entire scenario with a fresh repository, up to\\n   233→// maxScenarioRestarts times. This avoids stale CLI session state from the\\n   234→// failed attempt poisoning the retry.\\n   235→func ForEachAgent(t *testing.T, timeout time.Duration, fn func(t *testing.T, s *RepoState, ctx context.Context)) {\\n   236→\\tt.Helper()\\n   237→\\tt.Parallel()\\n   238→\\tall := agents.All()\\n   239→\\tif len(all) == 0 {\\n   240→\\t\\tt.Skip(\\\"no agents registered (check E2E_AGENT filter)\\\")\\n   241→\\t}\\n   242→\\tfor _, agent := range all {\\n   243→\\t\\tt.Run(agent.Name(), func(t *testing.T) {\\n   244→\\t\\t\\t// Use the global test deadline for slot wait so we don't\\n   245→\\t\\t\\t// skip prematurely — only bail if the whole binary is dying.\\n   246→\\t\\t\\tslotCtx := context.Background()\\n   247→\\t\\t\\tif deadline, ok := t.Deadline(); ok {\\n   248→\\t\\t\\t\\tvar cancel context.CancelFunc\\n   249→\\t\\t\\t\\tslotCtx, cancel = context.WithDeadline(slotCtx, deadline)\\n   250→\\t\\t\\t\\tdefer cancel()\\n   251→\\t\\t\\t}\\n   252→\\t\\t\\tif err := agents.AcquireSlot(slotCtx, agent); err != nil {\\n   253→\\t\\t\\t\\tt.Fatalf(\\\"timed out waiting for agent slot: %v\\\", err)\\n   254→\\t\\t\\t}\\n   255→\\t\\t\\tdefer agents.ReleaseSlot(agent)\\n   256→\\n   257→\\t\\t\\t// Per-test timeout starts after slot is acquired, scaled\\n   258→\\t\\t\\t// by the agent's multiplier (e.g. 2.5× for gemini).\\n   259→\\t\\t\\tscaled := time.Duration(float64(timeout) * agent.TimeoutMultiplier())\\n   260→\\n   261→\\t\\t\\tvar prevState *RepoState\\n   262→\\t\\t\\tfor attempt := range maxScenarioRestarts + 1 {\\n   263→\\t\\t\\t\\ts := SetupRepo(t, agent)\\n   264→\\t\\t\\t\\tctx, cancel := context.WithTimeout(context.Background(), scaled)\\n   265→\\n   266→\\t\\t\\t\\t// On restart, suppress artifact capture from the previous\\n   267→\\t\\t\\t\\t// failed attempt so it doesn't overwrite the final one.\\n   268→\\t\\t\\t\\tif prevState != nil {\\n   269→\\t\\t\\t\\t\\tprevState.skipArtifacts = true\\n   270→\\t\\t\\t\\t}\\n   271→\\n   272→\\t\\t\\t\\trestarted := runScenario(t, s, ctx, fn)\\n   273→\\t\\t\\t\\tcancel()\\n   274→\\n   275→\\t\\t\\t\\tif !restarted {\\n   276→\\t\\t\\t\\t\\treturn\\n   277→\\t\\t\\t\\t}\\n   278→\\t\\t\\t\\tprevState = s\\n   279→\\t\\t\\t\\tif attempt >= maxScenarioRestarts {\\n   280→\\t\\t\\t\\t\\tt.Fatalf(\\\"exhausted %d scenario attempts due to transient API errors\\\", maxScenarioRestarts+1)\\n   281→\\t\\t\\t\\t}\\n   282→\\t\\t\\t\\tt.Logf(\\\"transient error, restarting scenario (attempt %d/%d)\\\", attempt+2, maxScenarioRestarts+1)\\n   283→\\t\\t\\t}\\n   284→\\t\\t})\\n   285→\\t}\\n   286→}\\n   287→\\n   288→// runScenario runs the test function and recovers from errScenarioRestart\\n   289→// panics triggered by transient API errors in RunPrompt. Returns true if\\n   290→// the scenario should be restarted with a fresh repository.\\n   291→func runScenario(t *testing.T, s *RepoState, ctx context.Context, fn func(t *testing.T, s *RepoState, ctx context.Context)) (restarted bool) {\\n   292→\\tt.Helper()\\n   293→\\tdefer func() {\\n   294→\\t\\tif r := recover(); r != nil {\\n   295→\\t\\t\\tif _, ok := r.(errScenarioRestart); ok {\\n   296→\\t\\t\\t\\trestarted = true\\n   297→\\t\\t\\t\\treturn\\n   298→\\t\\t\\t}\\n   299→\\t\\t\\tpanic(r) // re-panic for unexpected panics\\n   300→\\t\\t}\\n   301→\\t}()\\n   302→\\tfn(t, s, ctx)\\n   303→\\treturn false\\n   304→}\\n   305→\\n   306→const maxScenarioRestarts = 2 // restart up to 2 times = 3 total attempts\\n   307→\\n   308→// errScenarioRestart is panicked by RunPrompt when a transient API error is\\n   309→// detected. ForEachAgent recovers from this panic and restarts the test\\n   310→// scenario with a fresh repository, avoiding stale CLI state from the failed\\n   311→// attempt.\\n   312→type errScenarioRestart struct {\\n   313→\\tmsg string\\n   314→}\\n   315→\\n   316→// RunPrompt runs an agent prompt, logs the command and output to ConsoleLog,\\n   317→// and returns the result. If the agent reports a transient API error, it\\n   318→// panics with errScenarioRestart to trigger a full scenario restart in\\n   319→// ForEachAgent (see runScenario).\\n   320→func (s *RepoState) RunPrompt(t *testing.T, ctx context.Context, prompt string, opts ...agents.Option) (agents.Output, error) {\\n   321→\\tt.Helper()\\n   322→\\tout, err := s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n   323→\\ts.logPromptResult(out)\\n   324→\\n   325→\\tif err != nil && s.Agent.IsTransientError(out, err) {\\n   326→\\t\\terrMsg := fmt.Sprintf(\\\"transient API error (stderr: %s)\\\", strings.TrimSpace(out.Stderr))\\n   327→\\t\\tt.Logf(\\\"%s — restarting scenario\\\", errMsg)\\n   328→\\t\\tfmt.Fprintf(s.ConsoleLog, \\\"> [transient] %s — restarting scenario\\\\n\\\", errMsg)\\n   329→\\t\\tpanic(errScenarioRestart{msg: errMsg})\\n   330→\\t}\\n   331→\\n   332→\\treturn out, err\\n   333→}\\n   334→\\n   335→func (s *RepoState) logPromptResult(out agents.Output) {\\n   336→\\ts.ConsoleLog.WriteString(\\\"> \\\" + out.Command + \\\"\\\\n\\\")\\n   337→\\ts.ConsoleLog.WriteString(\\\"stdout:\\\\n\\\" + out.Stdout + \\\"\\\\n\\\")\\n   338→\\ts.ConsoleLog.WriteString(\\\"stderr:\\\\n\\\" + out.Stderr + \\\"\\\\n\\\")\\n   339→}\\n   340→\\n   341→// Git runs a git command in the repo and logs it to ConsoleLog.\\n   342→func (s *RepoState) Git(t *testing.T, args ...string) {\\n   343→\\tt.Helper()\\n   344→\\ts.ConsoleLog.WriteString(\\\"> git \\\" + strings.Join(args, \\\" \\\") + \\\"\\\\n\\\")\\n   345→\\tGit(t, s.Dir, args...)\\n   346→}\\n   347→\\n   348→// StartSession starts an interactive session and registers it for pane\\n   349→// capture in artifacts. Returns nil if the agent does not support interactive\\n   350→// mode. The session is closed automatically during test cleanup.\\n   351→func (s *RepoState) StartSession(t *testing.T, ctx context.Context) agents.Session {\\n   352→\\tt.Helper()\\n   353→\\tsession, err := s.Agent.StartSession(ctx, s.Dir)\\n   354→\\tif err != nil {\\n   355→\\t\\tt.Fatalf(\\\"start session: %v\\\", err)\\n   356→\\t}\\n   357→\\tif session == nil {\\n   358→\\t\\treturn nil\\n   359→\\t}\\n   360→\\ts.session = session\\n   361→\\treturn session\\n   362→}\\n   363→\\n   364→// WaitFor waits for a pattern in the interactive session's pane and logs the\\n   365→// pane content to ConsoleLog after the wait completes (success or failure).\\n   366→func (s *RepoState) WaitFor(t *testing.T, session agents.Session, pattern string, timeout time.Duration) {\\n   367→\\tt.Helper()\\n   368→\\tcontent, err := session.WaitFor(pattern, timeout)\\n   369→\\tfmt.Fprintf(s.ConsoleLog, \\\"> pane after WaitFor(%q):\\\\n%s\\\\n\\\", pattern, content)\\n   370→\\tif err != nil {\\n   371→\\t\\tt.Fatalf(\\\"WaitFor(%q): %v\\\", pattern, err)\\n   372→\\t}\\n   373→}\\n   374→\\n   375→// Send sends input to an interactive session and logs it to ConsoleLog.\\n   376→// Fails the test on error.\\n   377→func (s *RepoState) Send(t *testing.T, session agents.Session, input string) {\\n   378→\\tt.Helper()\\n   379→\\ts.ConsoleLog.WriteString(\\\"> send: \\\" + input + \\\"\\\\n\\\")\\n   380→\\tif err := session.Send(input); err != nil {\\n   381→\\t\\tt.Fatalf(\\\"send failed: %v\\\", err)\\n   382→\\t}\\n   383→}\\n   384→\\n   385→// PatchSettings merges extra keys into .entire/settings.json.\\n   386→func PatchSettings(t *testing.T, dir string, extra map[string]any) {\\n   387→\\tt.Helper()\\n   388→\\tpath := filepath.Join(dir, \\\".entire\\\", \\\"settings.json\\\")\\n   389→\\tdata, err := os.ReadFile(path)\\n   390→\\tif err != nil {\\n   391→\\t\\tt.Fatalf(\\\"read settings: %v\\\", err)\\n   392→\\t}\\n   393→\\tvar settings map[string]any\\n   394→\\tif err := json.Unmarshal(data, &settings); err != nil {\\n   395→\\t\\tt.Fatalf(\\\"parse settings: %v\\\", err)\\n   396→\\t}\\n   397→\\tfor k, v := range extra {\\n   398→\\t\\tsettings[k] = v\\n   399→\\t}\\n   400→\\tout, err := json.MarshalIndent(settings, \\\"\\\", \\\"  \\\")\\n   401→\\tif err != nil {\\n   402→\\t\\tt.Fatalf(\\\"marshal settings: %v\\\", err)\\n   403→\\t}\\n   404→\\tif err := os.WriteFile(path, out, 0o644); err != nil {\\n   405→\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n   406→\\t}\\n   407→}\\n   408→\\n   409→// Git runs a git command in the given directory and fails the test if it\\n   410→// returns a non-zero exit code.\\n   411→func Git(t *testing.T, dir string, args ...string) {\\n   412→\\tt.Helper()\\n   413→\\n   414→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   415→\\tif dir != \\\"\\\" {\\n   416→\\t\\tcmd.Dir = dir\\n   417→\\t}\\n   418→\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   419→\\n   420→\\tout, err := cmd.CombinedOutput()\\n   421→\\tif err != nil {\\n   422→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n   423→\\t}\\n   424→}\\n   425→\\n   426→// GitOutput runs a git command in the given directory, returns its trimmed\\n   427→// stdout, and fails the test on error.\\n   428→func GitOutput(t *testing.T, dir string, args ...string) string {\\n   429→\\tt.Helper()\\n   430→\\n   431→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   432→\\tif dir != \\\"\\\" {\\n   433→\\t\\tcmd.Dir = dir\\n   434→\\t}\\n   435→\\n   436→\\tout, err := cmd.Output()\\n   437→\\tif err != nil {\\n   438→\\t\\tvar stderr string\\n   439→\\t\\tee := &exec.ExitError{}\\n   440→\\t\\tif errors.As(err, &ee) {\\n   441→\\t\\t\\tstderr = string(ee.Stderr)\\n   442→\\t\\t}\\n   443→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, stderr)\\n   444→\\t}\\n   445→\\n   446→\\treturn strings.TrimSpace(string(out))\\n   447→}\\n   448→\\n   449→// NewCheckpointCommits returns the SHAs of commits added to the\\n   450→// entire/checkpoints/v1 branch since the test was set up, oldest first.\\n   451→func NewCheckpointCommits(t *testing.T, s *RepoState) []string {\\n   452→\\tt.Helper()\\n   453→\\n   454→\\tlog := GitOutput(t, s.Dir, \\\"log\\\", \\\"--reverse\\\", \\\"--format=%H\\\", s.CheckpointBefore+\\\"..entire/checkpoints/v1\\\")\\n   455→\\tif log == \\\"\\\" {\\n   456→\\t\\treturn nil\\n   457→\\t}\\n   458→\\treturn strings.Split(log, \\\"\\\\n\\\")\\n   459→}\\n   460→\\n   461→// CheckpointIDs lists all checkpoint IDs from the tree at the tip of the\\n   462→// checkpoint branch. It parses the two-level directory structure\\n   463→// ({prefix}/{suffix}/metadata.json) and returns the concatenated IDs.\\n   464→func CheckpointIDs(t *testing.T, dir string) []string {\\n   465→\\tt.Helper()\\n   466→\\tout := gitOutputSafe(dir, \\\"ls-tree\\\", \\\"-r\\\", \\\"--name-only\\\", \\\"entire/checkpoints/v1\\\")\\n   467→\\tif out == \\\"\\\" {\\n   468→\\t\\treturn nil\\n   469→\\t}\\n   470→\\tseen := map[string]bool{}\\n   471→\\tvar ids []string\\n   472→\\tfor _, line := range strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\") {\\n   473→\\t\\t// Match {prefix}/{suffix}/metadata.json (top-level, not session-level)\\n   474→\\t\\tparts := strings.Split(line, \\\"/\\\")\\n   475→\\t\\tif len(parts) == 3 && parts[2] == \\\"metadata.json\\\" {\\n   476→\\t\\t\\tid := parts[0] + parts[1]\\n   477→\\t\\t\\tif !seen[id] {\\n   478→\\t\\t\\t\\tseen[id] = true\\n   479→\\t\\t\\t\\tids = append(ids, id)\\n   480→\\t\\t\\t}\\n   481→\\t\\t}\\n   482→\\t}\\n   483→\\treturn ids\\n   484→}\\n   485→\\n   486→// ReadCheckpointMetadata reads the checkpoint-level metadata.json from the\\n   487→// tip of the checkpoint branch for the given checkpoint ID.\\n   488→func ReadCheckpointMetadata(t *testing.T, dir string, checkpointID string) CheckpointMetadata {\\n   489→\\tt.Helper()\\n   490→\\n   491→\\tpath := CheckpointPath(checkpointID) + \\\"/metadata.json\\\"\\n   492→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   493→\\n   494→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   495→\\n   496→\\tvar meta CheckpointMetadata\\n   497→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   498→\\t\\tt.Fatalf(\\\"unmarshal checkpoint metadata from %s: %v\\\", blob, err)\\n   499→\\t}\\n   500→\\n   501→\\treturn meta\\n   502→}\\n   503→\\n   504→// ReadSessionMetadata reads a session's metadata.json from the tip of the\\n   505→// checkpoint branch for the given checkpoint ID and session index.\\n   506→func ReadSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int) SessionMetadata {\\n   507→\\tt.Helper()\\n   508→\\n   509→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   510→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   511→\\n   512→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   513→\\n   514→\\tvar meta SessionMetadata\\n   515→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   516→\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   517→\\t}\\n   518→\\n   519→\\treturn meta\\n   520→}\\n   521→\\n   522→// WaitForSessionMetadata polls until session metadata exists on the checkpoint\\n   523→// branch for the given checkpoint ID and session index, then returns it.\\n   524→// This handles the race where the checkpoint branch advances before session\\n   525→// metadata is fully committed.\\n   526→func WaitForSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int, timeout time.Duration) SessionMetadata {\\n   527→\\tt.Helper()\\n   528→\\n   529→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   530→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   531→\\n   532→\\tdeadline := time.Now().Add(timeout)\\n   533→\\tfor time.Now().Before(deadline) {\\n   534→\\t\\traw := gitOutputSafe(dir, \\\"show\\\", blob)\\n   535→\\t\\tif raw != \\\"\\\" {\\n   536→\\t\\t\\tvar meta SessionMetadata\\n   537→\\t\\t\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   538→\\t\\t\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   539→\\t\\t\\t}\\n   540→\\t\\t\\treturn meta\\n   541→\\t\\t}\\n   542→\\t\\ttime.Sleep(500 * time.Millisecond)\\n   543→\\t}\\n   544→\\tt.Fatalf(\\\"session metadata %s did not appear within %s\\\", blob, timeout)\\n   545→\\treturn SessionMetadata{}\\n   546→}\\n   547→\\n   548→// SetupBareRemote creates a bare git repo, adds it as \\\"origin\\\", and pushes\\n   549→// the initial commit. Returns the bare repo path.\\n   550→func SetupBareRemote(t *testing.T, s *RepoState) string {\\n   551→\\tt.Helper()\\n   552→\\n   553→\\tvar bareDir string\\n   554→\\tif os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\" {\\n   555→\\t\\tvar err error\\n   556→\\t\\tbareDir, err = os.MkdirTemp(\\\"\\\", \\\"e2e-bare-*\\\")\\n   557→\\t\\tif err != nil {\\n   558→\\t\\t\\tt.Fatalf(\\\"create bare remote dir: %v\\\", err)\\n   559→\\t\\t}\\n   560→\\t\\tt.Logf(\\\"E2E_KEEP_REPOS: bare remote will be preserved at %s\\\", bareDir)\\n   561→\\t} else {\\n   562→\\t\\tbareDir = t.TempDir()\\n   563→\\t}\\n   564→\\n   565→\\tGit(t, bareDir, \\\"init\\\", \\\"--bare\\\")\\n   566→\\tGit(t, s.Dir, \\\"remote\\\", \\\"add\\\", \\\"origin\\\", bareDir)\\n   567→\\tGit(t, s.Dir, \\\"push\\\", \\\"-u\\\", \\\"origin\\\", \\\"HEAD\\\")\\n   568→\\treturn bareDir\\n   569→}\\n   570→\\n   571→// GitOutputErr runs a git command and returns (output, error) without\\n   572→// failing the test. For commands expected to fail.\\n   573→func GitOutputErr(dir string, args ...string) (string, error) {\\n   574→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   575→\\tif dir != \\\"\\\" {\\n   576→\\t\\tcmd.Dir = dir\\n   577→\\t}\\n   578→\\tout, err := cmd.CombinedOutput()\\n   579→\\treturn strings.TrimSpace(string(out)), err\\n   580→}\\n   581→\\n   582→// GetCheckpointTrailer extracts the Entire-Checkpoint trailer value from a\\n   583→// code commit. Returns the trimmed trailer value, or an empty string if the\\n   584→// trailer is not present.\\n   585→func GetCheckpointTrailer(t *testing.T, dir string, ref string) string {\\n   586→\\tt.Helper()\\n   587→\\n   588→\\treturn GitOutput(t, dir, \\\"log\\\", \\\"-1\\\", \\\"--format=%(trailers:key=Entire-Checkpoint,valueonly)\\\", ref)\\n   589→}\\n   590→\"}]},\"uuid\":\"39d5265c-50f4-4b22-ad48-84fcf193ac94\",\"timestamp\":\"2026-03-04T16:21:30.570Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alisha/Projects/wt/droid-e2e-ci/e2e/testutil/repo.go\",\"content\":\"package testutil\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"os/exec\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"testing\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/e2e/agents\\\"\\n\\t\\\"github.com/entireio/cli/e2e/entire\\\"\\n)\\n\\nconst droidRepoSettingsPath = \\\".factory/settings.json\\\"\\n\\n// RepoState holds the working state for a single test's cloned repository.\\ntype RepoState struct {\\n\\tAgent            agents.Agent\\n\\tDir              string\\n\\tArtifactDir      string\\n\\tHeadBefore       string\\n\\tCheckpointBefore string\\n\\tConsoleLog       *os.File\\n\\tsession          agents.Session // interactive session, if started via StartSession\\n\\tskipArtifacts    bool           // suppresses artifact capture on scenario restart\\n}\\n\\n// SetupRepo creates a fresh git repository in a temporary directory, seeds it\\n// with an initial commit, and runs `entire enable` for the given agent.\\n// Artifact capture is registered as a cleanup function.\\n//\\n// When E2E_KEEP_REPOS is set, the temporary directory is not cleaned up\\n// so it can be inspected after the test. A symlink in the artifact dir\\n// points to the preserved repo.\\nfunc SetupRepo(t *testing.T, agent agents.Agent) *RepoState {\\n\\tt.Helper()\\n\\n\\tkeepRepos := os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\"\\n\\n\\t// Always use os.MkdirTemp instead of t.TempDir(). Go's t.TempDir()\\n\\t// creates nested subdirectories (TestName.../001/) whose structure\\n\\t// confuses some agents' (e.g. opencode) working-directory resolution.\\n\\tdir, err := os.MkdirTemp(\\\"\\\", \\\"e2e-repo-*\\\")\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"create temp dir: %v\\\", err)\\n\\t}\\n\\tif keepRepos {\\n\\t\\tt.Logf(\\\"E2E_KEEP_REPOS: repo will be preserved at %s\\\", dir)\\n\\t} else {\\n\\t\\tt.Cleanup(func() { os.RemoveAll(dir) })\\n\\t}\\n\\n\\t// Resolve symlinks (macOS: /var -> /private/var) so paths match\\n\\t// what agent CLIs see when they resolve their own CWD.\\n\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n\\t\\tdir = resolved\\n\\t}\\n\\n\\tGit(t, dir, \\\"init\\\")\\n\\tGit(t, dir, \\\"config\\\", \\\"user.name\\\", \\\"E2E Test\\\")\\n\\tGit(t, dir, \\\"config\\\", \\\"user.email\\\", \\\"e2e@test.local\\\")\\n\\tGit(t, dir, \\\"commit\\\", \\\"--allow-empty\\\", \\\"-m\\\", \\\"initial commit\\\")\\n\\n\\tentire.Enable(t, dir, agent.EntireAgent())\\n\\tif agent.Name() == \\\"factoryai-droid\\\" {\\n\\t\\tif err := configureDroidRepoSettings(dir); err != nil {\\n\\t\\t\\tt.Fatalf(\\\"configure droid repo settings: %v\\\", err)\\n\\t\\t}\\n\\t}\\n\\tPatchSettings(t, dir, map[string]any{\\\"log_level\\\": \\\"debug\\\"})\\n\\n\\t// OpenCode's non-interactive mode auto-rejects external_directory permission\\n\\t// since there's no user to prompt. Write a config to allow it.\\n\\tif agent.Name() == \\\"opencode\\\" {\\n\\t\\tcfg := `{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}}`\\n\\t\\tif key := os.Getenv(\\\"ANTHROPIC_API_KEY\\\"); key != \\\"\\\" {\\n\\t\\t\\tcfg = fmt.Sprintf(`{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}, \\\"provider\\\": {\\\"anthropic\\\": {\\\"options\\\": {\\\"apiKey\\\": %q}}}}`, key)\\n\\t\\t}\\n\\t\\tif err := os.WriteFile(filepath.Join(dir, \\\"opencode.json\\\"), []byte(cfg+\\\"\\\\n\\\"), 0o644); err != nil {\\n\\t\\t\\tt.Fatalf(\\\"write opencode.json: %v\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// Create artifact dir eagerly so console.log is written to disk\\n\\t// incrementally. Even if the test is killed by a global timeout,\\n\\t// partial output survives.\\n\\tartDir := artifactDir(t)\\n\\tconsoleLog, err := os.Create(filepath.Join(artDir, \\\"console.log\\\"))\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"create console.log: %v\\\", err)\\n\\t}\\n\\n\\tstate := &RepoState{\\n\\t\\tAgent:            agent,\\n\\t\\tDir:              dir,\\n\\t\\tArtifactDir:      artDir,\\n\\t\\tHeadBefore:       GitOutput(t, dir, \\\"rev-parse\\\", \\\"HEAD\\\"),\\n\\t\\tCheckpointBefore: GitOutput(t, dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\"),\\n\\t\\tConsoleLog:       consoleLog,\\n\\t}\\n\\n\\tt.Cleanup(func() {\\n\\t\\t_ = consoleLog.Close()\\n\\t\\tif !state.skipArtifacts {\\n\\t\\t\\tCaptureArtifacts(t, state)\\n\\t\\t}\\n\\t})\\n\\n\\treturn state\\n}\\n\\nfunc configureDroidRepoSettings(repoDir string) error {\\n\\thome, err := os.UserHomeDir()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"get home dir: %w\\\", err)\\n\\t}\\n\\n\\tglobalSettingsPath := filepath.Join(home, \\\".factory\\\", \\\"settings.json\\\")\\n\\trepoSettingsPath := filepath.Join(repoDir, droidRepoSettingsPath)\\n\\n\\tif err := mergeDroidCustomModels(globalSettingsPath, repoSettingsPath); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\tif err := ensureGitInfoExcludeContains(repoDir, droidRepoSettingsPath); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"exclude droid settings from git: %w\\\", err)\\n\\t}\\n\\treturn nil\\n}\\n\\nfunc mergeDroidCustomModels(globalSettingsPath, repoSettingsPath string) error {\\n\\tglobalSettings, err := loadJSONMap(globalSettingsPath, \\\"global droid settings\\\")\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\tcustomModels, ok := globalSettings[\\\"customModels\\\"]\\n\\tif !ok {\\n\\t\\treturn fmt.Errorf(\\n\\t\\t\\t\\\"global droid settings at %s missing customModels; repo-local %s shadows global settings\\\",\\n\\t\\t\\tglobalSettingsPath,\\n\\t\\t\\trepoSettingsPath,\\n\\t\\t)\\n\\t}\\n\\n\\tvar models []json.RawMessage\\n\\tif err := json.Unmarshal(customModels, &models); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"parse customModels in %s: %w\\\", globalSettingsPath, err)\\n\\t}\\n\\tif len(models) == 0 {\\n\\t\\treturn fmt.Errorf(\\\"global droid settings at %s has empty customModels\\\", globalSettingsPath)\\n\\t}\\n\\n\\trepoSettings, err := loadJSONMap(repoSettingsPath, \\\"repo-local droid settings\\\")\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\trepoSettings[\\\"customModels\\\"] = customModels\\n\\n\\tout, err := json.MarshalIndent(repoSettings, \\\"\\\", \\\"  \\\")\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"marshal repo-local droid settings: %w\\\", err)\\n\\t}\\n\\tout = append(out, '\\\\n')\\n\\n\\tif err := os.WriteFile(repoSettingsPath, out, 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"write repo-local droid settings %s: %w\\\", repoSettingsPath, err)\\n\\t}\\n\\treturn nil\\n}\\n\\nfunc loadJSONMap(path, description string) (map[string]json.RawMessage, error) {\\n\\tdata, err := os.ReadFile(path)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"read %s at %s: %w\\\", description, path, err)\\n\\t}\\n\\n\\tvar parsed map[string]json.RawMessage\\n\\tif err := json.Unmarshal(data, &parsed); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"parse %s at %s: %w\\\", description, path, err)\\n\\t}\\n\\tif parsed == nil {\\n\\t\\tparsed = make(map[string]json.RawMessage)\\n\\t}\\n\\treturn parsed, nil\\n}\\n\\nfunc ensureGitInfoExcludeContains(repoDir, entry string) error {\\n\\texcludePath := filepath.Join(repoDir, \\\".git\\\", \\\"info\\\", \\\"exclude\\\")\\n\\n\\tdata, err := os.ReadFile(excludePath)\\n\\tif err != nil && !errors.Is(err, os.ErrNotExist) {\\n\\t\\treturn fmt.Errorf(\\\"read %s: %w\\\", excludePath, err)\\n\\t}\\n\\n\\tnormalized := strings.ReplaceAll(string(data), \\\"\\\\r\\\\n\\\", \\\"\\\\n\\\")\\n\\tfor _, line := range strings.Split(normalized, \\\"\\\\n\\\") {\\n\\t\\tif strings.TrimSpace(line) == entry {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t}\\n\\n\\tvar b strings.Builder\\n\\tif len(data) > 0 {\\n\\t\\tb.Write(data)\\n\\t\\tif data[len(data)-1] != '\\\\n' {\\n\\t\\t\\tb.WriteByte('\\\\n')\\n\\t\\t}\\n\\t}\\n\\tb.WriteString(entry)\\n\\tb.WriteByte('\\\\n')\\n\\n\\tif err := os.MkdirAll(filepath.Dir(excludePath), 0o755); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"create %s: %w\\\", filepath.Dir(excludePath), err)\\n\\t}\\n\\tif err := os.WriteFile(excludePath, []byte(b.String()), 0o644); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"write %s: %w\\\", excludePath, err)\\n\\t}\\n\\treturn nil\\n}\\n\\n// ForEachAgent runs fn as a parallel subtest for every registered agent.\\n// It handles repo setup, concurrency gating, context timeout, and cleanup.\\n// The timeout is scaled by each agent's TimeoutMultiplier.\\n//\\n// If RunPrompt detects a transient API error (e.g. rate limit, token refresh\\n// failure), it panics with errScenarioRestart. ForEachAgent recovers from the\\n// panic and restarts the entire scenario with a fresh repository, up to\\n// maxScenarioRestarts times. This avoids stale CLI session state from the\\n// failed attempt poisoning the retry.\\nfunc ForEachAgent(t *testing.T, timeout time.Duration, fn func(t *testing.T, s *RepoState, ctx context.Context)) {\\n\\tt.Helper()\\n\\tt.Parallel()\\n\\tall := agents.All()\\n\\tif len(all) == 0 {\\n\\t\\tt.Skip(\\\"no agents registered (check E2E_AGENT filter)\\\")\\n\\t}\\n\\tfor _, agent := range all {\\n\\t\\tt.Run(agent.Name(), func(t *testing.T) {\\n\\t\\t\\t// Use the global test deadline for slot wait so we don't\\n\\t\\t\\t// skip prematurely — only bail if the whole binary is dying.\\n\\t\\t\\tslotCtx := context.Background()\\n\\t\\t\\tif deadline, ok := t.Deadline(); ok {\\n\\t\\t\\t\\tvar cancel context.CancelFunc\\n\\t\\t\\t\\tslotCtx, cancel = context.WithDeadline(slotCtx, deadline)\\n\\t\\t\\t\\tdefer cancel()\\n\\t\\t\\t}\\n\\t\\t\\tif err := agents.AcquireSlot(slotCtx, agent); err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"timed out waiting for agent slot: %v\\\", err)\\n\\t\\t\\t}\\n\\t\\t\\tdefer agents.ReleaseSlot(agent)\\n\\n\\t\\t\\t// Per-test timeout starts after slot is acquired, scaled\\n\\t\\t\\t// by the agent's multiplier (e.g. 2.5× for gemini).\\n\\t\\t\\tscaled := time.Duration(float64(timeout) * agent.TimeoutMultiplier())\\n\\n\\t\\t\\tvar prevState *RepoState\\n\\t\\t\\tfor attempt := range maxScenarioRestarts + 1 {\\n\\t\\t\\t\\ts := SetupRepo(t, agent)\\n\\t\\t\\t\\tctx, cancel := context.WithTimeout(context.Background(), scaled)\\n\\n\\t\\t\\t\\t// On restart, suppress artifact capture from the previous\\n\\t\\t\\t\\t// failed attempt so it doesn't overwrite the final one.\\n\\t\\t\\t\\tif prevState != nil {\\n\\t\\t\\t\\t\\tprevState.skipArtifacts = true\\n\\t\\t\\t\\t}\\n\\n\\t\\t\\t\\trestarted := runScenario(t, s, ctx, fn)\\n\\t\\t\\t\\tcancel()\\n\\n\\t\\t\\t\\tif !restarted {\\n\\t\\t\\t\\t\\treturn\\n\\t\\t\\t\\t}\\n\\t\\t\\t\\tprevState = s\\n\\t\\t\\t\\tif attempt >= maxScenarioRestarts {\\n\\t\\t\\t\\t\\tt.Fatalf(\\\"exhausted %d scenario attempts due to transient API errors\\\", maxScenarioRestarts+1)\\n\\t\\t\\t\\t}\\n\\t\\t\\t\\tt.Logf(\\\"transient error, restarting scenario (attempt %d/%d)\\\", attempt+2, maxScenarioRestarts+1)\\n\\t\\t\\t}\\n\\t\\t})\\n\\t}\\n}\\n\\n// runScenario runs the test function and recovers from errScenarioRestart\\n// panics triggered by transient API errors in RunPrompt. Returns true if\\n// the scenario should be restarted with a fresh repository.\\nfunc runScenario(t *testing.T, s *RepoState, ctx context.Context, fn func(t *testing.T, s *RepoState, ctx context.Context)) (restarted bool) {\\n\\tt.Helper()\\n\\tdefer func() {\\n\\t\\tif r := recover(); r != nil {\\n\\t\\t\\tif _, ok := r.(errScenarioRestart); ok {\\n\\t\\t\\t\\trestarted = true\\n\\t\\t\\t\\treturn\\n\\t\\t\\t}\\n\\t\\t\\tpanic(r) // re-panic for unexpected panics\\n\\t\\t}\\n\\t}()\\n\\tfn(t, s, ctx)\\n\\treturn false\\n}\\n\\nconst maxScenarioRestarts = 2 // restart up to 2 times = 3 total attempts\\n\\n// errScenarioRestart is panicked by RunPrompt when a transient API error is\\n// detected. ForEachAgent recovers from this panic and restarts the test\\n// scenario with a fresh repository, avoiding stale CLI state from the failed\\n// attempt.\\ntype errScenarioRestart struct {\\n\\tmsg string\\n}\\n\\n// RunPrompt runs an agent prompt, logs the command and output to ConsoleLog,\\n// and returns the result. If the agent reports a transient API error, it\\n// panics with errScenarioRestart to trigger a full scenario restart in\\n// ForEachAgent (see runScenario).\\nfunc (s *RepoState) RunPrompt(t *testing.T, ctx context.Context, prompt string, opts ...agents.Option) (agents.Output, error) {\\n\\tt.Helper()\\n\\tout, err := s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n\\ts.logPromptResult(out)\\n\\n\\tif err != nil && s.Agent.IsTransientError(out, err) {\\n\\t\\terrMsg := fmt.Sprintf(\\\"transient API error (stderr: %s)\\\", strings.TrimSpace(out.Stderr))\\n\\t\\tt.Logf(\\\"%s — restarting scenario\\\", errMsg)\\n\\t\\tfmt.Fprintf(s.ConsoleLog, \\\"