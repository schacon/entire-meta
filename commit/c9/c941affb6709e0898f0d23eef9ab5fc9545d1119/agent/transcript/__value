30d\\\\n\\\\nBy default, only commits on the `main` branch are counted. Use\\\\n`--all-branches` to include all branches.\\\\n\\\\nNotes:\\\\n- Counts are based on commit timestamps (`commit.committer.date`), which is the\\\\n  closest REST field available for \\\\\\\"pushed\\\\\\\" timing in this context.\\\\n- Commits without a mapped GitHub user are skipped.\\\\n\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\\nfrom __future__ import annotations\\\\n\\\\nimport argparse\\\\nimport concurrent.futures\\\\nimport json\\\\nimport os\\\\nimport shutil\\\\nimport subprocess\\\\nimport sys\\\\nfrom collections import defaultdict\\\\nfrom dataclasses import dataclass\\\\nfrom datetime import datetime, timedelta, timezone\\\\nfrom typing import Any\\\\nfrom urllib.parse import urlencode\\\\n\\\\n\\\\nGREEN = \\\\\\\"\\\\\\\\033[32m\\\\\\\"\\\\nRED = \\\\\\\"\\\\\\\\033[31m\\\\\\\"\\\\nRESET = \\\\\\\"\\\\\\\\033[0m\\\\\\\"\\\\nDIM = \\\\\\\"\\\\\\\\033[2m\\\\\\\"\\\\n\\\\n\\\\n@dataclass\\\\nclass Activity:\\\\n    last_24h: int = 0\\\\n    last_7d: int = 0\\\\n    last_30d: int = 0\\\\n\\\\n\\\\ndef run_gh_api(path: str, *, paginate: bool = False) -> Any:\\\\n    cmd = [\\\\\\\"gh\\\\\\\", \\\\\\\"api\\\\\\\", path]\\\\n    if paginate:\\\\n        cmd.extend([\\\\\\\"--paginate\\\\\\\", \\\\\\\"--slurp\\\\\\\"])\\\\n\\\\n    try:\\\\n        proc = subprocess.run(cmd, check=True, capture_output=True, text=True)\\\\n    except FileNotFoundError:\\\\n        raise RuntimeError(\\\\\\\"`gh` CLI is not installed or not in PATH.\\\\\\\") from None\\\\n    except subprocess.CalledProcessError as exc:\\\\n        details = exc.stderr.strip() or exc.stdout.strip() or str(exc)\\\\n        raise RuntimeError(details) from exc\\\\n\\\\n    output = proc.stdout.strip()\\\\n    if not output:\\\\n        return []\\\\n\\\\n    data = json.loads(output)\\\\n\\\\n    if paginate:\\\\n        flattened: list[Any] = []\\\\n        for page in data:\\\\n            if isinstance(page, list):\\\\n                flattened.extend(page)\\\\n            else:\\\\n                flattened.append(page)\\\\n        return flattened\\\\n\\\\n    return data\\\\n\\\\n\\\\ndef iso_z(dt: datetime) -> str:\\\\n    return dt.astimezone(timezone.utc).isoformat().replace(\\\\\\\"+00:00\\\\\\\", \\\\\\\"Z\\\\\\\")\\\\n\\\\n\\\\ndef parse_args() -> argparse.Namespace:\\\\n    parser = argparse.ArgumentParser(\\\\n        description=(\\\\n            \\\\\\\"Analyze all repos in a GitHub organization and count commits per \\\\\\\"\\\\n            \\\\\\\"member in the last 24h, 7d, and 30d.\\\\\\\"\\\\n        )\\\\n    )\\\\n    parser.add_argument(\\\\n        \\\\\\\"orgs\\\\\\\",\\\\n        help=\\\\\\\"Comma-separated GitHub org logins, e.g. my-org,another-org\\\\\\\",\\\\n    )\\\\n    parser.add_argument(\\\\n        \\\\\\\"--workers\\\\\\\",\\\\n        type=int,\\\\n        default=min(16, (os.cpu_count() or 4) * 4),\\\\n        help=\\\\\\\"Parallel repo workers (default: %(default)s)\\\\\\\",\\\\n    )\\\\n    parser.add_argument(\\\\n        \\\\\\\"--no-progress\\\\\\\",\\\\n        action=\\\\\\\"store_true\\\\\\\",\\\\n        help=\\\\\\\"Disable progress logging to stderr\\\\\\\",\\\\n    )\\\\n    parser.add_argument(\\\\n        \\\\\\\"--all-branches\\\\\\\",\\\\n        action=\\\\\\\"store_true\\\\\\\",\\\\n        help=\\\\\\\"Count commits across all branches (default: main branch only)\\\\\\\",\\\\n    )\\\\n    return parser.parse_args()\\\\n\\\\n\\\\ndef parse_orgs(raw_orgs: str) -> list[str]:\\\\n    orgs = [org.strip() for org in raw_orgs.split(\\\\\\\",\\\\\\\") if org.strip()]\\\\n    seen: set[str] = set()\\\\n    unique_orgs: list[str] = []\\\\n    for org in orgs:\\\\n        if org not in seen:\\\\n            unique_orgs.append(org)\\\\n            seen.add(org)\\\\n    return unique_orgs\\\\n\\\\n\\\\ndef fetch_org_members(org: str) -> set[str]:\\\\n    path = f\\\\\\\"orgs/{org}/members?per_page=100\\\\\\\"\\\\n    members = run_gh_api(path, paginate=True)\\\\n    return {member[\\\\\\\"login\\\\\\\"] for member in members if member.get(\\\\\\\"login\\\\\\\")}\\\\n\\\\n\\\\ndef fetch_org_repos(org: str) -> list[dict[str, Any]]:\\\\n    path = f\\\\\\\"orgs/{org}/repos?{urlencode({'per_page': 100, 'type': 'all'})}\\\\\\\"\\\\n    repos = run_gh_api(path, paginate=True)\\\\n    return [repo for repo in repos if repo.get(\\\\\\\"name\\\\\\\")]\\\\n\\\\n\\\\ndef fetch_repo_branches(org: str, repo: str) -> list[str]:\\\\n    path = f\\\\\\\"repos/{org}/{repo}/branches?{urlencode({'per_page': 100})}\\\\\\\"\\\\n    branches = run_gh_api(path, paginate=True)\\\\n    return [branch[\\\\\\\"name\\\\\\\"] for branch in branches if branch.get(\\\\\\\"name\\\\\\\")]\\\\n\\\\n\\\\ndef fetch_repo_commits(\\\\n    org: str,\\\\n    repo: str,\\\\n    since: datetime,\\\\n    *,\\\\n    branch: str | None = None,\\\\n) -> list[dict[str, Any]]:\\\\n    query_params: dict[str, Any] = {\\\\n        \\\\\\\"since\\\\\\\": iso_z(since),\\\\n        \\\\\\\"per_page\\\\\\\": 100,\\\\n    }\\\\n    if branch:\\\\n        query_params[\\\\\\\"sha\\\\\\\"] = branch\\\\n    query = urlencode(query_params)\\\\n    path = f\\\\\\\"repos/{org}/{repo}/commits?{query}\\\\\\\"\\\\n    return run_gh_api(path, paginate=True)\\\\n\\\\n\\\\ndef fetch_repo_unique_commits(\\\\n    org: str, repo: str, since: datetime, *, all_branches: bool\\\\n) -> list[dict[str, Any]]:\\\\n    if not all_branches:\\\\n        return fetch_repo_commits(org, repo, since, branch=\\\\\\\"main\\\\\\\")\\\\n\\\\n    branches = fetch_repo_branches(org, repo)\\\\n    commits_by_sha: dict[str, dict[str, Any]] = {}\\\\n    for branch in branches:\\\\n        for commit in fetch_repo_commits(org, repo, since, branch=branch):\\\\n            sha = commit.get(\\\\\\\"sha\\\\\\\")\\\\n            if not sha or sha in commits_by_sha:\\\\n                continue\\\\n            commits_by_sha[sha] = commit\\\\n    return list(commits_by_sha.values())\\\\n\\\\n\\\\ndef fetch_repo_commits_safe(\\\\n    org: str, repo: str, since: datetime, *, all_branches: bool\\\\n) -> tuple[str, list[dict[str, Any]] | None, str | None]:\\\\n    try:\\\\n        commits = fetch_repo_unique_commits(org, repo, since, all_branches=all_branches)\\\\n        return repo, commits, None\\\\n    except RuntimeError as exc:\\\\n        return repo, None, str(exc)\\\\n\\\\n\\\\ndef activity_total(activity: Activity) -> int:\\\\n    return activity.last_24h + activity.last_7d + activity.last_30d\\\\n\\\\n\\\\ndef pick_highlight_rows(\\\\n    members: list[tuple[str, Activity]],\\\\n) -> tuple[dict[str, str], dict[str, str]]:\\\\n    columns = [\\\\\\\"last_24h\\\\\\\", \\\\\\\"last_7d\\\\\\\", \\\\\\\"last_30d\\\\\\\"]\\\\n    highest_rows: dict[str, str] = {}\\\\n    lowest_rows: dict[str, str] = {}\\\\n\\\\n    for column in columns:\\\\n        max_value = max(getattr(activity, column) for _, activity in members)\\\\n        min_value = min(getattr(activity, column) for _, activity in members)\\\\n\\\\n        max_candidates = [\\\\n            (login, activity)\\\\n            for login, activity in members\\\\n            if getattr(activity, column) == max_value\\\\n        ]\\\\n        min_candidates = [\\\\n            (login, activity)\\\\n            for login, activity in members\\\\n            if getattr(activity, column) == min_value\\\\n        ]\\\\n\\\\n        highest_rows[column] = min(\\\\n            max_candidates,\\\\n            key=lambda item: (-activity_total(item[1]), item[0].lower()),\\\\n        )[0]\\\\n        lowest_rows[column] = min(\\\\n            min_candidates,\\\\n            key=lambda item: (activity_total(item[1]), item[0].lower()),\\\\n        )[0]\\\\n\\\\n    return highest_rows, lowest_rows\\\\n\\\\n\\\\ndef format_activity_cell(\\\\n    login: str,\\\\n    value: int,\\\\n    width: int,\\\\n    column: str,\\\\n    highest_rows: dict[str, str],\\\\n    lowest_rows: dict[str, str],\\\\n) -> str:\\\\n    cell = f\\\\\\\"{value:>{width}}\\\\\\\"\\\\n    if highest_rows.get(column) == login:\\\\n        return f\\\\\\\"{GREEN}{cell}{RESET}\\\\\\\"\\\\n    if lowest_rows.get(column) == login:\\\\n        return f\\\\\\\"{RED}{cell}{RESET}\\\\\\\"\\\\n    return cell\\\\n\\\\n\\\\ndef print_member_table(members: list[tuple[str, Activity]]) -> None:\\\\n    for line in build_member_table_lines(members):\\\\n        print(line)\\\\n\\\\n\\\\ndef sorted_members_by_activity(\\\\n    stats: dict[str, Activity],\\\\n) -> list[tuple[str, Activity]]:\\\\n    return sorted(\\\\n        stats.items(),\\\\n        key=lambda item: (\\\\n            item[1].last_30d,\\\\n            item[1].last_7d,\\\\n            item[1].last_24h,\\\\n            item[0].lower(),\\\\n        ),\\\\n        reverse=True,\\\\n    )\\\\n\\\\n\\\\ndef build_member_table_lines(\\\\n    members: list[tuple[str, Activity]],\\\\n    *,\\\\n    max_rows: int | None = None,\\\\n) -> list[str]:\\\\n    lines = [f\\\\\\\"{'Member':<30} {'24h':>8} {'7d':>8} {'30d':>8}\\\\\\\", \\\\\\\"-\\\\\\\" * 58]\\\\n    if not members:\\\\n        return lines\\\\n\\\\n    highest_rows, lowest_rows = pick_highlight_rows(members)\\\\n    rows = members if max_rows is None else members[:max_rows]\\\\n    for login, activity in rows:\\\\n        lines.append(\\\\n            f\\\\\\\"{login:<30} \\\\\\\"\\\\n            f\\\\\\\"{format_activity_cell(login, activity.last_24h, 8, 'last_24h', highest_rows, lowest_rows)} \\\\\\\"\\\\n            f\\\\\\\"{format_activity_cell(login, activity.last_7d, 8, 'last_7d', highest_rows, lowest_rows)} \\\\\\\"\\\\n            f\\\\\\\"{format_activity_cell(login, activity.last_30d, 8, 'last_30d', highest_rows, lowest_rows)}\\\\\\\"\\\\n        )\\\\n\\\\n    if max_rows is not None and len(members) > max_rows:\\\\n        lines.append(f\\\\\\\"{DIM}... {len(members) - max_rows} more members{RESET}\\\\\\\")\\\\n\\\\n    return lines\\\\n\\\\n\\\\ndef render_live_table(\\\\n    current_repo: str,\\\\n    progress: str,\\\\n    skipped_repos: int,\\\\n    members: list[tuple[str, Activity]],\\\\n    previous_lines: int,\\\\n) -> int:\\\\n    term_lines = shutil.get_terminal_size(fallback=(80, 24)).lines\\\\n    target_lines = max(4, term_lines)\\\\n    available_table_lines = max(2, target_lines - 3)\\\\n    max_member_rows = max(1, available_table_lines - 2)\\\\n    table_lines = build_member_table_lines(members, max_rows=max_member_rows)\\\\n    while len(table_lines) > available_table_lines and max_member_rows > 1:\\\\n        max_member_rows -= 1\\\\n        table_lines = build_member_table_lines(members, max_rows=max_member_rows)\\\\n\\\\n    lines = [\\\\n        f\\\\\\\"Scanning repo: {current_repo}\\\\\\\",\\\\n        f\\\\\\\"Progress: {progress} | skipped: {skipped_repos}\\\\\\\",\\\\n        \\\\\\\"\\\\\\\",\\\\n        *table_lines,\\\\n    ]\\\\n    if len(lines) < target_lines:\\\\n        lines.extend([\\\\\\\"\\\\\\\"] * (target_lines - len(lines)))\\\\n\\\\n    if previous_lines > 0:\\\\n        sys.stderr.write(f\\\\\\\"\\\\\\\\033[{max(1, previous_lines - 1)}F\\\\\\\")\\\\n\\\\n    draw_lines = lines + ([\\\\\\\"\\\\\\\"] * max(0, previous_lines - len(lines)))\\\\n    for index, line in enumerate(draw_lines):\\\\n        sys.stderr.write(\\\\\\\"\\\\\\\\033[2K\\\\\\\")\\\\n        sys.stderr.write(line)\\\\n        if index < len(draw_lines) - 1:\\\\n            sys.stderr.write(\\\\\\\"\\\\\\\\n\\\\\\\")\\\\n\\\\n    sys.stderr.flush()\\\\n    return len(lines)\\\\n\\\\n\\\\ndef wait_for_quit() -> None:\\\\n    while True:\\\\n        try:\\\\n            command = input().strip().lower()\\\\n        except EOFError:\\\\n            return\\\\n        if command == \\\\\\\"q\\\\\\\":\\\\n            return\\\\n\\\\n\\\\ndef main() -> None:\\\\n    args = parse_args()\\\\n    orgs = parse_orgs(args.orgs)\\\\n    workers = max(1, args.workers)\\\\n    show_progress = not args.no_progress\\\\n    all_branches = args.all_branches\\\\n\\\\n    if not orgs:\\\\n        print(\\\\\\\"Error: provide at least one organization name.\\\\\\\", file=sys.stderr)\\\\n        sys.exit(1)\\\\n\\\\n    now = datetime.now(timezone.utc)\\\\n    cutoff_24h = now - timedelta(hours=24)\\\\n    cutoff_7d = now - timedelta(days=7)\\\\n    cutoff_30d = now - timedelta(days=30)\\\\n    combined_stats: dict[str, Activity] = defaultdict(Activity)\\\\n    total_repos_scanned = 0\\\\n    total_repos_skipped = 0\\\\n    processed_orgs: list[str] = []\\\\n    render_live = show_progress and sys.stderr.isatty()\\\\n    live_table_lines = 0\\\\n    known_total_repos = 0\\\\n    processed_total_repos = 0\\\\n\\\\n    for org_index, org in enumerate(orgs, start=1):\\\\n        try:\\\\n            members = fetch_org_members(org)\\\\n        except RuntimeError as exc:\\\\n            print(f\\\\\\\"Error fetching organization members for {org}: {exc}\\\\\\\", file=sys.stderr)\\\\n            continue\\\\n\\\\n        if not members:\\\\n            print(f\\\\\\\"No members found for organization: {org}\\\\\\\")\\\\n            print()\\\\n            continue\\\\n\\\\n        for login in members:\\\\n            combined_stats[login]\\\\n\\\\n        try:\\\\n            repos = fetch_org_repos(org)\\\\n        except RuntimeError as exc:\\\\n            print(\\\\n                f\\\\\\\"Error fetching organization repositories for {org}: {exc}\\\\\\\",\\\\n                file=sys.stderr,\\\\n            )\\\\n            continue\\\\n\\\\n        processed_orgs.append(org)\\\\n        known_total_repos += len(repos)\\\\n\\\\n        stats: dict[str, Activity] = defaultdict(Activity)\\\\n        for login in members:\\\\n            stats[login] = Activity()\\\\n\\\\n        total_repos = len(repos)\\\\n        processed_repos = 0\\\\n        skipped_repos = 0\\\\n\\\\n        if render_live:\\\\n            live_table_lines = render_live_table(\\\\n                f\\\\\\\"{org}/initializing\\\\\\\",\\\\n                f\\\\\\\"{processed_total_repos}/{known_total_repos} repos | org {org_index}/{len(orgs)}\\\\\\\",\\\\n                skipped_repos,\\\\n                sorted_members_by_activity(combined_stats),\\\\n                live_table_lines,\\\\n            )\\\\n\\\\n        with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as executor:\\\\n            future_to_repo = {\\\\n                executor.submit(\\\\n                    fetch_repo_commits_safe,\\\\n                    org,\\\\n                    repo[\\\\\\\"name\\\\\\\"],\\\\n                    cutoff_30d,\\\\n                    all_branches=all_branches,\\\\n                ): repo[\\\\\\\"name\\\\\\\"]\\\\n                for repo in repos\\\\n            }\\\\n\\\\n            heartbeat_frames = [\\\\\\\"|\\\\\\\", \\\\\\\"/\\\\\\\", \\\\\\\"-\\\\\\\", \\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\"]\\\\n            heartbeat_index = 0\\\\n            pending_futures: set[concurrent.futures.Future[tuple[str, list[dict[str, Any]] | None, str | None]]] = set(\\\\n                future_to_repo\\\\n            )\\\\n\\\\n            while pending_futures:\\\\n                done_futures, pending_futures = concurrent.futures.wait(\\\\n                    pending_futures,\\\\n                    timeout=1.0,\\\\n                    return_when=concurrent.futures.FIRST_COMPLETED,\\\\n                )\\\\n\\\\n                if render_live and not done_futures:\\\\n                    frame = heartbeat_frames[heartbeat_index % len(heartbeat_frames)]\\\\n                    heartbeat_index += 1\\\\n                    live_table_lines = render_live_table(\\\\n                        f\\\\\\\"{org}/processing {frame} ({len(pending_futures)} active repos)\\\\\\\",\\\\n                        f\\\\\\\"{processed_total_repos}/{known_total_repos} repos | org {org_index}/{len(orgs)}\\\\\\\",\\\\n                        skipped_repos,\\\\n                        sorted_members_by_activity(combined_stats),\\\\n                        live_table_lines,\\\\n                    )\\\\n                    continue\\\\n\\\\n                for future in done_futures:\\\\n                    processed_repos += 1\\\\n                    processed_total_repos += 1\\\\n                    repo_name, commits, error = future.result()\\\\n\\\\n                    if error is not None:\\\\n                        skipped_repos += 1\\\\n                        if render_live:\\\\n                            live_table_lines = render_live_table(\\\\n                                f\\\\\\\"{org}/{repo_name} (skipped: {error})\\\\\\\",\\\\n                                f\\\\\\\"{processed_total_repos}/{known_total_repos} repos | org {org_index}/{len(orgs)}\\\\\\\",\\\\n                                skipped_repos,\\\\n                                sorted_members_by_activity(combined_stats),\\\\n                                live_table_lines,\\\\n                            )\\\\n                        elif show_progress:\\\\n                            print(\\\\n                                f\\\\\\\"[{org}] [{processed_repos}/{total_repos}] skipped {repo_name}: {error}\\\\\\\",\\\\n                                file=sys.stderr,\\\\n                            )\\\\n                        continue\\\\n\\\\n                    if commits is None:\\\\n                        skipped_repos += 1\\\\n                        if render_live:\\\\n                            live_table_lines = render_live_table(\\\\n                                f\\\\\\\"{org}/{repo_name} (no commits)\\\\\\\",\\\\n                                f\\\\\\\"{processed_total_repos}/{known_total_repos} repos | org {org_index}/{len(orgs)}\\\\\\\",\\\\n                                skipped_repos,\\\\n                                sorted_members_by_activity(combined_stats),\\\\n                                live_table_lines,\\\\n                            )\\\\n                        continue\\\\n\\\\n                    if show_progress and not render_live:\\\\n                        print(\\\\n                            f\\\\\\\"[{org}] [{processed_repos}/{total_repos}] scanned {repo_name} ({len(commits)} commits)\\\\\\\",\\\\n                            file=sys.stderr,\\\\n                        )\\\\n\\\\n                    for commit in commits:\\\\n                        author = commit.get(\\\\\\\"author\\\\\\\") or {}\\\\n                        login = author.get(\\\\\\\"login\\\\\\\")\\\\n                        if not login or login not in members:\\\\n                            continue\\\\n\\\\n                        commit_date_raw = (\\\\n                            (commit.get(\\\\\\\"commit\\\\\\\") or {})\\\\n                            .get(\\\\\\\"committer\\\\\\\", {})\\\\n                            .get(\\\\\\\"date\\\\\\\")\\\\n                        )\\\\n                        if not commit_date_raw:\\\\n                            continue\\\\n\\\\n                        try:\\\\n                            commit_date = datetime.fromisoformat(\\\\n                                commit_date_raw.replace(\\\\\\\"Z\\\\\\\", \\\\\\\"+00:00\\\\\\\")\\\\n                            )\\\\n                        except ValueError:\\\\n                            continue\\\\n\\\\n                        if commit_date >= cutoff_30d:\\\\n                            stats[login].last_30d += 1\\\\n                            combined_stats[login].last_30d += 1\\\\n                            if commit_date >= cutoff_7d:\\\\n                                stats[login].last_7d += 1\\\\n                                combined_stats[login].last_7d += 1\\\\n                                if commit_date >= cutoff_24h:\\\\n                                    stats[login].last_24h += 1\\\\n                                    combined_stats[login].last_24h += 1\\\\n\\\\n                    if render_live:\\\\n                        live_table_lines = render_live_table(\\\\n                            f\\\\\\\"{org}/{repo_name} ({len(commits)} commits)\\\\\\\",\\\\n                            f\\\\\\\"{processed_total_repos}/{known_total_repos} repos | org {org_index}/{len(orgs)}\\\\\\\",\\\\n                            skipped_repos,\\\\n                            sorted_members_by_activity(combined_stats),\\\\n                            live_table_lines,\\\\n                        )\\\\n\\\\n        total_repos_scanned += len(repos)\\\\n        total_repos_skipped += skipped_repos\\\\n\\\\n    combined_sorted_members = sorted_members_by_activity(combined_stats)\\\\n\\\\n    if not processed_orgs:\\\\n        print(\\\\\\\"No organizations were processed successfully.\\\\\\\")\\\\n        return\\\\n\\\\n    if render_live and live_table_lines > 0:\\\\n        render_live_table(\\\\n            \\\\\\\"processing finished - type q + Enter to quit\\\\\\\",\\\\n            f\\\\\\\"{processed_total_repos}/{known_total_repos} repos | org {len(processed_orgs)}/{len(orgs)}\\\\\\\",\\\\n            total_repos_skipped,\\\\n            combined_sorted_members,\\\\n            live_table_lines,\\\\n        )\\\\n        wait_for_quit()\\\\n        return\\\\n\\\\n    print(\\\\\\\"Combined organizations\\\\\\\")\\\\n    print(f\\\\\\\"Organizations included: {', '.join(processed_orgs)}\\\\\\\")\\\\n    print(f\\\\\\\"Total repositories scanned: {total_repos_scanned}\\\\\\\")\\\\n    print(f\\\\\\\"Total repositories skipped: {total_repos_skipped}\\\\\\\")\\\\n    print()\\\\n    print_member_table(combined_sorted_members)\\\\n\\\\n\\\\nif __name__ == \\\\\\\"__main__\\\\\\\":\\\\n    main()\\\\n\\\",\\n              \\\"after\\\": \\\"#!/usr/bin/env python3\\\\n\\\\n\\\\\\\"\\\\\\\"\\\\\\\"Count recent commit activity per organization member using GitHub CLI.\\\\n\\\\nThis script scans all repositories in a GitHub organization and counts commits\\\\nby member in three windows:\\\\n  - last 24h\\\\n  - last 7d\\\\n  - last 30d\\\\n\\\\nBy default, only commits on the `main` branch are counted. Use\\\\n`--all-branches` to include all branches.\\\\n\\\\nNotes:\\\\n- Counts are based on commit timestamps (`commit.committer.date`), which is the\\\\n  closest REST field available for \\\\\\\"pushed\\\\\\\" timing in this context.\\\\n- Commits without a mapped GitHub user are skipped.\\\\n\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\\nfrom __future__ import annotations\\\\n\\\\nimport argparse\\\\nimport concurrent.futures\\\\nimport json\\\\nimport os\\\\nimport select\\\\nimport shutil\\\\nimport subprocess\\\\nimport sys\\\\nfrom collections import defaultdict\\\\nfrom dataclasses import dataclass\\\\nfrom datetime import datetime, timedelta, timezone\\\\nfrom typing import Any\\\\nfrom urllib.parse import urlencode\\\\n\\\\n\\\\nGREEN = \\\\\\\"\\\\\\\\033[32m\\\\\\\"\\\\nRED = \\\\\\\"\\\\\\\\033[31m\\\\\\\"\\\\nRESET = \\\\\\\"\\\\\\\\033[0m\\\\\\\"\\\\nDIM = \\\\\\\"\\\\\\\\033[2m\\\\\\\"\\\\n\\\\n\\\\n@dataclass\\\\nclass Activity:\\\\n    last_24h: int = 0\\\\n    last_7d: int = 0\\\\n    last_30d: int = 0\\\\n\\\\n\\\\ndef run_gh_api(path: str, *, paginate: bool = False) -> Any:\\\\n    cmd = [\\\\\\\"gh\\\\\\\", \\\\\\\"api\\\\\\\", path]\\\\n    if paginate:\\\\n        cmd.extend([\\\\\\\"--paginate\\\\\\\", \\\\\\\"--slurp\\\\\\\"])\\\\n\\\\n    try:\\\\n        proc = subprocess.run(cmd, check=True, capture_output=True, text=True)\\\\n    except FileNotFoundError:\\\\n        raise RuntimeError(\\\\\\\"`gh` CLI is not installed or not in PATH.\\\\\\\") from None\\\\n    except subprocess.CalledProcessError as exc:\\\\n        details = exc.stderr.strip() or exc.stdout.strip() or str(exc)\\\\n        raise RuntimeError(details) from exc\\\\n\\\\n    output = proc.stdout.strip()\\\\n    if not output:\\\\n        return []\\\\n\\\\n    data = json.loads(output)\\\\n\\\\n    if paginate:\\\\n        flattened: list[Any] = []\\\\n        for page in data:\\\\n            if isinstance(page, list):\\\\n                flattened.extend(page)\\\\n            else:\\\\n                flattened.append(page)\\\\n        return flattened\\\\n\\\\n    return data\\\\n\\\\n\\\\ndef iso_z(dt: datetime) -> str:\\\\n    return dt.astimezone(timezone.utc).isoformat().replace(\\\\\\\"+00:00\\\\\\\", \\\\\\\"Z\\\\\\\")\\\\n\\\\n\\\\ndef parse_args() -> argparse.Namespace:\\\\n    parser = argparse.ArgumentParser(\\\\n        description=(\\\\n            \\\\\\\"Analyze all repos in a GitHub organization and count commits per \\\\\\\"\\\\n            \\\\\\\"member in the last 24h, 7d, and 30d.\\\\\\\"\\\\n        )\\\\n    )\\\\n    parser.add_argument(\\\\n        \\\\\\\"orgs\\\\\\\",\\\\n        help=\\\\\\\"Comma-separated GitHub org logins, e.g. my-org,another-org\\\\\\\",\\\\n    )\\\\n    parser.add_argument(\\\\n        \\\\\\\"--workers\\\\\\\",\\\\n        type=int,\\\\n        default=min(16, (os.cpu_count() or 4) * 4),\\\\n        help=\\\\\\\"Parallel repo workers (default: %(default)s)\\\\\\\",\\\\n    )\\\\n    parser.add_argument(\\\\n        \\\\\\\"--no-progress\\\\\\\",\\\\n        action=\\\\\\\"store_true\\\\\\\",\\\\n        help=\\\\\\\"Disable progress logging to stderr\\\\\\\",\\\\n    )\\\\n    parser.add_argument(\\\\n        \\\\\\\"--all-branches\\\\\\\",\\\\n        action=\\\\\\\"store_true\\\\\\\",\\\\n        help=\\\\\\\"Count commits across all branches (default: main branch only)\\\\\\\",\\\\n    )\\\\n    return parser.parse_args()\\\\n\\\\n\\\\ndef parse_orgs(raw_orgs: str) -> list[str]:\\\\n    orgs = [org.strip() for org in raw_orgs.split(\\\\\\\",\\\\\\\") if org.strip()]\\\\n    seen: set[str] = set()\\\\n    unique_orgs: list[str] = []\\\\n    for org in orgs:\\\\n        if org not in seen:\\\\n            unique_orgs.append(org)\\\\n            seen.add(org)\\\\n    return unique_orgs\\\\n\\\\n\\\\ndef fetch_org_members(org: str) -> set[str]:\\\\n    path = f\\\\\\\"orgs/{org}/members?per_page=100\\\\\\\"\\\\n    members = run_gh_api(path, paginate=True)\\\\n    return {member[\\\\\\\"login\\\\\\\"] for member in members if member.get(\\\\\\\"login\\\\\\\")}\\\\n\\\\n\\\\ndef fetch_org_repos(org: str) -> list[dict[str, Any]]:\\\\n    path = f\\\\\\\"orgs/{org}/repos?{urlencode({'per_page': 100, 'type': 'all'})}\\\\\\\"\\\\n    repos = run_gh_api(path, paginate=True)\\\\n    return [repo for repo in repos if repo.get(\\\\\\\"name\\\\\\\")]\\\\n\\\\n\\\\ndef fetch_repo_branches(org: str, repo: str) -> list[str]:\\\\n    path = f\\\\\\\"repos/{org}/{repo}/branches?{urlencode({'per_page': 100})}\\\\\\\"\\\\n    branches = run_gh_api(path, paginate=True)\\\\n    return [branch[\\\\\\\"name\\\\\\\"] for branch in branches if branch.get(\\\\\\\"name\\\\\\\")]\\\\n\\\\n\\\\ndef fetch_repo_commits(\\\\n    org: str,\\\\n    repo: str,\\\\n    since: datetime,\\\\n    *,\\\\n    branch: str | None = None,\\\\n) -> list[dict[str, Any]]:\\\\n    query_params: dict[str, Any] = {\\\\n        \\\\\\\"since\\\\\\\": iso_z(since),\\\\n        \\\\\\\"per_page\\\\\\\": 100,\\\\n    }\\\\n    if branch:\\\\n        query_params[\\\\\\\"sha\\\\\\\"] = branch\\\\n    query = urlencode(query_params)\\\\n    path = f\\\\\\\"repos/{org}/{repo}/commits?{query}\\\\\\\"\\\\n    return run_gh_api(path, paginate=True)\\\\n\\\\n\\\\ndef fetch_repo_unique_commits(\\\\n    org: str, repo: str, since: datetime, *, all_branches: bool\\\\n) -> list[dict[str, Any]]:\\\\n    if not all_branches:\\\\n        return fetch_repo_commits(org, repo, since, branch=\\\\\\\"main\\\\\\\")\\\\n\\\\n    branches = fetch_repo_branches(org, repo)\\\\n    commits_by_sha: dict[str, dict[str, Any]] = {}\\\\n    for branch in branches:\\\\n        for commit in fetch_repo_commits(org, repo, since, branch=branch):\\\\n            sha = commit.get(\\\\\\\"sha\\\\\\\")\\\\n            if not sha or sha in commits_by_sha:\\\\n                continue\\\\n            commits_by_sha[sha] = commit\\\\n    return list(commits_by_sha.values())\\\\n\\\\n\\\\ndef fetch_repo_commits_safe(\\\\n    org: str, repo: str, since: datetime, *, all_branches: bool\\\\n) -> tuple[str, list[dict[str, Any]] | None, str | None]:\\\\n    try:\\\\n        commits = fetch_repo_unique_commits(org, repo, since, all_branches=all_branches)\\\\n        return repo, commits, None\\\\n    except RuntimeError as exc:\\\\n        return repo, None, str(exc)\\\\n\\\\n\\\\ndef activity_total(activity: Activity) -> int:\\\\n    return activity.last_24h + activity.last_7d + activity.last_30d\\\\n\\\\n\\\\ndef pick_highlight_rows(\\\\n    members: list[tuple[str, Activity]],\\\\n) -> tuple[dict[str, str], dict[str, str]]:\\\\n    columns = [\\\\\\\"last_24h\\\\\\\", \\\\\\\"last_7d\\\\\\\", \\\\\\\"last_30d\\\\\\\"]\\\\n    highest_rows: dict[str, str] = {}\\\\n    lowest_rows: dict[str, str] = {}\\\\n\\\\n    for column in columns:\\\\n        max_value = max(getattr(activity, column) for _, activity in members)\\\\n        min_value = min(getattr(activity, column) for _, activity in members)\\\\n\\\\n        max_candidates = [\\\\n            (login, activity)\\\\n            for login, activity in members\\\\n            if getattr(activity, column) == max_value\\\\n        ]\\\\n        min_candidates = [\\\\n            (login, activity)\\\\n            for login, activity in members\\\\n            if getattr(activity, column) == min_value\\\\n        ]\\\\n\\\\n        highest_rows[column] = min(\\\\n            max_candidates,\\\\n            key=lambda item: (-activity_total(item[1]), item[0].lower()),\\\\n        )[0]\\\\n        lowest_rows[column] = min(\\\\n            min_candidates,\\\\n            key=lambda item: (activity_total(item[1]), item[0].lower()),\\\\n        )[0]\\\\n\\\\n    return highest_rows, lowest_rows\\\\n\\\\n\\\\ndef format_activity_cell(\\\\n    login: str,\\\\n    value: int,\\\\n    width: int,\\\\n    column: str,\\\\n    highest_rows: dict[str, str],\\\\n    lowest_rows: dict[str, str],\\\\n) -> str:\\\\n    cell = f\\\\\\\"{value:>{width}}\\\\\\\"\\\\n    if highest_rows.get(column) == login:\\\\n        return f\\\\\\\"{GREEN}{cell}{RESET}\\\\\\\"\\\\n    if lowest_rows.get(column) == login:\\\\n        return f\\\\\\\"{RED}{cell}{RESET}\\\\\\\"\\\\n    return cell\\\\n\\\\n\\\\ndef truncate_with_ellipsis(value: str, width: int) -> str:\\\\n    if width <= 0:\\\\n        return \\\\\\\"\\\\\\\"\\\\n    if len(value) <= width:\\\\n        return value\\\\n    if width <= 3:\\\\n        return value[:width]\\\\n    return f\\\\\\\"{value[: width - 3]}...\\\\\\\"\\\\n\\\\n\\\\ndef print_member_table(members: list[tuple[str, Activity]]) -> None:\\\\n    for line in build_member_table_lines(members):\\\\n        print(line)\\\\n\\\\n\\\\ndef sorted_members_by_activity(\\\\n    stats: dict[str, Activity],\\\\n) -> list[tuple[str, Activity]]:\\\\n    return sorted(\\\\n        stats.items(),\\\\n        key=lambda item: (\\\\n            item[1].last_30d,\\\\n            item[1].last_7d,\\\\n            item[1].last_24h,\\\\n            item[0].lower(),\\\\n        ),\\\\n        reverse=True,\\\\n    )\\\\n\\\\n\\\\ndef build_member_table_lines(\\\\n    members: list[tuple[str, Activity]],\\\\n    *,\\\\n    max_rows: int | None = None,\\\\n    member_width: int = 30,\\\\n    activity_width: int = 8,\\\\n) -> list[str]:\\\\n    lines = [\\\\n        f\\\\\\\"{'Member':<{member_width}} {'24h':>{activity_width}} {'7d':>{activity_width}} {'30d':>{activity_width}}\\\\\\\",\\\\n        \\\\\\\"-\\\\\\\" * (member_width + (activity_width * 3) + 3),\\\\n    ]\\\\n    if not members:\\\\n        return lines\\\\n\\\\n    highest_rows, lowest_rows = pick_highlight_rows(members)\\\\n    rows = members if max_rows is None else members[:max_rows]\\\\n    for login, activity in rows:\\\\n        login_label = truncate_with_ellipsis(login, member_width)\\\\n        lines.append(\\\\n            f\\\\\\\"{login_label:<{member_width}} \\\\\\\"\\\\n            f\\\\\\\"{format_activity_cell(login, activity.last_24h, activity_width, 'last_24h', highest_rows, lowest_rows)} \\\\\\\"\\\\n            f\\\\\\\"{format_activity_cell(login, activity.last_7d, activity_width, 'last_7d', highest_rows, lowest_rows)} \\\\\\\"\\\\n            f\\\\\\\"{format_activity_cell(login, activity.last_30d, activity_width, 'last_30d', highest_rows, lowest_rows)}\\\\\\\"\\\\n        )\\\\n\\\\n    if max_rows is not None and len(members) > max_rows:\\\\n        lines.append(f\\\\\\\"{DIM}... {len(members) - max_rows} more members{RESET}\\\\\\\")\\\\n\\\\n    return lines\\\\n\\\\n\\\\ndef render_live_table(\\\\n    current_repo: str,\\\\n    progress: str,\\\\n    skipped_repos: int,\\\\n    members: list[tuple[str, Activity]],\\\\n    previous_lines: int,\\\\n) -> int:\\\\n    term_size = shutil.get_terminal_size(fallback=(80, 24))\\\\n    term_columns = term_size.columns\\\\n    term_lines = term_size.lines\\\\n\\\\n    spacing = 3\\\\n    min_member_width = 6\\\\n    min_activity_width = 3\\\\n    max_activity_width = 8\\\\n    max_member_width = 30\\\\n\\\\n    available_width = max(1, term_columns - spacing)\\\\n    if available_width <= min_member_width + (min_activity_width * 3):\\\\n        activity_width = min_activity_width\\\\n        member_width = min_member_width\\\\n    else:\\\\n        activity_width = min(\\\\n            max_activity_width,\\\\n            max(min_activity_width, (available_width - min_member_width) // 3),\\\\n        )\\\\n        member_width = min(max_member_width, available_width - (activity_width * 3))\\\\n\\\\n    target_lines = max(4, term_lines)\\\\n    available_table_lines = max(2, target_lines - 3)\\\\n    max_member_rows = max(1, available_table_lines - 2)\\\\n    table_lines = build_member_table_lines(\\\\n        members,\\\\n        max_rows=max_member_rows,\\\\n        member_width=member_width,\\\\n        activity_width=activity_width,\\\\n    )\\\\n    while len(table_lines) > available_table_lines and max_member_rows > 1:\\\\n        max_member_rows -= 1\\\\n        table_lines = build_member_table_lines(\\\\n            members,\\\\n            max_rows=max_member_rows,\\\\n            member_width=member_width,\\\\n            activity_width=activity_width,\\\\n        )\\\\n\\\\n    lines = [\\\\n        f\\\\\\\"Scanning repo: {current_repo}\\\\\\\",\\\\n        f\\\\\\\"Progress: {progress} | skipped: {skipped_repos}\\\\\\\",\\\\n        \\\\\\\"\\\\\\\",\\\\n        *table_lines,\\\\n    ]\\\\n    if len(lines) < target_lines:\\\\n        lines.extend([\\\\\\\"\\\\\\\"] * (target_lines - len(lines)))\\\\n\\\\n    if previous_lines > 0:\\\\n        sys.stderr.write(f\\\\\\\"\\\\\\\\033[{max(1, previous_lines - 1)}F\\\\\\\")\\\\n\\\\n    draw_lines = lines + ([\\\\\\\"\\\\\\\"] * max(0, previous_lines - len(lines)))\\\\n    for index, line in enumerate(draw_lines):\\\\n        sys.stderr.write(\\\\\\\"\\\\\\\\033[2K\\\\\\\")\\\\n        sys.stderr.write(line)\\\\n        if index < len(draw_lines) - 1:\\\\n            sys.stderr.write(\\\\\\\"\\\\\\\\n\\\\\\\")\\\\n\\\\n    sys.stderr.flush()\\\\n    return len(lines)\\\\n\\\\n\\\\ndef wait_for_quit_with_resize(\\\\n    progress: str,\\\\n    skipped_repos: int,\\\\n    members: list[tuple[str, Activity]],\\\\n    previous_lines: int,\\\\n) -> None:\\\\n    current_lines = previous_lines\\\\n    last_size = shutil.get_terminal_size(fallback=(80, 24))\\\\n\\\\n    while True:\\\\n        current_size = shutil.get_terminal_size(fallback=(80, 24))\\\\n        if current_size != last_size:\\\\n            current_lines = render_live_table(\\\\n                \\\\\\\"processing finished - type q + Enter to quit\\\\\\\",\\\\n                progress,\\\\n                skipped_repos,\\\\n                members,\\\\n                current_lines,\\\\n            )\\\\n            last_size = current_size\\\\n\\\\n        try:\\\\n            ready, _, _ = select.select([sys.stdin], [], [], 0.25)\\\\n        except (OSError, ValueError):\\\\n            return\\\\n\\\\n        if not ready:\\\\n            continue\\\\n\\\\n        command = sys.stdin.readline()\\\\n        if command == \\\\\\\"\\\\\\\":\\\\n            return\\\\n        if command.strip().lower() == \\\\\\\"q\\\\\\\":\\\\n            return\\\\n\\\\n\\\\ndef main() -> None:\\\\n    args = parse_args()\\\\n    orgs = parse_orgs(args.orgs)\\\\n    workers = max(1, args.workers)\\\\n    show_progress = not args.no_progress\\\\n    all_branches = args.all_branches\\\\n\\\\n    if not orgs:\\\\n        print(\\\\\\\"Error: provide at least one organization name.\\\\\\\", file=sys.stderr)\\\\n        sys.exit(1)\\\\n\\\\n    now = datetime.now(timezone.utc)\\\\n    cutoff_24h = now - timedelta(hours=24)\\\\n    cutoff_7d = now - timedelta(days=7)\\\\n    cutoff_30d = now - timedelta(days=30)\\\\n    combined_stats: dict[str, Activity] = defaultdict(Activity)\\\\n    total_repos_scanned = 0\\\\n    total_repos_skipped = 0\\\\n    processed_orgs: list[str] = []\\\\n    render_live = show_progress and sys.stderr.isatty()\\\\n    live_table_lines = 0\\\\n    known_total_repos = 0\\\\n    processed_total_repos = 0\\\\n\\\\n    for org_index, org in enumerate(orgs, start=1):\\\\n        try:\\\\n            members = fetch_org_members(org)\\\\n        except RuntimeError as exc:\\\\n            print(f\\\\\\\"Error fetching organization members for {org}: {exc}\\\\\\\", file=sys.stderr)\\\\n            continue\\\\n\\\\n        if not members:\\\\n            print(f\\\\\\\"No members found for organization: {org}\\\\\\\")\\\\n            print()\\\\n            continue\\\\n\\\\n        for login in members:\\\\n            combined_stats[login]\\\\n\\\\n        try:\\\\n            repos = fetch_org_repos(org)\\\\n        except RuntimeError as exc:\\\\n            print(\\\\n                f\\\\\\\"Error fetching organization repositories for {org}: {exc}\\\\\\\",\\\\n                file=sys.stderr,\\\\n            )\\\\n            continue\\\\n\\\\n        processed_orgs.append(org)\\\\n        known_total_repos += len(repos)\\\\n\\\\n        stats: dict[str, Activity] = defaultdict(Activity)\\\\n        for login in members:\\\\n            stats[login] = Activity()\\\\n\\\\n        total_repos = len(repos)\\\\n        processed_repos = 0\\\\n        skipped_repos = 0\\\\n\\\\n        if render_live:\\\\n            live_table_lines = render_live_table(\\\\n                f\\\\\\\"{org}/initializing\\\\\\\",\\\\n                f\\\\\\\"{processed_total_repos}/{known_total_repos} repos | org {org_index}/{len(orgs)}\\\\\\\",\\\\n                skipped_repos,\\\\n                sorted_members_by_activity(combined_stats),\\\\n                live_table_lines,\\\\n            )\\\\n\\\\n        with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as executor:\\\\n            future_to_repo = {\\\\n                executor.submit(\\\\n                    fetch_repo_commits_safe,\\\\n                    org,\\\\n                    repo[\\\\\\\"name\\\\\\\"],\\\\n                    cutoff_30d,\\\\n                    all_branches=all_branches,\\\\n                ): repo[\\\\\\\"name\\\\\\\"]\\\\n                for repo in repos\\\\n            }\\\\n\\\\n            heartbeat_frames = [\\\\\\\"|\\\\\\\", \\\\\\\"/\\\\\\\", \\\\\\\"-\\\\\\\", \\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\"]\\\\n            heartbeat_index = 0\\\\n            pending_futures: set[concurrent.futures.Future[tuple[str, list[dict[str, Any]] | None, str | None]]] = set(\\\\n                future_to_repo\\\\n            )\\\\n\\\\n            while pending_futures:\\\\n                done_futures, pending_futures = concurrent.futures.wait(\\\\n                    pending_futures,\\\\n                    timeout=1.0,\\\\n                    return_when=concurrent.futures.FIRST_COMPLETED,\\\\n                )\\\\n\\\\n                if render_live and not done_futures:\\\\n                    frame = heartbeat_frames[heartbeat_index % len(heartbeat_frames)]\\\\n                    heartbeat_index += 1\\\\n                    live_table_lines = render_live_table(\\\\n                        f\\\\\\\"{org}/processing {frame} ({len(pending_futures)} active repos)\\\\\\\",\\\\n                        f\\\\\\\"{processed_total_repos}/{known_total_repos} repos | org {org_index}/{len(orgs)}\\\\\\\",\\\\n                        skipped_repos,\\\\n                        sorted_members_by_activity(combined_stats),\\\\n                        live_table_lines,\\\\n                    )\\\\n                    continue\\\\n\\\\n                for future in done_futures:\\\\n                    processed_repos += 1\\\\n                    processed_total_repos += 1\\\\n                    repo_name, commits, error = future.result()\\\\n\\\\n                    if error is not None:\\\\n                        skipped_repos += 1\\\\n                        if render_live:\\\\n                            live_table_lines = render_live_table(\\\\n                                f\\\\\\\"{org}/{repo_name} (skipped: {error})\\\\\\\",\\\\n                                f\\\\\\\"{processed_total_repos}/{known_total_repos} repos | org {org_index}/{len(orgs)}\\\\\\\",\\\\n                                skipped_repos,\\\\n                                sorted_members_by_activity(combined_stats),\\\\n                                live_table_lines,\\\\n                            )\\\\n                        elif show_progress:\\\\n                            print(\\\\n                                f\\\\\\\"[{org}] [{processed_repos}/{total_repos}] skipped {repo_name}: {error}\\\\\\\",\\\\n                                file=sys.stderr,\\\\n                            )\\\\n                        continue\\\\n\\\\n                    if commits is None:\\\\n                        skipped_repos += 1\\\\n                        if render_live:\\\\n                