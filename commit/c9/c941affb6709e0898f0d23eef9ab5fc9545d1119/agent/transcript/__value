\\", err\\n    26→\\t}\\n    27→\\treturn filepath.Join(commonDir, session.SessionStateDirName), nil\\n    28→}\\n    29→\\n    30→// sessionStateFile returns the path to a session state file.\\n    31→func sessionStateFile(ctx context.Context, sessionID string) (string, error) {\\n    32→\\tstateDir, err := getSessionStateDir(ctx)\\n    33→\\tif err != nil {\\n    34→\\t\\treturn \\\"\\\", err\\n    35→\\t}\\n    36→\\treturn filepath.Join(stateDir, sessionID+\\\".json\\\"), nil\\n    37→}\\n    38→\\n    39→// LoadSessionState loads the session state for the given session ID.\\n    40→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n    41→// Stale sessions are automatically deleted by the underlying StateStore.\\n    42→func LoadSessionState(ctx context.Context, sessionID string) (*SessionState, error) {\\n    43→\\tstore, err := session.NewStateStore(ctx)\\n    44→\\tif err != nil {\\n    45→\\t\\treturn nil, fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n    46→\\t}\\n    47→\\n    48→\\tstate, err := store.Load(ctx, sessionID)\\n    49→\\tif err != nil {\\n    50→\\t\\treturn nil, fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n    51→\\t}\\n    52→\\treturn state, nil\\n    53→}\\n    54→\\n    55→// SaveSessionState saves the session state atomically.\\n    56→func SaveSessionState(ctx context.Context, state *SessionState) error {\\n    57→\\t// Validate session ID to prevent path traversal\\n    58→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n    59→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n    60→\\t}\\n    61→\\n    62→\\tstateDir, err := getSessionStateDir(ctx)\\n    63→\\tif err != nil {\\n    64→\\t\\treturn fmt.Errorf(\\\"failed to get session state directory: %w\\\", err)\\n    65→\\t}\\n    66→\\n    67→\\tif err := os.MkdirAll(stateDir, 0o750); err != nil {\\n    68→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n    69→\\t}\\n    70→\\n    71→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n    72→\\tif err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n    74→\\t}\\n    75→\\n    76→\\tstateFile, err := sessionStateFile(ctx, state.SessionID)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn fmt.Errorf(\\\"failed to get session state file path: %w\\\", err)\\n    79→\\t}\\n    80→\\n    81→\\t// Atomic write: write to temp file, then rename\\n    82→\\ttmpFile := stateFile + \\\".tmp\\\"\\n    83→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n    84→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n    85→\\t}\\n    86→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n    87→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n    88→\\t}\\n    89→\\treturn nil\\n    90→}\\n    91→\\n    92→// ListSessionStates returns all session states from the state directory.\\n    93→// This is a package-level function that doesn't require a specific strategy instance.\\n    94→func ListSessionStates(ctx context.Context) ([]*SessionState, error) {\\n    95→\\tstore, err := session.NewStateStore(ctx)\\n    96→\\tif err != nil {\\n    97→\\t\\treturn nil, fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n    98→\\t}\\n    99→\\n   100→\\tstates, err := store.List(ctx)\\n   101→\\tif err != nil {\\n   102→\\t\\treturn nil, fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   103→\\t}\\n   104→\\treturn states, nil\\n   105→}\\n   106→\\n   107→// FindMostRecentSession returns the session ID of the most recently interacted session\\n   108→// (by LastInteractionTime) in the current worktree. Returns empty string if no sessions exist.\\n   109→// Scoping to the current worktree prevents cross-worktree pollution in log routing.\\n   110→// Falls back to unfiltered search if the worktree pa