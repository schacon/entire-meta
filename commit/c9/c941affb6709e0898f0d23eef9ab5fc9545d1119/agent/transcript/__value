\n    71→\\ts.LastTranscriptLineCount = 0\\n    72→\\n    73→\\t// Migrate all deprecated fields to the unified TranscriptOffset\\n    74→\\tif s.TranscriptOffset == 0 {\\n    75→\\t\\tif s.StepTranscriptStart > 0 {\\n    76→\\t\\t\\ts.TranscriptOffset = s.StepTranscriptStart\\n    77→\\t\\t} else if s.StartMessageIndex > 0 {\\n    78→\\t\\t\\ts.TranscriptOffset = s.StartMessageIndex\\n    79→\\t\\t}\\n    80→\\t}\\n    81→\\ts.StepTranscriptStart = 0\\n    82→\\ts.StartMessageIndex = 0\\n    83→}\\n    84→\\n    85→// CapturePrePromptState captures current untracked files and transcript position before a prompt\\n    86→// and saves them to a state file.\\n    87→//\\n    88→// The agent parameter is used to determine the transcript position via TranscriptAnalyzer.\\n    89→// If the agent does not implement TranscriptAnalyzer, the transcript offset will be 0.\\n    90→// The sessionRef parameter is optional — if empty, transcript position won't be captured.\\n    91→//\\n    92→// Works correctly from any subdirectory within the repository.\\n    93→func CapturePrePromptState(ctx context.Context, ag agent.Agent, sessionID, sessionRef string) error {\\n    94→\\tif sessionID == \\\"\\\" {\\n    95→\\t\\tsessionID = unknownSessionID\\n    96→\\t}\\n    97→\\n    98→\\t// Get absolute path for tmp directory\\n    99→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   100→\\tif err != nil {\\n   101→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   102→\\t}\\n   103→\\n   104→\\t// Create tmp directory if it doesn't exist\\n   105→\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   106→\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n   107→\\t}\\n   108→\\n   109→\\t// Get list of untracked files (excluding .entire directory itself)\\n   110→\\tuntrackedFiles, err := getUntrackedFilesForState(ctx)\\n   111→\\tif err != nil {\\n   112→\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n   113→\\t}\\n   114→\\n   115→\\t// Get transcript position using TranscriptAnalyzer if available\\n   116→\\tvar transcriptOffset int\\n   117→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok && sessionRef != \\\"\\\" {\\n   118→\\t\\tpos, posErr := analyzer.GetTranscriptPosition(sessionRef)\\n   119→\\t\\tif posErr != nil {\\n   120→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to get transcript position: %v\\\\n\\\", posErr)\\n   121→\\t\\t} else {\\n   122→\\t\\t\\ttranscriptOffset = pos\\n   123→\\t\\t}\\n   124→\\t}\\n   125→\\n   126→\\t// Create state file\\n   127→\\tstateFile := prePromptStateFile(ctx, sessionID)\\n   128→\\tstate := PrePromptState{\\n   129→\\t\\tSessionID:        sessionID,\\n   130→\\t\\tTimestamp:        time.Now().UTC().Format(time.RFC3339),\\n   131→\\t\\tUntrackedFiles:   untrackedFiles,\\n   132→\\t\\tTranscriptOffset: transcriptOffset,\\n   133→\\t}\\n   134→\\n   135→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   136→\\tif err != nil {\\n   137→\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n   138→\\t}\\n   139→\\n   140→\\tif err := os.WriteFile(stateFile, data, 0o600); err != nil {\\n   141→\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   142→\\t}\\n   143→\\n   144→\\tfmt.Fprintf(os.Stderr, \\\"Captured state before prompt: %d untracked files, transcript offset: %d\\\\n\\\",\\n   145→\\t\\tlen(untrackedFiles), transcriptOffset)\\n   146→\\treturn nil\\n   147→}\\n   148→\\n   149→// LoadPrePromptState loads previously captured state.\\n   150→// Returns nil if no state file exists.\\n   151→func LoadPrePromptState(ctx context.Context, sessionID string) (*PrePromptState, error) {\\n   152→\\tstateFile := prePromptStateFile(ctx, sessionID)\\n   153→\\n   154→\\tif !fileExists(stateFile) {\\n   155→\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   156→\\t}\\n   157→\\n   158→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // Reading from controlled git metadata path\\n   159→\\tif err != nil {\\n   160→\\t\\treturn nil, fmt.Errorf(\\\"failed to read state file: %w\\\", err)\\n   161→\\t}\\n   162→\\n   163→\\tvar state PrePromptState\\n   164→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   165→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal state: %w\\\", err)\\n   166→\\t}\\n   167→\\n   168→\\tstate.normalizePrePromptState()\\n   169→\\n   170→\\treturn &state, nil\\n   171→}\\n   172→\\n   173→// CleanupPrePromptState removes the state file after use\\n   174→func CleanupPrePromptState(ctx context.Context, sessionID string) error {\\n   175→\\tstateFile := prePromptStateFile(ctx, sessionID)\\n   176→\\tif fileExists(stateFile) {\\n   177→\\t\\treturn os.Remove(stateFile) //nolint:wrapcheck // already present in codebase\\n   178→\\t}\\n   179→\\treturn nil\\n   180→}\\n   181→\\n   182→// FileChanges holds categorized file changes from git status.\\n   183→type FileChanges struct {\\n   184→\\tModified []string // Modified or staged files\\n   185→\\tNew      []string // Untracked files (filtered if previouslyUntracked provided)\\n   186→\\tDeleted  []string // Deleted files (staged or unstaged)\\n   187→}\\n   188→\\n   189→// DetectFileChanges returns categorized file changes from the current git status.\\n   190→//\\n   191→// previouslyUntracked controls new-file detection:\\n   192→//   - nil: all untracked files go into New\\n   193→//   - non-nil: only untracked files NOT in the pre-existing set go into New\\n   194→//\\n   195→// Modified includes both worktree and staging modified/added files.\\n   196→// Deleted includes both staged and unstaged deletions.\\n   197→// All results exclude .entire/ directory.\\n   198→func DetectFileChanges(ctx context.Context, previouslyUntracked []string) (*FileChanges, error) {\\n   199→\\trepo, err := openRepository(ctx)\\n   200→\\tif err != nil {\\n   201→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   202→\\t}\\n   203→\\n   204→\\tworktree, err := repo.Worktree()\\n   205→\\tif err != nil {\\n   206→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   207→\\t}\\n   208→\\n   209→\\tstatus, err := worktree.Status()\\n   210→\\tif err != nil {\\n   211→\\t\\treturn nil, fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n   212→\\t}\\n   213→\\n   214→\\t// Build set of pre-existing untracked files for quick lookup\\n   215→\\tvar preExisting map[string]bool\\n   216→\\tif previouslyUntracked != nil {\\n   217→\\t\\tpreExisting = make(map[string]bool, len(previouslyUntracked))\\n   218→\\t\\tfor _, f := range previouslyUntracked {\\n   219→\\t\\t\\tpreExisting[f] = true\\n   220→\\t\\t}\\n   221→\\t}\\n   222→\\n   223→\\tvar changes FileChanges\\n   224→\\tfor file, st := range status {\\n   225→\\t\\tif paths.IsInfrastructurePath(file) {\\n   226→\\t\\t\\tcontinue\\n   227→\\t\\t}\\n   228→\\n   229→\\t\\tswitch {\\n   230→\\t\\tcase st.Worktree == git.Untracked:\\n   231→\\t\\t\\tif preExisting != nil {\\n   232→\\t\\t\\t\\tif !preExisting[file] {\\n   233→\\t\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   234→\\t\\t\\t\\t}\\n   235→\\t\\t\\t} else {\\n   236→\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   237→\\t\\t\\t}\\n   238→\\t\\tcase st.Worktree == git.Deleted || st.Staging == git.Deleted:\\n   239→\\t\\t\\tchanges.Deleted = append(changes.Deleted, file)\\n   240→\\t\\tcase st.Worktree == git.Modified || st.Staging == git.Modified ||\\n   241→\\t\\t\\tst.Worktree == git.Added || st.Staging == git.Added:\\n   242→\\t\\t\\tchanges.Modified = append(changes.Modified, file)\\n   243→\\t\\t}\\n   244→\\t}\\n   245→\\n   246→\\treturn &changes, nil\\n   247→}\\n   248→\\n   249→// filterToUncommittedFiles removes files from the list that are already committed to HEAD\\n   250→// with matching content. This prevents re-adding files that an agent committed mid-turn\\n   251→// (already condensed by PostCommit) back to FilesTouched via SaveStep. Files not in\\n   252→// HEAD or with different content in the working tree are kept. Fails open: if any git\\n   253→// operation errors, returns the original list unchanged.\\n   254→func filterToUncommittedFiles(ctx context.Context, files []string, repoRoot string) []string {\\n   255→\\tif len(files) == 0 {\\n   256→\\t\\treturn files\\n   257→\\t}\\n   258→\\n   259→\\trepo, err := openRepository(ctx)\\n   260→\\tif err != nil {\\n   261→\\t\\treturn files // fail open\\n   262→\\t}\\n   263→\\n   264→\\thead, err := repo.Head()\\n   265→\\tif err != nil {\\n   266→\\t\\treturn files // fail open (empty repo, detached HEAD, etc.)\\n   267→\\t}\\n   268→\\n   269→\\tcommit, err := repo.CommitObject(head.Hash())\\n   270→\\tif err != nil {\\n   271→\\t\\treturn files // fail open\\n   272→\\t}\\n   273→\\n   274→\\theadTree, err := commit.Tree()\\n   275→\\tif err != nil {\\n   276→\\t\\treturn files // fail open\\n   277→\\t}\\n   278→\\n   279→\\tvar result []string\\n   280→\\tfor _, relPath := range files {\\n   281→\\t\\theadFile, err := headTree.File(relPath)\\n   282→\\t\\tif err != nil {\\n   283→\\t\\t\\t// File not in HEAD — it's uncommitted\\n   284→\\t\\t\\tresult = append(result, relPath)\\n   285→\\t\\t\\tcontinue\\n   286→\\t\\t}\\n   287→\\n   288→\\t\\t// File is in HEAD — compare content with working tree\\n   289→\\t\\tabsPath := filepath.Join(repoRoot, relPath)\\n   290→\\t\\tworkingContent, err := os.ReadFile(absPath) //nolint:gosec // path from controlled source\\n   291→\\t\\tif err != nil {\\n   292→\\t\\t\\t// Can't read working tree file (deleted?) — keep it\\n   293→\\t\\t\\tresult = append(result, relPath)\\n   294→\\t\\t\\tcontinue\\n   295→\\t\\t}\\n   296→\\n   297→\\t\\theadContent, err := headFile.Contents()\\n   298→\\t\\tif err != nil {\\n   299→\\t\\t\\tresult = append(result, relPath)\\n   300→\\t\\t\\tcontinue\\n   301→\\t\\t}\\n   302→\\n   303→\\t\\tif string(wor