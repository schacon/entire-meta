st_rows, lowest_rows = pick_highlight_rows(members)\\\\n    rows = members if max_rows is None else members[:max_rows]\\\\n    for login, activity in rows:\\\\n        lines.append(\\\\n            f\\\\\\\"{login:<30} \\\\\\\"\\\\n            f\\\\\\\"{format_activity_cell(login, activity.last_24h, 8, 'last_24h', highest_rows, lowest_rows)} \\\\\\\"\\\\n            f\\\\\\\"{format_activity_cell(login, activity.last_7d, 8, 'last_7d', highest_rows, lowest_rows)} \\\\\\\"\\\\n            f\\\\\\\"{format_activity_cell(login, activity.last_30d, 8, 'last_30d', highest_rows, lowest_rows)}\\\\\\\"\\\\n        )\\\\n\\\\n    if max_rows is not None and len(members) > max_rows:\\\\n        lines.append(f\\\\\\\"{DIM}... {len(members) - max_rows} more members{RESET}\\\\\\\")\\\\n\\\\n    return lines\\\\n\\\\n\\\\ndef render_live_table(\\\\n    current_repo: str,\\\\n    progress: str,\\\\n    skipped_repos: int,\\\\n    members: list[tuple[str, Activity]],\\\\n    previous_lines: int,\\\\n) -> int:\\\\n    term_lines = shutil.get_terminal_size(fallback=(80, 24)).lines\\\\n    target_lines = max(4, term_lines)\\\\n    available_table_lines = max(2, target_lines - 3)\\\\n    max_member_rows = max(1, available_table_lines - 2)\\\\n    table_lines = build_member_table_lines(members, max_rows=max_member_rows)\\\\n    while len(table_lines) > available_table_lines and max_member_rows > 1:\\\\n        max_member_rows -= 1\\\\n        table_lines = build_member_table_lines(members, max_rows=max_member_rows)\\\\n\\\\n    lines = [\\\\n        f\\\\\\\"Scanning repo: {current_repo}\\\\\\\",\\\\n        f\\\\\\\"Progress: {progress} | skipped: {skipped_repos}\\\\\\\",\\\\n        \\\\\\\"\\\\\\\",\\\\n        *table_lines,\\\\n    ]\\\\n    if len(lines) < target_lines:\\\\n        lines.extend([\\\\\\\"\\\\\\\"] * (target_lines - len(lines)))\\\\n\\\\n    if previous_lines > 0:\\\\n        sys.stderr.write(f\\\\\\\"\\\\\\\\033[{max(1, previous_lines - 1)}F\\\\\\\")\\\\n\\\\n    draw_lines = lines + ([\\\\\\\"\\\\\\\"] * max(0, previous_lines - len(lines)))\\\\n    for index, line in enumerate(draw_lines):\\\\n        sys.stderr.write(\\\\\\\"\\\\\\\\033[2K\\\\\\\")\\\\n        sys.stderr.write(line)\\\\n        if index < len(draw_lines) - 1:\\\\n            sys.stderr.write(\\\\\\\"\\\\\\\\n\\\\\\\")\\\\n\\\\n    sys.stderr.flush()\\\\n    return len(lines)\\\\n\\\\n\\\\ndef wait_for_quit() -> None:\\\\n    while True:\\\\n        try:\\\\n            command = input().strip().lower()\\\\n        except EOFError:\\\\n            return\\\\n        if command == \\\\\\\"q\\\\\\\":\\\\n            return\\\\n\\\\n\\\\ndef main() -> None:\\\\n    args = parse_args()\\\\n    orgs = parse_orgs(args.orgs)\\\\n    workers = max(1, args.workers)\\\\n    show_progress = not args.no_progress\\\\n    all_branches = args.all_branches\\\\n\\\\n    if not orgs:\\\\n        print(\\\\\\\"Error: provide at least one organization name.\\\\\\\", file=sys.stderr)\\\\n        sys.exit(1)\\\\n\\\\n    now = datetime.now(timezone.utc)\\\\n    cutoff_24h = now - timedelta(hours=24)\\\\n    cutoff_7d = now - timedelta(days=7)\\\\n    cutoff_30d = now - timedelta(days=30)\\\\n    combined_stats: dict[str, Activity] = defaultdict(Activity)\\\\n    total_repos_scanned = 0\\\\n    total_repos_skipped = 0\\\\n    processed_orgs: list[str] = []\\\\n    render_live = show_progress and sys.stderr.isatty()\\\\n    live_table_lines = 0\\\\n    known_total_repos = 0\\\\n    processed_total_repos = 0\\\\n\\\\n    for org_index, org in enumerate(orgs, start=1):\\\\n        try:\\\\n            members = fetch_org_members(org)\\\\n        except RuntimeError as exc:\\\\n            print(f\\\\\\\"Error fetching organization members for {org}: {exc}\\\\\\\", file=sys.stderr)\\\\n            continue\\\\n\\\\n        if not members:\\\\n            print(f\\\\\\\"No members found for organization: {org}\\\\\\\")\\\\n            print()\\\\n            continue\\\\n\\\\n        for login in members:\\\\n            combined_stats[login]\\\\n\\\\n        try:\\\\n            repos = fetch_org_repos(org)\\\\n        except RuntimeError as exc:\\\\n            print(\\\\n                f\\\\\\\"Error fetching organization repositories for {org}: {exc}\\\\\\\",\\\\n                file=sys.stderr,\\\\n            )\\\\n            continue\\\\n\\\\n        processed_orgs.append(org)\\\\n        known_total_repos += len(repos)\\\\n\\\\n        stats: dict[str, Activity] = defaultdict(Activity)\\\\n        for login in members:\\\\n            stats[login] = Activity()\\\\n\\\\n        total_repos = len(repos)\\\\n        processed_repos = 0\\\\n        skipped_repos = 0\\\\n\\\\n        if render_live:\\\\n            live_table_lines = render_live_table(\\\\n                f\\\\\\\"{org}/initializing\\\\\\\",\\\\n                f\\\\\\\"{processed_total_repos}/{known_total_repos} repos | org {org_index}/{len(orgs)}\\\\\\\",\\\\n                skipped_repos,\\\\n                sorted_members_by_activity(combined_stats),\\\\n                live_table_lines,\\\\n            )\\\\n\\\\n        with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as executor:\\\\n            future_to_repo = {\\\\n                executor.submit(\\\\n                    fetch_repo_commits_safe,\\\\n                    org,\\\\n                    repo[\\\\\\\"name\\\\\\\"],\\\\n                    cutoff_30d,\\\\n                    all_branches=all_branches,\\\\n                ): repo[\\\\\\\"name\\\\\\\"]\\\\n                for repo in repos\\\\n            }\\\\n\\\\n            heartbeat_frames = [\\\\\\\"|\\\\\\\", \\\\\\\"/\\\\\\\", \\\\\\\"-\\\\\\\", \\\\\\\"\\\\\\\\\\\\\\\\\\\\\\\"]\\\\n            heartbeat_index = 0\\\\n            pending_futures: set[concurrent.futures.Future[tuple[str, list[dict[str, Any]] | None, str | None]]] = set(\\\\n                future_to_repo\\\\n            )\\\\n\\\\n            while pending_futures:\\\\n                done_futures, pending_futures = concurrent.futures.wait(\\\\n                    pending_futures,\\\\n                    timeout=1.0,\\\\n                    return_when=concurrent.futures.FIRST_COMPLETED,\\\\n                )\\\\n\\\\n                if render_live and not done_futures:\\\\n                    frame = heartbeat_frames[heartbeat_index % len(heartbeat_frames)]\\\\n                    heartbeat_index += 1\\\\n                    live_table_lines = render_live_table(\\\\n                        f\\\\\\\"{org}/processing {frame} ({len(pending_futures)} active repos)\\\\\\\",\\\\n                        f\\\\\\\"{processed_total_repos}/{known_total_repos} repos | org {org_index}/{len(orgs)}\\\\\\\",\\\\n                        skipped_repos,\\\\n                        sorted_members_by_activity(combined_stats),\\\\n                        live_table_lines,\\\\n                    )\\\\n                    continue\\\\n\\\\n                for future in done_futures:\\\\n                    processed_repos += 1\\\\n                    processed_total_repos += 1\\\\n                    repo_name, commits, error = future.result()\\\\n\\\\n                    if error is not None:\\\\n                        skipped_repos += 1\\\\n                        if render_live:\\\\n                            live_table_lines = render_live_table(\\\\n                                f\\\\\\\"{org}/{repo_name} (skipped: {error})\\\\\\\",\\\\n                                f\\\\\\\"{processed_total_repos}/{known_total_repos} repos | org {org_index}/{len(orgs)}\\\\\\\",\\\\n                                skipped_repos,\\\\n                                sorted_members_by_activity(combined_stats),\\\\n                                live_table_lines,\\\\n                            )\\\\n                        elif show_progress:\\\\n                            print(\\\\n                                f\\\\\\\"[{org}] [{processed_repos}/{total_repos