\n    75→        case \\\"message.part.updated\\\": {\\n    76→          const part = (event as any).properties?.part\\n    77→          if (!part?.messageID) break\\n    78→\\n    79→          // Fire turn-start on the first text part of a new user message\\n    80→          const msg = messageStore.get(part.messageID)\\n    81→          if (msg?.role === \\\"user\\\" && part.type === \\\"text\\\" && !seenUserMessages.has(msg.id)) {\\n    82→            seenUserMessages.add(msg.id)\\n    83→            const sessionID = msg.sessionID ?? currentSessionID\\n    84→            if (sessionID) {\\n    85→              await callHook(\\\"turn-start\\\", {\\n    86→                session_id: sessionID,\\n    87→                prompt: part.text ?? \\\"\\\",\\n    88→              })\\n    89→            }\\n    90→          }\\n    91→          break\\n    92→        }\\n    93→\\n    94→        case \\\"session.status\\\": {\\n    95→          // session.status fires in both TUI and non-interactive (run) mode.\\n    96→          // session.idle is deprecated and not reliably emitted in run mode.\\n    97→          const props = (event as any).properties\\n    98→          if (props?.status?.type !== \\\"idle\\\") break\\n    99→          const sessionID = props?.sessionID\\n   100→          if (!sessionID) break\\n   101→          // Use sync variant: `opencode run` exits on the same idle event,\\n   102→          // so an async hook would be killed before completing.\\n   103→          callHookSync(\\\"turn-end\\\", {\\n   104→            session_id: sessionID,\\n   105→          })\\n   106→          break\\n   107→        }\\n   108→\\n   109→        case \\\"session.compacted\\\": {\\n   110→          const sessionID = (event as any).properties?.sessionID\\n   111→          if (!sessionID) break\\n   112→          await callHook(\\\"compaction\\\", {\\n   113→            session_id: sessionID,\\n   114→          })\\n   115→          break\\n   116→        }\\n   11