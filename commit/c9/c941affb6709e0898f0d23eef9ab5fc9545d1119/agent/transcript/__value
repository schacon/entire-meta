e hash, the checkpoint\\n    55→// is skipped to avoid duplicate commits (deduplication).\\n    56→func (s *GitStore) WriteTemporary(ctx context.Context, opts WriteTemporaryOptions) (WriteTemporaryResult, error) {\\n    57→\\t// Validate base commit - required for shadow branch naming\\n    58→\\tif opts.BaseCommit == \\\"\\\" {\\n    59→\\t\\treturn WriteTemporaryResult{}, errors.New(\\\"BaseCommit is required for temporary checkpoint\\\")\\n    60→\\t}\\n    61→\\n    62→\\t// Validate session ID to prevent path traversal\\n    63→\\tif err := validation.ValidateSessionID(opts.SessionID); err != nil {\\n    64→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"invalid temporary checkpoint options: %w\\\", err)\\n    65→\\t}\\n    66→\\n    67→\\t// Get shadow branch name\\n    68→\\tshadowBranchName := ShadowBranchNameForCommit(opts.BaseCommit, opts.WorktreeID)\\n    69→\\n    70→\\t// Get or create shadow branch\\n    71→\\tparentHash, baseTreeHash, err := s.getOrCreateShadowBranch(shadowBranchName)\\n    72→\\tif err != nil {\\n    73→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to get shadow branch: %w\\\", err)\\n    74→\\t}\\n    75→\\n    76→\\t// Get the last checkpoint's tree hash for deduplication\\n    77→\\tvar lastTreeHash plumbing.Hash\\n    78→\\tif parentHash != plumbing.ZeroHash {\\n    79→\\t\\tif lastCommit, err := s.repo.CommitObject(parentHash); err == nil {\\n    80→\\t\\t\\tlastTreeHash = lastCommit.TreeHash\\n    81→\\t\\t}\\n    82→\\t}\\n    83→\\n    84→\\t// Collect all files to include\\n    85→\\tvar allFiles []string\\n    86→\\tvar allDeletedFiles []string\\n    87→\\tif opts.IsFirstCheckpoint {\\n    88→\\t\\t// For the first checkpoint, capture all changed files (modified tracked + untracked)\\n    89→\\t\\t// using `git status --porcelain -z` which respects both repo and global .gitignore.\\n    90→\\t\\t// This is much faster than filesystem walk. The base tree from HEAD already contains\\n    91→\\t\\t// all unchanged tracked files. We also capture user's pre-existing deletions.\\n    92→\\t\\tresult, err := collectChangedFiles(ctx, s.repo)\\n    93→\\t\\tif err != nil {\\n    94→\\t\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to collect changed files: %w\\\", err)\\n    95→\\t\\t}\\n    96→\\t\\tallFiles = result.Changed\\n    97→\\t\\t// Merge user's pre-existing deletions with agent's deletions\\n    98→\\t\\tallDeletedFiles = result.Deleted\\n    99→\\t\\tallDeletedFiles = append(allDeletedFiles, opts.DeletedFiles...)\\n   100→\\t} else {\\n   101→\\t\\t// For subsequent checkpoints, only include modified/new files\\n   102→\\t\\tallFiles = make([]string, 0, len(opts.ModifiedFiles)+len(opts.NewFiles))\\n   103→\\t\\tallFiles = append(allFiles, opts.ModifiedFiles...)\\n   104→\\t\\tallFiles = append(allFiles, opts.NewFiles...)\\n   105→\\t\\tallDeletedFiles = opts.DeletedFiles\\n   106→\\t}\\n   107→\\n   108→\\t// Build tree with changes\\n   109→\\ttreeHash, err := s.buildTreeWithChanges(ctx, baseTreeHash, allFiles, allDeletedFiles, opts.MetadataDir, opts.MetadataDirAbs)\\n   110→\\tif err != nil {\\n   111→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n   112→\\t}\\n   113→\\n   114→\\t// Deduplication: skip if tree hash matches the last checkpoint\\n   115→\\tif lastTreeHash != plumbing.ZeroHash && treeHash == lastTreeHash {\\n   116→\\t\\treturn WriteTemporaryResult{\\n   117→\\t\\t\\tCommitHash: parentHash,\\n   118→\\t\\t\\tSkipped:    true,\\n   119→\\t\\t}, nil\\n   120→\\t}\\n   121→\\n   122→\\t// Create checkpoint commit with trailers\\n   123→\\tcommitMsg := trailers.FormatShadowCommit(opts.CommitMessage, opts.MetadataDir, opts.SessionID)\\n   124→\\n   125→\\tcommitHash, err := s.createCommit(treeHash, parentHash, commitMsg, opts.AuthorName, opts.AuthorEmail)\\n   126→\\tif err != nil {\\n   127→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   128→\\t}\\n   129→\\n   130→\\t// Update branch reference\\n   131→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   132→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n   133→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n   134→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to update branch reference: %w\\\", err)\\n   135→\\t}\\n   136→\\n   137→\\treturn WriteTemporaryResult{\\n   138→\\t\\tCommitHash: commitHash,\\n   139→\\t\\tSkipped:    false,\\n   140→\\t}, nil\\n   141→}\\n   142→\\n   143→// ReadTemporary reads the latest checkpoint from a shadow branch.\\n   144→// Returns nil if the shadow branch doesn't exist.\\n   145→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   146→func (s *GitStore) ReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error) {\\n   147→\\t_ = ctx // Reserved for future use\\n   148→\\n   149→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   150→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   151→\\n   152→\\tref, err := s.repo.Reference(refName, true)\\n   153→\\tif err != nil {\\n   154→\\t\\treturn nil, nil //nolint:nilnil,nilerr // Branch not found is an expected case\\n   155→\\t}\\n   156→\\n   157→\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n   158→\\tif err != nil {\\n   159→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   160→\\t}\\n   161→\\n   162→\\t// Extract session ID and metadata dir from commit trailers\\n   163→\\tsessionID, _ := trailers.ParseSession(commit.Message)\\n   164→\\tmetadataDir, _ := trailers.ParseMetadata(commit.Message)\\n   165→\\n   166→\\treturn &ReadTemporaryResult{\\n   167→\\t\\tCommitHash:  ref.Hash(),\\n   168→\\t\\tTreeHash:    commit.TreeHash,\\n   169→\\t\\tSessionID:   sessionID,\\n   170→\\t\\tMetadataDir: metadataDir,\\n   171→\\t\\tTimestamp:   commit.Author.When,\\n   172→\\t}, nil\\n   173→}\\n   174→\\n   175→// ListTemporary lists all shadow branches with their checkpoint info.\\n   176→func (s *GitStore) ListTemporary(ctx context.Context) ([]TemporaryInfo, error) {\\n   177→\\t_ = ctx // Reserved for future use\\n   178→\\n   179→\\titer, err := s.repo.Branches()\\n   180→\\tif err != nil {\\n   181→\\t\\treturn nil, fmt.Errorf(\\\"failed to list branches: %w\\\", err)\\n   182→\\t}\\n   183→\\n   184→\\tvar results []TemporaryInfo\\n   185→\\terr = iter.ForEach(func(ref *plumbing.Reference) error {\\n   186→\\t\\tbranchName := ref.Name().Short()\\n   187→\\t\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n   188→\\t\\t\\treturn nil\\n   189→\\t\\t}\\n   190→\\n   191→\\t\\t// Skip the sessions branch\\n   192→\\t\\tif branchName == paths.MetadataBranchName {\\n   193→\\t\\t\\treturn nil\\n   194→\\t\\t}\\n   195→\\n   196→\\t\\tcommit, commitErr := s.repo.CommitObject(ref.Hash())\\n   197→\\t\\tif commitErr != nil {\\n   198→\\t\\t\\t//nolint:nilerr // Skip branches we can't read (non-fatal)\\n   199→\\t\\t\\treturn nil\\n   200→\\t\\t}\\n   201→\\n   202→\\t\\tsessionID, _ := trailers.ParseSession(commit.Message)\\n   203→\\n   204→\\t\\t// Extract base commit from branch name (handles new \\\"entire/<commit>-<worktreeHash>\\\" format)\\n   205→\\t\\tbaseCommit, _, _ := ParseShadowBranchName(branchName)\\n   206→\\n   207→\\t\\tresults = append(results, TemporaryInfo{\\n   208→\\t\\t\\tBranchName:   branchName,\\n   209→\\t\\t\\tBaseCommit:   baseCommit,\\n   210→\\t\\t\\tLatestCommit: ref.Hash(),\\n   211→\\t\\t\\tSessionID:    sessionID,\\n   212→\\t\\t\\tTimestamp:    commit.Author.When,\\n   213→\\t\\t})\\n   214→\\n   215→\\t\\treturn nil\\n   216→\\t})\\n   217→\\n   218→\\tif err != nil {\\n   219→\\t\\treturn nil, fmt.Errorf(\\\"failed to iterate branches: %w\\\", err)\\n   220→\\t}\\n   221→\\n   222→\\treturn results, nil\\n   223→}\\n   224→\\n   225→// WriteTemporaryTask writes a task checkpoint to a shadow branch.\\n   226→// Task checkpoints include both code changes and task-specific metadata.\\n   227→// Returns the commit hash of the created checkpoint.\\n   228→func (s *GitStore) WriteTemporaryTask(ctx context.Context, opts WriteTemporaryTaskOptions) (plumbing.Hash, error) {\\n   229→\\t// Validate base commit - required for shadow branch naming\\n   230→\\tif opts.BaseCommit == \\\"\\\" {\\n   231→\\t\\treturn plumbing.ZeroHash, errors.New(\\\"BaseCommit is required for task checkpoint\\\")\\n   232→\\t}\\n   233→\\n   234→\\t// Validate identifiers to prevent path traversal and malformed data\\n   235→\\tif err := validation.ValidateSessionID(opts.SessionID); err != nil {\\n   236→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n   237→\\t}\\n   238→\\tif err := validation.ValidateToolUseID(opts.ToolUseID); err != nil {\\n   239→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n   240→\\t}\\n   241→\\tif err := validation.ValidateAgentID(opts.AgentID); err != nil {\\n   242→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n   243→\\t}\\n   244→\\n   245→\\t// Get shadow branch name\\n   246→\\tshadowBranchName := ShadowBranchNameForCommit(opts.BaseCommit, opts.WorktreeID)\\n   247→\\n   248→\\t// Get or create shadow branch\\n   249→\\tparentHash, baseTreeHash, err := s.getOrCreateShadowBranch(shadowBranchName)\\n   250→\\tif err != nil {\\n   251→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get shadow branch: %w\\\", err)\\n   252→\\t}\\n   253→\\n   254→\\t// Collect all files to include in the commit\\n   255→\\tallFiles := make([]string, 0, len(opts.ModifiedFiles)+len(opts.NewFiles))\\n   256→\\tallFiles = append(allFiles, opts.ModifiedFiles...)\\n   257→\\tallFiles = append(allFiles, opts.NewFiles...)\\n   258→\\n   259→\\t// Build new tree with code changes (no metadata dir yet)\\n   260→\\tnewTreeHash, err := s.buildTreeWithChanges(ctx, baseTreeHash, allFiles, opts.DeletedFiles, \\\"\\\", \\\"\\\")\\n   261→\\tif err != nil {\\n   262→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n   263→\\t}\\n   264→\\n   265→\\t// Add task metadata to tree\\n   266→\\tnewTreeHash, err = s.addTaskMetadataToTree(ctx, newTreeHash, opts)\\n   267→\\tif err != nil {\\n   268→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to add task metadata: %w\\\", err)\\n   269→\\t}\\n   270→\\n   271→\\t// Create the commit\\n   272→\\tcommitHash, err := s.createCommit(newTreeHash, parentHash, opts.CommitMessage, opts.AuthorName, opts.AuthorEmail)\\n   273→\\tif err != nil {\\n   274→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   275→\\t}\\n   276→\\n   277→\\t// Update shadow branch reference\\n   278→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   279→\\tref := plumbing.NewHashReference(refName, commitHash)\\n   280→\\tif err := s.repo.Storer.SetReference(ref); err != nil {\\n   281→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to update shadow branch reference: %w\\\", err)\\n   282→\\t}\\n   283→\\n   284→\\treturn commitHash, nil\\n   285→}\\n   286→\\n   287→// addTaskMetadataToTree adds task checkpoint metadata to a git tree.\\n   288→// When IsIncremental is true, only adds the incremental checkpoint file.\\n   289→//\\n   290→// Uses ApplyTreeChanges (tree surgery) instead of FlattenTree+BuildTreeFromEntries,\\n   291→// so only affected subtrees are read/rebuilt.\\n   292→func (s *GitStore) addTaskMetadataToTree(ctx context.Context, baseTreeHash plumbing.Hash, opts WriteTemporaryTaskOptions) (plumbing.Hash, error) {\\n   293→\\t// Compute metadata paths\\n   294→\\tsessionMetadataDir := paths.EntireMetadataDir + \\\"/\\\" + opts.SessionID\\n   295→\\ttaskMetadataDir := sessionMetadataDir + \\\"/tasks/\\\" + opts.ToolUseID\\n   296→\\n   297→\\tvar changes []TreeChange\\n   298→\\n   299→\\tif opts.IsIncremental {\\n   300→\\t\\t// Incremental checkpoint: only add the checkpoint file\\n   301→\\t\\tvar incData []byte\\n   302→\\t\\tvar err error\\n   303→\\t\\tif opts.IncrementalData != nil {\\n   304→\\t\\t\\tincData, err = redact.JSONLBytes(opts.IncrementalData)\\n   305→\\t\\t\\tif err != nil {\\n   306→\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to redact incremental checkpoint: %w\\\", err)\\n   307→\\t\\t\\t}\\n   308→\\t\\t}\\n   309→\\t\\tincrementalCheckpoint := struct {\\n   310→\\t\\t\\tType      string          `json:\\\"type\\\"`\\n   311→\\t\\t\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   312→\\t\\t\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n   313→\\t\\t\\tData      json.RawMessage `json:\\\"data\\\"`\\n   314→\\t\\t}{\\n   315→\\t\\t\\tType:      opts.IncrementalType,\\n   316→\\t\\t\\tToolUseID: opts.ToolUseID,\\n   317→\\t\\t\\tTimestamp: time.Now().UTC(),\\n   318→\\t\\t\\tData:      incData,\\n   319→\\t\\t}\\n   320→\\t\\tcpData, err := jsonutil.MarshalIndentWithNewline(incrementalCheckpoint, \\\"\\\", \\\"  \\\")\\n   321→\\t\\tif err != nil {\\n   322→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to marshal incremental checkpoint: %w\\\", err)\\n   323→\\t\\t}\\n   324→\\n   325→\\t\\tcpBlobHash, err := CreateBlobFromContent(s.repo, cpData)\\n   326→\\t\\tif err != nil {\\n   327→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create incremental checkpoint blob: %w\\\", err)\\n   328→\\t\\t}\\n   329→\\t\\tcpFilename := fmt.Sprintf(\\\"%03d-%s.json\\\", opts.IncrementalSequence, opts.ToolUseID)\\n   330→\\t\\tcpPath := taskMetadataDir + \\\"/checkpoints/\\\" + cpFilename\\n   331→\\t\\tchanges = append(changes, TreeChange{\\n   332→\\t\\t\\tPath:  cpPath,\\n   333→\\t\\t\\tEntry: &object.TreeEntry{Mode: filemode.Regular, Hash: cpBlobHash},\\n   334→\\t\\t})\\n   335→\\t} else {\\n   336→\\t\\t// Final checkpoint: add transcripts and checkpoint.json\\n   337→\\n   338→\\t\\t// Add session transcript (with chunking support for large transcripts)\\n   339→\\t\\tif opts.TranscriptPath != \\\"\\\" {\\n   340→\\t\\t\\tif transcriptContent, readErr := os.ReadFile(opts.TranscriptPath); readErr == nil {\\n   341→\\t\\t\\t\\tagentType := agent.DetectAgentTypeFromContent(transcriptContent)\\n   342→\\n   343→\\t\\t\\t\\t// Chunk if necessary\\n   344→\\t\\t\\t\\tchunks, chunkErr := agent.ChunkTranscript(ctx, transcriptContent, agentType)\\n   345→\\t\\t\\t\\tif chunkErr != nil {\\n   346→\\t\\t\\t\\t\\tlogging.Warn(ctx, \\\"failed to chunk transcript, checkpoint will be saved without transcript\\\",\\n   347→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", chunkErr.Error()),\\n   348→\\t\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n   349→\\t\\t\\t\\t\\t)\\n   350→\\t\\t\\t\\t} else {\\n   351→\\t\\t\\t\\t\\tfor i, chunk := range chunks {\\n   352→\\t\\t\\t\\t\\t\\tchunkPath := sessionMetadataDir + \\\"/\\\" + agent.ChunkFileName(paths.TranscriptFileName, i)\\n   353→\\t\\t\\t\\t\\t\\tblobHash, blobErr := CreateBlobFromContent(s.repo, chunk)\\n   354→\\t\\t\\t\\t\\t\\tif blobErr != nil {\\n   355→\\t\\t\\t\\t\\t\\t\\tlogging.Warn(ctx, \\\"failed to create blob for transcript chunk\\\",\\n   356→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", blobErr.Error()),\\n   357→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n   358→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"chunk_index\\\", i),\\n   359→\\t\\t\\t\\t\\t\\t\\t)\\n   360→\\t\\t\\t\\t\\t\\t\\tcontinue\\n   361→\\t\\t\\t\\t\\t\\t}\\n   362→\\t\\t\\t\\t\\t\\tchanges = append(changes, TreeChange{\\n   363→\\t\\t\\t\\t\\t\\t\\tPath:  chunkPath,\\n   364→\\t\\t\\t\\t\\t\\t\\tEntry: &object.TreeEntry{Mode: filemode.Regular, Hash: blobHash},\\n   365→\\t\\t\\t\\t\\t\\t})\\n   366→\\t\\t\\t\\t\\t}\\n   367→\\t\\t\\t\\t}\\n   368→\\t\\t\\t}\\n   369→\\t\\t}\\n   370→\\n   371→\\t\\t// Add subagent transcript if available\\n   372→\\t\\tif opts.SubagentTranscriptPath != \\\"\\\" && opts.AgentID != \\\"\\\" {\\n   373→\\t\\t\\tif agentContent, readErr := os.ReadFile(opts.SubagentTranscriptPath); readErr == nil {\\n   374→\\t\\t\\t\\tredacted, jsonlErr := redact.JSONLBytes(agentContent)\\n   375→\\t\\t\\t\\tif jsonlErr != nil {\\n   376→\\t\\t\\t\\t\\tlogging.Warn(ctx, \\\"subagent transcript is not valid JSONL, falling back to plain redaction\\\",\\n   377→\\t\\t\\t\\t\\t\\tslog.String(\\\"path\\\", opts.SubagentTranscriptPath),\\n   378→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", jsonlErr.Error()),\\n   379→\\t\\t\\t\\t\\t)\\n   380→\\t\\t\\t\\t\\tredacted = redact.Bytes(agentContent)\\n   381→\\t\\t\\t\\t}\\n   382→\\t\\t\\t\\tagentContent = redacted\\n   383→\\t\\t\\t\\tif blobHash, blobErr := CreateBlobFromContent(s.repo, agentContent); blobErr == nil {\\n   384→\\t\\t\\t\\t\\tagentPath := taskMetadataDir + \\\"/agent-\\\" + opts.AgentID + \\\".jsonl\\\"\\n   385→\\t\\t\\t\\t\\tchanges = append(changes, TreeChange{\\n   386→\\t\\t\\t\\t\\t\\tPath:  agentPath,\\n   387→\\t\\t\\t\\t\\t\\tEntry: &object.TreeEntry{Mode: filemode.Regular, Hash: blobHash},\\n   388→\\t\\t\\t\\t\\t})\\n   389→\\t\\t\\t\\t}\\n   390→\\t\\t\\t}\\n   391→\\t\\t}\\n   392→\\n   393→\\t\\t// Add checkpoint.json\\n   394→\\t\\tcheckpointJSON := fmt.Sprintf(`{\\n   395→  \\\"session_id\\\": %q,\\n   396→  \\\"tool_use_id\\\": %q,\\n   397→  \\\"checkpoint_uuid\\\": %q,\\n   398→  \\\"agent_id\\\": %q\\n   399→}`, opts.SessionID, opts.ToolUseID, opts.CheckpointUUID, opts.AgentID)\\n   400→\\n   401→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(checkpointJSON))\\n   402→\\t\\tif err != nil {\\n   403→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create checkpoint blob: %w\\\", err)\\n   404→\\t\\t}\\n   405→\\t\\tcheckpointPath := taskMetadataDir + \\\"/checkpoint.json\\\"\\n   406→\\t\\tchanges = append(changes, TreeChange{\\n   407→\\t\\t\\tPath:  checkpointPath,\\n   408→\\t\\t\\tEntry: &object.TreeEntry{Mode: filemode.Regular, Hash: blobHash},\\n   409→\\t\\t})\\n   410→\\t}\\n   411→\\n   412→\\treturn ApplyTreeChanges(s.repo, baseTreeHash, changes)\\n   413→}\\n   414→\\n   415→// ListTemporaryCheckpoints lists all checkpoint commits on a shadow branch.\\n   416→// This returns individual commits (rewind points), not just branch info.\\n   417→// The sessionID filter, if provided, limits results to commits from that session.\\n   418→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   419→func (s *GitStore) ListTemporaryCheckpoints(ctx context.Context, baseCommit, worktreeID, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   420→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   421→\\treturn s.listCheckpointsForBranch(ctx, shadowBranchName, sessionID, limit)\\n   422→}\\n   423→\\n   424→// ListCheckpointsForBranch lists checkpoint commits for a shadow branch by name.\\n   425→// Use this when you already have the full branch name (e.g., from ListTemporary).\\n   426→// The sessionID filter, if provided, limits results to commits from that session.\\n   427→func (s *GitStore) ListCheckpointsForBranch(ctx context.Context, branchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   428→\\treturn s.listCheckpointsForBranch(ctx, branchName, sessionID, limit)\\n   429→}\\n   430→\\n   431→// listCheckpointsForBranch lists checkpoint commits for a specific shadow branch name.\\n   432→// This is an internal helper used by ListTemporaryCheckpoints, ListCheckpointsForBranch, and ListAllTemporaryCheckpoints.\\n   433→func (s *GitStore) listCheckpointsForBranch(ctx context.Context, shadowBranchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   434→\\t_ = ctx // Reserved for future use\\n   435→\\n   436→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   437→\\n   438→\\tref, err := s.repo.Reference(refName, true)\\n   439→\\tif err != nil {\\n   440→\\t\\treturn nil, nil //nolint:nilerr // No shadow branch is expected case\\n   441→\\t}\\n   442→\\n   443→\\titer, err := s.repo.Log(&git.LogOptions{From: ref.Hash()})\\n   444→\\tif err != nil {\\n   445→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   446→\\t}\\n   447→\\n   448→\\tvar results []TemporaryCheckpointInfo\\n   449→\\tcount := 0\\n   450→\\n   451→\\terr = iter.ForEach(func(c *object.Commit) error {\\n   452→\\t\\tif count >= limit*5 { // Scan more to allow for session filtering\\n   453→\\t\\t\\treturn errStop\\n   454→\\t\\t}\\n   455→\\t\\tcount++\\n   456→\\n   457→\\t\\t// Verify commit belongs to target session via Entire-Session trailer\\n   458→\\t\\tcommitSessionID, hasTrailer := trailers.ParseSession(c.Message)\\n   459→\\t\\tif !hasTrailer {\\n   460→\\t\\t\\treturn nil // Skip commits without session trailer\\n   461→\\t\\t}\\n   462→\\t\\tif sessionID != \\\"\\\" && commitSessionID != sessionID {\\n   463→\\t\\t\\treturn nil // Skip commits from other sessions\\n   464→\\t\\t}\\n   465→\\n   466→\\t\\t// Get first line of message\\n   467→\\t\\tmessage := c.Message\\n   468→\\t\\tif idx := strings.Index(message, \\\"\\\\n\\\"); idx > 0 {\\n   469→\\t\\t\\tmessage = message[:idx]\\n   470→\\t\\t}\\n   471→\\n   472→\\t\\tinfo := TemporaryCheckpointInfo{\\n   473→\\t\\t\\tCommitHash: c.Hash,\\n   474→\\t\\t\\tMessage:    message,\\n   475→\\t\\t\\tSessionID:  commitSessionID,\\n   476→\\t\\t\\tTimestamp:  c.Author.When,\\n   477→\\t\\t}\\n   478→\\n   479→\\t\\t// Check for task checkpoint first\\n   480→\\t\\ttaskMetadataDir, foundTask := trailers.ParseTaskMetadata(c.Message)\\n   481→\\t\\tif foundTask {\\n   482→\\t\\t\\tinfo.IsTaskCheckpoint = true\\n   483→\\t\\t\\tinfo.MetadataDir = taskMetadataDir\\n   484→\\t\\t\\tinfo.ToolUseID = extractToolUseIDFromPath(taskMetadataDir)\\n   485→\\t\\t} else {\\n   486→\\t\\t\\tmetadataDir, found := trailers.ParseMetadata(c.Message)\\n   487→\\t\\t\\tif found {\\n   488→\\t\\t\\t\\tinfo.MetadataDir = metadataDir\\n   489→\\t\\t\\t}\\n   490→\\t\\t}\\n   491→\\n   492→\\t\\tresults = append(results, info)\\n   493→\\n   494→\\t\\tif len(results) >= limit {\\n   495→\\t\\t\\treturn errStop\\n   496→\\t\\t}\\n   497→\\t\\treturn nil\\n   498→\\t})\\n   499→\\n   500→\\tif err != nil && !errors.Is(err, errStop) {\\n   501→\\t\\treturn nil, fmt.Errorf(\\\"error iterating commits: %w\\\", err)\\n   502→\\t}\\n   503→\\n   504→\\treturn results, nil\\n   505→}\\n   506→\\n   507→// ListAllTemporaryCheckpoints lists checkpoint commits from ALL shadow branches.\\n   508→// This is used for checkpoint lookup when the base commit is unknown (e.g., HEAD advanced since session start).\\n   509→// The sessionID filter, if provided, limits results to commits from that session.\\n   510→func (s *GitStore) ListAllTemporaryCheckpoints(ctx context.Context, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   511→\\t_ = ctx // Reserved for future use\\n   512→\\n   513→\\t// List all shadow branches\\n   514→\\tbranches, err := s.ListTemporary(ctx)\\n   515→\\tif err != nil {\\n   516→\\t\\treturn nil, fmt.Errorf(\\\"failed to list shadow branches: %w\\\", err)\\n   517→\\t}\\n   518→\\n   519→\\tvar results []TemporaryCheckpointInfo\\n   520→\\n   521→\\t// Iterate through each shadow branch and collect checkpoints\\n   522→\\tfor _, branch := range branches {\\n   523→\\t\\t// Use the branch name directly to get checkpoints\\n   524→\\t\\tbranchCheckpoints, branchErr := s.listCheckpointsForBranch(ctx, branch.BranchName, sessionID, limit)\\n   525→\\t\\tif branchErr != nil {\\n   526→\\t\\t\\tcontinue // Skip branches we can't read\\n   527→\\t\\t}\\n   528→\\t\\tresults = append(results, branchCheckpoints...)\\n   529→\\t\\tif len(results) >= limit {\\n   530→\\t\\t\\tresults = results[:limit]\\n   531→\\t\\t\\tbreak\\n   532→\\t\\t}\\n   533→\\t}\\n   534→\\n   535→\\treturn results, nil\\n   536→}\\n   537→\\n   538→// extractToolUseIDFromPath extracts the ToolUseID from a task metadata directory path.\\n   539→// Task metadata dirs have format: .entire/metadata/<session>/tasks/<toolUseID>\\n   540→func extractToolUseIDFromPath(metadataDir string) string {\\n   541→\\tparts := strings.Split(metadataDir, \\\"/\\\")\\n   542→\\tif len(parts) >= 2 && parts[len(parts)-2] == \\\"tasks\\\" {\\n   543→\\t\\treturn parts[len(parts)-1]\\n   544→\\t}\\n   545→\\treturn \\\"\\\"\\n   546→}\\n   547→\\n   548→// errStop is a sentinel error used to break out of git log iteration.\\n   549→var errStop = errors.New(\\\"stop iteration\\\")\\n   550→\\n   551→// GetTranscriptFromCommit retrieves the transcript from a specific commit's tree.\\n   552→// This is used for shadow branch checkpoints where the transcript is stored in the commit tree\\n   553→// rather than on the entire/checkpoints/v1 branch.\\n   554→// commitHash is the commit to read from, metadataDir is the path within the tree.\\n   555→// agentType is used for reassembling chunked transcripts in the correct format.\\n   556→// Handles both chunked and non-chunked transcripts.\\n   557→func (s *GitStore) GetTranscriptFromCommit(ctx context.Context, commitHash plumbing.Hash, metadataDir string, agentType agent.AgentType) ([]byte, error) {\\n   558→\\tcommit, err := s.repo.CommitObject(commitHash)\\n   559→\\tif err != nil {\\n   560→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   561→\\t}\\n   562→\\n   563→\\ttree, err := commit.Tree()\\n   564→\\tif err != nil {\\n   565→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   566→\\t}\\n   567→\\n   568→\\t// Try to get the metadata subtree for chunk detection\\n   569→\\tsubTree, subTreeErr := tree.Tree(metadataDir)\\n   570→\\tif subTreeErr == nil {\\n   571→\\t\\t// Use the helper function that handles chunking\\n   572→\\t\\ttranscript, err := readTranscriptFromTree(ctx, subTree, agentType)\\n   573→\\t\\tif err == nil && transcript != nil {\\n   574→\\t\\t\\treturn transcript, nil\\n   575→\\t\\t}\\n   576→\\t}\\n   577→\\n   578→\\t// Fall back to direct file access (for backwards compatibility)\\n   579→\\ttranscriptPath := metadataDir + \\\"/\\\" + paths.TranscriptFileName\\n   580→\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n   581→\\t\\tcontent, contentErr := file.Contents()\\n   582→\\t\\tif contentErr == nil {\\n   583→\\t\\t\\treturn []byte(content), nil\\n   584→\\t\\t}\\n   585→\\t}\\n   586→\\n   587→\\ttranscriptPath = metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n   588→\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n   589→\\t\\tcontent, contentErr := file.Contents()\\n   590→\\t\\tif contentErr == nil {\\n   591→\\t\\t\\treturn []byte(content), nil\\n   592→\\t\\t}\\n   593→\\t}\\n   594→\\n   595→\\treturn nil, ErrNoTranscript\\n   596→}\\n   597→\\n   598→// ShadowBranchExists checks if a shadow branch exists for the given base commit and worktree.\\n   599→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   600→func (s *GitStore) ShadowBranchExists(baseCommit, worktreeID string) bool {\\n   601→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   602→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   603→\\t_, err := s.repo.Reference(refName, true)\\n   604→\\treturn err == nil\\n   605→}\\n   606→\\n   607→// DeleteShadowBranch deletes the shadow branch for the given base commit and worktree.\\n   608→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   609→// Uses git CLI instead of go-git's RemoveReference because go-git v5 doesn't properly\\n   610→// persist deletions with packed refs or worktrees.\\n   611→func (s *GitStore) DeleteShadowBranch(ctx context.Context, baseCommit, worktreeID string) error {\\n   612→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   613→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", shadowBranchName)\\n   614→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   615→\\t\\treturn fmt.Errorf(\\\"failed to delete shadow branch %s: %s: %w\\\", shadowBranchName, strings.TrimSpace(string(output)), err)\\n   616→\\t}\\n   617→\\treturn nil\\n   618→}\\n   619→\\n   620→// ShadowBranchNameForCommit returns the shadow branch name for a base commit hash\\n   621→// and worktree identifier. The worktree ID should be empty for the main worktree\\n   622→// or the internal git worktree name for linked worktrees.\\n   623→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   624→func ShadowBranchNameForCommit(baseCommit, worktreeID string) string {\\n   625→\\tcommitPart := baseCommit\\n   626→\\tif len(baseCommit) >= ShadowBranchHashLength {\\n   627→\\t\\tcommitPart = baseCommit[:ShadowBranchHashLength]\\n   628→\\t}\\n   629→\\tworktreeHash := HashWorktreeID(worktreeID)\\n   630→\\treturn ShadowBranchPrefix + commitPart + \\\"-\\\" + worktreeHash\\n   631→}\\n   632→\\n   633→// ParseShadowBranchName extracts the commit prefix and worktree hash from a shadow branch name.\\n   634→// Input format: \\\"entire/<commit[:7]>-<worktreeHash[:6]>\\\"\\n   635→// Returns (commitPrefix, worktreeHash, ok). Returns (\\\"\\\", \\\"\\\", false) if not a valid shadow branch.\\n   636→func ParseShadowBranchName(branchName string) (commitPrefix, worktreeHash string, ok bool) {\\n   637→\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n   638→\\t\\treturn \\\"\\\", \\\"\\\", false\\n   639→\\t}\\n   640→\\tsuffix := strings.TrimPrefix(branchName, ShadowBranchPrefix)\\n   641→\\n   642→\\t// Find the last dash - everything before is commit prefix, after is worktree hash\\n   643→\\tlastDash := strings.LastIndex(suffix, \\\"-\\\")\\n   644→\\tif lastDash == -1 || lastDash == 0 || lastDash == len(suffix)-1 {\\n   645→\\t\\t// No dash, or dash at start/end - invalid format\\n   646→\\t\\t// Could be old format \\\"entire/<commit[:7]>\\\" without worktree hash\\n   647→\\t\\treturn suffix, \\\"\\\", true // Return as commit prefix with empty worktree hash\\n   648→\\t}\\n   649→\\n   650→\\treturn suffix[:lastDash], suffix[lastDash+1:], true\\n   651→}\\n   652→\\n   653→// getOrCreateShadowBranch gets or creates the shadow branch for checkpoints.\\n   654→// Returns (parentHash, baseTreeHash, error).\\n   655→func (s *GitStore) getOrCreateShadowBranch(branchName string) (plumbing.Hash, plumbing.Hash, error) {\\n   656→\\trefName := plumbing.NewBranchReferenceName(branchName)\\n   657→\\tref, err := s.repo.Reference(refName, true)\\n   658→\\n   659→\\tif err == nil {\\n   660→\\t\\t// Branch exists\\n   661→\\t\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n   662→\\t\\tif err != nil {\\n   663→\\t\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   664→\\t\\t}\\n   665→\\t\\treturn ref.Hash(), commit.TreeHash, nil\\n   666→\\t}\\n   667→\\n   668→\\t// Branch doesn't exist, use current HEAD's tree as base\\n   669→\\thead, err := s.repo.Head()\\n   670→\\tif err != nil {\\n   671→\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   672→\\t}\\n   673→\\n   674→\\theadCommit, err := s.repo.CommitObject(head.Hash())\\n   675→\\tif err != nil {\\n   676→\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   677→\\t}\\n   678→\\n   679→\\treturn plumbing.ZeroHash, headCommit.TreeHash, nil\\n   680→}\\n   681→\\n   682→// buildTreeWithChanges builds a git tree with the given changes.\\n   683→// metadataDir is the relative path for git tree entries, metadataDirAbs is the absolute path\\n   684→// for filesystem operations (needed when CLI is run from a subdirectory).\\n   685→//\\n   686→// Uses ApplyTreeChanges (tree surgery) instead of FlattenTree+BuildTreeFromEntries,\\n   687→// so only affected subtrees are read/rebuilt — O(changed dirs) instead of O(total files).\\n   688→func (s *GitStore) buildTreeWithChanges(\\n   689→\\tctx context.Context,\\n   690→\\tbaseTreeHash plumbing.Hash,\\n   691→\\tmodifiedFiles, deletedFiles []string,\\n   692→\\tmetadataDir, metadataDirAbs string,\\n   693→) (plumbing.Hash, error) {\\n   694→\\t// Get worktree root for resolving file paths\\n   695→\\t// This is critical because fileExists() and createBlobFromFile() use os.Stat()\\n   696→\\t// which resolves relative to CWD. The modifiedFiles are repo-relative paths,\\n   697→\\t// so we must resolve them against repo root, not CWD.\\n   698→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   699→\\tif err != nil {\\n   700→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   701→\\t}\\n   702→\\n   703→\\t// Build list of tree changes\\n   704→\\tchanges := make([]TreeChange, 0, len(modifiedFiles)+len(deletedFiles))\\n   705→\\n   706→\\t// Deleted files → nil Entry means deletion\\n   707→\\tfor _, file := range deletedFiles {\\n   708→\\t\\tchanges = append(changes, TreeChange{Path: file, Entry: nil})\\n   709→\\t}\\n   710→\\n   711→\\t// Modified/new files → create blobs from disk\\n   712→\\tfor _, file := range modifiedFiles {\\n   713→\\t\\tabsPath := filepath.Join(repoRoot, file)\\n   714→\\t\\tif !fileExists(absPath) {\\n   715→\\t\\t\\t// File disappeared since detection — treat as deletion\\n   716→\\t\\t\\tchanges = append(changes, TreeChange{Path: file, Entry: nil})\\n   717→\\t\\t\\tcontinue\\n   718→\\t\\t}\\n   719→\\n   720→\\t\\tblobHash, mode, blobErr := createBlobFromFile(s.repo, absPath)\\n   721→\\t\\tif blobErr != nil {\\n   722→\\t\\t\\t// Skip files that can't be staged (may have been deleted since detection)\\n   723→\\t\\t\\tcontinue\\n   724→\\t\\t}\\n   725→\\n   726→\\t\\tchanges = append(changes, TreeChange{\\n   727→\\t\\t\\tPath: file,\\n   728→\\t\\t\\tEntry: &object.TreeEntry{\\n   729→\\t\\t\\t\\tMode: mode,\\n   730→\\t\\t\\t\\tHash: blobHash,\\n   731→\\t\\t\\t},\\n   732→\\t\\t})\\n   733→\\t}\\n   734→\\n   735→\\t// Metadata directory files\\n   736→\\tif metadataDir != \\\"\\\" && metadataDirAbs != \\\"\\\" {\\n   737→\\t\\tmetaChanges, metaErr := addDirectoryToChanges(s.repo, metadataDirAbs, metadataDir)\\n   738→\\t\\tif metaErr != nil {\\n   739→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to add metadata directory: %w\\\", metaErr)\\n   740→\\t\\t}\\n   741→\\t\\tchanges = append(changes, metaChanges...)\\n   742→\\t}\\n   743→\\n   744→\\treturn ApplyTreeChanges(s.repo, baseTreeHash, changes)\\n   745→}\\n   746→\\n   747→// createCommit creates a commit object.\\n   748→func (s *GitStore) createCommit(treeHash, parentHash plumbing.Hash, message, authorName, authorEmail string) (plumbing.Hash, error) {\\n   749→\\tnow := time.Now()\\n   750→\\tsig := object.Signature{\\n   751→\\t\\tName:  authorName,\\n   752→\\t\\tEmail: authorEmail,\\n   753→\\t\\tWhen:  now,\\n   754→\\t}\\n   755→\\n   756→\\tcommit := &object.Commit{\\n   757→\\t\\tTreeHash:  treeHash,\\n   758→\\t\\tAuthor:    sig,\\n   759→\\t\\tCommitter: sig,\\n   760→\\t\\tMessage:   message,\\n   761→\\t}\\n   762→\\n   763→\\t// Add parent if not a new branch\\n   764→\\tif parentHash != plumbing.ZeroHash {\\n   765→\\t\\tcommit.ParentHashes = []plumbing.Hash{parentHash}\\n   766→\\t}\\n   767→\\n   768→\\tobj := s.repo.Storer.NewEncodedObject()\\n   769→\\tif err := commit.Encode(obj); err != nil {\\n   770→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n   771→\\t}\\n   772→\\n   773→\\thash, err := s.repo.Storer.SetEncodedObject(obj)\\n   774→\\tif err != nil {\\n   775→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store commit: %w\\\", err)\\n   776→\\t}\\n   777→\\n   778→\\treturn hash, nil\\n   779→}\\n   780→\\n   781→// Helper functions extracted from strategy/common.go\\n   782→// These are exported for use by strategy package (push_common.go, session_test.go)\\n   783→\\n   784→// FlattenTree recursively flattens a tree into a map of full paths to entries.\\n   785→func FlattenTree(repo *git.Repository, tree *object.Tree, prefix string, entries map[string]object.TreeEntry) error {\\n   786→\\tfor _, entry := range tree.Entries {\\n   787→\\t\\tfullPath := entry.Name\\n   788→\\t\\tif prefix != \\\"\\\" {\\n   789→\\t\\t\\tfullPath = prefix + \\\"/\\\" + entry.Name\\n   790→\\t\\t}\\n   791→\\n   792→\\t\\tif entry.Mode == filemode.Dir {\\n   793→\\t\\t\\t// Recurse into subtree\\n   794→\\t\\t\\tsubtree, err := repo.TreeObject(entry.Hash)\\n   795→\\t\\t\\tif err != nil {\\n   796→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to get subtree %s: %w\\\", fullPath, err)\\n   797→\\t\\t\\t}\\n   798→\\t\\t\\tif err := FlattenTree(repo, subtree, fullPath, entries); err != nil {\\n   799→\\t\\t\\t\\treturn err\\n   800→\\t\\t\\t}\\n   801→\\t\\t} else {\\n   802→\\t\\t\\tentries[fullPath] = object.TreeEntry{\\n   803→\\t\\t\\t\\tName: fullPath,\\n   804→\\t\\t\\t\\tMode: entry.Mode,\\n   805→\\t\\t\\t\\tHash: entry.Hash,\\n   806→\\t\\t\\t}\\n   807→\\t\\t}\\n   808→\\t}\\n   809→\\treturn nil\\n   810→}\\n   811→\\n   812→// fileExists checks if a file exists at the given path.\\n   813→func fileExists(path string) bool {\\n   814→\\t_, err := os.Stat(path)\\n   815→\\treturn err == nil\\n   816→}\\n   817→\\n   818→// createBlobFromFile creates a blob object from a file in the working directory.\\n   819→func createBlobFromFile(repo *git.Repository, filePath string) (plumbing.Hash, filemode.FileMode, error) {\\n   820→\\tinfo, err := os.Stat(filePath)\\n   821→\\tif err != nil {\\n   822→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to stat file: %w\\\", err)\\n   823→\\t}\\n   824→\\n   825→\\t// Determine file mode\\n   826→\\tmode :=