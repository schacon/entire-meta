urn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store tree: %w\\\", err)\\n  1060→\\t}\\n  1061→\\n  1062→\\treturn hash, nil\\n  1063→}\\n  1064→\\n  1065→// sortTreeEntries sorts tree entries in git's required order.\\n  1066→// Git sorts tree entries by name, with directories having a trailing /\\n  1067→func sortTreeEntries(entries []object.TreeEntry) {\\n  1068→\\tsort.Slice(entries, func(i, j int) bool {\\n  1069→\\t\\tnameI := entries[i].Name\\n  1070→\\t\\tnameJ := entries[j].Name\\n  1071→\\t\\tif entries[i].Mode == filemode.Dir {\\n  1072→\\t\\t\\tnameI += \\\"/\\\"\\n  1073→\\t\\t}\\n  1074→\\t\\tif entries[j].Mode == filemode.Dir {\\n  1075→\\t\\t\\tnameJ += \\\"/\\\"\\n  1076→\\t\\t}\\n  1077→\\t\\treturn nameI < nameJ\\n  1078→\\t})\\n  1079→}\\n  1080→\\n  1081→// collectChangedFiles collects all changed files (modified tracked + untracked non-ignored)\\n  1082→// using git CLI. This is much faster than filesystem walk and respects all gitignore sources\\n  1083→// including global gitignore (core.excludesfile).\\n  1084→//\\n  1085→// Uses git CLI instead of go-git because go-git's worktree.Status() does not respect\\n  1086→// global gitignore, which can cause globally ignored files to appear as untracked.\\n  1087→// See: https://github.com/entireio/cli/pull/129\\n  1088→//\\n  1089→// changedFilesResult contains both changed and deleted files from git status.\\n  1090→type changedFilesResult struct {\\n  1091→\\tChanged []string // Files to include (modified, added, untracked, renamed, etc.)\\n  1092→\\tDeleted []string // Files that were deleted (need to be excluded from checkpoint tree)\\n  1093→}\\n  1094→\\n  1095→// collectChangedFiles returns all changed files from git status for the first checkpoint.\\n  1096→//\\n  1097→// For the first checkpoint, we need to capture:\\n  1098→// - Modified tracked files (user's uncommitted changes)\\n  1099→// - Untracked non-ignored files (new files not yet added to git)\\n  1100→// - Renamed/copied file