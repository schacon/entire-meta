s claude-code ...\\\")\\n    32→// rather than guessing from directory presence.\\n    33→// Falls back to GetAgent() if not in a hook context.\\n    34→func GetCurrentHookAgent() (agent.Agent, error) {\\n    35→\\tif currentHookAgentName == \\\"\\\" {\\n    36→\\t\\treturn nil, errors.New(\\\"not in a hook context: agent name not set\\\")\\n    37→\\t}\\n    38→\\n    39→\\tag, err := agent.Get(currentHookAgentName)\\n    40→\\tif err != nil {\\n    41→\\t\\treturn nil, fmt.Errorf(\\\"getting hook agent %q: %w\\\", currentHookAgentName, err)\\n    42→\\t}\\n    43→\\treturn ag, nil\\n    44→}\\n    45→\\n    46→// newAgentHooksCmd creates a hooks subcommand for an agent that implements HookSupport.\\n    47→// It dynamically creates subcommands for each hook the agent supports.\\n    48→func newAgentHooksCmd(agentName agent.AgentName, handler agent.HookSupport) *cobra.Command {\\n    49→\\tcmd := &cobra.Command{\\n    50→\\t\\tUse:    string(agentName),\\n    51→\\t\\tShort:  handler.Description() + \\\" hook handlers\\\",\\n    52→\\t\\tHidden: true,\\n    53→\\t\\tPersistentPreRunE: func(cmd *cobra.Command, _ []string) error {\\n    54→\\t\\t\\tagentHookLogCleanup = initHookLogging(cmd.Context())\\n    55→\\t\\t\\treturn nil\\n    56→\\t\\t},\\n    57→\\t\\tPersistentPostRunE: func(_ *cobra.Command, _ []string) error {\\n    58→\\t\\t\\tif agentHookLogCleanup != nil {\\n    59→\\t\\t\\t\\tagentHookLogCleanup()\\n    60→\\t\\t\\t}\\n    61→\\t\\t\\treturn nil\\n    62→\\t\\t},\\n    63→\\t}\\n    64→\\n    65→\\tfor _, hookName := range handler.HookNames() {\\n    66→\\t\\tcmd.AddCommand(newAgentHookVerbCmdWithLogging(agentName, hookName))\\n    67→\\t}\\n    68→\\n    69→\\treturn cmd\\n    70→}\\n    71→\\n    72→// getHookType returns the hook type based on the hook name.\\n    73→// Returns \\\"subagent\\\" for task-related hooks (pre-task, post-task, post-todo),\\n    74→// \\\"tool\\\" for tool-related hooks (before-tool, after-tool),\\n    75→// \\\"agent\\\" for all other agent hooks.\\n    76→func getHookType(hookName string) string {\\n    77→\\tswitch hookName {\\n    78→\\tcase claudecode.HookNamePreTask, claudecode.HookNamePostTask, claudecode.HookNamePostTodo:\\n    79→\\t\\treturn \\\"subagent\\\"\\n    80→\\tcase geminicli.HookNameBeforeTool, geminicli.HookNameAfterTool:\\n    81→\\t\\treturn \\\"tool\\\"\\n    82→\\tdefault:\\n    83→\\t\\treturn \\\"agent\\\"\\n    84→\\t}\\n    85→}\\n    86→\\n    87→// newAgentHookVerbCmdWithLogging creates a command for a specific hook verb with structured logging.\\n    88→// It uses the lifecycle dispatcher (ParseHookEvent → DispatchLifecycleEvent) as the primary path.\\n    89→// PostTodo is handled directly as it's Claude-specific and not part of the lifecycle dispatcher.\\n    90→func newAgentHookVerbCmdWithLogging(agentName agent.AgentName, hookName string) *cobra.Command {\\n    91→\\treturn &cobra.Command{\\n    92→\\t\\tUse:    hookName,\\n    93→\\t\\tHidden: true,\\n    94→\\t\\tShort:  \\\"Called on \\\" + hookName,\\n    95→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    96→\\t\\t\\t// Skip silently if not in a git repository - hooks shouldn't prevent the agent from working\\n    97→\\t\\t\\tif _, err := paths.WorktreeRoot(cmd.Context()); err != nil {\\n    98→\\t\\t\\t\\treturn nil\\n    99→\\t\\t\\t}\\n   100→\\n   101→\\t\\t\\t// Skip if Entire is not enabled\\n   102→\\t\\t\\tenabled, err := IsEnabled(cmd.Context())\\n   103→\\t\\t\\tif err == nil && !enabled {\\n   104→\\t\\t\\t\\treturn nil\\n   105→\\t\\t\\t}\\n   106→\\n   107→\\t\\t\\tstart := time.Now()\\n   108→\\n   109→\\t\\t\\t// Initialize logging context with agent name\\n   110→\\t\\t\\tctx := logging.WithAgent(logging.WithComponent(cmd.Context(), \\\"hooks\\\"), agentName)\\n   111→\\n   112→\\t\\t\\t// Get strategy name for logging\\n   113→\\t\\t\\tstrategyName := GetStrategy(ctx).Name()\\n   114→\\n   115→\\t\\t\\thookType := getHookType(hookName)\\n   116→\\n   117→\\t\\