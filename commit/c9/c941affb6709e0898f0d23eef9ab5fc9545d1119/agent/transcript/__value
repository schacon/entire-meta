}\\n   962→\\t\\tif strings.HasPrefix(relWithinDir, \\\"..\\\") {\\n   963→\\t\\t\\treturn fmt.Errorf(\\\"path traversal detected: %s\\\", relWithinDir)\\n   964→\\t\\t}\\n   965→\\n   966→\\t\\ttreePath := filepath.ToSlash(filepath.Join(dirPathRel, relWithinDir))\\n   967→\\n   968→\\t\\tblobHash, mode, blobErr := createRedactedBlobFromFile(repo, path, treePath)\\n   969→\\t\\tif blobErr != nil {\\n   970→\\t\\t\\treturn fmt.Errorf(\\\"failed to create blob for %s: %w\\\", path, blobErr)\\n   971→\\t\\t}\\n   972→\\t\\tchanges = append(changes, TreeChange{\\n   973→\\t\\t\\tPath:  treePath,\\n   974→\\t\\t\\tEntry: &object.TreeEntry{Mode: mode, Hash: blobHash},\\n   975→\\t\\t})\\n   976→\\t\\treturn nil\\n   977→\\t})\\n   978→\\tif err != nil {\\n   979→\\t\\treturn nil, fmt.Errorf(\\\"failed to walk directory %s: %w\\\", dirPathAbs, err)\\n   980→\\t}\\n   981→\\treturn changes, nil\\n   982→}\\n   983→\\n   984→// BuildTreeFromEntries builds a proper git tree structure from flattened file entries.\\n   985→// Exported for use by strategy package (push_common.go, session_test.go)\\n   986→func BuildTreeFromEntries(repo *git.Repository, entries map[string]object.TreeEntry) (plumbing.Hash, error) {\\n   987→\\t// Build a tree structure\\n   988→\\troot := &treeNode{\\n   989→\\t\\tentries: make(map[string]*treeNode),\\n   990→\\t\\tfiles:   []object.TreeEntry{},\\n   991→\\t}\\n   992→\\n   993→\\t// Insert all entries into the tree structure\\n   994→\\tfor fullPath, entry := range entries {\\n   995→\\t\\tparts := strings.Split(fullPath, \\\"/\\\")\\n   996→\\t\\tinsertIntoTree(root, parts, entry)\\n   997→\\t}\\n   998→\\n   999→\\t// Recursively build tree objects from bottom up\\n  1000→\\treturn buildTreeObject(repo, root)\\n  1001→}\\n  1002→\\n  1003→// insertIntoTree inserts a file entry into the tree structure.\\n  1004→func insertIntoTree(node *treeNode, pathParts []string, entry object.TreeEntry) {\\n  1005→\\tif len(pathParts) == 1 {\\n  1006→\\t\\t//