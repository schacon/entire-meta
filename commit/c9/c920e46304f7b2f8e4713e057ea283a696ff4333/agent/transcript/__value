en if the test is killed by a global timeout,\\n  8247→+\\t// partial output survives.\\n  8248→+\\tartDir := artifactDir(t)\\n  8249→+\\tconsoleLog, err := os.Create(filepath.Join(artDir, \\\"console.log\\\"))\\n  8250→+\\tif err != nil {\\n  8251→+\\t\\tt.Fatalf(\\\"create console.log: %v\\\", err)\\n  8252→+\\t}\\n  8253→+\\n  8254→+\\tstate := &RepoState{\\n  8255→+\\t\\tAgent:            agent,\\n  8256→+\\t\\tDir:              dir,\\n  8257→+\\t\\tArtifactDir:      artDir,\\n  8258→+\\t\\tHeadBefore:       GitOutput(t, dir, \\\"rev-parse\\\", \\\"HEAD\\\"),\\n  8259→+\\t\\tCheckpointBefore: GitOutput(t, dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\"),\\n  8260→+\\t\\tConsoleLog:       consoleLog,\\n  8261→+\\t}\\n  8262→+\\n  8263→+\\tt.Cleanup(func() {\\n  8264→+\\t\\t_ = consoleLog.Close()\\n  8265→+\\t\\tCaptureArtifacts(t, state)\\n  8266→+\\t})\\n  8267→+\\n  8268→+\\treturn state\\n  8269→+}\\n  8270→+\\n  8271→+// ForEachAgent runs fn as a parallel subtest for every registered agent.\\n  8272→+// It handles repo setup, concurrency gating, context timeout, and cleanup.\\n  8273→+// The timeout is scaled by each agent's TimeoutMultiplier.\\n  8274→+func ForEachAgent(t *testing.T, timeout time.Duration, fn func(t *testing.T, s *RepoState, ctx context.Context)) {\\n  8275→+\\tt.Helper()\\n  8276→+\\tt.Parallel()\\n  8277→+\\tfor _, agent := range agents.All() {\\n  8278→+\\t\\tt.Run(agent.Name(), func(t *testing.T) {\\n  8279→+\\t\\t\\ts := SetupRepo(t, agent)\\n  8280→+\\n  8281→+\\t\\t\\t// Use the global test deadline for slot wait so we don't\\n  8282→+\\t\\t\\t// skip prematurely — only bail if the whole binary is dying.\\n  8283→+\\t\\t\\tslotCtx := context.Background()\\n  8284→+\\t\\t\\tif deadline, ok := t.Deadline(); ok {\\n  8285→+\\t\\t\\t\\tvar cancel context.CancelFunc\\n  8286→+\\t\\t\\t\\tslotCtx, cancel = context.WithDeadline(slotCtx, deadline)\\n  8287→+\\t\\t\\t\\tdefer cancel()\\n  8288→+\\t\\t\\t}\\n  8289→+\\t\\t\\tif err := agents.AcquireSlot(slotCtx, agent); err != nil {\\n  8290→+\\t\\t\\t\\tt.Fatalf(\\\"timed out waiting for agent slot: %v\\\", err)\\n  8291→+\\t\\t\\t}\\n  8292→+\\t\\t\\tdefer agents.ReleaseSlot(agent)\\n  8293→+\\n  8294→+\\t\\t\\t// Per-test timeout starts after slot is acquired, scaled\\n  8295→+\\t\\t\\t// by the agent's multiplier (e.g. 2.5× for gemini).\\n  8296→+\\t\\t\\tscaled := time.Duration(float64(timeout) * agent.TimeoutMultiplier())\\n  8297→+\\t\\t\\tctx, cancel := context.WithTimeout(context.Background(), scaled)\\n  8298→+\\t\\t\\tdefer cancel()\\n  8299→+\\t\\t\\tfn(t, s, ctx)\\n  8300→+\\t\\t})\\n  8301→+\\t}\\n  8302→+}\\n  8303→+\\n  8304→+// RunPrompt runs an agent prompt, logs the command and output to ConsoleLog,\\n  8305→+// and returns the result. If the agent reports a transient API error, the\\n  8306→+// prompt is retried once after a short delay. The caller should still check err.\\n  8307→+func (s *RepoState) RunPrompt(t *testing.T, ctx context.Context, prompt string, opts ...agents.Option) (agents.Output, error) {\\n  8308→+\\tt.Helper()\\n  8309→+\\tout, err := s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n  8310→+\\ts.logPromptResult(out)\\n  8311→+\\n  8312→+\\tif err != nil && s.Agent.IsTransientError(out, err) {\\n  8313→+\\t\\tt.Logf(\\\"transient API error detected, retrying in 5s: %v\\\", err)\\n  8314→+\\t\\ts.ConsoleLog.WriteString(\\\"> [retry] transient error, waiting 5s...\\\\n\\\")\\n  8315→+\\t\\tselect {\\n  8316→+\\t\\tcase <-time.After(5 * time.Second):\\n  8317→+\\t\\tcase <-ctx.Done():\\n  8318→+\\t\\t\\treturn out, err\\n  8319→+\\t\\t}\\n  8320→+\\t\\tout, err = s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n  8321→+\\t\\ts.logPromptResult(out)\\n  8322→+\\t}\\n  8323→+\\n  8324→+\\treturn out, err\\n  8325→+}\\n  8326→+\\n  8327→+func (s *RepoState) logPromptResult(out agents.Output) {\\n  8328→+\\ts.ConsoleLog.WriteString(\\\"> \\\" + out.Command + \\\"\\\\n\\\")\\n  8329→+\\ts.ConsoleLog.WriteString(\\\"std