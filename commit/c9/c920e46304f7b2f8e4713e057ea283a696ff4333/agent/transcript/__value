 (\\n  8168→+\\t\\\"context\\\"\\n  8169→+\\t\\\"encoding/json\\\"\\n  8170→+\\t\\\"errors\\\"\\n  8171→+\\t\\\"fmt\\\"\\n  8172→+\\t\\\"os\\\"\\n  8173→+\\t\\\"os/exec\\\"\\n  8174→+\\t\\\"path/filepath\\\"\\n  8175→+\\t\\\"strings\\\"\\n  8176→+\\t\\\"testing\\\"\\n  8177→+\\t\\\"time\\\"\\n  8178→+\\n  8179→+\\t\\\"github.com/entireio/cli/e2e/agents\\\"\\n  8180→+\\t\\\"github.com/entireio/cli/e2e/entire\\\"\\n  8181→+)\\n  8182→+\\n  8183→+// RepoState holds the working state for a single test's cloned repository.\\n  8184→+type RepoState struct {\\n  8185→+\\tAgent            agents.Agent\\n  8186→+\\tDir              string\\n  8187→+\\tArtifactDir      string\\n  8188→+\\tHeadBefore       string\\n  8189→+\\tCheckpointBefore string\\n  8190→+\\tConsoleLog       *os.File\\n  8191→+\\tsession          agents.Session // interactive session, if started via StartSession\\n  8192→+}\\n  8193→+\\n  8194→+// SetupRepo creates a fresh git repository in a temporary directory, seeds it\\n  8195→+// with an initial commit, and runs `entire enable` for the given agent.\\n  8196→+// Artifact capture is registered as a cleanup function.\\n  8197→+//\\n  8198→+// When E2E_KEEP_REPOS is set, the temporary directory is not cleaned up\\n  8199→+// so it can be inspected after the test. A symlink in the artifact dir\\n  8200→+// points to the preserved repo.\\n  8201→+func SetupRepo(t *testing.T, agent agents.Agent) *RepoState {\\n  8202→+\\tt.Helper()\\n  8203→+\\n  8204→+\\tkeepRepos := os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\"\\n  8205→+\\n  8206→+\\t// Always use os.MkdirTemp instead of t.TempDir(). Go's t.TempDir()\\n  8207→+\\t// creates nested subdirectories (TestName.../001/) whose structure\\n  8208→+\\t// confuses some agents' (e.g. opencode) working-directory resolution.\\n  8209→+\\tdir, err := os.MkdirTemp(\\\"\\\", \\\"e2e-repo-*\\\")\\n  8210→+\\tif err != nil {\\n  8211→+\\t\\tt.Fatalf(\\\"create temp dir: %v\\\", err)\\n  8212→+\\t}\\n  8213→+\\tif keepRepos