mpty(t, matches, \\\"expected files matching %s in %s\\\", glob, dir)\\n  7821→+}\\n  7822→+\\n  7823→+// WaitForFileExists polls until at least one file matches the glob pattern\\n  7824→+// relative to dir, or fails the test after timeout. Handles the race where an\\n  7825→+// interactive agent's prompt pattern appears before file writes land on disk.\\n  7826→+func WaitForFileExists(t *testing.T, dir string, glob string, timeout time.Duration) {\\n  7827→+\\tt.Helper()\\n  7828→+\\tpattern := filepath.Join(dir, glob)\\n  7829→+\\tdeadline := time.Now().Add(timeout)\\n  7830→+\\tfor {\\n  7831→+\\t\\tmatches, err := filepath.Glob(pattern)\\n  7832→+\\t\\trequire.NoError(t, err)\\n  7833→+\\t\\tif len(matches) > 0 {\\n  7834→+\\t\\t\\treturn\\n  7835→+\\t\\t}\\n  7836→+\\t\\tif time.Now().After(deadline) {\\n  7837→+\\t\\t\\tt.Fatalf(\\\"expected files matching %s in %s within %s\\\", glob, dir, timeout)\\n  7838→+\\t\\t}\\n  7839→+\\t\\ttime.Sleep(500 * time.Millisecond)\\n  7840→+\\t}\\n  7841→+}\\n  7842→+\\n  7843→+// AssertNewCommits polls until at least `atLeast` new commits exist since setup,\\n  7844→+// or fails after 10 seconds. Polling handles the race where an interactive\\n  7845→+// agent's prompt pattern appears before its git commit lands on disk.\\n  7846→+func AssertNewCommits(t *testing.T, s *RepoState, atLeast int) {\\n  7847→+\\tt.Helper()\\n  7848→+\\tdeadline := time.Now().Add(10 * time.Second)\\n  7849→+\\tfor {\\n  7850→+\\t\\tout := GitOutput(t, s.Dir, \\\"log\\\", \\\"--oneline\\\", s.HeadBefore+\\\"..HEAD\\\")\\n  7851→+\\t\\tvar lines []string\\n  7852→+\\t\\tif out != \\\"\\\" {\\n  7853→+\\t\\t\\tlines = strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\")\\n  7854→+\\t\\t}\\n  7855→+\\t\\tif len(lines) >= atLeast {\\n  7856→+\\t\\t\\treturn\\n  7857→+\\t\\t}\\n  7858→+\\t\\tif time.Now().After(deadline) {\\n  7859→+\\t\\t\\tt.Fatalf(\\\"expected at least %d new commit(s), got %d after 10s\\\", atLeast, len(lines))\\n  7860→+\\t\\t}\\n  7861→+\\t\\ttime.Sleep(500 * time.Millisecond)\\n  7862→+\\t}\\n  7863→+}\\n  7864→+\\n  7865→+// WaitForCheckpoint polls until the checkpoint branch advances from its\\n  7866→+// initial state, or fails the test after timeout. Use this before any\\n  7867→+// assertions that depend on the checkpoint branch (post-commit hook is async).\\n  7868→+func WaitForCheckpoint(t *testing.T, s *RepoState, timeout time.Duration) {\\n  7869→+\\tt.Helper()\\n  7870→+\\tdeadline := time.Now().Add(timeout)\\n  7871→+\\tfor time.Now().Before(deadline) {\\n  7872→+\\t\\tafter := GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n  7873→+\\t\\tif after != s.CheckpointBefore {\\n  7874→+\\t\\t\\treturn\\n  7875→+\\t\\t}\\n  7876→+\\t\\ttime.Sleep(200 * time.Millisecond)\\n  7877→+\\t}\\n  7878→+\\tt.Fatalf(\\\"checkpoint branch did not advance within %s\\\", timeout)\\n  7879→+}\\n  7880→+\\n  7881→+// AssertCheckpointAdvanced asserts the checkpoint branch moved forward.\\n  7882→+func AssertCheckpointAdvanced(t *testing.T, s *RepoState) {\\n  7883→+\\tt.Helper()\\n  7884→+\\tafter := GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n  7885→+\\tassert.NotEqual(t, s.CheckpointBefore, after, \\\"checkpoint branch did not advance\\\")\\n  7886→+}\\n  7887→+\\n  7888→+// AssertCheckpointNotAdvanced asserts the checkpoint branch has NOT moved.\\n  7889→+func AssertCheckpointNotAdvanced(t *testing.T, s *RepoState) {\\n  7890→+\\tt.Helper()\\n  7891→+\\tafter := GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n  7892→+\\tassert.Equal(t, s.CheckpointBefore, after, \\\"checkpoint branch advanced unexpectedly\\\")\\n  7893→+}\\n  7894→+\\n  7895→+// AssertCheckpointIDFormat asserts the checkpoint ID is 12 lowercase hex chars.\\n  7896→+func AssertCheckpointIDFormat(t *testing.T, checkpointID string) {\\n  7897→+\\tt.Helper()\\n  7898→+\\tassert.Regexp(t, hexIDPattern, checkpointID,\\n  7899→+\\t\\t\\\"checkpoint ID %q should