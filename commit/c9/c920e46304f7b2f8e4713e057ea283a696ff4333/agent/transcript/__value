eckpointPath(checkpointID) + \\\"/metadata.json\\\"\\n  7935→+\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n  7936→+\\traw := gitOutputSafe(dir, \\\"show\\\", blob)\\n  7937→+\\tassert.NotEmpty(t, raw,\\n  7938→+\\t\\t\\\"checkpoint %s metadata not found at %s\\\", checkpointID, path)\\n  7939→+}\\n  7940→+\\n  7941→+// AssertCommitLinkedToCheckpoint asserts the trailer exists AND the\\n  7942→+// checkpoint data exists on the checkpoint branch.\\n  7943→+func AssertCommitLinkedToCheckpoint(t *testing.T, dir string, ref string) {\\n  7944→+\\tt.Helper()\\n  7945→+\\ttrailer := AssertHasCheckpointTrailer(t, dir, ref)\\n  7946→+\\tAssertCheckpointExists(t, dir, trailer)\\n  7947→+}\\n  7948→+\\n  7949→+// AssertCheckpointHasSingleSession asserts checkpoint metadata has exactly one session.\\n  7950→+func AssertCheckpointHasSingleSession(t *testing.T, dir string, checkpointID string) {\\n  7951→+\\tt.Helper()\\n  7952→+\\tmeta := ReadCheckpointMetadata(t, dir, checkpointID)\\n  7953→+\\tassert.Len(t, meta.Sessions, 1,\\n  7954→+\\t\\t\\\"expected 1 session in checkpoint %s, got %d\\\", checkpointID, len(meta.Sessions))\\n  7955→+}\\n  7956→+\\n  7957→+// AssertCheckpointMetadataComplete asserts essential fields in checkpoint metadata are populated.\\n  7958→+func AssertCheckpointMetadataComplete(t *testing.T, dir string, checkpointID string) {\\n  7959→+\\tt.Helper()\\n  7960→+\\tmeta := ReadCheckpointMetadata(t, dir, checkpointID)\\n  7961→+\\tassert.NotEmpty(t, meta.CLIVersion, \\\"checkpoint %s: cli_version should be set\\\", checkpointID)\\n  7962→+\\tassert.NotEmpty(t, meta.Strategy, \\\"checkpoint %s: strategy should be set\\\", checkpointID)\\n  7963→+\\tassert.NotEmpty(t, meta.Sessions, \\\"checkpoint %s: should have at least 1 session\\\", checkpointID)\\n  7964→+\\tassert.Equal(t, checkpointID, meta.CheckpointID,\\n  7965→+\\t\\t\\\"checkpoint metadata ID should match expected\\\")\\n  7966→+}\\n  7967→+\\n  7968→+// WaitForCheckpointAdvanceFrom polls un