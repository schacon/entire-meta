Droid JSONL content from a byte slice.\\n    50→// startLine skips the first N raw JSONL lines before parsing (0 = parse all).\\n    51→// This mirrors ParseDroidTranscript's startLine parameter, applying the offset\\n    52→// at the raw line level before filtering out non-message entries.\\n    53→func ParseDroidTranscriptFromBytes(content []byte, startLine int) ([]transcript.Line, error) {\\n    54→\\tlines, _, err := parseDroidTranscriptFromReader(bytes.NewReader(content), startLine)\\n    55→\\treturn lines, err\\n    56→}\\n    57→\\n    58→func parseDroidTranscriptFromReader(r io.Reader, startLine int) ([]transcript.Line, int, error) {\\n    59→\\treader := bufio.NewReader(r)\\n    60→\\tvar lines []transcript.Line\\n    61→\\ttotalLines := 0\\n    62→\\n    63→\\tfor {\\n    64→\\t\\tlineBytes, err := reader.ReadBytes('\\\\n')\\n    65→\\t\\tif err != nil && err != io.EOF {\\n    66→\\t\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    67→\\t\\t}\\n    68→\\n    69→\\t\\tif len(lineBytes) == 0 {\\n    70→\\t\\t\\tif err == io.EOF {\\n    71→\\t\\t\\t\\tbreak\\n    72→\\t\\t\\t}\\n    73→\\t\\t\\tcontinue\\n    74→\\t\\t}\\n    75→\\n    76→\\t\\tif totalLines >= startLine {\\n    77→\\t\\t\\tif line, ok := parseDroidLine(lineBytes); ok {\\n    78→\\t\\t\\t\\tlines = append(lines, line)\\n    79→\\t\\t\\t}\\n    80→\\t\\t}\\n    81→\\t\\ttotalLines++\\n    82→\\n    83→\\t\\tif err == io.EOF {\\n    84→\\t\\t\\tbreak\\n    85→\\t\\t}\\n    86→\\t}\\n    87→\\n    88→\\treturn lines, totalLines, nil\\n    89→}\\n    90→\\n    91→// parseDroidLine converts a single Droid JSONL line into a normalized transcript.Line.\\n    92→// Returns false if the line is not a message entry (e.g., session_start).\\n    93→func parseDroidLine(lineBytes []byte) (transcript.Line, bool) {\\n    94→\\tvar env droidEnvelope\\n    95→\\tif err := json.Unmarshal(lineBytes, &env); err != nil {\\n    96→\\t\\treturn transcript.Line{}, false\\n    97→\\t}\\n    98→\\n    99→\\t// Only process \\\"message\\\" type entries — skip session_start, etc.\\n   100→\\tif env.Type != \\\"message\\\" {\\n   101→\\t\\treturn transcript.Line{}, false\\n   102→\\t}\\n   103→\\n   104→\\t// Extract role from the inner message\\n   105→\\tvar role droidMessageRole\\n   106→\\tif err := json.Unmarshal(env.Message, &role); err != nil {\\n   107→\\t\\treturn transcript.Line{}, false\\n   108→\\t}\\n   109→\\n   110→\\treturn transcript.Line{\\n   111→\\t\\tType:    role.Role, // \\\"assistant\\\" or \\\"user\\\"\\n   112→\\t\\tUUID:    env.ID,\\n   113→\\t\\tMessage: env.Message,\\n   114→\\t}, true\\n   115→}\\n   116→\\n   117→// SerializeTranscript converts transcript lines back to JSONL bytes.\\n   118→func SerializeTranscript(lines []TranscriptLine) ([]byte, error) {\\n   119→\\tvar buf bytes.Buffer\\n   120→\\tfor _, line := range lines {\\n   121→\\t\\tdata, err := json.Marshal(line)\\n   122→\\t\\tif err != nil {\\n   123→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal line: %w\\\", err)\\n   124→\\t\\t}\\n   125→\\t\\tbuf.Write(data)\\n   126→\\t\\tbuf.WriteByte('\\\\n')\\n   127→\\t}\\n   128→\\treturn buf.Bytes(), nil\\n   129→}\\n   130→\\n   131→// ExtractModifiedFiles extracts files modified by tool calls from transcript.\\n   132→func ExtractModifiedFiles(lines []TranscriptLine) []string {\\n   133→\\tfileSet := make(map[string]bool)\\n   134→\\tvar files []string\\n   135→\\n   136→\\tfor _, line := range lines {\\n   137→\\t\\tif line.Type != \\\"assistant\\\" {\\n   138→\\t\\t\\tcontinue\\n   139→\\t\\t}\\n   140→\\n   141→\\t\\tvar msg transcript.AssistantMessage\\n   142→\\t\\tif err := json.Unmarshal(line.Message, &msg); err != nil {\\n   143→\\t\\t\\tcontinue\\n   144→\\t\\t}\\n   145→\\n   146→\\t\\tfor _, block := range msg.Content {\\n   147→\\t\\t\\tif block.Type != \\\"tool_use\\\" || !slices.Contains(FileModificationTools, block.Name) {\\n   148→\\t\\t\\t\\tcontinue\\n   149→\\t\\t\\t}\\n   150→\\n   1