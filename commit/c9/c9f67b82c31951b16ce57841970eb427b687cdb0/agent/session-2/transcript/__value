\\n   301→\\t\\treturn \\\"\\\"\\n   302→\\t}\\n   303→\\n   304→\\t// Extract the ID (alphanumeric characters after the prefix)\\n   305→\\tstart := idx + len(prefix)\\n   306→\\tend := start\\n   307→\\tfor end < len(text) && (text[end] >= 'a' && text[end] <= 'z' ||\\n   308→\\t\\ttext[end] >= 'A' && text[end] <= 'Z' ||\\n   309→\\t\\ttext[end] >= '0' && text[end] <= '9') {\\n   310→\\t\\tend++\\n   311→\\t}\\n   312→\\n   313→\\tif end > start {\\n   314→\\t\\treturn text[start:end]\\n   315→\\t}\\n   316→\\treturn \\\"\\\"\\n   317→}\\n   318→\\n   319→// CalculateTotalTokenUsageFromTranscript calculates token usage for a turn, including subagents.\\n   320→// It parses the main transcript from startLine, extracts spawned agent IDs,\\n   321→// and calculates their token usage from transcripts in subagentsDir.\\n   322→func CalculateTotalTokenUsageFromTranscript(transcriptPath string, startLine int, subagentsDir string) (*agent.TokenUsage, error) {\\n   323→\\tif transcriptPath == \\\"\\\" {\\n   324→\\t\\treturn &agent.TokenUsage{}, nil\\n   325→\\t}\\n   326→\\n   327→\\t// Parse transcript once using Droid-specific parser\\n   328→\\tparsed, _, err := ParseDroidTranscript(transcriptPath, startLine)\\n   329→\\tif err != nil {\\n   330→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   331→\\t}\\n   332→\\n   333→\\t// Calculate token usage from parsed transcript\\n   334→\\tmainUsage := CalculateTokenUsage(parsed)\\n   335→\\n   336→\\t// Extract spawned agent IDs from the same parsed transcript\\n   337→\\tagentIDs := ExtractSpawnedAgentIDs(parsed)\\n   338→\\n   339→\\t// Calculate subagent token usage\\n   340→\\tif len(agentIDs) > 0 {\\n   341→\\t\\tsubagentUsage := &agent.TokenUsage{}\\n   342→\\t\\tfor agentID := range agentIDs {\\n   343→\\t\\t\\tagentPath := filepath.Join(subagentsDir, fmt.Sprintf(\\\"agent-%s.jsonl\\\", agentID))\\n   344→\\t\\t\\tagentUsage, err := CalculateTokenUsageFromFile(agentPath, 0)\\n   345→\\t\\t