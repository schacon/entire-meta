ipt only)\\n   382→\\t\\tusage, tokenErr := calculator.CalculateTokenUsage(transcriptRef, transcriptLinesAtStart)\\n   383→\\t\\tif tokenErr != nil {\\n   384→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage: %v\\\\n\\\", tokenErr)\\n   385→\\t\\t} else {\\n   386→\\t\\t\\ttokenUsage = usage\\n   387→\\t\\t}\\n   388→\\t}\\n   389→\\n   390→\\t// Build fully-populated step context and delegate to strategy\\n   391→\\tctx := strategy.StepContext{\\n   392→\\t\\tSessionID:                sessionID,\\n   393→\\t\\tModifiedFiles:            relModifiedFiles,\\n   394→\\t\\tNewFiles:                 relNewFiles,\\n   395→\\t\\tDeletedFiles:             relDeletedFiles,\\n   396→\\t\\tMetadataDir:              sessionDir,\\n   397→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   398→\\t\\tCommitMessage:            commitMessage,\\n   399→\\t\\tTranscriptPath:           transcriptRef,\\n   400→\\t\\tAuthorName:               author.Name,\\n   401→\\t\\tAuthorEmail:              author.Email,\\n   402→\\t\\tAgentType:                agentType,\\n   403→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   404→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   405→\\t\\tTokenUsage:               tokenUsage,\\n   406→\\t}\\n   407→\\n   408→\\tif err := strat.SaveStep(ctx); err != nil {\\n   409→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   410→\\t}\\n   411→\\n   412→\\t// Update session state transcript position for auto-commit strategy\\n   413→\\tif strat.Name() == strategy.StrategyNameAutoCommit && newTranscriptPosition > 0 {\\n   414→\\t\\tupdateAutoCommitTranscriptPosition(sessionID, newTranscriptPosition)\\n   415→\\t}\\n   416→\\n   417→\\t// Transition session phase and cleanup\\n   418→\\ttransitionSessionTurnEnd(sessionID)\\n   419→\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n   420→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   421→\\t}\\n   422→\\n   423→\\treturn nil\\n   424→}\\n   425→\\n   426→// handleLifecycleCompaction handles context compaction: saves current progress\\n   427→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   428→// Also resets the transcript offset since the transcript may be truncated.\\n   429→func handleLifecycleCompaction(ag agent.Agent, event *agent.Event) error {\\n   430→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   431→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   432→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   433→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   434→\\t)\\n   435→\\n   436→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   437→\\tsessionID := event.SessionID\\n   438→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   439→\\tif loadErr != nil {\\n   440→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for compaction: %v\\\\n\\\", loadErr)\\n   441→\\t}\\n   442→\\tif sessionState != nil {\\n   443→\\t\\tif transErr := strategy.TransitionAndLog(sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   444→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: compaction transition failed: %v\\\\n\\\", transErr)\\n   445→\\t\\t}\\n   446→\\n   447→\\t\\t// Reset transcript offset since the transcript may be truncated/reorganized\\n   448→\\t\\tsessionState.CheckpointTranscriptStart = 0\\n   449→\\n   450→\\t\\tif saveErr := strategy.SaveSessionState(sessionState); saveErr != nil {\\n   451→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to save session state after compaction: %v\\\\n\\\", saveErr)\\n   452→\\t\\t}\\n   453→\\t}\\n   454→\\n   455→\\tfmt.Fprintf(os.Stderr, \\\"Context compaction: transcript offset reset\\\\n\\\")\\n   456→\\treturn nil\\n  