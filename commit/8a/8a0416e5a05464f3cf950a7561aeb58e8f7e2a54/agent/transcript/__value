treturn checkpoint.ShadowBranchNameForCommit(headHash, worktreeID)\\n   571→}\\n   572→\\n   573→// GetShadowBranchNameForCommit returns the worktree-specific shadow branch name for a given commit.\\n   574→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   575→func (env *TestEnv) GetShadowBranchNameForCommit(commitHash string) string {\\n   576→\\tenv.T.Helper()\\n   577→\\n   578→\\tworktreeID, err := paths.GetWorktreeID(env.RepoDir)\\n   579→\\tif err != nil {\\n   580→\\t\\tenv.T.Fatalf(\\\"failed to get worktree ID: %v\\\", err)\\n   581→\\t}\\n   582→\\treturn checkpoint.ShadowBranchNameForCommit(commitHash, worktreeID)\\n   583→}\\n   584→\\n   585→// GetGitLog returns a list of commit hashes from HEAD.\\n   586→func (env *TestEnv) GetGitLog() []string {\\n   587→\\tenv.T.Helper()\\n   588→\\n   589→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   590→\\tif err != nil {\\n   591→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   592→\\t}\\n   593→\\n   594→\\thead, err := repo.Head()\\n   595→\\tif err != nil {\\n   596→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   597→\\t}\\n   598→\\n   599→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   600→\\tif err != nil {\\n   601→\\t\\tenv.T.Fatalf(\\\"failed to get log: %v\\\", err)\\n   602→\\t}\\n   603→\\n   604→\\tvar commits []string\\n   605→\\terr = commitIter.ForEach(func(c *object.Commit) error {\\n   606→\\t\\tcommits = append(commits, c.Hash.String())\\n   607→\\t\\treturn nil\\n   608→\\t})\\n   609→\\tif err != nil {\\n   610→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   611→\\t}\\n   612→\\n   613→\\treturn commits\\n   614→}\\n   615→\\n   616→// GitCheckoutNewBranch creates and checks out a new branch.\\n   617→// Uses git CLI instead of go-git to work around go-git v5 bug where Checkout\\n   618→// deletes untracked files (see https://github.com/go-git/go-git/issues/970).\\n   619→func (env *TestEnv) GitCheckoutNewBranch(branchName string) {\\n   620→\\tenv.T.Helper()\\n   621→\\n   622→\\tcmd := exec.Command(\\\"git\\\", \\\"checkout\\\", \\\"-b\\\", branchName)\\n   623→\\tcmd.Dir = env.RepoDir\\n   624→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   625→\\t\\tenv.T.Fatalf(\\\"failed to checkout new branch %s: %v\\\\nOutput: %s\\\", branchName, err, output)\\n   626→\\t}\\n   627→}\\n   628→\\n   629→// GetCurrentBranch returns the current branch name.\\n   630→func (env *TestEnv) GetCurrentBranch() string {\\n   631→\\tenv.T.Helper()\\n   632→\\n   633→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   634→\\tif err != nil {\\n   635→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   636→\\t}\\n   637→\\n   638→\\thead, err := repo.Head()\\n   639→\\tif err != nil {\\n   640→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   641→\\t}\\n   642→\\n   643→\\tif !head.Name().IsBranch() {\\n   644→\\t\\treturn \\\"\\\" // Detached HEAD\\n   645→\\t}\\n   646→\\n   647→\\treturn head.Name().Short()\\n   648→}\\n   649→\\n   650→// RewindPoint mirrors strategy.RewindPoint for test assertions.\\n   651→type RewindPoint struct {\\n   652→\\tID               string\\n   653→\\tMessage          string\\n   654→\\tMetadataDir      string\\n   655→\\tDate             time.Time\\n   656→\\tIsTaskCheckpoint bool\\n   657→\\tToolUseID        string\\n   658→\\tIsLogsOnly       bool\\n   659→\\tCondensationID   string\\n   660→}\\n   661→\\n   662→// GetRewindPoints returns available rewind points using the CLI.\\n   663→func (env *TestEnv) GetRewindPoints() []RewindPoint {\\n   664→\\tenv.T.Helper()\\n   665→\\n   666→\\t// Run rewind --list using the shared binary\\n   667→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--list\\\")\\n   668→\\tcmd.Dir = env.RepoDir\\n   669→\\tcmd.Env = env.cliEnv()\\n   670→\\n   671→\\toutput, err := cmd.CombinedOutput()\\n   672→\\tif err != nil {\\n   673→\\t\\tenv.T.Fatalf(\\\"rewind --list failed: %v\\\\nOutput: %s\\\", err, output)\\n   674→\\t}\\n   675→\\n   676→\\t// Parse JSON output\\n   677→\\tvar jsonPoints []struct {\\n   678→\\t\\tID               string `json:\\\"id\\\"`\\n   679→\\t\\tMessage          string `json:\\\"message\\\"`\\n   680→\\t\\tMetadataDir      string `json:\\\"metadata_dir\\\"`\\n   681→\\t\\tDate             string `json:\\\"date\\\"`\\n   682→\\t\\tIsTaskCheckpoint bool   `json:\\\"is_task_checkpoint\\\"`\\n   683→\\t\\tToolUseID        string `json:\\\"tool_use_id\\\"`\\n   684→\\t\\tIsLogsOnly       bool   `json:\\\"is_logs_only\\\"`\\n   685→\\t\\tCondensationID   string `json:\\\"condensation_id\\\"`\\n   686→\\t}\\n   687→\\n   688→\\tif err := json.Unmarshal(output, &jsonPoints); err != nil {\\n   689→\\t\\tenv.T.Fatalf(\\\"failed to parse rewind points: %v\\\\nOutput: %s\\\", err, output)\\n   690→\\t}\\n   691→\\n   692→\\tpoints := make([]RewindPoint, len(jsonPoints))\\n   693→\\tfor i, jp := range jsonPoints {\\n   694→\\t\\tdate, _ := time.Parse(time.RFC3339, jp.Date)\\n   695→\\t\\tpoints[i] = RewindPoint{\\n   696→\\t\\t\\tID:               jp.ID,\\n   697→\\t\\t\\tMessage:          jp.Message,\\n   698→\\t\\t\\tMetadataDir:      jp.MetadataDir,\\n   699→\\t\\t\\tDate:             date,\\n   700→\\t\\t\\tIsTaskCheckpoint: jp.IsTaskCheckpoint,\\n   701→\\t\\t\\tToolUseID:        jp.ToolUseID,\\n   702→\\t\\t\\tIsLogsOnly:       jp.IsLogsOnly,\\n   703→\\t\\t\\tCondensationID:   jp.CondensationID,\\n   704→\\t\\t}\\n   705→\\t}\\n   706→\\n   707→\\treturn points\\n   708→}\\n   709→\\n   710→// Rewind performs a rewind to the specified commit ID using the CLI.\\n   711→func (env *TestEnv) Rewind(commitID string) error {\\n   712→\\tenv.T.Helper()\\n   713→\\n   714→\\t// Run rewind --to <commitID> using the shared binary\\n   715→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID)\\n   716→\\tcmd.Dir = env.RepoDir\\n   717→\\tcmd.Env = env.cliEnv()\\n   718→\\n   719→\\toutput, err := cmd.CombinedOutput()\\n   720→\\tif err != nil {\\n   721→\\t\\treturn errors.New(\\\"rewind failed: \\\" + string(output))\\n   722→\\t}\\n   723→\\n   724→\\tenv.T.Logf(\\\"Rewind output: %s\\\", output)\\n   725→\\treturn nil\\n   726→}\\n   727→\\n   728→// RewindLogsOnly performs a logs-only rewind using the CLI.\\n   729→// This restores session logs without modifying the working directory.\\n   730→func (env *TestEnv) RewindLogsOnly(commitID string) error {\\n   731→\\tenv.T.Helper()\\n   732→\\n   733→\\t// Run rewind --to <commitID> --logs-only using the shared binary\\n   734→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID, \\\"--logs-only\\\")\\n   735→\\tcmd.Dir = env.RepoDir\\n   736→\\tcmd.Env = env.cliEnv()\\n   737→\\n   738→\\toutput, err := cmd.CombinedOutput()\\n   739→\\tif err != nil {\\n   740→\\t\\treturn errors.New(\\\"rewind logs-only failed: \\\" + string(output))\\n   741→\\t}\\n   742→\\n   743→\\tenv.T.Logf(\\\"Rewind logs-only output: %s\\\", output)\\n   744→\\treturn nil\\n   745→}\\n   746→\\n   747→// RewindReset performs a reset rewind using the CLI.\\n   748→// This resets the branch to the specified commit (destructive).\\n   749→func (env *TestEnv) RewindReset(commitID string) error {\\n   750→\\tenv.T.Helper()\\n   751→\\n   752→\\t// Run rewind --to <commitID> --reset using the shared binary\\n   753→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID, \\\"--reset\\\")\\n   754→\\tcmd.Dir = env.RepoDir\\n   755→\\tcmd.Env = env.cliEnv()\\n   756→\\n   757→\\toutput, err := cmd.CombinedOutput()\\n   758→\\tif err != nil {\\n   759→\\t\\treturn errors.New(\\\"rewind reset failed: \\\" + string(output))\\n   760→\\t}\\n   761→\\n   762→\\tenv.T.Logf(\\\"Rewind reset output: %s\\\", output)\\n   763→\\treturn nil\\n   764→}\\n   765→\\n   766→// BranchExists checks if a branch exists in the repository.\\n   767→func (env *TestEnv) BranchExists(branchName string) bool {\\n   768→\\tenv.T.Helper()\\n   769→\\n   770→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   771→\\tif err != nil {\\n   772→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   773→\\t}\\n   774→\\n   775→\\trefs, err := repo.References()\\n   776→\\tif err != nil {\\n   777→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   778→\\t}\\n   779→\\n   780→\\tfound := false\\n   781→\\t_ = refs.ForEach(func(ref *plumbing.Reference) error {\\n   782→\\t\\tif ref.Name().Short() == branchName {\\n   783→\\t\\t\\tfound = true\\n   784→\\t\\t}\\n   785→\\t\\treturn nil\\n   786→\\t})\\n   787→\\n   788→\\treturn found\\n   789→}\\n   790→\\n   791→// GetCommitMessage returns the commit message for the given commit hash.\\n   792→func (env *TestEnv) GetCommitMessage(hash string) string {\\n   793→\\tenv.T.Helper()\\n   794→\\n   795→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   796→\\tif err != nil {\\n   797→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   798→\\t}\\n   799→\\n   800→\\tcommitHash := plumbing.NewHash(hash)\\n   801→\\tcommit, err := repo.CommitObject(commitHash)\\n   802→\\tif err != nil {\\n   803→\\t\\tenv.T.Fatalf(\\\"failed to get commit %s: %v\\\", hash, err)\\n   804→\\t}\\n   805→\\n   806→\\treturn commit.Message\\n   807→}\\n   808→\\n   809→// FileExistsInBranch checks if a file exists in a specific branch's tree.\\n   810→func (env *TestEnv) FileExistsInBranch(branchName, filePath string) bool {\\n   811→\\tenv.T.Helper()\\n   812→\\n   813→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   814→\\tif err != nil {\\n   815→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   816→\\t}\\n   817→\\n   818→\\t// Get the branch reference\\n   819→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   820→\\tif err != nil {\\n   821→\\t\\t// Try as a remote-style ref\\n   822→\\t\\tref, err = repo.Reference(plumbing.ReferenceName(\\\"refs/heads/\\\"+branchName), true)\\n   823→\\t\\tif err != nil {\\n   824→\\t\\t\\treturn false\\n   825→\\t\\t}\\n   826→\\t}\\n   827→\\n   828→\\t// Get the commit\\n   829→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   830→\\tif err != nil {\\n   831→\\t\\treturn false\\n   832→\\t}\\n   833→\\n   834→\\t// Get the tree\\n   835→\\ttree, err := commit.Tree()\\n   836→\\tif err != nil {\\n   837→\\t\\treturn false\\n   838→\\t}\\n   839→\\n   840→\\t// Check if file exists\\n   841→\\t_, err = tree.File(filePath)\\n   842→\\treturn err == nil\\n   843→}\\n   844→\\n   845→// ReadFileFromBranch reads a file's content from a specific branch's tree.\\n   846→// Returns the content and true if found, empty string and false if not found.\\n   847→func (env *TestEnv) ReadFileFromBranch(branchName, filePath string) (string, bool) {\\n   848→\\tenv.T.Helper()\\n   849→\\n   850→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   851→\\tif err != nil {\\n   852→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   853→\\t}\\n   854→\\n   855→\\t// Get the branch reference\\n   856→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   857→\\tif err != nil {\\n   858→\\t\\t// Try as a remote-style ref\\n   859→\\t\\tref, err = repo.Reference(plumbing.ReferenceName(\\\"refs/heads/\\\"+branchName), true)\\n   860→\\t\\tif err != nil {\\n   861→\\t\\t\\treturn \\\"\\\", false\\n   862→\\t\\t}\\n   863→\\t}\\n   864→\\n   865→\\t// Get the commit\\n   866→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   867→\\tif err != nil {\\n   868→\\t\\treturn \\\"\\\", false\\n   869→\\t}\\n   870→\\n   871→\\t// Get the tree\\n   872→\\ttree, err := commit.Tree()\\n   873→\\tif err != nil {\\n   874→\\t\\treturn \\\"\\\", false\\n   875→\\t}\\n   876→\\n   877→\\t// Get the file\\n   878→\\tfile, err := tree.File(filePath)\\n   879→\\tif err != nil {\\n   880→\\t\\treturn \\\"\\\", false\\n   881→\\t}\\n   882→\\n   883→\\t// Get the content\\n   884→\\tcontent, err := file.Contents()\\n   885→\\tif err != nil {\\n   886→\\t\\treturn \\\"\\\", false\\n   887→\\t}\\n   888→\\n   889→\\treturn content, true\\n   890→}\\n   891→\\n   892→// GetLatestCommitMessageOnBranch returns the commit message of the latest commit on the given branch.\\n   893→func (env *TestEnv) GetLatestCommitMessageOnBranch(branchName string) string {\\n   894→\\tenv.T.Helper()\\n   895→\\n   896→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   897→\\tif err != nil {\\n   898→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   899→\\t}\\n   900→\\n   901→\\t// Get the branch reference\\n   902→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   903→\\tif err != nil {\\n   904→\\t\\tenv.T.Fatalf(\\\"failed to get branch %s reference: %v\\\", branchName, err)\\n   905→\\t}\\n   906→\\n   907→\\t// Get the commit\\n   908→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   909→\\tif err != nil {\\n   910→\\t\\tenv.T.Fatalf(\\\"failed to get commit object: %v\\\", err)\\n   911→\\t}\\n   912→\\n   913→\\treturn commit.Message\\n   914→}\\n   915→\\n   916→// GitCommitWithShadowHooks stages and commits files, simulating the prepare-commit-msg\\n   917→// and post-commit hooks as a human (with TTY). This is the default for tests.\\n   918→func (env *TestEnv) GitCommitWithShadowHooks(message string, files ...string) {\\n   919→\\tenv.T.Helper()\\n   920→\\tenv.gitCommitWithShadowHooks(message, true, files...)\\n   921→}\\n   922→\\n   923→// GitCommitWithShadowHooksAsAgent is like GitCommitWithShadowHooks but simulates\\n   924→// an agent commit (no TTY). This triggers the fast path in PrepareCommitMsg that\\n   925→// skips content detection and interactive prompts for ACTIVE sessions.\\n   926→func (env *TestEnv) GitCommitWithShadowHooksAsAgent(message string, files ...string) {\\n   927→\\tenv.T.Helper()\\n   928→\\tenv.gitCommitWithShadowHooks(message, false, files...)\\n   929→}\\n   930→\\n   931→// gitCommitWithShadowHooks is the shared implementation for committing with shadow hooks.\\n   932→// When simulateTTY is true, sets ENTIRE_TEST_TTY=1 to simulate a human at the terminal.\\n   933→// When false, filters it out to simulate an agent subprocess (no controlling terminal).\\n   934→func (env *TestEnv) gitCommitWithShadowHooks(message string, simulateTTY bool, files ...string) {\\n   935→\\tenv.T.Helper()\\n   936→\\n   937→\\t// Stage files using go-git\\n   938→\\tfor _, file := range files {\\n   939→\\t\\tenv.GitAdd(file)\\n   940→\\t}\\n   941→\\n   942→\\t// Create a temp file for the commit message (prepare-commit-msg hook modifies this)\\n   943→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n   944→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n   945→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n   946→\\t}\\n   947→\\n   948→\\t// Run prepare-commit-msg hook using the shared binary.\\n   949→\\t// Pass source=\\\"message\\\" to match real `git commit -m` behavior.\\n   950→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile, \\\"message\\\")\\n   951→\\tprepCmd.Dir = env.RepoDir\\n   952→\\tif simulateTTY {\\n   953→\\t\\t// Simulate human at terminal: ENTIRE_TEST_TTY=1 makes hasTTY() return true\\n   954→\\t\\t// and askConfirmTTY() return defaultYes without reading from /dev/tty.\\n   955→\\t\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n   956→\\t} else {\\n   957→\\t\\t// Simulate agent: ENTIRE_TEST_TTY=0 makes hasTTY() return false,\\n   958→\\t\\t// triggering the fast path that adds trailers for ACTIVE sessions.\\n   959→\\t\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   960→\\t}\\n   961→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n   962→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n   963→\\t\\t// Don't fail - hook may silently succeed\\n   964→\\t}\\n   965→\\n   966→\\t// Read the modified message\\n   967→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n   968→\\tif err != nil {\\n   969→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n   970→\\t}\\n   971→\\n   972→\\t// Create the commit using go-git with the modified message\\n   973→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   974→\\tif err != nil {\\n   975→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   976→\\t}\\n   977→\\n   978→\\tworktree, err := repo.Worktree()\\n   979→\\tif err != nil {\\n   980→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   981→\\t}\\n   982→\\n   983→\\t_, err = worktree.Commit(string(modifiedMsg), &git.CommitOptions{\\n   984→\\t\\tAuthor: &object.Signature{\\n   985→\\t\\t\\tName:  \\\"Test User\\\",\\n   986→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   987→\\t\\t\\tWhen:  time.Now(),\\n   988→\\t\\t},\\n   989→\\t})\\n   990→\\tif err != nil {\\n   991→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   992→\\t}\\n   993→\\n   994→\\t// Run post-commit hook using the shared binary\\n   995→\\t// This triggers condensation if the commit has an Entire-Checkpoint trailer\\n   996→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n   997→\\tpostCmd.Dir = env.RepoDir\\n   998→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n   999→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n  1000→\\t\\t// Don't fail - hook may silently succeed\\n  1001→\\t}\\n  1002→}\\n  1003→\\n  1004→// GitCommitAmendWithShadowHooks amends the last commit with shadow hooks.\\n  1005→// This simulates `git commit --amend` with the prepare-commit-msg and post-commit hooks.\\n  1006→// The prepare-commit-msg hook is called with \\\"commit\\\" source to indicate an amend.\\n  1007→func (env *TestEnv) GitCommitAmendWithShadowHooks(message string, files ...string) {\\n  1008→\\tenv.T.Helper()\\n  1009→\\n  1010→\\t// Stage any additional files\\n  1011→\\tfor _, file := range files {\\n  1012→\\t\\tenv.GitAdd(file)\\n  1013→\\t}\\n  1014→\\n  1015→\\t// Write commit message to temp file\\n  1016→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n  1017→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n  1018→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n  1019→\\t}\\n  1020→\\n  1021→\\t// Run prepare-commit-msg hook with \\\"commit\\\" source (indicates amend).\\n  1022→\\t// Set ENTIRE_TEST_TTY=1 to simulate human (amend is always a human operation).\\n  1023→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile, \\\"commit\\\")\\n  1024→\\tprepCmd.Dir = env.RepoDir\\n  1025→\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n  1026→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n  1027→\\t\\tenv.T.Logf(\\\"prepare-commit-msg (amend) output: %s\\\", output)\\n  1028→\\t}\\n  1029→\\n  1030→\\t// Read the modified message\\n  1031→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n  1032→\\tif err != nil {\\n  1033→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n  1034→\\t}\\n  1035→\\n  1036→\\t// Amend the commit using go-git\\n  1037→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1038→\\tif err != nil {\\n  1039→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1040→\\t}\\n  1041→\\n  1042→\\tworktree, err := repo.Worktree()\\n  1043→\\tif err != nil {\\n  1044→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n  1045→\\t}\\n  1046→\\n  1047→\\t_, err = worktree.Commit(string(modifiedMsg), &git.CommitOptions{\\n  1048→\\t\\tAuthor: &object.Signature{\\n  1049→\\t\\t\\tName:  \\\"Test User\\\",\\n  1050→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n  1051→\\t\\t\\tWhen:  time.Now(),\\n  1052→\\t\\t},\\n  1053→\\t\\tAmend: true,\\n  1054→\\t})\\n  1055→\\tif err != nil {\\n  1056→\\t\\tenv.T.Fatalf(\\\"failed to amend commit: %v\\\", err)\\n  1057→\\t}\\n  1058→\\n  1059→\\t// Run post-commit hook\\n  1060→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n  1061→\\tpostCmd.Dir = env.RepoDir\\n  1062→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n  1063→\\t\\tenv.T.Logf(\\\"post-commit (amend) output: %s\\\", output)\\n  1064→\\t}\\n  1065→}\\n  1066→\\n  1067→// GitCommitWithTrailerRemoved stages and commits files, simulating what happens when\\n  1068→// a user removes the Entire-Checkpoint trailer during commit message editing.\\n  1069→// This tests the opt-out behavior where removing the trailer skips condensation.\\n  1070→func (env *TestEnv) GitCommitWithTrailerRemoved(message string, files ...string) {\\n  1071→\\tenv.T.Helper()\\n  1072→\\n  1073→\\t// Stage files using go-git\\n  1074→\\tfor _, file := range files {\\n  1075→\\t\\tenv.GitAdd(file)\\n  1076→\\t}\\n  1077→\\n  1078→\\t// Create a temp file for the commit message (prepare-commit-msg hook modifies this)\\n  1079→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n  1080→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n  1081→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n  1082→\\t}\\n  1083→\\n  1084→\\t// Run prepare-commit-msg hook using the shared binary.\\n  1085→\\t// Set ENTIRE_TEST_TTY=1 to simulate human (this tests the editor flow where\\n  1086→\\t// the user removes the trailer before committing).\\n  1087→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile)\\n  1088→\\tprepCmd.Dir = env.RepoDir\\n  1089→\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n  1090→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n  1091→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n  1092→\\t}\\n  1093→\\n  1094→\\t// Read the modified message (with trailer added by hook)\\n  1095→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n  1096→\\tif err != nil {\\n  1097→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n  1098→\\t}\\n  1099→\\n  1100→\\t// REMOVE the Entire-Checkpoint trailer (simulating user editing the message)\\n  1101→\\tlines := strings.Split(string(modifiedMsg), \\\"\\\\n\\\")\\n  1102→\\tvar cleanedLines []string\\n  1103→\\tfor _, line := range lines {\\n  1104→\\t\\t// Skip the trailer and the comments about it\\n  1105→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n  1106→\\t\\t\\tcontinue\\n  1107→\\t\\t}\\n  1108→\\t\\tif strings.Contains(line, \\\"Remove the Entire-Checkpoint trailer\\\") {\\n  1109→\\t\\t\\tcontinue\\n  1110→\\t\\t}\\n  1111→\\t\\tif strings.Contains(line, \\\"trailer will be added to your next commit\\\") {\\n  1112→\\t\\t\\tcontinue\\n  1113→\\t\\t}\\n  1114→\\t\\tcleanedLines = append(cleanedLines, line)\\n  1115→\\t}\\n  1116→\\tcleanedMsg := strings.TrimRight(strings.Join(cleanedLines, \\\"\\\\n\\\"), \\\"\\\\n\\\") + \\\"\\\\n\\\"\\n  1117→\\n  1118→\\t// Create the commit using go-git with the cleaned message (no trailer)\\n  1119→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1120→\\tif err != nil {\\n  1121→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1122→\\t}\\n  1123→\\n  1124→\\tworktree, err := repo.Worktree()\\n  1125→\\tif err != nil {\\n  1126→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n  1127→\\t}\\n  1128→\\n  1129→\\t_, err = worktree.Commit(cleanedMsg, &git.CommitOptions{\\n  1130→\\t\\tAuthor: &object.Signature{\\n  1131→\\t\\t\\tName:  \\\"Test User\\\",\\n  1132→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n  1133→\\t\\t\\tWhen:  time.Now(),\\n  1134→\\t\\t},\\n  1135→\\t})\\n  1136→\\tif err != nil {\\n  1137→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n  1138→\\t}\\n  1139→\\n  1140→\\t// Run post-commit hook - since trailer was removed, no condensation should happen\\n  1141→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n  1142→\\tpostCmd.Dir = env.RepoDir\\n  1143→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n  1144→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n  1145→\\t}\\n  1146→}\\n  1147→\\n  1148→// GitRm stages file deletions using git rm.\\n  1149→func (env *TestEnv) GitRm(paths ...string) {\\n  1150→\\tenv.T.Helper()\\n  1151→\\n  1152→\\targs := append([]string{\\\"rm\\\", \\\"--\\\"}, paths...)\\n  1153→\\tcmd := exec.Command(\\\"git\\\", args...)\\n  1154→\\tcmd.Dir = env.RepoDir\\n  1155→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1156→\\t\\tenv.T.Fatalf(\\\"git rm failed: %v\\\\nOutput: %s\\\", err, output)\\n  1157→\\t}\\n  1158→}\\n  1159→\\n  1160→// GitCommitStagedWithShadowHooks commits whatever is already staged (without adding files first),\\n  1161→// running the prepare-commit-msg and post-commit hooks like a real workflow.\\n  1162→// Use this after GitRm or when files are already staged.\\n  1163→func (env *TestEnv) GitCommitStagedWithShadowHooks(message string) {\\n  1164→\\tenv.T.Helper()\\n  1165→\\tenv.gitCommitStagedWithShadowHooks(message, true)\\n  1166→}\\n  1167→\\n  1168→// gitCommitStagedWithShadowHooks is the shared implementation for committing staged changes with hooks.\\n  1169→func (env *TestEnv) gitCommitStagedWithShadowHooks(message string, simulateTTY bool) {\\n  1170→\\tenv.T.Helper()\\n  1171→\\n  1172→\\t// Create a temp file for the commit message (prepare-commit-msg hook modifies this)\\n  1173→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n  1174→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n  1175→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n  1176→\\t}\\n  1177→\\n  1178→\\t// Run prepare-commit-msg hook using the shared binary.\\n  1179→\\tprepCm