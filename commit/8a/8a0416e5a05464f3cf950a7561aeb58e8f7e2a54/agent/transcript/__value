 226→\\n   227→// parseHookType parses a specific hook type from rawHooks into the target slice.\\n   228→// Silently ignores parse errors (leaves target unchanged).\\n   229→func parseHookType(rawHooks map[string]json.RawMessage, hookType string, target *[]ClaudeHookMatcher) {\\n   230→\\tif data, ok := rawHooks[hookType]; ok {\\n   231→\\t\\t//nolint:errcheck,gosec // Intentionally ignoring parse errors - leave target as nil/empty\\n   232→\\t\\tjson.Unmarshal(data, target)\\n   233→\\t}\\n   234→}\\n   235→\\n   236→// marshalHookType marshals a hook type back to rawHooks.\\n   237→// If the slice is empty, removes the key from rawHooks.\\n   238→func marshalHookType(rawHooks map[string]json.RawMessage, hookType string, matchers []ClaudeHookMatcher) {\\n   239→\\tif len(matchers) == 0 {\\n   240→\\t\\tdelete(rawHooks, hookType)\\n   241→\\t\\treturn\\n   242→\\t}\\n   243→\\tdata, err := json.Marshal(matchers)\\n   244→\\tif err != nil {\\n   245→\\t\\treturn // Silently ignore marshal errors (shouldn't happen)\\n   246→\\t}\\n   247→\\trawHooks[hookType] = data\\n   248→}\\n   249→\\n   250→// UninstallHooks removes Entire hooks from Claude Code settings.\\n   251→func (c *ClaudeCodeAgent) UninstallHooks() error {\\n   252→\\t// Use repo root to find .claude directory when run from a subdirectory\\n   253→\\trepoRoot, err := paths.RepoRoot()\\n   254→\\tif err != nil {\\n   255→\\t\\trepoRoot = \\\".\\\" // Fallback to CWD if not in a git repo\\n   256→\\t}\\n   257→\\tsettingsPath := filepath.Join(repoRoot, \\\".claude\\\", ClaudeSettingsFileName)\\n   258→\\tdata, err := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   259→\\tif err != nil {\\n   260→\\t\\treturn nil //nolint:nilerr // No settings file means nothing to uninstall\\n   261→\\t}\\n   262→\\n   263→\\tvar rawSettings map[string]json.RawMessage\\n   264→\\tif err := json.Unmarshal(data, &rawSettings); err != nil {\\n   265→\\t\\treturn fmt.Errorf(\\\"failed to parse settings.json: %w\\\", err)\\n   266→\\t}\\n   267→\\n   268→\\t// rawHooks preserves unknown hook types (e.g., \\\"Notification\\\", \\\"SubagentStop\\\")\\n   269→\\tvar rawHooks map[string]json.RawMessage\\n   270→\\tif hooksRaw, ok := rawSettings[\\\"hooks\\\"]; ok {\\n   271→\\t\\tif err := json.Unmarshal(hooksRaw, &rawHooks); err != nil {\\n   272→\\t\\t\\treturn fmt.Errorf(\\\"failed to parse hooks: %w\\\", err)\\n   273→\\t\\t}\\n   274→\\t}\\n   275→\\tif rawHooks == nil {\\n   276→\\t\\trawHooks = make(map[string]json.RawMessage)\\n   277→\\t}\\n   278→\\n   279→\\t// Parse only the hook types we need to modify\\n   280→\\tvar sessionStart, sessionEnd, stop, userPromptSubmit, preToolUse, postToolUse []ClaudeHookMatcher\\n   281→\\tparseHookType(rawHooks, \\\"SessionStart\\\", &sessionStart)\\n   282→\\tparseHookType(rawHooks, \\\"SessionEnd\\\", &sessionEnd)\\n   283→\\tparseHookType(rawHooks, \\\"Stop\\\", &stop)\\n   284→\\tparseHookType(rawHooks, \\\"UserPromptSubmit\\\", &userPromptSubmit)\\n   285→\\tparseHookType(rawHooks, \\\"PreToolUse\\\", &preToolUse)\\n   286→\\tparseHookType(rawHooks, \\\"PostToolUse\\\", &postToolUse)\\n   287→\\n   288→\\t// Remove Entire hooks from all hook types\\n   289→\\tsessionStart = removeEntireHooks(sessionStart)\\n   290→\\tsessionEnd = removeEntireHooks(sessionEnd)\\n   291→\\tstop = removeEntireHooks(stop)\\n   292→\\tuserPromptSubmit = removeEntireHooks(userPromptSubmit)\\n   293→\\tpreToolUse = removeEntireHooksFromMatchers(preToolUse)\\n   294→\\tpostToolUse = removeEntireHooksFromMatchers(postToolUse)\\n   295→\\n   296→\\t// Marshal modified hook types back to rawHooks\\n   297→\\tmarshalHookType(rawHooks, \\\"SessionStart\\\", sessionStart)\\n   298→\\tmarshalHookType(rawHooks, \\\"SessionEnd\\\", sessionEnd)\\n   299→\\tmarshalHookType(rawHooks, \\\"Stop\\\", stop)\\n   300→\\tmarshalHookType(rawHooks, \\\"UserPromptSubmit\\\", userPromptSubmit)\\n   301→\\tmarshalHookType(rawHooks, \\\"PreToolUse\\\", preToolUse)\\n   302→\\tmarshalHookType(rawHooks, \\\"PostToolUse\\\", postToolUse)\\n   303→\\n   304→\\t// Also remove the metadata deny rule from permissions\\n   305→\\tvar rawPermissions map[string]json.RawMessage\\n   306→\\tif permRaw, ok := rawSettings[\\\"permissions\\\"]; ok {\\n   307→\\t\\tif err := json.Unmarshal(permRaw, &rawPermissions); err != nil {\\n   308→\\t\\t\\t// If parsing fails, just skip permissions cleanup\\n   309→\\t\\t\\trawPermissions = nil\\n   310→\\t\\t}\\n   311→\\t}\\n   312→\\n   313→\\tif rawPermissions != nil {\\n   314→\\t\\tif denyRaw, ok := rawPermissions[\\\"deny\\\"]; ok {\\n   315→\\t\\t\\tvar denyRules []string\\n   316→\\t\\t\\tif err := json.Unmarshal(denyRaw, &denyRules); err == nil {\\n   317→\\t\\t\\t\\t// Filter out the metadata deny rule\\n   318→\\t\\t\\t\\tfilteredRules := make([]string, 0, len(denyRules))\\n   319→\\t\\t\\t\\tfor _, rule := range denyRules {\\n   320→\\t\\t\\t\\t\\tif rule != metadataDenyRule {\\n   321→\\t\\t\\t\\t\\t\\tfilteredRules = append(filteredRules, rule)\\n   322→\\t\\t\\t\\t\\t}\\n   323→\\t\\t\\t\\t}\\n   324→\\t\\t\\t\\tif len(filteredRules) > 0 {\\n   325→\\t\\t\\t\\t\\tdenyJSON, err := json.Marshal(filteredRules)\\n   326→\\t\\t\\t\\t\\tif err == nil {\\n   327→\\t\\t\\t\\t\\t\\trawPermissions[\\\"deny\\\"] = denyJSON\\n   328→\\t\\t\\t\\t\\t}\\n   329→\\t\\t\\t\\t} else {\\n   330→\\t\\t\\t\\t\\t// Remove empty deny array\\n   331→\\t\\t\\t\\t\\tdelete(rawPermissions, \\\"deny\\\")\\n   332→\\t\\t\\t\\t}\\n   333→\\t\\t\\t}\\n   334→\\t\\t}\\n   335→\\n   336→\\t\\t// If permissions is empty, remove it entirely\\n   337→\\t\\tif len(rawPermissions) > 0 {\\n   338→\\t\\t\\tpermJSON, err := json.Marshal(rawPermissions)\\n   339→\\t\\t\\tif err == nil {\\n   340→\\t\\t\\t\\trawSettings[\\\"permissions\\\"] = permJSON\\n   341→\\t\\t\\t}\\n   342→\\t\\t} else {\\n   343→\\t\\t\\tdelete(rawSettings, \\\"permissions\\\")\\n   344→\\t\\t}\\n   345→\\t}\\n   346→\\n   347→\\