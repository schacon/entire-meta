  315→  if (checkpoints.length === 0) {\\n   316→    console.log(`  No checkpoint commits found, skipping.`);\\n   317→    return { indexed: 0, skipped: 0 };\\n   318→  }\\n   319→\\n   320→  console.log(`  Fetched ${checkpoints.length} checkpoint rows from DB.`);\\n   321→\\n   322→  const githubToken = process.env.GITHUB_TOKEN;\\n   323→\\n   324→  // Build text fields (with optional transcript excerpts)\\n   325→  const texts: string[] = [];\\n   326→  let skipped = 0;\\n   327→\\n   328→  for (let i = 0; i < checkpoints.length; i++) {\\n   329→    const cp = checkpoints[i];\\n   330→    let transcriptExcerpt: string | undefined;\\n   331→\\n   332→    if (options.withTranscripts && githubToken) {\\n   333→      transcriptExcerpt =\\n   334→        (await fetchTranscriptExcerpt(repo.full_name, cp.checkpoint_id, cp.agent, githubToken)) ??\\n   335→        undefined;\\n   336→      // Rate limit GitHub API calls\\n   337→      if (i < checkpoints.length - 1) {\\n   338→        await sleep(TRANSCRIPT_DELAY_MS);\\n   339→      }\\n   340→    }\\n   341→\\n   342→    const text = buildSearchText(cp, transcriptExcerpt);\\n   343→    if (!text.trim()) {\\n   344→      skipped++;\\n   345→      texts.push(\\\"\\\"); // placeholder to maintain index alignment\\n   346→      continue;\\n   347→    }\\n   348→\\n   349→    texts.push(text);\\n   350→  }\\n   351→\\n   352→  // Filter out empty texts for embedding, but keep index mapping\\n   353→  const nonEmptyIndices = texts.map((t, i) => (t.trim() ? i : -1)).filter((i) => i >= 0);\\n   354→  const nonEmptyTexts = nonEmptyIndices.map((i) => texts[i]);\\n   355→\\n   356→  if (nonEmptyTexts.length === 0) {\\n   357→    console.log(`  All checkpoints had empty text, skipping.`);\\n   358→    return { indexed: 0, skipped };\\n   359→  }\\n   360→\\n   361→  if (options.dryRun) {\\n   362→    console.log(`  [DRY RUN] Would index ${nonEmptyTexts.length} checkpoints.`);\\n   363→    for (let i = 0; i < Math.min(3, nonEmptyTexts