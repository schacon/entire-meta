a branch that are not in the valid set of checkpoint IDs.\\n   621→// Used during sync backfill to reconcile after force pushes or history rewrites.\\n   622→export async function deleteStaleCommitsForBranch(\\n   623→  db: Kysely<DB>,\\n   624→  repoId: string,\\n   625→  branch: string,\\n   626→  validCheckpointIds: string[],\\n   627→): Promise<number> {\\n   628→  if (validCheckpointIds.length === 0) {\\n   629→    // No valid checkpoints = delete all commits for this branch\\n   630→    return deleteCommitsByBranch(db, repoId, branch);\\n   631→  }\\n   632→\\n   633→  const result = await db\\n   634→    .deleteFrom(\\\"repo_checkpoint_commits\\\")\\n   635→    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n   636→    .where(\\\"branch\\\", \\\"=\\\", branch)\\n   637→    .where(\\\"checkpoint_id\\\", \\\"not in\\\", validCheckpointIds)\\n   638→    .executeTakeFirst();\\n   639→\\n   640→  return Number(result.numDeletedRows);\\n   641→}\\n   642→\\n   643→export async function deleteOrphanedCheckpoints(\\n   644→  db: Kysely<DB>,\\n   645→  repoId: string,\\n   646→): Promise<number> {\\n   647→  // Get all checkpoint_ids that have commits\\n   648→  const commitsData = await db\\n   649→    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n   650→    .select(\\\"checkpoint_id\\\")\\n   651→    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n   652→    .execute();\\n   653→\\n   654→  const commitCheckpointIds = new Set(commitsData.map((c) => c.checkpoint_id));\\n   655→\\n   656→  // Get all checkpoints for this repo\\n   657→  const checkpointsData = await db\\n   658→    .selectFrom(\\\"repo_checkpoints\\\")\\n   659→    .select([\\\"id\\\", \\\"checkpoint_id\\\", \\\"created_at\\\"])\\n   660→    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n   661→    .execute();\\n   662→\\n   663→  // Grace period: don't delete checkpoints created in the last 5 minutes\\n   664→  const gracePeriodMs = 5 * 60 * 1000;\\n   665→  const cutoffTime = Date.now() - gracePeriodMs;\\n   666→\\n   667→  const orphanedIds = checkpointsData\\n   668→    .filter((cp) => {\\n   669→      if (commitCheckpointIds.has(cp.checkpoint_id)) return false;\\n   670→      if (!cp.created_at) return true;\\n   671→      return cp.created_at.getTime() < cutoffTime;\\n   672→    })\\n   673→    .map((cp) => cp.id);\\n   674→\\n   675→  if (orphanedIds.length === 0) return 0;\\n   676→\\n   677→  // Delete orphaned checkpoints in batches to avoid oversized IN lists.\\n   678→  // Each batch re-checks via NOT IN subquery to avoid FK violations from race conditions.\\n   679→  const BATCH_SIZE = 100;\\n   680→  let totalDeleted = 0;\\n   681→\\n   682→  for (let i = 0; i < orphanedIds.length; i += BATCH_SIZE) {\\n   683→    const batch = orphanedIds.slice(i, i + BATCH_SIZE);\\n   684→    const result = await db\\n   685→      .deleteFrom(\\\"repo_checkpoints\\\")\\n   686→      .where(\\\"id\\\", \\\"in\\\", batch)\\n   687→      .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n   688→      .where((eb) =>\\n   689→        eb(\\n   690→          \\\"checkpoint_id\\\",\\n   691→          \\\"not in\\\",\\n   692→          eb\\n   693→            .selectFrom(\\\"repo_checkpoint_commits\\\")\\n   694→            .select(\\\"checkpoint_id\\\")\\n   695→            .where(\\\"repo_id\\\", \\\"=\\\", repoId),\\n   696→        ),\\n   697→      )\\n   698→      .executeTakeFirst();\\n   699→\\n   700→    totalDeleted += Number(result.numDeletedRows);\\n   701→  }\\n   702→\\n   703→  return totalDeleted;\\n   704→}\\n   705→\\n   706→export async function recalculateCheckpointCount(\\n   707→  db: Kysely<DB>,\\n   708→  repoId: string,\\n   709→): Promise<void> {\\n   710→  // Count distinct checkpoints that have commits\\n   711→  const rows = await db\\n   712→    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n   713→    .select(\\\"checkpoint_id\\\")\\n   714→    .distinct()\\n   715→    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n   716→    .execute();\\n   717→\\n   718→  // CRITICAL: If query fails it will throw, which is safe (won't set to 0)\\n   719→  await db\\n   720→    .updateTable(\\\"repos\\\")\\n   721→    .set({\\n   722→      checkpoint_count: rows.length,\\n   723→      updated_at: new Date(),\\n   724→    })\\n   725→    .where(\\\"id\\\", \\\"=\\\", repoId)\\n   726→    .execute();\\n   727→}\\n   728→\\n   729→/**\\n   730→ * Returns the week index (0-51) for a commit date relative to currentWeekStart.\\n   731→ * Week 51 = current week, week 0 = 51 weeks ago. Returns null if outside the 52-week window.\\n   732→ * Week boundaries align to Sunday 00:00:00.\\n   733→ */\\n   734→export function commitDateToWeekIndex(commitDate: Date, currentWeekStart: Date): number | null {\\n   735→  const weeksAgo = Math.ceil(\\n   736→    (currentWeekStart.getTime() - commitDate.getTime()) / (7 * 24 * 60 * 60 * 1000),\\n   737→  );\\n   738→\\n   739→  if (weeksAgo >= 0 && weeksAgo < 52) {\\n   740→    return 51 - weeksAgo;\\n   741→  }\\n   742→  return null;\\n   743→}\\n   744→\\n   745→export async function getCheckpointActivityForUser(\\n   746→  db: Kysely<DB>,\\n   747→  userId: string,\\n   748→): Promise<RepoCommitActivity[]> {\\n   749→  const fiftyTwoWeeksAgo = new Date();\\n   750→  fiftyTwoWeeksAgo.setDate(fiftyTwoWeeksAgo.getDate() - 52 * 7);\\n   751→\\n   752→  const commits = await db\\n   753→    .selectFrom(\\\"repo_checkpoint_commits as cc\\\")\\n   754→    .innerJoin(\\\"repos\\\", \\\"repos.id\\\", \\\"cc.repo_id\\\")\\n   755→    .innerJoin(\\\"user_repos\\\", (join) =>\\n   756→      join\\n   757→        .onRef(\\\"user_repos.repo_id\\\", \\\"=\\\", \\\"repos.id\\\")\\n   758→        .on(\\\"user_repos.user_id\\\", \\\"=\\\", userId),\\n   759→    )\\n   760→    .select([\\n   761→      \\\"cc.repo_id\\\",\\n   762→      \\\"cc.checkpoint_id\\\",\\n   763→      \\\"cc.commit_date\\\",\\n   764→      \\\"repos.full_name\\\",\\n   765→    ])\\n   766→    .where(\\\"repos.is_fork\\\", \\\"=\\\", 0)\\n   767→    .where(\\\"cc.commit_date\\\", \\\">=\\\", fiftyTwoWeeksAgo)\\n   768→    .where(\\\"cc.commit_date\\\", \\\"is not\\\", null)\\n   769→    .execute();\\n   770→\\n   771→  // Build repo map\\n   772→  const repoMap = new Map<string, string>();\\n   773→  for (const commit of commits) {\\n   774→    if (commit.repo_id && !repoMap.has(commit.repo_id)) {\\n   775→      repoMap.set(commit.repo_id, commit.full_name);\\n   776→    }\\n   777→  }\\n   778→\\n   779→  // Calculate the start of the current week (Sunday)\\n   780→  const now = new Date();\\n   781→  const currentWeekStart = new Date(now);\\n   782→  currentWeekStart.setDate(now.getDate() - now.getDay());\\n   783→  currentWeekStart.setHours(0, 0, 0, 0);\\n   784→\\n   785→  const oldestWeekStart = new Date(currentWeekStart);\\n   786→  oldestWeekStart.setDate(oldestWeekStart.getDate() - 51 * 7);\\n   787→  const weekStartTimestamp = Math.floor(oldestWeekStart.getTime() / 1000);\\n   788→\\n   789→  // Aggregate commits by repo and week, deduplicating by checkpoint_id\\n   790→  const repoWeeks = new Map<string, number[]>();\\n   791→  const seenCheckpoints = new Map<string, Set<string>>();\\n   792→\\n   793→  for (const commit of commits) {\\n   794→    const repoFullName = repoMap.get(commit.repo_id ?? \\\"\\\");\\n   795→    if (!repoFullName || !commit.commit_date) continue;\\n   796→\\n   797→    const commitDate = commit.commit_date instanceof Date\\n   798→      ? commit.commit_date\\n   799→      : new Date(commit.commit_date);\\n   800→    const weekIndex = commitDateToWeekIndex(commitDate, currentWeekStart);\\n   801→\\n   802→    if (weekIndex !== null) {\\n   803→      const dedupeKey = `${repoFullName}:${weekIndex}`;\\n   804→\\n   805→      if (!seenCheckpoints.has(dedupeKey)) {\\n   806→        seenCheckpoints.set(dedupeKey, new Set());\\n   807→      }\\n   808→      const seen = seenCheckpoints.get(dedupeKey)!;\\n   809→      if (seen.has(commit.checkpoint_id)) continue;\\n   810→      seen.add(commit.checkpoint_id);\\n   811→\\n   812→      if (!repoWeeks.has(repoFullName)) {\\n   813→        repoWeeks.set(repoFullName, new Array(52).fill(0));\\n   814→      }\\n   815→      repoWeeks.get(repoFullName)![weekIndex]++;\\n   816→    }\\n   817→  }\\n   818→\\n   819→  const activities: RepoCommitActivity[] = [];\\n   820→  for (const [repoFullName, weeks] of repoWeeks) {\\n   821→    activities.push({ repo_full_name: repoFullName, weeks, week_start: weekStartTimestamp });\\n   822→  }\\n   823→\\n   824→  return activities;\\n   825→}\\n   826→\\n   827→export async function getCheckpointsByUser(\\n   828→  db: Kysely<DB>,\\n   829→  userId: string,\\n   830→  githubId: number,\\n   831→  startDate: string,\\n   832→  endDate: string,\\n   833→  limit: number = 500,\\n   834→): Promise<UserCheckpoint[]> {\\n   835→  const commits = await db\\n   836→    .selectFrom(\\\"repo_checkpoint_commits as cc\\\")\\n   837→    .innerJoin(\\\"repos\\\", \\\"repos.id\\\", \\\"cc.repo_id\\\")\\n   838→    .innerJoin(\\\"user_repos\\\", (join) =>\\n   839→      join\\n   840→        .onRef(\\\"user_repos.repo_id\\\", \\\"=\\\", \\\"repos.id\\\")\\n   841→        .on(\\\"user_repos.user_id\\\", \\\"=\\\", userId),\\n   842→    )\\n   843→    .leftJoin(\\\"repo_checkpoints as cp\\\", (join) =>\\n   844→      join\\n   845→        .onRef(\\\"cp.repo_id\\\", \\\"=\\\", \\\"cc.repo_id\\\")\\n   846→        .onRef(\\\"cp.checkpoint_id\\\", \\\"=\\\", \\\"cc.checkpoint_id\\\"),\\n   847→    )\\n   848→    .select([\\n   849→      \\\"cc.checkpoint_id\\\",\\n   850→      \\\"cc.branch\\\",\\n   851→      \\\"cc.commit_sha\\\",\\n   852→      \\\"cc.commit_message\\\",\\n   853→      \\\"cc.commit_date\\\",\\n   854→      \\\"cc.additions\\\",\\n   855→      \\\"cc.deletions\\\",\\n   856→      \\\"cc.files_changed\\\",\\n   857→      \\\"cc.repo_id\\\",\\n   858→      \\\"repos.full_name as repo_full_name\\\",\\n   859→      \\\"repos.is_private\\\",\\n   860→      \\\"cp.a