      \\\"cc.commit_date\\\",\\n    64→      \\\"cc.additions\\\",\\n    65→      \\\"cc.deletions\\\",\\n    66→      \\\"cc.files_changed\\\",\\n    67→      \\\"cc.file_stats\\\",\\n    68→      \\\"cp.prompt\\\",\\n    69→      \\\"cp.agent\\\",\\n    70→      \\\"cp.steps\\\",\\n    71→      \\\"cp.session_count\\\",\\n    72→      \\\"cp.strategy\\\",\\n    73→      \\\"cp.created_at\\\",\\n    74→      \\\"cp.files_touched\\\",\\n    75→      \\\"cp.input_tokens\\\",\\n    76→      \\\"cp.cache_creation_tokens\\\",\\n    77→      \\\"cp.cache_read_tokens\\\",\\n    78→      \\\"cp.output_tokens\\\",\\n    79→      \\\"cp.api_call_count\\\",\\n    80→      \\\"cp.attribution_agent_lines\\\",\\n    81→      \\\"cp.attribution_human_added\\\",\\n    82→      \\\"cp.attribution_human_modified\\\",\\n    83→      \\\"cp.attribution_human_removed\\\",\\n    84→      \\\"cp.attribution_total_committed\\\",\\n    85→      \\\"cp.attribution_agent_percentage\\\",\\n    86→      \\\"cp.attribution_calculated_at\\\",\\n    87→    ])\\n    88→    .where(\\n    89→      \\\"cc.id\\\",\\n    90→      \\\"in\\\",\\n    91→      idRows.map((r) => r.id),\\n    92→    )\\n    93→    .execute();\\n    94→\\n    95→  // Restore sort order from the first query (already sorted by commit_date desc)\\n    96→  // without ORDER BY on the large-row query which causes OOM on the sort buffer.\\n    97→  const rowById = new Map(rows.map((r) => [r.id, r]));\\n    98→  const sorted = idRows.map((r) => rowById.get(r.id)).filter(Boolean) as typeof rows;\\n    99→\\n   100→  return sorted.map((row) => ({\\n   101→    checkpoint_id: row.checkpoint_id,\\n   102→    branch: row.branch,\\n   103→    prompt: row.prompt ?? null,\\n   104→    agent: row.agent ?? \\\"Claude Code\\\",\\n   105→    steps: row.steps ?? 1,\\n   106→    session_count: row.session_count ?? 1,\\n   107→    strategy: row.strategy ?? null,\\n   108→    created_at: dateToStr(row.created_at),\\n   109→    commit_sha: row.commit