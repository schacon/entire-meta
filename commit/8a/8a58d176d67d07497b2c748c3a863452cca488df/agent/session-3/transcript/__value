mmit_message,\\n          commit_author: values.commit_author,\\n          commit_author_username: values.commit_author_username,\\n          commit_author_github_id: values.commit_author_github_id,\\n          commit_date: values.commit_date,\\n          additions: values.additions,\\n          deletions: values.deletions,\\n          files_changed: values.files_changed,\\n          file_stats: values.file_stats,\\n          synced_at: values.synced_at,\\n        })\\n        .execute();\\n    }\\n\\n    successCount += batch.length;\\n  }\\n\\n  return successCount;\\n}\\n\\nexport async function deleteCommitsByBranch(\\n  db: Kysely<DB>,\\n  repoId: string,\\n  branch: string,\\n): Promise<number> {\\n  const result = await db\\n    .deleteFrom(\\\"repo_checkpoint_commits\\\")\\n    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n    .where(\\\"branch\\\", \\\"=\\\", branch)\\n    .executeTakeFirst();\\n\\n  return Number(result.numDeletedRows);\\n}\\n\\n// Delete stale commits for a branch that are not in the valid set of checkpoint IDs.\\n// Used during sync backfill to reconcile after force pushes or history rewrites.\\nexport async function deleteStaleCommitsForBranch(\\n  db: Kysely<DB>,\\n  repoId: string,\\n  branch: string,\\n  validCheckpointIds: string[],\\n): Promise<number> {\\n  if (validCheckpointIds.length === 0) {\\n    // No valid checkpoints = delete all commits for this branch\\n    return deleteCommitsByBranch(db, repoId, branch);\\n  }\\n\\n  const result = await db\\n    .deleteFrom(\\\"repo_checkpoint_commits\\\")\\n    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n    .where(\\\"branch\\\", \\\"=\\\", branch)\\n    .where(\\\"checkpoint_id\\\", \\\"not in\\\", validCheckpointIds)\\n    .executeTakeFirst();\\n\\n  return Number(result.numDeletedRows);\\n}\\n\\nexport async function deleteOrphanedCheckpoints(\\n  db: Kysely<DB>,\\n  repoId: string,\\n): Promise<number> {\\n  // Get all checkpoint_ids that have commits\\n  const commitsData = await db\\n    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n    .select(\\\"checkpoint_id\\\")\\n    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n    .execute();\\n\\n  const commitCheckpointIds = new Set(commitsData.map((c) => c.checkpoint_id));\\n\\n  // Get all checkpoints for this repo\\n  const checkpointsData = await db\\n    .selectFrom(\\\"repo_checkpoints\\\")\\n    .select([\\\"id\\\", \\\"checkpoint_id\\\", \\\"created_at\\\"])\\n    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n    .execute();\\n\\n  // Grace period: don't delete checkpoints created in the last 5 minutes\\n  const gracePeriodMs = 5 * 60 * 1000;\\n  const cutoffTime = Date.now() - gracePeriodMs;\\n\\n  const orphanedIds = checkpointsData\\n    .filter((cp) => {\\n      if (commitCheckpointIds.has(cp.checkpoint_id)) return false;\\n      if (!cp.created_at) return true;\\n      return cp.created_at.getTime() < cutoffTime;\\n    })\\n    .map((cp) => cp.id);\\n\\n  if (orphanedIds.length === 0) return 0;\\n\\n  // Delete orphaned checkpoints in batches to avoid oversized IN lists.\\n  // Each batch re-checks via NOT IN subquery to avoid FK violations from race conditions.\\n  const BATCH_SIZE = 100;\\n  let totalDeleted = 0;\\n\\n  for (let i = 0; i < orphanedIds.length; i += BATCH_SIZE) {\\n    const batch = orphanedIds.slice(i, i + BATCH_SIZE);\\n    const result = await db\\n      .deleteFrom(\\\"repo_checkpoints\\\")\\n      .where(\\\"id\\\", \\\"in\\\", batch)\\n      .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n      .where((eb) =>\\n        eb(\\n          \\\"checkpoint_id\\\",\\n          \\\"not in\\\",\\n          eb\\n            .selectFrom(\\\"repo_checkpoint_commits\\\")\\n            .select(\\\"checkpoint_id\\\")\\n            .where(\\\"repo_id\\\", \\\"=\\\", repoId),\\n        ),\\n      )\\n      .executeTakeFirst();\\n\\n    totalDeleted += Number(result.numDeletedRows);\\n  }\\n\\n  return totalDeleted;\\n}\\n\\nexport async function recalculateCheckpointCount(\\n  db: Kysely<DB>,\\n  repoId: string,\\n): Promise<void> {\\n  // Count distinct checkpoints that have commits\\n  const rows = await db\\n    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n    .select(\\\"checkpoint_id\\\")\\n    .distinct()\\n    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n    .execute();\\n\\n  // CRITICAL: If query fails it will throw, which is safe (won't set to 0)\\n  await db\\n    .updateTable(\\\"repos\\\")\\n    .set({\\n      checkpoint_count: rows.length,\\n      updated_at: new Date(),\\n    })\\n    .where(\\\"id\\\", \\\"=\\\", repoId)\\n    .execute();\\n}\\n\\n/**\\n * Returns the week index (0-51) for a commit date relative to currentWeekStart.\\n * Week 51 = current week, week 0 = 51 weeks ago. Returns null if outside the 52-week window.\\n * Week boundaries align to Sunday 00:00:00.\\n */\\nexport function commitDateToWeekIndex(commitDate: Date, currentWeekStart: Date): number | null {\\n  const weeksAgo = Math.ceil(\\n    (currentWeekStart.getTime() - commitDate.getTime()) / (7 * 24 * 60 * 60 * 1000),\\n  );\\n\\n  if (weeksAgo >= 0 && weeksAgo < 52) {\\n    return 51 - weeksAgo;\\n  }\\n  return null;\\n}\\n\\nexport async function getCheckpointActivityForUser(\\n  db: Kysely<DB>,\\n  userId: string,\\n): Promise<RepoCommitActivity[]> {\\n  const fiftyTwoWeeksAgo = new Date();\\n  fiftyTwoWeeksAgo.setDate(fiftyTwoWeeksAgo.getDate() - 52 * 7);\\n\\n  const commits = await db\\n    .selectFrom(\\\"repo_checkpoint_commits as cc\\\")\\n    .innerJoin(\\\"repos\\\", \\\"repos.id\\\", \\\"cc.repo_id\\\")\\n    .innerJoin(\\\"user_repos\\\", (join) =>\\n      join\\n        .onRef(\\\"user_repos.repo_id\\\", \\\"=\\\", \\\"repos.id\\\")\\n        .on(\\\"user_repos.user_id\\\", \\\"=\\\", userId),\\n    )\\n    .select([\\n      \\\"cc.repo_id\\\",\\n      \\\"cc.checkpoint_id\\\",\\n      \\\"cc.commit_date\\\",\\n      \\\"repos.full_name\\\",\\n    ])\\n    .where(\\\"repos.is_fork\\\", \\\"=\\\", 0)\\n    .where(\\\"cc.commit_date\\\", \\\">=\\\", fiftyTwoWeeksAgo)\\n    .where(\\\"cc.commit_date\\\", \\\"is not\\\", null)\\n    .execute();\\n\\n  // Build repo map\\n  const repoMap = new Map<string, string>();\\n  for (const commit of commits) {\\n    if (commit.repo_id && !repoMap.has(commit.repo_id)) {\\n      repoMap.set(commit.repo_id, commit.full_name);\\n    }\\n  }\\n\\n  // Calculate the start of the current week (Sunday)\\n  const now = new Date();\\n  const currentWeekStart = new Date(now);\\n  currentWeekStart.setDate(now.getDate() - now.getDay());\\n  currentWeekStart.setHours(0, 0, 0, 0);\\n\\n  const oldestWeekStart = new Date(currentWeekStart);\\n  oldestWeekStart.setDate(oldestWeekStart.getDate() - 51 * 7);\\n  const weekStartTimestamp = Math.floor(oldestWeekStart.getTime() / 1000);\\n\\n  // Aggregate commits by repo and week, deduplicating by checkpoint_id\\n  const repoWeeks = new Map<string, number[]>();\\n  const seenCheckpoints = new Map<string, Set<string>>();\\n\\n  for (const commit of commits) {\\n    const repoFullName = repoMap.get(commit.repo_id ?? \\\"\\\");\\n    if (!repoFullName || !commit.commit_date) continue;\\n\\n    const commitDate = commit.commit_date instanceof Date\\n      ? commit.commit_date\\n      : new Date(commit.commit_date);\\n    const weekIndex = commitDateToWeekIndex(commitDate, currentWeekStart);\\n\\n    if (weekIndex !== null) {\\n      const dedupeKey = `${repoFullName}:${weekIndex}`;\\n\\n      if (!seenCheckpoints.has(dedupeKey)) {\\n        seenCheckpoints.set(dedupeKey, new Set());\\n      }\\n      const seen = seenCheckpoints.get(dedupeKey)!;\\n      if (seen.has(commit.checkpoint_id)) continue;\\n      seen.add(commit.checkpoint_id);\\n\\n      if (!repoWeeks.has(repoFullName)) {\\n        repoWeeks.set(repoFullName, new Array(52).fill(0));\\n      }\\n      repoWeeks.get(repoFullName)![weekIndex]++;\\n    }\\n  }\\n\\n  const activities: RepoCommitActivity[] = [];\\n  for (const [repoFullName, weeks] of repoWeeks) {\\n    activities.push({ repo_full_name: repoFullName, weeks, week_start: weekStartTimestamp });\\n  }\\n\\n  return activities;\\n}\\n\\nexport async function getCheckpointsByUser(\\n  db: Kysely<DB>,\\n  userId: string,\\n  githubId: number,\\n  startDate: string,\\n  endDate: string,\\n  limit: number = 500,\\n): Promise<UserCheckpoint[]> {\\n  const commits = await db\\n    .selectFrom(\\\"repo_checkpoint_commits as cc\\\")\\n    .innerJoin(\\\"repos\\\", \\\"repos.id\\\", \\\"cc.repo_id\\\")\\n    .innerJoin(\\\"user_repos\\\", (join) =>\\n      join\\n        .onRef(\\\"user_repos.repo_id\\\", \\\"=\\\", \\\"repos.id\\\")\\n        .on(\\\"user_repos.user_id\\\", \\\"=\\\", userId),\\n    )\\n    .leftJoin(\\\"repo_checkpoints as cp\\\", (join) =>\\n      join\\n        .onRef(\\\"cp.repo_id\\\", \\\"=\\\", \\\"cc.repo_id\\\")\\n        .onRef(\\\"cp.checkpoint_id\\\", \\\"=\\\", \\\"cc.checkpoint_id\\\"),\\n    )\\n    .select([\\n      \\\"cc.checkpoint_id\\\",\\n      \\\"cc.branch\\\",\\n      \\\"cc.commit_sha\\\",\\n      \\\"cc.commit_message\\\",\\n      \\\"cc.commit_date\\\",\\n      \\\"cc.additions\\\",\\n      \\\"cc.deletions\\\",\\n      \\\"cc.files_changed\\\",\\n      \\\"cc.repo_id\\\",\\n      \\\"repos.full_name as repo_full_name\\\",\\n      \\\"repos.is_private\\\",\\n      \\\"cp.agent\\\",\\n      \\\"cp.steps\\\",\\n      \\\"cp.session_count\\\",\\n      \\\"cp.input_tokens\\\",\\n      \\\"cp.output_tokens\\\",\\n    ])\\n    .where(\\\"cc.commit_author_github_id\\\", \\\"=\\\", githubId)\\n    .where(\\\"cc.commit_date\\\", \\\">=\\\", new Date(startDate))\\n    .where(\\\"cc.commit_date\\\", \\\"<=\\\", new Date(endDate))\\n    .orderBy(\\\"cc.commit_date\\\", \\\"desc\\\")\\n    .limit(limit * 2) // Fetch extra to account for duplicates\\n    .execute();\\n\\n  if (commits.length === 0) return [];\\n\\n  // Deduplicate by (repo_id, checkpoint_id), preferring main branch\\n  const deduplicatedCommits = new Map<string, (typeof commits)[0]>();\\n\\n  for (const commit of commits) {\\n    const key = `${commit.repo_id}:${commit.checkpoint_id}`;\\n    const existing = deduplicatedCommits.get(key);\\n\\n    if (!existing) {\\n      deduplicatedCommits.set(key, commit);\\n    } else if (commit.branch === \\\"main\\\" && existing.branch !== \\\"main\\\") {\\n      deduplicatedCommits.set(key, commit);\\n    }\\n  }\\n\\n  return Array.from(deduplicatedCommits.values())\\n    .slice(0, limit)\\n    .map((commit) => ({\\n      checkpoint_id: commit.checkpoint_id,\\n      commit_sha: commit.commit_sha,\\n      commit_message: commit.commit_message,\\n      commit_date: dateToStr(commit.commit_date),\\n      additions: commit.additions ?? 0,\\n      deletions: commit.deletions ?? 0,\\n      files_changed: commit.files_changed ?? 0,\\n      repo_full_name: commit.repo_full_name ?? \\\"\\\",\\n      branch: commit.branch,\\n      is_private: toBool(commit.is_private),\\n      agent: commit.agent ?? null,\\n      steps: commit.steps ?? null,\\n      session_count: commit.session_count ?? null,\\n      input_tokens: commit.input_tokens ?? null,\\n      output_tokens: commit.output_tokens ?? null,\\n    }));\\n}\\n\\n// --- Sync Functions ---\\n\\nconst SYNC_LOG_PREFIX = \\\"[repo-sync]\\\";\\n\\nfunction syncLog(event: string, data: Record<string, unknown>): void {\\n  console.log(`${SYNC_LOG_PREFIX} ${event}`, JSON.stringify(data));\\n}\\n\\nexport async function getCheckpointIdsWithCommitsForRepo(\\n  db: Kysely<DB>,\\n  repoId: string,\\n  checkpointIds: string[],\\n  branch?: string,\\n): Promise<Set<string>> {\\n  if (checkpointIds.length === 0) return new Set();\\n\\n  let query = db\\n    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n    .select(\\\"checkpoint_id\\\")\\n    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n    .where(\\\"checkpoint_id\\\", \\\"in\\\", checkpointIds);\\n\\n  if (branch) {\\n    query = query.where(\\\"branch\\\", \\\"=\\\", branch);\\n  }\\n\\n  const rows = await query.execute();\\n  return new Set(rows.map((r) => r.checkpoint_id));\\n}\\n\\nexport async function upsertSyncCheckpointBatch(\\n  db: Kysely<DB>,\\n  repoId: string,\\n  checkpoints: CheckpointData[],\\n): Promise<number> {\\n  if (checkpoints.length === 0) return 0;\\n\\n  const uniqueCheckpoints = deduplicateCheckpoints(checkpoints);\\n  const now = new Date().toISOString();\\n  let successCount = 0;\\n\\n  for (let i = 0; i < uniqueCheckpoints.length; i += BATCH_SIZE) {\\n    const batch = uniqueCheckpoints.slice(i, i + BATCH_SIZE);\\n\\n    // Fetch existing records for COALESCE behavior\\n    let existingRecords;\\n    try {\\n      existingRecords = await db\\n        .selectFrom(\\\"repo_checkpoints\\\")\\n        .selectAll()\\n        .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n        .where(\\\"checkpoint_id\\\", \\\"in\\\", batch.map((cp) => cp.checkpoint_id))\\n        .execute();\\n    } catch (e) {\\n      syncLog(\\\"fetch_existing_checkpoints_error\\\", { batch: i / BATCH_SIZE + 1, error: String(e) });\\n      continue;\\n    }\\n\\n    const existingMap = new Map(existingRecords.map((row) => [row.checkpoint_id, row]));\\n\\n    const safeJsonParse = (value: string | null | undefined, fallback: unknown): unknown => {\\n      if (!value) return fallback;\\n      try {\\n        return JSON.parse(value);\\n      } catch {\\n        syncLog(\\\"json_parse_error\\\", { value: value.substring(0, 100) });\\n        return fallback;\\n      }\\n    };\\n\\n    for (const cp of batch) {\\n      const existing = existingMap.get(cp.checkpoint_id);\\n      const values = {\\n        id: existing?.id ?? generateId(),\\n        repo_id: repoId,\\n        checkpoint_id: cp.checkpoint_id,\\n        prompt: cp.prompt ?? existing?.prompt ?? null,\\n        agent: cp.agent ?? existing?.agent ?? \\\"Claude Code\\\",\\n        steps: cp.steps ?? existing?.steps ?? 1,\\n        session_count: cp.session_count ?? existing?.session_count ?? 1,\\n        strategy: cp.strategy ?? existing?.strategy ?? null,\\n        branch: cp.branch ?? existing?.branch ?? null,\\n        session_id: cp.session_id ?? existing?.session_id ?? null,\\n        files_touched: JSON.stringify(safeJsonParse(cp.files_touched, existing?.files_touched ?? null)) as unknown as string,\\n        session_ids: JSON.stringify(safeJsonParse(cp.session_ids, existing?.session_ids ?? null)) as unknown as string,\\n        transcript_uuid_at_start: cp.transcript_uuid_at_start ?? existing?.transcript_uuid_at_start ?? null,\\n        transcript_lines_at_start: cp.transcript_lines_at_start ?? existing?.transcript_lines_at_start ?? null,\\n        checkpoint_transcript_start:\\n          cp.checkpoint_transcript_start ??\\n          existing?.checkpoint_transcript_start ??\\n          cp.transcript_lines_at_start ??\\n          existing?.transcript_lines_at_start ??\\n          null,\\n        input_tokens: cp.input_tokens ?? existing?.input_tokens ?? null,\\n        cache_creation_tokens: cp.cache_creation_tokens ?? existing?.cache_creation_tokens ?? null,\\n        cache_read_tokens: cp.cache_read_tokens ?? existing?.cache_read_tokens ?? null,\\n        output_tokens: cp.output_tokens ?? existing?.output_tokens ?? null,\\n        api_call_count: cp.api_call_count ?? existing?.api_call_count ?? null,\\n        sessions: JSON.stringify(safeJsonParse(cp.sessions, existing?.sessions ?? null)) as unknown as string,\\n        created_at: cp.created_at ? new Date(cp.created_at) : existing?.created_at ?? new Date(now),\\n        synced_at: new Date(now),\\n      };\\n\\n      try {\\n        await db\\n          .insertInto(\\\"repo_checkpoints\\\")\\n          .values(values)\\n          .onDuplicateKeyUpdate({\\n            prompt: values.prompt,\\n            agent: values.agent,\\n            steps: values.steps,\\n            session_count: values.session_count,\\n            strategy: values.strategy,\\n            branch: values.branch,\\n            session_id: values.session_id,\\n            files_touched: values.files_touched,\\n            session_ids: values.session_ids,\\n            transcript_uuid_at_start: values.transcript_uuid_at_start,\\n            transcript_lines_at_start: values.transcript_lines_at_start,\\n            checkpoint_transcript_start: values.checkpoint_transcript_start,\\n            input_tokens: values.input_tokens,\\n            cache_creation_tokens: values.cache_creation_tokens,\\n            cache_read_tokens: values.cache_read_tokens,\\n            output_tokens: values.output_tokens,\\n            api_call_count: values.api_call_count,\\n            sessions: values.sessions,\\n            created_at: values.created_at,\\n            synced_at: values.synced_at,\\n          })\\n          .execute();\\n        successCount++;\\n      } catch (e) {\\n        syncLog(\\\"upsert_checkpoint_error\\\", { checkpoint_id: cp.checkpoint_id, error: String(e) });\\n        continue;\\n      }\\n    }\\n  }\\n\\n  return successCount;\\n}\\n\\nexport async function upsertSyncCommitBatch(\\n  db: Kysely<DB>,\\n  repoId: string,\\n  commits: CommitData[],\\n): Promise<number> {\\n  if (commits.length === 0) return 0;\\n\\n  const uniqueCommits = deduplicateCommits(commits);\\n  const now = new Date().toISOString();\\n  let successCount = 0;\\n\\n  for (let i = 0; i < uniqueCommits.length; i += BATCH_SIZE) {\\n    const batch = uniqueCommits.slice(i, i + BATCH_SIZE);\\n\\n    let existingRecords;\\n    try {\\n      existingRecords = await db\\n        .selectFrom(\\\"repo_checkpoint_commits\\\")\\n        .selectAll()\\n        .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n        .where(\\\"checkpoint_id\\\", \\\"in\\\", batch.map((c) => c.checkpoint_id))\\n        .execute();\\n    } catch (e) {\\n      syncLog(\\\"fetch_existing_error\\\", { batch: i / BATCH_SIZE + 1, error: String(e) });\\n      continue;\\n    }\\n\\n    const existingMap = new Map(existingRecords.map((row) => [`${row.checkpoint_id}:${row.branch}`, row]));\\n\\n    for (const c of batch) {\\n      const existing = existingMap.get(`${c.checkpoint_id}:${c.branch}`);\\n      const values = {\\n        id: existing?.id ?? generateId(),\\n        repo_id: repoId,\\n        checkpoint_id: c.checkpoint_id,\\n        branch: c.branch,\\n        commit_sha: c.commit_sha ?? existing?.commit_sha ?? null,\\n        commit_message: c.commit_message ?? existing?.commit_message ?? null,\\n        commit_author: c.commit_author ?? existing?.commit_author ?? null,\\n        commit_author_username: c.commit_author_username ?? existing?.commit_author_username ?? null,\\n        commit_author_github_id: c.commit_author_github_id ?? existing?.commit_author_github_id ?? null,\\n        commit_date: c.commit_date ? new Date(c.commit_date) : existing?.commit_date ?? null,\\n        additions: c.additions ?? existing?.additions ?? 0,\\n        deletions: c.deletions ?? existing?.deletions ?? 0,\\n        files_changed: c.files_changed ?? existing?.files_changed ?? 0,\\n        file_stats: JSON.stringify(c.file_stats ?? existing?.file_stats ?? null) as unknown as string,\\n        synced_at: new Date(now),\\n      };\\n\\n      try {\\n        await db\\n          .insertInto(\\\"repo_checkpoint_commits\\\")\\n          .values(values)\\n          .onDuplicateKeyUpdate({\\n            commit_sha: values.commit_sha,\\n            commit_message: values.commit_message,\\n            commit_author: values.commit_author,\\n            commit_author_username: values.commit_author_username,\\n            commit_author_github_id: values.commit_author_github_id,\\n            commit_date: values.commit_date,\\n            additions: values.additions,\\n            deletions: values.deletions,\\n            files_changed: values.files_changed,\\n            file_stats: values.file_stats,\\n            synced_at: values.synced_at,\\n          })\\n          .execute();\\n        successCount++;\\n      } catch (e) {\\n        syncLog(\\\"upsert_commit_error\\\", { checkpoint_id: c.checkpoint_id, branch: c.branch, error: String(e) });\\n        continue;\\n      }\\n    }\\n  }\\n\\n  return successCount;\\n}\\n\\nexport async function updateRepoSyncState(\\n  db: Kysely<DB>,\\n  repoId: string,\\n  options: {\\n    cursor?: string;\\n    backfilled?: boolean;\\n    resetBackfill?: boolean;\\n    error?: string;\\n  },\\n): Promise<void> {\\n  const now = new Date();\\n\\n  if (options.error) {\\n    await db\\n      .updateTable(\\\"repos\\\")\\n      .set({\\n        checkpoints_sync_error: options.error,\\n        checkpoints_sync_error_at: now,\\n        updated_at: now,\\n      })\\n      .where(\\\"id\\\", \\\"=\\\", repoId)\\n      .execute();\\n    return;\\n  }\\n\\n  const updates: Record<string, unknown> = {\\n    checkpoints_last_synced_at: now,\\n    checkpoints_sync_error: null,\\n    checkpoints_sync_error_at: null,\\n    updated_at: now,\\n  };\\n\\n  if (options.cursor) {\\n    updates.checkpoints_sync_cursor = options.cursor;\\n  }\\n\\n  if (options.backfilled) {\\n    updates.checkpoints_backfilled_at = now;\\n  }\\n\\n  // Force a full re-backfill on the next sync (e.g., after force push)\\n  if (options.resetBackfill) {\\n    updates.checkpoints_backfilled_at = null;\\n    updates.checkpoints_sync_cursor = null;\\n  }\\n\\n  await db\\n    .updateTable(\\\"repos\\\")\\n    .set(updates)\\n    .where(\\\"id\\\", \\\"=\\\", repoId)\\n    .execute();\\n}\\n\\n// --- Namespace Factory ---\\n\\nexport function createCheckpointsNamespace(db: Kysely<DB>): CheckpointsNamespace {\\n  return {\\n    // Query\\n    getForBranch: (repoId, branch, options) => getCheckpointsForBranch(db, repoId, branch, options),\\n    countForBranch: async (repoId, branch) => {\\n      const result = await db\\n        .selectFrom(\\\"repo_checkpoint_commits\\\")\\n        .select(db.fn.countAll().as(\\\"count\\\"))\\n        .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n        .where(\\\"branch\\\", \\\"=\\\", branch)\\n  