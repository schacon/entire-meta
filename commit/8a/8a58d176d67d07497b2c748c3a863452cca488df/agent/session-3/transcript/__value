 .where(\\\"cc.id\\\", \\\"in\\\", dedupedIds.map((r) => r.id))\\n    .execute();\\n\\n  // Restore input checkpointIds order (trail detail expects checkpoints.json order)\\n  const rowByCheckpointId = new Map(commitRows.map((r) => [r.checkpoint_id, r]));\\n  const sorted = checkpointIds\\n    .map((cpId) => rowByCheckpointId.get(cpId))\\n    .filter(Boolean) as typeof commitRows;\\n\\n  return sorted.map((row) => ({\\n    checkpoint_id: row.checkpoint_id,\\n    branch: row.branch,\\n    prompt: row.prompt ?? null,\\n    agent: row.agent ?? \\\"Claude Code\\\",\\n    steps: row.steps ?? 1,\\n    session_count: row.session_count ?? 1,\\n    strategy: row.strategy ?? null,\\n    created_at: dateToStr(row.created_at),\\n    commit_sha: row.commit_sha,\\n    commit_message: row.commit_message,\\n    commit_author: row.commit_author,\\n    commit_author_username: row.commit_author_username,\\n    commit_date: dateToStr(row.commit_date),\\n    additions: row.additions ?? 0,\\n    deletions: row.deletions ?? 0,\\n    files_changed: row.files_changed ?? 0,\\n    files_touched: (row.files_touched as string[] | null) ?? [],\\n    file_stats: (row.file_stats as FileStats[] | null) ?? null,\\n    input_tokens: row.input_tokens ?? null,\\n    cache_creation_tokens: row.cache_creation_tokens ?? null,\\n    cache_read_tokens: row.cache_read_tokens ?? null,\\n    output_tokens: row.output_tokens ?? null,\\n    api_call_count: row.api_call_count ?? null,\\n    attribution_agent_lines: row.attribution_agent_lines ?? null,\\n    attribution_human_added: row.attribution_human_added ?? null,\\n    attribution_human_modified: row.attribution_human_modified ?? null,\\n    attribution_human_removed: row.attribution_human_removed ?? null,\\n    attribution_total_committed: row.attribution_total_committed ?? null,\\n    attribution_agent_percentage: row.attribution_agent_percentage ?? null,\\n    attribution_calculated_at: dateToStr(row.attribution_calculated_at),\\n  }));\\n}\\n\\n// --- Up