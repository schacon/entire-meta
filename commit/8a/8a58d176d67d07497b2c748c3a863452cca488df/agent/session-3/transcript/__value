T return 401 if missing.\\n    11→// Used for repo-specific routes that serve public repos without auth.\\n    12→// Skips CSRF check since these routes are read-only (GET only).\\n    13→export async function optionalAuth(\\n    14→  c: Context<{ Bindings: Env; Variables: Variables }>,\\n    15→  next: Next\\n    16→): Promise<Response | void> {\\n    17→  const sessionToken = getCookie(c, \\\"session\\\");\\n    18→\\n    19→  if (sessionToken) {\\n    20→    try {\\n    21→      const session = await getSession(c.env.ENTIRE_CACHE, sessionToken);\\n    22→      if (session) {\\n    23→        c.set(\\\"userId\\\", session.userId);\\n    24→      }\\n    25→    } catch {\\n    26→      // KV transient error — degrade to unauthenticated rather than crashing\\n    27→    }\\n    28→  }\\n    29→\\n    30→  // No 401 — proceed with or without userId\\n    31→  await next();\\n    32→}\\n    33→\\n    34→// Rate limit unauthenticated requests (IP-based, 60 req/min via KV)\\n    35→const RATE_LIMIT_WINDOW_SECONDS = 60;\\n    36→const RATE_LIMIT_MAX_REQUESTS = 60;\\n    37→\\n    38→export async function rateLimitUnauthenticated(\\n    39→  c: Context<{ Bindings: Env; Variables: Variables }>,\\n    40→  next: Next\\n    41→): Promise<Response | void> {\\n    42→  // Skip rate limiting for authenticated users\\n    43→  const userId = c.get(\\\"userId\\\");\\n    44→  if (userId) {\\n    45→    await next();\\n    46→    return;\\n    47→  }\\n    48→\\n    49→  const ip = c.req.header(\\\"cf-connecting-ip\\\") || \\\"unknown\\\";\\n    50→  // Use a time-bucketed key so the counter resets each window without TTL drift.\\n    51→  const bucket = Math.floor(Date.now() / 1000 / RATE_LIMIT_WINDOW_SECONDS);\\n    52→  const key = `ratelimit:${ip}:${bucket}`;\\n    53→\\n    54→  const current = await c.env.ENTIRE_CACHE.get<number>(key, \\\"json\\\");\\n    55→  const count = current ?? 0;\\n    56→\\n    57→  if (count >= RATE_LIMIT_MAX_REQUESTS) {\\n    58→    return c.json({ error: \\\"Rate limit exceeded\\\" }, 429);\\n    59→  }\\n    60→\\n    61→  // Increment counter with TTL for cleanup (2x window to ensure availability)\\n    62→  await c.env.ENTIRE_CACHE.put(key, JSON.stringify(count + 1), {\\n    63→    expirationTtl: RATE_LIMIT_WINDOW_SECONDS * 2,\\n    64→  });\\n    65→\\n    66→  await next();\\n    67→}\\n    68→\\n    69→// Require authentication middleware\\n    70→// Also validates CSRF double-submit token for state-changing methods\\n    71→export async function requireAuth(\\n    72→  c: Context<{ Bindings: Env; Variables: Variables }>,\\n    73→  next: Next\\n    74→): Promise<Response | void> {\\n    75→  const sessionToken = getCookie(c, \\\"session\\\");\\n    76→\\n    77→  if (!sessionToken) {\\n    78→    return c.json({ error: \\\"Not authenticated\\\" }, 401);\\n    79→  }\\n    80→\\n    81→  const session = await getSession(c.env.ENTIRE_CACHE, sessionToken);\\n    82→\\n    83→  if (!session) {\\n    84→    return c.json({ error: \\\"Session expired\\\" }, 401);\\n    85→  }\\n    86→\\n    87→  // CSRF check for state-changing methods\\n    88→  const method = c.req.method;\\n    89→  if (\\n    90→    method === \\\"POST\\\" ||\\n    91→    method === \\\"PUT\\\" ||\\n    92→    method === \\\"DELETE\\\" ||\\n    93→    method === \\\"PATCH\\\"\\n    94→  ) {\\n    95→    const csrfCookie = getCookie(c, \\\"csrf\\\");\\n    96→    const csrfHeader = c.req.header(\\\"X-CSRF-Token\\\");\\n    97→\\n    98→    let csrfFailureReason: string | null = null;\\n    99→    if (!csrfCookie && !csrfHeader) {\\n   100→      csrfFailureReason = \\\"missing_both\\\";\\n   101→    } else if (!csrfCookie) {\\n   102→      csrfFailureReason = \\\"missing_cookie\\\";\\n   103→    } else if (!csrfHeader) {\\n   104→      csrfFailureReason = \\\"missing_header\\\";\\n   105→    } else if (!(await timingSafeEqual(csrfCookie, csrfHeader))) {\\n   106→      csrfFailureReason = \\\"mismatch\\\";\\n   107→    }\\n   108→\\n   1