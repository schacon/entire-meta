po: string | null;\\n    43→  withTranscripts: boolean;\\n    44→  dryRun: boolean;\\n    45→  limit: number | null;\\n    46→}\\n    47→\\n    48→function parseArgs(): CliOptions {\\n    49→  const args = process.argv.slice(2);\\n    50→  const options: CliOptions = {\\n    51→    repo: null,\\n    52→    withTranscripts: false,\\n    53→    dryRun: false,\\n    54→    limit: null,\\n    55→  };\\n    56→\\n    57→  for (let i = 0; i < args.length; i++) {\\n    58→    switch (args[i]) {\\n    59→      case \\\"--repo\\\":\\n    60→        options.repo = args[++i];\\n    61→        if (!options.repo) {\\n    62→          console.error(\\\"Error: --repo requires a value (e.g., 'entireio/cli')\\\");\\n    63→          process.exit(1);\\n    64→        }\\n    65→        break;\\n    66→      case \\\"--with-transcripts\\\":\\n    67→        options.withTranscripts = true;\\n    68→        break;\\n    69→      case \\\"--dry-run\\\":\\n    70→        options.dryRun = true;\\n    71→        break;\\n    72→      case \\\"--limit\\\":\\n    73→        options.limit = parseInt(args[++i], 10);\\n    74→        if (isNaN(options.limit) || options.limit <= 0) {\\n    75→          console.error(\\\"Error: --limit requires a positive integer\\\");\\n    76→          process.exit(1);\\n    77→        }\\n    78→        break;\\n    79→      default:\\n    80→        console.error(`Unknown option: ${args[i]}`);\\n    81→        console.error(\\\"Usage: npx tsx scripts/backfill-search.ts [--repo <name>] [--with-transcripts] [--dry-run] [--limit <n>]\\\");\\n    82→        process.exit(1);\\n    83→    }\\n    84→  }\\n    85→\\n    86→  return options;\\n    87→}\\n    88→\\n    89→// --- Database Setup ---\\n    90→\\n    91→function createDb(): Kysely<DB> {\\n    92→  const url = process.env.DATABASE_URL ?? \\\"mysql://entire:entire@localhost:3306/entire\\\";\\n    93→  const parsed = new URL(url);\\n    94→  const isLocalhost = parsed.hostname === \\\"localhost\\\" || parsed.