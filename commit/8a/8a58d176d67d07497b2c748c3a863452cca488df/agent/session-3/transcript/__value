RANCH } from \\\"../lib/constants\\\";\\n    29→import { requireAuth, optionalAuth, rateLimitUnauthenticated } from \\\"../lib/middleware\\\";\\n    30→\\n    31→const VALID_PRIORITIES: TrailPriority[] = [\\\"urgent\\\", \\\"high\\\", \\\"medium\\\", \\\"low\\\", \\\"none\\\"];\\n    32→const VALID_TYPES: TrailType[] = [\\\"bug\\\", \\\"feature\\\", \\\"chore\\\", \\\"docs\\\", \\\"refactor\\\"];\\n    33→import {\\n    34→  fetchUserReposWithForks,\\n    35→  fetchUserContributions,\\n    36→  fetchUserFollowers,\\n    37→  fetchUserStarred,\\n    38→  fetchUserWatched,\\n    39→  fetchUserPRs,\\n    40→  fetchRepoCommits,\\n    41→  getPermissionLevel,\\n    42→  fetchFileAtCommit,\\n    43→  checkBranchExists,\\n    44→  fetchInstallationRepos,\\n    45→  fetchUserInstallations,\\n    46→  isValidCheckpointId,\\n    47→  isValidBranchName,\\n    48→  discoverTrailsFromBranch,\\n    49→  fetchTrailDataBatch,\\n    50→  generateTrailId,\\n    51→  generateCommentId,\\n    52→  createBranchIfNotExists,\\n    53→  commitTrailFiles,\\n    54→  updateTrailDiscussion,\\n    55→  updateTrailMetadata,\\n    56→  isValidTrailId,\\n    57→} from \\\"../lib/github\\\";\\n    58→import { getValidGitHubTokenFromContext, getInstallationToken } from \\\"../lib/token\\\";\\n    59→import { getDb } from \\\"../lib/db\\\";\\n    60→import type { Db } from \\\"../lib/db/db-types\\\";\\n    61→import type {\\n    62→  GitHubRepoData,\\n    63→  Repo,\\n    64→} from \\\"../lib/db/repos\\\";\\n    65→import type { CheckpointWithCommit } from \\\"../lib/db/checkpoints\\\";\\n    66→import type { GitHubPRData } from \\\"../lib/db/prs\\\";\\n    67→import { isSyncInProgress } from \\\"../lib/sync-service\\\";\\n    68→import { runInBackground } from \\\"../lib/context\\\";\\n    69→import { adminRoutes } from \\\"./admin\\\";\\n    70→\\n    71→/** Map a DB checkpoint row to the API CheckpointInfo shape */\\n    72→function mapCheckpointToInfo(row: CheckpointWithCommit): CheckpointInfo {\\n    73→  return {\\n    74→    commitSha: row.commit_sha,\\n    75→    commitMessage: row.commit_message,\\n    76→    commitAuthor: row.commit_author,\\n    77→    commitAuthorUsername: row.commit_author_username,\\n    78→    commitDate: row.commit_date,\\n    79→    additions: row.additions,\\n    80→    deletions: row.deletions,\\n    81→    filesChanged: row.files_changed,\\n    82→    filesTouched: row.files_touched,\\n    83→    fileStats: row.file_stats,\\n    84→    checkpointId: row.checkpoint_id,\\n    85→    createdAt: row.created_at ?? new Date().toISOString(),\\n    86→    sessions: [\\n    87→      {\\n    88→        prompt: row.prompt,\\n    89→        agent: row.agent ?? \\\"Claude Code\\\",\\n    90→        steps: row.steps ?? 1,\\n    91→      },\\n    92→    ],\\n    93→    sessionCount: row.session_count ?? 1,\\n    94→    totalSteps: row.steps ?? 1,\\n    95→    agents: [row.agent ?? \\\"Claude Code\\\"],\\n    96→    inputTokens: row.input_tokens,\\n    97→    cacheCreationTokens: row.cache_creation_tokens,\\n    98→    cacheReadTokens: row.cache_read_tokens,\\n    99→    outputTokens: row.output_tokens,\\n   100→    apiCallCount: row.api_call_count,\\n   101→    attribution:\\n   102→      row.attribution_calculated_at != null\\n   103→        ? {\\n   104→          calculatedAt: row.attribution_calculated_at,\\n   105→          agentLines: row.attribution_agent_lines ?? 0,\\n   106→          humanAdded: row.attribution_human_added ?? 0,\\n   107→          humanModified: row.attribution_human_modified ?? 0,\\n   108→          humanRemoved: row.attribution_human_removed ?? 0,\\n   109→          totalCommitted: row.attribution_total_committed ?? 0,\\n   110→          agentPercentage: row.attribution_agent_percentage ?? 0,\\n   111→        }\\n   112→        : null,\\n   113→  };\\n   114→}\\n   115→\\n   116→export const cacheRoutes = new Hono<{ Bindings: Env; Variables: Variables }>();\\n   117→\\n   118→// User-specific routes — require authentication (applied per-route to avoid\\n   119→// Hono middleware bleeding when both sub-routers are mounted at the same path)\\n   120→const userRoutes = new Hono<{ Bindings: Env; Variables: Variables }>();\\n   121→\\n   122→// Repo-specific routes — auth optional (public repos accessible without login)\\n   123→// Middleware applied per-route for the same reason as above.\\n   124→const repoRoutes = new Hono<{ Bindings: Env; Variables: Variables }>();\\n   125→\\n   126→// Mount admin routes under /admin/* — apply requireAuth before admin's own guard\\n   127→userRoutes.use(\\\"/admin\\\", requireAuth);\\n   128→userRoutes.use(\\\"/admin/*\\\", requireAuth);\\n   129→userRoutes.route(\\\"/admin\\\", adminRoutes);\\n   130→\\n   131→// Detect GitHub 401 errors so we can tell the frontend to re-authenticate\\n   132→// rather than showing a generic 500 error.\\n   133→// GitHub lib throws errors in two formats:\\n   134→//   \\\"GitHub API error: 401\\\" / \\\"GitHub GraphQL error: 401\\\"\\n   135→//   \\\"Failed to fetch <thing>: 401\\\"\\n   136→function isGitHubAuthError(err: unknown): boolean {\\n   137→  if (!(err instanceof Error)) return false;\\n   138→  return /: 401$/.test(err.message);\\n   139→}\\n   140→\\n   141→// Helper to check repo access. Returns repo record if user has access.\\n   142→// Returns null if repo doesn't exist (and requireRepo is false).\\n   143→// Returns 404 response if unauthorized OR repo required but missing.\\n   144→// Using 404 for unauthorized prevents fishing for private repo existence.\\n   145→//\\n   146→// When userId is undefined (unauthenticated), only public repos are returned.\\n   147→type RepoRecord = Repo;\\n   148→\\n   149→async function checkRepoAccess(\\n   150→  db: Db,\\n   151→  repoFullName: string,\\n   152→  userId: string | undefined,\\n   153→  options: { requireRepo: true },\\n   154→): Promise<RepoRecord | Response>;\\n   155→async function checkRepoAccess(\\n   156→  db: Db,\\n   157→  repoFullName: string,\\n   158→  userId: string | undefined,\\n   159→  options?: { requireRepo?: false },\\n   160→): Promise<RepoRecord | null | Response>;\\n   161→async function checkRepoAccess(\\n   162→  db: Db,\\n   163→  repoFullName: string,\\n   164→  userId: string | undefined,\\n   165→  options: { requireRepo?: boolean } = {},\\n   166→): Promise<RepoRecord | null | Response> {\\n   167→  if (userId) {\\n   168→    // Authenticated: check user_repos join (existing behavior)\\n   169→    const result = await db.repos.getByFullNameWithAccess(repoFullName, userId);\\n   170→\\n   171→    if (result.status === \\\"found\\\") {\\n   172→      return result.repo;\\n   173→    }\\n   174→\\n   175→    if (result.status === \\\"not_found\\\") {\\n   176→      if (options.requireRepo) {\\n   177→        return new Response(JSON.stringify({ error: \\\"Repository not found\\\" }), {\\n   178→          status: 404,\\n   179→          headers: { \\\"Content-Type\\\": \\\"application/json\\\" },\\n   180→        });\\n   181→      }\\n   182→      return null;\\n   183→    }\\n   184→\\n   185→    // status === \\\"no_access\\\"\\n   186→    // Fall back to public repo access for authenticated users too.\\n   187→    // This ensures signed-in users can view public repos they don't explicitly own.\\n   188→    const publicRepo = await db.repos.getPublicByFullName(repoFullName);\\n   189→    if (publicRepo) return publicRepo;\\n   190→\\n   191→    // Private repo with no access: return 404 to prevent repo fishing.\\n   192→    return new Response(JSON.stringify({ error: \\\"Repository not found\\\" }), {\\n   193→      status: 404,\\n   194→      headers: { \\\"Content-Type\\\": \\\"application/json\\\" },\\n   195→    });\\n   196→  }\\n   197→\\n   198→  // Unauthenticated: only serve public repos (hardcoded is_private = false)\\n   199→  const repo = await db.repos.getPublicByFullName(repoFullName);\\n   200→  if (!repo) {\\n   201→    if (options.requireRepo) {\\n   202→      return new Response(JSON.stringify({ error: \\\"Repository not found\\\" }), {\\n   203→        status: 404,\\n   204→        headers: { \\\"Content-Type\\\": \\\"application/json\\\" },\\n   205→      });\\n   206→    }\\n   207→    return null;\\n   208→  }\\n   209→  return repo;\\n   210→}\\n   211→\\n   212→async function getInstallationTokenForRepo(\\n   213→  db: Db,\\n   214→  env: Env,\\n   215→  repo: RepoRecord | null,\\n   216→): Promise<string | undefined> {\\n   217→  if (!repo?.installation_id) return undefined;\\n   218→\\n   219→  const githubInstallationId = await db.installations.getGithubId(repo.installation_id);\\n   220→  if (!githubInstallationId) return undefined;\\n   221→\\n   222→  try {\\n   223→    return await getInstallationToken(\\n   224→      githubInstallationId,\\n   225→      { appId: env.GITHUB_CLIENT_ID, privateKey: env.GITHUB_APP_PRIVATE_KEY },\\n   226→      env.ENTIRE_CACHE,\\n   227→    );\\n   228→  } catch {\\n   229→    return undefined;\\n   230→  }\\n   231→}\\n   232→\\n   233→interface RepoRequestTokenResult {\\n   234→  token: string | null;\\n   235→  response?: Response;\\n   236→}\\n   237→\\n   238→async function getGitHubTokenForRepoRequest(\\n   239→  c: Context<{ Bindings: Env; Variables: Variables }>,\\n   240→  db: Db,\\n   241→  userId: string | undefined,\\n   242→  repo: RepoRecord | null,\\n   243→): Promise<RepoRequestTokenResult> {\\n   244→  if (userId) {\\n   245→    const user = await db.users.getWithCache(c.env.ENTIRE_CACHE, userId);\\n   246→    if (!user) {\\n   247→      return {\\n   248→        token: null,\\n   249→        response: new Response(JSON.stringify({ error: \\\"User not found\\\" }), {\\n   250→          status: 404,\\n   251→          headers: { \\\"Content-Type\\\": \\\"application/json\\\" },\\n   252→        }),\\n   253→      };\\n   254→    }\\n   255→\\n   256→    if (user.github_token_enc) {\\n   257→      const result = await getValidGitHubTokenFromContext(c, db, 