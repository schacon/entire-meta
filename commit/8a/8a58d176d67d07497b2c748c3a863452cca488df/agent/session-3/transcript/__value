   2→ * Backfill script: Index checkpoints into Turbopuffer for full-text + semantic search.\\n     3→ *\\n     4→ * Usage:\\n     5→ *   npx tsx scripts/backfill-search.ts [options]\\n     6→ *\\n     7→ * Options:\\n     8→ *   --repo <full_name>     Only backfill a specific repo (e.g., \\\"entireio/cli\\\")\\n     9→ *   --with-transcripts     Fetch transcript excerpts from GitHub (slower, needs GITHUB_TOKEN)\\n    10→ *   --dry-run              Show what would be indexed without writing to Turbopuffer\\n    11→ *   --limit <n>            Max checkpoints per repo (for testing)\\n    12→ *\\n    13→ * Environment:\\n    14→ *   DATABASE_URL           MySQL connection string (defaults to local Docker MySQL)\\n    15→ *   TURBOPUFFER_API_KEY    Turbopuffer API key (required unless --dry-run)\\n    16→ *   OPENAI_API_KEY         OpenAI API key for embeddings (required unless --dry-run)\\n    17→ *   GITHUB_TOKEN           GitHub PAT with repo read access (required for --with-transcripts)\\n    18→ */\\n    19→\\n    20→import { Kysely, MysqlDialect } from \\\"kysely\\\";\\n    21→import { createPool } from \\\"mysql2\\\";\\n    22→import type { DB } from \\\"../db/types\\\";\\n    23→import { Turbopuffer } from \\\"@turbopuffer/turbopuffer\\\";\\n    24→import type { Vector } from \\\"@turbopuffer/turbopuffer\\\";\\n    25→import OpenAI from \\\"openai\\\";\\n    26→import { getParserForAgent } from \\\"../src/lib/transcript-parsers/registry\\\";\\n    27→\\n    28→// --- Config ---\\n    29→\\n    30→const EMBEDDING_MODEL = \\\"text-embedding-3-small\\\";\\n    31→const EMBEDDING_DIMENSIONS = 1536;\\n    32→const EMBEDDING_BATCH_SIZE = 50;\\n    33→const TURBOPUFFER_UPSERT_BATCH_SIZE = 50;\\n    34→const CHECKPOINT_BRANCH = \\\"entire/checkpoints/v1\\\";\\n    35→const GITHUB_API = \\\"https://api.github.com\\\";\\n    36→const TRANSCRIPT_DELAY_MS = 200; // delay between GitHub API calls to avoid rate limiting\\n    37→const MAX_TRANSCRIPT_CHARS = 2000;\\n    38→\\n