e,\\n          created_at: cp.created_at,\\n          commit_sha: cp.commit_sha,\\n          commit_message: cp.commit_message,\\n          prompt: cp.prompt,\\n          files_touched: cp.files_touched_str,\\n          text: nonEmptyTexts[textIdx],\\n        },\\n      };\\n    });\\n\\n    await ns.upsert({\\n      vectors,\\n      distance_metric: \\\"cosine_distance\\\",\\n    });\\n\\n    if (i + TURBOPUFFER_UPSERT_BATCH_SIZE < nonEmptyIndices.length) {\\n      console.log(`    Upserted ${Math.min(i + TURBOPUFFER_UPSERT_BATCH_SIZE, nonEmptyIndices.length)}/${nonEmptyIndices.length}`);\\n    }\\n  }\\n\\n  const elapsed = ((Date.now() - start) / 1000).toFixed(1);\\n  console.log(`  Done: ${nonEmptyIndices.length} indexed, ${skipped} skipped (${elapsed}s)`);\\n\\n  return { indexed: nonEmptyIndices.length, skipped };\\n}\\n\\n// --- Main ---\\n\\nasync function main() {\\n  const options = parseArgs();\\n\\n  // Validate env vars\\n  if (!options.dryRun) {\\n    if (!process.env.TURBOPUFFER_API_KEY) {\\n      console.error(\\\"Error: TURBOPUFFER_API_KEY is required (or use --dry-run)\\\");\\n      process.exit(1);\\n    }\\n    if (!process.env.OPENAI_API_KEY) {\\n      console.error(\\\"Error: OPENAI_API_KEY is required (or use --dry-run)\\\");\\n      process.exit(1);\\n    }\\n  }\\n\\n  if (options.withTranscripts && !process.env.GITHUB_TOKEN) {\\n    console.error(\\\"Error: GITHUB_TOKEN is required when using --with-transcripts\\\");\\n    process.exit(1);\\n  }\\n\\n  const db = createDb();\\n\\n  const tpuf = new Turbopuffer({\\n    apiKey: process.env.TURBOPUFFER_API_KEY ?? \\\"\\\",\\n  });\\n\\n  const openai = new OpenAI({\\n    apiKey: process.env.OPENAI_API_KEY ?? \\\"\\\",\\n  });\\n\\n  console.log(\\\"Backfill Search Index\\\");\\n  console.log(\\\"=====================\\\");\\n  if (options.dryRun) console.log(\\\"[DRY RUN MODE]\\\");\\n  if (options.repo) console.log(`Repo filter: ${options.repo}`);\\n  if (options.limit) console.log(`Limit: ${