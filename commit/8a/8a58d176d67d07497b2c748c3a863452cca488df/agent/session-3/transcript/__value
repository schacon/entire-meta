rId (uses KV cache)\\n  1007→    const db = getDb(c.env);\\n  1008→    const user = await db.users.getWithCache(c.env.ENTIRE_CACHE, userId);\\n  1009→    if (!user) {\\n  1010→      return c.json({ error: \\\"User not found\\\" }, 404);\\n  1011→    }\\n  1012→\\n  1013→    // Check if any repos with app access are still pending initial checkpoint sync\\n  1014→    const pendingSyncCount = await db.repos.countPendingSync(userId);\\n  1015→\\n  1016→    const syncing = (pendingSyncCount ?? 0) > 0;\\n  1017→\\n  1018→    const checkpoints = await db.checkpoints.getByUser(\\n  1019→      userId,\\n  1020→      user.github_id,\\n  1021→      startDate.toISOString(),\\n  1022→      endDate.toISOString(),\\n  1023→      limit,\\n  1024→    );\\n  1025→\\n  1026→    return c.json({\\n  1027→      checkpoints,\\n  1028→      timeframe,\\n  1029→      updated_at: new Date().toISOString(),\\n  1030→      syncing,\\n  1031→    });\\n  1032→  } catch (err) {\\n  1033→    console.error(\\\"Failed to fetch user checkpoints:\\\", err);\\n  1034→    recordSpanError(err);\\n  1035→    return c.json({ error: \\\"Failed to fetch checkpoints\\\" }, 500);\\n  1036→  }\\n  1037→});\\n  1038→\\n  1039→// Get cached checkpoint activity for repos\\n  1040→userRoutes.get(\\\"/activity\\\", requireAuth, async (c) => {\\n  1041→  const userId = c.get(\\\"userId\\\");\\n  1042→\\n  1043→  try {\\n  1044→    // Compute activity by aggregating checkpoint commits\\n  1045→    const db = getDb(c.env);\\n  1046→    const activity = await db.checkpoints.getActivityForUser(userId);\\n  1047→\\n  1048→    return c.json({\\n  1049→      activity,\\n  1050→      updated_at: new Date().toISOString(),\\n  1051→    });\\n  1052→  } catch (err) {\\n  1053→    console.error(\\\"Failed to fetch checkpoint activity:\\\", err);\\n  1054→    recordSpanError(err);\\n  1055→    return c.json({ error: \\\"Failed to fetch checkpoint activity\\\" }, 500);\\n  1056→  }\\n  1057→});\\n  1058→\\n  1059→// Get cached comm