y_synced_at),\\n   189→    created_at: repoRow.created_at.toISOString(),\\n   190→    updated_at: repoRow.updated_at.toISOString(),\\n   191→  };\\n   192→\\n   193→  // Step 2: Get checkpoints for this branch\\n   194→  const checkpoints = await getCheckpointsForBranch(db, repoRow.id, branch, { limit });\\n   195→\\n   196→  return { repo, checkpoints };\\n   197→}\\n   198→\\n   199→export async function getBranchesWithCheckpoints(\\n   200→  db: Kysely<DB>,\\n   201→  repoId: string,\\n   202→): Promise<Array<{ branch: string; checkpoint_count: number }>> {\\n   203→  // Kysely GROUP BY\\n   204→  const rows = await db\\n   205→    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n   206→    .select([\\\"branch\\\", db.fn.countAll<number>().as(\\\"checkpoint_count\\\")])\\n   207→    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n   208→    .groupBy(\\\"branch\\\")\\n   209→    .orderBy(\\\"checkpoint_count\\\", \\\"desc\\\")\\n   210→    .execute();\\n   211→\\n   212→  return rows.map((row) => ({\\n   213→    branch: row.branch,\\n   214→    checkpoint_count: row.checkpoint_count,\\n   215→  }));\\n   216→}\\n   217→\\n   218→export async function branchHasCheckpointCommits(\\n   219→  db: Kysely<DB>,\\n   220→  repoId: string,\\n   221→  branch: string,\\n   222→): Promise<boolean> {\\n   223→  const row = await db\\n   224→    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n   225→    .select(\\\"id\\\")\\n   226→    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n   227→    .where(\\\"branch\\\", \\\"=\\\", branch)\\n   228→    .limit(1)\\n   229→    .executeTakeFirst();\\n   230→\\n   231→  return !!row;\\n   232→}\\n   233→\\n   234→export async function findCheckpointById(\\n   235→  db: Kysely<DB>,\\n   236→  repoId: string,\\n   237→  checkpointId: string,\\n   238→  defaultBranch: string = \\\"main\\\",\\n   239→): Promise<CheckpointLocation | null> {\\n   240→  // Query 1: Get all commits for this checkpoint across all branches\\n   241→  const commits = await