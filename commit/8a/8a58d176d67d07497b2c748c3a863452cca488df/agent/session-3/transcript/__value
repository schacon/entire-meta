"originalFile\":\"/**\\n * Backfill script: Index checkpoints into Turbopuffer for full-text + semantic search.\\n *\\n * Usage:\\n *   npx tsx scripts/backfill-search.ts [options]\\n *\\n * Options:\\n *   --repo <full_name>     Only backfill a specific repo (e.g., \\\"entireio/cli\\\")\\n *   --with-transcripts     Fetch transcript excerpts from GitHub (slower, needs GITHUB_TOKEN)\\n *   --dry-run              Show what would be indexed without writing to Turbopuffer\\n *   --limit <n>            Max checkpoints per repo (for testing)\\n *\\n * Environment:\\n *   DATABASE_URL           MySQL connection string (defaults to local Docker MySQL)\\n *   TURBOPUFFER_API_KEY    Turbopuffer API key (required unless --dry-run)\\n *   OPENAI_API_KEY         OpenAI API key for embeddings (required unless --dry-run)\\n *   GITHUB_TOKEN           GitHub PAT with repo read access (required for --with-transcripts)\\n */\\n\\nimport { Kysely, MysqlDialect } from \\\"kysely\\\";\\nimport { createPool } from \\\"mysql2\\\";\\nimport type { DB } from \\\"../db/types\\\";\\nimport { Turbopuffer } from \\\"@turbopuffer/turbopuffer\\\";\\nimport type { Vector } from \\\"@turbopuffer/turbopuffer\\\";\\nimport OpenAI from \\\"openai\\\";\\nimport { getParserForAgent } from \\\"../src/lib/transcript-parsers/registry\\\";\\n\\n// --- Config ---\\n\\nconst EMBEDDING_MODEL = \\\"text-embedding-3-small\\\";\\nconst EMBEDDING_DIMENSIONS = 1536;\\nconst CHUNK_SIZE = 50; // process checkpoints in chunks of 50 (fetch transcripts + embed + upsert per chunk)\\nconst CHECKPOINT_BRANCH = \\\"entire/checkpoints/v1\\\";\\nconst GITHUB_API = \\\"https://api.github.com\\\";\\nconst TRANSCRIPT_DELAY_MS = 100; // delay between GitHub API calls to avoid rate limiting\\nconst MAX_TRANSCRIPT_CHARS = 2000;\\nconst MAX_ATTRIBUTE_BYTES = 3800; // Turbopuffer limit is 4096, leave headroom\\nconst MAX_RETRIES = 3;\\nconst RETRY_BASE_DELAY_MS = 1000;\\n\\n// --- CLI Argument Parsing ---\\n\\ninterface CliOptions {\\n  repo: string | null;\\n  withTranscripts: boolean;\\n  dryRun: boolean;\\n  limit: number | null;\\n}\\n\\nfunction parseArgs(): CliOptions {\\n  const args = process.argv.slice(2);\\n  const options: CliOptions = {\\n    repo: null,\\n    withTranscripts: false,\\n    dryRun: false,\\n    limit: null,\\n  };\\n\\n  for (let i = 0; i < args.length; i++) {\\n    switch (args[i]) {\\n      case \\\"--repo\\\":\\n        options.repo = args[++i];\\n        if (!options.repo) {\\n          console.error(\\\"Error: --repo requires a value (e.g., 'entireio/cli')\\\");\\n          process.exit(1);\\n        }\\n        break;\\n      case \\\"--with-transcripts\\\":\\n        options.withTranscripts = true;\\n        break;\\n      case \\\"--dry-run\\\":\\n        options.dryRun = true;\\n        break;\\n      case \\\"--limit\\\":\\n        options.limit = parseInt(args[++i], 10);\\n        if (isNaN(options.limit) || options.limit <= 0) {\\n          console.error(\\\"Error: --limit requires a positive integer\\\");\\n          process.exit(1);\\n        }\\n        break;\\n      default:\\n        console.error(`Unknown option: ${args[i]}`);\\n        console.error(\\\"Usage: npx tsx scripts/backfill-search.ts [--repo <name>] [--with-transcripts] [--dry-run] [--limit <n>]\\\");\\n        process.exit(1);\\n    }\\n  }\\n\\n  return options;\\n}\\n\\n// --- Database Setup ---\\n\\nfunction createDb(): Kysely<DB> {\\n  const url = process.env.DATABASE_URL ?? \\\"mysql://entire:entire@localhost:3306/entire\\\";\\n  const parsed = new URL(url);\\n  const isLocalhost = parsed.hostname === \\\"localhost\\\" || parsed.hostname === \\\"127.0.0.1\\\";\\n\\n  return new Kysely<DB>({\\n    dialect: new MysqlDialect({\\n      pool: createPool({\\n        host: parsed.hostname,\\n        port: Number(parsed.port) || 3306,\\n        user: decodeURIComponent(parsed.username),\\n        password: decodeURIComponent(parsed.password),\\n        database: parsed.pathname.replace(\\\"/\\\", \\\"\\\"),\\n        ssl: isLocalhost ? undefined : { rejectUnauthorized: true },\\n      }),\\n    }),\\n  });\\n}\\n\\n// --- Text Construction ---\\n\\nfunction buildSearchText(\\n  checkpoint: CheckpointRow,\\n  transcriptExcerpt?: string,\\n): string {\\n  const parts: string[] = [];\\n\\n  if (checkpoint.prompt) {\\n    parts.push(`Prompt: ${checkpoint.prompt}`);\\n  }\\n  if (checkpoint.commit_message) {\\n    parts.push(`Commit: ${checkpoint.commit_message}`);\\n  }\\n  if (checkpoint.files_touched_str) {\\n    parts.push(`Files: ${checkpoint.files_touched_str}`);\\n  }\\n  if (transcriptExcerpt) {\\n    parts.push(`Transcript: ${transcriptExcerpt}`);\\n  }\\n\\n  return parts.join(\\\"\\\\n\\\");\\n}\\n\\n// --- Embedding Generation ---\\n\\nasync function generateEmbeddings(\\n  openai: OpenAI,\\n  texts: string[],\\n): Promise<number[][]> {\\n  const response = await openai.embeddings.create({\\n    model: EMBEDDING_MODEL,\\n    input: texts,\\n    dimensions: EMBEDDING_DIMENSIONS,\\n  });\\n\\n  // Sort by index to maintain order\\n  return response.data\\n    .sort((a, b) => a.index - b.index)\\n    .map((item) => item.embedding);\\n}\\n\\n// --- Attribute Truncation ---\\n\\nfunction truncateToBytes(str: string | null, maxBytes: number): string | null {\\n  if (str === null) return null;\\n  // Fast path: ASCII strings where 1 char = 1 byte\\n  if (str.length <= maxBytes) return str;\\n  // Truncate by encoding to bytes\\n  const encoder = new TextEncoder();\\n  const encoded = encoder.encode(str);\\n  if (encoded.length <= maxBytes) return str;\\n  // Find the last valid UTF-8 boundary within maxBytes\\n  const truncated = encoded.slice(0, maxBytes);\\n  const decoder = new TextDecoder(\\\"utf-8\\\", { fatal: false });\\n  return decoder.decode(truncated);\\n}\\n\\n// --- Fetch with Retry ---\\n\\nasync function fetchWithRetry(\\n  url: string,\\n  options: RequestInit,\\n): Promise<Response> {\\n  for (let attempt = 0; attempt < MAX_RETRIES; attempt++) {\\n    try {\\n      const response = await fetch(url, options);\\n      // Retry on transient server errors and rate limits\\n      if (response.status >= 500 || response.status === 429) {\\n        if (attempt < MAX_RETRIES - 1) {\\n          const delay = RETRY_BASE_DELAY_MS * Math.pow(2, attempt);\\n          await sleep(delay);\\n          continue;\\n        }\\n      }\\n      return response;\\n    } catch (err) {\\n      if (attempt < MAX_RETRIES - 1) {\\n        const delay = RETRY_BASE_DELAY_MS * Math.pow(2, attempt);\\n        await sleep(delay);\\n        continue;\\n      }\\n      throw err;\\n    }\\n  }\\n  throw new Error(\\\"fetchWithRetry: exhausted retries\\\");\\n}\\n\\n// --- Transcript Fetching ---\\n\\nasync function fetchTranscriptExcerpt(\\n  repoFullName: string,\\n  checkpointId: string,\\n  agent: string,\\n  token: string,\\n): Promise<string | null> {\\n  const folder = `${checkpointId.slice(0, 2)}/${checkpointId.slice(2)}`;\\n  const path = `${folder}/0/full.jsonl`;\\n\\n  // Encode each path segment individually (preserves / separators)\\n  const encodedPath = path.split(\\\"/\\\").map(encodeURIComponent).join(\\\"/\\\");\\n  const url = `${GITHUB_API}/repos/${repoFullName}/contents/${encodedPath}?ref=${CHECKPOINT_BRANCH}`;\\n\\n  try {\\n    const response = await fetchWithRetry(url, {\\n      headers: {\\n        Accept: \\\"application/vnd.github.raw+json\\\",\\n        Authorization: `Bearer ${token}`,\\n        \\\"User-Agent\\\": \\\"entire-backfill\\\",\\n        \\\"X-GitHub-Api-Version\\\": \\\"2022-11-28\\\",\\n      },\\n    });\\n\\n    if (!response.ok) {\\n      if (response.status === 404) {\\n        return null;\\n      }\\n      return null;\\n    }\\n\\n    const content = await response.text();\\n\\n    const parser = getParserForAgent(agent);\\n    const result = parser.parse(content);\\n\\n    if (result.messages.length === 0) {\\n      return null;\\n    }\\n\\n    // Extract first user message +