s: ${reposResponse.status} - ${errorText}` },\\n   576→        500\\n   577→      );\\n   578→    }\\n   579→\\n   580→    const data = await reposResponse.json<{\\n   581→      total_count: number;\\n   582→      repositories: Array<{ id: number; full_name: string; private?: boolean; default_branch?: string }>;\\n   583→    }>();\\n   584→\\n   585→    allRepos.push(...data.repositories);\\n   586→\\n   587→    if (allRepos.length >= data.total_count || data.repositories.length === 0) {\\n   588→      break;\\n   589→    }\\n   590→    page++;\\n   591→  }\\n   592→\\n   593→  const db = getDb(c.env);\\n   594→\\n   595→  // Step 4: Upsert the installation record\\n   596→  const installationUuid = await db.installations.upsert({\\n   597→    github_installation_id: installationId,\\n   598→    account_login: installationData.account.login,\\n   599→    account_type: installationData.account.type,\\n   600→    account_id: installationData.account.id,\\n   601→    app_slug: installationData.app_slug ?? null,\\n   602→    suspended_at: null,\\n   603→  });\\n   604→\\n   605→  // Step 5: Batch upsert all repos with app_has_access=true\\n   606→  const repoIds = await db.repos.upsertBatch(\\n   607→    allRepos.map((repo) => ({\\n   608→      github_id: repo.id,\\n   609→      full_name: repo.full_name,\\n   610→      app_has_access: true,\\n   611→      installation_id: installationUuid,\\n   612→      default_branch: repo.default_branch,\\n   613→      is_private: repo.private,\\n   614→    }))\\n   615→  );\\n   616→\\n   617→  // Step 6: Queue repos for checkpoint sync if queue is available\\n   618→  let reposQueued = 0;\\n   619→  try {\\n   620→    if (c.env.REPO_SYNC_QUEUE) {\\n   621→      reposQueued = await queueRepoSyncBatch(\\n   622→        c.env.REPO_SYNC_QUEUE,\\n   623→        repoIds.map((id) => ({ id })),\\n   624→        \\\"installation\\\",\\n   625→        10\\n   626→      );\\n   627→    }\\n   628→  } catch (err) {\\n   629→    console.error(