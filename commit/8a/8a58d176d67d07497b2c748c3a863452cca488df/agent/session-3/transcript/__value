b/transcript-parsers/registry\\\";\\n\\n// --- Config ---\\n\\nconst EMBEDDING_MODEL = \\\"text-embedding-3-small\\\";\\nconst EMBEDDING_DIMENSIONS = 1536;\\nconst EMBEDDING_BATCH_SIZE = 50;\\nconst TURBOPUFFER_UPSERT_BATCH_SIZE = 50;\\nconst CHECKPOINT_BRANCH = \\\"entire/checkpoints/v1\\\";\\nconst GITHUB_API = \\\"https://api.github.com\\\";\\nconst TRANSCRIPT_DELAY_MS = 200; // delay between GitHub API calls to avoid rate limiting\\nconst MAX_TRANSCRIPT_CHARS = 2000;\\n\\n// --- CLI Argument Parsing ---\\n\\ninterface CliOptions {\\n  repo: string | null;\\n  withTranscripts: boolean;\\n  dryRun: boolean;\\n  limit: number | null;\\n}\\n\\nfunction parseArgs(): CliOptions {\\n  const args = process.argv.slice(2);\\n  const options: CliOptions = {\\n    repo: null,\\n    withTranscripts: false,\\n    dryRun: false,\\n    limit: null,\\n  };\\n\\n  for (let i = 0; i < args.length; i++) {\\n    switch (args[i]) {\\n      case \\\"--repo\\\":\\n        options.repo = args[++i];\\n        if (!options.repo) {\\n          console.error(\\\"Error: --repo requires a value (e.g., 'entireio/cli')\\\");\\n          process.exit(1);\\n        }\\n        break;\\n      case \\\"--with-transcripts\\\":\\n        options.withTranscripts = true;\\n        break;\\n      case \\\"--dry-run\\\":\\n        options.dryRun = true;\\n        break;\\n      case \\\"--limit\\\":\\n        options.limit = parseInt(args[++i], 10);\\n        if (isNaN(options.limit) || options.limit <= 0) {\\n          console.error(\\\"Error: --limit requires a positive integer\\\");\\n          process.exit(1);\\n        }\\n        break;\\n      default:\\n        console.error(`Unknown option: ${args[i]}`);\\n        console.error(\\\"Usage: npx tsx scripts/backfill-search.ts [--repo <name>] [--with-transcripts] [--dry-run] [--limit <n>]\\\");\\n        process.exit(1);\\n    }\\n  }\\n\\n  return options;\\n}\\n\\n// --- Database Setup ---\\n\\nfunction createDb(): Kysely<DB> {\\n  const url = process.env.DATABASE_URL ?? \\\"mysql://entire:entire@localhost:3306/entire\\\";\\n  const parsed = new URL(url);\\n  const isLocalhost = parsed.hostname === \\\"localhost\\\" || parsed.hostname === \\\"127.0.0.1\\\";\\n\\n  return new Kysely<DB>({\\n    dialect: new MysqlDialect({\\n      pool: createPool({\\n        host: parsed.hostname,\\n        port: Number(parsed.port) || 3306,\\n        user: decodeURIComponent(parsed.username),\\n        password: decodeURIComponent(parsed.password),\\n        database: parsed.pathname.replace(\\\"/\\\", \\\"\\\"),\\n        ssl: isLocalhost ? undefined : { rejectUnauthorized: true },\\n      }),\\n    }),\\n  });\\n}\\n\\n// --- Text Construction ---\\n\\nfunction buildSearchText(\\n  checkpoint: CheckpointRow,\\n  transcriptExcerpt?: string,\\n): string {\\n  const parts: string[] = [];\\n\\n  if (checkpoint.prompt) {\\n    parts.push(`Prompt: ${checkpoint.prompt}`);\\n  }\\n  if (checkpoint.commit_message) {\\n    parts.push(`Commit: ${checkpoint.commit_message}`);\\n  }\\n  if (checkpoint.files_touched_str) {\\n    parts.push(`Files: ${checkpoint.files_touched_str}`);\\n  }\\n  if (transcriptExcerpt) {\\n    parts.push(`Transcript: ${transcriptExcerpt}`);\\n  }\\n\\n  return parts.join(\\\"\\\\n\\\");\\n}\\n\\n// --- Embedding Generation ---\\n\\nasync function generateEmbeddings(\\n  openai: OpenAI,\\n  texts: string[],\\n): Promise<number[][]> {\\n  const response = await openai.embeddings.create({\\n    model: EMBEDDING_MODEL,\\n    input: texts,\\n    dimensions: EMBEDDING_DIMENSIONS,\\n  });\\n\\n  // Sort by index to maintain order\\n  return response.data\\n    .sort((a, b) => a.index - b.index)\\n    .map((item) => item.embedding);\\n}\\n\\n// --- Transcript Fetching ---\\n\\nasync function fetchTranscriptExcerpt(\\n  repoFullName: string,\\n  checkpointId: string,\\n  agent: string,\\n  token: string,\\n): Promise<string | null> {\\n  const folder = `${checkpointId.slice(0, 2)}/${checkpointId.slice(2)}`;\\n  const path = `${folder}/0/full.jsonl`;\\n\\n  // Encode each path segment individually (preserves / separators)\\n  const encodedPath = path.split(\\\"/\\\").map(encodeURIComponent).join(\\\"/\\\");\\n  const url = `${GITHUB_API}/repos/${repoFullName}/contents/${encodedPath}?ref=${CHECKPOINT_BRANCH}`;\\n\\n  const response = await fetch(url, {\\n    headers: {\\n      Accept: \\\"application/vnd.github.raw+json\\\",\\n      Authorization: `Bearer ${token}`,\\n      \\\"User-Agent\\\": \\\"entire-backfill\\\",\\n      \\\"X-GitHub-Api-Version\\\": \\\"2022-11-28\\\",\\n    },\\n  });\\n\\n  if (!response.ok) {\\n    if (response.status === 404) {\\n      return null;\\n    }\\n    console.warn(`  Warning: Failed to fetch transcript for ${checkpointId}: ${response.status}`);\\n    return null;\\n  }\\n\\n  const content = await response.text();\\n\\n  try {\\n    const parser = getParserForAgent(agent);\\n    const result = parser.parse(content);\\n\\n    if (result.messages.length === 0) {\\n      return null;\\n    }\\n\\n    // Extract first user message + first assistant message\\n    const parts: string[] = [];\\n    let charsUsed = 0;\\n\\n    for (const msg of result.messages) {\\n      if (charsUsed >= MAX_TRANSCRIPT_CHARS) break;\\n\\n      const remaining = MAX_TRANSCRIPT_CHARS - charsUsed;\\n      const text = msg.content.slice(0, remaining);\\n      parts.push(`[${msg.role}]: ${text}`);\\n      charsUsed += text.length;\\n\\n      // Only take the first user + first assistant\\n      if (msg.role === \\\"assistant\\\") break;\\n    }\\n\\n    return parts.join(\\\"\\\\n\\\") || null;\\n  } catch {\\n    console.warn(`  Warning: Failed to parse transcript for ${checkpointId}`);\\n    return null;\\n  }\\n}\\n\\nfunction sleep(ms: number): Promise<void> {\\n  return new Promise((resolve) => setTimeout(resolve, ms));\\n}\\n\\n// --- Types ---\\n\\ninterface CheckpointRow {\\n  checkpoint_id: string;\\n  branch: string;\\n  agent: string;\\n  commit_author_username: string | null;\\n  created_at: string | null;\\n  commit_sha: string | null;\\n  commit_message: string | null;\\n  prompt: string | null;\\n  files_touched_str: string | null;\\n}\\n\\ninterface RepoRow {\\n  id: string;\\n  full_name: string;\\n  checkpoint_count: number;\\n}\\n\\n// --- Per-Repo Processing ---\\n\\nasync function fetchCheckpointsForRepo(\\n  db: Kysely<DB>,\\n  repoId: string,\\n  limit: number | null,\\n): Promise<CheckpointRow[]> {\\n  // Use the same deferred-join pattern as getCheckpointsForBranch\\n  let idQuery = db\\n    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n    .select(\\\"id\\\")\\n    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n    .orderBy(\\\"commit_date\\\", \\\"desc\\\");\\n\\n  if (limit) {\\n    idQuery = idQuery.limit(limit);\\n  }\\n\\n  const idRows = await idQuery.execute();\\n  if (idRows.length === 0) return [];\\n\\n  const rows = await db\\n    .selectFrom(\\\"repo_checkpoint_commits as cc\\\")\\n    .leftJoin(\\\"repo_checkpoints as cp\\\", (join) =>\\n      join\\n        .onRef(\\\"cp.repo_id\\\", \\\"=\\\", \\\"cc.repo_id\\\")\\n        .onRef(\\\"cp.checkpoint_id\\\", \\\"=\\\", \\\"cc.checkpoint_id\\\"),\\n    )\\n    .select([\\n      \\\"cc.checkpoint_id\\\",\\n      \\\"cc.branch\\\",\\n      \\\"cc.commit_sha\\\",\\n      \\\"cc.commit_message\\\",\\n      \\\"cc.commit_author_username\\\",\\n      \\\"cc.commit_date\\\",\\n      \\\"cp.prompt\\\",\\n      \\\"cp.agent\\\",\\n      \\\"cp.created_at\\\",\\n      \\\"cp.files_touched\\\",\\n    ])\\n    .where(\\n      \\\"cc.id\\\",\\n      \\\"in\\\",\\n      idRows.map((r) => r.id),\\n    )\\n    .execute();\\n\\n  return rows.map((row) => {\\n    const filesTouched = row.files_touched as string[] | null;\\n    return {\\n      checkpoint_id: row.checkpoint_id,\\n      branch: row.branch,\\n      agent: row.agent ?? \\\"Claude Code\\\",\\n      commit_author_username: row.commit_author_username,\\n      created_at: row.created_at?.toISOString() ?? row.commit_date?.toISOString() ?? null,\\n      commit_sha: row.commit_sha,\\n      commit_message: row.commit_message,\\n      prompt: row.prompt,\\n      files_touched_str: filesTouched?.join(\\\", \\\") ?? null,\\n    };\\n  });\\n}\\n\\nasync function processRepo(\\n  db: Kysely<DB>,\\n  tpuf: Turbopuffer,\\n  openai: OpenAI,\\n  repo: RepoRow,\\n  options: CliOptions,\\n): Promise<{ indexed: number; skipped: number }> {\\n  const start = Date.now();\\n  console.log(`\\\\nProcessing ${repo.full_name} (${repo.checkpoint_count} checkpoints)...`);\\n\\n  const checkpoints = await fetchCheckpointsForRepo(db, repo.id, options.limit);\\n  if (checkpoints.length === 0) {\\n    console.log(`  No checkpoint commits found, skipping.`);\\n    return { indexed: 0, skipped: 0 };\\n  }\\n\\n  console.log(`  Fetched ${checkpoints.length} checkpoint rows from DB.`);\\n\\n  const githubToken = process.env.GITHUB_TOKEN;\\n\\n  // Build text fields (with optional transcript excerpts)\\n  const texts: string[] = [];\\n  let skipped = 0;\\n\\n  for (let i = 0; i < checkpoints.length; i++) {\\n    const cp = checkpoints[i];\\n    let transcriptExcerpt: string | undefined;\\n\\n    if (options.withTranscripts && githubToken) {\\n      transcriptExcerpt =\\n        (await fetchTranscriptExcerpt(repo.full_name, cp.checkpoint_id, cp.agent, githubToken)) ??\\n        undefined;\\n      // Rate limit GitHub API calls\\n      if (i < checkpoints.length - 1) {\\n        await sleep(TRANSCRIPT_DELAY_MS);\\n      }\\n    }\\n\\n    const text = buildSearchText(cp, transcriptExcerpt);\\n    if (!text.trim()) {\\n      skipped++;\\n      texts.push(\\\"\\\"); // placeholder to maintain index alignment\\n      continue;\\n    }\\n\\n    texts.push(text);\\n  }\\n\\n  // Filter out empty texts for embedding, but keep index mapping\\n  const nonEmptyIndices = texts.map((t, i) => (t.trim() ? i : -1)).filter((i) => i >= 0);\\n  const nonEmptyTexts = nonEmptyIndices.map((i) => texts[i]);\\n\\n  if (nonEmptyTexts.length === 0) {\\n    console.log(`  All checkpoints had empty text, skipping.`);\\n    return { indexed: 0, skipped };\\n  }\\n\\n  if (options.dryRun) {\\n    console.log(`  [DRY RUN] Would index ${nonEmptyTexts.length} checkpoints.`);\\n    for (let i = 0; i < Math.min(3, nonEmptyTexts.length); i++) {\\n      const idx = nonEmptyIndices[i];\\n      const cp = checkpoints[idx];\\n      console.log(`    - ${cp.checkpoint_id}: ${nonEmptyTexts[i].slice(0, 120)}...`);\\n    }\\n    return { indexed: nonEmptyTexts.length, skipped };\\n  }\\n\\n  // Generate embeddings in batches\\n  console.log(`  Generating embeddings for ${nonEmptyTexts.length} checkpoints...`);\\n  const allEmbeddings: number[][] = [];\\n\\n  for (let i = 0; i < nonEmptyTexts.length; i += EMBEDDING_BATCH_SIZE) {\\n    const batch = nonEmptyTexts.slice(i, i + EMBEDDING_BATCH_SIZE);\\n    const embeddings = await generateEmbeddings(openai, batch);\\n    allEmbeddings.push(...embeddings);\\n\\n    if (i + EMBEDDING_BATCH_SIZE < nonEmptyTexts.length) {\\n      console.log(`    Embedded ${Math.min(i + EMBEDDING_BATCH_SIZE, nonEmptyTexts.length)}/${nonEmptyTexts.length}`);\\n    }\\n  }\\n\\n  // Upsert to Turbopuffer in batches\\n  const ns = tpuf.namespace(`checkpoints-${repo.id}`);\\n  console.log(`  Upserting to Turbopuffer namespace checkpoints-${repo.id}...`);\\n\\n  for (let i = 0; i < nonEmptyIndices.length; i += TURBOPUFFER_UPSERT_BATCH_SIZE) {\\n    const batchIndices = nonEmptyIndices.slice(i, i + TURBOPUFFER_UPSERT_BATCH_SIZE);\\n    const batchEmbeddings = allEmbeddings.slice(i, i + TURBOPUFFER_UPSERT_BATCH_SIZE);\\n\\n    const vectors: Vector[] = batchIndices.map((cpIdx, j) => {\\n      const cp = checkpoints[cpIdx];\\n      const textIdx = nonEmptyIndices.indexOf(cpIdx);\\n\\n      return {\\n        id: i + j + 1, // 1-based auto-incrementing ID within namespace\\n        vector: batchEmbeddings[j],\\n        attributes: {\\n          checkpoint_id: cp.checkpoint_id,\\n          branch: cp.branch,\\n          agent: cp.agent,\\n          author: cp.commit_author_username,\\n          created_at: cp.created_at,\\n          commit_sha: cp.commit_sha,\\n          commit_message: cp.commit_message,\\n          prompt: cp.prompt,\\n          files_touched: cp.files_touched_str,\\n          text: nonEmptyTexts[textIdx],\\n        },\\n      };\\n    });\\n\\n    await ns.upsert({\\n      vectors,\\n      distance_metric: \\\"cosine_distance\\\",\\n    });\\n\\n    if (i + TURBOPUFFER_UPSERT_BATCH_SIZE < nonEmptyIndices.length) {\\n      console.log(`    Upserted ${Math.min(i + TURBOPUFFER_UPSERT_BATCH_SIZE, nonEmptyIndices.length)}/${nonEmptyIndices.length}`);\\n    }\\n  }\\n\\n  const elapsed = ((Date.now() - start) / 1000).toFixed(1);\\n  console.log(`  Done: ${nonEmptyIndices.length} indexed, ${skipped} skipped (${elapsed}s)`);\\n\\n  return { indexed: nonEmptyIndices.length, skipped };\\n}\\n\\n// --- Main ---\\n\\nasync function main() {\\n  const options = parseArgs();\\n\\n  // Validate env vars\\n  if (!options.dryRun) {\\n    if (!process.env.TURBOPUFFER_API_KEY) {\\n      console.error(\\\"Error: TURBOPUFFER_API_KEY is required (or use --dry-run)\\\");\\n      process.exit(1);\\n    }\\n    if (!process.env.OPENAI_API_KEY) {\\n      console.error(\\\"Error: OPENAI_API_KEY is required (or use --dry-run)\\\");\\n      process.exit(1);\\n    }\\n  }\\n\\n  if (options.withTranscripts && !process.env.GITHUB_TOKEN) {\\n    console.error(\\\"Error: GITHUB_TOKEN is required when using --with-transcripts\\\");\\n    process.exit(1);\\n  }\\n\\n  const db = createDb();\\n\\n  const tpuf = new Turbopuffer({\\n    apiKey: process.env.TURBOPUFFER_API_KEY ?? \\\"\\\",\\n  });\\n\\n  const openai = new OpenAI({\\n    apiKey: process.env.OPENAI_API_KEY ?? \\\"\\\",\\n  });\\n\\n  console.log(\\\"Backfill Search Index\\\");\\n  console.log(\\\"=====================\\\");\\n  if (options.dryRun) console.log(\\\"[DRY RUN MODE]\\\");\\n  if (options.repo) console.log(`Repo filter: ${options.repo}`);\\n  if (options.limit) console.log(`Limit: ${options.limit} checkpoints per repo`);\\n  if (options.withTranscripts) console.log(\\\"Transcript fetching: enabled\\\");\\n\\n  // Fetch repos with checkpoints\\n  let repoQuery = db\\n    .selectFrom(\\\"repos\\\")\\n    .select([\\\"id\\\", \\\"full_name\\\", \\\"checkpoint_count\\\"])\\n    .where(\\\"checkpoint_count\\\", \\\">\\\", 0);\\n\\n  if (options.repo) {\\n    repoQuery = repoQuery.where(\\\"full_name\\\", \\\"=\\\", options.repo);\\n  }\\n\\n  const repos = (await repoQuery.execute()) as RepoRow[];\\n\\n  if (repos.length === 0) {\\n    console.log(\\\"\\\\nNo repos with checkpoints found.\\\");\\n    await db.destroy();\\n    return;\\n  }\\n\\n  console.log(`\\\\nFound ${repos.length} repo(s) with checkpoints.`);\\n\\n  // Process each repo\\n  let totalIndexed = 0;\\n  let totalSkipped = 0;\\n\\n  for (const repo of repos) {\\n    try {\\n      const result = await processRepo(db, tpuf, openai, repo, options);\\n      totalIndexed += result.indexed;\\n      totalSkipped += result.skipped;\\n    } catch (err) {\\n      console.error(`\\\\nError processing ${repo.full_name}:`, err);\\n      console.error(\\\"Continuing with next repo...\\\");\\n    }\\n  }\\n\\n  // Summary\\n  console.log(\\\"\\\\n=====================\\\");\\n  console.log(\\\"Summary:\\\");\\n  console.log(`  Repos processed: ${repos.length}`);\\n  console.log(`  Checkpoints indexed: ${totalIndexed}`);\\n  console.log(`  Checkpoints skipped: ${totalSkipped}`);\\n\\n  await db.destroy();\\n}\\n\\nmain();\\n\",\"numLines\":516,\"startLine\":1,\"totalLines\":516}},\"sourceToolAssistantUUID\":\"211e46b6-afa1-4c3f-ab45-d20681be614c\"}\n{\"parentUuid\":\"d6772828-d42c-4afb-94f5-040d9c19d046\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/evisdrenova/code/entire/devenv/cli\",\"sessionId\":\"504a5988-0478-439b-bb41-a58eeaef723a\",\"version\":\"2.1.56\",\"gitBranch\":\"main\",\