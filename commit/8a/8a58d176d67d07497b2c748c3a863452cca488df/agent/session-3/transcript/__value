 new URL(url);\\n    94→  const isLocalhost = parsed.hostname === \\\"localhost\\\" || parsed.hostname === \\\"127.0.0.1\\\";\\n    95→\\n    96→  return new Kysely<DB>({\\n    97→    dialect: new MysqlDialect({\\n    98→      pool: createPool({\\n    99→        host: parsed.hostname,\\n   100→        port: Number(parsed.port) || 3306,\\n   101→        user: decodeURIComponent(parsed.username),\\n   102→        password: decodeURIComponent(parsed.password),\\n   103→        database: parsed.pathname.replace(\\\"/\\\", \\\"\\\"),\\n   104→        ssl: isLocalhost ? undefined : { rejectUnauthorized: true },\\n   105→      }),\\n   106→    }),\\n   107→  });\\n   108→}\\n   109→\\n   110→// --- Text Construction ---\\n   111→\\n   112→function buildSearchText(\\n   113→  checkpoint: CheckpointRow,\\n   114→  transcriptExcerpt?: string,\\n   115→): string {\\n   116→  const parts: string[] = [];\\n   117→\\n   118→  if (checkpoint.prompt) {\\n   119→    parts.push(`Prompt: ${checkpoint.prompt}`);\\n   120→  }\\n   121→  if (checkpoint.commit_message) {\\n   122→    parts.push(`Commit: ${checkpoint.commit_message}`);\\n   123→  }\\n   124→  if (checkpoint.files_touched_str) {\\n   125→    parts.push(`Files: ${checkpoint.files_touched_str}`);\\n   126→  }\\n   127→  if (transcriptExcerpt) {\\n   128→    parts.push(`Transcript: ${transcriptExcerpt}`);\\n   129→  }\\n   130→\\n   131→  return parts.join(\\\"\\\\n\\\");\\n   132→}\\n   133→\\n   134→// --- Embedding Generation ---\\n   135→\\n   136→async function generateEmbeddings(\\n   137→  openai: OpenAI,\\n   138→  texts: string[],\\n   139→): Promise<number[][]> {\\n   140→  const response = await openai.embeddings.create({\\n   141→    model: EMBEDDING_MODEL,\\n   142→    input: texts,\\n   143→    dimensions: EMBEDDING_DIMENSIONS,\\n   144→  });\\n   145→\\n   146→  // Sort by index to maintain order\\n   147→  return response.data\\n   148→    .sort((a, b) => a.index - b.index)\\n   149→    .map((item) => item.embe