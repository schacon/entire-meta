ata,\\n  CommitWebhookData,\\n  UserCheckpoint,\\n  RepoCommitActivity,\\n} from \\\"../db/checkpoints\\\";\\nimport type { CheckpointsNamespace } from \\\"../db/db-types\\\";\\nimport type { Repo } from \\\"../db/repos\\\";\\nimport { dateToStr, toBool } from \\\"./row-helpers\\\";\\n\\nconst LOG_PREFIX = \\\"[db-checkpoints]\\\";\\nconst BATCH_SIZE = 50;\\n\\n// --- Checkpoint Functions ---\\n\\nexport async function getCheckpointsForBranch(\\n  db: Kysely<DB>,\\n  repoId: string,\\n  branch: string,\\n  options: { limit?: number } = {},\\n): Promise<CheckpointWithCommit[]> {\\n  const { limit = 100 } = options;\\n\\n  // Deferred join: sort/limit on IDs only to avoid \\\"Out of sort memory\\\" on large JSON columns.\\n  // PlanetScale's sort buffer can't hold file_stats blobs for many rows during ORDER BY.\\n  const idRows = await db\\n    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n    .select(\\\"id\\\")\\n    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n    .where(\\\"branch\\\", \\\"=\\\", branch)\\n    .orderBy(\\\"commit_date\\\", \\\"desc\\\")\\n    .limit(limit)\\n    .execute();\\n\\n  if (idRows.length === 0) return [];\\n\\n  const rows = await db\\n    .selectFrom(\\\"repo_checkpoint_commits as cc\\\")\\n    .leftJoin(\\\"repo_checkpoints as cp\\\", (join) =>\\n      join\\n        .onRef(\\\"cp.repo_id\\\", \\\"=\\\", \\\"cc.repo_id\\\")\\n        .onRef(\\\"cp.checkpoint_id\\\", \\\"=\\\", \\\"cc.checkpoint_id\\\"),\\n    )\\n    .select([\\n      \\\"cc.id\\\",\\n      \\\"cc.checkpoint_id\\\",\\n      \\\"cc.branch\\\",\\n      \\\"cc.commit_sha\\\",\\n      \\\"cc.commit_message\\\",\\n      \\\"cc.commit_author\\\",\\n      \\\"cc.commit_author_username\\\",\\n      \\\"cc.commit_date\\\",\\n      \\\"cc.additions\\\",\\n      \\\"cc.deletions\\\",\\n      \\\"cc.files_changed\\\",\\n      \\\"cc.file_stats\\\",\\n      \\\"cp.prompt\\\",\\n      \\\"cp.agent\\\",\\n      \\\"cp.steps\\\",\\n      \\\"cp.session_count\\\",\\n      \\\"cp.strategy\\\",\\n      \\\"cp.created_at\\\",\\n      \\\"cp.files_touched\\\",\\n      \\\"cp.input_tokens\\\",\\n      \\\"cp.cache_creation_tokens\\\",\\n      \\\"cp.cache_read_tokens\\\",\\n      \\\"cp.output_tokens\\\",\\n      \\\"cp.api_call_count\\\",\\n      \\\"cp.attribution_agent_lines\\\",\\n      \\\"cp.attribution_human_added\\\",\\n      \\\"cp.attribution_human_modified\\\",\\n      \\\"cp.attribution_human_removed\\\",\\n      \\\"cp.attribution_total_committed\\\",\\n      \\\"cp.attribution_agent_percentage\\\",\\n      \\\"cp.attribution_calculated_at\\\",\\n    ])\\n    .where(\\n      \\\"cc.id\\\",\\n      \\\"in\\\",\\n      idRows.map((r) => r.id),\\n    )\\n    .execute();\\n\\n  // Restore sort order from the first query (already sorted by commit_date desc)\\n  // without ORDER BY on the large-row query which causes OOM on the sort buffer.\\n  const rowById = new Map(rows.map((r) => [r.id, r]));\\n  const sorted = idRows.map((r) => rowById.get(r.id)).filter(Boolean) as typeof rows;\\n\\n  return sorted.map((row) => ({\\n    checkpoint_id: row.checkpoint_id,\\n    branch: row.branch,\\n    prompt: row.prompt ?? null,\\n    agent: row.agent ?? \\\"Claude Code\\\",\\n    steps: row.steps ?? 1,\\n    session_count: row.session_count ?? 1,\\n    strategy: row.strategy ?? null,\\n    created_at: dateToStr(row.created_at),\\n    commit_sha: row.commit_sha,\\n    commit_message: row.commit_message,\\n    commit_author: row.commit_author,\\n    commit_author_username: row.commit_author_username,\\n    commit_date: dateToStr(row.commit_date),\\n    additions: row.additions ?? 0,\\n    deletions: row.deletions ?? 0,\\n    files_changed: row.files_changed ?? 0,\\n    files_touched: (row.files_touched as string[] | null) ?? [],\\n    file_stats: (row.file_stats as FileStats[] | null) ?? null,\\n    input_tokens: row.input_tokens ?? null,\\n    cache_creation_tokens: row.cache_creation_tokens ?? null,\\n    cache_read_tokens: row.cache_read_tokens ?? null,\\n    output_tokens: row.output_tokens ?? null,\\n    api_call_count: row.api_call_count ?? null,\\n    attribution_agent_lines: row.attribution_agent_lines ?? null,\\n    attribution_human_added: row.attribution_human_added ?? null,\\n    attribution_human_modified: row.attribution_human_modified ?? null,\\n    attribution_human_removed: row.attribution_human_removed ?? null,\\n    attribution_total_committed: row.attribution_total_committed ?? null,\\n    attribution_agent_percentage: row.attribution_agent_percentage ?? null,\\n    attribution_calculated_at: dateToStr(row.attribution_calculated_at),\\n  }));\\n}\\n\\nexport async function getRepoWithCheckpoints(\\n  db: Kysely<DB>,\\n  repoFullName: string,\\n  userId: string,\\n  branch: string,\\n  limit: number = 100,\\n): Promise<RepoWithCheckpointsResult | null | \\\"no_access\\\"> {\\n  // Step 1: Get the repo with user access check\\n  const repoRow = await db\\n    .selectFrom(\\\"repos\\\")\\n    .innerJoin(\\\"user_repos\\\", (join) =>\\n      join\\n        .onRef(\\\"user_repos.repo_id\\\", \\\"=\\\", \\\"repos.id\\\")\\n        .on(\\\"user_repos.user_id\\\", \\\"=\\\", userId),\\n    )\\n    .selectAll(\\\"repos\\\")\\n    .where(\\\"repos.full_name\\\", \\\"=\\\", repoFullName)\\n    .executeTakeFirst();\\n\\n  if (!repoRow) {\\n    // Distinguish between repo not found vs no access\\n    const repoOnly = await db\\n      .selectFrom(\\\"repos\\\")\\n      .select(\\\"id\\\")\\n      .where(\\\"full_name\\\", \\\"=\\\", repoFullName)\\n      .executeTakeFirst();\\n\\n    return repoOnly ? \\\"no_access\\\" : null;\\n  }\\n\\n  // Convert repo row to Repo type (number→boolean, Date→string)\\n  const repo: Repo = {\\n    id: repoRow.id,\\n    github_id: repoRow.github_id,\\n    full_name: repoRow.full_name,\\n    name: repoRow.name,\\n    description: repoRow.description,\\n    html_url: repoRow.html_url,\\n    language: repoRow.language,\\n    stargazers_count: repoRow.stargazers_count,\\n    is_fork: toBool(repoRow.is_fork),\\n    is_private: toBool(repoRow.is_private),\\n    pushed_at: dateToStr(repoRow.pushed_at),\\n    default_branch: repoRow.default_branch,\\n    app_has_access: toBool(repoRow.app_has_access),\\n    checkpoints_backfilled_at: dateToStr(repoRow.checkpoints_backfilled_at),\\n    checkpoints_last_synced_at: dateToStr(repoRow.checkpoints_last_synced_at),\\n    checkpoints_sync_cursor: repoRow.checkpoints_sync_cursor,\\n    checkpoints_sync_error: repoRow.checkpoints_sync_error,\\n    checkpoints_sync_error_at: dateToStr(repoRow.checkpoints_sync_error_at),\\n    checkpoint_count: repoRow.checkpoint_count,\\n    installation_id: repoRow.installation_id,\\n    activity_weeks: repoRow.activity_weeks,\\n    activity_week_start: repoRow.activity_week_start,\\n    activity_synced_at: dateToStr(repoRow.activity_synced_at),\\n    created_at: repoRow.created_at.toISOString(),\\n    updated_at: repoRow.updated_at.toISOString(),\\n  };\\n\\n  // Step 2: Get checkpoints for this branch\\n  const checkpoints = await getCheckpointsForBranch(db, repoRow.id, branch, { limit });\\n\\n  return { repo, checkpoints };\\n}\\n\\nexport async function getBranchesWithCheckpoints(\\n  db: Kysely<DB>,\\n  repoId: string,\\n): Promise<Array<{ branch: string; checkpoint_count: number }>> {\\n  // Kysely GROUP BY\\n  const rows = await db\\n    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n    .select([\\\"branch\\\", db.fn.countAll<number>().as(\\\"checkpoint_count\\\")])\\n    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n    .groupBy(\\\"branch\\\")\\n    .orderBy(\\\"checkpoint_count\\\", \\\"desc\\\")\\n    .execute();\\n\\n  return rows.map((row) => ({\\n    branch: row.branch,\\n    checkpoint_count: row.checkpoint_count,\\n  }));\\n}\\n\\nexport async function branchHasCheckpointCommits(\\n  db: Kysely<DB>,\\n  repoId: string,\\n  branch: string,\\n): Promise<boolean> {\\n  const row = await db\\n    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n    .select(\\\"id\\\")\\n    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n    .where(\\\"branch\\\", \\\"=\\\", branch)\\n    .limit(1)\\n    .executeTakeFirst();\\n\\n  return !!row;\\n}\\n\\nexport async function findCheckpointById(\\n  db: Kysely<DB>,\\n  repoId: string,\\n  checkpointId: string,\\n  defaultBranch: string = \\\"main\\\",\\n): Promise<CheckpointLocation | null> {\\n  // Query 1: Get all commits for this checkpoint across all branches\\n  const commits = await db\\n    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n    .selectAll()\\n    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n    .where(\\\"checkpoint_id\\\", \\\"=\\\", checkpointId)\\n    .execute();\\n\\n  if (commits.length === 0) return null;\\n\\n  // Query 2: Get checkpoint metadata\\n  const checkpoint = await db\\n    .selectFrom(\\\"repo_checkpoints\\\")\\n    .selectAll()\\n    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n    .where(\\\"checkpoint_id\\\", \\\"=\\\", checkpointId)\\n    .executeTakeFirst();\\n\\n  // Get unique branches\\n  const branches = [...new Set(commits.map((c) => c.branch))];\\n  const onDefaultBranch = branches.includes(defaultBranch) ? defaultBranch : null;\\n\\n  // Pick the best commit: prefer default branch, then source branch, then first\\n  let preferredCommit = commits.find((c) => c.branch === defaultBranch);\\n  if (!preferredCommit && checkpoint?.branch) {\\n    preferredCommit = commits.find((c) => c.branch === checkpoint.branch);\\n  }\\n  if (!preferredCommit) {\\n    preferredCommit = commits[0];\\n  }\\n\\n  const commit: CheckpointWithCommit = {\\n    checkpoint_id: preferredCommit.checkpoint_id,\\n    branch: preferredCommit.branch,\\n    prompt: checkpoint?.prompt ?? null,\\n    agent: checkpoint?.agent ?? \\\"Claude Code\\\",\\n    steps: checkpoint?.steps ?? 1,\\n    session_count: checkpoint?.session_count ?? 1,\\n    strategy: checkpoint?.strategy ?? null,\\n    created_at: dateToStr(checkpoint?.created_at),\\n    commit_sha: preferredCommit.commit_sha,\\n    commit_message: preferredCommit.commit_message,\\n    commit_author: preferredCommit.commit_author,\\n    commit_author_username: preferredCommit.commit_author_username,\\n    commit_date: dateToStr(preferredCommit.commit_date),\\n    additions: preferredCommit.additions,\\n    deletions: preferredCommit.deletions,\\n    files_changed: preferredCommit.files_changed,\\n    files_touched: (checkpoint?.files_touched as string[] | null) ?? [],\\n    file_stats: (preferredCommit.file_stats as FileStats[] | null) ?? null,\\n    input_tokens: checkpoint?.input_tokens ?? null,\\n    cache_creation_tokens: checkpoint?.cache_creation_tokens ?? null,\\n    cache_read_tokens: checkpoint?.cache_read_tokens ?? null,\\n    output_tokens: checkpoint?.output_tokens ?? null,\\n    api_call_count: checkpoint?.api_call_count ?? null,\\n    attribution_agent_lines: checkpoint?.attribution_agent_lines ?? null,\\n    attribution_human_added: checkpoint?.attribution_human_added ?? null,\\n    attribution_human_modified: checkpoint?.attribution_human_modified ?? null,\\n    attribution_human_removed: checkpoint?.attribution_human_removed ?? null,\\n    attribution_total_committed: checkpoint?.attribution_total_committed ?? null,\\n    attribution_agent_percentage: checkpoint?.attribution_agent_percentage ?? null,\\n    attribution_calculated_at: dateToStr(checkpoint?.attribution_calculated_at),\\n  };\\n\\n  return {\\n    checkpoint_id: checkpointId,\\n    branches,\\n    default_branch: onDefaultBranch,\\n    commit,\\n  };\\n}\\n\\nexport async function getCheckpointsByIds(\\n  db: Kysely<DB>,\\n  repoId: string,\\n  checkpointIds: string[],\\n): Promise<CheckpointWithCommit[]> {\\n  if (checkpointIds.length === 0) return [];\\n\\n  // Deferred join: sort/limit on IDs only to avoid \\\"Out of sort memory\\\" on large JSON columns.\\n  const idRows = await db\\n    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n    .select([\\\"id\\\", \\\"checkpoint_id\\\"])\\n    .where(\\\"repo