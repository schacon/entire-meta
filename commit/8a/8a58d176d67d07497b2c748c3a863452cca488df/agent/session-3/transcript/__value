defined;\\n   147→    const message = parsed.message as Record<string, unknown> | undefined;\\n   148→    const timestamp = (parsed.timestamp as string) || new Date().toISOString();\\n   149→\\n   150→    if (type === \\\"assistant\\\" && message?.content) {\\n   151→      // Check for tool_use blocks in assistant messages\\n   152→      const toolUses = extractToolUseBlocks(message.content);\\n   153→      for (const tu of toolUses) {\\n   154→        toolUseById.set(tu.id, {\\n   155→          name: tu.name,\\n   156→          input: tu.input,\\n   157→          timestamp,\\n   158→        });\\n   159→      }\\n   160→    } else if (type === \\\"user\\\" && message?.content) {\\n   161→      // Check for tool_result blocks (they come as \\\"user\\\" type messages)\\n   162→      const content = message.content as unknown[];\\n   163→      if (Array.isArray(content)) {\\n   164→        for (const block of content) {\\n   165→          if (typeof block === \\\"object\\\" && block !== null) {\\n   166→            const b = block as Record<string, unknown>;\\n   167→            if (b.type === \\\"tool_result\\\" && b.tool_use_id) {\\n   168→              const resultMeta = extractToolResultMetadata(parsed);\\n   169→              if (resultMeta) {\\n   170→                toolResultById.set(b.tool_use_id as string, resultMeta);\\n   171→              }\\n   172→            }\\n   173→          }\\n   174→        }\\n   175→      }\\n   176→    }\\n   177→  }\\n   178→\\n   179→  // Second pass: collect messages and track tool calls per turn\\n   180→  const messages: InternalMessage[] = [];\\n   181→  const assistantByRequestId = new Map<string, number>();\\n   182→\\n   183→  // Track tool calls in the current turn (between user messages)\\n   184→  // Key is the index in messages array where we'll eventually attach them\\n   185→  const toolCallsPerTurn: ToolCall[] = [];\\n   186→\\n   187→  for (const line of lines) {\\n   188→    let parsed: Record<string, unknown>;\\n   189→    try {\\n   190→      parsed = JSON.parse(line);\\n   191→    } catch {\\n   192→      continue;\\n   193→    }\\n   194→\\n   195→    const type = parsed.type as string | undefined;\\n   196→    if (type !== \\\"user\\\" && type !== \\\"assistant\\\") continue;\\n   197→\\n   198→    const message = parsed.message as Record<string, unknown> | undefined;\\n   199→    if (!message) continue;\\n   200→\\n   201→    const timestamp = (parsed.timestamp as string) || new Date().toISOString();\\n   202→\\n   203→    if (type === \\\"assistant\\\") {\\n   204→      // Check for tool_use blocks first\\n   205→      const toolUses = extractToolUseBlocks(message.content);\\n   206→      for (const tu of toolUses) {\\n   207→        const toolData = toolUseById.get(tu.id);\\n   208→        if (toolData) {\\n   209→          const toolCall: ToolCall = {\\n   210→            id: tu.id,\\n   211→            name: tu.name,\\n   212→            input: tu.input,\\n   213→            timestamp: toolData.timestamp,\\n   214→            result: toolResultById.get(tu.id),\\n   215→          };\\n   216→          toolCallsPerTurn.push(toolCall);\\n   217→        }\\n   218→      }\\n   219→\\n   220→      // Also extract text content for the message\\n   221→      const { text, images } = extractTextContent(message.content);\\n   222→      const content = text.trim();\\n   223→      const requestId = (parsed.requestId as string) || (message.id as string);\\n   224→      if (!requestId) continue;\\n   225→\\n   226→      const existingIdx = assistantByRequestId.get(requestId);\\n   227→      if (existingIdx !== undefined) {\\n   228→        // Streaming update: replace with latest content\\n   229→        if (content) {\\n   230→          messages[existingIdx].content = content;\\n   231→          messages[existingIdx].timestamp = timestamp;\\n   232→        }\\n   233→        if (images.length > 0) {\\n   234→          messages[existingIdx].images = images;\\n   235→     