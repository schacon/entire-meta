      agent: [],\\n      author: [],\\n      created_at: [],\\n      commit_sha: [],\\n      commit_message: [],\\n      prompt: [],\\n      files_touched: [],\\n      text: [],\\n    };\\n\\n    for (let j = 0; j < batchIndices.length; j++) {\\n      const cpIdx = batchIndices[j];\\n      const cp = checkpoints[cpIdx];\\n\\n      ids.push(i + j + 1); // 1-based auto-incrementing ID within namespace\\n      vectors.push(batchEmbeddings[j]);\\n      (attributes.checkpoint_id as (string | null)[]).push(cp.checkpoint_id);\\n      (attributes.branch as (string | null)[]).push(cp.branch);\\n      (attributes.agent as (string | null)[]).push(cp.agent);\\n      (attributes.author as (string | null)[]).push(cp.commit_author_username);\\n      (attributes.created_at as (string | null)[]).push(cp.created_at);\\n      (attributes.commit_sha as (string | null)[]).push(cp.commit_sha);\\n      (attributes.commit_message as (string | null)[]).push(cp.commit_message);\\n      (attributes.prompt as (string | null)[]).push(cp.prompt);\\n      (attributes.files_touched as (string | null)[]).push(cp.files_touched_str);\\n      (attributes.text as (string | null)[]).push(nonEmptyTexts[nonEmptyIndices.indexOf(cpIdx)]);\\n    }\\n\\n    await ns.upsert({\\n      ids,\\n      vectors,\\n      attributes,\\n    });\\n\\n    if (i + TURBOPUFFER_UPSERT_BATCH_SIZE < nonEmptyIndices.length) {\\n      console.log(`    Upserted ${Math.min(i + TURBOPUFFER_UPSERT_BATCH_SIZE, nonEmptyIndices.length)}/${nonEmptyIndices.length}`);\\n    }\\n  }\\n\\n  const elapsed = ((Date.now() - start) / 1000).toFixed(1);\\n  console.log(`  Done: ${nonEmptyIndices.length} indexed, ${skipped} skipped (${elapsed}s)`);\\n\\n  return { indexed: nonEmptyIndices.length, skipped };\\n}\\n\\n// --- Main ---\\n\\nasync function main() {\\n  const options = parseArgs();\\n\\n  // Validate env vars\\n  if (!options.dryRun) {\\n    if (!process.env.TURBOPUFFER_API_KEY) {\\n      console.error(\\\"Error: TURBOPUFFER_API_KEY is required (or use --dry-run)\\\");\\n      process.exit(1);\\n    }\\n    if (!process.env.OPENAI_API_KEY) {\\n      console.error(\\\"Error: OPENAI_API_KEY is required (or use --dry-run)\\\");\\n      process.exit(1);\\n    }\\n  }\\n\\n  if (options.withTranscripts && !process.env.GITHUB_TOKEN) {\\n    console.error(\\\"Error: GITHUB_TOKEN is required when using --with-transcripts\\\");\\n    process.exit(1);\\n  }\\n\\n  const db = createDb();\\n\\n  const tpuf = new Turbopuffer({\\n    apiKey: process.env.TURBOPUFFER_API_KEY ?? \\\"\\\",\\n  });\\n\\n  const openai = new OpenAI({\\n    apiKey: process.env.OPENAI_API_KEY ?? \\\"\\\",\\n  });\\n\\n  console.log(\\\"Backfill Search Index\\\");\\n  console.log(\\\"=====================\\\");\\n  if (options.dryRun) console.log(\\\"[DRY RUN MODE]\\\");\\n  if (options.repo) console.log(`Repo filter: ${options.repo}`);\\n  if (options.limit) console.log(`Limit: ${options.limit} checkpoints per repo`);\\n  if (options.withTranscripts) console.log(\\\"Transcript fetching: enabled\\\");\\n\\n  // Fetch repos with checkpoints\\n  let repoQuery = db\\n    .selectFrom(\\\"repos\\\")\\n    .select([\\\"id\\\", \\\"full_name\\\", \\\"checkpoint_count\\\"])\\n    .where(\\\"checkpoint_count\\\", \\\">\\\", 0);\\n\\n  if (options.repo) {\\n    repoQuery = repoQuery.where(\\\"full_name\\\", \\\"=\\\", options.repo);\\n  }\\n\\n  const repos = (await repoQuery.execute()) as RepoRow[];\\n\\n  if (repos.length === 0) {\\n    console.log(\\\"\\\\nNo repos with checkpoints found.\\\");\\n    await db.destroy();\\n    return;\\n  }\\n\\n  console.log(`\\\\nFound ${repos.length} repo(s) with checkpoints.`);\\n\\n  // Process each repo\\n  let totalIndexed = 0;\\n  let totalSkipped = 0;\\n\\n  for (const repo of repos) {\\n    try {\\n      const result = await processRepo(db, tpuf, openai, repo, options);\\n      totalIndexed += result.indexed;\\n      totalSkipped += result.skipped;\\n    } catch (err) {\\n      console.error(`\\\\nErr