liveryId: string;\\n  eventType: string;\\n  action: string | null;\\n  repositoryName: string | null;\\n  payload?: string;                  // Inline for small payloads\\n  payloadStoredInKV?: boolean;       // Flag when payload is in KV\\n}\\n```\\n\\n### 2. QUEUE CONSUMER ROUTING\\n\\n**File:** `/Users/evisdrenova/code/entire/devenv/entire.io/api/src/index.ts` (lines 167-287)\\n\\nThe `queue()` handler routes messages by type:\\n```typescript\\n// All three queue types configured in wrangler.jsonc:\\n// - WEBHOOK_QUEUE → partialto-api-webhook-retry (staging)\\n// - REPO_SYNC_QUEUE → partialto-api-repo-checkpoint-sync\\n// - USER_REPO_SYNC_QUEUE → partialto-api-user-repo-sync\\n\\n// Message routing logic:\\nif (isRepoSyncMessage(firstMessage)) {\\n  await processRepoSyncBatch(...)    // Repo checkpoint syncs\\n} else if (isUserRepoSyncMessage(firstMessage)) {\\n  await processUserRepoSyncBatch(...) // User repo syncs\\n} else if (\\\"deliveryId\\\" in firstMessage) {\\n  await processQueueMessage(...)      // Webhook retries\\n}\\n```\\n\\n### 3. CLOUDFLARE QUEUE CONFIGURATION\\n\\n**File:** `/Users/evisdrenova/code/entire/devenv/entire.io/api/wrangler.jsonc`\\n\\n**Queue Bindings (lines 55-91):**\\n```json\\n\\\"queues\\\": {\\n  \\\"producers\\\": [\\n    { \\\"binding\\\": \\\"WEBHOOK_QUEUE\\\", \\\"queue\\\": \\\"partialto-api-webhook-retry\\\" },\\n    { \\\"binding\\\": \\\"REPO_SYNC_QUEUE\\\", \\\"queue\\\": \\\"partialto-api-repo-checkpoint-sync\\\" },\\n    { \\\"binding\\\": \\\"USER_REPO_SYNC_QUEUE\\\", \\\"queue\\\": \\\"partialto-api-user-repo-sync\\\" }\\n  ],\\n  \\\"consumers\\\": [\\n    {\\n      \\\"queue\\\": \\\"partialto-api-webhook-retry\\\",\\n      \\\"max_retries\\\": 5,\\n      \\\"max_batch_size\\\": 10,\\n      \\\"max_batch_timeout\\\": 5\\n    },\\n    {\\n      \\\"queue\\\": \\\"partialto-api-repo-checkpoint-sync\\\",\\n      \\\"max_retries\\\": 3,\\n      \\\"max_batch_size\\\": 5,\\n      \\\"max_batch_timeout\\\": 5,\\n      \\\"max_concurrency\\\": 2 // staging: 2, production: 20\\n    },\\n    {\\n      \\\"queue\\\": \\\"partialto-api-user-repo-sync\\\",\\n      \\\"max_retries\\\": 3,\\n      \\\"max_batch_size\\\": 5,\\n      \\\"max_batch_timeout\\\": 5\\n    }\\n  ]\\n}\\n```\\n\\n### 4. ENV INTERFACE WITH QUEUE BINDINGS\\n\\n**File:** `/Users/evisdrenova/code/entire/devenv/entire.io/api/src/env.ts` (lines 91-124)\\n\\n```typescript\\nexport interface Env {\\n  HYPERDRIVE: Hyperdrive;           // PlanetScale MySQL\\n  ENTIRE_CACHE: KVNamespace;         // Caching\\n  \\n  // Cloudflare Queues (3 queues)\\n  WEBHOOK_QUEUE: Queue;              // Webhook retry queue\\n  REPO_SYNC_QUEUE: Queue;            // Repo checkpoint sync\\n  USER_REPO_SYNC_QUEUE: Queue;       // User repo sync\\n  \\n  // Environment variables & secrets\\n  ENVIRONMENT: string;\\n  FRONTEND_BASE_URL: string;\\n  GITHUB_CLIENT_ID: string;\\n  GITHUB_CLIENT_SECRET: string;\\n  GITHUB_APP_NAME: string;\\n  GITHUB_APP_PRIVATE_KEY: string;\\n  ENCRYPTION_KEY: string;\\n  SESSION_SECRET: string;\\n  GITHUB_WEBHOOK_SECRET: string;\\n  \\n  // Search (optional)\\n  TURBOPUFFER_API_KEY?: string;\\n  OPENAI_API_KEY?: string;\\n  \\n  // OpenTelemetry (optional)\\n  OTEL_EXPORTER_OTLP_ENDPOINT?: string;\\n  OTEL_EXPORTER_OTLP_HEADERS?: string;\\n}\\n```\\n\\n### 5. CHECKPOINT WEBHOOK PROCESSING DETAILS\\n\\n**File:** `/Users/evisdrenova/code/entire/devenv/entire.io/api/src/lib/webhook/queue.ts`\\n\\n**Queue Message Processing Flow:**\\n```typescript\\nprocessQueueMessage(message, attempts, maxRetries, queueWaitMs, db, cache, env)\\n  ↓ idempotency check (cache key: webhook:<deliveryId>)\\n  ↓ resolve payload (inline or from KV)\\n  ↓ parse JSON payload\\n  ↓ call processEvent(eventType, action, payload, db, cache, env)\\n  ↓ mark as processed in cache (24-hour TTL)\\n  ↓ return { result: \\\"ack\\\" | \\\"retry\\\" | \\\"dead-letter\\\" }\\n```\\n\\n### 6. CHECKPOINT UPSERT INTO PLANETSCALE\\n\\n**File:** `/Users/evis