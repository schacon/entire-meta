s(db, repoFullName, userId, {\\n      requireRepo: true,\\n    });\\n    if (repoRecord instanceof Response) return repoRecord;\\n\\n    // Find checkpoint across all branches\\n    const location = await db.checkpoints.findById(repoRecord.id, checkpointId);\\n\\n    if (!location) {\\n      return c.json({ error: \\\"Checkpoint not found\\\" }, 404);\\n    }\\n\\n    // Determine if a redirect is needed\\n    const needsRedirect =\\n      requestedBranch && !location.branches.includes(requestedBranch);\\n\\n    // Suggest redirect to default branch if available, otherwise first available branch\\n    const suggestedBranch = location.default_branch || location.branches[0];\\n\\n    // Transform commit to CheckpointInfo format\\n    const commit = location.commit;\\n    const checkpoint = commit\\n      ? {\\n        commitSha: commit.commit_sha,\\n        commitMessage: commit.commit_message,\\n        commitAuthor: commit.commit_author,\\n        commitAuthorUsername: commit.commit_author_username,\\n        commitDate: commit.commit_date,\\n        additions: commit.additions,\\n        deletions: commit.deletions,\\n        filesChanged: commit.files_changed,\\n        filesTouched: commit.files_touched,\\n        fileStats: commit.file_stats,\\n        checkpointId: commit.checkpoint_id,\\n        createdAt: commit.created_at ?? new Date().toISOString(),\\n        sessions: [\\n          {\\n            prompt: commit.prompt,\\n            agent: commit.agent ?? \\\"Claude Code\\\",\\n            steps: commit.steps ?? 1,\\n          },\\n        ],\\n        sessionCount: commit.session_count ?? 1,\\n        totalSteps: commit.steps ?? 1,\\n        agents: [commit.agent ?? \\\"Claude Code\\\"],\\n        inputTokens: commit.input_tokens,\\n        cacheCreationTokens: commit.cache_creation_tokens,\\n        cacheReadTokens: commit.cache_read_tokens,\\n        outputTokens: commit.output_tokens,\\n        apiCallCount: commit.api_call_count,\\n        attribution:\\n          commit.attribution_calculated_at != null\\n            ? {\\n              calculatedAt: commit.attribution_calculated_at,\\n              agentLines: commit.attribution_agent_lines ?? 0,\\n              humanAdded: commit.attribution_human_added ?? 0,\\n              humanModified: commit.attribution_human_modified ?? 0,\\n              humanRemoved: commit.attribution_human_removed ?? 0,\\n              totalCommitted: commit.attribution_total_committed ?? 0,\\n              agentPercentage: commit.attribution_agent_percentage ?? 0,\\n            }\\n            : null,\\n      }\\n      : null;\\n\\n    return c.json({\\n      checkpoint_id: checkpointId,\\n      branches: location.branches,\\n      default_branch: location.default_branch,\\n      suggested_branch: suggestedBranch,\\n      needs_redirect: needsRedirect,\\n      requested_branch: requestedBranch || null,\\n      checkpoint,\\n      repo_full_name: repoFullName,\\n    });\\n  } catch (err) {\\n    console.error(\\n      `Failed to resolve checkpoint ${checkpointId} for ${repoFullName}:`,\\n      err,\\n    );\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to resolve checkpoint\\\" }, 500);\\n  }\\n});\\n\\nimport { ClaudeCodeParser } from \\\"../lib/transcript-parsers/claude-code-parser\\\";\\n\\nconst _legacyParser = new ClaudeCodeParser();\\n\\n/**\\n * @deprecated Use getParserForAgent() from lib/transcript-parsers instead.\\n * Kept for backward compatibility with existing tests.\\n */\\nexport function parseTranscript(jsonlContent: string): TranscriptMessage[] {\\n  return _legacyParser.parse(jsonlContent).messages;\\n}\\n\\n/**\\n * Filter messages to only include those from this session.\\n * Uses transcriptIdentifierAtStart to find where prior context ends;\\n * messages after that identifier are the \\\"new\\\" messages from this session.\\n */\\nfunction filterRelevantMessages(\\n  messages: TranscriptMessage[],\\n  transcriptIdentifierAtStart: string |