        labels: updatedMetadata.labels,\\n        created_at: updatedMetadata.created_at,\\n        updated_at: updatedMetadata.updated_at,\\n        merged_at: updatedMetadata.merged_at,\\n        priority: updatedMetadata.priority ?? \\\"none\\\",\\n        type: updatedMetadata.type ?? null,\\n        reviewers: updatedMetadata.reviewers ?? [],\\n        comment_count: commentCount,\\n        unresolved_count: unresolvedCount,\\n        checkpoint_count: checkpointCount,\\n      },\\n    });\\n  } catch (err) {\\n    if (isGitHubAuthError(err)) {\\n      return c.json({ error: \\\"GitHub token expired\\\" }, 401);\\n    }\\n    console.error(`Failed to update trail ${trailId}:`, err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to update trail\\\" }, 500);\\n  }\\n});\\n\\n// Get repository collaborators\\nrepoRoutes.get(\\\"/:org/:repo/collaborators\\\", requireAuth, async (c) => {\\n  const userId = c.get(\\\"userId\\\");\\n\\n  const org = c.req.param(\\\"org\\\");\\n  const repo = c.req.param(\\\"repo\\\");\\n  const repoFullName = `${org}/${repo}`;\\n\\n  try {\\n    const db = getDb(c.env);\\n\\n    // Check repo access\\n    const repoAccess = await checkRepoAccess(db, repoFullName, userId, { requireRepo: true });\\n    if (repoAccess instanceof Response) return repoAccess;\\n\\n    const user = await db.users.findById(userId);\\n    if (!user) {\\n      return c.json({ error: \\\"User not found\\\" }, 404);\\n    }\\n\\n    let token: string | undefined;\\n    if (user.github_token_enc) {\\n      const result = await getValidGitHubTokenFromContext(c, db, user);\\n      token = result.token;\\n    }\\n\\n    if (!token) {\\n      return c.json({ error: \\\"GitHub token required\\\" }, 401);\\n    }\\n\\n    // Fetch collaborators from GitHub\\n    const response = await fetch(\\n      `https://api.github.com/repos/${repoFullName}/collaborators?per_page=100`,\\n      {\\n        headers: {\\n          Accept: \\\"application/vnd.github+json\\\",\\n          Authorization: `Bearer ${token}`,\\n          \\\"User-Agent\\\": \\\"entire-api\\\",\\n          \\\"X-GitHub-Api-Version\\\": \\\"2022-11-28\\\",\\n        },\\n      }\\n    );\\n\\n    if (!response.ok) {\\n      // If we don't have permission to list collaborators, return just the current user\\n      if (response.status === 403) {\\n        return c.json({\\n          collaborators: user.github_login ? [{ login: user.github_login }] : [],\\n        });\\n      }\\n      throw new Error(`Failed to fetch collaborators: ${response.status}`);\\n    }\\n\\n    const data = await response.json<Array<{ login: string; avatar_url: string }>>();\\n\\n    return c.json({\\n      collaborators: data.map((c) => ({\\n        login: c.login,\\n        avatar_url: c.avatar_url,\\n      })),\\n    });\\n  } catch (err) {\\n    if (isGitHubAuthError(err)) {\\n      return c.json({ error: \\\"GitHub token expired\\\" }, 401);\\n    }\\n    console.error(`Failed to fetch collaborators for ${repoFullName}:`, err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch collaborators\\\" }, 500);\\n  }\\n});\\n\\n// Search checkpoints using Turbopuffer BM25 full-text search\\nrepoRoutes.get(\\\"/:org/:repo/checkpoints/search\\\", optionalAuth, rateLimitUnauthenticated, async (c) => {\\n  const userId = c.get(\\\"userId\\\") as string | undefined;\\n\\n  const org = c.req.param(\\\"org\\\");\\n  const repo = c.req.param(\\\"repo\\\");\\n  const repoFullName = `${org}/${repo}`;\\n\\n  const query = c.req.query(\\\"q\\\");\\n  const branch = c.req.query(\\\"branch\\\");\\n\\n  if (!query || query.trim().length === 0) {\\n    return c.json({ error: \\\"Query parameter 'q' is required\\\" }, 400);\\n  }\\n\\n  if (branch && !isValidBranchName(branch)) {\\n    return c.json({ error: \\\"Invalid branch name format\\\" }, 400);\\n  }\\n\\n  try {\\n    const apiKey = c.env.TURBOPUFFER_API_KEY;\\n    if (!apiKey) {\\n      return c.json({ error: \\\"Search is not configured\\\" }, 503);\\n    }\\n\\n    const db = getDb(c.env);\\n\\n    const repoAccess = await checkRepoAccess(\\n      db,\\n      repoFullName,\\n      userId,\\n      { requireRepo: true },\\n    );\\n    if (repoAccess instanceof Response) return repoAccess;\\n\\n    const repoRecord = repoAccess;\\n\\n    const searchResults = await searchCheckpoints(\\n      apiKey,\\n      repoRecord.id,\\n      query.trim(),\\n      branch ? { branch } : undefined,\\n    );\\n\\n    if (searchResults.length === 0) {\\n      return c.json({\\n        checkpoints: [],\\n        repo_full_name: repoFullName,\\n        updated_at: new Date().toISOString(),\\n        from_cache: false,\\n        app_has_access: repoRecord.app_has_access ?? null,\\n        session_branch_exists: repoRecord.checkpoints_backfilled_at ? true : null,\\n      });\\n    }\\n\\n    const checkpointIds = searchResults.map((r) => r.checkpoint_id);\\n    const dbCheckpoints = await db.checkpoints.getByIds(repoRecord.id, checkpointIds);\\n\\n    // Preserve Turbopuffer relevance ordering\\n    const byId = new Map(dbCheckpoints.map((row) => [row.checkpoint_id, row]));\\n    const ordered = checkpointIds\\n      .map((id) => byId.get(id))\\n      .filter((row): row is CheckpointWithCommit => row != null);\\n\\n    const checkpoints: CheckpointInfo[] = ordered.map(mapCheckpointToInfo);\\n\\n    return c.json({\\n      checkpoints,\\n      repo_full_name: repoFullName,\\n      updated_at: new Date().toISOString(),\\n      from_cache: false,\\n      app_has_access: repoRecord.app_has_access ?? null,\\n      session_branch_exists: repoRecord.checkpoints_backfilled_at ? true : null,\\n    });\\n  } catch (err) {\\n    if ((err as any)?.status === 404) {\\n      return c.json({ error: (err as Error).message }, 404);\\n    }\\n    if (isGitHubAuthError(err)) {\\n      return c.json({ error: \\\"GitHub token expired\\\" }, 401);\\n    }\\n    console.error(`Failed to search checkpoints for ${repoFullName}:`, err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to search checkpoints\\\" }, 500);\\n  }\\n});\\n\\n// Resolve a checkpoint by ID - finds which branches it exists on\\n// Useful when the original branch has been deleted (e.g., after PR merge)\\n// Returns redirect info if the checkpoint exists on other branches\\nrepoRoutes.get(\\\"/:org/:repo/checkpoints/resolve/:checkpointId\\\", optionalAuth, rateLimitUnauthenticated, async (c) => {\\n  const userId = c.get(\\\"userId\\\") as string | undefined;\\n\\n  const org = c.req.param(\\\"org\\\");\\n  const repo = c.req.param(\\\"repo\\\");\\n  const checkpointId = c.req.param(\\\"checkpointId\\\");\\n  const repoFullName = `${org}/${repo}`;\\n\\n  // Optional: the branch the user originally requested (for determining if redirect needed)\\n  const requestedBranch = c.req.query(\\\"branch\\\");\\n\\n  // Validate branch name format if provided\\n  if (requestedBranch && !isValidBranchName(requestedBranch)) {\\n    return c.json({ error: \\\"Invalid branch name format\\\" }, 400);\\n  }\\n\\n  try {\\n    const db = getDb(c.env);\\n\\n    // Check repo access (returns 404 if unauthorized or repo doesn't exist)\\n    const repoRecord = await checkRepoAccess(db, repoFullName, userId, {\\n      requireRepo: true,\\n    });\\n    if (repoRecord instanceof Response) return repoRecord;\\n\\n    // Find checkpoint across all branches\\n    const location = await db.checkpoints.findById(repoRecord.id, checkpointId);\\n\\n    if (!location) {\\n      return c.json({ error: \\\"Checkpoint not found\\\" }, 404);\\n    }\\n\\n    // Determine if a redirect is needed\\n    const needsRedirect =\\n      requestedBranch && !location.branches.includes(requestedBranch);\\n\\n    // Suggest redirect to default branch if available, otherwise first available branch\\n    const suggestedBranch = location.default_branch || location.branches[0];\\n\\n    // Transform commit to CheckpointInfo format\\n    const commit = location.commit;\\n    const checkpoint = commit\\n      ? {\\n        commitSha: commit.commit_sha,\\n        commitMessage: commit.commit_message,\\n        commitAuthor: commit.commit_author,\\n        commitAuthorUsername: commit.commit_author_username,\\n        commitDate: commit.commit_date,\\n        additions: commit.additions,\\n        deletions: commit.deletions,\\n        filesChanged: commit.files_changed,\\n        filesTouched: commit.files_touched,\\n        fileStats: commit.file_stats,\\n        checkpointId: commit.checkpoint_id,\\n        createdAt: commit.created_at ?? new Date().toISOString(),\\n        sessions: [\\n          {\\n            prompt: commit.prompt,\\n            agent: commit.agent ?? \\\"Claude Code\\\",\\n            steps: commit.steps ?? 1,\\n          },\\n        ],\\n        sessionCount: commit.session_count ?? 1,\\n        totalSteps: commit.steps ?? 1,\\n        agents: [commit.agent ?? \\\"Claude Code\\\"],\\n        inputTokens: commit.input_tokens,\\n        cacheCreationTokens: commit.cache_creation_tokens,\\n        cacheReadTokens: commit.cache_read_tokens,\\n        outputTokens: commit.output_tokens,\\n        apiCallCount: commit.api_call_count,\\n        attribution:\\n          commit.attribution_calculated_at != null\\n            ? {\\n              calculatedAt: commit.attribution_calculated_at,\\n              agentLines: commit.attribution_agent_lines ?? 0,\\n              humanAdded: commit.attribution_human_added ?? 0,\\n              humanModified: commit.attribution_human_modified ?? 0,\\n              humanRemoved: commit.attribution_human_removed ?? 0,\\n              totalCommitted: commit.attribution_total_committed ?? 0,\\n              agentPercentage: commit.attribution_agent_percentage ?? 0,\\n            }\\n            : null,\\n      }\\n      : null;\\n\\n    return c.json({\\n      checkpoint_id: checkpointId,\\n      branches: location.branches,\\n      default_branch: location.default_branch,\\n      suggested_branch: suggestedBranch,\\n      needs_redirect: needsRedirect,\\n      requested_branch: requestedBranch || null,\\n      checkpoint,\\n      repo_full_name: repoFullName,\\n    });\\n  } catch (err) {\\n    console.error(\\n      `Failed to resolve checkpoint ${checkpointId} for ${repoFullName}:`,\\n      err,\\n    );\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to resolve checkpoint\\\" }, 500);\\n  }\\n});\\n\\nimport { ClaudeCodeParser } from \\\"../lib/transcript-parsers/claude-code-parser\\\";\\n\\nconst _legacyParser = new ClaudeCodeParser();\\n\\n/**\\n * @deprecated Use getParserForAgent() from lib/transcript-parsers instead.\\n * Kept for backward compatibility with existing tests.\\n */\\nexport function parseTranscript(jsonlContent: string): TranscriptMessage[] {\\n  return _legacyParser.parse(jsonlContent).messages;\\n}\\n\\n/**\\n * Filter messages to only include those from this session.\\n * Uses transcriptIdentifierAtStart to find where prior context ends;\\n * messages after that identifier are the \\\"new\\\" messages from this session.\\n */\\nfunction filterRelevantMessages(\\n  messages: TranscriptMessage[],\\n  transcriptIdentifierAtStart: string | null,\\n): TranscriptMessage[] {\\n  if (!transcriptIdentifierAtStart) return messages;\\n  const startIndex = messages.findIndex(\\n    (msg) => msg.id === transcriptIdentifierAtStart,\\n  );\\n  if (startIndex === -1) return messages;\\n  return messages.slice(startIndex + 1);\\n}\\n\\nimport {\\n  buildTranscriptCacheKey,\\n  TRANSCRIPT_CACHE_TTL_SECONDS,\\n} from \\\"../lib/kv\\\";\\n\\n// Get transcript for a checkpoint\\n// Transcripts are immutable so we cache them for 7 days\\nrepoRoutes.get(\\n  \\\"/:org/:repo/checkpoints/:checkpointId/transcript\\\",\\n  optionalAuth,\\n  rateLimitUnauthenticated,\\n  async (c) => {\\n    const userId = c.get(\\\"userId\\\") as string | undefined;\\n\\n    const org = c.req.param(\\\"org\\\");\\n    const repo = c.req.param(\\\"repo\\\");\\n    const checkpointId = c.req.param(\\\"checkpointId\\\");\\n    const repoFullName = `${org}/${repo}`;\\n\\n    // Validate checkpointId format to prevent path traversal\\n    if (!isValidCheckpointId(checkpointId)) {\\n      return c.json({ error: \\\"Invalid checkpoint ID format\\\" }, 400);\\n    }\\n\\n    const db = getDb(c.env);\\n\\n    // Check repo access BEFORE cache lookup (cache is shared across users)\\n    const repoAccess = await checkRepoAccess(db, repoFullName, userId);\\n    if (repoAccess instanceof Response) return repoAccess;\\n    if (!repoAccess) return c.json({ error: \\\"Repository not found\\\" }, 404);\\n\\n    // Cache key is repo + checkpoint specific (not user-specific — shared safely)\\n    const cacheKey = buildTranscriptCacheKey(repoFullName, checkpointId);\\n\\n\\n    const cached = await c.env.ENTIRE_CACHE.get<CachedTranscript>(\\n      cacheKey,\\n      \\\"json\\\",\\n    );\\n    if (cached) {\\n      return c.json({\\n        checkpointId: cached.checkpointId,\\n        sessions: cached.sessions,\\n        from_cache: true,\\n        cached_at: cached.cached_at,\\n      });\\n    }\\n\\n\\n    try {\\n      // Get a token: user's OAuth token if authenticated, installation token otherwise.\\n      // Token may be undefined for public repos without an installation — GitHub's\\n      // public API still works for fetching file content (rate-limited).\\n      const tokenResult = await getGitHubTokenForRepoRequest(c, db, userId, repoAccess);\\n      if (tokenResult.response) return tokenResult.response;\\n      const token = tokenResult.token ?? undefined;\\n\\n      // Convert checkpointId to folder path\\n      const folderPath = `${checkpointId.slice(0, 2)}/${checkpointId.slice(2)}`;\\n\\n      // Fetch root metadata.json (CheckpointSummary in v1 format)\\n      const metadataContent = await fetchFileAtCommit(\\n        repoFullName,\\n        `${folderPath}/metadata.json`,\\n        CHECKPOINT_BRANCH,\\n        token,\\n      ).catch(() => null);\\n\\n      let checkpointSummary: CheckpointSummary | null = null;\\n      if (metadataContent) {\\n        try {\\n          checkpointSummary = JSON.parse(metadataContent) as CheckpointSummary;\\n        } catch {\\n          // Invalid JSON\\n        }\\n      }\\n\\n      const sessions: SessionTranscript[] = [];\\n\\n      // V1 format: use sessions[] array from CheckpointSummary for explicit paths\\n      // Sessions are 0-indexed (0/, 1/, 2/, etc.)\\n      if (checkpointSummary?.sessions && checkpointSummary.sessions.length > 0) {\\n        // Fetch all sessions using paths from CheckpointSummary\\n        // Strip leading slashes from paths (V1 format includes them but GitHub API doesn't expect them)\\n        const stripLeadingSlash = (path: string) => path.replace(/^\\\\/+/, \\\"\\\");\\n        const sessionPromises: Promise<SessionTranscript | null>[] =\\n          checkpointSummary.sessions.map((sessionPaths, idx) =>\\n            (async () => {\\n              try {\\n                const [transcriptContent, sessionMetadataContent] =\\n                  await Promise.all([\\n                    fetchFileAtCommit(\\n                      repoFullName,\\n                      stripLeadingSlash(sessionPaths.transcript),\\n                      CHECKPOINT_BRANCH,\\n                      token,\\n                    ).catch(() => null),\\n                    fetchFileAtCommit(\\n                      repoFullName,\\n                      stripLeadingSlash(sessionPaths.metadata),\\n                      CHECKPOINT_BRANCH,\\n                      token,\\n                    ).catch(() => null),\\n                  ]);\\n\\n                if (!transcriptContent) return null;\\n\\n                let agent = \\\"Claude Code\\\";\\n                let sessionId = String(idx);\\n                let transcriptIdentifierAtStart: string | null = null;\\n                let tokenUsage: { inputTokens: number; outputTokens: number } | undefined;\\n                let attribution: SessionAttribution | undefined;\\n                if (sessionMetadataContent) {\\n                  try {\\n                    const meta = JSON.parse(sessionMetadataContent);\\n                    agent = meta.agent ?? \\\"Claude Code\\\";\\n                    sessionId = meta.session_id ?? String(idx);\\n                    transcriptIdentifierAtStart = meta.transcript_identifier_at_start ?? null;\\n                    if (meta.token_usage) {\\n                      tokenUsage = {\\n                        inputTokens: meta.token_usage.input_tokens ?? 0,\\n                        outputTokens: meta.token_usage.output_tokens ?? 0,\\n                      };\\n                    }\\n                    if (meta.initial_attribution) {\\n                      attribution = {\\n                        calculatedAt: meta.initial_attribution.calculated_at ?? \\\"\\\",\\n                        agentLines: meta.initial_attribution.agent_lines ?? 0,\\n                        humanAdded: meta.initial_attribution.human_added ?? 0,\\n                        humanModified: meta.initial_attribution.human_modified ?? 0,\\n                        humanRemoved: meta.initial_attribution.human_removed ?? 0,\\n                        totalCommitted: meta.initial_attribution.total_committed ?? 0,\\n                        agentPercentage: meta.initial_attribution.agent_percentage ?? 0,\\n                      };\\n                    }\\n                  } catch {\\n                    // Invalid JSON\\n                  }\\n                }\\n\\n                const parseResult = getParserForAgent(agent).parse(transcriptContent);\\n                const messages = filterRelevantMessages(\\n                  parseResult.messages,\\n                  transcriptIdentifierAtStart,\\n                );\\n\\n                return {\\n                  sessionId,\\n                  agent,\\n                  messages,\\n                  transcriptIdentifierAtStart,\\n                  tokenUsage,\\n                  attribution,\\n                  parsingFallback: parseResult.isFallback || undefined,\\n                  parsingWarning: parseResult.warning,\\n                };\\n              } catch {\\n                return null;\\n              }\\n            })(),\\n          );\\n\\n        const fetchedSessions = await Promise.all(sessionPromises);\\n        for (const s of fetchedSessions) {\\n          if (s) sessions.push(s);\\n        }\\n      } else {\\n        // Fallback for checkpoints without sessions array (single session in 0/ per v1 spec)\\n        const [transcriptContent, sessionMetadataContent] = await Promise.all([\\n          fetchFileAtCommit(\\n            repoFullName,\\n            `${folderPath}/0/full.jsonl`,\\n            CHECKPOINT_BRANCH,\\n            token,\\n          ).catch(() => null),\\n          fetchFileAtCommit(\\n            repoFullName,\\n            `${folderPath}/0/metadata.json`,\\n            CHECKPOINT_BRANCH,\\n            token,\\n          ).catch(() => null),\\n        ]);\\n\\n        if (transcriptContent) {\\n          let agent = \\\"Claude Code\\\";\\n          let sessionId = \\\"0\\\";\\n          let transcriptIdentifierAtStart: string | null = null;\\n          let tokenUsage: { inputTokens: number; outputTokens: number } | undefined;\\n          let attribution: SessionAttribution | undefined;\\n\\n          if (sessionMetadataContent) {\\n            try {\\n              const meta = JSON.parse(sessionMetadataContent);\\n              agent = meta.agent ?? \\\"Claude Code\\\";\\n              sessionId = meta.session_id ?? \\\"0\\\";\\n              transcriptIdentifierAtStart = meta.transcript_identifier_at_start ?? null;\\n              if (meta.token_usage) {\\n                tokenUsage = {\\n                  inputTokens: meta.token_usage.input_tokens ?? 0,\\n                  o