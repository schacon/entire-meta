\\n    96→    },\\n    97→  })\\n    98→);\\n    99→\\n   100→// Mount API routes under v1\\n   101→v1.route(\\\"/auth\\\", authApiRoutes);\\n   102→v1.route(\\\"/cache\\\", cacheRoutes);\\n   103→v1.route(\\\"/webhooks\\\", webhookRoutes);\\n   104→\\n   105→// Mount v1 under /api/v1\\n   106→app.route(\\\"/api/v1\\\", v1);\\n   107→\\n   108→// Mount OAuth routes at root (user-facing browser redirects)\\n   109→app.route(\\\"/auth\\\", authOAuthRoutes);\\n   110→\\n   111→// 404 handler\\n   112→app.notFound((c) => c.json({ error: \\\"Not found\\\" }, 404));\\n   113→\\n   114→// Error handler\\n   115→app.onError((err, c) => {\\n   116→  const requestId = crypto.randomUUID();\\n   117→  console.error(`Unhandled error [${requestId}]:`, err);\\n   118→  recordSpanError(err);\\n   119→  // Safe if ENVIRONMENT is missing - isLocalDev returns false for undefined\\n   120→  const showMessage = isLocalDev(c.env);\\n   121→  return c.json(\\n   122→    {\\n   123→      error: \\\"Internal server error\\\",\\n   124→      requestId,\\n   125→      message: showMessage ? err.message : undefined,\\n   126→    },\\n   127→    500\\n   128→  );\\n   129→});\\n   130→\\n   131→// OpenTelemetry configuration - only exports traces when OTEL_EXPORTER_OTLP_ENDPOINT is set\\n   132→const otelConfig: ResolveConfigFn = (env: Env) => {\\n   133→  if (!env.OTEL_EXPORTER_OTLP_ENDPOINT || isLocalDev(env)) {\\n   134→    // No exporter configured or local dev - use a no-op processor to disable\\n   135→    // trace export. An empty spanProcessors array triggers a warning from the\\n   136→    // otel-cf-workers library, so we provide a single processor that drops spans.\\n   137→    const noop = { onStart() {}, onEnd() {}, shutdown: () => Promise.resolve(), forceFlush: () => Promise.resolve() };\\n   138→    return {\\n   139→      spanProcessors: [noop],\\n   140→      service: { name: \\\"entire-api\\\" },\\n   141→    };\\n   142→  }\\n   143→\\n   144→  return {\\n   145→    exporter: {\\n   146→      url: env.OTEL_EXPORTER_OTLP_ENDPOINT,\\n   147→      headers: env.OTEL_EXPORTER_OTLP_HEADERS\\n   148→        ? Object.fromEntries(\\n   149→            env.OTEL_EXPORTER_OTLP_HEADERS.split(\\\",\\\").map((h) => {\\n   150→              const [key, ...rest] = h.split(\\\"=\\\");\\n   151→              return [key.trim(), rest.join(\\\"=\\\").trim()];\\n   152→            })\\n   153→          )\\n   154→        : {},\\n   155→    },\\n   156→    service: { name: \\\"entire-api\\\" },\\n   157→  };\\n   158→};\\n   159→\\n   160→// Worker handlers\\n   161→const handler = {\\n   162→  fetch: app.fetch,\\n   163→\\n   164→  // Queue consumer for webhook retries, repo checkpoint syncs, and user repo syncs\\n   165→  // Note: Cloudflare Queues guarantee that all messages in a batch come from the same queue,\\n   166→  // so we can safely check the first message type to determine batch handling.\\n   167→  async queue(\\n   168→    batch: MessageBatch<WebhookMessage | RepoSyncMessage | UserRepoSyncMessage>,\\n   169→    env: Env\\n   170→  ): Promise<void> {\\n   171→    validateEnv(env);\\n   172→\\n   173→    if (batch.messages.length === 0) {\\n   174→      return;\\n   175→    }\\n   176→\\n   177→    const firstMessage = batch.messages[0]?.body;\\n   178→\\n   179→    // Determine message type from first message\\n   180→    // Cloudflare Queues deliver messages from one queue per batch\\n   181→    if (firstMessage && isRepoSyncMessage(firstMessage)) {\\n   182→      // Process repo checkpoint sync messages\\n   183→      await processRepoSyncBatch(\\n   184→        batch as MessageBatch<RepoSyncMessage>,\\n   185→        env\\n   186→      );\\n   187→    } else if (firstMessage && isUserRepoSyncMessage(firstMessage)) {\\n   188→      // Process user repo sync messages\\n   189→      await processUserRepoSyncBatch(\\n   190→        batch as MessageBatch<UserRepoSyncMessage>,\\n   191→        env\\n   192→      );\\n   193→    } else if (firstMessage && \\\"deliveryId\\\" in firstMessage) {\\n   194→      // Process webhook messages (identified by deliveryId field)\\n   195→      const WEBHOOK_MAX_RETRIES = 5;\\n   196→      const batchStartTime = Date.now();\\n   197→      const batchId = generateBatchId();\\n   198→\\n   199→      // Calculate queue wait times\\n   200→      const queueWaitTimes = batch.messages.map((msg) => Date.now() - msg.timestamp.getTime());\\n   201→      const maxWaitMs = queueWaitTimes.length > 0 ? Math.max(...queueWaitTimes) : 0;\\n   202→\\n   203→      console.log(`[webhook-queue] batch_started`, JSON.stringify({\\n   204→        batchId,\\n   205→        queue: batch.queue,\\n   206→        count: batch.messages.length,\\n   207→        avgQueueWaitMs: avgMs(queueWaitTimes),\\n   208→        maxQueueWaitMs: maxWaitMs,\\n   209→      }));\\n   210→\\n   211→      let successCount = 0;\\n   212→      let retryCount = 0;\\n   213→      let deadLetterCount = 0;\\n   214→      const processingTimes: number[] = [];\\n   215→\\n   216→      for (const msg of batch.messages) {\\n   217→        const msgStartTime = Date.now();\\n   218→        const queueWaitMs = Date.now() - msg.timestamp.getTime();\\n   219→        const webhookResult = await processQueueMessage(\\n   220→          msg.body as WebhookMessage,\\n   221→          msg.attempts,\\n   222→          WEBHOOK_MAX_RETRIES,\\n   223→          queueWaitMs,\\n   224→          getDb(env),\\n   225→          env.ENTIRE_CACHE,\\n   226→          env,\\n   227→          processAllWebhookEvents\\n   228→        );\\n   229→\\n   230→        const processingMs = Date.now() - msgStartTime;\\n   231→        processingTimes.push(processingMs);\\n   232→\\n   233→        if (webhookResult.result === \\\"retry\\\") {\\n   234→          msg.retry();\\n   235→          retryCount++;\\n   236→        } else {\\n   237→          msg.ack();\\n   238→          if (webhookResult.result === \\\"dead-letter\\\") {\\n   239→            deadLetterCount++;\\n   240→          } else {\\n   241→            successCount++;\\n   242→          }\\n   243→        }\\n   244→\\n   245→        console.log(`[webhook-queue] message_processed`, JSON.stringify({\\n   246→          batchId,\\n   247→          deliveryId: (msg.body as WebhookMessage).deliveryId,\\n   248→          result: webhookResult.result,\\n   249→          processingMs,\\n   250→          attempt: msg.attempts,\\n   251→        }));\\n   252→      }\\n   253→\\n   254→      const totalBatchTimeMs = Date.now() - batchStartTime;\\n   255→\\n   256→      if (deadLetterCount > 0) {\\n   257→        const queueSpan = trace.getActiveSpan();\\n   258→        queueSpan?.setAttribute(\\\"webhook.queue.dead_letter_count\\\", deadLetterCount);\\n   259→        queueSpan?.setStatus({\\n   260→          code: SpanStatusCode.ERROR,\\n   261→          message: `${deadLetterCount} dead-lettered`,\\n   262→        });\\n   263→      }\\n   264→\\n   265→      console.log(`[webhook-queue] batch_complete`, JSON.stringify({\\n   266→        batchId,\\n   267→        count: batch.messages.length,\\n   268→        successCount,\\n   269→        retryCount,\\n   270→        deadLetterCount,\\n   271→        totalBatchTimeMs,\\n   272→        avgProcessingMs: avgMs(processingTimes),\\n   273→        throughputPerMin: totalBatchTimeMs > 0\\n   274→          ? Math.round((batch.messages.length / totalBatchTimeMs) * 60000)\\n   275→          : 0,\\n   276→      }));\\n   277→    } else {\\n   278→      // Unknown message type - log and ack to prevent infinite retries\\n   279→      console.error(\\n   280→        \\\"[queue] Unknown message type in batch:\\\",\\n   281→        JSON.stringify(firstMessage).slice(0, 200)\\n   282→      );\\n   283→      for (const msg of batch.messages) {\\n   284→        msg.ack();\\n   285→      }\\n   286→    }\\n   287→  },\\n   288→\\n   289→  // Cron trigger for daily reconciliation\\n   290→  async scheduled(\\n   291→    controller: Schedule