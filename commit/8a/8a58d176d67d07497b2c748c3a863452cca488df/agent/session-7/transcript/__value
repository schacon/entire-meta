rge\\\"\\n          value={[branch]}\\n          onChange={(selected) => handleBranchChange(selected[0] ?? null)}\\n        >\\n          <ComboboxTrigger className=\\\"max-w-52 shrink-0 justify-start\\\">\\n            <span className=\\\"flex items-center gap-1.5 w-full\\\">\\n              <BranchIcon size={18} className=\\\"shrink-0\\\" />\\n              <span className=\\\"truncate\\\">{branch}</span>\\n              <ChevronDownIcon size={18} className=\\\"shrink-0 ml-auto\\\" />\\n            </span>\\n          </ComboboxTrigger>\\n          <ComboboxContent>\\n            <ComboboxInput placeholder=\\\"Search branches...\\\" />\\n            <ComboboxList emptyMessage=\\\"No branches found.\\\">\\n              <BranchOptions defaultBranch={defaultBranch} />\\n            </ComboboxList>\\n          </ComboboxContent>\\n        </Combobox>\\n\\n        <div className=\\\"min-w-45 md:min-w-65 lg:min-w-[320px] ml-auto\\\">\\n          <Input\\n            type=\\\"text\\\"\\n            placeholder=\\\"Search checkpoints...\\\"\\n            value={searchQuery}\\n            onChange={(e) => setSearchQuery(e.target.value)}\\n            icon={<SearchIcon />}\\n          />\\n        </div>\\n      </div>}\\n\\n      {/* Loading state - only show skeleton once status confirms checkpoints exist */}\\n      {isLoading && repoHasCheckpoints && <CheckpointsSkeleton />}\\n\\n      {isBranchNotFound && (\\n        <ErrorState selectedBranch={branch} hasBranches={branches.length > 0} />\\n      )}\\n\\n      {data && data.checkpoints.length > 0 && checkpoints.length > 0 && (\\n        <CheckpointsList\\n          checkpoints={checkpoints}\\n          navigate={navigate}\\n          isDev={isDev}\\n          isFetchingFromGitHub={isFetchingFromGitHub}\\n          handleFetchFromGitHub={handleFetchFromGitHub}\\n          org={org}\\n          repo={repo}\\n          branch={branch}\\n        />\\n      )}\\n\\n      {/* Empty search results */}\\n      {data &&\\n    