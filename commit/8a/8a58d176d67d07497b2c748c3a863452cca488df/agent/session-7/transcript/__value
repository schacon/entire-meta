ckpoints/v1\\\";\\n    34→const GITHUB_API = \\\"https://api.github.com\\\";\\n    35→const TRANSCRIPT_DELAY_MS = 100; // delay between GitHub API calls to avoid rate limiting\\n    36→const MAX_TRANSCRIPT_CHARS = 2000;\\n    37→const MAX_ATTRIBUTE_BYTES = 3800; // Turbopuffer limit is 4096, leave headroom\\n    38→const MAX_EMBEDDING_CHARS = 25000; // ~8K tokens, text-embedding-3-small limit is 8192 tokens\\n    39→const MAX_RETRIES = 3;\\n    40→const RETRY_BASE_DELAY_MS = 1000;\\n    41→\\n    42→// --- CLI Argument Parsing ---\\n    43→\\n    44→interface CliOptions {\\n    45→  repo: string | null;\\n    46→  withTranscripts: boolean;\\n    47→  dryRun: boolean;\\n    48→  limit: number | null;\\n    49→}\\n    50→\\n    51→function parseArgs(): CliOptions {\\n    52→  const args = process.argv.slice(2);\\n    53→  const options: CliOptions = {\\n    54→    repo: null,\\n    55→    withTranscripts: false,\\n    56→    dryRun: false,\\n    57→    limit: null,\\n    58→  };\\n    59→\\n    60→  for (let i = 0; i < args.length; i++) {\\n    61→    switch (args[i]) {\\n    62→      case \\\"--repo\\\":\\n    63→        options.repo = args[++i];\\n    64→        if (!options.repo) {\\n    65→          console.error(\\\"Error: --repo requires a value (e.g., 'entireio/cli')\\\");\\n    66→          process.exit(1);\\n    67→        }\\n    68→        break;\\n    69→      case \\\"--with-transcripts\\\":\\n    70→        options.withTranscripts = true;\\n    71→        break;\\n    72→      case \\\"--dry-run\\\":\\n    73→        options.dryRun = true;\\n    74→        break;\\n    75→      case \\\"--limit\\\":\\n    76→        options.limit = parseInt(args[++i], 10);\\n    77→        if (isNaN(options.limit) || options.limit <= 0) {\\n    78→          console.error(\\\"Error: --limit requires a positive integer\\\");\\n    79→          process.exit(1);\\n    80→        }\\n    81→        break;\\n    82→      default:\\n    83→        console.error(`Unknown option: ${args[i]}`);\\n    84→        console.error(\\\"Usage: npx tsx scripts/backfill-search.ts [--repo <name>] [--with-transcripts] [--dry-run] [--limit <n>]\\\");\\n    85→        process.exit(1);\\n    86→    }\\n    87→  }\\n    88→\\n    89→  return options;\\n    90→}\\n    91→\\n    92→// --- Database Setup ---\\n    93→\\n    94→function createDb(): Kysely<DB> {\\n    95→  const url = process.env.DATABASE_URL ?? \\\"mysql://entire:entire@localhost:3306/entire\\\";\\n    96→  const parsed = new URL(url);\\n    97→  const isLocalhost = parsed.hostname === \\\"localhost\\\" || parsed.hostname === \\\"127.0.0.1\\\";\\n    98→\\n    99→  return new Kysely<DB>({\\n   100→    dialect: new MysqlDialect({\\n   101→      pool: createPool({\\n   102→        host: parsed.hostname,\\n   103→        port: Number(parsed.port) || 3306,\\n   104→        user: decodeURIComponent(parsed.username),\\n   105→        password: decodeURIComponent(parsed.password),\\n   106→        database: parsed.pathname.replace(\\\"/\\\", \\\"\\\"),\\n   107→        ssl: isLocalhost ? undefined : { rejectUnauthorized: true },\\n   108→      }),\\n   109→    }),\\n   110→  });\\n   111→}\\n   112→\\n   113→// --- Text Construction ---\\n   114→\\n   115→function buildSearchText(\\n   116→  checkpoint: CheckpointRow,\\n   117→  transcriptExcerpt?: string,\\n   118→): string {\\n   119→  const parts: string[] = [];\\n   120→\\n   121→  if (checkpoint.prompt) {\\n   122→    parts.push(`Prompt: ${checkpoint.prompt}`);\\n   123→  }\\n   124→  if (checkpoint.commit_message) {\\n   125→    parts.push(`Commit: ${checkpoint.commit_message}`);\\n   126→  }\\n   127→  if (checkpoint.files_touched_str) {\\n   128→    parts.push(`Files: ${checkpoint.files_touched_str}`);\\n   129→  }\\n   130→  if (transcriptExcerpt) {\\n   131→    parts.push(`Transcript: ${transcriptExcerpt}`);\\n   132→  }\\n   133→\\n   134→  return parts.join(\\\"\\\\n\\\");\\n   135→}\\n   136→\\n   137→// --- Embedding Generation ---\\n   138→\\n   139→async function generateEmbeddings(\\n   140→  openai: OpenAI,\\n   141→  texts: string[],\\n   142→): Promise<number[][]> {\\n   143→  const response = await openai.embeddings.create({\\n   144→    model: EMBEDDING_MODEL,\\n   145→    input: texts,\\n   146→    dimensions: EMBEDDING_DIMENSIONS,\\n   147→  });\\n   148→\\n   149→  // Sort by index to maintain order\\n   150→  return response.data\\n   151→    .sort((a, b) => a.index - b.index)\\n   152→    .map((item) => item.embedding);\\n   153→}\\n   154→\\n   155→// --- Attribute Truncation ---\\n   156→\\n   157→function truncateToBytes(str: string | null, maxBytes: number): string | null {\\n   158→  if (str === null) return null;\\n   159→  // Fast path: ASCII strings where 1 char = 1 byte\\n   160→  if (str.length <= maxBytes) return str;\\n   161→  // Truncate by encoding to bytes\\n   162→  const encoder = new TextEncoder();\\n   163→  const encoded = encoder.encode(str);\\n   164→  if (encoded.length <= maxBytes) return str;\\n   165→  // Find the last valid UTF-8 boundary within maxBytes\\n   166→  const truncated = encoded.slice(0, maxBytes);\\n   167→  const decoder = new TextDecoder(\\\"utf-8\\\", { fatal: false });\\n   168→  return decoder.decode(truncated);\\n   169→}\\n   170→\\n   171→// --- Fetch with Retry ---\\n   172→\\n   173→async function fetchWithRetry(\\n   174→  url: string,\\n   175→  options: RequestInit,\\n   176→): Promise<Response> {\\n   177→  for (let attempt = 0; attempt < MAX_RETRIES; attempt++) {\\n   178→    try {\\n   179→      const response = await fetch(url, options);\\n   180→      // Retry on transient server errors and rate limits\\n   181→      if (response.status >= 500 || response.status === 429) {\\n   182→        if (attempt < MAX_RETRIES - 1) {\\n   183→          const delay = RETRY_BASE_DELAY_MS * Math.pow(2, attempt);\\n   184→          await sleep(delay);\\n   185→          continue;\\n   186→        }\\n   187→      }\\n   188→      return response;\\n   189→    } catch (err) {\\n   190→      if (attempt < MAX_RETRIES - 1) {\\n   191→        const delay = RETRY_BASE_DELAY_MS * Math.pow(2, attempt);\\n   192→        await sleep(delay);\\n   193→        continue;\\n   194→      }\\n   195→      throw err;\\n   196→    }\\n   197→  }\\n   198→  throw new Error(\\\"fetchWithRetry: exhausted retries\\\");\\n   199→}\\n   200→\\n   201→// --- Transcript Fetching ---\\n   202→\\n   203→async function fetchTranscriptExcerpt(\\n   204→  repoFullName: string,\\n   205→  checkpointId: string,\\n   206→  agent: string,\\n   207→  token: string,\\n   208→): Promise<string | null> {\\n   209→  const folder = `${checkpointId.slice(0, 2)}/${checkpointId.slice(2)}`;\\n   210→  const path = `${folder}/0/full.jsonl`;\\n   211→\\n   212→  // Encode each path segment individually (preserves / separators)\\n   213→  const encodedPath = path.split(\\\"/\\\").map(encodeURIComponent).join(\\\"/\\\");\\n   214→  const url = `${GITHUB_API}/repos/${repoFullName}/contents/${encodedPath}?ref=${CHECKPOINT_BRANCH}`;\\n   215→\\n   216→  try {\\n   217→    const response = await fetchWithRetry(url, {\\n   218→      headers: {\\n   219→        Accept: \\\"application/vnd.github.raw+json\\\",\\n   220→        Authorization: `Bearer ${token}`,\\n   221→        \\\"User-Agent\\\": \\\"entire-backfill\\\",\\n   222→        \\\"X-GitHub-Api-Version\\\": \\\"2022-11-28\\\",\\n   223→      },\\n   224→    });\\n   225→\\n   226→    if (!response.ok) {\\n   227→      if (response.status === 404) {\\n   228→        return null;\\n   229→      }\\n   230→      return null;\\n   231→    }\\n   232→\\n   233→    const content = await response.text();\\n   234→\\n   235→    const parser = getParserForAgent(agent);\\n   236→    const result = parser.parse(content);\\n   237→\\n   238→    if (result.messages.length === 0) {\\n   239→      return null;\\n   240→    }\\n   241→\\n   242→    // Extract first user message + first assistant message\\n   243→    const parts: string[] = [];\\n   244→    let charsUsed = 0;\\n   245→\\n   246→    for (const msg of result.messages) {\\n   247→      if (charsUsed >= MAX_TRANSCRIPT_CHARS) break;\\n   248→\\n   249→      const remaining = MAX_TRANSCRIPT_CHARS - charsUsed;\\n   250→      const text = msg.content.slice(0, remaining);\\n   251→      parts.push(`[${msg.role}]: ${text}`);\\n   252→      charsUsed += text.length;\\n   253→\\n   254→      // Only take the first user + first assistant\\n   255→      if (msg.role === \\\"assistant\\\") break;\\n   256→    }\\n   257→\\n   258→    return parts.join(\\\"\\\\n\\\") || null;\\n   259→  } catch {\\n   260→    return null;\\n   261→  }\\n   262→}\\n   263→\\n   264→function sleep(ms: number): Promise<void> {\\n   265→  return new Promise((resolve) => setTimeout(resolve, ms));\\n   266→}\\n   267→\\n   268→// --- Types ---\\n   269→\\n   270→interface CheckpointRow {\\n   271→  checkpoint_id: string;\\n   272→  branch: string;\\n   273→  agent: string;\\n   274→  commit_author_username: string | null;\\n   275→  created_at: string | null;\\n   276→  commit_sha: string | null;\\n   277→  commit_message: string | null;\\n   278→  prompt: string | null;\\n   279→  files_touched_str: string | null;\\n   280→}\\n   281→\\n   282→interface RepoRow {\\n   283→  id: string;\\n   284→  full_name: string;\\n   285→  checkpoint_count: number;\\n   286→}\\n   287→\\n   288→// --- Per-Repo Processing ---\\n   289→\\n   290→async function fetchCheckpointsForRepo(\\n   291→  db: Kysely<DB>,\\n   292→  repoId: string,\\n   293→  limit: number | null,\\n   294→): Promise<CheckpointRow[]> {\\n   295→  // Use the same deferred-join pattern as getCheckpointsForBranch\\n   296→  let idQuery = db\\n   297→    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n   298→    .select(\\\"id\\\")\\n   299→    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n   300→    .orderBy(\\\"commit_date\\\", \\\"desc\\\");\\n   301→\\n   302→  if (limit) {\\n   303→    idQuery = idQuery.limit(limit);\\n   304→  }\\n   305→\\n   306→  const idRows = await idQuery.execute();\\n   307→  if (idRows.length === 0) return [];\\n   308→\\n   309→  const rows = await db\\n   310→    .selectFrom(\\\"repo_checkpoint_commits as cc\\\")\\n   311→    .leftJoin(\\\"repo_checkpoints as cp\\\", (join) =>\\n   312→      join\\n   313→        .onRef(\\\"cp.repo_id\\\", \\\"=\\\", \\\"cc.repo_id\\\")\\n   314→        .onRef(\\\"cp.checkpoint_id\\\", \\\"=\\\", \\\"cc.checkpoint_id\\\"),\\n   315→    )\\n   316→    .select([\\n   317→      \\\"cc.checkpoint_id\\\",\\n   318→      \\\"cc.branch\\\",\\n   319→      \\\"cc.commit_sha\\\",\\n   320→      \\\"cc.commit_message\\\",\\n   321→      \\\"cc.commit_author_username\\\",\\n   322→      \\\"cc.commit_date\\\",\\n   323→      \\\"cp.prompt\\\",\\n   324→      \\\"cp.agent\\\",\\n   325→      \\\"cp.created_at\\\",\\n   326→      \\\"cp.files_touched\\\",\\n   327→    ])\\n   328→    .where(\\n   329→      \\\"cc.id\\\",\\n   330→      \\\"in\\\",\\n   331→      idRows.map((r) => r.id),\\n   332→    )\\n   333→    .execute();\\n   334→\\n   335→  return rows.map((row) => {\\n   336→    const filesTouched = row.files_touched as string[] | null;\\n   337→    return {\\n   338→      checkpoint_id: row.checkpoint_id,\\n   339→      branch: row.branch,\\n   340→      agent: row.agent ?? \\\"Claude Code\\\",\\n   341→      commit_author_username: row.commit_author_username,\\n   342→      created_at: row.created_at?.toISOString() ?? row.commit_date?.toISOString() ?? null,\\n   343→      commit_sha: row.commit_sha,\\n   344→      commit_message: row.commit_message,\\n   345→      prompt: row.prompt,\\n   346→      files_touched_str: filesTouched?.join(\\\", \\\") ?? null,\\n   347→    };\\n   348→  });\\n   349→}\\n   350→\\n   351→function formatElapsed(ms: number): string {\\n   352→  const s = Math.floor(ms / 1000);\\n   353→  if (s < 60) return `${s}s`;\\n   354→  const m = Math.floor(s / 60);\\n   355→  return `${m}m${s % 60}s`;\\n   356→}\\n   357→\\n   358→async function processRepo(\\n   359→  db: Kysely<DB>,\\n   360→  tpuf: Turbopuffer,\\n   361→  openai: OpenAI,\\n   362→  repo: RepoRow,\\n   363→  options: CliOptions,\\n   364→): Promise<{ indexed: number; skipped: number }> {\\n   365→  const start = Date.now();\\n   366→  const total = repo.checkpoint_count;\\n   367→  console.log(`\\\\n--- ${repo.full_name} (${total} checkpoints) ---`);\\n   368→\\n   369→  const checkpoints = await fetchCheckpointsForRepo(db, repo.id, options.limit);\\n   370→  if (checkpoints.length === 0) {\\n   371→    console.log(`  No checkpoint commits found, skipping.`);\\n   372→    return { indexed: 0, skipped: 0 };\\n   373→  }\\n   374→\\n   375→  console.log(`  Fetched ${checkpoints.length} checkpoint rows from DB.`);\\n   376→\\n   377→  const githubToken = process.env.GITHUB_TOKEN;\\n   378→  const ns = tpuf.namespace(`checkpoints-${repo.id}`);\\n   379→  let totalIndexed = 0;\\n   380→  let totalSkipped = 0;\\n   381→  let totalTranscripts = 0;\\n   382→\\n   383→  // Process in chunks: for each chunk, fetch transcripts -> build text -> embed -> upsert\\n   384→  const numChunks = Math.ceil(checkpoints.length / CHUNK_SIZE);\\n   385→\\n   386→  for (let chunkIdx = 0; chunkIdx < numChunks; chunkIdx++) {\\n   387→    const chunkStart = chunkIdx * CHUNK_SIZE;\\n   388→    const chunkEnd = Math.min(chunkStart + CHUNK_SIZE, checkpoints.length);\\n   389→    const chunk = checkpoints.slice(chunkStart, chunkEnd);\\n   390→    const chunkNum = chunkIdx + 1;\\n   391→    const elapsed = formatElapsed(Date.now() - start);\\n   392→\\n   393→    console.log(`  [${chunkNum}/${numChunks}] Processing checkpoints ${chunkStart + 1}-${chunkEnd} of ${checkpoints.length} (${elapsed})`);\\n   394→\\n   395→    // 1. Fetch transcripts for this chunk\\n   396→    const transcripts: (string | undefined)[] = [];\\n   397→    if (options.withTranscripts && githubToken) {\\n   398→      let fetched =