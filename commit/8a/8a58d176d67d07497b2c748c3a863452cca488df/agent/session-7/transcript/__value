;\\n    61→    trace.getActiveSpan()?.addEvent(\\\"entire-api.webhooks.blocked\\\");\\n    62→    return c.json({ error: \\\"Forbidden\\\" }, 403);\\n    63→  }\\n    64→\\n    65→  // Idempotency check - skip webhooks that have already been successfully processed\\n    66→  const idempotencyKey = `webhook:${deliveryId}`;\\n    67→  const existingState = await c.env.ENTIRE_CACHE.get(idempotencyKey);\\n    68→\\n    69→  if (existingState === \\\"processed\\\") {\\n    70→    console.log(`Skipping duplicate webhook: ${eventType} [${deliveryId}]`);\\n    71→    return c.json({ received: true, duplicate: true });\\n    72→  }\\n    73→\\n    74→  // Get raw payload for signature verification\\n    75→  const payload = await c.req.text();\\n    76→\\n    77→  // Verify signature\\n    78→  const isValid = await verifySignature(\\n    79→    payload,\\n    80→    signature,\\n    81→    c.env.GITHUB_WEBHOOK_SECRET\\n    82→  );\\n    83→\\n    84→  if (!isValid) {\\n    85→    console.error(\\\"Invalid webhook signature for delivery:\\\", deliveryId);\\n    86→    return c.json({ error: \\\"Invalid signature\\\" }, 401);\\n    87→  }\\n    88→\\n    89→  // Parse payload to extract metadata\\n    90→  let parsedPayload: Record<string, unknown>;\\n    91→  try {\\n    92→    parsedPayload = JSON.parse(payload);\\n    93→  } catch {\\n    94→    return c.json({ error: \\\"Invalid JSON payload\\\" }, 400);\\n    95→  }\\n    96→\\n    97→  // Extract common fields\\n    98→  const action = (parsedPayload.action as string | undefined) ?? null;\\n    99→  const repository = parsedPayload.repository as\\n   100→    | { full_name?: string }\\n   101→    | undefined;\\n   102→\\n   103→  // Add webhook attributes to the parent span for filtering in Honeycomb\\n   104→  trace.getActiveSpan()?.setAttributes({\\n   105→    \\\"webhook.event_type\\\": eventType,\\n   106→    \\\"webhook.action\\\": action ?? \\\"none\\\",\\n   107→    \\\"webhook.repo\\\": repository?.full_name ?? \