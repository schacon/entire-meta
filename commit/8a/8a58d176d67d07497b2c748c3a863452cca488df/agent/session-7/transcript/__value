nknown message type - log and ack to prevent infinite retries\\n      console.error(\\n        \\\"[queue] Unknown message type in batch:\\\",\\n        JSON.stringify(firstMessage).slice(0, 200)\\n      );\\n      for (const msg of batch.messages) {\\n        msg.ack();\\n      }\\n    }\\n  },\\n\\n  // Cron trigger for daily reconciliation\\n  async scheduled(\\n    controller: ScheduledController,\\n    env: Env,\\n    ctx: ExecutionContext\\n  ): Promise<void> {\",\"numLines\":130,\"startLine\":165,\"totalLines\":324}},\"sourceToolAssistantUUID\":\"fe8da89a-b392-414b-ba34-c81525fbdef9\"}\n{\"parentUuid\":\"4904e5c6-c655-4819-815f-4d864f1488ca\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/evisdrenova/code/entire/devenv/cli\",\"sessionId\":\"b3a25300-460d-43d2-8f54-c13ecfe5387c\",\"version\":\"2.1.56\",\"gitBranch\":\"main\",\"slug\":\"resilient-squishing-fern\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01WoEUrktfgyejK7PQ8PLi5M\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_012G1v4ENemPyBiKjmMaN2qE\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/evisdrenova/code/entire/devenv/entire.io/api/src/lib/repo-sync-queue.ts\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":4699,\"cache_read_input_tokens\":103390,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":4699},\"output_tokens\":25,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"}},\"requestId\":\"req_011CYiaHi2LuZCivkJyKB3go\",\"type\":\"assistant\",\"uuid\":\"a0bba130-bd9a-44b4-956d-5aa127746926\",\"timestamp\":\"2026-03-04T19:15:10.402Z\"}\n{\"parentUuid\":\"a0bba130-bd9a-44b4-956d-5aa127746926\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/evisdrenova/code/entire/devenv/cli\",\"sessionId\":\"b3a25300-460d-43d2-8f54-c13ecfe5387c\",\"version\":\"2.1.56\",\"gitBranch\":\"main\",\"slug\":\"resilient-squishing-fern\",\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"PostToolUse\",\"hookName\":\"PostToolUse:Read\",\"command\":\"callback\"},\"parentToolUseID\":\"toolu_012G1v4ENemPyBiKjmMaN2qE\",\"toolUseID\":\"toolu_012G1v4ENemPyBiKjmMaN2qE\",\"timestamp\":\"2026-03-04T19:15:10.460Z\",\"uuid\":\"8bdcf34c-5ee1-4936-9ce1-d62dac9e2ff7\"}\n{\"parentUuid\":\"a0bba130-bd9a-44b4-956d-5aa127746926\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/evisdrenova/code/entire/devenv/cli\",\"sessionId\":\"b3a25300-460d-43d2-8f54-c13ecfe5387c\",\"version\":\"2.1.56\",\"gitBranch\":\"main\",\"slug\":\"resilient-squishing-fern\",\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_012G1v4ENemPyBiKjmMaN2qE\",\"type\":\"tool_result\",\"content\":\"     1→// Repo sync queue consumer and cron handler\\n     2→// Processes checkpoint sync messages for individual repos\\n     3→\\n     4→import { trace } from \\\"@opentelemetry/api\\\";\\n     5→import type { Env } from \\\"../env\\\";\\n     6→import { GitHubRateLimitError } from \\\"./github\\\";\\n     7→import {\\n     8→  queueRepoSyncBatch,\\n     9→  syncRepoCheckpoints,\\n    10→  type RepoSyncMessage,\\n    11→} from \\\"./repo-sync-service\\\";\\n    12→import { getDb } from \\\"./db\\\";\\n    13→import type { Db } from \\\"./db/db-types\\\";\\n    14→import { avgMs, errorString, generateBatchId, traced } from \\\"./telemetry\\\";\\n    15→import { getInstallationToken } from \\\"./token\\\";\\n    16→import { queueUserRepoSyncBatch } from \\\"./user-repo-sync\\\";\\n    17→\\n    18→export type { RepoSyncMessage } from \\\"./repo-sync-service\\\";\\n    19→\\n    20→// TTL for sync:lastUpdate KV entries (7 days)\\n    21→const SYNC_LAST_UPDATE_TTL = 60 * 60 * 24 * 7;\\n    22→\\n    23→// Log with consistent prefix\\n    24→function log(event: string, data: Record<string, unknown>): void {\\n    25→  console.log(`[repo-sync-queue] ${event}`, JSON.stringify(data));\\n    26→}\\n    27→\\n    28→// KV key for per-installation rate limit state\\n    29→function rateLimitKey(installationId: number): string {\\n    30→  return `github:ratelimit:installation:${installationId}:resetAt`;\\n    31→}\\n    32→\\n    33→// Check if a specific installation is currently rate limited\\n    34→async function isRateLimited(cache: KVNamespace, installationId: number): Promise<boolean> {\\n    35→  const key = rateLimitKey(installationId);\\n    36→  const resetAt = await cache.get(key);\\n    37→  if (!resetAt) return false;\\n    38→\\n    39→  const resetTime = parseInt(resetAt, 10);\\n    40→  if (Date.now() < resetTime) {\\n    41→    return true;\\n    42→  }\\n    43→\\n    44→  // Rate limit has expired, clean up\\n    45→  await cache.delete(key);\\n    46→  return false;\\n    47→}\\n    48→\\n    49→// Set rate limit marker for a specific installation (called when we hit a rate limit)\\n    50→async function setRateLimitMarker(\\n    51→  cache: KVNamespace,\\n    52→  installationId: number,\\n    53→  resetAt?: number,\\n    54→): Promise<void> {\\n    55→  // Default to 15 minutes from now if no reset time provided\\n    56→  const resetTime = resetAt ?? Date.now() + 15 * 60 * 1000;\\n    57→  // Store with TTL of 1 hour (self-cleaning)\\n    58→  await cache.put(rateLimitKey(installationId), String(resetTime), {\\n    59→    expirationTtl: 60 * 60,\\n    60→  });\\n    61→  log(\\\"rate_limit_set\\\", { installationId, resetAt: new Date(resetTime).toISOString() });\\n    62→}\\n    63→\\n    64→// Notify users with access to a repo that data has been updated\\n    65→// This triggers frontend polling to detect the change and refresh\\n    66→// Note: This function never throws - errors are logged and swallowed\\n    67→// to avoid affecting the main sync flow (notification is best-effort)\\n    68→async function notifyUsersOfRepoUpdate(\\n    69→  db: Db,\\n    70→  cache: KVNamespace,\\n    71→  repoId: string\\n    72→): Promise<number> {\\n    73→  try {\\n    74→    // Get all users with access to this repo (reuse existing utility)\\n    75→    const userIds = await db.repos.getUsersForRepo(repoId);\\n    76→\\n    77→    if (userIds.length === 0) {\\n    78→      return 0;\\n    79→    }\\n    80→\\n    81→    // Update sync:lastUpdate for each user\\n    82→    const now = String(Date.now());\\n    83→    await Promise.all(\\n    84→      userIds.map((userId) =>\\n    85→        cache.put(`sync:lastUpdate:${userId}`, now, {\\n    86→          expirationTtl: SYNC_LAST_UPDATE_TTL,\\n    87→        })\\n    88→      )\\n    89→    );\\n    90→\\n    91→    return userIds.length;\\n    92→  } catch (err) {\\n    93→    log(\\\"notify_users_error\\\", {\\n    94→      repoId,\\n    95→      error: errorString(err),\\n    96→    });\\n    97→    return 0;\\n    98→  }\\n    99→}\\n   100→\\n   101→// Type guard to check if a message is a RepoSyncMessage\\n   102→export function isRepoSyncMessage(msg: unknown): msg is RepoSyncMessage {\\n   103→  return (\\n   104→    typeof msg === \\\"object\\\" &&\\n   105→    msg !== null &&\\n   106→    \\\"repoId\\\" in msg &&\\n   107→    \\\"reason\\\" in msg &&\\n   108→    \\\"priority\\\" in msg &&\\n   109→    \\\"queuedAt\\\" in msg &&\\n   110→    typeof (msg as RepoSyncMessage).repoId === \\\"string\\\" &&\\n   111→    typeof (msg as RepoSyncMessage).reason === \\\"string\\\" &&\\n   112→    typeof (msg as RepoSyncMessage).priority === \\\"number\\\"\\n   113→  );\\n   114→}\\n   115→\\n   116→// Look up the GitHub App installation ID for a repo\\n   117→async function getRepoInstallationId(\\n   118→  db: Db,\\n   119→  repoId: string,\\n   120→): Promise<number | null> {\\n   121→  const repo = await db.repos.getById(repoId);\\n   122→\\n   123→  if (!repo) {\\n   124→    log(\\\"repo_not_found\\\", { repoId });\\n   125→    return null;\\n   126→  }\\n   127→\\n   128→  // Fast path: use the direct FK if available\\n   129→  if (repo.installation_id) {\\n   130→    const githubInstallationId = await db.installations.getGithubId(repo.installation_id);\\n   131→    if (githubInstallationId) {\\n   132→      return githubInstallationId;\\n   133→    }\\n   134→  }\\n   135→\\n   136→  // NB: This fallback shouldn't be required for long.\\n   137→  // Fallback: look up by owner name (for repos not yet backfilled)\\n   138→  const owner = repo.full_name.split(\\\"/\\\")[0];\\n   139→  const githubInstallationId = await db.installations.getGithubIdByOwner(owner);\\n   140→  if (!githubInstallationId) {\\n   141→    log(\\\"no_installation_for_repo\\\", { repoId, owner });\\n   142→    return null;\\n   143→  }\\n   144→\\n   145→  return githubInstallationId;\\n   146→}\\n   147→\\n   148→// Get a valid token for a GitHub App installation\\n   149→async function getTokenForInstallation(\\n   150→  installationId: number,\\n   151→  env: Env,\\n   152→): Promise<string | null> {\\n   153→  try {\\n   154→    return await getInstallationToken(\\n   155→      installationId,\\n   156→      {\\n   157→        appId: env.GITHUB_CLIENT_ID,\\n   158→        privateKey: env.GITHUB_APP_PRIVATE_KEY,\\n   159→      },\\n   160→      env.ENTIRE_CACHE,\\n   161→    );\\n   162→  } catch (err) {\\n   163→    log(\\\"installation_token_error\\\", {\\n   164→      installationId,\\n   165→      error: errorString(err),\\n   166→    });\\n   167→    return null;\\n   168→  }\\n   169→}\\n   170→\\n   171→// Process a batch of repo sync messages\\n   172→export async function processRepoSyncBatch(\\n   173→  batch: MessageBatch<RepoSyncMessage>,\\n   174→  env: Env,\\n   175→): Promise<void> {\\n   176→  const batchStartTime = Date.now();\\n   177→  const batchId = generateBatchId();\\n   178→\\n   179→  // Calculate queue wait times for all messages in batch\\n   180→  const queueWaitTimes = batch.messages.map(\\n   181→    (msg) => Date.now() - msg.timestamp.getTime(),\\n   182→  );\\n   183→  const maxWaitMs = queueWaitTimes.length > 0 ? Math.max(...queueWaitTimes) : 0;\\n   184→\\n   185→  log(\\\"batch_started\\\", {\\n   186→    batchId,\\n   187→    queue: batch.queue,\\n   188→    count: batch.messages.length,\\n   189→    avgQueueWaitMs: avgMs(queueWaitTimes),\\n   190→    maxQueueWaitMs: maxWaitMs,\\n   191→  });\\n   192→\\n   193→  const db = getDb(env);\\n   194→  const processingTimes: number[] = [];\\n   195→  let successCount = 0;\\n   196→  let errorCount = 0;\\n   197→  let skippedCount = 0;\\n   198→\\n   199→  for (let i = 0; i < batch.messages.length; i++) {\\n   200→    const msg = batch.messages[i];\\n   201→    const msgStartTime = Date.now();\\n   202→    const { repoId, reason } = msg.body;\\n   203→    const queueWaitMs = Date.now() - msg.timestamp.getTime();\\n   204→\\n   205→    let installationId: number | null = null;\\n   206→    try {\\n   207→      // Look up installation for rate limit checks\\n   208→      installationId = await getRepoInstallationId(db, repoId);\\n   209→\\n   210→      if (!installationId) {\\n   211→        log(\\\"no_installation_for_repo\\\", { batchId, repoId, reason });\\n   212→        msg.ack();\\n   213→        skippedCount++;\\n   214→        continue;\\n   215→      }\\n   216→\\n   217→      // Check if this installation is rate limited\\n   218→      if (await isRateLimited(env.ENTIRE_CACHE, installationId)) {\\n   219→        log(\\\"message_skipped_rate_limited\\\", { batchId, repoId, installationId, reason });\\n   220→        msg.retry();\\n   221→        skippedCount++;\\n   222→        continue;\\n   223→      }\\n   224→\\n   225→      // Get a token for this installation\\n   226→      const token = await getTokenForInstallation(installationId, env);\\n   227→\\n   228→      if (!token) {\\n   229→        log(\\\"no_token_for_repo\\\", { batchId, repoId, installationId, reason });\\n   230→        // Can't sync without a token - ack to avoid infinite retries\\n   231→        // The repo will be picked up again on next reconciliation\\n   232→        msg.ack();\\n   233→        skippedCount++;\\n   234→        continue;\\n   235→      }\\n   236→\\n   237→      // For user_sync, skip if repo was already synced (another job got there first)\\n   238→      // This prevents duplicate work when multiple users log in for the same repo\\n   239→      if (reason === \\\"user_sync\\\" && await db.repos.isCheckpointsSynced(repoId)) {\\n   240→        log(\\\"skip_already_synced\\\", { batchId, repoId, reason });\\n   241→        msg.ack();\\n   242→        skippedCount++;\\n   243→        continue;\\n   244→      }\\n   245→\\n   246→      const result = await traced(\\\"repo-sync-queue.processMessage\\\", async () => {\\n   247→        const span = trace.getActiveSpan();\\n   248→        span?.setAttribute(\\\"queue.message_wait_ms\\\", queueWaitMs);\\n   249→        span?.setAttribute(\\\"github.installation_id\\\", installationId!);\\n   250→\\n   251→        return await syncRepoCheckpoints(db, repoId, token);\\n   252→      });\\n   253→      const processingMs = Date.now() - msgStartTime;\\n   254→      processingTimes.push(processingMs);\\n   255→\\n   256→      log(\\\"message_processed\\\", {\\n   257→        batchId,\\n   258→        messageIndex: i + 1,\\n   259→        totalMessages: batch.messages.length,\\n   260→        repoId,\\n   261→        reason,\\n   262→        result: result.status,\\n   263→        skipReason: result.reason,\\n   264→        checkpoints: result.checkpointsDiscovered,\\n   265→        queueWaitMs,\\n   266→        processingMs,\\n   267→        attempt: msg.attempts,\\n   268→      });\\n   269→\\n   270→      msg.ack();\\n   271→      if (result.status === \\\"ok\\\") {\\n   272→        successCount++;\\n   273→        // Notify users so frontend refreshes\\n   274→        const usersNotified = await notifyUsersOfRepoUpdate(db, env.ENTIRE_CACHE, repoId);\\n   275→        if (usersNotified > 0) {\\n   276→          log(\\\"users_notified\\\", { repoId, usersNotified });\\n   277→        }\\n   278→      } else if (result.status === \\\"error\\\") {\\n   279→        errorCount++;\\n   280→      } else {\\n   281→        skippedCount++;\\n   282→      }\\n   283→    } catch (err) {\\n   284→      const processingMs = Date.now() - msgStartTime;\\n   285→      processingTimes.push(processingMs);\\n   286→      errorCount++;\\n   287→\\n   288→      // Check if this is a rate limit error\\n   289→      if (err instanceof GitHubRateLimitError) {\\n   290→        log(\\\"rate_limit_hit\\\", {\\n   291→          batchId,\\n   292→          repoId,\\n   293→          installationId,\\n   294→          reason,\\n   295→          resetAt: err.resetAt\\n   296→            ? new Date(err.resetAt * 1000).toISOString()\\n   297→            : undefined,\\n   298→          processingMs,\\n   299→        });\\n   300→\\n   301→        // Set the rate limit marker for this installation only\\n   302→        if (installationId) {\\n   303→          await setRateLimitMarker(\\n   304→            env.ENTIRE_CACHE,\\n   305→            installationId,\\n   306→            err.resetAt ? err.resetAt * 1000 : undefined,\\n   307→          );\\n   308→        }\\n   309→\\n   310→        // Retry only this message; continue processing remaining\\n   311→        // (they may belong to different installations)\\n   312→        msg.retry();\\n   313→        continue;\\n   314→      }\\n   315→\\n   316→      log(\\\"message_error\\\", {\\n   317→        batchId,\\n   318→        repoId,\\n   319→        reason,\\n   320→        attempt: msg.attempts,\\n   321→        processingMs,\\n   322→        error: errorString(err),\\n   323→      });\\n   324→\\n   325→      // Retry if not at max attempts (max_retries is configured in wrangler.jsonc)\\n   326→      msg.retry();\\n   327→    }\\n   328→  }\\n   329→\\n   330→  const totalBatchTimeMs = Date.now() - batchStartTime;\\n   331→\\n   332→  log(\\\"batch_complete\\\", {\\n   333→    batchId,\\n   334→    count: batch.messages.length,\\n   335→    successCount,\\n   336→    errorCount,\\n   337→    skippedCount,\\n   338→    totalBatchTimeMs,\\n   339→    avgProcessingMs: avgMs(processingTimes),\\n   340→    throughputPerMin:\\n   341→      totalBatchTimeMs > 0\\n   342→        ? Math.round((batch.messages.length / totalBatchTimeMs) * 60000)\\n   343→        : 0,\\n   344→  });\\n   345→}\\n   346→\\n   347→// Reconciliation options\\n   348→export interface ReconciliationOptions {\\n   349→  force?: boolean; // Skip staleness check and queue all repos\\n   350→  repoFullName?: string; // Target a specific repo by full name (e.g., \\\"owner/repo\\\")\\n   351→  repoIds?: string[]; // Target specific repos by ID\\n   352→}\\n   353→\\n   354→// Reconciliation result\\n   355→export interface ReconciliationResult {\\n   356→  reposQueued: number;\\n   357→  usersQueued: number;\\n   358→  targetedRepo?: string; // The repo that was targeted (if any)\\n   359→}\\n   360→\\n   361→// Daily reconciliation cron handler\\n   362→// Queues stale repos for checkpoint sync and identifies stale users\\n   363→export async function handleReconciliationCron(\\n   364→  env: Env,\\n   365→  options: ReconciliationOptions = {},\\n   366→): Promise<ReconciliationResult> {\\n   367→  const now = new Date();\\n   368→  const staleThreshold = new Date(\\n   369→    now.getTime() - 24 * 60 * 60 * 1000,\\n   370→  ).toISOString();\\n   371→  const isTargeted = !!(options.repoFullName || options.repoIds?.length);\\n   372→\\n   373→  log(\\\"cron_started\\\", {\\n   374→    threshold: staleThreshold,\\n   375→    force: options.force ?? false,\\n   376→    targeted: isTargeted,\\n   377→    repoFullName: options.repoFullName,\\n   378→    repoIds: options.repoIds,\\n   379→  });\\n   380→\\n   381→  const db = getDb(env);\\n   382→\\n   383→  // A. Queue repos for checkpoint reconciliation\\n   384→  let reposToQueue: { id: string; full_name: string }[];\\n   385→  try {\\n   386→    reposToQueue = await db.repos.getForReconciliation({\\n   387→      repoFullName: options.repoFullName,\\n   388→      repoIds: options.repoIds,\\n   389→      force: options.force,\\n   390→      staleThreshold,\\n   391→    });\\n   392→  } catch (err) {\\n   393→    if (options.repoFullName) {\\n   394→      log(\\\"cron_error_repo_not_found\\\", {\\n   395→        repoFullName: options.repoFullName,\\n   396→        error: errorString(err),\\n   397→      });\\n   398→      return { reposQueued: 0, usersQueued: 0, targetedRepo: options.repoFullName };\\n   399→    }\\n   400→    log(\\\"cron_error_fetching_repos\\\", { error: errorString(err) });\\n   401→    return { reposQueued: 0, usersQueued: 0 };\\n   402→  }\\n   403→\\n   404→  const reposQueued = await queueRepoSyncBatch(\\n   405→    env.REPO_SYNC_QUEUE,\\n   406→    reposToQueue,\\n   407→    \\\"reconciliation\\\",\\n   408→    1,\\n   409→  );\\n   410→\\n   411→  // B. Queue stale users for repo sync (skip if targeting specific repos)\\n   412→  let usersQueued = 0;\\n   413→  if (!isTargeted) {\\n   414→    try {\\n   415→      const staleUsers = await db.refreshState.getStaleUsers(staleThreshold, 100);\\n   416→      usersQueued = await queueUserRepoSyncBatch(\\n   417→        env.USER_REPO_SYNC_QUEUE,\\n   418→        staleUsers,\\n   419→        \\\"reconciliation\\\",\\n   420→      );\\n   421→    } catch (err) {\\n   422→      log(\\\"cron_error_fetching_users\\\", { error: errorString(err) });\\n   423→    }\\n   424→  }\\n   425→\\n   426→  const result: ReconciliationResult = {\\n   427→    reposQueued,\\n   428→    usersQueued,\\n   429→    targetedRepo: options.repoFullName,\\n   430→  };\\n   431→\\n   432→  log(\\\"cron_complete\\\", { ...result });\\n   433→\\n   434→  return result;\\n   435→}\\n   436→\"}]},\"uuid\":\"7065194c-bf5f-49d4-a96d-50e5f45c059d\",\"timestamp\":\"2026-03-04T19:15:10.459Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/evisdrenova/code/entire/devenv/entire.io/api/src/lib/repo-sync-queue.ts\",\"content\":\"// Repo sync queue consumer and cron handler\\n// Processes checkpoint sync messages for individual repos\\n\\nimport { trace } from \\\"@opentelemetry/api\\\";\\nimport type { Env } from \\\"../env\\\";\\nimport { GitHubRateLimitError } from \\\"./github\\\";\\nimport {\\n  queueRepoSyncBatch,\\n  syncRepoCheckpoints,\\n  type RepoSyncMessage,\\n} from \\\"./repo-sync-service\\\";\\nimport { getDb } from \\\"./db\\\";\\nimport type { Db } from \\\"./db/db-types\\\";\\nimport { avgMs, errorString, generateBatchId, traced } from \\\"./telemetry\\\";\\nimport { getInstallationToken } from \\\"./token\\\";\\nimport { queueUserRepoSyncBatch } from \\\"./user-repo-sync\\\";\\n\\nexport type { RepoSyncMessage } from \\\"./repo-sync-service\\\";\\n\\n// TTL for sync:lastUpdate KV entries (7 days)\\nconst SYNC_LAST_UPDATE_TTL = 60 * 60 * 24 * 7;\\n\\n// Log with consistent prefix\\nfunction log(event: string, data: Record<string, unknown>): void {\\n  console.log(`[repo-sync-queue] ${event}`, JSON.stringify(data));\\n}\\n\\n// KV key for per-installation rate limit state\\nfunction rateLimitKey(installationId: number): string {\\n  return `github:ratelimit:installation:${installationId}:resetAt`;\\n}\\n\\n// Check if a specific installation is currently rate limited\\nasync function isRateLimited(cache: KVNamespace, installationId: number): Promise<boolean> {\\n  const key = rateLimitKey(installationId);\\n  const resetAt = await cache.get(key);\\n  if (!resetAt) return false;\\n\\n  const resetTime = parseInt(resetAt, 10);\\n  if (Date.now() < resetTime) {\\n    return true;\\n  }\\n\\n  // Rate limit has expired, clean up\\n  await cache.delete(key);\\n  return false;\\n}\\n\\n// Set rate limit marker for a specific installation (called when we hit a rate limit)\\nasync function setRateLimitMarker(\\n  cache: KVNamespace,\\n  installationId: number,\\n  resetAt?: number,\\n): Promise<void> {\\n  // Default to 15 minutes from now if no reset time provided\\n  const resetTime = resetAt ?? Date.now() + 15 * 60 * 1000;\\n  // Store with TTL of 1 hour (self-cleaning)\\n  await cache.put(rateLimitKey(installationId), String(resetTime), {\\n    expirationTtl: 60 * 60,\\n  });\\n  log(\\\"rate_limit_set\\\", { installationId, resetAt: new Date(resetTime).toISOString() });\\n}\\n\\n// Notify users with access to a repo that data has been updated\\n// This triggers frontend polling to detect the change and refresh\\n// Note: This function never throws - errors are logged and swallowed\\n// to avoid affecting the main sync flow (notification is best-effort)\\nasync function notifyUsersOfRepoUpdate(\\n  db: Db,\\n  cache: KVNamespace,\\n  repoId: string\\n): Promise<number> {\\n  try {\\n    // Get all users with access to this repo (reuse existing utility)\\n    const userIds = await db.repos.getUsersForRepo(repoId);\\n\\n    if (userIds.length === 0) {\\n      return 0;\\n    }\\n\\n    // Update sync:lastUpdate for each user\\n    const now = String(Date.now());\\n    await Promise.all(\\n      userIds.map((userId) =>\\n        cache.put(`sync:lastUpdate:${userId}`, now, {\\n          expirationTtl: SYNC_LAST_UPDATE_TTL,\\n        })\\n      )\\n    );\\n\\n    return userIds.length;\\n  } catch (err) {\\n    log(\\\"notify_users_error\\\", {\\n      repoId,\\n      error: errorString(err),\\n    });\\n    return 0;\\n  }\\n}\\n\\n// Type guard to check if a message is a RepoSyncMessage\\nexport function isRepoSyncMessage(msg: unknown): msg is RepoSyncMessage {\\n  return (\\n    typeof msg === \\\"object\\\" &&\\n    msg !== null &&\\n    \\\"repoId\\\" in msg &&\\n    \\\"reason\\\" in msg &&\\n    \\\"priority\\\" in msg &&\\n    \\\"queuedAt\\\" in msg &&\\n    typeof (msg as RepoSyncMessage).repoId === \\\"string\\\" &&\\n    typeof (msg as RepoSyncMessage).reason === \\\"string\\\" &&\\n    typeof (msg as RepoSyncMessage).priority === \\\"number\\\"\\n  );\\n}\\n\\n// Look up the GitHub App installation ID for a repo\\nasync function getRepoInstallationId(\\n  db: Db,\\n  repoId: string,\\n): Promise<number | null> {\\n  const repo = await db.repos.getById(repoId);\\n\\n  if (!repo) {\\n    log(\\\"repo_not_found\\\", { repoId });\\n    return null;\\n  }\\n\\n  // Fast path: use the direct FK if available\\n  if (repo.installation_id) {\\n    const githubInstallationId = await db.installations.getGithubId(repo.installation_id);\\n    if (githubInstallationId) {\\n      return githubInstallationId;\\n    }\\n  }\\n\\n  // NB: This fallback shouldn't be required for long.\\n  // Fallback: look up by owner name (for repos not yet backfilled)\\n  const owner = repo.full_name.split(\\\"/\\\")[0];\\n  const githubInstallationId = await db.installations.getGithubIdByOwner(owner);\\n  if (!githubInstallationId) {\\n    log(\\\"no_installation_for_repo\\\", { repoId, owner });\\n    return null;\\n  }\\n\\n  return githubInstallationId;\\n}\\n\\n// Get a valid token for a GitHub App installation\\nasync function getTokenForInstallation(\\n  installationId: number,\\n  env: Env,\\n): Promise<string | null> {\\n  try {\\n    return await getInstallationToken(\\n      installationId,\\n      {\\n        appId: env.GITHUB_CLIENT_ID,\\n        privateKey: env.GITHUB_APP_PRIVATE_KEY,\\n      },\\n      env.ENTIRE_CACHE,\\n    );\\n  } catch (err) {\\n    log(\\\"installation_token_error\\\", {\\n      installationId,\\n      error: errorString(err),\\n    });\\n    return null;\\n  }\\n}\\n\\n// Process a batch of repo sync messages\\nexport async function processRepoSyncBatch(\\n  batch: MessageBatch<RepoSyncMessage>,\\n  env: Env,\\n): Promise<void> {\\n  const batchStartTime = Date.now();\\n  const batchId = generateBatchId();\\n\\n  // Calculate queue wait times for all messages in batch\\n  const queueWaitTimes = batch.messages.map(\\n    (msg) => Date.now() - msg.timestamp.getTime(),\\n  );\\n  const maxWaitMs = queueWaitTimes.length > 0 ? Math.max(...queueWaitTimes) : 0;\\n\\n  log(\\\"batch_started\\\", {\\n    batchId,\\n    queue: batch.queue,\\n    count: batch.messages.length,\\n    avgQueueWaitMs: avgMs(queueWaitTimes),\\n    maxQueueWaitMs: maxWaitMs,\\n  });\\n\\n  const db = getDb(env);\\n  const processingTimes: number[] = [];\\n  let successCount = 0;\\n  let errorCount = 0;\\n  let skippedCount = 0;\\n\\n  for (let i = 0; i < batch.messages.length; i++) {\\n    const msg = batch.messages[i];\\n    const msgStartTime = Date.now();\\n    const { repoId, reason } = msg.body;\\n    const queueWaitMs = Date.now() - msg.timestamp.getTime();\\n\\n    let installationId: number | null = null;\\n    try {\\n      // Look up installation for rate limit checks\\n      installationId = await getRepoInstallationId(db, repoId);\\n\\n      if (!installationId) {\\n        log(\\\"no_installation_for_repo\\\", { batchId, repoId, reason });\\n        msg.ack();\\n        skippedCount++;\\n        continue;\\n      }\\n\\n      // Check if this installation is rate limited\\n      if (await isRateLimited(env.ENTIRE_CACHE, installationId)) {\\n        log(\\\"message_skipped_rate_limited\\\", { batchId, repoId, installationId, reason });\\n        msg.retry();\\n        skippedCount++;\\n        continue;\\n      }\\n\\n      // Get a token for this installation\\n      const token = await getTokenForInstallation(installationId, env);\\n\\n      if (!token) {\\n        log(\\\"no_token_for_repo\\\", { batchId, repoId, installationId, reason });\\n        // Can't sync without a token - ack to avoid infinite retries\\n        // The repo will be picked up again on next reconciliation\\n        msg.ack();\\n        skippedCount++;\\n        continue;\\n      }\\n\\n      // For user_sync, skip if repo was already synced (another job got there first)\\n      // This prevents duplicate work when multiple users log in for the same repo\\n      if (reason === \\\"user_sync\\\" && await db.repos.isCheckpointsSynced(repoId)) {\\n        log(\\\"skip_already_synced\\\", { batchId, repoId, reason });\\n        msg.ack();\\n        skippedCount++;\\n        continue;\\n      }\\n\\n      const result = await traced(\\\"repo-sync-queue.processMessage\\\", async () => {\\n        const span = trace.getActiveSpan();\\n        span?.setAttribute(\\\"queue.message_wait_ms\\\", queueWaitMs);\\n        span?.setAttribute(\\\"github.installation_id\\\", installationId!);\\n\\n        return await syncRepoCheckpoints(db, repoId, token);\\n      });\\n      const processingMs = Date.now() - msgStartTime;\\n      processingTimes.push(processingMs);\\n\\n      log(\\\"message_processed\\\", {\\n        batchId,\\n        messageIndex: i + 1,\\n        totalMessages: batch.messages.length,\\n        repoId,\\n        reason,\\n        result: result.status,\\n        skipReason: result.reason,\\n        checkpoints: result.checkpointsDiscovered,\\n        queueWaitMs,\\n        processingMs,\\n        attempt: msg.attempts,\\n      });\\n\\n      msg.ack();\\n      if (result.status === \\\"ok\\\") {\\n        successCount++;\\n        // Notify users so frontend refreshes\\n        const usersNotified = await notifyUsersOfRepoUpdate(db, env.ENTIRE_CACHE, repoId);\\n        if (usersNotified > 0) {\\n          log(\\\"users_notified\\\", { repoId, usersNotified });\\n        }\\n      } else if (result.status === \\\"error\\\") {\\n        errorCount++;\\n      } else {\\n        skippedCount++;\\n      }\\n    } catch (err) {\\n      const processingMs = Date.now() - msgStartTime;\\n      processingTimes.push(processingMs);\\n      errorCount++;\\n\\n      // Check if this is a rate limit error\\n      if (err instanceof GitHubRateLimitError) {\\n        log(\\\"rate_limit_hit\\\", {\\n          batchId,\\n          repoId,\\n          installationId,\\n          reason,\\n          resetAt: err.resetAt\\n            ? new Date(err.resetAt * 1000).toISOString()\\n            : undefined,\\n          processingMs,\\n        });\\n\\n        // Set the rate limit marker for this installation only\\n        if (installationId) {\\n          await setRateLimitMarker(\\n            env.ENTIRE_CACHE,\\n            installationId,\\n            err.resetAt ? err.resetAt * 1000 : undefined,\\n          );\\n        }\\n\\n        // Retry only this message; continue processing remaining\\n        // (they may belong to different installations)\\n        msg.retry();\\n        continue;\\n      }\\n\\n      log(\\\"message_error\\\", {\\n        batchId,\\n        repoId,\\n        reason,\\n        attempt: msg.attempts,\\n        processingMs,\\n        error: errorString(err),\\n      });\\n\\n      // Retry if not at max attempts (max_retries is configured in wrangler.jsonc)\\n      msg.retry();\\n    }\\n  }\\n\\n  const totalBatchTimeMs = Date.now() - batchStartTime;\\n\\n  log(\\\"batch_complete\\\", {\\n    batchId,\\n    count: batch.messages.length,\\n    successCount,\\n    errorCount,\\n    skippedCount,\\n    totalBatchTimeMs,\\n    avgProcessingMs: avgMs(processingTimes),\\n    throughputPerMin:\\n      totalBatchTimeMs > 0\\n        ? Math.round((batch.messages.length / totalBatchTimeMs) * 60000)\\n        : 0,\\n  });\\n}\\n\\n// Reconciliation options\\nexport interface ReconciliationOptions {\\n  force?: boolean; // Skip staleness check and queue all repos\\n  repoFullName?: string; // Target a specific repo by full name (e.g., \\\"owner/repo\\\")\\n  repoIds?: string[]; // Target specific repos by ID\\n}\\n\\n// Reconciliation result\\nexport interface ReconciliationResult {\\n  reposQueued: number;\\n  usersQueued: number;\\n  targetedRepo?: string; // The repo that was targeted (if any)\\n}\\n\\n// Daily reconciliation cron handler\\n// Queues stale repos for checkpoint sync and identifies stale users\\nexport async function handleReconciliationCron(\\n  env: Env,\\n  options: ReconciliationOptions = {},\\n): Promise<ReconciliationResult> {\\n  const now = new Date();\\n  const staleThreshold = new Date(\\n    now.getTime() - 24 * 60 * 60 * 1000,\\n  ).toISOString();\\n  const isTargeted = !!(options.repoFullName || options.repoIds?.length);\\n\\n  log(\\\"cron_started\\\", {\\n    threshold: staleThreshold,\\n    force: options.force ?? false,\\n    targeted: isTargeted,\\n    repoFullName: options.repoFullName,\\n    repoIds: options.repoIds,\\n  });\\n\\n  const db = getDb(env);\\n\\n  // A. Queue repos for checkpoint reconciliation\\n  let reposToQueue: { id: string; full_name: string }[];\\n  try {\\n    reposToQueue = await db.repos.getForReconciliation({\\n      repoFullName: options.repoFullName,\\n      repoIds: options.repoIds,\\n      force: options.force,\\n      staleThreshold,\\n    });\\n  } catch (err) {\\n    if (options.repoFullName) {\\n      log(\\\"cron_error_repo_not_found\\\", {\\n        repoFullName: options.repoFullName,\\n        error: errorString(err),\\n      });\\n      return { reposQueued: 0, usersQueued: 0, targetedRepo: options.repoFullName };\\n    }\\n    log(\\\"cron_error_fetching_repos\\\", { error: errorString(err) });\\n    return { reposQueued: 0, usersQueued: 0 };\\n  }\\n\\n  const reposQueued = await queueRepoSyncBatch(\\n    env.REPO_SYNC_QUEUE,\\n    reposToQueue,\\n    \\\"reconciliation\\\",\\n    1,\\n  );\\n\\n  // B. Queue stale users for repo sync (skip if targeting specific repos)\\n  let usersQueued = 0;\\n  if (!isTargeted) {\\n    try {\\n      const staleUsers = await db.refreshState.getStaleUsers(staleThreshold, 100);\\n      usersQueued = await queueUserRepoSyncBatch(\\n        env.USER_REPO_SYNC_QUEUE,\\n        staleUsers,\\n        \\\"reconciliation\\\",\\n      );\\n    } catch (err) {\\n      log(\\\"cron_error_fetching_users\\\", { error: errorString(err) });\\n    }\\n  }\\n\\n  const result: ReconciliationResult = {\\n    reposQueued,\\n    usersQueued,\\n    targetedRepo: options.repoFullName,\\n  };\\n\\n  log(\\\"cron_complete\\\", { ...result });\\n\\n  return result;\\n}\\n\",\"numLines\":436,\"startLine\":1,\"totalLines\":436}},\"sourceToolAssistantUUID\":\"a0bba130-bd9a-44b4-956d-5aa127746926\"}\n{\"parentUuid\":\"7065194c-bf5f-49d4-a96d-50e5f45c059d\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/evisdrenova/code/entire/devenv/cli\",\"sessionId\":\"b3a25300-460d-43d2-8f54-c13ecfe5387c\",\"version\":\"2.1.56\",\"gitBranch\":\"main\",\"slug\":\"resilient-squishing-fern\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01APSALus41sGBDbGw5c93Dw\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Now let me check the commit push event processing to see where we'd also want to hook in, and the wrangler.jsonc queue config.\"}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":8308,\"cache_read_input_tokens\":108089,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":8308},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"}},\"requestId\":\"req_011CYiaJ6WwaTHphepTr9MxQ\",\"type\":\"assistant\",\"uuid\":\"038c5d51-5391-4085-a77b-cf66b7da4b69\",\"timestamp\":\"2026-03-04T19:15:14.187Z\"}\n{\"parentUuid\":\"038c5d51-5391-4085-a77b-cf66b7da4b69\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/evisdrenova/code/entire/devenv/cli\",\"sessionId\":\"b3a25300-460d-43d2-8f54-c13ecfe5387c\",\"version\":\"2.1.56\",\"gitBranch\":\"main\",\"slug\":\"resilient-squishing-fern\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01APSALus41sGBDbGw5c93Dw\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01Y2AUSdmYkBUWFudyb2KCvJ\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/evisdrenova/code/entire/devenv/entire.io/api/src/lib/webhook/processing.ts\",\"offset\":995,\"limit\":80},