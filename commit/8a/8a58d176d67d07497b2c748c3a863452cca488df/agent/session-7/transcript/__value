n    29→}\\n    30→\\n    31→// Retrieve a large webhook payload from KV (TTL handles cleanup)\\n    32→export async function retrieveWebhookPayload(\\n    33→  cache: KVNamespace,\\n    34→  deliveryId: string\\n    35→): Promise<string | null> {\\n    36→  return cache.get(`webhook_payload:${deliveryId}`);\\n    37→}\\n    38→\\n    39→// Process a single webhook message from the queue\\n    40→export async function processQueueMessage(\\n    41→  message: WebhookMessage,\\n    42→  attempts: number,\\n    43→  maxRetries: number,\\n    44→  queueWaitMs: number,\\n    45→  db: Db,\\n    46→  cache: KVNamespace,\\n    47→  env: Env,\\n    48→  processEvent: (\\n    49→    eventType: string,\\n    50→    action: string | null,\\n    51→    payload: Record<string, unknown>,\\n    52→    db: Db,\\n    53→    cache: KVNamespace,\\n    54→    env?: Env\\n    55→  ) => Promise<void>\\n    56→): Promise<{ result: ProcessResult; error?: unknown }> {\\n    57→  return traced(\\\"webhook-queue.processMessage\\\", async () => {\\n    58→    const span = trace.getActiveSpan();\\n    59→    const { deliveryId, eventType, action, payload } = message;\\n    60→\\n    61→    span?.setAttributes({\\n    62→      \\\"webhook.delivery_id\\\": deliveryId,\\n    63→      \\\"webhook.event_type\\\": eventType,\\n    64→      \\\"webhook.action\\\": action ?? \\\"none\\\",\\n    65→      \\\"webhook.repo\\\": message.repositoryName ?? \\\"unknown\\\",\\n    66→      \\\"webhook.queue.attempt\\\": attempts,\\n    67→      \\\"webhook.queue.max_retries\\\": maxRetries,\\n    68→    });\\n    69→    span?.setAttribute(\\\"queue.message_wait_ms\\\", queueWaitMs);\\n    70→\\n    71→    // Idempotency check - skip if already processed (e.g., via HTTP retry)\\n    72→    // Uses same key format as HTTP handler: webhook:{deliveryId} with value \\\"processed\\\"\\n    73→    const idempotencyKey = `webhook:${deliveryId}`;\\n    74→    const existingState = await cache.get(idempotencyKey);\\n    