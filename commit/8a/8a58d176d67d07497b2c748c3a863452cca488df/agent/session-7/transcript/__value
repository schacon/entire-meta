 meta.initial_attribution.human_removed ?? 0,\\n                        totalCommitted: meta.initial_attribution.total_committed ?? 0,\\n                        agentPercentage: meta.initial_attribution.agent_percentage ?? 0,\\n                      };\\n                    }\\n                  } catch {\\n                    // Invalid JSON\\n                  }\\n                }\\n\\n                const parseResult = getParserForAgent(agent).parse(transcriptContent);\\n                const messages = filterRelevantMessages(\\n                  parseResult.messages,\\n                  transcriptIdentifierAtStart,\\n                );\\n\\n                return {\\n                  sessionId,\\n                  agent,\\n                  messages,\\n                  transcriptIdentifierAtStart,\\n                  tokenUsage,\\n                  attribution,\\n                  parsingFallback: parseResult.isFallback || undefined,\\n                  parsingWarning: parseResult.warning,\\n                };\\n              } catch {\\n                return null;\\n              }\\n            })(),\\n          );\\n\\n        const fetchedSessions = await Promise.all(sessionPromises);\\n        for (const s of fetchedSessions) {\\n          if (s) sessions.push(s);\\n        }\\n      } else {\\n        // Fallback for checkpoints without sessions array (single session in 0/ per v1 spec)\\n        const [transcriptContent, sessionMetadataContent] = await Promise.all([\\n          fetchFileAtCommit(\\n            repoFullName,\\n            `${folderPath}/0/full.jsonl`,\\n            CHECKPOINT_BRANCH,\\n            token,\\n          ).catch(() => null),\\n          fetchFileAtCommit(\\n            repoFullName,\\n            `${folderPath}/0/metadata.json`,\\n            CHECKPOINT_BRANCH,\\n            token,\\n          ).catch(() => null),\\n        ]);\\n\\n        if (transcriptContent) {\\n          let agent = \\\"Claude Code\\\";\\n          le