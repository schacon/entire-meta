repos accessible without login)\\n// Middleware applied per-route for the same reason as above.\\nconst repoRoutes = new Hono<{ Bindings: Env; Variables: Variables }>();\\n\\n// Mount admin routes under /admin/* — apply requireAuth before admin's own guard\\nuserRoutes.use(\\\"/admin\\\", requireAuth);\\nuserRoutes.use(\\\"/admin/*\\\", requireAuth);\\nuserRoutes.route(\\\"/admin\\\", adminRoutes);\\n\\n// Detect GitHub 401 errors so we can tell the frontend to re-authenticate\\n// rather than showing a generic 500 error.\\n// GitHub lib throws errors in two formats:\\n//   \\\"GitHub API error: 401\\\" / \\\"GitHub GraphQL error: 401\\\"\\n//   \\\"Failed to fetch <thing>: 401\\\"\\nfunction isGitHubAuthError(err: unknown): boolean {\\n  if (!(err instanceof Error)) return false;\\n  return /: 401$/.test(err.message);\\n}\\n\\n// Helper to check repo access. Returns repo record if user has access.\\n// Returns null if repo doesn't exist (and requireRepo is false).\\n// Returns 404 response if unauthorized OR repo required but missing.\\n// Using 404 for unauthorized prevents fishing for private repo existence.\\n//\\n// When userId is undefined (unauthenticated), only public repos are returned.\\ntype RepoRecord = Repo;\\n\\nasync function checkRepoAccess(\\n  db: Db,\\n  repoFullName: string,\\n  userId: string | undefined,\\n  options: { requireRepo: true },\\n): Promise<RepoRecord | Response>;\\nasync function checkRepoAccess(\\n  db: Db,\\n  repoFullName: string,\\n  userId: string | undefined,\\n  options?: { requireRepo?: false },\\n): Promise<RepoRecord | null | Response>;\\nasync function checkRepoAccess(\\n  db: Db,\\n  repoFullName: string,\\n  userId: string | undefined,\\n  options: { requireRepo?: boolean } = {},\\n): Promise<RepoRecord | null | Response> {\\n  if (userId) {\\n    // Authenticated: check user_repos join (existing behavior)\\n    const result = await db.repos.getByFullNameWithAccess(repoFullName, userId);\\n\\n    if (result.status === \\\"found\\\") {\\n      return result.repo;\\n    }\\n\\n    if (result.status === \\\"not_found\\\") {\\n      if (options.requireRepo) {\\n        return new Response(JSON.stringify({ error: \\\"Repository not found\\\" }), {\\n          status: 404,\\n          headers: { \\\"Content-Type\\\": \\\"application/json\\\" },\\n        });\\n      }\\n      return null;\\n    }\\n\\n    // status === \\\"no_access\\\"\\n    // Fall back to public repo access for authenticated users too.\\n    // This ensures signed-in users can view public repos they don't explicitly own.\\n    const publicRepo = await db.repos.getPublicByFullName(repoFullName);\\n    if (publicRepo) return publicRepo;\\n\\n    // Private repo with no access: return 404 to prevent repo fishing.\\n    return new Response(JSON.stringify({ error: \\\"Repository not found\\\" }), {\\n      status: 404,\\n      headers: { \\\"Content-Type\\\": \\\"application/json\\\" },\\n    });\\n  }\\n\\n  // Unauthenticated: only serve public repos (hardcoded is_private = false)\\n  const repo = await db.repos.getPublicByFullName(repoFullName);\\n  if (!repo) {\\n    if (options.requireRepo) {\\n      return new Response(JSON.stringify({ error: \\\"Repository not found\\\" }), {\\n        status: 404,\\n        headers: { \\\"Content-Type\\\": \\\"application/json\\\" },\\n      });\\n    }\\n    return null;\\n  }\\n  return repo;\\n}\\n\\nasync function getInstallationTokenForRepo(\\n  db: Db,\\n  env: Env,\\n  repo: RepoRecord | null,\\n): Promise<string | undefined> {\\n  if (!repo?.installation_id) return undefined;\\n\\n  const githubInstallationId = await db.installations.getGithubId(repo.installation_id);\\n  if (!githubInstallationId) return undefined;\\n\\n  try {\\n    return await getInstallationToken(\\n      githubInstallationId,\\n      { appId: env.GITHUB_CLIENT_ID, privateKey: env.GITHUB_APP_PRIVATE_KEY },\\n      env.ENTIRE_CACHE,\\n    );\\n  } catch {\\n    return undefined;\\n  }\\n}\\n\\ninterface RepoRequestTokenResult {\\n  token: string | null;\\n  response?: Response;\\n}\\n\\nasync function getGitHubTokenForRepoRequest(\\n  c: Context<{ Bindings: Env; Variables: Variables }>,\\n  db: Db,\\n  userId: string | undefined,\\n  repo: RepoRecord | null,\\n): Promise<RepoRequestTokenResult> {\\n  if (userId) {\\n    const user = await db.users.getWithCache(c.env.ENTIRE_CACHE, userId);\\n    if (!user) {\\n      return {\\n        token: null,\\n        response: new Response(JSON.stringify({ error: \\\"User not found\\\" }), {\\n          status: 404,\\n          headers: { \\\"Content-Type\\\": \\\"application/json\\\" },\\n        }),\\n      };\\n    }\\n\\n    if (user.github_token_enc) {\\n      const result = await getValidGitHubTokenFromContext(c, db, user);\\n      return { token: result.token };\\n    }\\n  }\\n\\n  const installationToken = await getInstallationTokenForRepo(db, c.env, repo);\\n  return { token: installationToken ?? null };\\n}\\n\\n// Result type for local dev sync\\ninterface LocalDevSyncResult {\\n  repoRecord: RepoRecord | null;\\n  checkpoints: CheckpointWithCommit[];\\n}\\n\\n// Helper for local dev: fetches repo from GitHub if needed, syncs checkpoints, returns data\\n// Used when ?source=github is passed (webhooks don't fire in local dev)\\nasync function fetchRepoWithSyncForLocalDev(\\n  db: Db,\\n  repoFullName: string,\\n  userId: string,\\n  branch: string,\\n  limit: number,\\n  getGitHubToken: () => Promise<string | null>,\\n): Promise<LocalDevSyncResult | Response> {\\n  // Check repo access first\\n  const repoAccess = await checkRepoAccess(db, repoFullName, userId);\\n  if (repoAccess instanceof Response) return repoAccess;\\n  let repoRecord = repoAccess;\\n\\n  // If repo not in DB, create it from GitHub API\\n  if (!repoRecord) {\\n    const token = await getGitHubToken();\\n    if (!token) {\\n      return new Response(\\n        JSON.stringify({ error: \\\"GitHub token required for this operation\\\" }),\\n        { status: 403, headers: { \\\"Content-Type\\\": \\\"application/json\\\" } },\\n      );\\n    }\\n\\n    const repoResponse = await fetch(\\n      `https://api.github.com/repos/${repoFullName}`,\\n      {\\n        headers: {\\n          Authorization: `Bearer ${token}`,\\n          Accept: \\\"application/vnd.github+json\\\",\\n          \\\"User-Agent\\\": \\\"entire-api\\\",\\n        },\\n      },\\n    );\\n\\n    if (repoResponse.ok) {\\n      const ghRepo = (await repoResponse.json()) as {\\n        id: number;\\n        name: string;\\n        full_name: string;\\n        description: string | null;\\n        html_url: string;\\n        language: string | null;\\n        stargazers_count: number;\\n        fork: boolean;\\n        private: boolean;\\n        pushed_at: string | null;\\n      };\\n\\n      await db.repos.upsert({\\n        github_id: ghRepo.id,\\n        full_name: ghRepo.full_name,\\n        name: ghRepo.name,\\n        description: ghRepo.description,\\n        html_url: ghRepo.html_url,\\n        language: ghRepo.language,\\n        stargazers_count: ghRepo.stargazers_count,\\n        is_fork: ghRepo.fork,\\n        is_private: ghRepo.private,\\n        pushed_at: ghRepo.pushed_at,\\n      });\\n\\n      repoRecord = await db.repos.getByFullName(repoFullName);\\n    }\\n  }\\n\\n  // Trigger sync and fetch checkpoints\\n  if (repoRecord) {\\n    const token = await getGitHubToken();\\n    if (!token) {\\n      return new Response(\\n        JSON.stringify({ error: \\\"GitHub token required for this operation\\\" }),\\n        { status: 403, headers: { \\\"Content-Type\\\": \\\"application/json\\\" } },\\n      );\\n    }\\n\\n    const { syncRepoCheckpoints } = await import(\\\"../lib/repo-sync-service\\\");\\n    await syncRepoCheckpoints(db, repoRecord.id, token, {\\n      skipAppInstallationCheck: true,\\n      extraBranches: [branch],\\n    });\\n\\n    const checkpoints = await db.checkpoints.getForBranch(\\n      repoRecord.id,\\n      branch,\\n      { limit },\\n    );\\n    return { repoRecord, checkpoints };\\n  }\\n\\n  return { repoRecord: null, checkpoints: [] };\\n}\\n\\n// Get repos from database (auto-fetches from GitHub on first visit)\\nuserRoutes.get(\\\"/repos\\\", requireAuth, async (c) => {\\n  const userId = c.get(\\\"userId\\\");\\n\\n  try {\\n    // Check if user has ever synced repos (use KV-cached user to avoid DB roundtrip)\\n    const db = getDb(c.env);\\n    const user = await db.users.getWithCache(c.env.ENTIRE_CACHE, userId);\\n    if (!user) {\\n      return c.json({ error: \\\"User not found\\\" }, 404);\\n    }\\n    if (!user.github_login) {\\n      return c.json({ error: \\\"User has no GitHub login\\\" }, 400);\\n    }\\n\\n    // If never synced, handle based on environment\\n    if (!user.repos_synced_at) {\\n      // In production, background job handles this - return empty and let client poll\\n      if (!isLocalDev(c.env)) {\\n        console.log(\\n          `First visit for user ${user.github_login}, repos syncing in background`,\\n        );\\n        return c.json({\\n          repos: [],\\n          updated_at: new Date().toISOString(),\\n          from_db: false,\\n          syncing: true, // Indicate sync is in progress\\n        });\\n      }\\n\\n      // Local development: fetch synchronously (no background jobs)\\n      console.log(\\n        `[Local dev] First visit for user ${user.github_login}, fetching repos from GitHub`,\\n      );\\n\\n      let token: string | undefined;\\n      if (user.github_token_enc) {\\n        const result = await getValidGitHubTokenFromContext(c, db, user);\\n        token = result.token;\\n      }\\n\\n      // Fetch user repos and installation repos in parallel\\n      const installationsResult = token\\n        ? await fetchUserInstallations(token)\\n        : { installations: [], error: false };\\n\\n      // Check for installations fetch error - don't proceed with partial data\\n      // as this would incorrectly set app_has_access = false for all repos\\n      if (installationsResult.error) {\\n        console.error(\\n          `[Local dev] Failed to fetch installations for user ${user.github_login}`,\\n        );\\n        return c.json({ error: \\\"Failed to fetch installations\\\" }, 500);\\n      }\\n\\n      const [githubRepos, ...installationReposResults] = await Promise.all([\\n        fetchUserReposWithForks(user.github_login, token),\\n        ...installationsResult.installations.map((inst) =>\\n          fetchInstallationRepos(inst.id, token!),\\n        ),\\n      ]);\\n\\n      // Build map of repos by github_id, starting with user repos (they have permission info)\\n      const reposByGithubId = new Map<number, GitHubRepoData>();\\n      for (const r of githubRepos) {\\n        reposByGithubId.set(r.id, {\\n          github_id: r.id,\\n          name: r.name,\\n          full_name: r.full_name,\\n          description: r.description,\\n          html_url: r.html_url,\\n          language: r.language,\\n          stargazers_count: r.stargazers_count,\\n          is_fork: r.fork,\\n          is_private: r.private,\\n          pushed_at: r.pushed_at || r.updated_at,\\n          default_branch: r.default_branch,\\n          permission: getPermissionLevel(r.permissions),\\n        });\\n      }\\n\\n      // Add installation repos that aren't already in the map\\n      const installationRepoIds = new Set<number>();\\n      for (const repos of installationReposResults) {\\n        if (repos) {\\n          for (const repo of repos) {\\n            installationRepoIds.add(repo.github_id);\\n            if (!reposByGithubId.has(repo.github_id)) {\\n              reposByGithubId.set(repo.github_id, {\\n                github_id: repo.github_id,\\n                name: repo.name,\\n                full_name: repo.full_name,\\n                description: repo.description,\\n                html_url: repo.html_url,\\n                language: repo.language,\\n                stargazers_count: repo.stargazers_count,\\n                is_fork: repo.is_fork,\\n                is_private: repo.is_private,\\n                pushed_at: repo.pushed_at,\\n                default_branch: repo.default_branch,\\n                permission: \\\"read\\\",\\n              });\\n            }\\n          }\\n        }\\n      }\\n\\n      // Convert map to array for upsert\\n      const reposToUpsert = Array.from(reposByGithubId.values());\\n\\n      // Upsert repos to database with installation repo IDs for app_has_access\\n      await db.repos.upsertForUser(\\n        userId,\\n        reposToUpsert,\\n        installationRepoIds,\\n        c.env.ENTIRE_CACHE,\\n      );\\n\\n      const now = new Date().toISOString();\\n\\n      // Return repos (filter out forks unless user explicitly granted app access)\\n      const repos = reposToUpsert\\n        .filter((r) => !r.is_fork || installationRepoIds.has(r.github_id))\\n        .map((r) => ({\\n          name: r.name,\\n          full_name: r.full_name,\\n          description: r.description,\\n          html_url: r.html_url,\\n          stargazers_count: r.stargazers_count,\\n          language: r.language,\\n          private: r.is_private,\\n          updated_at: r.pushed_at || now,\\n          default_branch: r.default_branch ?? \\\"main\\\",\\n          permission: r.permission,\\n          checkpoint_count: null, // Not yet synced\\n        }));\\n\\n      return c.json({\\n        repos,\\n        updated_at: now,\\n        from_db: false, // Fetched fresh from GitHub\\n      });\\n    }\\n\\n    // Normal path: read from database\\n    const dbRepos = await db.repos.getForUser(userId);\\n\\n    // Transform DB format to API format (filter out forks unless user explicitly granted app access)\\n    const repos = dbRepos\\n      .filter((r) => !r.is_fork || r.app_has_access)\\n      .map((r) => ({\\n        name: r.name,\\n        full_name: r.full_name,\\n        description: r.description,\\n        html_url: r.html_url,\\n        stargazers_count: r.stargazers_count,\\n        language: r.language,\\n        private: r.is_private,\\n        updated_at: r.pushed_at || r.synced_at || new Date().toISOString(),\\n        default_branch: r.default_branch ?? \\\"main\\\",\\n        permission: r.permission,\\n        checkpoint_count: r.checkpoint_count ?? 0,\\n      }));\\n\\n    // Get last sync time from first repo (they all have same synced_at after a sync)\\n    const lastSyncedAt = dbRepos.length > 0 ? dbRepos[0].synced_at : null;\\n\\n    return c.json({\\n      repos,\\n      updated_at: lastSyncedAt || new Date().toISOString(),\\n      from_db: true,\\n    });\\n  } catch (err) {\\n    console.error(\\\"Failed to get repos from DB:\\\", err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch repos\\\" }, 500);\\n  }\\n});\\n\\n// Sync repos from GitHub to database (dev only)\\nuserRoutes.post(\\\"/repos/sync\\\", requireAuth, async (c) => {\\n  if (!isLocalDev(c.env)) {\\n    return c.notFound();\\n  }\\n\\n  const userId = c.get(\\\"userId\\\");\\n\\n  try {\\n    const db = getDb(c.env);\\n    const user = await db.users.getWithCache(c.env.ENTIRE_CACHE, userId);\\n    if (!user) {\\n      return c.json({ error: \\\"User not found\\\" }, 404);\\n    }\\n    if (!user.github_login) {\\n      return c.json({ error: \\\"User has no GitHub login\\\" }, 400);\\n    }\\n\\n    let token: string | undefined;\\n    if (user.github_token_enc) {\\n      const result = await getValidGitHubTokenFromContext(c, db, user);\\n      token = result.token;\\n    }\\n\\n    // Fetch installations to get installation repos\\n    // If this fails, we continue with OAuth repos only (graceful degradation)\\n    const installationsResult = token\\n      ? await fetchUserInstallations(token)\\n      : { installations: [], error: false };\\n\\n    if (installationsResult.error) {\\n      console.warn(\\n        `Failed to fetch installations for user ${user.github_login}, continuing with OAuth repos only`,\\n      );\\n    }\\n\\n    // Fetch user repos and installation repos in parallel\\n    const [githubRepos, ...installationReposResults] = await Promise.all([\\n      fetchUserReposWithForks(user.github_login, token),\\n      ...installationsResult.installations.map((inst) =>\\n        fetchInstallationRepos(inst.id, token!),\\n      ),\\n    ]);\\n\\n    // Build map of repos by github_id, starting with user repos (they have permission info)\\n    const reposByGithubId = new Map<number, GitHubRepoData>();\\n    for (const r of githubRepos) {\\n      reposByGithubId.set(r.id, {\\n        github_id: r.id,\\n        name: r.name,\\n        full_name: r.full_name,\\n        description: r.description,\\n        html_url: r.html_url,\\n        language: r.language,\\n        stargazers_count: r.stargazers_count,\\n        is_fork: r.fork,\\n        is_private: r.private,\\n        pushed_at: r.pushed_at || r.updated_at,\\n        default_branch: r.default_branch,\\n        permission: getPermissionLevel(r.permissions),\\n      });\\n    }\\n\\n    // Add installation repos that aren't already in the map\\n    const installationRepoIds = new Set<number>();\\n    for (const repos of installationReposResults) {\\n      if (repos) {\\n        for (const repo of repos) {\\n          installationRepoIds.add(repo.github_id);\\n          if (!reposByGithubId.has(repo.github_id)) {\\n            reposByGithubId.set(repo.github_id, {\\n              github_id: repo.github_id,\\n              name: repo.name,\\n              full_name: repo.full_name,\\n              description: repo.description,\\n              html_url: repo.html_url,\\n              language: repo.language,\\n              stargazers_count: repo.stargazers_count,\\n              is_fork: repo.is_fork,\\n              is_private: repo.is_private,\\n              pushed_at: repo.pushed_at,\\n              default_branch: repo.default_branch,\\n              permission: \\\"read\\\",\\n            });\\n          }\\n        }\\n      }\\n    }\\n\\n    // Convert map to array for upsert\\n    const reposToUpsert = Array.from(reposByGithubId.values());\\n\\n    // Upsert all repos with installation repo IDs for app_has_access\\n    await db.repos.upsertForUser(\\n      userId,\\n      reposToUpsert,\\n      installationRepoIds,\\n      c.env.ENTIRE_CACHE,\\n    );\\n\\n    // Delete repos that no longer exist (include both OAuth and installation repos)\\n    const currentGithubIds = Array.from(reposByGithubId.keys());\\n    await db.repos.deleteStaleForUser(userId, currentGithubIds);\\n\\n    // Get non-fork repos for PRs (include forks with explicit app access)\\n    const nonForkRepos = reposToUpsert.filter((r) => !r.is_fork || installationRepoIds.has(r.github_id));\\n    const repoNames = nonForkRepos.map((r) => r.full_name);\\n\\n    // Record sync start time before fetching PRs from GitHub\\n    // This prevents race conditions with webhooks that may insert PRs during sync\\n    const syncStartTime = new Date().toISOString();\\n\\n    // Fetch PRs from GitHub\\n    const prs = await fetchUserPRs(repoNames, token);\\n\\n    // Persist PRs to database\\n    const prData: GitHubPRData[] = prs.map((pr) => ({\\n      github_pr_id: pr.id,\\n      number: pr.number,\\n      title: pr.title,\\n      html_url: pr.html_url,\\n      state: pr.state,\\n      draft: pr.draft,\\n      created_at: pr.created_at,\\n      updated_at: pr.updated_at,\\n      repo_full_name: pr.repo_full_name,\\n    }));\\n    await db.prs.upsertPRsForUser(userId, prData);\\n\\n    // Delete PRs that are no longer open (only those that existed before sync started)\\n    const currentPRIds = prs.map((pr) => pr.id);\\n    await db.prs.deleteStalePRsForUser(\\n      userId,\\n      currentPRIds,\\n      syncStartTime,\\n    );\\n\\n    const now = new Date().toISOString();\\n\\n    // Return the synced repos with PRs\\n    // checkpoint_count is null until checkpoint sync runs (indicates \\\"unknown\\\" vs \\\"zero\\\")\\n    const repos = nonForkRepos.map((r) => ({\\n      name: r.name,\\n      full_name: r.full_name,\\n      description: r.description,\\n      html_url: r.html_url,\\n      stargazers_count: r.stargazers_count,\\n      language: r.language,\\n      private: r.is_private,\\n      updated_at: r.pushed_at || new Date().toISOString(),\\n      permission: r.permission,\\n      checkpoint_count: null,\\n    }));\\n\\n    return c.json({\\n      repos,\\n      prs,\\n      updated_at: now,\\n      synced: true,\\n      total_synced: reposToUpsert.length,\\n    });\\n  } catch (err) {\\n    if (isGitHubAuthError(err)) {\\n      return c.json({ error: \\\"GitHub token expired\\\" }, 401);\\n    }\\n    console.error(\\\"Failed to sync repos:\\\", err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to sync repos\\\" }, 500);\\n  }\\n});\\n\\n// Get cached contributions (stale-while-revalidate)\\nuserRoutes.get(\\\"/contrib\\\", requireAuth, async (c) => {\\n  const userId = c.get(\\\"userId\\\");\\n\\n  const cacheKey = `contrib:${userId}`;\\n\\n  // Try cache first\\n  const cached = await c.env.ENTIRE_CACHE.get<CachedContributions>(\\n    cacheKey,\\n    \\\"json\\\",\\n  );\\n\\n  if (cached) {\\n    return c.json({\\n      ...cached,\\n      from_cache: true,\\n    });\\n  }\\n\\n  // No cache - fetch fresh data\\n  try {\\n    const db = getDb(c.env);\\n    const user = await db.users.getWithCache(c.env.ENTIRE_CACHE, userId);\\n    if (!user) {\\n      return c.json({ error: \\\"User not found\\\" }, 404);\\n    }\\n    if (!user.github_login) {\\n      return c.json({ error: \\\"User has no GitHub login\\\" }, 400);\\n    }\\n\\n    let token: string | undefined;\\n    if (user.github_token_enc) {\\n      const result = await getValidGitHubTokenFromContext(c, db, user);\\n      token = result.token;\\n    }\\n\\n    const contributions = await fetchUserContributions(\\n      user.github_login,\\n      token,\\n    );\\n\\n    const data: CachedContributions = {\\n      ...contributions,\\n      updated_at: new Date().toISOString(),\\n    };\\n\\n    await c.env.ENTIRE_CACHE.put(cacheKey, JSON.stringify(data), {\\n      expirationTtl: 60 * 60 * 24, // 24h TTL\\n    });\\n\\n    return c.json({ ...data, from_cache: false });\\n  } catch (err) {\\n    if (isGitHubAuthError(err)) {\\n      return c.json({ error: \\\"GitHub token expired\\\" }, 401);\\n    }\\n    console.error(\\\"Failed to fetch contributions:\\\", err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch contributions\\\" }, 500);\\n  }\\n});\\n\\n// Get cached GitHub followers/following\\nuserRoutes.get(\\\"/followers\\\", requireAuth, async (c) => {\\n  const userId = c.get(\\\"userId\\\");\\n\\n  const cacheKey = `followers:${userId}`;\\n  const cached = await c.env.ENTIRE_CACHE.get<CachedFollowers>(\\n    cacheKey,\\n    \\\"json\\\",\\n  );\\n\\n  if (cached) {\\n    return c.json({ ...cached, from_cache: true });\\n  }\\n\\n  try {\\n    const db = getDb(c.env);\\n    const user = await db.users.getWithCache(c.env.ENTIRE_CACHE, userId);\\n    if (!user) {\\n      return c.json({ error: \\\"User not found\\\" }, 404);\\n    }\\n    if (!user.github_login) {\\n      return c.json({ error: \\\"User has no GitHub login\\\" }, 400);\\n    }\\n\\n    const { followers, following } = await fetchUserFollowers(\\n      user.github_login,\\n    );\\n\\n    const data: CachedFollowers = {\\n      followers,\\n      following,\\n      updated_at: new Date().toISOString(),\\n    };\\n\\n    await c.env.ENTIRE_CACHE.put(cacheKey, JSON.stringify(data), {\\n      expirationTtl: 60 * 60 * 24,\\n    });\\n\\n    return c.json({ ...data, from_cache: false });\\n  } catch (err) {\\n    console.error(\\\"Failed to fetch followers:\\\", err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch followers\\\" }, 500);\\n  }\\n});\\n\\n// Get cached starred repos\\nuserRoutes.get(\\\"/starred\\\", requireAuth, async (c) => {\\n  const userId = c.get(\\\"userId\\\");\\n\\n  const cacheKey = `starred:${userId}`;\\n  const cached = await c.env.ENTIRE_CACHE.get<CachedStarred>(cacheKey, \\\"json\\\");\\n\\n  if (cached) {\\n    return c.json({ ...cached, from_cache: true });\\n  }\\n\\n  try {\\n    const db = getDb(c.env);\\n    const user = await db.users.getWithCache(c.env.ENTIRE_CACHE, userId);\\n    if (!user) {\\n      return c.json({ error: \\\"User not found\\\" }, 404);\\n    }\\n    if (!user.github_login) {\\n      return c.json({ error: \\\"User has no GitHub login\\\" }, 400);\\n    }\\n\\n    const starred = await fetchUserStarred(user.github_login);\\n\\n    const data: CachedStarred = {\\n      starred,\\n      updated_at: new Date().toISOString(),\\n    };\\n\\n    await c.env.ENTIRE_CACHE.put(cacheKey, JSON.stringify(data), {\\n      expirationTtl: 60 * 60 * 24,\\n    });\\n\\n    return c.json({ ...data, from_cache: false });\\n  } catch (err) {\\n    console.error(\\\"Failed to fetch starred:\\\", err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch starred repos\\\" }, 500);\\n  }\\n});\\n\\n// Get cached watched repos\\nuserRoutes.get(\\\"/watched\\\", requireAuth, async (c) => {\\n  const userId = c.get(\\\"userId\\\");\\n\\n  const cacheKey = `watched:${userId}`;\\n  const cached = await c.env.ENTIRE_CACHE.get<CachedWatched>(cacheKey, \\\"json\\\");\\n\\n  if (cached) {\\n    return c.json({ ...cached, from_cache: true });\\n  }\\n\\n  try {\\n    const db = getDb(c.env);\\n    const user = await db.users.getWithCache(c.env.ENTIRE_CACHE, userId);\\n    if (!user) {\\n      return c.json({ error: \\\"User not found\\\" }, 404);\\n    }\\n    if (!user.github_login) {\\n      return c.json({ error: \\\"User has no GitHub login\\\" }, 400);\\n    }\\n\\n    const watched = await fetchUserWatched(user.github_login);\\n\\n    const data: CachedWatched = {\\n      watched,\\n      updated_at: new Date().toISOString(),\\n    };\\n\\n    await c.env.ENTIRE_CACHE.put(cacheKey, JSON.stringify(data), {\\n      expirationTtl: 60 * 60 * 24,\\n    });\\n\\n    return c.json({ ...data, from_cache: false });\\n  } catch (err) {\\n    console.error(\\\"Failed to fetch watched:\\\", err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch watched repos\\\" }, 500);\\n  }\\n});\\n\\n// Get cached open PRs\\nuserRoutes.get(\\\"/prs\\\", requireAuth, async (c) => {\\n  const userId = c.get(\\\"userId\\\");\\n\\n  try {\\n    // Read PRs from database (includes repo_full_name from JOIN)\\n    const db = getDb(c.env);\\n    const dbPRs = await db.prs.getOpenPRsForUser(userId);\\n\\n    // Transform to API format\\n    const prs = dbPRs.map((pr) => ({\\n      id: pr.github_pr_id,\\n      number: pr.number,\\n      title: pr.title,\\n      html_url: pr.html_url,\\n      state: pr.state,\\n      repo_full_name: pr.repo_full_name,\\n      created_at: pr.created_at,\\n      updated_at: pr.updated_at,\\n      draft: pr.draft,\\n    }));\\n\\n    // Get last synced time from first PR (or use current time if no PRs)\\n    const lastSyncedAt =\\n      dbPRs.length > 0 ? dbPRs[0].synced_at : new Date().toISOString();\\n\\n    return c.json({\\n      prs,\\n      updated_at: lastSyncedAt,\\n      from_db: true,\\n    });\\n  } catch (err) {\\n    console.error(\\\"Failed to fetch PRs:\\\", err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch PRs\\\" }, 500);\\n  }\\n});\\n\\n// Get sync status (last webhook update timestamp for polling)\\n// Also triggers background sync if needed (visit-triggered sync)\\nuserRoutes.get(\\\"/sync-status\\\", requireAuth, async (c) => {\\n  const userId = c.get(\\\"userId\\\");\\n\\n  // Update last_visited_at timestamp (for dead-user filtering)\\n  const db = getDb(c.env);\\n  await db.users.updateLastVisitedAt(userId);\\n\\n  // Get last update timestamp from KV\\n  const lastUpdate = await c.env.ENTIRE_CACHE.get(\\n    `sync:lastUpdate:${userId}`,\\n  );\\n\\n  // Check if sync is already in progress\\n  const syncInProgress = await isSyncInProgress(\\n    c.env.ENTIRE_CACHE,\\n    userId,\\n  );\\n\\n  // Note: In the new repo-centric architecture, repos are synced immediately\\n  // via POST /repos/sync. This endpoint just reports status for frontend polling.\\n  // Checkpoint syncs are handled per-repo via REPO_SYNC_QUEUE.\\n\\n  return c.json({\\n    lastUpdate: lastUpdate ? parseInt(lastUpdate, 10) : null,\\n    syncInProgress,\\n  });\\n});\\n\\n// Get checkpoints for the current user (for dashboard)\\nuserRoutes.get(\\\"/user/checkpoints\\\", requireAuth, async (c) => {\\n  const userId = c.get(\\\"userId\\\");\\n\\n  // Parse query params\\n  const timeframe = c.req.query(\\\"timeframe\\\") || \\\"last-6-months\\\";\\n  const limitParam = c.req.query(\\\"limit\\\");\\n  const parsedLimit = limitParam ? parseInt(limitParam, 10) : 500;\\n  const limit =\\n    Number.isNaN(parsedLimit) || parsedLimit <= 0\\n      ? 500\\n      : Math.min(parsedLimit, 1000);\\n\\n  // Calculate date range based on timeframe\\n  const now = new Date();\\n  let startDate: Date;\\n  const endDate = now;\\n\\n  switch (timeframe) {\\n    case \\\"last-month\\\":\\n      startDate = new Date(now);\\n      startDate.setDate(startDate.getDate() - 30);\\n      break;\\n    case \\\"last-3-months\\\":\\n      startDate = new Date(now);\\n      startDate.setMonth(startDate.getMonth() - 3);\\n      break;\\n    case \\\"last-6-months\\\":\\n    default:\\n      startDate = new Date(now);\\n      startDate.setMonth(startDate.getMonth() - 6);\\n      break;\\n  }\\n\\n  try {\\n    // Look up user's github_id from session userId (uses KV cache)\\n    const db = getDb(c.env);\\n    const user = await db.users.getWithCache(c.env.ENTIRE_CACHE, userId);\\n    if (!user) {\\n      return c.json({ error: \\\"User not found\\\" }, 404);\\n    }\\n\\n    // Check if any repos with app access are still pending initial checkpoint sync\\n    const pendingSyncCount = await db.repos.countPendingSync(userId);\\n\\n    const syncing = (pendingSyncCount ?? 0) > 0;\\n\\n    const checkpoints = await db.checkpoints.getByUser(\\n      userId,\\n      user.github_id,\\n      startDate.toISOString(),\\n      endDate.toISOString(),\\n      limit,\\n    );\\n\\n    return c.json({\\n      checkpoints,\\n      timeframe,\\n      updated_at: new Date().toISOString(),\\n      syncing,\\n    });\\n  } catch (err) {\\n    console.error(\\\"Failed to fetch user checkpoints:\\\", err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch checkpoints\\\" }, 500);\\n  }\\n});\\n\\n// Get cached checkpoint activity for repos\\nuserRoutes.get(\\\"/activity\\\", requireAuth, async (c) => {\\n  const userId = c.get(\\\"userId\\\");\\n\\n  try {\\n    // Compute activity by aggregating checkpoint commits\\n    const db = getDb(c.env);\\n    const activity = await db.checkpoints.getActivityForUser(userId);\\n\\n    return c.json({\\n      activity,\\n      updated_at: new Date().toISOString(),\\n    });\\n  } catch (err) {\\n    console.error(\\\"Failed to fetch checkpoint activity:\\\", err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch checkpoint activity\\\" }, 500);\\n  }\\n});\\n\\n// Get cached commits for a specific repo\\nrepoRoutes.get(\\\"/:org/:repo/commits\\\", optionalAuth, rateLimitUnauthenticated, async (c) => {\\n  const userId = c.get(\\\"userId\\\") as string | undefined;\\n\\n  const org = c.req.param(\\\"org\\\");\\n  const repo = c.req.param(\\\"repo\\\");\\n  const repoFullName = `${org}/${repo}`;\\n  const cacheKey = `commits:${repoFullName}`;\\n\\n  const db = getDb(c.env);\\n\\n  // Check repo access BEFORE cache lookup (cache is shared across users)\\n  const repoAccess = await checkRepoAccess(db, repoFullName, userId);\\n  if (repoAccess instanceof Response) return repoAccess;\\n  if (!repoAccess) return c.json({ error: \\\"Repository not found\\\" }, 404);\\n\\n  // Try cache first\\n  const cached = await c.env.ENTIRE_CACHE.get<CachedRepoCommits>(\\n    cacheKey,\\n    \\\"json\\\",\\n  );\\n\\n  if (cached) {\\n    return c.json({ ...cached, from_cache: true });\\n  }\\n\\n  try {\\n    // Get a token: user's OAuth token if authenticated, installation token otherwise\\n    const tokenResult = await getGitHubTokenForRepoRequest(c, db, userId, repoAccess);\\n    if (tokenResult.response) return tokenResult.response;\\n    const token = tokenResult.token ?? undefined;\\n\\n    const commits = await fetchRepoCommits(repoFullName, undefined, token);\\n\\n    const data: CachedRepoCommits = {\\n      commits,\\n      repo_full_name: repoFullName,\\n      updated_at: new Date().toISOString(),\\n    };\\n\\n    await c.env.ENTIRE_CACHE.put(cacheKey, JSON.stringify(data), {\\n      expirationTtl: 60 * 60, // 1h TTL\\n    });\\n\\n    return c.json({ ...data, from_cache: false });\\n  } catch (err) {\\n    if (isGitHubAuthError(err)) {\\n      return c.json({ error: \\\"GitHub token expired\\\" }, 401);\\n    }\\n    console.error(`Failed to fetch commits for ${repoFullName}:`, err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch commits\\\" }, 500);\\n  }\\n});\\n\\n// Get branches for a specific repo\\nrepoRoutes.get(\\\"/:org/:repo/branches\\\", optionalAuth, rateLimitUnauthenticated, async (c) => {\\n  const userId = c.get(\\\"userId\\\") as string | undefined;\\n\\n  const org = c.req.param(\\\"org\\\");\\n  const repo = c.req.param(\\\"repo\\\");\\n  const repoFullName = `${org}/${repo}`;\\n\\n  const cacheKey = `branches:${repoFullName}`;\\n\\n  const db = getDb(c.env);\\n\\n  // Check repo access BEFORE cache lookup (cache is shared across users)\\n  const repoAccess = await checkRepoAccess(db, repoFullName, userId);\\n  if (repoAccess instanceof Response) return repoAccess;\\n  if (!repoAccess) return c.json({ error: \\\"Repository not found\\\" }, 404);\\n\\n  // Get default_branch from repo record (falls back to \\\"main\\\" if not in DB)\\n  const defaultBranch = repoAccess.default_branch ?? \\\"main\\\";\\n\\n  // Try cache first\\n  const cached = await c.env.ENTIRE_CACHE.get<{ branches: string[]; default_branch: string; stored_default_branch?: string }>(\\n    cacheKey,\\n    \\\"json\\\",\\n  );\\n\\n  if (cached) {\\n    // Prefer the cached default_branch (may have been self-healed) over the DB value,\\n    // since the DB update from self-healing may not have completed yet\\n    return c.json({\\n      ...cached,\\n      default_branch: cached.default_branch ?? defaultBranch,\\n      stored_default_branch: cached.stored_default_branch ?? defaultBranch,\\n      from_cache: true,\\n    });\\n  }\\n\\n  try {\\n    // Get a token: user's OAuth token if authenticated, installation token otherwise.\\n    // Token may be undefined for public repos without an installation — GitHub's\\n    // public API still works (rate-limited to 60 req/hr per IP).\\n    const tokenResult = await getGitHubTokenForRepoRequest(c, db, userId, repoAccess);\\n    if (tokenResult.response) return tokenResult.response;\\n    const token = tokenResult.token ?? undefined;\\n\\n    const { fetchRepoBranches, fetchRepoDefaultBranch } = await import(\\\"../lib/github\\\");\\n    const branches = await fetchRepoBranches(repoFullName, token);\\n\\n    // Self-heal: if DB's default_branch isn't in the actual branch list,\\n    // fetch the real default from GitHub and update the DB\\n    let resolvedDefaultBranch = defaultBranch;\\n    if (!branches.includes(defaultBranch)) {\\n      console.log(`[branches] default_branch mismatch for ${repoFullName}: DB has \\\"${defaultBranch}\\\" but it's not in branch list`);\\n      const githubDefault = token ? await fetchRepoDefaultBranch(repoFullName, token) : null;\\n      if (githubDefault && branches.includes(githubDefault)) {\\n        console.log(`[branches] Healing default_branch for ${repoFullName}: \\\"${defaultBranch}\\\" -> \\\"${githubDefault}\\\"`);\\n        resolvedDefaultBranch = githubDefault;\\n        // Persist corrected default_branch in background via waitUntil\\n        const identifier = repoAccess ? { id: repoAccess.id } : { fullName: repoFullName };\\n        await runInBackground(c, () =>\\n          db.repos.updateDefaultBranch(identifier, githubDefault)\\n        );\\n      }\\n    }\\n\\n    const data = {\\n      branches,\\n      default_branch: resolvedDefaultBranch,\\n      // Raw DB value before self-healing — the repos list navigates to this,\\n      // so the frontend needs it to detect stale-default redirects\\n      stored_default_branch: defaultBranch,\\n    };\\n\\n    await c.env.ENTIRE_CACHE.put(cacheKey, JSON.stringify(data), {\\n      expirationTtl: 60 * 60, // 1 hour TTL\\n    });\\n\\n    return c.json({ ...data, from_cache: false });\\n  } catch (err) {\\n    if (isGitHubAuthError(err)) {\\n      return c.json({ error: \\\"GitHub token expired\\\" }, 401);\\n    }\\n    console.error(`Failed to fetch branches for ${repoFullName}:`, err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch branches\\\" }, 500);\\n  }\\n});\\n\\n// Lightweight checkpoint status check\\n// Returns repo-level metadata (access, sync status, checkpoint count) without loading checkpoint data.\\n// session_branch_exists: true if repo has been synced, null if not yet synced (never false).\\n// Used by the frontend to decide whether to show an empty state or a skeleton loader.\\nrepoRoutes.get(\\\"/:org/:repo/checkpoint-status\\\", optionalAuth, rateLimitUnauthenticated, async (c) => {\\n  const userId = c.get(\\\"userId\\\") as string | undefined;\\n  const org = c.req.param(\\\"org\\\");\\n  const repo = c.req.param(\\\"repo\\\");\\n  const repoFullName = `${org}/${repo}`;\\n  const db = getDb(c.env);\\n\\n  try {\\n    const repoAccess = await checkRepoAccess(db, repoFullName, userId);\\n    if (repoAccess instanceof Response) return repoAccess;\\n    if (!repoAccess) return c.json({ error: \\\"Repository not found\\\" }, 404);\\n\\n    const appHasAccess = repoAccess.app_has_access;\\n    const sessionBranchExists = repoAccess?.checkpoints_backfilled_at\\n      ? true\\n      : null;\\n    const checkpointCount = repoAccess?.checkpoint_count ?? 0;\\n\\n    return c.json({\\n      app_has_access: appHasAccess,\\n      session_branch_exists: sessionBranchExists,\\n      checkpoint_count: checkpointCount,\\n    });\\n  } catch (err) {\\n    console.error(`Failed to fetch checkpoint status for ${repoFullName} (user: ${userId}):`, err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch checkpoint status\\\" }, 500);\\n  }\\n});\\n\\n// Get checkpoints for a specific repo\\n// ALWAYS serves from D1 - background sync populates the data\\n// Pass ?source=github to trigger a sync from GitHub before returning data (for local dev)\\nrepoRoutes.get(\\\"/:org/:repo/checkpoints\\\", optionalAuth, rateLimitUnauthenticated, async (c) => {\\n  const userId = c.get(\\\"userId\\\") as string | undefined;\\n\\n  const org = c.req.param(\\\"org\\\");\\n  const repo = c.req.param(\\\"repo\\\");\\n  const repoFullName = `${org}/${repo}`;\\n\\n  // Optional query params\\n  const branch = c.req.query(\\\"branch\\\") || \\\"main\\\";\\n  const limitParam = c.req.query(\\\"limit\\\");\\n  const limit = limitParam ? parseInt(limitParam, 10) : 100;\\n  const source = c.req.query(\\\"source\\\"); // \\\"github\\\" to trigger sync\\n\\n  // Validate branch name format to prevent cache key issues and unexpected behavior\\n  if (!isValidBranchName(branch)) {\\n    return c.json({ error: \\\"Invalid branch name format\\\" }, 400);\\n  }\\n\\n  try {\\n    const db = getDb(c.env);\\n    let repoRecord: Repo | null = null;\\n\\n    // Helper to get GitHub token only when needed (for source=github or branch validation)\\n    // Uses undefined as \\\"not yet fetched\\\" so null can be cached as \\\"fetched, no token\\\"\\n    let cachedToken: string | null | undefined = undefined;\\n    const getGitHubToken = async (): Promise<string | null> => {\\n      if (cachedToken !== undefined) return cachedToken;\\n      const tokenResult = await getGitHubTokenForRepoRequest(c, db, userId, repoRecord);\\n      if (tokenResult.response) {\\n        const err = new Error(\\\"User not found\\\");\\n        (err as any).status = 404;\\n        throw err;\\n      }\\n      cachedToken = tokenResult.token;\\n      return tokenResult.token;\\n    };\\n\\n    // For source=github (local dev), use multi-query path since we may need to create/sync.\\n    // For normal requests, resolve repo access first, then fetch branch checkpoints separately.\\n    // This avoids false 404s when a repo exists but has zero checkpoints on the branch.\\n    let dbCheckpoints: CheckpointWithCommit[] = [];\\n\\n    if (source === \\\"github\\\" && isLocalDev(c.env)) {\\n      // Local dev path: requires auth (webhooks don't fire in local dev)\\n      if (!userId) return c.json({ error: \\\"Authentication required\\\" }, 401);\\n\\n      // Also invalidate branches cache since webhooks don't fire in local dev\\n      await c.env.ENTIRE_CACHE.delete(`branches:${repoFullName}`);\\n      console.log(`source=github: invalidated branches cache for ${repoFullName}`);\\n\\n      const result = await fetchRepoWithSyncForLocalDev(\\n        db,\\n        repoFullName,\\n        userId,\\n        branch,\\n        limit,\\n        getGitHubToken,\\n      );\\n      if (result instanceof Response) return result;\\n      repoRecord = result.repoRecord;\\n      dbCheckpoints = result.checkpoints;\\n    } else {\\n      const repoAccess = await checkRepoAccess(\\n        db,\\n        repoFullName,\\n        userId,\\n        { requireRepo: true },\\n      );\\n      if (repoAccess instanceof Response) return repoAccess;\\n\\n      repoRecord = repoAccess;\\n      dbCheckpoints = await db.checkpoints.getForBranch(repoRecord.id, branch, { limit });\\n    }\\n\\n    // null = unknown (repo not in DB), true/false = definitive from DB\\n    const appHasAccess = repoRecord ? repoRecord.app_has_access : null;\\n\\n    // Validate branch existence when we have no checkpoints\\n    // This catches non-existent branches even if repo hasn't been synced yet\\n    if (dbCheckpoints.length === 0) {\\n      // If repo exists in DB, check if it has any commits for this branch\\n      const hasCommitsInDb = repoRecord\\n        ? await db.checkpoints.branchHasCommits(repoRecord.id, branch)\\n        : false;\\n\\n      if (!hasCommitsInDb) {\\n        // If app doesn't have access, skip branch check and show \\\"no access\\\" state\\n        // (User's token might also not have access, giving false 404s)\\n        if (appHasAccess !== false) {\\n          // No commits in DB - verify with GitHub API (only fetches token if needed)\\n          const token = await getGitHubToken();\\n          const branchExists = await checkBranchExists(\\n            repoFullName,\\n            branch,\\n            token,\\n          );\\n\\n          // If GitHub definitively says branch doesn't exist, return 404\\n          if (branchExists === false) {\\n            return c.json({ error: `Branch '${branch}' not found` }, 404);\\n          }\\n          // If branchExists is true or null, continue - let component show appropriate empty state\\n        }\\n        // If appHasAccess === false, skip branch check and return empty checkpoints\\n      }\\n    }\\n\\n    // Build response from DB data\\n    const checkpoints: CheckpointInfo[] = dbCheckpoints.map(mapCheckpointToInfo);\\n\\n    // session_branch_exists is true if repo has been backfilled (branch was checked during sync)\\n    // null if we haven't checked yet (repo not synced)\\n    const sessionBranchExists = repoRecord?.checkpoints_backfilled_at\\n      ? true\\n      : null;\\n\\n    return c.json({\\n      checkpoints,\\n      repo_full_name: repoFullName,\\n      updated_at: new Date().toISOString(),\\n      source: \\\"db\\\",\\n      app_has_access: appHasAccess,\\n      session_branch_exists: sessionBranchExists,\\n    });\\n  } catch (err) {\\n    if ((err as any)?.status === 404) {\\n      return c.json({ error: (err as Error).message }, 404);\\n    }\\n    if (isGitHubAuthError(err)) {\\n      return c.json({ error: \\\"GitHub token expired\\\" }, 401);\\n    }\\n    console.error(`Failed to fetch checkpoints for ${repoFullName}:`, err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch checkpoints\\\" }, 500);\\n  }\\n});\\n\\n// Get list of branches that have checkpoints for a repo\\nrepoRoutes.get(\\\"/:org/:repo/checkpoint-branches\\\", optionalAuth, rateLimitUnauthenticated, async (c) => {\\n  const userId = c.get(\\\"userId\\\") as string | undefined;\\n\\n  const org = c.req.param(\\\"org\\\");\\n  const repo = c.req.param(\\\"repo\\\");\\n  const repoFullName = `${org}/${repo}`;\\n\\n  try {\\n    const db = getDb(c.env);\\n\\n    // Check repo access (returns 404 if unauthorized or repo doesn't exist)\\n    const repoRecord = await checkRepoAccess(db, repoFullName, userId, {\\n      requireRepo: true,\\n    });\\n    if (repoRecord instanceof Response) return repoRecord;\\n\\n    const branches = await db.checkpoints.getBranchesWithCheckpoints(repoRecord.id);\\n\\n    return c.json({ branches, repo_full_name: repoFullName });\\n  } catch (err) {\\n    console.error(\\n      `Failed to fetch checkpoint branches for ${repoFullName}:`,\\n      err,\\n    );\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch checkpoint branches\\\" }, 500);\\n  }\\n});\\n\\n// ============================================================================\\n// Trail routes (admin-only)\\n// ============================================================================\\n\\n/** Middleware: require authenticated admin user for trail routes */\\nasync function requireTrailsAdmin(\\n  c: Context<{ Bindings: Env; Variables: Variables }>,\\n  next: () => Promise<void>,\\n): Promise<Response | void> {\\n  const userId = c.get(\\\"userId\\\");\\n  const db = getDb(c.env);\\n  const user = await db.users.findById(userId);\\n  if (!user || !isAdmin(c.env, user.is_admin ?? false)) {\\n    return c.json({ error: \\\"Forbidden\\\" }, 403);\\n  }\\n  await next();\\n}\\n\\n// Get all trails for a specific repo\\nrepoRoutes.get(\\\"/:org/:repo/trails\\\", requireAuth, requireTrailsAdmin, async (c) => {\\n  const userId = c.get(\\\"userId\\\");\\n\\n  const org = c.req.param(\\\"org\\\");\\n  const repo = c.req.param(\\\"repo\\\");\\n  const repoFullName = `${org}/${repo}`;\\n\\n  try {\\n    const db = getDb(c.env);\\n\\n    // Check repo access\\n    const repoAccess = await checkRepoAccess(db, repoFullName, userId, { requireRepo: true });\\n    if (repoAccess instanceof Response) return repoAccess;\\n\\n    const user = await db.users.findById(userId);\\n    if (!user) {\\n      return c.json({ error: \\\"User not found\\\" }, 404);\\n    }\\n\\n    let token: string | undefined;\\n    if (user.github_token_enc) {\\n      const result = await getValidGitHubTokenFromContext(c, db, user);\\n      token = result.token;\\n    }\\n\\n    if (!token) {\\n      return c.json({ error: \\\"GitHub token required\\\" }, 401);\\n    }\\n\\n    // Check if trails branch exists\\n    const branchExists = await checkBranchExists(repoFullName, TRAILS_BRANCH, token);\\n    if (!branchExists) {\\n      return c.json({\\n        trails: [],\\n        repo_full_name: repoFullName,\\n        updated_at: new Date().toISOString(),\\n      });\\n    }\\n\\n    // Discover and fetch trails\\n    const trailIds = await discoverTrailsFromBranch(repoFullName, token);\\n    const trailData = await fetchTrailDataBatch(repoFullName, trailIds, token);\\n\\n    // Get checkpoint counts per branch for each trail\\n    const trails: TrailInfo[] = [];\\n    for (const [trailId, trail] of trailData) {\\n      const { metadata, discussion } = trail;\\n\\n      // Calculate comment counts\\n      let commentCount = 0;\\n      let unresolvedCount = 0;\\n      for (const comment of discussion.comments ?? []) {\\n        commentCount += 1 + (comment.replies?.length ?? 0);\\n        if (!comment.resolved) {\\n          unresolvedCount++;\\n        }\\n      }\\n\\n      // Get checkpoint count for this branch from DB\\n      let checkpointCount = 0;\\n      try {\\n        checkpointCount = await db.checkpoints.countForBranch(repoAccess.id, metadata.branch);\\n      } catch {\\n        // Ignore errors - just use 0\\n      }\\n\\n      trails.push({\\n        trail_id: trailId,\\n        branch: metadata.branch,\\n        base: metadata.base,\\n        title: metadata.title,\\n        body: metadata.body ?? \\\"\\\",\\n        status: metadata.status,\\n        author: metadata.author,\\n        assignees: metadata.assignees,\\n        labels: metadata.labels,\\n        created_at: metadata.created_at,\\n        updated_at: metadata.updated_at,\\n        merged_at: metadata.merged_at,\\n        priority: metadata.priority ?? \\\"none\\\",\\n        type: metadata.type ?? null,\\n        reviewers: metadata.reviewers ?? [],\\n        comment_count: commentCount,\\n        unresolved_count: unresolvedCount,\\n        checkpoint_count: checkpointCount,\\n      });\\n    }\\n\\n    return c.json({\\n      trails,\\n      repo_full_name: repoFullName,\\n      updated_at: new Date().toISOString(),\\n    });\\n  } catch (err) {\\n    if (isGitHubAuthError(err)) {\\n      return c.json({ error: \\\"GitHub token expired\\\" }, 401);\\n    }\\n    console.error(`Failed to fetch trails for ${repoFullName}:`, err);\\n    recordSpanError(err);\\n    return c.json({ error: \\\"Failed to fetch trails\\\" }, 500);\\n  }\\n});\\n\\n// Create a new trail\\nrepoRoutes.post(\\\"/:org/:repo/trails\\\", requireAuth, requireTrailsAdmin, async (c) => {\\n  const userId = c.get(\\\"userId\\\");\\n\\n  const org = c.req.param(\\\"org\\\");\\n  const repo = c.req.param(\\\"repo\\\");\\n  const repoFullName = `${org}/${repo}`;\\n\\n  try {\\n    const db = getDb(c.env);\\n\\n    // Check repo access\\n    const repoAccess = await checkRepoAccess(db, repoFullName, userId, { requireRepo: true });\\n    if (repoAccess instanceof Response) return repoAccess;\\n\\n    const user = await db.users.findById(userId);\\n    if (!user) {\\n      return c.json({ error: \\\"User not found\\\" }, 404);\\n    }\\n\\n    // Use installation token for write operations (has Contents: write permission)\\n    if (!repoAccess.installation_id) {\\n      return c.json({ error: \\\"Repository has no app installation\\\" }, 400);\\n    }\\n\\n    const githubInstallationId = await db.installations.getGithubId(repoAccess.installation_id);\\n    if (!githubInstallationId) {\\n      return c.json({ error: \\\"Installation not found\\\" }, 400);\\n    }\\n\\n    const token = await getInstallationToken(\\n      githubInstallationId,\\n      {\\n        appId: c.env.GITHUB_CLIENT_ID,\\n        privateKey: c.env.GITHUB_APP_PRIVATE_KEY,\\n      },\\n      c.env.ENTIRE_CACHE\\n    );\\n\\n    // Parse request body\\n    const body = await c.req.json<{\\n      title: string;\\n      body?: string;\\n      branch_name: string;\\n      base?: string;\\n      assignees?: string[];\\n      labels?: string[];\\n      priority?: TrailPriority;\\n      type?: TrailType;\\n    }>();\\n\\n    // Validate required fields\\n    if (!body.title?.trim()) {\\n      return c.json({ error: \\\"Title is required\\\" }, 400);\\n    }\\n    if (!body.branch_name?.trim()) {\\n      return c.json({ error: \\\"Branch name is required\\\" }, 400);\\n    }\\n\\n    // Validate branch name format\\n    if (!isValidBranchName(body.branch_name)) {\\n      return c.json({ error: \\\"Invalid branch name format\\\" }, 400);\\n    }\\n\\n    // Prevent creating branches in the reserved 'entire/' namespace\\n    if (body.branch_name.startsWith(\\\"entire/\\\")) {\\n      return c.json({ error: \\\"Cannot create branches under 'entire/' namespace\\\" }, 400);\\n    }\\n\\n    // Validate priority and type\\n    if (body.priority !== undefined && !VALID_PRIORITIES.includes(body.priority)) {\\n      return c.json({ error: `Invalid priority. Must be one of: ${VALID_PRIORITIES.join(\\\", \\\")}` }, 400);\\n    }\\n    if (body.type !== undefined && !VALID_TYPES.includes(body.type)) {\\n      return c.json({ error: `Invalid type. Must be one of: ${VALID_TYPES.join(\\\", \\\")}` }, 400);\\n    }\\n\\n    const base = body.base || repoAccess.default_branch || \\\"main\\\";\\n    const trailId = generateTrailId();\\n    const now = new Date().toISOString();\\n\\n    // Create the feature branch (if it doesn't exist)\\n    const branchCreated = await createBranchIfNotExists(\\n      repoFullName,\\n      body.branch_name,\\n      base,\\n      token\\n    );\\n\\n    // Create trail metadata\\n    const metadata: TrailMetadata = {\\n      trail_id: trailId,\\n      branch: body.branch_name,\\n      base: base,\\n      title: body.title.trim(),\\n      body: body.body?.trim() || \\\"\\\",\\n      status: \\\"draft\\\",\\n      author: user.github_login || \\\"unknown\\\",\\n      assignees: body.assignees || [],\\n      labels: body.labels || [],\\n      created_at: now,\\n      updated_at: now,\\n      merged_at: null,\\n      priority: body.priority ?? \\\"none\\\",\\n      type: body.type,\\n      reviewers: [],\\n    };\\n\\n    const discussion: TrailDiscussion = {\\n      comments: [],\\n    };\\n\\n    const checkpoints: TrailCheckpoints = {\\n      checkpoints: [],\\n    };\\n\\n    // Commit to entire/trails/v1 branch\\n    await commitTrailFiles(\\n      repoFullName,\\n      trailId,\\n      metadata,\\n      discussion,\\n      checkpoints,\\n      token,\\