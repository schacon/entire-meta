1→  }\\n   262→}\\n   263→\\n   264→function sleep(ms: number): Promise<void> {\\n   265→  return new Promise((resolve) => setTimeout(resolve, ms));\\n   266→}\\n   267→\\n   268→// --- Types ---\\n   269→\\n   270→interface CheckpointRow {\\n   271→  checkpoint_id: string;\\n   272→  branch: string;\\n   273→  agent: string;\\n   274→  commit_author_username: string | null;\\n   275→  created_at: string | null;\\n   276→  commit_sha: string | null;\\n   277→  commit_message: string | null;\\n   278→  prompt: string | null;\\n   279→  files_touched_str: string | null;\\n   280→}\\n   281→\\n   282→interface RepoRow {\\n   283→  id: string;\\n   284→  full_name: string;\\n   285→  checkpoint_count: number;\\n   286→}\\n   287→\\n   288→// --- Per-Repo Processing ---\\n   289→\\n   290→async function fetchCheckpointsForRepo(\\n   291→  db: Kysely<DB>,\\n   292→  repoId: string,\\n   293→  limit: number | null,\\n   294→): Promise<CheckpointRow[]> {\\n   295→  // Use the same deferred-join pattern as getCheckpointsForBranch\\n   296→  let idQuery = db\\n   297→    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n   298→    .select(\\\"id\\\")\\n   299→    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n   300→    .orderBy(\\\"commit_date\\\", \\\"desc\\\");\\n   301→\\n   302→  if (limit) {\\n   303→    idQuery = idQuery.limit(limit);\\n   304→  }\\n   305→\\n   306→  const idRows = await idQuery.execute();\\n   307→  if (idRows.length === 0) return [];\\n   308→\\n   309→  const rows = await db\\n   310→    .selectFrom(\\\"repo_checkpoint_commits as cc\\\")\\n   311→    .leftJoin(\\\"repo_checkpoints as cp\\\", (join) =>\\n   312→      join\\n   313→        .onRef(\\\"cp.repo_id\\\", \\\"=\\\", \\\"cc.repo_id\\\")\\n   314→        .onRef(\\\"cp.checkpoint_id\\\", \\\"=\\\", \\\"cc.checkpoint_id\\\"),\\n   315→    )\\n   316→    .select([\\n   317→      \\\"cc.checkpoint_id\\\",\\n   318→      \\\"cc.branch\\\",\\n   319→      \\\"cc.commit_sha\\\",\\n   320→      \\\"cc.commit_message\\\",\\n   321→      \\\"cc.commit_author_username\\\",\\n   322→      \\\"cc.commit_date\\\",\\n   323→      \\\"cp.prompt\\\",\\n   324→      \\\"cp.agent\\\",\\n   325→      \\\"cp.created_at\\\",\\n   326→      \\\"cp.files_touched\\\",\\n   327→    ])\\n   328→    .where(\\n   329→      \\\"cc.id\\\",\\n   330→      \\\"in\\\",\\n   331→      idRows.map((r) => r.id),\\n   332→    )\\n   333→    .execute();\\n   334→\\n   335→  return rows.map((row) => {\\n   336→    const filesTouched = row.files_touched as string[] | null;\\n   337→    return {\\n   338→      checkpoint_id: row.checkpoint_id,\\n   339→      branch: row.branch,\\n   340→      agent: row.agent ?? \\\"Claude Code\\\",\\n   341→      commit_author_username: row.commit_author_username,\\n   342→      created_at: row.created_at?.toISOString() ?? row.commit_date?.toISOString() ?? null,\\n   343→      commit_sha: row.commit_sha,\\n   344→      commit_message: row.commit_message,\\n   345→      prompt: row.prompt,\\n   346→      files_touched_str: filesTouched?.join(\\\", \\\") ?? null,\\n   347→    };\\n   348→  });\\n   349→}\\n   350→\\n   351→function formatElapsed(ms: number): string {\\n   352→  const s = Math.floor(ms / 1000);\\n   353→  if (s < 60) return `${s}s`;\\n   354→  const m = Math.floor(s / 60);\\n   355→  return `${m}m${s % 60}s`;\\n   356→}\\n   357→\\n   358→async function processRepo(\\n   359→  db: Kysely<DB>,\\n   360→  tpuf: Turbopuffer,\\n   361→  openai: OpenAI,\\n   362→  repo: RepoRow,\\n   363→  options: CliOptions,\\n   364→): Promise<{ indexed: number; skipped: number }> {\\n   365→  const start = Date.now();\\n   366→  const total = repo.checkpoint_count;\\n   367→  console.log(`\\\\n--- ${repo.full_name} (${total} checkpoints) ---`);\\n   368→\\n   369→  const checkpoints = await fetchCheckpointsForRepo(db, repo.id, options.limit);\\n   370→  if (checkpoints.length === 0) {\\n   371→    console.log(`  No checkpoint commits found, skipping.`);\\n   372→    return { indexed: 0, skipped: 0 };\\n   373→  }\\n   374→\\n   375→  console.log(`  Fetched ${checkpoints.length} checkpoint rows from DB.`);\\n   376→\\n   377→  const githubToken = process.env.GITHUB_TOKEN;\\n   378→  const ns = tpuf.namespace(`checkpoints-${repo.id}`);\\n   379→  let totalIndexed = 0;\\n   380→  let totalSkipped = 0;\\n   381→  let totalTranscripts = 0;\\n   382→\\n   383→  // Process in chunks: for each chunk, fetch transcripts -> build text -> embed -> upsert\\n   384→  const numChunks = Math.ceil(checkpoints.length / CHUNK_SIZE);\\n   385→\\n   386→  for (let chunkIdx = 0; chunkIdx < numChunks; chunkIdx++) {\\n   387→    const chunkStart = chunkIdx * CHUNK_SIZE;\\n   388→    const chunkEnd = Math.min(chunkStart + CHUNK_SIZE, checkpoints.length);\\n   389→    const chunk = checkpoints.slice(chunkStart, chunkEnd);\\n   390→    const chunkNum = chunkIdx + 1;\\n   391→    const elapsed = formatElapsed(Date.now() - start);\\n   392→\\n   393→    console.log(`  [${chunkNum}/${numChunks}] Processing checkpoints ${chunkStart + 1}-${chunkEnd} of ${checkpoints.length} (${elapsed})`);\\n   394→\\n   395→    // 1. Fetch transcripts for this chunk\\n   396→    const transcripts: (string | undefined)[] = [];\\n   397→    if (options.withTranscripts && githubToken) {\\n   398→      let fetched = 0;\\n   399→      let found = 0;\\n   400→      for (const cp of chunk) {\\n   401→        const excerpt = await fetchTranscriptExcerpt(repo.full_name, cp.checkpoint_id, cp.agent, githubToken);\\n   402→        transcripts.push(excerpt ?? undefined);\\n   403→        fetched++;\\n   404→        if (excerpt) found++;\\n   405→        if (fetched < chunk.length) {\\n   406→          await sleep(TRANSCRIPT_DELAY_MS);\\n   407→        }\\n   408→      }\\n   409→      totalTranscripts += found;\\n   410→      console.log(`    Transcripts: ${found}/${chunk.length} found`);\\n   411→    } else {\\n   412→      chunk.forEach(() => transcripts.push(undefined));\\n   413→    }\\n   414→\\n   415→    // 2. Build search text for each checkpoint\\n   416→    const texts: string[] = [];\\n   417→    const validIndices: number[] = []; // indices within this chunk that have non-empty text\\n   418→    let chunkSkipped = 0;\\n   419→\\n   420→    for (let i = 0; i < chunk.length; i++) {\\n   421→      const text = buildSearchText(chunk[i], transcripts[i]);\\n   422→      if (!text.trim()) {\\n   423→        chunkSkipped++;\\n   424→        continue;\\n   425→      }\\n   426→      texts.push(text);\\n   427→      validIndices.push(i);\\n   428→    }\\n   429→\\n   430→    totalSkipped += chunkSkipped;\\n   431→\\n   432→    if (texts.length === 0) {\\n   433→      console.log(`    All empty, skipped.`);\\n   434→      continue;\\n   435→    }\\n   436→\\n   437→    if (options.dryRun) {\\n   438→      console.log(`    [DRY RUN] Would index ${texts.length} (${chunkSkipped} skipped)`);\\n   439→      totalIndexed += texts.length;\\n   440→      continue;\\n   441→    }\\n   442→\\n   443→    // 3. Truncate texts to stay under embedding model token limit\\n   444→    const embeddingTexts = texts.map((t) => t.slice(0, MAX_EMBEDDING_CHARS));\\n   445→\\n   446→    // 4. Generate embeddings\\n   447→    let embeddings: number[][];\\n   448→    try {\\n   449→      embeddings = await generateEmbeddings(openai, embeddingTexts);\\n   450→    } catch (err) {\\n   451→      const msg = err instanceof Error ? err.message : String(err);\\n   452→      console.error(`    Embedding failed for chunk ${chunkNum}: ${msg.slice(0, 200)}`);\\n   453→      console.error(`    Skipping chunk, continuing...`);\\n   454→      totalSkipped += texts.length;\\n   455→      continue;\\n   456→    }\\n   457→    console.log(`    Embedded ${texts.length} checkpoints`);\\n   458→\\n   459→    // 5. Upsert to Turbopuffer\\n   460→    const vectors: Vector[] = validIndices.map((localIdx, j) => {\\n   461→      const cp = chunk[localIdx];\\n   462→      const globalId = chunkStart