ess but no session branch (CLI not used yet) */}\\n      {showCliInstall && (\\n        <div className=\\\"flex items-center justify-center min-h-[calc(100vh-var(--global-header-height)-120px)]\\\">\\n          <div>\\n            <CliInstallationSteps />\\n            {isDev && (\\n              <div className=\\\"flex justify-center pb-8\\\">\\n                <Button\\n                  variant=\\\"outline\\\"\\n                  onClick={handleFetchFromGitHub}\\n                  disabled={isFetchingFromGitHub}\\n                >\\n                  {isFetchingFromGitHub ? \\\"Fetching...\\\" : \\\"Fetch from GitHub\\\"}\\n                </Button>\\n              </div>\\n            )}\\n          </div>\\n        </div>\\n      )}\\n\\n      {/* Empty state: App has access and session branch exists, but no checkpoints on this branch */}\\n      {showNoBranchCheckpoints && (\\n        <div className=\\\"border border-default rounded bg-raised p-8\\\">\\n          <div className=\\\"text-center text-muted\\\">\\n            <p className=\\\"text-lg font-medium\\\">\\n              No checkpoints on this branch\\n            </p>\\n            <p className=\\\"mt-2 text-sm max-w-md mx-auto\\\">\\n              This repository has Claude Code sessions, but none of them are\\n              linked to commits on the{\\\" \\\"}\\n              <code className=\\\"font-mono bg-muted px-1 rounded\\\">\\n                {branch}\\n              </code>{\\\" \\\"}\\n              branch.\\n            </p>\\n            {isDev && (\\n              <div className=\\\"mt-4\\\">\\n                <Button\\n                  variant=\\\"outline\\\"\\n                  onClick={handleFetchFromGitHub}\\n                  disabled={isFetchingFromGitHub}\\n                >\\n                  {isFetchingFromGitHub ? \\\"Fetching...\\\" : \\\"Fetch from GitHub\\\"}\\n                </Button>\\n              </div>\\n            )}\\n          </div>\\n        </div>\\n      )}