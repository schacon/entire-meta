tring\\\"\\n    55→  );\\n    56→}\\n    57→\\n    58→// Sync repos for a single user\\n    59→// Reuses logic from OAuth callback background job\\n    60→export async function syncReposForUser(\\n    61→  db: Db,\\n    62→  userId: string,\\n    63→  env: Env,\\n    64→): Promise<UserRepoSyncResult> {\\n    65→  // Get user with token\\n    66→  const user = await db.users.findById(userId);\\n    67→\\n    68→  if (!user) {\\n    69→    return { status: \\\"skipped\\\", reason: \\\"user_not_found\\\" };\\n    70→  }\\n    71→\\n    72→  if (!user.github_token_enc || !user.github_login) {\\n    73→    return { status: \\\"skipped\\\", reason: \\\"no_token_or_login\\\" };\\n    74→  }\\n    75→\\n    76→  // Get valid token (refreshes if expired)\\n    77→  let token: string;\\n    78→  try {\\n    79→    const tokenResult = await getValidGitHubToken(\\n    80→      db,\\n    81→      user,\\n    82→      {\\n    83→        clientId: env.GITHUB_CLIENT_ID,\\n    84→        clientSecret: env.GITHUB_CLIENT_SECRET,\\n    85→        encryptionKey: env.ENCRYPTION_KEY,\\n    86→      },\\n    87→      env.ENTIRE_CACHE,\\n    88→    );\\n    89→    token = tokenResult.token;\\n    90→  } catch (err) {\\n    91→    log(\\\"token_error\\\", {\\n    92→      userId,\\n    93→      error: errorString(err),\\n    94→    });\\n    95→    return { status: \\\"error\\\", reason: \\\"token_refresh_failed\\\" };\\n    96→  }\\n    97→\\n    98→  return syncReposWithToken(db, userId, user.github_login, token, env);\\n    99→}\\n   100→\\n   101→// Sync repos for a user with an already-available token\\n   102→// Used by waitUntil() fast-path during OAuth callback to avoid token lookup delay\\n   103→export async function syncReposForUserWithToken(\\n   104→  db: Db,\\n   105→  userId: string,\\n   106→  githubLogin: string,\\n   107→  token: string,\\n   108→  env: Env,\\n   109→): Promise<UserRepoSyncResult> {\\n   110→  return syncReposWithToken(db, userId, githubLogin, token, env);\\n   111→}\\n   112→\\n   113→// Internal: shared sync logic for both entry points\\n   114→async function syncReposWithToken(\\n   115→  db: Db,\\n   116→  userId: string,\\n   117→  githubLogin: string,\\n   118→  token: string,\\n   119→  env: Env,\\n   120→): Promise<UserRepoSyncResult> {\\n   121→  try {\\n   122→    // Fetch user's installations\\n   123→    const installationsResult = await fetchUserInstallations(token);\\n   124→\\n   125→    // Check for installations fetch error - don't proceed with partial data\\n   126→    // as this would incorrectly set app_has_access = false for all repos\\n   127→    if (installationsResult.error) {\\n   128→      log(\\\"installations_fetch_error\\\", {\\n   129→        userId,\\n   130→        error: installationsResult.error,\\n   131→      });\\n   132→      return { status: \\\"error\\\", reason: \\\"installations_fetch_failed\\\" };\\n   133→    }\\n   134→\\n   135→    // Sync user-installation links (recovery mechanism)\\n   136→    // This ensures users get linked to their installations even if the OAuth\\n   137→    // callback's sync failed (e.g., due to transient API errors).\\n   138→    // Also removes stale links when a user revokes installations.\\n   139→    try {\\n   140→      const syncResult = await db.installations.syncForUser(\\n   141→        userId,\\n   142→        installationsResult.installations.map((inst) => ({\\n   143→          github_installation_id: inst.id,\\n   144→          account_login: inst.account.login,\\n   145→          account_type: inst.account.type,\\n   146→          account_id: inst.account.id,\\n   147→          app_slug: inst.app_slug ?? null,\\n   148→          suspended_at: inst.suspended_at ?? null,\\n   149→        }))\\n   150→      );\\n   151→      if (syncResult.added > 0 || syncResult.removed > 0) {\\n   152→        log(\\\"installations_synced\\\", {\\n   153→          userId,\\n   154→          added: syncResult.added,\\n   155→          removed: syncResul