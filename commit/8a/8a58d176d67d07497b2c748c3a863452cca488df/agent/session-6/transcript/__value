n        commit_message: commitTitle,\\n        commit_author: commit.author.name,\\n        commit_author_username: username,\\n        commit_author_github_id: username ? usernameToGithubId.get(username) ?? null : null,\\n        commit_date: commit.timestamp,\\n        additions: stats?.additions ?? 0,\\n        deletions: stats?.deletions ?? 0,\\n        files_changed: stats?.filesChanged ?? 0,\\n        file_stats: stats?.files ?? null,\\n      };\\n    });\\n\\n    // Fetch session metadata from CHECKPOINT_BRANCH tree (may be empty if session push hasn't arrived yet)\\n    const sessionDataResult = await fetchSessionDataBatch(repoFullName, checkpointIds, token);\\n\\n    if (sessionDataResult.failedItems.length > 0) {\\n      logCheckpointMetric(\\\"commit_sessions_partial_failure\\\", {\\n        repo: repoFullName,\\n        failed: sessionDataResult.failedItems.length,\\n        errors: sessionDataResult.errors,\\n      });\\n    }\\n\\n    // Upsert full checkpoint records (COALESCE preserves existing data)\\n    const checkpointData = buildCheckpointDataFromSessions(checkpointIds, sessionDataResult, branch);\\n    const checkpointsProcessed = await db.checkpoints.upsertBatch(repoRecord.id, checkpointData);\\n\\n    // Upsert commits for the global repo (once, not per-user)\\n    const successCount = await db.checkpoints.upsertCommitBatch(repoRecord.id, branch, commitDataArray);\\n\\n    // Recalculate checkpoint count\\n    if (successCount > 0) {\\n      await db.checkpoints.recalculateCount(repoRecord.id);\\n    }\\n\\n    if (checkpointsProcessed > 0) {\\n      logCheckpointMetric(\\\"checkpoints_upserted\\\", { repo: repoFullName, branch, count: checkpointsProcessed });\\n    }\\n\\n    logCheckpointMetric(\\\"commits_completed\\\", { repo: repoFullName, branch, successCount });\\n\\n    // Link checkpoints to matching trails (best-effort, non-blocking)\\n    try {\\n      await linkCheckpointsToTrails(\\n        repoFullName,\\n        branch,\\n        checkpointCommits.map((c) => ({\\n          sha: c.sha,\\n          checkpointId: c.checkpointId,\\n          message: c.message.split(\\\"\\\\n\\\")[0],\\n          timestamp: c.timestamp,\\n        })),\\n        token,\\n      );\\n    } catch (err) {\\n      logCheckpointMetric(\\\"trail_linkage_error\\\", {\\n        repo: repoFullName,\\n        branch,\\n        error: err instanceof Error ? err.message : String(err),\\n      });\\n    }\\n  } catch (err) {\\n    logCheckpointMetric(\\\"error_commits\\\", {\\n      repo: repoFullName,\\n      branch,\\n      error: err instanceof Error ? err.message : String(err),\\n    });\\n    throw err; // Re-throw to trigger webhook retry mechanism\\n  }\\n}\\n\\n// ============================================================================\\n// Checkpoint-to-trail linkage\\n// ============================================================================\\n\\n/**\\n * Link newly synced checkpoints to any trails that match the pushed branch.\\n * Discovers trails from the entire/trails/v1 git branch, finds those whose\\n * metadata.branch matches the pushed branch, and appends new checkpoint\\n * references to their checkpoints.json.\\n */\\nasync function linkCheckpointsToTrails(\\n  repoFullName: string,\\n  branch: string,\\n  checkpointCommits: Array<{ sha: string; checkpointId: string; message: string; timestamp: string }>,\\n  token: string,\\n): Promise<void> {\\n  // Discover all trails in this repo\\n  const trailIds = await discoverTrailsFromBranch(repoFullName, token);\\n  if (trailIds.length === 0) return;\\n\\n  // Fetch trail metadata + checkpoints only (skip discussion to reduce latency)\\n  const trailData = await fetchTrailMetadataAndCheckpointsBatch(repoFullName, trailIds, token);\\n\\n  // Find trails whose branch matches the pushed branch\\n  for (const [trailId, trail] of trailData) {\\n    if (trail.metadata.branch !== branch) continue;\\n\\n    // Build set of existing checkpoint IDs for deduplication\\n    const existingIds = new Set(trail.checkpoints.checkpoints.map((cp) => cp.checkpoint_id));\\n\\n    // Filter to only new checkpoint refs\\n    const newRefs = checkpointCommits\\n      .filter((c) => !existingIds.has(c.checkpointId))\\n      .map((c) => ({\\n        checkpoint_id: c.checkpointId,\\n        commit_sha: c.sha,\\n        created_at: c.timestamp,\\n        summary: c.message,\\n      }));\\n\\n    if (newRefs.length === 0) continue;\\n\\n    // Prepend new refs (newest first) to existing checkpoints\\n    const merged = {\\n      checkpoints: [...newRefs, ...trail.checkpoints.checkpoints],\\n    };\\n\\n    await updateTrailCheckpoints(\\n      repoFullName,\\n      trailId,\\n      merged,\\n      token,\\n      `Link ${newRefs.length} checkpoint(s) to trail ${trailId}`,\\n    );\\n\\n    logCheckpointMetric(\\\"trail_checkpoints_linked\\\", {\\n      repo: repoFullName,\\n      branch,\\n      trailId,\\n      count: newRefs.length,\\n    });\\n  }\\n}\\n\\n// ============================================================================\\n// Trail merge detection\\n// ============================================================================\\n\\n/**\\n * Check if any trail's feature branch has been merged into the pushed base branch.\\n * For each trail whose metadata.base matches the pushed branch, uses the GitHub\\n * compare API to check if ahead_by === 0 (all feature branch commits are in base).\\n */\\nasync function checkAndMergeTrails(\\n  repoFullName: string,\\n  pushedBranch: string,\\n  beforeSha: string,\\n  token: string,\\n): Promise<void> {\\n  const trailIds = await discoverTrailsFromBranch(repoFullName, token);\\n  if (trailIds.length === 0) return;\\n\\n  const trailData = await fetchTrailMetadataAndCheckpointsBatch(repoFullName, trailIds, token);\\n  const isNewBranch = beforeSha === \\\"0000000000000000000000000000000000000000\\\";\\n\\n  for (const [trailId, trail] of trailData) {\\n    if (trail.metadata.base !== pushedBranch) continue;\\n    if (trail.metadata.status === \\\"merged\\\" || trail.metadata.status === \\\"closed\\\") continue;\\n\\n    try {\\n      let merged = await isBranchMergedInto(repoFullName, pushedBranch, trail.metadata.branch, token);\\n\\n      // If the branch ref is gone (deleted after merge), fall back to comparing\\n      // the latest checkpoint commit SHA — the SHA still exists in git even after\\n      // the branch ref is removed.\\n      if (merged === null && trail.checkpoints.checkpoints.length > 0) {\\n        const latestSha = trail.checkpoints.checkpoints[0].commit_sha;\\n        merged = await isBranchMergedInto(repoFullName, pushedBranch, latestSha, token);\\n      }\\n\\n      if (!merged) continue;\\n\\n      // Verify this push actually merged the branch by checking it wasn't already\\n      // incorporated before this push. This prevents false positives for branches\\n      // that were created from the base but never diverged.\\n      // Skip this check if the trail has checkpoints (real work was done) — we\\n      // want to mark it merged regardless, and this handles retries when a\\n      // previous merge detection succeeded but the metadata update failed.\\n      if (!isNewBranch && trail.checkpoints.checkpoints.length === 0) {\\n        const wasAlreadyIn = await isBranchMergedInto(repoFullName, beforeSha, trail.metadata.branch, token);\\n        if (wasAlreadyIn) continue;\\n      }\\n\\n      const now = new Date().toISOString();\\n      const updatedMetadata = {\\n        ...trail.metadata,\\n        status: \\\"merged\\\" as const,\\n        merged_at: now,\\n        updated_at: now,\\n      };\\n\\n      await updateTrailMetadata(\\n        repoFullName,\\n        trailId,\\n        updatedMetadata,\\n        token,\\n        `Merge trail ${trailId} (branch ${trail.metadata.branch} merged into ${pushedBranch})`,\\n      );\\n\\n      console.log(`[trails-merge] merged trail=${trailId} repo=${repoFullName} branch=${trail.metadata.branch}`);\\n    } catch (err) {\\n      console.error(`[trails-merge] failed trail=${trailId} repo=${repoFullName}: ${err}`);\\n    }\\n  }\\n}\\n\\n/**\\n * Detect trail merges on push events. When a branch receives a push,\\n * check if any trail's feature branch has been fully merged into it.\\n */\\nasync function processTrailMergeDetection(\\n  eventType: string,\\n  payload: Record<string, unknown>,\\n  db: Db,\\n  env: Env\\n): Promise<void> {\\n  if (eventType !== \\\"push\\\") return;\\n\\n  const repo = payload.repository as Record<string, unknown> | undefined;\\n  if (!repo?.full_name) return;\\n\\n  const ref = payload.ref as string | undefined;\\n  if (!ref?.startsWith(\\\"refs/heads/\\\")) return;\\n  const branch = ref.replace(\\\"refs/heads/\\\", \\\"\\\");\\n\\n  // Skip special branches\\n  if (branch === CHECKPOINT_BRANCH || branch === TRAILS_BRANCH) return;\\n\\n  // Skip branch deletions\\n  if (payload.deleted === true) return;\\n\\n  const repoFullName = repo.full_name as string;\\n\\n  const installationId = await validateInstallation(payload, db, `Trail merge detection ${repoFullName}`);\\n  if (installationId === null) return;\\n\\n  let token: string;\\n  try {\\n    token = await getInstallationToken(\\n      installationId,\\n      { appId: env.GITHUB_CLIENT_ID, privateKey: env.GITHUB_APP_PRIVATE_KEY },\\n      env.ENTIRE_CACHE\\n    );\\n  } catch {\\n    return;\\n  }\\n\\n  try {\\n    const before = (payload.before as string) || \\\"\\\";\\n    await checkAndMergeTrails(repoFullName, branch, before, token);\\n  } catch (err) {\\n    console.log(`[trails-merge] error repo=${repoFullName} branch=${branch} error=${err instanceof Error ? err.message : String(err)}`);\\n  }\\n}\\n\\n// ============================================================================\\n// Trail webhook handlers\\n// ============================================================================\\n\\n// Process push to TRAILS_BRANCH - sync trail metadata