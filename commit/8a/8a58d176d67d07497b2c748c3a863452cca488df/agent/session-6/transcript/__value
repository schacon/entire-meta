 3800; // Turbopuffer limit is 4096, leave headroom\\n\\nexport interface TurbopufferSearchResult {\\n  checkpoint_id: string;\\n}\\n\\ninterface TurbopufferQueryRow {\\n  id: number;\\n  dist: number;\\n  attributes: {\\n    checkpoint_id?: string;\\n  };\\n}\\n\\ntype TurbopufferQueryResponse = TurbopufferQueryRow[];\\n\\nfunction truncateToBytes(str: string | null, maxBytes: number): string | null {\\n  if (str === null) return null;\\n  if (str.length <= maxBytes) return str;\\n  const encoder = new TextEncoder();\\n  const encoded = encoder.encode(str);\\n  if (encoded.length <= maxBytes) return str;\\n  const truncated = encoded.slice(0, maxBytes);\\n  const decoder = new TextDecoder();\\n  return decoder.decode(truncated);\\n}\\n\\nfunction buildSearchText(checkpoint: {\\n  prompt: string | null;\\n  commit_message: string | null;\\n  files_touched: string[] | null;\\n}): string {\\n  const parts: string[] = [];\\n  if (checkpoint.prompt) {\\n    parts.push(`Prompt: ${checkpoint.prompt}`);\\n  }\\n  if (checkpoint.commit_message) {\\n    parts.push(`Commit: ${checkpoint.commit_message}`);\\n  }\\n  if (checkpoint.files_touched) {\\n    parts.push(`Files: ${checkpoint.files_touched.join(\\\", \\\")}`);\\n  }\\n  return parts.join(\\\"\\\\n\\\");\\n}\\n\\n// Hash checkpoint_id to a deterministic numeric ID for Turbopuffer\\n// Uses FNV-1a 32-bit hash for fast, well-distributed IDs\\nfunction hashToNumericId(checkpointId: string): number {\\n  let hash = 0x811c9dc5; // FNV offset basis\\n  for (let i = 0; i < checkpointId.length; i++) {\\n    hash ^= checkpointId.charCodeAt(i);\\n    hash = Math.imul(hash, 0x01000193); // FNV prime\\n  }\\n  return hash >>> 0; // unsigned 32-bit\\n}\\n\\nasync function embedTexts(\\n  openaiApiKey: string,\\n  texts: string[],\\n): Promise<number[][]> {\\n  const resp = await fetch(\\\"https://api.openai.com/v1/embeddings\\\", {\\n    method: \\\"POST\\\",\\n    headers: {\\n      Authorization: `Bearer ${openaiApiKey}`,\\n      \\\"Content-Type\\\": \\\"application/json\\\",\\n    },\\n    body: JSON.stringify({\\n      model: EMBEDDING_MODEL,\\n      input: texts,\\n      dimensions: EMBEDDING_DIMENSIONS,\\n    }),\\n  });\\n\\n  if (!resp.ok) {\\n    const err = await resp.text().catch(() => \\\"\\\");\\n    throw new Error(`OpenAI embedding failed (${resp.status}): ${err}`);\\n  }\\n\\n  const result = (await resp.json()) as {\\n    data: Array<{ index: number; embedding: number[] }>;\\n  };\\n  return result.data\\n    .sort((a, b) => a.index - b.index)\\n    .map((item) => item.embedding);\\n}\\n\\nasync function embedQuery(openaiApiKey: string, text: string): Promise<number[]> {\\n  const resp = await fetch(\\\"https://api.openai.com/v1/embeddings\\\", {\\n    method: \\\"POST\\\",\\n    headers: {\\n      Authorization: `Bearer ${openaiApiKey}`,\\n      \\\"Content-Type\\\": \\\"application/json\\\",\\n    },\\n    body: JSON.stringify({\\n      model: EMBEDDING_MODEL,\\n      input: text,\\n      dimensions: EMBEDDING_DIMENSIONS,\\n    }),\\n  });\\n\\n  if (!resp.ok) {\\n    const err = await resp.text().catch(() => \\\"\\\");\\n    throw new Error(`OpenAI embedding failed (${resp.status}): ${err}`);\\n  }\\n\\n  const result = (await resp.json()) as { data: Array<{ embedding: number[] }> };\\n  return result.data[0].embedding;\\n}\\n\\nexport async function searchCheckpoints(\\n  turbopufferApiKey: string,\\n  openaiApiKey: string,\\n  repoId: string,\\n  query: string,\\n  filters?: { branch?: string },\\n  limit: number = 50,\\n): Promise<TurbopufferSearchResult[]> {\\n  // 1. Embed the query\\n  const vector = await embedQuery(openaiApiKey, query);\\n\\n  // 2. Query Turbopuffer\\n  // TODO: use repoId dynamically once backfill runs per-environment\\n  const namespace = `checkpoints-5be1c302-97d2-4cf4-8436-b001efe227e0`;\\n  const url = `https://api.turbopuffer.com/v1/vectors/${encodeURIComponent(namespace)}/query`;\\n\\n  const body: Record<string, unknown> = {\\n    vector,