ST_UPDATE_TTL = 60 * 60 * 24 * 7;\\n\\n// Log with consistent prefix\\nfunction log(event: string, data: Record<string, unknown>): void {\\n  console.log(`[repo-sync-queue] ${event}`, JSON.stringify(data));\\n}\\n\\n// KV key for per-installation rate limit state\\nfunction rateLimitKey(installationId: number): string {\\n  return `github:ratelimit:installation:${installationId}:resetAt`;\\n}\\n\\n// Check if a specific installation is currently rate limited\\nasync function isRateLimited(cache: KVNamespace, installationId: number): Promise<boolean> {\\n  const key = rateLimitKey(installationId);\\n  const resetAt = await cache.get(key);\\n  if (!resetAt) return false;\\n\\n  const resetTime = parseInt(resetAt, 10);\\n  if (Date.now() < resetTime) {\\n    return true;\\n  }\\n\\n  // Rate limit has expired, clean up\\n  await cache.delete(key);\\n  return false;\\n}\\n\\n// Set rate limit marker for a specific installation (called when we hit a rate limit)\\nasync function setRateLimitMarker(\\n  cache: KVNamespace,\\n  installationId: number,\\n  resetAt?: number,\\n): Promise<void> {\\n  // Default to 15 minutes from now if no reset time provided\\n  const resetTime = resetAt ?? Date.now() + 15 * 60 * 1000;\\n  // Store with TTL of 1 hour (self-cleaning)\\n  await cache.put(rateLimitKey(installationId), String(resetTime), {\\n    expirationTtl: 60 * 60,\\n  });\\n  log(\\\"rate_limit_set\\\", { installationId, resetAt: new Date(resetTime).toISOString() });\\n}\\n\\n// Notify users with access to a repo that data has been updated\\n// This triggers frontend polling to detect the change and refresh\\n// Note: This function never throws - errors are logged and swallowed\\n// to avoid affecting the main sync flow (notification is best-effort)\\nasync function notifyUsersOfRepoUpdate(\\n  db: Db,\\n  cache: KVNamespace,\\n  repoId: string\\n): Promise<number> {\\n  try {\\n    // Get all users with access to this repo (reuse existing utility)\\n    const userIds = await db.repos.getUsersForRepo(repoId);\\n\\n    if (userIds.length === 0) {\\n      return 0;\\n    }\\n\\n    // Update sync:lastUpdate for each user\\n    const now = String(Date.now());\\n    await Promise.all(\\n      userIds.map((userId) =>\\n        cache.put(`sync:lastUpdate:${userId}`, now, {\\n          expirationTtl: SYNC_LAST_UPDATE_TTL,\\n        })\\n      )\\n    );\\n\\n    return userIds.length;\\n  } catch (err) {\\n    log(\\\"notify_users_error\\\", {\\n      repoId,\\n      error: errorString(err),\\n    });\\n    return 0;\\n  }\\n}\\n\\n// Type guard to check if a message is a RepoSyncMessage\\nexport function isRepoSyncMessage(msg: unknown): msg is RepoSyncMessage {\\n  return (\\n    typeof msg === \\\"object\\\" &&\\n    msg !== null &&\\n    \\\"repoId\\\" in msg &&\\n    \\\"reason\\\" in msg &&\\n    \\\"priority\\\" in msg &&\\n    \\\"queuedAt\\\" in msg &&\\n    typeof (msg as RepoSyncMessage).repoId === \\\"string\\\" &&\\n    typeof (msg as RepoSyncMessage).reason === \\\"string\\\" &&\\n    typeof (msg as RepoSyncMessage).priority === \\\"number\\\"\\n  );\\n}\\n\\n// Look up the GitHub App installation ID for a repo\\nasync function getRepoInstallationId(\\n  db: Db,\\n  repoId: string,\\n): Promise<number | null> {\\n  const repo = await db.repos.getById(repoId);\\n\\n  if (!repo) {\\n    log(\\\"repo_not_found\\\", { repoId });\\n    return null;\\n  }\\n\\n  // Fast path: use the direct FK if available\\n  if (repo.installation_id) {\\n    const githubInstallationId = await db.installations.getGithubId(repo.installation_id);\\n    if (githubInstallationId) {\\n      return githubInstallationId;\\n    }\\n  }\\n\\n  // NB: This fallback shouldn't be required for long.\\n  // Fallback: look up by owner name (for repos not yet backfilled)\\n  const owner = repo.full_name.split(\\\"/\\\")[0];\\n  const githubInstallationId = await db.installations.getGithubIdByOwner(owner);\\n  if (!githubInstallationId) {\\n    log(\\\"no_installation_for_repo\\\", { repoId, owner });\\n    return null;\\n  }\\n\\n  return githubInstallationId;\\n}\\n\\n// Get a valid token for a GitHub App installation\\nasync function getTokenForInstallation(\\n  installationId: number,\\n  env: Env,\\n): Promise<string | null> {\\n  try {\\n    return await getInstallationToken(\\n      installationId,\\n      {\\n        appId: env.GITHUB_CLIENT_ID,\\n        privateKey: env.GITHUB_APP_PRIVATE_KEY,\\n      },\\n      env.ENTIRE_CACHE,\\n    );\\n  } catch (err) {\\n    log(\\\"installation_token_error\\\", {\\n      installationId,\\n      error: errorString(err),\\n    });\\n    return null;\\n  }\\n}\\n\\n// Process a batch of repo sync messages\\nexport async function processRepoSyncBatch(\\n  batch: MessageBatch<RepoSyncMessage>,\\n  env: Env,\\n): Promise<void> {\\n  const batchStartTime = Date.now();\\n  const batchId = generateBatchId();\\n\\n  // Calculate queue wait times for all messages in batch\\n  const queueWaitTimes = batch.messages.map(\\n    (msg) => Date.now() - msg.timestamp.getTime(),\\n  );\\n  const maxWaitMs = queueWaitTimes.length > 0 ? Math.max(...queueWaitTimes) : 0;\\n\\n  log(\\\"batch_started\\\", {\\n    batchId,\\n    queue: batch.queue,\\n    count: batch.messages.length,\\n    avgQueueWaitMs: avgMs(queueWaitTimes),\\n    maxQueueWaitMs: maxWaitMs,\\n  });\\n\\n  const db = getDb(env);\\n  const processingTimes: number[] = [];\\n  let successCount = 0;\\n  let errorCount = 0;\\n  let skippedCount = 0;\\n\\n  for (let i = 0; i < batch.messages.length; i++) {\\n    const msg = batch.messages[i];\\n    const msgStartTime = Date.now();\\n    const { repoId, reason } = msg.body;\\n    const queueWaitMs = Date.now() - msg.timestamp.getTime();\\n\\n    let installationId: number | null = null;\\n    try {\\n      // Look up installation for rate limit checks\\n      installationId = await getRepoInstallationId(db, repoId);\\n\\n      if (!installationId) {\\n        log(\\\"no_installation_for_repo\\\", { batchId, repoId, reason });\\n        msg.ack();\\n        skippedCount++;\\n        continue;\\n      }\\n\\n      // Check if this installation is rate limited\\n      if (await isRateLimited(env.ENTIRE_CACHE, installationId)) {\\n        log(\\\"message_skipped_rate_limited\\\", { batchId, repoId, installationId, reason });\\n        msg.retry();\\n        skippedCount++;\\n        continue;\\n      }\\n\\n      // Get a token for this installation\\n      const token = await getTokenForInstallation(installationId, env);\\n\\n      if (!token) {\\n        log(\\\"no_token_for_repo\\\", { batchId, repoId, installationId, reason });\\n        // Can't sync without a token - ack to avoid infinite retries\\n        // The repo will be picked up again on next reconciliation\\n        msg.ack();\\n        skippedCount++;\\n        continue;\\n      }\\n\\n      // For user_sync, skip if repo was already synced (another job got there first)\\n      // This prevents duplicate work when multiple users log in for the same repo\\n      if (reason === \\\"user_sync\\\" && await db.repos.isCheckpointsSynced(repoId)) {\\n        log(\\\"skip_already_synced\\\", { batchId, repoId, reason });\\n        msg.ack();\\n        skippedCount++;\\n        continue;\\n      }\\n\\n      const result = await traced(\\\"repo-sync-queue.processMessage\\\", async () => {\\n        const span = trace.getActiveSpan();\\n        span?.setAttribute(\\\"queue.message_wait_ms\\\", queueWaitMs);\\n        span?.setAttribute(\\\"github.installation_id\\\", installationId!);\\n\\n        return await syncRepoCheckpoints(db, repoId, token);\\n      });\\n      const processingMs = Date.now() - msgStartTime;\\n      processingTimes.push(processingMs);\\n\\n      log(\\\"message_processed\\\", {\\n        batchId,\\n        messageIndex: i + 1,\\n        totalMessages: batch.messages.length,\\n        repoId,\\n        reason,\\n        result: result.status,\\n        skipReason: result.reason,\\n        checkpoints: result.checkpointsDiscovered,\\n        queueWaitMs,\\n        processingMs,\\n        attempt: msg.attempts,\\n      });\\n\\n      msg.ack();\\n      if (result.status === \\\"ok\\\") {\\n        successCount++;\\n        // Notify users so frontend refreshes\\n        const usersNotified = await notifyUsersOfRepoUpdate(db, env.ENTIRE_CACHE, repoId);\\n        if (usersNotified > 0) {\\n          log(\\\"users_notified\\\", { repoId, usersNotified });\\n        }\\n      } else if (result.status === \\\"error\\\") {\\n        errorCount++;\\n      } else {\\n        skippedCount++;\\n      }\\n    } catch (err) {\\n      const processingMs = Date.now() - msgStartTime;\\n      processingTimes.push(processingMs);\\n      errorCount++;\\n\\n      // Check if this is a rate limit error\\n      if (err instanceof GitHubRateLimitError) {\\n        log(\\\"rate_limit_hit\\\", {\\n          batchId,\\n          repoId,\\n          installationId,\\n          reason,\\n          resetAt: err.resetAt\\n            ? new Date(err.resetAt * 1000).toISOString()\\n            : undefined,\\n          processingMs,\\n        });\\n\\n        // Set the rate limit marker for this installation only\\n        if (installationId) {\\n          await setRateLimitMarker(\\n            env.ENTIRE_CACHE,\\n            installationId,\\n            err.resetAt ? err.resetAt * 1000 : undefined,\\n          );\\n        }\\n\\n        // Retry only this message; continue processing remaining\\n        // (they may belong to different installations)\\n        msg.retry();\\n        continue;\\n      }\\n\\n      log(\\\"message_error\\\", {\\n        batchId,\\n        repoId,\\n        reason,\\n        attempt: msg.attempts,\\n        processingMs,\\n        error: errorString(err),\\n      });\\n\\n      // Retry if not at max attempts (max_retries is configured in wrangler.jsonc)\\n      msg.retry();\\n    }\\n  }\\n\\n  const totalBatchTimeMs = Date.now() - batch