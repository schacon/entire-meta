ction string (defaults to local Docker MySQL)\\n *   TURBOPUFFER_API_KEY    Turbopuffer API key (required unless --dry-run)\\n *   OPENAI_API_KEY         OpenAI API key for embeddings (required unless --dry-run)\\n */\\n\\nimport { Kysely, MysqlDialect } from \\\"kysely\\\";\\nimport { createPool } from \\\"mysql2\\\";\\nimport type { DB } from \\\"../db/types\\\";\\n\\n// --- Config ---\\n\\nconst EMBEDDING_MODEL = \\\"text-embedding-3-small\\\";\\nconst EMBEDDING_DIMENSIONS = 1536;\\nconst MAX_EMBEDDING_CHARS = 25000;\\nconst MAX_ATTRIBUTE_BYTES = 3800;\\n\\n// --- CLI ---\\n\\ninterface CliOptions {\\n  repo: string | null;\\n  limit: number;\\n  dryRun: boolean;\\n}\\n\\nfunction parseArgs(): CliOptions {\\n  const args = process.argv.slice(2);\\n  const options: CliOptions = { repo: null, limit: 5, dryRun: false };\\n\\n  for (let i = 0; i < args.length; i++) {\\n    switch (args[i]) {\\n      case \\\"--repo\\\":\\n        options.repo = args[++i];\\n        break;\\n      case \\\"--limit\\\":\\n        options.limit = parseInt(args[++i], 10);\\n        break;\\n      case \\\"--dry-run\\\":\\n        options.dryRun = true;\\n        break;\\n      default:\\n        console.error(`Unknown option: ${args[i]}`);\\n        process.exit(1);\\n    }\\n  }\\n  return options;\\n}\\n\\n// --- Database ---\\n\\nfunction createDb(): Kysely<DB> {\\n  const url =\\n    process.env.DATABASE_URL ?? \\\"mysql://entire:entire@localhost:3306/entire\\\";\\n  const parsed = new URL(url);\\n  return new Kysely<DB>({\\n    dialect: new MysqlDialect({\\n      pool: createPool({\\n        host: parsed.hostname,\\n        port: Number(parsed.port) || 3306,\\n        user: decodeURIComponent(parsed.username),\\n        password: decodeURIComponent(parsed.password),\\n        database: parsed.pathname.replace(\\\"/\\\", \\\"\\\"),\\n      }),\\n    }),\\n  });\\n}\\n\\n// --- Helpers (mirroring turbopuffer.ts) ---\\n\\nfunction truncateToBytes(str: string | null, maxBytes: number): string | null {\\n  if (str === null) return null;\\n  if (str.length <= maxBytes) return str;\\n  const encoder = new TextEncoder();\\n  const encoded = encoder.encode(str);\\n  if (encoded.length <= maxBytes) return str;\\n  const truncated = encoded.slice(0, maxBytes);\\n  return new TextDecoder().decode(truncated);\\n}\\n\\nfunction buildSearchText(checkpoint: {\\n  prompt: string | null;\\n  commit_message: string | null;\\n  files_touched_str: string | null;\\n}): string {\\n  const parts: string[] = [];\\n  if (checkpoint.prompt) parts.push(`Prompt: ${checkpoint.prompt}`);\\n  if (checkpoint.commit_message)\\n    parts.push(`Commit: ${checkpoint.commit_message}`);\\n  if (checkpoint.files_touched_str)\\n    parts.push(`Files: ${checkpoint.files_touched_str}`);\\n  return parts.join(\\\"\\\\n\\\");\\n}\\n\\nfunction hashToNumericId(checkpointId: string): number {\\n  let hash = 0x811c9dc5;\\n  for (let i = 0; i < checkpointId.length; i++) {\\n    hash ^= checkpointId.charCodeAt(i);\\n    hash = Math.imul(hash, 0x01000193);\\n  }\\n  return hash >>> 0;\\n}\\n\\n// --- Main ---\\n\\nasync function main() {\\n  const options = parseArgs();\\n  const turbopufferApiKey = process.env.TURBOPUFFER_API_KEY;\\n  const openaiApiKey = process.env.OPENAI_API_KEY;\\n\\n  if (!options.dryRun) {\\n    if (!turbopufferApiKey) {\\n      console.error(\\\"TURBOPUFFER_API_KEY is required (or use --dry-run)\\\");\\n      process.exit(1);\\n    }\\n    if (!openaiApiKey) {\\n      console.error(\\\"OPENAI_API_KEY is required (or use --dry-run)\\\");\\n      process.exit(1);\\n    }\\n  }\\n\\n  console.log(\\\"=== Search Index Test ===\\\");\\n  console.log(`  dry-run: ${options.dryRun}`);\\n  console.log(`  limit:   ${options.limit}`);\\n  if (options.repo) console.log(`  repo:    ${options.repo}`);\\n  console.log();\\n\\n  // Step 1: Fetch checkpoints from DB\\n  const db = createDb();\\n\\n  let repoQuery = db\\n    .selectFrom(\\\"repos\\\")\\n    .select([\\\"id\\\", \\\"full_name\\\", \\\"checkpoint_count\\\"])\\n    .where(\\\"checkpoint_count\\\", \\\">\\\", 0);\\n\\n  if (options.repo) {\\n    repoQuery = repoQuery.where(\\\"full_name\\\", \\\"=\\\", options.repo);\\n  }\\n\\n  const repos = await repoQuery.limit(1).execute();\\n\\n  if (repos.length === 0) {\\n    console.log(\\\"No repos with checkpoints found.\\\");\\n    await db.destroy();\\n    return;\\n  }\\n\\n  const repo = repos[0];\\n  console.log(\\n    `[1/5] Repo: ${repo.full_name} (${repo.checkpoint_count} total checkpoints)`,\\n  );\\n\\n  // Step 2: Fetch checkpoint data (simulates db.checkpoints.getByIds)\\n  const idRows = await db\\n    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n    .select(\\\"id\\\")\\n    .where(\\\"repo_id\\\", \\\"=\\\", repo.id)\\n    .orderBy(\\\"commit_date\\\", \\\"desc\\\")\\n    .limit(options.limit)\\n    .execute();\\n\\n  if (idRows.length === 0) {\\n    console.log(\\\"  No checkpoint commits found.\\\");\\n    await db.destroy();\\n    return;\\n  }\\n\\n  const rows = await db\\n    .selectFrom(\\\"repo_checkpoint_commits as cc\\\")\\n    .leftJoin(\\\"repo_checkpoints as cp\\\", (join) =>\\n      join\\n        .onRef(\\\"cp.repo_id\\\", \\\"=\\\", \\\"cc.repo_id\\\")\\n        .onRef(\\\"cp.checkpoint_id\\\", \\\"=\\\", \\\"cc.checkpoint_id\\\"),\\n    )\\n    .select([\\n      \\\"cc.checkpoint_id\\\",\\n      \\\"cc.branch\\\",\\n      \\\"cc.commit_sha\\\",\\n      \\\"cc.commit_message\\\",\\n      \\\"cc.commit_author_username\\\",\\n      \\\"cc.commit_date\\\",\\n      \\\"cp.prompt\\\",\\n      \\\"cp.agent\\\",\\n      \\\"cp.created_at\\\",\\n      \\\"cp.files_touched\\\",\\n    ])\\n    .where(\\n      \\\"cc.id\\\",\\n      \\\"in\\\",\\n      idRows.map((r) => r.id),\\n    )\\n    .execute();\\n\\n  console.log(`[2/5] Fetched ${rows.length} checkpoints from DB\\\\n`);\\n\\n  // Step 3: Build search text\\n  const checkpoints = rows.map((row) => {\\n    const filesTouched = row.files_touched as string[] | null