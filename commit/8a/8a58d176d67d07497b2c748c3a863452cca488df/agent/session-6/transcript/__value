n    35→\\n    36→function buildSearchText(checkpoint: {\\n    37→  prompt: string | null;\\n    38→  commit_message: string | null;\\n    39→  files_touched: string[] | null;\\n    40→}): string {\\n    41→  const parts: string[] = [];\\n    42→  if (checkpoint.prompt) {\\n    43→    parts.push(`Prompt: ${checkpoint.prompt}`);\\n    44→  }\\n    45→  if (checkpoint.commit_message) {\\n    46→    parts.push(`Commit: ${checkpoint.commit_message}`);\\n    47→  }\\n    48→  if (checkpoint.files_touched) {\\n    49→    parts.push(`Files: ${checkpoint.files_touched.join(\\\", \\\")}`);\\n    50→  }\\n    51→  return parts.join(\\\"\\\\n\\\");\\n    52→}\\n    53→\\n    54→// Hash checkpoint_id to a deterministic numeric ID for Turbopuffer\\n    55→// Uses FNV-1a 32-bit hash for fast, well-distributed IDs\\n    56→function hashToNumericId(checkpointId: string): number {\\n    57→  let hash = 0x811c9dc5; // FNV offset basis\\n    58→  for (let i = 0; i < checkpointId.length; i++) {\\n    59→    hash ^= checkpointId.charCodeAt(i);\\n    60→    hash = Math.imul(hash, 0x01000193); // FNV prime\\n    61→  }\\n    62→  return hash >>> 0; // unsigned 32-bit\\n    63→}\\n    64→\\n    65→async function embedTexts(\\n    66→  openaiApiKey: string,\\n    67→  texts: string[],\\n    68→): Promise<number[][]> {\\n    69→  const resp = await fetch(\\\"https://api.openai.com/v1/embeddings\\\", {\\n    70→    method: \\\"POST\\\",\\n    71→    headers: {\\n    72→      Authorization: `Bearer ${openaiApiKey}`,\\n    73→      \\\"Content-Type\\\": \\\"application/json\\\",\\n    74→    },\\n    75→    body: JSON.stringify({\\n    76→      model: EMBEDDING_MODEL,\\n    77→      input: texts,\\n    78→      dimensions: EMBEDDING_DIMENSIONS,\\n    79→    }),\\n    80→  });\\n    81→\\n    82→  if (!resp.ok) {\\n    83→    const err = await resp.text().catch(() => \\\"\\\");\\n    84→    throw new Error(`OpenAI embedding failed (${resp.status}): ${err}`);\\n    85→  }\\n    86→\\n    87→  const result = (await resp.json()) as {\\n    88→    data: Array<{ index: number; embedding: number[] }>;\\n    89→  };\\n    90→  return result.data\\n    91→    .sort((a, b) => a.index - b.index)\\n    92→    .map((item) => item.embedding);\\n    93→}\\n    94→\\n    95→async function embedQuery(openaiApiKey: string, text: string): Promise<number[]> {\\n    96→  const resp = await fetch(\\\"https://api.openai.com/v1/embeddings\\\", {\\n    97→    method: \\\"POST\\\",\\n    98→    headers: {\\n    99→      Authorization: `Bearer ${openaiApiKey}`,\\n   100→      \\\"Content-Type\\\": \\\"application/json\\\",\\n   101→    },\\n   102→    body: JSON.stringify({\\n   103→      model: EMBEDDING_MODEL,\\n   104→      input: text,\\n   105→      dimensions: EMBEDDING_DIMENSIONS,\\n   106→    }),\\n   107→  });\\n   108→\\n   109→  if (!resp.ok) {\\n   110→    const err = await resp.text().catch(() => \\\"\\\");\\n   111→    throw new Error(`OpenAI embedding failed (${resp.status}): ${err}`);\\n   112→  }\\n   113→\\n   114→  const result = (await resp.json()) as { data: Array<{ embedding: number[] }> };\\n   115→  return result.data[0].embedding;\\n   116→}\\n   117→\\n   118→export async function searchCheckpoints(\\n   119→  turbopufferApiKey: string,\\n   120→  openaiApiKey: string,\\n   121→  repoId: string,\\n   122→  query: string,\\n   123→  filters?: { branch?: string },\\n   124→  limit: number = 50,\\n   125→): Promise<TurbopufferSearchResult[]> {\\n   126→  // 1. Embed the query\\n   127→  const vector = await embedQuery(openaiApiKey, query);\\n   128→\\n   129→  // 2. Query Turbopuffer\\n   130→  // TODO: use repoId dynamically once backfill runs per-environment\\n   131→  const namespace = `checkpoints-5be1c302-97d2-4cf4-8436-b001efe227e0`;\\n   132→  const url = `https://api.turbopuffer.com/v1/vectors/${encodeURIComponent(namespace)}/query`;\\n   133→\\n   134→  const body: Record<string, unknown> = {\\n   135→    vector,\\n   136→    top_k: limit,\\n   137→ 