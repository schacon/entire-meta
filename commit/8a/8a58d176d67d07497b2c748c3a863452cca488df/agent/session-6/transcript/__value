id\\\", installationId!);\\n   250→\\n   251→        return await syncRepoCheckpoints(db, repoId, token);\\n   252→      });\\n   253→      const processingMs = Date.now() - msgStartTime;\\n   254→      processingTimes.push(processingMs);\\n   255→\\n   256→      log(\\\"message_processed\\\", {\\n   257→        batchId,\\n   258→        messageIndex: i + 1,\\n   259→        totalMessages: batch.messages.length,\\n   260→        repoId,\\n   261→        reason,\\n   262→        result: result.status,\\n   263→        skipReason: result.reason,\\n   264→        checkpoints: result.checkpointsDiscovered,\\n   265→        queueWaitMs,\\n   266→        processingMs,\\n   267→        attempt: msg.attempts,\\n   268→      });\\n   269→\\n   270→      msg.ack();\\n   271→      if (result.status === \\\"ok\\\") {\\n   272→        successCount++;\\n   273→        // Notify users so frontend refreshes\\n   274→        const usersNotified = await notifyUsersOfRepoUpdate(db, env.ENTIRE_CACHE, repoId);\\n   275→        if (usersNotified > 0) {\\n   276→          log(\\\"users_notified\\\", { repoId, usersNotified });\\n   277→        }\\n   278→      } else if (result.status === \\\"error\\\") {\\n   279→        errorCount++;\\n   280→      } else {\\n   281→        skippedCount++;\\n   282→      }\\n   283→    } catch (err) {\\n   284→      const processingMs = Date.now() - msgStartTime;\\n   285→      processingTimes.push(processingMs);\\n   286→      errorCount++;\\n   287→\\n   288→      // Check if this is a rate limit error\\n   289→      if (err instanceof GitHubRateLimitError) {\\n   290→        log(\\\"rate_limit_hit\\\", {\\n   291→          batchId,\\n   292→          repoId,\\n   293→          installationId,\\n   294→          reason,\\n   295→          resetAt: err.resetAt\\n   296→            ? new Date(err.resetAt * 1000).toISOString()\\n   297→            : undefined,\\n   298→          processingMs,\\n   299→        });\\n   300→\\n   301→        // Set the rat