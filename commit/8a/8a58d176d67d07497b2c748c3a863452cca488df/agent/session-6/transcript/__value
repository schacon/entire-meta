onToken } from \\\"./token\\\";\\n    16→import { queueUserRepoSyncBatch } from \\\"./user-repo-sync\\\";\\n    17→\\n    18→export type { RepoSyncMessage } from \\\"./repo-sync-service\\\";\\n    19→\\n    20→// TTL for sync:lastUpdate KV entries (7 days)\\n    21→const SYNC_LAST_UPDATE_TTL = 60 * 60 * 24 * 7;\\n    22→\\n    23→// Log with consistent prefix\\n    24→function log(event: string, data: Record<string, unknown>): void {\\n    25→  console.log(`[repo-sync-queue] ${event}`, JSON.stringify(data));\\n    26→}\\n    27→\\n    28→// KV key for per-installation rate limit state\\n    29→function rateLimitKey(installationId: number): string {\\n    30→  return `github:ratelimit:installation:${installationId}:resetAt`;\\n    31→}\\n    32→\\n    33→// Check if a specific installation is currently rate limited\\n    34→async function isRateLimited(cache: KVNamespace, installationId: number): Promise<boolean> {\\n    35→  const key = rateLimitKey(installationId);\\n    36→  const resetAt = await cache.get(key);\\n    37→  if (!resetAt) return false;\\n    38→\\n    39→  const resetTime = parseInt(resetAt, 10);\\n    40→  if (Date.now() < resetTime) {\\n    41→    return true;\\n    42→  }\\n    43→\\n    44→  // Rate limit has expired, clean up\\n    45→  await cache.delete(key);\\n    46→  return false;\\n    47→}\\n    48→\\n    49→// Set rate limit marker for a specific installation (called when we hit a rate limit)\\n    50→async function setRateLimitMarker(\\n    51→  cache: KVNamespace,\\n    52→  installationId: number,\\n    53→  resetAt?: number,\\n    54→): Promise<void> {\\n    55→  // Default to 15 minutes from now if no reset time provided\\n    56→  const resetTime = resetAt ?? Date.now() + 15 * 60 * 1000;\\n    57→  // Store with TTL of 1 hour (self-cleaning)\\n    58→  await cache.put(rateLimitKey(installationId), String(resetTime), {\\n    59→    expirationTtl: 60 * 60,\\n    60→  });\\n    61→  log(\\\"rate_limit_set\\\", { installationId, resetAt: new Date(resetTime).toISOString() });\\n    62→}\\n    63→\\n    64→// Notify users with access to a repo that data has been updated\\n    65→// This triggers frontend polling to detect the change and refresh\\n    66→// Note: This function never throws - errors are logged and swallowed\\n    67→// to avoid affecting the main sync flow (notification is best-effort)\\n    68→async function notifyUsersOfRepoUpdate(\\n    69→  db: Db,\\n    70→  cache: KVNamespace,\\n    71→  repoId: string\\n    72→): Promise<number> {\\n    73→  try {\\n    74→    // Get all users with access to this repo (reuse existing utility)\\n    75→    const userIds = await db.repos.getUsersForRepo(repoId);\\n    76→\\n    77→    if (userIds.length === 0) {\\n    78→      return 0;\\n    79→    }\\n    80→\\n    81→    // Update sync:lastUpdate for each user\\n    82→    const now = String(Date.now());\\n    83→    await Promise.all(\\n    84→      userIds.map((userId) =>\\n    85→        cache.put(`sync:lastUpdate:${userId}`, now, {\\n    86→          expirationTtl: SYNC_LAST_UPDATE_TTL,\\n    87→        })\\n    88→      )\\n    89→    );\\n    90→\\n    91→    return userIds.length;\\n    92→  } catch (err) {\\n    93→    log(\\\"notify_users_error\\\", {\\n    94→      repoId,\\n    95→      error: errorString(err),\\n    96→    });\\n    97→    return 0;\\n    98→  }\\n    99→}\\n   100→\\n   101→// Type guard to check if a message is a RepoSyncMessage\\n   102→export function isRepoSyncMessage(msg: unknown): msg is RepoSyncMessage {\\n   103→  return (\\n   104→    typeof msg === \\\"object\\\" &&\\n   105→    msg !== null &&\\n   106→    \\\"repoId\\\" in msg &&\\n   107→    \\\"reason\\\" in msg &&\\n   108→    \\\"priority\\\" in msg &&\\n   109→    \\\"queuedAt\\\" in msg &&\\n   110→    typeof (msg as RepoSyncMessage).repoId === \\\"string\\\" &&\\n   111→    typeof (msg as RepoSyncMessage).reason === \\\"string\\\" &&\\n   112→    typeof (msg as RepoSyncMessage).priority === \\\"number\\\"\\n   113→  );\\n   114→}\\n   115→\\n   116→// Look up the GitHub App installation ID for a repo\\n   117→async function getRepoInstallationId(\\n   118→  db: Db,\\n   119→  repoId: string,\\n   120→): Promise<number | null> {\\n   121→  const repo = await db.repos.getById(repoId);\\n   122→\\n   123→  if (!repo) {\\n   124→    log(\\\"repo_not_found\\\", { repoId });\\n   125→    return null;\\n   126→  }\\n   127→\\n   128→  // Fast path: use the direct FK if available\\n   129→  if (repo.installation_id) {\\n   130→    const githubInstallationId = await db.installations.getGithubId(repo.installation_id);\\n   131→    if (githubInstallationId) {\\n   132→      return githubInstallationId;\\n   133→    }\\n   134→  }\\n   135→\\n   136→  // NB: This fallback shouldn't be required for long.\\n   137→  // Fallback: look up by owner name (for repos not yet backfilled)\\n   138→  const owner = repo.full_name.split(\\\"/\\\")[0];\\n   139→  const githubInstallationId = await db.installations.getGithubIdByOwner(owner);\\n   140→  if (!githubInstallationId) {\\n   141→    log(\\\"no_installation_for_repo\\\", { repoId, owner });\\n   142→    return null;\\n   143→  }\\n   144→\\n   145→  return githubInstallationId;\\n   146→}\\n   147→\\n   148→// Get a valid token for a GitHub App installation\\n   149→async function getTokenForInstallation(\\n   150→  installationId: number,\\n   151→  env: Env,\\n   152→): Promise<string | null> {\\n   153→  try {\\n   154→    return await getInstallationToken(\\n   155→      installationId,\\n   156→      {\\n   157→        appId: env.GITHUB_CLIENT_ID,\\n   158→        privateKey: env.GITHUB_APP_PRIVATE_KEY,\\n   159→      },\\n   160→      env.ENTIRE_CACHE,\\n   161→    );\\n   162→  } catch (err) {\\n   163→    log(\\\"installation_token_error\\\", {\\n   164→      installationId,\\n   165→      error: errorString(err),\\n   166→    });\\n   167→    return null;\\n   168→  }\\n   169→}\\n   170→\\n   171→// Process a batch of repo sync messages\\n   172→export async function processRepoSyncBatch(\\n   173→  batch: MessageBatch<RepoSyncMessage>,\\n   174→  env: Env,\\n   175→): Promise<void> {\\n   176→  const batchStartTime = Date.now();\\n   177→  const batchId = generateBatchId();\\n   178→\\n   179→  // Calculate queue wait times for all messages in batch\\n   180→  const queueWaitTimes = batch.messages.map(\\n   181→    (msg) => Date.now() - msg.timestamp.getTime(),\\n   182→  );\\n   183→  const maxWaitMs = queueWaitTimes.length > 0 ? Math.max(...queueWaitTimes) : 0;\\n   184→\\n   185→  log(\\\"batch_started\\\", {\\n   186→    batchId,\\n   187→    queue: batch.queue,\\n   188→    count: batch.messages.length,\\n   189→    avgQueueWaitMs: avgMs(queueWaitTimes),\\n   190→    maxQueueWaitMs: maxWaitMs,\\n   191→  });\\n   192→\\n   193→  const db = getDb(env);\\n   194→  const processingTimes: number[] = [];\\n   195→  let successCount = 0;\\n   196→  let errorCount = 0;\\n   197→  let skippedCount = 0;\\n   198→\\n   199→  for (let i = 0; i < batch.messages.length; i++) {\\n   200→    const msg = batch.messages[i];\\n   201→    const msgStartTime = Date.now();\\n   202→    const { repoId, reason } = msg.body;\\n   203→    const queueWaitMs = Date.now() - msg.timestamp.getTime();\\n   204→\\n   205→    let installationId: number | null = null;\\n   206→    try {\\n   207→      // Look up installation for rate limit checks\\n   208→      installationId = await getRepoInstallationId(db, repoId);\\n   209→\\n   210→      if (!installationId) {\\n   211→        log(\\\"no_installation_for_repo\\\", { batchId, repoId, reason });\\n   212→        msg.ack();\\n   213→        skippedCount++;\\n   214→        continue;\\n   215→      }\\n   216→\\n   217→      // Check if this installation is rate limited\\n   218→      if (await isRateLimited(env.ENTIRE_CACHE, installationId)) {\\n   219→        log(\\\"message_skipped_rate_limited\\\", { batchId, repoId, installationId, reason });\