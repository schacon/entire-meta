etch,\\n\\n  // Queue consumer for webhook retries, repo checkpoint syncs, and user repo syncs\\n  // Note: Cloudflare Queues guarantee that all messages in a batch come from the same queue,\\n  // so we can safely check the first message type to determine batch handling.\\n  async queue(\\n    batch: MessageBatch<WebhookMessage | RepoSyncMessage | UserRepoSyncMessage>,\\n    env: Env\\n  ): Promise<void> {\\n    validateEnv(env);\\n\\n    if (batch.messages.length === 0) {\\n      return;\\n    }\\n\\n    const firstMessage = batch.messages[0]?.body;\\n\\n    // Determine message type from first message\\n    // Cloudflare Queues deliver messages from one queue per batch\\n    if (firstMessage && isRepoSyncMessage(firstMessage)) {\\n      // Process repo checkpoint sync messages\\n      await processRepoSyncBatch(\\n        batch as MessageBatch<RepoSyncMessage>,\\n        env\\n      );\\n    } else if (firstMessage && isUserRepoSyncMessage(firstMessage)) {\\n      // Process user repo sync messages\\n      await processUserRepoSyncBatch(\\n        batch as MessageBatch<UserRepoSyncMessage>,\\n        env\\n      );\\n    } else if (firstMessage && \\\"deliveryId\\\" in firstMessage) {\\n      // Process webhook messages (identified by deliveryId field)\\n      const WEBHOOK_MAX_RETRIES = 5;\\n      const batchStartTime = Date.now();\\n      const batchId = generateBatchId();\\n\\n      // Calculate queue wait times\\n      const queueWaitTimes = batch.messages.map((msg) => Date.now() - msg.timestamp.getTime());\\n      const maxWaitMs = queueWaitTimes.length > 0 ? Math.max(...queueWaitTimes) : 0;\\n\\n      console.log(`[webhook-queue] batch_started`, JSON.stringify({\\n        batchId,\\n        queue: batch.queue,\\n        count: batch.messages.length,\\n        avgQueueWaitMs: avgMs(queueWaitTimes),\\n        maxQueueWaitMs: maxWaitMs,\\n      }));\\n\\n      let successCount = 0;\\n      let retryCount = 0;\\n      let deadLetterCount = 0;\\n      const processingTimes: number[] = [];\\n\\n      for (const msg of batch.messages) {\\n        const msgStartTime = Date.now();\\n        const queueWaitMs = Date.now() - msg.timestamp.getTime();\\n        const webhookResult = await processQueueMessage(\\n          msg.body as WebhookMessage,\\n          msg.attempts,\\n          WEBHOOK_MAX_RETRIES,\\n          queueWaitMs,\\n          getDb(env),\\n          env.ENTIRE_CACHE,\\n          env,\\n          processAllWebhookEvents\\n        );\\n\\n        const processingMs = Date.now() - msgStartTime;\\n        processingTimes.push(processingMs);\\n\\n        if (webhookResult.result === \\\"retry\\\") {\\n          msg.retry();\\n          retryCount++;\\n        } else {\\n          msg.ack();\\n          if (webhookResult.result === \\\"dead-letter\\\") {\\n            deadLetterCount++;\\n          } else {\\n            successCount++;\\n          }\\n        }\\n\\n        console.log(`[webhook-queue] message_processed`, JSON.stringify({\\n          batchId,\\n          deliveryId: (msg.body as WebhookMessage).deliveryId,\\n          result: webhookResult.result,\\n          processingMs,\\n          attempt: msg.attempts,\\n        }));\\n      }\\n\\n      const totalBatchTimeMs = Date.now() - batchStartTime;\\n\\n      if (deadLetterCount > 0) {\\n        const queueSpan = trace.getActiveSpan();\\n        queueSpan?.setAttribute(\\\"webhook.queue.dead_letter_count\\\", deadLetterCount);\\n        queueSpan?.setStatus({\\n          code: SpanStatusCode.ERROR,\\n          message: `${deadLetterCount} dead-lettered`,\\n        });\\n      }\\n\\n      console.log(`[webhook-queue] batch_complete`, JSON.stringify({\\n        batchId,\\n        count: batch.messages.length,\\n        successCount,\\n        retryCount,\\n        deadLetterCount,\\n        totalBatchTimeMs,\\n        avgProcessingMs: avgMs(processingTimes),\\n        throughputPerMin: totalBatchTimeMs > 0\\n          ? Math.round((batch.messages.length / totalBatchTimeMs) * 60000)\\n          : 0,\\n      }));\\n    } else {\\n      // Unknown message type - log and ack to prevent infinite retries\\n      console.error(\\n        \\\"[queue] Unknown message type in batch:\\\",\\n        JSON.stringify(firstMessage).slice(0, 200)\\n      );\\n      for (const msg of batch.messages) {\\n        msg.ack();\\n      }\\n    }\\n  },\\n\\n  // Cron trigger for daily reconciliation\\n  async scheduled(\\n    controller: ScheduledController,\\n    env: Env,\\n    ctx: ExecutionContext\\n  ): Promise<void> {\\n    validateEnv(env);\\n\\n    const startedAt = new Date().toISOString();\\n    console.log(`[cron] Reconciliation cron triggered at ${startedAt}`);\\n\\n    ctx.waitUntil(\\n      handleReconciliationCron(env)\\n        .then(async (result) => {\\n          // Store last cron run info in KV\\n          await env.ENTIRE_CACHE.put(\\n            \\\"cron:reconciliation:last_run\\\",\\n            JSON.stringify({\\n              startedAt,\\n              completedAt: new Date().toISOString(),\\n              reposQueued: result.reposQueued,\\n              usersQueued: result.usersQueued,\\n            }),\\n            { expirationTtl: 60 * 60 * 24 * 7 } // Keep for 7 days\\n          );\\n        })\\n        .catch((err) => {\\n          console.error(\\\"[cron] Reconciliation failed:\\\", err);\\n        })\\n    );\\n  },\\n};\\n\\n// Export instrumented handler for Cloudflare Workers\\nexport default instrument(handler, otelConfig);\\n\",\"numLines\":324,\"startLine\":1,\"totalLines\":324}},\"sourceToolAssistantUUID\":\"4c139bab-ba77-4fab-bb15-ff24db9ff77e\"}\n{\"parentUuid\":\"b77eed21-4565-4736-9d80-0be79ea593dc\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/evisdrenova/code/entire/devenv/cli\",\"sessionId\":\"a680cc5e-06bc-4b55-b4b6-38f7b2fa7e61\",\"version\":\"2.1.56\",\"gitBranch\":\"main\",\"slug\":\"resilient-squishing-fern\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_014G