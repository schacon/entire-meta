ey (required unless --dry-run)\\n *   OPENAI_API_KEY         OpenAI API key for embeddings (required unless --dry-run)\\n */\\n\\nimport { Kysely, MysqlDialect } from \\\"kysely\\\";\\nimport { createPool } from \\\"mysql2\\\";\\nimport type { DB } from \\\"../db/types\\\";\\n\\n// --- Config ---\\n\\nconst EMBEDDING_MODEL = \\\"text-embedding-3-small\\\";\\nconst EMBEDDING_DIMENSIONS = 1536;\\nconst MAX_EMBEDDING_CHARS = 25000;\\nconst MAX_ATTRIBUTE_BYTES = 3800;\\n\\n// --- CLI ---\\n\\ninterface CliOptions {\\n  repo: string | null;\\n  limit: number;\\n  dryRun: boolean;\\n}\\n\\nfunction parseArgs(): CliOptions {\\n  const args = process.argv.slice(2);\\n  const options: CliOptions = { repo: null, limit: 5, dryRun: false };\\n\\n  for (let i = 0; i < args.length; i++) {\\n    switch (args[i]) {\\n      case \\\"--repo\\\":\\n        options.repo = args[++i];\\n        break;\\n      case \\\"--limit\\\":\\n        options.limit = parseInt(args[++i], 10);\\n        break;\\n      case \\\"--dry-run\\\":\\n        options.dryRun = true;\\n        break;\\n      default:\\n        console.error(`Unknown option: ${args[i]}`);\\n        process.exit(1);\\n    }\\n  }\\n  return options;\\n}\\n\\n// --- Database ---\\n\\nfunction createDb(): Kysely<DB> {\\n  const url =\\n    process.env.DATABASE_URL ?? \\\"mysql://entire:entire@localhost:3306/entire\\\";\\n  const parsed = new URL(url);\\n  return new Kysely<DB>({\\n    dialect: new MysqlDialect({\\n      pool: createPool({\\n        host: parsed.hostname,\\n        port: Number(parsed.port) || 3306,\\n        user: decodeURIComponent(parsed.username),\\n        password: decodeURIComponent(parsed.password),\\n        database: parsed.pathname.replace(\\\"/\\\", \\\"\\\"),\\n      }),\\n    }),\\n  });\\n}\\n\\n// --- Helpers (mirroring turbopuffer.ts) ---\\n\\nfunction truncateToBytes(str: string | null, maxBytes: number): string | null {\\n  if (str === null) return null;\\n  if (str.length <= maxBytes) return str