g | null;\\n   192→    commit_message: string | null;\\n   193→    prompt: string | null;\\n   194→    files_touched: string[] | null;\\n   195→  }>,\\n   196→): Promise<number> {\\n   197→  // Build search text and filter out empty entries\\n   198→  const validCheckpoints: Array<{\\n   199→    checkpoint: (typeof checkpoints)[number];\\n   200→    text: string;\\n   201→  }> = [];\\n   202→\\n   203→  for (const cp of checkpoints) {\\n   204→    const text = buildSearchText(cp);\\n   205→    if (text.trim()) {\\n   206→      validCheckpoints.push({ checkpoint: cp, text });\\n   207→    }\\n   208→  }\\n   209→\\n   210→  if (validCheckpoints.length === 0) {\\n   211→    return 0;\\n   212→  }\\n   213→\\n   214→  // Truncate texts for embedding model token limit\\n   215→  const embeddingTexts = validCheckpoints.map((v) =>\\n   216→    v.text.slice(0, MAX_EMBEDDING_CHARS),\\n   217→  );\\n   218→\\n   219→  // Embed all texts in one batch call\\n   220→  const embeddings = await embedTexts(openaiApiKey, embeddingTexts);\\n   221→\\n   222→  // Build upsert payload (row-based format for Turbopuffer v1 API)\\n   223→  const upserts = validCheckpoints.map(({ checkpoint, text }, i) => {\\n   224→    const filesTouchedStr = checkpoint.files_touched?.join(\\\", \\\") ?? null;\\n   225→    return {\\n   226→      id: hashToNumericId(checkpoint.checkpoint_id),\\n   227→      vector: embeddings[i],\\n   228→      attributes: {\\n   229→        checkpoint_id: checkpoint.checkpoint_id,\\n   230→        branch: checkpoint.branch,\\n   231→        agent: checkpoint.agent,\\n   232→        author: checkpoint.commit_author_username,\\n   233→        created_at: checkpoint.created_at,\\n   234→        commit_sha: checkpoint.commit_sha,\\n   235→        commit_message: truncateToBytes(\\n   236→          checkpoint.commit_message,\\n   237→          MAX_ATTRIBUTE_BYTES,\\n   238→        ),\\n   239→        prompt: truncateToBytes(checkpoint.prompt, MAX_ATTRIBUTE_BYTES),\\n   240→ 