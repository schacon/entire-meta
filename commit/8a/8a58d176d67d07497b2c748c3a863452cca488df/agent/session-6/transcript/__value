\\n  });\\n});\\n\\n// Status endpoint with available endpoints\\nv1.get(\\\"/status\\\", (c) =>\\n  c.json({\\n    status: \\\"ok\\\",\\n    message: \\\"Entire API is operational\\\",\\n    endpoints: {\\n      auth: {\\n        start: \\\"GET /auth/github/start (user-facing)\\\",\\n        start_installation: \\\"GET /auth/github/start-installation (user-facing)\\\",\\n        callback: \\\"GET /auth/github/callback (user-facing)\\\",\\n        me: \\\"GET /api/v1/auth/me\\\",\\n        logout: \\\"POST /api/v1/auth/logout\\\",\\n      },\\n      cache: {\\n        repos: \\\"GET /api/v1/cache/repos\\\",\\n        prs: \\\"GET /api/v1/cache/prs\\\",\\n        activity: \\\"GET /api/v1/cache/activity\\\",\\n        contributions: \\\"GET /api/v1/cache/contrib\\\",\\n        followers: \\\"GET /api/v1/cache/followers\\\",\\n        starred: \\\"GET /api/v1/cache/starred\\\",\\n        watched: \\\"GET /api/v1/cache/watched\\\",\\n        commits: \\\"GET /api/v1/cache/:org/:repo/commits\\\",\\n        checkpoints: \\\"GET /api/v1/cache/:org/:repo/checkpoints\\\",\\n        checkpointResolve: \\\"GET /api/v1/cache/:org/:repo/checkpoints/resolve/:checkpointId\\\",\\n        checkpointTranscript: \\\"GET /api/v1/cache/:org/:repo/checkpoints/:checkpointId/transcript\\\",\\n        clear: \\\"DELETE /api/v1/cache\\\",\\n      },\\n      webhooks: {\\n        github: \\\"POST /api/v1/webhooks/github\\\",\\n        health: \\\"GET /api/v1/webhooks/health\\\",\\n      },\\n    },\\n  })\\n);\\n\\n// Mount API routes under v1\\nv1.route(\\\"/auth\\\", authApiRoutes);\\nv1.route(\\\"/cache\\\", cacheRoutes);\\nv1.route(\\\"/webhooks\\\", webhookRoutes);\\n\\n// Mount v1 under /api/v1\\napp.route(\\\"/api/v1\\\", v1);\\n\\n// Mount OAuth routes at root (user-facing browser redirects)\\napp.route(\\\"/auth\\\", authOAuthRoutes);\\n\\n// 404 handler\\napp.notFound((c) => c.json({ error: \\\"Not found\\\" }, 404));\\n\\n// Error handler\\napp.onError((err, c) => {\\n  const requestId = crypto.randomUUID();\\n  console.error(`Unhandled error [${requestId}]:`, err);\\n  recordSpanError(err);\\n  // Safe if ENVIRONMENT is missing - isLocalDev returns false for undefined\\n  const showMessage = isLocalDev(c.env);\\n  return c.json(\\n    {\\n      error: \\\"Internal server error\\\",\\n      requestId,\\n      message: showMessage ? err.message : undefined,\\n    },\\n    500\\n  );\\n});\\n\\n// OpenTelemetry configuration - only exports traces when OTEL_EXPORTER_OTLP_ENDPOINT is set\\nconst otelConfig: ResolveConfigFn = (env: Env) => {\\n  if (!env.OTEL_EXPORTER_OTLP_ENDPOINT || isLocalDev(env)) {\\n    // No exporter configured or local dev - use a no-op processor to disable\\n    // trace export. An empty spanProcessors array triggers a warning from the\\n    // otel-cf-workers library, so we provide a single processor that drops spans.\\n    const noop = { onStart() {}, onEnd() {}, shutdown: () => Promise.resolve(), forceFlush: () => Promise.resolve() };\\n    return {\\n      spanProcessors: [noop],\\n      service: { name: \\\"entire-api\\\" },\\n    };\\n  }\\n\\n  return {\\n    exporter: {\\n      url: env.OTEL_EXPORTER_OTLP_ENDPOINT,\\n      headers: env.OTEL_EXPORTER_OTLP_HEADERS\\n        ? Object.fromEntries(\\n            env.OTEL_EXPORTER_OTLP_HEADERS.split(\\\",\\\").map((h) => {\\n              const [key, ...rest] = h.split(\\\"=\\\");\\n              return [key.trim(), rest.join(\\\"=\\\").trim()];\\n            })\\n          )\\n        : {},\\n    },\\n    service: { name: \\\"entire-api\\\" },\\n  };\\n};\\n\\n// Worker handlers\\nconst handler = {\\n  fetch: app.fetch,\\n\\n  // Queue consumer for webhook retries, repo checkpoint syncs, and user repo syncs\\n  // Note: Cloudflare Queues guarantee that all messages in a batch come from the same queue,\\n  // so we can safely check the first message type to determine batch handling.\\n  async queue(\\n    batch: MessageBatch<WebhookMessage | RepoSyncMessage | UserRepoSyncMessage | SearchIndexMessage>,\\n    env: Env\\n  ): Promise<void> {\\n    validateEnv(env);\\n\\n    if (batch.messages.length === 0) {\\n      return;\\n    }\\n\\n    const firstMessage = batch.messages[0]?.body;\\n\\n    // Determine message type from first message\\n    // Cloudflare Queues deliver messages from one queue per batch\\n    if (firstMessage && isRepoSyncMessage(firstMessage)) {\\n      // Process repo checkpoint sync messages\\n      await processRepoSyncBatch(\\n        batch as MessageBatch<RepoSyncMessage>,\\n        env\\n      );\\n    } else if (firstMessage && isUserRepoSyncMessage(firstMessage)) {\\n      // Process user repo sync messages\\n      await processUserRepoSyncBatch(\\n        batch as MessageBatch<UserRepoSyncMessage>,\\n        env\\n      );\\n    } else if (firstMessage && \\\"deliveryId\\\" in firstMessage) {\\n      // Process webhook messages (identified by deliveryId field)\\n      const WEBHOOK_MAX_RETRIES = 5;\\n      const batchStartTime = Date.now();\\n      const batchId = generateBatchId();\\n\\n      // Calculate queue wait times\\n      const queueWaitTimes = batch.messages.map((msg) => Date.now() - msg.timestamp.getTime());\\n      const maxWaitMs = queueWaitTimes.length > 0 ? Math.max(...queueWaitTimes) : 0;\\n\\n      console.log(`[webhook-queue] batch_started`, JSON.stringify({\\n        batchId,\\n        queue: batch.queue,\\n        count: batch.messages.length,\\n        avgQueueWaitMs: avgMs(queueWaitTimes),\\n        maxQueueWaitMs: maxWaitMs,\\n      }));\\n\\n      let successCount = 0;\\n      let retryCount = 0;\\n      let deadLetterCount = 0;\\n      const processingTimes: number[] = [];\\n\\n      for (const msg of batch.messages) {\\n        const msgStartTime = Date.now();\\n        const queueWaitMs = Date.now() - msg.timestamp.getTime();\\n        const webhookResult = await processQueueMessage(\\n          msg.body as WebhookMessage,\\n          msg.attempts,\\n          WEBHOOK_MAX_RETRIES,\\n          queueWaitMs,\\n          getDb(env),\\n          env.ENTIRE_CACHE,\\n          env,\\n          processAllWebhookEvents\\n        );\\n\\n        const processingMs = Date.now() - msgStartTime;\\n        processingTimes.push(processingMs);\\n\\n        if (webhookResult.result === \\\"retry\\\") {\\n          msg.retry();\\n          retryCount++;\\n        } else {\\n          msg.ack();\\n          if (webhookResult.result === \\\"dead-letter\\\") {\\n            deadLetterCount++;\\n          } else {\\n            successCount++;\\n          }\\n        }\\n\\n        console.log(`[webhook-queue] message_processed`, JSON.stringify({\\n          batchId,\\n          deliveryId: (msg.body as WebhookMessage).deliveryId,\\n          result: webhookResult.result,\\n          processingMs,\\n          attempt: msg.attempts,\\n        }));\\n      }\\n\\n      const totalBatchTimeMs = Date.now() - batchStartTime;\\n\\n      if (deadLetterCount > 0) {\\n        const queueSpan = trace.getActiveSpan();\\n        queueSpan?.setAttribute(\\\"webhook.queue.dead_letter_count\\\", deadLetterCount);\\n        queueSpan?.setStatus({\\n          code: SpanStatusCode.ERROR,\\n          message: `${deadLetterCount} dead-lettered`,\\n        });\\n      }\\n\\n      console.log(`[webhook-queue] batch_complete`, JSON.stringify({\\n        batchId,\\n        count: batch.messages.length,\\n        successCount,\\n        retryCount,\\n        deadLetterCount,\\n        totalBatchTimeMs,\\n        avgProcessingMs: avgMs(processingTimes),\\n        throughputPerMin: totalBatchTimeMs > 0\\n          ? Math.round((batch.messages.length / totalBatchTimeMs) * 60000)\\n          : 0,\\n      }));\\n    } else {\\n      // Unknown message type - log and ack to prevent infinite retries\\n      console.error(\\n        \\\"[queue] Unknown message type in batch:\\\",\\n        JSON.stringify(firstMessage).slice(0, 200)\\n      );\\n      for (const msg of batch.messages) {\\n        msg.ack();\\n      }\\n    }\\n  },\\n\\n  // Cron trigger for daily reconciliation\\n  async scheduled(\\n    controller: ScheduledController,\\n    env: Env,\\n    ctx: ExecutionContext\\n  ): Promise<void> {\\n    validateEnv(env);\\n\\n    const startedAt = new Date().toISOString();\\n    console.log(`[cron] Reconciliation cron triggered at ${startedAt}`);\\n\\n    ctx.waitUntil(\\n      handleReconciliationCron(env)\\n        .then(async (result) => {\\n          // Store last cron run info in KV\\n          await env.ENTIRE_CACHE.put(\\n            \\\"cron:reconciliation:last_run\\\",\\n            JSON.stringify({\\n              startedAt,\\n              completedAt: new Date().toISOString(),\\n              reposQueued: result.reposQueued,\\n              usersQueued: result.usersQueued,\\n            }),\\n            { expirationTtl: 60 * 60 * 24 * 7 } // Keep for 7 days\\n          );\\n        })\\n        .catch((err) => {\\n          console.error(\\\"[cron] Reconciliation failed:\\\", err);\\n        })\\n    );\\n  },\\n};\\n\\n// Export instrumented handler for Cloudflare Workers\\nexport default instrument(handler, otelConfig);\\n\",\"structuredPatch\":[{\"oldStart\":195,\"oldLines\":6,\"newStart\":195,\"newLines\":12,\"lines\":[\"         batch as MessageBatch<UserRepoSyncMessage>,\",\"         env\",\"       );\",\"+    } else if (firstMessage && isSearchIndexMessage(firstMessage)) {\",\"+      // Process search index messages\",\"+      await processSearchIndexBatch(\",\"+        batch as MessageBatch<SearchIndexMessage>,\",\"+        env,\",\"+      );\",\"     } else if (firstMessage && \\\"deliveryId\\\" in firstMessage) {\",\"       // Process webhook messages (identified by deliveryId field)\",\"       const WEBHOOK_MAX_RETRIES = 5;\"]}],\"userModified\":false,\"replaceAll\":false},\"sourceToolAssistantUUID\":\"b007e90c-deba-45df-bc02-25fa67de0eb3\"}\n{\"parentUuid\":\"a1af2146-d0a0-4fec-8ae2-d99bb8074ce2\",\"isSidechain\":false,\"