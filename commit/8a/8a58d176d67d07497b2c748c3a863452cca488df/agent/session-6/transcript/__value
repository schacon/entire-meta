ata } from \\\"../db/prs\\\";\\nimport { queueUserRepoSync, queueUserRepoSyncBatch } from \\\"../user-repo-sync\\\";\\nimport { parseTrailers, extractCheckpointIds, parseSquashCommitTitles, fetchSessionDataBatch, type BatchResult, type SessionData, fetchCommitStatsBatch, discoverTrailsFromBranch, fetchTrailMetadataAndCheckpointsBatch, updateTrailCheckpoints, updateTrailMetadata, isBranchMergedInto } from \\\"../github\\\";\\nimport { buildTranscriptCacheKey } from \\\"../kv\\\";\\nimport { CHECKPOINT_BRANCH, TRAILS_BRANCH } from \\\"../constants\\\";\\nimport { getInstallationToken } from \\\"../token\\\";\\nimport { queueRepoSyncBatch, syncRepoTrails } from \\\"../repo-sync-service\\\";\\nimport { traced } from \\\"../telemetry\\\";\\n\\n// Relevant webhook events that affect repository data\\nconst RELEVANT_EVENTS = new Set([\\n  \\\"push\\\",\\n  \\\"repository\\\",\\n  \\\"star\\\",\\n  \\\"fork\\\",\\n  \\\"delete\\\",\\n  \\\"create\\\",\\n  \\\"pull_request\\\",\\n]);\\n\\n// Installation events that trigger a full repo sync\\nconst INSTALLATION_EVENTS = new Set([\\n  \\\"installation\\\",\\n  \\\"installation_repositories\\\",\\n]);\\n\\n// Convert a timestamp to ISO 8601 string\\n// GitHub webhooks send pushed_at as Unix timestamp (number), but API returns ISO string\\nfunction toISOString(value: unknown): string | null {\\n  if (value === null || value === undefined) {\\n    return null;\\n  }\\n  if (typeof value === \\\"number\\\") {\\n    return new Date(value * 1000).toISOString();\\n  }\\n  if (typeof value === \\\"string\\\") {\\n    return value;\\n  }\\n  return null;\\n}\\n\\n/**\\n * Validate that installation exists in database before processing webhook.\\n * Returns null if no installation ID in payload (caller should skip processing).\\n * Throws if installation ID exists but not found in DB (to trigger retry queue).\\n * Returns the validated installation ID on success.\\n */\\nasync function validateInstallation(\\n  payload: Record<string, unknown>,\\n  db: Db,\\n  context: string\\n): Promise<number | null> {\\n  const installation = payload.installation as { id?: number } | undefined;\\n  if (!installation?.id) {\\n    return null;\\n  }\\n\\n  const exists = await db.installations.existsByGitHubId(installation.id);\\n  if (!exists) {\\n    throw new Error(`${context}: installation ${installation.id} not found in database`);\\n  }\\n\\n  return installation.id;\\n}\\n\\n// Extract repository data from webhook payload\\nfunction extractRepoData(payload: Record<string, unknown>): WebhookRepoData | null {\\n  const repo = payload.repository as Record<string, unknown> | undefined;\\n  if (!repo || typeof repo.full_name !== \\\"string\\\" || typeof repo.id !== \\\"number\\\") {\\n    return null;\\n  }\\n\\n  return {\\n    github_id: repo.id as number,\\n    full_name: repo.full_name as string,\\n    name: repo.name as string | undefined,\\n    description: repo.description as string | null | undefined,\\n    html_url: repo.html_url as string | undefined,\\n    language: repo.language as string | null | undefined,\\n    stargazers_count: repo.stargazers_count as number | undefined,\\n    private: repo.private as boolean | undefined,\\n    pushed_at: toISOString(repo.pushed_at) ?? toISOString(repo.updated_at),\\n  };\\n}\\n\\n// Unified webhook processor - calls all webhook handlers\\n// Used by the queue worker to ensure consistent processing\\nexport async function processAllWebhookEvents(\\n  eventType: string,\\n  action: string | null,\\n  payload: Record<string, unknown>,\\n  db: Db,\\n  cache: KVNamespace,\\n  env?: Env\\n): Promise<void> {\\n  // Process standard repo events\\n  await traced(\\\"processWebhookEvent\\\", () =>\\n    processWebhookEvent(eventType, action, payload, db, cache)\\n  );\\n\\n  // Process installation events (invalidate caches + queue checkpoint sync)\\n  await traced(\\\"processInstallationEvent\\\", () =>\\n    processInstallationEvent(eventType, action, payload, db, cache, env)\\n  );\\n\\n  // Process access-change events (queue user repo sync)\\n  await traced(\\\"processAccessChangeEvent\\\", () =>\\n    processAccessChangeEvent(eventType, action, payload, db, cache, env)\\n  );\\n\\n  // Process pull request events (invalidate PR cache)\\n  await traced(\\\"processPullRequestEvent\\\", () =>\\n    processPullRequestEvent(eventType, action, payload, db)\\n  );\\n\\n  // Process checkpoint webhooks and trail merge detection (handlers check ref internally)\\n  if (env) {\\n    await Promise.all([\\n      traced(\\\"processSessionsPushEvent\\\", () =>\\n        processSessionsPushEvent(eventType, payload, db, env)\\n      ),\\n      traced(\\\"processCommitPushEvent\\\", () =>\\n        processCommitPushEvent(eventType, payload, db, env)\\n      ),\\n      traced(\\\"processTrailsPushEvent\\\", () =>\\n        processTrailsPushEvent(eventType, payload, db, env)\\n      ),\\n      traced(\\\"processTrailMergeDetection\\\", () =>\\n        processTrailMergeDetection(eventType, payload, db, env)\\n      ),\\n    ]);\\n  }\\n}\\n\\n// Process webhook event to update DB directly and notify affected users\\nexport async function processWebhookEvent(\\n  eventType: string,\\n  action: string | null,\\n  payload: Record<string, unknown>,\\n  db: Db,\\n  cache: KVNamespace\\n): Promise<void> {\\n  // Only process relevant events\\n  if (!RELEVANT_EVENTS.has(eventType)) {\\n    return;\\n  }\\n\\n  // Validate installation exists before processing\\n  // This prevents unauthorized data modification from compromised webhook secrets\\n  const installationId = await validateInstallation(payload, db, `Webhook ${eventType}`);\\n  if (installationId === null) {\\n    console.log(`Webhook ${eventType}: no installation ID in payload, skipping`);\\n    return;\\n  }\\n\\n  const repoData = extractRepoData(payload);\\n  if (!repoData) {\\n    console.log(`Webhook ${eventType}: no repository data, skipping`);\\n    return;\\n  }\\n\\n  const repoGithubId = repoData.github_id;\\n  const repoFullName = repoData.full_name;\\n\\n  // Invalidate branches cache when a branch is created or deleted\\n  // GitHub's create/delete events include ref_type (\\\"branch\\\" or \\\"tag\\\") and ref (the name)\\n  if ((eventType === \\\"create\\\" || eventType === \\\"delete\\\") && payload.ref_type === \\\"branch\\\") {\\n    await cache.delete(`branches:${repoFullName}`);\\n    console.log(`Webhook ${eventType}/branch: invalidated branches cache for ${repoFullName}`);\\n  }\\n\\n  // Find all users who have this repo synced (by stable GitHub ID)\\n  const userIds = await db.repos.getUsersByRepoGithubId(repoGithubId);\\n\\n  if (userIds.length === 0) {\\n    console.log(`Webhook ${eventType} for ${repoFullName}: no affected users`);\\n    return;\\n  }\\n\\n  // Handle different event types\\n  let dbChanges = 0;\\n\\n  if (eventType === \\\"repository\\\" && action === \\\"deleted\\\") {\\n    // Repository was deleted - remove from DB (by stable GitHub ID)\\n    dbChanges = await db.repos.deleteByGithubId(repoGithubId);\\n    console.log(`Webhook repository/deleted for ${repoFullName}: removed ${dbChanges} row(s)`);\\n  } else {\\n    // For all other events, update the repository with the latest data\\n    // This also handles renames by updating full_name via github_id lookup\\n    dbChanges = await db.repos.updateFromWebhook(repoGithubId, repoData);\\n    console.log(\\n      `Webhook ${eventType}/${action || \\\"n/a\\\"} for ${repoFullName}: updated ${dbChanges} row(s)`\\n    );\\n\\n    // For push events, increment the weekly activity counter\\n    if (eventType === \\\"push\\\") {\\n      const activityUpdated = await db.repos.incrementActivity(repoGithubId);\\n      console.log(\\n        `Push event for ${repoFullName}: incremented activity for ${activityUpdated} repo record(s)`\\n      );\\n    }\\n  }\\n\\n  // Update sync timestamp for each affected user so frontend knows to refresh\\n  const now = Date.now();\\n  await Promise.all(\\n    userIds.map((userId) =>\\n      cache.put(`sync:lastUpdate:${userId}`, String(now), {\\n        expirationTtl: 60 * 60 * 24 * 7, // 7 days\\n      })\\n    )\\n  );\\n\\n  console.log(\\n    `Webhook ${eventType}/${action || \\\"n/a\\\"} for ${repoFullName}: notified ${userIds.length} user(s)`\\n  );\\n}\\n\\n// Process installation webhook event - update app_has_access, invalidate caches, and queue checkpoint sync\\n// NOTE: We don't do full repo sync here to avoid timeouts. We queue repos for background sync.\\n// This now handles multi-user installations (e.g., org installations accessible by multiple users).\\nexport async function processInstallationEvent(\\n  eventType: string,\\n  action: string | null,\\n  payload: Record<string, unknown>,\\n  db: Db,\\n  cache: KVNamespace,\\n  env?: Env\\n): Promise<void> {\\n  // Only process installation events\\n  if (!INSTALLATION_EVENTS.has(eventType)) {\\n    return;\\n  }\\n\\n  const installation = payload.installation as Record<string, unknown> | undefined;\\n  if (!installation?.id) {\\n    console.log(`Installation event ${eventType}/${action}: no installation.id, skipping`);\\n    return;\\n  }\\n\\n  const githubInstallationId = installation.id as number;\\n  console.log(`Processing installation event ${eventType}/${action} for installation ${githubInstallationId}`);\\n\\n  // Find all users linked to this installation\\n  const users = await db.installations.findUsersByGitHubId(githubInstallationId);\\n\\n  // Handle installation.created - create the installation record and process repos\\n  if (eventType === \\\"installation\\\" && action === \\\"created\\\") {\\n    const account = installation.account as Record<string, unknown> | undefined;\\n    if (!account) {\\n      // No account data - can't create installation record, skip processing\\n      console.warn(`Installation ${githubInstallationId}: missing account data, skipping`);\\n      return;\\n    }\\n\\n    const accountId = account.id as number | undefined;\\n    const accountLogin = account.login as string | undefined;\\n    const accountType = account.type as string | undefined;\\n\\n    // Log warning if account data is incomplete (but still create the record)\\n    if (!accountId || !accountLogin) {\\n      console.warn(`Installation ${githubInstallationId}: incomplete account data - id: ${accountId}, login: ${accountLogin}`);\\n    }\\n\\n    const installationUuid = await db.installations.upsert({\\n      github_installation_id: githubInstallationId,\\n      account_login: accountLogin ?? \\\"unknown\\\",\\n      account_type: accountType ?? \\\"User\\\",\\n      account_id: accountId ?? 0,\\n      app_slug: (installation.app_slug as string) ?? null,\\n      suspended_at: null,\\n    });\\n    console.log(`Installation ${githubInstallationId}: created in DB`);\\n\\n    // Process repos for this new installation - upsert with app_has_access and queue for sync\\n    // Note: No users are linked yet (they link on OAuth), so we just set up the repos\\n    const repos = (payload.repositories as Array<{ id: number; full_name: string; private?: boolean; default_branch?: string }>) || [];\\n    const queueAvailable = !!env?.REPO_SYNC_QUEUE;\\n\\n    // Batch upsert all repos\\n    const repoIds = await db.repos.upsertBatch(\\n      repos.map((repo) => ({\\n        github_id: repo.id,\\n        full_name: repo.full_name,\\n        app_has_access: true,\\n        installation_id: installationUuid,\\n        default_branch: repo.default_branch,\\n        is_private: repo.private,\\n      }))\\n    );\\n\\n    // Queue all for checkpoint backfill (user links created on OAuth callback)\\n    if (queueAvailable) {\\n      await queueRepoSyncBatch(\\n        env!.REPO_SYNC_QUEUE,\\n        repoIds.map((id) => ({ id })),\\n        \\\"installation\\\",\\n        10\\n      );\\n      console.log(`Installation created: ${repos.length} repos queued for sync`);\\n    } else {\\n      console.log(`Installation created: ${repos.length} repos upserted`);\\n    }\\n    return; // Done processing installation.created\\n  }\\n\\n  // Handle installation.deleted - remove from installations table (CASCADE handles links)\\n  if (eventType === \\\"installation\\\" && action === \\\"deleted\\\") {\\n    const deleted = await db.installations.deleteByGitHubId(githubInstallationId);\\n    if (deleted) {\\n      console.log(`Installation ${githubInstallationId}: deleted from DB (links removed by CASCADE)`);\\n    }\\n    // Note: app_has_access will be reset on next refresh-app-access run\\n    // Invalidate cache for all affected users\\n    const now = Date.now();\\n    await Promise.all(\\n      users.map((user) =>\\n        cache.put(`sync:lastUpdate:${user.id}`, String(now), {\\n          expirationTtl: 60 * 60 * 24 * 7,\\n        })\\n      )\\n    );\\n    return;\\n  }\\n\\n  // Handle repos added/removed - always update app_has_access, only link to users if they exist\\n  if (eventType === \\\"installation_repositories\\\") {\\n    const reposAdded = (payload.repositories_added as Array<{ id: number; full_name: string; private?: boolean; default_branch?: string }>) || [];\\n    const reposRemoved = (payload.repositories_removed as Array<{ id: number; full_name: string }>) || [];\\n    const queueAvailable = !!env?.REPO_SYNC_QUEUE;\\n\\n    // Look up installation UUID for linking repos\\n    const installationUuid = await db.installations.findIdByGitHubId(githubInstallationId);\\n\\n    // Batch upsert added repos\\n    const repoIds = await db.repos.upsertBatch(\\n      reposAdded.map((repo) => ({\\n        github_id: repo.id,\\n        full_name: repo.full_name,\\n        app_has_access: true,\\n        installation_id: installationUuid,\\n        default_branch: repo.default_branch,\\n        is_private: repo.private,\\n      }))\\n    );\\n\\n    // Link repos to ALL users who have access via this installation (if any)\\n    await db.repos.addUserReposBatch(users.map((u) => u.id), repoIds);\\n\\n    // Queue all for checkpoint backfill\\n    if (queueAvailable) {\\n      await queueRepoSyncBatch(\\n        env!.REPO_SYNC_QUEUE,\\n        repoIds.map((id) => ({ id })),\\n        \\\"installation\\\",\\n        10\\n      );\\n    }\\n\\n    // Process removed repos - update access flag\\n    for (const repo of reposRemoved) {\\n      await db.repos.updateAppAccessByFullName(repo.full_name, false);\\n    }\\n\\n    if (queueAvailable) {\\n      console.log(`Installation repos updated: +${reposAdded.length} queued (linked to ${users.length} users), -${reposRemoved.length} removed`);\\n    } else {\\n      console.log(`Installation repos updated: +${reposAdded.length} upserted (linked to ${users.length} users), -${reposRemoved.length} removed`);\\n    }\\n    return;\\n  }\\n\\n  // For other events, skip if no users linked\\n  if (users.length === 0) {\\n    console.log(`Installation ${githubInstallationId}: no users found (not onboarded yet), skipping`);\\n    return;\\n  }\\n\\n  // Invalidate sync timestamp for all affected users\\n  const now = Date.now();\\n  await Promise.all(\\n    users.map((user) =>\\n      cache.put(`sync:lastUpdate:${user.id}`, String(now), {\\n        expirationTtl: 60 * 60 * 24 * 7, // 7 days\\n      })\\n    )\\n  );\\n\\n  const userLogins = users.map((u) => u.github_login).filter(Boolean).join(\\\", \\\");\\n  console.log(`Installation ${eventType}/${action} for users [${userLogins}]: cache invalidated`);\\n}\\n\\n// Relevant actions per access-change event type\\nconst ACCESS_CHANGE_ACTIONS: Record<string, Set<string>> = {\\n  member: new Set([\\\"added\\\", \\\"removed\\\", \\\"edited\\\"]),\\n  membership: new Set([\\\"added\\\", \\\"removed\\\"]),\\n  organization: new Set([\\\"member_added\\\", \\\"member_removed\\\"]),\\n  team: new Set([\\\"added_to_repository\\\", \\\"removed_from_repository\\\"]),\\n  repository: new Set([\\\"created\\\"]),\\n};\\n\\n// Process access-change webhook events\\n// Optimized handlers for repository.created and member.added/removed use direct DB operations\\n// Other events (team, membership, organization) queue full syncs\\nexport async function processAccessChangeEvent(\\n  eventType: string,\\n  action: string | null,\\n  payload: Record<string, unknown>,\\n  db: Db,\\n  cache: KVNamespace,\\n  env?: Env\\n): Promise<void> {\\n  // Gate on relevant action\\n  const relevantActions = ACCESS_CHANGE_ACTIONS[eventType];\\n  if (!action || !relevantActions?.has(action)) {\\n    return;\\n  }\\n\\n  // Handle repository.created with direct DB operations (no API calls needed)\\n  if (eventType === \\\"repository\\\" && action === \\\"created\\\") {\\n    await handleRepositoryCreated(payload, db, cache, env);\\n    return;\\n  }\\n\\n  // Handle member events - added/removed use direct DB, edited queues sync\\n  if (eventType === \\\"member\\\") {\\n    await handleMemberEvent(action, payload, db, cache, env);\\n    return;\\n  }\\n\\n  // membership events always queue full sync (team membership changes)\\n  if (eventType === \\\"membership\\\") {\\n    await handleMembershipEvent(action, payload, db, cache, env);\\n    return;\\n  }\\n\\n  // organization events always queue full sync\\n  if (eventType === \\\"organization\\\") {\\n    await handleOrganizationEvent(action, payload, db, cache, env);\\n    return;\\n  }\\n\\n  // team events always queue full sync (we don't have team membership data)\\n  if (eventType === \\\"team\\\") {\\n    await handleTeamEvent(action, payload, db, cache, env);\\n    return;\\n  }\\n}\\n\\n// Handle repository.created - directly upsert repo and link to all installation users\\nasync function handleRepositoryCreated(\\n  payload: Record<string, unknown>,\\n  db: Db,\\n  cache: KVNamespace,\\n  env?: Env\\n): Promise<void> {\\n  const installation = payload.installation as { id?: number } | undefined;\\n  if (!installation?.id) {\\n    console.log(\\\"Access change repository/created: no installation.id, skipping\\\");\\n    return;\\n  }\\n\\n  const repository = payload.repository as { id?: number; full_name?: string; name?: string; description?: string | null; html_url?: string; language?: string | null; private?: boolean; default_branch?: string } | undefined;\\n  if (!repository?.id || !repository?.full_name) {\\n    console.log(\\\"Access change repository/created: no repository data, skipping\\\");\\n    return;\\n  }\\n\\n  // Look up installation UUID by GitHub installation ID\\n  const installationUuid = await db.installations.findIdByGitHubId(installation.id);\\n\\n  if (!installationUuid) {\\n    console.log(`Access change repository/created: installation ${installation.id} not found in DB, skipping`);\\n    return;\\n  }\\n\\n  // Find users linked to this installation\\n  const users = await db.installations.findUsersByGitHubId(installation.id);\\n\\n  // Upsert the repo with app_has_access=true\\n  const repoIds = await db.repos.upsertBatch([{\\n    github_id: repository.id,\\n    full_name: repository.full_name,\\n    app_has_access: true,\\n    installation_id: installationUuid,\\n    default_branch: repository.default_branch,\\n    is_private: repository.private,\\n  }]);\\n\\n  if (repoIds.length === 0) {\\n    console.log(`Access change repository/created: failed to upsert repo ${repository.full_name}`);\\n    return;\\n  }\\n\\n  const repoId = repoIds[0];\\n\\n  // Link all installation users to the new repo\\n  if (users.length > 0) {\\n    await db.repos.addUserReposBatch(users.map((u) => u.id), [repoId]);\\n  }\\n\\n  // Queue checkpoint sync for the new repo\\n  if (env?.REPO_SYNC_QUEUE) {\\n    await queueRepoSyncBatch(env.REPO_SYNC_QUEUE, [{ id: repoId }], \\\"installation\\\", 10);\\n  }\\n\\n  // Invalidate user caches\\n  if (users.length > 0) {\\n    const now = Date.now();\\n    await Promise.all(\\n      users.map((user) =>\\n        cache.put(`sync:lastUpdate:${user.id}`, String(now), {\\n          expirationTtl: 60 * 60 * 24 * 7,\\n        })\\n      )\\n    );\\n  }\\n\\n  console.log(`Access change repository/created: upserted ${repository.full_name}, linked to ${users.length} user(s)`);\\n}\\n\\n// Handle member events - added/removed use direct DB operations, edited queues sync\\nasync function handleMemberEvent(\\n  action: string | null,\\n  payload: Record<string, unknown>,\\n  db: Db,\\n  cache: KVNamespace,\\n  env?: Env\\n): Promise<void> {\\n  const member = payload.member as { id?: number } | undefined;\\n  if (!member?.id) {\\n    console.log(`Access change member/${action}: no member.id, skipping`);\\n    return;\\n  }\\n\\n  const user = await db.users.findByGitHubId(member.id);\\n  if (!user) {\\n    console.log(`Access change member/${action}: user not found for GitHub ID ${member.id}, skipping`);\\n    return;\\n  }\\n\\n  const repository = payload.repository as { id?: number; full_name?: string } | undefined;\\n\\n  // For member.added - try direct DB link, fallback to full sync if repo doesn't exist\\n  if (action === \\\"added\\\") {\\n    if (repository?.id) {\\n      const repo = await db.repos.getByGithubId(repository.id);\\n      if (repo) {\\n        // Repo exists - add direct link\\n        await db.repos.addUserRepo(user.id, repo.id);\\n        const now = Date.now();\\n        await cache.put(`sync:lastUpdate:${user.id}`, String(now), {\\n          expirationTtl: 60 * 60 * 24 * 7,\\n        });\\n        console.log(`Access change member/added: linked user ${user.id} to repo ${repo.full_name}`);\\n        return;\\n      }\\n    }\\n    // Repo doesn't exist in our DB - fall back to full sync\\n    if (env?.USER_REPO_SYNC_QUEUE) {\\n      await queueUserRepoSync(env.USER_REPO_SYNC_QUEUE, user.id, \\\"access_change\\\");\\n      const now = Date.now();\\n      await cache.put(`sync:lastUpdate:${user.id}`, String(now), {\\n        expirationTtl: 60 * 60 * 24 * 7,\\n      });\\n      console.log(`Access change member/added: queued sync for user ${user.id} (repo not in DB)`);\\n    }\\n    return;\\n  }\\n\\n  // For member.removed - remove direct DB link\\n  if (action === \\\"removed\\\") {\\n    if (repository?.id) {\\n      const repo = await db.repos.getByGithubId(repository.id);\\n      if (repo) {\\n        await db.repos.removeUserRepo(user.id, repo.id);\\n        const now = Date.now();\\n        await cache.put(`sync:lastUpdate:${user.id}`, String(now), {\\n          expirationTtl: 60 * 60 * 24 * 7,\\n        });\\n        console.log(`Access change member/removed: unlinked user ${user.id} from repo ${repo.full_name}`);\\n        return;\\n      }\\n    }\\n    // Even if repo doesn't exist, invalidate cache\\n    const now = Date.now();\\n    await cache.put(`sync:lastUpdate:${user.id}`, String(now), {\\n      expirationTtl: 60 * 60 * 24 * 7,\\n    });\\n    console.log(`Access change member/removed: cache invalidated for user ${user.id}`);\\n    return;\\n  }\\n\\n  // For member.edited (permission changes) - queue full sync to reconcile\\n  if (action === \\\"edited\\\") {\\n    if (!env?.USER_REPO_SYNC_QUEUE) {\\n      console.log(\\\"Access change member/edited: no USER_REPO_SYNC_QUEUE, skipping\\\");\\n      return;\\n    }\\n    await queueUserRepoSync(env.USER_REPO_SYNC_QUEUE, user.id, \\\"access_change\\\");\\n    const now = Date.now();\\n    await cache.put(`sync:lastUpdate:${user.id}`, String(now), {\\n      expirationTtl: 60 * 60 * 24 * 7,\\n    });\\n    console.log(`Access change member/edited: queued sync for user ${user.id}`);\\n  }\\n}\\n\\n// Handle membership events (team membership) - always queue full sync\\nasync function handleMembershipEvent(\\n  action: string | null,\\n  payload: Record<string, unknown>,\\n  db: Db,\\n  cache: KVNamespace,\\n  env?: Env\\n): Promise<void> {\\n  if (!env?.USER_REPO_SYNC_QUEUE) {\\n    console.log(`Access change membership/${action}: no USER_REPO_SYNC_QUEUE, skipping`);\\n    return;\\n  }\\n\\n  const member = payload.member as { id?: number } | undefined;\\n  if (!member?.id) {\\n    console.log(`Access change membership/${action}: no member.id, skipping`);\\n    return;\\n  }\\n\\n  const user = await db.users.findByGitHubId(member.id);\\n  if (!user) {\\n    console.log(`Access change membership/${action}: user not found for GitHub ID ${member.id}, skipping`);\\n    return;\\n  }\\n\\n  await queueUserRepoSync(env.USER_REPO_SYNC_QUEUE, user.id, \\\"access_change\\\");\\n  const now = Date.now();\\n  await cache.put(`sync:lastUpdate:${user.id}`, String(now), {\\n    expirationTtl: 60 * 60 * 24 * 7,\\n  });\\n  console.log(`Access change membership/${action}: queued sync for user ${user.id}`);\\n}\\n\\n// Handle organization events (member_added/removed) - always queue full sync\\nasync function handleOrganizationEvent(\\n  action: string | null,\\n  payload: Record<string, unknown>,\\n  db: Db,\\n  cache: KVNamespace,\\n  env?: Env\\n): Promise<void> {\\n  if (!env?.USER_REPO_SYNC_QUEUE) {\\n    console.log(`Access change organization/${action}: no USER_REPO_SYNC_QUEUE, skipping`);\\n    return;\\n  }\\n\\n  const membership = payload.membership as { user?: { id?: number } } | undefined;\\n  if (!membership?.user?.id) {\\n    console.log(`Access change organization/${action}: no membership.user.id, skipping`);\\n    return;\\n  }\\n\\n  const user = await db.users.findByGitHubId(membership.user.id);\\n  if (!user) {\\n    console.log(`Access change organization/${action}: user not found for GitHub ID ${membership.user.id}, skipping`);\\n    return;\\n  }\\n\\n  await queueUserRepoSync(env.USER_REPO_SYNC_QUEUE, user.id, \\\"access_change\\\");\\n  const now = Date.now();\\n  await cache.put(`sync:lastUpdate:${user.id}`, String(now), {\\n    expirationTtl: 60 * 60 * 24 * 7,\\n  });\\n  console.log(`Access change organization/${action}: queued sync for user ${user.id}`);\\n}\\n\\n// Handle team events (added_to_repository/removed_from_repository) - always queue full sync\\n// We don't have team membership data, so we can't determine which users are affected\\nasync function handleTeamEvent(\\n  action: string | null,\\n  payload: Record<string, unknown>,\\n  db: Db,\\n  cache: KVNamespace,\\n  env?: Env\\n): Promise<void> {\\n  if (!env?.USER_REPO_SYNC_QUEUE) {\\n    console.log(`Access change team/${action}: no USER_REPO_SYNC_QUEUE, skipping`);\\n    return;\\n  }\\n\\n  const installation = payload.installation as { id?: number } | undefined;\\n  if (!installation?.id) {\\n    console.log(`Access change team/${action}: no installation.id, skipping`);\\n    return;\\n  }\\n\\n  const users = await db.installations.findUsersByGitHubId(installation.id);\\n  if (users.length === 0) {\\n    console.log(`Access change team/${action}: no users for installation ${installation.id}, skipping`);\\n    return;\\n  }\\n\\n  const queued = await queueUserRepoSyncBatch(env.USER_REPO_SYNC_QUEUE, users, \\\"access_change\\\");\\n  const now = Date.now();\\n  await Promise.all(\\n    users.map((user) =>\\n      cache.put(`sync:lastUpdate:${user.id}`, String(now), {\\n        expirationTtl: 60 * 60 * 24 * 7,\\n      })\\n    )\\n  );\\n  console.log(`Access change team/${action}: queued sync for ${queued} user(s)`);\\n}\\n\\n// PR actions that affect the open PR list\\nconst PR_RELEVANT_ACTIONS = new Set([\\n  \\\"opened\\\",\\n  \\\"closed\\\",\\n  \\\"reopened\\\",\\n  \\\"converted_to_draft\\\",\\n  \\\"ready_for_review\\\",\\n]);\\n\\n// Extract PR data from webhook payload\\nfunction extractPRData(payload: Record<string, unknown>): WebhookPRData | null {\\n  const pr = payload.pull_request as Record<string, unknown> | undefined;\\n  if (!pr || typeof pr.id !== \\\"number\\\") {\\n    return null;\\n  }\\n\\n  return {\\n    github_pr_id: pr.id as number,\\n    number: pr.number as number,\\n    title: pr.title as string,\\n    html_url: pr.html_url as string,\\n    state: pr.state as string,\\n    draft: (pr.draft as boolean) ?? false,\\n    created_at: pr.created_at as string,\\n    updated_at: pr.updated_at as string,\\n  };\\n}\\n\\n// Process pull_request webhook event - update PR in database\\nexport async function processPullRequestEvent(\\n  eventType: string,\\n  action: string | null,\\n  payload: Record<string, unknown>,\\n  db: Db\\n): Promise<void> {\\n  if (eventType !== \\\"pull_request\\\") {\\n    return;\\n  }\\n\\n  if (!action || !PR_RELEVANT_ACTIONS.has(action)) {\\n    console.log(`PR event ${action}: not relevant for DB, skipping`);\\n    return;\\n  }\\n\\n  // Validate installation exists before processing\\n  // This prevents unauthorized data modification from compromised webhook secrets\\n  const installationId = await validateInstallation(payload, db, `PR event ${action}`);\\n  if (installationId === null) {\\n    console.log(`PR event ${action}: no installation ID in payload, skipping`);\\n    return;\\n  }\\n\\n  const repo = payload.repository as Record<string, unknown> | undefined;\\n  if (!repo || typeof repo.full_name !== \\\"string\\\" || typeof repo.id !== \\\"number\\\") {\\n    console.log(`PR event: no repository data, skipping`);\\n    return;\\n  }\\n\\n  const repoGithubId = repo.id as number;\\n  const repoFullName = repo.full_name as string;\\n  const prData = extractPRData(payload);\\n  if (!prData) {\\n    console.log(`PR event: no pull_request data, skipping`);\\n    return;\\n  }\\n\\n  let dbChanges = 0;\\n\\n  if (action === \\\"opened\\\" || action === \\\"reopened\\\") {\\n    // Insert or update PR in the global repo_pull_requests table\\n    dbChanges = await db.prs.upsertPRFromWebhook(repoGithubId, prData);\\n    console.log(`PR ${action} #${prData.number} for ${repoFullName}: upserted ${dbChanges} row(s)`);\\n  } else if (action === \\\"closed\\\") {\\n    // Delete PR (we only keep open PRs)\\n    dbChanges = await db.prs.deletePRByGithubId(repoGithubId, prData.github_pr_id);\\n    console.log(`PR closed #${prData.number} for ${repoFullName}: deleted ${dbChanges} row(s)`);\\n  } else if (action === \\\"converted_to_draft\\\" || action === \\\"ready_for_review\\\") {\\n    // Update draft status\\n    const draft = action === \\\"converted_to_draft\\\";\\n    dbChanges = await db.prs.updatePRDraftStatusByGithubIds(repoGithubId, prData.github_pr_id, draft);\\n    console.log(`PR ${action} #${prData.number} for ${repoFullName}: updated draft status ${dbChanges} row(s)`);\\n  }\\n\\n  // Note: sync:lastUpdate cache invalidation is already handled by processWebhookEvent\\n  // for all pull_request events, so we don't duplicate it here (Cloudflare KV has a\\n  // 1 write/sec/key rate limit that would cause 429 errors).\\n}\\n\\n// ============================================================================\\n// Checkpoint webhook handlers\\n// ============================================================================\\n\\nfunction logCheckpointMetric(event: string, data: Record<string, unknown>): void {\\n  console.log(`[checkpoint-sync] ${event}`, JSON.stringify(data));\\n}\\n\\n/** Map session data (from the checkpoint branch) into CheckpointWebhookData records. */\\nfunction buildCheckpointDataFromSessions(\\n  checkpointIds: string[],\\n  sessionDataResult: BatchResult<SessionData>,\\n  fallbackBranch?: string | null,\\n): CheckpointWebhookData[] {\\n  return checkpointIds.map((checkpointId) => {\\n    const session = sessionDataResult.data.get(checkpointId);\\n    return {\\n      checkpoint_id: checkpointId,\\n      prompt: session?.prompt ?? null,\\n      agent: session?.agent ?? null,\\n      steps: session?.steps ?? null,\\n      session_count: session?.sessionCount ?? null,\\n      strategy: session?.strategy ?? null,\\n      created_at: session?.createdAt ?? new Date().toISOString(),\\n      branch: session?.branch ?? fallbackBranch ?? null,\\n      session_id: session?.sessionId ?? null,\\n      files_touched: session?.filesTouched ?? null,\\n      session_ids: session?.sessionIds ?? null,\\n      transcript_uuid_at_start: session?.transcriptUuidAtStart ?? null,\\n      transcript_lines_at_start: session?.transcriptLinesAtStart ?? null,\\n      checkpoint_transcript_start: session?.checkpointTranscriptStart ?? null,\\n      input_tokens: session?.inputTokens ?? null,\\n      cache_creation_tokens: session?.cacheCreationTokens ?? null,\\n      cache_read_tokens: session?.cacheReadTokens ?? null,\\n      output_tokens: session?.outputTokens ?? null,\\n      api_call_count: session?.apiCallCount ?? null,\\n      attribution_agent_lines: session?.attributionAgentLines ?? null,\\n      attribution_human_added: session?.attributionHumanAdded ?? null,\\n      attribution_human_modified: session?.attributionHumanModified ?? null,\\n      attribution_human_removed: session?.attributionHumanRemoved ?? null,\\n      attribution_total_committed: session?.attributionTotalCommitted ?? null,\\n      attribution_agent_percentage: session?.attributionAgentPercentage ?? null,\\n      attribution_calculated_at: session?.attributionCalculatedAt ?? null,\\n      sessions: (session?.sessions ?? null) as Json | null,\\n    };\\n  });\\n}\\n\\n// Process push to CHECKPOINT_BRANCH - stores session metadata (prompt, agent, steps)\\nexport async function processSessionsPushEvent(\\n  eventType: string,\\n  payload: Record<string, unknown>,\\n  db: Db,\\n  env: Env\\n): Promise<void> {\\n  if (eventType !== \\\"push\\\") return;\\n\\n  const repo = payload.repository as Record<string, unknown> | undefined;\\n  if (!repo?.full_name) return;\\n\\n  const repoFullName = repo.full_name as string;\\n  const ref = payload.ref as string | undefined;\\n\\n  // Only process pushes to CHECKPOINT_BRANCH\\n  if (ref !== `refs/heads/${CHECKPOINT_BRANCH}`) return;\\n\\n  const deleted = payload.deleted as boolean | undefined;\\n  if (deleted) {\\n    logCheckpointMetric(\\\"sessions_branch_deleted\\\", { repo: repoFullName });\\n    return;\\n  }\\n\\n  // Find the global repo record\\n  const repoGithubId = repo.id as number;\\n  const repoRecord = await db.repos.getByGithubId(repoGithubId);\\n  if (!repoRecord) {\\n    logCheckpointMetric(\\\"skip_repo_not_found\\\", { repo: repoFullName });\\n    return;\\n  }\\n\\n  // Get commits from push payload\\n  const commits = payload.commits as Array<Record<string, unknown>> | undefined;\\n  if (!commits?.length) return;\\n\\n  // Extract checkpoint IDs from Checkpoint: trailer\\n  // Handle multiple trailers per commit (e.g., from squashed commits)\\n  const checkpointIds: string[] = [];\\n  for (const commit of commits) {\\n    const message = commit.message as string;\\n    const trailers = parseTrailers(message);\\n    const commitCheckpointIds = trailers[\\\"Checkpoint\\\"] ?? [];\\n    checkpointIds.push(...commitCheckpointIds);\\n  }\\n\\n  if (checkpointIds.length === 0) {\\n    logCheckpointMetric(\\\"no_session_checkpoints\\\", { repo: repoFullName });\\n    return;\\n  }\\n\\n  logCheckpointMetric(\\\"processing_sessions\\\", { repo: repoFullName, count: checkpointIds.length });\\n\\n  // Validate installation exists before processing\\n  // This prevents unauthorized data modification from compromised webhook secrets\\n  const installationId = await validateInstallation(payload, db, `Sessions push ${repoFullName}`);\\n  if (installationId === null) {\\n    logCheckpointMetric(\\\"skip_no_installation\\\", { repo: repoFullName });\\n    return;\\n  }\\n\\n  // Get app installation token\\n  let token: string | null = null;\\n  try {\\n    token = await getInstallationToken(\\n      installationId,\\n      {\\n        appId: env.GITHUB_CLIENT_ID,\\n        privateKey: env.GITHUB_APP_PRIVATE_KEY,\\n      },\\n      env.ENTIRE_CACHE\\n    );\\n  } catch (err) {\\n    logCheckpointMetric(\\\"installation_token_unavailable\\\", {\\n      repo: repoFullName,\\n      installationId,\\n      error: err instanceof Error ? err.message : String(err),\\n    });\\n  }\\n\\n  // If no token, we can't fetch session files - skip processing\\n  if (!token) {\\n    logCheckpointMetric(\\\"skip_no_token\\\", { repo: repoFullName });\\n    return;\\n  }\\n\\n  trace.getActiveSpan()?.setAttribute(\\\"github.installation_id\\\", installationId);\\n\\n  try {\\n    // Batch fetch all session data using GraphQL\\n    const sessionDataResult = await fetchSessionDataBatch(repoFullName, checkpointIds, token);\\n\\n    if (sessionDataResult.failedItems.length > 0) {\\n      logCheckpointMetric(\\\"sessions_partial_failure\\\", {\\n        repo: repoFullName,\\n        failed: sessionDataResult.failedItems.length,\\n        errors: sessionDataResult.errors,\\n      });\\n    }\\n\\n    // Build checkpoint data array\\n    const checkpointDataArray = buildCheckpointDataFromSessions(checkpointIds, sessionDataResult);\\n\\n    // Upsert checkpoints for the global repo (once, not per-user)\\n    const successCount = await db.checkpoints.upsertBatch(repoRecord.id, checkpointDataArray);\\n\\n    // Invalidate transcript cache for affected checkpoints\\n    // Session data changes mean transcripts may have changed\\n    await Promise.all(\\n      checkpointIds.map((id) =>\\n        env.ENTIRE_CACHE.delete(buildTranscriptCacheKey(repoFullName, id))\\n      )\\n    );\\n\\n    // Count session metrics for monitoring\\n    const totalSessions = checkpointDataArray.reduce((sum, cp) => sum + (cp.session_count ?? 0), 0);\\n    const checkpointsWithSessions = checkpointDataArray.filter((cp) => cp.sessions != null).length;\\n\\n    logCheckpointMetric(\\\"sessions_completed\\\", {\\n      repo: repoFullName,\\n      successCount,\\n      totalSessions,\\n      checkpointsWithSessions,\\n      checkpointsTotal: checkpointDataArray.length,\\n    });\\n  } catch (err) {\\n    logCheckpointMetric(\\\"error_sessions\\\", {\\n      repo: repoFullName,\\n      error: err instanceof Error ? err.message : String(err),\\n    });\\n    throw err; // Re-throw to trigger webhook retry mechanism\\n  }\\n}\\n\\n// Process push to any branch (except CHECKPOINT_BRANCH) - stores commit data\\nexport async function processCommitPushEvent(\\n  eventType: string,\\n  payload: Record<string, unknown>,\\n  db: Db,\\n  env: Env\\n): Promise<void> {\\n  if (eventType !== \\\"push\\\") return;\\n\\n  const repo = payload.repository as Record<string, unknown> | undefined;\\n  if (!repo?.full_name) return;\\n\\n  const repoFullName = repo.full_name as string;\\n  const ref = payload.ref as string | undefined;\\n  const deleted = payload.deleted as boolean | undefined;\\n\\n  // Only process branch pushes (not tags)\\n  if (!ref?.startsWith(\\\"refs/heads/\\\")) return;\\n  const branch = ref.replace(\\\"refs/heads/\\\", \\\"\\\");\\n\\n  // Skip CHECKPOINT_BRANCH - handled by processSessionsPushEvent\\n  if (branch === CHECKPOINT_BRANCH) return;\\n\\n  // Skip TRAILS_BRANCH - handled by processTrailsPushEvent\\n  if (branch === TRAILS_BRANCH) return;\\n\\n  // Validate installation exists before processing any DB operations\\n  // This prevents unauthorized data modification from compromised webhook secrets\\n  const installationId = await validateInstallation(payload, db, `Commit push ${repoFullName}`);\\n  if (installationId === null) {\\n    logCheckpointMetric(\\\"skip_no_installation\\\", { repo: repoFullName, branch });\\n    return;\\n  }\\n\\n  trace.getActiveSpan()?.setAttribute(\\\"github.installation_id\\\", installationId);\\n\\n  // Find the global repo record\\n  const repoGithubId = repo.id as number;\\n  const repoRecord = await db.repos.getByGithubId(repoGithubId);\\n  if (!repoRecord) {\\n    logCheckpointMetric(\\\"skip_repo_not_found\\\", { repo: repoFullName });\\n    return;\\n  }\\n\\n  // Handle branch deletion\\n  if (deleted) {\\n    const deletedCount = await db.checkpoints.deleteCommitsByBranch(repoRecord.id, branch);\\n    const orphansDeleted = await db.checkpoints.deleteOrphaned(repoRecord.id);\\n    if (deletedCount > 0 || orphansDeleted > 0) {\\n      await db.checkpoints.recalculateCount(repoRecord.id);\\n    }\\n    logCheckpointMetric(\\\"branch_deleted\\\", { repo: repoFullName, branch, deletedCount, orphansDeleted });\\n    return;\\n  }\\n\\n  // Handle force push: clear stale checkpoint commits for this branch and queue re-sync.\\n  // Force pushes rewrite history, so old checkpoint commits may no longer be reachable.\\n  // The push payload only contains newly pushed commits (not the full branch), so we\\n  // delete stale entries immediately and queue a full backfill to re-discover the rest.\\n  const forced = payload.forced as boolean | undefined;\\n  if (forced) {\\n    const deletedCount = await db.checkpoints.deleteCommitsByBranch(repoRecord.id, branch);\\n    const orphansDeleted = await db.checkpoints.deleteOrphaned(repoRecord.id);\\n    if (deletedCount > 0 || orphansDeleted > 0) {\\n      await db.checkpoints.recalculateCount(repoRecord.id);\\n    }\\n\\n    // Invalidate backfill state so next sync does a full re-discovery\\n    await db.checkpoints.updateSyncState(repoRecord.id, { resetBackfill: true });\\n\\n    // Queue immediate re-sync to backfill reachable checkpoints\\n    if (env?.REPO_SYNC_QUEUE) {\\n      await queueRepoSyncBatch(env.REPO_SYNC_QUEUE, [{ id: repoRecord.id }], \\\"manual\\\", 10);\\n    }\\n\\n    logCheckpointMetric(\\\"force_push_cleanup\\\", { repo: repoFullName, branch, deletedCount, orphansDeleted });\\n  }\\n\\n  // Get commits from push payload\\n  const commits = payload.commits as Array<Record<string, unknown>> | undefined;\\n  if (!commits?.length) return;\\n\\n  const defaultBranch = repoRecord.default_branch || repo.default_branch || \\\"main\\\";\\n\\n  // Extract checkpoint IDs from Entire-Checkpoint trailers in commit messages.\\n  // On non-default branches, skip non-distinct commits (distinct=false means the\\n  // commit already existed in the repository / was pushed before, e.g. via \\\"Update branch\\\" merge).\\n  const checkpointCommits: Array<{\\n    sha: string;\\n    message: string;\\n    checkpointId: string;\\n    author: { name: string; username?: string };\\n    timestamp: string;\\n  }> = [];\\n\\n  let skippedNonDistinct = 0;\\n\\n  for (const commit of commits) {\\n    if (branch !== defaultBranch && commit.distinct === false) {\\n      skippedNonDistinct++;\\n      continue;\\n    }\\n\\n    const message = commit.message as string;\\n    const checkpointIds = extractCheckpointIds(message);\\n\\n    for (const checkpointId of checkpointIds) {\\n      checkpointCommits.push({\\n        sha: commit.id as string,\\n        message,\\n        checkpointId,\\n        author: {\\n          name: (commit.author as Record<string, unknown>)?.name as string,\\n          username: (commit.author as Record<string, unknown>)?.username as string | undefined,\\n        },\\n        timestamp: commit.timestamp as string,\\n      });\\n    }\\n  }\\n\\n  if (skippedNonDistinct > 0) {\\n    logCheckpointMetric(\\\"skipped_non_distinct_commits\\\", {\\n      repo: repoFullName,\\n      branch,\\n      skipped: skippedNonDistinct,\\n    });\\n  }\\n\\n  if (checkpointCommits.length === 0) {\\n    logCheckpointMetric(\\\"no_commit_checkpoints\\\", { repo: repoFullName, branch });\\n    return;\\n  }\\n\\n  logCheckpointMetric(\\\"processing_commits\\\", { repo: repoFullName, branch, count: checkpointCommits.length });\\n\\n  // Get app installation token (installation already validated above)\\n  // Token is required to fetch commit stats - without it we'd store incomplete data\\n  let token: string;\\n  try {\\n    token = await getInstallationToken(\\n      installationId,\\n      {\\n        appId: env.GITHUB_CLIENT_ID,\\n        privateKey: env.GITHUB_APP_PRIVATE_KEY,\\n      },\\n      env.ENTIRE_CACHE\\n    );\\n  } catch (err) {\\n    logCheckpointMetric(\\\"installation_token_unavailable\\\", {\\n      repo: repoFullName,\\n      branch,\\n      installationId,\\n      error: err instanceof Error ? err.message : String(err),\\n    });\\n    // Thro