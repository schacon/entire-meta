);\\n   214→}\\n   215→\\n   216→// Index checkpoints into Turbopuffer for vector search\\n   217→// Builds search text, embeds via OpenAI, and upserts to Turbopuffer\\n   218→// Returns the number of successfully indexed checkpoints\\n   219→export async function indexCheckpoints(\\n   220→  turbopufferApiKey: string,\\n   221→  openaiApiKey: string,\\n   222→  repoId: string,\\n   223→  checkpoints: Array<{\\n   224→    checkpoint_id: string;\\n   225→    branch: string | null;\\n   226→    agent: string | null;\\n   227→    commit_author_username: string | null;\\n   228→    created_at: string | null;\\n   229→    commit_sha: string | null;\\n   230→    commit_message: string | null;\\n   231→    prompt: string | null;\\n   232→    files_touched: string[] | null;\\n   233→  }>,\\n   234→): Promise<number> {\\n   235→  // Build search text and filter out empty entries\\n   236→  const validCheckpoints: Array<{\\n   237→    checkpoint: (typeof checkpoints)[number];\\n   238→    text: string;\\n   239→  }> = [];\\n   240→\\n   241→  for (const cp of checkpoints) {\\n   242→    const text = buildSearchText(cp);\\n   243→    if (text.trim()) {\\n   244→      validCheckpoints.push({ checkpoint: cp, text });\\n   245→    }\\n   246→  }\\n   247→\\n   248→  if (validCheckpoints.length === 0) {\\n   249→    return 0;\\n   250→  }\\n   251→\\n   252→  // Truncate texts for embedding model token limit\\n   253→  const embeddingTexts = validCheckpoints.map((v) =>\\n   254→    v.text.slice(0, MAX_EMBEDDING_CHARS),\\n   255→  );\\n   256→\\n   257→  // Embed all texts in one batch call\\n   258→  const embeddings = await embedTexts(openaiApiKey, embeddingTexts);\\n   259→\\n   260→  // Build upsert payload (row-based format for Turbopuffer v1 API)\\n   261→  const upserts = validCheckpoints.map(({ checkpoint, text }, i) => {\\n   262→    const filesTouchedStr = checkpoint.files_touched?.join(\\\", \\\") ?? null;\\n   263→    return {\\n   264→      id: hashToNumericId(checkpoi