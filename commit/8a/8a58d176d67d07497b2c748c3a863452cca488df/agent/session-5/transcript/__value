;\\n   479→    });\\n   480→\\n   481→    try {\\n   482→      await ns.upsert({\\n   483→        vectors,\\n   484→        distance_metric: \\\"cosine_distance\\\",\\n   485→      });\\n   486→      totalIndexed += texts.length;\\n   487→      console.log(`    Upserted ${texts.length} to Turbopuffer (${totalIndexed} total)`);\\n   488→    } catch (err) {\\n   489→      const msg = err instanceof Error ? err.message : String(err);\\n   490→      console.error(`    Upsert failed for chunk ${chunkNum}: ${msg.slice(0, 200)}`);\\n   491→      console.error(`    Skipping chunk, continuing...`);\\n   492→      totalSkipped += texts.length;\\n   493→    }\\n   494→  }\\n   495→\\n   496→  const elapsed = formatElapsed(Date.now() - start);\\n   497→  console.log(`  Done: ${totalIndexed} indexed, ${totalSkipped} skipped, ${totalTranscripts} transcripts (${elapsed})`);\\n   498→\\n   499→  return { indexed: totalIndexed, skipped: totalSkipped };\\n   500→}\\n   501→\\n   502→// --- Main ---\\n   503→\\n   504→async function main() {\\n   505→  const options = parseArgs();\\n   506→\\n   507→  // Validate env vars\\n   508→  if (!options.dryRun) {\\n   509→    if (!process.env.TURBOPUFFER_API_KEY) {\\n   510→      console.error(\\\"Error: TURBOPUFFER_API_KEY is required (or use --dry-run)\\\");\\n   511→      process.exit(1);\\n   512→    }\\n   513→    if (!process.env.OPENAI_API_KEY) {\\n   514→      console.error(\\\"Error: OPENAI_API_KEY is required (or use --dry-run)\\\");\\n   515→      process.exit(1);\\n   516→    }\\n   517→  }\\n   518→\\n   519→  if (options.withTranscripts && !process.env.GITHUB_TOKEN) {\\n   520→    console.error(\\\"Error: GITHUB_TOKEN is required when using --with-transcripts\\\");\\n   521→    process.exit(1);\\n   522→  }\\n   523→\\n   524→  const db = createDb();\\n   525→\\n   526→  const tpuf = new Turbopuffer({\\n   527→    apiKey: process.env.TURBOPUFFER_API_KEY ?? \\\"\\\",\\n   528→  });\\n   529→\\n   530→  const openai = new OpenAI({