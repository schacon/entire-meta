str: string | null, maxBytes: number): string | null {\\n    26→  if (str === null) return null;\\n    27→  if (str.length <= maxBytes) return str;\\n    28→  const encoder = new TextEncoder();\\n    29→  const encoded = encoder.encode(str);\\n    30→  if (encoded.length <= maxBytes) return str;\\n    31→  const truncated = encoded.slice(0, maxBytes);\\n    32→  const decoder = new TextDecoder();\\n    33→  return decoder.decode(truncated);\\n    34→}\\n    35→\\n    36→function buildSearchText(checkpoint: {\\n    37→  prompt: string | null;\\n    38→  commit_message: string | null;\\n    39→  files_touched: string[] | null;\\n    40→}): string {\\n    41→  const parts: string[] = [];\\n    42→  if (checkpoint.prompt) {\\n    43→    parts.push(`Prompt: ${checkpoint.prompt}`);\\n    44→  }\\n    45→  if (checkpoint.commit_message) {\\n    46→    parts.push(`Commit: ${checkpoint.commit_message}`);\\n    47→  }\\n    48→  if (checkpoint.files_touched) {\\n    49→    parts.push(`Files: ${checkpoint.files_touched.join(\\\", \\\")}`);\\n    50→  }\\n    51→  return parts.join(\\\"\\\\n\\\");\\n    52→}\\n    53→\\n    54→// Hash checkpoint_id to a deterministic numeric ID for Turbopuffer\\n    55→// Uses FNV-1a 32-bit hash for fast, well-distributed IDs\\n    56→function hashToNumericId(checkpointId: string): number {\\n    57→  let hash = 0x811c9dc5; // FNV offset basis\\n    58→  for (let i = 0; i < checkpointId.length; i++) {\\n    59→    hash ^= checkpointId.charCodeAt(i);\\n    60→    hash = Math.imul(hash, 0x01000193); // FNV prime\\n    61→  }\\n    62→  return hash >>> 0; // unsigned 32-bit\\n    63→}\\n    64→\\n    65→async function embedTexts(\\n    66→  openaiApiKey: string,\\n    67→  texts: string[],\\n    68→): Promise<number[][]> {\\n    69→  const resp = await fetch(\\\"https://api.openai.com/v1/embeddings\\\", {\\n    70→    method: \\\"POST\\\",\\n    71→    headers: {\\n    72→      Authorization: `Bearer ${openaiApiKey}`,\\n    73→      \\\"Content-Ty