 return parts.join(\\\"\\\\n\\\");\\n}\\n\\n// Hash checkpoint_id to a deterministic numeric ID for Turbopuffer\\n// Uses FNV-1a 32-bit hash for fast, well-distributed IDs\\nfunction hashToNumericId(checkpointId: string): number {\\n  let hash = 0x811c9dc5; // FNV offset basis\\n  for (let i = 0; i < checkpointId.length; i++) {\\n    hash ^= checkpointId.charCodeAt(i);\\n    hash = Math.imul(hash, 0x01000193); // FNV prime\\n  }\\n  return hash >>> 0; // unsigned 32-bit\\n}\\n\\nasync function embedTexts(\\n  openaiApiKey: string,\\n  texts: string[],\\n): Promise<number[][]> {\\n  const resp = await fetch(\\\"https://api.openai.com/v1/embeddings\\\", {\\n    method: \\\"POST\\\",\\n    headers: {\\n      Authorization: `Bearer ${openaiApiKey}`,\\n      \\\"Content-Type\\\": \\\"application/json\\\",\\n    },\\n    body: JSON.stringify({\\n      model: EMBEDDING_MODEL,\\n      input: texts,\\n      dimensions: EMBEDDING_DIMENSIONS,\\n    }),\\n  });\\n\\n  if (!resp.ok) {\\n    const err = await resp.text().catch(() => \\\"\\\");\\n    throw new Error(`OpenAI embedding failed (${resp.status}): ${err}`);\\n  }\\n\\n  const result = (await resp.json()) as {\\n    data: Array<{ index: number; embedding: number[] }>;\\n  };\\n  return result.data\\n    .sort((a, b) => a.index - b.index)\\n    .map((item) => item.embedding);\\n}\\n\\nasync function embedQuery(openaiApiKey: string, text: string): Promise<number[]> {\\n  const resp = await fetch(\\\"https://api.openai.com/v1/embeddings\\\", {\\n    method: \\\"POST\\\",\\n    headers: {\\n      Authorization: `Bearer ${openaiApiKey}`,\\n      \\\"Content-Type\\\": \\\"application/json\\\",\\n    },\\n    body: JSON.stringify({\\n      model: EMBEDDING_MODEL,\\n      input: text,\\n      dimensions: EMBEDDING_DIMENSIONS,\\n    }),\\n  });\\n\\n  if (!resp.ok) {\\n    const err = await resp.text().catch(() => \\\"\\\");\\n    throw new Error(`OpenAI embedding failed (${resp.status}): ${err}`);\\n  }\\n\\n  const result = (await resp.json()) as { data: Array<{ embedding: number[] }> };\\n  return result.data[0].embedding;\\n}\\n\\n// RRF constant — standard value that prevents top-ranked items from dominating\\nconst RRF_K = 60;\\n\\nexport async function searchCheckpoints(\\n  turbopufferApiKey: string,\\n  openaiApiKey: string,\\n  repoId: string,\\n  query: string,\\n  filters?: { branch?: string },\\n  limit: number = 50,\\n): Promise<TurbopufferSearchResult[]> {\\n  // TODO: use repoId dynamically once backfill runs per-environment\\n  const namespace = `checkpoints-5be1c302-97d2-4cf4-8436-b001efe227e0`;\\n\\n  const headers = {\\n    Authorization: `Bearer ${turbopufferApiKey}`,\\n    \\\"Content-Type\\\": \\\"application/json\\\",\\n  };\\n\\n  const branchFilters = filters?.branch\\n    ? { branch: [[\\\"Eq\\\", filters.branch]] }\\n    : undefined;\\n\\n  // Fire vector + BM25 queries in parallel\\n  const [vectorResults, bm25Results] = await Promise.all([\\n    // Vector cosine similarity (v1 API)\\n    (async (): Promise<TurbopufferQueryRow[]> => {\\n      const vector = await embedQuery(openaiApiKey, query);\\n      const url = `https://api.turbopuffer.com/v1/vectors/${encodeURIComponent(namespace)}/query`;\\n      const body: Record<string, unknown> = {\\n        vector,\\n        top_k: limit,\\n        distance_metric: \\\"cosine_distance\\\",\\n        include_attributes: [\\\"checkpoint_id\\\"],\\n      };\\n      if (branchFilters) body.filters = branchFilters;\\n\\n      const resp = await fetch(url, {\\n        method: \\\"POST\\\",\\n        headers,\\n        body: JSON.stringify(body),\\n      });\\n      if (!resp.ok) {\\n        const text = await resp.text().catch(() => \\\"\\\");\\n        throw new Error(`Turbopuffer vector query failed (${resp.status}): ${text}`);\\n      }\\n      return (await resp.json()) as TurbopufferQueryResponse;\\n    })(),\\n\\n    // BM25 full-text search (v2 API)\\n    (async (): Promise<TurbopufferQueryRow[]> => {\\n      const url = `https://api.turbopuffer.com/v2/namespaces/${encodeURIComponent(namespace)}/query`;\\n      const body: Record<string, unknown> = {\\n        rank_by: [\\\"text\\\", \\\"BM25\\\", query],\\n        top_k: limit,\\n        include_attributes: [\\\"checkpoint_id\\\"],\\n      };\\n      if (branchFilters) body.filters = branchFilters;\\n\\n      const resp = await fetch(url, {\\n        method: \\\"POST\\\",\\n        headers,\\n        body: JSON.stringify(body),\\n      });\\n      if (!resp.ok) {\\n        const text = await resp.text().catch(() => \\\"\\\");\\n        throw new Error(`Turbopuffer BM25 query failed (${resp.status}): ${text}`);\\n      }\\n      return (await resp.json()) as TurbopufferQueryResponse;\\n    })(),\\n  ]);\\n\\n  // Merge via Reciprocal Rank Fusion (RRF)\\n  // score(doc) = 1/(k + rank_vector) + 1/(k + rank_bm25)\\n  const scores = new Map<string, number>();\\n\\n  for (let rank = 0; rank < vectorResults.length; rank++) {\\n    const id = vectorResults[rank].attributes?.checkpoint_id;\\n    if (id) {\\n      scores.set(id, (scores.get(id) ?? 0) + 1 / (RRF_K + rank + 1));\\n    }\\n  }\\n\\n  for (let rank = 0; rank < bm25Results.length; rank++) {\\n    const id = bm25Results[rank].attributes?.checkpoint_id;\\n    if (id) {\\n      scores.set(id, (scores.get(id) ?? 0) + 1 / (RRF_K + rank + 1));\\n    }\\n  }\\n\\n  // Sort by RRF score descending, take top `limit`\\n  const sorted = [...scores.entries()]\\n    .sort((a, b) => b[1] - a[1])\\n    .slice(0, limit);\\n\\n  return sorted.map(([checkpoint_id]) => ({ checkpoint_id }));\\n}\\n\\n// Index checkpoints into Turbopuffer for vector search\\n// Builds search text, embeds via OpenAI, and upserts to Turbopuffer\\n// Returns the number of successfully indexed checkpoints\\nexport async function indexCheckpoints(\\n  turbopufferApiKey: string,\\n  openaiApiKey: string,\\n  repoId: string,\\n  checkpoints: Array<{\\n    checkpoint_id: string;\\n    branch: string | null;\\n    agent: string | null;\\n    commit_author_username: string | null;\\n    created_at: string | null;\\n    commit_sha: string | null;\\n    commit_message: string | null;\\n    prompt: string | null;\\n    files_touched: string[] | null;\\n  }>,\\n): Promise<number> {\\n  // Build search text and filter out empty entries\\n  const validCheckpoints: Array<{\\n    checkpoint: (typeof checkpoints)[number];\\n    text: string;\\n  }> = [];\\n\\n  for (const cp of checkpoints) {\\n    const text = buildSearchText(cp);\\n    if (text.trim()) {\\n      validCheckpoints.push({ checkpoint: cp, text });\\n    }\\n  }\\n\\n  if (validCheckpoints.length === 0) {\\n    return 0;\\n  }\\n\\n  // Truncate texts for embedding model token limit\\n  const embeddingTexts = validCheckpoints.map((v) =>\\n    v.text.slice(0, MAX_EMBEDDING_CHARS),\\n  );\\n\\n  // Embed all texts in one batch call\\n  const embeddings = await embedTexts(openaiApiKey, embeddingTexts);\\n\\n  // Build upsert payload (row-based format for Turbopuffer v1 API)\\n  const upserts = validCheckpoints.map(({ checkpoint, text }, i) => {\\n    const filesTouchedStr = checkpoint.files_touched?.join(\\\", \\\") ?? null;\\n    return {\\n      id: hashToNumericId(checkpoint.checkpoint_id),\\n      vector: embeddings[i],\\n      attributes: {\\n        checkpoint_id: checkpoint.checkpoint_id,\\n        branch: checkpoint.branch,\\n        agent: checkpoint.agent,\\n        author: checkpoint.commit_author_username,\\n        created_at: checkpoint.created_at,\\n        commit_sha: checkpoint.commit_sha,\\n        commit_message: truncateToBytes(\\n          checkpoint.commit_message,\\n          MAX_ATTRIBUTE_BYTES,\\n        ),\\n        prompt: truncateToBytes(checkpoint.prompt, MAX_ATTRIBUTE_BYTES),\\n        files_touched: truncateToBytes(filesTouchedStr, MAX_ATTRIBUTE_BYTES),\\n        text: truncateToBytes(text, MAX_ATTRIBUTE_BYTES),\\n      },\\n    };\\n  });\\n\\n  // Upsert to Turbopuffer\\n  const namespace = `checkp