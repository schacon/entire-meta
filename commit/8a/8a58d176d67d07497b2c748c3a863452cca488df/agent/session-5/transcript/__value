mit = parseInt(args[++i], 10);\\n    43→        break;\\n    44→      case \\\"--dry-run\\\":\\n    45→        options.dryRun = true;\\n    46→        break;\\n    47→      default:\\n    48→        console.error(`Unknown option: ${args[i]}`);\\n    49→        process.exit(1);\\n    50→    }\\n    51→  }\\n    52→  return options;\\n    53→}\\n    54→\\n    55→// --- Database ---\\n    56→\\n    57→function createDb(): Kysely<DB> {\\n    58→  const url =\\n    59→    process.env.DATABASE_URL ?? \\\"mysql://entire:entire@localhost:3306/entire\\\";\\n    60→  const parsed = new URL(url);\\n    61→  return new Kysely<DB>({\\n    62→    dialect: new MysqlDialect({\\n    63→      pool: createPool({\\n    64→        host: parsed.hostname,\\n    65→        port: Number(parsed.port) || 3306,\\n    66→        user: decodeURIComponent(parsed.username),\\n    67→        password: decodeURIComponent(parsed.password),\\n    68→        database: parsed.pathname.replace(\\\"/\\\", \\\"\\\"),\\n    69→      }),\\n    70→    }),\\n    71→  });\\n    72→}\\n    73→\\n    74→// --- Helpers (mirroring turbopuffer.ts) ---\\n    75→\\n    76→function truncateToBytes(str: string | null, maxBytes: number): string | null {\\n    77→  if (str === null) return null;\\n    78→  if (str.length <= maxBytes) return str;\\n    79→  const encoder = new TextEncoder();\\n    80→  const encoded = encoder.encode(str);\\n    81→  if (encoded.length <= maxBytes) return str;\\n    82→  const truncated = encoded.slice(0, maxBytes);\\n    83→  return new TextDecoder().decode(truncated);\\n    84→}\\n    85→\\n    86→function buildSearchText(checkpoint: {\\n    87→  prompt: string | null;\\n    88→  commit_message: string | null;\\n    89→  files_touched_str: string | null;\\n    90→}): string {\\n    91→  const parts: string[] = [];\\n    92→  if (checkpoint.prompt) parts.push(`Prompt: ${checkpoint.prompt}`);\\n    93→  if (checkpoint.commit_message)\\n    94→    parts.push(`Commit: ${checkpoint.commit_message}`);\\n    95→  if (checkpoint.files_touched_str)\\n    96→    parts.push(`Files: ${checkpoint.files_touched_str}`);\\n    97→  return parts.join(\\\"\\\\n\\\");\\n    98→}\\n    99→\\n   100→function hashToNumericId(checkpointId: string): number {\\n   101→  let hash = 0x811c9dc5;\\n   102→  for (let i = 0; i < checkpointId.length; i++) {\\n   103→    hash ^= checkpointId.charCodeAt(i);\\n   104→    hash = Math.imul(hash, 0x01000193);\\n   105→  }\\n   106→  return hash >>> 0;\\n   107→}\\n   108→\\n   109→// --- Main ---\\n   110→\\n   111→async function main() {\\n   112→  const options = parseArgs();\\n   113→  const turbopufferApiKey = process.env.TURBOPUFFER_API_KEY;\\n   114→  const openaiApiKey = process.env.OPENAI_API_KEY;\\n   115→\\n   116→  if (!options.dryRun) {\\n   117→    if (!turbopufferApiKey) {\\n   118→      console.error(\\\"TURBOPUFFER_API_KEY is required (or use --dry-run)\\\");\\n   119→      process.exit(1);\\n   120→    }\\n   121→    if (!openaiApiKey) {\\n   122→      console.error(\\\"OPENAI_API_KEY is required (or use --dry-run)\\\");\\n   123→      process.exit(1);\\n   124→    }\\n   125→  }\\n   126→\\n   127→  console.log(\\\"=== Search Index Test ===\\\");\\n   128→  console.log(`  dry-run: ${options.dryRun}`);\\n   129→  console.log(`  limit:   ${options.limit}`);\\n   130→  if (options.repo) console.log(`  repo:    ${options.repo}`);\\n   131→  console.log();\\n   132→\\n   133→  // Step 1: Fetch checkpoints from DB\\n   134→  const db = createDb();\\n   135→\\n   136→  let repoQuery = db\\n   137→    .selectFrom(\\\"repos\\\")\\n   138→    .select([\\\"id\\\", \\\"full_name\\\", \\\"checkpoint_count\\\"])\\n   139→    .where(\\\"checkpoint_count\\\", \\\">\\\", 0);\\n   140→\\n   141→  if (options.repo) {\\n   142→    repoQuery = repoQuery.where(\\\"full_name\\\", \\\"=\\\", options.repo);\\n   143→  }\\n   144→\\n   145→  const repos = await repoQuery.limit(1).execute();\\n   146→\\n   147→  if (repos.length === 0) {\\n   14