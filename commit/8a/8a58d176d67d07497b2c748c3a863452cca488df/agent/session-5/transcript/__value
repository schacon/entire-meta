h transcripts + embed + upsert per chunk)\\nconst CHECKPOINT_BRANCH = \\\"entire/checkpoints/v1\\\";\\nconst GITHUB_API = \\\"https://api.github.com\\\";\\nconst TRANSCRIPT_DELAY_MS = 100; // delay between GitHub API calls to avoid rate limiting\\nconst MAX_TRANSCRIPT_CHARS = 2000;\\nconst MAX_ATTRIBUTE_BYTES = 3800; // Turbopuffer limit is 4096, leave headroom\\nconst MAX_EMBEDDING_CHARS = 25000; // ~8K tokens, text-embedding-3-small limit is 8192 tokens\\nconst MAX_RETRIES = 3;\\nconst RETRY_BASE_DELAY_MS = 1000;\\n\\n// --- CLI Argument Parsing ---\\n\\ninterface CliOptions {\\n  repo: string | null;\\n  withTranscripts: boolean;\\n  dryRun: boolean;\\n  limit: number | null;\\n}\\n\\nfunction parseArgs(): CliOptions {\\n  const args = process.argv.slice(2);\\n  const options: CliOptions = {\\n    repo: null,\\n    withTranscripts: false,\\n    dryRun: false,\\n    limit: null,\\n  };\\n\\n  for (let i = 0; i < args.length; i++) {\\n    switch (args[i]) {\\n      case \\\"--repo\\\":\\n        options.repo = args[++i];\\n        if (!options.repo) {\\n          console.error(\\\"Error: --repo requires a value (e.g., 'entireio/cli')\\\");\\n          process.exit(1);\\n        }\\n        break;\\n      case \\\"--with-transcripts\\\":\\n        options.withTranscripts = true;\\n        break;\\n      case \\\"--dry-run\\\":\\n        options.dryRun = true;\\n        break;\\n      case \\\"--limit\\\":\\n        options.limit = parseInt(args[++i], 10);\\n        if (isNaN(options.limit) || options.limit <= 0) {\\n          console.error(\\\"Error: --limit requires a positive integer\\\");\\n          process.exit(1);\\n        }\\n        break;\\n      default:\\n        console.error(`Unknown option: ${args[i]}`);\\n        console.error(\\\"Usage: npx tsx scripts/backfill-search.ts [--repo <name>] [--with-transcripts] [--dry-run] [--limit <n>]\\\");\\n        process.exit(1);\\n    }\\n  }\\n\\n  return options;\\n}\\n\\n// --- Database Setup ---\\n\\nfunction createDb(): Kysely<DB> {\\n  const url = process.env.DATABASE_URL ?? \\\"mysql://entire:entire@localhost:3306/entire\\\";\\n  const parsed = new URL(url);\\n  const isLocalhost = parsed.hostname === \\\"localhost\\\" || parsed.hostname === \\\"127.0.0.1\\\";\\n\\n  return new Kysely<DB>({\\n    dialect: new MysqlDialect({\\n      pool: createPool({\\n        host: parsed.hostname,\\n        port: Number(parsed.port) || 3306,\\n        user: decodeURIComponent(parsed.username),\\n        password: decodeURIComponent(parsed.password),\\n        database: parsed.pathname.replace(\\\"/\\\", \\\"\\\"),\\n        ssl: isLocalhost ? undefined : { rejectUnauthorized: true },\\n      }),\\n    }),\\n  });\\n}\\n\\n// --- Text Construction ---\\n\\nfunction buildSearchText(\\n  checkpoint: CheckpointRow,\\n  transcriptExcerpt?: string,\\n): string {\\n  const parts: string[] = [];\\n\\n  if (checkpoint.prompt) {\\n    parts.push(`Prompt: ${checkpoint.prompt}`);\\n  }\\n  if (checkpoint.commit_message) {\\n    parts.push(`Commit: ${checkpoint.commit_message}`);\\n  }\\n  if (checkpoint.files_touched_str) {\\n    parts.push(`Files: ${checkpoint.files_touched_str}`);\\n  }\\n  if (transcriptExcerpt) {\\n    parts.push(`Transcript: ${transcriptExcerpt}`);\\n  }\\n\\n  return parts.join(\\\"\\\\n\\\");\\n}\\n\\n// --- Embedding Generation ---\\n\\nasync function generateEmbeddings(\\n  openai: OpenAI,\\n  texts: string[],\\n): Promise<number[][]> {\\n  const response = await openai.embeddings.create({\\n    model: EMBEDDING_MODEL,\\n    input: texts,\\n    dimensions: EMBEDDING_DIMENSIONS,\\n  });\\n\\n  // Sort by index to maintain order\\n  return response.data\\n    .sort((a, b) => a.index - b.index)\\n    .map((item) => item.embedding);\\n}\\n\\n// --- Attribute Truncation ---\\n\\nfunction truncateToBytes(str: string | null, maxBytes: number): string | null {\\n  if (str === null) return null;\\n  // Fast path: ASCII strings where 1 char = 1 byte\\n  if (str.length <= maxBytes) return str;\\n  // Truncate by encoding to bytes\\n  const encoder = new TextEncoder();\\n  const encoded = encoder.encode(str);\\n  if (encoded.length <= maxBytes) return str;\\n  // Find the last valid UTF-8 boundary within maxBytes\\n  const truncated = encoded.slice(0, maxBytes);\\n  const decoder = new TextDecoder(\\\"utf-8\\\", { fatal: false });\\n  return decoder.decode(truncated);\\n}\\n\\n// --- Fetch with Retry ---\\n\\nasync function fetchWithRetry(\\n  url: string,\\n  options: RequestInit,\\n): Promise<Response> {\\n  for (let attempt = 0; attempt < MAX_RETRIES; attempt++) {\\n    try {\\n      const response = await fetch(url, options);\\n      // Retry on transient server errors and rate limits\\n      if (response.status >= 500 || response.status === 429) {\\n        if (attempt < MAX_RETRIES - 1) {\\n          const delay = RETRY_BASE_DELAY_MS * Math.pow(2, attempt);\\n          await sleep(delay);\\n          continue;\\n        }\\n      }\\n      return response;\\n    } catch (err) {\\n      if (attempt < MAX_RETRIES - 1) {\\n        const delay = RETRY_BASE_DELAY_MS * Math.pow(2, attempt);\\n        await sleep(delay);\\n        continue;\\n      }\\n      throw err;\\n    }\\n  }\\n  throw new Error(\\\"fetchWithRetry: exhausted retries\\\");\\n}\\n\\n// --- Transcript Fetching ---\\n\\nasync function fetchTranscriptExcerpt(\\n  repoFullName: string,\\n  checkpointId: string,\\n  agent: string,\\n  token: string,\\n): Promise<string | null> {\\n  const folder = `${checkpointId.slice(0, 2)}/${checkpointId.slice(2)}`;\\n  const path = `${folder}/0/full.jsonl`;\\n\\n  // Encode each path segment individually (preserves / separators)\\n  const encodedPath = path.split(\\\"/\\\").map(encodeURIComponent).join(\\\"/\\\");\\n  const url = `${GITHUB_API}/repos/${repoFullName}/contents/${encodedPath}?ref=${CHECKPOINT_BRANCH}`;\\n\\n  try {\\n    const response = await fetchWithRetry(url, {\\n      headers: {\\n        Accept: \\\"application/vnd.github.raw+json\\\",\\n        Authorization: `Bearer ${token}`,\\n        \\\"User-Agent\\\": \\\"entire-backfill\\\",\\n        \\\"X-GitHub-Api-Version\\\": \\\"2022-11-28\\\",\\n      },\\n    });\\n\\n    if (!response.ok) {\\n      if (response.status === 404) {\\n        return null;\\n      }\\n      return null;\\n    }\\n\\n    const content = await response.text();\\n\\n    const parser = getParserForAgent(agent);\\n    const result = parser.parse(content);\\n\\n    if (result.messages.length === 0) {\\n      return null;\\n    }\\n\\n    // Extract first user message + first assistant message\\n    const parts: string[] = [];\\n    let charsUsed = 0;\\n\\n    for (const msg of result.messages) {\\n      if (charsUsed >= MAX_TRANSCRIPT_CHARS) break;\\n\\n      const remaining = MAX_TRANSCRIPT_CHARS - charsUsed;\\n      const text = msg.content.slice(0, remaining);\\n      parts.push(`[${msg.role}]: ${text}`);\\n      charsUsed += text.length;\\n\\n      // Only take the first user + first assistant\\n      if (msg.role === \\\"assistant\\\") break;\\n    }\\n\\n    return parts.join(\\\"\\\\n\\\") || null;\\n  } catch {\\n    return null;\\n  }\\n}\\n\\nfunction sleep(ms: number): Promise<void> {\\n  return new Promise((resolve) => setTimeout(resolve, ms));\\n}\\n\\n// --- Types ---\\n\\ninterface CheckpointRow {\\n  checkpoint_id: string;\\n  branch: string;\\n  agent: string;\\n  commit_author_username: string | null;\\n  created_at: string | null;\\n  commit_sha: string | null;\\n  commit_message: string | null;\\n  prompt: string | null;\\n  files_touched_str: string | null;\\n}\\n\\ninterface RepoRow {\\n  id: string;\\n  full_name: string;\\n  checkpoint_count: number;\\n}\\n\\n// --- Per-Repo Processing ---\\n\\nasync function fetchCheckpointsForRepo(\\n  db: Kysely<DB>,\\n  repoId: string,\\n  limit: number | null,\\n): Promise<CheckpointRow[]> {\\n  // Use the same deferred-join pattern as getCheckpointsForBranch\\n  let idQuery = db\\n    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n    .select(\\\"id\\\")\\n    .where(\\\"repo_id\\\", \\\"=\\\", repoId)\\n    .orderBy(\\\"commit_date\\\", \\\"desc\\\");\\n\\n  if (limit) {\\n    idQuery = idQuery.limit(limit);\\n  }\\n\\n  const idRows = await idQuery.execute();\\n  if (idRows.length === 0) return [];\\n\\n  const rows = await db\\n    .selectFrom(\\\"repo_checkpoint_commits as cc\\\")\\n    .leftJoin(\\\"repo_checkpoints as cp\\\", (join) =>\\n      join\\n        .onRef(\\\"cp.repo_id\\\", \\\"=\\\", \\\"cc.repo_id\\\")\\n        .onRef(\\\"cp.checkpoint_id\\\", \\\"=\\\", \\\"cc.checkpoint_id\\\"),\\n    )\\n    .select([\\n      \\\"cc.checkpoint_id\\\",\\n      \\\"cc.branch\\\",\\n      \\\"cc.commit_sha\\\",\\n      \\\"cc.commit_message\\\",\\n      \\\"cc.commit_author_username\\\",\\n      \\\"cc.commit_date\\\",\\n      \\\"cp.prompt\\\",\\n      \\\"cp.agent\\\",\\n      \\\"cp.created_at\\\",\\n      \\\"cp.files_touched\\\",\\n    ])\\n    .where(\\n      \\\"cc.id\\\",\\n      \\\"in\\\",\\n      idRows.map((r) => r.id),\\n    )\\n    .execute();\\n\\n  return rows.map((row) => {\\n    const filesTouched = row.files_touched as string[] | null;\\n    return {\\n      checkpoint_id: row.checkpoint_id,\\n      branch: row.branch,\\n      agent: row.agent ?? \\\"Claude Code\\\",\\n      commit_author_username: row.commit_author_username,\\n      created_at: row.created_at?.toISOString() ?? row.commit_date?.toISOString() ?? null,\\n      commit_sha: row.commit_sha,\\n      commit_message: row.commit_message,\\n      prompt: row.prompt,\\n      files_touched_str: filesTouched?.join(\\\", \\\") ?? null,\\n    };\\n  });\\n}\\n\\nfunction formatElapsed(ms: number): string {\\n  const s = Math.floor(ms / 1000);\\n  if (s < 60) return `${s}s`;\\n  const m = Math.floor(s / 60);\\n  return `${m}m${s % 60}s`;\\n}\\n\\nasync function processRepo(\\n  db: Kysely<DB>,\\n  tpuf: Turbopuffer,\\n  openai: OpenAI,\\n  repo: RepoRow,\\n  options: CliOptions,\\n): Promise<{ indexed: number; skipped: number }> {\\n  const start = Date.now();\\n  const total = repo.checkpoint_count;\\n  console.log(`\\\\n--- ${repo.full_name} (${total} checkpoints) ---`);\\n\\n  const checkpoints = await fetchCheckpointsForRepo(db, repo.id, options.limit);\\n  if (checkpoints.length === 0) {\\n    console.log(`  No checkpoint commits found, skipping.`);\\n    return { indexed: 0, skipped: 0 };\\n  }\\n\\n  console.log(`  Fetched ${checkpoints.length} checkpoint rows from DB.`);\\n\\n  const githubToken = process.env.GITHUB_TOKEN;\\n  const ns = tpuf.namespace(`checkpoints-${repo.id}`);\\n  let totalIndexed = 0;\\n  let totalSkipped = 0;\\n  let totalTranscripts = 0;\\n\\n  // Process in chunks: for each chunk, fetch transcripts -> build text -> embed -> upsert\\n  const numChunks = Math.ceil(checkpoints.length / CHUNK_SIZE);\\n\\n  for (let chunkIdx = 0; chunkIdx < numChunks; chunkIdx++) {\\n    const chunkStart = chunkIdx * CHUNK_SIZE;\\n    const chunkEnd = Math.min(chunkStart + CHUNK_SIZE, checkpoints.length);\\n    const chunk = checkpoints.slice(chunkStart, chunkEnd);\\n    const chunkNum = chunkIdx + 1;\\n    const elapsed = formatElapsed(Date.now() - start);\\n\\n    console.log(`  [${chunkNum}/${numChunks}] Processing checkpoints ${chunkStart + 1}-${chunkEnd} of ${checkpoints.length} (${elapsed})`);\\n\\n    // 1. Fetch transcripts for this chunk\\n    const transcripts: (string | undefined)[] = [];\\n    if (options.withTranscripts && githubToken) {\\n      let fetched = 0;\\n      let found = 0;\\n      for (const cp of chunk) {\\n        const excerpt = await fetchTranscriptExcerpt(repo.full_name, cp.checkpoint_id, cp.agent, githubToken);\\n        transcripts.push(excerpt ?? undefined);\\n        fetched++;\\n        if (excerpt) found++;\\n        if (fetched < chunk.length) {\\n          await sleep(TRANSCRIPT_DELAY_MS);\\n        }\\n      }\\n      totalTranscripts += found;\\n      console.log(`    Transcripts: ${found}/${chunk.length} found`);\\n    } else {\\n      chunk.forEach(() => transcripts.push(undefined));\\n    }\\n\\n    // 2. Build search text for each checkpoint\\n    const texts: string[] = [];\\n    const validIndices: number[] = []; // indices within this chunk that have non-empty text\\n    let chunkSkipped = 0;\\n\\n    for (let i = 0; i < chunk.length; i++) {\\n      const text = buildSearchText(chunk[i], transcripts[i]);\\n      if (!text.trim()) {\\n        chunkSkipped++;\\n        continue;\\n      }\\n      texts.push(text);\\n      validIndices.push(i);\\n    }\\n\\n    totalSkipped += chunkSkipped;\\n\\n    if (texts.length === 0) {\\n      console.log(`    All empty, skipped.`);\\n      continue;\\n    }\\n\\n    if (options.dryRun) {\\n      console.log(`    [DRY RUN] Would index ${texts.length} (${chunkSkipped} skipped)`);\\n      totalIndexed += texts.length;\\n      continue;\\n    }\\n\\n    // 3. Truncate texts to stay under embedding model token limit\\n    const embeddingTexts = texts.map((t) => t.slice(0, MAX_EMBEDDING_CHARS));\\n\\n    // 4. Generate embeddings\\n    let embeddings: number[][];\\n    try {\\n      embeddings = await generateEmbeddings(openai, embeddingTexts);\\n    } catch (err) {\\n      const msg = err instanceof Error ? err.message : String(err);\\n      console.error(`    Embedding failed for chunk ${chunkNum}: ${msg.slice(0, 200)}`);\\n      console.error(`    Skipping chunk, continuing...`);\\n      totalSkipped += texts.length;\\n      continue;\\n    }\\n    console.log(`    Embedded ${texts.length} checkpoints`);\\n\\n    // 5. Upsert to Turbopuffer\\n    const vectors: Vector[] = validIndices.map((localIdx, j) => {\\n      const cp = chunk[localIdx];\\n      const globalId = chunkStart + localIdx + 1; // unique ID across all chunks\\n      return {\\n        id: globalId,\\n        vector: embeddings[j],\\n        attributes: {\\n          checkpoint_id: cp.checkpoint_id,\\n          branch: cp.branch,\\n          agent: cp.agent,\\n          author: cp.commit_author_username,\\n          created_at: cp.created_at,\\n          commit_sha: cp.commit_sha,\\n          commit_message: truncateToBytes(cp.commit_message, MAX_ATTRIBUTE_BYTES),\\n          prompt: truncateToBytes(cp.prompt, MAX_ATTRIBUTE_BYTES),\\n          files_touched: truncateToBytes(cp.files_touched_str, MAX_ATTRIBUTE_BYTES),\\n          text: truncateToBytes(texts[j], MAX_ATTRIBUTE_BYTES),\\n        },\\n      };\\n    });\\n\\n    try {\\n      await ns.upsert({\\n        vectors,\\n        distance_metric: \\\"cosine_distance\\\",\\n      });\\n      totalIndexed += texts.length;\\n      console.log(`    Upserted ${texts.length} to Turbopuffer (${totalIndexed} total)`);\\n    } catch (err) {\\n      const msg = err instanceof Error ? err.message : String(err);\\n      console.error(`    Upsert failed for chunk ${chunkNum}: ${msg.slice(0, 200)}`);\\n      console.error(`    Skipping chunk, continuing...`);\\n      totalSkipped += texts.length;\\n    }\\n  }\\n\\n  const elapsed = formatElapsed(Date.now() - start);\\n  console.log(`  Done: ${totalIndexed} indexed, ${totalSkipped} skipped, ${totalTranscripts} transcripts (${elapsed})`);\\n\\n  return { indexed: totalIndexed, skipped: totalSkipped };\\n}\\n\\n// --- Main ---\\n\\nasync function main() {\\n  const options = parseArgs();\\n\\n  // Validate env vars\\n  if (!options.dryRun) {\\n    if (!process.env.TURBOPUFFER_API_KEY) {\\n      console.error(\\\"Error: TURBOPUFFER_API_KEY is required (or use --dry-run)\\\");\\n      process.exit(1);\\n    }\\n    if (!process.env.OPENAI_API_KEY) {\\n      console.error(\\\"Error: OPENAI_API_KEY is required (or use --dry-run)\\\");\\n      process.exit(1);\\n    }\\n  }\\n\\n  if (options.withTranscripts && !process.env.GITHUB_TOKEN) {\\n    console.error(\\\"Error: GITHUB_TOKEN is required when using --with-transcripts\\\");\\n    process.exit(1);\\n  }\\n\\n  const db = createDb();\\n\\n  const tpuf = new Turbopuffer({\\n    apiKey: process.env.TURBOPUFFER_API_KEY ?? \\\"\\\",\\n  });\\n\\n  const openai = new OpenAI({\\n    apiKey: process.env.OPENAI_API_KEY ?? \\\"\\\",\\n  });\\n\\n  console.log(\\\"Backfill Search Index\\\");\\n  console.log(\\\"=====================\\\");\\n  if (options.dryRun) console.log(\\\"[DRY RUN MODE]\\\");\\n  if (options.repo) console.log(`Repo filter: ${options.repo}`);\\n  if (options.limit) console.log(`Limit: ${options.limit} checkpoints per repo`);\\n  if (options.withTranscripts) console.log(\\\"Transcript fetching: enabled\\\");\\n\\n  // Fetch repos with checkpoints\\n  let repoQuery = db\\n    .selectFrom(\\\"repos\\\")\\n    .select([\\\"id\\\", \\\"full_name\\\", \\\"checkpoint_count\\\"])\\n    .where(\\\"checkpoint_count\\\", \\\">\\\", 0);\\n\\n  if (options.repo) {\\n    repoQuery = repoQuery.where(\\\"full_name\\\", \\\"=\\\", options.repo);\\n  }\\n\\n  const repos = (await repoQuery.execute()) as RepoRow[];\\n\\n  if (repos.length === 0) {\\n    console.log(\\\"\\\\nNo repos with checkpoints found.\\\");\\n    await db.destroy();\\n    return;\\n  }\\n\\n  console.log(`\\\\nFound ${repos.length} repo(s) with checkpoints.`);\\n\\n  // Process each repo\\n  let totalIndexed = 0;\\n  let totalSkipped = 0;\\n\\n  for (const repo of repos) {\\n    try {\\n      const result = await processRepo(db, tpuf, openai, repo, options);\\n      totalIndexed += result.indexed;\\n      totalSkipped += result.skipped;\\n    } catch (err) {\\n      console.error(`\\\\nError processing ${repo.full_name}:`, err);\\n      console.error(\\\"Continuing with next repo...\\\");\\n    }\\n  }\\n\\n  // Summary\\n  console.log(\\\"\\\\n=====================\\\");\\n  console.log(\\\"Summary:\\\");\\n  console.log(`  Repos processed: ${repos.length}`);\\n  console.log(`  Checkpoints indexed: ${totalIndexed}`);\\n  console.log(`  Checkpoints skipped: ${totalSkipped}`);\\n\\n  await db.destroy();\\n}\\n\\nmain();\\n\",\"numLines\":587,\"startLine\":1,\"totalLines