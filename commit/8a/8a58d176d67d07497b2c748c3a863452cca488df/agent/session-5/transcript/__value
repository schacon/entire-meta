oint_id: cp.checkpoint_id,\\n   299→      branch: cp.branch,\\n   300→      agent: cp.agent,\\n   301→      author: cp.commit_author_username,\\n   302→      created_at: cp.created_at,\\n   303→      commit_sha: cp.commit_sha,\\n   304→      commit_message: truncateToBytes(cp.commit_message, MAX_ATTRIBUTE_BYTES),\\n   305→      prompt: truncateToBytes(cp.prompt, MAX_ATTRIBUTE_BYTES),\\n   306→      files_touched: truncateToBytes(cp.files_touched_str, MAX_ATTRIBUTE_BYTES),\\n   307→      text: truncateToBytes(text, MAX_ATTRIBUTE_BYTES),\\n   308→    },\\n   309→  }));\\n   310→\\n   311→  const namespace = `checkpoints-${repo.id}`;\\n   312→  const upsertUrl = `https://api.turbopuffer.com/v1/vectors/${encodeURIComponent(namespace)}`;\\n   313→\\n   314→  console.log(`  namespace: ${namespace}`);\\n   315→  console.log(`  url:       ${upsertUrl}`);\\n   316→\\n   317→  const upsertStart = Date.now();\\n   318→  const upsertResp = await fetch(upsertUrl, {\\n   319→    method: \\\"POST\\\",\\n   320→    headers: {\\n   321→      Authorization: `Bearer ${turbopufferApiKey}`,\\n   322→      \\\"Content-Type\\\": \\\"application/json\\\",\\n   323→    },\\n   324→    body: JSON.stringify({\\n   325→      upserts,\\n   326→      distance_metric: \\\"cosine_distance\\\",\\n   327→    }),\\n   328→  });\\n   329→\\n   330→  const upsertMs = Date.now() - upsertStart;\\n   331→\\n   332→  if (!upsertResp.ok) {\\n   333→    const errText = await upsertResp.text().catch(() => \\\"\\\");\\n   334→    console.error(\\n   335→      `  Turbopuffer upsert failed (${upsertResp.status}): ${errText}`,\\n   336→    );\\n   337→    await db.destroy();\\n   338→    process.exit(1);\\n   339→  }\\n   340→\\n   341→  const upsertResult = await upsertResp.json();\\n   342→  console.log(\\n   343→    `  Upserted ${upserts.length} vectors in ${upsertMs}ms`,\\n   344→  );\\n   345→  console.log(`  Response:`, JSON.stringify(upsertResult));\\n   346→\\n   347→  // Verify: query back one of the che