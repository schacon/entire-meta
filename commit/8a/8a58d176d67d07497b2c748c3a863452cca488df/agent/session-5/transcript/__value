rts: string[] = [];\\n  if (checkpoint.prompt) parts.push(`Prompt: ${checkpoint.prompt}`);\\n  if (checkpoint.commit_message)\\n    parts.push(`Commit: ${checkpoint.commit_message}`);\\n  if (checkpoint.files_touched_str)\\n    parts.push(`Files: ${checkpoint.files_touched_str}`);\\n  return parts.join(\\\"\\\\n\\\");\\n}\\n\\nfunction hashToNumericId(checkpointId: string): number {\\n  let hash = 0x811c9dc5;\\n  for (let i = 0; i < checkpointId.length; i++) {\\n    hash ^= checkpointId.charCodeAt(i);\\n    hash = Math.imul(hash, 0x01000193);\\n  }\\n  return hash >>> 0;\\n}\\n\\n// --- Main ---\\n\\nasync function main() {\\n  const options = parseArgs();\\n  const turbopufferApiKey = process.env.TURBOPUFFER_API_KEY;\\n  const openaiApiKey = process.env.OPENAI_API_KEY;\\n\\n  if (!options.dryRun) {\\n    if (!turbopufferApiKey) {\\n      console.error(\\\"TURBOPUFFER_API_KEY is required (or use --dry-run)\\\");\\n      process.exit(1);\\n    }\\n    if (!openaiApiKey) {\\n      console.error(\\\"OPENAI_API_KEY is required (or use --dry-run)\\\");\\n      process.exit(1);\\n    }\\n  }\\n\\n  console.log(\\\"=== Search Index Test ===\\\");\\n  console.log(`  dry-run: ${options.dryRun}`);\\n  console.log(`  limit:   ${options.limit}`);\\n  if (options.repo) console.log(`  repo:    ${options.repo}`);\\n  console.log();\\n\\n  // Step 1: Fetch checkpoints from DB\\n  const db = createDb();\\n\\n  let repoQuery = db\\n    .selectFrom(\\\"repos\\\")\\n    .select([\\\"id\\\", \\\"full_name\\\", \\\"checkpoint_count\\\"])\\n    .where(\\\"checkpoint_count\\\", \\\">\\\", 0);\\n\\n  if (options.repo) {\\n    repoQuery = repoQuery.where(\\\"full_name\\\", \\\"=\\\", options.repo);\\n  }\\n\\n  const repos = await repoQuery.limit(1).execute();\\n\\n  if (repos.length === 0) {\\n    console.log(\\\"No repos with checkpoints found.\\\");\\n    await db.destroy();\\n    return;\\n  }\\n\\n  const repo = repos[0];\\n  console.log(\\n    `[1/8] Repo: ${repo.full_name} (${repo.checkpoint_count} total checkpoints)`,\\n  );\\n\\n  // Step 2: Fetch checkpoint data (simulates db.checkpoints.getByIds)\\n  const idRows = await db\\n    .selectFrom(\\\"repo_checkpoint_commits\\\")\\n    .select(\\\"id\\\")\\n    .where(\\\"repo_id\\\", \\\"=\\\", repo.id)\\n    .orderBy(\\\"commit_date\\\", \\\"desc\\\")\\n    .limit(options.limit)\\n    .execute();\\n\\n  if (idRows.length === 0) {\\n    console.log(\\\"  No checkpoint commits found.\\\");\\n    await db.destroy();\\n    return;\\n  }\\n\\n  const rows = await db\\n    .selectFrom(\\\"repo_checkpoint_commits as cc\\\")\\n    .leftJoin(\\\"repo_checkpoints as cp\\\", (join) =>\\n      join\\n        .onRef(\\\"cp.repo_id\\\", \\\"=\\\", \\\"cc.repo_id\\\")\\n        .onRef(\\\"cp.checkpoint_id\\\", \\\"=\\\", \\\"cc.checkpoint_id\\\"),\\n    )\\n    .select([\\n      \\\"cc.checkpoint_id\\\",\\n      \\\"cc.branch\\\",\\n      \\\"cc.commit_sha\\\",\\n      \\\"cc.commit_message\\\",\\n      \\\"cc.commit_author_username\\\",\\n      \\\"cc.commit_date\\\",\\n      \\\"cp.prompt\\\",\\n      \\\"cp.agent\\\",\\n      \\\"cp.created_at\\\",\\n      \\\"cp.files_touched\\\",\\n    ])\\n    .where(\\n      \\\"cc.id\\\",\\n      \\\"in\\\",\\n      idRows.map((r) => r.id),\\n    )\\n    .execute();\\n\\n  console.log(`[2/8] Fetched ${rows.length} checkpoints from DB\\\\n`);\\n\\n  // Step 3: Build search text\\n  const checkpoints = rows.map((row) => {\\n    const filesTouched = row.files_touched as string[] | null;\\n    return {\\n      checkpoint_id: row.checkpoint_id,\\n      branch: row.branch,\\n      agent: row.agent ?? \\\"Claude Code\\\",\\n      commit_author_username: row.commit_author_username,\\n      created_at:\\n        row.created_at?.toISOString() ??\\n        row.commit_date?.toISOString() ??\\n        null,\\n      commit_sha: row.commit_sha,\\n      commit_message: row.commit_message,\\n      prompt: row.prompt,\\n      files_touched_str: filesTouched?.join(\\\", \\\") ?? null,\\n