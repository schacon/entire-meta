\tctx      context.Context\\n    22→\\tended    bool\\n    23→\\terr      error\\n    24→}\\n    25→\\n    26→// Start begins a new span. If ctx already has a span, the new one becomes a child.\\n    27→// Returns the updated context and the span. Call span.End() when the operation completes.\\n    28→func Start(ctx context.Context, name string, attrs ...slog.Attr) (context.Context, *Span) {\\n    29→\\tparent := spanFromContext(ctx)\\n    30→\\ts := &Span{\\n    31→\\t\\tname:   name,\\n    32→\\t\\tstart:  time.Now(),\\n    33→\\t\\tparent: parent,\\n    34→\\t\\tattrs:  attrs,\\n    35→\\t\\tctx:    ctx,\\n    36→\\t}\\n    37→\\tif parent != nil {\\n    38→\\t\\tparent.children = append(parent.children, s)\\n    39→\\t}\\n    40→\\treturn contextWithSpan(ctx, s), s\\n    41→}\\n    42→\\n    43→// RecordError marks the span as errored. Only the first non-nil error is stored;\\n    44→// subsequent calls are no-ops. Call this before End() on error paths.\\n    45→func (s *Span) RecordError(err error) {\\n    46→\\tif err == nil || s.err != nil {\\n    47→\\t\\treturn\\n    48→\\t}\\n    49→\\ts.err = err\\n    50→}\\n    51→\\n    52→// End completes the span. For root spans, emits a single DEBUG log line\\n    53→// with the full timing tree. For child spans, records the duration only.\\n    54→// Safe to call multiple times -- subsequent calls are no-ops.\\n    55→func (s *Span) End() {\\n    56→\\tif s.ended {\\n    57→\\t\\treturn\\n    58→\\t}\\n    59→\\ts.ended = true\\n    60→\\ts.duration = time.Since(s.start)\\n    61→\\n    62→\\t// Only root spans emit log output\\n    63→\\tif s.parent != nil {\\n    64→\\t\\treturn\\n    65→\\t}\\n    66→\\n    67→\\t// Build log attributes: component, op, duration_ms, error flag, then child step durations.\\n    68→\\t// The \\\"component\\\" key is intentionally set to \\\"perf\\\" for easy filtering,\\n    69→\\t// even if the context already has a component set via logging.WithComponent().\\n    70→\\tattrs := make([]any, 0, 4+2*len(s.children)+len(s.attrs))\\n    71→\\tattrs = append(attrs, slog.String(\\\"component\\\", \\\"perf\\\"))\\n    72→\\tattrs = append(attrs, slog.String(\\\"op\\\", s.name))\\n    73→\\tattrs = append(attrs, slog.Int64(\\\"duration_ms\\\", s.duration.Milliseconds()))\\n    74→\\tif s.err != nil {\\n    75→\\t\\tattrs = append(attrs, slog.Bool(\\\"error\\\", true))\\n    76→\\t}\\n    77→\\n    78→\\t// Add child step durations (and error flags) as flat keys\\n    79→\\tfor _, child := range s.children {\\n    80→\\t\\t// Auto-end children that were not explicitly ended\\n    81→\\t\\tif !child.ended {\\n    82→\\t\\t\\tchild.ended = true\\n    83→\\t\\t\\tchild.duration = time.Since(child.start)\\n    84→\\t\\t}\\n    85→\\t\\tkey := fmt.Sprintf(\\\"steps.%s_ms\\\", child.name)\\n    86→\\t\\tattrs = append(attrs, slog.Int64(key, child.duration.Milliseconds()))\\n    87→\\t\\tif child.err != nil {\\n    88→\\t\\t\\terrKey := fmt.Sprintf(\\\"steps.%s_err\\\", child.name)\\n    89→\\t\\t\\tattrs = append(attrs, slog.Bool(errKey, true))\\n    90→\\t\\t}\\n    91→\\t}\\n    92→\\n    93→\\t// Add any extra attributes from Start()\\n    94→\\tfor _, a := range s.attrs {\\n    95→\\t\\tattrs = append(attrs, a)\\n    96→\\t}\\n    97→\\n    98→\\tlogging.Debug(s.ctx, \\\"perf\\\", attrs...)\\n    99→}\\n   100→\\n   101→// Measure times a function as a child substep of this span.\\n   102→func (s *Span) Measure(name string, fn func()) {\\n   103→\\tctx := contextWithSpan(s.ctx, s)\\n   104→\\t_, child := Start(ctx, name)\\n   105→\\tdefer child.End()\\n   106→\\tfn()\\n   107→}\\n   108→\"}]},\"uuid\":\"7b6c5237-be97-403a-b691-1c710d3904d9\",\"timestamp\":\"2026-03-06T00:19:28.236Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"ac129d8ba23a9446b\"},\"toolUseID\":\"agent_msg_01DDd2kZf3ZXMKUtYZjGucMx\",\"parentToolUseID\":\"toolu_01Jd6H39apQ2Wmb2RBjFjLVM\",\"uuid\":\"a72a594f-9cf9-49fd-8003-8d86d351d98b\",\"timestamp\":\"2026-03-06T00:19:28