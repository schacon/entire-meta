var checkpoints []CheckpointInfo\\n   107→\\n   108→\\t// Scan sharded structure: <2-char-prefix>/<remaining-id>/metadata.json\\n   109→\\t// The tree has 2-character directories (hex buckets)\\n   110→\\tfor _, bucketEntry := range tree.Entries {\\n   111→\\t\\tif bucketEntry.Mode != filemode.Dir {\\n   112→\\t\\t\\tcontinue\\n   113→\\t\\t}\\n   114→\\t\\t// Bucket should be 2 hex chars\\n   115→\\t\\tif len(bucketEntry.Name) != 2 {\\n   116→\\t\\t\\tcontinue\\n   117→\\t\\t}\\n   118→\\n   119→\\t\\tbucketTree, treeErr := repo.TreeObject(bucketEntry.Hash)\\n   120→\\t\\tif treeErr != nil {\\n   121→\\t\\t\\tcontinue\\n   122→\\t\\t}\\n   123→\\n   124→\\t\\t// Each entry in the bucket is the remaining part of the checkpoint ID\\n   125→\\t\\tfor _, checkpointEntry := range bucketTree.Entries {\\n   126→\\t\\t\\tif checkpointEntry.Mode != filemode.Dir {\\n   127→\\t\\t\\t\\tcontinue\\n   128→\\t\\t\\t}\\n   129→\\n   130→\\t\\t\\tcheckpointTree, cpTreeErr := repo.TreeObject(checkpointEntry.Hash)\\n   131→\\t\\t\\tif cpTreeErr != nil {\\n   132→\\t\\t\\t\\tcontinue\\n   133→\\t\\t\\t}\\n   134→\\n   135→\\t\\t\\t// Reconstruct checkpoint ID: <bucket><remaining>\\n   136→\\t\\t\\tcheckpointIDStr := bucketEntry.Name + checkpointEntry.Name\\n   137→\\t\\t\\tcheckpointID, cpErr := id.NewCheckpointID(checkpointIDStr)\\n   138→\\t\\t\\tif cpErr != nil {\\n   139→\\t\\t\\t\\t// Skip invalid checkpoint IDs\\n   140→\\t\\t\\t\\tcontinue\\n   141→\\t\\t\\t}\\n   142→\\n   143→\\t\\t\\tinfo := CheckpointInfo{\\n   144→\\t\\t\\t\\tCheckpointID: checkpointID,\\n   145→\\t\\t\\t}\\n   146→\\n   147→\\t\\t\\t// Get details from metadata file (CheckpointSummary format)\\n   148→\\t\\t\\tif metadataFile, fileErr := checkpointTree.File(paths.MetadataFileName); fileErr == nil {\\n   149→\\t\\t\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n   150→\\t\\t\\t\\t\\tvar summary checkpoint.CheckpointSummary\\n   151→\\t\\t\\t\\t\\tif json.Unmarshal([]byte(content), &summary) == nil && len(summary.Sessions) > 0 {\\n   152→\\t\\t\\t\\t\\t\\tinfo.CheckpointsCount = summary.CheckpointsCount\\n   153→\\t\\t\\t\\t\\t\\tinfo.FilesTouched = summary.FilesTouched\\n   154→\\t\\t\\t\\t\\t\\tinfo.SessionCount = len(summary.Sessions)\\n   155→\\n   156→\\t\\t\\t\\t\\t\\t// Read session-level metadata for Agent, SessionID, CreatedAt, SessionIDs\\n   157→\\t\\t\\t\\t\\t\\tfor i, sessionPaths := range summary.Sessions {\\n   158→\\t\\t\\t\\t\\t\\t\\tif sessionPaths.Metadata != \\\"\\\" {\\n   159→\\t\\t\\t\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n   160→\\t\\t\\t\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n   161→\\t\\t\\t\\t\\t\\t\\t\\tsessionMetadataPath := strings.TrimPrefix(sessionPaths.Metadata, \\\"/\\\")\\n   162→\\t\\t\\t\\t\\t\\t\\t\\tif sessionFile, sErr := tree.File(sessionMetadataPath); sErr == nil {\\n   163→\\t\\t\\t\\t\\t\\t\\t\\t\\tif sessionContent, scErr := sessionFile.Contents(); scErr == nil {\\n   164→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata checkpoint.CommittedMetadata\\n   165→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   166→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionIDs = append(info.SessionIDs, sessionMetadata.SessionID)\\n   167→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t// Use first session's metadata for Agent, SessionID, CreatedAt\\n   168→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif i == 0 {\\n   169→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   170→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   171→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   172→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.IsTask = sessionMetadata.IsTask\\n   173→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.ToolUseID = sessionMetadata.ToolUseID\\n   174→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   175→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   176→\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   177→\\t\\t\\t\\t\\t\\t\\t\\t}\\n   178→\\t\\t\\t\\t\\t\\t\\t}\\n   179→\\t\\t\\t\\t\\t\\t}\\n   180→\\t\\t\\t\\t\\t}\\n   181→\\t\\t\\t\\t}\\n   182→\\t\\t\\t}\\n   183→\\n   184→\\t\\t\\tcheckpoints = append(checkpoints, info)\\n   185→\\t\\t}\\n   186→\\t}\\n   187→\\n   188→\\t// Sort by time (most recent first)\\n   189→\\tsort.Slice(checkpoints, func(i, j int) bool {\\n   190→\\t\\treturn checkpoints[i].CreatedAt.After(checkpoints[j].CreatedAt)\\n   191→\\t})\\n   192→\\n   193→\\treturn checkpoints, nil\\n   194→}\\n   195→\\n   196→const (\\n   197→\\tentireGitignore    = \\\".entire/.gitignore\\\"\\n   198→\\tentireDir          = \\\".entire\\\"\\n   199→\\tgitDir             = \\\".git\\\"\\n   200→\\tshadowBranchPrefix = \\\"entire/\\\"\\n   201→\\n   202→\\t// DefaultAgentType is the generic fallback agent type name\\n   203→\\tDefaultAgentType = agent.AgentTypeUnknown\\n   204→)\\n   205→\\n   206→// isProtectedPath returns true if relPath is inside a directory that should\\n   207→// never be modified or deleted during rewind or other destructive operations.\\n   208→// Protected directories include git internals, entire metadata, and all\\n   209→// registered agent config directories.\\n   210→func isProtectedPath(relPath string) bool {\\n   211→\\tfor _, dir := range protectedDirs() {\\n   212→\\t\\tif relPath == dir || strings.HasPrefix(relPath, dir+string(filepath.Separator)) {\\n   213→\\t\\t\\treturn true\\n   214→\\t\\t}\\n   215→\\t}\\n   216→\\treturn false\\n   217→}\\n   218→\\n   219→// protectedDirs returns the list of directories to protect. This combines\\n   220→// static infrastructure dirs with agent-reported dirs from the registry.\\n   221→// The result is cached via sync.Once since it's called per-file when filtering untracked files.\\n   222→//\\n   223→// NOTE: The cache is never invalidated. In production this is fine (the agent registry\\n   224→// is populated at init time and never changes). However, tests that mutate the agent\\n   225→// registry after the first call to protectedDirs/isProtectedPath will see stale results.\\n   226→// If you need to test isProtectedPath with a custom registry, either:\\n   227→//   - run those tests in a separate process, or\\n   228→//   - call resetProtectedDirsForTest() to clear the cache.\\n   229→func protectedDirs() []string {\\n   230→\\tprotectedDirsOnce.Do(func() {\\n   231→\\t\\tprotectedDirsCache = append([]string{gitDir, entireDir}, agent.AllProtectedDirs()...)\\n   232→\\t})\\n   233→\\treturn protectedDirsCache\\n   234→}\\n   235→\\n   236→var (\\n   237→\\tprotectedDirsOnce  sync.Once\\n   238→\\tprotectedDirsCache []string\\n   239→)\\n   240→\\n   241→// isSpecificAgentType returns true if the agent type is a known, specific value\\n   242→// (not empty and not the generic \\\"Agent\\\" fallback).\\n   243→func isSpecificAgentType(t agent.AgentType) bool {\\n   244→\\treturn t != \\\"\\\" && t != DefaultAgentType\\n   245→}\\n   246→\\n   247→// resolveAgentType picks the best agent type from the context and existing state.\\n   248→// Priority: existing state (if specific) > context value > default fallback.\\n   249→func resolveAgentType(ctxAgentType agent.AgentType, state *SessionState) agent.AgentType {\\n   250→\\tif state != nil && isSpecificAgentType(state.AgentType) {\\n   251→\\t\\treturn state.AgentType\\n   252→\\t}\\n   253→\\tif ctxAgentType != \\\"\\\" {\\n   254→\\t\\treturn ctxAgentType\\n   255→\\t}\\n   256→\\treturn DefaultAgentType\\n   257→}\\n   258→\\n   259→// ensureMetadataBranch creates the orphan entire/checkpoints/v1 branch if it doesn't exist.\\n   260→// This branch has no parent and starts with an empty tree.\\n   261→func EnsureMetadataBranch(repo *git.Repository) error {\\n   262→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   263→\\n   264→\\t// Check if branch already exists\\n   265→\\t_, err := repo.Reference(refName, true)\\n   266→\\tif err == nil {\\n   267→\\t\\t// Branch already exists\\n   268→\\t\\treturn nil\\n   269→\\t}\\n   270→\\n   271→\\t// Create empty tree (no files)\\n   272→\\temptyTree := &object.Tree{Entries: []object.TreeEntry{}}\\n   273→\\tobj := repo.Storer.NewEncodedObject()\\n   274→\\tif err := emptyTree.Encode(obj); err != nil {\\n   275→\\t\\treturn fmt.Errorf(\\\"failed to encode empty tree: %w\\\", err)\\n   276→\\t}\\n   277→\\temptyTreeHash, err := repo.Storer.SetEncodedObject(obj)\\n   278→\\tif err != nil {\\n   279→\\t\\treturn fmt.Errorf(\\\"failed to store empty tree: %w\\\", err)\\n   280→\\t}\\n   281→\\n   282→\\t// Create orphan commit (no parent)\\n   283→\\tnow := time.Now()\\n   284→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   285→\\tsig := object.Signature{\\n   286→\\t\\tName:  authorName,\\n   287→\\t\\tEmail: authorEmail,\\n   288→\\t\\tWhen:  now,\\n   289→\\t}\\n   290→\\n   291→\\tcommit := &object.Commit{\\n   292→\\t\\tTreeHash:  emptyTreeHash,\\n   293→\\t\\tAuthor:    sig,\\n   294→\\t\\tCommitter: sig,\\n   295→\\t\\tMessage:   \\\"Initialize metadata branch\\\\n\\\\nThis branch stores session metadata for the auto-commit strategy.\\\\n\\\",\\n   296→\\t}\\n   297→\\t// Note: No ParentHashes - this is an orphan commit\\n   298→\\n   299→\\tcommitObj := repo.Storer.NewEncodedObject()\\n   300→\\tif err := commit.Encode(commitObj); err != nil {\\n   301→\\t\\treturn fmt.Errorf(\\\"failed to encode orphan commit: %w\\\", err)\\n   302→\\t}\\n   303→\\tcommitHash, err := repo.Storer.SetEncodedObject(commitObj)\\n   304→\\tif err != nil {\\n   305→\\t\\treturn fmt.Errorf(\\\"failed to store orphan commit: %w\\\", err)\\n   306→\\t}\\n   307→\\n   308→\\t// Create branch reference\\n   309→\\tref := plumbing.NewHashReference(refName, commitHash)\\n   310→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   311→\\t\\treturn fmt.Errorf(\\\"failed to create metadata branch