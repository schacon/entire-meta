\",\"type\":\"tool_result\",\"content\":\"     1→// Package kiro implements the Agent interface for Amazon's Kiro CLI.\\n     2→package kiro\\n     3→\\n     4→import (\\n     5→\\t\\\"context\\\"\\n     6→\\t\\\"encoding/json\\\"\\n     7→\\t\\\"errors\\\"\\n     8→\\t\\\"fmt\\\"\\n     9→\\t\\\"os\\\"\\n    10→\\t\\\"os/exec\\\"\\n    11→\\t\\\"path/filepath\\\"\\n    12→\\t\\\"runtime\\\"\\n    13→\\t\\\"strings\\\"\\n    14→\\t\\\"time\\\"\\n    15→\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    20→)\\n    21→\\n    22→//nolint:gochecknoinits // Agent self-registration is the intended pattern\\n    23→func init() {\\n    24→\\tagent.Register(agent.AgentNameKiro, NewKiroAgent)\\n    25→}\\n    26→\\n    27→// KiroAgent implements the Agent interface for Amazon's Kiro CLI.\\n    28→//\\n    29→//nolint:revive // KiroAgent is clearer than Agent in this context\\n    30→type KiroAgent struct{}\\n    31→\\n    32→// NewKiroAgent creates a new Kiro agent instance.\\n    33→func NewKiroAgent() agent.Agent {\\n    34→\\treturn &KiroAgent{}\\n    35→}\\n    36→\\n    37→// --- Identity ---\\n    38→\\n    39→func (k *KiroAgent) Name() types.AgentName   { return agent.AgentNameKiro }\\n    40→func (k *KiroAgent) Type() types.AgentType   { return agent.AgentTypeKiro }\\n    41→func (k *KiroAgent) Description() string     { return \\\"Kiro - Amazon AI coding CLI\\\" }\\n    42→func (k *KiroAgent) IsPreview() bool         { return true }\\n    43→func (k *KiroAgent) ProtectedDirs() []string { return []string{\\\".kiro\\\"} }\\n    44→\\n    45→// DetectPresence checks if Kiro is configured in the repository.\\n    46→func (k *KiroAgent) DetectPresence(ctx context.Context) (bool, error) {\\n    47→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    48→\\tif err != nil {\\n    49→\\t\\tworktreeRoot = \\\".\\\"\\n    50→\\t}\\n    51→\\tif _, err := os.Stat(filepath.Join(worktreeRoot, \\\".kiro\\\")); err == nil {\\n    52→\\t\\treturn true, nil\\n    53→\\t}\\n    54→\\treturn false, nil\\n    55→}\\n    56→\\n    57→// --- Transcript Storage ---\\n    58→\\n    59→// ReadTranscript reads the cached transcript JSON for a session.\\n    60→func (k *KiroAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    61→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    62→\\tif err != nil {\\n    63→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    64→\\t}\\n    65→\\treturn data, nil\\n    66→}\\n    67→\\n    68→// ChunkTranscript splits a JSON transcript into chunks.\\n    69→// Kiro transcripts are single JSON objects; we use the JSONL chunker since the\\n    70→// cached format is a JSON blob that fits in a single chunk in most cases.\\n    71→func (k *KiroAgent) ChunkTranscript(_ context.Context, content []byte, maxSize int) ([][]byte, error) {\\n    72→\\tif len(content) <= maxSize {\\n    73→\\t\\treturn [][]byte{content}, nil\\n    74→\\t}\\n    75→\\t// For large transcripts, split at line boundaries\\n    76→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n    79→\\t}\\n    80→\\treturn chunks, nil\\n    81→}\\n    82→\\n    83→// ReassembleTranscript combines transcript chunks back into a single blob.\\n    84→func (k *KiroAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    85→\\tif len(chunks) == 1 {\\n    86→\\t\\treturn chunks[0], nil\\n    87→\\t}\\n    88→\\treturn agent.ReassembleJSONL(chunks), nil\\n    89→}\\n    90→\\n    91→// --- Session Management ---\\n    92→\\n    93→// GetSessionID extracts the session ID from hook input.\\n    94→func (k *KiroAgent) GetSessionID(input *agent.HookInput) string {\\n    95→\\treturn input.SessionID\\n    96→}\\n    97→\\n    98→// GetSessionDir returns the directory where Kiro stores session data.\\n    99→// For Kiro, sessions are in SQLite, but we cache transcripts to .entire/tmp/.\\n   100→func (k *KiroAgent) GetSessionDir(repoPath string) (string, error) {\\n   101→\\treturn filepath.Join(repoPath, \\\".entire\\\", \\\"tmp\\\"), nil\\n   102→}\\n   103→\\n   104→// ResolveSessionFile returns the path to the cached transcript file.\\n   105→func (k *KiroAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   106→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".json\\\")\\n   107→}\\n   108→\\n   109→// ReadSession reads session data from the cached transcript.\\n   110→func (k *KiroAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   111→\\tif input.SessionRef == \\\"\\\" {\\n   112→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   113→\\t}\\n   114→\\n   115→\\tdata, err := os.ReadFile(input.SessionRef)\\n   116→\\tif err != nil {\\n   117→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   118→\\t}\\n   119→\\n   120→\\treturn &agent.AgentSession{\\n   121→\\t\\tSessionID:  input.SessionID,\\n   122→\\t\\tAgentName:  k.Name(),\\n   123→\\t\\tSessionRef: input.SessionRef,\\n   124→\\t\\tStartTime:  time.Now(),\\n   125→\\t\\tNativeData: data,\\n   126→\\t}, nil\\n   127→}\\n   128→\\n   129→// WriteSession writes session data for resumption.\\n   130→func (k *KiroAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   131→\\tif session == nil {\\n   132→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   133→\\t}\\n   134→\\tif session.AgentName != \\\"\\\" && session.AgentName != k.Name() {\\n   135→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, k.Name())\\n   136→\\t}\\n   137→\\tif session.SessionRef == \\\"\\\" {\\n   138→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   139→\\t}\\n   140→\\tif len(session.NativeData) == 0 {\\n   141→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   142→\\t}\\n   143→\\n   144→\\tif err := os.MkdirAll(filepath.Dir(session.SessionRef), 0o750); err != nil {\\n   145→\\t\\treturn fmt.Errorf(\\\"failed to create session dir: %w\\\", err)\\n   146→\\t}\\n   147→\\n   148→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   149→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   150→\\t}\\n   151→\\treturn nil\\n   152→}\\n   153→\\n   154→// FormatResumeCommand returns the command to resume a Kiro session.\\n   155→func (k *KiroAgent) FormatResumeCommand(_ string) string {\\n   156→\\treturn \\\"kiro-cli chat --resume\\\"\\n   157→}\\n   158→\\n   159→// GetHookConfigPath returns the path to the hook config file relative to repo root.\\n   160→func (k *KiroAgent) GetHookConfigPath() string {\\n   161→\\treturn filepath.Join(\\\".kiro\\\", hooksDir, HooksFileName)\\n   162→}\\n   163→\\n   164→// --- SQLite helpers ---\\n   165→\\n   166→// escapeSQLString escapes single quotes for use in SQLite string literals.\\n   167→func escapeSQLString(s string) string {\\n   168→\\treturn strings.ReplaceAll(s, \\\"'\\\", \\\"''\\\")\\n   169→}\\n   170→\\n   171→// --- SQLite session resolution ---\\n   172→\\n   173→// dbPath returns the path to Kiro's SQLite database.\\n   174→func dbPath() (string, error) {\\n   175→\\thome, err := os.UserHomeDir()\\n   176→\\tif err != nil {\\n   177→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   178→\\t}\\n   179→\\tswitch runtime.GOOS {\\n   180→\\tcase \\\"darwin\\\":\\n   181→\\t\\treturn filepath.Join(home, \\\"Library\\\", \\\"Application Support\\\", \\\"kiro-cli\\\", \\\"data.sqlite3\\\"), nil\\n   182→\\tdefault: // linux\\n   183→\\t\\treturn filepath.Join(home, \\\".local\\\", \\\"share\\\", \\\"kiro-cli\\\", \\\"data.sqlite3\\\"), nil\\n   184→\\t}\\n   185→}\\n   186→\\n   187→// querySessionID queries the SQLite database for the most recent conversation ID\\n   188→// associated with the given CWD.\\n   189→func (k *KiroAgent) querySessionID(ctx context.Context, cwd string) (string, error) {\\n   190→\\tif os.Getenv(\\\"ENTIRE_TEST_KIRO_MOCK_DB\\\") == \\\"1\\\" {\\n   191→\\t\\treturn \\\"mock-session-id\\\", nil\\n   192→\\t}\\n   193→\\n   194→\\tdb, err := dbPath()\\n   195→\\tif err != nil {\\n   196→\\t\\treturn \\\"\\\", err\\n   197→\\t}\\n   198→\\tif _, err := os.Stat(db); err != nil {\\n   199→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"kiro database not found at %s: %w\\\", db, err)\\n   200→\\t}\\n   201→\\n   202→\\tquery := fmt.Sprintf(\\n   203→\\t\\t\\\"SELECT json_extract(value, '$.conversation_id') FROM conversations_v2 WHERE key = '%s' ORDER BY updated_at DESC LIMIT 1\\\",\\n   204→\\t\\tescapeSQLString(cwd),\\n   205→\\t)\\n   206→\\n   207→\\tcmd := exec.CommandContext(ctx, \\\"sqlite3\\\", \\\"-json\\\", db, query)\\n   208→\\tout, err := cmd.Output()\\n   209→\\tif err != nil {\\n   210→\\t\\tlogging.Warn(ctx, \\\"kiro: sqlite3 query failed\\\", \\\"err\\\", err, \\\"cwd\\\", cwd)\\n   211→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"sqlite3 query failed: %w\\\", err)\\n   212→\\t}\\n   213→\\n   214→\\tresult := strings.TrimSpace(string(out))\\n   215→\\tif result == \\\"\\\" || result == \\\"[]\\\" {\\n   216→\\t\\treturn \\\"\\\", nil\\n   217→\\t}\\n   218→\\n   219→\\t// sqlite3 -json returns an array of objects\\n   220→\\tvar rows []map[string]string\\n   221→\\tif err := json.Unmarshal([]byte(result), &rows); err != nil {\\n   222→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse sqlite3 output: %w\\\", err)\\n   223→\\t}\\n   224→\\tif len(rows) == 0 {\\n   225→\\t\\treturn \\\"\\\", nil\\n   226→\\t}\\n   227→\\n   228→\\t// The column name from json_extract\\n   229→\\tfor _, v := range rows[0] {\\n   230→\\t\\treturn v, nil\\n   231→\\t}\\n   232→\\treturn \\\"\\\", nil\\n   233→}\\n   234→\\n   235→// ensureCachedTranscript fetches the conversation from SQLite and caches it\\n   236→// to .entire/tmp/<sessionID>.json. Returns the cache file path.\\n   237→func (k *KiroAgent) ensureCachedTranscript(ctx context.Context, cwd, sessionID string) (string, error) {\\n   238→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   239→\\tif err != nil {\\n   240→\\t\\trepoRoot = cwd\\n   241→\\t}\\n   242→\\n   243→\\tcacheDir := filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\")\\n   244→\\tcachePath := filepath.Join(cacheDir, sessionID+\\\".json\\\")\\n   245→\\n   246→\\t// Fetch fresh transcript from SQLite on every call (transcript grows during session)\\n   247→\\tif os.Getenv(\\\"ENTIRE_TEST_KIRO_MOCK_DB\\\") == \\\"1\\\" {\\n   248→\\t\\t// In test mode, return the expected cache path without hitting SQLite.\\n   249→\\t\\treturn cachePath, nil\\n   250→\\t}\\n   251→\\n   252→\\tdb, err := dbPath()\\n   253→\\tif err != nil {\\n   254→\\t\\treturn \\\"\\\", err\\n   255→\\t}\\n   256→\\n   257→\\tquery := fmt.Sprintf(\\n   258→\\t\\t\\\"SELECT value FROM conversations_v2 WHERE key = '%s' ORDER BY updated_at DESC LIMIT 1\\\",\\n   259→\\t\\tescapeSQLString(cwd),\\n   260→\\t)\\n   261→\\n   262→\\tcmd := exec.CommandContext(ctx, \\\"sqlite3\\\", db, query)\\n   263→\\tout, err := cmd.Output()\\n   264→\\tif err != nil {\\n   265→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"sqlite3 transcript query failed: %w\\\", err)\\n   266→\\t}\\n   267→\\n   268→\\ttranscript := strings.TrimSpace(string(out))\\n   269→\\tif transcript == \\\"\\\" {\\n   270→\\t\\treturn \\\"\\\", errors.New(\\\"no transcript found\\\")\\n   271→\\t}\\n   272→\\n   273→\\tif err := os.MkdirAll(cacheDir, 0o750); err != nil {\\n   274→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create cache dir: %w\\\", err)\\n   275→\\t}\\n   276→\\n   277→\\tif err := os.WriteFile(cachePath, []byte(transcript), 0o600); err != nil {\\n   278→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write cached transcript: %w\\\", err)\\n   279→\\t}\\n   280→\\n   281→\\treturn cachePath, nil\\n   282→}\\n   283→\"}]},\"uuid\":\"64b71771-3bdb-4db0-80ee-144e54e7b810\",\"timestamp\":\"2026-03-03T21:26:31.711Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a3065ba1879174194\"},\"toolUseID\":\"agent_msg_01BaQ1832M6d2CsCXHWx2VQm\",\"parentToolUseID\":\"toolu_01CsWwmqfd9QsiE1zMaUHxqk\",\"uuid\":\"30a9091e-7204-4fd9-9c99-448de7f7ab76\",\"timestamp\":\"2026-03-03T21:26:32.161Z\"}\n{\"parentUuid\":\"30a9091e-7204-4fd9-9c99-448de7f7ab76\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"4ab3ddd7-2bb2-4d33-bbe6-7ee25ce1f55e\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"glittery-waddling-parrot\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-03T21:26:32.172Z\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01DhxhAmSFWFztjkRdSARf14\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01YJH2b6ZyGyHbeotSDn8iGK\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/alisha/Projects/wt/kiro-oneshot/cmd/entire/cli/agent/agent.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":9949,\"cache_read_input_tokens\":72659,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":9949},\"output_tokens\":3,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYgrVqUWL9bo3UVwvaQyM\",\"uuid\":\"4fe2fcab-8c62-42c7-98f1-c3d6fee4a163\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a3065ba1879174194\"},\"toolUseID\":\"agent_msg_01BaQ1832M6d2CsCXHWx2VQm\",\"parentToolUseID\":\"toolu_01CsWwmqfd9QsiE1zMaUHxqk\",\"uuid\":\"e4af79a5-0f8b-4e42-82eb-689e0575d941\",\"timestamp\":\"2026-03-03T21:26:32.172Z\"}\n{\"parentUuid\":\"e4af79a5-0f8b-4e42-82eb-689e0575d941\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"4ab3ddd7-2bb2-4d33-bbe6-7ee25ce1f55e\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"glittery-waddling-parrot\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01YJH2b6ZyGyHbeotSDn8iGK\",\"type\":\"tool_result\",\"content\":\"     1→// Package agent provides interfaces and types for integrating with coding agents.\\n     2→// It abstracts agent-specific behavior (hooks, log parsing, session storage) so that\\n     3→// the same Strategy implementations can work with any coding agent.\\n     4→package agent\\n     5→\\n     6→import (\\n     7→\\t\\\"context\\\"\\n     8→\\t\\\"io\\\"\\n     9→\\n    10→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    11→)\\n    12→\\n    13→// Agent defines the interface for interacting with a coding agent.\\n    14→// Each agent implementation (Claude Code, Cursor, Aider, etc.) converts its\\n    15→// native format to the normalized types defined in this package.\\n    16→//\\n    17→// The interface is organized into three groups:\\n    18→//   - Identity (5 methods): Name, Type, Description, DetectPresence, ProtectedDirs\\n    19→//   - Transcript Storage (3 methods): ReadTranscript, ChunkTranscript, ReassembleTranscript\\n    20→//   - Legacy (6 methods): Will be moved to optional interfaces or removed in a future phase\\n    21→type Agent interface {\\n    22→\\t// --- Identity ---\\n    23→\\n    24→\\t// Name returns the agent registry key (e.g., \\\"claude-code\\\", \\\"gemini\\\")\\n    25→\\tName() types.AgentName\\n    26→\\n    27→\\t// Type returns the agent type identifier (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\")\\n    28→\\t// This is stored in metadata and trailers.\\n    29→\\tType() types.AgentType\\n    30→\\n    31→\\t// Description returns a human-readable description for UI\\n    32→\\tDescription() string\\n    33→\\n    34→\\t// IsPreview returns whether the agent integration is in preview or stable\\n    35→\\tIsPreview() bool\\n    36→\\n    37→\\t// DetectPresence checks if this agent is configured in the repository\\n    38→\\tDetectPresence(ctx context.Context) (bool, error)\\n    39→\\n    40→\\t// ProtectedDirs returns repo-root-relative directories that should never be\\n    41→\\t// modified or deleted during rewind or other destructive operations.\\n    42→\\t// Examples: [\\\".claude\\\"] for Claude, [\\\".gemini\\\"] for Gemini.\\n    43→\\tProtectedDirs() []string\\n    44→\\n    45→\\t// --- Transcript Storage ---\\n    46→\\n    47→\\t// ReadTranscript reads the raw transcript bytes for a session.\\n    48→\\tReadTranscript(sessionRef string) ([]byte, error)\\n    49→\\n    50→\\t// ChunkTranscript splits a transcript into chunks if it exceeds maxSize.\\n    51→\\t// Returns a slice of chunks. If the transcript fits in one chunk, returns single-element slice.\\n    52→\\t// The chunking is format-aware: JSONL splits at line boundaries, JSON splits message arrays.\\n    53→\\tChunkTranscript(ctx context.Context, content []byte, maxSize int) ([][]byte, error)\\n    54→\\n    55→\\t// ReassembleTranscript combines chunks back into a single transcript.\\n    56→\\t// Handles format-specific reassembly (JSONL concatenation, JSON message merging).\\n    57→\\tReassembleTranscript(chunks [][]byte) ([]byte, error)\\n    58→\\n    59→\\t// --- Legacy methods (will move to optional interfaces in Phase 4) ---\\n    60→\\n    61→\\t// GetSessionID extracts session ID from hook input.\\n    62→\\tGetSessionID(input *HookInput) string\\n    63→\\n    64→\\t// GetSessionDir returns where agent stores session data for this repo.\\n    65→\\tGetSessionDir(repoPath string) (string, error)\\n    66→\\n    67→\\t// ResolveSessionFile returns the path to the session transcript file.\\n    68→\\tResolveSessionFile(sessionDir, agentSessionID string) string\\n    69→\\n    70→\\t// ReadSession reads session data from agent's storage.\\n    71→\\tReadSession(input *HookInput) (*AgentSession, error)\\n    72→\\n    73→\\t// WriteSession writes session data for resumption.\\n    74→\\tWriteSession(ctx context.Context, session *AgentSession) error\\n    75→\\n    76→\\t// FormatResumeCommand returns command to resume a session.\\n    77→\\tFormatResumeCommand(sessionID string) string\\n    78→}\\n    79→\\n    80→// HookSupport is implemented by agents with lifecycle hooks.\\n    81→// This optional interface allows agents like Claude Code and Cursor to\\n    82→// install and manage hooks that notify Entire of agent events.\\n    83→//\\n    84→// The interface is organized into two groups:\\n    85→//   - Hook Mapping (2 methods): HookNames, ParseHookEvent\\n    86→//   - Hook Management (3 methods): InstallHooks, UninstallHooks, AreHooksInstalled\\n    87→type HookSupport interface {\\n    88→\\tAgent\\n    89→\\n    90→\\t// HookNames returns the hook verbs this agent supports.\\n    91→\\t// These become subcommands under `entire hooks <agent>`.\\n    92→\\t// e.g., [\\\"stop\\\", \\\"user-prompt-submit\\\", \\\"session-start\\\", \\\"session-end\\\"]\\n    93→\\tHookNames() []string\\n    94→\\n    95→\\t// ParseHookEvent translates an agent-native hook into a normalized lifecycle Event.\\n    96→\\t// Returns nil if the hook has no lifecycle significance (e.g., pass-through hooks).\\n    97→\\t// This is the core contribution surface for new agent implementations.\\n    98→\\tParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*Event, error)\\n    99→\\n   100→\\t// InstallHooks installs agent-specific hooks.\\n   101→\\t// If localDev is true, hooks point to local development build.\\n   102→\\t// If force is true, removes existing Entire hooks before installing.\\n   103→\\t// Returns the number of hooks installed.\\n   104→\\tInstallHooks(ctx context.Context, localDev bool, force bool) (int, error)\\n   105→\\n   106→\\t// UninstallHooks removes installed hooks\\n   107→\\tUninstallHooks(ctx context.Context) error\\n   108→\\n   109→\\t// AreHooksInstalled checks if hooks are currently installed\\n   110→\\tAreHooksInstalled(ctx context.Context) bool\\n   111→}\\n   112→\\n   113→// FileWatcher is implemented by agents that use file-based detection.\\n   114→// Agents like Aider that don't support hooks can use file watching\\n   115→// to detect session activity.\\n   116→type FileWatcher interface {\\n   117→\\tAgent\\n   118→\\n   119→\\t// GetWatchPaths returns paths to watch for session changes\\n   120→\\tGetWatchPaths() ([]string, error)\\n   121→\\n   122→\\t// OnFileChange handles a detected file change and returns session info\\n   123→\\tOnFileChange(path string) (*SessionChange, error)\\n   124→}\\n   125→\\n   126→// TranscriptAnalyzer provides format-specific transcript parsing.\\n   127→// Agents that implement this get richer checkpoints (transcript-derived file lists,\\n   128→// prompts, summaries). Agents that don't still participate in the checkpoint lifecycle\\n   129→// via git-status-based file detection and raw transcript storage.\\n   130→type TranscriptAnalyzer interface {\\n   131→\\tAgent\\n   132→\\n   133→\\t// GetTranscriptPosition returns the current position (length) of a transcript.\\n   134→\\t// For JSONL formats (Claude Code), this is the line count.\\n   135→\\t// For JSON formats (Gemini CLI), this is the message count.\\n   136→\\t// Returns 0 if the file doesn't exist or is empty.\\n   137→\\tGetTranscriptPosition(path string) (int, error)\\n   138→\\n   139→\\t// ExtractModifiedFilesFromOffset extracts files modified since a given offset.\\n   140→\\t// For JSONL formats (Claude Code), offset is the starting line number.\\n   141→\\t// For JSON formats (Gemini CLI), offset is the starting message index.\\n   142→\\t// Returns:\\n   143→\\t//   - files: list of file paths modified by the agent (from Write/Edit tools)\\n   144→\\t//   - currentPosition: the current position (line count or message count)\\n   145→\\t//   - error: any error encountered during reading\\n   146→\\tExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error)\\n   147→\\n   148→\\t// ExtractPrompts extracts user prompts from the transcript starting at the given offset.\\n   149→\\tExtractPrompts(sessionRef string, fromOffset int) ([]string, error)\\n   150→\\n   151→\\t// ExtractSummary extracts a summary of the session from the transcript.\\n   152→\\tExtractSummary(sessionRef string) (string, error)\\n   153→}\\n   154→\\n   155→// TranscriptPreparer is called before ReadTranscript to handle agent-specific\\n   156→// flush/sync requirements (e.g., Claude Code's async transcript writing).\\n   157→// The framework calls PrepareTranscript before ReadTranscript if implemented.\\n   158→type TranscriptPreparer interface {\\n   159→\\tAgent\\n   160→\\n   161→\\t// PrepareTranscript ensures the transcript is ready to read.\\n   162→\\t// For Claude Code, this waits for the async transcript flush to complete.\\n   163→\\tPrepareTranscript(ctx context.Context, sessionRef string) error\\n   164→}\\n   165→\\n   166→// TokenCalculator provides token usage calculation for a session.\\n   167→// The framework calls this during step save and checkpoint if implemented.\\n   168→type TokenCalculator interface {\\n   169→\\tAgent\\n   170→\\n   171→\\t// CalculateTokenUsage computes token usage from the transcript starting at the given offset.\\n   172→\\tCalculateTokenUsage(transcriptData []byte, fromOffset int) (*TokenUsage, error)\\n   173→}\\n   174→\\n   175→// HookResponseWriter is implemented by agents that support structured hook responses.\\n 