Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"4ab3ddd7-2bb2-4d33-bbe6-7ee25ce1f55e\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"glittery-waddling-parrot\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_0116qE2nYGvcGxuE7H2WfA3v\",\"type\":\"tool_result\",\"content\":\"     1→package kiro\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"crypto/rand\\\"\\n     6→\\t\\\"encoding/hex\\\"\\n     7→\\t\\\"errors\\\"\\n     8→\\t\\\"io\\\"\\n     9→\\t\\\"os\\\"\\n    10→\\t\\\"path/filepath\\\"\\n    11→\\t\\\"strings\\\"\\n    12→\\t\\\"time\\\"\\n    13→\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    17→)\\n    18→\\n    19→// Kiro hook names — these become CLI subcommands under `entire hooks kiro`.\\n    20→// Kiro uses camelCase hook names natively, but CLI subcommands use kebab-case.\\n    21→const (\\n    22→\\tHookNameAgentSpawn       = \\\"agent-spawn\\\"\\n    23→\\tHookNameUserPromptSubmit = \\\"user-prompt-submit\\\"\\n    24→\\tHookNamePreToolUse       = \\\"pre-tool-use\\\"\\n    25→\\tHookNamePostToolUse      = \\\"post-tool-use\\\"\\n    26→\\tHookNameStop             = \\\"stop\\\"\\n    27→)\\n    28→\\n    29→// sessionIDFile is the filename for caching the generated session ID.\\n    30→// Stored in .entire/tmp/ to ensure a stable ID across all hooks in one session.\\n    31→const sessionIDFile = \\\"kiro-active-session\\\"\\n    32→\\n    33→// HookNames returns the hook verbs Kiro supports.\\n    34→// These become subcommands: entire hooks kiro <verb>\\n    35→func (k *KiroAgent) HookNames() []string {\\n    36→\\treturn []string{\\n    37→\\t\\tHookNameAgentSpawn,\\n    38→\\t\\tHookNameUserPromptSubmit,\\n    39→\\t\\tHookNamePreToolUse,\\n    40→\\t\\tHookNamePostToolUse,\\n    41→\\t\\tHookNameStop,\\n    42→\\t}\\n    43→}\\n    44→\\n    45→// ParseHookEvent translates a Kiro hook into a normalized lifecycle Event.\\n    46→// Returns nil for hooks with no lifecycle significance (preToolUse, postToolUse).\\n    47→func (k *KiroAgent) ParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*agent.Event, error) {\\n    48→\\tswitch hookName {\\n    49→\\tcase HookNameAgentSpawn:\\n    50→\\t\\treturn k.parseAgentSpawn(ctx, stdin)\\n    51→\\tcase HookNameUserPromptSubmit:\\n    52→\\t\\treturn k.parseUserPromptSubmit(ctx, stdin)\\n    53→\\tcase HookNameStop:\\n    54→\\t\\treturn k.parseStop(ctx, stdin)\\n    55→\\tcase HookNamePreToolUse, HookNamePostToolUse:\\n    56→\\t\\t// Pass-through hooks with no lifecycle significance\\n    57→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    58→\\tdefault:\\n    59→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    60→\\t}\\n    61→}\\n    62→\\n    63→// readHookInputOrEmpty wraps ReadAndParseHookInput, returning a zero-value\\n    64→// hookInputRaw on empty stdin instead of erroring. This supports the Kiro IDE\\n    65→// which delivers data via environment variables rather than JSON on stdin.\\n    66→// Malformed JSON still returns an error.\\n    67→func readHookInputOrEmpty(stdin io.Reader) (*hookInputRaw, error) {\\n    68→\\traw, err := agent.ReadAndParseHookInput[hookInputRaw](stdin)\\n    69→\\tif err != nil {\\n    70→\\t\\tif errors.Is(err, agent.ErrEmptyHookInput) {\\n    71→\\t\\t\\treturn &hookInputRaw{}, nil\\n    72→\\t\\t}\\n    73→\\t\\treturn nil, err\\n    74→\\t}\\n    75→\\treturn raw, nil\\n    76→}\\n    77→\\n    78→func (k *KiroAgent) parseAgentSpawn(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n    79→\\t_, err := readHookInputOrEmpty(stdin)\\n    80→\\tif err != nil {\\n    81→\\t\\treturn nil, err\\n    82→\\t}\\n    83→\\n    84→\\t// Gener