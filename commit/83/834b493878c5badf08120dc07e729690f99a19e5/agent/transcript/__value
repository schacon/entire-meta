ata, err := os.ReadFile(settingsPath)\\n    if err != nil {\\n        t.Fatalf(\\\"failed to read settings.json: %v\\\", err)\\n    }\\n    var rawSettings map[string]json.RawMessage\\n    json.Unmarshal(data, &rawSettings)\\n    rawSettings[trustedCommandsKey] = json.RawMessage(`[\\\"npm test *\\\", \\\"entire hooks kiro *\\\"]`)\\n    output, _ := json.MarshalIndent(rawSettings, \\\"\\\", \\\"  \\\")\\n    os.WriteFile(settingsPath, output, 0o600)\\n\\n    // Uninstall\\n    if err := ag.UninstallHooks(context.Background()); err != nil {\\n        t.Fatalf(\\\"UninstallHooks() error = %v\\\", err)\\n    }\\n\\n    // Read back and verify \\\"npm test *\\\" is preserved, our pattern removed\\n    data, err = os.ReadFile(settingsPath)\\n    if err != nil {\\n        t.Fatalf(\\\"settings.json should still exist: %v\\\", err)\\n    }\\n    json.Unmarshal(data, &rawSettings)\\n    var remaining []string\\n    json.Unmarshal(rawSettings[trustedCommandsKey], &remaining)\\n\\n    if len(remaining) != 1 || remaining[0] != \\\"npm test *\\\" {\\n        t.Errorf(\\\"trustedCommands = %v, want [\\\\\\\"npm test *\\\\\\\"]\\\", remaining)\\n    }\\n}\\n\\nfunc TestUninstallHooks_RemovesBothProdAndLocalDevPatterns(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    // Create settings with both prod and localdev patterns\\n    vsDir := filepath.Join(tempDir, \\\".vscode\\\")\\n    os.MkdirAll(vsDir, 0o750)\\n    localDevPattern := localDevCmdPrefix + \\\"hooks kiro *\\\"\\n    both, _ := json.Marshal([]string{prodTrustedPattern, localDevPattern, \\\"npm test *\\\"})\\n    settings, _ := json.MarshalIndent(map[string]json.RawMessage{\\n        trustedCommandsKey: both,\\n    }, \\\"\\\", \\\"  \\\")\\n    os.WriteFile(filepath.Join(vsDir, \\\"settings.json\\\"), settings, 0o600)\\n\\n    ag := &KiroAgent{}\\n    if err := ag.UninstallHooks(context.Background()); err != nil {\\n        t.Fatalf(\\\"UninstallHooks() error = %v\\\", err)\\n    }\\n\\n    d