→\\tfor _, tc := range testCases {\\n   726→\\t\\tt.Run(tc.command, func(t *testing.T) {\\n   727→\\t\\t\\tt.Parallel()\\n   728→\\t\\t\\tgot := isEntireHook(tc.command)\\n   729→\\t\\t\\tif got != tc.want {\\n   730→\\t\\t\\t\\tt.Errorf(\\\"isEntireHook(%q) = %v, want %v\\\", tc.command, got, tc.want)\\n   731→\\t\\t\\t}\\n   732→\\t\\t})\\n   733→\\t}\\n   734→}\\n   735→\\n   736→func TestHasEntireHook(t *testing.T) {\\n   737→\\tt.Parallel()\\n   738→\\n   739→\\ttestCases := []struct {\\n   740→\\t\\tname    string\\n   741→\\t\\tentries []kiroHookEntry\\n   742→\\t\\twant    bool\\n   743→\\t}{\\n   744→\\t\\t{\\n   745→\\t\\t\\tname:    \\\"empty\\\",\\n   746→\\t\\t\\tentries: nil,\\n   747→\\t\\t\\twant:    false,\\n   748→\\t\\t},\\n   749→\\t\\t{\\n   750→\\t\\t\\tname:    \\\"non-entire hook\\\",\\n   751→\\t\\t\\tentries: []kiroHookEntry{{Command: \\\"other-tool stop\\\"}},\\n   752→\\t\\t\\twant:    false,\\n   753→\\t\\t},\\n   754→\\t\\t{\\n   755→\\t\\t\\tname:    \\\"entire hook\\\",\\n   756→\\t\\t\\tentries: []kiroHookEntry{{Command: \\\"entire hooks kiro stop\\\"}},\\n   757→\\t\\t\\twant:    true,\\n   758→\\t\\t},\\n   759→\\t\\t{\\n   760→\\t\\t\\tname: \\\"mixed hooks\\\",\\n   761→\\t\\t\\tentries: []kiroHookEntry{\\n   762→\\t\\t\\t\\t{Command: \\\"other-tool stop\\\"},\\n   763→\\t\\t\\t\\t{Command: \\\"entire hooks kiro stop\\\"},\\n   764→\\t\\t\\t},\\n   765→\\t\\t\\twant: true,\\n   766→\\t\\t},\\n   767→\\t\\t{\\n   768→\\t\\t\\tname:    \\\"local dev hook\\\",\\n   769→\\t\\t\\tentries: []kiroHookEntry{{Command: localDevCmdPrefix + \\\"hooks kiro stop\\\"}},\\n   770→\\t\\t\\twant:    true,\\n   771→\\t\\t},\\n   772→\\t}\\n   773→\\n   774→\\tfor _, tc := range testCases {\\n   775→\\t\\tt.Run(tc.name, func(t *testing.T) {\\n   776→\\t\\t\\tt.Parallel()\\n   777→\\t\\t\\tgot := hasEntireHook(tc.entries)\\n   778→\\t\\t\\tif got != tc.want {\\n   779→\\t\\t\\t\\tt.Errorf(\\\"hasEntireHook() = %v, want %v\\\", got, tc.want)\\n   780→