r != nil {\\n        t.Fatalf(\\\"failed to create .vscode: %v\\\", err)\\n    }\\n    existing := `{\\n  \\\"editor.fontSize\\\": 14,\\n  \\\"kiroAgent.trustedCommands\\\": [\\\"npm test *\\\"],\\n  \\\"other.setting\\\": true\\n}\\n`\\n    if err := os.WriteFile(filepath.Join(vsDir, \\\"settings.json\\\"), []byte(existing), 0o600); err != nil {\\n        t.Fatalf(\\\"failed to write settings.json: %v\\\", err)\\n    }\\n\\n    ag := &KiroAgent{}\\n    _, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"InstallHooks() error = %v\\\", err)\\n    }\\n\\n    data, err := os.ReadFile(filepath.Join(vsDir, \\\"settings.json\\\"))\\n    if err != nil {\\n        t.Fatalf(\\\"failed to read settings.json: %v\\\", err)\\n    }\\n\\n    var settings map[string]json.RawMessage\\n    if err := json.Unmarshal(data, &settings); err != nil {\\n        t.Fatalf(\\\"failed to parse settings.json: %v\\\", err)\\n    }\\n\\n    // Verify existing settings are preserved\\n    if _, ok := settings[\\\"editor.fontSize\\\"]; !ok {\\n        t.Error(\\\"editor.fontSize should be preserved\\\")\\n    }\\n    if _, ok := settings[\\\"other.setting\\\"]; !ok {\\n        t.Error(\\\"other.setting should be preserved\\\")\\n    }\\n\\n    // Verify trustedCommands includes both existing and new\\n    var trustedCmds []string\\n    if err := json.Unmarshal(settings[trustedCommandsKey], &trustedCmds); err != nil {\\n        t.Fatalf(\\\"failed to parse trustedCommands: %v\\\", err)\\n    }\\n\\n    if len(trustedCmds) != 2 {\\n        t.Fatalf(\\\"trustedCommands length = %d, want 2\\\", len(trustedCmds))\\n    }\\n    if trustedCmds[0] != \\\"npm test *\\\" {\\n        t.Errorf(\\\"trustedCommands[0] = %q, want %q\\\", trustedCmds[0], \\\"npm test *\\\")\\n    }\\n    if trustedCmds[1] != prodTrustedPattern {\\n        t.Errorf(\\\"trustedCommands[1] = %q, want %q\\\", trustedCmds[1], prodTrustedPattern)\\n    }\\n}\\n\\nfunc TestInstallHooks_TrustedCommands_Idempotent(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    ag := &KiroAgent{}\\n\\n    // First install\\n    _, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"first InstallHooks() error = %v\\\", err)\\n    }\\n\\n    // Second install should be idempotent (returns 0)\\n    count, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"second InstallHooks() error = %v\\\", err)\\n    }\\n    if count != 0 {\\n        t.Errorf(\\\"second InstallHooks() count = %d, want 0 (idempotent)\\\", count)\\n    }\\n\\n    // Verify pattern is not duplicated\\n    settingsPath := filepath.Join(tempDir, \\\".vscode\\\", \\\"settings.json\\\")\\n    data, err := os.ReadFile(settingsPath)\\n    if err != nil {\\n        t.Fatalf(\\\"failed to read settings.json: %v\\\", err)\\n    }\\n\\n    var settings map[string]json.RawMessage\\n    if err := json.Unmarshal(data, &settings); err != nil {\\n        t.Fatalf(\\\"failed to parse settings.json: %v\\\", err)\\n    }\\n\\n    var trustedCmds []string\\n    if err := json.Unmarshal(settings[trustedCommandsKey], &trustedCmds); err != nil {\\n        t.Fatalf(\\\"failed to parse trustedCommands: %v\\\", err)\\n    }\\n\\n    if len(trustedCmds) != 1 {\\n        t.Errorf(\\\"trustedCommands length = %d, want 1 (no duplicates)\\\", len(trustedCmds))\\n    }\\n}\\n\\nfunc TestInstallHooks_TrustedCommands_ReinstallWhenMissing(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    ag := &KiroAgent{}\\n\\n    // Install hooks\\n    _, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"first InstallHooks() error = %v\\\", err)\\n    }\\n\\n    // Delete .vscode/settings.json to simulate missing trusted commands\\n    os.Remove(filepath.Join(tempDir, \\\".vscode\\\", \\\"settings.json\\\"))\\n\\n    // Reinstall should