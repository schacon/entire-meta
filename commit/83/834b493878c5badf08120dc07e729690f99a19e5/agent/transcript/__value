s `json:\\\"hooks\\\"`\\n    21→}\\n    22→\\n    23→// kiroHooks contains all hook configurations using camelCase keys.\\n    24→type kiroHooks struct {\\n    25→\\tAgentSpawn       []kiroHookEntry `json:\\\"agentSpawn,omitempty\\\"`\\n    26→\\tUserPromptSubmit []kiroHookEntry `json:\\\"userPromptSubmit,omitempty\\\"`\\n    27→\\tPreToolUse       []kiroHookEntry `json:\\\"preToolUse,omitempty\\\"`\\n    28→\\tPostToolUse      []kiroHookEntry `json:\\\"postToolUse,omitempty\\\"`\\n    29→\\tStop             []kiroHookEntry `json:\\\"stop,omitempty\\\"`\\n    30→}\\n    31→\\n    32→// kiroHookEntry represents a single hook command in the config file.\\n    33→type kiroHookEntry struct {\\n    34→\\tCommand string `json:\\\"command\\\"`\\n    35→}\\n    36→\\n    37→// kiroIDEHookFile represents a .kiro/hooks/*.kiro.hook file for the Kiro IDE.\\n    38→// Unlike CLI agent hooks (nested in entire.json), IDE hooks are standalone files\\n    39→// with a when/then structure. The IDE delivers data via environment variables\\n    40→// (e.g., USER_PROMPT) rather than JSON on stdin.\\n    41→type kiroIDEHookFile struct {\\n    42→\\tEnabled     bool            `json:\\\"enabled\\\"`\\n    43→\\tName        string          `json:\\\"name\\\"`\\n    44→\\tDescription string          `json:\\\"description\\\"`\\n    45→\\tVersion     string          `json:\\\"version\\\"`\\n    46→\\tWhen        kiroIDEHookWhen `json:\\\"when\\\"`\\n    47→\\tThen        kiroIDEHookThen `json:\\\"then\\\"`\\n    48→}\\n    49→\\n    50→// kiroIDEHookWhen defines the trigger condition for an IDE hook.\\n    51→type kiroIDEHookWhen struct {\\n    52→\\tType string `json:\\\"type\\\"`\\n    53→}\\n    54→\\n    55→// kiroIDEHookThen defines the action for an IDE hook.\\n    56→type kiroIDEHookThen struct {\\n    57→\\tType    string `json:\\\"type\\\"`\\n    58→\\tCommand string `json:\\\"command\\\"`\\n    59→}\\n    60→\"}]},\"uuid\":\"3278cddc-90d1-4e95-bbaf-4fa2659722db\",\"timestamp\":\"20