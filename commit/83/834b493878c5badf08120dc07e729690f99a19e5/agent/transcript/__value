rror) bool {\\n    38→\\tcombined := out.Stdout + out.Stderr\\n    39→\\tfor _, p := range []string{\\\"overloaded\\\", \\\"rate limit\\\", \\\"503\\\", \\\"529\\\", \\\"throttl\\\"} {\\n    40→\\t\\tif strings.Contains(strings.ToLower(combined), p) {\\n    41→\\t\\t\\treturn true\\n    42→\\t\\t}\\n    43→\\t}\\n    44→\\treturn false\\n    45→}\\n    46→\\n    47→func (k *Kiro) Bootstrap() error {\\n    48→\\t// kiro-cli uses Amazon Q / Builder ID auth.\\n    49→\\t// On CI, ensure auth is available; locally, auth is handled by the desktop app.\\n    50→\\tif os.Getenv(\\\"CI\\\") == \\\"\\\" {\\n    51→\\t\\treturn nil\\n    52→\\t}\\n    53→\\n    54→\\tif isTruthyEnvValue(os.Getenv(\\\"AMAZON_Q_SIGV4\\\")) {\\n    55→\\t\\tif err := validateKiroSIGV4Inputs(\\n    56→\\t\\t\\tos.Getenv(\\\"AWS_REGION\\\"),\\n    57→\\t\\t\\tos.Getenv(\\\"AWS_ACCESS_KEY_ID\\\"),\\n    58→\\t\\t\\tos.Getenv(\\\"AWS_SECRET_ACCESS_KEY\\\"),\\n    59→\\t\\t); err != nil {\\n    60→\\t\\t\\treturn fmt.Errorf(\\\"kiro-cli sigv4 auth check failed: %w\\\", err)\\n    61→\\t\\t}\\n    62→\\t\\treturn nil\\n    63→\\t}\\n    64→\\n    65→\\t// Verify login status — fail fast if not authenticated.\\n    66→\\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\\n    67→\\tdefer cancel()\\n    68→\\tcmd := exec.CommandContext(ctx, \\\"kiro-cli\\\", \\\"whoami\\\", \\\"-f\\\", \\\"json\\\")\\n    69→\\tout, err := cmd.CombinedOutput()\\n    70→\\tif err != nil {\\n    71→\\t\\treturn fmt.Errorf(\\n    72→\\t\\t\\t\\\"kiro-cli auth check failed (run `kiro-cli login --use-device-flow`): %s\\\",\\n    73→\\t\\t\\tstrings.TrimSpace(string(out)),\\n    74→\\t\\t)\\n    75→\\t}\\n    76→\\tif err := validateKiroWhoamiJSON(out); err != nil {\\n    77→\\t\\treturn fmt.Errorf(\\\"kiro-cli auth check failed: %w\\\", err)\\n    78→\\t}\\n    79→\\treturn nil\\n    80→}\\n    81→\\n    82→func isTruthyEnvValue(v string) bool {\\n    83→\\tvalue := strings.TrimSpace(v)\\n    84→\\tif value == \\\"\\\" {\\n    85→\\t\\treturn false\\n    86→\\t}\\n    87→\\tlower := strings.ToLower(value)\\n    88→\\treturn lower != \\\"0\\\" && lower != \\\"false\\\"\\n    89→}\\n    90→\\n    91→func validateKiroSIGV4Inputs(region, accessKeyID, secretAccessKey string) error {\\n    92→\\tif strings.TrimSpace(region) == \\\"\\\" {\\n    93→\\t\\treturn errors.New(\\\"AWS_REGION is required when AMAZON_Q_SIGV4 is enabled\\\")\\n    94→\\t}\\n    95→\\tif strings.TrimSpace(accessKeyID) == \\\"\\\" {\\n    96→\\t\\treturn errors.New(\\\"AWS_ACCESS_KEY_ID is required when AMAZON_Q_SIGV4 is enabled\\\")\\n    97→\\t}\\n    98→\\tif strings.TrimSpace(secretAccessKey) == \\\"\\\" {\\n    99→\\t\\treturn errors.New(\\\"AWS_SECRET_ACCESS_KEY is required when AMAZON_Q_SIGV4 is enabled\\\")\\n   100→\\t}\\n   101→\\treturn nil\\n   102→}\\n   103→\\n   104→func validateKiroWhoamiJSON(out []byte) error {\\n   105→\\tvar response struct {\\n   106→\\t\\tAccount json.RawMessage `json:\\\"account\\\"`\\n   107→\\t}\\n   108→\\n   109→\\tif err := json.Unmarshal(out, &response); err != nil {\\n   110→\\t\\treturn fmt.Errorf(\\\"invalid whoami JSON: %w\\\", err)\\n   111→\\t}\\n   112→\\tif len(response.Account) == 0 {\\n   113→\\t\\treturn errors.New(\\\"account is missing\\\")\\n   114→\\t}\\n   115→\\tif strings.EqualFold(strings.TrimSpace(string(response.Account)), \\\"null\\\") {\\n   116→\\t\\treturn errors.New(\\\"account is null\\\")\\n   117→\\t}\\n   118→\\treturn nil\\n   119→}\\n   120→\\n   121→func (k *Kiro) RunPrompt(ctx context.Context, dir string, prompt string, opts ...Option) (Output, error) {\\n   122→\\tcfg := &runConfig{}\\n   123→\\tfor _, o := range opts {\\n   124→\\t\\to(cfg)\\n   125→\\t}\\n   126→\\n   127→\\t// kiro-cli --no-interactive mode does not fire agent hooks, so we must\\n   128→\\t// use interactive (tmux) mode and send the prompt through the TUI.\\n   129→\\ttimeout := 2 * time.Minute\\n   130→\\tif cfg.PromptTimeout > 0 {\\n   131→\\t\\ttimeout = cfg.PromptTimeout\\n   132→\\t}\\n   133→\\n   134→\\t// --agent entire activates the agent profile that contains our hooks\\n   135→\\targs := []string{\\\"chat\\\", \\\"-a\\\", \\\"--agent\\\", \\\"entire\\\"}\\n   136→\\tif cfg.Model != \\\"\\\" {\\n   137→\\t\\targs = append(args, \\\"--model\\\", cfg.Model)\\n   138→\\t}\\n   139→\\n   140→\\tname := fmt.Sprintf(\\\"kiro-run-%d\\\", time.Now().UnixNano())\\n   141→\\ts, err := NewTmuxSession(name, dir, []string{\\\"ENTIRE_TEST_TTY\\\"}, k.Binary(), args...)\\n   142→\\tif err != nil {\\n   143→\\t\\treturn Output{}, fmt.Errorf(\\\"starting kiro session: %w\\\", err)\\n   144→\\t}\\n   145→\\tdefer func() { _ = s.Close() }()\\n   146→\\n   147→\\t// Wait for initial prompt — kiro-cli TUI shows \\\"!>\\\" in trust-all mode\\n   148→\\tif _, err := s.WaitFor(k.PromptPattern(), 30*time.Second); err != nil {\\n   149→\\t\\tcontent := s.Capture()\\n   150→\\t\\treturn Output{\\n   151→\\t\\t\\tCommand: k.Binary() + \\\" \\\" + strings.Join(args, \\\" \\\"),\\n   152→\\t\\t\\tStderr:  content,\\n   153→\\t\\t}, fmt.Errorf(\\\"waiting for kiro startup: %w\\\", err)\\n   154→\\t}\\n   155→\\ts.stableAtSend = \\\"\\\"\\n   156→\\n   157→\\t// Send the prompt\\n   158→\\tif err := s.Send(prompt); err != nil {\\n   159→\\t\\treturn Output{}, fmt.Errorf(\\\"sending prompt to kiro: %w\\\", err)\\n   160→\\t}\\n   161→\\n   162→\\t// Wait for \\\"Credits:\\\" which only appears after the agent finishes a response.\\n   163→\\t// More reliable than PromptPattern for single-prompt mode since it uniquely\\n   164→\\t// identifies response completion without needing to distinguish echoed input.\\n   165→\\tcontent, err := s.WaitFor(`Credits:`, timeout)\\n   166→\\texitCode := 0\\n   167→\\tif err != nil {\\n   168→\\t\\texitCode = -1\\n   169→\\t}\\n   170→\\n   171→\\treturn Output{\\n   172→\\t\\tCommand:  k.Binary() + \\\" \\\" + strings.Join(args, \\\" \\\") + \\\" \\\" + fmt.Sprintf(\\\"%q\\\", prompt),\\n   173→\\t\\tStdout:   content,\\n   174→\\t\\tExitCode: exitCode,\\n   175→\\t}, err\\n   176→}\\n   177→\\n   178→func (k *Kiro) StartSession(ctx context.Context, dir string) (Session, error) {\\n   179→\\tname := fmt.Sprintf(\\\"kiro-test-%d\\\", time.Now().UnixNano())\\n   180→\\ts, err := NewTmuxSession(name, dir, []string{\\\"ENTIRE_TEST_TTY\\\"}, k.Binary(), \\\"chat\\\", \\\"-a\\\", \\\"--agent\\\", \\\"entire\\\")\\n   181→\\tif err != nil {\\n   182→\\t\\treturn nil, err\\n   183→\\t}\\n   184→\\n   185→\\t// Wait for the prompt indicator — kiro-cli TUI shows \\\"!>\\\" in trust-all mode\\n   186→\\tif _, err := s.WaitFor(k.PromptPattern(), 15*time.Second); err != nil {\\n   187→\\t\\t_ = s.Close()\\n   188→\\t\\treturn nil, fmt.Errorf(\\\"waiting for kiro startup prompt: %w\\\", err)\\n   189→\\t}\\n   190→\\ts.stableAtSend = \\\"\\\"\\n   191→\\n   192→\\treturn &KiroSession{TmuxSession: s}, nil\\n   193→}\\n   194→\\n   195→// KiroSession wraps TmuxSession for Kiro's interactive sessions.\\n   196→// After Send, WaitFor uses an end-of-line pattern to avoid matching\\n   197→// the echoed \\\"!>\\\" prompt in the input line.\\n   198→type KiroSession struct {\\n   199→\\t*TmuxSession\\n   200→}\\n   201→\\n   202→func (s *KiroSession) WaitFor(pattern string, timeout time.Duration) (string, error) {\\n   203→\\t// For initial waits (before any Send), use the original pattern (\\\"!>\\\").\\n   204→\\tif s.stableAtSend == \\\"\\\" {\\n   205→\\t\\treturn s.TmuxSession.WaitFor(pattern, timeout)\\n   206→\\t}\\n   207→\\t// After a Send, the echoed input line contains \\\"!>\\\" with text after it\\n   208→\\t// (e.g., \\\"[entire] 3% !> now commit it\\\"). The real prompt has \\\"!>\\\" at\\n   209→\\t// end-of-line (e.g., \\\"[entire] 3% !>\\\"). Match only the latter.\\n   210→\\treturn s.TmuxSession.WaitFor(`(?m)!>\\\\s*$`, timeout)\\n   211→}\\n   212→\"}]},\"uuid\":\"b3be8198-2d15-4572-a8fc-53b92ab4dc76\",\"timestamp\":\"2026-03-03T21:28:02.369Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a3065ba1879174194\"},\"toolUseID\":\"agent_msg_01BaQ1832M6d2CsCXHWx2VQm\",\"parentToolUseID\":\"toolu_01CsWwmqfd9QsiE1zMaUHxqk\",\"uuid\":\"ebac6290-ceef-4379-ad77-461b49cbeee1\",\"timestamp\":\"2026-03-03T21:28:02.371Z\"}\n{\"parentUuid\":\"ebac6290-ceef-4379-ad77-461b49cbeee1\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"4ab3ddd7-2bb2-4d33-bbe6-7ee25ce1f55e\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"glittery-waddling-parrot\",\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"PostToolUse\",\"hookName\":\"PostToolUse:Agent\",\"command\":\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code post-task\"},\"parentToolUseID\":\"toolu_01CsWwmqfd9QsiE1zMaUHxqk\",\"toolUseID\":\"toolu_01CsWwmqfd9QsiE1zMaUHxqk\",\"timestamp\":\"2026-03-03T21:29:59.500Z\",\"uuid\":\"e561f841-9b23-4edf-a528-13e9ce826fd7\"}\n{\"parentUuid\":\"4de56981-dc0c-458d-af75-d9029bedbc2a\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"4ab3ddd7-2bb2-4d33-bbe6-7ee25ce1f55e\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"glittery-waddling-parrot\",\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01CsWwmqfd9QsiE1zMaUHxqk\",\"type\":\"tool_result\",\"content\":[{\"type\":\"text\",\"text\":\"Now I have a complete understanding of the codebase. Let me present the implementation plan.\\n\\n---\\n\\n## Implementation Plan: `kiroAgent.trustedCommands` Support in Kiro Agent\\n\\n### Problem Summary\\n\\nWhen `entire enable` installs Kiro IDE hooks (`.kiro/hooks/*.kiro.hook`), the hooks use `\\\"then\\\": {\\\"type\\\": \\\"runCommand\\\", \\\"command\\\": \\\"entire hooks kiro ...\\\"}`. The Kiro IDE prompts the user for approval before executing each hook command because `entire hooks kiro *` is not in the trusted commands list. The fix is to auto-configure `kiroAgent.trustedCommands` in `.vscode/settings.json` during `InstallHooks` and clean it up during `UninstallHooks`.\\n\\n### Design Decisions\\n\\n**1. Trust pattern**\\n\\n- Production: `\\\"entire hooks kiro *\\\"` -- narrow, only trusts the specific subcommand tree that our hooks actually use. Using `\\\"entire *\\\"` would be too broad and could auto-approve future Entire CLI commands that the user might want to review.\\n- Local dev: `\\\"go run ${KIRO_PROJECT_DIR}/cmd/entire/main.go hooks kiro *\\\"` -- mirrors the production pattern using the local dev command prefix.\\n\\nRationale: The hooks use commands like `entire hooks kiro user-prompt-submit`, `entire hooks kiro stop`, etc. The pattern `\\\"entire hooks kiro *\\\"` covers all of these via Kiro's prefix matching. This follows the principle of least privilege.\\n\\n**2. File management strategy**\\n\\nUse the same `map[string]json.RawMessage` round-trip pattern from the Claude Code agent's `hooks.go`. This is the established pattern in this codebase for reading, modifying a single key, and writing back a JSON file while preserving all unknown fields.\\n\\nSpecifically:\\n- If `.vscode/settings.json` does not exist, create it with only our key\\n- If it exists, round-trip all existing keys, only modifying `kiroAgent.trustedCommands`\\n- When reading the existing array, check if our pattern is already present before appending (idempotency)\\n- On uninstall, remove only our specific patterns from the array; remove the key if the array becomes empty; do NOT remove `.vscode/settings.json` even if empty (other tools may expect it to exist)\\n\\n**3. Integration into existing flow**\\n\\n- `InstallHooks`: Add a new step after `installIDEHooks()` that calls `installTrustedCommands(worktreeRoot, cmdPrefix)`.\\n- `UninstallHooks`: Add a new step after removing IDE hook files that calls `uninstallTrustedCommands(worktreeRoot)`.\\n- Idempotency check in `InstallHooks`: Add `trustedCommandsPresent(worktreeRoot, localDev)` to the `!force` early-return check alongside `allHooksPresent` and `allIDEHooksPresent`.\\n- `AreHooksInstalled`: No change needed. The trusted commands are a supporting configuration, not a hook themselves. `AreHooksInstalled` should only check for actual hooks.\\n\\n**4. Count**\\n\\nThe trusted commands configuration should NOT count toward the hook count returned by `InstallHooks`. It is a supporting configuration that enables the hooks to run, not a hook itself. The return value `len(k.HookNames()) + ideCount` stays the same. However, if trusted commands were the only thing that needed updating (hooks already present, trusted commands missing), we still need to proceed with the full install. The current early-return logic checks `allHooksPresent && allIDEHooksPresent` -- we need to add `&& trustedCommandsPresent` to this condition.\\n\\n**5. Uninstall behavior**\\n\\n- Remove only our specific pattern(s) from the `kiroAgent.trustedCommands` array\\n- If the array becomes empty, remove the `kiroAgent.trustedCommands` key entirely\\n- Never remove `.vscode/settings.json` itself, even if it becomes `{}`\\n- Do NOT remove `.vscode/` directory\\n\\n### New Constants and Functions\\n\\nAll new code goes in `/Users/alisha/Projects/wt/kiro-oneshot/cmd/entire/cli/agent/kiro/hooks.go`.\\n\\n#### Constants\\n\\n```go\\n// vscodeSettingsDir is the directory for VS Code workspace settings.\\nconst vscodeSettingsDir = \\\".vscode\\\"\\n\\n// vscodeSettingsFile is the VS Code workspace settings file name.\\nconst vscodeSettingsFile = \\\"settings.json\\\"\\n\\n// trustedCommandsKey is the VS Code settings key for Kiro trusted commands.\\nconst trustedCommandsKey = \\\"kiroAgent.trustedCommands\\\"\\n\\n// prodTrustedPattern is the trusted command pattern for production builds.\\nconst prodTrustedPattern = \\\"entire hooks kiro *\\\"\\n```\\n\\n#### Function: `trustedCommandPattern`\\n\\n```go\\n// trustedCommandPattern returns the trusted command pattern for the current mode.\\nfunc trustedCommandPattern(localDev bool) string {\\n    if localDev {\\n        return localDevCmdPrefix + \\\"hooks kiro *\\\"\\n    }\\n    return prodTrustedPattern\\n}\\n```\\n\\n#### Function: `trustedCommandPatterns`\\n\\n```go\\n// trustedCommandPatterns returns all known trusted command patterns (both prod and local dev).\\n// Used by uninstall to remove any pattern we may have previously installed.\\nfunc trustedCommandPatterns() []string {\\n    return []string{\\n        prodTrustedPattern,\\n        localDevCmdPrefix + \\\"hooks kiro *\\\",\\n    }\\n}\\n```\\n\\n#### Function: `installTrustedCommands`\\n\\n```go\\n// installTrustedCommands adds the Entire hook command pattern to\\n// kiroAgent.trustedCommands in .vscode/settings.json.\\n// Uses read-modify-write to preserve existing settings.\\n// Returns true if the file was modified, false if the pattern was already present.\\nfunc installTrustedCommands(worktreeRoot string, localDev bool) (bool, error) {\\n    settingsPath := filepath.Join(worktreeRoot, vscodeSettingsDir, vscodeSettingsFile)\\n    pattern := trustedCommandPattern(localDev)\\n\\n    // Read existing settings if they exist\\n    var rawSettings map[string]json.RawMessage\\n    existingData, readErr := os.ReadFile(settingsPath)\\n    if readErr == nil {\\n        if err := json.Unmarshal(existingData, &rawSettings); err != nil {\\n            return false, fmt.Errorf(\\\"failed to parse .vscode/settings.json: %w\\\", err)\\n        }\\n    } else {\\n        rawSettings = make(map[string]json.RawMessage)\\n    }\\n\\n    // Parse existing trusted commands\\n    var trustedCmds []string\\n    if existing, ok := rawSettings[trustedCommandsKey]; ok {\\n        if err := json.Unmarshal(existing, &trustedCmds); err != nil {\\n            return false, fmt.Errorf(\\\"failed to parse %s: %w\\\", trustedCommandsKey, err)\\n        }\\n    }\\n\\n    // Check if pattern already present\\n    for _, cmd := range trustedCmds {\\n        if cmd == pattern {\\n            return false, nil // Already present\\n        }\\n    }\\n\\n    // Append our pattern\\n    trustedCmds = append(trustedCmds, pattern)\\n    trustedJSON, err := json.Marshal(trustedCmds)\\n    if err != nil {\\n        return false, fmt.Errorf(\\\"failed to marshal %s: %w\\\", trustedCommandsKey, err)\\n    }\\n    rawSettings[trustedCommandsKey] = trustedJSON\\n\\n    // Write back\\n    if err := os.MkdirAll(filepath.Dir(settingsPath), 0o750); err != nil {\\n        return false, fmt.Errorf(\\\"failed to create .vscode directory: %w\\\", err)\\n    }\\n\\n    output, err := jsonutil.MarshalIndentWithNewline(rawSettings, \\\"\\\", \\\"  \\\")\\n    if err != nil {\\n        return false, fmt.Errorf(\\\"failed to marshal .vscode/settings.json: %w\\\", err)\\n    }\\n\\n    if err := os.WriteFile(settingsPath, output, 0o600); err != nil {\\n        return false, fmt.Errorf(\\\"failed to write .vscode/settings.json: %w\\\", err)\\n    }\\n\\n    return true, nil\\n}\\n```\\n\\n#### Function: `uninstallTrustedCommands`\\n\\n```go\\n// uninstallTrustedCommands removes Entire hook patterns from\\n// kiroAgent.trustedCommands in .vscode/settings.json.\\n// Removes the key entirely if the array becomes empty.\\nfunc uninstallTrustedCommands(worktreeRoot string) error {\\n    settingsPath := filepath.Join(worktreeRoot, vscodeSettingsDir, vscodeSettingsFile)\\n\\n    existingData, err := os.ReadFile(settingsPath)\\n    if err != nil {\\n        return nil // No settings file, nothing to uninstall\\n    }\\n\\n    var rawSettings map[string]json.RawMessage\\n    if err := json.Unmarshal(existingData, &rawSettings); err != nil {\\n        return fmt.Errorf(\\\"failed to parse .vscode/settings.json: %w\\\", err)\\n    }\\n\\n    existing, ok := rawSettings[trustedCommandsKey]\\n    if !ok {\\n        return nil // Key not present, nothing to remove\\n    }\\n\\n    var trustedCmds []string\\n    if err := json.Unmarshal(existing, &trustedCmds); err != nil {\\n        return fmt.Errorf(\\\"failed to parse %s: %w\\\", trustedCommandsKey, err)\\n    }\\n\\n    // Build set of patterns to remove\\n    removeSet := make(map[string]bool)\\n    for _, p := range trustedCommandPatterns() {\\n        removeSet[p] = true\\n    }\\n\\n    // Filter out our patterns\\n    filtered := make([]string, 0, len(trustedCmds))\\n    for _, cmd := range trustedCmds {\\n        if !removeSet[cmd] {\\n            filtered = append(filtered, cmd)\\n        }\\n    }\\n\\n    // If nothing changed, skip write\\n    if len(filtered) == len(trustedCmds) {\\n        return nil\\n    }\\n\\n    // Update or remove the key\\n    if len(filtered) > 0 {\\n        filteredJSON, err := json.Marshal(filtered)\\n        if err != nil {\\n            return fmt.Errorf(\\\"failed to marshal %s: %w\\\", trustedCommandsKey, err)\\n        }\\n        rawSettings[trustedCommandsKey] = filteredJSON\\n    } else {\\n        delete(rawSettings, trustedCommandsKey)\\n    }\\n\\n    // Write back\\n    output, err := jsonutil.MarshalIndentWithNewline(rawSettings, \\\"\\\", \\\"  \\\")\\n    if err != nil {\\n        return fmt.Errorf(\\\"failed to marshal .vscode/settings.json: %w\\\", err)\\n    }\\n\\n    if err := os.WriteFile(settingsPath, output, 0o600); err != nil {\\n        return fmt.Errorf(\\\"failed to write .vscode/settings.json: %w\\\", err)\\n    }\\n\\n    return nil\\n}\\n```\\n\\n#### Function: `trustedCommandsPresent`\\n\\n```go\\n// trustedCommandsPresent checks if the trusted command pattern is already\\n// configured in .vscode/settings.json for the given mode.\\nfunc trustedCommandsPresent(worktreeRoot string, localDev bool) bool {\\n    settingsPath := filepath.Join(worktreeRoot, vscodeSettingsDir, vscodeSettingsFile)\\n    pattern := trustedCommandPattern(localDev)\\n\\n    data, err := os.ReadFile(settingsPath)\\n    if err != nil {\\n        return false\\n    }\\n\\n    var rawSettings map[string]json.RawMessage\\n    if err := json.Unmarshal(data, &rawSettings); err != nil {\\n        return false\\n    }\\n\\n    existing, ok := rawSettings[trustedCommandsKey]\\n    if !ok {\\n        return false\\n    }\\n\\n    var trustedCmds []string\\n    if err := json.Unmarshal(existing, &trustedCmds); err != nil {\\n        return false\\n    }\\n\\n    for _, cmd := range trustedCmds {\\n        if cmd == pattern {\\n            return true\\n        }\\n    }\\n    return false\\n}\\n```\\n\\n### Modifications to Existing Functions\\n\\n#### `InstallHooks` (lines 66-128 in hooks.go)\\n\\nTwo changes:\\n\\n1. Add `trustedCommandsPresent` to the idempotency check on line 78:\\n\\n```go\\n// Before (line 78):\\nif json.Unmarshal(existing, &file) == nil && allHooksPresent(file.Hooks, localDev) && allIDEHooksPresent(worktreeRoot, localDev) {\\n\\n// After:\\nif json.Unmarshal(existing, &file) == nil && allHooksPresent(file.Hooks, localDev) && allIDEHooksPresent(worktreeRoot, localDev) && trustedCommandsPresent(worktreeRoot, localDev) {\\n```\\n\\n2. Add `installTrustedCommands` call after `installIDEHooks`, between lines 125 and 127:\\n\\n```go\\n    // Install IDE hooks (.kiro/hooks/*.kiro.hook)\\n    ideCount, err := installIDEHooks(worktreeRoot, cmdPrefix)\\n    if err != nil {\\n        return 0, fmt.Errorf(\\\"failed to install IDE hooks: %w\\\", err)\\n    }\\n\\n    // Configure trusted commands in .vscode/settings.json so the\\n    // Kiro IDE auto-approves our hook commands without prompting.\\n    if _, err := installTrustedCommands(worktreeRoot, localDev); err != nil {\\n        return 0, fmt.Errorf(\\\"failed to configure trusted commands: %w\\\", err)\\n    }\\n\\n    return len(k.HookNames()) + ideCount, nil\\n```\\n\\n#### `UninstallHooks` (lines 131-152 in hooks.go)\\n\\nAdd `uninstallTrustedCommands` call after removing IDE hook files, before the final return:\\n\\n```go\\n    // Remove IDE hook files\\n    for _, def := range ideHookDefs {\\n        idePath := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir, def.Filename+ideHookFileSuffix)\\n        if err := os.Remove(idePath); err != nil && !os.IsNotExist(err) {\\n            return fmt.Errorf(\\\"failed to remove IDE hook %s: %w\\\", def.Filename, err)\\n        }\\n    }\\n\\n    // Remove trusted commands from .vscode/settings.json\\n    if err := uninstallTrustedCommands(worktreeRoot); err != nil {\\n        return fmt.Errorf(\\\"failed to remove trusted commands: %w\\\", err)\\n    }\\n\\n    return nil\\n```\\n\\n### Test Cases\\n\\nAll tests go in `/Users/alisha/Projects/wt/kiro-oneshot/cmd/entire/cli/agent/kiro/hooks_test.go`.\\n\\nNote: Tests that call `installTrustedCommands`/`uninstallTrustedCommands` use `t.Chdir` so they cannot be parallelized.\\n\\n```go\\n// --- Trusted Commands Tests ---\\n\\nfunc TestInstallHooks_ConfiguresTrustedCommands(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    ag := &KiroAgent{}\\n    _, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"InstallHooks() error = %v\\\", err)\\n    }\\n\\n    // Verify .vscode/settings.json was created with trustedCommands\\n    settingsPath := filepath.Join(tempDir, \\\".vscode\\\", \\\"settings.json\\\")\\n    data, err := os.ReadFile(settingsPath)\\n    if err != nil {\\n        t.Fatalf(\\\"failed to read settings.json: %v\\\", err)\\n    }\\n\\n    var settings map[string]json.RawMessage\\n    if err := json.Unmarshal(data, &settings); err != nil {\\n        t.Fatalf(\\\"failed to parse settings.json: %v\\\", err)\\n    }\\n\\n    var trustedCmds []string\\n    if err := json.Unmarshal(settings[trustedCommandsKey], &trustedCmds); err != nil {\\n        t.Fatalf(\\\"failed to parse trustedCommands: %v\\\", err)\\n    }\\n\\n    if len(trustedCmds) != 1 || trustedCmds[0] != prodTrustedPattern {\\n        t.Errorf(\\\"trustedCommands = %v, want [%q]\\\", trustedCmds, prodTrustedPattern)\\n    }\\n}\\n\\nfunc TestInstallHooks_TrustedCommands_LocalDev(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    ag := &KiroAgent{}\\n    _, err := ag.InstallHooks(context.Background(), true, false)\\n    if err != nil {\\n        t.Fatalf(\\\"InstallHooks() error = %v\\\", err)\\n    }\\n\\n    settingsPath := filepath.Join(tempDir, \\\".vscode\\\", \\\"settings.json\\\")\\n    data, err := os.ReadFile(settingsPath)\\n    if err != nil {\\n        t.Fatalf(\\\"failed to read settings.json: %v\\\", err)\\n    }\\n\\n    var settings map[string]json.RawMessage\\n    if err := json.Unmarshal(data, &settings); err != nil {\\n        t.Fatalf(\\\"failed to parse settings.json: %v\\\", err)\\n    }\\n\\n    var trustedCmds []string\\n    if err := json.Unmarshal(settings[trustedCommandsKey], &trustedCmds); err != nil {\\n        t.Fatalf(\\\"failed to parse trustedCommands: %v\\\", err)\\n    }\\n\\n    expectedPattern := localDevCmdPrefix + \\\"hooks kiro *\\\"\\n    if len(trustedCmds) != 1 || trustedCmds[0] != expectedPattern {\\n        t.Errorf(\\\"trustedCommands = %v, want [%q]\\\", trustedCmds, expectedPattern)\\n    }\\n}\\n\\nfunc TestInstallHooks_TrustedCommands_PreservesExistingSettings(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    // Pre-create .vscode/settings.json with other settings\\n    vsDir := filepath.Join(tempDir, \\\".vscode\\\")\\n    if err := os.MkdirAll(vsDir, 0o750); err != nil {\\n        t.Fatalf(\\\"failed to create .vscode: %v\\\", err)\\n    }\\n    existing := `{\\n  \\\"editor.fontSize\\\": 14,\\n  \\\"kiroAgent.trustedCommands\\\": [\\\"npm test *\\\"],\\n  \\\"other.setting\\\": true\\n}\\n`\\n    if err := os.WriteFile(filepath.Join(vsDir, \\\"settings.json\\\"), []byte(existing), 0o600); err != nil {\\n        t.Fatalf(\\\"failed to write settings.json: %v\\\", err)\\n    }\\n\\n    ag := &KiroAgent{}\\n    _, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"InstallHooks() error = %v\\\", err)\\n    }\\n\\n    data, err := os.ReadFile(filepath.Join(vsDir, \\\"settings.json\\\"))\\n    if err != nil {\\n        t.Fatalf(\\\"failed to read settings.json: %v\\\", err)\\n    }\\n\\n    var settings map[string]json.RawMessage\\n    if err := json.Unmarshal(data, &settings); err != nil {\\n        t.Fatalf(\\\"failed to parse settings.json: %v\\\", err)\\n    }\\n\\n    // Verify existing settings are preserved\\n    if _, ok := settings[\\\"editor.fontSize\\\"]; !ok {\\n        t.Error(\\\"editor.fontSize should be preserved\\\")\\n    }\\n    if _, ok := settings[\\\"other.setting\\\"]; !ok {\\n        t.Error(\\\"other.setting should be preserved\\\")\\n    }\\n\\n    // Verify trustedCommands includes both existing and new\\n    var trustedCmds []string\\n    if err := json.Unmarshal(settings[trustedCommandsKey], &trustedCmds); err != nil {\\n        t.Fatalf(\\\"failed to parse trustedCommands: %v\\\", err)\\n    }\\n\\n    if len(trustedCmds) != 2 {\\n        t.Fatalf(\\\"trustedCommands length = %d, want 2\\\", len(trustedCmds))\\n    }\\n    if trustedCmds[0] != \\\"npm test *\\\" {\\n        t.Errorf(\\\"trustedCommands[0] = %q, want %q\\\", trustedCmds[0], \\\"npm test *\\\")\\n    }\\n    if trustedCmds[1] != prodTrustedPattern {\\n        t.Errorf(\\\"trustedCommands[1] = %q, want %q\\\", trustedCmds[1], prodTrustedPattern)\\n    }\\n}\\n\\nfunc TestInstallHooks_TrustedCommands_Idempotent(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    ag := &KiroAgent{}\\n\\n    // First install\\n    _, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"first InstallHooks() error = %v\\\", err)\\n    }\\n\\n    // Second install should be idempotent (returns 0)\\n    count, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"second InstallHooks() error = %v\\\", err)\\n    }\\n    if count != 0 {\\n        t.Errorf(\\\"second InstallHooks() count = %d, want 0 (idempotent)\\\", count)\\n    }\\n\\n    // Verify pattern is not duplicated\\n    settingsPath := filepath.Join(tempDir, \\\".vscode\\\", \\\"settings.json\\\")\\n    data, err := os.ReadFile(settingsPath)\\n    if err != nil {\\n        t.Fatalf(\\\"failed to read settings.json: %v\\\", err)\\n    }\\n\\n    var settings map[string]json.RawMessage\\n    if err := json.Unmarshal(data, &settings); err != nil {\\n        t.Fatalf(\\\"failed to parse settings.json: %v\\\", err)\\n    }\\n\\n    var trustedCmds []string\\n    if err := json.Unmarshal(settings[trustedCommandsKey], &trustedCmds); err != nil {\\n        t.Fatalf(\\\"failed to parse trustedCommands: %v\\\", err)\\n    }\\n\\n    if len(trustedCmds) != 1 {\\n        t.Errorf(\\\"trustedCommands length = %d, want 1 (no duplicates)\\\", len(trustedCmds))\\n    }\\n}\\n\\nfunc TestInstallHooks_TrustedCommands_ReinstallWhenMissing(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    ag := &KiroAgent{}\\n\\n    // Install hooks\\n    _, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"first InstallHooks() error = %v\\\", err)\\n    }\\n\\n    // Delete .vscode/settings.json to simulate missing trusted commands\\n    os.Remove(filepath.Join(tempDir, \\\".vscode\\\", \\\"settings.json\\\"))\\n\\n    // Reinstall should detect missing trusted commands and reinstall\\n    count, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"second InstallHooks() error = %v\\\", err)\\n    }\\n    // count should be >0 because the idempotency check now includes trustedCommandsPresent\\n    if count == 0 {\\n        t.Error(\\\"expected non-zero count when trusted commands are missing\\\")\\n    }\\n\\n    // Verify trusted commands were restored\\n    if !trustedCommandsPresent(tempDir, false) {\\n        t.Error(\\\"trusted commands should be present after reinstall\\\")\\n    }\\n}\\n\\nfunc TestUninstallHooks_RemovesTrustedCommands(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    ag := &KiroAgent{}\\n\\n    // Install first\\n    _, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"InstallHooks() error = %v\\\", err)\\n    }\\n\\n    // Verify trusted commands exist\\n    if !trustedCommandsPresent(tempDir, false) {\\n        t.Fatal(\\\"trusted commands should be present after install\\\")\\n    }\\n\\n    // Uninstall\\n    if err := ag.UninstallHooks(context.Background()); err != nil {\\n        t.Fatalf(\\\"UninstallHooks() error = %v\\\", err)\\n    }\\n\\n    // Verify trusted commands are removed\\n    if trustedCommandsPresent(tempDir, false) {\\n        t.Error(\\\"trusted commands should be removed after uninstall\\\")\\n    }\\n}\\n\\nfunc TestUninstallHooks_PreservesOtherTrustedCommands(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    ag := &KiroAgent{}\\n\\n    // Install hooks (creates .vscode/settings.json with our pattern)\\n    _, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"InstallHooks() error = %v\\\", err)\\n    }\\n\\n    // Add another trusted command manually\\n    settingsPath := filepath.Join(tempDir, \\\".vscode\\\", \\\"settings.json\\\")\\n    data, err := os.ReadFile(settingsPath)\\n    if err != nil {\\n        t.Fatalf(\\\"failed to read settings.json: %v\\\", err)\\n    }\\n    var rawSettings map[string]json.RawMessage\\n    json.Unmarshal(data, &rawSettings)\\n    rawSettings[trustedCommandsKey] = json.RawMessage(`[\\\"npm test *\\\", \\\"entire hooks kiro *\\\"]`)\\n    output, _ := json.MarshalIndent(rawSettings, \\\"\\\", \\\"  \\\")\\n    os.WriteFile(settingsPath, output, 0o600)\\n\\n    // Uninstall\\n    if err := ag.UninstallHooks(context.Background()); err != nil {\\n        t.Fatalf(\\\"UninstallHooks() error = %v\\\", err)\\n    }\\n\\n    // Read back and verify \\\"npm test *\\\" is preserved, our pattern removed\\n    data, err = os.ReadFile(settingsPath)\\n    if err != nil {\\n        t.Fatalf(\\\"settings.json should still exist: %v\\\", err)\\n    }\\n    json.Unmarshal(data, &rawSettings)\\n    var remaining []string\\n    json.Unmarshal(rawSettings[trustedCommandsKey], &remaining)\\n\\n    if len(remaining) != 1 || remaining[0] != \\\"npm test *\\\" {\\n        t.Errorf(\\\"trustedCommands = %v, want [\\\\\\\"npm test *\\\\\\\"]\\\", remaining)\\n    }\\n}\\n\\nfunc TestUninstallHooks_RemovesBothProdAndLocalDevPatterns(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    // Create settings with both prod and localdev patterns\\n    vsDir := filepath.Join(tempDir, \\\".vscode\\\")\\n    os.MkdirAll(vsDir, 0o750)\\n    localDevPattern := localDevCmdPrefix + \\\"hooks kiro *\\\"\\n    both, _ := json.Marshal([]string{prodTrustedPattern, localDevPattern, \\\"npm test *\\\"})\\n    settings, _ := json.MarshalIndent(map[string]json.RawMessage{\\n        trustedCommandsKey: both,\\n    }, \\\"\\\", \\\"  \\\")\\n    os.WriteFile(filepath.Join(vsDir, \\\"settings.json\\\"), settings, 0o600)\\n\\n    ag := &KiroAgent{}\\n    if err := ag.UninstallHooks(context.Background()); err != nil {\\n        t.Fatalf(\\\"UninstallHooks() error = %v\\\", err)\\n    }\\n\\n    data, _ := os.ReadFile(filepath.Join(vsDir, \\\"settings.json\\\"))\\n    var rawSettings map[string]json.RawMessage\\n    json.Unmarshal(data, &rawSettings)\\n    var remaining []string\\n    json.Unmarshal(rawSettings[trustedCommandsKey], &remaining)\\n\\n    if len(remaining) != 1 || remaining[0] != \\\"npm test *\\\" {\\n        t.Errorf(\\\"trustedCommands = %v, want [\\\\\\\"npm test *\\\\\\\"]\\\", remaining)\\n    }\\n}\\n\\nfunc TestUninstallHooks_RemovesKeyWhenEmpty(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    ag := &KiroAgent{}\\n\\n    // Install then uninstall\\n    _, _ = ag.InstallHooks(context.Background(), false, false)\\n    _ = ag.UninstallHooks(context.Background())\\n\\n    settingsPath := filepath.Join(tempDir, \\\".vscode\\\", \\\"settings.json\\\")\\n    data, err := os.ReadFile(settingsPath)\\n    if err != nil {\\n        t.Fatalf(\\\"settings.json should still exist: %v\\\", err)\\n    }\\n\\n    var rawSettings map[string]json.RawMessage\\n    json.Unmarshal(data, &rawSettings)\\n\\n    if _, exists := rawSettings[trustedCommandsKey]; exists {\\n        t.Error(\\\"trustedCommands key should be removed when array is empty\\\")\\n    }\\n}\\n\\nfunc TestUninstallHooks_NoSettingsFile(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    ag := &KiroAgent{}\\n    // Uninstall with no .vscode/settings.json should not error\\n    err := ag.UninstallHooks(context.Background())\\n    if err != nil {\\n        t.Fatalf(\\\"UninstallHooks() should not error when no settings.json exists: %v\\\", err)\\n    }\\n}\\n\\n// --- Internal helper tests ---\\n\\nfunc TestTrustedCommandPattern(t *testing.T) {\\n    t.Parallel()\\n\\n    tests := []struct {\\n        name     string\\n        localDev bool\\n        want     string\\n    }{\\n        {\\\"production\\\", false, \\\"entire hooks kiro *\\\"},\\n        {\\\"local dev\\\", true, localDevCmdPrefix + \\\"hooks kiro *\\\"},\\n    }\\n    for _, tc := range tests {\\n        t.Run(tc.name, func(t *testing.T) {\\n            t.Parallel()\\n            got := trustedCommandPattern(tc.localDev)\\n            if got != tc.want {\\n                t.Errorf(\\\"trustedCommandPattern(%v) = %q, want %q\\\", tc.localDev, got, tc.want)\\n            }\\n        })\\n    }\\n}\\n\\nfunc TestTrustedCommandsPresent(t *testing.T) {\\n    t.Parallel()\\n\\n    tests := []struct {\\n        name     string\\n        content 