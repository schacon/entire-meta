Input struct {\\n    96→\\tSessionID      string          `json:\\\"session_id\\\"`\\n    97→\\tTranscriptPath string          `json:\\\"transcript_path\\\"`\\n    98→\\tToolName       string          `json:\\\"tool_name\\\"`\\n    99→\\tToolUseID      string          `json:\\\"tool_use_id\\\"`\\n   100→\\tToolInput      json.RawMessage `json:\\\"tool_input\\\"`\\n   101→\\tToolResponse   json.RawMessage `json:\\\"tool_response\\\"`\\n   102→}\\n   103→\\n   104→// parseSubagentCheckpointHookInput parses PostToolUse hook input for subagent checkpoints\\n   105→func parseSubagentCheckpointHookInput(r io.Reader) (*SubagentCheckpointHookInput, error) {\\n   106→\\tdata, err := io.ReadAll(r)\\n   107→\\tif err != nil {\\n   108→\\t\\treturn nil, fmt.Errorf(\\\"failed to read input: %w\\\", err)\\n   109→\\t}\\n   110→\\n   111→\\tif len(data) == 0 {\\n   112→\\t\\treturn nil, errors.New(\\\"empty input\\\")\\n   113→\\t}\\n   114→\\n   115→\\tvar input SubagentCheckpointHookInput\\n   116→\\tif err := json.Unmarshal(data, &input); err != nil {\\n   117→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse JSON: %w\\\", err)\\n   118→\\t}\\n   119→\\n   120→\\treturn &input, nil\\n   121→}\\n   122→\\n   123→// taskToolInput represents the tool_input structure for the Task tool.\\n   124→// Used to extract subagent_type and description for descriptive commit messages.\\n   125→type taskToolInput struct {\\n   126→\\tSubagentType string `json:\\\"subagent_type\\\"`\\n   127→\\tDescription  string `json:\\\"description\\\"`\\n   128→}\\n   129→\\n   130→// ParseSubagentTypeAndDescription extracts subagent_type and description from Task tool_input.\\n   131→// Returns empty strings if parsing fails or fields are not present.\\n   132→func ParseSubagentTypeAndDescription(toolInput json.RawMessage) (agentType, description string) {\\n   133→\\tif len(toolInput) == 0 {\\n   134→\\t\\treturn \\\"\\\", \\\"\\\"\\n   135→\\t}\\n   136→\\n   137→\\tvar input taskToolInput\\n   138→\\tif err := json.Unmarshal(toolInput, &input); err != nil {\\n   139→\\t\\treturn \\\"\\\", \\\"\\\"\\n   140→\\t}\\n   141→\\n   142→\\treturn input.SubagentType, input.Description\\n   143→}\\n   144→\\n   145→// todoWriteToolInput represents the tool_input structure for the TodoWrite tool.\\n   146→// Used to extract the todos array which is then passed to strategy.ExtractInProgressTodo.\\n   147→type todoWriteToolInput struct {\\n   148→\\tTodos json.RawMessage `json:\\\"todos\\\"`\\n   149→}\\n   150→\\n   151→// ExtractTodoContentFromToolInput extracts the content of the in-progress todo item from TodoWrite tool_input.\\n   152→// Falls back to the first pending item if no in-progress item is found.\\n   153→// Returns empty string if no suitable item is found or JSON is invalid.\\n   154→//\\n   155→// This function unwraps the outer tool_input object to extract the todos array,\\n   156→// then delegates to strategy.ExtractInProgressTodo for the actual parsing logic.\\n   157→func ExtractTodoContentFromToolInput(toolInput json.RawMessage) string {\\n   158→\\tif len(toolInput) == 0 {\\n   159→\\t\\treturn \\\"\\\"\\n   160→\\t}\\n   161→\\n   162→\\t// First extract the todos array from tool_input\\n   163→\\tvar input todoWriteToolInput\\n   164→\\tif err := json.Unmarshal(toolInput, &input); err != nil {\\n   165→\\t\\treturn \\\"\\\"\\n   166→\\t}\\n   167→\\n   168→\\t// Delegate to strategy package for the actual extraction logic\\n   169→\\treturn strategy.ExtractInProgressTodo(input.Todos)\\n   170→}\\n   171→\\n   172→// ExtractLastCompletedTodoFromToolInput extracts the content of the last completed todo item.\\n   173→// In PostToolUse[TodoWrite], the tool_input contains the NEW todo list where the\\n   174→// just-finished work is marked as \\\"completed\\\". The last completed item represents\\n   175→// the work that was just done.\\n   176→//\\n   177→// Returns empty string if no completed items exist or JSON is invalid.\\n   178→func ExtractLastCompletedTodoFromToolInput(toolInput json.RawMessage) string {\\n   179→\\tif len(toolInput) == 0 {\\n   180→\\t\\treturn \\\"\\\"\\n   181→\\t}\\n   182→\\n   183→\\t// First extract the todos array from tool_input\\n   184→\\tvar input todoWriteToolInput\\n   185→\\tif err := json.Unmarshal(toolInput, &input); err != nil {\\n   186→\\t\\treturn \\\"\\\"\\n   187→\\t}\\n   188→\\n   189→\\t// Delegate to strategy package for the actual extraction logic\\n   190→\\treturn strategy.ExtractLastCompletedTodo(input.Todos)\\n   191→}\\n   192→\\n   193→// CountTodosFromToolInput returns the number of todo items in the TodoWrite tool_input.\\n   194→// Returns 0 if the JSON is invalid or empty.\\n   195→//\\n   196→// This function unwraps the outer tool_input object to extract the todos array,\\n   197→// then delegates to strategy.CountTodos for the actual count.\\n   198→func CountTodosFromToolInput(toolInput json.RawMessage) int {\\n   199→\\tif len(toolInput) == 0 {\\n   200→\\t\\treturn 0\\n   201→\\t}\\n   202→\\n   203→\\t// First extract the todos array from tool_input\\n   204→\\tvar input todoWriteToolInput\\n   205→\\tif err := json.Unmarshal(toolInput, &input); err != nil {\\n   206→\\t\\treturn 0\\n   207→\\t}\\n   208→\\n   209→\\t// Delegate to strategy package for the actual count\\n   210→\\treturn strategy.CountTodos(input.Todos)\\n   211→}\\n   212→\\n   213→// logPostTaskHookContext logs the PostToolUse[Task] hook context to the writer\\n   214→func logPostTaskHookContext(w io.Writer, input *PostTaskHookInput, subagentTranscriptPath string) {\\n   215→\\t_, _ = fmt.Fprintln(w, \\\"[entire] PostToolUse[Task] hook invoked\\\")\\n   216→\\t_, _ = fmt.Fprintf(w, \\\"  Session ID: %s\\\\n\\\", input.SessionID)\\n   217→\\t_, _ = fmt.Fprintf(w, \\\"  Tool Use ID: %s\\\\n\\\", input.ToolUseID)\\n   218→\\n   219→\\tif input.AgentID != \\\"\\\" {\\n   220→\\t\\t_, _ = fmt.Fprintf(w, \\\"  Agent ID: %s\\\\n\\\", input.AgentID)\\n   221→\\t} else {\\n   222→\\t\\t_, _ = fmt.Fprintln(w, \\\"  Agent ID: (none)\\\")\\n   223→\\t}\\n   224→\\n   225→\\t_, _ = fmt.Fprintf(w, \\\"  Transcript: %s\\\\n\\\", input.TranscriptPath)\\n   226→\\n   227→\\tif subagentTranscriptPath != \\\"\\\" {\\n   228→\\t\\t_, _ = fmt.Fprintf(w, \\\"  Subagent Transcript: %s\\\\n\\\", subagentTranscriptPath)\\n   229→\\t} else {\\n   230→\\t\\t_, _ = fmt.Fprintln(w, \\\"  Subagent Transcript: (none)\\\")\\n   231→\\t}\\n   232→}\\n   233→\"}]},\"uuid\":\"76ad2ec2-3560-4e38-9437-1d9089e1b6de\",\"timestamp\":\"2026-03-03T23:19:36.616Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a20f89dc26eabdf90\"},\"toolUseID\":\"agent_msg_01Gw5YaDeU8GJX3c7Jf18Qxi\",\"parentToolUseID\":\"toolu_01XcLyULuLK8CWxVVisuwRX6\",\"uuid\":\"92bb8ea7-d7b3-4036-84cf-ba3bccc2fc56\",\"timestamp\":\"2026-03-03T23:19:36.782Z\"}\n{\"parentUuid\":\"92bb8ea7-d7b3-4036-84cf-ba3bccc2fc56\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"8ff7050d-1d9f-42fa-9893-4a3ce065bc04\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"recursive-giggling-reef\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-03T23:19:36.782Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01M5WDypWjppYGE7Nz6VbHdg\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01PyseN3PqvXHLAkQrNNcgJM\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/alisha/Projects/wt/kiro-oneshot/cmd/entire/cli/lifecycle.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":7,\"cache_creation_input_tokens\":8761,\"cache_read_input_tokens\":43403,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":8761},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYh18BafR2xA6QBbq19Ry\",\"uuid\":\"90e9e433-daaf-40e2-82b1-fa5c6c208119\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a20f89dc26eabdf90\"},\"toolUseID\":\"agent_msg_01Gw5YaDeU8GJX3c7Jf18Qxi\",\"parentToolUseID\":\"toolu_01XcLyULuLK8CWxVVisuwRX6\",\"uuid\":\"fa26f44b-51ad-4e58-9b58-41d9972f5d89\",\"timestamp\":\"2026-03-03T23:19:36.782Z\"}\n{\"parentUuid\":\"fa26f44b-51ad-4e58-9b58-41d9972f5d89\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"8ff7050d-1d9f-42fa-9893-4a3ce065bc04\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"recursive-giggling-reef\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01PyseN3PqvXHLAkQrNNcgJM\",\"type\":\"tool_result\",\"content\":\"     1→// lifecycle.go implements the generic lifecycle event dispatcher.\\n     2→// It routes normalized events from any agent to the appropriate framework actions.\\n     3→//\\n     4→// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n     5→// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n     6→// the dispatcher handles all orchestration: state transitions, strategy calls,\\n     7→// file change detection, metadata generation.\\n     8→package cli\\n     9→\\n    10→import (\\n    11→\\t\\\"context\\\"\\n    12→\\t\\\"errors\\\"\\n    13→\\t\\\"fmt\\\"\\n    14→\\t\\\"log/slog\\\"\\n    15→\\t\\\"os\\\"\\n    16→\\t\\\"path/filepath\\\"\\n    17→\\t\\\"strings\\\"\\n    18→\\t\\\"time\\\"\\n    19→\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    22→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    23→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    25→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    26→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    27→)\\n    28→\\n    29→// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n    30→// Returns nil if the event was handled successfully.\\n    31→func DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    32→\\tif ag == nil {\\n    33→\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    34→\\t}\\n    35→\\tif event == nil {\\n    36→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    37→\\t}\\n    38→\\n    39→\\tswitch event.Type {\\n    40→\\tcase agent.SessionStart:\\n    41→\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n    42→\\tcase agent.TurnStart:\\n    43→\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n    44→\\tcase agent.TurnEnd:\\n    45→\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n    46→\\tcase agent.Compaction:\\n    47→\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n    48→\\tcase agent.SessionEnd:\\n    49→\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n    50→\\tcase agent.SubagentStart:\\n    51→\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n    52→\\tcase agent.SubagentEnd:\\n    53→\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n    54→\\tdefault:\\n    55→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    56→\\t}\\n    57→}\\n    58→\\n    59→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    60→// fires state machine transition.\\n    61→func handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    62→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n    63→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    64→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    65→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    66→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    67→\\t)\\n    68→\\n    69→\\tif event.SessionID == \\\"\\\" {\\n    70→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    71→\\t}\\n    72→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    74→\\t}\\n    75→\\n    76→\\t// Build informational message\\n    77→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    78→\\n    79→\\t// Check for concurrent sessions and append count if any\\n    80→\\tstrat := GetStrategy(ctx)\\n    81→\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n    82→\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    83→\\t}\\n    84→\\n    85→\\t// Output informational message if the agent supports hook responses.\\n    86→\\t// Claude Code reads JSON from stdout; agents that don't implement\\n    87→\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n    88→\\tif event.ResponseMessage != \\\"\\\" {\\n    89→\\t\\tmessage = event.ResponseMessage\\n    90→\\t}\\n    91→\\tif writer, ok := ag.(agent.HookResponseWriter); ok {\\n    92→\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n    93→\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n    94→\\t\\t}\\n    95→\\t}\\n    96→\\n    97→\\t// Fire EventSessionStart for the current session (if state exists).\\n    98→\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n    99→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n   100→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   101→\\t} else if state != nil {\\n   102→\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   103→\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n   104→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   105→\\t\\t}\\n   106→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   107→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n   108→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   109→\\t\\t}\\n   110→\\t}\\n   111→\\n   112→\\treturn nil\\n   113→}\\n   114→\\n   115→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   116→// ensures strategy setup, initializes session.\\n   117→func handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   118→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   119→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   120→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   121→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   122→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   123→\\t)\\n   124→\\n   125→\\tsessionID := event.SessionID\\n   126→\\tif sessionID == \\\"\\\" {\\n   127→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   128→\\t}\\n   129→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   130→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   131→\\t}\\n   132→\\n   133→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   134→\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n   135→\\t\\treturn err\\n   136→\\t}\\n   137→\\n   138→\\t// Ensure strategy setup and initialize session\\n   139→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   140→\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n   141→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   142→\\t}\\n   143→\\n   144→\\tstrat := GetStrategy(ctx)\\n   145→\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt); err != nil {\\n   146→\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n   147→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   148→\\t}\\n   149→\\n   150→\\treturn nil\\n   151→}\\n   152→\\n   153→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   154→// detects file changes, saves step + checkpoint, transitions phase.\\n   155→//\\n   156→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   157→func handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   158→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   159→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   160→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   161→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   162→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   163→\\t)\\n   164→\\n   165→\\tsessionID := event.SessionID\\n   166→\\tif sessionID == \\\"\\\" {\\n   167→\\t\\tsessionID = unknownSessionID\\n   168→\\t}\\n   169→\\n   170→\\ttranscriptRef := event.SessionRef\\n   171→\\tif transcriptRef == \\\"\\\" {\\n   172→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   173→\\t}\\n   174→\\tif !fileExists(transcriptRef) {\\n   175→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   176→\\t}\\n   177→\\n   178→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   179→\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n   180→\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n   181→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   182→\\t}\\n   183→\\n   184→\\t// Create session metadata directory\\n   185→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   186→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   187→\\tif err != nil {\\n   188→\\t\\tsessionDirAbs = sessionDir\\n   189→\\t}\\n   190→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   191→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   192→\\t}\\n   193→\\n   194→\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n   195→\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n   196→\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n   197→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n   198→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   199→\\t\\t}\\n   200→\\t}\\n   201→\\n   202→\\t// Copy transcript to session directory\\n   203→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   204→\\tif err != nil {\\n   205→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   206→\\t}\\n   207→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   208→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   209→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   210→\\t}\\n   211→\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n   212→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n   213→\\n   214→\\t// Load pre-prompt state (captured on TurnStart)\\n   215→\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n   216→\\tif err != nil {\\n   217→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n   218→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   219→\\t}\\n   220→\\n   221→\\t// Determine transcript offset\\n   222→\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n   223→\\n   224→\\t// Compute subagents directory for agents that support subagent extraction.\\n   225→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   226→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   227→\\n   228→\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n   229→\\tvar allPrompts []string\\n   230→\\tvar summary string\\n   231→\\tvar modifiedFiles []string\\n   232→\\n   233→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   234→\\t\\t// Extract prompts\\n   235→\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n   236→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract prompts\\\",\\n   237→\\t\\t\\t\\tslog.String(\\\"error\\\", promptErr.Error()))\\n   238→\\t\\t} else {\\n   239→\\t\\t\\tallPrompts = prompts\\n   240→\\t\\t}\\n   241→\\n   242→\\t\\t// Extract summary\\n   243→\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n   244→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract summary\\\",\\n   245→\\t\\t\\t\\tslog.String(\\\"error\\\", sumErr.Error()))\\n   246→\\t\\t} else {\\n   247→\\t\\t\\tsummary = s\\n   248→\\t\\t}\\n   249→\\n   250→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   251→\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n   252→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n   253→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n   254→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   255→\\t\\t\\t} else {\\n   256→\\t\\t\\t\\tmodifiedFiles = files\\n   257→\\t\\t\\t}\\n   258→\\t\\t} else {\\n   259→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   260→\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   261→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n   262→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   263→\\t\\t\\t} else {\\n   264→\\t\\t\\t\\tmodifiedFiles = files\\n   265→\\t\\t\\t}\\n   266→\\t\\t}\\n   267→\\t}\\n   268→\\n   269→\\t// Write prompts file\\n   270→\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   271→\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   272→\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   273→\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   274→\\t}\\n   275→\\tlogging.Debug(logCtx, \\\"extracted prompts\\\",\\n   276→\\t\\tslog.Int(\\\"count\\\", len(allPrompts)),\\n   277→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.PromptFileName))\\n   278→\\n   279→\\t// Write summary file\\n   280→\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   281→\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   282→\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   283→\\t}\\n   284→\\tlogging.Debug(logCtx, \\\"extracted summary\\\",\\n   285→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName))\\n   286→\\n   287→\\t// Generate commit message from last prompt\\n   288→\\tlastPrompt := \\\"\\\"\\n   289→\\tif len(allPrompts) > 0 {\\n   290→\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   291→\\t}\\n   292→\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n   293→\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n   294→\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n   295→\\n   296→\\t// Get worktree root for path normalization\\n   297→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   298→\\tif err != nil {\\n   299→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   300→\\t}\\n   301→\\n   302→\\tvar preUntrackedFiles []string\\n   303→\\tif preState != nil {\\n   304→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n   305→\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n   306→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   307→\\t}\\n   308→\\n   309→\\t// Detect file changes via git status\\n   310→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   311→\\tif err != nil {\\n   312→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   313→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   314→\\t}\\n   315→\\n   316→\\t// Filter and normalize all paths\\n   317→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   318→\\tvar relNewFiles, relDeletedFiles []string\\n   319→\\tif changes != nil {\\n   320→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   321→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   322→\\n   323→\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n   324→\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n   325→\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n   326→\\t\\t// Git status catches any tracked file with working-tree changes.\\n   327→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   328→\\t}\\n   329→\\n   330→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   331→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   332→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   333→\\t// if it exists in HEAD with the same content as the working tree.\\n   334→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   335→\\n   336→\\t// Check if there are any changes\\n   337→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   338→\\tif totalChanges == 0 {\\n   339→\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n   340→\\t\\ttransitionSessionTurnEnd(ctx, sessionID, transcriptRef)\\n   341→\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   342→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   343→\\t\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   344→\\t\\t}\\n   345→\\t\\treturn nil\\n   346→\\t}\\n   347→\\n   348→\\t// Log file changes\\n   349→\\tlogFileChanges(ctx, relModifiedFiles, relNewFiles, relDeletedFiles)\\n   350→\\n   351→\\t// Create context file\\n   352→\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n   353→\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n   354→\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n   355→\\t}\\n   356→\\tlogging.Debug(logCtx, \\\"created context file\\\",\\n   357→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.ContextFileName))\\n   358→\\n   359→\\t// Get git author\\n   360→\\tauthor, err := GetGitAuthor(ctx)\\n   361→\\tif err != nil {\\n   362→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   363→\\t}\\n   364→\\n   365→\\t// Get strategy and agent type\\n   366→\\tstrat := GetStrategy(ctx)\\n   367→\\tagentType := ag.Type()\\n   368→\\n   369→\\t// Get transcript position/identifier from pre-prompt state\\n   370→\\tvar transcriptIdentifierAtStart string\\n   371→\\tvar transcriptLinesAtStart int\\n   372→\\tif preState != nil {\\n   373→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   374→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   375→\\t}\\n   376→\\n   377→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   378→\\ttokenUsage := agent.CalculateTokenUsage(ctx, ag, transcriptData, transcriptLinesAtStart, subagentsDir)\\n   379→\\n   380→\\t// Build fully-populated step context and delegate to strategy\\n   381→\\tstepCtx := strategy.StepContext{\\n   382→\\t\\tSessionID:                sessionID,\\n   383→\\t\\tModifiedFiles:            relModifiedFiles,\\n   384→\\t\\tNewFiles:                 relNewFiles,\\n   385→\\t\\tDeletedFiles:             relDeletedFiles,\\n   386→\\t\\tMetadataDir:              sessionDir,\\n   387→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   388→\\t\\tCommitMessage:            commitMessage,\\n   389→\\t\\tTranscriptPath:           transcriptRef,\\n   390→\\t\\tAuthorName:               author.Name,\\n   391→\\t\\tAuthorEmail:              author.Email,\\n   392→\\t\\tAgentType:                agentType,\\n   393→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   394→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   395→\\t\\tTokenUsage:               tokenUsage,\\n   396→\\t}\\n   397→\\n   398→\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   399→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   400→\\t}\\n   401→\\n   402→\\t// Transition session phase and cleanup\\n   403→\\ttransitionSessionTurnEnd(ctx, sessionID, transcriptRef)\\n   404→\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   405→\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   406→\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   407→\\t}\\n   408→\\n   409→\\treturn nil\\n   410→}\\n   411→\\n   412→// handleLifecycleCompaction handles context compaction: saves current progress\\n   413→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   414→// Also resets the transcript offset since the transcript may be truncated.\\n   415→func handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   416→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   417→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   418→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   419→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   420→\\t)\\n   421→\\n   422→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   423→\\tsessionID := event.SessionID\\n   424→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   425→\\tif loadErr != nil {\\n   426→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for compaction\\\",\\n   427→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   428→\\t}\\n   429→\\tif sessionState != nil {\\n   430→\\t\\tif transErr := strategy.TransitionAndLog(ctx, sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   431→\\t\\t\\tlogging.Warn(logCtx, \\\"compaction transition failed\\\",\\n   432→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   433→\\t\\t}\\n   434→\\n   435→\\t\\tif saveErr := strategy.SaveSessionState(ctx, sessionState); saveErr != nil {\\n   436→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to save session state after compaction\\\",\\n   437→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   438→\\t\\t}\\n   439→\\t}\\n   440→\\n   441→\\tlogging.Info(logCtx, \\\"context compaction detected\\\")\\n   442→\\treturn nil\\n   443→}\\n   444→\\n   445→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   446→func handleLifecycleSessionEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   447→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   448→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   449→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   450→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   451→\\t)\\n   452→\\n   453→\\tif event.SessionID == \\\"\\\" {\\n   454→\\t\\treturn nil // No session to update\\n   455→\\t}\\n   456→\\n   457→\\t// Note: We intentionally don't clean up cached transcripts here.\\n   458→\\t// Post-session commits (carry-forward in ENDED phase) may still need\\n   459→\\t// the transcript to extract file changes. Cleanup is handled by\\n   460→\\t// `entire clean` or when the session state is fully removed.\\n   461→\\n   462→\\tif err := markSessionEnded(ctx, event.SessionID); err != nil {\\n   463→\\t\\tlogging.Warn(logCtx, \\\"failed to mark session ended\\\",\\n   464→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   465→\\t}\\n   466→\\treturn nil\\n   467→}\\n   468→\\n   469→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   470→func handleLifecycleSubagentStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   471→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   472→\\tlogging.Info(logCtx, \\\"subagent started\\\",\\n   473→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   474→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   475→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   476→\\t\\tslog.String(\\\"transcript\\\", event.SessionRef),\\n   477→\\t)\\n   478→\\n   479→\\t// Capture pre-task state\\n   480→\\tif err := CapturePreTaskState(ctx, event.ToolUseID); err != nil {\\n   481→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   482→\\t}\\n   483→\\n   484→\\treturn nil\\n   485→}\\n   486→\\n   487→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   488→func handleLifecycleSubagentEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   489→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   490→\\tif event.SubagentType == \\\"\\\" && event.TaskDescription == \\\"\\\" {\\n   491→\\t\\t// Extract subagent type and description from tool input\\n   492→\\t\\tevent.SubagentType, event.TaskDescription = ParseSubagentTypeAndDescription(event.ToolInput)\\n   493→\\t}\\n   494→\\n   495→\\t// Determine subagent transcript path\\n   496→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   497→\\tvar subagentTranscriptPath string\\n   498→\\tif event.SubagentID != \\\"\\\" {\\n   499→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   500→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   501→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   502→\\t\\t}\\n   503→\\t}\\n   504→\\n   505→\\t// Log context\\n   506→\\tsubagentEndAttrs := []any{\\n   507→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   508→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   509→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   510→\\t}\\n   511→\\tif event.SubagentID != \\\"\\\" {\\n   512→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"agent_id\\\", event.SubagentID))\\n   513→\\t}\\n   514→\\tif subagentTranscriptPath != \\\"\\\" {\\n   515→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"subagent_transcript\\\", subagentTranscriptPath))\\n   516→\\t}\\n   517→\\tlogging.Info(logCtx, \\\"subagent completed\\\", subagentEndAttrs...)\\n   518→\\n   519→\\t// Extract modified files from subagent transcript\\n   520→\\tvar modifiedFiles []string\\n   521→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   522→\\t\\ttranscriptToScan := event.SessionRef\\n   523→\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n   524→\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n   525→\\t\\t}\\n   526→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n   527→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files from subagent\\\",\\n   528→\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   529→\\t\\t} else {\\n   530→\\t\\t\\tmodifiedFiles = files\\n   531→\\t\\t}\\n   532→\\t}\\n   533→\\n   534→\\t// Load pre-task state and detect file changes\\n   535→\\tpreState, err := LoadPreTaskState(ctx, event.ToolUseID)\\n   536→\\tif err != nil {\\n   537→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-task state\\\",\\n   538→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   539→\\t}\\n   540→\\tvar preUntrackedFiles []string\\n   541→\\tif preState != nil {\\n   542→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   543→\\t}\\n   544→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   545→\\tif err != nil {\\n   546→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   547→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   548→\\t}\\n   549→\\n   550→\\t// Get worktree root and normalize paths\\n   551→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   552→\\tif err != nil {\\n   553→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   554→\\t}\\n   555→\\n   556→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   557→\\tvar relNewFiles, relDeletedFiles []string\\n   558→\\tif changes != nil {\\n   559→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   560→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   561→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   562→\\t}\\n   563→\\n   564→\\t// If no changes, skip\\n   565→\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n   566→\\t\\tlogging.Info(logCtx, \\\"no file changes detected, skipping task checkpoint\\\")\\n   567→\\t\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   568→\\t\\treturn nil\\n   569→\\t}\\n   570→\\n   571→\\t// Find checkpoint UUID from main transcript (best-effort)\\n   572→\\tvar checkpointUUID string\\n   573→\\t// Use the existing CLI-level checkpoint UUID finder\\n   574→\\tmainLines, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n   575→\\tif mainLines != nil {\\n   576→\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n   577→\\t}\\n   578→\\n   579→\\t// Get git author\\n   580→\\tauthor, err := GetGitAuthor(ctx)\\n   581→\\tif err != nil {\\n   582→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   583→\\t}\\n   584→\\n   585→\\t// Build task checkpoint context\\n   586→\\tstrat := GetStrategy(ctx)\\n   587→\\tagentType := ag.Type()\\n   588→\\n   589→\\ttaskStepCtx := strategy.TaskStepContext{\\n   590→\\t\\tSessionID:              event.SessionID,\\n   591→\\t\\tToolUseID:              event.ToolUseID,\\n   592→\\t\\tAgentID:                event.SubagentID,\\n   593→\\t\\tModifiedFiles:          relModifiedFiles,\\n   594→\\t\\tNewFiles:               relNewFiles,\\n   595→\\t\\tDeletedFiles:           relDeletedFiles,\\n   596→\\t\\tTranscriptPath:         event.SessionRef,\\n   597→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   598→\\t\\tCheckpointUUID:         checkpointUUID,\\n   599→\\t\\tAuthorName:             author.Name,\\n   600→\\t\\tAuthorEmail:            author.Email,\\n   601→\\t\\tSubagentType:           event.SubagentType,\\n   602→\\t\\tTaskDescription:        event.TaskDescription,\\n   603→\\t\\tAgentType:              agentType,\\n   604→\\t}\\n   605→\\n   606→\\tif err := strat.SaveTaskStep(ctx, taskStepCtx); err != nil {\\n   607→\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n   608→\\t}\\n   609→\\n   610→\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   611→\\treturn nil\\n   612→}\\n   613→\\n   614→// --- Helper functions ---\\n   615→\\n   616→// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n   617→// Prefers pre-prompt state, falls back to session state.\\n   618→func resolveTranscriptOffset(ctx context.Context, preState *PrePromptState, sessionID string) int {\\n   619→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   620→\\tif preState != nil && preState.TranscriptOffset > 0 {\\n   621→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state found, parsing transcript from offset\\\",\\n   622→\\t\\t\\tslog.Int(\\\"offset\\\", preState.TranscriptOffset))\\n   623→\\t\\treturn preState.TranscriptOffset\\n   624→\\t}\\n   625→\\n   626→\\t// Fall back to session state\\n   627→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   628→\\tif loadErr != nil {\\n   629→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state\\\",\\n   630→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   631→\\t\\treturn 0\\n   632→\\t}\\n   633→\\tif sessionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n   634→\\t\\tlogging.Debug(logCtx, \\\"session state found, parsing transcript from offset\\\",\\n   635→\\t\\t\\tslog.Int(\\\"offset\\\", sessionState.CheckpointTranscriptStart))\\n   636→\\t\\treturn sessionState.CheckpointTranscriptStart\\n   637→\\t}\\n   638→\\n   639→\\treturn 0\\n   640→}\\n   641→\\n   642→// createContextFile creates a context.md file for the session checkpoint.\\n   643→// This is a unified version that works for all agents.\\n   644→func createContextFile(contextFile, commitMessage, sessionID string, prompts []string, summary string) error {\\n   645→\\tvar sb strings.Builder\\n   646→\\n   647→\\tsb.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   648→\\tfmt.Fprintf(&sb, \\\"Session ID: %s\\\\n\\\", sessionID)\\n   649→\\tfmt.Fprintf(&sb, \\\"Commit Message: %s\\\\n\\\\n\\\", commitMessage)\\n   650→\\n   651→\\tif len(prompts) > 0 {\\n   652→\\t\\tsb.WriteString(\\\"## Prompts\\\\n\\\\n\\\")\\n   653→\\t\\tfor i, p := range prompts {\\n   654→\\t\\t\\tfmt.Fprintf(&sb, \\\"### Prompt %d\\\\n\\\\n%s\\\\n\\\\n\\\", i+1, p)\\n   655→\\t\\t}\\n   656→\\t}\\n   657→\\n   658→\\tif summary != \\\"\\\" {\\n   659→\\t\\tsb.WriteString(\\\"## Summary\\\\n\\\\n\\\")\\n   660→\\t\\tsb.WriteString(summary)\\n   661→\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   662→\\t}\\n   663→\\n   664→\\tif err := os.WriteFile(contextFile, []byte(sb.String()), 0o600); err != nil {\\n   665→\\t\\treturn fmt.Errorf(\\\"failed to write context file: %w\\\", err)\\n   666→\\t}\\n   667→\\treturn nil\\n   668→}\\n   669→\\n   670→// parseTranscriptForCheckpointUUID is a thin wrapper around transcript parsing for checkpoint UUID lookup.\\n   671→// Returns parsed transcript lines for use with FindCheckpointUUID.\\n   672→func parseTranscriptForCheckpointUUID(transcriptPath string) ([]transcriptLine, error) {\\n   673→\\tlines, err := transcript.ParseFromFileAtLine(transcriptPath, 0)\\n   674→\\tif err != nil {\\n   675→\\t\\treturn nil, fmt.Errorf(\\\"parsing transcript for checkpoint UUID: %w\\\", err)\\n   676→\\t}\\n   677→\\treturn lines, nil\\n   678→}\\n   679→\\n   680→// transitionSessionTurnEnd transitions the session phase to IDLE and dispatches turn-end actions.\\n   681→// An optional transcriptPath can be provided to backfill the session state's TranscriptPath\\n   682→// when SaveStep was skipped (e.g., no file changes because the agent committed mid-turn).\\n   683→func transitionSessionTurnEnd(ctx context.Context, sessionID string, transcriptPath ...string) {\\n   684→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   685→\\tturnState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   686→\\tif loadErr != nil {\\n   687→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for turn end\\\",\\n   688→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   689→\\t\\treturn\\n   690→\\t}\\n   691→\\tif turnState == nil {\\n   692→\\t\\treturn\\n   693→\\t}\\n   694→\\n   695→\\t// Backfill TranscriptPath if not yet set. This handles agents with deferred\\n   696→\\t// transcript persistence (e.g., Kiro) where the transcript wasn't available\\n   697→\\t// during mid-turn commits but is available now at TurnEnd.\\n   698→\\tif turnState.TranscriptPath == \\\"\\\" && len(transcriptPath) > 0 && transcriptPath[0] != \\\"\\\" {\\n   699→\\t\\tturnState.TranscriptPath = transcriptPath[0]\\n   700→\\t}\\n   701→\\n   702→\\tif err := strategy.TransitionAndLog(ctx, turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   703→\\t\\tlogging.Warn(logCtx, \\\"turn-end transition failed\\\",\\n   704→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   705→\\t}\\n   706→\\n   707→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   708→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   709→\\tstrat := GetStrategy(ctx)\\n   710→\\tif err := strat.HandleTurnEnd(ctx, turnState); err != nil {\\n   711→\\t\\tlogging.Warn(logCtx, \\\"turn-end action dispatch failed\\\",\\n   712→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   713→\\t}\\n   714→\\n   715→\\tif updateErr := strategy.SaveSessionState(ctx, turnState); updateErr != nil {\\n   716→\\t\\tlogging.Warn(logCtx, \\\"failed to update session phase on turn end\\\",\\n   717→\\t\\t\\tslog.String(\\\"error\\\", updateErr.Error()))\\n   718→\\t}\\n   719→}\\n   720→\\n   721→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   722→func markSessionEnded(ctx context.Context, sessionID string) error {\\n   723→\\tstate, err := strategy.LoadSessionState(ctx, sessionID)\\n   724→\\tif err != nil {\\n   725→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   726→\\t}\\n   727→\\tif state == nil {\\n   728→\\t\\treturn nil // No state file, nothing to update\\n   729→\\t}\\n   730→\\n   731→\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStop, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   732→\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"lifecycle\\\"), \\\"session stop transition failed\\\",\\n   733→\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   734→\\t}\\n   735→\\n   736→\\tnow := time.Now()\\n   737→\\tstate.EndedAt = &now\\n   738→\\n   739→\\tif err := strategy.SaveSessionState(ctx, state); err != nil {\\n   740→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   741→\\t}\\n   742→\\treturn nil\\n   743→}\\n   744→\\n   745→// logFileChanges logs the files modified, created, and deleted during a session.\\n   746→func logFileChanges(ctx context.Context, modified, newFiles, deleted []string) {\\n   747→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   748→\\tlogging.Debug(logCtx, \\\"files changed during session\\\",\\n   749→\\t\\tslog.Int(\\\"modified\\\", len(modified)),\\n   750→\\t\\tslog.Int(\\\"new\\\", len(newFiles)),\\n   751→\\t\\tslog.Int(\\\"deleted\\\", len(deleted)))\\n   752→}\\n   753→\"}]},\"uuid\":\"a52d1eb9-af5b-4fa3-86f1-80bc36a34228\",\"timestamp\":\"2026-03-03T23:19:37.020Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a20f89dc26eabdf90\"},\"toolUseID\":\"agent_msg_01Gw5YaDeU8GJX3c7Jf18Qxi\",\"parentToolUseID\":\"toolu_01XcLyULuLK8CWxVVisuwRX6\",\"uuid\":\"2a4f7840-a119-4be1-aa26-4a44b2382fed\",\"timestamp\":\"2026-03-03T23:19:37.022Z\"}\n{\"parentUuid\":\"2a4f7840-a119-4be1-aa26-4a44b2382fed\",\"isSidechain\":