 21→\\n    22→// Kiro hook names — these become CLI subcommands under `entire hooks kiro`.\\n    23→// Kiro uses camelCase hook names natively, but CLI subcommands use kebab-case.\\n    24→const (\\n    25→\\tHookNameAgentSpawn       = \\\"agent-spawn\\\"\\n    26→\\tHookNameUserPromptSubmit = \\\"user-prompt-submit\\\"\\n    27→\\tHookNamePreToolUse       = \\\"pre-tool-use\\\"\\n    28→\\tHookNamePostToolUse      = \\\"post-tool-use\\\"\\n    29→\\tHookNameStop             = \\\"stop\\\"\\n    30→)\\n    31→\\n    32→// sessionIDFile is the filename for caching the generated session ID.\\n    33→// Stored in .entire/tmp/ to ensure a stable ID across all hooks in one session.\\n    34→const sessionIDFile = \\\"kiro-active-session\\\"\\n    35→\\n    36→// HookNames returns the hook verbs Kiro supports.\\n    37→// These become subcommands: entire hooks kiro <verb>\\n    38→func (k *KiroAgent) HookNames() []string {\\n    39→\\treturn []string{\\n    40→\\t\\tHookNameAgentSpawn,\\n    41→\\t\\tHookNameUserPromptSubmit,\\n    42→\\t\\tHookNamePreToolUse,\\n    43→\\t\\tHookNamePostToolUse,\\n    44→\\t\\tHookNameStop,\\n    45→\\t}\\n    46→}\\n    47→\\n    48→// ParseHookEvent translates a Kiro hook into a normalized lifecycle Event.\\n    49→// Returns nil for hooks with no lifecycle significance (preToolUse, postToolUse).\\n    50→func (k *KiroAgent) ParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*agent.Event, error) {\\n    51→\\tswitch hookName {\\n    52→\\tcase HookNameAgentSpawn:\\n    53→\\t\\treturn k.parseAgentSpawn(ctx, stdin)\\n    54→\\tcase HookNameUserPromptSubmit:\\n    55→\\t\\treturn k.parseUserPromptSubmit(ctx, stdin)\\n    56→\\tcase HookNameStop:\\n    57→\\t\\treturn k.parseStop(ctx, stdin)\\n    58→\\tcase HookNamePreToolUse, HookNamePostToolUse:\\n    59→\\t\\t// Pass-through hooks with no lifecycle significance\\n    60→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    61→\\tdefault:\\n    62→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    63→\\t}\\n    64→}\\n    65→\\n    66→// readHookInputOrEmpty wraps ReadAndParseHookInput, returning a zero-value\\n    67→// hookInputRaw on empty stdin instead of erroring. This supports the Kiro IDE\\n    68→// which delivers data via environment variables rather than JSON on stdin.\\n    69→// Malformed JSON still returns an error.\\n    70→func readHookInputOrEmpty(stdin io.Reader) (*hookInputRaw, error) {\\n    71→\\traw, err := agent.ReadAndParseHookInput[hookInputRaw](stdin)\\n    72→\\tif err != nil {\\n    73→\\t\\tif errors.Is(err, agent.ErrEmptyHookInput) {\\n    74→\\t\\t\\treturn &hookInputRaw{}, nil\\n    75→\\t\\t}\\n    76→\\t\\treturn nil, err\\n    77→\\t}\\n    78→\\treturn raw, nil\\n    79→}\\n    80→\\n    81→func (k *KiroAgent) parseAgentSpawn(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n    82→\\t_, err := readHookInputOrEmpty(stdin)\\n    83→\\tif err != nil {\\n    84→\\t\\treturn nil, err\\n    85→\\t}\\n    86→\\n    87→\\t// Generate a new stable session ID and cache it for subsequent hooks.\\n    88→\\t// Kiro's SQLite transcript isn't populated until the turn ends, so we can't\\n    89→\\t// use the native conversation_id as our session ID — it would be \\\"unknown\\\"\\n    90→\\t// at agentSpawn/userPromptSubmit and change to the real ID at stop.\\n    91→\\tsessionID := k.generateAndCacheSessionID(ctx)\\n    92→\\n    93→\\treturn &agent.Event{\\n    94→\\t\\tType:      agent.SessionStart,\\n    95→\\t\\tSessionID: sessionID,\\n    96→\\t\\tTimestamp: time.Now(),\\n    97→\\t}, nil\\n    98→}\\n    99→\\n   100→func (k *KiroAgent) parseUserPromptSubmit(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n   101→\\traw, err := readHookInputOrEmpty(stdin)\\n   102→\\tif err != nil {\\n   103→\\t\\treturn nil, err\\n   104→\\t}\\n   105→\\n   106→\\t// IDE mode: prompt comes from USER_PROMPT env var when stdin is empty.\\n   107→\\tprompt := raw.Prompt\\n   108→\\tif prompt == \\\"\\\" {\\n   109→\\t\\tprompt = os.Getenv(\\\"USER_PROMPT\\\")\\n   110→\\t}\\n   111→\\n   112→\\t// Read the stable session ID generated at agentSpawn.\\n   113→\\tsessionID := k.readCachedSessionID(ctx)\\n   114→\\tif sessionID == \\\"\\\" {\\n   115→\\t\\t// Fallback: generate new ID if cache file is missing (e.g., agentSpawn was skipped).\\n   116→\\t\\tsessionID = k.generateAndCacheSessionID(ctx)\\n   117→\\t}\\n   118→\\n   119→\\treturn &agent.Event{\\n   120→\\t\\tType:      agent.TurnStart,\\n   121→\\t\\tSessionID: sessionID,\\n   122→\\t\\tPrompt:    prompt,\\n   123→\\t\\tTimestamp: time.Now(),\\n   124→\\t}, nil\\n   125→}\\n   126→\\n   127→func (k *KiroAgent) parseStop(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n   128→\\traw, err := readHookInputOrEmpty(stdin)\\n   129→\\tif err != nil {\\n   130→\\t\\treturn nil, err\\n   131→\\t}\\n   132→\\n   133→\\t// IDE mode: CWD may not be in stdin. Fall back to repo root.\\n   134→\\tcwd := raw.CWD\\n   135→\\tif cwd == \\\"\\\" {\\n   136→\\t\\trepoRoot, rootErr := paths.WorktreeRoot(ctx)\\n   137→\\t\\tif rootErr == nil {\\n   138→\\t\\t\\tcwd = repoRoot\\n   139→\\t\\t}\\n   140→\\t}\\n   141→\\n   142→\\t// Read the stable session ID generated at agentSpawn.\\n   143→\\tsessionID := k.readCachedSessionID(ctx)\\n   144→\\tif sessionID == \\\"\\\" {\\n   145→\\t\\t// Fallback: try SQLite for the session ID.\\n   146→\\t\\tsid, queryErr := k.querySessionID(ctx, cwd)\\n   147→\\t\\tif queryErr != nil || sid == \\\"\\\" {\\n   148→\\t\\t\\tsessionID = \\\"unknown\\\"\\n   149→\\t\\t} else {\\n   150→\\t\\t\\tsessionID = sid\\n   151→\\t\\t}\\n   152→\\t}\\n   153→\\n   154→\\t// At stop, Kiro's SQLite transcript is available. Fetch and cache it\\n   155→\\t// under our stable session ID so lifecycle.go can read it.\\n   156→\\tsessionRef, _ := k.ensureCachedTranscript(ctx, cwd, sessionID) //nolint:errcheck // best-effort: fall back to placeholder\\n   157→\\n   158→\\t// IDE mode: SQLite may not exist or be at a different path. Create a\\n   159→\\t// minimal placeholder transcript so the lifecycle handler can proceed\\n   160→\\t// (file-diff checkpoints still work without a real transcript).\\n   161→\\tif sessionRef == \\\"\\\" {\\n   162→\\t\\tsessionRef = k.createPlaceholderTranscript(ctx, cwd, sessionID)\\n   163→\\t}\\n   164→\\n   165→\\treturn &agent.Event{\\n   166→\\t\\tType:       agent.TurnEnd,\\n   167→\\t\\tSessionID:  sessionID,\\n   168→\\t\\tSessionRef: sessionRef,\\n   169→\\t\\tTimestamp:  time.Now(),\\n   170→\\t}, nil\\n   171→}\\n   172→\\n   173→// createPlaceholderTranscript writes a minimal JSON transcript to .entire/tmp/\\n   174→// so the lifecycle handler can proceed when the real transcript is unavailable\\n   175→// (e.g., Kiro IDE mode where SQLite is at a different path).\\n   176→func (k *KiroAgent) createPlaceholderTranscript(ctx context.Context, cwd, sessionID string) string {\\n   177→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   178→\\tif err != nil {\\n   179→\\t\\trepoRoot = cwd\\n   180→\\t}\\n   181→\\tif repoRoot == \\\"\\\" {\\n   182→\\t\\treturn \\\"\\\"\\n   183→\\t}\\n   184→\\tcacheDir := filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\")\\n   185→\\tcachePath := filepath.Join(cacheDir, sessionID+\\\".json\\\")\\n   186→\\tif err := os.MkdirAll(cacheDir, 0o750); err != nil {\\n   187→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to create transcript cache dir\\\", \\\"err\\\", err)\\n   188→\\t\\treturn \\\"\\\"\\n   189→\\t}\\n   190→\\tif err := os.WriteFile(cachePath, []byte(\\\"{}\\\"), 0o600); err != nil {\\n   191→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to write placeholder transcript\\\", \\\"err\\\", err)\\n   192→\\t\\treturn \\\"\\\"\\n   193→\\t}\\n   194→\\treturn cachePath\\n   195→}\\n   196→\\n   197→// generateAndCacheSessionID creates a new random session ID and writes it\\n   198→// to .entire/tmp/kiro-active-session for subsequent hooks to read.\\n   199→func (k *KiroAgent) generateAndCacheSessionID(ctx context.Context) string {\\n   200→\\tsid := generateSessionID()\\n   201→\\tcachePath := k.sessionIDCachePath(ctx)\\n   202→\\tif err := os.MkdirAll(filepath.Dir(cachePath), 0o750); err != nil {\\n   203→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to create session ID cache dir\\\", \\\"err\\\", err)\\n   204→\\t\\treturn sid\\n   205→\\t}\\n   206→\\tif err := os.WriteFile(cachePath, []byte(sid), 0o600); err != nil {\\n   207→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to write session ID cache\\\", \\\"err\\\", err)\\n   208→\\t}\\n   209→\\treturn sid\\n   210→}\\n   211→\\n   212→// readCachedSessionID reads the stable session ID from .entire/tmp/kiro-active-session.\\n   213→// Returns empty string if the cache file doesn't exist.\\n   214→func (k *KiroAgent) readCachedSessionID(ctx context.Context) string {\\n   215→\\tcachePath := k.sessionIDCachePath(ctx)\\n   216→\\tdata, err := os.ReadFile(cachePath) //nolint:gosec // cachePath is constructed from WorktreeRoot + constant suffix\\n   217→\\tif err != nil {\\n   218→\\t\\treturn \\\"\\\"\\n   219→\\t}\\n   220→\\treturn strings.TrimSpace(string(data))\\n   221→}\\n   222→\\n   223→// sessionIDCachePath returns the path to the session ID cache file.\\n   224→func (k *KiroAgent) sessionIDCachePath(ctx context.Context) string {\\n   225→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   226→\\tif err != nil {\\n   227→\\t\\trepoRoot = \\\".\\\"\\n   228→\\t}\\n   229→\\treturn filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\", sessionIDFile)\\n   230→}\\n   231→\\n   232→// generateSessionID creates a random 32-character hex string for use as a session ID.\\n   233→func generateSessionID() string {\\n   234→\\tb := make([]byte, 16)\\n   235→\\tif _, err := rand.Read(b); err != nil {\\n   236→\\t\\t// crypto/rand.Read never fails on supported platforms, but use timestamp fallback.\\n   237→\\t\\treturn \\\"kiro-\\\" + time.Now().Format(\\\"20060102-150405\\\")\\n   238→\\t}\\n   239→\\treturn hex.EncodeToString(b)\\n   240→}\\n   241→\"}]},\"uuid\":\"e0601141-fa3b-42f2-a2ba-474ffcc18c0e\",\"timestamp\":\"2026-03-03T23:19:34.240Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a20f89dc26eabdf90\"},\"toolUseID\":\"agent_msg_01Gw5YaDeU8GJX3c7Jf18Qxi\",\"parentToolUseID\":\"toolu_01XcLyULuLK8CWxVVisuwRX6\",\"uuid\":\"31342921-546e-4fd5-92dd-8804a37ec8d0\",\"timestamp\":\"2026-03-03T23:19:34.717Z\"}\n{\"parentUuid\":\"31342921-546e-4fd5-92dd-8804a37ec8d0\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"8ff7050d-1d9f-42fa-9893-4a3ce065bc04\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"recursive-giggling-reef\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-03T23:19:34.717Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01NLQv9akBQqEUNuGofYX54k\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01U5t6iEXk1GSmdULEW41VMx\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/alisha/Projects/wt/kiro-oneshot/cmd/entire/cli/agent/kiro/hooks.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":3,\"cache_creation_input_tokens\":43403,\"cache_read_input_tokens\":0,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":43403},\"output_tokens\":3,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYh17zWQjn9myS4me8iKW\",\"uuid\":\"bacf7e0e-4c5e-4664-8da0-7ba0855dcac9\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a20f89dc26eabdf90\"},\"toolUseID\":\"agent_msg_01Gw5YaDeU8GJX3c7Jf18Qxi\",\"parentToolUseID\":\"toolu_01XcLyULuLK8CWxVVisuwRX6\",\"uuid\":\"66181aa5-dad2-4b16-ab5