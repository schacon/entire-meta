unc hasEntireHook(entries []kiroHookEntry) bool {\\n   225→\\tfor _, entry := range entries {\\n   226→\\t\\tif isEntireHook(entry.Command) {\\n   227→\\t\\t\\treturn true\\n   228→\\t\\t}\\n   229→\\t}\\n   230→\\treturn false\\n   231→}\\n   232→\\n   233→// installIDEHooks creates .kiro/hooks/*.kiro.hook files for the Kiro IDE.\\n   234→func installIDEHooks(worktreeRoot, cmdPrefix string) (int, error) {\\n   235→\\tdir := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir)\\n   236→\\tif err := os.MkdirAll(dir, 0o750); err != nil {\\n   237→\\t\\treturn 0, fmt.Errorf(\\\"failed to create .kiro/hooks directory: %w\\\", err)\\n   238→\\t}\\n   239→\\n   240→\\tfor _, def := range ideHookDefs {\\n   241→\\t\\thook := kiroIDEHookFile{\\n   242→\\t\\t\\tEnabled:     true,\\n   243→\\t\\t\\tName:        def.Filename,\\n   244→\\t\\t\\tDescription: \\\"Entire CLI \\\" + def.TriggerType + \\\" hook\\\",\\n   245→\\t\\t\\tVersion:     ideHookVersion,\\n   246→\\t\\t\\tWhen: kiroIDEHookWhen{\\n   247→\\t\\t\\t\\tType: def.TriggerType,\\n   248→\\t\\t\\t},\\n   249→\\t\\t\\tThen: kiroIDEHookThen{\\n   250→\\t\\t\\t\\tType:    \\\"runCommand\\\",\\n   251→\\t\\t\\t\\tCommand: cmdPrefix + def.CLIVerb,\\n   252→\\t\\t\\t},\\n   253→\\t\\t}\\n   254→\\n   255→\\t\\tdata, err := jsonutil.MarshalIndentWithNewline(hook, \\\"\\\", \\\"  \\\")\\n   256→\\t\\tif err != nil {\\n   257→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal IDE hook %s: %w\\\", def.Filename, err)\\n   258→\\t\\t}\\n   259→\\n   260→\\t\\tpath := filepath.Join(dir, def.Filename+ideHookFileSuffix)\\n   261→\\t\\tif err := os.WriteFile(path, data, 0o600); err != nil {\\n   262→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to write IDE hook %s: %w\\\", def.Filename, err)\\n   263→\\t\\t}\\n   264→\\t}\\n   265→\\n   266→\\treturn len(ideHookDefs), nil\\n   267→}\\n   268→\\n   269→// allIDEHooksPresent checks that all 4 IDE hook files exist and have correct commands.\\n   270→func allIDEHooksPresent(worktreeRoot string, localDev bool) bool {\\n   271→\\tvar cmdPrefix string\\n   272→\\tif localDev {\\n   273→\\t\\tcmdPrefix = localDevCmdPrefix + \\\"hooks kiro \\\"\\n   274→\\t} else {\\n   275→\\t\\tcmdPrefix = prodHookCmdPrefix\\n   276→\\t}\\n   277→\\n   278→\\tfor _, def := range ideHookDefs {\\n   279→\\t\\tpath := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir, def.Filename+ideHookFileSuffix)\\n   280→\\t\\tdata, err := os.ReadFile(path) //nolint:gosec // path constructed from repo root\\n   281→\\t\\tif err != nil {\\n   282→\\t\\t\\treturn false\\n   283→\\t\\t}\\n   284→\\t\\tvar hook kiroIDEHookFile\\n   285→\\t\\tif err := json.Unmarshal(data, &hook); err != nil {\\n   286→\\t\\t\\treturn false\\n   287→\\t\\t}\\n   288→\\t\\tif hook.Then.Command != cmdPrefix+def.CLIVerb {\\n   289→\\t\\t\\treturn false\\n   290→\\t\\t}\\n   291→\\t}\\n   292→\\treturn true\\n   293→}\\n   294→\\n   295→// anyIDEHookPresent checks if any Entire IDE hook file exists.\\n   296→func anyIDEHookPresent(worktreeRoot string) bool {\\n   297→\\tfor _, def := range ideHookDefs {\\n   298→\\t\\tpath := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir, def.Filename+ideHookFileSuffix)\\n   299→\\t\\tdata, err := os.ReadFile(path) //nolint:gosec // path constructed from repo root\\n   300→\\t\\tif err != nil {\\n   301→\\t\\t\\tcontinue\\n   302→\\t\\t}\\n   303→\\t\\tvar hook kiroIDEHookFile\\n   304→\\t\\tif json.Unmarshal(data, &hook) == nil && isEntireIDEHook(hook) {\\n   305→\\t\\t\\treturn true\\n   306→\\t\\t}\\n   307→\\t}\\n   308→\\treturn false\\n   309→}\\n   310→\\n   311→// isEntireIDEHook checks if an IDE hook file belongs to Entire.\\n   312→func isEntireIDEHook(hook kiroIDEHookFile) bool {\\n   313→\\treturn strings.HasPrefix(hook.Name, \\\"entire-\\\") && isEntireHook(hook.Then.Command)\\n   314→}\\n   315→\"}]},\"uuid\":\"2150e166-2aea-4dc7-95a8-b589bb94b4b3\",\"timestamp\":\"2026-03-03T23:19:34.774Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",