LEW41VMx\",\"type\":\"tool_result\",\"content\":\"     1→package kiro\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"encoding/json\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"os\\\"\\n     8→\\t\\\"path/filepath\\\"\\n     9→\\t\\\"strings\\\"\\n    10→\\n    11→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    14→)\\n    15→\\n    16→// Ensure KiroAgent implements HookSupport\\n    17→var _ agent.HookSupport = (*KiroAgent)(nil)\\n    18→\\n    19→// HooksFileName is the config file for Kiro hooks.\\n    20→const HooksFileName = \\\"entire.json\\\"\\n    21→\\n    22→// hooksDir is the directory within .kiro where agent hook configs live.\\n    23→const hooksDir = \\\"agents\\\"\\n    24→\\n    25→// ideHooksDir is the directory within .kiro where IDE hook files live.\\n    26→const ideHooksDir = \\\"hooks\\\"\\n    27→\\n    28→// ideHookFileSuffix is the file extension for IDE hook files.\\n    29→const ideHookFileSuffix = \\\".kiro.hook\\\"\\n    30→\\n    31→// ideHookVersion is the schema version for IDE hook files.\\n    32→const ideHookVersion = \\\"1\\\"\\n    33→\\n    34→// localDevCmdPrefix is the command prefix used for local development builds.\\n    35→const localDevCmdPrefix = \\\"go run ${KIRO_PROJECT_DIR}/cmd/entire/main.go \\\"\\n    36→\\n    37→// prodHookCmdPrefix is the command prefix for production hook commands.\\n    38→const prodHookCmdPrefix = \\\"entire hooks kiro \\\"\\n    39→\\n    40→// entireHookPrefixes identify Entire hooks in the config file.\\n    41→var entireHookPrefixes = []string{\\n    42→\\t\\\"entire \\\",\\n    43→\\tlocalDevCmdPrefix,\\n    44→}\\n    45→\\n    46→// ideHookDef defines a single IDE hook file to install.\\n    47→type ideHookDef struct {\\n    48→\\tFilename    string // e.g. \\\"entire-prompt-submit\\\"\\n    49→\\tTriggerType string // e.g. \\\"promptSubmit\\\"\\n    50→\\tCLIVerb     string // e.g. \\\"user-prompt-submit\\\"\\n    51→}\\n    52→\\n    53→// ideHookDefs lists the 4 IDE hook files to install.\\n    54→// No agentSpawn IDE hook — the IDE has no such trigger.\\n    55→// The first promptSubmit serves as session start.\\n    56→var ideHookDefs = []ideHookDef{\\n    57→\\t{Filename: \\\"entire-prompt-submit\\\", TriggerType: \\\"promptSubmit\\\", CLIVerb: HookNameUserPromptSubmit},\\n    58→\\t{Filename: \\\"entire-stop\\\", TriggerType: \\\"agentStop\\\", CLIVerb: HookNameStop},\\n    59→\\t{Filename: \\\"entire-pre-tool-use\\\", TriggerType: \\\"preToolUse\\\", CLIVerb: HookNamePreToolUse},\\n    60→\\t{Filename: \\\"entire-post-tool-use\\\", TriggerType: \\\"postToolUse\\\", CLIVerb: HookNamePostToolUse},\\n    61→}\\n    62→\\n    63→// InstallHooks installs Entire hooks in .kiro/agents/entire.json (CLI hooks)\\n    64→// and .kiro/hooks/*.kiro.hook (IDE hooks).\\n    65→// Returns the total number of hooks installed (CLI + IDE).\\n    66→func (k *KiroAgent) InstallHooks(ctx context.Context, localDev bool, force bool) (int, error) {\\n    67→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    68→\\tif err != nil {\\n    69→\\t\\tworktreeRoot = \\\".\\\"\\n    70→\\t}\\n    71→\\n    72→\\thooksPath := filepath.Join(worktreeRoot, \\\".kiro\\\", hooksDir, HooksFileName)\\n    73→\\n    74→\\t// If hooks are already installed and not forcing, check if they're current\\n    75→\\tif !force {\\n    76→\\t\\tif existing, readErr := os.ReadFile(hooksPath); readErr == nil { //nolint:gosec // path constructed from repo root\\n    77→\\t\\t\\tvar file kiroAgentFile\\n    78→\\t\\t\\tif json.Unmarshal(existing, &file) == nil && allHooksPresent(file.Hooks, localDev) && allIDEHooksPresent(worktreeRoot, localDev) {\\n    79→\\t\\t\\t\\treturn 0, nil\\n    80→\\t\\t\\t}\\n    81→\\t\\t}\\n    82→\\t}\\n    83→\\n    84→\\tvar cmdPrefix string\\n    85→\\tif localDev {\\n    86→\\t\\tcmdPrefix = localDevCmdPrefix + \\\"hooks kiro \\\"\\n    87→\\t} else {\\n    88→\\t\\tcmdPrefix = prodHookCmdPrefix\\n    89→\\t}\\n    90→\\n    91→\\tfile := kiroAgentFile{\\n    92→\\t\\tName: \\\"entire\\\",\\n    93→\\t\\t// Include all default Kiro tools so the agent profile doesn't restrict them.\\n    94→\\t\\tTools: []string{\\n    95→\\t\\t\\t\\\"read\\\", \\\"write\\\", \\\"shell\\\", \\\"grep\\\", \\\"glob\\\",\\n    96→\\t\\t\\t\\\"aws\\\", \\\"report\\\", \\\"introspect\\\", \\\"knowledge\\\",\\n    97→\\t\\t\\t\\\"thinking\\\", \\\"todo\\\", \\\"delegate\\\",\\n    98→\\t\\t},\\n    99→\\t\\tHooks: kiroHooks{\\n   100→\\t\\t\\tAgentSpawn:       []kiroHookEntry{{Command: cmdPrefix + HookNameAgentSpawn}},\\n   101→\\t\\t\\tUserPromptSubmit: []kiroHookEntry{{Command: cmdPrefix + HookNameUserPromptSubmit}},\\n   102→\\t\\t\\tPreToolUse:       []kiroHookEntry{{Command: cmdPrefix + HookNamePreToolUse}},\\n   103→\\t\\t\\tPostToolUse:      []kiroHookEntry{{Command: cmdPrefix + HookNamePostToolUse}},\\n   104→\\t\\t\\tStop:             []kiroHookEntry{{Command: cmdPrefix + HookNameStop}},\\n   105→\\t\\t},\\n   106→\\t}\\n   107→\\n   108→\\tif err := os.MkdirAll(filepath.Dir(hooksPath), 0o750); err != nil {\\n   109→\\t\\treturn 0, fmt.Errorf(\\\"failed to create .kiro/agents directory: %w\\\", err)\\n   110→\\t}\\n   111→\\n   112→\\toutput, err := jsonutil.MarshalIndentWithNewline(file, \\\"\\\", \\\"  \\\")\\n   113→\\tif err != nil {\\n   114→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal hooks config: %w\\\", err)\\n   115→\\t}\\n   116→\\n   117→\\tif err := os.WriteFile(hooksPath, output, 0o600); err != nil {\\n   118→\\t\\treturn 0, fmt.Errorf(\\\"failed to write hooks config: %w\\\", err)\\n   119→\\t}\\n   120→\\n   121→\\t// Install IDE hooks (.kiro/hooks/*.kiro.hook)\\n   122→\\tideCount, err := installIDEHooks(worktreeRoot, cmdPrefix)\\n   123→\\tif err != nil {\\n   124→\\t\\treturn 0, fmt.Errorf(\\\"failed to install IDE hooks: %w\\\", err)\\n   125→\\t}\\n   126→\\n   127→\\treturn len(k.HookNames()) + ideCount, nil\\n   128→}\\n   129→\\n   130→// UninstallHooks removes the Entire hooks config file and IDE hook files.\\n   131→func (k *KiroAgent) UninstallHooks(ctx context.Context) error {\\n   132→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n   133→\\tif err != nil {\\n   134→\\t\\tworktreeRoot = \\\".\\\"\\n   135→\\t}\\n   136→\\n   137→\\t// Remove CLI agent file\\n   138→\\thooksPath := filepath.Join(worktreeRoot, \\\".kiro\\\", hooksDir, HooksFileName)\\n   139→\\tif err := os.Remove(hooksPath); err != nil && !os.IsNotExist(err) {\\n   140→\\t\\treturn fmt.Errorf(\\\"failed to remove hooks config: %w\\\", err)\\n   141→\\t}\\n   142→\\n   143→\\t// Remove IDE hook files\\n   144→\\tfor _, def := range ideHookDefs {\\n   145→\\t\\tidePath := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir, def.Filename+ideHookFileSuffix)\\n   146→\\t\\tif err := os.Remove(idePath); err != nil && !os.IsNotExist(err) {\\n   147→\\t\\t\\treturn fmt.Errorf(\\\"failed to remove IDE hook %s: %w\\\", def.Filename, err)\\n   148→\\t\\t}\\n   149→\\t}\\n   150→\\n   151→\\treturn nil\\n   152→}\\n   153→\\n   154→// AreHooksInstalled checks if Entire hooks are installed.\\n   155→// Returns true if EITHER CLI agent hooks or IDE hooks are present.\\n   156→func (k *KiroAgent) AreHooksInstalled(ctx context.Context) bool {\\n   157→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n   158→\\tif err != nil {\\n   159→\\t\\tworktreeRoot = \\\".\\\"\\n   160→\\t}\\n   161→\\n   162→\\t// Check CLI agent hooks\\n   163→\\thooksPath := filepath.Join(worktreeRoot, \\\".kiro\\\", hooksDir, HooksFileName)\\n   164→\\tdata, err := os.ReadFile(hooksPath) //nolint:gosec // path constructed from repo root\\n   165→\\tif err == nil {\\n   166→\\t\\tvar file kiroAgentFile\\n   167→\\t\\tif json.Unmarshal(data, &file) == nil {\\n   168→\\t\\t\\tif hasEntireHook(file.Hooks.AgentSpawn) ||\\n   169→\\t\\t\\t\\thasEntireHook(file.Hooks.User