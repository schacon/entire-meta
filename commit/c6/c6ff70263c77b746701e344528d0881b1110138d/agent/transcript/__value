9→\\t\\t\\tform := NewAccessibleForm(\\n   240→\\t\\t\\t\\thuh.NewGroup(\\n   241→\\t\\t\\t\\t\\thuh.NewInput().\\n   242→\\t\\t\\t\\t\\t\\tTitle(\\\"Trail title\\\").\\n   243→\\t\\t\\t\\t\\t\\tPlaceholder(defaultTitle).\\n   244→\\t\\t\\t\\t\\t\\tValue(&inputTitle),\\n   245→\\t\\t\\t\\t),\\n   246→\\t\\t\\t)\\n   247→\\t\\t\\tif formErr := form.Run(); formErr != nil {\\n   248→\\t\\t\\t\\treturn fmt.Errorf(\\\"form cancelled: %w\\\", formErr)\\n   249→\\t\\t\\t}\\n   250→\\t\\t\\tif inputTitle != \\\"\\\" {\\n   251→\\t\\t\\t\\ttitle = inputTitle\\n   252→\\t\\t\\t} else {\\n   253→\\t\\t\\t\\ttitle = defaultTitle\\n   254→\\t\\t\\t}\\n   255→\\t\\t} else {\\n   256→\\t\\t\\ttitle = defaultTitle\\n   257→\\t\\t}\\n   258→\\t}\\n   259→\\n   260→\\t// Determine status\\n   261→\\tvar trailStatus trail.Status\\n   262→\\tif statusStr != \\\"\\\" {\\n   263→\\t\\ttrailStatus = trail.Status(statusStr)\\n   264→\\t\\tif !trailStatus.IsValid() {\\n   265→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusStr, formatValidStatuses())\\n   266→\\t\\t}\\n   267→\\t} else {\\n   268→\\t\\ttrailStatus = trail.StatusDraft\\n   269→\\t}\\n   270→\\n   271→\\t// Generate trail ID\\n   272→\\ttrailID, err := trail.GenerateID()\\n   273→\\tif err != nil {\\n   274→\\t\\treturn fmt.Errorf(\\\"failed to generate trail ID: %w\\\", err)\\n   275→\\t}\\n   276→\\n   277→\\t// Get git author\\n   278→\\tauthorName, _ := checkpoint.GetGitAuthorFromRepo(repo)\\n   279→\\n   280→\\tnow := time.Now()\\n   281→\\tmetadata := &trail.Metadata{\\n   282→\\t\\tTrailID:     trailID,\\n   283→\\t\\tBranch:      branch,\\n   284→\\t\\tBase:        base,\\n   285→\\t\\tTitle:       title,\\n   286→\\t\\tDescription: description,\\n   287→\\t\\tStatus:      trailStatus,\\n   288→\\t\\tAuthor:      authorName,\\n   289→\\t\\tAssignees:   []string{},\\n   290→\\t\\tLabels:      []string{},\\n   291→\\t\\tCreatedAt:   now,\\n   292→\\t\\tUpdatedAt:   now,\\n   293→\\t}\\n   294→\\n   295→\\tif err := store.Write(metadata, nil, nil); err != nil {\\n   296→\\t\\treturn fmt.Errorf(\\\"failed to create trail: %w\\\", err)\\n   297→\\t}\\n   298→\\n   299→\\tfmt.Fprintf(w, \\\"Created trail %q for branch %s (ID: %s)\\\\n\\\", title, branch, trailID)\\n   300→\\treturn nil\\n   301→}\\n   302→\\n   303→func newTrailUpdateCmd() *cobra.Command {\\n   304→\\tvar statusStr, title, description, branch string\\n   305→\\tvar labelAdd, labelRemove []string\\n   306→\\n   307→\\tcmd := &cobra.Command{\\n   308→\\t\\tUse:   \\\"update\\\",\\n   309→\\t\\tShort: \\\"Update trail metadata\\\",\\n   310→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   311→\\t\\t\\treturn runTrailUpdate(cmd.OutOrStdout(), statusStr, title, description, branch, labelAdd, labelRemove)\\n   312→\\t\\t},\\n   313→\\t}\\n   314→\\n   315→\\tcmd.Flags().StringVar(&statusStr, \\\"status\\\", \\\"\\\", \\\"Update status\\\")\\n   316→\\tcmd.Flags().StringVar(&title, \\\"title\\\", \\\"\\\", \\\"Update title\\\")\\n   317→\\tcmd.Flags().StringVar(&description, \\\"description\\\", \\\"\\\", \\\"Update description\\\")\\n   318→\\tcmd.Flags().StringVar(&branch, \\\"branch\\\", \\\"\\\", \\\"Branch to update trail for (defaults to current)\\\")\\n   319→\\tcmd.Flags().StringSliceVar(&labelAdd, \\\"add-label\\\", nil, \\\"Add label(s)\\\")\\n   320→\\tcmd.Flags().StringSliceVar(&labelRemove, \\\"remove-label\\\", nil, \\\"Remove label(s)\\\")\\n   321→\\n   322→\\treturn cmd\\n   323→}\\n   324→\\n   325→func runTrailUpdate(w io.Writer, statusStr, title, description, branch string, labelAdd, labelRemove []string) error {\\n   326→\\trepo, err := strategy.OpenRepository()\\n   327→\\tif err != nil {\\n   328→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   329→\\t}\\n   330→\\n   331→\\t// Determine branch\\n   332→\\tif branch == \\\"\\\" {\\n   333→\\t\\tbranch, err = GetCurrentBranch()\\n   334→\\t\\tif err != nil {\\n   335→\\t\\t\\treturn fmt.Errorf(\\\"failed to determine current branch: %w\\\", err)\\n   336→\\t\\t}\\n   337→\\t}\\n   338→\\n   339→\\tstore := trail.NewStore(repo)\\n   340→\\tmetadata, err := store.FindByBranch(branch)\\n   341→\\tif err != nil {\\n   342→\\t\\treturn fmt.Errorf(\\\"failed to find trail: %w\\\", err)\\n   343→\\t}\\n   344→\\tif metadata == nil {\\n   345→\\t\\treturn fmt.Errorf(\\\"no trail found for branch %q\\\", branch)\\n   346→\\t}\\n   347→\\n   348→\\t// Validate status if provided\\n   349→\\tif statusStr != \\\"\\\" {\\n   350→\\t\\tstatus := trail.Status(statusStr)\\n   351→\\t\\tif !status.IsValid() {\\n   352→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusStr, formatValidStatuses())\\n   353→\\t\\t}\\n   354→\\t}\\n   355→\\n   356→\\terr = store.Update(metadata.TrailID, func(m *trail.Metadata) {\\n   357→\\t\\tif statusStr != \\\"\\\" {\\n   358→\\t\\t\\tm.Status = trail.Status(statusStr)\\n   359→\\t\\t}\\n   360→\\t\\tif title != \\\"\\\" {\\n   361→\\t\\t\\tm.Title = title\\n   362→\\t\\t}\\n   363→\\t\\tif description != \\\"\\\" {\\n   364→\\t\\t\\tm.Description = description\\n   365→\\t\\t}\\n   366→\\t\\tfor _, l := range labelAdd {\\n   367→\\t\\t\\tif !containsString(m.Labels, l) {\\n   368→\\t\\t\\t\\tm.Labels = append(m.Labels, l)\\n   369→\\t\\t\\t}\\n   370→\\t\\t}\\n   371→\\t\\tfor _, l := range labelRemove {\\n   372→\\t\\t\\tm.Labels = removeString(m.Labels, l)\\n   373→\\t\\t}\\n   374→\\t})\\n   375→\\tif err != nil {\\n   376→\\t\\treturn fmt.Errorf(\\\"failed to update trail: %w\\\", err)\\n   377→\\t}\\n   378→\\n   379→\\tfmt.Fprintf(w, \\\"Updated trail for branch %s\\\\n\\\", branch)\\n   380→\\treturn nil\\n   381→}\\n   382→\\n   383→func newTrailEnableCmd() *cobra.Command {\\n   384→\\tcmd := &cobra.Command{\\n   385→\\t\\tUse:   \\\"enable\\\",\\n   386→\\t\\tShort: \\\"Enable automatic trail creation and pushing\\\",\\n   387→\\t\\tLong: `Enable trail auto-creation on session start and pushing the trails branch\\n   388→on git push. Trails are enabled by default.`,\\n   389→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   390→\\t\\t\\treturn runTrailEnable(cmd.OutOrStdout())\\n   391→\\t\\t},\\n   392→\\t}\\n   393→\\treturn cmd\\n   394→}\\n   395→\\n   396→func runTrailEnable(w io.Writer) error {\\n   397→\\ts, err := LoadEntireSettings()\\n   398→\\tif err != nil {\\n   399→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   400→\\t}\\n   401→\\n   402→\\tif s.StrategyOptions != nil {\\n   403→\\t\\tdelete(s.StrategyOptions, \\\"trails\\\")\\n   404→\\t}\\n   405→\\n   406→\\tif err := SaveEntireSettings(s); err != nil {\\n   407→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   408→\\t}\\n   409→\\n   410→\\tfmt.Fprintln(w, \\\"Trails enabled.\\\")\\n   411→\\treturn nil\\n   412→}\\n   413→\\n   414→func newTrailDisableCmd() *cobra.Command {\\n   415→\\tvar useProjectSettings bool\\n   416→\\n   417→\\tcmd := &cobra.Command{\\n   418→\\t\\tUse:   \\\"disable\\\",\\n   419→\\t\\tShort: \\\"Disable automatic trail creation and pushing\\\",\\n   420→\\t\\tLong: `Disable trail auto-creation on session start and pushing the trails branch\\n   421→on git push. Existing trails are preserved.\\n   422→\\n   423→By default, writes to .entire/settings.local.json. Use --project to write to\\n   424→.entire/settings.json instead.`,\\n   425→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   426→\\t\\t\\treturn runTrailDisable(cmd.OutOrStdout(), useProjectSettings)\\n   427→\\t\\t},\\n   428→\\t}\\n   429→\\n   430→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Write to .entire/settings.json instead of .entire/settings.local.json\\\")\\n   431→\\treturn cmd\\n   432→}\\n   433→\\n   434→func runTrailDisable(w io.Writer, useProjectSettings bool) error {\\n   435→\\ts, err := LoadEntireSettings()\\n   436→\\tif err != nil {\\n   437→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   438→\\t}\\n   439→\\n   440→\\tif s.StrategyOptions == nil {\\n   441→\\t\\ts.StrategyOptions = make(map[string]any)\\n   442→\\t}\\n   443→\\ts.StrategyOptions[\\\"trails\\\"] = false\\n   444→\\n   445→\\tif useProjectSettings {\\n   446→\\t\\tif err := SaveEntireSettings(s); err != nil {\\n   447→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   448→\\t\\t}\\n   449→\\t} else {\\n   450→\\t\\tif err := SaveEntireSettingsLocal(s); err != nil {\\n   451→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   452→\\t\\t}\\n   453→\\t}\\n   454→\\n   455→\\tfmt.Fprintln(w, \\\"Trails disabled.\\\")\\n   456→\\treturn nil\\n   457→}\\n   458→\\n   459→// defaultBaseBranch is the fallback base branch name when it cannot be determined.\\n   460→const defaultBaseBranch = \\\"main\\\"\\n   461→\\n   462→// AutoCreateTrail creates a trail automatically for the current branch if one doesn't exist.\\n   463→// This is called during session start for non-main branches.\\n   464→// If prompt is non-empty, its first line is used as the trail title instead of the branch name.\\n   465→func AutoCreateTrail(repo *git.Repository, branchName, baseBranch, prompt string) error {\\n   466→\\tstore := trail.NewStore(repo)\\n   467→\\n   468→\\texisting, err := store.FindByBranch(branchName)\\n   469→\\tif err == nil && existing != nil {\\n   470→\\t\\treturn nil // Trail already exists\\n   471→\\t}\\n   472→\\n   473→\\ttrailID, err := trail.GenerateID()\\n   474→\\tif err != nil {\\n   475→\\t\\treturn fmt.Errorf(\\\"failed to generate trail ID: %w\\\", err)\\n   476→\\t}\\n   477→\\n   478→\\tauthorName, _ := checkpoint.GetGitAuthorFromRepo(repo)\\n   479→\\tnow := time.Now()\\n   480→\\n   481→\\ttitle := titleFromPrompt(prompt)\\n   482→\\tif title == \\\"\\\" {\\n   483→\\t\\ttitle = trail.HumanizeBranchName(branchName)\\n   484→\\t}\\n   485→\\n   486→\\tmetadata := &trail.Metadata{\\n   487→\\t\\tTrailID:   trailID,\\n   488→\\t\\tBranch:    branchName,\\n   489→\\t\\tBase:      baseBranch,\\n   490→\\t\\tTitle:     title,\\n   491→\\t\\tStatus:    trail.StatusInProgress,\\n   492→\\t\\tAuthor:    authorName,\\n   493→\\t\\tAssignees: []string{},\\n   494→\\t\\tLabels:    []string{},\\n   495→\\t\\tCreatedAt: now,\\n   496→\\t\\tUpdatedAt: now,\\n   497→\\t}\\n   498→\\n   499→\\tif err := store.Write(metadata, nil, nil); err != nil {\\n   500→\\t\\treturn fmt.Errorf(\\\"failed to create trail: %w\\\", err)\\n   501→\\t}\\n   502→\\n   503→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Created trail for branch: %s\\\\n\\\", branchName)\\n   504→\\treturn nil\\n   505→}\\n   506→\\n   507→// titleFromPrompt extracts a trail title from the user's prompt.\\n   508→// Uses the first line, trimmed and truncated to 80 characters.\\n   509→// Returns empty string if prompt is empty.\\n   510→func titleFromPrompt(prompt string) string {\\n   511→\\tif prompt == \\\"\\\" {\\n   512→\\t\\treturn \\\"\\\"\\n   513→\\t}\\n   514→\\tline, _, _ := strings.Cut(prompt, \\\"\\\\n\\\")\\n   515→\\ttitle := strings.TrimSpace(line)\\n   516→\\tif len(title) > 80 {\\n   517→\\t\\ttitle = title[:77] + \\\"...\\\"\\n   518→\\t}\\n   519→\\treturn title\\n   520→}\\n   521→\\n   522→// hasFlag is a simple helper that checks os.Args for --flag presence.\\n   523→// Used to distinguish between \\\"flag not provided\\\" and \\\"flag provided with empty value\\\".\\n   524→func hasFlag(name string) bool {\\n   525→\\tfor _, arg := range os.Args {\\n   526→\\t\\tif arg == \\\"--\\\"+name || strings.HasPrefix(arg, \\\"--\\\"+name+\\\"=\\\") {\\n   527→\\t\\t\\treturn true\\n   528→\\t\\t}\\n   529→\\t}\\n   530→\\treturn false\\n   531→}\\n   532→\\n   533→func truncate(s string, maxLen int) string {\\n   534→\\tif len(s) <= maxLen {\\n   535→\\t\\treturn s\\n   536→\\t}\\n   537→\\tif maxLen <= 3 {\\n   538→\\t\\treturn s[:maxLen]\\n   539→\\t}\\n   540→\\treturn s[:maxLen-3] + \\\"...\\\"\\n   541→}\\n   542→\\n   543→func formatValidStatuses() string {\\n   544→\\tstatuses := trail.ValidStatuses()\\n   545→\\tnames := make([]string, len(statuses))\\n   546→\\tfor i, s := range statuses {\\n   547→\\t\\tnames[i] = string(s)\\n   548→\\t}\\n   549→\\treturn strings.Join(names, \\\", \\\")\\n   550→}\\n   551→\\n   552→func containsString(slice []string, s string) bool {\\n   553→\\tfor _, v := range slice {\\n   554→\\t\\tif v == s {\\n   555→\\t\\t\\treturn true\\n   556→\\t\\t}\\n   557→\\t}\\n   558→\\treturn false\\n   559→}\\n   560→\\n   561→func removeString(slice []string, s string) []string {\\n   562→\\tvar result []string\\n   563→\\tfor _, v := range slice {\\n   564→\\t\\tif v != s {\\n   565→\\t\\t\\tresult = append(result, v)\\n   566→\\t\\t}\\n   567→\\t}\\n   568→\\treturn result\\n   569→}\\n   570→\"}]},\"uuid\":\"b7eb3a56-e968-46c1-b3f8-a39b18093eeb\",\"timestamp\":\"2026-02-23T08:26:12.207Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/dip/Repositories/cli/cmd/entire/cli/trail_cmd.go\",\"content\":\"package cli\\n\\nimport (\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"io\\\"\\n\\t\\\"os\\\"\\n\\t\\\"sort\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/trail\\\"\\n\\n\\t\\\"github.com/charmbracelet/huh\\\"\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/spf13/cobra\\\"\\n)\\n\\nfunc newTrailCmd() *cobra.Command {\\n\\tcmd := &cobra.Command{\\n\\t\\tUse:   \\\"trail\\\",\\n\\t\\tShort: \\\"Manage trails for your branches\\\",\\n\\t\\tLong: `Trails are branch-centric work tracking abstractions. They describe the\\n\\\"why\\\" and \\\"what\\\" of your work, while checkpoints capture the \\\"how\\\" and \\\"when\\\".\\n\\nRunning 'entire trail' without a subcommand shows the trail for the current\\nbranch, or lists all trails if no trail exists for the current branch.`,\\n\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n\\t\\t\\treturn runTrailShow(cmd.OutOrStdout())\\n\\t\\t},\\n\\t}\\n\\n\\tcmd.AddCommand(newTrailListCmd())\\n\\tcmd.AddCommand(newTrailCreateCmd())\\n\\tcmd.AddCommand(newTrailUpdateCmd())\\n\\tcmd.AddCommand(newTrailEnableCmd())\\n\\tcmd.AddCommand(newTrailDisableCmd())\\n\\n\\treturn cmd\\n}\\n\\n// runTrailShow shows the trail for the current branch, or falls through to list.\\nfunc runTrailShow(w io.Writer) error {\\n\\tbranch, err := GetCurrentBranch()\\n\\tif err != nil {\\n\\t\\treturn runTrailListAll(w, \\\"\\\", false)\\n\\t}\\n\\n\\trepo, err := strategy.OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\tstore := trail.NewStore(repo)\\n\\tmetadata, err := store.FindByBranch(branch)\\n\\tif err != nil || metadata == nil {\\n\\t\\treturn runTrailListAll(w, \\\"\\\", false)\\n\\t}\\n\\n\\tprintTrailDetails(w, metadata)\\n\\treturn nil\\n}\\n\\nfunc printTrailDetails(w io.Writer, m *trail.Metadata) {\\n\\tfmt.Fprintf(w, \\\"Trail: %s\\\\n\\\", m.Title)\\n\\tfmt.Fprintf(w, \\\"  ID:      %s\\\\n\\\", m.TrailID)\\n\\tfmt.Fprintf(w, \\\"  Branch:  %s\\\\n\\\", m.Branch)\\n\\tfmt.Fprintf(w, \\\"  Base:    %s\\\\n\\\", m.Base)\\n\\tfmt.Fprintf(w, \\\"  Status:  %s\\\\n\\\", m.Status)\\n\\tfmt.Fprintf(w, \\\"  Author:  %s\\\\n\\\", m.Author)\\n\\tif m.Description != \\\"\\\" {\\n\\t\\tfmt.Fprintf(w, \\\"  Description: %s\\\\n\\\", m.Description)\\n\\t}\\n\\tif len(m.Labels) > 0 {\\n\\t\\tfmt.Fprintf(w, \\\"  Labels:  %s\\\\n\\\", strings.Join(m.Labels, \\\", \\\"))\\n\\t}\\n\\tif len(m.Assignees) > 0 {\\n\\t\\tfmt.Fprintf(w, \\\"  Assignees: %s\\\\n\\\", strings.Join(m.Assignees, \\\", \\\"))\\n\\t}\\n\\tfmt.Fprintf(w, \\\"  Created: %s\\\\n\\\", m.CreatedAt.Format(time.RFC3339))\\n\\tfmt.Fprintf(w, \\\"  Updated: %s\\\\n\\\", m.UpdatedAt.Format(time.RFC3339))\\n}\\n\\nfunc newTrailListCmd() *cobra.Command {\\n\\tvar statusFilter string\\n\\tvar jsonOutput bool\\n\\n\\tcmd := &cobra.Command{\\n\\t\\tUse:   \\\"list\\\",\\n\\t\\tShort: \\\"List all trails\\\",\\n\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n\\t\\t\\treturn runTrailListAll(cmd.OutOrStdout(), statusFilter, jsonOutput)\\n\\t\\t},\\n\\t}\\n\\n\\tcmd.Flags().StringVar(&statusFilter, \\\"status\\\", \\\"\\\", \\\"Filter by status (draft, open, in_progress, in_review, done, closed)\\\")\\n\\tcmd.Flags().BoolVar(&jsonOutput, \\\"json\\\", false, \\\"Output as JSON\\\")\\n\\n\\treturn cmd\\n}\\n\\nfunc runTrailListAll(w io.Writer, statusFilter string, jsonOutput bool) error {\\n\\trepo, err := strategy.OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\tstore := trail.NewStore(repo)\\n\\ttrails, err := store.List()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to list trails: %w\\\", err)\\n\\t}\\n\\n\\tif trails == nil {\\n\\t\\ttrails = []*trail.Metadata{}\\n\\t}\\n\\n\\t// Apply status filter\\n\\tif statusFilter != \\\"\\\" {\\n\\t\\tstatus := trail.Status(statusFilter)\\n\\t\\tif !status.IsValid() {\\n\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusFilter, formatValidStatuses())\\n\\t\\t}\\n\\t\\tvar filtered []*trail.Metadata\\n\\t\\tfor _, t := range trails {\\n\\t\\t\\tif t.Status == status {\\n\\t\\t\\t\\tfiltered = append(filtered, t)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t\\ttrails = filtered\\n\\t}\\n\\n\\t// Sort by updated_at descending\\n\\tsort.Slice(trails, func(i, j int) bool {\\n\\t\\treturn trails[i].UpdatedAt.After(trails[j].UpdatedAt)\\n\\t})\\n\\n\\tif jsonOutput {\\n\\t\\tenc := json.NewEncoder(w)\\n\\t\\tenc.SetIndent(\\\"\\\", \\\"  \\\")\\n\\t\\tif err := enc.Encode(trails); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to encode JSON: %w\\\", err)\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\tif len(trails) == 0 {\\n\\t\\tfmt.Fprintln(w, \\\"No trails found.\\\")\\n\\t\\tfmt.Fprintln(w)\\n\\t\\tfmt.Fprintln(w, \\\"Commands:\\\")\\n\\t\\tfmt.Fprintln(w, \\\"  entire trail create   Create a trail for the current branch\\\")\\n\\t\\tfmt.Fprintln(w, \\\"  entire trail list     List all trails\\\")\\n\\t\\tfmt.Fprintln(w, \\\"  entire trail update   Update trail metadata\\\")\\n\\t\\tfmt.Fprintln(w, \\\"  entire trail enable   Enable automatic trail creation\\\")\\n\\t\\tfmt.Fprintln(w, \\\"  entire trail disable  Disable automatic trail creation\\\")\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Table output\\n\\tfmt.Fprintf(w, \\\"%-30s %-40s %-13s %-15s %s\\\\n\\\", \\\"BRANCH\\\", \\\"TITLE\\\", \\\"STATUS\\\", \\\"AUTHOR\\\", \\\"UPDATED\\\")\\n\\tfor _, t := range trails {\\n\\t\\tbranch := truncate(t.Branch, 30)\\n\\t\\ttitle := truncate(t.Title, 40)\\n\\t\\tfmt.Fprintf(w, \\\"%-30s %-40s %-13s %-15s %s\\\\n\\\",\\n\\t\\t\\tbranch, title, t.Status, truncate(t.Author, 15), timeAgo(t.UpdatedAt))\\n\\t}\\n\\n\\treturn nil\\n}\\n\\nfunc newTrailCreateCmd() *cobra.Command {\\n\\tvar title, description, base, branch, status string\\n\\n\\tcmd := &cobra.Command{\\n\\t\\tUse:   \\\"create\\\",\\n\\t\\tShort: \\\"Create a trail for the current or a new branch\\\",\\n\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n\\t\\t\\treturn runTrailCreate(cmd.OutOrStdout(), cmd.ErrOrStderr(), title, description, base, branch, status)\\n\\t\\t},\\n\\t}\\n\\n\\tcmd.Flags().StringVar(&title, \\\"title\\\", \\\"\\\", \\\"Trail title\\\")\\n\\tcmd.Flags().StringVar(&description, \\\"description\\\", \\\"\\\", \\\"Trail description\\\")\\n\\tcmd.Flags().StringVar(&base, \\\"base\\\", \\\"\\\", \\\"Base branch (defaults to detected default branch)\\\")\\n\\tcmd.Flags().StringVar(&branch, \\\"branch\\\", \\\"\\\", \\\"Branch for the trail (defaults to current branch)\\\")\\n\\tcmd.Flags().StringVar(&status, \\\"status\\\", \\\"\\\", \\\"Initial status (defaults to draft)\\\")\\n\\n\\treturn cmd\\n}\\n\\n//nolint:cyclop // sequential steps for creating a trail — splitting would obscure the flow\\nfunc runTrailCreate(w, errW io.Writer, title, description, base, branch, statusStr string) error {\\n\\trepo, err := strategy.OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\t// Determine branch\\n\\tif branch == \\\"\\\" {\\n\\t\\tbranch, err = GetCurrentBranch()\\n\\t\\tif err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to determine current branch: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// Check if on default branch\\n\\tif isDefault, _, defaultErr := IsOnDefaultBranch(); defaultErr == nil && isDefault {\\n\\t\\tfmt.Fprintln(errW, \\\"Cannot create a trail on the default branch.\\\")\\n\\t\\tfmt.Fprintln(errW, \\\"Create or switch to a feature branch first.\\\")\\n\\t\\treturn NewSilentError(errors.New(\\\"cannot create trail on default branch\\\"))\\n\\t}\\n\\n\\t// Determine base branch\\n\\tif base == \\\"\\\" {\\n\\t\\tbase = strategy.GetDefaultBranchName(repo)\\n\\t\\tif base == \\\"\\\" {\\n\\t\\t\\tbase = defaultBaseBranch\\n\\t\\t}\\n\\t}\\n\\n\\t// Check if trail already exists for this branch\\n\\tstore := trail.NewStore(repo)\\n\\texisting, err := store.FindByBranch(branch)\\n\\tif err == nil && existing != nil {\\n\\t\\tfmt.Fprintf(w, \\\"Trail already exists for branch %q (ID: %s)\\\\n\\\", branch, existing.TrailID)\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Determine title\\n\\tif title == \\\"\\\" {\\n\\t\\tdefaultTitle := trail.HumanizeBranchName(branch)\\n\\n\\t\\t// Interactive mode if flags not provided\\n\\t\\tif !hasFlag(\\\"title\\\") {\\n\\t\\t\\tvar inputTitle string\\n\\t\\t\\tform := NewAccessibleForm(\\n\\t\\t\\t\\thuh.NewGroup(\\n\\t\\t\\t\\t\\thuh.NewInput().\\n\\t\\t\\t\\t\\t\\tTitle(\\\"Trail title\\\").\\n\\t\\t\\t\\t\\t\\tPlaceholder(defaultTitle).\\n\\t\\t\\t\\t\\t\\tValue(&inputTitle),\\n\\t\\t\\t\\t),\\n\\t\\t\\t)\\n\\t\\t\\tif formErr := form.Run(); formErr != nil {\\n\\t\\t\\t\\treturn fmt.Errorf(\\\"form cancelled: %w\\\", formErr)\\n\\t\\t\\t}\\n\\t\\t\\tif inputTitle != \\\"\\\" {\\n\\t\\t\\t\\ttitle = inputTitle\\n\\t\\t\\t} else {\\n\\t\\t\\t\\ttitle = defaultTitle\\n\\t\\t\\t}\\n\\t\\t} else {\\n\\t\\t\\ttitle = defaultTitle\\n\\t\\t}\\n\\t}\\n\\n\\t// Determine status\\n\\tvar trailStatus trail.Status\\n\\tif statusStr != \\\"\\\" {\\n\\t\\ttrailStatus = trail.Status(statusStr)\\n\\t\\tif !trailStatus.IsValid() {\\n\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusStr, formatValidStatuses())\\n\\t\\t}\\n\\t} else {\\n\\t\\ttrailStatus = trail.StatusDraft\\n\\t}\\n\\n\\t// Generate trail ID\\n\\ttrailID, err := trail.GenerateID()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to generate trail ID: %w\\\", err)\\n\\t}\\n\\n\\t// Get git author\\n\\tauthorName, _ := checkpoint.GetGitAuthorFromRepo(repo)\\n\\n\\tnow := time.Now()\\n\\tmetadata := &trail.Metadata{\\n\\t\\tTrailID:     trailID,\\n\\t\\tBranch:      branch,\\n\\t\\tBase:        base,\\n\\t\\tTitle:       title,\\n\\t\\tDescription: description,\\n\\t\\tStatus:      trailStatus,\\n\\t\\tAuthor:      authorName,\\n\\t\\tAssignees:   []string{},\\n\\t\\tLabels:      []string{},\\n\\t\\tCreatedAt:   now,\\n\\t\\tUpdatedAt:   now,\\n\\t}\\n\\n\\tif err := store.Write(metadata, nil, nil); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create trail: %w\\\", err)\\n\\t}\\n\\n\\tfmt.Fprintf(w, \\\"Created trail %q for branch %s (ID: %s)\\\\n\\\", title, branch, trailID)\\n\\treturn nil\\n}\\n\\nfunc newTrailUpdateCmd() *cobra.Command {\\n\\tvar statusStr, title, description, branch string\\n\\tvar labelAdd, labelRemove []string\\n\\n\\tcmd := &cobra.Command{\\n\\t\\tUse:   \\\"update\\\",\\n\\t\\tShort: \\\"Update trail metadata\\\",\\n\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n\\t\\t\\treturn runTrailUpdate(cmd.OutOrStdout(), statusStr, title, description, branch, labelAdd, labelRemove)\\n\\t\\t},\\n\\t}\\n\\n\\tcmd.Flags().StringVar(&statusStr, \\\"status\\\", \\\"\\\", \\\"Update status\\\")\\n\\tcmd.Flags().StringVar(&title, \\\"title\\\", \\\"\\\", \\\"Update title\\\")\\n\\tcmd.Flags().StringVar(&description, \\\"description\\\", \\\"\\\", \\\"Update description\\\")\\n\\tcmd.Flags().StringVar(&branch, \\\"branch\\\", \\\"\\\", \\\"Branch to update trail for (defaults to current)\\\")\\n\\tcmd.Flags().StringSliceVar(&labelAdd, \\\"add-label\\\", nil, \\\"Add label(s)\\\")\\n\\tcmd.Flags().StringSliceVar(&labelRemove, \\\"remove-label\\\", nil, \\\"Remove label(s)\\\")\\n\\n\\treturn cmd\\n}\\n\\nfunc runTrailUpdate(w io.Writer, statusStr, title, description, branch string, labelAdd, labelRemove []string) error {\\n\\trepo, err := strategy.OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\t// Determine branch\\n\\tif branch == \\\"\\\" {\\n\\t\\tbranch, err = GetCurrentBranch()\\n\\t\\tif err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to determine current branch: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\tstore := trail.NewStore(repo)\\n\\tmetadata, err := store.FindByBranch(branch)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to find trail: %w\\\", err)\\n\\t}\\n\\tif metadata == nil {\\n\\t\\treturn fmt.Errorf(\\\"no trail found for branch %q\\\", branch)\\n\\t}\\n\\n\\t// Validate status if provided\\n\\tif statusStr != \\\"\\\" {\\n\\t\\tstatus := trail.Status(statusStr)\\n\\t\\tif !status.IsValid() {\\n\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusStr, formatValidStatuses())\\n\\t\\t}\\n\\t}\\n\\n\\terr = store.Update(metadata.TrailID, func(m *trail.Metadata) {\\n\\t\\tif statusStr != \\\"\\\" {\\n\\t\\t\\tm.Status = trail.Status(statusStr)\\n\\t\\t}\\n\\t\\tif title != \\\"\\\" {\\n\\t\\t\\tm.Title = title\\n\\t\\t}\\n\\t\\tif description != \\\"\\\" {\\n\\t\\t\\tm.Description = description\\n\\t\\t}\\n\\t\\tfor _, l := range labelAdd {\\n\\t\\t\\tif !containsString(m.Labels, l) {\\n\\t\\t\\t\\tm.Labels = append(m.Labels, l)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t\\tfor _, l := range labelRemove {\\n\\t\\t\\tm.Labels = removeString(m.Labels, l)\\n\\t\\t}\\n\\t})\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to update trail: %w\\\", err)\\n\\t}\\n\\n\\tfmt.Fprintf(w, \\\"Updated trail for branch %s\\\\n\\\", branch)\\n\\treturn nil\\n}\\n\\nfunc newTrailEnableCmd() *cobra.Command {\\n\\tcmd := &cobra.Command{\\n\\t\\tUse:   \\\"enable\\\",\\n\\t\\tShort: \\\"Enable automatic trail creation and pushing\\\",\\n\\t\\tLong: `Enable trail auto-creation on session start and pushing the trails branch\\non git push. Trails are enabled by default.`,\\n\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n\\t\\t\\treturn runTrailEnable(cmd.OutOrStdout())\\n\\t\\t},\\n\\t}\\n\\treturn cmd\\n}\\n\\nfunc runTrailEnable(w io.Writer) error {\\n\\ts, err := LoadEntireSettings()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n\\t}\\n\\n\\tif s.StrategyOptions != nil {\\n\\t\\tdelete(s.StrategyOptions, \\\"trails\\\")\\n\\t}\\n\\n\\tif err := SaveEntireSettings(s); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n\\t}\\n\\n\\tfmt.Fprintln(w, \\\"Trails enabled.\\\")\\n\\treturn nil\\n}\\n\\nfunc newTrailDisableCmd() *cobra.Command {\\n\\tvar useProjectSettings bool\\n\\n\\tcmd := &cobra.Command{\\n\\t\\tUse:   \\\"disable\\\",\\n\\t\\tShort: \\\"Disable automatic trail creation and pushing\\\",\\n\\t\\tLong: `Disable trail auto-creation on session start and pushing the trails branch\\non git push. Existing trails are preserved.\\n\\nBy default, writes to .entire/settings.local.json. Use --project to write to\\n.entire/settings.json instead.`,\\n\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n\\t\\t\\treturn runTrailDisable(cmd.OutOrStdout(), useProjectSettings)\\n\\t\\t},\\n\\t}\\n\\n\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Write to .entire/settings.json instead of .entire/settings.local.json\\\")\\n\\treturn cmd\\n}\\n\\nfunc runTrailDisable(w io.Writer, useProjectSettings bool) error {\\n\\ts, err := LoadEntireSettings()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n\\t}\\n\\n\\tif s.StrategyOptions == nil {\\n\\t\\ts.StrategyOptions = make(map[string]any)\\n\\t}\\n\\ts.StrategyOptions[\\\"trails\\\"] = false\\n\\n\\tif useProjectSettings {\\n\\t\\tif err := SaveEntireSettings(s); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n\\t\\t}\\n\\t} else {\\n\\t\\tif err := SaveEntireSettingsLocal(s); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\tfmt.Fprintln(w, \\\"Trails disabled.\\\")\\n\\treturn nil\\n}\\n\\n// defaultBaseBranch is the fallback base branch name when it cannot be determined.\\nconst defaultBaseBranch = \\\"main\\\"\\n\\n// AutoCreateTrail creates a trail automatically for the current branch if one doesn't exist.\\n// This is called during session start for non-main branches.\\n// If prompt is non-empty, its first line is used as the trail title instead of the branch name.\\nfunc AutoCreateTrail(repo *git.Repository, branchName, baseBranch, prompt string) error {\\n\\tstore := trail.NewStore(repo)\\n\\n\\texisting, err := store.FindByBranch(branchName)\\n\\tif err == nil && existing != nil {\\n\\t\\treturn nil // Trail already exists\\n\\t}\\n\\n\\ttrailID, err := trail.GenerateID()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to generate trail ID: %w\\\", err)\\n\\t}\\n\\n\\tauthorName, _ := checkpoint.GetGitAuthorFromRepo(repo)\\n\\tnow := time.Now()\\n\\n\\ttitle := titleFromPrompt(prompt)\\n\\tif title == \\\"\\\" {\\n\\t\\ttitle = trail.HumanizeBranchName(branchName)\\n\\t}\\n\\n\\tmetadata := &trail.Metadata{\\n\\t\\tTrailID:   trailID,\\n\\t\\tBranch:    branchName,\\n\\t\\tBase:      baseBranch,\\n\\t\\tTitle:     title,\\n\\t\\tStatus:    trail.StatusInProgress,\\n\\t\\tAuthor:    authorName,\\n\\t\\tAssignees: []string{},\\n\\t\\tLabels:    []string{},\\n\\t\\tCreatedAt: now,\\n\\t\\tUpdatedAt: now,\\n\\t}\\n\\n\\tif err := store.Write(metadata, nil, nil); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create trail: %w\\\", err)\\n\\t}\\n\\n\\tfmt.Fprintf(os.Stderr, \\\"[entire] Created trail for branch: %s\\\\n\\\", branchName)\\n\\treturn nil\\n}\\n\\n// titleFromPrompt extracts a trail title from the user's prompt.\\n// Uses the first line, trimmed and truncated to 80 characters.\\n// Returns empty string if prompt is empty.\\nfunc titleFromPrompt(prompt string) string {\\n\\tif prompt == \\\"\\\" {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\tline, _, _ := strings.Cut(prompt, \\\"\\\\n\\\")\\n\\ttitle := strings.TrimSpace(line)\\n\\tif len(title) > 80 {\\n\\t\\ttitle = title[:77] + \\\"...\\\"\\n\\t}\\n\\treturn title\\n}\\n\\n// hasFlag is a simple helper that checks os.Args for --flag presence.\\n// Used to distinguish between \\\"flag not provided\\\" and \\\"flag provided with empty value\\\".\\nfunc hasFlag(name string) bool {\\n\\tfor _, arg := range os.Args {\\n\\t\\tif arg == \\\"--\\\"+name || strings.HasPrefix(arg, \\\"--\\\"+name+\\\"=\\\") {\\n\\t\\t\\treturn true\\n\\t\\t}\\n\\t}\\n\\treturn false\\n}\\n\\nfunc truncate(s string, maxLen int) string {\\n\\tif len(s) <= maxLen {\\n\\t\\treturn s\\n\\t}\\n\\tif maxLen <= 3 {\\n\\t\\treturn s[:maxLen]\\n\\t}\\n\\treturn s[:maxLen-3] + \\\"...\\\"\\n}\\n\\nfunc formatValidStatuses() string {\\n\\tstatuses := trail.ValidStatuses()\\n\\tnames := make([]string, len(statuses))\\n\\tfor i, s := range statuses {\\n\\t\\tnames[i] = string(s)\\n\\t}\\n\\treturn strings.Join(names, \\\", \\\")\\n}\\n\\nfunc containsString(slice []string, s string) bool {\\n\\tfor _, v := range slice {\\n\\t\\tif v == s {\\n\\t\\t\\treturn true\\n\\t\\t}\\n\\t}\\n\\treturn false\\n}\\n\\nfunc removeString(s