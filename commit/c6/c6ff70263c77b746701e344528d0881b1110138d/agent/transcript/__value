t// Write prompts file\\n   281→\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   282→\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   283→\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   284→\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   285→\\t}\\n   286→\\tfmt.Fprintf(os.Stderr, \\\"Extracted %d prompt(s) to: %s\\\\n\\\", len(allPrompts), sessionDir+\\\"/\\\"+paths.PromptFileName)\\n   287→\\n   288→\\t// Write summary file\\n   289→\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   290→\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   291→\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   292→\\t}\\n   293→\\tfmt.Fprintf(os.Stderr, \\\"Extracted summary to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName)\\n   294→\\n   295→\\t// Generate commit message from last prompt\\n   296→\\tlastPrompt := \\\"\\\"\\n   297→\\tif len(allPrompts) > 0 {\\n   298→\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   299→\\t}\\n   300→\\tcommitMessage := generateCommitMessage(lastPrompt)\\n   301→\\tfmt.Fprintf(os.Stderr, \\\"Using commit message: %s\\\\n\\\", commitMessage)\\n   302→\\n   303→\\t// Get repo root for path normalization\\n   304→\\trepoRoot, err := paths.RepoRoot()\\n   305→\\tif err != nil {\\n   306→\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   307→\\t}\\n   308→\\n   309→\\tvar preUntrackedFiles []string\\n   310→\\tif preState != nil {\\n   311→\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state: %d pre-existing untracked files\\\\n\\\", len(preState.UntrackedFiles))\\n   312→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   313→\\t}\\n   314→\\n   315→\\t// Detect file changes via git status\\n   316→\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n   317→\\tif err != nil {\\n   318→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   319→\\t}\\n   320→\\n   321→\\t// Filter and normalize all paths\\n   322→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   323→\\tvar relNewFiles, relDeletedFiles []string\\n   324→\\tif changes != nil {\\n   325→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   326→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   327→\\t}\\n   328→\\n   329→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   330→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   331→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   332→\\t// if it exists in HEAD with the same content as the working tree.\\n   333→\\trelModifiedFiles = filterToUncommittedFiles(relModifiedFiles, repoRoot)\\n   334→\\n   335→\\t// Check if there are any changes\\n   336→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   337→\\tif totalChanges == 0 {\\n   338→\\t\\tfmt.Fprintf(os.Stderr, \\\"No files were modified during this session\\\\n\\\")\\n   339→\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipping commit\\\\n\\\")\\n   340→\\t\\ttransitionSessionTurnEnd(sessionID)\\n   341→\\t\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n   342→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   343→\\t\\t}\\n   344→\\t\\treturn nil\\n   345→\\t}\\n   346→\\n   347→\\t// Log file changes\\n   348→\\tlogFileChanges(relModifiedFiles, relNewFiles, relDeletedFiles)\\n   349→\\n   350→\\t// Create context file\\n   351→\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n   352→\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n   353→\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n   354→\\t}\\n   355→\\tfmt.Fprintf(os.Stderr, \\\"Created context file: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.ContextFileName)\\n   356→\\n   357→\\t// Get git author\\n   358→\\tauthor, err := GetGitAuthor()\\n   359→\\tif err != nil {\\n   360→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   361→\\t}\\n   362→\\n   363→\\t// Get strategy and agent type\\n   364→\\tstrat := GetStrategy()\\n   365→\\tagentType := ag.Type()\\n   366→\\n   367→\\t// Get transcript position/identifier from pre-prompt state\\n   368→\\tvar transcriptIdentifierAtStart string\\n   369→\\tvar transcriptLinesAtStart int\\n   370→\\tif preState != nil {\\n   371→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   372→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   373→\\t}\\n   374→\\n   375→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   376→\\tvar tokenUsage *agent.TokenUsage\\n   377→\\tif subagentExtractor, ok := ag.(agent.SubagentAwareExtractor); ok {\\n   378→\\t\\tusage, tokenErr := subagentExtractor.CalculateTotalTokenUsage(transcriptRef, transcriptLinesAtStart, subagentsDir)\\n   379→\\t\\tif tokenErr != nil {\\n   380→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage (with subagents): %v\\\\n\\\", tokenErr)\\n   381→\\t\\t} else {\\n   382→\\t\\t\\ttokenUsage = usage\\n   383→\\t\\t}\\n   384→\\t} else if calculator, ok := ag.(agent.TokenCalculator); ok {\\n   385→\\t\\t// Fall back to basic token calculation (main transcript only)\\n   386→\\t\\tusage, tokenErr := calculator.CalculateTokenUsage(transcriptRef, transcriptLinesAtStart)\\n   387→\\t\\tif tokenErr != nil {\\n   388→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage: %v\\\\n\\\", tokenErr)\\n   389→\\t\\t} else {\\n   390→\\t\\t\\ttokenUsage = usage\\n   391→\\t\\t}\\n   392→\\t}\\n   393→\\n   394→\\t// Build fully-populated step context and delegate to strategy\\n   395→\\tctx := strategy.StepContext{\\n   396→\\t\\tSessionID:                sessionID,\\n   397→\\t\\tModifiedFiles:            relModifiedFiles,\\n   398→\\t\\tNewFiles:                 relNewFiles,\\n   399→\\t\\tDeletedFiles:             relDeletedFiles,\\n   400→\\t\\tMetadataDir:              sessionDir,\\n   401→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   402→\\t\\tCommitMessage:            commitMessage,\\n   403→\\t\\tTranscriptPath:           transcriptRef,\\n   404→\\t\\tAuthorName:               author.Name,\\n   405→\\t\\tAuthorEmail:              author.Email,\\n   406→\\t\\tAgentType:                agentType,\\n   407→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   408→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   409→\\t\\tTokenUsage:               tokenUsage,\\n   410→\\t}\\n   411→\\n   412→\\tif err := strat.SaveStep(ctx); err != nil {\\n   413→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   414→\\t}\\n   415→\\n   416→\\t// Update session state transcript position for auto-commit strategy\\n   417→\\tif strat.Name() == strategy.StrategyNameAutoCommit && newTranscriptPosition > 0 {\\n   418→\\t\\tupdateAutoCommitTranscriptPosition(sessionID, newTranscriptPosition)\\n   419→\\t}\\n   420→\\n   421→\\t// Transition session phase and cleanup\\n   422→\\ttransitionSessionTurnEnd(sessionID)\\n   423→\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n   424→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   425→\\t}\\n   426→\\n   427→\\treturn nil\\n   428→}\\n   429→\\n   430→// handleLifecycleCompaction handles context compaction: saves current progress\\n   431→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   432→// Also resets the transcript offset since the transcript may be truncated.\\n   433→func handleLifecycleCompaction(ag agent.Agent, event *agent.Event) error {\\n   434→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   435→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   436→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   437→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   438→\\t)\\n   439→\\n   440→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   441→\\tsessionID := event.SessionID\\n   442→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   443→\\tif loadErr != nil {\\n   444→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for compaction: %v\\\\n\\\", loadErr)\\n   445→\\t}\\n   446→\\tif sessionState != nil {\\n   447→\\t\\tif transErr := strategy.TransitionAndLog(sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   448→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: compaction transition failed: %v\\\\n\\\", transErr)\\n   449→\\t\\t}\\n   450→\\n   451→\\t\\t// Reset transcript offset since the transcript may be truncated/reorganized\\n   452→\\t\\tsessionState.CheckpointTranscriptStart = 0\\n   453→\\n   454→\\t\\tif saveErr := strategy.SaveSessionState(sessionState); saveErr != nil {\\n   455→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to save session state after compaction: %v\\\\n\\\", saveErr)\\n   456→\\t\\t}\\n   457→\\t}\\n   458→\\n   459→\\tfmt.Fprintf(os.Stderr, \\\"Context compaction: transcript offset reset\\\\n\\\")\\n   460→\\treturn nil\\n   461→}\\n   462→\\n   463→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   464→func handleLifecycleSessionEnd(ag agent.Agent, event *agent.Event) error {\\n   465→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   466→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   467→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   468→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   469→\\t)\\n   470→\\n   471→\\tif event.SessionID == \\\"\\\" {\\n   472→\\t\\treturn nil // No session to update\\n   473→\\t}\\n   474→\\n   475→\\tif err := markSessionEnded(event.SessionID); err != nil {\\n   476→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to mark session ended: %v\\\\n\\\", err)\\n   477→\\t}\\n   478→\\treturn nil\\n   479→}\\n   480→\\n   481→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   482→func handleLifecycleSubagentStart(ag agent.Agent, event *agent.Event) error {\\n   483→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   484→\\tlogging.Info(logCtx, \\\"subagent-start\\\",\\n   485→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   486→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   487→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   488→\\t)\\n   489→\\n   490→\\t// Log context\\n   491→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent started\\\\n\\\")\\n   492→\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n   493→\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n   494→\\tfmt.Fprintf(os.Stderr, \\\"  Transcript: %s\\\\n\\\", event.SessionRef)\\n   495→\\n   496→\\t// Capture pre-task state\\n   497→\\tif err := CapturePreTaskState(event.ToolUseID); err != nil {\\n   498→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   499→\\t}\\n   500→\\n   501→\\treturn nil\\n   502→}\\n   503→\\n   504→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   505→func handleLifecycleSubagentEnd(ag agent.Agent, event *agent.Event) error {\\n   506→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   507→\\tlogging.Info(logCtx, \\\"subagent-end\\\",\\n   508→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   509→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   510→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   511→\\t\\tslog.String(\\\"subagent_id\\\", event.SubagentID),\\n   512→\\t)\\n   513→\\n   514→\\t// Extract subagent type and description from tool input\\n   515→\\tsubagentType, taskDescription := ParseSubagentTypeAndDescription(event.ToolInput)\\n   516→\\n   517→\\t// Determine subagent transcript path\\n   518→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   519→\\tvar subagentTranscriptPath string\\n   520→\\tif event.SubagentID != \\\"\\\" {\\n   521→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   522→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   523→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   524→\\t\\t}\\n   525→\\t}\\n   526→\\n   527→\\t// Log context\\n   528→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent completed\\\\n\\\")\\n   529→\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n   530→\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n   531→\\tif event.SubagentID != \\\"\\\" {\\n   532→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Agent ID: %s\\\\n\\\", event.SubagentID)\\n   533→\\t}\\n   534→\\tif subagentTranscriptPath != \\\"\\\" {\\n   535→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Subagent Transcript: %s\\\\n\\\", subagentTranscriptPath)\\n   536→\\t}\\n   537→\\n   538→\\t// Extract modified files from subagent transcript\\n   539→\\tvar modifiedFiles []string\\n   540→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   541→\\t\\ttranscriptToScan := event.SessionRef\\n   542→\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n   543→\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n   544→\\t\\t}\\n   545→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n   546→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files from subagent: %v\\\\n\\\", fileErr)\\n   547→\\t\\t} else {\\n   548→\\t\\t\\tmodifiedFiles = files\\n   549→\\t\\t}\\n   550→\\t}\\n   551→\\n   552→\\t// Load pre-task state and detect file changes\\n   553→\\tpreState, err := LoadPreTaskState(event.ToolUseID)\\n   554→\\tif err != nil {\\n   555→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-task state: %v\\\\n\\\", err)\\n   556→\\t}\\n   557→\\tvar preUntrackedFiles []string\\n   558→\\tif preState != nil {\\n   559→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   560→\\t}\\n   561→\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n   562→\\tif err != nil {\\n   563→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   564→\\t}\\n   565→\\n   566→\\t// Get repo root and normalize paths\\n   567→\\trepoRoot, err := paths.RepoRoot()\\n   568→\\tif err != nil {\\n   569→\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   570→\\t}\\n   571→\\n   572→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   573→\\tvar relNewFiles, relDeletedFiles []string\\n   574→\\tif changes != nil {\\n   575→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   576→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   577→\\t}\\n   578→\\n   579→\\t// If no changes, skip\\n   580→\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n   581→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] No file changes detected, skipping task checkpoint\\\\n\\\")\\n   582→\\t\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   583→\\t\\treturn nil\\n   584→\\t}\\n   585→\\n   586→\\t// Find checkpoint UUID from main transcript (best-effort)\\n   587→\\tvar checkpointUUID string\\n   588→\\t// Use the existing CLI-level checkpoint UUID finder\\n   589→\\tmainLines, _, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n   590→\\tif mainLines != nil {\\n   591→\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n   592→\\t}\\n   593→\\n   594→\\t// Get git author\\n   595→\\tauthor, err := GetGitAuthor()\\n   596→\\tif err != nil {\\n   597→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   598→\\t}\\n   599→\\n   600→\\t// Build task checkpoint context\\n   601→\\tstrat := GetStrategy()\\n   602→\\tagentType := ag.Type()\\n   603→\\n   604→\\tctx := strategy.TaskStepContext{\\n   605→\\t\\tSessionID:              event.SessionID,\\n   606→\\t\\tToolUseID:              event.ToolUseID,\\n   607→\\t\\tAgentID:                event.SubagentID,\\n   608→\\t\\tModifiedFiles:          relModifiedFiles,\\n   609→\\t\\tNewFiles:               relNewFiles,\\n   610→\\t\\tDeletedFiles:           relDeletedFiles,\\n   611→\\t\\tTranscriptPath:         event.SessionRef,\\n   612→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   613→\\t\\tCheckpointUUID:         checkpointUUID,\\n   614→\\t\\tAuthorName:             author.Name,\\n   615→\\t\\tAuthorEmail:            author.Email,\\n   616→\\t\\tSubagentType:           subagentType,\\n   617→\\t\\tTaskDescription:        taskDescription,\\n   618→\\t\\tAgentType:              agentType,\\n   619→\\t}\\n   620→\\n   621→\\tif err := strat.SaveTaskStep(ctx); err != nil {\\n   622→\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n   623→\\t}\\n   624→\\n   625→\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   626→\\treturn nil\\n   627→}\\n   628→\\n   629→// --- Helper functions ---\\n   630→\\n   631→// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n   632→// Prefers pre-prompt state, falls back to session state.\\n   633→func resolveTranscriptOffset(preState *PrePromptState, sessionID string) int {\\n   634→\\tif preState != nil && preState.TranscriptOffset > 0 {\\n   635→\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state found: parsing transcript from offset %d\\\\n\\\", preState.TranscriptOffset)\\n   636→\\t\\treturn preState.TranscriptOffset\\n   637→\\t}\\n   638→\\n   639→\\t// Fall back to session state (e.g., auto-commit strategy updates it after each save)\\n   640→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   641→\\tif loadErr != nil {\\n   642→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state: %v\\\\n\\\", loadErr)\\n   643→\\t\\treturn 0\\n   644→\\t}\\n   645→\\tif sessionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n   646→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session state found: parsing transcript from offset %d\\\\n\\\", sessionState.CheckpointTranscriptStart)\\n   647→\\t\\treturn sessionState.CheckpointTranscriptStart\\n   648→\\t}\\n   649→\\n   650→\\treturn 0\\n   651→}\\n   652→\\n   653→// updateAutoCommitTranscriptPosition updates the session state with the new transcript position\\n   654→// for the auto-commit strategy.\\n   655→func updateAutoCommitTranscriptPosition(sessionID string, newPosition int) {\\n   656→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   657→\\tif loadErr != nil {\\n   658→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state: %v\\\\n\\\", loadErr)\\n   659→\\t\\treturn\\n   660→\\t}\\n   661→\\tif sessionState == nil {\\n   662→\\t\\tsessionState = &strategy.SessionState{\\n   663→\\t\\t\\tSessionID: sessionID,\\n   664→\\t\\t}\\n   665→\\t}\\n   666→\\tsessionState.CheckpointTranscriptStart = newPosition\\n   667→\\tsessionState.StepCount++\\n   668→\\tif updateErr := strategy.SaveSessionState(sessionState); updateErr != nil {\\n   669→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session state: %v\\\\n\\\", updateErr)\\n   670→\\t} else {\\n   671→\\t\\tfmt.Fprintf(os.Stderr, \\\"Updated session state: transcript position=%d, checkpoint=%d\\\\n\\\",\\n   672→\\t\\t\\tnewPosition, sessionState.StepCount)\\n   673→\\t}\\n   674→}\\n   675→\\n   676→// createContextFile creates a context.md file for the session checkpoint.\\n   677→// This is a unified version that works for all agents.\\n   678→func createContextFile(contextFile, commitMessage, sessionID string, prompts []string, summary string) error {\\n   679→\\tvar sb strings.Builder\\n   680→\\n   681→\\tsb.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   682→\\tfmt.Fprintf(&sb, \\\"Session ID: %s\\\\n\\\", sessionID)\\n   683→\\tfmt.Fprintf(&sb, \\\"Commit Message: %s\\\\n\\\\n\\\", commitMessage)\\n   684→\\n   685→\\tif len(prompts) > 0 {\\n   686→\\t\\tsb.WriteString(\\\"## Prompts\\\\n\\\\n\\\")\\n   687→\\t\\tfor i, p := range prompts {\\n   688→\\t\\t\\tfmt.Fprintf(&sb, \\\"### Prompt %d\\\\n\\\\n%s\\\\n\\\\n\\\", i+1, p)\\n   689→\\t\\t}\\n   690→\\t}\\n   691→\\n   692→\\tif summary != \\\"\\\" {\\n   693→\\t\\tsb.WriteString(\\\"## Summary\\\\n\\\\n\\\")\\n   694→\\t\\tsb.WriteString(summary)\\n   695→\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   696→\\t}\\n   697→\\n   698→\\tif err := os.WriteFile(contextFile, []byte(sb.String()), 0o600); err != nil {\\n   699→\\t\\treturn fmt.Errorf(\\\"failed to write context file: %w\\\", err)\\n   700→\\t}\\n   701→\\treturn nil\\n   702→}\\n   703→\\n   704→// parseTranscriptForCheckpointUUID is a thin wrapper around transcript parsing for checkpoint UUID lookup.\\n   705→// Returns parsed transcript lines for use with FindCheckpointUUID.\\n   706→func parseTranscriptForCheckpointUUID(transcriptPath string) ([]transcriptLine, int, error) {\\n   707→\\tlines, total, err := transcript.ParseFromFileAtLine(transcriptPath, 0)\\n   708→\\tif err != nil {\\n   709→\\t\\treturn nil, 0, fmt.Errorf(\\\"parsing transcript for checkpoint UUID: %w\\\", err)\\n   710→\\t}\\n   711→\\treturn lines, total, nil\\n   712→}\\n   713→\\n   714→// transitionSessionTurnEnd transitions the session phase to IDLE and dispatches turn-end actions.\\n   715→func transitionSessionTurnEnd(sessionID string) {\\n   716→\\tturnState, loadErr := strategy.LoadSessionState(sessionID)\\n   717→\\tif loadErr != nil {\\n   718→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for turn end: %v\\\\n\\\", loadErr)\\n   719→\\t\\treturn\\n   720→\\t}\\n   721→\\tif turnState == nil {\\n   722→\\t\\treturn\\n   723→\\t}\\n   724→\\tif err := strategy.TransitionAndLog(turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   725→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: turn-end transition failed: %v\\\\n\\\", err)\\n   726→\\t}\\n   727→\\n   728→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   729→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   730→\\tstrat := GetStrategy()\\n   731→\\tif handler, ok := strat.(strategy.TurnEndHandler); ok {\\n   732→\\t\\tif err := handler.HandleTurnEnd(turnState); err != nil {\\n   733→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: turn-end action dispatch failed: %v\\\\n\\\", err)\\n   734→\\t\\t}\\n   735→\\t}\\n   736→\\n   737→\\tif updateErr := strategy.SaveSessionState(turnState); updateErr != nil {\\n   738→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session phase on turn end: %v\\\\n\\\", updateErr)\\n   739→\\t}\\n   740→}\\n   741→\\n   742→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   743→func markSessionEnded(sessionID string) error {\\n   744→\\tstate, err := strategy.LoadSessionState(sessionID)\\n   745→\\tif err != nil {\\n   746→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   747→\\t}\\n   748→\\tif state == nil {\\n   749→\\t\\treturn nil // No state file, nothing to update\\n   750→\\t}\\n   751→\\n   752→\\tif transErr := strategy.TransitionAndLog(state, session.EventSessionStop, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   753→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: session stop transition failed: %v\\\\n\\\", transErr)\\n   754→\\t}\\n   755→\\n   756→\\tnow := time.Now()\\n   757→\\tstate.EndedAt = &now\\n   758→\\n   759→\\tif err := strategy.SaveSessionState(state); err != nil {\\n   760→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   761→\\t}\\n   762→\\treturn nil\\n   763→}\\n   764→\\n   765→// autoCreateTrailOnTurnStart creates a trail if on a non-main branch without one.\\n   766→// Non-blocking: logs errors but doesn't fail the session.\\n   767→// prompt is the user's prompt text, used for the trail title.\\n   768→func autoCreateTrailOnTurnStart(prompt string) {\\n   769→\\tif settings.IsTrailsDisabled() {\\n   770→\\t\\treturn\\n   771→\\t}\\n   772→\\n   773→\\tisDefault, branchName, err := IsOnDefaultBranch()\\n   774→\\tif err != nil || isDefault || branchName == \\\"\\\" {\\n   775→\\t\\treturn\\n   776→\\t}\\n   777→\\n   778→\\trepo, err := strategy.OpenRepository()\\n   779→\\tif err != nil {\\n   780→\\t\\treturn\\n   781→\\t}\\n   782→\\n   783→\\tbaseBranch := strategy.GetDefaultBranchName(repo)\\n   784→\\tif baseBranch == \\\"\\\" {\\n   785→\\t\\tbaseBranch = defaultBaseBranch\\n   786→\\t}\\n   787→\\n   788→\\tif err := AutoCreateTrail(repo, branchName, baseBranch, prompt); err != nil {\\n   789→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to auto-create trail: %v\\\\n\\\", err)\\n   790→\\t}\\n   791→}\\n   792→\\n   793→// logFileChanges logs the files modified, created, and deleted during a session.\\n   794→func logFileChanges(modified, newFiles, deleted []string) {\\n   795→\\tfmt.Fprintf(os.Stderr, \\\"Files modified during session (%d):\\\\n\\\", len(modified))\\n   796→\\tfor _, file := range modified {\\n   797→\\t\\tfmt.Fprintf(os.Stderr, \\\"  - %s\\\\n\\\", file)\\n   798→\\t}\\n   799→\\tif len(newFiles) > 0 {\\n   800→\\t\\tfmt.Fprintf(os.Stderr, \\\"New files created (%d):\\\\n\\\", len(newFiles))\\n   801→\\t\\tfor _, file := range newFiles {\\n   802→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  - %s\\\\n\\\", file)\\n   803→\\t\\t}\\n   804→\\t}\\n   805→\\tif len(deleted) > 0 {\\n   806→\\t\\tfmt.Fprintf(os.Stderr, \\\"Files deleted (%d):\\\\n\\\", len(deleted))\\n   807→\\t\\tfor _, file := range deleted {\\n   808→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  - %s\\\\n\\\", file)\\n   809→\\t\\t}\\n   810→\\t}\\n   811→}\\n   812→\"}]},\"uuid\":\"6b93fe6f-2f6f-4357-903f-ab69fe985021\",\"timestamp\":\"2026-02-23T08:26:13.806Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/dip/Repositories/cli/cmd/entire/cli/lifecycle.go\",\"content\":\"// lifecycle.go implements the generic lifecycle event dispatcher.\\n// It routes normalized events from any agent to the appropriate framework actions.\\n//\\n// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n// the dispatcher handles all orchestration: state transitions, strategy calls,\\n// file change detection, metadata generation.\\npackage cli\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n)\\n\\n// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n// Returns nil if the event was handled successfully.\\nfunc DispatchLifecycleEvent(ag agent.Agent, event *agent.Event) error {\\n\\tif ag == nil {\\n\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n\\t}\\n\\tif event == nil {\\n\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n\\t}\\n\\n\\tswitch event.Type {\\n\\tcase agent.SessionStart:\\n\\t\\treturn handleLifecycleSessionStart(ag, event)\\n\\tcase agent.TurnStart:\\n\\t\\treturn handleLifecycleTurnStart(ag, event)\\n\\tcase agent.TurnEnd:\\n\\t\\treturn handleLifecycleTurnEnd(ag, event)\\n\\tcase agent.Compaction:\\n\\t\\treturn handleLifecycleCompaction(ag, event)\\n\\tcase agent.SessionEnd:\\n\\t\\treturn handleLifecycleSessionEnd(ag, event)\\n\\tcase agent.SubagentStart:\\n\\t\\treturn handleLifecycleSubagentStart(ag, event)\\n\\tcase agent.SubagentEnd:\\n\\t\\treturn handleLifecycleSubagentEnd(ag, event)\\n\\tdefault:\\n\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n\\t}\\n}\\n\\n// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n// fires state machine transition.\\nfunc handleLifecycleSessionStart(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"session-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Build informational message\\n\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n\\n\\t// Check for concurrent sessions and append count if any\\n\\tstrat := GetStrategy()\\n\\tif concurrentChecker, ok := strat.(strategy.ConcurrentSessionChecker); ok {\\n\\t\\tif count, err := concurrentChecker.CountOtherActiveSessionsWithCheckpoints(event.SessionID); err == nil && count > 0 {\\n\\t\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n\\t\\t}\\n\\t}\\n\\n\\t// Output informational message\\n\\tif event.ResponseMessage != \\\"\\\" {\\n\\t\\tmessage = event.ResponseMessage\\n\\t}\\n\\tif err := outputHookResponse(message); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Fire EventSessionStart for the current session (if state exists).\\n\\tif state, loadErr := strategy.LoadSessionState(event.SessionID); loadErr != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state on start: %v\\\\n\\\", loadErr)\\n\\t} else if state != nil {\\n\\t\\tif transErr := strategy.TransitionAndLog(state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: session start transition failed: %v\\\\n\\\", transErr)\\n\\t\\t}\\n\\t\\tif saveErr := strategy.SaveSessionState(state); saveErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session state on start: %v\\\\n\\\", saveErr)\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n// ensures strategy setup, initializes session.\\nfunc handleLifecycleTurnStart(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n\\tif err := CapturePrePromptState(ag, sessionID, event.SessionRef); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Ensure strategy setup and initialize session\\n\\tstrat := GetStrategy()\\n\\n\\tif err := strat.EnsureSetup(); err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to ensure strategy setup: %v\\\\n\\\", err)\\n\\t}\\n\\n\\tif initializer, ok := strat.(strategy.SessionInitializer); ok {\\n\\t\\tagentType := ag.Type()\\n\\t\\tif err := initializer.InitializeSession(sessionID, agentType, event.SessionRef, event.Prompt); err != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to initialize session state: %v\\\\n\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// Auto-create trail for non-main branches\\n\\tautoCreateTrailOnTurnStart(event.Prompt)\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n// detects file changes, saves step + checkpoint, transitions phase.\\n//\\n//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\nfunc handleLifecycleTurnEnd(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\tsessionID = unknownSessionID\\n\\t}\\n\\n\\ttranscriptRef := event.SessionRef\\n\\tif transcriptRef == \\\"\\\" {\\n\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n\\t}\\n\\tif !fileExists(transcriptRef) {\\n\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n\\t}\\n\\n\\t// Early check: bail out quickly if the repo has no commits yet.\\n\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n\\t\\tfmt.Fprintln(os.Stderr, \\\"Entire: skipping checkpoint. Will activate after first commit.\\\")\\n\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n\\t}\\n\\n\\t// Create session metadata directory\\n\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\tsessionDirAbs, err := paths.AbsPath(sessionDir)\\n\\tif err != nil {\\n\\t\\tsessionDirAbs = sessionDir\\n\\t}\\n\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n\\t}\\n\\n\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n\\t\\tif err := preparer.PrepareTranscript(transcriptRef); err != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to prepare transcript: %v\\\\n\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// Copy transcript to session directory\\n\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n\\t}\\n\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n\\t}\\n\\tfmt.Fprintf(os.Stderr, \\\"Copied transcript to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName)\\n\\n\\t// Copy export JSON if it exists alongside the transcript (written by OpenCode plugin).\\n\\t// This is used by `opencode import` during resume/rewind to restore the session\\n\\t// into OpenCode's SQLite database with the original session ID.\\n\\texportSrc := strings.TrimSuffix(transcriptRef, filepath.Ext(transcriptRef)) + \\\".export.json\\\"\\n\\tif exportData, readErr := os.ReadFile(exportSrc); readErr == nil { //nolint:gosec // Path derived from agent hook\\n\\t\\texportDest := filepath.Join(sessionDirAbs, paths.ExportDataFileName)\\n\\t\\tif writeErr := os.WriteFile(exportDest, exportData, 0o600); writeErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to write export data: %v\\\\n\\\", writeErr)\\n\\t\\t}\\n\\t}\\n\\n\\t// Load pre-prompt state (captured on TurnStart)\\n\\tpreState, err := LoadPrePromptState(sessionID)\\n\\tif err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-prompt state: %v\\\\n\\\", err)\\n\\t}\\n\\n\\t// Determine transcript offset\\n\\ttranscriptOffset := resolveTranscriptOffset(preState, sessionID)\\n\\n\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n\\tvar allPrompts []string\\n\\tvar summary string\\n\\tvar modifiedFiles []string\\n\\tvar newTranscriptPosition int\\n\\n\\t// Compute subagents directory for agents that support subagent extraction.\\n\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n\\n\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n\\t\\t// Extract prompts\\n\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract prompts: %v\\\\n\\\", promptErr)\\n\\t\\t} else {\\n\\t\\t\\tallPrompts = prompts\\n\\t\\t}\\n\\n\\t\\t// Extract summary\\n\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract summary: %v\\\\n\\\", sumErr)\\n\\t\\t} else {\\n\\t\\t\\tsummary = s\\n\\t\\t}\\n\\n\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptRef, transcriptOffset, subagentsDir); fileErr != nil {\\n\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files (with subagents): %v\\\\n\\\", fileErr)\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t}\\n\\t\\t\\t// Get position from basic analyzer\\n\\t\\t\\tif _, pos, posErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); posErr == nil {\\n\\t\\t\\t\\tnewTranscriptPosition = pos\\n\\t\\t\\t}\\n\\t\\t} else {\\n\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n\\t\\t\\tif files, pos, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files: %v\\\\n\\\", fileErr)\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t\\tnewTranscriptPosition = pos\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write prompts file\\n\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n\\t}\\n\\tfmt.Fprintf(os.Stderr, \\\"Extracted %d prompt(s) to: %s\\\\n\\\", len(allPrompts), sessionDir+\\\"/\\\"+paths.PromptFileName)\\n\\n\\t// Write summary file\\n\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n\\t}\\n\\tfmt.Fprintf(os.Stderr, \\\"Extracted summary to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName)\\n\\n\\t// Generate commit message from last prompt\\n\\tlastPrompt := \\\"\\\"\\n\\tif len(allPrompts) > 0 {\\n\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n\\t}\\n\\tcommitMessage := generateCommitMessage(lastPrompt)\\n\\tfmt.Fprintf(os.Stderr, \\\"Using commit message: %s\\\\n\\\", commitMessage)\\n\\n\\t// Get repo root for path normalization\\n\\trepoRoot, err := paths.RepoRoot()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n\\t}\\n\\n\\tvar preUntrackedFiles []string\\n\\tif preState != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state: %d pre-existing untracked files\\\\n\\\", len(preState.UntrackedFiles))\\n\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n\\t}\\n\\n\\t// Detect file changes via git status\\n\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n\\tif err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n\\t}\\n\\n\\t// Filter and normalize all paths\\n\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n\\tvar relNewFiles, relDeletedFiles []string\\n\\tif changes != nil {\\n\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n\\t}\\n\\n\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n\\t// if it exists in HEAD with the same content as the working tree.\\n\\trelModifiedFiles = filterToUncommittedFiles(relModifiedFiles, repoRoot)\\n\\n\\t// Check if there are any changes\\n\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n\\tif totalChanges == 0 {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"No files were modified during this session\\\\n\\\")\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipping commit\\\\n\\\")\\n\\t\\ttransitionSessionTurnEnd(sessionID)\\n\\t\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Log file changes\\n\\tlogFileChanges(relModifiedFiles, relNewFiles, relDeletedFiles)\\n\\n\\t// Create context file\\n\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n\\t}\\n\\tfmt.Fprintf(os.Stderr, \\\"Created context file: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.ContextFileName)\\n\\n\\t// Get git author\\n\\tauthor, err := GetGitAuthor()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n\\t}\\n\\n\\t// Get strategy and agent type\\n\\tstrat := GetStrategy()\\n\\tagentType := ag.Type()\\n\\n\\t// Get transcript position/identifier from pre-prompt state\\n\\tvar transcriptIdentifierAtStart string\\n\\tvar transcriptLinesAtStart int\\n\\tif preState != nil {\\n\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n\\t}\\n\\n\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n\\tvar tokenUsage *agent.TokenUsage\\n\\tif subagentExtractor, ok := ag.(agent.SubagentAwareExtractor); ok {\\n\\t\\tusage, tokenErr := subagentExtractor.CalculateTotalTokenUsage(transcriptRef, transcriptLinesAtStart, subagentsDir)\\n\\t\\tif tokenErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage (with subagents): %v\\\\n\\\", tokenErr)\\n