dlerErr = fmt.Errorf(\\\"%s: %w\\\", action, err)\\n   331→\\t\\t\\t\\t}\\n   332→\\t\\t\\t}\\n   333→\\t\\tcase ActionCondenseIfFilesTouched:\\n   334→\\t\\t\\tif handlerErr == nil {\\n   335→\\t\\t\\t\\tif err := handler.HandleCondenseIfFilesTouched(state); err != nil {\\n   336→\\t\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"%s: %w\\\", action, err)\\n   337→\\t\\t\\t\\t}\\n   338→\\t\\t\\t}\\n   339→\\t\\tcase ActionDiscardIfNoFiles:\\n   340→\\t\\t\\tif handlerErr == nil {\\n   341→\\t\\t\\t\\tif err := handler.HandleDiscardIfNoFiles(state); err != nil {\\n   342→\\t\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"%s: %w\\\", action, err)\\n   343→\\t\\t\\t\\t}\\n   344→\\t\\t\\t}\\n   345→\\t\\tcase ActionWarnStaleSession:\\n   346→\\t\\t\\tif handlerErr == nil {\\n   347→\\t\\t\\t\\tif err := handler.HandleWarnStaleSession(state); err != nil {\\n   348→\\t\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"%s: %w\\\", action, err)\\n   349→\\t\\t\\t\\t}\\n   350→\\t\\t\\t}\\n   351→\\t\\tdefault:\\n   352→\\t\\t\\tif handlerErr == nil {\\n   353→\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"unhandled action: %s\\\", action)\\n   354→\\t\\t\\t}\\n   355→\\t\\t}\\n   356→\\t}\\n   357→\\treturn handlerErr\\n   358→}\\n   359→\\n   360→// MermaidDiagram generates a Mermaid state diagram from the transition table.\\n   361→// The diagram is derived by calling Transition() for representative context\\n   362→// variants per phase/event, so it stays in sync with the implementation.\\n   363→func MermaidDiagram() string {\\n   364→\\tvar b strings.Builder\\n   365→\\tb.WriteString(\\\"stateDiagram-v2\\\\n\\\")\\n   366→\\n   367→\\t// State declarations with descriptions.\\n   368→\\tb.WriteString(\\\"    state \\\\\\\"IDLE\\\\\\\" as idle\\\\n\\\")\\n   369→\\tb.WriteString(\\\"    state \\\\\\\"ACTIVE\\\\\\\" as active\\\\n\\\")\\n   370→\\tb.WriteString(\\\"    state \\\\\\\"ENDED\\\\\\\" as ended\\\\n\\\")\\n   371→\\tb.WriteString(\\\"\\\\n\\\")\\n   372→\\n   373→\\t// Context variants for GitCommit: rebase, files/no-files.\\n   374→\\ttype contextVariant struct {\\n   375→\\t\\tlabel string\\n   376→\\t\\tctx   TransitionContext\\n   377→\\t}\\n   378→\\n   379→\\t// For each phase/event, generate edges.\\n   380→\\tfor _, phase := range allPhases {\\n   381→\\t\\tfor _, event := range allEvents {\\n   382→\\t\\t\\tvar variants []contextVariant\\n   383→\\t\\t\\tswitch {\\n   384→\\t\\t\\tcase event == EventGitCommit && phase == PhaseEnded:\\n   385→\\t\\t\\t\\t// HasFilesTouched only affects PhaseEnded transitions;\\n   386→\\t\\t\\t\\t// other phases produce identical edges for both values.\\n   387→\\t\\t\\t\\tvariants = []contextVariant{\\n   388→\\t\\t\\t\\t\\t{\\\"[files]\\\", TransitionContext{HasFilesTouched: true}},\\n   389→\\t\\t\\t\\t\\t{\\\"[no files]\\\", TransitionContext{HasFilesTouched: false}},\\n   390→\\t\\t\\t\\t\\t{\\\"[rebase]\\\", TransitionContext{IsRebaseInProgress: true}},\\n   391→\\t\\t\\t\\t}\\n   392→\\t\\t\\tcase event == EventGitCommit:\\n   393→\\t\\t\\t\\tvariants = []contextVariant{\\n   394→\\t\\t\\t\\t\\t{\\\"\\\", TransitionContext{}},\\n   395→\\t\\t\\t\\t\\t{\\\"[rebase]\\\", TransitionContext{IsRebaseInProgress: true}},\\n   396→\\t\\t\\t\\t}\\n   397→\\t\\t\\tdefault:\\n   398→\\t\\t\\t\\tvariants = []contextVariant{\\n   399→\\t\\t\\t\\t\\t{\\\"\\\", TransitionContext{}},\\n   400→\\t\\t\\t\\t}\\n   401→\\t\\t\\t}\\n   402→\\n   403→\\t\\t\\tfor _, v := range variants {\\n   404→\\t\\t\\t\\tresult := Transition(phase, event, v.ctx)\\n   405→\\n   406→\\t\\t\\t\\t// Build edge label.\\n   407→\\t\\t\\t\\tlabel := event.String()\\n   408→\\t\\t\\t\\tif v.label != \\\"\\\" {\\n   409→\\t\\t\\t\\t\\tlabel += \\\" \\\" + v.label\\n   410→\\t\\t\\t\\t}\\n   411→\\t\\t\\t\\tif len(result.Actions) > 0 {\\n   412→\\t\\t\\t\\t\\tactionNames := make([]string, 0, len(result.Actions))\\n   413→\\t\\t\\t\\t\\tfor _, a := range result.Actions {\\n   414→\\t\\t\\t\\t\\t\\tactionNames = append(actionNames, a.String())\\n   4