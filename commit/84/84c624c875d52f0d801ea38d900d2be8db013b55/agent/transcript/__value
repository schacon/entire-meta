normalizePrePromptState() {\\n    71→\\t// Migrate the oldest field to the intermediate field first\\n    72→\\tif s.StepTranscriptStart == 0 && s.LastTranscriptLineCount > 0 {\\n    73→\\t\\ts.StepTranscriptStart = s.LastTranscriptLineCount\\n    74→\\t}\\n    75→\\ts.LastTranscriptLineCount = 0\\n    76→\\n    77→\\t// Migrate all deprecated fields to the unified TranscriptOffset\\n    78→\\tif s.TranscriptOffset == 0 {\\n    79→\\t\\tif s.StepTranscriptStart > 0 {\\n    80→\\t\\t\\ts.TranscriptOffset = s.StepTranscriptStart\\n    81→\\t\\t} else if s.StartMessageIndex > 0 {\\n    82→\\t\\t\\ts.TranscriptOffset = s.StartMessageIndex\\n    83→\\t\\t}\\n    84→\\t}\\n    85→\\ts.StepTranscriptStart = 0\\n    86→\\ts.StartMessageIndex = 0\\n    87→}\\n    88→\\n    89→// CapturePrePromptState captures current untracked files and transcript position before a prompt\\n    90→// and saves them to a state file.\\n    91→//\\n    92→// The agent parameter is used to determine the transcript position via TranscriptAnalyzer.\\n    93→// If the agent does not implement TranscriptAnalyzer, the transcript offset will be 0.\\n    94→// The sessionRef parameter is optional — if empty, transcript position won't be captured.\\n    95→//\\n    96→// Works correctly from any subdirectory within the repository.\\n    97→func CapturePrePromptState(ctx context.Context, ag agent.Agent, sessionID, sessionRef string) error {\\n    98→\\tif sessionID == \\\"\\\" {\\n    99→\\t\\tsessionID = unknownSessionID\\n   100→\\t}\\n   101→\\n   102→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   103→\\t\\treturn fmt.Errorf(\\\"invalid session ID for pre-prompt state: %w\\\", err)\\n   104→\\t}\\n   105→\\n   106→\\t// Get absolute path for tmp directory\\n   107→\\ttmpDirAbs := resolveTmpDir(ctx)\\n   108→\\n   109→\\t// Create tmp directory if it doesn't exist\\n   110→\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   111→\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n   112→\\t}\\n   113→\\n   114→\\t// Get list of untracked files (excluding .entire directory itself)\\n   115→\\tuntrackedFiles, err := getUntrackedFilesForState(ctx)\\n   116→\\tif err != nil {\\n   117→\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n   118→\\t}\\n   119→\\n   120→\\t// Get transcript position using TranscriptAnalyzer if available\\n   121→\\tvar transcriptOffset int\\n   122→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok && sessionRef != \\\"\\\" {\\n   123→\\t\\tpos, posErr := analyzer.GetTranscriptPosition(sessionRef)\\n   124→\\t\\tif posErr != nil {\\n   125→\\t\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"state\\\"), \\\"failed to get transcript position\\\",\\n   126→\\t\\t\\t\\tslog.String(\\\"error\\\", posErr.Error()))\\n   127→\\t\\t} else {\\n   128→\\t\\t\\ttranscriptOffset = pos\\n   129→\\t\\t}\\n   130→\\t}\\n   131→\\n   132→\\t// Create state file using os.Root for traversal-resistant write\\n   133→\\tstate := PrePromptState{\\n   134→\\t\\tSessionID:        sessionID,\\n   135→\\t\\tTimestamp:        time.Now().UTC().Format(time.RFC3339),\\n   136→\\t\\tUntrackedFiles:   untrackedFiles,\\n   137→\\t\\tTranscriptOffset: transcriptOffset,\\n   138→\\t}\\n   139→\\n   140→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   141→\\tif err != nil {\\n   142→\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n   143→\\t}\\n   144→\\n   145→\\tfileName := fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID)\\n   146→\\troot, err := os.OpenRoot(tmpDirAbs)\\n   147→\\tif err != nil {\\n   148→\\t\\treturn fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   149→\\t}\\n   150→\\tdefer root.Close()\\n   151→\\n   152→\\tif err := osroot.WriteFile(root, fileName, data, 0o600); err != nil {\\n   153→\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   154→\\t}\\n   155→\\n   156→\\tloggi