   858→\\t}\\n   859→\\n   860→\\treturn sessions\\n   861→}\\n   862→\\n   863→// ClassifyTimestamps determines the restore status based on local and checkpoint timestamps.\\n   864→func ClassifyTimestamps(localTime, checkpointTime time.Time) SessionRestoreStatus {\\n   865→\\t// Local file doesn't exist (no timestamp found)\\n   866→\\tif localTime.IsZero() {\\n   867→\\t\\treturn StatusNew\\n   868→\\t}\\n   869→\\n   870→\\t// Can't determine checkpoint time - treat as new/safe\\n   871→\\tif checkpointTime.IsZero() {\\n   872→\\t\\treturn StatusNew\\n   873→\\t}\\n   874→\\n   875→\\t// Compare timestamps\\n   876→\\tif localTime.After(checkpointTime) {\\n   877→\\t\\treturn StatusLocalNewer\\n   878→\\t}\\n   879→\\tif checkpointTime.After(localTime) {\\n   880→\\t\\treturn StatusCheckpointNewer\\n   881→\\t}\\n   882→\\treturn StatusUnchanged\\n   883→}\\n   884→\\n   885→// StatusToText returns a human-readable status string.\\n   886→func StatusToText(status SessionRestoreStatus) string {\\n   887→\\tswitch status {\\n   888→\\tcase StatusNew:\\n   889→\\t\\treturn \\\"(new)\\\"\\n   890→\\tcase StatusUnchanged:\\n   891→\\t\\treturn \\\"(unchanged)\\\"\\n   892→\\tcase StatusCheckpointNewer:\\n   893→\\t\\treturn \\\"(checkpoint is newer)\\\"\\n   894→\\tcase StatusLocalNewer:\\n   895→\\t\\treturn \\\"(local is newer)\\\" // shouldn't appear in non-conflict list\\n   896→\\tdefault:\\n   897→\\t\\treturn \\\"\\\"\\n   898→\\t}\\n   899→}\\n   900→\\n   901→// PromptOverwriteNewerLogs asks the user for confirmation to overwrite local\\n   902→// session logs that have newer timestamps than the checkpoint versions.\\n   903→func PromptOverwriteNewerLogs(sessions []SessionRestoreInfo) (bool, error) {\\n   904→\\t// Separate conflicting and non-conflicting sessions\\n   905→\\tvar conflicting, nonConflicting []SessionRestoreInfo\\n   906→\\tfor _, s := range sessions {\\n   907→\\t\\tif s.Status == StatusLocalNewer {\\n   908→\\t\\t\\tconflicting = append(con