n fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   467→\\t}\\n   468→\\tif state == nil {\\n   469→\\t\\treturn fmt.Errorf(\\\"session %s not found\\\", sessionID)\\n   470→\\t}\\n   471→\\n   472→\\t// Reset the shadow branch to the checkpoint commit\\n   473→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   474→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   475→\\n   476→\\t// Update the reference to point to the checkpoint commit\\n   477→\\tref := plumbing.NewHashReference(refName, commit.Hash)\\n   478→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   479→\\t\\treturn fmt.Errorf(\\\"failed to update shadow branch: %w\\\", err)\\n   480→\\t}\\n   481→\\n   482→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Reset shadow branch %s to checkpoint %s\\\\n\\\", shadowBranchName, commit.Hash.String()[:7])\\n   483→\\treturn nil\\n   484→}\\n   485→\\n   486→// CanRewind checks if rewinding is possible.\\n   487→// For manual-commit strategy, rewind restores files from a checkpoint - uncommitted changes are expected\\n   488→// and will be replaced by the checkpoint contents. Returns true with a warning message showing\\n   489→// what changes will be reverted.\\n   490→func (s *ManualCommitStrategy) CanRewind(ctx context.Context) (bool, string, error) {\\n   491→\\treturn checkCanRewindWithWarning(ctx)\\n   492→}\\n   493→\\n   494→// PreviewRewind returns what will happen if rewinding to the given point.\\n   495→// This allows showing warnings about untracked files that will be deleted.\\n   496→func (s *ManualCommitStrategy) PreviewRewind(ctx context.Context, point RewindPoint) (*RewindPreview, error) {\\n   497→\\t// Logs-only points don't modify the working directory\\n   498→\\tif point.IsLogsOnly {\\n   499→\\t\\treturn &RewindPreview{}, nil\\n   500→\\t}\\n   501→\\n   502→\\trepo, err := OpenRepository(ctx)\\n   503→\\tif err != nil {\\n   504→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   505→\\t}\\n   506→\\n   507→\\t// Get the checkpoint commit\\n   508→\\tcommitHash := plumbing.NewHash(point.ID)\\n   509→\\tcommit, err := repo.CommitObject(commitHash)\\n   510→\\tif err != nil {\\n   511→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   512→\\t}\\n   513→\\n   514→\\ttree, err := commit.Tree()\\n   515→\\tif err != nil {\\n   516→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n   517→\\t}\\n   518→\\n   519→\\t// Load session state to get untracked files that existed at session start\\n   520→\\tsessionID, hasSessionTrailer := trailers.ParseSession(commit.Message)\\n   521→\\tvar preservedUntrackedFiles map[string]bool\\n   522→\\tif hasSessionTrailer {\\n   523→\\t\\tstate, stateErr := s.loadSessionState(ctx, sessionID)\\n   524→\\t\\tif stateErr == nil && state != nil && len(state.UntrackedFilesAtStart) > 0 {\\n   525→\\t\\t\\tpreservedUntrackedFiles = make(map[string]bool)\\n   526→\\t\\t\\tfor _, f := range state.UntrackedFilesAtStart {\\n   527→\\t\\t\\t\\tpreservedUntrackedFiles[f] = true\\n   528→\\t\\t\\t}\\n   529→\\t\\t}\\n   530→\\t}\\n   531→\\n   532→\\t// Build set of files in the checkpoint tree (excluding metadata)\\n   533→\\tcheckpointFiles := make(map[string]bool)\\n   534→\\tvar filesToRestore []string\\n   535→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   536→\\t\\tif err := ctx.Err(); err != nil {\\n   537→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   538→\\t\\t}\\n   539→\\t\\tif !strings.HasPrefix(f.Name, entireDir) {\\n   540→\\t\\t\\tcheckpointFiles[f.Name] = true\\n   541→\\t\\t\\tfilesToRestore = append(filesToRestore, f.Name)\\n   542→\\t\\t}\\n   543→\\t\\treturn nil\\n   544→\\t})\\n   545→\\tif err != nil {\\n   546→\\t\\treturn nil, fmt.Errorf(\\\"failed to list checkpoint files: %w\\\", err)\\n   547→\\t}\\n   548→\\n   549→\\t// Get HEAD tree to identify tracked files\\n   550→\\thead, err := repo.Head()\\n   551→\\tif err != nil {\\n   552→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   553→\\t}\\n   554→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   555→\\tif err != nil {\\n   556→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   557→\\t}\\n   558→\\theadTree, err := headCommit.Tree()\\n   559→\\tif err != nil {\\n   560→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD tree: %w\\\", err)\\n   561→\\t}\\n   562→\\n   563→\\t// Build set of files tracked in HEAD\\n   564→\\ttrackedFiles := make(map[string]bool)\\n   565→\\t//nolint:errcheck // Error is not critical for preview\\n   566→\\t_ = headTree.Files().ForEach(func(f *object.File) error {\\n   567→\\t\\tif err := ctx.Err(); err != nil {\\n   568→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   569→\\t\\t}\\n   570→\\t\\ttrackedFiles[f.Name] = true\\n   571→\\t\\treturn nil\\n   572→\\t})\\n   573→\\n   574→\\t// Find untracked files that would be deleted.\\n   575→\\t// Uses git ls-files to only consider non-ignored files.\\n   576→\\tvar filesToDelete []string\\n   577→\\tuntrackedNow, untrackedErr := collectUntrackedFiles(ctx)\\n   578→\\tif untrackedErr != nil {\\n   579→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: could not list untracked files for preview: %v\\\\n\\\", untrackedErr)\\n   580→\\t\\treturn &RewindPreview{\\n   581→\\t\\t\\tFilesToRestore: filesToRestore,\\n   582→\\t\\t\\tFilesToDelete:  filesToDelete,\\n   583→\\t\\t}, nil\\n   584→\\t}\\n   585→\\tfor _, relPath := range untrackedNow {\\n   586→\\t\\tif checkpointFiles[relPath] {\\n   587→\\t\\t\\tcontinue\\n   588→\\t\\t}\\n   589→\\t\\tif trackedFiles[relPath] {\\n   590→\\t\\t\\tcontinue\\n   591→\\t\\t}\\n   592→\\t\\tif preservedUntrackedFiles[relPath] {\\n   593→\\t\\t\\tcontinue\\n   594→\\t\\t}\\n   595→\\t\\tfilesToDelete = append(filesToDelete, relPath)\\n   596→\\t}\\n   597→\\n   598→\\t// Sort for consistent output\\n   599→\\tsort.Strings(filesToRestore)\\n   600→\\tsort.Strings(filesToDelete)\\n   601→\\n   602→\\treturn &RewindPreview{\\n   603→\\t\\tFilesToRestore: filesToRestore,\\n   604→\\t\\tFilesToDelete:  filesToDelete,\\n   605→\\t}, nil\\n   606→}\\n   607→\\n   608→// RestoreLogsOnly restores session logs from a logs-only rewind point.\\n   609→// This fetches the transcript from entire/checkpoints/v1 and writes it to the agent's session directory.\\n   610→// Does not modify the working directory.\\n   611→// When multiple sessions were condensed to the same checkpoint, ALL sessions are restored.\\n   612→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   613→// Returns info about each restored session so callers can print correct per-session resume commands.\\n   614→func (s *ManualCommitStrategy) RestoreLogsOnly(ctx context.Context, point RewindPoint, force bool) ([]RestoredSession, error) {\\n   615→\\tif !point.IsLogsOnly {\\n   616→\\t\\treturn nil, errors.New(\\\"not a logs-only rewind point\\\")\\n   617→\\t}\\n   618→\\n   619→\\tif point.CheckpointID.IsEmpty() {\\n   620→\\t\\treturn nil, errors.New(\\\"missing checkpoint ID\\\")\\n   621→\\t}\\n   622→\\n   623→\\t// Get checkpoint store\\n   624→\\tstore, err := s.getCheckpointStore()\\n   625→\\tif err != nil {\\n   626→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   627→\\t}\\n   628→\\n   629→\\t// Read checkpoint summary to get session count\\n   630→\\tsummary, err := store.ReadCommitted(ctx, point.CheckpointID)\\n   631→\\tif err != nil {\\n   632→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   633→\\t}\\n   634→\\tif summary == nil {\\n   635→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", point.CheckpointID)\\n   636→\\t}\\n   637→\\n   638→\\t// Get worktree root for agent session directory lookup\\n   639→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   640→\\tif err != nil {\\n   641→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   642→\\t}\\n   643→\\n   644→\\t// Check for newer local logs if not forcing\\n   645→\\tif !force {\\n   646→\\t\\tsessions := s.classifySessionsForRestore(ctx, repoRoot, store, point.CheckpointID, summary)\\n   647→\\t\\thasConflicts := false\\n   648→\\t\\tfor _, sess := range sessions {\\n   649→\\t\\t\\tif sess.Status == StatusLocalNewer {\\n   650→\\t\\t\\t\\thasConflicts = true\\n   651→\\t\\t\\t\\tbreak\\n   652→\\t\\t\\t}\\n   653→\\t\\t}\\n   654→\\t\\tif hasConflicts {\\n   655→\\t\\t\\tshouldOverwrite, promptErr := PromptOverwriteNewerLogs(sessions)\\n   656→\\t\\t\\tif promptErr != nil {\\n   657→\\t\\t\\t\\treturn nil, promptErr\\n   658→\\t\\t\\t}\\n   659→\\t\\t\\tif !shouldOverwrite {\\n   660→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled. Local session logs preserved.\\\\n\\\")\\n   661→\\t\\t\\t\\treturn nil, nil\\n   662→\\t\\t\\t}\\n   663→\\t\\t}\\n   664→\\t}\\n   665→\\n   666→\\t// Count sessions to restore\\n   667→\\ttotalSessions := len(summary.Sessions)\\n   668→\\tif totalSessions > 1 {\\n   669→\\t\\tfmt.Fprintf(os.Stderr, \\\"Restoring %d sessions from checkpoint:\\\\n\\\", totalSessions)\\n   670→\\t}\\n   671→\\n   672→\\t// Restore all sessions (oldest to newest, using 0-based indexing)\\n   673→\\tvar restored []RestoredSession\\n   674→\\tfor i := range totalSessions {\\n   675→\\t\\tcontent, readErr := store.ReadSessionContent(ctx, point.CheckpointID, i)\\n   676→\\t\\tif readErr != nil {\\n   677→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: failed to read session %d: %v\\\\n\\\", i, readErr)\\n   678→\\t\\t\\tcontinue\\n   679→\\t\\t}\\n   680→\\t\\tif content == nil || len(content.Transcript) == 0 {\\n   681→\\t\\t\\tcontinue\\n   682→\\t\\t}\\n   683→\\n   684→\\t\\tsessionID := content.Metadata.SessionID\\n   685→\\t\\tif sessionID == \\\"\\\" {\\n   686→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %