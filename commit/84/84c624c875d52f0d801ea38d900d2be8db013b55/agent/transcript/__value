dRoot(dst string) (*os.Root, string, error) {\\n    83→\\tallowed := allowedRootDirs()\\n    84→\\n    85→\\t// Resolve the directory portion of dst through symlinks so that e.g.\\n    86→\\t// /var/folders/... matches /private/var/folders/... on macOS.\\n    87→\\t// Only the parent directory is resolved; the final component may not exist yet.\\n    88→\\tresolvedDst := dst\\n    89→\\tif r, err := filepath.EvalSymlinks(filepath.Dir(dst)); err == nil {\\n    90→\\t\\tresolvedDst = filepath.Join(r, filepath.Base(dst))\\n    91→\\t}\\n    92→\\n    93→\\tfor _, dir := range allowed {\\n    94→\\t\\trel, err := filepath.Rel(dir, resolvedDst)\\n    95→\\t\\tif err != nil {\\n    96→\\t\\t\\tcontinue\\n    97→\\t\\t}\\n    98→\\t\\t// Check that rel doesn't escape dir (traversal-resistant).\\n    99→\\t\\t// This is the same logic as paths.IsSubpath but avoids a redundant\\n   100→\\t\\t// filepath.Rel call since we already have rel.\\n   101→\\t\\tif rel == \\\"..\\\" || strings.HasPrefix(rel, \\\"..\\\"+string(filepath.Separator)) {\\n   102→\\t\\t\\tcontinue\\n   103→\\t\\t}\\n   104→\\t\\troot, err := os.OpenRoot(dir)\\n   105→\\t\\tif err != nil {\\n   106→\\t\\t\\treturn nil, \\\"\\\", fmt.Errorf(\\\"copyFile: failed to open root %q: %w\\\", dir, err)\\n   107→\\t\\t}\\n   108→\\t\\treturn root, rel, nil\\n   109→\\t}\\n   110→\\n   111→\\treturn nil, \\\"\\\", fmt.Errorf(\\\"copyFile: dst %q is outside allowed directories\\\", dst)\\n   112→}\\n   113→\\n   114→// allowedRootDirs returns the list of directories that copyFile may write to.\\n   115→// Directories are resolved through symlinks so they match resolved dst paths.\\n   116→func allowedRootDirs() []string {\\n   117→\\tallowed := make([]string, 0, 3)\\n   118→\\n   119→\\tif repoRoot, err := paths.WorktreeRoot(context.Background()); err == nil {\\n   120→\\t\\tallowed = appendResolved(allowed, repoRoot)\\n   121→\\t}\\n   122→\\tif home, err := os.UserHomeDir(); err == nil {\\n   123→\\t\\tallowed = app