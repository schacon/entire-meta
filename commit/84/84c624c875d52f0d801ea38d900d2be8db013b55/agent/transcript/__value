t\\tif !existingIDs[p.ID] {\\n   110→\\t\\t\\t\\tallPoints = append(allPoints, p)\\n   111→\\t\\t\\t}\\n   112→\\t\\t}\\n   113→\\n   114→\\t\\t// Re-sort by date\\n   115→\\t\\tsort.Slice(allPoints, func(i, j int) bool {\\n   116→\\t\\t\\treturn allPoints[i].Date.After(allPoints[j].Date)\\n   117→\\t\\t})\\n   118→\\n   119→\\t\\t// Re-trim to limit\\n   120→\\t\\tif len(allPoints) > limit {\\n   121→\\t\\t\\tallPoints = allPoints[:limit]\\n   122→\\t\\t}\\n   123→\\t}\\n   124→\\n   125→\\treturn allPoints, nil\\n   126→}\\n   127→\\n   128→// GetLogsOnlyRewindPoints finds commits in the current branch's history that have\\n   129→// condensed session logs on the entire/checkpoints/v1 branch. These are commits that\\n   130→// were created with session data but the shadow branch has been condensed.\\n   131→//\\n   132→// The function works by:\\n   133→// 1. Getting all checkpoints from the entire/checkpoints/v1 branch\\n   134→// 2. Building a map of checkpoint ID -> checkpoint info\\n   135→// 3. Scanning the current branch history for commits with Entire-Checkpoint trailers\\n   136→// 4. Matching by checkpoint ID (stable across amend/rebase)\\n   137→func (s *ManualCommitStrategy) GetLogsOnlyRewindPoints(ctx context.Context, limit int) ([]RewindPoint, error) {\\n   138→\\trepo, err := OpenRepository(ctx)\\n   139→\\tif err != nil {\\n   140→\\t\\treturn nil, err\\n   141→\\t}\\n   142→\\n   143→\\t// Get all checkpoints from entire/checkpoints/v1 branch\\n   144→\\tcheckpoints, err := s.listCheckpoints(ctx)\\n   145→\\tif err != nil {\\n   146→\\t\\t// No checkpoints yet is fine\\n   147→\\t\\treturn nil, nil //nolint:nilerr // Expected when no checkpoints exist\\n   148→\\t}\\n   149→\\n   150→\\tif len(checkpoints) == 0 {\\n   151→\\t\\treturn nil, nil\\n   152→\\t}\\n   153→\\n   154→\\t// Build map of checkpoint ID -> checkpoint info\\n   155→\\t// Checkpoint ID is the stable link from Entire-Checkpoint trailer\\n   156→\\tcheckpointInfoMap := make(map[id.CheckpointID]CheckpointInfo)\\n   157→\\tfor _, cp := range checkpoints {\\n   158→\\t\\tif !cp.CheckpointID.IsEmpty() {\\n   159→\\t\\t\\tcheckpointInfoMap[cp.CheckpointID] = cp\\n   160→\\t\\t}\\n   161→\\t}\\n   162→\\n   163→\\t// Get metadata branch tree for reading session prompts (best-effort, ignore errors)\\n   164→\\tmetadataTree, _ := GetMetadataBranchTree(repo) //nolint:errcheck // Best-effort for session prompts\\n   165→\\n   166→\\thead, err := repo.Head()\\n   167→\\tif err != nil {\\n   168→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   169→\\t}\\n   170→\\n   171→\\t// Use LogOptions with Order=LogOrderCommitterTime to traverse all parents of merge commits.\\n   172→\\titer, err := repo.Log(&git.LogOptions{\\n   173→\\t\\tFrom:  head.Hash(),\\n   174→\\t\\tOrder: git.LogOrderCommitterTime,\\n   175→\\t})\\n   176→\\tif err != nil {\\n   177→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   178→\\t}\\n   179→\\n   180→\\tvar points []RewindPoint\\n   181→\\tcount := 0\\n   182→\\n   183→\\terr = iter.ForEach(func(c *object.Commit) error {\\n   184→\\t\\tif err := ctx.Err(); err != nil {\\n   185→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   186→\\t\\t}\\n   187→\\t\\tif count >= logsOnlyScanLimit {\\n   188→\\t\\t\\treturn errStop\\n   189→\\t\\t}\\n   190→\\t\\tcount++\\n   191→\\n   192→\\t\\t// Extract all checkpoint IDs from Entire-Checkpoint trailers.\\n   193→\\t\\t// Squash merge commits may contain multiple trailers from the original commits.\\n   194→\\t\\tallCpIDs := trailers.ParseAllCheckpoints(c.Message)\\n   195→\\t\\tif len(allCpIDs) == 0 {\\n   196→\\t\\t\\treturn nil\\n   197→\\t\\t}\\n   198→\\n   199→\\t\\t// Resolve to the latest checkpoint by creation time (consistent with `entire resume`).\\n   200→\\t\\tcpInfo, found := ResolveLatestCheckpointFromMap(allCpIDs, checkpointInfoMap)\\n   201→\\t\\tif !found {\\n   202→\\t\\t\\treturn nil\\n   203→\\t\\t}\\n   204→\\n   205→\\t\\t// Create logs-only rewind point\\n   206→\\t\\tmessage := strings.Split(c.Message, \\\"\\\\n\\\")[0]\\n   207→\\n   208→\\t\\t// Read session prompts from metadata tree\\n   209→\\t\\tvar sessionPrompt string\\n   210→\\t\\tvar sessionPrompts []string\\n   211→\\t\\tif metadataTree != nil {\\n   212→\\t\\t\\tcheckpointPath := paths.CheckpointPath(cpInfo.CheckpointID) //nolint:staticcheck // already present in codebase\\n   213→\\t\\t\\t// For multi-session checkpoints, read all prompts\\n   214→\\t\\t\\tif cpInfo.SessionCount > 1 && len(cpInfo.SessionIDs) > 1 {\\n   215→\\t\\t\\t\\tsessionPrompts = ReadAllSessionPromptsFromTree(metadataTree, checkpointPath, cpInfo.SessionCount, cpInfo.SessionIDs)\\n   216→\\t\\t\\t\\t// Use the last (most recent) prompt as the main session prompt\\n   217→\\t\\t\\t\\tif len(sessionPrompts) > 0 {\\n   218→\\t\\t\\t\\t\\tsessionPrompt = sessionPrompts[len(sessionPrompts)-1]\\n   219→\\t\\t\\t\\t}\\n   220→\\t\\t\\t} else {\\n   221→\\t\\t\\t\\tsessionPrompt = ReadSessionPromptFromTree(metadataTree, checkpointPath)\\n   222→\\t\\t\\t\\tif sessionPrompt != \\\"\\\" {\\n   223→\\t\\t\\t\\t\\tsessionPrompts = []string{sessionPrompt}\\n   224→\\t\\t\\t\\t}\\n   225→\\t\\t\\t}\\n   226→\\t\\t}\\n   227→\\n   228→\\t\\tpoints = append(points, RewindPoint{\\n   229→\\t\\t\\tID:             c.Hash.String(),\\n   230→\\t\\t\\tMessage:        message,\\n   231→\\t\\t\\tDate:           c.Author.When,\\n   232→\\t\\t\\tIsLogsOnly:     true,\\n   233→\\t\\t\\tCheckpointID:   cpInfo.CheckpointID,\\n   234→\\t\\t\\tAgent:          cpInfo.Agent,\\n   235→\\t\\t\\tSessionID:      cpInfo.SessionID,\\n   236→\\t\\t\\tSessionPrompt:  sessionPrompt,\\n   237→\\t\\t\\tSessionCount:   cpInfo.SessionCount,\\n   238→\\t\\t\\tSessionIDs:     cpInfo.SessionIDs,\\n   239→\\t\\t\\tSessionPrompts: sessionPrompts,\\n   240→\\t\\t})\\n   241→\\n   242→\\t\\treturn nil\\n   243→\\t})\\n   244→\\n   245→\\tif err != nil && !errors.Is(err, errStop) {\\n   246→\\t\\treturn nil, fmt.Errorf(\\\"error iterating commits: %w\\\", err)\\n   247→\\t}\\n   248→\\n   249→\\tif len(points) > limit {\\n   250→\\t\\tpoints = points[:limit]\\n   251→\\t}\\n   252→\\n   253→\\treturn points, nil\\n   254→}\\n   255→\\n   256→// ResolveLatestCheckpointFromMap picks the checkpoint with the latest CreatedAt\\n   257→// from a list of checkpoint IDs. Filters to IDs present in infoMap, then picks\\n   258→// the one with the most recent CreatedAt.\\n   259→func ResolveLatestCheckpointFromMap(cpIDs []id.CheckpointID, infoMap map[id.CheckpointID]CheckpointInfo) (CheckpointInfo, bool) {\\n   260→\\tvar found bool\\n   261→\\tvar latest CheckpointInfo\\n   262→\\tfor _, cpID := range cpIDs {\\n   263→\\t\\tinfo, ok := infoMap[cpID]\\n   264→\\t\\tif !ok {\\n   265→\\t\\t\\tcontinue\\n   266→\\t\\t}\\n   267→\\t\\tif !found || info.CreatedAt.After(latest.CreatedAt) {\\n   268→\\t\\t\\tlatest = info\\n   269→\\t\\t\\tfound = true\\n   270→\\t\\t}\\n   271→\\t}\\n   272→\\treturn latest, found\\n   273→}\\n   274→\\n   275→// Rewind restores the working directory to a checkpoint.\\n   276→//\\n   277→\\n   278→func (s *ManualCommitStrategy) Rewind(ctx context.Context, point RewindPoint) error {\\n   279→\\trepo, err := OpenRepository(ctx)\\n   280→\\tif err != nil {\\n   281→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   282→\\t}\\n   283→\\n   284→\\t// Get the checkpoint commit\\n   285→\\tcommitHash := plumbing.NewHash(point.ID)\\n   286→\\tcommit, err := repo.CommitObject(commitHash)\\n   287→\\tif err != nil {\\n   288→\\t\\treturn fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   289→\\t}\\n   290→\\n   291→\\ttree, err := commit.Tree()\\n   292→\\tif err != nil {\\n   293→\\t\\treturn fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n   294→\\t}\\n   295→\\n   296→\\t// Reset the shadow branch to the rewound checkpoint\\n   297→\\t// This ensures the next checkpoint will only include prompts from this point forward\\n   298→\\tif err := s.resetShadowBranchToCheckpoint(ctx, repo, commit); err != nil {\\n   299→\\t\\t// Log warning but don't fail - file restoration is the primary operation\\n   300→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to reset shadow branch: %v\\\\n\\\", err)\\n   301→\\t}\\n   302→\\n   303→\\t// Load session state to get untracked files that existed at session start\\n   304→\\tsessionID, hasSessionTrailer := trailers.ParseSession(commit.Message)\\n   305→\\tvar preservedUntrackedFiles map[string]bool\\n   306→\\tif hasSessionTrailer {\\n   307→\\t\\tstate, stateErr := s.loadSessionState(ctx, sessionID)\\n   308→\\t\\tif stateErr == nil && state != nil && len(state.UntrackedFilesAtStart) > 0 {\\n   309→\\t\\t\\tpreservedUntrackedFiles = make(map[string]bool)\\n   310→\\t\\t\\tfor _, f := range state.UntrackedFilesAtStart {\\n   311→\\t\\t\\t\\tpreservedUntrackedFiles[f] = true\\n   312→\\t\\t\\t}\\n   313→\\t\\t}\\n   314→\\t}\\n   315→\\n   316→\\t// Build set of files in the checkpoint tree (excluding metadata)\\n   317→\\tcheckpointFiles := make(map[string]bool)\\n   318→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   319→\\t\\tif err := ctx.Err(); err != nil {\\n   320→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   321→\\t\\t}\\n   322→\\t\\tif !strings.HasPrefix(f.Name, entireDir) {\\n   323→\\t\\t\\tcheckpointFiles[f.Name] = true\\n   324→\\t\\t}\\n   325→\\t\\treturn nil\\n   326→\\t})\\n   327→\\tif err != nil {\\n   328→\\t\\treturn fmt.Errorf(\\\"failed to list checkpoint files: %w\\\", err)\\n   329→\\t}\\n   330→\\n   331→\\t// Get HEAD tree to identify tracked files\\n   332→\\thead, err := repo.Head()\\n   333→\\tif err != nil {\\n   334→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   335→\\t}\\n   336→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   337→\\tif err != nil {\\n   338→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   339→\\t}\\n   340→\\theadTree, err := headCommit.Tree()\\n   341→\\tif err != nil {\\n   342→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD tree: %w\\\", err)\\n   343→\\t}\\n   344→\\n   345→\\t// Build set of files tracked in HEAD\\n   346→\\ttrackedFiles := make(map[string]bool)\\n   347→\\t//nolint:errcheck // Error is not critical for rewind\\n   348→\\t_ = headTree.Files().ForEach(func(f *object.File) error {\\n   349→\\t\\tif err := ctx.Err(); err != nil {\\n   350→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   351→\\t\\t}\\n   352→\\t\\ttrackedFiles[f.Name] = true\\n   353→\\t\\treturn nil\\n   354→\\t})\\n   355→\\n   356→\\t// Get repository root to walk from there\\n   357→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   358→\\tif err != nil {\\n   359→\\t\\trepoRoot = \\\".\\\" // Fallback to current directory\\n   360→\\t}\\n   361→\\n   362→\\t// Open os.Root at repo root for traversal-resistant file operations.\\n   363→\\t// Defense-in-depth: paths come from git tree objects (trusted) but we\\n   364→\\t// still scope operations to prevent any escape from the repo root.\\n   365→\\trepoRootHandle, err := os.OpenRoot(repoRoot)\\n   366→\\tif err != nil {\\n   367→\\t\\treturn fmt.Errorf(\\\"failed to open repo root: %w\\\", err)\\n   368→\\t}\\n   369→\\tdefer repoRootHandle.Close()\\n   370→\\n   371→\\t// Find and delete untracked files that aren't in the checkpoint.\\n   372→\\t// Uses git ls-files to only consider non-ignored files, avoiding walks through\\n   373→\\t// large ignored directories like node_modules/.\\n   374→\\tuntrackedNow, err := collectUntrackedFiles(ctx)\\n   375→\\tif err != nil {\\n   376→\\t\\t// Non-fatal - continue with restoration\\n   377→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: error listing untracked files: %v\\\\n\\\", err)\\n   378→\\t}\\n   379→\\tfor _, relPath := range untrackedNow {\\n   380→\\t\\t// If file is in checkpoint, it will be restored\\n   381→\\t\\tif checkpointFiles[relPath] {\\n   382→\\t\\t\\tcontinue\\n   383→\\t\\t}\\n   384→\\n   385→\\t\\t// If file is tracked in HEAD, don't delete (user's committed work)\\n   386→\\t\\tif trackedFiles[relPath] {\\n   387→\\t\\t\\tcontinue\\n   388→\\t\\t}\\n   389→\\n   390→\\t\\t// If file existed at session start, preserve it (untracked user files)\\n   391→\\t\\tif preservedUntrackedFiles[relPath] {\\n   392→\\t\\t\\tcontinue\\n   393→\\t\\t}\\n   394→\\n   395→\\t\\t// File is untracked and not in checkpoint - delete it via os.Root\\n   396→\\t\\tif removeErr := osroot.Remove(repoRootHandle, relPath); removeErr == nil {\\n   397→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Deleted: %s\\\\n\\\", relPath)\\n   398→\\t\\t}\\n   399→\\t}\\n   400→\\n   401→\\t// Restore files from checkpoint\\n   402→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   403→\\t\\tif err := ctx.Err(); err != nil {\\n   404→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   405→\\t\\t}\\n   406→\\t\\t// Skip metadata directories - these are for checkpoint storage, not working dir\\n   407→\\t\\tif strings.HasPrefix(f.Name, entireDir) {\\n   408→\\t\\t\\treturn nil\\n   409→\\t\\t}\\n   410→\\n   411→\\t\\tcontents, err := f.Contents()\\n   412→\\t\\tif err != nil {\\n   413→\\t\\t\\treturn fmt.Errorf(\\\"failed to read file %s: %w\\\", f.Name, err)\\n   414→\\t\\t}\\n   415→\\n   416→\\t\\t// Ensure directory exists (MkdirAll not available on os.Root)\\n   417→\\t\\tabsPath := filepath.Join(repoRoot, f.Name)\\n   418→\\t\\tdir := filepath.Dir(absPath)\\n   419→\\t\\tif dir != \\\".\\\" {\\n   420→\\t\\t\\t//nolint:gosec // G301: Need 0o755 for user directories during rewind\\n   421→\\t\\t\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   422→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to create directory %s: %w\\\", dir, err)\\n   423→\\t\\t\\t}\\n   424→\\t\\t}\\n   425→\\n   426→\\t\\t// Write file with appropriate permissions via os.Root\\n   427→\\t\\tvar perm os.FileMode = 0o644\\n   428→\\t\\tif f.Mode == filemode.Executable {\\n   429→\\t\\t\\tperm = 0o755\\n   430→\\t\\t}\\n   431→\\t\\tif err := osroot.WriteFile(repoRootHandle, f.Name, []byte(contents), perm); err != nil {\\n   432→\\t\\t\\treturn fmt.Errorf(\\\"failed to write file %s: %w\\\", f.Name, err)\\n   433→\\t\\t}\\n   434→\\n   435→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Restored: %s\\\\n\\\", f.Name)\\n   436→\\t\\treturn nil\\n   437→\\t})\\n   438→\\tif err != nil {\\n   439→\\t\\treturn fmt.Errorf(\\\"failed to iterate tree files: %w\\\", err)\\n   440→\\t}\\n   441→\\n   442→\\tfmt.Println()\\n   443→\\tif len(point.ID) >= 7 {\\n   444→\\t\\tfmt.Printf(\\\"Restored files from shadow commit %s\\\\n\\\", point.ID[:7])\\n   445→\\t} else {\\n   446→\\t\\tfmt.Printf(\\\"Restored files from shadow commit %s\\\\n\\\", point.ID)\\n   447→\\t}\\n   448→\\tfmt.Println()\\n   449→\\n   450→\\treturn nil\\n   451→}\\n   452→\\n   453→// resetShadowBranchToCheckpoint resets the shadow branch HEAD to the given checkpoint.\\n   454→// This ensures that when the user commits after rewinding, the next checkpoint will only\\n   455→// include prompts from the rewound point, not prompts from later checkpoints.\\n   456→func (s *ManualCommitStrategy) resetShadowBranchToCheckpoint(ctx context.Context, repo *git.Repository, commit *object.Commit) error {\\n   457→\\t// Extract session ID from the checkpoint commit's Entire-Session trailer\\n   458→\\tsessionID, found := trailers.ParseSession(commit.Message)\\n   459→\\tif !found {\\n   460→\\t\\treturn errors.New(\\\"checkpoint has no Entire-Session trailer\\\")\\n   461→\\t}\\n   462→\\n   463→\\t// Load session state to get the shadow branch name\\n   464→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   465→\\tif err != nil {\\n   466→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   467→\\t}\\n   468→\\tif state == nil {\\n   469→\\t\\treturn fmt.Errorf(\\\"session %s not found\\\", sessionID)\\n   470→\\t}\\n   471→\\n   472→\\t// Reset the shadow branch to the checkpoint commit\\n   473→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   474→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   475→\\n   476→\\t// Update the reference to point to the checkpoint commit\\n   477→\\tref := plumbing.NewHashReference(refName, commit.Hash)\\n   478→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   479→\\t\\treturn fmt.Errorf(\\\"failed to update shadow branch: %w\\\", err)\\n   480→\\t}\\n   481→\\n   482→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Reset shadow branch %s to checkpoint %s\\\\n\\\", shadowBranchName, commit.Hash.String()[:7])\\n   483→\\treturn nil\\n   484→}\\n   485→\\n   486→// CanRewind checks if rewinding is possible.\\n   487→// For manual-commit strategy, rewind restores files from a checkpoint - uncommitted changes are expected\\n   488→// and will be replaced by the checkpoint contents. Returns true with a warning message showing\\n   489→// what changes will be reverted.\\n   490→func (s *ManualCommitStrategy) CanRewind(ctx context.Context) (bool, string, error) {\\n   491→\\treturn checkCanRewindWithWarning(ctx)\\n   492→}\\n   493→\\n   494→// PreviewRewind returns what will happen if rewinding to the given point.\\n   495→// This allows showing warnings about untracked files that will be deleted.\\n   496→func (s *ManualCommitStrategy) PreviewRewind(ctx context.Context, point RewindPoint) (*RewindPreview, error) {\\n   497→\\t// Logs-only points don't modify the working directory\\n   498→\\tif point.IsLogsOnly {\\n   499→\\t\\treturn &RewindPreview{}, nil\\n   500→\\t}\\n   501→\\n   502→\\trepo, err := OpenRepository(ctx)\\n   503→\\tif err != nil {\\n   504→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   505→\\t}\\n   506→\\n   507→\\t// Get the checkpoint commit\\n   508→\\tcommitHash := plumbing.NewHash(point.ID)\\n   509→\\tcommit, err := repo.CommitObject(commitHash)\\n   510→\\tif err != nil {\\n   511→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   512→\\t}\\n   513→\\n   514→\\ttree, err := commit.Tree()\\n   515→\\tif err != nil {\\n   516→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n   517→\\t}\\n   518→\\n   519→\\t// Load session state to get untracked files that existed at session start\\n   520→\\tsessionID, hasSessionTrailer := trailers.ParseSession(commit.Message)\\n   521→\\tvar preservedUntrackedFiles map[string]bool\\n   522→\\tif hasSessionTrailer {\\n   523→\\t\\tstate, stateErr := s.loadSessionState(ctx, sessionID)\\n   524→\\t\\tif stateErr == nil && state != nil && len(state.UntrackedFilesAtStart) > 0 {\\n   525→\\t\\t\\tpreservedUntrackedFiles = make(map[string]bool)\\n   526→\\t\\t\\tfor _, f := range state.UntrackedFilesAtStart {\\n   527→\\t\\t\\t\\tpreservedUntrackedFiles[f] = true\\n   528→\\t\\t\\t}\\n   529→\\t\\t}\\n   530→\\t}\\n   531→\\n   532→\\t// Build set of files in the checkpoint tree (excluding metadata)\\n   533→\\tcheckpointFiles := make(map[string]bool)\\n   534→\\tvar filesToRestore []string\\n   535→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   536→\\t\\tif err := ctx.Err(); err != nil {\\n   537→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   538→\\t\\t}\\n   539→\\t\\tif !strings.HasPrefix(f.Name, entireDir) {\\n   540→\\t\\t\\tcheckpointFiles[f.Name] = true\\n   541→\\t\\t\\tfilesToRestore = append(filesToRestore, f.Name)\\n   542→\\t\\t}\\n   543→\\t\\treturn nil\\n   544→\\t})\\n   545→\\tif err != nil {\\n   546→\\t\\treturn nil, fmt.Errorf(\\\"failed to list checkpoint files: %w\\\", err)\\n   547→\\t}\\n   548→\\n   549→\\t// Get HEAD tree to identify tracked files\\n   550→\\thead, err := repo.Head()\\n   551→\\tif err != nil {\\n   552→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   553→\\t}\\n   554→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   555→\\tif err != nil {\\n   556→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   557→\\t}\\n   558→\\theadTree, err := headCommit.Tree()\\n   559→\\tif err != nil {\\n   560→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD tree: %w\\\", err)\\n   561→\\t}\\n   562→\\n   563→\\t// Build set of files tracked in HEAD\\n   564→\\ttrackedFiles := make(map[string]bool)\\n   565→\\t//nolint:errcheck // Error is not critical for preview\\n   566→\\t_ = headTree.Files().ForEach(func(f *object.File) error {\\n   567→\\t\\tif err := ctx.Err(); err != nil {\\n   568→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   569→\\t\\t}\\n   570→\\t\\ttrackedFiles[f.Name] = true\\n   571→\\t\\treturn nil\\n   572→\\t})\\n   573→\\n   574→\\t// Find untracked files that would be deleted.\\n   575→\\t// Uses git ls-files to only consider non-ignored files.\\n   576→\\tvar filesToDelete []string\\n   577→\\tuntrackedNow, untrackedErr := collectUntrackedFiles(ctx)\\n   578→\\tif untrackedErr != nil {\\n   579→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: could not list untracked files for preview: %v\\\\n\\\", untrackedErr)\\n   580→\\t\\treturn &RewindPreview{\\n   581→\\t\\t\\tFilesToRestore: filesToRestore,\\n   582→\\t\\t\\tFilesToDelete:  filesToDelete,\\n   583→\\t\\t}, nil\\n   584→\\t}\\n   585→\\tfor _, relPath := range untrackedNow {\\n   586→\\t\\tif checkpointFiles[relPath] {\\n   587→\\t\\t\\tcontinue\\n   588→\\t\\t}\\n   589→\\t\\tif trackedFiles[relPath] {\\n   590→\\t\\t\\tcontinue\\n   591→\\t\\t}\\n   592→\\t\\tif preservedUntrackedFiles[relPath] {\\n   593→\\t\\t\\tcontinue\\n   594→\\t\\t}\\n   595→\\t\\tfilesToDelete = append(filesToDelete, relPath)\\n   596→\\t}\\n   597→\\n   598→\\t// Sort for consistent output\\n   599→\\tsort.Strings(filesToRestore)\\n   600→\\tsort.Strings(filesToDelete)\\n   601→\\n   602→\\treturn &RewindPreview{\\n   603→\\t\\tFilesToRestore: filesToRestore,\\n   604→\\t\\tFilesToDelete:  filesToDelete,\\n   605→\\t}, nil\\n   606→}\\n   607→\\n   608→// RestoreLogsOnly restores session logs from a logs-only rewind point.\\n   609→// This fetches the transcript from entire/checkpoints/v1 and writes it to the agent's session directory.\\n   610→// Does not modify the working directory.\\n   611→// When multiple sessions were condensed to the same checkpoint, ALL sessions are restored.\\n   612→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   613→// Returns info about each restored session so callers can print correct per-session resume commands.\\n   614→func (s *ManualCommitStrategy) RestoreLogsOnly(ctx context.Context, point RewindPoint, force bool) ([]RestoredSession, error) {\\n   615→\\tif !point.IsLogsOnly {\\n   616→\\t\\treturn nil, errors.New(\\\"not a logs-only rewind point\\\")\\n   617→\\t}\\n   618→\\n   619→\\tif point.CheckpointID.IsEmpty() {\\n   620→\\t\\treturn nil, errors.New(\\\"missing checkpoint ID\\\")\\n   621→\\t}\\n   622→\\n   623→\\t// Get checkpoint store\\n   624→\\tstore, err := s.getCheckpointStore()\\n   625→\\tif err != nil {\\n   626→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   627→\\t}\\n   628→\\n   629→\\t// Read checkpoint summary to get session count\\n   630→\\tsummary, err := store.ReadCommitted(ctx, point.CheckpointID)\\n   631→\\tif err != nil {\\n   632→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   633→\\t}\\n   634→\\tif summary == nil {\\n   635→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", point.CheckpointID)\\n   636→\\t}\\n   637→\\n   638→\\t// Get worktree root for agent session directory lookup\\n   639→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   640→\\tif err != nil {\\n   641→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   642→\\t}\\n   643→\\n   644→\\t// Chec