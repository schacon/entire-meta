n fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   149→\\t}\\n   150→\\tdefer root.Close()\\n   151→\\n   152→\\tif err := osroot.WriteFile(root, fileName, data, 0o600); err != nil {\\n   153→\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   154→\\t}\\n   155→\\n   156→\\tlogging.Debug(logging.WithComponent(ctx, \\\"state\\\"), \\\"captured state before prompt\\\",\\n   157→\\t\\tslog.Int(\\\"untracked_files\\\", len(untrackedFiles)),\\n   158→\\t\\tslog.Int(\\\"transcript_offset\\\", transcriptOffset))\\n   159→\\treturn nil\\n   160→}\\n   161→\\n   162→// LoadPrePromptState loads previously captured state.\\n   163→// Returns nil if no state file exists.\\n   164→func LoadPrePromptState(ctx context.Context, sessionID string) (*PrePromptState, error) {\\n   165→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   166→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID for pre-prompt state: %w\\\", err)\\n   167→\\t}\\n   168→\\n   169→\\ttmpDirAbs := resolveTmpDir(ctx)\\n   170→\\n   171→\\troot, err := os.OpenRoot(tmpDirAbs)\\n   172→\\tif err != nil {\\n   173→\\t\\t// Directory doesn't exist yet — no state file\\n   174→\\t\\tif os.IsNotExist(err) {\\n   175→\\t\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   176→\\t\\t}\\n   177→\\t\\treturn nil, fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   178→\\t}\\n   179→\\tdefer root.Close()\\n   180→\\n   181→\\tfileName := fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID)\\n   182→\\tdata, err := osroot.ReadFile(root, fileName)\\n   183→\\tif err != nil {\\n   184→\\t\\tif os.IsNotExist(err) {\\n   185→\\t\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   186→\\t\\t}\\n   187→\\t\\treturn nil, fmt.Errorf(\\\"failed to read state file: %w\\\", err)\\n   188→\\t}\\n   189→\\n   190→\\tvar state PrePromptState\\n   191→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   192→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal state: %w\\\", err)\\n   193→\\t}\\n   194→\\n   195→\\tstate.normalizePrePromptState()\\n   196→\\n   197→\\treturn &state, nil\\n   198→}\\n   199→\\n   200→// CleanupPrePromptState removes the state file after use\\n   201→func CleanupPrePromptState(ctx context.Context, sessionID string) error {\\n   202→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   203→\\t\\treturn fmt.Errorf(\\\"invalid session ID for pre-prompt state cleanup: %w\\\", err)\\n   204→\\t}\\n   205→\\n   206→\\ttmpDirAbs := resolveTmpDir(ctx)\\n   207→\\n   208→\\troot, err := os.OpenRoot(tmpDirAbs)\\n   209→\\tif err != nil {\\n   210→\\t\\tif os.IsNotExist(err) {\\n   211→\\t\\t\\treturn nil // Directory doesn't exist, nothing to clean up\\n   212→\\t\\t}\\n   213→\\t\\treturn fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   214→\\t}\\n   215→\\tdefer root.Close()\\n   216→\\n   217→\\tfileName := fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID)\\n   218→\\treturn osroot.Remove(root, fileName) //nolint:wrapcheck // best-effort cleanup, caller adds context via wrapping function name\\n   219→}\\n   220→\\n   221→// FileChanges holds categorized file changes from git status.\\n   222→type FileChanges struct {\\n   223→\\tModified []string // Modified or staged files\\n   224→\\tNew      []string // Untracked files (filtered if previouslyUntracked provided)\\n   225→\\tDeleted  []string // Deleted files (staged or unstaged)\\n   226→}\\n   227→\\n   228→// DetectFileChanges returns categorized file changes from the current git status.\\n   229→//\\n   230→// previouslyUntracked controls new-file detection:\\n   231→//   - nil: all untracked files go into New\\n   232→//   - non-nil: only untracked files NOT in the pre-existing set go into New\\n   233→//\\n   234→// Modified includes both worktree and staging modified/added files.\\n   235→// Deleted includes both staged and unstaged deletions.\\n   236→// All results exclude .entire/ directory.\\n   237→func DetectFileChanges(ctx context.Context, previouslyUntracked []string) (*FileChanges, error) {\\n   238→\\trepo, err := openRepository(ctx)\\n   239→\\tif err != nil {\\n   240→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   241→\\t}\\n   242→\\n   243→\\tworktree, err := repo.Worktree()\\n   244→\\tif err != nil {\\n   245→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   246→\\t}\\n   247→\\n   248→\\tstatus, err := worktree.Status()\\n   249→\\tif err != nil {\\n   250→\\t\\treturn nil, fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n   251→\\t}\\n   252→\\n   253→\\t// Build set of pre-existing untracked files for quick lookup\\n   254→\\tvar preExisting map[string]bool\\n   255→\\tif previouslyUntracked != nil {\\n   256→\\t\\tpreExisting = make(map[string]bool, len(previouslyUntracked))\\n   257→\\t\\tfor _, f := range previouslyUntracked {\\n   258→\\t\\t\\tpreExisting[f] = true\\n   259→\\t\\t}\\n   260→\\t}\\n   261→\\n   262→\\tvar changes FileChanges\\n   263→\\tfor file, st := range status {\\n   264→\\t\\tif paths.IsInfrastructurePath(file) {\\n   265→\\t\\t\\tcontinue\\n   266→\\t\\t}\\n   267→\\n   268→\\t\\tswitch {\\n   269→\\t\\tcase st.Worktree == git.Untracked:\\n   270→\\t\\t\\tif preExisting != nil {\\n   271→\\t\\t\\t\\tif !preExisting[file] {\\n   272→\\t\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   273→\\t\\t\\t\\t}\\n   274→\\t\\t\\t} else {\\n   275→\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   276→\\t\\t\\t}\\n   277→\\t\\tcase st.Worktree == git.Deleted || st.Staging == git.Deleted:\\n   278→\\t\\t\\tchanges.Deleted = append(changes.Deleted, file)\\n   279→\\t\\tcase st.Worktree == git.Modified || st.Staging == git.Modified ||\\n   280→\\t\\t\\tst.Worktree == git.Added || st.Staging == git.Added:\\n   281→\\t\\t\\tchanges.Modified = append(changes.Modified, file)\\n   282→\\t\\t}\\n   283→\\t}\\n   284→\\n   285→\\treturn &changes, nil\\n   286→}\\n   287→\\n   288→// filterToUncommittedFiles removes files from the list that are already committed to HEAD\\n   289→// with matching content. This prevents re-adding files that an agent committed mid-turn\\n   290→// (already condensed by PostCommit) back to FilesTouched via SaveStep. Files not in\\n   291→// HEAD or with different content in the working tree are kept. Fails open: if any git\\n   292→// operation errors, returns the original list unchanged.\\n   293→func filterToUncommittedFiles(ctx context.Context, files []string, repoRoot string) []string {\\n   294→\\tif len(files) == 0 {\\n   295→\\t\\treturn files\\n   296→\\t}\\n   297→\\n   298→\\trepo, err := openRepository(ctx)\\n   299→\\tif err != nil {\\n   300→\\t\\treturn files // fail open\\n   301→\\t}\\n   302→\\n   303→\\thead, err := repo.Head()\\n   304→\\tif err != nil {\\n   305→\\t\\treturn files // fail open (empty repo, detached HEAD, etc.)\\n   306→\\t}\\n   307→\\n   308→\\tcommit, err := repo.CommitObject(head.Hash())\\n   309→\\tif err != nil {\\n   310→\\t\\treturn files // fail open\\n   311→\\t}\\n   312→\\n   313→\\theadTree, err := commit.Tree()\\n   314→\\tif err != nil {\\n   315→\\t\\treturn files // fail open\\n   316→\\t}\\n   317→\\n   318→\\tvar result []string\\n   319→\\tfor _, relPath := range files {\\n   320→\\t\\theadFile, err := headTree.File(relPath)\\n   321→\\t\\tif err != nil {\\n   322→\\t\\t\\t// File not in HEAD — it's uncommitted\\n   323→\\t\\t\\tresult = append(result, relPath)\\n   324→\\t\\t\\tcontinue\\n   325→\\t\\t}\\n   326→\\n   327→\\t\\t// File is in HEAD — compare content with working tree\\n   328→\\t\\tabsPath := filepath.Join(repoRoot, relPath)\\n   329→\\t\\tworkingContent, err := os.ReadFile(absPath) //nolint:gosec // path from controlled source\\n   330→\\t\\tif err != nil {\\n   331→\\t\\t\\t// Can't read working tree file (deleted?) — keep it\\n   332→\\t\\t\\tresult = append(result, relPath)\\n   333→\\t\\t\\tcontinue\\n   334→\\t\\t}\\n   335→\\n   336→\\t\\theadContent, err := headFile.Contents()\\n   337→\\t\\tif err != nil {\\n   338→\\t\\t\\tresult = append(result, relPath)\\n   339→\\t\\t\\tcontinue\\n   340→\\t\\t}\\n   341→\\n   342→\\t\\tif string(workingContent) != headContent {\\n   343→\\t\\t\\t// Working tree differs from HEAD — uncommitted changes\\n   344→\\t\\t\\tresult = append(result, relPath)\\n   345→\\t\\t}\\n   346→\\t\\t// else: content matches HEAD — already committed, skip\\n   347→\\t}\\n   348→\\n   349→\\treturn result\\n   350→}\\n   351→\\n   352→// FilterAndNormalizePaths converts absolute paths to relative and filters out\\n   353→// infrastructure paths and paths outside the repo.\\n   354→func FilterAndNormalizePaths(files []string, cwd string) []string {\\n   355→\\tvar result []string\\n   356→\\tfor _, file := range files {\\n   357→\\t\\trelPath := paths.ToRelativePath(file, cwd)\\n   358→\\t\\tif relPath == \\\"\\\" {\\n   359→\\t\\t\\tcontinue // outside repo\\n   360→\\t\\t}\\n   361→\\t\\tif paths.IsInfrastructurePath(relPath) {\\n   362→\\t\\t\\tcontinue // skip .entire directory\\n   363→\\t\\t}\\n   364→\\t\\tresult = append(result, relPath)\\n   365→\\t}\\n   366→\\treturn result\\n   367→}\\n   368→\\n   369→// mergeUnique appends elements from extra into base, skipping duplicates already in base.\\n   370→func mergeUnique(base, extra []string) []string {\\n   371→\\tif len(extra) == 0 {\\n   372→\\t\\treturn base\\n   373→\\t}\\n   374→\\tseen := make(map[string]bool, len(base))\\n   375→\\tfor _, s := range base {\\n   376→\\t\\tseen[s] = true\\n   377→\\t}\\n   378→\\tfor _, s := range extra {\\n   379→\\t\\tif !seen[s] {\\n   380→\\t\\t\\tseen[s] = true\\n   381→\\t\\t\\tbase = append(base, s)\\n   382→\\t\\t}\\n   383→\\t}\\n   384→\\treturn base\\n   385→}\\n   386→\\n   387→// resolveTmpDir returns the absolute path to the .entire/tmp directory,\\n   388→// falling back to a relative path if the repo root can't be determined.\\n   389→func resolveTmpDir(ctx context.Context) string {\\n   390→\\tabs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   391→\\tif err != nil {\\n   392→\\t\\treturn paths.EntireTmpDir\\n   393→\\t}\\n   394→\\treturn abs\\n   395→}\\n   396→\\n   397→// getUntrackedFilesForState returns a list of untracked files using go-git\\n   398→// Excludes .entire directory\\n   399→func getUntrackedFilesForState(ctx context.Context) ([]string, error) {\\n   400→\\trepo, err := openRepository(ctx)\\n   401→\\tif err != nil {\\n   402→\\t\\treturn nil, err\\n   403→\\t}\\n   404→\\n   405→\\tworktree, err := repo.Worktree()\\n   406→\\tif err != nil {\\n   407→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   408→\\t}\\n   409→\\n   410→\\tstatus, err := worktree.Status()\\n   411→\\tif err != nil {\\n   412→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   413→\\t}\\n   414→\\n   415→\\tuntrackedFiles := []string{}\\n   416→\\tfor file, st := range status {\\n   417→\\t\\tif st.Worktree == git.Untracked {\\n   418→\\t\\t\\t// Exclude .entire directory\\n   419→\\t\\t\\tif !paths.IsInfrastructurePath(file) {\\n   420→\\t\\t\\t\\tuntrackedFiles = append(untrackedFiles, file)\\n   421→\\t\\t\\t}\\n   422→\\t\\t}\\n   423→\\t}\\n   424→\\n   425→\\treturn untrackedFiles, nil\\n   426→}\\n   427→\\n   428→// PreTaskState stores the state captured before a task execution\\n   429→type PreTaskState struct {\\n   430→\\tToolUseID      string   `json:\\\"tool_use_id\\\"`\\n   431→\\tTimestamp      string   `json:\\\"timestamp\\\"`\\n   432→\\tUntrackedFiles []string `json:\\\"untracked_files\\\"`\\n   433→}\\n   434→\\n   435→// PreUntrackedFiles returns the untracked files list, or nil if the receiver is nil.\\n   436→// See PrePromptState.PreUntrackedFiles for nil-vs-empty semantics.\\n   437→func (s *PreTaskState) PreUntrackedFiles() []string {\\n   438→\\tif s == nil {\\n   439→\\t\\treturn nil\\n   440→\\t}\\n   441→\\tif s.UntrackedFiles == nil {\\n   442→\\t\\treturn []string{}\\n   443→\\t}\\n   444→\\treturn s.UntrackedFiles\\n   445→}\\n   446→\\n   447→// CapturePreTaskState captures current untracked files before a Task execution\\n   448→// and saves them to a state file.\\n   449→// Works correctly from any subdirectory within the repository.\\n   450→func CapturePreTaskState(ctx context.Context, toolUseID string) error {\\n   451→\\tif toolUseID == \\\"\\\" {\\n   452→\\t\\treturn errors.New(\\\"tool_use_id is required\\\")\\n   453→\\t}\\n   454→\\n   455→\\tif err := validation.ValidateToolUseID(toolUseID); err != nil {\\n   456→\\t\\treturn fmt.Errorf(\\\"invalid tool use ID for pre-task state: %w\\\", err)\\n   457→\\t}\\n   458→\\n   459→\\t// Get absolute path for tmp directory\\n   460→\\ttmpDirAbs := resolveTmpDir(ctx)\\n   461→\\n   462→\\t// Create tmp directory if it doesn't exist\\n   463→\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   464→\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n   465→\\t}\\n   466→\\n   467→\\t// Get list of untracked files (excluding .entire directory itself)\\n   468→\\tuntrackedFiles, err := getUntrackedFilesForState(ctx)\\n   469→\\tif err != nil {\\n   470→\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n   471→\\t}\\n   472→\\n   473→\\t// Create state file using os.Root for traversal-resistant write\\n   474→\\tstate := PreTaskState{\\n   475→\\t\\tToolUseID:      toolUseID,\\n   476→\\t\\tTimestamp:      time.Now().UTC().Format(time.RFC3339),\\n   477→\\t\\tUntrackedFiles: untrackedFiles,\\n   478→\\t}\\n   479→\\n   480→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   481→\\tif err != nil {\\n   482→\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n   483→\\t}\\n   484→\\n   485→\\tfileName := fmt.Sprintf(\\\"pre-task-%s.json\\\", toolUseID)\\n   486→\\troot, err := os.OpenRoot(tmpDirAbs)\\n   487→\\tif err != nil {\\n   488→\\t\\treturn fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   489→\\t}\\n   490→\\tdefer root.Close()\\n   491→\\n   492→\\tif err := osroot.WriteFile(root, fileName, data, 0o600); err != nil {\\n   493→\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   494→\\t}\\n   495→\\n   496→\\tlogging.Debug(logging.WithComponent(ctx, \\\"state\\\"), \\\"captured state before task\\\",\\n   497→\\t\\tslog.Int(\\\"untracked_files\\\", len(untrackedFiles)))\\n   498→\\treturn nil\\n   499→}\\n   500→\\n   501→// LoadPreTaskState loads previously captured task state.\\n   502→// Returns nil if no state file exists.\\n   503→func LoadPreTaskState(ctx context.Context, toolUseID string) (*PreTaskState, error) {\\n   504→\\tif err := validation.ValidateToolUseID(toolUseID); err != nil {\\n   505→\\t\\treturn nil, fmt.Errorf(\\\"invalid tool use ID for pre-task state: %w\\\", err)\\n   506→\\t}\\n   507→\\n   508→\\ttmpDirAbs := resolveTmpDir(ctx)\\n   509→\\n   510→\\troot, err := os.OpenRoot(tmpDirAbs)\\n   511→\\tif err != nil {\\n   512→\\t\\tif os.IsNotExist(err) {\\n   513→\\t\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   514→\\t\\t}\\n   515→\\t\\treturn nil, fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   516→\\t}\\n   517→\\tdefer root.Close()\\n   518→\\n   519→\\tfileName := fmt.Sprintf(\\\"pre-task-%s.json\\\", toolUseID)\\n   520→\\tdata, err := osroot.ReadFile(root, fileName)\\n   521→\\tif err != nil {\\n   522→\\t\\tif os.IsNotExist(err) {\\n   523→\\t\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   524→\\t\\t}\\n   525→\\t\\treturn nil, fmt.Errorf(\\\"failed to read state file: %w\\\", err)\\n   526→\\t}\\n   527→\\n   528→\\tvar state PreTaskState\\n   529→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   530→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal state: %w\\\", err)\\n   531→\\t}\\n   532→\\n   533→\\treturn &state, nil\\n   534→}\\n   535→\\n   536→// CleanupPreTaskState removes the task state file after use\\n   537→func CleanupPreTaskState(ctx context.Context, toolUseID string) error {\\n   538→\\tif err := validation.ValidateToolUseID(toolUseID); err != nil {\\n   539→\\t\\treturn fmt.Errorf(\\\"invalid tool use ID for pre-task state cleanup: %w\\\", err)\\n   540→\\t}\\n   541→\\n   542→\\ttmpDirAbs := resolveTmpDir(ctx)\\n   543→\\n   544→\\troot, err := os.OpenRoot(tmpDirAbs)\\n   545→\\tif err != nil {\\n   546→\\t\\tif os.IsNotExist(err) {\\n   547→\\t\\t\\treturn nil // Directory doesn't exist, nothing to clean up\\n   548→\\t\\t}\\n   549→\\t\\treturn fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   550→\\t}\\n   551→\\tdefer root.Close()\\n   552→\\n   553→\\tfileName := fmt.Sprintf(\\\"pre-task-%s.json\\\", toolUseID)\\n   554→\\treturn osroot.Remove(root, fileName) //nolint:wrapcheck // best-effort cleanup, caller adds context via wrapping function name\\n   555→}\\n   556→\\n   557→// preTaskFilePrefix is the prefix for pre-task state files\\n   558→const preTaskFilePrefix = \\\"pre-task-\\\"\\n   559→\\n   560→// FindActivePreTaskFile finds an active pre-task file in .entire/tmp/ and returns\\n   561→// the parent Task's tool_use_id. Returns (\\\"\\\", false) if no pre-task file exists.\\n   562→// When multiple pre-task files exist (nested subagents), returns the most recently\\n   563→// modified one.\\n   564→// Works correctly from any subdirectory within the repository.\\n   565→func FindActivePreTaskFile(ctx context.Context) (taskToolUseID string, found bool) {\\n   566→\\ttmpDirAbs := resolveTmpDir(ctx)\\n   567→\\tentries, err := os.ReadDir(tmpDirAbs)\\n   568→\\tif err != nil {\\n   569→\\t\\treturn \\\"\\\", false\\n   570→\\t}\\n   571→\\n   572→\\tvar latestFile string\\n   573→\\tvar latestTime time.Time\\n   574→\\n   575→\\tfor _, entry := range entries {\\n   576→\\t\\tif entry.IsDir() {\\n   577→\\t\\t\\tcontinue\\n   578→\\t\\t}\\n   579→\\t\\tname := entry.Name()\\n   580→\\t\\tif !strings.HasPrefix(name, preTaskFilePrefix) || !strings.HasSuffix(name, \\\".json\\\") {\\n   581→\\t\\t\\tcontinue\\n   582→\\t\\t}\\n   583→\\n   584→\\t\\t// Check modification time for nested subagent handling\\n   585→\\t\\tinfo, err := entry.Info()\\n   586→\\t\\tif err != nil {\\n   587→\\t\\t\\tcontinue\\n   588→\\t\\t}\\n   589→\\t\\tif latestFile == \\\"\\\" || info.ModTime().After(latestTime) {\\n   590→\\t\\t\\tlatestFile = name\\n   591→\\t\\t\\tlatestTime = info.ModTime()\\n   592→\\t\\t}\\n   593→\\t}\\n   594→\\n   595→\\tif latestFile == \\\"\\\" {\\n   596→\\t\\treturn \\\"\\\", false\\n   597→\\t}\\n   598→\\n   599→\\t// Extract tool_use_id from filename: pre-task-<tool_use_id>.json\\n   600→\\ttoolUseID := strings.TrimPrefix(latestFile, preTaskFilePrefix)\\n   601→\\ttoolUseID = strings.TrimSuffix(toolUseID, \\\".json\\\")\\n   602→\\treturn toolUseID, true\\n   603→}\\n   604→\\n   605→// GetNextCheckpointSequence returns the next sequence number for incremental checkpoints.\\n   606→// It counts existing checkpoint files in the task metadata checkpoints directory.\\n   607→// Returns 1 if no checkpoints exist yet.\\n   608→func GetNextCheckpointSequence(sessionID, taskToolUseID string) int {\\n   609→\\t// Use the session ID directly as the metadata directory name\\n   610→\\tsessionMetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   611→\\ttaskMetadataDir := strategy.TaskMetadataDir(sessionMetadataDir, taskToolUseID)\\n   612→\\tcheckpointsDir := filepath.Join(taskMetadataDir, \\\"checkpoints\\\")\\n   613→\\n   614→\\tentries, err := os.ReadDir(checkpointsDir)\\n   615→\\tif err != nil {\\n   616→\\t\\t// Directory doesn't exist or can't be read - start at 1\\n   617→\\t\\treturn 1\\n   618→\\t}\\n   619→\\n   620→\\t// Count JSON files (checkpoints)\\n   621→\\tcount := 0\\n   622→\\tfor _, entry := range entries {\\n   623→\\t\\tif !entry.IsDir() && strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   624→\\t\\t\\tcount++\\n   625→\\t\\t}\\n   626→\\t}\\n   627→\\n   628→\\treturn count + 1\\n   629→}\\n   630→\"}]},\"uuid\":\"5327f1aa-c962-45bf-96fb-f062e0b8e1d3\",\"timestamp\":\"2026-03-16T15:06:45.349Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/state.go\",\"content\":\"package cli\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/osroot\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v6\\\"\\n)\\n\\n// PrePromptState stores the state captured before a user prompt\\ntype PrePromptState struct {\\n\\tSessionID      string   `json:\\\"session_id\\\"`\\n\\tTimestamp      string   `json:\\\"timestamp\\\"`\\n\\tUntrackedFiles []string `json:\\\"untracked_files\\\"`\\n\\n\\t// TranscriptOffset is the unified transcript position when this state was captured.\\n\\t// For Claude Code (JSONL), this is the line count.\\n\\t// For Gemini CLI (JSON), this is the message count.\\n\\t// Zero means not set or session just started.\\n\\tTranscriptOffset int `json:\\\"transcript_offset,omitempty\\\"`\\n\\n\\t// LastTranscriptIdentifier is the agent-specific identifier at the transcript position.\\n\\t// UUID for Claude Code, message ID for Gemini CLI. Optional metadata.\\n\\tLastTranscriptIdentifier string `json:\\\"last_transcript_identifier,omitempty\\\"`\\n\\n\\t// Deprecated: StartMessageIndex is the old Gemini-specific field.\\n\\t// Migrated to TranscriptOffset on load.\\n\\tStartMessageIndex int `json:\\\"start_message_index,omitempty\\\"`\\n\\n\\t// Deprecated: StepTranscriptStart is the old Claude-specific field.\\n\\t// Migrated to TranscriptOffset on load.\\n\\tStepTranscriptStart int `json:\\\"step_transcript_start,omitempty\\\"`\\n\\n\\t// Deprecated: LastTranscriptLineCount is the oldest name for transcript position.\\n\\t// Migrated to TranscriptOffset on load.\\n\\tLastTranscriptLineCount int `json:\\\"last_transcript_line_count,omitempty\\\"`\\n}\\n\\n// PreUntrackedFiles returns the untracked files list, or nil if the receiver is nil.\\n// This nil-vs-empty distinction lets DetectFileChanges know whether to skip new-file detection.\\n// When the receiver is non-nil but UntrackedFiles is nil (e.g., old state files deserialized with\\n// \\\"untracked_files\\\": null), returns an empty non-nil slice so that all current untracked files\\n// are correctly treated as new.\\nfunc (s *PrePromptState) PreUntrackedFiles() []string {\\n\\tif s == nil {\\n\\t\\treturn nil\\n\\t}\\n\\tif s.UntrackedFiles == nil {\\n\\t\\treturn []string{}\\n\\t}\\n\\treturn s.UntrackedFiles\\n}\\n\\n// normalizePrePromptState migrates deprecated fields after loading from JSON.\\nfunc (s *PrePromptState) normalizePrePromptState() {\\n\\t// Migrate the oldest field to the intermediate field first\\n\\tif s.StepTranscriptStart == 0 && s.LastTranscriptLineCount > 0 {\\n\\t\\ts.StepTranscriptStart = s.LastTranscriptLineCount\\n\\t}\\n\\ts.LastTranscriptLineCount = 0\\n\\n\\t// Migrate all deprecated fields to the unified TranscriptOffset\\n\\tif s.TranscriptOffset == 0 {\\n\\t\\tif s.StepTranscriptStart > 0 {\\n\\t\\t\\ts.TranscriptOffset = s.StepTranscriptStart\\n\\t\\t} else if s.StartMessageIndex > 0 {\\n\\t\\t\\ts.TranscriptOffset = s.StartMessageIndex\\n\\t\\t}\\n\\t}\\n\\ts.StepTranscriptStart = 0\\n\\ts.StartMessageIndex = 0\\n}\\n\\n// CapturePrePromptState captures current untracked files and transcript position before a prompt\\n// and saves them to a state file.\\n//\\n// The agent parameter is used to determine the transcript position via TranscriptAnalyzer.\\n// If the agent does not implement TranscriptAnalyzer, the transcript offset will be 0.\\n// The sessionRef parameter is optional — if empty, transcript position won't be captured.\\n//\\n// Works correctly from any subdirectory within the repository.\\nfunc CapturePrePromptState(ctx context.Context, ag agent.Agent, sessionID, sessionRef string) error {\\n\\tif sessionID == \\\"\\\" {\\n\\t\\tsessionID = unknownSessionID\\n\\t}\\n\\n\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid session ID for pre-prompt state: %w\\\", err)\\n\\t}\\n\\n\\t// Get absolute path for tmp directory\\n\\ttmpDirAbs := resolveTmpDir(ctx)\\n\\n\\t// Create tmp directory if it doesn't exist\\n\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n\\t}\\n\\n\\t// Get list of untracked files (excluding .entire directory itself)\\n\\tuntrackedFiles, err := getUntrackedFilesForState(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n\\t}\\n\\n\\t// Get transcript position using TranscriptAnalyzer if available\\n\\tvar transcriptOffset int\\n\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok && sessionRef != \\\"\\\" {\\n\\t\\tpos, posErr := analyzer.GetTranscriptPosition(sessionRef)\\n\\t\\tif posErr != nil {\\n\\t\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"state\\\"), \\\"failed to get transcript position\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", posErr.Error()))\\n\\t\\t} else {\\n\\t\\t\\ttranscriptOffset = pos\\n\\t\\t}\\n\\t}\\n\\n\\t// Create state file using os.Root for traversal-resistant write\\n\\tstate := PrePromptState{\\n\\t\\tSessionID:        sessionID,\\n\\t\\tTimestamp:        time.Now().UTC().Format(time.RFC3339),\\n\\t\\tUntrackedFiles:   untrackedFiles,\\n\\t\\tTranscriptOffset: transcriptOffset,\\n\\t}\\n\\n\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n\\t}\\n\\n\\tfileName := fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID)\\n\\troot, err := os.OpenRoot(tmpDirAbs)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n\\t}\\n\\tdefer root.Close()\\n\\n\\tif err := osroot.WriteFile(root, fileName, data, 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n\\t}\\n\\n\\tlogging.Debug(logging.WithComponent(ctx, \\\"state\\\"), \\\"captured state before prompt\\\",\\n\\t\\tslog.Int(\\\"untracked_files\\\", len(untrackedFiles)),\\n\\t\\tslog.Int(\\\"transcript_offset\\\", transcriptOffset))\\n\\treturn nil\\n}\\n\\n// LoadPrePromptState loads previously captured state.\\n// Returns nil if no state file exists.\\nfunc LoadPrePromptState(ctx context.Context, sessionID string) (*PrePromptState, error) {\\n\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID for pre-prompt state: %w\\\", err)\\n\\t}\\n\\n\\ttmpDirAbs := resolveTmpDir(ctx)\\n\\n\\troot, err := os.OpenRoot(tmpDirAbs)\\n\\tif err != nil {\\n\\t\\t// Directory doesn't exist yet — no state file\\n\\t\\tif os.IsNotExist(err) {\\n\\t\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n\\t\\t}\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n\\t}\\n\\tdefer root.Close()\\n\\n\\tfileName := fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID)\\n\\tdata, err := osroot.ReadFile(root, fileName)\\n\\tif err != nil {\\n\\t\\tif os.IsNotExist(err) {\\n\\t\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n\\t\\t}\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read state file: %w\\\", err)\\n\\t}\\n\\n\\tvar state PrePromptState\\n\\tif err := json.Unmarshal(data, &state); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal state: %w\\\", err)\\n\\t}\\n\\n\\tstate.normalizePrePromptState()\\n\\n\\treturn &state, nil\\n}\\n\\n// CleanupPrePromptState removes the state file after use\\nfunc CleanupPrePromptState(ctx context.Context, sessionID string) error {\\n\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid session ID for pre-prompt state cleanup: %w\\\", err)\\n\\t}\\n\\n\\ttmpDirAbs := resolveTmpDir(ctx)\\n\\n\\troot, err := os.OpenRoot(tmpDirAbs)\\n\\tif err != nil {\\n\\t\\tif os.IsNotExist(err) {\\n\\t\\t\\treturn nil // Directory doesn't exist, nothing to clean up\\n\\t\\t}\\n\\t\\treturn fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n\\t}\\n\\tdefer root.Close()\\n\\n\\tfileName := fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID)\\n\\treturn osroot.Remove(root, fileName) //nolint:wrapcheck // best-effort cleanup, caller adds context via wrapping function name\\n}\\n\\n// FileChanges holds categorized file changes from git status.\\ntype FileChanges struct {\\n\\tModified []string // Modified or staged files\\n\\tNew      []string // Untracked files (filtered if previouslyUntracked provided)\\n\\tDeleted  []string // Deleted files (staged or unstaged)\\n}\\n\\n// DetectFileChanges returns categorized file changes from the current git status.\\n//\\n// previouslyUntracked controls new-file detection:\\n//   - nil: all untracked files go into New\\n//   - non-nil: only untracked files NOT in the pre-existing set go into New\\n//\\n// Modified includes both worktree and staging modified/added files.\\n// Deleted includes both staged and unstaged deletions.\\n// All results exclude .entire/ directory.\\nfunc DetectFileChanges(ctx context.Context, previouslyUntracked []string) (*FileChanges, error) {\\n\\trepo, err := openRepository(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\tworktree, err := repo.Worktree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n\\t}\\n\\n\\tstatus, err := worktree.Status()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n\\t}\\n\\n\\t// Build set of pre-existing untracked files for quick lookup\\n\\tvar preExisting map[string]bool\\n\\tif previouslyUntracked != nil {\\n\\t\\tpreExisting = make(map[string]bool, len(previouslyUntracked))\\n\\t\\tfor _, f := range previouslyUntracked {\\n\\t\\t\\tpreExisting[f] = true\\n\\t\\t}\\n\\t}\\n\\n\\tvar changes FileChanges\\n\\tfor file, st := range status {\\n\\t\\tif paths.IsInfrastructurePath(file) {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tswitch {\\n\\t\\tcase st.Worktree == git.Untracked:\\n\\t\\t\\tif preExisting != nil {\\n\\t\\t\\t\\tif !preExisting[file] {\\n\\t\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n\\t\\t\\t\\t}\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n\\t\\t\\t}\\n\\t\\tcase st.Worktree == git.Deleted || st.Staging == git.Deleted:\\n\\t\\t\\tchanges.Deleted = append(changes.Deleted, file)\\n\\t\\tcase st.Worktree == git.Modified || st.Staging == git.Modified ||\\n\\t\\t\\tst.Worktree == git.Added || st.Staging == git.Added:\\n\\t\\t\\tchanges.Modified = append(changes.Modified, file)\\n\\t\\t}\\n\\t}\\n\\n\\treturn &changes, nil\\n}\\n\\n// filterToUncommittedFiles removes files from the list that are already committed to HEAD\\n// with matching content. This prevents re-adding files that an agent committed mid-turn\\n// (already condensed by PostCommit) back to FilesTouched via SaveStep. Files not in\\n// HEAD or with different content in the working tree are kept. Fails open: if any git\\n// operation errors, returns the original list unchanged.\\nfunc filterToUncommittedFiles(ctx context.Context, files []string, repoRoot string) []string {\\n\\tif len(files) == 0 {\\n\\t\\treturn files\\n\\t}\\n\\n\\trepo, err := openRepository(ctx)\\n\\tif err != nil {\\n\\t\\treturn files // fail open\\n\\t}\\n\\n\\thead, err := repo.Head()\\n\\tif err != nil {\\n\\t\\treturn files // fail open (empty repo, detached HEAD, etc.)\\n\\t}\\n\\n\\tcommit, err := repo.CommitObject(head.Hash())\\n\\tif err != nil {\\n\\t\\treturn files // fail open\\n\\t}\\n\\n\\theadTree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn files // fail open\\n\\t}\\n\\n\\tvar result []string\\n\\tfor _, relPath := range files {\\n\\t\\theadFile, err := headTree.File(relPath)\\n\\t\\tif err != nil {\\n\\t\\t\\t// File not in HEAD — it's uncommitted\\n\\t\\t\\tresult = append(result, relPath)\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// File is in HEAD — compare content with working tree\\n\\t\\tabsPath := filepath.Join(repoRoot, relPath)\\n\\t\\tworkingContent, err := os.ReadFile(absPath) //nolint:gosec // path from controlled source\\n\\t\\tif err != nil {\\n\\t\\t\\t// Can't read working tree file (deleted?) — keep it\\n\\t\\t\\tresult = append(result, relPath)\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\theadContent, err := headFile.Contents()\\n\\t\\tif err != nil {\\n\\t\\t\\tresult = append(result, relPath)\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tif string(workingContent) != headContent {\\n\\t\\t\\t// Working tree differs from HEAD — uncommitted changes\\n\\t\\t\\tresult = append(result, relPath)\\n\\t\\t}\\n\\t\\t// else: content matches HEAD — already committed, skip\\n\\t}\\n\\n\\treturn result\\n}\\n\\n// FilterAndNormalizePaths converts absolute paths to relative and filters out\\n// infrastructure paths and paths outside the repo.\\nfunc FilterAndNormalizePaths(files []string, cwd string) []string {\\n\\tvar result []string\\n\\tfor _, file := range files {\\n\\t\\trelPath := paths.ToRelativePath(file, cwd)\\n\\t\\tif relPath == \\\"\\\" {\\n\\t\\t\\tcontinue // outside repo\\n\\t\\t}\\n\\t\\tif paths.IsInfrastructurePath(relPath) {\\n\\t\\t\\tcontinue // skip .entire directory\\n\\t\\t}\\n\\t\\tresult = append(result, relPath)\\n\\t}\\n\\treturn result\\n}\\n\\n// mergeUnique appends elements from extra into base, skipping duplicates already in base.\\nfunc mergeUnique(base, extra []string) []string {\\n\\tif len(extra) == 0 {\\n\\t\\treturn base\\n\\t}\\n\\tseen := make(map[string]bool, len(base))\\n\\tfor _, s := range base {\\n\\t\\tseen[s] = true\\n\\t}\\n\\tfor _, s := range extra {\\n\\t\\tif !seen[s] {\\n\\t\\t\\tseen[s] = true\\n\\t\\t\\tbase = append(base, s)\\n\\t\\t}\\n\\t}\\n\\treturn base\\n}\\n\\n// resolveTmpDir returns the absolute path to the .entire/tmp directory,\\n// falling back to a relative path if the repo root can't be determined.\\nfunc resolveTmpDir(ctx context.Context) string {\\n\\tabs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n\\tif err != nil {\\n\\t\\treturn paths.EntireTmpDir\\n\\t}\\n\\treturn abs\\n}\\n\\n// getUntrackedFilesForState returns a list of untracked files using go-git\\n// Excludes .entire directory\\nfunc getUntrackedFilesForState(ctx context.Context) ([]string, error) {\\n\\trepo, err := openRepository(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tworktree, err := repo.Worktree()\\n\\tif err != nil {\\n\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n\\t}\\n\\n\\tstatus, err := worktree.Status()\\n\\tif err != nil {\\n\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n\\t}\\n\\n\\tuntrackedFiles := []string{}\\n\\tfor file, st := range status {\\n\\t\\tif st.Worktree == git.Untracked {\\n\\t\\t\\t// Exclude .entire directory\\n\\t\\t\\tif !paths.IsInfrastructurePath(file) {\\n\\t\\t\\t\\tuntrackedFiles = append(untrackedFiles, file)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\treturn untrackedFiles, nil\\n}\\n\\n// PreTaskState stores the state captured before a task execution\\ntype PreTaskState struct {\\n\\tToolUseID      s