 {\\n   770→\\t// Get the commit and its tree\\n   771→\\tcommit, err := repo.CommitObject(commitHash)\\n   772→\\tif err != nil {\\n   773→\\t\\treturn \\\"\\\"\\n   774→\\t}\\n   775→\\n   776→\\ttree, err := commit.Tree()\\n   777→\\tif err != nil {\\n   778→\\t\\treturn \\\"\\\"\\n   779→\\t}\\n   780→\\n   781→\\t// Look for prompt.txt in the metadata directory\\n   782→\\tpromptPath := metadataDir + \\\"/\\\" + paths.PromptFileName\\n   783→\\tpromptEntry, err := tree.File(promptPath)\\n   784→\\tif err != nil {\\n   785→\\t\\treturn \\\"\\\"\\n   786→\\t}\\n   787→\\n   788→\\tcontent, err := promptEntry.Contents()\\n   789→\\tif err != nil {\\n   790→\\t\\treturn \\\"\\\"\\n   791→\\t}\\n   792→\\n   793→\\treturn ExtractFirstPrompt(content)\\n   794→}\\n   795→\\n   796→// SessionRestoreStatus represents the status of a session being restored.\\n   797→type SessionRestoreStatus int\\n   798→\\n   799→const (\\n   800→\\tStatusNew             SessionRestoreStatus = iota // Local file doesn't exist\\n   801→\\tStatusUnchanged                                   // Local and checkpoint are the same\\n   802→\\tStatusCheckpointNewer                             // Checkpoint has newer entries\\n   803→\\tStatusLocalNewer                                  // Local has newer entries (conflict)\\n   804→)\\n   805→\\n   806→// SessionRestoreInfo contains information about a session being restored.\\n   807→type SessionRestoreInfo struct {\\n   808→\\tSessionID      string\\n   809→\\tPrompt         string               // First prompt preview for display\\n   810→\\tStatus         SessionRestoreStatus // Status of this session\\n   811→\\tLocalTime      time.Time\\n   812→\\tCheckpointTime time.Time\\n   813→}\\n   814→\\n   815→// classifySessionsForRestore checks all sessions in a checkpoint and returns info\\n   816→// about each session, including whether local logs have newer timestamps.\\n   817→// repoRoot is used to compute per-session agent directories.\\n   