 string) ([]byte, error) {\\n    23→\\tf, err := root.Open(name)\\n    24→\\tif err != nil {\\n    25→\\t\\treturn nil, err //nolint:wrapcheck // preserve original error for os.IsNotExist checks\\n    26→\\t}\\n    27→\\tdefer f.Close()\\n    28→\\n    29→\\tdata, err := io.ReadAll(f)\\n    30→\\tif err != nil {\\n    31→\\t\\treturn nil, err //nolint:wrapcheck // preserve original error\\n    32→\\t}\\n    33→\\treturn data, nil\\n    34→}\\n    35→\\n    36→// WriteFile writes data to the named file relative to root using os.Root\\n    37→// for traversal-resistant access. Creates the file if it doesn't exist,\\n    38→// truncates it if it does. The kernel enforces that the write cannot escape\\n    39→// the root directory.\\n    40→func WriteFile(root *os.Root, name string, data []byte, perm os.FileMode) error {\\n    41→\\tf, err := root.OpenFile(name, os.O_WRONLY|os.O_CREATE|os.O_TRUNC, perm)\\n    42→\\tif err != nil {\\n    43→\\t\\treturn err //nolint:wrapcheck // preserve original error for os.IsNotExist checks\\n    44→\\t}\\n    45→\\tdefer f.Close()\\n    46→\\n    47→\\tif _, err := f.Write(data); err != nil {\\n    48→\\t\\treturn err //nolint:wrapcheck // preserve original error\\n    49→\\t}\\n    50→\\treturn nil\\n    51→}\\n    52→\\n    53→// Remove removes the named file relative to root using os.Root for\\n    54→// traversal-resistant access. Returns nil if the file doesn't exist.\\n    55→func Remove(root *os.Root, name string) error {\\n    56→\\terr := root.Remove(name)\\n    57→\\tif err != nil && !os.IsNotExist(err) {\\n    58→\\t\\treturn err //nolint:wrapcheck // preserve original error\\n    59→\\t}\\n    60→\\treturn nil\\n    61→}\\n    62→\"}]},\"uuid\":\"953e583e-f01c-4710-810c-0997cb8d3e6d\",\"timestamp\":\"2026-03-16T15:14:55.449Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a775565d39bf4ad54\"},\"toolUseID\":\"agent_msg_01U3hCNWmqYKGTQp6Hta99Lp\",\"parentToolUseID\":\"toolu_011mSAELc8qYYejp2ddC6iNr\",\"uuid\":\