ssionID string) error {\\n   202→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   203→\\t\\treturn fmt.Errorf(\\\"invalid session ID for pre-prompt state cleanup: %w\\\", err)\\n   204→\\t}\\n   205→\\n   206→\\ttmpDirAbs := resolveTmpDir(ctx)\\n   207→\\n   208→\\troot, err := os.OpenRoot(tmpDirAbs)\\n   209→\\tif err != nil {\\n   210→\\t\\tif os.IsNotExist(err) {\\n   211→\\t\\t\\treturn nil // Directory doesn't exist, nothing to clean up\\n   212→\\t\\t}\\n   213→\\t\\treturn fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   214→\\t}\\n   215→\\tdefer root.Close()\\n   216→\\n   217→\\tfileName := fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID)\\n   218→\\treturn osroot.Remove(root, fileName) //nolint:wrapcheck // best-effort cleanup, caller adds context via wrapping function name\\n   219→}\\n   220→\\n   221→// FileChanges holds categorized file changes from git status.\\n   222→type FileChanges struct {\\n   223→\\tModified []string // Modified or staged files\\n   224→\\tNew      []string // Untracked files (filtered if previouslyUntracked provided)\\n   225→\\tDeleted  []string // Deleted files (staged or unstaged)\\n   226→}\\n   227→\\n   228→// DetectFileChanges returns categorized file changes from the current git status.\\n   229→//\\n   230→// previouslyUntracked controls new-file detection:\\n   231→//   - nil: all untracked files go into New\\n   232→//   - non-nil: only untracked files NOT in the pre-existing set go into New\\n   233→//\\n   234→// Modified includes both worktree and staging modified/added files.\\n   235→// Deleted includes both staged and unstaged deletions.\\n   236→// All results exclude .entire/ directory.\\n   237→func DetectFileChanges(ctx context.Context, previouslyUntracked []string) (*FileChanges, error) {\\n   238→\\trepo, err := openRepository(ctx)\\n   239→\\tif err != nil {\\n   240→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   241→\\t}\\n   2