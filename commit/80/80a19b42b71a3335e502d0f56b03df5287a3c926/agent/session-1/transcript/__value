→}\\n    58→\\n    59→// AssertNewCommits polls until at least `atLeast` new commits exist since setup,\\n    60→// or fails after 10 seconds. Polling handles the race where an interactive\\n    61→// agent's prompt pattern appears before its git commit lands on disk.\\n    62→func AssertNewCommits(t *testing.T, s *RepoState, atLeast int) {\\n    63→\\tt.Helper()\\n    64→\\tdeadline := time.Now().Add(10 * time.Second)\\n    65→\\tfor {\\n    66→\\t\\tout := GitOutput(t, s.Dir, \\\"log\\\", \\\"--oneline\\\", s.HeadBefore+\\\"..HEAD\\\")\\n    67→\\t\\tvar lines []string\\n    68→\\t\\tif out != \\\"\\\" {\\n    69→\\t\\t\\tlines = strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\")\\n    70→\\t\\t}\\n    71→\\t\\tif len(lines) >= atLeast {\\n    72→\\t\\t\\treturn\\n    73→\\t\\t}\\n    74→\\t\\tif time.Now().After(deadline) {\\n    75→\\t\\t\\tt.Fatalf(\\\"expected at least %d new commit(s), got %d after 10s\\\", atLeast, len(lines))\\n    76→\\t\\t}\\n    77→\\t\\ttime.Sleep(500 * time.Millisecond)\\n    78→\\t}\\n    79→}\\n    80→\\n    81→// WaitForCheckpoint polls until the checkpoint branch advances from its\\n    82→// initial state, or fails the test after timeout. Use this before any\\n    83→// assertions that depend on the checkpoint branch (post-commit hook is async).\\n    84→func WaitForCheckpoint(t *testing.T, s *RepoState, timeout time.Duration) {\\n    85→\\tt.Helper()\\n    86→\\tdeadline := time.Now().Add(timeout)\\n    87→\\tfor time.Now().Before(deadline) {\\n    88→\\t\\tafter := GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n    89→\\t\\tif after != s.CheckpointBefore {\\n    90→\\t\\t\\treturn\\n    91→\\t\\t}\\n    92→\\t\\ttime.Sleep(200 * time.Millisecond)\\n    93→\\t}\\n    94→\\tt.Fatalf(\\\"checkpoint branch did not advance within %s\\\", timeout)\\n    95→}\\n    96→\\n    97→// AssertNoShadowBranches asserts that no shadow branches (entire/*) remain,\\n    98→// excluding entire/checkpoints/*. Shadow branches should be cleaned up after\\n    99→// commits condense session data to the metadata branch.\\n   100→func AssertNoShadowBranches(t *testing.T, dir string) {\\n   101→\\tt.Helper()\\n   102→\\tbranches := GitOutput(t, dir, \\\"for-each-ref\\\", \\\"--format=%(refname:short)\\\", \\\"refs/heads/entire/\\\")\\n   103→\\tvar shadow []string\\n   104→\\tfor _, b := range strings.Split(branches, \\\"\\\\n\\\") {\\n   105→\\t\\tb = strings.TrimSpace(b)\\n   106→\\t\\tif b == \\\"\\\" || strings.HasPrefix(b, \\\"entire/checkpoints\\\") {\\n   107→\\t\\t\\tcontinue\\n   108→\\t\\t}\\n   109→\\t\\tshadow = append(shadow, b)\\n   110→\\t}\\n   111→\\tassert.Empty(t, shadow,\\n   112→\\t\\t\\\"shadow branches should be cleaned up after commit, found: %v\\\", shadow)\\n   113→}\\n   114→\\n   115→// AssertCheckpointAdvanced asserts the checkpoint branch moved forward.\\n   116→func AssertCheckpointAdvanced(t *testing.T, s *RepoState) {\\n   117→\\tt.Helper()\\n   118→\\tafter := GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n   119→\\tassert.NotEqual(t, s.CheckpointBefore, after, \\\"checkpoint branch did not advance\\\")\\n   120→}\\n   121→\\n   122→// AssertCheckpointNotAdvanced asserts the checkpoint branch has NOT moved.\\n   123→func AssertCheckpointNotAdvanced(t *testing.T, s *RepoState) {\\n   124→\\tt.Helper()\\n   125→\\tafter := GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n   126→\\tassert.Equal(t, s.CheckpointBefore, after, \\\"checkpoint branch advanced unexpectedly\\\")\\n   127→}\\n   128→\\n   129→// AssertCheckpointIDFormat asserts the checkpoint ID is 12 lowercase hex chars.\\n   130→func AssertCheckpointIDFormat(t *testing.T, checkpointID string) {\\n   131→\\tt.Helper()\\n   132→\\tassert.Regexp(t, hexIDPattern, checkpointID,\\n   133→\\t\\t\\\"checkpoint ID %q should be 12 lowercase hex chars\\\", checkpointID)\\n   134→}\\n   135→\\n   136→// AssertHasCheckpointTrailer asserts the commit has an Entire-Checkpoint trailer,\\n   137→// validates its format, and returns its value.\\n   138→func AssertHasCheckpointTrailer(t *testing.T, dir string, ref string) string {\\n   139→\\tt.Helper()\\n   140→\\ttrailer := GetCheckpointTrailer(t, dir, ref)\\n   141→\\trequire.NotEmpty(t, trailer, \\\"no Entire-Checkpoint trailer on %s\\\", ref)\\n   142→\\tAssertCheckpointIDFormat(t, trailer)\\n   143→\\treturn trailer\\n   144→}\\n   145→\\n   146→// AssertCheckpointInLastN asserts the given checkpoint ID appears in the\\n   147→// last n commits on the checkpoint branch (e.g. initial + catchup).\\n   148→func AssertCheckpointInLastN(t *testing.T, dir string, checkpointID string, n int) {\\n   149→\\tt.Helper()\\n   150→\\tout := GitOutput(t, dir, \\\"log\\\", \\\"-n\\\", strconv.Itoa(n),\\n   151→\\t\\t\\\"--format=%s\\\", \\\"entire/checkpoints/v1\\\")\\n   152→\\tlines := strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\")\\n   153→\\trequire.Len(t, lines, n,\\n   154→\\t\\t\\\"expected %d commits on checkpoint branch, got %d\\\", n, len(lines))\\n   155→\\tfor i, line := range lines {\\n   156→\\t\\tassert.Contains(t, line, checkpointID,\\n   157→\\t\\t\\t\\\"checkpoint commit %d/%d does not mention %s: %s\\\", i+1, n, checkpointID, line)\\n   158→\\t}\\n   159→}\\n   160→\\n   161→// AssertCheckpointExists asserts that the checkpoint ID is mentioned on\\n   162→// the checkpoint branch and that its metadata.json exists in the tree.\\n   163→func AssertCheckpointExists(t *testing.T, dir string, checkpointID string) {\\n   164→\\tt.Helper()\\n   165→\\tout := GitOutput(t, dir, \\\"log\\\", \\\"entire/checkpoints/v1\\\", \\\"--grep=\\\"+checkpointID, \\\"--oneline\\\")\\n   166→\\tassert.NotEmpty(t, out, \\\"checkpoint %s not found on checkpoint branch\\\", checkpointID)\\n   167→\\n   168→\\tpath := CheckpointPath(checkpointID) + \\\"/metadata.json\\\"\\n   169→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   170→\\traw := gitOutputSafe(dir, \\\"show\\\", blob)\\n   171→\\tassert.NotEmpty(t, raw,\\n   172→\\t\\t\\\"checkpoint %s metadata not found at %s\\\", checkpointID, path)\\n   173→}\\n   174→\\n   175→// AssertCommitLinkedToCheckpoint asserts the trailer exists AND the\\n   176→// checkpoint data exists on the checkpoint branch.\\n   177→func AssertCommitLinkedToCheckpoint(t *testing.T, dir string, ref string) {\\n   178→\\tt.Helper()\\n   179→\\ttrailer := AssertHasCheckpointTrailer(t, dir, ref)\\n   180→\\tAssertCheckpointExists(t, dir, trailer)\\n   181→}\\n   182→\\n   183→// AssertCheckpointHasSingleSession asserts checkpoint metadata has exactly one session.\\n   184→func AssertCheckpointHasSingleSession(t *testing.T, dir string, checkpointID string) {\\n   185→\\tt.Helper()\\n   186→\\tmeta := ReadCheckpointMetadata(t, dir, checkpointID)\\n   187→\\tassert.Len(t, meta.Sessions, 1,\\n   188→\\t\\t\\\"expected 1 session in checkpoint %s, got %d\\\", checkpointID, len(meta.Sessions))\\n   189→}\\n   190→\\n   191→// AssertCheckpointMetadataComplete asserts essential fields in checkpoint metadata are populated.\\n   192→func AssertCheckpointMetadataComplete(t *testing.T, dir string, checkpointID string) {\\n   193→\\tt.Helper()\\n   194→\\tmeta := ReadCheckpointMetadata(t, dir, checkpointID)\\n   195→\\tassert.NotEmpty(t, meta.CLIVersion, \\\"checkpoint %s: cli_version should be set\\\", checkpointID)\\n   196→\\tassert.NotEmpty(t, meta.Strategy, \\\"checkpoint %s: strategy should be set\\\", checkpointID)\\n   197→\\tassert.NotEmpty(t, meta.Sessions, \\\"checkpoint %s: should have at least 1 session\\\", checkpointID)\\n   198→\\tassert.Equal(t, checkpointID, meta.CheckpointID,\\n   199→\\t\\t\\\"checkpoint metadata ID should match expected\\\")\\n   200→}\\n   201→\\n   202→// WaitForCheckpointAdvanceFrom polls until the checkpoint branch advances from\\n   203→// the given ref, or fails the test after timeout. Use this when waiting for a\\n   204→// second (or subsequent) checkpoint after recording the branch position.\\n   205→func WaitForCheckpointAdvanceFrom(t *testing.T, dir string, fromRef string, timeout time.Duration) {\\n   206→\\tt.Helper()\\n   207→\\tdeadline := time.Now().Add(timeout)\\n   208→\\tfor time.Now().Before(deadline) {\\n   209→\\t\\tafter := GitOutput(t, dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n   210→\\t\\tif after != fromRef {\\n   211→\\t\\t\\treturn\\n   212→\\t\\t}\\n   213→\\t\\ttime.Sleep(200 * time.Millisecond)\\n   214→\\t}\\n   215→\\tt.Fatalf(\\\"checkpoint branch did not advance from %s within %s\\\", fromRef[:8], timeout)\\n   216→}\\n   217→\\n   218→// AssertNoCheckpointTrailer asserts the commit does NOT have an Entire-Checkpoint trailer.\\n   219→func AssertNoCheckpointTrailer(t *testing.T, dir string, ref string) {\\n   220→\\tt.Helper()\\n   221→\\ttrailer := GetCheckpointTrailer(t, dir, ref)\\n   222→\\tassert.Empty(t, trailer, \\\"expected no Entire-Checkpoint trailer on %s, got %q\\\", ref, trailer)\\n   223→}\\n   224→\\n   225→// AssertCheckpointFilesTouched asserts the checkpoint metadata lists exactly\\n   226→// the expected files in files_touched (order-independent).\\n   227→func AssertCheckpointFilesTouched(t *testing.T, dir string, checkpointID string, expected []string) {\\n   228→\\tt.Helper()\\n   229→\\tmeta := ReadCheckpointMetadata(t, dir, checkpointID)\\n   230→\\tassert.ElementsMatch(t, expected, meta.FilesTouched,\\n   231→\\t\\t\\\"checkpoint %s: files_touched mismatch\\\", checkpointID)\\n   232→}\\n   233→\\n   234→// AssertCheckpointFilesTouchedContains asserts files_touched contains a\\n   235→// specific file path (subset check, unlike the exact-match AssertCheckpointFilesTouched).\\n   236→func AssertCheckpointFilesTouchedContains(t *testing.T, dir string, checkpointID string, file string) {\\n   237→\\tt.Helper()\\n   238→\\tmeta := ReadCheckpointMetadata(t, dir, checkpointID)\\n   239→\\tassert.Contains(t, meta.FilesTouched, file,\\n   240→\\t\\t\\\"checkpoint %s: files_touched should contain %s\\\", checkpointID, file)\\n   241→}\\n   242→\\n   243→// AssertDistinctSessions asserts session metadata across checkpoints has unique session IDs.\\n   244→func AssertDistinctSessions(t *testing.T, dir string, checkpointIDs []string) {\\n   245→\\tt.Helper()\\n   246→\\tseen := map[string]bool{}\\n   247→\\tfor _, cpID := range checkpointIDs {\\n   248→\\t\\tsm := ReadSessionMetadata(t, dir, cpID, 0)\\n   249→\\t\\tassert.False(t, seen[sm.SessionID],\\n   250→\\t\\t\\t\\\"duplicate session_id %s across checkpoints\\\", sm.SessionID)\\n   251→\\t\\tseen[sm.SessionID] = true\\n   252→\\t}\\n   253→}\\n   254→\\n   255→// ValidateCheckpointDeep performs comprehensive validation of checkpoint metadata\\n   256→// on the checkpoint branch, including transcript JSONL validity, content hash\\n   257→// verification, and prompt content checking.\\n   258→func ValidateCheckpointDeep(t *testing.T, dir string, v DeepCheckpointValidation) {\\n   259→\\tt.Helper()\\n   260→\\n   261→\\t// Basic metadata validation\\n   262→\\tAssertCheckpointExists(t, dir, v.CheckpointID)\\n   263→\\tAssertCheckpointMetadataComplete(t, dir, v.CheckpointID)\\n   264→\\n   265→\\tif v.Strategy != \\\"\\\" {\\n   266→\\t\\tmeta := ReadCheckpointMetadata(t, dir, v.CheckpointID)\\n   267→\\t\\tassert.Equal(t, v.Strategy, meta.Strategy,\\n   268→\\t\\t\\t\\\"checkpoint %s: strategy mismatch\\\", v.CheckpointID)\\n   269→\\t}\\n   270→\\n   271→\\tif len(v.FilesTouched) > 0 {\\n   272→\\t\\tAssertCheckpointFilesTouched(t, dir, v.CheckpointID, v.FilesTouched)\\n   273→\\t}\\n   274→\\n   275→\\tpath := CheckpointPath(v.CheckpointID)\\n   276→\\n   277→\\t// Validate session metadata exists and has checkpoint_id\\n   278→\\tsessionBlob := fmt.Sprintf(\\\"entire/checkpoints/v1:%s/0/metadata.json\\\", path)\\n   279→\\tsessionRaw := gitOutputSafe(dir, \\\"show\\\", sessionBlob)\\n   280→\\tif assert.NotEmpty(t, sessionRaw, \\\"session metadata should exist at %s\\\", sessionBlob) {\\n   281→\\t\\t