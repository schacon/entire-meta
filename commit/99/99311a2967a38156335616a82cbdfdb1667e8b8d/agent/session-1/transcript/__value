tegy, checkpoint, session, commands, hook_registry, lifecycle) which\\n    19→// would create brittle dependencies that break when internals change.\\n    20→//\\n    21→// Agents should depend only on:\\n    22→//   - The agent contract package (agent, agent/types, agent/testutil)\\n    23→//   - Utility packages (logging, paths, jsonutil, textutil, transcript, etc.)\\n    24→//   - Standard library and external dependencies\\n    25→func TestAgentPackages_NoForbiddenImports(t *testing.T) {\\n    26→\\tt.Parallel()\\n    27→\\n    28→\\tconst repoPrefix = \\\"github.com/entireio/cli/cmd/entire/cli/\\\"\\n    29→\\n    30→\\t// Packages that agent implementations must NOT import.\\n    31→\\t// These are framework internals that agents should be decoupled from.\\n    32→\\tforbiddenSuffixes := []string{\\n    33→\\t\\t\\\"strategy\\\",\\n    34→\\t\\t\\\"checkpoint\\\",\\n    35→\\t\\t\\\"session\\\",\\n    36→\\t\\t\\\"commands\\\",\\n    37→\\t}\\n    38→\\n    39→\\t// Individual files in the cli package that agents must not depend on.\\n    40→\\t// We check for the cli package import itself since these are all in\\n    41→\\t// the top-level cli package (not sub-packages).\\n    42→\\tforbiddenCLIPackage := repoPrefix[:len(repoPrefix)-1] // \\\"github.com/entireio/cli/cmd/entire/cli\\\"\\n    43→\\n    44→\\t// Packages within the repo that agents ARE allowed to import.\\n    45→\\tallowedPrefixes := []string{\\n    46→\\t\\trepoPrefix + \\\"agent\\\",      // agent contract + sub-packages\\n    47→\\t\\trepoPrefix + \\\"logging\\\",    // logging utilities\\n    48→\\t\\trepoPrefix + \\\"paths\\\",      // path utilities\\n    49→\\t\\trepoPrefix + \\\"jsonutil\\\",   // JSON utilities\\n    50→\\t\\trepoPrefix + \\\"textutil\\\",   // text utilities\\n    51→\\t\\trepoPrefix + \\\"transcript\\\", // transcript utilities\\n    52→\\t\\trepoPrefix + \\\"trailers\\\",   // git trailer utilities\\n    53→\\t\\trepoPrefix + \\\"stringutil\\\", // string utilities\\n    54→\\t\\trepoPrefix + \\\"telemetry\\\",  // telemetry\\n    55→\\t\\trepoPrefix + \\\"validation\\\", // validation utilities\\n    56→\\t\\trepoPrefix + \\\"settings\\\",   // settings (read-only access)\\n    57→\\t}\\n    58→\\n    59→\\tagentDir := findAgentDir(t)\\n    60→\\tagentPkgs := discoverAgentPackages(t, agentDir)\\n    61→\\n    62→\\tif len(agentPkgs) == 0 {\\n    63→\\t\\tt.Fatal(\\\"no agent packages found — test setup is broken\\\")\\n    64→\\t}\\n    65→\\n    66→\\tfor _, pkgDir := range agentPkgs {\\n    67→\\t\\tpkgName := filepath.Base(pkgDir)\\n    68→\\t\\tt.Run(pkgName, func(t *testing.T) {\\n    69→\\t\\t\\tt.Parallel()\\n    70→\\t\\t\\timports := extractImports(t, pkgDir)\\n    71→\\t\\t\\tfor _, imp := range imports {\\n    72→\\t\\t\\t\\tif !strings.HasPrefix(imp, repoPrefix) && imp != forbiddenCLIPackage {\\n    73→\\t\\t\\t\\t\\tcontinue // external or stdlib — allowed\\n    74→\\t\\t\\t\\t}\\n    75→\\n    76→\\t\\t\\t\\t// Check if it's the top-level cli package itself\\n    77→\\t\\t\\t\\tif imp == forbiddenCLIPackage {\\n    78→\\t\\t\\t\\t\\tt.Errorf(\\\"forbidden import %q — agent packages must not import the top-level cli package directly\\\", imp)\\n    79→\\t\\t\\t\\t\\tcontinue\\n    80→\\t\\t\\t\\t}\\n    81→\\n    82→\\t\\t\\t\\t// Check forbidden suffixes\\n    83→\\t\\t\\t\\trel := strings.TrimPrefix(imp, repoPrefix)\\n    84→\\t\\t\\t\\tisForbidden := false\\n    85→\\t\\t\\t\\tfor _, forbidden := range forbiddenSuffixes {\\n    86→\\t\\t\\t\\t\\tif rel == forbidden || strings.HasPrefix(rel, forbidden+\\\"/\\\") {\\n    87→\\t\\t\\t\\t\\t\\tt.Errorf(\\\"forbidden import %q — agent packages must not import %s internals\\\", imp, forbidden)\\n    88→\\t\\t\\t\\t\\t\\tisForbidden = true\\n    89→\\t\\t\\t\\t\\t}\\n    90→\\t\\t\\t\\t}\\n    91→\\t\\t\\t\\tif isForbidden {\\n    92→\\t\\t\\t\\t\\tcontinue\\n    93→\\t\\t\\t\\t}\\n    94→\\n    95→\\t\\t\\t\\t// Check it's in the allowed list\\n    96→\\t\\t\\t\\tallowed := false\\n    97→\\t\\t\\t\\tfor _, prefix := range allowedPrefixes {\\n    98→\\t\\t\\t\\t\\tif imp == prefix || strings.HasPrefix(imp, prefix+\\\"/\\\") {\\n    99→\\t\\t\\t\\t\\t\\tallowed = true\\n   100→\\t\\t\\t\\t\\t\\tbreak\\n   101→\\t\\t\\t\\t\\t}\\n   102→\\t\\t\\t\\t}\\n   103→\\t\\t\\t\\tif !allowed {\\n   104→\\t\\t\\t\\t\\tt.Errorf(\\\"unexpected internal import %q — if this is intentional, add it to allowedPrefixes in architecture_test.go\\\", imp)\\n   105→\\t\\t\\t\\t}\\n   106→\\t\\t\\t}\\n   107→\\t\\t})\\n   108→\\t}\\n   109→}\\n   110→\\n   111→// findAgentDir returns the absolute path to cmd/entire/cli/agent/.\\n   112→// Go test runner sets cwd to the package directory, so os.Getwd() gives us\\n   113→// the agent dir directly.\\n   114→func findAgentDir(t *testing.T) string {\\n   115→\\tt.Helper()\\n   116→\\twd, err := os.Getwd()\\n   117→\\tif err != nil {\\n   118→\\t\\tt.Fatalf(\\\"os.Getwd: %v\\\", err)\\n   119→\\t}\\n   120→\\treturn wd\\n   121→}\\n   122→\\n   123→// discoverAgentPackages finds all subdirectories of the agent dir that contain\\n   124→// Go files, excluding \\\"types\\\" and \\\"testutil\\\" (those are contract/shared packages).\\n   125→func discoverAgentPackages(t *testing.T, agentDir string) []string {\\n   126→\\tt.Helper()\\n   127→\\n   128→\\tskipDirs := map[string]bool{\\n   129→\\t\\t\\\"types\\\":    true, // contract types, not an agent implementation\\n   130→\\t\\t\\\"testutil\\\": true, // shared test utilities\\n   131→\\t\\t\\\"external\\\": true, // external agent adapter, not a self-registering agent\\n   132→\\t}\\n   133→\\n   134→\\tentries, err := os.ReadDir(agentDir)\\n   135→\\tif err != nil {\\n   136→\\t\\tt.Fatalf(\\\"ReadDir(%s): %v\\\", agentDir, err)\\n   137→\\t}\\n   138→\\n   139→\\tvar pkgs []string\\n   140→\\tfor _, e := range entries {\\n   141→\\t\\tif !e.IsDir() || skipDirs[e.Name()] {\\n   142→\\t\\t\\tcontinue\\n   143→\\t\\t}\\n   144→\\t\\tdir := filepath.Join(agentDir, e.Name())\\n   145→\\t\\t// Only include if it has Go files\\n   146→\\t\\tgoFiles, err := filepath.Glob(filepath.Join(dir, \\\"*.go\\\"))\\n   147→\\t\\tif err != nil {\\n   148→\\t\\t\\tt.Fatalf(\\\"filepath.Glob(%s): %v\\\", dir, err)\\n   149→\\t\\t}\\n   150→\\t\\tif len(goFiles) > 0 {\\n   151→\\t\\t\\tpkgs = append(pkgs, dir)\\n   152→\\t\\t}\\n   153→\\t}\\n   154→\\treturn pkgs\\n   155→}\\n   156→\\n   157→// extractImports parses all Go files in a directory and returns unique import paths.\\n   158→// Includes both production and test files — test-only imports should also respect boundaries.\\n   159→func extractImports(t *testing.T, dir string) []string {\\n   160→\\tt.Helper()\\n   161→\\n   162→\\tfset := token.NewFileSet()\\n   163→\\t//nolint:staticcheck // ParseDir is deprecated in favor of go/packages, but we intentionally\\n   164→\\t// scan all files regardless of build tags to catch forbidden imports in test files too.\\n   165→\\tpkgs, err := parser.ParseDir(fset, dir, nil, parser.ImportsOnly)\\n   166→\\tif err != nil {\\n   167→\\t\\tt.Fatalf(\\\"parser.ParseDir(%s): %v\\\", dir, err)\\n   168→\\t}\\n   169→\\n   170→\\tseen := make(map[string]bool)\\n   171→\\tfor _, pkg := range pkgs {\\n   172→\\t\\tfor _, file := range pkg.Files {\\n   173→\\t\\t\\tfor _, imp := range file.Imports {\\n   174→\\t\\t\\t\\tpath, err := strconv.Unquote(imp.Path.Value)\\n   175→\\t\\t\\t\\tif err != nil {\\n   176→\\t\\t\\t\\t\\tt.Fatalf(\\\"strconv.Unquote(%s): %v\\\", imp.Path.Value, err)\\n   177→\\t\\t\\t\\t}\\n   178→\\t\\t\\t\\tseen[path] = true\\n   179→\\t\\t\\t}\\n   180→\\t\\t}\\n   181→\\t}\\n   182→\\n   183→\\timports := make([]string, 0, len(seen))\\n   184→\\tfor imp := range seen {\\n   185→\\t\\timports = append(imports, imp)\\n   186→\\t}\\n   187→\\treturn imports\\n   188→}\\n   189→\\n   190→// TestAgentPackages_SelfRegister verifies that each agent package has an init()\\n   191→// function that calls agent.Register(). This ensures agents are properly\\n   192→// discoverable via the registry.\\n   193→func TestAgentPackages_SelfRegister(t *testing.T) {\\n   194→\\tt.Parallel()\\n   195→\\n   196→\\tagentDir := findAgentDir(t)\\n   197→\\tagentPkgs := discoverAgentPackages(t, agentDir)\\n   198→\\n   199→\\tif len(agentPkgs) == 0 {\\n   200→\\t\\tt.Fatal(\\\"no agent packages found — test setup is broken\\\")\\n   201→\\t}\\n   202→\\n   203→\\tfor _, pkgDir := range agentPkgs {\\n   204→\\t\\tpkgName := filepath.Base(pkgDir)\\n   205→\\t\\tt.Run(pkgName, func(t *testing.T) {\\n   206→\\t\\t\\tt.Parallel()\\n   207→\\t\\t\\tif !hasInitWithRegister(t, pkgDir) {\\n   208→\\t\\t\\t\\tt.Errorf(\\\"agent package %q has no init() function calling Register() — agents must self-register\\\", pkgName)\\n   209→\\t\\t\\t}\\n   210→\\t\\t})\\n   211→\\t}\\n   212→}\\n   213→\\n   214→// hasInitWithRegister checks if any Go file in the directory has an init()\\n   215→// function that contains a call to Register.\\n   216→func hasInitWithRegister(t *testing.T, dir string) bool {\\n   217→\\tt.Helper()\\n   218→\\n   219→\\tfset := token.NewFileSet()\\n   220→\\t//nolint:staticcheck // See extractImports for rationale.\\n   221→\\tpkgs, err := parser.ParseDir(fset, dir, func(fi os.FileInfo) bool {\\n   222→\\t\\treturn !strings.HasSuffix(fi.Name(), \\\"_test.go\\\")\\n   223→\\t}, 0)\\n   224→\\tif err != nil {\\n   225→\\t\\tt.Fatalf(\\\"parser.ParseDir(%s): %v\\\", dir, err)\\n   226→\\t}\\n   227→\\n   228→\\tfor _, pkg := range pkgs {\\n   229→\\t\\tfor _, file := range pkg.Files {\\n   230→\\t\\t\\tfor _, decl := range file.Decls {\\n   231→\\t\\t\\t\\tfn, ok := decl.(*ast.FuncDecl)\\n   232→\\t\\t\\t\\tif !ok || fn.Name.Name != \\\"init\\\" || fn.Recv != nil {\\n   233→\\t\\t\\t\\t\\tcontinue\\n   234→\\t\\t\\t\\t}\\n   235→\\t\\t\\t\\t// Walk the init body looking for a call to Register or agent.Register\\n   236→\\t\\t\\t\\tfound := false\\n   237→\\t\\t\\t\\tast.Inspect(fn.Body, func(n ast.Node) bool {\\n   238→\\t\\t\\t\\t\\tcall, ok := n.(*ast.CallExpr)\\n   239→\\t\\t\\t\\t\\tif !ok {\\n   240→\\t\\t\\t\\t\\t\\treturn true\\n   241→\\t\\t\\t\\t\\t}\\n   242→\\t\\t\\t\\t\\tswitch fun := call.Fun.(type) {\\n   243→\\t\\t\\t\\t\\tcase *ast.Ident:\\n   244→\\t\\t\\t\\t\\t\\tif fun.Name == \\\"Register\\\" {\\n   245→\\t\\t\\t\\t\\t\\t\\tfound = true\\n   246→\\t\\t\\t\\t\\t\\t}\\n   247→\\t\\t\\t\\t\\tcase *ast.SelectorExpr:\\n   248→\\t\\t\\t\\t\\t\\tif fun.Sel.Name == \\\"Register\\\" {\\n   249→\\t\\t\\t\\t\\t\\t\\tfound = true\\n   250→\\t\\t\\t\\t\\t\\t}\\n   251→\\t\\t\\t\\t\\t}\\n   252→\\t\\t\\t\\t\\treturn !found\\n   253→\\t\\t\\t\\t})\\n   254→\\t\\t\\t\\tif found {\\n   255→\\t\\t\\t\\t\\treturn true\\n   256→\\t\\t\\t\\t}\\n   257→\\t\\t\\t}\\n   258→\\t\\t}\\n   259→\\t}\\n   260→\\treturn false\\n   261→}\\n   262→\"}]},\"uuid\":\"6020040b-917c-405b-8117-a3b2de0e7aec\",\"timestamp\":\"2026-03-04T15:12:22.989Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a319bbab901d83ebe\"},\"toolUseID\":\"agent_msg_01S1ZHCUWmZb3vKXyFT2rwK9\",\"parentToolUseID\":\"toolu_01R1eaUCkwQYe7EeYZTcBJVM\",\"uuid\":\"46162538-b0b2-44cb-a9b6-95000aca448e\",\"timestamp\":\"2026-03-04T15:12:22.991Z\"}\n{\"parentUuid\":\"46162538-b0b2-44cb-a9b6-95000aca448e\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"c588621f-9b30-4c9e-85f2-af703ef8b7c3\",\"version\":\"2.1.68\",\"gitBranch\":\"nodo/external-plugins\",\"slug\":\"melodic-sniffing-sphinx\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-04T15:12:25.158Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_014PLKPseTVC98ZnsBKeGNXj\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01SxLdF4JnZngKSKNGobJpsc\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/nodo/work/cli/cmd/entire/cli/agent/registry.go\"},\"caller\":{\"type\":\"