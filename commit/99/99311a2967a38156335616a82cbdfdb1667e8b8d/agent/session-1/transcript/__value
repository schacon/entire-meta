les\\\"`\\n    88→\\tCurrentPosition int      `json:\\\"current_position\\\"`\\n    89→}\\n    90→\\n    91→// ExtractPromptsResponse is the JSON returned by the \\\"extract-prompts\\\" subcommand.\\n    92→type ExtractPromptsResponse struct {\\n    93→\\tPrompts []string `json:\\\"prompts\\\"`\\n    94→}\\n    95→\\n    96→// ExtractSummaryResponse is the JSON returned by the \\\"extract-summary\\\" subcommand.\\n    97→type ExtractSummaryResponse struct {\\n    98→\\tSummary    string `json:\\\"summary\\\"`\\n    99→\\tHasSummary bool   `json:\\\"has_summary\\\"`\\n   100→}\\n   101→\\n   102→// TokenUsageResponse is the JSON returned by token calculation subcommands.\\n   103→type TokenUsageResponse struct {\\n   104→\\tInputTokens         int                 `json:\\\"input_tokens\\\"`\\n   105→\\tCacheCreationTokens int                 `json:\\\"cache_creation_tokens\\\"`\\n   106→\\tCacheReadTokens     int                 `json:\\\"cache_read_tokens\\\"`\\n   107→\\tOutputTokens        int                 `json:\\\"output_tokens\\\"`\\n   108→\\tAPICallCount        int                 `json:\\\"api_call_count\\\"`\\n   109→\\tSubagentTokens      *TokenUsageResponse `json:\\\"subagent_tokens,omitempty\\\"`\\n   110→}\\n   111→\\n   112→// GenerateTextResponse is the JSON returned by the \\\"generate-text\\\" subcommand.\\n   113→type GenerateTextResponse struct {\\n   114→\\tText string `json:\\\"text\\\"`\\n   115→}\\n   116→\\n   117→// AgentSessionJSON is the JSON representation of agent.AgentSession for stdin/stdout transfer.\\n   118→type AgentSessionJSON struct {\\n   119→\\tSessionID     string   `json:\\\"session_id\\\"`\\n   120→\\tAgentName     string   `json:\\\"agent_name\\\"`\\n   121→\\tRepoPath      string   `json:\\\"repo_path\\\"`\\n   122→\\tSessionRef    string   `json:\\\"session_ref\\\"`\\n   123→\\tStartTime     string   `json:\\\"start_time\\\"`\\n   124→\\tNativeData    []byte   `json:\\\"native_data\\\"`\\n   125→\\tModifiedFiles []stri