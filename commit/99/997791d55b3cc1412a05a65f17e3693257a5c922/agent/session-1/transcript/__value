\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"encoding/json\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"log/slog\\\"\\n     8→\\t\\\"os\\\"\\n     9→\\t\\\"os/exec\\\"\\n    10→\\t\\\"path/filepath\\\"\\n    11→\\t\\\"strings\\\"\\n    12→\\t\\\"sync\\\"\\n    13→\\t\\\"time\\\"\\n    14→\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    21→)\\n    22→\\n    23→const (\\n    24→\\t// SessionStateDirName is the directory name for session state files within git common dir.\\n    25→\\tSessionStateDirName = \\\"entire-sessions\\\"\\n    26→\\n    27→\\t// StaleSessionThreshold is the duration after which an ended session is considered stale\\n    28→\\t// and will be automatically deleted during load/list operations.\\n    29→\\tStaleSessionThreshold = 7 * 24 * time.Hour\\n    30→)\\n    31→\\n    32→// State represents the state of an active session.\\n    33→// This is stored in .git/entire-sessions/<session-id>.json\\n    34→type State struct {\\n    35→\\t// SessionID is the unique session identifier\\n    36→\\tSessionID string `json:\\\"session_id\\\"`\\n    37→\\n    38→\\t// CLIVersion is the version of the CLI that created this session\\n    39→\\tCLIVersion string `json:\\\"cli_version,omitempty\\\"`\\n    40→\\n    41→\\t// BaseCommit tracks the current shadow branch base. Initially set to HEAD when the\\n    42→\\t// session starts, but updated on migration (pull/rebase) and after condensation.\\n    43→\\t// Used for shadow branch naming and checkpoint storage — NOT for attribution.\\n    44→\\tBaseCommit string `json:\\\"base_commit\\\"`\\n    45→\\n    46→\\t// AttributionBaseCommit is the commit used as the reference point for attribution calculations.\\n    47→\\t// Unlike BaseCommit (which tracks the shadow branch and moves with migration), this field\\n    48→\\t// preserves the original base commit so deferred condensation can correctly calculate\\n    49→\\t// agent vs human line attribution. Updated only after successful condensation.\\n    50→\\tAttributionBaseCommit string `json:\\\"attribution_base_commit,omitempty\\\"`\\n    51→\\n    52→\\t// WorktreePath is the absolute path to the worktree root\\n    53→\\tWorktreePath string `json:\\\"worktree_path,omitempty\\\"`\\n    54→\\n    55→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n    56→\\t// Derived from .git/worktrees/<name>/, stable across git worktree move\\n    57→\\tWorktreeID string `json:\\\"worktree_id,omitempty\\\"`\\n    58→\\n    59→\\t// StartedAt is when the session was started\\n    60→\\tStartedAt time.Time `json:\\\"started_at\\\"`\\n    61→\\n    62→\\t// EndedAt is when the session was explicitly closed by the user.\\n    63→\\t// nil means the session is still active or was not cleanly closed.\\n    64→\\tEndedAt *time.Time `json:\\\"ended_at,omitempty\\\"`\\n    65→\\n    66→\\t// Phase is the lifecycle stage of this session (see phase.go).\\n    67→\\t// Empty means idle (backward compat with pre-state-machine files).\\n    68→\\tPhase Phase `json:\\\"phase,omitempty\\\"`\\n    69→\\n    70→\\t// TurnID is a unique identifier for the current agent turn.\\n    71→\\t// Lifecycle:\\n    72→\\t//   - Generated fresh in InitializeSession at each turn start\\n    73→\\t//   - Shared across all checkpoints within the same turn\\n    74→\\t//   - Used to correlate related checkpoints when a turn's work spans multiple commits\\n    75→\\t//   - Persists until the next InitializeSession call generates a new one\\n    76→\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n    77→\\n    78→\\t// TurnCheckpointIDs tracks all checkpoint IDs condensed during the current turn.\\n    79→\\t// Lifecycle:\\n    80→\\t//   - Set in PostCommit when a checkpoint is condensed for an ACTIVE session\\n    81→\\t//   - Consumed in HandleTurnEnd to finalize all checkpoints with the full transcript\\n    82→\\t//   - Cleared in HandleTurnEnd after finalization completes\\n    83→\\t//   - Cleared in InitializeSession when a new prompt starts\\n    84→\\t//   - Cleared when session is reset (ResetSession deletes the state file entirely)\\n    85→\\tTurnCheckpointIDs []string `json:\\\"turn_checkpoint_ids,omitempty\\\"`\\n    86→\\n    87→\\t// LastInteractionTime is updated on agent-interaction events (TurnStart,\\n    88→\\t// TurnEnd, SessionStop, Compaction) but NOT on git commit hooks.\\n    89→\\t// Used for stale session detection in \\\"entire doctor\\\".\\n    90→\\tLastInteractionTime *time.Time `json:\\\"last_interaction_time,omitempty\\\"`\\n    91→\\n    92→\\t// StepCount is the number of checkpoints/steps created in this session.\\n    93→\\t// JSON tag kept as \\\"checkpoint_count\\\" for backward compatibility with existing state files.\\n    94→\\tStepCount int `json:\\\"checkpoint_count\\\"`\\n    95→\\n    96→\\t// CheckpointTranscriptStart is the transcript line offset where the current\\n    97→\\t// checkpoint cycle began. Set to 0 at session start, updated to current\\n    98→\\t// transcript length after each condensation. Used to scope the transcript\\n    99→\\t// for checkpoint condensation: \\\"everything since last checkpoint\\\".\\n   100→\\tCheckpointTranscriptStart int `json:\\\"checkpoint_transcript_start,omitempty\\\"`\\n   101→\\n   102→\\t// Deprecated: CondensedTranscriptLines is replaced by CheckpointTranscriptStart.\\n   103→\\t// Kept for backward compatibility with existing state files.\\n   104→\\t// Use NormalizeAfterLoad() to migrate.\\n   105→\\tCondensedTranscriptLines int `json:\\\"condensed_transcript_lines,omitempty\\\"`\\n   106→\\n   107→\\t// UntrackedFilesAtStart tracks files that existed at session start (to preserve during rewind)\\n   108→\\tUntrackedFilesAtStart []string `json:\\\"untracked_files_at_start,omitempty\\\"`\\n   109→\\n   110→\\t// FilesTouched tracks files modified/created/deleted during this session\\n   111→\\tFilesTouched []string `json:\\\"files_touched,omitempty\\\"`\\n   112→\\n   113→\\t// LastCheckpointID is the checkpoint ID from the most recent condensation.\\n   114→\\t// Used to restore the Entire-Checkpoint trailer on amend and to identify\\n   115→\\t// sessions that have been condensed at least once. Cleared on new prompt.\\n   116→\\tLastCheckpointID id.CheckpointID `json:\\\"last_checkpoint_id,omitempty\\\"`\\n   117→\\n   118→\\t// FullyCondensed indicates this session has been condensed and has no remaining\\n   119→\\t// carry-forward files. PostCommit skips fully-condensed sessions entirely.\\n   120→\\t// Set after successful condensation when no files remain for carry-forward\\n   121→\\t// and the session phase is ENDED. Cleared on session reactivation (ENDED →\\n   122→\\t// ACTIVE via TurnStart, or ENDED → IDLE via SessionStart) by ActionClearEndedAt.\\n   123→\\tFullyCondensed bool `json:\\\"fully_condensed,omitempty\\\"`\\n   124→\\n   125→\\t// AgentType identifies the agent that created this session (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\", \\\"Cursor\\\")\\n   126→\\tAgentType types.AgentType `json:\\\"agent_type,omitempty\\\"`\\n   127→\\n   128→\\t// ModelName is the LLM model used in this session (e.g., \\\"claude-sonnet-4-20250514\\\", \\\"gpt-4o\\\").\\n   129→\\t// Set from hook data when the agent provides it.\\n   130→\\tModelName string `json:\\\"model_name,omitempty\\\"`\\n   131→\\n   132→\\t// Token usage tracking (accumulated across all checkpoints in this session)\\n   133→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   134→\\n   135→\\t// Hook-provided session metrics (for agents like Cursor that report via hooks)\\n   136→\\tSessionDurationMs int64 `json:\\\"session_duration_ms,omitempty\\\"`\\n   137→\\tSessionTurnCount  int   `json:\\\"session_turn_count,omitempty\\\"`\\n   138→\\tContextTokens     int   `json:\\\"context_tokens,omitempty\\\"`\\n   139→\\tContextWindowSize int   `json:\\\"context_window_size,omitempty\\\"`\\n   140→\\n   141→\\t// Deprecated: TranscriptLinesAtStart is replaced by CheckpointTranscriptStart.\\n   142→\\t// Kept for backward compatibility with existing state files.\\n   143→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   144→\\n   145→\\t// TranscriptIdentifierAtStart is the last transcript identifier when the session started.\\n   146→\\t// Used for identifier-based transcript scoping (UUID for Claude, message ID for Gemini).\\n   147→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"`\\n   148→\\n   149→\\t// TranscriptPath is the path to the live transcript file (for mid-session commit detection)\\n   150→\\tTranscriptPath string `json:\\\"transcript_path,omitempty\\\"`\\n   151→\\n   152→\\t// LastPrompt is the most recent user prompt for this session (truncated for display).\\n   153→\\t// Updated on every turn start (UserPromptSubmit). JSON tag kept as \\\"first_prompt\\\"\\n   154→\\t// for backward compatibility with existing state files.\\n   155→\\tLastPrompt string `json:\\\"last_prompt,omitempty\\\"`\\n   156→\\n   157→\\t// PromptAttributions tracks user and agent line changes at each prompt start.\\n   158→\\t// This enables accurate attribution by capturing user edits between checkpoints.\\n   159→\\tPromptAttributions []PromptAttribution `json:\\\"prompt_attributions,omitempty\\\"`\\n   160→\\n   161→\\t// PendingPromptAttribution holds attribution calculated at prompt start (before agent runs).\\n   162→\\t// This is moved to PromptAttributions when SaveStep is called.\\n   163→\\tPendingPromptAttribution *PromptAttribution `json:\\\"pending_prompt_attribution,omitempty\\\"`\\n   164→}\\n   165→\\n   166→// PromptAttribution captures line-level attribution data at the start of each prompt.\\n   167→// By recording what changed since the last checkpoint BEFORE the agent works,\\n   168→// we can accurately separate user edits from agent contributions.\\n   169→type PromptAttribution struct {\\n   170→\\t// CheckpointNumber is which checkpoint this was recorded before (1-indexed)\\n   171→\\tCheckpointNumber int `json:\\\"checkpoint_number\\\"`\\n   172→\\n   173→\\t// UserLinesAdded is lines added by user since the last checkpoint\\n   174→\\tUserLinesAdded int `json:\\\"user_lines_added\\\"`\\n   175→\\n   176→\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   177→\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   178→\\n   179→\\t// AgentLinesAdded is total agent lines added so far (base → last checkpoint).\\n   180→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   181→\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   182→\\n   183→\\t// AgentLinesRemoved is total agent lines removed so far (base → last checkpoint).\\n   184→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   185→\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   186→\\n   187→\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   188→\\t// This enables distinguishing user self-modifications from agent modifications.\\n   189→\\t// See docs/architecture/attribution.md for details.\\n   190→\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   191→}\\n   192→\\n   193→// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   194→// Call this after deserializing a State from JSON.\\n   195→func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   196→\\t// Normalize legacy phase values. \\\"active_committed\\\" was removed with the\\n   197→\\t// 1:1 checkpoint model in favor of the state machine handling commits\\n   198→\\t// during ACTIVE phase with immediate condensation.\\n   199→\\tif s.Phase == \\\"active_committed\\\" {\\n   200→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   201→\\t\\tlogging.Info(logCtx, \\\"migrating legacy active_committed phase to active\\\",\\n   202→\\t\\t\\tslog.String(\\\"session_id\\\", s.SessionID),\\n   203→\\t\\t)\\n   204→\\t\\ts.Phase = PhaseActive\\n   205→\\t}\\n   206→\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n   207→\\ts.Phase = PhaseFromString(string(s.Phase))\\n   208→\\n   209→\\t// Migrate transcript fields: CheckpointTranscriptStart replaces both\\n   210→\\t// CondensedTranscriptLines and TranscriptLinesAtStart from older state files.\\n   211→\\tif s.CheckpointTranscriptStart == 0 {\\n   212→\\t\\tif s.CondensedTranscriptLines > 0 {\\n   213→\\t\\t\\ts.CheckpointTranscriptStart = s.CondensedTranscriptLines\\n   214→\\t\\t} else if s.TranscriptLinesAtStart > 0 {\\n   215→\\t\\t\\ts.CheckpointTranscriptStart = s.TranscriptLinesAtStart\\n   216→\\t\\t}\\n   217→\\t}\\n   218→\\t// Clear deprecated fields so they aren't re-persisted.\\n   219→\\t// Note: this is a one-way migration. If the state is re-saved, older CLI versions\\n   220→\\t// will see 0 for these fields and fall back to scoping from the transcript start.\\n   221→\\t// This is acceptable since CLI upgrades are monotonic and the worst case is\\n   222→\\t// redundant transcript content in a condensation, not data loss.\\n   223→\\ts.CondensedTranscriptLines = 0\\n   224→\\ts.TranscriptLinesAtStart = 0\\n   225→\\n   226→\\t// Backfill AttributionBaseCommit for sessions created before this field existed.\\n   227→\\t// Without this, a mid-turn commit would migrate BaseCommit and the fallback in\\n   228→\\t// calculateSessionAttributions would use the migrated value, producing zero attribution.\\n   229→\\tif s.AttributionBaseCommit == \\\"\\\" && s.BaseCommit != \\\"\\\" {\\n   230→\\t\\ts.AttributionBaseCommit = s.BaseCommit\\n   231→\\t}\\n   232→}\\n   233→\\n   234→// IsStale returns true when a session hasn't seen interaction for longer than\\n   235→// StaleSessionThreshold. Falls back to StartedAt when LastInteractionTime is\\n   236→// nil (sessions created before interaction tracking was added).\\n   237→func (s *State) IsStale() bool {\\n   238→\\tvar since time.Duration\\n   239→\\tif s.LastInteractionTime != nil {\\n   240→\\t\\tsince = time.Since(*s.LastInteractionTime)\\n   241→\\t} else {\\n   242→\\t\\tsince = time.Since(s.StartedAt)\\n   243→\\t}\\n   244→\\treturn since > StaleSessionThreshold\\n   245→}\\n   246→\\n   247→// StateStore provides low-level operations for managing session state files.\\n   248→//\\n   249→// StateStore is a primitive for session state persistence. It is NOT the same as\\n   250→// the Sessions interface - it only handles state files in .git/entire-sessions/,\\n   251→// not the full session data which includes checkpoint content.\\n   252→//\\n   253→// Use StateStore directly in strategies for performance-critical state operations.\\n   254→// Use the Sessions interface (when implemented) for high-level session management.\\n   255→type StateStore struct {\\n   256→\\t// stateDir is the directory where session state files are stored\\n   257→\\tstateDir string\\n   258→}\\n   259→\\n   260→// NewStateStore creates a new state store.\\n   261→// Uses the git common dir to store session state (shared across worktrees).\\n   262→func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   263→\\tcommonDir, err := getGitCommonDir(ctx)\\n   264→\\tif err != nil {\\n   265→\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   266→\\t}\\n   267→\\treturn &StateStore{\\n   268→\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   269→\\t}, nil\\n   270→}\\n   271→\\n   272→// NewStateStoreWithDir creates a new state store with a custom directory.\\n   273→// This is useful for testing.\\n   274→func NewStateStoreWithDir(stateDir string) *StateStore {\\n   275→\\treturn &StateStore{stateDir: stateDir}\\n   276→}\\n   277→\\n   278→// Load loads the session state for the given session ID.\\n   279→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   280→// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   281→func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   282→\\t// Validate session ID to prevent path traversal\\n   283→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   284→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   285→\\t}\\n   286→\\n   287→\\tstateFile := s.stateFilePath(sessionID)\\n   288→\\n   289→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is derived from sessionID\\n   290→\\tif os.IsNotExist(err) {\\n   291→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   292→\\t}\\n   293→\\tif err != nil {\\n   294→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   295→\\t}\\n   296→\\n   297→\\tvar state State\\n   298→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   299→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal session state: %w\\\", err)\\n   300→\\t}\\n   301→\\tstate.NormalizeAfterLoad(ctx)\\n   302→\\n   303→\\tif state.IsStale() {\\n   304→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   305→\\t\\tlogging.Debug(logCtx, \\\"deleting stale session state\\\",\\n   306→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   307→\\t\\t)\\n   308→\\t\\t_ = s.Clear(ctx, sessionID) //nolint:errcheck // best-effort cleanup of stale session\\n   309→\\t\\treturn nil, nil             //nolint:nilnil // stale session treated as not found\\n   310→\\t}\\n   311→\\n   312→\\treturn &state, nil\\n   313→}\\n   314→\\n   315→// Save saves the session state atomically.\\n   316→func (s *StateStore) Save(ctx context.Context, state *State) error {\\n   317→\\t_ = ctx // Reserved for future use\\n   318→\\n   319→\\t// Validate session ID to prevent path traversal\\n   320→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n   321→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   322→\\t}\\n   323→\\n   324→\\tif err := os.MkdirAll(s.stateDir, 0o750); err != nil {\\n   325→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   326→\\t}\\n   327→\\n   328→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   329→\\tif err != nil {\\n   330→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   331→\\t}\\n   332→\\n   333→\\tstateFile := s.stateFilePath(state.SessionID)\\n   334→\\n   335→\\t// Atomic write: write to temp file, then rename\\n   336→\\ttmpFile := stateFile + \\\".tmp\\\"\\n   337→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n   338→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   339→\\t}\\n   340→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n   341→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n   342→\\t}\\n   343→\\treturn nil\\n   344→}\\n   345→\\n   346→// Clear removes the session state file for the given session ID.\\n   347→func (s *StateStore) Clear(ctx context.Context, sessionID string) error {\\n   348→\\t_ = ctx // Reserved for future use\\n   349→\\n   350→\\t// Validate session ID to prevent path traversal\\n   351→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   352→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   353→\\t}\\n   354→\\n   355→\\t// Remove all files for this session (state .json, .model hint, any future hint files).\\n   356→\\tmatches, _ := filepath.Glob(filepath.Join(s.stateDir, sessionID+\\\".*\\\")) //nolint:errcheck // pattern is always valid\\n   357→\\tfor _, f := range matches {\\n   358→\\t\\t_ = os.Remove(f)\\n   359→\\t}\\n   360→\\n   361→\\treturn nil\\n   362→}\\n   363→\\n   364→// RemoveAll removes the entire session state directory.\\n   365→// This is used during uninstall to completely remove all session state.\\n   366→func (s *StateStore) RemoveAll() error {\\n   367→\\tif err := os.RemoveAll(s.stateDir); err != nil {\\n   368→\\t\\treturn fmt.Errorf(\\\"failed to remove session state directory: %w\\\", err)\\n   369→\\t}\\n   370→\\treturn nil\\n   371→}\\n   372→\\n   373→// List returns all session states.\\n   374→func (s *StateStore) List(ctx context.Context) ([]*State, error) {\\n   375→\\tentries, err := os.ReadDir(s.stateDir)\\n   376→\\tif os.IsNotExist(err) {\\n   377→\\t\\treturn nil, nil\\n   378→\\t}\\n   379→\\tif err != nil {\\n   380→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state directory: %w\\\", err)\\n   381→\\t}\\n   382→\\n   383→\\tvar states []*State\\n   384→\\tfor _, entry := range entries {\\n   385→\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   386→\\t\\t\\tcontinue\\n   387→\\t\\t}\\n   388→\\t\\tif strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   389→\\t\\t\\tcontinue // Skip temp files\\n   390→\\t\\t}\\n   391→\\n   392→\\t\\tsessionID := strings.TrimSuffix(entry.Name(), \\\".json\\\")\\n   393→\\t\\tstate, err := s.Load(ctx, sessionID)\\n   394→\\t\\tif err != nil {\\n   395→\\t\\t\\tcontinue // Skip corrupted state files\\n   396→\\t\\t}\\n   397→\\t\\tif state == nil {\\n   398→\\t\\t\\tcontinue // Not found or stale (Load handles cleanup)\\n   399→\\t\\t}\\n   400→\\n   401→\\t\\tstates = append(states, state)\\n   402→\\t}\\n   403→\\treturn states, nil\\n   404→}\\n   405→\\n   406→// stateFilePath returns the path to a session state file.\\n   407→func (s *StateStore) stateFilePath(sessionID string) string {\\n   408→\\treturn filepath.Join(s.stateDir, sessionID+\\\".json\\\")\\n   409→}\\n   410→\\n   411→// gitCommonDirCache caches the git common dir to avoid repeated subprocess calls.\\n   412→// Keyed by working directory to handle directory changes (same pattern as paths.WorktreeRoot).\\n   413→var (\\n   414→\\tgitCommonDirMu       sync.RWMutex\\n   415→\\tgitCommonDirCache    string\\n   416→\\tgitCommonDirCacheDir string\\n   417→)\\n   418→\\n   419→// ClearGitCommonDirCache clears the cached git common dir.\\n   420→// Useful for testing when changing directories.\\n   421→func ClearGitCommonDirCache() {\\n   422→\\tgitCommonDirMu.Lock()\\n   423→\\tgitCommonDirCache = \\\"\\\"\\n   424→\\tgitCommonDirCacheDir = \\\"\\\"\\n   425→\\tgitCommonDirMu.Unlock()\\n   426→}\\n   427→\\n   428→// getGitCommonDir returns the path to the shared git directory.\\n   429→// In a regular checkout, this is .git/\\n   430→// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n   431→// The result is cached per working directory.\\n   432→func getGitCommonDir(ctx context.Context) (string, error) {\\n   433→\\tcwd, err := os.Getwd() //nolint:forbidigo // used for cache key, not git-relative paths\\n   434→\\tif err != nil {\\n   435→\\t\\tcwd = \\\"\\\"\\n   436→\\t}\\n   437→\\n   438→\\t// Check cache with read lock first\\n   439→\\tgitCommonDirMu.RLock()\\n   440→\\tif gitCommonDirCache != \\\"\\\" && gitCommonDirCacheDir == cwd {\\n   441→\\t\\tcached := gitCommonDirCache\\n   442→\\t\\tgitCommonDirMu.RUnlock()\\n   443→\\t\\treturn cached, nil\\n   444→\\t}\\n   445→\\tgitCommonDirMu.RUnlock()\\n   446→\\n   447→\\t// Cache miss — resolve via git subprocess\\n   448→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-common-dir\\\")\\n   449→\\tcmd.Dir = \\\".\\\"\\n   450→\\toutput, err := cmd.Output()\\n   451→\\tif err != nil {\\n   452→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   453→\\t}\\n   454→\\n   455→\\tcommonDir := strings.TrimSpace(string(output))\\n   456→\\n   457→\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\n   458→\\t// so we need to make it absolute if it isn't already\\n   459→\\tif !filepath.IsAbs(commonDir) {\\n   460→\\t\\tcommonDir = filepath.Join(\\\".\\\", commonDir)\\n   461→\\t}\\n   462→\\tcommonDir = filepath.Clean(commonDir)\\n   463→\\n   464→\\tgitCommonDirMu.Lock()\\n   465→\\tgitCommonDirCache = commonDir\\n   466→\\tgitCommonDirCacheDir = cwd\\n   467→\\tgitCommonDirMu.Unlock()\\n   468→\\n   469→\\treturn commonDir, nil\\n   470→}\\n   471→\"}]},\"uuid\":\"026d3e8c-4638-4371-9944-f19aa13052ba\",\"timestamp\":\"2026-03-11T09:38:00.347Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a8780a4069e5bf1c7\"},\"toolUseID\":\"agent_msg_015PHRLxyNP4Xu2ckg5gyn6F\",\"parentToolUseID\":\"toolu_01FCN86GanHciyze74dBbwHR\",\"uuid\":\"bd0daa4f-decd-4325-a168-c0cc335fe363\",\"timestamp\":\"2026-03-11T09:38:00.368Z\"}\n{\"parentUuid\":\"bd0daa4f-decd-4325-a168-c0cc335fe363\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli_worktree1\",\"sessionId\":\"48eed839-7047-483a-bdd8-9daf242c6427\",\"version\":\"2.1.72\",\"gitBranch\":\"soph/improve-enable\",\"slug\":\"precious-greeting-spring\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-11T09:38:00.926Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_014e6kNQ4qFbRJqey3wnPzXg\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_012pJw64zPrAa23HYHmeZJL3\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/soph/Work/entire/devenv/cli_worktree1/cmd/entire/cli/session/phase.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":7,\"cache_creation_input_tokens\":2248,\"cache_read_input_tokens\":23191,\"cache_creation\":{\"ephemeral_5m_input_tokens\":2248,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYw4wWbNNQkqcALhtQVKo\",\"uuid\":\"95f9951d-3421-430d-bd4b-a99a5a623b5e\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a8780a4069e5bf1c7\"},\"toolUseID\":\"agent_msg_015PHRLxyNP4Xu2ckg5gyn6F\",\"parentToolUseID\":\"toolu_01FCN86GanHciyze74dBbwHR\",\"uuid\":\"ca8cde88-893b-4017-a9f3-40f449ce8b1d\",\"timestamp\":\"2026-03-11T09:38:00.927Z\"}\n{\"parentUuid\":\"ca8cde88-893b-4017-a9f3-40f449ce8b1d\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli_worktree1\",\"sessionId\":\"48eed839-7047-483a-bdd8-9daf242c6427\",\"version\":\"2.1.72\",\"gitBranch\":\"soph/improve-enable\",\"slug\":\"precious-greeting-spring\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_012pJw64zPrAa23HYHmeZJL3\",\"type\":\"tool_result\",\"content\":\"     1→//go:generate go run gen_state_diagram.go\\n     2→\\n     3→package session\\n     4→\\n     5→import (\\n     6→\\t\\\"context\\\"\\n     7→\\t\\\"fmt\\\"\\n     8→\\t\\\"log/slog\\\"\\n     9→\\t\\\"strings\\\"\\n    10→\\t\\\"time\\\"\\n    11→\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    13→)\\n    14→\\n    15→// Phase represents the lifecycle stage of a session.\\n    16→type Phase string\\n    17→\\n    18→const (\\n    19→\\tPhaseActive Phase = \\\"active\\\"\\n    20→\\tPhaseIdle   Phase = \\\"idle\\\"\\n    21→\\tPhaseEnded  Phase = \\\"ended\\\"\\n    22→)\\n    23→\\n    24→// allPhases is the canonical list of phases for enumeration (e.g., diagram generation).\\n    25→var allPhases = []Phase{PhaseIdle, PhaseActive, PhaseEnded}\\n    26→\\n    27→// PhaseFromString normalizes a phase string, treating empty or unknown values\\n    28→// as PhaseIdle for backward compatibility with pre-state-machine session files.\\n    29→func PhaseFromString(s string) Phase {\\n    30→\\tswitch Phase(s) {\\n    31→\\tcase PhaseActive, \\\"active_committed\\\":\\n    32→\\t\\t// \\\"active_committed\\\" was removed with the 1:1 checkpoint model.\\n    33→\\t\\t// It previously meant \\\"agent active + commit happened during turn\\\".\\n    34→\\t\\t// Normalize to ACTIVE so HandleTurnEnd can finalize any pending checkpoints.\\n    35→\\t\\treturn PhaseActive\\n    36→\\tcase PhaseIdle:\\n    37→\\t\\treturn PhaseIdle\\n    38→\\tcase PhaseEnded:\\n    39→\\t\\treturn PhaseEnded\\n    40→\\tdefault:\\n    41→\\t\\t// Backward compat: truly unknown phases normalize to idle.\\n    42→\\t\\treturn PhaseIdle\\n    43→\\t}\\n    44→}\\n    45→\\n    46→// IsActive reports whether the phase represents an active agent turn.\\n    47→func (p Phase) IsActive() bool {\\n    48→\\treturn p == PhaseActive\\n    49→}\\n    50→\\n    51→// Event represents something that happened to a session.\\n    52→type Event int\\n    53→\\n    54→const (\\n    55→\\tEventTurnStart    Event = iota // Agent begins working on a prompt\\n    56→\\tEventTurnEnd                   // Agent finishes its turn\\n    57→\\tEventGitCommit                 // A git commit was made (PostCommit hook)\\n    58→\\tEventSessionStart              // Session process started (SessionStart hook)\\n    59→\\tEventSessionStop               // Session process ended (SessionStop hook)\\n    60→\\tEventCompaction                // Agent compacted context mid-turn (PreCompress hook)\\n    61→)\\n    62→\\n    63→// allEvents is the canonical list of events for enumeration.\\n    64→var allEvents = []Event{EventTurnStart, EventTurnEnd, EventGitCommit, EventSessionStart, EventSessionStop, EventCompaction}\\n    65→\\n    66→// String returns a human-readable name for the event.\\n    67→func (e Event) String() string {\\n    68→\\tswitch e {\\n    69→\\tcase EventTurnStart:\\n    70→\\t\\treturn \\\"TurnStart\\\"\\n    71→\\tcase EventTurnEnd:\\n    72→\\t\\treturn \\\"TurnEnd\\\"\\n    73→\\tcase EventGitCommit:\\n    74→\\t\\treturn \\\"GitCommit\\\"\\n    75→\\tcase EventSessionStart:\\n    76→\\t\\treturn \\\"SessionStart\\\"\\n    77→\\tcase EventSessionStop:\\n    78→\\t\\treturn \\\"SessionStop\\\"\\n    79→\\tcase EventCompaction:\\n    80→\\t\\treturn \\\"Compaction\\\"\\n    81→\\tdefault:\\n    82→\\t\\treturn fmt.Sprintf(\\\"Event(%d)\\\", int(e))\\n    83→\\t}\\n    84→}\\n    85→\\n    86→// Action represents a side effect that should be performed after a transition.\\n    87→// The caller is responsible for executing these -- the state machine only declares them.\\n    88→type Action int\\n    89→\\n    90→const (\\n    91→\\tActionCondense               Action = iota // Condense session data to permanent storage\\n    92→\\tActionCondenseIfFilesTouched               // Condense only if FilesTouched is non-empty\\n    93→\\tActionDiscardIfNoFiles                     // Discard session if FilesTouched is empty\\n    94→\\tActionWarnStaleSession                     // Warn user about stale session(s)\\n    95→\\tActionClearEndedAt                         // Clear EndedAt timestamp (session re-entering)\\n    96→\\tActionUpdateLastInteraction                // Update LastInteractionTime\\n    97→)\\n    98→\\n    99→// String returns a human-readable name for the action.\\n   100→func (a Action) String() string {\\n   101→\\tswitch a {\\n   102→\\tcase ActionCondense:\\n   103→\\t\\treturn \\\"Condense\\\"\\n   104→\\tcase ActionCondenseIfFilesTouched:\\n   105→\\t\\treturn \\\"CondenseIfFilesTouched\\\"\\n   106→\\tcase ActionDiscardIfNoFiles:\\n   107→\\t\\treturn \\\"DiscardIfNoFiles\\\"\\n   108→\\tcase ActionWarnStaleSession:\\n   109→\\t\\treturn \\\"WarnStaleSession\\\"\\n   110→\\tcase ActionClearEndedAt:\\n   111→\\t\\treturn \\\"ClearEndedAt\\\"\\n   112→\\tcase ActionUpdateLastInteraction:\\n   113→\\t\\treturn \\\"UpdateLastInteraction\\\"\\n   114→\\tdefault:\\n   115→\\t\\treturn fmt.Sprintf(\\\"Action(%d)\\\", int(a))\\n   116→\\t}\\n   117→}\\n   118→\\n   119→// TransitionContext provides read-only context for transitions that need\\n   120→// to inspect session state without mutating it.\\n   121→type TransitionContext struct {\\n   122→\\tHasFilesTouched    bool // len(FilesTouched) > 0\\n   123→\\tIsRebaseInProgress bool // .git/rebase-merge/ or .git/rebase-apply/ exists\\n   124→}\\n   125→\\n   126→// TransitionResult holds the outcome of a state machine transition.\\n   127→type TransitionResult struct {\\n   128→\\tNewPhase Phase\\n   129→\\tActions  []Action\\n   130→}\\n   131→\\n   132→// Transition computes the next phase and required actions given the current\\n   133→// phase and an event. This is a pure function with no side effects.\\n   134→//\\n   135→// Empty or unknown phase values are normalized to PhaseIdle for backward\\n   136→// compatibility with session state files created before phase tracking.\\n   137→func Transition(current Phase, event Event, ctx TransitionContext) TransitionResult {\\n   138→\\t// Normalize empty/unknown phase to idle for backward compatibility.\\n   139→\\tcurrent = PhaseFromString(string(current))\\n   140→\\n   141→\\tswitch current {\\n   142→\\tcase PhaseIdle:\\n   143→\\t\\treturn transitionFromIdle(event, ctx)\\n   144→\\tcase PhaseActive:\\n   145→\\t\\treturn transitionFromActive(event, ctx)\\n   146→\\tcase PhaseEnded:\\n   147→\\t\\treturn transitionFromEnded(event, ctx)\\n   148→\\tdefault:\\n   149→\\t\\t// PhaseFromString guarantees we only get known phases, but the\\n   150→\\t\\t// exhaustive linter requires handling the default case.\\n   151→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   152→\\t}\\n   153→}\\n   154→\\n   155→func transitionFromIdle(event Event, ctx TransitionContext) TransitionResult {\\n   156→\\tswitch event {\\n   157→\\tcase EventTurnStart:\\n   158→\\t\\treturn TransitionResult{\\n   159→\\t\\t\\tNewPhase: PhaseActive,\\n   160→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   161→\\t\\t}\\n   162→\\tcase EventTurnEnd:\\n   163→\\t\\t// Turn end while idle is a no-op (no active turn to end).\\n   164→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   165→\\tcase EventGitCommit:\\n   166→\\t\\tif ctx.IsRebaseInProgress {\\n   167→\\t\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   168→\\t\\t}\\n   169→\\t\\treturn TransitionResult{\\n   170→\\t\\t\\tNewPhase: PhaseIdle,\\n   171→\\t\\t\\tActions:  []Action{ActionCondense},\\n   172→\\t\\t}\\n   173→\\tcase EventSessionStart:\\n   174→\\t\\t// Already condensable, no-op.\\n   175→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   176→\\tcase EventSessionStop:\\n   177→\\t\\treturn TransitionResult{\\n   178→\\t\\t\\tNewPhase: PhaseEnded,\\n   179→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   180→\\t\\t}\\n   181→\\tcase EventCompaction:\\n   182→\\t\\t// Compaction while idle shouldn't happen, but condense if there's work.\\n   183→\\t\\treturn TransitionResult{\\n   184→\\t\\t\\tNewPhase: PhaseIdle,\\n   185→\\t\\t\\tActions:  []Action{ActionCondenseIfFilesTouched, ActionUpdateLastInteraction},\\n   186→\\t\\t}\\n   187→\\tdefault:\\n   188→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   189→\\t}\\n   190→}\\n   191→\\n   192→func transitionFromActive(event Event, ctx TransitionContext) TransitionResult {\\n   193→\\tswitch event {\\n   194→\\tcase EventTurnStart:\\n   195→\\t\\t// Ctrl-C recovery: agent crashed or user interrupted mid-turn.\\n   196→\\t\\treturn TransitionResult{\\n   197→\\t\\t\\tNewPhase: PhaseActive,\\n   198→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   199→\\t\\t}\\n   200→\\tcase EventTurnEnd:\\n   201→\\t\\treturn TransitionResult{\\n   202→\\t\\t\\tNewPhase: PhaseIdle,\\n   203→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   204→\\t\\t}\\n   205→\\tcase EventGitCommit:\\n   206→\\t\\tif ctx.IsRebaseInProgress {\\n   207→\\t\\t\\treturn TransitionResult{NewPhase: PhaseActive}\\n   208→\\t\\t}\\n   209→\\t\\treturn TransitionResult{\\n   210→\\t\\t\\tNewPhase: PhaseActive,\\n   211→\\t\\t\\tActions:  []Action{ActionCondense},\\n   212→\\t\\t}\\n   213→\\tcase EventSessionStart:\\n   214→\\t\\treturn TransitionResult{\\n   215→\\t\\t\\tNewPhase: PhaseActive,\\n   216→\\t\\t\\tActions:  []Action{ActionWarnStaleSession},\\n   217→\\t\\t}\\n   218→\\tcase EventSessionStop:\\n   219→\\t\\treturn TransitionResult{\\n   220→\\t\\t\\tNewPhase: PhaseEnded,\\n   221→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   222→\\t\\t}\\n   223→\\tcase EventCompaction:\\n   224→\\t\\t// Compaction mid-turn: save current progress but stay active.\\n   225→\\t\\t// The transcript offset will be reset by the compaction handler.\\n   226→\\t\\treturn TransitionResult{\\n   227→\\t\\t\\tNewPhase: PhaseActive,\\n   228→\\t\\t\\tActions:  []Action{ActionCondenseIfFilesTouched, ActionUpdateLastInteraction},\\n   229→\\t\\t}\\n   230→\\tdefault:\\n   231→\\t\\treturn TransitionResult{NewPhase: PhaseActive}\\n   232→\\t}\\n   233→}\\n   234→\\n   235→func transitionFromEnded(event Event, ctx TransitionContext) TransitionResult {\\n   236→\\tswitch event {\\n   237→\\tcase EventTurnStart:\\n   238→\\t\\treturn TransitionResult{\\n   239→\\t\\t\\tNewPhase: PhaseActive,\\n   240→\\t\\t\\tActions:  []Action{ActionClearEndedAt, ActionUpdateLastInteraction},\\n   241→\\t\\t}\\n   242→\\tcase EventTurnEnd:\\n   243→\\t\\t// Turn end while ended is a no-op.\\n   244→\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   245→\\tcase EventGitCommit:\\n   246→\\t\\tif ctx.IsRebaseInProgress {\\n   247→\\t\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   248→\\t\\t}\\n   249→\\t\\tif ctx.HasFilesTouched {\\n   250→\\t\\t\\treturn TransitionResult{\\n   251→\\t\\t\\t\\tNewPhase: PhaseEnded,\\n   252→\\t\\t\\t\\tActions:  []Action{ActionCondenseIfFilesTouched},\\n   253→\\t\\t\\t}\\n   254→\\t\\t}\\n   255→\\t\\treturn TransitionResult{\\n   256→\\t\\t\\tNewPhase: PhaseEnded,\\n   257→\\t\\t\\tActions:  []Action{ActionDiscardIfNoFiles},\\n   258→\\t\\t}\\n   259→\\tcase EventSessionStart:\\n   260→\\t\\treturn TransitionResult{\\n   261→\\t\\t\\tNewPhase: PhaseIdle,\\n   262→\\t\\t\\tActions:  []Action{ActionClearEndedAt},\\n   263→\\t\\t}\\n   264→\\tcase EventSessionStop:\\n   265→\\t\\t// Already ended, no-op.\\n   266→\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   267→\\tcase EventCompaction:\\n   268→\\t\\t// Compaction while ended shouldn't happen, no-op.\\n   269→\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   270→\\tdefault:\\n   271→\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   272→\\t}\\n   273→}\\n   274→\\n   275→// ActionHandler defines strategy-specific side effects for state transitions.\\n   276→// The compiler enforces that every strategy-specific action has a handler.\\n   277→type ActionHandler interface {\\n   278→\\tHandleCondense(state *State) error\\n   279→\\tHandleCondenseIfFilesTouched(state *State) error\\n   280→\\tHandleDiscardIfNoFiles(state *State) error\\n   281→\\tHandleWarnStaleSession(state *State) error\\n   282→}\\n   283→\\n   284→// NoOpActionHandler is a default ActionHandler where all methods are no-ops.\\n   285→// Embed this in handler structs to only override the methods you need.\\n   286→type NoOpActionHandler struct{}\\n   287→\\n   288→func (NoOpActionHandler) HandleCondense(_ *State) error               { return nil }\\n   289→func (NoOpActionHandler) HandleCondenseIfFilesTouched(_ *State) error { return nil }\\n   290→func (NoOpActionHandler) HandleDiscardIfNoFiles(_ *State) error       { return nil }\\n   291→func (NoOpActionHandler) HandleWarnStaleSession(_ *State) error       { return nil }\\n   292→\\n   293→// ApplyTransition applies a TransitionResult to state