/cmd/entire/cli/paths\\\"\\n    35→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    36→)\\n    37→\\n    38→// LogLevelEnvVar is the environment variable that controls log level.\\n    39→const LogLevelEnvVar = \\\"ENTIRE_LOG_LEVEL\\\"\\n    40→\\n    41→// LogsDir is the directory where log files are stored (relative to repo root).\\n    42→const LogsDir = \\\".entire/logs\\\"\\n    43→\\n    44→var (\\n    45→\\t// logger is the package-level logger instance\\n    46→\\tlogger *slog.Logger\\n    47→\\n    48→\\t// logFile holds the current log file handle for cleanup\\n    49→\\tlogFile *os.File\\n    50→\\n    51→\\t// logBufWriter wraps logFile with buffered I/O for performance\\n    52→\\tlogBufWriter *bufio.Writer\\n    53→\\n    54→\\t// currentSessionID stores the session ID from Init() to include in all logs\\n    55→\\tcurrentSessionID string\\n    56→\\n    57→\\t// mu protects logger, logFile, logBufWriter, and currentSessionID\\n    58→\\tmu sync.RWMutex\\n    59→\\n    60→\\t// logLevelGetter is an optional callback to get log level from settings.\\n    61→\\t// Set by SetLogLevelGetter before Init is called.\\n    62→\\tlogLevelGetter func() string\\n    63→)\\n    64→\\n    65→// SetLogLevelGetter sets a callback function to get the log level from settings.\\n    66→// This allows the logging package to read settings without a circular dependency.\\n    67→// The callback is only used if ENTIRE_LOG_LEVEL env var is not set.\\n    68→func SetLogLevelGetter(getter func() string) {\\n    69→\\tmu.Lock()\\n    70→\\tdefer mu.Unlock()\\n    71→\\tlogLevelGetter = getter\\n    72→}\\n    73→\\n    74→// Init initializes the logger for a session, writing JSON logs to\\n    75→// .entire/logs/entire.log.\\n    76→//\\n    77→// If sessionID is non-empty, it is stored as an slog attribute on every log line for filtering.\\n    78→// If the log file cannot be created, falls back to stderr.\\n    79→// Log level is controlled by ENTIRE_LOG_LEVEL environment variable.\\n    80→func Init(ctx context.Context, sessionID string) error {\\n    81→\\t// Validate session ID if provided (used only for the slog attribute, not the filename)\\n    82→\\tif sessionID != \\\"\\\" {\\n    83→\\t\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n    84→\\t\\t\\treturn fmt.Errorf(\\\"invalid session ID for logging: %w\\\", err)\\n    85→\\t\\t}\\n    86→\\t}\\n    87→\\n    88→\\tmu.Lock()\\n    89→\\tdefer mu.Unlock()\\n    90→\\n    91→\\t// Close any existing log file (flush buffer first)\\n    92→\\tif logBufWriter != nil {\\n    93→\\t\\t_ = logBufWriter.Flush()\\n    94→\\t\\tlogBufWriter = nil\\n    95→\\t}\\n    96→\\tif logFile != nil {\\n    97→\\t\\t_ = logFile.Close()\\n    98→\\t\\tlogFile = nil\\n    99→\\t}\\n   100→\\n   101→\\t// Get log level from environment first, then settings\\n   102→\\tlevelStr := os.Getenv(LogLevelEnvVar)\\n   103→\\tif levelStr == \\\"\\\" && logLevelGetter != nil {\\n   104→\\t\\tlevelStr = logLevelGetter()\\n   105→\\t}\\n   106→\\tlevel := parseLogLevel(levelStr)\\n   107→\\n   108→\\t// Warn if invalid level was provided\\n   109→\\tif levelStr != \\\"\\\" && !isValidLogLevel(levelStr) {\\n   110→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: invalid log level %q, defaulting to INFO\\\\n\\\", levelStr)\\n   111→\\t}\\n   112→\\n   113→\\t// Determine log file path\\n   114→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   115→\\tif err != nil {\\n   116→\\t\\t// Fall back to current directory\\n   117→\\t\\trepoRoot = \\\".\\\"\\n   118→\\t}\\n   119→\\n   120→\\tlogsPath := filepath.Join(repoRoot, LogsDir)\\n   121→\\tif err := os.MkdirAll(logsPath, 0o750); err != nil {\\n   122→\\t\\t// Fall back to stderr\\n   123→\\t\\tlogger = createLogger(os.Stderr, level)\\n   124→\\t\\treturn nil\\n   125→\\t}\\n   126→\\n   127→\\tlogFilePath := filepath.Join(logsPath, \\\"entire.log\\\")\\n   128→\\tf, err := os.OpenFile(logFilePath, os.O_CREATE|os.O_APPEND|os.O_WRONLY, 0o600) //nolint:gosec // fixed filename, not user-controlled\\n   129→\\tif err != nil {\\n   130→\\t\\t// Fall back to stderr\\n   131→\\t\\tlogger = createLogger(os.Stderr, level)\\n   132→\\t\\treturn nil\\n   133→\\t}\\n   134→\\n   135→\\tlogFile = f\\n   136→\\tlogBufWriter = bufio.NewWriterSize(f, 8192) // 8KB buffer for batched writes\\n   137→\\tlogger = createLogger(logBufWriter, level)\\n   138→\\tcurrentSessionID = sessionID\\n   139→\\n   140→\\treturn nil\\n   141→}\\n   142→\\n   143→// Close closes the log file if one is open.\\n   144→// Flushes any buffered data before closing.\\n   145→// Safe to call multiple times.\\n   146→func Close() {\\n   147→\\tmu.Lock()\\n   148→\\tdefer mu.Unlock()\\n   149→\\n   150→\\tif logBufWriter != nil {\\n   151→\\t\\t_ = logBufWriter.Flush()\\n   152→\\t\\tlogBufWriter = nil\\n   153→\\t}\\n   154→\\tif logFile != nil {\\n   155→\\t\\t_ = logFile.Close()\\n   156→\\t\\tlogFile = nil\\n   157→\\t}\\n   158→\\tcurrentSessionID = \\\"\\\"\\n   159→}\\n   160→\\n   161→// resetLogger resets the logger to nil (for testing).\\n   162→func resetLogger() {\\n   163→\\tmu.Lock()\\n   164→\\tdefer mu.Unlock()\\n   165→\\tlogger = nil\\n   166→\\tcurrentSessionID = \\\"\\\"\\n   167→\\tif logBufWriter != nil {\\n   168→\\t\\t_ = logBufWriter.Flush()\\n   169→\\t\\tlogBufWriter = nil\\n   170→\\t}\\n   171→\\tif logFile != nil {\\n   172→\\t\\t_ = logFile.Close()\\n   173→\\t\\tlogFile = nil\\n   174→\\t}\\n   175→}\\n   176→\\n   177→// getLogger returns the current logger, or a default stderr logger if not initialized.\\n   178→func getLogger() *slog.Logger {\\n   179→\\tmu.RLock()\\n   180→\\tdefer mu.RUnlock()\\n   181→\\n   182→\\tif logger == nil {\\n   183→\\t\\t// Return default stderr logger\\n   184→\\t\\treturn slog.Default()\\n   185→\\t}\\n   186→\\treturn logger\\n   187→}\\n   188→\\n   189→// getSessionID returns the current session ID (thread-safe).\\n   190→func getSessionID() string {\\n   191→\\tmu.RLock()\\n   192→\\tdefer mu.RUnlock()\\n   193→\\treturn currentSessionID\\n   194→}\\n   195→\\n   196→// createLogger creates a JSON logger writing to the given writer at the specified level.\\n   197→func createLogger(w io.Writer, level slog.Level) *slog.Logger {\\n   198→\\topts := &slog.HandlerOptions{\\n   199→\\t\\tLevel: level,\\n   200→\\t}\\n   201→\\thandler := slog.NewJSONHandler(w, opts)\\n   202→\\treturn slog.New(handler)\\n   203→}\\n   204→\\n   205→// parseLogLevel parses a log level string to slog.Level.\\n   206→// Returns slog.LevelInfo for empty or invalid values.\\n   207→func parseLogLevel(s string) slog.Level {\\n   208→\\tswitch strings.ToUpper(strings.TrimSpace(s)) {\\n   209→\\tcase \\\"DEBUG\\\":\\n   210→\\t\\treturn slog.LevelDebug\\n   211→\\tcase \\\"INFO\\\":\\n   212→\\t\\treturn slog.LevelInfo\\n   213→\\tcase \\\"WARN\\\", \\\"WARNING\\\":\\n   214→\\t\\treturn slog.LevelWarn\\n   215→\\tcase \\\"ERROR\\\":\\n   216→\\t\\treturn slog.LevelError\\n   217→\\tdefault:\\n   218→\\t\\treturn slog.LevelInfo\\n   219→\\t}\\n   220→}\\n   221→\\n   222→// isValidLogLevel checks if the given string is a valid log level.\\n   223→func isValidLogLevel(s string) bool {\\n   224→\\tswitch strings.ToUpper(strings.TrimSpace(s)) {\\n   225→\\tcase \\\"DEBUG\\\", \\\"INFO\\\", \\\"WARN\\\", \\\"WARNING\\\", \\\"ERROR\\\", \\\"\\\":\\n   226→\\t\\treturn true\\n   227→\\tdefault:\\n   228→\\t\\treturn false\\n   229→\\t}\\n   230→}\\n   231→\\n   232→// Debug logs at DEBUG level with context values automatically extracted.\\n   233→func Debug(ctx context.Context, msg string, attrs ...any) {\\n   234→\\tlog(ctx, slog.LevelDebug, msg, attrs...)\\n   235→}\\n   236→\\n   237→// Info logs at INFO level with context values automatically extracted.\\n   238→func Info(ctx context.Context, msg string, attrs ...any) {\\n   239→\\tlog(ctx, slog.LevelInfo, msg, attrs...)\\n   240→}\\n   241→\\n   242→// Warn logs at WARN level with context values automatically extracted.\\n   243→func Warn(ctx context.Context, msg string, attrs ...any) {\\n   244→\\tlog(ctx, slog.LevelWarn, msg, attrs...)\\n   245→}\\n   246→\\n   247→// Error logs at ERROR level with context values automatically extracted.\\n   248→func Error(ctx context.Context, msg string, attrs ...any) {\\n   249→\\tlog(ctx, slog.LevelError, msg, attrs...)\\n   250→}\\n   251→\\n   252→// LogDuration logs a message with duration_ms calculated from the start time.\\n   253→// The level parameter specifies the log level (use slog.LevelDebug, slog.LevelInfo, etc).\\n   254→// Designed for use with defer:\\n   255→//\\n   256→//\\tdefer logging.LogDuration(ctx, slog.LevelInfo, \\\"operation completed\\\", time.Now())\\n   257→//\\n   258→// Or with additional attrs:\\n   259→//\\n   260→//\\tdefer logging.LogDuration(ctx, slog.LevelDebug, \\\"hook executed\\\", start,\\n   261→//\\t    slog.String(\\\"hook\\\", hookName),\\n   262→//\\t    slog.Bool(\\\"success\\\", true),\\n   263→//\\t)\\n   264→func LogDuration(ctx context.Context, level slog.Level, msg string, start time.Time, attrs ...any) {\\n   265→\\tdurationMs := time.Since(start).Milliseconds()\\n   266→\\n   267→\\t// Prepend duration_ms to attrs\\n   268→\\tallAttrs := make([]any, 0, len(attrs)+1)\\n   269→\\tallAttrs = append(allAttrs, slog.Int64(\\\"duration_ms\\\", durationMs))\\n   270→\\tallAttrs = append(allAttrs, attrs...)\\n   271→\\n   272→\\tlog(ctx, level, msg, allAttrs...)\\n   273→}\\n   274→\\n   275→// log is the internal logging function that extracts context values and logs.\\n   276→func log(ctx context.Context, level slog.Level, msg string, attrs ...any) {\\n   277→\\tl := getLogger()\\n   278→\\n   279→\\t// Build attributes slice with session ID first (if set)\\n   280→\\tvar allAttrs []any\\n   281→\\n   282→\\t// Add session ID from Init() if set (always first for consistency)\\n   283→\\tglobalSessionID := getSessionID()\\n   284→\\tif globalSessionID != \\\"\\\" {\\n   285→\\t\\tallAttrs = append(allAttrs, slog.String(\\\"session_id\\\", globalSessionID))\\n   286→\\t}\\n   287→\\n   288→\\t// Extract context values, skipping session_id if already added from Init()\\n   289→\\tcontextAttrs := attrsFromContext(ctx, globalSessionID)\\n   290→\\tfor _, a := range contextAttrs {\\n   291→\\t\\tallAttrs = append(allAttrs, a)\\n   292→\\t}\\n   293→\\n   294→\\t// Add caller-provided attributes\\n   295→\\tallAttrs = append(allAttrs, attrs...)\\n   296→\\n   297→\\t// Pass nil context to slog as we've already extracted context values as attributes.\\n   298→\\t// slog handlers are expected to handle nil context gracefully.\\n   299→\\tl.Log(nil, level, msg, allAttrs...) //nolint:staticcheck // nil context is intentional - we extract values as attributes\\n   300→}\\n   301→\\n   302→// attrsFromContext extracts logging attributes from a context.\\n   303→// If globalSessionID is non-empty, skips adding session_id from context to avoid duplicates.\\n   304→func attrsFromContext(ctx context.Context, globalSessionID string) []slog.Attr {\\n   305→\\tif ctx == nil {\\n   306→\\t\\treturn nil\\n   307→\\t}\\n   308→\\n   309→\\tvar attrs []slog.Attr\\n   310→\\n   311→\\t// Only add session_id from context if not already set globally\\n   312→\\tif globalSessionID == \\\"\\\" {\\n   313→\\t\\tif v := ctx.Value(sessionIDKey); v != nil {\\n   314→\\t\\t\\tif s, ok := v.(string); ok && s != \\\"\\\" {\\n   315→\\t\\t\\t\\tattrs = append(attrs, slog.String(\\\"session_id\\\", s))\\n   316→\\t\\t\\t}\\n   317→\\t\\t}\\n   318→\\t}\\n   319→\\tif v := ctx.Value(parentSessionIDKey); v != nil {\\n   320→\\t\\tif s, ok := v.(string); ok && s != \\\"\\\" {\\n   321→\\t\\t\\tattrs = append(attrs, slog.String(\\\"parent_session_id\\\", s))\\n   322→\\t\\t}\\n   323→\\t}\\n   324→\\tif v := ctx.Value(toolCallIDKey); v != nil {\\n   325→\\t\\tif s, ok := v.(string); ok && s != \\\"\\\" {\\n   326→\\t\\t\\tattrs = append(attrs, slog.String(\\\"tool_call_id\\\", s