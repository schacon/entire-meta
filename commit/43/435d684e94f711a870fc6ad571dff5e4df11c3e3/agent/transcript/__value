\t\\t// Load settings once for telemetry and version check\\n    51→\\t\\t\\tvar telemetryEnabled *bool\\n    52→\\t\\t\\tsettings, err := LoadEntireSettings(cmd.Context())\\n    53→\\t\\t\\tif err == nil {\\n    54→\\t\\t\\t\\ttelemetryEnabled = settings.Telemetry\\n    55→\\t\\t\\t}\\n    56→\\n    57→\\t\\t\\t// Check if telemetry is enabled\\n    58→\\t\\t\\tif telemetryEnabled != nil && *telemetryEnabled {\\n    59→\\t\\t\\t\\t// Use detached tracking (non-blocking)\\n    60→\\t\\t\\t\\tinstalledAgents := GetAgentsWithHooksInstalled(cmd.Context())\\n    61→\\t\\t\\t\\tagentStr := JoinAgentNames(installedAgents)\\n    62→\\t\\t\\t\\ttelemetry.TrackCommandDetached(cmd, agentStr, settings.Enabled, versioninfo.Version)\\n    63→\\t\\t\\t}\\n    64→\\n    65→\\t\\t\\t// Version check and notification (synchronous with 2s timeout)\\n    66→\\t\\t\\t// Runs AFTER command completes to avoid interfering with interactive modes\\n    67→\\t\\t\\tversioncheck.CheckAndNotify(cmd.Context(), cmd.OutOrStdout(), versioninfo.Version)\\n    68→\\t\\t},\\n    69→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    70→\\t\\t\\treturn cmd.Help()\\n    71→\\t\\t},\\n    72→\\t}\\n    73→\\n    74→\\t// Add subcommands here\\n    75→\\tcmd.AddCommand(newRewindCmd())\\n    76→\\tcmd.AddCommand(newResumeCmd())\\n    77→\\tcmd.AddCommand(newCleanCmd())\\n    78→\\tcmd.AddCommand(newResetCmd())\\n    79→\\tcmd.AddCommand(newEnableCmd())\\n    80→\\tcmd.AddCommand(newDisableCmd())\\n    81→\\tcmd.AddCommand(newStatusCmd())\\n    82→\\tcmd.AddCommand(newLoginCmd())\\n    83→\\tcmd.AddCommand(newHooksCmd())\\n    84→\\tcmd.AddCommand(newVersionCmd())\\n    85→\\tcmd.AddCommand(newExplainCmd())\\n    86→\\tcmd.AddCommand(newDoctorCmd())\\n    87→\\tcmd.AddCommand(newTrailCmd())\\n    88→\\tcmd.AddCommand(newSendAnalyticsCmd())\\n    89→\\tcmd.AddCommand(newCurlBashPostInstallCmd())\\n    90→\\n    91→\\tcmd.SetVersionTemplate(versionString())\\n    92→\\n    93→\\t// Replace default help command with custom one that supports -t flag\\n    94→\\tcmd.SetHelpCommand(NewHelpCmd(cmd))\\n    95→\\n    96→\\treturn cmd\\n    97→}\\n    98→\\n    99→func versionString() string {\\n   100→\\treturn fmt.Sprintf(\\\"Entire CLI %s (%s)\\\\nGo version: %s\\\\nOS/Arch: %s/%s\\\\n\\\",\\n   101→\\t\\tversioninfo.Version, versioninfo.Commit, runtime.Version(), runtime.GOOS, runtime.GOARCH)\\n   102→}\\n   103→\\n   104→func newVersionCmd() *cobra.Command {\\n   105→\\treturn &cobra.Command{\\n   106→\\t\\tUse:   \\\"version\\\",\\n   107→\\t\\tShort: \\\"Show build information\\\",\\n   108→\\t\\tRun: func(cmd *cobra.Command, _ []string) {\\n   109→\\t\\t\\t// Use OutOrStdout explicitly — cobra's cmd.Print() defaults to\\n   110→\\t\\t\\t// stderr in v1.10+, but version output should go to stdout.\\n   111→\\t\\t\\tfmt.Fprint(cmd.OutOrStdout(), versionString())\\n   112→\\t\\t},\\n   113→\\t}\\n   114→}\\n   115→\\n   116→// newSendAnalyticsCmd creates the hidden command for sending analytics from a detached subprocess.\\n   117→// This command is invoked by TrackCommandDetached and should not be called directly by users.\\n   118→func newSendAnalyticsCmd() *cobra.Command {\\n   119→\\treturn &cobra.Command{\\n   120→\\t\\tUse:    \\\"__send_analytics\\\",\\n   121→\\t\\tHidden: true,\\n   122→\\t\\tArgs:   cobra.ExactArgs(1),\\n   123→\\t\\tRun: func(_ *cobra.Command, args []string) {\\n   124→\\t\\t\\ttelemetry.SendEvent(args[0])\\n   125→\\t\\t},\\n   126→\\t}\\n   127→}\\n   128→\"}]},\"uuid\":\"25f6a647-a1eb-45b7-8033-077cebdece27\",\"timestamp\":\"2026-03-14T09:55:31.553Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a713062a872c2d8d3\"},\"toolUseID\":\"agent_msg_01NTuMV5ZbpfAYdR7H5mQQ8y\",\"parentToolUseID\":\"toolu_01H6xkMdUbRJbb54L58NNMnv\",\"uuid\":\"a434074f-17e0-44ed-a106-93100df652f9\",\"timestamp\":\"2026-03-14T09:55:32.784Z\",\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli\",\"sessionId\":\"6045d8ec-bf58-4e