bined, p) {\\n    98→\\t\\t\\treturn true\\n    99→\\t\\t}\\n   100→\\t}\\n   101→\\treturn false\\n   102→}\\n   103→\\n   104→func (a *${AgentName}) RunPrompt(ctx context.Context, dir string, prompt string, opts ...Option) (Output, error) {\\n   105→\\tcfg := &runConfig{}\\n   106→\\tfor _, o := range opts {\\n   107→\\t\\to(cfg)\\n   108→\\t}\\n   109→\\n   110→\\targs := []string{/* agent CLI flags for non-interactive prompt execution */}\\n   111→\\tcmd := exec.CommandContext(ctx, a.Binary(), args...)\\n   112→\\tcmd.Dir = dir\\n   113→\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   114→\\tcmd.SysProcAttr = &syscall.SysProcAttr{Setpgid: true}\\n   115→\\tcmd.Cancel = func() error {\\n   116→\\t\\treturn syscall.Kill(-cmd.Process.Pid, syscall.SIGKILL)\\n   117→\\t}\\n   118→\\n   119→\\tvar stdout, stderr strings.Builder\\n   120→\\tcmd.Stdout = &stdout\\n   121→\\tcmd.Stderr = &stderr\\n   122→\\n   123→\\terr := cmd.Run()\\n   124→\\texitCode := 0\\n   125→\\tif err != nil {\\n   126→\\t\\texitErr := &exec.ExitError{}\\n   127→\\t\\tif errors.As(err, &exitErr) {\\n   128→\\t\\t\\texitCode = exitErr.ExitCode()\\n   129→\\t\\t} else {\\n   130→\\t\\t\\texitCode = -1\\n   131→\\t\\t}\\n   132→\\t}\\n   133→\\n   134→\\treturn Output{\\n   135→\\t\\tCommand:  a.Binary() + \\\" \\\" + strings.Join(args, \\\" \\\"),\\n   136→\\t\\tStdout:   stdout.String(),\\n   137→\\t\\tStderr:   stderr.String(),\\n   138→\\t\\tExitCode: exitCode,\\n   139→\\t}, err\\n   140→}\\n   141→\\n   142→func (a *${AgentName}) StartSession(ctx context.Context, dir string) (Session, error) {\\n   143→\\t// Use NewTmuxSession for interactive PTY support.\\n   144→\\t// Return nil if agent doesn't support interactive mode.\\n   145→\\tname := fmt.Sprintf(\\\"${agent-slug}-test-%d\\\", time.Now().UnixNano())\\n   146→\\ts, err := NewTmuxSession(name, dir, nil, a.Binary(), /* interactive args */)\\n   147→\\tif err != nil {\\n   148→\\t\\treturn nil, err\\n   149→\\t}\\n   150→\\treturn s, nil\\n   151→}\\n   152→```\\n   153→\\n   154→Key implementation details:\\n   155→- Self-register in `init()` with `Register()`, gated by `E2E_AGENT` env var\\n   156→- Use `RegisterGate(\\\"name\\\", N)` if the agent's API has strict rate limits (e.g., Gemini uses gate of 1)\\n   157→- `Bootstrap()` handles CI-specific one-time setup (auth config, API key injection)\\n   158→- `IsTransientError()` identifies retryable API failures — `RepoState.RunPrompt` retries once on transient errors\\n   159→- `RunPrompt()` uses `exec.CommandContext` with `Setpgid: true` and process-group kill for clean cancellation\\n   160→- `StartSession()` uses `NewTmuxSession` for interactive PTY tests; return `nil` if interactive mode isn't supported\\n   161→- Use `AGENT.md` (the one-pager) for CLI flags, prompt passing mechanism, and env vars\\n   162→\\n   163→### Step 5: Update SetupRepo (if needed)\\n   164→\\n   165→Check if `testutil.SetupRepo` in `e2e/testutil/repo.go` needs agent-specific configuration. Look for the existing `if agent.Name() == \\\"opencode\\\"` block as an example:\\n   166→\\n   167→- Agent-specific config files that must exist before `entire enable`\\n   168→- Permission or auth config files\\n   169→- Environment variables needed for hook testing\\n   170→\\n   171→If no special setup is needed, skip this step.\\n   172→\\n   173→### Step 6: Verify\\n   174→\\n   175→After writing the runner code:\\n   176→\\n   177→1. **Lint check**: `mise run lint` — ensure no lint errors\\n   178→2. **Compile check**: `go test -c -tags=e2e ./e2e/tests` — compile-only with the build tag to verify the runner compiles and registers\\n   179→3. **Verify registration**: The runner's `init()` calls `Register()` and will be picked up by `ForEachAgent` in existing tests\\n   180→4. **Add mise task**: Remind the user to add a `test:e2e:${agent_slug}` task in `mise.toml` and update CI workflows\\n   181→5. **Next step**: The implement phase will run E2E tests against