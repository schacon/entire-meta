ge\\\",\\n521: \\t\\t\\t\\tResponses: []string{},\\n522: \\t\\t\\t}},\\n523: \\t\\t},\\n524: \\t\\t{\\n525: \\t\\t\\tIndex:     2,\\n526: \\t\\t\\tShortID:   \\\"bbb2222\\\",\\n527: \\t\\t\\tTimestamp: now.Add(-time.Hour),\\n528: \\t\\t\\tMessage:   \\\"Second checkpoint\\\",\\n529: \\t\\t\\tInteractions: []interaction{{\\n530: \\t\\t\\t\\tPrompt:    \\\"Middle change\\\",\\n531: \\t\\t\\t\\tResponses: []string{},\\n532: \\t\\t\\t}},\\n533: \\t\\t},\\n534: \\t\\t{\\n535: \\t\\t\\tIndex:     1, // Oldest checkpoint should be #1\\n536: \\t\\t\\tShortID:   \\\"aaa1111\\\",\\n537: \\t\\t\\tTimestamp: now.Add(-2 * time.Hour),\\n538: \\t\\t\\tMessage:   \\\"First (oldest) checkpoint\\\",\\n539: \\t\\t\\tInteractions: []interaction{{\\n540: \\t\\t\\t\\tPrompt:    \\\"Initial change\\\",\\n541: \\t\\t\\t\\tResponses: []string{},\\n542: \\t\\t\\t}},\\n543: \\t\\t},\\n544: \\t}\\n545: \\n546: \\toutput := formatSessionInfo(session, \\\"\\\", checkpointDetails)\\n547: \\n548: \\t// Verify checkpoint ordering in output\\n549: \\t// Checkpoint 3 should appear before Checkpoint 2 which should appear before Checkpoint 1\\n550: \\tidx3 := strings.Index(output, \\\"Checkpoint 3\\\")\\n551: \\tidx2 := strings.Index(output, \\\"Checkpoint 2\\\")\\n552: \\tidx1 := strings.Index(output, \\\"Checkpoint 1\\\")\\n553: \\n554: \\tif idx3 == -1 || idx2 == -1 || idx1 == -1 {\\n555: \\t\\tt.Fatalf(\\\"expected all checkpoints to be in output, got:\\\\n%s\\\", output)\\n556: \\t}\\n557: \\n558: \\t// In the output, they should appear in the order they're in the slice (newest first)\\n559: \\tif idx3 > idx2 || idx2 > idx1 {\\n560: \\t\\tt.Errorf(\\\"expected checkpoints to appear in order 3, 2, 1 in output (newest first), got positions: 3=%d, 2=%d, 1=%d\\\", idx3, idx2, idx1)\\n561: \\t}\\n562: \\n563: \\t// Verify the dates appear correctly\\n564: \\tif !strings.Contains(output, \\\"Latest change\\\") {\\n565: \\t\\tt.Error(\\\"expected output to contain 'Latest change' prompt\\\")\\n566: \\t}\