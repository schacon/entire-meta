ting.T) {\\n110: \\tcontent := ExtractUserContent([]byte(`not valid json`))\\n111: \\n112: \\tif content != \\\"\\\" {\\n113: \\t\\tt.Errorf(\\\"expected empty string for invalid JSON, got '%s'\\\", content)\\n114: \\t}\\n115: }\\n116: \\n117: func TestExtractUserContent_StripsIDETags(t *testing.T) {\\n118: \\tmsg := UserMessage{Content: \\\"<ide_opened_file>file.go</ide_opened_file>Hello, world!\\\"}\\n119: \\traw, err := json.Marshal(msg)\\n120: \\tif err != nil {\\n121: \\t\\tt.Fatalf(\\\"failed to marshal: %v\\\", err)\\n122: \\t}\\n123: \\n124: \\tcontent := ExtractUserContent(raw)\\n125: \\n126: \\tif content != \\\"Hello, world!\\\" {\\n127: \\t\\tt.Errorf(\\\"expected IDE tags stripped, got '%s'\\\", content)\\n128: \\t}\\n129: }\\n130: \\n131: func TestExtractUserContent_ToolResultsIgnored(t *testing.T) {\\n132: \\t// Tool result content should return empty (not a user prompt)\\n133: \\traw := []byte(`{\\\"content\\\":[{\\\"type\\\":\\\"tool_result\\\",\\\"tool_use_id\\\":\\\"123\\\",\\\"content\\\":\\\"result\\\"}]}`)\\n134: \\n135: \\tcontent := ExtractUserContent(raw)\\n136: \\n137: \\tif content != \\\"\\\" {\\n138: \\t\\tt.Errorf(\\\"expected empty string for tool results, got '%s'\\\", content)\\n139: \\t}\\n140: }\\n141: \\n142: func TestSliceFromLine_SkipsFirstNLines(t *testing.T) {\\n143: \\t// 5 JSONL lines\\n144: \\tcontent := []byte(`{\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"u1\\\",\\\"message\\\":{\\\"content\\\":\\\"prompt 1\\\"}}\\n145: {\\\"type\\\":\\\"assistant\\\",\\\"uuid\\\":\\\"a1\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"response 1\\\"}]}}\\n146: {\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"u2\\\",\\\"message\\\":{\\\"content\\\":\\\"prompt 2\\\"}}\\n147: {\\\"type\\\":\\\"assistant\\\",\\\"uuid\\\":\\\"a2\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"response 2\\\"}]}}\\n148: {\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"u3\\\",\\\"message\\\":{\\\"content\\\":\\\"prompt 3\\\"}}\\n149: `)\\n150: \\n151: \\t// Skip first 2 lines, should get lines 3-5\\n152: \\tsliced := SliceFromLine(content, 2)\\n153: \\n154: \\tlines, err := ParseFromBytes(sliced)\\n155: \\tif err != nil {\\n156: \\t\\tt.Fatalf(\\\"unexpected error: %v\\\", err)\\n157: \\t}\\n158: \\n159: \\tif len(lines) != 3 {\\n160: \\t\\tt.Fatalf(\\\"expected 3 lines after skipping 2, got %d\\\", len(lines))\\n161: \\t}\\n162: \\n163: \\tif lines[0].UUID != \\\"u2\\\" {\\n164: \\t\\tt.Errorf(\\\"expected first line to be u2, got %s\\\", lines[0].UUID)\\n165: \\t}\\n166: \\tif lines[1].UUID != \\\"a2\\\" {\\n167: \\t\\tt.Errorf(\\\"expected second line to be a2, got %s\\\", lines[1].UUID)\\n168: \\t}\\n169: \\tif lines[2].UUID != \\\"u3\\\" {\\n170: \\t\\tt.Errorf(\\\"expected third line to be u3, got %s\\\", lines[2].UUID)\\n171: \\t}\\n172: }\\n173: \\n174: func TestSliceFromLine_ZeroReturnsAll(t *testing.T) {\\n175: \\tcontent := []byte(`{\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"u1\\\",\\\"message\\\":{\\\"content\\\":\\\"prompt 1\\\"}}\\n176: {\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"u2\\\",\\\"message\\\":{\\\"content\\\":\\\"prompt 2\\\"}}\\n177: `)\\n178: \\n179: \\tsliced := SliceFromLine(content, 0)\\n180: \\n181: \\tlines, err := ParseFromBytes(sliced)\\n182: \\tif err != nil {\\n183: \\t\\tt.Fatalf(\\\"unexpected error: %v\\\", err)\\n184: \\t}\\n185: \\n186: \\tif len(lines) != 2 {\\n187: \\t\\tt.Fatalf(\\\"expected 2 lines, got %d\\\", len(lines))\\n188: \\t}\\n189: }\\n190: \\n191: func TestSliceFromLine_SkipMoreThanExists(t *testing.T) {\\n192: \\tcontent := []byte(`{\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"u1\\\",\\\"message\\\":{\\\"content\\\":\\\"prompt 1\\\"}}\\n193: `)\\n194: \\n195: \\t// Skip more lines than exist\\n196: \\tsliced := SliceFromLine(content, 10)\\n197: \\n198: \\tif len(sliced) != 0 {\\n199: \\t\\tt.Errorf(\\\"expected empty slice when skipping more lines than exist, got %d bytes\\\", len(sliced))\\n200: \\t}\\n201: }\\n202: \\n203: func TestSliceFromLine_EmptyContent(t *testing.T) {\\n204: \\tsliced := SliceFromLine([]byte{}, 5)\\n205: \\n206: \\tif len(sliced) != 0 {\\n207: \\t\\tt.Errorf(\\\"expected empty slice for empty content, got %d bytes\\\", len(sliced))\\n208: \\t}\\n209: }\\n210: \\n211: func TestSliceFromLine_NoTrailingNewline(t *testing.T) {\\n212: \\t// No trailing newline\\n213: \\tcontent := []byte(`{\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"u1\\\",\\\"message\\\":{\\\"content\\\":\\\"prompt 1\\\"}}\\n214: {\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"u2\\\",\\\"message\\\":{\\\"content\\\":\\\"prompt 2\\\"}}`)\\n215: \\n216: \\tsliced := SliceFromLine(content, 1)\\n217: \\n218: \\tlines, err := ParseFromBytes(sliced)\\n219: \\tif err != nil {\\n220: \\t\\tt.Fatalf(\\\"unexpected error: %v\\\", err)\\n221: \\t}\\n222: \\n223: \\tif len(lines) != 1 {\\n224: \\t\\tt.Fatalf(\\\"expected 1 line after skipping 1, got %d\\\", len(lines))\\n225: \\t}\\n226: \\n227: \\tif lines[0].UUID != \\\"u2\\\" {\\n228: \\t\\tt.Errorf(\\\"expected line to be u2, got %s\\\", lines[0].UUID)\\n229: \\t}\\n230: }\\n231: \\n232: // --- ParseFromFileAtLine tests ---\\n233: \\n234: func createTempTranscript(t *testing.T, content string) string {\\n235: \\tt.Helper()\\n236: \\ttmpDir := t.TempDir()\\n237: \\ttmpFile := filepath.Join(tmpDir, \\\"transcript.jsonl\\\")\\n238: \\tif err := os.WriteFile(tmpFile, []byte(content), 0o644); err != nil {\\n239: \\t\\tt.Fatalf(\\\"failed to create temp file: %v\\\", err)\\n240: \\t}\\n241: \\treturn tmpFile\\n242: }\\n243: \\n244: func TestParseFromFileAtLine_ValidMixedMessages(t *testing.T) {\\n245: \\tt.Parallel()\\n246: \\n247: \\tcontent := `{\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"user-1\\\",\\\"message\\\":{\\\"content\\\":\\\"Hello\\\"}}\\n248: {\\\"type\\\":\\\"assistant\\\",\\\"uuid\\\":\\\"asst-1\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"Hi there\\\"}]}}\\n249: {\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"user-2\\\",\\\"message\\\":{\\\"content\\\":\\\"Thanks\\\"}}`\\n250: \\n251: \\ttmpFile := createTempTranscript(t, content)\\n252: \\n253: \\tlines, err := ParseFromFileAtLine(tmpFile, 0)\\n254: \\tif err != nil {\\n255: \\t\\tt.Fatalf(\\\"unexpected error: %v\\\", err)\\n256: \\t}\\n257: \\n258: \\tif len(lines) != 3 {\\n259: \\t\\tt.Fatalf(\\\"expected 3 lines, got %d\\\", len(lines))\\n260: \\t}\\n261: \\n262: \\tif lines[0].Type != TypeUser || lines[0].UUID != \\\"user-1\\\" {\\n263: \\t\\tt.Errorf(\\\"first line mismatch: got type=%s uuid=%s\\\", lines[0].Type, lines[0].UUID)\\n264: \\t}\\n265: \\tif lines[1].Type != TypeAssistant || lines[1].UUID != \\\"asst-1\\\" {\\n266: \\t\\tt.Errorf(\\\"second line mismatch: got type=%s uuid=%s\\\", lines[1].Type, lines[1].UUID)\\n267: \\t}\\n268: \\tif lines[2].Type != TypeUser || lines[2].UUID != \\\"user-2\\\" {\\n269: \\t\\tt.Errorf(\\\"third line mismatch: got type=%s uuid=%s\\\", lines[2].Type, lines[2].UUID)\\n270: \\t}\\n271: }\\n272: \\n273: func TestParseFromFileAtLine_SkipsMalformedLines(t *testing.T) {\\n274: \\tt.Parallel()\\n275: \\n276: \\tcontent := `{\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"user-1\\\",\\\"message\\\":{\\\"content\\\":\\\"Hello\\\"}}\\n277: this is not valid json\\n278: {\\\"type\\\":\\\"assistant\\\",\\\"uuid\\\":\\\"asst-1\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"Hi\\\"}]}}\\n279: {\\\"broken json\\n280: {\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"user-2\\\",\\\"message\\\":{\\\"content\\\":\\\"Bye\\\"}}`\\n281: \\n282: \\ttmpFile := createTempTranscript(t, content)\\n283: \\n284: \\tlines, err := ParseFromFileAtLine(tmpFile, 0)\\n285: \\tif err != nil {\\n286: \\t\\tt.Fatalf(\\\"unexpected error: %v\\\", err)\\n287: \\t}\\n288: \\n289: \\tif len(lines) != 3 {\\n290: \\t\\tt.Fatalf(\\\"expected 3 valid lines, got %d\\\", len(lines))\\n291: \\t}\\n292: }\\n293: \\n294: func TestParseFromFileAtLine_LargeLines(t *testing.T) {\\n295: \\tt.Parallel()