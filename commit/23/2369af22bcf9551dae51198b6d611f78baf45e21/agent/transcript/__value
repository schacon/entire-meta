 associated with a checkpoint.\\n43: type associatedCommit struct {\\n44: \\tSHA      string\\n45: \\tShortSHA string\\n46: \\tMessage  string\\n47: \\tAuthor   string\\n48: \\tEmail    string\\n49: \\tDate     time.Time\\n50: }\\n51: \\n52: // checkpointDetail holds detailed information about a checkpoint for display.\\n53: type checkpointDetail struct {\\n54: \\tIndex            int\\n55: \\tShortID          string\\n56: \\tTimestamp        time.Time\\n57: \\tIsTaskCheckpoint bool\\n58: \\tMessage          string\\n59: \\t// Interactions contains all prompt/response pairs in this checkpoint.\\n60: \\t// Most strategies have one, but shadow condensations may have multiple.\\n61: \\tInteractions []interaction\\n62: \\t// Files is the aggregate list of all files modified (for backwards compat)\\n63: \\tFiles []string\\n64: }\\n65: \\n66: func newExplainCmd() *cobra.Command {\\n67: \\tvar sessionFlag string\\n68: \\tvar commitFlag string\\n69: \\tvar checkpointFlag string\\n70: \\tvar noPagerFlag bool\\n71: \\tvar shortFlag bool\\n72: \\tvar fullFlag bool\\n73: \\tvar rawTranscriptFlag bool\\n74: \\tvar generateFlag bool\\n75: \\tvar forceFlag bool\\n76: \\tvar searchAllFlag bool\\n77: \\n78: \\tcmd := &cobra.Command{\\n79: \\t\\tUse:   \\\"explain\\\",\\n80: \\t\\tShort: \\\"Explain a session, commit, or checkpoint\\\",\\n81: \\t\\tLong: `Explain provides human-readable context about sessions, commits, and checkpoints.\\n82: \\n83: Use this command to understand what happened during agent-driven development,\\n84: either for self-review or to understand a teammate's work.\\n85: \\n86: By default, shows checkpoints on the current branch. Use flags to filter or\\n87: explain specific items.\\n88: \\n89: Filtering the list view:\\n90:   --session      Filter checkpoints by session ID (or prefix)\\n91: \\n92: Viewing specific items:\\n93:   --commit       Explain a specific commit (shows its associated checkpoint)\\n94:   --checkpoint   Explain a specific checkpoint by ID\\n95: \\n96: Output verbosity levels (for --checkpoint):\\n97:   Default:         Detailed view with scoped prompts (ID, session, tokens, intent, prompts, files)\\n98:   --short          Summary only (ID, session, timestamp, tokens, intent)\\n99:   --full           Parsed full transcript (all prompts/responses from entire session)\\n100:   --raw-transcript Raw transcript file (JSONL format)\\n101: \\n102: Summary generation (for --checkpoint):\\n103:   --generate    Generate an AI summary for the checkpoint\\n104:   --force       Regenerate even if a summary already exists (requires --generate)\\n105: \\n106: Performance options:\\n107:   --search-all  Remove branch/depth limits when searching for commits (may be slow)\\n108: \\n109: Checkpoint detail view shows:\\n110:   - Author of the checkpoint\\n111:   - Associated git commits that reference the checkpoint\\n112:   - Prompts and responses from the session\\n113: \\n114: Note: --session filters the list view; --commit and --checkpoint are mutually exclusive.`,\\n115: \\t\\tArgs: func(_ *cobra.Command, args []string) error {\\n116: \\t\\t\\tif len(args) > 0 {\\n117: \\t\\t\\t\\treturn fmt.Errorf(\\\"unexpected argument %q\\\\nHint: use --checkpoint, --session, or --commit to specify what to explain\\\", args[0])\\n118: \\t\\t\\t}\\n119: \\t\\t\\treturn nil\\n120: \\t\\t},\\n121: \\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n122: \\t\\t\\t// Check if Entire is disabled\\n123: \\t\\t\\tif checkDisabledGuard(cmd.Context(), cmd.OutOrStdout()) {\\n124: \\t\\t\\t\\treturn nil\\n125: \\t\\t\\t}\\n126: \\n127: \\t\\t\\t// Validate flag dependencies\\n128: \\t\\t\\tif generateFlag && checkpointFlag == \\\"\\\" {\\n129: \\t\\t\\t\\treturn errors.New(\\\"--generate requires --checkpoint/-c flag\\\")\\n130: \\t\\t\\t}\\n131: \\t\\t\\tif forceFlag && !generateFlag {\\n132: \\t\\t\\t\\treturn errors.New(\\\"--force requires --generate flag\\\")\\n133: \\t\\t\\t}\\n134: \\t\\t\\tif rawTranscriptFlag && checkpointFlag == \\\"\\\" {\\n135: \\t\\t\\t\\treturn errors.New(\\\"--raw-transcript requires --checkpoint/-c flag\\\")\\n136: \\t\\t\\t}\\n137: \\n138: \\t\\t\\t// Convert short flag to verbose (verbose = !short)\\n139: \\t\\t\\tverbose := !shortFlag\\n140: \\t\\t\\treturn runExplain(cmd.Context(), cmd.OutOrStdout(), cmd.ErrOrStderr(), sessionFlag, commitFlag, checkpointFlag, noPagerFlag, verbose, fullFlag, rawTranscriptFlag, generateFlag, forceFlag, searchAllFlag)\\n141: \\t\\t},\\n142: \\t}\\n143: \\n144: \\tcmd.Flags().StringVar(&sessionFlag, \\\"session\\\", \\\"\\\", \\\"Filter checkpoints by session ID (or prefix)\\\")\\n145: \\tcmd.Flags().StringVar(&commitFlag, \\\"commit\\\", \\\"\\\", \\\"Explain a specific commit (SHA or ref, \\\\\\\"commit-ish\\\\\\\")\\\")\\n146: \\tcmd.Flags().StringVarP(&checkpointFlag, \\\"checkpoint\\\", \\\"c\\\", \\\"\\\", \\\"Explain a specific checkpoint (ID or prefix)\\\")\\n147: \\tcmd.Flags().BoolVar(&noPagerFlag, \\\"no-pager\\\", false, \\\"Disable pager output\\\")\\n148: \\tcmd.Flags().BoolVarP(&shortFlag, \\\"short\\\", \\\"s\\\", false, \\\"Show summary only (omit prompts and files)\\\")\\n149: \\tcmd.Flags().BoolVar(&fullFlag, \\\"full\\\", false, \\\"Show full parsed transcript (all prompts/responses)\\\")\\n150: \\tcmd.Flags().BoolVar(&rawTranscriptFlag, \\\"raw-transcript\\\", false, \\\"Show raw transcript file (JSONL format)\\\")\\n151: \\tcmd.Flags().BoolVar(&generateFlag, \\\"generate\\\", false, \\\"Generate an AI summary for the checkpoint\\\")\\n152: \\tcmd.Flags().BoolVar(&forceFlag, \\\"force\\\", false, \\\"Regenerate summary even if one already exists (requires --generate)\\\")\\n153: \\tcmd.Flags().BoolVar(&searchAllFlag, \\\"search-all\\\", false, \\\"Search all commits (no branch/depth limit, may be slow)\\\")\\n154: \\n155: \\t// Make --short, --full, and --raw-transcript mutually exclusive\\n156: \\tcmd.MarkFlagsMutuallyExclusive(\\\"short\\\", \\\"full\\\", \\\"raw-transcript\\\")\\n157: \\t// --generate and --raw-transcript are incompatible (summary would be generated but not shown)\\n158: \\tcmd.MarkFlagsMutuallyExclusive(\\\"generate\\\", \\\"raw-transcript\\\")\\n159: \\n160: \\treturn cmd\\n161: }\\n162: \\n163: // runExplain routes to the appropriate explain function based on flags.\\n164: func runExplain(ctx context.Context, w, errW io.Writer, sessionID, commitRef, checkpointID string, noPager, verbose, full, rawTranscript, generate, force, searchAll bool) error {\\n165: \\t// Count mutually exclusive flags (--commit and --checkpoint are mutually exclusive)\\n166: \\t// --session is now a filter for the list view, not a separate mode\\n167: \\tflagCount := 0\\n168: \\tif commitRef != \\\"\\\" {\\n169: \\t\\tflagCount++\\n170: \\t}\\n171: \\tif checkpointID != \\\"\\\" {\\n172: \\t\\tflagCount++\\n173: \\t}\\n174: \\t// If --session is combined with --commit or --checkpoint, that's still an error\\n175: \\tif sessionID != \\\"\\\" && flagCount > 0 {\\n176: \\t\\treturn errors.New(\\\"cannot specify multiple of --session, --commit, --checkpoint\\\")\\n177: \\t}\\n178: \\tif flagCount > 1 {\\n179: \\t\\treturn errors.New(\\\"cannot specify multiple of --session, --commit, --checkpoint\\\")\\n180: \\t}\\n181: \\n182: \\t// Route to appropriate handler\\n183: \\tif commitRef != \\\"\\\" {\\n184: \\t\\treturn runExplainCommit(ctx, w, commitRef, noPager, verbose, full, searchAll)\\n185: \\t}\\n186: \\tif checkpointID != \\\"\\\" {\\n187: \\t\\treturn runExplainCheckpoint(ctx, w, errW, checkpointID, noPager, verbose, full, rawTranscript, generate, force, searchAll)\\n188: \\t}\\n189: \\n190: \\t// Default or with session filter: show list view (optionally filtered by session)\\n191: \\treturn runExplainBranchWithFilter(ctx, w, noPager, sessionID)\\n192: }\\n193: \\n194: // runExplainCheckpoint explains a specific checkpoint.\\n195: // Supports both committed checkpoints (by checkpoint ID) and temporary checkpoints (by git SHA).\\n196: // First tries to match committed checkpoints, then falls back to temporary checkpoints.\\n197: // When generate is true, generates an AI summary for the checkpoint.\\n198: // When force is true, regenerates even if a summary already exists.\\n199: // When rawTranscript is true, outputs only the raw transcript file (JSONL format).\\n200: // When searchAll is true, searches all commits without branch/depth limits (used for finding associated commits).\\n201: func runExplainCheckpoint(ctx context.Context, w, errW io.Writer, checkpointIDPrefix string, noPager, verbose, full, rawTranscript, generate, force, searchAll bool) error {\\n202: \\trepo, err := openRepository(ctx)\\n203: \\tif err != nil {\\n204: \\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n205: \\t}\\n206: \\n207: \\tstore := checkpoint.NewGitStore(repo)\\n208: \\n209: \\t// First, try to find in committed checkpoints by checkpoint ID prefix\\n210: \\tcommitted, err := store.ListCommitted(ctx)\\n211: \\tif err != nil {\\n212: \\t\\treturn fmt.Errorf(\\\"failed to list checkpoints: %w\\\", err)\\n213: \\t}\\n214: \\n215: \\t// Collect all matching checkpoint IDs to detect ambiguity\\n216: \\tvar matches []id.CheckpointID\\n217: \\tfor _, info := range committed {\\n218: \\t\\tif strings.HasPrefix(info.CheckpointID.String(), checkpointIDPrefix) {\\n219: \\t\\t\\tmatches = append(matches, info.CheckpointID)\\n220: \\t\\t}\\n221: \\t}\\n222: \\n223: \\tvar fullCheckpointID id.CheckpointID\\n224: \\tswitch len(matches) {\\n225: \\tcase 0:\\n226: \\t\\t// Not found in committed, try temporary checkpoints by git SHA\\n227: \\t\\tif generate {\\n228: \\t\\t\\treturn fmt.Errorf(\\\"cannot generate summary for temporary checkpoint %s (only committed checkpoints supported)\\\", checkpointIDPrefix)\\n229: \\t\\t}\\n230: \\t\\toutput, found := explainTemporaryCheckpoint(ctx, w, repo, store, checkpointIDPrefix, verbose, full, rawTranscript)\\n231: \\t\\tif found {\\n232: \\t\\t\\toutputExplainContent(w, output, noPager)\\n233: \\t\\t\\treturn nil\\n234: \\t\\t}\\n235: \\t\\t// If output is non-empty, it contains an error message (e.g., ambiguous prefix)\\n236: \\t\\tif output != \\\"\\\" {\\n237: \\t\\t\\treturn errors.New(output)\\n238: \\t\\t}\\n239: \\t\\treturn fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointIDPrefix)\\n240: \\tcase 1:\\n241: \\t\\tfullCheckpointID = matches[0]\\n242: \\tdefault:\\n243: \\t\\t// Ambiguous prefix - show up to 5 examples\\n244: \\t\\texamples := make([]string, 0, 5)\\n245: \\t\\tfor i := 0; i < len(matches) && i < 5; i++ {\\n246: \\t\\t\\texamples = append(examples, matches[i].String())\\n247: \\t\\t}\\n248: \\t\\treturn fmt.Errorf(\\\"ambiguous checkpoint prefix %q matches %d checkpoints: %s\\\", checkpointIDPrefix, len(matches), strings.Join(examples, \\\", \\\"))\\n249: \\t}\\n250: \\n251: \\t// Load checkpoint summary\\n252: \\tsummary, err := store.ReadCommitted(ctx, fullCheckpointID)\\n253: \\tif err != nil {\\n254: \\t\\treturn fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n255: \\t}\\n256: \\tif summary == nil {\\n257: \\t\\treturn fmt.Errorf(\\\"checkpoint not found: %s\\\", fullCheckpointID)\\n258: \\t}\\n259: \\n260: \\t// Load latest session content (needed for transcript and metadata)\\n261: \\tcontent, err := store.ReadLatestSessionContent(ctx, fullCheckpointID)\\n262: \\tif err != nil {\\n263: \\t\\treturn fmt.Errorf(\\\"failed to read checkpoint content: %w\\\", err)\\n264: \\t}\\n265: \\n266: \\t// Handle summary generation\\n267: \\tif generate {\\n268: \\t\\tif err := generateCheckpointSummary(ctx, w, errW, store, fullCheckpointID, summary, content, force); err != nil {\\n269: \\t\\t\\treturn err\\n270: \\t\\t}\\n271: \\t\\t// Reload the content to get the updated summary\\n272: \\t\\tcontent, err = store.ReadLatestSessionContent(ctx, fullCheckpointID)\\n273: \\t\\tif err != nil {\\n274: \\t\\t\\treturn fmt.Errorf(\\\"failed to reload checkpoint: %w\\\", err)\\n275: \\t\\t}\\n276: \\t}\\n277: \\n278: \\t// Handle raw transcript output\\n279: \\tif rawTranscript {\\n280: \\t\\tif len(content.Transcript) == 0 {\\n281: \\t\\t\\treturn fmt.Errorf(\\\"checkpoint %s has no transcript\\\", fullCheckpointID)\\n282: \\t\\t}\\n283: \\t\\t// Output raw transcript directly (no pager, no formatting)\\n284: \\t\\tif _, err = w.Write(content.Transcript); err != nil {\\n285: \\t\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n286: \\t\\t}\\n287: \\t\\treturn nil\\n288: \\t}\\n289: \\n290: \\t// Find associated commits (git commits with matching Entire-Checkpoint trailer)\\n291: \\tassociatedCommits, _ := getAssociatedCommits(ctx, repo, fullCheckpointID, searchAll) //nolint:errcheck // Best-effort\\n292: \\n293: \\t// Derive author from the first associated commit (the user who made the commit).\\n294: \\t// Fall back to GetCheckpointAuthor (walks entire/checkpoints/v1) for checkpoints\\n295: \\t// not reachable from the current branch.\\n296: \\tvar author checkpoint.Author\\n297: \\tif len(associatedCommits) > 0 {\\n298: \\t\\tauthor = checkpoint.Author{\\n299: \\t\\t\\tName:  associatedCommits[0].Author,\\n300: \\t\\t\\tEmail: associatedCommits[0].Email,\\n301: \\t\\t}\\n302: \\t} else {\\n303: \\t\\tauthor, _ = store.GetCheckpointAuthor(ctx, fullCheckpointID) //nolint:errcheck // Author is optional\\n304: \\t}\\n305: \\n306: \\t// Format and output\\n307: \\toutput := formatCheckpointOutput(summary, content, fullCheckpointID, associatedCommits, author, verbose, full)\\n308: \\toutputExplainContent(w, output, noPager)\\n309: \\treturn nil\\n310: }\\n311: \\n312: // generateCheckpointSummary generates an AI summary for a checkpoint and persists it.\\n313: // The summary is generated from the scoped transcript (only this checkpoint's portion),\\n314: // not the entire session transcript.\\n315: func generateCheckpointSummary(ctx context.Context, w, _ io.Writer, store *checkpoint.GitStore, checkpointID id.CheckpointID, cpSummary *checkpoint.CheckpointSummary, content *checkpoint.SessionContent, force bool) error {\\n316: \\t// Check if summary already exists\\n317: \\tif content.Metadata.Summary != nil && !force {\\n318: \\t\\treturn fmt.Errorf(\\\"checkpoint %s already has a summary (use --force to regenerate)\\\", checkpointID)\\n319: \\t}\\n320: \\n321: \\t// Check if transcript exists\\n322: \\tif len(content.Transcript) == 0 {\\n323: \\t\\treturn fmt.Errorf(\\\"checkpoint %s has no transcript to summarize\\\", checkpointID)\\n324: \\t}\\n325: \\n326: \\t// Scope the transcript to only this checkpoint's portion\\n327: \\tscopedTranscript := scopeTranscriptForCheckpoint(content.Transcript, content.Metadata.GetTranscriptStart(), content.Metadata.Agent)\\n328: \\tif len(scopedTranscript) == 0 {\\n329: \\t\\treturn fmt.Errorf(\\\"checkpoint %s has no transcript content for this checkpoint (scoped)\\\", checkpointID)\\n330: \\t}\\n331: \\n332: \\t// Generate summary using shared helper\\n333: \\tlogging.Info(ctx, \\\"generating checkpoint summary\\\")\\n334: \\n335: \\tsummary, err := summarize.GenerateFromTranscript(ctx, scopedTranscript, cpSummary.FilesTouched, content.Metadata.Agent, nil)\\n336: \\tif err != nil {\\n337: \\t\\treturn fmt.Errorf(\\\"failed to generate summary: %w\\\", err)\\n338: \\t}\\n339: \\n340: \\t// Persist the summary\\n341: \\tif err := store.UpdateSummary(ctx, checkpointID, summary); err != nil {\\n342: \\t\\treturn fmt.Errorf(\\\"failed to save summary: %w\\\", err)\\n343: \\t}\\n344: \\n345: \\tfmt.Fprintln(w, \\\"✓ Summary generated and saved\\\")\\n346: \\treturn nil\\n347: }\\n348: \\n349: // explainTemporaryCheckpoint finds and formats a temporary checkpoint by shadow commit hash prefix.\\n350: // Returns the formatted output and whether the checkpoint was found.\\n351: // Searches ALL shadow branches, not just the one for current HEAD, to find checkpoints\\n352: // created from different base commits (e.g., if HEAD advanced since session start).\\n353: // The writer w is used for raw transcript output to bypass the pager.\\n354: func explainTemporaryCheckpoint(ctx context.Context, w io.Writer, repo *git.Repository, store *checkpoint.GitStore, shaPrefix string, verbose, full, rawTranscript bool) (string, bool) {\\n355: \\t// List temporary checkpoints from ALL shadow branches\\n356: \\t// This ensures we find checkpoints even if HEAD has advanced since the session started\\n357: \\ttempCheckpoints, err := store.ListAllTemporaryCheckpoints(ctx, \\\"\\\", branchCheckpointsLimit)\\n358: \\tif err != nil {\\n359: \\t\\treturn \\\"\\\", false\\n360: \\t}\\n361: \\n362: \\t// Find checkpoints matching the SHA prefix - check for ambiguity\\n363: \\tvar matches []checkpoint.TemporaryCheckpointInfo\\n364: \\tfor _, tc := range tempCheckpoints {\\n365: \\t\\tif strings.HasPrefix(tc.CommitHash.String(), shaPrefix) {\\n366: \\t\\t\\tmatches = append(matches, tc)\\n367: \\t\\t}\\n368: \\t}\\n369: \\n370: \\tif len(matches) == 0 {\\n371: \\t\\treturn \\\"\\\", false\\n372: \\t}\\n373: \\n374: \\tif len(matches) > 1 {\\n375: \\t\\t// Multiple matches - return ambiguous error (consistent with committed checkpoint behavior)\\n376: \\t\\tvar sb strings.Builder\\n377: \\t\\tfmt.Fprintf(&sb, \\\"ambiguous checkpoint prefix %q matches %d temporary checkpoints:\\\\n\\\", shaPrefix, len(matches))\\n378: \\t\\tfor _, m := range matches {\\n379: \\t\\t\\tshortID := m.CommitHash.String()[:7]\\n380: \\t\\t\\tfmt.Fprintf(&sb, \\\"  %s  %s  session %s\\\\n\\\",\\n381: \\t\\t\\t\\tshortID,\\n382: \\t\\t\\t\\tm.Timestamp.Format(\\\"2006-01-02 15:04:05\\\"),\\n383: \\t\\t\\t\\tm.SessionID)\\n384: \\t\\t}\\n385: \\t\\t// Return as \\\"not found\\\" with error message - caller will use this as error\\n386: \\t\\treturn sb.String(), false\\n387: \\t}\\n388: \\n389: \\ttc := matches[0]\\n390: \\n391: \\t// Get shadow commit and tree to read metadata\\n392: \\tshadowCommit, commitErr := repo.CommitObject(tc.CommitHash)\\n393: \\tif commitErr != nil {\\n394: \\t\\treturn \\\"\\\", false\\n395: \\t}\\n396: \\n397: \\tshadowTree, treeErr := shadowCommit.Tree()\\n398: \\tif treeErr != nil {\\n399: \\t\\treturn \\\"\\\", false\\n400: \\t}\\n401: \\n402: \\t// Read agent type from shadow branch metadata (stored during checkpoint creation)\\n403: \\tagentType := strategy.ReadAgentTypeFromTree(shadowTree, tc.MetadataDir)\\n404: \\n405: \\t// Handle raw transcript output\\n406: \\tif rawTranscript {\\n407: \\t\\ttranscriptBytes, transcriptErr := store.GetTranscriptFromCommit(ctx, tc.CommitHash, tc.MetadataDir, agentType)\\n408: \\t\\tif transcriptErr != nil || len(transcriptBytes) == 0 {\\n409: \\t\\t\\t// Return specific error message (consistent with committed checkpoints)\\n410: \\t\\t\\treturn fmt.Sprintf(\\\"checkpoint %s has no transcript\\\", tc.CommitHash.String()[:7]), false\\n411: \\t\\t}\\n412: \\t\\t// Write directly to writer (no pager, no formatting) - matches committed checkpoint behavior\\n413: \\t\\tif _, writeErr := fmt.Fprint(w, string(transcriptBytes)); writeErr != nil {\\n414: \\t\\t\\treturn fmt.Sprintf(\\\"failed to write transcript: %v\\\", writeErr), false\\n415: \\t\\t}\\n416: \\t\\treturn \\\"\\\", true\\n417: \\t}\\n418: \\n419: \\t// Read prompts from shadow branch\\n420: \\tsessionPrompt := strategy.ReadSessionPromptFromTree(shadowTree, tc.MetadataDir)\\n421: \\n422: \\t// Build output similar to formatCheckpointOutput but for temporary\\n423: \\tvar sb strings.Builder\\n424: \\tshortID := tc.CommitHash.String()[:7]\\n425: \\tfmt.Fprintf(&sb, \\\"Checkpoint: %s [temporary]\\\\n\\\", shortID)\\n426: \\tfmt.Fprintf(&sb, \\\"Session: %s\\\\n\\\", tc.SessionID)\\n427: \\tfmt.Fprintf(&sb, \\\"Created: %s\\\\n\\\", tc.Timestamp.Format(\\\"2006-01-02 15:04:05\\\"))\\n428: \\tsb.WriteString(\\\"\\\\n\\\")\\n429: \\n430: \\t// Intent from prompt\\n431: \\tintent := \\\"(not available)\\\"\\n432: \\tif sessionPrompt != \\\"\\\" {\\n433: \\t\\tlines := strings.Split(sessionPrompt, \\\"\\\\n\\\")\\n434: \\t\\tif len(lines) > 0 && lines[0] != \\\"\\\" {\\n435: \\t\\t\\tintent = strategy.TruncateDescription(lines[0], maxIntentDisplayLength)\\n436: \\t\\t}\\n437: \\t}\\n438: \\tfmt.Fprintf(&sb, \\\"Intent: %s\\\\n\\\", intent)\\n439: \\tsb.WriteString(\\\"Outcome: (not generated)\\\\n\\\")\\n440: \\n441: \\t// Transcript section: full shows entire session, verbose shows checkpoint scope\\n442: \\t// For temporary checkpoints, load transcript and compute scope from parent commit\\n443: \\tvar fullTranscript []byte\\n444: \\tvar scopedTranscript []byte\\n445: \\tif full || verbose {\\n446: \\t\\tfullTranscript, _ = store.GetTranscriptFromCommit(ctx, tc.CommitHash, tc.MetadataDir, agentType) //nolint:errcheck // Best-effort\\n447: \\n448: \\t\\tif verbose && len(fullTranscript) > 0 {\\n449: \\t\\t\\t// Compute scoped transcript by finding where parent's transcript ended\\n450: \\t\\t\\t// Each shadow branch commit has the full transcript up to that point,\\n451: \\t\\t\\t// so we diff against parent to get just this checkpoint's activity\\n452: \\t\\t\\tscopedTranscript = fullTranscript // Default to full if no parent\\n453: \\t\\t\\tif shadowCommit.NumParents() > 0 {\\n454: \\t\\t\\t\\tif parent, parentErr := shadowCommit.Parent(0); parentErr == nil {\\n455: \\t\\t\\t\\t\\tparentTranscript, _ := store.GetTranscriptFromCommit(ctx, parent.Hash, tc.MetadataDir, agentType) //nolint:errcheck // Best-effort\\n456: \\t\\t\\t\\t\\tif len(parentTranscript) > 0 {\\n457: \\t\\t\\t\\t\\t\\tparentOffset := transcriptOffset(parentTranscript, agentType)\\n458: \\t\\t\\t\\t\\t\\tscopedTranscript = scopeTranscriptForCheckpoint(fullTranscript, parentOffset, agentType)\\n459: \\t\\t\\t\\t\\t}\\n460: \\t\\t\\t\\t}\\n461: \\t\\t\\t}\\n462: \\t\\t}\\n463: \\t}\\n464: \\tappendTranscriptSection(&sb, verbose, full, fullTranscript, scopedTranscript, sessionPrompt, agentType)\\n465: \\n466: \\treturn sb.String(), true\\n467: }\\n468: \\n469: // getAssociatedCommits finds git commits that reference the given checkpoint ID.\\n470: // Searches commits on the current branch for Entire-Checkpoint trailer matches.\\n471: // When searchAll is true, uses full DAG walk with no depth limit (may be slow).\\n472: // This finds checkpoint commits on merged feature branches (second parents of merges).\\n473: func getAssociatedCommits(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID, searchAll bool) ([]associatedCommit, error) {\\n474: \\thead, err := repo.Head()\\n475: \\tif err != nil {\\n476: \\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n477: \\t}\\n478: \\n479: \\tcommits := []associatedCommit{} // Initialize as empty slice, not nil (nil means \\\"not searched\\\")\\n480: \\ttargetID := checkpointID.String()\\n481: \\n482: \\tcollectCommit := func(c *object.Commit) {\\n483: \\t\\tfullSHA := c.Hash.String()\\n484: \\t\\tshortSHA := fullSHA\\n485: \\t\\tif len(fullSHA) >= 7 {\\n486: \\t\\t\\tshortSHA = fullSHA[:7]\\n487: \\t\\t}\\n488: \\t\\tcommits = append(commits, associatedCommit{\\n489: \\t\\t\\tSHA:      fullSHA,\\n490: \\t\\t\\tShortSHA: shortSHA,\\n491: \\t\\t\\tMessage:  strings.Split(c.Message, \\\"\\\\n\\\")[0],\\n492: \\t\\t\\tAuthor:   c.Author.Name,\\n493: \\t\\t\\tEmail:    c.Author.Email,\\n494: \\t\\t\\tDate:     c.Author.When,\\n495: \\t\\t})\\n496: \\t}\\n497: \\n498: \\tif searchAll {\\n499: \\t\\t// Full DAG walk: follows all parents of merge commits, no depth limit.\\n500: \\t\\t// This finds checkpoint commits on merged feature branches.\\n501: \\t\\titer, iterErr := repo.Log(&git.LogOptions{\\n502: \\t\\t\\tFrom:  head.Hash(),\\n503: \\t\\t\\tOrder: git.LogOrderCommitterTime,\\n504: \\t\\t})\\n505: \\t\\tif iterErr != nil {\\n506: \\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", iterErr)\\n507: \\t\\t}\\n508: \\t\\tdefer iter.Close()\\n509: \\n510: \\t\\terr = iter.ForEach(func(c *object.Commit) error {\\n511: \\t\\t\\tif err := ctx.Err(); err != nil {\\n512: \\t\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n513: \\t\\t\\t}\\n514: \\t\\t\\tcpID, found := trailers.ParseCheckpoint(c.Message)\\n515: \\t\\t\\tif found && cpID.String() == targetID {\\n516: \\t\\t\\t\\tcollectCommit(c)\\n517: \\t\\t\\t}\\n518: \\t\\t\\treturn nil\\n519: \\t\\t})\\n520: \\t} else {\\n521: \\t\\t// First-parent walk with depth limit and branch filtering.\\n522: \\t\\t// Avoids walking into main's history through merge commit parents.\\n523: \\t\\treachableFromMain := computeReachableFromMain(ctx, repo)\\n524: \\n525: \\t\\terr = walkFirstParentCommits(ctx, repo, head.Hash(), commitScanLimit, func(c *object.Commit) error {\\n526: \\t\\t\\t// Once we hit a commit reachable from main on the first-parent chain,\\n527: \\t\\t\\t// all earlier ancestors are also shared-with-main, so stop scanning.\\n528: \\t\\t\\tif reachableFromMain[c.Hash] {\\n529: \\t\\t\\t\\treturn errStopIteration\\n530: \\t\\t\\t}\\n531: \\n532: \\t\\t\\tcpID, found := trailers.ParseCheckpoint(c.Message)\\n533: \\t\\t\\tif found && cpID.String() == targetID {\\n534: \\t\\t\\t\\tcollectCommit(c)\\n535: \\t\\t\\t}\\n536: \\t\\t\\treturn nil\\n537: \\t\\t})\\n538: \\t}\\n539: \\n540: \\tif err != nil {\\n541: \\t\\treturn nil, fmt.Errorf(\\\"error iterating commits: %w\\\", err)\\n542: \\t}\\n543: \\n544: \\treturn commits, nil\\n545: }\\n546: \\n547: // scopeTranscriptForCheckpoint slices a transcript to include only the portion\\n548: // relevant to a specific checkpoint, starting from the given offset.\\n549: // For Claude Code (JSONL), the offset is a line number and we slice by line.\\n550: // For Gemini (single JSON blob), the offset is a message index and we slice by message.\\n551: func scopeTranscriptForCheckpoint(fullTranscript []byte, startOffset int, agentType types.AgentType) []byte {\\n552: \\tswitch agentType {\\n553: \\tcase agent.AgentTypeGemini:\\n554: \\t\\tscoped, err := geminicli.SliceFromMessage(fullTranscript, startOffset)\\n555: \\t\\tif err != nil {\\n556: \\t\\t\\treturn nil\\n557: \\t\\t}\\n558: \\t\\treturn scoped\\n559: \\tcase agent.AgentTypeOpenCode:\\n560: \\t\\tscoped, err := opencode.SliceFromMessage(fullTranscript, startOffset)\\n561: \\t\\tif err != nil {\\n562: \\t\\t\\treturn nil\\n563: \\t\\t}\\n564: \\t\\treturn scoped\\n565: \\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeFactoryAIDroid, agent.AgentTypeUnknown:\\n566: \\t\\treturn transcript.SliceFromLine(fullTranscript, startOffset)\\n567: \\t}\\n568: \\treturn transcript.SliceFromLine(fullTranscript, startOffset)\\n569: }\\n570: \\n571: // extractPromptsFromTranscript extracts user prompts from transcript bytes.\\n572: // Returns a slice of prompt strings.\\n573: func extractPromptsFromTranscript(transcriptBytes []byte, agentType types.AgentType) []string {\\n574: \\tif len(transcriptBytes) == 0 {\\n575: \\t\\treturn nil\\n576: \\t}\\n577: \\n578: \\tcondensed, err := summarize.BuildCondensedTranscriptFromBytes(transcriptBytes, agentType)\\n579: \\tif err != nil {\\n580: \\t\\treturn nil\\n581: \\t}\\n582: \\n583: \\tvar prompts []string\\n584: \\tfor _, entry := range condensed {\\n585: \\t\\tif entry.Type == summarize.EntryTypeUser && entry.Content != \\\"\\\" {\\n586: \\t\\t\\tprompts = append(prompts, entry.Content)\\n587: \\t\\t}\\n588: \\t}\\n589: \\treturn prompts\\n590: }\\n591: \\n592: // formatCheckpointOutput formats checkpoint data based on verbosity level.\\n593: // When verbose is false: summary only (ID, session, timestamp, tokens, intent).\\n594: // When verbose is true: adds files, associated commits, and scoped transcript for this checkpoint.\\n595: // When full is true: shows parsed full session transcript instead of scoped transcript.\\n596: //\\n597: // Transcript scope is controlled by CheckpointTranscriptStart in metadata, which indicates\\n598: // where this checkpoint's content begins in the full session transcript.\\n599: //\\n600: // Author is displayed when available (only for committed checkpoints).\\n601: // Associated commits are git commits that reference this checkpoint via Entire-Checkpoint trailer.\\n602: func formatCheckpointOutput(summary *checkpoint.CheckpointSummary, content *checkpoint.SessionContent, checkpointID id.CheckpointID, associatedCommits []associatedCommit, author checkpoint.Author, verbose, full bool) string {\\n603: \\tvar sb strings.Builder\\n604: \\tmeta := content.Metadata\\n605: \\n606: \\t// Scope the transcript to this checkpoint's portion\\n607: \\t// If CheckpointTranscriptStart > 0, we slice the transcript to only include\\n608: \\t// content from that point onwards (excluding earlier checkpoint content)\\n609: \\tscopedTranscript := scopeTranscriptForCheckpoint(content.Transcript, meta.GetTranscriptStart(), meta.Agent)\\n610: \\n611: \\t// Extract prompts from the scoped transcript for intent extraction\\n612: \\tscopedPrompts := extractPromptsFromTranscript(scopedTranscript, meta.Agent)\\n613: \\n614: \\t// Header - always shown\\n615: \\t// Note: CheckpointID is always exactly 12 characters, matching checkpointIDDisplayLength\\n616: \\tfmt.Fprintf(&sb, \\\"Checkpoint: %s\\\\n\\\", checkpointID)\\n617: \\tfmt.Fprintf(&sb, \\\"Session: %s\\\\n\\\", meta.SessionID)\\n618: \\tfmt.Fprintf(&sb, \\\"Created: %s\\\\n\\\", meta.CreatedAt.Format(\\\"2006-01-02 15:04:05\\\"))\\n619: \\n620: \\t// Author (only for committed checkpoints with known author)\\n621: \\tif author.Name != \\\"\\\" {\\n622: \\t\\tfmt.Fprintf(&sb, \\\"Author: %s <%s>\\\\n\\\", author.Name, author.Email)\\n623: \\t}\\n624: \\n625: \\t// Token usage - prefer content metadata, fall back to summary\\n626: \\ttokenUsage := meta.TokenUsage\\n627: \\tif tokenUsage == nil && summary != nil {\\n628: \\t\\ttokenUsage = summary.TokenUsage\\n629: \\t}\\n630: \\tif tokenUsage != nil {\\n631: \\t\\ttotalTokens := tokenUsage.InputTokens + tokenUsage.CacheCreationTokens +\\n632: \\t\\t\\ttokenUsage.CacheReadTokens + tokenUsage.OutputTokens\\n633: \\t\\tfmt.Fprintf(&sb, \\\"Tokens: %d\\\\n\\\", totalTokens)\\n634: \\t}\\n635: \\n636: \\t// Associated commits section\\n637: \\tif len(associatedCommits) > 0 {\\n638: \\t\\tsb.WriteString(\\\"\\\\n\\\")\\n639: \\t\\tfmt.Fprintf(&sb, \\\"Commits: (%d)\\\\n\\\", len(associatedCommits))\\n640: \\t\\tfor _, c := range associatedCommits {\\n641: \\t\\t\\tfmt.Fprintf(&sb, \\\"  %s %s %s\\\\n\\\", c.ShortSHA, c.Date.Format(\\\"2006-01-02\\\"), c.Message)\\n642: \\t\\t}\\n643: \\t} else if associatedCommits != nil {\\n644: \\t\\t// associatedCommits is non-nil but empty - show \\\"no commits found\\\" message\\n645: \\t\\tsb.WriteString(\\\"\\\\nCommits: No commits found on this branch\\\\n\\\")\\n646: \\t}\\n647: \\n648: \\tsb.WriteString(\\\"\\\\n\\\")\\n649: \\n650: \\t// Intent and Outcome from AI summary, or fallback to prompt text\\n651: \\tif meta.Summary != nil {\\n652: \\t\\tfmt.Fprintf(&sb, \\\"Intent: %s\\\\n\\\", meta.Summary.Intent)\\n653: \\t\\tfmt.Fprintf(&sb, \\\"Outcome: %s\\\\n\\\", meta.Summary.Outcome)\\n654: \\t} else {\\n655: \\t\\t// Fallback: use first line of scoped prompts for intent,\\n656: \\t\\t// or fall back to result.Prompts for backwards compatibility with older checkpoints\\n657: \\t\\tintent := \\\"(not generated)\\\"\\n658: \\t\\tif len(scopedPrompts) > 0 && scopedPrompts[0] != \\\"\\\" {\\n659: \\t\\t\\tintent = strategy.TruncateDescription(scopedPrompts[0], maxIntentDisplayLength)\\n660: \\t\\t} else if content.Prompts != \\\"\\\" {\\n661: \\t\\t\\t// Backwards compatibility: use stored prompts if no transcript available\\n662: \\t\\t\\tlines := strings.Split(content.Prompts, \\\"\\\\n\\\")\\n663: \\t\\t\\tif len(lines) > 0 && lines[0] != \\\"\\\" {\\n664: \\t\\t\\t\\tintent = strategy.TruncateDescription(lines[0], maxIntentDisplayLength)\\n665: \\t\\t\\t}\\n666: \\t\\t}\\n667: \\t\\tfmt.Fprintf(&sb, \\\"Intent: %s\\\\n\\\", intent)\\n668: \\t\\tsb.WriteString(\\\"Outcome: (not generated)\\\\n\\\")\\n669: \\t}\\n670: \\n671: \\t// Verbose: add learnings, friction, files, and scoped transcript\\n672: \\tif verbose || full {\\n673: \\t\\t// AI Summary details (learnings, friction, open items)\\n674: \\t\\tif meta.Summary != nil {\\n675: \\t\\t\\tformatSummaryDetails(&sb, meta.Summary)\\n676: \\t\\t}\\n677: \\n678: \\t\\tsb.WriteString(\\\"\\\\n\\\")\\n679: \\n680: \\t\\t// Files section\\n681: \\t\\tif len(meta.FilesTouched) > 0 {\\n682: \\t\\t\\tfmt.Fprintf(&sb, \\\"Files: (%d)\\\\n\\\", len(meta.FilesTouched))\\n683: \\t\\t\\tfor _, file := range meta.FilesTouched {\\n684: \\t\\t\\t\\tfmt.Fprintf(&sb, \\\"  - %s\\\\n\\\", file)\\n685: \\t\\t\\t}\\n686: \\t\\t} else {\\n687: \\t\\t\\tsb.WriteString(\\\"Files: (none)\\\\n\\\")\\n688: \\t\\t}\\n689: \\t}\\n690: \\n691: \\t// Transcript section: full shows entire session, verbose shows checkpoint scope\\n692: \\tappendTranscriptSection(&sb, verbose, full, content.Transcript, scopedTranscript, content.Prompts, meta.Agent)\\n693: \\n694: \\treturn sb.String()\\n695: }\\n696: \\n697: // appendTranscriptSection appends the appropriate transcript section to the builder\\n698: // based on verbosity level. Full mode shows the entire session, verbose shows checkpoint scope.\\n699: // fullTranscript is the entire session transcript, scopedContent is either scoped transcript bytes\\n700: // or a pre-formatted string (for backwards compat), and scopedFallback is used when scoped parsing fails.\\n701: func appendTranscriptSection(sb *strings.Builder, verbose, full bool, fullTranscript, scopedTranscript []byte, scopedFallback string, agentType types.AgentType) {\\n702: \\tswitch {\\n703: \\tcase full:\\n704: \\t\\tsb.WriteString(\\\"\\\\n\\\")\\n705: \\t\\tsb.WriteString(\\\"Transcript (full session):\\\\n\\\")\\n706: \\t\\tsb.WriteString(formatTranscriptBytes(fullTranscript, \\\"\\\", agentType))\\n707: \\n708: \\tcase verbose:\\n709: \\t\\tsb.WriteString(\\\"\\\\n\\\")\\n710: \\t\\tsb.WriteString(\\\"Transcript (checkpoint scope):\\\\n\\\")\\n711: \\t\\tsb.WriteString(formatTranscriptBytes(scopedTranscript, scopedFallback, agentType))\\n712: \\t}\\n713: }\\n714: \\n715: // formatTranscriptBytes formats transcript bytes into a human-readable string.\\n716: // It parses the transcript (JSONL for Claude, JSON for Gemini) and formats it using the condensed format.\\n717: // The fallback is used for backwards compatibility when transcript parsing fails or is empty.\\n718: func formatTranscriptBytes(transcriptBytes []byte, fallback string, agentType types.AgentType) string {\\n719: \\tif len(transcriptBytes) == 0 {\\n720: \\t\\tif fallback != \\\"\\\" {\\n721: \\t\\t\\treturn fallback + \\\"\\\\n\\\"\\n722: \\t\\t}\\n723: \\t\\treturn \\\"  (none)\\\\n\\\"\\n724: \\t}\\n725: \\n726: \\tcondensed, err := summarize.BuildCondensedTranscriptFromBytes(transcriptBytes, agentType)\\n727: \\tif err != nil || len(condensed) == 0 {\\n728: \\t\\tif fallback != \\\"\\\" {\\n729: \\t\\t\\treturn fallback + \\\"\\\\n\\\"\\n730: \\t\\t}\\n731: \\t\\treturn \\\"  (failed to parse transcript)\\\\n\\\"\\n732: \\t}\\n733: \\n734: \\tinput := summarize.Input{Transcript: condensed}\\n735: \\treturn summarize.FormatCondensedTranscript(input)\\n736: }\\n737: \\n738: // formatSummaryDetails formats the detailed sections of an AI summary.\\n739: func formatSummaryDetails(sb *strings.Builder, summary *checkpoint.Summary) {\\n740: \\t// Learnings section\\n741: \\thasLearnings := len(summary.Learnings.Repo) > 0 ||\\n742: \\t\\tlen(summary.Learnings.Code) > 0 ||\\n743: \\t\\tlen(summary.Learnings.Workflow) > 0\\n744: \\n745: \\tif hasLearnings {\\n746: \\t\\tsb.WriteString(\\\"\\\\nLearnings:\\\\n\\\")\\n747: \\n748: \\t\\tif len(summary.Learnings.Repo) > 0 {\\n749: \\t\\t\\tsb.WriteString(\\\"  Repository:\\\\n\\\")\\n750: \\t\\t\\tfor _, learning := range summary.Learnings.Repo {\\n751: \\t\\t\\t\\tfmt.Fprintf(sb, \\\"    - %s\\\\n\\\", learning)\\n752: \\t\\t\\t}\\n753: \\t\\t}\\n754: \\n755: \\t\\tif len(summary.Learnings.Code) > 0 {\\n756: \\t\\t\\tsb.WriteString(\\\"  Code:\\\\n\\\")\\n757: \\t\\t\\tfor _, learning := range summary.Learnings.Code {\\n758: \\t\\t\\t\\tif learning.Line > 0 {\\n759: \\t\\t\\t\\t\\tif learning.EndLine > 0 {\\n760: \\t\\t\\t\\t\\t\\tfmt.Fprintf(sb, \\\"    - %s:%d-%d: %s\\\\n\\\", learning.Path, learning.Line, learning.EndLine, learning.Finding)\\n761: \\t\\t\\t\\t\\t} else {\\n762: \\t\\t\\t\\t\\t\\tfmt.Fprintf(sb, \\\"    - %s:%d: %s\\\\n\\\", learning.Path, learning.Line, learning.Finding)\\n763: \\t\\t\\t\\t\\t}\\n764: \\t\\t\\t\\t} else {\\n765: \\t\\t\\t\\t\\tfmt.Fprintf(sb, \\\"    - %s: %s\\\\n\\\", learning.Path, learning.Finding)\\n766: \\t\\t\\t\\t}\\n767: \\t\\t\\t}\\n768: \\t\\t}\\n769: \\n770: \\t\\tif len(summary.Learnings.Workflow) > 0 {\\n771: \\t\\t\\tsb.WriteString(\\\"  Workflow:\\\\n\\\")\\n772: \\t\\t\\tfor _, learning := range summary.Learnings.Workflow {\\n773: \\t\\t\\t\\tfmt.Fprintf(sb, \\\"    - %s\\\\n\\\", learning)\\n774: \\t\\t\\t}\\n775: \\t\\t}\\n776: \\t}\\n777: \\n778: \\t// Friction section\\n779: \\tif len(summary.Friction) > 0 {\\n780: \\t\\tsb.WriteString(\\\"\\\\nFriction:\\\\n\\\")\\n781: \\t\\tfor _, item := range summary.Friction {\\n782: \\t\\t\\tfmt.Fprintf(sb, \\\"  - %s\\\\n\\\", item)\\n783: \\t\\t}\\n784: \\t}\\n785: \\n786: \\t// Open items section\\n787: \\tif len(summary.OpenItems) > 0 {\\n788: \\t\\tsb.WriteString(\\\"\\\\nOpen Items:\\\\n\\\")\\n789: \\t\\tfor _, item := range summary.OpenItems {\\n790: \\t\\t\\tfmt.Fprintf(sb, \\\"  - %s\\\\n\\\", item)\\n791: \\t\\t}\\n792: \\t}\\n793: }\\n794: \\n795: // runExplainDefault shows all checkpoints on the current branch.\\n796: // This is the default view when no flags are provided.\\n797: func runExplainDefault(ctx context.Context, w io.Writer, noPager bool) error {\\n798: \\treturn runExplainBranchDefault(ctx, w, noPager)\\n799: }\\n800: \\n801: // branchCheckpointsLimit is the max checkpoints to show in branch view\\n802: const branchCheckpointsLimit = 100\\n803: \\n804: // commitScanLimit is how far back to scan git history for checkpoints\\n805: const commitScanLimit = 500\\n806: \\n807: // errStopIteration is used to stop commit iteration early\\n808: var errStopIteration = errors.New(\\\"stop iteration\\\")\\n809: \\n810: // getCurrentWorktreeHash returns the hashed worktree ID for the current working directory.\\n811: // This is used to filter shadow branches to only those belonging to this worktree.\\n812: func getCurrentWorktreeHash(ctx context.Context) string {\\n813: \\trepoRoot, err := paths.WorktreeRoot(ctx)\\n814: \\tif err != nil {\\n815: \\t\\treturn \\\"\\\"\\n816: \\t}\\n817: \\tworktreeID, err := paths.GetWorktreeID(repoRoot)\\n818: \\tif err != nil {\\n819: \\t\\treturn \\\"\\\"\\n820: \\t}\\n821: \\treturn checkpoint.HashWorktreeID(worktreeID)\\n822: }\\n823: \\n824: // computeReachableFromMain returns a set of commit hashes on the main/default branch's first-parent chain.\\n825: // On the default branch itself, returns an empty map (no filtering needed).\\n826: // Only first-parent commits are included — commits from side branches merged into main are excluded,\\n827: // since those could be feature branch commits that shouldn't be filtered out.\\n828: func computeReachableFromMain(ctx context.Context, repo *git.Repository) map[plumbing.Hash]bool {\\n829: \\treachableFromMain := make(map[plumbing.Hash]bool)\\n830: \\n831: \\tisOnDefault, _ := strategy.IsOnDefaultBranch(repo)\\n832: \\tif isOnDefault {\\n833: \\t\\treturn reachableFromMain // No filtering needed on default branch\\n834: \\t}\\n835: \\n836: \\t// Resolve main branch hash\\n837: \\tvar mainBranchHash plumbing.Hash\\n838: \\tif defaultBranchName := strategy.GetDefaultBranchName(repo); defaultBranchName != \\\"\\\" {\\n839: \\t\\tref, refErr := repo.Reference(plumbing.ReferenceName(\\\"refs/heads/\\\"+defaultBranchName), true)\\n840: \\t\\tif refErr != nil {\\n841: \\t\\t\\tref, refErr = repo.Reference(plumbing.ReferenceName(\\\"refs/remotes/origin/\\\"+defaultBranchName), true)\\n842: \\t\\t}\\n843: \\t\\tif refErr == nil {\\n844: \\t\\t\\tmainBranchHash = ref.Hash()\\n845: \\t\\t}\\n846: \\t}\\n847: \\tif mainBranchHash == plumbing.ZeroHash {\\n848: \\t\\tmainBranchHash = strategy.GetMainBranchHash(repo)\\n849: \\t}\\n850: \\tif mainBranchHash == plumbing.ZeroHash {\\n851: \\t\\treturn reachableFromMain\\n852: \\t}\\n853: \\n854: \\t// Walk main's first-parent chain to build the set\\n855: \\t_ = walkFirstParentCommits(ctx, repo, mainBranchHash, strategy.MaxCommitTraversalDepth, func(c *object.Commit) error { //nolint:errcheck // Best-effort\\n856: \\t\\treachableFromMain[c.Hash] = true\\n857: \\t\\treturn nil\\n858: \\t})\\n859: \\n860: \\treturn reachableFromMain\\n861: }\\n862: \\n863: // walkFirstParentCommits walks the first-parent chain starting from `from`,\\n864: // calling fn for each commit. It stops after visiting `limit` commits (0 = no limit).\\n865: // This avoids the full DAG traversal that repo.Log() does, which follows ALL parents\\n866: // of merge commits and can walk into unrelated branch history (e.g., main's full\\n867: // history after merging main into a feature branch).\\n868: func walkFirstParentCommits(ctx context.Context, repo *git.Repository, from plumbing.Hash, limit int, fn func(*object.Commit) error) error {\\n869: \\tcurrent, err := repo.CommitObject(from)\\n870: \\tif err != nil {\\n871: \\t\\treturn fmt.Errorf(\\\"failed to get commit %s: %w\\\", from, err)\\n872: \\t}\\n873: \\n874: \\tfor count := 0; limit <= 0 || count < limit; count++ {\\n875: \\t\\tif err := ctx.Err(); err != nil {\\n876: \\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n877: \\t\\t}\\n878: \\t\\tif err := fn(current); err != nil {\\n879: \\t\\t\\tif errors.Is(err, errStopIteration) {\\n880: \\t\\t\\t\\treturn nil\\n881: \\t\\t\\t}\\n882: \\t\\t\\treturn err\\n883: \\t\\t}\\n884: \\n885: \\t\\t// Follow first parent only (skip merge parents).\\n886: \\t\\t// When there are no parents or parent lookup fails, we've reached the\\n887: \\t\\t// end of the chain — this is a normal termination, not an error.\\n888: \\t\\tif current.NumParents() == 0 {\\n889: \\t\\t\\treturn nil\\n890: \\t\\t}\\n891: \\t\\tparentHash := current.Hash\\n892: \\t\\tcurrent, err = current.Parent(0)\\n893: \\t\\tif err != nil {\\n894: \\t\\t\\treturn fmt.Errorf(\\\"failed to load first parent of commit %s: %w\\\", parentHash, err)\\n895: \\t\\t}\\n896: \\t}\\n897: \\treturn nil\\n898: }\\n899: \\n900: // getBranchCheckpoints returns checkpoints relevant to the current branch.\\n901: // This is strategy-agnostic - it queries checkpoints directly from the checkpoint store.\\n902: //\\n903: // Behavior:\\n904: //   - On feature branches: only show checkpoints unique to this branch (not in main)\\n905: //   - On default branch (main/master): show all checkpoints in history (up to limit)\\n906: //   - Includes both committed checkpoints (entire/checkpoints/v1) and temporary checkpoints (shadow branches)\\n907: func getBranchCheckpoints(ctx context.Context, repo *git.Repository, limit int) ([]strategy.RewindPoint, error) {\\n908: \\t// Warn (once per process) if metadata branches are disconnected\\n909: \\tstrategy.WarnIfMetadataDisconnected()\\n910: \\n911: \\tstore := checkpoint.NewGitStore(repo)\\n912: \\n913: \\t// Get all committed checkpoints for lookup\\n914: \\tcommittedInfos, err := store.ListCommitted(ctx)\\n915: \\tif err != nil {\\n916: \\t\\tcommittedInfos = nil // Continue without committed checkpoints\\n917: \\t}\\n918: \\n919: \\t// Build map of checkpoint ID -> committed info\\n920: \\tcommittedByID := make(map[id.CheckpointID]checkpoint.CommittedInfo)\\n921: \\tfor _, info := range committedInfos {\\n922: \\t\\tif !info.CheckpointID.IsEmpty() {\\n923: \\t\\t\\tcommittedByID[info.CheckpointID] = info\\n924: \\t\\t}\\n925: \\t}\\n926: \\n927: \\thead, err := repo.Head()\\n928: \\tif err != nil {\\n929: \\t\\t// Unborn HEAD (no commits yet) - return empty list instead of erroring\\n930: \\t\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n931: \\t\\t\\treturn []strategy.RewindPoint{}, nil\\n932: \\t\\t}\\n933: \\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n934: \\t}\\n935: \\n936: \\t// Check if we're on the default branch (needed for getReachableTemporaryCheckpoints)\\n937: \\tisOnDefault, _ := strategy.IsOnDefaultBranch(repo)\\n938: \\n939: \\t// Fetch metadata branch tree once for reading session prompts (cheap tree lookups).\\n940: \\t// This avoids calling ReadLatestSessionContent per checkpoint which reads+parses\\n941: \\t// the full JSONL transcript — extremely slow with hundreds of checkpoints.\\n942: \\tmetadataTree, _ := strategy.GetMetadataBranchTree(repo) //nolint:errcheck // Best-effort, continue without prompts\\n943: \\n944: \\tvar points []strategy.RewindPoint\\n945: \\n946: \\tcollectCheckpoint := func(c *object.Commit) {\\n947: \\t\\tcpID, found := trailers.ParseCheckpoint(c.Message)\\n948: \\t\\tif !found {\\n949: \\t\\t\\treturn\\n950: \\t\\t}\\n951: \\t\\tcpInfo, found := committedByID[cpID]\\n952: \\t\\tif !found {\\n953: \\t\\t\\treturn\\n954: \\t\\t}\\n955: \\n956: \\t\\tmessage := strings.Split(c.Message, \\\"\\\\n\\\")[0]\\n957: \\t\\tpoint := strategy.RewindPoint{\\n958: \\t\\t\\tID:               c.Hash.String(),\\n959: \\t\\t\\tMessage:          message,\\n960: \\t\\t\\tDate:             c.Committer.When,\\n961: \\t\\t\\tIsLogsOnly:       true, // Committed checkpoints are logs-only\\n962: \\t\\t\\tCheckpointID:     cpID,\\n963: \\t\\t\\tSessionID:        cpInfo.SessionID,\\n964: \\t\\t\\tIsTaskCheckpoint: cpInfo.IsTask,\\n965: \\t\\t\\tToolUseID:        cpInfo.ToolUseID,\\n966: \\t\\t\\tAgent:            cpInfo.Agent,\\n967: \\t\\t}\\n968: \\t\\t// Read session prompt from metadata branch tree (best-effort).\\n969: \\t\\t// Read prompt.txt directly from the latest session subdirectory instead of\\n970: \\t\\t// parsing the full transcript — prompt.txt is tiny vs multi-MB transcripts.\\n971: \\t\\tif metadataTree != nil {\\n972: \\t\\t\\tpoint.SessionPrompt = strategy.ReadLatestSessionPromptFromCommittedTree(metadataTree, cpID, cpInfo.SessionCount)\\n973: \\t\\t}\\n974: \\n975: \\t\\tpoints = append(points, point)\\n976: \\t}\\n977: \\n978: \\tif isOnDefault {\\n979: \\t\\t// On the default branch, use full DAG walk to find checkpoint commits\\n980: \\t\\t// on merged feature branches (second parents of merge commits).\\n981: \\t\\titer, iterErr := repo.Log(&git.LogOptions{\\n982: \\t\\t\\tFrom:  head.Hash(),\\n983: \\t\\t\\tOrder: git.LogOrderCommitterTime,\\n984: \\t\\t})\\n985: \\t\\tif iterErr != nil {\\n986: \\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", iterErr)\\n987: \\t\\t}\\n988: \\t\\tdefer iter.Close()\\n989: \\n990: \\t\\tcount := 0\\n991: \\t\\terr = iter.ForEach(func(c *object.Commit) error {\\n992: \\t\\t\\tif err := ctx.Err(); err != nil {\\n993: \\t\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n994: \\t\\t\\t}\\n995: \\t\\t\\tif count >= commitScanLimit {\\n996: \\t\\t\\t\\treturn storer.ErrStop\\n997: \\t\\t\\t}\\n998: \\t\\t\\tcount++\\n999: \\t\\t\\tcollectCheckpoint(c)\\n1000: \\t\\t\\treturn nil\\n1001: \\t\\t})\\n1002: \\t} else {\\n1003: \\t\\t// On feature branches, use first-parent walk with branch filtering.\\n1004: \\t\\t// This avoids walking into main's full history through merge commit parents.\\n1005: \\t\\treachableFromMain := computeReachableFromMain(ctx, repo)\\n1006: \\n1007: \\t\\terr = walkFirstParentCommits(ctx, repo, head.Hash(), commitScanLimit, func(c *object.Commit) error {\\n1008: \\t\\t\\t// Once we hit a commit reachable from main on the first-parent chain,\\n1009: \\t\\t\\t// all earlier ancestors are also shared-with-main, so stop scanning.\\n1010: \\t\\t\\tif reachableFromMain[c.Hash] {\\n1011: \\t\\t\\t\\treturn errStopIteration\\n1012: \\t\\t\\t}\\n1013: \\t\\t\\tcollectCheckpoint(c)\\n1014: \\t\\t\\treturn nil\\n1015: \\t\\t})\\n1016: \\t}\\n1017: \\n1018: \\tif err != nil {\\n1019: \\t\\treturn nil, fmt.Errorf(\\\"error iterating commits: %w\\\", err)\\n1020: \\t}\\n1021: \\n1022: \\t// Get temporary checkpoints from ALL shadow branches whose base commit is reachable from HEAD.\\n1023: \\ttempPoints := getReachableTemporaryCheckpoints(ctx, repo, store, head.Hash(), isOnDefault, limit)\\n1024: \\tpoints = append(points, tempPoints...)\\n1025: \\n1026: \\t// Sort by date, most recent first\\n1027: \\tsort.Slice(points, func(i, j int) bool {\\n1028: \\t\\treturn points[i].Date.After(points[j].Date)\\n1029: \\t})\\n1030: \\n1031: \\t// Apply limit\\n1032: \\tif len(points) > limit {\\n1033: \\t\\tpoints = points[:limit]\\n1034: \\t}\\n1035: \\n1036: \\treturn points, nil\\n1037: }\\n1038: \\n1039: // getReachableTemporaryCheckpoints returns temporary checkpoints from shadow branches\\n1040: // whose base commit is reachable from the given HEAD hash and that belong to this worktree.\\n1041: // For default branches, all shadow branches for this worktree are included.\\n1042: // For feature branches, only shadow branches whose base commit is in HEAD's history are included.\\n1043: func getReachableTemporaryCheckpoints(ctx context.Context, repo *git.Repository, store *checkpoint.GitStore, headHash plumbing.Hash, isOnDefault bool, limit int) []strategy.RewindPoint {\\n1044: \\tvar points []strategy.RewindPoint\\n1045: \\n1046: \\t// Compute current worktree's hash for filtering shadow branches\\n1047: \\tcurrentWorktreeHash := getCurrentWorktreeHash(ctx)\\n1048: \\n1049: \\tshadowBranches, _ := store.ListTemporary(ctx) //nolint:errcheck // Best-effort\\n1050: \\tfor _, sb := range shadowBranches {\\n1051: \\t\\t// Filter by worktree: only show shadow branches belonging to this worktree.\\n1052: \\t\\t// Skip filtering if currentWorktreeHash is empty (error computing it) to avoid\\n1053: \\t\\t// accidentally filtering out ALL shadow branches.\\n1054: \\t\\t_, branchWorktreeHash, parsed := checkpoint.ParseShadowBranchName(sb.BranchName)\\n1055: \\t\\tif currentWorktreeHash != \\\"\\\" && parsed && branchWorktreeHash != \\\"\\\" && branchWorktreeHash != currentWorktreeHash {\\n1056: \\t\\t\\tcontinue\\n1057: \\t\\t}\\n1058: \\n1059: \\t\\t// Check if this shadow branch's base commit is reachable from current HEAD\\n1060: \\t\\tif !isShadowBranchReachable(ctx, repo, sb.BaseCommit, headHash, isOnDefault) {\\n1061: \\t\\t\\tcontinue\\n1062: \\t\\t}\\n1063: \\n1064: \\t\\t// List checkpoints from this shadow branch\\n1065: \\t\\ttempCheckpoints, _ := store.ListCheckpointsForBranch(ctx, sb.BranchName, \\\"\\\", limit) //nolint:errcheck // Best-effort\\n1066: \\t\\tfor _, tc := range tempCheckpoints {\\n1067: \\t\\t\\tpoint := convertTemporaryCheckpoint(repo, tc)\\n1068: \\t\\t\\tif point != nil {\\n1069: \\t\\t\\t\\tpoints = append(points, *point)\\n1070: \\t\\t\\t}\\n1071: \\t\\t}\\n1072: \\t}\\n1073: \\n1074: \\treturn points\\n1075: }\\n1076: \\n1077: // isShadowBranchReachable checks if a shadow branch's base commit is reachable from HEAD.\\n1078: // For default branches, all shadow branches are considered reachable.\\n1079: // For feature branches, we check if any commit with the base commit prefix is in HEAD's history.\\n1080: func isShadowBranchReachable(ctx context.Context, repo *git.Repository, baseCommit string, headHash plumbing.Hash, isOnDefault bool) bool {\\n1081: \\t// For default branch: all shadow branches are potentially relevant\\n1082: \\tif isOnDefault {\\n1083: \\t\\treturn true\\n1084: \\t}\\n1085: \\n1086: \\t// Check if base commit hash prefix matches any commit in HEAD's first-parent chain\\n1087: \\tfound := false\\n1088: \\t_ = walkFirstParentCommits(ctx, repo, headHash, commitScanLimit, func(c *object.Commit) error { //nolint:errcheck // Best-effort\\n1089: \\t\\tif strings.HasPrefix(c.Hash.String(), baseCommit) {\\n1090: \\t\\t\\tfound = true\\n1091: \\t\\t\\treturn errStopIteration\\n1092: \\t\\t}\\n1093: \\t\\treturn nil\\n1094: \\t})\\n1095: \\n1096: \\treturn found\\n1097: }\\n1098: \\n1099: // convertTemporaryCheckpoint converts a TemporaryCheckpointInfo to a RewindPoint.\\n1100: // Returns nil if the checkpoint should be skipped (no tree changes or can't be read).\\n1101: //\\n1102: // Filtering uses hasAnyChanges (O(1) tree hash comparison) rather than hasCodeChanges\\n1103: // (O(files) full diff). This means metadata-only checkpoints (.entire/ changes without\\n1104: // code changes) are kept — only true no-ops (identical tree as parent) are dropped.\\n1105: // This trade-off is intentional for list-view performance.\\n1106: func convertTemporaryCheckpoint(repo *git.Repository, tc checkpoint.TemporaryCheckpointInfo) *strategy.RewindPoint {\\n1107: \\tshadowCommit, commitErr := repo.CommitObject(tc.CommitHash)\\n1108: \\tif commitErr != nil {\\n1109: \\t\\treturn nil\\n1110: \\t}\\n1111: \\n1112: \\t// Skip no-op commits where the tree is identical to the parent's.\\n1113: \\t// Note: this keeps metadata-only changes (e.g. transcript updates in .entire/)\\n1114: \\t// since those produce a different tree hash. See hasAnyChanges godoc.\\n1115: \\tif !hasAnyChanges(shadowCommit) {\\n1116: \\t\\treturn nil\\n1117: \\t}\\n1118: \\n1119: \\t// Read session prompt from the shadow branch commit's tree (not from entire/checkpoints/v1)\\n1120: \\t// Temporary checkpoints store their metadata in the shadow branch, not in entire/checkpoints/v1\\n1121: \\tvar sessionPrompt string\\n1122: \\tshadowTree, treeErr := shadowCommit.Tree()\\n1123: \\tif treeErr == nil {\\n1124: \\t\\tsessionPrompt = strategy.ReadSessionPromptFromTree(shadowTree, tc.MetadataDir)\\n1125: \\t}\\n1126: \\n1127: \\treturn &strategy.RewindPoint{\\n1128: \\t\\tID:               tc.CommitHash.String(),\\n1129: \\t\\tMessage:          tc.Message,\\n1130: \\t\\tMetadataDir:      tc.MetadataDir,\\n1131: \\t\\tDate:             tc.Timestamp,\\n1132: \\t\\tIsTaskCheckpoint: tc.IsTaskCheckpoint,\\n1133: \\t\\tToolUseID:        tc.ToolUseID,\\n1134: \\t\\tSessionID:        tc.SessionID,\\n1135: \\t\\tSessionPrompt:    sessionPrompt,\\n1136: \\t\\tIsLogsOnly:       false, // Temporary checkpoints can be fully rewound\\n1137: \\t}\\n1138: }\\n1139: \\n1140: // runExplainBranchWithFilter shows checkpoints on the current branch, optionally filtered by session.\\n1141: // This is strategy-agnostic - it queries checkpoints directly.\\n1142: func runExplainBranchWithFilter(ctx context.Context, w io.Writer, noPager bool, sessionFilter string) error {\\n1143: \\trepo, err := openRepository(ctx)\\n1144: \\tif err != nil {\\n1145: \\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n1146: \\t}\\n1147: \\n1148: \\t// Get current branch name\\n1149: \\tbranchName := strategy.GetCurrentBranchName(repo)\\n1150: \\tif branchName == \\\"\\\" {\\n1151: \\t\\t// Detached HEAD state or unborn HEAD - try to use short commit hash if possible\\n1152: \\t\\thead, headErr := repo.Head()\\n1153: \\t\\tif headErr != nil {\\n1154: \\t\\t\\t// Unborn HEAD (no commits yet) - treat as empty history instead of erroring\\n1155: \\t\\t\\tif errors.Is(headErr, plumbing.ErrReferenceNotFound) {\\n1156: \\t\\t\\t\\tbranchName = \\\"HEAD (no commits yet)\\\"\\n1157: \\t\\t\\t} else {\\n1158: \\t\\t\\t\\treturn fmt.Errorf(\\\"failed to get HEAD: %w\\\", headErr)\\n1159: \\t\\t\\t}\\n1160: \\t\\t} else {\\n1161: \\t\\t\\tbranchName = \\\"HEAD (\\\" + head.Hash().String()[:7] + \\\")\\\"\\n1162: \\t\\t}\\n1163: \\t}\\n1164: \\n1165: \\t// Get checkpoints for this branch (strategy-agnostic)\\n1166: \\tpoints, err := getBranchCheckpoints(ctx, repo, branchCheckpointsLimit)\\n1167: \\tif err != nil {\\n1168: \\t\\t// If context was cancelled (e.g. user hit Ctrl+C), exit silently\\n1169: \\t\\tif ctx.Err() != nil {\\n1170: \\t\\t\\treturn NewSilentError(ctx.Err())\\n1171: \\t\\t}\\n1172: \\t\\t// Log the error but continue with empty list so user sees helpful message\\n1173: \\t\\tlogging.Warn(ctx, \\\"failed to get branch checkpoints\\\", \\\"error\\\", err)\\n1174: \\t\\tpoints = nil\\n1175: \\t}\\n1176: \\n1177: \\t// Format output\\n1178: \\toutput := formatBranchCheckpoints(branchName, points, sessionFilter)\\n1179: \\n1180: \\toutputExplainContent(w, output, noPager)\\n1181: \\treturn nil\\n1182: }\\n1183: \\n1184: // runExplainBranchDefault shows all checkpoints on the current branch grouped by date.\\n1185: // This is a convenience wrapper that calls runExplainBranchWithFilter with no filter.\\n1186: func runExplainBranchDefault(ctx context.Context, w io.Writer, noPager bool) error {\\n1187: \\treturn runExplainBranchWithFilter(ctx, w, noPager, \\\"\\\")\\n1188: }\\n1189: \\n1190: // outputExplainContent outputs content with optional pager support.\\n1191: func outputExplainContent(w io.Writer, content string, noPager bool) {\\n1192: \\tif noPager {\\n1193: \\t\\tfmt.Fprint(w, content)\\n1194: \\t} else {\\n1195: \\t\\toutputWithPager(w, content)\\n1196: \\t}\\n1197: }\\n1198: \\n1199: // runExplainCommit looks up the checkpoint associated with a commit.\\n1200: // Extracts the Entire-Checkpoint trailer and delegates to checkpoint detail view.\\n1201: // If no trailer found, shows a message indicating no associated checkpoint.\\n1202: func runExplainCommit(ctx context.Context, w io.Writer, commitRef string, noPager, verbose, full, searchAll bool) error {\\n1203: \\trepo, err := openRepository(ctx)\\n1204: \\tif err != nil {\\n1205: \\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n1206: \\t}\\n1207: \\n1208: \\t// Resolve the commit reference\\n1209: \\thash, err := repo.ResolveRevision(plumbing.Revision(commitRef))\\n1210: \\tif err != nil {\\n1211: \\t\\treturn fmt.Errorf(\\\"commit not found: %s\\\", commitRef)\\n1212: \\t}\\n1213: \\n1214: \\tcommit, err := repo.CommitObject(*hash)\\n1215: \\tif err != nil {\\n1216: \\t\\treturn fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n1217: \\t}\\n1218: \\n1219: \\t// Extract Entire-Checkpoint trailer\\n1220: \\tcheckpointID, hasCheckpoint := trailers.ParseCheckpoint(commit.Message)\\n1221: \\