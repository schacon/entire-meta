 \\t}\\n62: \\tdefer func() { _ = file.Close() }()\\n63: \\n64: \\tvar lines []Line\\n65: \\treader := bufio.NewReader(file)\\n66: \\n67: \\ttotalLines := 0\\n68: \\tfor {\\n69: \\t\\tlineBytes, err := reader.ReadBytes('\\\\n')\\n70: \\t\\tif err != nil && err != io.EOF {\\n71: \\t\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n72: \\t\\t}\\n73: \\n74: \\t\\t// Handle empty line or EOF without content\\n75: \\t\\tif len(lineBytes) == 0 {\\n76: \\t\\t\\tif err == io.EOF {\\n77: \\t\\t\\t\\tbreak\\n78: \\t\\t\\t}\\n79: \\t\\t\\tcontinue\\n80: \\t\\t}\\n81: \\n82: \\t\\t// Count all lines for totalLines, but only parse after startLine\\n83: \\t\\tif totalLines >= startLine {\\n84: \\t\\t\\tvar line Line\\n85: \\t\\t\\tif err := json.Unmarshal(lineBytes, &line); err == nil {\\n86: \\t\\t\\t\\tnormalizeLineType(&line)\\n87: \\t\\t\\t\\tlines = append(lines, line)\\n88: \\t\\t\\t}\\n89: \\t\\t}\\n90: \\t\\ttotalLines++\\n91: \\n92: \\t\\tif err == io.EOF {\\n93: \\t\\t\\tbreak\\n94: \\t\\t}\\n95: \\t}\\n96: \\n97: \\treturn lines, nil\\n98: }\\n99: \\n100: // normalizeLineType ensures line.Type is populated for all transcript formats.\\n101: // Claude Code uses \\\"type\\\" while Cursor uses \\\"role\\\" for the same purpose.\\n102: // When Type is empty but Role is set, we copy Role into Type so all downstream\\n103: // consumers can switch on Type uniformly.\\n104: func normalizeLineType(line *Line) {\\n105: \\tif line.Type == \\\"\\\" && line.Role != \\\"\\\" {\\n106: \\t\\tline.Type = line.Role\\n107: \\t}\\n108: }\\n109: \\n110: // SliceFromLine returns the content starting from line number `startLine` (0-indexed).\\n111: // This is used to extract only the checkpoint-specific portion of a cumulative transcript.\\n112: // For example, if startLine is 2, lines 0 and 1 are skipped and the result starts at line 2.\\n113: // Returns empty slice if startLine exceeds the number of lines.\\n114: func SliceFromLine(content []byte, startLine int) []byte {\\n115: \\tif len(content) == 0 || startLine <= 0 {\\n116: \\t\\treturn content\\n117: \\t}\\n118: \\n119: \\t// Find the byte offset where startLine begins\\n120: \\tlineCount := 0\\n121: \\toffset := 0\\n122: \\tfor i, b := range content {\\n123: \\t\\tif b == '\\\\n' {\\n124: \\t\\t\\tlineCount++\\n125: \\t\\t\\tif lineCount == startLine {\\n126: \\t\\t\\t\\toffset = i + 1\\n127: \\t\\t\\t\\tbreak\\n128: \\t\\t\\t}\\n129: \\t\\t}\\n130: \\t}\\n131: \\n132: \\t// If we didn't find enough lines, return empty\\n133: \\tif lineCount < startLine {\\n134: \\t\\treturn nil\\n135: \\t}\\n136: \\n137: \\t// If offset is beyond content, return empty\\n138: \\tif offset >= len(content) {\\n139: \\t\\treturn nil\\n140: \\t}\\n141: \\n142: \\treturn content[offset:]\\n143: }\\n144: \\n145: // ExtractUserContent extracts user content from a raw message.\\n146: // Handles both string and array content formats.\\n147: // IDE-injected context tags (like <ide_opened_file>) are stripped from the result.\\n148: // Returns empty string if the message cannot be parsed or contains no text.\\n149: func ExtractUserContent(message json.RawMessage) string {\\n150: \\tvar msg UserMessage\\n151: \\tif err := json.Unmarshal(message, &msg); err != nil {\\n152: \\t\\treturn \\\"\\\"\\n153: \\t}\\n154: \\n155: \\t// Handle string content\\n156: \\tif str, ok := msg.Content.(string); ok {\\n157: \\t\\treturn textutil.StripIDEContextTags(str)\\n158: \\t}\\n159: \\n160: \\t// Handle array content (only if it contains text blocks)\\n161: \\tif arr, ok := msg.Content.([]interface{}); ok {\\n162: \\t\\tvar texts []string\\n163: \\t\\tfor _, item := range arr {\\n164: \\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n165: \\t\\t\\t\\tif m[\\\"type\\\"] == ContentTypeText {\\n166: \\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n167: \\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n168: \\t\\t\\t\\t\\t}\\n169: \\t\\t\\t\\t}\\n170: \\t\\t\\t}\\n171: \\t\\t}\\n172: \\t\\tif len(texts) > 0 {\\n173: \\t\\t\\treturn textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n174: \\t\\t}\\n175: \\t}\\n176: \\n177: \\treturn \\\"\\\"\\n178: }\\n\\n(End of file - total 178 lines)\\n</content>\",\n            \"title\": \"cmd/entire/cli/transcript/parse.go\",\n            \"metadata\": {\n              \"preview\": \"package transcript\\n\\nimport (\\n\\t\\\"bufio\\\"\\n\\t\\\"bytes\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"io\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n)\\n\\n// ParseFromBytes parses transcript content from a byte slice.\\n// Uses bufio.Reader to handle arbitrarily long lines.\\nfunc ParseFromBytes(content []byte) ([]Line, error) {\\n\\tvar lines []Line\\n\\treader := bufio.NewReader(bytes.NewReader(content))\\n\",\n              \"truncated\": false,\n              \"loaded\": []\n            },\n            \"time\": {\n              \"start\": 1773272358363,\n              \"end\": 1773272358366\n            }\n          },\n          \"metadata\": {\n            \"openai\": {\n              \"itemId\": \"fc_0ff894c8a87f44a00169b1fd2641a881919fddd8b5e36e602a\"\n            }\n          },\n          \"id\": \"prt_cdf44dddb001zvpPr6fojuV8Yw\",\n          \"sessionID\": \"ses_320bb9572ffeg9UEjfghnZJov8\",\n          \"messageID\": \"msg_cdf44c17b001DKka6475lL7Npe\"\n        },\n        {\n          \"type\": \"tool\",\n          \"callID\": \"REDACTED\",\n          \"tool\": \"read\",\n          \"state\": {\n            \"status\": \"completed\",\n            \"input\": {\n              \"filePath\": \"/Users/thomi/Projects/entire-cli/cmd/entire/cli/summarize/summarize.go\"\n            },\n            \"output\": \"<path>/Users/thomi/Projects/entire-cli/cmd/entire/cli/summarize/summarize.go</path>\\n<type>file</type>\\n<content>1: // Package summarize provides AI-powered summarization of development sessions.\\n2: package summarize\\n3: \\n4: import (\\n5: \\t\\\"context\\\"\\n6: \\t\\\"encoding/json\\\"\\n7: \\t\\\"errors\\\"\\n8: \\t\\\"fmt\\\"\\n9: \\t\\\"strings\\\"\\n10: \\n11: \\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n12: \\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/factoryaidroid\\\"\\n13: \\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n14: \\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/opencode\\\"\\n15: \\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n16: \\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n17: \\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n18: )\\n19: \\n20: // GenerateFromTranscript generates a summary from raw transcript bytes.\\n21: // This is the shared implementation used by both explain --generate and auto-summarize.\\n22: //\\n23: // Parameters:\\n24: //   - ctx: context for cancellation\\n25: //   - transcriptBytes: raw transcript bytes (JSONL or JSON format depending on agent)\\n26: //   - filesTouched: list of files modified during the session\\n27: //   - agentType: the agent type to determine transcript format\\n28: //   - generator: summary generator to use (if nil, uses default ClaudeGenerator)\\n29: //\\n30: // Returns nil, error if transcript is empty or cannot be parsed.\\n31: func GenerateFromTranscript(ctx context.Context, transcriptBytes []byte, filesTouched []string, agentType types.AgentType, generator Generator) (*checkpoint.Summary, error) {\\n32: \\tif len(transcriptBytes) == 0 {\\n33: \\t\\treturn nil, errors.New(\\\"empty transcript\\\")\\n34: \\t}\\n35: \\n36: \\t// Build condensed transcript for summarization\\n37: \\tcondensed, err := BuildCondensedTranscriptFromBytes(transcriptBytes, agentType)\\n38: \\tif err != nil {\\n39: \\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n40: \\t}\\n41: \\tif len(condensed) == 0 {\\n42: \\t\\treturn nil, errors.New(\\\"transcript has no content to summarize\\\")\\n43: \\t}\\n44: \\n45: \\tinput := Input{\\n46: \\t\\tTranscript:   condensed,\\n47: \\t\\tFilesTouched: filesTouched,\\n48: \\t}\\n49: \\n50: \\t// Use default generator if none provided\\n51: \\tif generator == nil {\\n52: \\t\\tgenerator = &ClaudeGenerator{}\\n53: \\t}\\n54: \\n55: \\tsummary, err := generator.Generate(ctx, input)\\n56: \\tif err != nil {\\n57: \\t\\treturn nil, fmt.Errorf(\\\"failed to generate summary: %w\\\", err)\\n58: \\t}\\n59: \\n60: \\treturn summary, nil\\n61: }\\n62: \\n63: // Generator generates checkpoint summaries using an LLM.\\n64: type Generator interface {\\n65: \\t// Generate creates a summary from checkpoint data.\\n66: \\t// Returns the generated summary or an error if generation fails.\\n67: \\tGenerate(ctx context.Context, input Input) (*checkpoint.Summary, error)\\n68: }\\n69: \\n70: // Input contains condensed checkpoint data for summarization.\\n71: type Input struct {\\n72: \\t// Transcript is the condensed transcript entries\\n73: \\tTranscript []Entry\\n74: \\n75: \\t// FilesTouched are the files modified during the session\\n76: \\tFilesTouched []string\\n77: }\\n78: \\n79: // EntryType represents the type of a transcript entry.\\n80: type EntryType string\\n81: \\n82: const (\\n83: \\t// EntryTypeUser indicates a user prompt entry.\\n84: \\tEntryTypeUser EntryType = \\\"user\\\"\\n85: \\t// EntryTypeAssistant indicates an assistant response entry.\\n86: \\tEntryTypeAssistant EntryType = \\\"assistant\\\"\\n87: \\t// EntryTypeTool indicates a tool call entry.\\n88: \\tEntryTypeTool EntryType = \\\"tool\\\"\\n89: )\\n90: \\n91: // Entry represents one item in the condensed transcript.\\n92: type Entry struct {\\n93: \\t// Type is the entry type (user, assistant, tool)\\n94: \\tType EntryType\\n95: \\n96: \\t// Content is the text content for user/assistant entries\\n97: \\tContent string\\n98: \\n99: \\t// ToolName is the name of the tool (for tool entries)\\n100: \\tToolName string\\n101: \\n102: \\t// ToolDetail is a description or file path (f