ile, 0)\\n342: \\tif err != nil {\\n343: \\t\\tt.Fatalf(\\\"unexpected error parsing line exceeding buffer: %v\\\", err)\\n344: \\t}\\n345: \\n346: \\tif len(lines) != 1 {\\n347: \\t\\tt.Fatalf(\\\"expected 1 parsed line, got %d\\\", len(lines))\\n348: \\t}\\n349: }\\n350: \\n351: func TestParseFromFileAtLine_EntireFile(t *testing.T) {\\n352: \\tt.Parallel()\\n353: \\n354: \\tcontent := `{\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"user-1\\\",\\\"message\\\":{\\\"content\\\":\\\"Hello\\\"}}\\n355: {\\\"type\\\":\\\"assistant\\\",\\\"uuid\\\":\\\"asst-1\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"Hi\\\"}]}}\\n356: {\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"user-2\\\",\\\"message\\\":{\\\"content\\\":\\\"Bye\\\"}}`\\n357: \\n358: \\ttmpFile := createTempTranscript(t, content)\\n359: \\n360: \\tlines, err := ParseFromFileAtLine(tmpFile, 0)\\n361: \\tif err != nil {\\n362: \\t\\tt.Fatalf(\\\"unexpected error: %v\\\", err)\\n363: \\t}\\n364: \\n365: \\tif len(lines) != 3 {\\n366: \\t\\tt.Errorf(\\\"len(lines) = %d, want 3\\\", len(lines))\\n367: \\t}\\n368: }\\n369: \\n370: func TestParseFromFileAtLine_Offset(t *testing.T) {\\n371: \\tt.Parallel()\\n372: \\n373: \\tcontent := `{\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"user-1\\\",\\\"message\\\":{\\\"content\\\":\\\"Line1\\\"}}\\n374: {\\\"type\\\":\\\"assistant\\\",\\\"uuid\\\":\\\"asst-1\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"Line2\\\"}]}}\\n375: {\\\"type\\\":\\\"user\\\",\\\"uuid\\\":\\\"user-2\\\",\\\"message\\\":{\\\"content\\\":\\\"Line3\\\"}}\\n376: {\\\"type\\\":\\\"assistant\\\",\\\"uuid\\\":\\\"asst-2\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"Line4\\\"}]}}`\\n377: \\n378: \\ttmpFile := createTempTranscript(t, content)\\n379: \\n380: \\t// Parse from line 2 (0-indexed, so skip first 2 lines)\\n381: \\tlines, err := ParseFromFileAtLine(tmpFile, 2)\\n382: \\tif err != nil {\\n383: \\t\\tt.Fata