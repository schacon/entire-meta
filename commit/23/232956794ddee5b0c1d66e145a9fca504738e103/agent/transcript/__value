    15→\\tName            string // \\\"Husky\\\", \\\"Lefthook\\\", \\\"pre-commit\\\", \\\"Overcommit\\\"\\n    16→\\tConfigPath      string // relative path that triggered detection (e.g., \\\".husky/\\\")\\n    17→\\tOverwritesHooks bool   // true if the tool will overwrite Entire's hooks on reinstall\\n    18→}\\n    19→\\n    20→// detectHookManagers checks the repository root for known hook manager config\\n    21→// files/directories. Detection is filesystem-only (os.Stat, no file reads).\\n    22→func detectHookManagers(repoRoot string) []hookManager {\\n    23→\\tvar managers []hookManager\\n    24→\\n    25→\\tchecks := []hookManager{\\n    26→\\t\\t{\\\"Husky\\\", \\\".husky/\\\", true},\\n    27→\\t\\t{\\\"pre-commit\\\", \\\".pre-commit-config.yaml\\\", false},\\n    28→\\t\\t{\\\"Overcommit\\\", \\\".overcommit.yml\\\", false},\\n    29→\\t}\\n    30→\\n    31→\\t// Lefthook supports {.,}lefthook{,-local}.{yml,yaml,json,toml}\\n    32→\\tfor _, prefix := range []string{\\\"\\\", \\\".\\\"} {\\n    33→\\t\\tfor _, variant := range []string{\\\"\\\", \\\"-local\\\"} {\\n    34→\\t\\t\\tfor _, ext := range []string{\\\"yml\\\", \\\"yaml\\\", \\\"json\\\", \\\"toml\\\"} {\\n    35→\\t\\t\\t\\tname := prefix + \\\"lefthook\\\" + variant + \\\".\\\" + ext\\n    36→\\t\\t\\t\\tchecks = append(checks, hookManager{\\\"Lefthook\\\", name, false})\\n    37→\\t\\t\\t}\\n    38→\\t\\t}\\n    39→\\t}\\n    40→\\n    41→\\tseen := make(map[string]bool)\\n    42→\\tfor _, c := range checks {\\n    43→\\t\\tpath := filepath.Join(repoRoot, c.ConfigPath)\\n    44→\\t\\tif _, err := os.Stat(path); err == nil {\\n    45→\\t\\t\\tif seen[c.Name] {\\n    46→\\t\\t\\t\\tcontinue // e.g., lefthook.yml and .lefthook.yml both present\\n    47→\\t\\t\\t}\\n    48→\\t\\t\\tseen[c.Name] = true\\n    49→\\t\\t\\tmanagers = append(managers, c)\\n    50→\\t\\t}\\n    51→\\t}\\n    52→\\n    53→\\treturn managers\\n    54→}\\n    55→\\n    56→// hookManagerWarning builds a warning str