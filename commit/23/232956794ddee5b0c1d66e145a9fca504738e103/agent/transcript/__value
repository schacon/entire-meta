/nolint:gosec // Git hooks require executable permissions\\n   235→\\t\\treturn false, fmt.Errorf(\\\"failed to write hook file %s: %w\\\", path, err)\\n   236→\\t}\\n   237→\\treturn true, nil\\n   238→}\\n   239→\\n   240→// RemoveGitHook removes all Entire CLI git hooks from the repository.\\n   241→// If a .pre-entire backup exists, it is restored.\\n   242→// Returns the number of hooks removed.\\n   243→func RemoveGitHook() (int, error) {\\n   244→\\thooksDir, err := GetHooksDir()\\n   245→\\tif err != nil {\\n   246→\\t\\treturn 0, err\\n   247→\\t}\\n   248→\\n   249→\\tremoved := 0\\n   250→\\tvar removeErrors []string\\n   251→\\n   252→\\tfor _, hook := range gitHookNames {\\n   253→\\t\\thookPath := filepath.Join(hooksDir, hook)\\n   254→\\t\\tbackupPath := hookPath + backupSuffix\\n   255→\\n   256→\\t\\t// Remove the hook if it contains our marker\\n   257→\\t\\tdata, err := os.ReadFile(hookPath) //nolint:gosec // path is controlled\\n   258→\\t\\thookIsOurs := err == nil && strings.Contains(string(data), entireHookMarker)\\n   259→\\t\\thookExists := err == nil\\n   260→\\n   261→\\t\\tif hookIsOurs {\\n   262→\\t\\t\\tif err := os.Remove(hookPath); err != nil {\\n   263→\\t\\t\\t\\tremoveErrors = append(removeErrors, fmt.Sprintf(\\\"%s: %v\\\", hook, err))\\n   264→\\t\\t\\t\\tcontinue\\n   265→\\t\\t\\t}\\n   266→\\t\\t\\tremoved++\\n   267→\\t\\t}\\n   268→\\n   269→\\t\\t// Restore .pre-entire backup if it exists\\n   270→\\t\\tif fileExists(backupPath) {\\n   271→\\t\\t\\tif hookExists && !hookIsOurs {\\n   272→\\t\\t\\t\\t// A non-Entire hook is present — don't overwrite it with the backup\\n   273→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: %s was modified since install; backup %s%s left in place\\\\n\\\", hook, hook, backupSuffix)\\n   274→\\t\\t\\t} else {\\n   275→\\t\\t\\t\\tif err := os.Rename(backupPath, hookPath); err != nil {\\n   276→\\t\\t\\t\\t\\tremoveErrors = append(removeErrors, fmt.Sprintf(\\\"restore %s%s: %v\\\", hook, backupSuffix, err))\\n   277→\\t\\t\\t\\t}\\n   278→\\t\\t\\t}\\n   279→\\t\\t}\\n   280→\\t}\\n   281→\\n   282→\\tif len(removeErrors) > 0 {\\n   283→\\t\\treturn removed, fmt.Errorf(\\\"failed to remove hooks: %s\\\", strings.Join(removeErrors, \\\"; \\\"))\\n   284→\\t}\\n   285→\\treturn removed, nil\\n   286→}\\n   287→\\n   288→// generateChainedContent appends a chain call to the base hook content,\\n   289→// so the pre-existing hook (backed up to .pre-entire) is called after our hook.\\n   290→func generateChainedContent(baseContent, hookName string) string {\\n   291→\\treturn baseContent + fmt.Sprintf(`%s\\n   292→_entire_hook_dir=\\\"$(dirname \\\"$0\\\")\\\"\\n   293→if [ -x \\\"$_entire_hook_dir/%s%s\\\" ]; then\\n   294→    \\\"$_entire_hook_dir/%s%s\\\" \\\"$@\\\"\\n   295→fi\\n   296→`, chainComment, hookName, backupSuffix, hookName, backupSuffix)\\n   297→}\\n   298→\\n   299→// hookCmdPrefix returns the command prefix for hook scripts and warning messages.\\n   300→// Returns \\\"go run ./cmd/entire/main.go\\\" when local_dev is enabled, \\\"entire\\\" otherwise.\\n   301→func hookCmdPrefix() string {\\n   302→\\tif isLocalDev() {\\n   303→\\t\\treturn \\\"go run ./cmd/entire/main.go\\\"\\n   304→\\t}\\n   305→\\treturn \\\"entire\\\"\\n   306→}\\n   307→\\n   308→// isLocalDev reads the local_dev setting from .entire/settings.json\\n   309→// Works correctly from any subdirectory within the repository.\\n   310→func isLocalDev() bool {\\n   311→\\ts, err := settings.Load()\\n   312→\\tif err != nil {\\n   313→\\t\\treturn false\\n   314→\\t}\\n   315→\\treturn s.LocalDev\\n   316→}\\n   317→\"}]},\"uuid\":\"bc3a4ef8-e252-442d-9755-5b136a3d58d8\",\"timestamp\":\"2026-02-20T11:01:17.718Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Explore the codebase to understand:\\n\\n1. The current `entire enable` command implementation - find the command file and understand what it does\\n2. How agents are detected/configured - 