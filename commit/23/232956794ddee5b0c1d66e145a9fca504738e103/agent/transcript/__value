y\\\"`\\n    48→\\n    49→\\t// Telemetry controls anonymous usage analytics.\\n    50→\\t// nil = not asked yet (show prompt), true = opted in, false = opted out\\n    51→\\tTelemetry *bool `json:\\\"telemetry,omitempty\\\"`\\n    52→}\\n    53→\\n    54→// Load loads the Entire settings from .entire/settings.json,\\n    55→// then applies any overrides from .entire/settings.local.json if it exists.\\n    56→// Returns default settings if neither file exists.\\n    57→// Works correctly from any subdirectory within the repository.\\n    58→func Load() (*EntireSettings, error) {\\n    59→\\t// Get absolute paths for settings files\\n    60→\\tsettingsFileAbs, err := paths.AbsPath(EntireSettingsFile)\\n    61→\\tif err != nil {\\n    62→\\t\\tsettingsFileAbs = EntireSettingsFile // Fallback to relative\\n    63→\\t}\\n    64→\\tlocalSettingsFileAbs, err := paths.AbsPath(EntireSettingsLocalFile)\\n    65→\\tif err != nil {\\n    66→\\t\\tlocalSettingsFileAbs = EntireSettingsLocalFile // Fallback to relative\\n    67→\\t}\\n    68→\\n    69→\\t// Load base settings\\n    70→\\tsettings, err := loadFromFile(settingsFileAbs)\\n    71→\\tif err != nil {\\n    72→\\t\\treturn nil, fmt.Errorf(\\\"reading settings file: %w\\\", err)\\n    73→\\t}\\n    74→\\n    75→\\t// Apply local overrides if they exist\\n    76→\\tlocalData, err := os.ReadFile(localSettingsFileAbs) //nolint:gosec // path is from AbsPath or constant\\n    77→\\tif err != nil {\\n    78→\\t\\tif !os.IsNotExist(err) {\\n    79→\\t\\t\\treturn nil, fmt.Errorf(\\\"reading local settings file: %w\\\", err)\\n    80→\\t\\t}\\n    81→\\t\\t// Local file doesn't exist, continue without overrides\\n    82→\\t} else {\\n    83→\\t\\tif err := mergeJSON(settings, localData); err != nil {\\n    84→\\t\\t\\treturn nil, fmt.Errorf(\\\"merging local settings: %w\\\", err)\\n    85→\\t\\t}\\n    86→\\t}\\n    87→\\n    88→\\tapplyDefaults(settings)\\n    89→\\n    90→\\treturn settings, nil\\n    91→}\\n    92→\\n    93→// LoadFromFile loads settings from a specific file path without merging local overrides.\\n    94→// Returns default settings if the file doesn't exist.\\n    95→// Use this when you need to display individual settings files separately.\\n    96→func LoadFromFile(filePath string) (*EntireSettings, error) {\\n    97→\\treturn loadFromFile(filePath)\\n    98→}\\n    99→\\n   100→// loadFromFile loads settings from a specific file path.\\n   101→// Returns default settings if the file doesn't exist.\\n   102→func loadFromFile(filePath string) (*EntireSettings, error) {\\n   103→\\tsettings := &EntireSettings{\\n   104→\\t\\tStrategy: DefaultStrategyName,\\n   105→\\t\\tEnabled:  true, // Default to enabled\\n   106→\\t}\\n   107→\\n   108→\\tdata, err := os.ReadFile(filePath) //nolint:gosec // path is from caller\\n   109→\\tif err != nil {\\n   110→\\t\\tif os.IsNotExist(err) {\\n   111→\\t\\t\\treturn settings, nil\\n   112→\\t\\t}\\n   113→\\t\\treturn nil, fmt.Errorf(\\\"%w\\\", err)\\n   114→\\t}\\n   115→\\n   116→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   117→\\tdec.DisallowUnknownFields()\\n   118→\\tif err := dec.Decode(settings); err != nil {\\n   119→\\t\\treturn nil, fmt.Errorf(\\\"parsing settings file: %w\\\", err)\\n   120→\\t}\\n   121→\\tapplyDefaults(settings)\\n   122→\\n   123→\\treturn settings, nil\\n   124→}\\n   125→\\n   126→// mergeJSON merges JSON data into existing settings.\\n   127→// Only non-zero values from the JSON override existing settings.\\n   128→func mergeJSON(settings *EntireSettings, data []byte) error {\\n   129→\\t// First, validate that there are no unknown keys using strict decoding\\n   130→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   131→\\tdec.DisallowUnknownFields()\\n   132→\\tvar temp EntireSettings\\n   133→\\tif err := dec.Decode(&temp); err != nil {\\n   134→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   135→\\t}\\n   136→\\n   137→\\t// Parse into a map to check which fields are present\\n   138→\\tvar raw map[string]json.RawMessage\\n   139→\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   140→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   141→\\t}\\n   142→\\n   143→\\t// Override strategy if present and non-empty\\n   144→\\tif strategyRaw, ok := raw[\\\"strategy\\\"]; ok {\\n   145→\\t\\tvar s string\\n   146→\\t\\tif err := json.Unmarshal(strategyRaw, &s); err != nil {\\n   147→\\t\\t\\treturn fmt.Errorf(\\\"parsing strategy field: %w\\\", err)\\n   148→\\t\\t}\\n   149→\\t\\tif s != \\\"\\\" {\\n   150→\\t\\t\\tsettings.Strategy = s\\n   151→\\t\\t}\\n   152→\\t}\\n   153→\\n   154→\\t// Override enabled if present\\n   155→\\tif enabledRaw, ok := raw[\\\"enabled\\\"]; ok {\\n   156→\\t\\tvar e bool\\n   157→\\t\\tif err := json.Unmarshal(enabledRaw, &e); err != nil {\\n   158→\\t\\t\\treturn fmt.Errorf(\\\"parsing enabled field: %w\\\", err)\\n   159→\\t\\t}\\n   160→\\t\\tsettings.Enabled = e\\n   161→\\t}\\n   162→\\n   163→\\t// Override local_dev if present\\n   164→\\tif localDevRaw, ok := raw[\\\"local_dev\\\"]; ok {\\n   165→\\t\\tvar ld bool\\n   166→\\t\\tif err := json.Unmarshal(localDevRaw, &ld); err != nil {\\n   167→\\t\\t\\treturn fmt.Errorf(\\\"parsing local_dev field: %w\\\", err)\\n   168→\\t\\t}\\n   169→\\t\\tsettings.LocalDev = ld\\n   170→\\t}\\n   171→\\n   172→\\t// Override log_level if present and non-empty\\n   173→\\tif logLevelRaw, ok := raw[\\\"log_level\\\"]; ok {\\n   174→\\t\\tvar ll string\\n   175→\\t\\tif err := json.Unmarshal(logLevelRaw, &ll); err != nil {\\n   176→\\t\\t\\treturn fmt.Errorf(\\\"parsing log_level field: %w\\\", err)\\n   177→\\t\\t}\\n   178→\\t\\tif ll != \\\"\\\" {\\n   179→\\t\\t\\tsettings.LogLevel = ll\\n   180→\\t\\t}\\n   181→\\t}\\n   182→\\n   183→\\t// Merge strategy_options if present\\n   184→\\tif optionsRaw, ok := raw[\\\"strategy_options\\\"]; ok {\\n   185→\\t\\tvar opts map[string]any\\n   186→\\t\\tif err := json.Unmarshal(optionsRaw, &opts); err != nil {\\n   187→\\t\\t\\treturn fmt.Errorf(\\\"parsing strategy_options field: %w\\\", err)\\n   188→\\t\\t}\\n   189→\\t\\tif settings.StrategyOptions == nil {\\n   190→\\t\\t\\tsettings.StrategyOptions = opts\\n   191→\\t\\t} else {\\n   192→\\t\\t\\tfor k, v := range opts {\\n   193→\\t\\t\\t\\tsettings.StrategyOptions[k] = v\\n   194→\\t\\t\\t}\\n   195→\\t\\t}\\n   196→\\t}\\n   197→\\n   198→\\t// Override telemetry if present\\n   199→\\tif telemetryRaw, ok := raw[\\\"telemetry\\\"]; ok {\\n   200→\\t\\tvar t bool\\n   201→\\t\\tif err := json.Unmarshal(telemetryRaw, &t); err != nil {\\n   202→\\t\\t\\treturn fmt.Errorf(\\\"parsing telemetry field: %w\\\", err)\\n   203→\\t\\t}\\n   204→\\t\\tsettings.Telemetry = &t\\n   205→\\t}\\n   206→\\n   207→\\treturn nil\\n   208→}\\n   209→\\n   210→func applyDefaults(settings *EntireSettings) {\\n   211→\\tif settings.Strategy == \\\"\\\" {\\n   212→\\t\\tsettings.Strategy = DefaultStrategyName\\n   213→\\t}\\n   214→}\\n   215→\\n   216→// IsSummarizeEnabled checks if auto-summarize is enabled in settings.\\n   217→// Returns false by default if settings cannot be loaded or the key is missing.\\n   218→func IsSummarizeEnabled() bool {\\n   219→\\tsettings, err := Load()\\n   220→\\tif err != nil {\\n   221→\\t\\treturn false\\n   222→\\t}\\n   223→\\treturn settings.IsSummarizeEnabled()\\n   224→}\\n   225→\\n   226→// IsSummarizeEnabled checks if auto-summarize is enabled in this settings instance.\\n   227→func (s *EntireSettings) IsSummarizeEnabled() bool {\\n   228→\\tif s.StrategyOptions == nil {\\n   229→\\t\\treturn false\\n   230→\\t}\\n   231→\\tsummarizeOpts, ok := s.StrategyOptions[\\\"summarize\\\"].(map[string]any)\\n   232→\\tif !ok {\\n   233→\\t\\treturn false\\n   234→\\t}\\n   235→\\tenabled, ok := summarizeOpts[\\\"enabled\\\"].(bool)\\n   236→\\tif !ok {\\n   237→\\t\\treturn false\\n   238→\\t}\\n   239→\\treturn enabled\\n   240→}\\n   241→\\n   242→// IsPushSessionsDisabled checks if push_sessions is disabled in settings.\\n   243→// Returns true if push_sessions is explicitly set to false.\\n   244→func (s *EntireSettings) IsPushSessionsDisabled() bool {\\n   245→\\tif s.StrategyOptions == nil {\\n   246→\\t\\treturn false\\n   247→\\t}\\n   248→\\tval, exists := s.StrategyOptions[\\\"push_sessions\\\"]\\n   249→\\tif !exists {\\n   250→\\t\\treturn false\\n   251→\\t}\\n   252→\\tif boolVal, ok := val.(bool); ok {\\n   253→\\t\\treturn !boolVal // disabled = !push_sessions\\n   254→\\t}\\n   255→\\treturn false\\n   256→}\\n   257→\\n   258→// Save saves the settings to .entire/settings.json.\\n   259→func Save(settings *EntireSettings) error {\\n   260→\\treturn saveToFile(settings, EntireSettingsFile)\\n   261→}\\n   262→\\n   263→// SaveLocal saves the settings to .entire/settings.local.json.\\n   264→func SaveLocal(settings *EntireSettings) error {\\n   265→\\treturn saveToFile(settings, EntireSettingsLocalFile)\\n   266→}\\n   267→\\n   268→// saveToFile saves settings to the specified file path.\\n   269→func saveToFile(settings *EntireSettings, filePath string) error {\\n   270→\\t// Get absolute path for the file\\n   271→\\tfilePathAbs, err := paths.AbsPath(filePath)\\n   272→\\tif err != nil {\\n   273→\\t\\tfilePathAbs = filePath // Fallback to relative\\n   274→\\t}\\n   275→\\n   276→\\t// Ensure directory exists\\n   277→\\tdir := filepath.Dir(filePathAbs)\\n   278→\\tif err := os.MkdirAll(dir, 0o750); err != nil {\\n   279→\\t\\treturn fmt.Errorf(\\\"creating settings directory: %w\\\", err)\\n   280→\\t}\\n   281→\\n   282→\\tdata, err := jsonutil.MarshalIndentWithNewline(settings, \\\"\\\", \\\"  \\\")\\n   283→\\tif err != nil {\\n   284→\\t\\treturn fmt.Errorf(\\\"marshaling settings: %w\\\", err)\\n   285→\\t}\\n   286→\\n   287→\\t//nolint:gosec // G306: settings file is config, not secrets; 0o644 is appropriate\\n   288→\\tif err := os.WriteFile(filePathAbs, data, 0o644); err != nil {\\n   289→\\t\\treturn fmt.Errorf(\\\"w