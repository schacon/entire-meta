95→\\n    96→\\treturn b.String()\\n    97→}\\n    98→\\n    99→// extractCommandLine returns the first non-shebang, non-comment, non-empty line\\n   100→// from a hook script. This is the actual command invocation line.\\n   101→func extractCommandLine(hookContent string) string {\\n   102→\\tfor _, line := range strings.Split(hookContent, \\\"\\\\n\\\") {\\n   103→\\t\\ttrimmed := strings.TrimSpace(line)\\n   104→\\t\\tif trimmed == \\\"\\\" || strings.HasPrefix(trimmed, \\\"#\\\") {\\n   105→\\t\\t\\tcontinue\\n   106→\\t\\t}\\n   107→\\t\\treturn trimmed\\n   108→\\t}\\n   109→\\treturn \\\"\\\"\\n   110→}\\n   111→\\n   112→// CheckAndWarnHookManagers detects external hook managers and writes a warning\\n   113→// to w if any are found.\\n   114→func CheckAndWarnHookManagers(w io.Writer) {\\n   115→\\trepoRoot, err := paths.RepoRoot()\\n   116→\\tif err != nil {\\n   117→\\t\\treturn\\n   118→\\t}\\n   119→\\n   120→\\tmanagers := detectHookManagers(repoRoot)\\n   121→\\tif len(managers) == 0 {\\n   122→\\t\\treturn\\n   123→\\t}\\n   124→\\n   125→\\twarning := hookManagerWarning(managers, hookCmdPrefix())\\n   126→\\tif warning != \\\"\\\" {\\n   127→\\t\\tfmt.Fprintln(w)\\n   128→\\t\\tfmt.Fprint(w, warning)\\n   129→\\t}\\n   130→}\\n   131→\"}]},\"uuid\":\"053107a7-b65b-4810-a30c-ad2ed42d5fc7\",\"timestamp\":\"2026-02-20T11:01:17.928Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Explore the codebase to understand:\\n\\n1. The current `entire enable` command implementation - find the command file and understand what it does\\n2. How agents are detected/configured - look for agent-related code (agent detection, agent types, supported agents)\\n3. How hooks are installed per agent - look for hook installation logic\\n4. The settings system - how settings are stored in `.entire/settings.json`\\n5. Any existing agent selection or multi-agent support\\n\\nFocus on these directories:\\n- cmd/entire/cli/commands/ (for the enable command)\\