ng        { return \\\"cursor\\\" }\\n    32→func (a *CursorCLI) TimeoutMultiplier() float64 { return 1.5 }\\n    33→\\n    34→// PromptPattern returns a regex matching the Cursor CLI's TUI input prompt.\\n    35→// The CLI shows a styled input box with placeholder text when ready for input.\\n    36→func (a *CursorCLI) PromptPattern() string { return `/ commands` }\\n    37→\\n    38→func (a *CursorCLI) IsTransientError(out Output, err error) bool {\\n    39→\\tif err == nil {\\n    40→\\t\\treturn false\\n    41→\\t}\\n    42→\\tif errors.Is(err, context.DeadlineExceeded) {\\n    43→\\t\\treturn true\\n    44→\\t}\\n    45→\\tcombined := out.Stdout + out.Stderr\\n    46→\\tfor _, p := range []string{\\n    47→\\t\\t\\\"overloaded\\\",\\n    48→\\t\\t\\\"rate limit\\\",\\n    49→\\t\\t\\\"429\\\",\\n    50→\\t\\t\\\"503\\\",\\n    51→\\t\\t\\\"529\\\",\\n    52→\\t\\t\\\"ECONNRESET\\\",\\n    53→\\t\\t\\\"ETIMEDOUT\\\",\\n    54→\\t\\t\\\"server error\\\",\\n    55→\\t\\t\\\"Internal Server Error\\\",\\n    56→\\t} {\\n    57→\\t\\tif strings.Contains(combined, p) {\\n    58→\\t\\t\\treturn true\\n    59→\\t\\t}\\n    60→\\t}\\n    61→\\treturn false\\n    62→}\\n    63→\\n    64→func (a *CursorCLI) Bootstrap() error {\\n    65→\\t// The Cursor CLI authenticates via CURSOR_API_KEY env var or OAuth.\\n    66→\\t// On CI, ensure CURSOR_API_KEY is set. Locally, OAuth/keychain works.\\n    67→\\tif os.Getenv(\\\"CI\\\") != \\\"\\\" && os.Getenv(\\\"CURSOR_API_KEY\\\") == \\\"\\\" {\\n    68→\\t\\treturn errors.New(\\\"CURSOR_API_KEY must be set on CI for cursor-cli E2E tests\\\")\\n    69→\\t}\\n    70→\\treturn nil\\n    71→}\\n    72→\\n    73→func (a *CursorCLI) RunPrompt(ctx context.Context, dir string, prompt string, opts ...Option) (Output, error) {\\n    74→\\tcfg := &runConfig{}\\n    75→\\tfor _, o := range opts {\\n    76→\\t\\to(cfg)\\n    77→\\t}\\n    78→\\n    79→\\ttimeout := 90 * time.Second\\n    80→\\tif cfg.PromptTimeout > 0 {\\n    81→\\t\\ttimeout = cfg.PromptTimeout\\n    82→\\t}\\n    83→\\n    84→\\tdisplayCmd := a.Binary() + \\\" --force --workspace \\\" + dir + \\\" (interactive prompt: \\\" + prompt + \\\")\\\"\\n    85→\\n    86→\\t// Start an interactive tmux session so all hooks fire\\n    87→\\t// (beforeSubmitPrompt and stop don't fire in headless -p mode).\\n    88→\\ts, err := a.startInteractiveSession(dir)\\n    89→\\tif err != nil {\\n    90→\\t\\treturn Output{Command: displayCmd, ExitCode: -1},\\n    91→\\t\\t\\tfmt.Errorf(\\\"start interactive session: %w\\\", err)\\n    92→\\t}\\n    93→\\tdefer s.Close()\\n    94→\\n    95→\\t// Wait for trust dialog and accept it.\\n    96→\\tif err := a.acceptTrustDialogIfNeeded(s); err != nil {\\n    97→\\t\\treturn Output{Command: displayCmd, Stdout: s.Capture(), ExitCode: -1}, err\\n    98→\\t}\\n    99→\\n   100→\\t// Wait for the TUI to be ready.\\n   101→\\tif _, err := s.WaitFor(a.PromptPattern(), 30*time.Second); err != nil {\\n   102→\\t\\treturn Output{Command: displayCmd, Stdout: s.Capture(), ExitCode: -1},\\n   103→\\t\\t\\tfmt.Errorf(\\\"waiting for startup prompt: %w\\\", err)\\n   104→\\t}\\n   105→\\n   106→\\t// Send the prompt.\\n   107→\\tif err := s.Send(prompt); err != nil {\\n   108→\\t\\treturn Output{Command: displayCmd, Stdout: s.Capture(), ExitCode: -1},\\n   109→\\t\\t\\tfmt.Errorf(\\\"sending prompt: %w\\\", err)\\n   110→\\t}\\n   111→\\n   112→\\t// Wait for the prompt pattern to reappear (agent finished processing).\\n   113→\\tcontent, waitErr := s.WaitFor(a.PromptPattern(), timeout)\\n   114→\\tif waitErr != nil {\\n   115→\\t\\t// Check for deadline exceeded to allow transient error detection.\\n   116→\\t\\tif ctx.Err() == context.DeadlineExceeded {\\n   117→\\t\\t\\twaitErr = fmt.Errorf(\\\"%w: %w\\\", waitErr, context.DeadlineExceeded)\\n   118→\\t\\t}\\n   119→\\t\\treturn Output{Command: displayCmd, Stdout: content, ExitCode: -1}, waitErr\\n   120→\\t}\\n   121→\\n   122→\\treturn Output{Command: displayCmd, Stdout: content, ExitCode: 0}, nil\\n   123→}\\n   124→\\n   125→func (a *CursorCLI) StartSession(ctx context.Context, dir string) (Session, error) {\\n   126→\\ts, err := a.startInteractiveSession(dir)\\n   127→\\tif err != nil {\\n   128→\\t\\treturn nil, err\\n   129→\\t}\\n   130→\\n   131→\\tif err := a.acceptTrustDialogIfNeeded(s); err != nil {\\n   132→\\t\\t_ = s.Close()\\n   133→\\t\\treturn nil, err\\n   134→\\t}\\n   135→\\n   136→\\t// Wait for the TUI to be ready (input prompt).\\n   137→\\tif _, err := s.WaitFor(a.PromptPattern(), 30*time.Second); err != nil {\\n   138→\\t\\t_ = s.Close()\\n   139→\\t\\treturn nil, fmt.Errorf(\\\"waiting for startup prompt: %w\\\", err)\\n   140→\\t}\\n   141→\\ts.stableAtSend = \\\"\\\"\\n   142→\\n   143→\\treturn s, nil\\n   144→}\\n   145→\\n   146→// startInteractiveSession creates a new tmux session running the Cursor CLI\\n   147→// in interactive mode (no -p flag) so all hooks fire.\\n   148→func (a *CursorCLI) startInteractiveSession(dir string) (*TmuxSession, error) {\\n   149→\\t// Resolve to absolute path so tmux can find the binary even if its\\n   150→\\t// shell doesn't inherit the test process's PATH (common on CI).\\n   151→\\tbin, err := exec.LookPath(a.Binary())\\n   152→\\tif err != nil {\\n   153→\\t\\treturn nil, fmt.Errorf(\\\"agent binary not found: %w\\\", err)\\n   154→\\t}\\n   155→\\n   156→\\t// Build env-wrapped command so the tmux session inherits critical env vars.\\n   157→\\t// tmux starts a new shell that doesn't inherit Go's os.Environ().\\n   158→\\tvar envArgs []string\\n   159→\\tfor _, key := range []string{\\\"CURSOR_API_KEY\\\", \\\"PATH\\\", \\\"HOME\\\", \\\"TERM\\\"} {\\n   160→\\t\\tif v := os.Getenv(key); v != \\\"\\\" {\\n   161→\\t\\t\\tenvArgs = append(envArgs, key+\\\"=\\\"+v)\\n   162→\\t\\t}\\n   163→\\t}\\n   164→\\n   165→\\targs := append([]string{\\\"env\\\"}, envArgs...)\\n   166→\\targs = append(args, bin, \\\"--force\\\", \\\"--workspace\\\", dir)\\n   167→\\n   168→\\tname := fmt.Sprintf(\\\"cursor-cli-test-%d\\\", time.Now().UnixNano())\\n   169→\\tunset := []string{\\\"CI\\\"}\\n   170→\\treturn NewTmuxSession(name, dir, unset, args[0], args[1:]...)\\n   171→}\\n   172→\\n   173→// acceptTrustDialogIfNeeded checks whether the workspace trust dialog appears\\n   174→// and presses \\\"a\\\" to accept it. The dialog only shows on the first launch in\\n   175→// a workspace — subsequent sessions in the same directory skip it.\\n   176→func (a *CursorCLI) acceptTrustDialogIfNeeded(s *TmuxSession) error {\\n   177→\\t// Race: either the trust dialog or the input prompt will appear first.\\n   178→\\t// Use a short timeout to check for the trust dialog without blocking\\n   179→\\t// too long if the workspace is already trusted.\\n   180→\\tcontent, err := s.WaitFor(`Trust this workspace|`+a.PromptPattern(), 30*time.Second)\\n   181→\\tif err != nil {\\n   182→\\t\\treturn fmt.Errorf(\\\"waiting for trust dialog or prompt: %w\\\", err)\\n   183→\\t}\\n   184→\\tif strings.Contains(content, \\\"Trust this workspace\\\") {\\n   185→\\t\\tif err := s.SendKeys(\\\"a\\\"); err != nil {\\n   186→\\t\\t\\treturn fmt.Errorf(\\\"accepting trust dialog: %w\\\", err)\\n   187→\\t\\t}\\n   188→\\t}\\n   189→\\treturn nil\\n   190→}\\n   191→\"}]},\"uuid\":\"25332cec-3398-45c3-842c-dc9e59e917d4\",\"timestamp\":\"2026-03-06T22:31:42.575Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"abae3e3c5bad52e1d\"},\"toolUseID\":\"agent_msg_01HZHQHRmSHGhbWaZuHbmvTd\",\"parentToolUseID\":\"toolu_01Dwzcwmfi8x181RPpBTiUqM\",\"uuid\":\"7655c95f-7243-41ba-b54e-b910aa412c94\",\"timestamp\":\"2026-03-06T22:31:42.856Z\"}\n{\"parentUuid\":\"7655c95f-7243-41ba-b54e-b910aa412c94\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/devenv/cli\",\"sessionId\":\"43151417-d46e-4428-9677-d17ed2bc6ee6\",\"version\":\"2.1.70\",\"gitBranch\":\"alisha/e2e-triage\",\"slug\":\"woolly-painting-waterfall\",\"type\":\"progress\",\"data\