can reset between format tests.\\n   110→\\t\\ts.Git(t, \\\"checkout\\\", mainBranch)\\n   111→\\t\\tmainHead := testutil.GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"HEAD\\\")\\n   112→\\n   113→\\t\\t// --- Format 1: GitHub squash merge ---\\n   114→\\t\\t// GitHub puts each original commit message (including trailers) as\\n   115→\\t\\t// top-level bullet points in the squash commit body.\\n   116→\\t\\ts.Git(t, \\\"merge\\\", \\\"--squash\\\", \\\"feature\\\")\\n   117→\\t\\tgithubMsg := fmt.Sprintf(\\n   118→\\t\\t\\t\\\"Squash merge feature (#1)\\\\n\\\\n* Add red doc\\\\n\\\\nEntire-Checkpoint: %s\\\\n\\\\n* Add blue doc\\\\n\\\\nEntire-Checkpoint: %s\\\",\\n   119→\\t\\t\\tcpID1, cpID2,\\n   120→\\t\\t)\\n   121→\\t\\ts.Git(t, \\\"commit\\\", \\\"-m\\\", githubMsg)\\n   122→\\n   123→\\t\\tout, err := entire.Resume(s.Dir, mainBranch)\\n   124→\\t\\trequire.NoError(t, err, \\\"github format: entire resume failed: %s\\\", out)\\n   125→\\t\\tassert.Contains(t, out, \\\"older checkpoints skipped\\\",\\n   126→\\t\\t\\t\\\"github format: squash merge should skip older checkpoints\\\")\\n   127→\\n   128→\\t\\t// Reset main to before the squash merge for the next format test.\\n   129→\\t\\ts.Git(t, \\\"reset\\\", \\\"--hard\\\", mainHead)\\n   130→\\n   131→\\t\\t// --- Format 2: git merge --squash ---\\n   132→\\t\\t// The git CLI nests original commit messages (with trailers) indented\\n   133→\\t\\t// by 4 spaces inside \\\"Squashed commit of the following:\\\".\\n   134→\\t\\ts.Git(t, \\\"merge\\\", \\\"--squash\\\", \\\"feature\\\")\\n   135→\\n   136→\\t\\t// Sanity-check: the auto-generated SQUASH_MSG should contain both trailers.\\n   137→\\t\\tsquashMsgBytes, err := os.ReadFile(filepath.Join(s.Dir, \\\".git\\\", \\\"SQUASH_MSG\\\"))\\n   138→\\t\\trequire.NoError(t, err, \\\"read .git/SQUASH_MSG\\\")\\n   139→\\t\\tsquashMsgStr := string(squashMsgBytes)\\n   140→\\t\\trequire.Contains(t, squashMsgStr, cpID1,\\n   141→\\t\\t\\t\\\"git SQUASH_MSG should contain first checkpoint ID\\\")\\n   142→\\t\\trequire.Contains(t, squashMsgStr, cpID2,\\n   143→\\t\\t\\t\\\"git SQUASH_MSG should contain second checkpoint ID\\\")\\n   144→\\n   145→\\t\\t// Commit using the git-generated squash message directly (not via -m).\\n   146→\\t\\t// GIT_EDITOR=true prevents git from opening an editor while letting\\n   147→\\t\\t// it use .git/SQUASH_MSG natively with all hooks running.\\n   148→\\t\\tcommitCmd := exec.Command(\\\"git\\\", \\\"commit\\\")\\n   149→\\t\\tcommitCmd.Dir = s.Dir\\n   150→\\t\\tcommitCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\", \\\"GIT_EDITOR=true\\\")\\n   151→\\t\\tcommitOut, commitErr := commitCmd.CombinedOutput()\\n   152→\\t\\tfmt.Fprintf(s.ConsoleLog, \\\"> git commit (GIT_EDITOR=true)\\\\n%s\\\\n\\\", commitOut)\\n   153→\\t\\trequire.NoError(t, commitErr, \\\"git commit with squash message failed: %s\\\", commitOut)\\n   154→\\n   155→\\t\\tout, err = entire.Resume(s.Dir, mainBranch)\\n   156→\\t\\trequire.NoError(t, err, \\\"git-cli format: entire resume failed: %s\\\", out)\\n   157→\\t\\tassert.Contains(t, out, \\\"older checkpoints skipped\\\",\\n   158→\\t\\t\\t\\\"git-cli format: squash merge should skip older checkpoints\\\")\\n   159→\\t})\\n   160→}\\n   161→\\n   162→// TestResumeNoCheckpointOnBranch: resume on a feature branch that has only\\n   163→// human commits (no agent interaction). Should switch to the branch and exit\\n   164→// cleanly with an informational message, not an error.\\n   165→func TestResumeNoCheckpointOnBranch(t *testing.T) {\\n   166→\\ttestutil.ForEachAgent(t, 1*time.Minute, func(t *testing.T, s *testutil.RepoState, ctx context.Context) {\\n   167→\\t\\tmainBranch := testutil.GitOutput(t, s.Dir, \\\"branch\\\", \\\"--show-current\\\")\\n   168→\\n   169→\\t\\t// Commit files from `entire enable` so main has a clean working tree.\\n   170→\\t\\ts.Git(t, \\\"add\\\", \\\".\\\")\\n   171→\\t\\ts.Git(t, \\\"commit\\\", \\\"-m\\\", \\\"Enable entire\\\")\\n