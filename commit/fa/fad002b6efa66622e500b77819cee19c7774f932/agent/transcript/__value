o that the freshly-built\\n    40→\\t// \\\"entire\\\" binary (prepended to PATH by main_test.go) is available inside the\\n    41→\\t// tmux session. Without this, tmux inherits the server's environment which may\\n    42→\\t// have an older binary (or none at all).\\n    43→\\tvar parts []string\\n    44→\\tparts = append(parts, \\\"env\\\")\\n    45→\\t// Options (-u) must precede variable assignments for BSD env on macOS.\\n    46→\\tfor _, v := range unsetEnv {\\n    47→\\t\\tparts = append(parts, \\\"-u\\\", shellQuote(v))\\n    48→\\t}\\n    49→\\tparts = append(parts, \\\"PATH=\\\"+shellQuote(os.Getenv(\\\"PATH\\\")))\\n    50→\\tparts = append(parts, shellQuote(command))\\n    51→\\tfor _, a := range args {\\n    52→\\t\\tparts = append(parts, shellQuote(a))\\n    53→\\t}\\n    54→\\ttmuxArgs = append(tmuxArgs, strings.Join(parts, \\\" \\\"))\\n    55→\\n    56→\\tcmd := exec.Command(\\\"tmux\\\", tmuxArgs...)\\n    57→\\tif out, err := cmd.CombinedOutput(); err != nil {\\n    58→\\t\\treturn nil, fmt.Errorf(\\\"tmux new-session: %w\\\\n%s\\\", err, out)\\n    59→\\t}\\n    60→\\t// Keep the pane around after the command exits so we can capture error output.\\n    61→\\tsetCmd := exec.Command(\\\"tmux\\\", \\\"set-option\\\", \\\"-t\\\", name, \\\"remain-on-exit\\\", \\\"on\\\")\\n    62→\\t_ = setCmd.Run()\\n    63→\\treturn s, nil\\n    64→}\\n    65→\\n    66→func (s *TmuxSession) Send(input string) error {\\n    67→\\tpreSend := stableContent(s.Capture())\\n    68→\\t// Send text and Enter separately — Claude's TUI can swallow Enter\\n    69→\\t// if it arrives before the input handler finishes processing the text.\\n    70→\\tif err := s.SendKeys(input); err != nil {\\n    71→\\t\\treturn err\\n    72→\\t}\\n    73→\\ttime.Sleep(200 * time.Millisecond)\\n    74→\\tif err := s.SendKeys(\\\"Enter\\\"); err != nil {\\n    75→\\t\\treturn err\\n    76→\\t}\\n    77→\\n    78→\\t// Wait for the terminal to reflect the echoed input, then snapshot.\\n    79→\