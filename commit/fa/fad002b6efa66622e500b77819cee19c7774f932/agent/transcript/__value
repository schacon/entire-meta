l_result\",\"content\":\"     1→//go:build e2e\\n     2→\\n     3→package tests\\n     4→\\n     5→import (\\n     6→\\t\\\"context\\\"\\n     7→\\t\\\"fmt\\\"\\n     8→\\t\\\"os\\\"\\n     9→\\t\\\"os/exec\\\"\\n    10→\\t\\\"path/filepath\\\"\\n    11→\\t\\\"testing\\\"\\n    12→\\t\\\"time\\\"\\n    13→\\n    14→\\t\\\"github.com/entireio/cli/e2e/entire\\\"\\n    15→\\t\\\"github.com/entireio/cli/e2e/testutil\\\"\\n    16→\\t\\\"github.com/stretchr/testify/assert\\\"\\n    17→\\t\\\"github.com/stretchr/testify/require\\\"\\n    18→)\\n    19→\\n    20→// TestResumeFromFeatureBranch: agent creates a file on a feature branch and\\n    21→// user commits, then switches back to main and runs `entire resume feature`.\\n    22→// Verifies the branch is switched and the session is restored.\\n    23→func TestResumeFromFeatureBranch(t *testing.T) {\\n    24→\\ttestutil.ForEachAgent(t, 3*time.Minute, func(t *testing.T, s *testutil.RepoState, ctx context.Context) {\\n    25→\\t\\tmainBranch := testutil.GitOutput(t, s.Dir, \\\"branch\\\", \\\"--show-current\\\")\\n    26→\\n    27→\\t\\t// Commit files from `entire enable` so main has a clean working tree\\n    28→\\t\\t// for branch switching (mirrors a real repo where .gitignore is tracked).\\n    29→\\t\\ts.Git(t, \\\"add\\\", \\\".\\\")\\n    30→\\t\\ts.Git(t, \\\"commit\\\", \\\"-m\\\", \\\"Enable entire\\\")\\n    31→\\n    32→\\t\\t// Do agent work on a feature branch.\\n    33→\\t\\ts.Git(t, \\\"checkout\\\", \\\"-b\\\", \\\"feature\\\")\\n    34→\\n    35→\\t\\t_, err := s.RunPrompt(t, ctx,\\n    36→\\t\\t\\t\\\"create a file at docs/hello.md with a paragraph about greetings. Do not ask for confirmation, just make the change.\\\")\\n    37→\\t\\tif err != nil {\\n    38→\\t\\t\\tt.Fatalf(\\\"agent failed: %v\\\", err)\\n    39→\\t\\t}\\n    40→\\n    41→\\t\\ts.Git(t, \\\"add\\\", \\\".\\\")\\n    42→\\t\\ts.Git(t, \\\"commit\\\", \\\"-m\\\", \\\"Add hello doc\\\")\\n    43→\\t\\ttestutil.WaitForCheckpoint(t, s, 15*time.Second)\\n    44→\\n    45→\\t\\t// Switch back to main and resume the feature branch.\\n    46→\\t\\ts.Git(t, \\\"checkout\\\", mainBranch)\\n    47→\\n    48→\\t\\tout, err := entire.Resume(s.Dir, \\\"feature\\\")\\n    49→\\t\\trequire.NoError(t, err, \\\"entire resume failed: %s\\\", out)\\n    50→\\n    51→\\t\\tcurrent := testutil.GitOutput(t, s.Dir, \\\"branch\\\", \\\"--show-current\\\")\\n    52→\\t\\tassert.Equal(t, \\\"feature\\\", current, \\\"should be on feature branch after resume\\\")\\n    53→\\t\\tassert.Contains(t, out, \\\"To continue\\\", \\\"resume output should show resume instructions\\\")\\n    54→\\t})\\n    55→}\\n    56→\\n    57→// TestResumeSquashMergeMultipleCheckpoints: two agent prompts on a feature\\n    58→// branch each get their own commit and checkpoint. The feature branch is\\n    59→// squash-merged to main and `entire resume` should restore only the latest\\n    60→// checkpoint (by CreatedAt), skipping older ones. Tests both squash merge message formats:\\n    61→//\\n    62→//   - GitHub format: trailers appear at the top level in the commit body\\n    63→//     (e.g. \\\"* Add red doc\\\\n\\\\nEntire-Checkpoint: aaa\\\\n\\\\n* Add blue doc\\\\n\\\\nEntire-Checkpoint: bbb\\\")\\n    64→//   - git CLI format: `git merge --squash` nests original commit messages\\n    65→//     (including trailers) indented with 4 spaces inside the squash message\\n    66→//\\n    67→// Both formats are tested in a single function to share the expensive agent\\n    68→// prompts. Main is reset between format tests.\\n    69→func TestResumeSquashMergeMultipleCheckpoints(t *testing.T) {\\n    70→\\ttestutil.ForEachAgent(t, 5*time.Minute, func(t *testing.T, s *testutil.RepoState, ctx context.Context) {\\n    71→\\t\\tmainBranch := testutil.GitOutput(t, s.Dir, \\\"branch\\\", \\\"--show-current\\\")\\n    72→\\n    73→\\t\\t// Commit files from `entire enable` so main has a clean working tree\\n    74→\\t\\t// for branch switching and squash