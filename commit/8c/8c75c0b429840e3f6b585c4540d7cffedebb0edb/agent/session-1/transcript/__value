rf(\\\"failed to rename session state file: %w\\\", err)\\n   342â†’\\t}\\n   343â†’\\treturn nil\\n   344â†’}\\n   345â†’\\n   346â†’// Clear removes the session state file for the given session ID.\\n   347â†’func (s *StateStore) Clear(ctx context.Context, sessionID string) error {\\n   348â†’\\t_ = ctx // Reserved for future use\\n   349â†’\\n   350â†’\\t// Validate session ID to prevent path traversal\\n   351â†’\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   352â†’\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   353â†’\\t}\\n   354â†’\\n   355â†’\\t// Remove all files for this session (state .json, .model hint, any future hint files).\\n   356â†’\\tmatches, _ := filepath.Glob(filepath.Join(s.stateDir, sessionID+\\\".*\\\")) //nolint:errcheck // pattern is always valid\\n   357â†’\\tfor _, f := range matches {\\n   358â†’\\t\\t_ = os.Remove(f)\\n   359â†’\\t}\\n   360â†’\\n   361â†’\\treturn nil\\n   362â†’}\\n   363â†’\\n   364â†’// RemoveAll removes the entire session state directory.\\n   365â†’// This is used during uninstall to completely remove all session state.\\n   366â†’func (s *StateStore) RemoveAll() error {\\n   367â†’\\tif err := os.RemoveAll(s.stateDir); err != nil {\\n   368â†’\\t\\treturn fmt.Errorf(\\\"failed to remove session state directory: %w\\\", err)\\n   369â†’\\t}\\n   370â†’\\treturn nil\\n   371â†’}\\n   372â†’\\n   373â†’// List returns all session states.\\n   374â†’func (s *StateStore) List(ctx context.Context) ([]*State, error) {\\n   375â†’\\tentries, err := os.ReadDir(s.stateDir)\\n   376â†’\\tif os.IsNotExist(err) {\\n   377â†’\\t\\treturn nil, nil\\n   378â†’\\t}\\n   379â†’\\tif err != nil {\\n   380â†’\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state directory: %w\\\", err)\\n   381â†’\\t}\\n   382â†’\\n   383â†’\\tvar states []*State\\n   384â†’\\tfor _, entry := range entries {\\n   385â†’\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   386â†’\\t\\t\\tcontinue\\n   387â†’\\t\\t}\\n   388â†’\\t\\tif strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   389â†’\\t\\t\\tcontinue // Skip temp files\\n   390â†’\\t\\t}\\n   391â†’\\n   392â†’\\t\\tsessionID := strings.TrimSuffix(entry.Name(), \\\".json\\\")\\n   393â†’\\t\\tstate, err := s.Load(ctx, sessionID)\\n   394â†’\\t\\tif err != nil {\\n   395â†’\\t\\t\\tcontinue // Skip corrupted state files\\n   396â†’\\t\\t}\\n   397â†’\\t\\tif state == nil {\\n   398â†’\\t\\t\\tcontinue // Not found or stale (Load handles cleanup)\\n   399â†’\\t\\t}\\n   400â†’\\n   401â†’\\t\\tstates = append(states, state)\\n   402â†’\\t}\\n   403â†’\\treturn states, nil\\n   404â†’}\\n   405â†’\\n   406â†’// stateFilePath returns the path to a session state file.\\n   407â†’func (s *StateStore) stateFilePath(sessionID string) string {\\n   408â†’\\treturn filepath.Join(s.stateDir, sessionID+\\\".json\\\")\\n   409â†’}\\n   410â†’\\n   411â†’// gitCommonDirCache caches the git common dir to avoid repeated subprocess calls.\\n   412â†’// Keyed by working directory to handle directory changes (same pattern as paths.WorktreeRoot).\\n   413â†’var (\\n   414â†’\\tgitCommonDirMu       sync.RWMutex\\n   415â†’\\tgitCommonDirCache    string\\n   416â†’\\tgitCommonDirCacheDir string\\n   417â†’)\\n   418â†’\\n   419â†’// ClearGitCommonDirCache clears the cached git common dir.\\n   420â†’// Useful for testing when changing directories.\\n   421â†’func ClearGitCommonDirCache() {\\n   422â†’\\tgitCommonDirMu.Lock()\\n   423â†’\\tgitCommonDirCache = \\\"\\\"\\n   424â†’\\tgitCommonDirCacheDir = \\\"\\\"\\n   425â†’\\tgitCommonDirMu.Unlock()\\n   426â†’}\\n   427â†’\\n   428â†’// getGitCommonDir returns the path to the shared git directory.\\n   429â†’// In a regular checkout, this is .git/\\n   430â†’// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n   431â†’// The result is cached per working directory.\\n   432â†’func getGitCommonDir(ctx context.Context) (str