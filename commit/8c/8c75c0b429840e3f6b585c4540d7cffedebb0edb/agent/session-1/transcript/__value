\t// PendingPromptAttribution holds attribution calculated at prompt start (before agent runs).\\n   162â†’\\t// This is moved to PromptAttributions when SaveStep is called.\\n   163â†’\\tPendingPromptAttribution *PromptAttribution `json:\\\"pending_prompt_attribution,omitempty\\\"`\\n   164â†’}\\n   165â†’\\n   166â†’// PromptAttribution captures line-level attribution data at the start of each prompt.\\n   167â†’// By recording what changed since the last checkpoint BEFORE the agent works,\\n   168â†’// we can accurately separate user edits from agent contributions.\\n   169â†’type PromptAttribution struct {\\n   170â†’\\t// CheckpointNumber is which checkpoint this was recorded before (1-indexed)\\n   171â†’\\tCheckpointNumber int `json:\\\"checkpoint_number\\\"`\\n   172â†’\\n   173â†’\\t// UserLinesAdded is lines added by user since the last checkpoint\\n   174â†’\\tUserLinesAdded int `json:\\\"user_lines_added\\\"`\\n   175â†’\\n   176â†’\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   177â†’\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   178â†’\\n   179â†’\\t// AgentLinesAdded is total agent lines added so far (base â†’ last checkpoint).\\n   180â†’\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   181â†’\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   182â†’\\n   183â†’\\t// AgentLinesRemoved is total agent lines removed so far (base â†’ last checkpoint).\\n   184â†’\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   185â†’\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   186â†’\\n   187â†’\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   188â†’\\t// This enables distinguishing user self-modifications from agent modifications.\\n   189â†’\\t// See docs/architecture/attribution.md for details.\\n   190â†’\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   191â†’}\\n   192â†’\\n   193â†’// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   194â†’// Call this after deserializing a State from JSON.\\n   195â†’func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   196â†’\\t// Normalize legacy phase values. \\\"active_committed\\\" was removed with the\\n   197â†’\\t// 1:1 checkpoint model in favor of the state machine handling commits\\n   198â†’\\t// during ACTIVE phase with immediate condensation.\\n   199â†’\\tif s.Phase == \\\"active_committed\\\" {\\n   200â†’\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   201â†’\\t\\tlogging.Info(logCtx, \\\"migrating legacy active_committed phase to active\\\",\\n   202â†’\\t\\t\\tslog.String(\\\"session_id\\\", s.SessionID),\\n   203â†’\\t\\t)\\n   204â†’\\t\\ts.Phase = PhaseActive\\n   205â†’\\t}\\n   206â†’\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n   207â†’\\ts.Phase = PhaseFromString(string(s.Phase))\\n   208â†’\\n   209â†’\\t// Migrate transcript fields: CheckpointTranscriptStart replaces both\\n   210â†’\\t// CondensedTranscriptLines and TranscriptLinesAtStart from older state files.\\n   211â†’\\tif s.CheckpointTranscriptStart == 0 {\\n   212â†’\\t\\tif s.CondensedTranscriptLines > 0 {\\n   213â†’\\t\\t\\ts.CheckpointTranscriptStart = s.CondensedTranscriptLines\\n   214â†’\\t\\t} else if s.TranscriptLinesAtStart > 0 {\\n   215â†’\\t\\t\\ts.CheckpointTranscriptStart = s.TranscriptLinesAtStart\\n   216â†’\\t\\t}\\n   217â†’\\t}\\n   218â†’\\t// Clear deprecated fields so they aren't re-persisted.\\n   219â†’\\t// Note: this is a one-way migration. If the state is re-saved, older CLI versions\\n   220â†’\\t// will see 0 for these fields and fall back to scoping from the transcript start.\\n   221â†’\\t// This is acceptable since CLI upgrades are monotonic and the worst case is\\n   222â†’\\t// redundant transcript content in a condensation, not data loss.\\n   223â†’\\ts.CondensedTranscriptLines = 0\\n   224â†’\\ts.TranscriptLinesAtStart = 0\\n   225â†’\\n   226â†’\\t// Backfill AttributionBaseCommit for sessions created before this field existed.\\n   227â†’\\t// Without this, a mid-turn commit would migrate BaseCommit and the fallback in\\n   228â†’\\t// calculateSessionAttributions would use the migrated value, producing zero attribution.\\n   229â†’\\tif s.AttributionBaseCommit == \\\"\\\" && s.BaseCommit != \\\"\\\" {\\n   230â†’\\t\\ts.AttributionBaseCommit = s.BaseCommit\\n   231â†’\\t}\\n   232â†’}\\n   233â†’\\n   234â†’// IsStale returns true when a session hasn't seen interaction for longer than\\n   235â†’// StaleSessionThreshold. Falls back to StartedAt when LastInteractionTime is\\n   236â†’// nil (sessions created before interaction tracking was added).\\n   237â†’func (s *State) IsStale() bool {\\n   238â†’\\tvar since time.Duration\\n   239â†’\\tif s.LastInteractionTime != nil {\\n   240â†’\\t\\tsince = time.Since(*s.LastInteractionTime)\\n   241â†’\\t} else {\\n   242â†’\\t\\tsince = time.Since(s.StartedAt)\\n   243â†’\\t}\\n   244â†’\\treturn since > StaleSessionThreshold\\n   245â†’}\\n   246â†’\\n   247â†’// StateStore provides low-level operations for managing session state files.\\n   248â†’//\\n   249â†’// StateStore is a primitive for session state persistence. It is NOT the same as\\n   250â†’// the Sessions interface - it only handles state files in .git/entire-sessions/,\\n   251â†’// not the full session data which includes checkpoint content.\\n   252â†’//\\n   253â†’// Use StateStore directly in strategies for performance-critical state operations.\\n   254â†’// Use the Sessions interface (when implemented) for high-level session management.\\n   255â†’type StateStore struct {\\n   256â†’\\t// stateDir is the directory where session state files are stored\\n   257â†’\\tstateDir string\\n   258â†’}\\n   259â†’\\n   260â†’// NewStateStore creates a new state store.\\n   261â†’// Uses the git common dir to store session state (shared across worktrees).\\n   262â†’func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   263â†’\\tcommonDir, err := getGitCommonDir(ctx)\\n   264â†’\\tif err != nil {\\n   265â†’\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   266â†’\\t}\\n   267â†’\\treturn &StateStore{\\n   268â†’\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   269â†’\\t}, nil\\n   270â†’}\\n   271â†’\\n   272â†’// NewStateStoreWithDir creates a new state store with a custom directory.\\n   273â†’// This is useful for testing.\\n   274â†’func NewStateStoreWithDir(stateDir string) *StateStore {\\n   275â†’\\treturn &StateStore{stateDir: stateDir}\\n   276â†’}\\n   277â†’\\n   278â†’// Load loads the session state for the given session ID.\\n   279â†’// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   280â†’// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   281â†’func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   282â†’\\t// Validate session ID to prevent path traversal\\n   283â†’\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   284â†’\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   285â†’\\t}\\n   286â†’\\n   287â†’\\tstateFile := s.stateFilePath(sessionID)\\n   288â†’\\n   289â†’\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is derived from sessionID\\n   290â†’\\tif os.IsNotExist(err) {\\n   291â†’\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   292â†’\\t}\\n   293â†’\\tif err != nil {\\n   294â†’\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   295â†’\\t}\\n   296â†’\\n   297â†’\\tvar state State\\n   298â†’\\tif err := json.Unmarshal(data, &state); err != nil {\\n   299â†’\\t\\treturn nil, fmt.Errorf(\\