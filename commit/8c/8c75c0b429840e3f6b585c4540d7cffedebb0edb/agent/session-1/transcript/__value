difiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   141â†’\\t}\\n   142â†’\\n   143â†’\\t// Filter to uncommitted files only\\n   144â†’\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   145â†’\\n   146â†’\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   147â†’\\t\\treturn fmt.Errorf(\\\"failed to set up strategy: %w\\\", err)\\n   148â†’\\t}\\n   149â†’\\n   150â†’\\t// Create session metadata directory and copy transcript\\n   151â†’\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   152â†’\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   153â†’\\tif err != nil {\\n   154â†’\\t\\treturn fmt.Errorf(\\\"failed to resolve session directory path: %w\\\", err)\\n   155â†’\\t}\\n   156â†’\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   157â†’\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   158â†’\\t}\\n   159â†’\\t// Normalize Gemini transcripts so the content field is a plain string\\n   160â†’\\t// (Gemini user messages use [{\\\"text\\\":\\\"...\\\"}] arrays, which the UI can't render).\\n   161â†’\\tstoredTranscript := transcriptData\\n   162â†’\\tif agentType == agent.AgentTypeGemini {\\n   163â†’\\t\\tif normalized, normErr := normalizeGeminiTranscript(transcriptData); normErr == nil {\\n   164â†’\\t\\t\\tstoredTranscript = normalized\\n   165â†’\\t\\t} else {\\n   166â†’\\t\\t\\tlogging.Warn(logCtx, \\\"failed to normalize Gemini transcript, storing raw\\\", \\\"error\\\", normErr)\\n   167â†’\\t\\t}\\n   168â†’\\t}\\n   169â†’\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   170â†’\\tif err := os.WriteFile(logFile, storedTranscript, 0o600); err != nil {\\n   171â†’\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   172â†’\\t}\\n   173â†’\\n   174â†’\\t// Get git author\\n   175â†’\\tauthor, err := GetGitAuthor(ctx)\\n   176â†’\\tif err != nil {\\n   177â†’\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   178â†’\\t}\\n   179â†’\\n   180â†’\\t// Extract first prompt from transcript for the commit message\\n   181â†’\\tfirstPrompt := extractFirstPromptFromTranscript(transcriptData)\\n   182â†’\\tcommitMessage := generateCommitMessage(firstPrompt, agentType)\\n   183â†’\\n   184â†’\\t// Write prompt.txt so SaveStep includes it on the shadow branch\\n   185â†’\\t// and CondenseSession can read it for the checkpoint metadata.\\n   186â†’\\tif firstPrompt != \\\"\\\" {\\n   187â†’\\t\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   188â†’\\t\\tif err := os.WriteFile(promptFile, []byte(firstPrompt), 0o600); err != nil {\\n   189â†’\\t\\t\\tlogging.Warn(logCtx, \\\"failed to write prompt file\\\", \\\"error\\\", err)\\n   190â†’\\t\\t}\\n   191â†’\\t}\\n   192â†’\\n   193â†’\\t// Initialize session state BEFORE SaveStep so it exists when SaveStep loads it\\n   194â†’\\tstrat := GetStrategy(ctx)\\n   195â†’\\tif err := strat.InitializeSession(ctx, sessionID, agentType, transcriptPath, firstPrompt, \\\"\\\"); err != nil {\\n   196â†’\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n   197â†’\\t}\\n   198â†’\\n   199â†’\\t// Enrich session state with transcript-derived metadata\\n   200â†’\\tif err := enrichSessionState(logCtx, sessionID, ag, transcriptData, transcriptPath); err != nil {\\n   201â†’\\t\\treturn err\\n   202â†’\\t}\\n   203â†’\\n   204â†’\\t// Build step context and save checkpoint\\n   205â†’\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   206â†’\\n   207â†’\\tstepCtx := strategy.StepContext{\\n   208â†’\\t\\tSessionID:      sessionID,\\n   209â†’\\t\\tModifiedFiles:  relModifiedFiles,\\n   210â†’\\t\\tNewFiles:       relNewFiles,\\n   211â†’\\t\\tDeletedFiles:   relDeletedFiles,\\n   212â†’\\t\\tMetadataDir:    sessionDir,\\n   213â†’\\t\\tMetadataDirAbs: sessionDirAbs,\\n   214â†’\\t\\tCommitMessage:  commitMessage,\\n   215â†’\\t\\tTranscriptPath: transcriptPath,\\n   216â†’\\t\\tAuthorName:     author.Name,\\n   217â†’\\t\\tAuthorEmail:    author.Email,\\n   218â†’\\t\\tAgentType:      agentType,\\n   219â†’\\t}\\n   220â†’\\n   221â†’\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   222â†’\\t\\treturn fmt.Errorf(\\\"failed to save checkpoint: %w\\\", err)\\n   223â†’\\t}\\n   224â†’\\n   225â†’\\tcheckpointIDStr, condenseErr := condenseAndFinalizeSession(logCtx, strat, sessionID)\\n   226â†’\\n   227â†’\\t// Print confirmation\\n   228â†’\\tfmt.Fprintf(w, \\\"Attached session %s\\\\n\\\", sessionID)\\n   229â†’\\tif totalChanges > 0 {\\n   230â†’\\t\\tfmt.Fprintf(w, \\\"  Checkpoint saved with %d file(s)\\\\n\\\", totalChanges)\\n   231â†’\\t} else {\\n   232â†’\\t\\tfmt.Fprintln(w, \\\"  Checkpoint saved (transcript only, no uncommitted file changes detected)\\\")\\n   233â†’\\t}\\n   234â†’\\tif condenseErr != nil {\\n   235â†’\\t\\tfmt.Fprintln(w, \\\"  Warning: checkpoint saved on shadow branch only (condensation failed)\\\")\\n   236â†’\\t}\\n   237â†’\\tfmt.Fprintln(w, \\\"  Session is now tracked â€” future prompts will be captured automatically\\\")\\n   238â†’\\n   239â†’\\t// Offer to amend the last commit with the checkpoint trailer\\n   240â†’\\tif checkpointIDStr != \\\"\\\" {\\n   241â†’\\t\\tif err := promptAmendCommit(ctx, w, checkpointIDStr, force); err != nil {\\n   242â†’\\t\\t\\tlogging.Warn(logCtx, \\\"failed to amend commit\\\", \\\"error\\\", err)\\n   243â†’\\t\\t\\tfmt.Fprintf(w, \\\"\\\\nCopy to your commit message to attach:\\\\n\\\\n  Entire-Checkpoint: %s\\\\n\\\", checkpointIDStr)\\n   244â†’\\t\\t}\\n   245â†’\\t}\\n   246â†’\\n   247â†’\\treturn nil\\n   248â†’}\\n   249â†’\\n   250â†’// enrichSessionState loads the session state after initialization and populates it with\\n   251â†’// transcript-derived metadata (token usage, turn count, model name, duration).\\n   252â†’func enrichSessionState(ctx context.Context, sessionID string, ag agent.Agent, transcriptData []byte, transcriptPath string) error {\\n   253â†’\\tstate, err := strategy.LoadSessionState(ctx, sessionID)\\n   254â†’\\tif err != nil {\\n   255â†’\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   256â†’\\t}\\n   257â†’\\tif state == nil {\\n   258â†’\\t\\treturn fmt.Errorf(\\\"session state not found after initialization (session_id=%s)\\\", sessionID)\\n   259â†’\\t}\\n   260â†’\\tstate.CLIVersion = versioninfo.Version\\n   261â†’\\tstate.TranscriptPath = transcriptPath\\n   262â†’\\n   263â†’\\tif usage := agent.CalculateTokenUsage(ctx, ag, transcriptData, 0, \\\"\\\"); usage != nil {\\n   264â†’\\t\\tstate.TokenUsage = usage\\n   265â†’\\t}\\n   266â†’\\tif turns := countUserTurns(transcriptData); turns > 0 {\\n   267â†’\\t\\tstate.SessionTurnCount = turns\\n   268â†’\\t}\\n   269â†’\\tif model := extractModelFromTranscript(transcriptData); model != \\\"\\\" {\\n   270â†’\\t\\tstate.ModelName = model\\n   271â†’\\t}\\n   272â†’\\tif dur := estimateSessionDuration(transcriptData); dur > 0 {\\n   273â†’\\t\\tstate.SessionDurationMs = dur\\n   274â†’\\t}\\n   275â†’\\n   276â†’\\tif err := strategy.SaveSessionState(ctx, state); err != nil {\\n   277â†’\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   278â†’\\t}\\n   279â†’\\treturn nil\\n   280â†’}\\n   281â†’\\n   282â†’// condenseAndFinalizeSession condenses the session to permanent storage and transitions it to IDLE.\\n   283â†’// Returns the checkpoint ID string and any condensation error.\\n   284â†’func condenseAndFinalizeSession(ctx context.Context, strat *strategy.ManualCommitStrategy, sessionID string) (string, error) {\\n   285â†’\\tvar checkpointIDStr string\\n   286â†’\\tvar condenseErr error\\n   287â†’\\tif err := strat.CondenseSessionByID(ctx, sessionID); err != nil {\\n   288â†’\\t\\tlogging.Warn(ctx, \\\"failed to condense session\\\", \\\"error\\\", err, \\\"session_id\\\", sessionID)\\n   289â†’\\t\\tcondenseErr = err\\n   290â†’\\t}\\n   291â†’\\n   292â†’\\t// Single load serves both checkpoint ID extraction and finalization\\n   293â†’\\tstate, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   294â†’\\tif loadErr != nil {\\n   295â†’\\t\\tlogging.Warn(ctx, \\\"failed to load session state after condensation\\\", \\\"error\\\", loadErr, \\\"session_id\\\", sessionID)\\n   296â†’\\t\\treturn checkpointIDStr, condenseErr\\n   297â†’\\t}\\n   298â†’\\tif state == nil {\\n   299â†’\\t\\treturn checkpointIDStr, condenseErr\\n   300â†’\\t}\\n   301â†’\\n   302â†’\\tif condenseErr == nil {\\n   303â†’\\t\\tcheckpointIDStr = state.LastCheckpointID.String()\\n   304â†’\\t}\\n   305â†’\\n   306â†’\\tnow := time.Now()\\n   307â†’\\tstate.LastInteractionTime = &now\\n   308â†’\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   309â†’\\t\\tlogging.Warn(ctx, \\\"failed to transition session to idle\\\", \\\"error\\\", transErr, \\\"session_id\\\", sessionID)\\n   310â†’\\t}\\n   311â†’\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   312â†’\\t\\tlogging.Warn(ctx, \\\"failed to save session state after transition\\\", \\\"error\\\", saveErr, \\\"session_id\\\", sessionID)\\n   313â†’\\t}\\n   314â†’\\n   315â†’\\treturn checkpointIDStr, condenseErr\\n   316â†’}\\n   317â†’\\n   318â†’// promptAmendCommit shows the last commit and asks whether to amend it with the checkpoint trailer.\\n   319â†’// When force is true, it amends without prompting.\\n   320â†’func promptAmendCommit(ctx context.Context, w io.Writer, checkpointIDStr string, force bool) error {\\n   321â†’\\t// Get HEAD commit info\\n   322â†’\\trepo, err := openRepository(ctx)\\n   323â†’\\tif err != nil {\\n   324â†’\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   325â†’\\t}\\n   326â†’\\theadRef, err := repo.Head()\\n   327â†’\\tif err != nil {\\n   328â†’\\t\\treturn fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   329â†’\\t}\\n   330â†’\\theadCommit, err := repo.CommitObject(headRef.Hash())\\n   331â†’\\tif err != nil {\\n   332â†’\\t\\treturn fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   333â†’\\t}\\n   334â†’\\n   335â†’\\tshortHash := headRef.Hash().String()[:7]\\n   336â†’\\tsubject := strings.SplitN(headCommit.Message, \\\"\\\\n\\\", 2)[0]\\n   337â†’\\n   338â†’\\t// Check if the commit already has this checkpoint trailer\\n   339â†’\\tif _, found := trailers.ParseCheckpoint(headCommit.Message); found {\\n   340â†’\\t\\tfmt.Fprintf(w, \\\"\\\\nLast commit already has an Entire-Checkpoint trailer.\\\\n\\\")\\n   341â†’\\t\\treturn nil\\n   342â†’\\t}\\n   343â†’\\n   344â†’\\tfmt.Fprintf(w, \\\"\\\\nLast commit: %s %s\\\\n\\\", shortHash, subject)\\n   345â†’\\n   346â†’\\tamend := true\\n   347â†’\\tif !force {\\n   348â†’\\t\\tform := NewAccessibleForm(\\n   349â†’\\t\\t\\thuh.NewGroup(\\n   350â†’\\t\\t\\t\\thuh.NewConfirm().\\n   351â†’\\t\\t\\t\\t\\tTitle(\\\"Amend the last commit in this branch?\\\").\\n   352â†’\\t\\t\\t\\t\\tAffirmative(\\\"Y\\\").\\n   353â†’\\t\\t\\t\\t\\tNegative(\\\"n\\\").\\n   354â†’\\t\\t\\t\\t\\tValue(&amend),\\n   355â†’\\t\\t\\t),\\n   356â†’\\t\\t)\\n   357â†’\\t\\tif err := form.Run(); err != nil {\\n   358â†’\\t\\t\\treturn fmt.Errorf(\\\"prompt failed: %w\\\", err)\\n   359â†’\\t\\t}\\n   360â†’\\t}\\n   361â†’\\n   362â†’\\tif !amend {\\n   363â†’\\t\\tfmt.Fprintf(w, \\\"\\\\nCopy to your commit message to attach:\\\\n\\\\n  Entire-Checkpoint: %s\\\\n\\\", checkpointIDStr)\\n   364â†’\\t\\treturn nil\\n   365â†’\\t}\\n   366â†’\\n   367â†’\\t// Amend the commit with the checkpoint trailer\\n   368â†’\\tnewMessage := fmt.Sprintf(\\\"%s\\\\n\\\\n%s: %s\\\\n\\\", strings.TrimRight(headCommit.Message, \\\"\\\\n\\\"), trailers.CheckpointTrailerKey, checkpointIDStr)\\n   369â†’\\n   370â†’\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"commit\\\", \\\"--amend\\\", \\\"-m\\\", newMessage)\\n   371â†’\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   372â†’\\t\\treturn fmt.Errorf(\\\"failed to amend commit: %w\\\\n%s\\\", err, output)\\n   373â†’\\t}\\n   374â†’\\n   375â†’\\tfmt.Fprintf(w, \\\"Amended commit %s with Entire-Checkpoint: %s\\\\n\\\", shortHash, checkpointIDStr)\\n   376â†’\\treturn nil\\n   377â†’}\\n   378â†’\\n   379â†’// extractFirstPromptFromTranscript reads transcript bytes and returns the first user prompt.\\n   380â†’// Supports both JSONL format (Claude Code, Cursor, OpenCode) and Gemini JSON format.\\n   381â†’func extractFirstPromptFromTranscript(data []byte) string {\\n   382â†’\\t// Try JSONL format first (Claude Code, Cursor, OpenCode, etc.)\\n   383â†’\\tlines, err := transcript.ParseFromBytes(data)\\n   384â†’\\tif err == nil {\\n   385â†’\\t\\tfor _, line := range lines {\\n   386â†’\\t\\t\\tif line.Type == transcript.TypeUser {\\n   387â†’\\t\\t\\t\\tprompt := extractTextFromMessage(line.Message)\\n   388â†’\\t\\t\\t\\tif prompt != \\\"\\\" {\\n   389â†’\\t\\t\\t\\t\\treturn prompt\\n   390â†’\\t\\t\\t\\t}\\n   391â†’\\t\\t\\t}\\n   392â†’\\t\\t}\\n   393â†’\\t}\\n   394â†’\\n   395â†’\\t// Fallback: try Gemini JSON format {\\\"messages\\\": [...]}\\n   396â†’\\tif prompts, gemErr := geminicli.ExtractAllUserPrompts(data); gemErr == nil && len(prompts) > 0 {\\n   397â†’\\t\\treturn prompts[0]\\n   398â†’\\t}\\n   399â†’\\n   400â†’\\treturn \\\"\\\"\\n   401â†’}\\n   402â†’\\n   403â†’// extractTextFromMessage extracts the text content from a transcript message.\\n   404â†’func extractTextFromMessage(msg json.RawMessage) string {\\n   405â†’\\t// Try string content first (simple user messages)\\n   406â†’\\tvar simple struct {\\n   407â†’\\t\\tContent string `json:\\\"content\\\"`\\n   408â†’\\t}\\n   409â†’\\tif err := json.Unmarshal(msg, &simple); err == nil && simple.Content != \\\"\\\" {\\n   410â†’\\t\\treturn simple.Content\\n   411â†’\\t}\\n   412â†’\\n   413â†’\\t// Try array content (messages with tool results, text blocks, etc.)\\n   414â†’\\tvar array struct {\\n   415â†’\\t\\tContent []struct {\\n   416â†’\\t\\t\\tType string `json:\\\"type\\\"`\\n   417â†’\\t\\t\\tText string `json:\\\"text\\\"`\\n   418â†’\\t\\t} `json:\\\"content\\\"`\\n   419â†’\\t}\\n   420â†’\\tif err := json.Unmarshal(msg, &array); err == nil {\\n   421â†’\\t\\tfor _, block := range array.Content {\\n   422â†’\\t\\t\\tif block.Type == \\\"text\\\" && block.Text != \\\"\\\" {\\n   423â†’\\t\\t\\t\\treturn block.Text\\n   424â†’\\t\\t\\t}\\n   425â†’\\t\\t}\\n   426â†’\\t}\\n   427â†’\\n   428â†’\\treturn \\\"\\\"\\n   429â†’}\\n   430â†’\\n   431â†’// normalizeGeminiTranscript re-serializes a Gemini JSON transcript so that all\\n   432â†’// content fields are plain strings. Gemini user messages store content as\\n   433â†’// [{\\\"text\\\":\\\"...\\\"}] arrays, but the UI expects string content. Parsing through\\n   434â†’// geminicli.ParseTranscript normalizes this via GeminiMessage.UnmarshalJSON.\\n   435â†’func normalizeGeminiTranscript(data []byte) ([]byte, error) {\\n   436â†’\\tparsed, err := geminicli.ParseTranscript(data)\\n   437â†’\\tif err != nil {\\n   438â†’\\t\\treturn nil, fmt.Errorf(\\\"failed to parse Gemini transcript: %w\\\", err)\\n   439â†’\\t}\\n   440â†’\\tnormalized, err := json.MarshalIndent(parsed, \\\"\\\", \\\"  \\\")\\n   441â†’\\tif err != nil {\\n   442â†’\\t\\treturn nil, fmt.Errorf(\\\"failed to re-serialize Gemini transcript: %w\\\", err)\\n   443â†’\\t}\\n   444â†’\\treturn normalized, nil\\n   445â†’}\\n   446â†’\\n   447â†’// countUserTurns counts real user prompts in a transcript (excluding tool_result messages).\\n   448â†’// Supports both JSONL format (Claude Code, Cursor) and Gemini JSON format.\\n   449â†’func countUserTurns(data []byte) int {\\n   450â†’\\t// Try JSONL format first â€” use extractTextFromMessage to distinguish\\n   451â†’\\t// real user prompts from tool_result messages (both have type \\\"user\\\").\\n   452â†’\\tlines, err := transcript.ParseFromBytes(data)\\n   453â†’\\tif err == nil {\\n   454â†’\\t\\tcount := 0\\n   455â†’\\t\\tfor _, line := range lines {\\n   456â†’\\t\\t\\tif line.Type == transcript.TypeUser {\\n   457â†’\\t\\t\\t\\tif extractTextFromMessage(line.Message) != \\\"\\\" {\\n   458â†’\\t\\t\\t\\t\\tcount++\\n   459â†’\\t\\t\\t\\t}\\n   460â†’\\t\\t\\t}\\n   461â†’\\t\\t}\\n   462â†’\\t\\tif count > 0 {\\n   463â†’\\t\\t\\treturn count\\n   464â†’\\t\\t}\\n   465â†’\\t}\\n   466â†’\\n   467â†’\\t// Fallback: Gemini JSON format\\n   468â†’\\tif prompts, gemErr := geminicli.ExtractAllUserPrompts(data); gemErr == nil {\\n   469â†’\\t\\treturn len(prompts)\\n   470â†’\\t}\\n   471â†’\\n   472â†’\\treturn 0\\n   473â†’}\\n   474â†’\\n   475â†’// extractModelFromTranscript extracts the model name from a JSONL transcript.\\n   476â†’// Best-effort: returns empty string if the transcript format doesn't include model info\\n   477â†’// (e.g., Gemini stores model info in hook events, not the transcript).\\n   478â†’func extractModelFromTranscript(data []byte) string {\\n   479â†’\\tlines, err := transcript.ParseFromBytes(data)\\n   480â†’\\tif err != nil {\\n   481â†’\\t\\treturn \\\"\\\"\\n   482â†’\\t}\\n   483â†’\\n   484â†’\\tfor _, line := range lines {\\n   485â†’\\t\\tif line.Type != transcript.TypeAssistant {\\n   486â†’\\t\\t\\tcontinue\\n   487â†’\\t\\t}\\n   488â†’\\t\\tvar msg struct {\\n   489â†’\\t\\t\\tModel string `json:\\\"model\\\"`\\n   490â†’\\t\\t}\\n   491â†’\\t\\tif err := json.Unmarshal(line.Message, &msg); err == nil && msg.Model != \\\"\\\" {\\n   492â†’\\t\\t\\treturn msg.Model\\n   493â†’\\t\\t}\\n   494â†’\\t}\\n   495â†’\\treturn \\\"\\\"\\n   496â†’}\\n   497â†’\\n   498â†’// estimateSessionDuration estimates session duration in milliseconds from JSONL transcript timestamps.\\n   499â†’// The \\\"timestamp\\\" field is a top-level field in JSONL lines (alongside \\\"type\\\", \\\"uuid\\\", \\\"message\\\"),\\n   500â†’// NOT inside the \\\"message\\\" object. We parse raw lines since transcript.Line doesn't capture it.\\n   501â†’// Returns 0 if timestamps are not available (e.g., Gemini transcripts).\\n   502â†’func estimateSessionDuration(data []byte) int64 {\\n   503â†’\\ttype timestamped struct {\\n   504â†’\\t\\tTimestamp string `json:\\\"timestamp\\\"`\\n   505â†’\\t}\\n   506â†’\\n   507â†’\\tvar first, last time.Time\\n   508â†’\\tfor _, rawLine := range bytes.Split(data, []byte(\\\"\\\\n\\\")) {\\n   509â†’\\t\\tif len(rawLine) == 0 {\\n   510â†’\\t\\t\\tcontinue\\n   511â†’\\t\\t}\\n   512â†’\\t\\tvar ts timestamped\\n   513â†’\\t\\tif err := json.Unmarshal(rawLine, &ts); err != nil || ts.Timestamp == \\\"\\\" {\\n   514â†’\\t\\t\\tcontinue\\n   515â†’\\t\\t}\\n   516â†’\\t\\tparsed, err := time.Parse(time.RFC3339Nano, ts.Timestamp)\\n   517â†’\\t\\tif err != nil {\\n   518â†’\\t\\t\\tparsed, err = time.Parse(time.RFC3339, ts.Timestamp)\\n   519â†’\\t\\t\\tif err != nil {\\n   520â†’\\t\\t\\t\\tcontinue\\n   521â†’\\t\\t\\t}\\n   522â†’\\t\\t}\\n   523â†’\\t\\tif first.IsZero() {\\n   524â†’\\t\\t\\tfirst = parsed\\n   525â†’\\t\\t}\\n   526â†’\\t\\tlast = parsed\\n   527â†’\\t}\\n   528â†’\\n   529â†’\\tif first.IsZero() || last.IsZero() || !last.After(first) {\\n   530â†’\\t\\treturn 0\\n   531â†’\\t}\\n   532â†’\\treturn last.Sub(first).Milliseconds()\\n   533â†’}\\n   534â†’\"}]},\"uuid\":\"ecabd685-80b1-4476-bc93-b6ecad621e35\",\"timestamp\":\"2026-03-12T23:49:00.620Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/ninawork/entire/devenv/cli/cmd/entire/cli/attach.go\",\"content\":\"package cli\\n\\nimport (\\n\\t\\\"bytes\\\"\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"io\\\"\\n\\t\\\"os\\\"\\n\\t\\\"os/exec\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/versioninfo\\\"\\n\\n\\t\\\"github.com/charmbracelet/huh\\\"\\n\\t\\\"github.com/spf13/cobra\\\"\\n)\\n\\nfunc newAttachCmd() *cobra.Command {\\n\\tvar (\\n\\t\\tforce     bool\\n\\t\\tagentFlag string\\n\\t)\\n\\tcmd := &cobra.Command{\\n\\t\\tUse:   \\\"attach <session-id>\\\",\\n\\t\\tShort: \\\"Attach an existing agent session\\\",\\n\\t\\tLong: `Attach an existing agent session that wasn't captured by hooks.\\n\\nThis creates a checkpoint from the session's transcript and registers the\\nsession for future tracking. Use this when hooks failed to fire or weren't\\ninstalled when the session started.\\n\\nSupported agents: claude-code, gemini, opencode, cursor, copilot-cli, factoryai-droid`,\\n\\t\\tArgs: cobra.ExactArgs(1),\\n\\t\\tRunE: func(cmd *cobra.Command, args []string) error {\\n\\t\\t\\tif checkDisabledGuard(cmd.Context(), cmd.OutOrStdout()) {\\n\\t\\t\\t\\treturn nil\\n\\t\\t\\t}\\n\\t\\t\\tagentName := types.AgentName(agentFlag)\\n\\t\\t\\treturn runAttach(cmd.Context(), cmd.OutOrStdout(), args[0], agentName, force)\\n\\t\\t},\\n\\t}\\n\\tcmd.Flags().BoolVarP(&force, \\\"force\\\", \\\"f\\\", false, \\\"Skip confirmation and amend the last commit with the checkpoint trailer\\\")\\n\\tcmd.Flags().StringVarP(&agentFlag, \\\"agent\\\", \\\"a\\\", string(agent.DefaultAgentName), \\\"Agent that created the session (claude-code, gemini, opencode, cursor, copilot-cli, factoryai-droid)\\\")\\n\\treturn cmd\\n}\\n\\nfunc runAttach(ctx context.Context, w io.Writer, sessionID string, agentName types.AgentName, force bool) error {\\n\\tlogCtx := logging.WithComponent(ctx, \\\"attach\\\")\\n\\n\\t// Validate session ID format\\n\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n\\t}\\n\\n\\t// Ensure we're in a git repo\\n\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n\\t}\\n\\n\\t// Check session isn't already tracked\\n\\tstore, err := session.NewStateStore(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open session store: %w\\\", err)\\n\\t}\\n\\texisting, err := store.Load(ctx, sessionID)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to check existing session: %w\\\", err)\\n\\t}\\n\\tif existing != nil {\\n\\t\\treturn fmt.Errorf(\\\"session %s is already tracked by Entire\\\", sessionID)\\n\\t}\\n\\n\\t// Resolve agent and transcript path\\n\\tag, err := agent.Get(agentName)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"agent %q not available: %w\\\", agentName, err)\\n\\t}\\n\\tagentType := ag.Type()\\n\\n\\ttranscriptPath, err := resolveTranscriptPath(ctx, sessionID, ag)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to resolve transcript path: %w\\\", err)\\n\\t}\\n\\t// Agents use cwd-derived project directories, so the transcript may be stored under\\n\\t// a different project directory if the session was started from a different working directory.\\n\\tif _, statErr := os.Stat(transcriptPath); statErr != nil {\\n\\t\\tif found, searchErr := searchTranscriptInProjectDirs(agentName, sessionID, ag); searchErr == nil {\\n\\t\\t\\tlogging.Info(logCtx, \\\"found transcript in alternative project directory\\\", \\\"path\\\", found)\\n\\t\\t\\ttranscriptPath = found\\n\\t\\t} else {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"fallback transcript search failed\\\", \\\"error\\\", searchErr)\\n\\t\\t}\\n\\t}\\n\\tif _, statErr := os.Stat(transcriptPath); statErr != nil {\\n\\t\\treturn fmt.Errorf(\\\"transcript not found for agent %q with session %s; is the session ID correct?\\\", agentName, sessionID)\\n\\t}\\n\\n\\t// Read transcript data\\n\\ttranscriptData, err := ag.ReadTranscript(transcriptPath)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n\\t}\\n\\n\\t// Extract modified files from transcript\\n\\tvar modifiedFiles []string\\n\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok {\\n\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptPath, 0); fileErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files from transcript\\\", \\\"error\\\", fileErr)\\n\\t\\t} else {\\n\\t\\t\\tmodifiedFiles = files\\n\\t\\t}\\n\\t}\\n\\n\\t// Detect file changes via git status (no pre-untracked filter since we don't know pre-state)\\n\\tchanges, err := DetectFileChanges(ctx, nil)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to detect file changes, checkpoint may be incomplete\\\", \\\"error\\\", err)\\n\\t}\\n\\n\\t// Filter and normalize paths\\n\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n\\tvar relNewFiles, relDeletedFiles []string\\n\\tif changes != nil {\\n\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n\\t}\\n\\n\\t// Filter to uncommitted files only\\n\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n\\n\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to set up strategy: %w\\\", err)\\n\\t}\\n\\n\\t// Create session metadata directory and copy transcript\\n\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to resolve session directory path: %w\\\", err)\\n\\t}\\n\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n\\t}\\n\\t// Normalize Gemini transcripts so the content field is a plain string\\n\\t// (Gemini user messages use [{\\\"text\\\":\\\"...\\\"}] arrays, which the UI can't render).\\n\\tstoredTranscript := transcriptData\\n\\tif agentType == agent.AgentTypeGemini {\\n\\t\\tif normalized, normErr := normalizeGeminiTranscript(transcriptData); normErr == nil {\\n\\t\\t\\tstoredTranscript = normalized\\n\\t\\t} else {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to normalize Gemini transcript, storing raw\\\", \\\"error\\\", normErr)\\n\\t\\t}\\n\\t}\\n\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n\\tif err := os.WriteFile(logFile, storedTranscript, 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n\\t}\\n\\n\\t// Get git author\\n\\tauthor, err := GetGitAuthor(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n\\t}\\n\\n\\t// Extract first prompt from transcript for the commit message\\n\\tfirstPrompt := extractFirstPromptFromTranscript(transcriptData)\\n\\tcommitMessage := generateCommitMessage(firstPrompt, agentType)\\n\\n\\t// Write prompt.txt so SaveStep includes it on the shadow branch\\n\\t// and CondenseSession can read it for the checkpoint metadata.\\n\\tif firstPrompt != \\\"\\\" {\\n\\t\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n\\t\\tif err := os.WriteFile(promptFile, []byte(firstPrompt), 0o600); err != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to write prompt file\\\", \\\"error\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// Initialize session state BEFORE SaveStep so it exists when SaveStep loads it\\n\\tstrat := GetStrategy(ctx)\\n\\tif err := strat.InitializeSession(ctx, sessionID, agentType, transcriptPath, firstPrompt, \\\"\\\"); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n\\t}\\n\\n\\t// Enrich session state with transcript-derived metadata\\n\\tif err := enrichSessionState(logCtx, sessionID, ag, transcriptData, transcriptPath); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Build step context and save checkpoint\\n\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n\\n\\tstepCtx := strategy.StepContext{\\n\\t\\tSessionID:      sessionID,\\n\\t\\tModifiedFiles:  relModifiedFiles,\\n\\t\\tNewFiles:       relNewFiles,\\n\\t\\tDeletedFiles:   relDeletedFiles,\\n\\t\\tMetadataDir:    sessionDir,\\n\\t\\tMetadataDirAbs: sessionDirAbs,\\n\\t\\tCommitMessage:  commitMessage,\\n\\t\\tTranscriptPath: transcriptPath,\\n\\t\\tAuthorName:     author.Name,\\n\\t\\tAuthorEmail:    author.Email,\\n\\t\\tAgentType:      agentType,\\n\\t}\\n\\n\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save checkpoint: %w\\\", err)\\n\\t}\\n\\n\\tcheckpointIDStr, condenseErr := condenseAndFinalizeSession(logCtx, strat, sessionID)\\n\\n\\t// Print confirmation\\n\\tfmt.Fprintf(w, \\\"Attached session %s\\\\n\\\", sessionID)\\n\\tif totalChanges > 0 {\\n\\t\\tfmt.Fprintf(w, \\\"  Checkpoint saved with %d file(s)\\\\n\\\", totalChanges)\\n\\t} else {\\n\\t\\tfmt.Fprintln(w, \\\"  Checkpoint saved (transcript only, no uncommitted file changes detected)\\\")\\n\\t}\\n\\tif condenseErr != nil {\\n\\t\\tfmt.Fprintln(w, \\\"  Warning: checkpoint saved on shadow branch only (condensation failed)\\\")\\n\\t}\\n\\tfmt.Fprintln(w, \\\"  Session is now tracked â€” future prompts will be captured automatically\\\")\\n\\n\\t// Offer to amend the last commit with the checkpoint trailer\\n\\tif checkpointIDStr != \\\"\\\" {\\n\\t\\tif err := promptAmendCommit(ctx, w, checkpointIDStr, force); err != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to amend commit\\\", \\\"error\\\", err)\\n\\t\\t\\tfmt.Fprintf(w, \\\"\\\\nCopy to your commit message to attach:\\\\n\\\\n  Entire-Checkpoint: %s\\\\n\\\", checkpointIDStr)\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// enrichSessionState loads the session state after initialization and populates it with\\n// transcript-derived metadata (token usage, turn count, model name, duration).\\nfunc enrichSessionState(ctx context.Context, sessionID string, ag agent.Agent, transcriptData []byte, transcriptPath string) error {\\n\\tstate, err := strategy.LoadSessionState(ctx, sessionID)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n\\t}\\n\\tif state == nil {\\n\\t\\treturn fmt.Errorf(\\\"session state not found after initialization (session_id=%s)\\\", sessionID)\\n\\t}\\n\\tstate.CLIVersion = versioninfo.Version\\n\\tstate.TranscriptPath = transcriptPath\\n\\n\\tif usage := agent.CalculateTokenUsage(ctx, ag, transcriptData, 0, \\\"\\\"); usage != nil {\\n\\t\\tstate.TokenUsage = usage\\n\\t}\\n\\tif turns := countUserTurns(transcriptData); turns > 0 {\\n\\t\\tstate.SessionTurnCount = turns\\n\\t}\\n\\tif model := extractModelFromTranscript(transcriptData); model != \\\"\\\" {\\n\\t\\tstate.ModelName = model\\n\\t}\\n\\tif dur := estimateSessionDuration(transcriptData); dur > 0 {\\n\\t\\tstate.SessionDurationMs = dur\\n\\t}\\n\\n\\tif err := strategy.SaveSessionState(ctx, state); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n\\t}\\n\\treturn nil\\n}\\n\\n// condenseAndFinalizeSession condenses the session to permanent storage and transitions it to IDLE.\\n// Returns the checkpoint ID string and any condensation error.\\nfunc condenseAndFinalizeSession(ctx context.Context, strat *strategy.ManualCommitStrategy, sessionID string) (string, error) {\\n\\tvar checkpointIDStr string\\n\\tvar condenseErr error\\n\\tif err := strat.CondenseSessionByID(ctx, sessionID); err != nil {\\n\\t\\tlogging.Warn(ctx, \\\"failed to condense session\\\", \\\"error\\\", err, \\\"session_id\\\", sessionID)\\n\\t\\tcondenseErr = err\\n\\t}\\n\\n\\t// Single load serves both checkpoint ID extraction and finalization\\n\\tstate, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n\\tif loadErr != nil {\\n\\t\\tlogging.Warn(ctx, \\\"failed to load session state after condensation\\\", \\\"error\\\", loadErr, \\\"session_id\\\", sessionID)\\n\\t\\treturn checkpointIDStr, condenseErr\\n\\t}\\n\\tif state == nil {\\n\\t\\treturn checkpointIDStr, condenseErr\\n\\t}\\n\\n\\tif condenseErr == nil {\\n\\t\\tcheckpointIDStr = state.LastCheckpointID.String()\\n\\t}\\n\\n\\tnow := time.Now()\\n\\tstate.LastInteractionTime = &now\\n\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\tlogging.Warn(ctx, \\\"failed to transition session to idle\\\", \\\"error\\\", transErr, \\\"session_id\\\", sessionID)\\n\\t}\\n\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n\\t\\tlogging.Warn(ctx, \\\"failed to save session state after transition\\\", \\\"error\\\", saveErr, \\\"session_id\\\", sessionID)\\n\\t}\\n\\n\\treturn checkpointIDStr, condenseErr\\n}\\n\\n// promptAmendCommit shows the last commit and asks whether to amend it with the checkpoint trailer.\\n// When force is true, it amends without prompting.\\nfunc promptAmendCommit(ctx context.Context, w io.Writer, checkpointIDStr string, force bool) error {\\n\\t// Get HEAD commit info\\n\\trepo, err := openRepository(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\theadRef, err := repo.Head()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n\\t}\\n\\theadCommit, err := repo.CommitObject(headRef.Hash())\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n\\t}\\n\\n\\tshortHash := headRef.Hash().String()[:7]\\n\\tsubject := strings.SplitN(headCommit.Message, \\\"\\\\n\\\", 2)[0]\\n\\n\\t// Check if the commit already has this checkpoint trailer\\n\\tif _, found := trailers.ParseCheckpoint(headCommit.Message); found {\\n\\t\\tfmt.Fprintf(w, \\\"\\\\nLast commit already has an Entire-Checkpoint trailer.\\\\n\\\")\\n\\t\\treturn nil\\n\\t}\\n\\n\\tfmt.Fprintf(w, \\\"\\\\nLast commit: %s %s\\\\n\\\", shortHash, subject)\\n\\n\\tamend := true\\n\\tif !force {\\n\\t\\tform := NewAccessibleForm(\\n\\t\\t\\thuh.NewGroup(\\n\\t\\t\\t\\thuh.NewConfirm().\\n\\t\\t\\t\\t\\tTitle(\\\"Amend the last commit in this branch?\\\").\\n\\t\\t\\t\\t\\tAffirmative(\\\"Y\\\").\\n\\t\\t\\t\\t\\tNegative(\\\"n\\\").\\n\\t\\t\\t\\t\\tValue(&amend),\\n\\t\\t\\t),\\n\\t\\t)\\n\\t\\tif err := form.Run(); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"prompt failed: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\tif !amend {\\n\\t\\tfmt.Fprintf(w, \\\"\\\\nCopy to your commit message to attach:\\\\n\\\\n  Entire-Checkpoint: %s\\\\n\\\", checkpointIDStr)\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Amend the commit with the checkpoint trailer\\n\\tnewMessage := fmt.Sprintf(\\\"%s\\\\n\\\\n%s: %s\\\\n\\\", strings.TrimRight(headCommit.Message, \\\"\\\\n\\\"), trailers.CheckpointTrailerKey, checkpointIDStr)\\n\\n\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"commit\\\", \\\"--amend\\\", \\\"-m\\\", newMessage)\\n\\tif output, err := cmd.CombinedOutput(); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to amend commit: %w\\\\n%s\\\", err, output)\\n\\t}\\n\\n\\tfmt.Fprintf(w, \\\"Amended commit %s with Entire-Checkpoint: %s\\\\n\\\", shortHash, checkpointIDStr)\\n\\treturn nil\\n}\\n\\n// extractFirstPromptFromTranscript reads transcript bytes and returns the first user prompt.\\n// Supports both JSONL format (Claude Code, Cursor, OpenCode) and Gemini JSON format.\\nfunc extractFirstPromptFromTranscript(data []byte) string {\\n\\t// Try JSONL fo