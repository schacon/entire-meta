\"fmt\\\"\\n    11→\\t\\\"os\\\"\\n    12→\\t\\\"path/filepath\\\"\\n    13→\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    16→)\\n    17→\\n    18→const (\\n    19→\\t// EntireSettingsFile is the path to the Entire settings file\\n    20→\\tEntireSettingsFile = \\\".entire/settings.json\\\"\\n    21→\\t// EntireSettingsLocalFile is the path to the local settings override file (not committed)\\n    22→\\tEntireSettingsLocalFile = \\\".entire/settings.local.json\\\"\\n    23→)\\n    24→\\n    25→// Commit linking mode constants.\\n    26→const (\\n    27→\\t// CommitLinkingAlways auto-links commits to sessions without prompting.\\n    28→\\tCommitLinkingAlways = \\\"always\\\"\\n    29→\\t// CommitLinkingPrompt prompts the user on each commit (default for existing users).\\n    30→\\tCommitLinkingPrompt = \\\"prompt\\\"\\n    31→)\\n    32→\\n    33→// EntireSettings represents the .entire/settings.json configuration\\n    34→type EntireSettings struct {\\n    35→\\n    36→\\t// Enabled indicates whether Entire is active. When false, CLI commands\\n    37→\\t// show a disabled message and hooks exit silently. Defaults to true.\\n    38→\\tEnabled bool `json:\\\"enabled\\\"`\\n    39→\\n    40→\\t// LocalDev indicates whether to use \\\"go run\\\" instead of the \\\"entire\\\" binary\\n    41→\\t// This is used for development when the binary is not installed\\n    42→\\tLocalDev bool `json:\\\"local_dev,omitempty\\\"`\\n    43→\\n    44→\\t// LogLevel sets the logging verbosity (debug, info, warn, error).\\n    45→\\t// Can be overridden by ENTIRE_LOG_LEVEL environment variable.\\n    46→\\t// Defaults to \\\"info\\\".\\n    47→\\tLogLevel string `json:\\\"log_level,omitempty\\\"`\\n    48→\\n    49→\\t// StrategyOptions contains strategy-specific configuration\\n    50→\\tStrategyOptions map[string]any `json:\\\"strategy_options,omitempty\\\"`\\n    51→\\n    52→\\t// AbsoluteGitHookPath embeds the full binary path in git hooks instead of\\n    53→\\t// bare \\\"entire\\\". This is needed for GUI git clients (Xcode, Tower, etc.)\\n    54→\\t// that don't source shell profiles and can't find \\\"entire\\\" on PATH.\\n    55→\\tAbsoluteGitHookPath bool `json:\\\"absolute_git_hook_path,omitempty\\\"`\\n    56→\\n    57→\\t// Telemetry controls anonymous usage analytics.\\n    58→\\t// nil = not asked yet (show prompt), true = opted in, false = opted out\\n    59→\\tTelemetry *bool `json:\\\"telemetry,omitempty\\\"`\\n    60→\\n    61→\\t// CommitLinking controls how commits are linked to agent sessions.\\n    62→\\t// \\\"always\\\" = auto-link without prompting, \\\"prompt\\\" = ask on each commit.\\n    63→\\t// Defaults to \\\"prompt\\\" (preserves existing user behavior).\\n    64→\\tCommitLinking string `json:\\\"commit_linking,omitempty\\\"`\\n    65→\\n    66→\\t// Deprecated: no longer used. Exists to tolerate old settings files\\n    67→\\t// that still contain \\\"strategy\\\": \\\"auto-commit\\\" or similar.\\n    68→\\tStrategy string `json:\\\"strategy,omitempty\\\"`\\n    69→}\\n    70→\\n    71→// GetCommitLinking returns the effective commit linking mode.\\n    72→// Returns the explicit value if set, otherwise defaults to \\\"prompt\\\"\\n    73→// to preserve existing user behavior.\\n    74→func (s *EntireSettings) GetCommitLinking() string {\\n    75→\\tif s.CommitLinking != \\\"\\\" {\\n    76→\\t\\treturn s.CommitLinking\\n    77→\\t}\\n    78→\\treturn CommitLinkingPrompt\\n    79→}\\n    80→\\n    81→// Load loads the Entire settings from .entire/settings.json,\\n    82→// then applies any overrides from .entire/settings.local.json if it exists.\\n    83→// Returns default settings if neither file exists.\\n    84→// Works correctly from any subdirectory within the repository.\\n    85→func Load(ctx context.Context) (*EntireSettings, error) {\\n    86→\\t// Get absolute paths for settings files\\n    87→\\tsettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsFile)\\n    88→\\tif err != nil {\\n    89→\\t\\tsettingsFileAbs = EntireSettingsFile // Fallback to relative\\n    90→\\t}\\n    91→\\tlocalSettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsLocalFile)\\n    92→\\tif err != nil {\\n    93→\\t\\tlocalSettingsFileAbs = EntireSettingsLocalFile // Fallback to relative\\n    94→\\t}\\n    95→\\n    96→\\t// Load base settings\\n    97→\\tsettings, err := loadFromFile(settingsFileAbs)\\n    98→\\tif err != nil {\\n    99→\\t\\treturn nil, fmt.Errorf(\\\"reading settings file: %w\\\", err)\\n   100→\\t}\\n   101→\\n   102→\\t// Apply local overrides if they exist\\n   103→\\tlocalData, err := os.ReadFile(localSettingsFileAbs) //nolint:gosec // path is from AbsPath or constant\\n   104→\\tif err != nil {\\n   105→\\t\\tif !os.IsNotExist(err) {\\n   106→\\t\\t\\treturn nil, fmt.Errorf(\\\"reading local settings file: %w\\\", err)\\n   107→\\t\\t}\\n   108→\\t\\t// Local file doesn't exist, continue without overrides\\n   109→\\t} else {\\n   110→\\t\\tif err := mergeJSON(settings, localData); err != nil {\\n   111→\\t\\t\\treturn nil, fmt.Errorf(\\\"merging local settings: %w\\\", err)\\n   112→\\t\\t}\\n   113→\\t}\\n   114→\\n   115→\\treturn settings, nil\\n   116→}\\n   117→\\n   118→// LoadFromFile loads settings from a specific file path without merging local overrides.\\n   119→// Returns default settings if the file doesn't exist.\\n   120→// Use this when you need to display individual settings files separately.\\n   121→func LoadFromFile(filePath string) (*EntireSettings, error) {\\n   122→\\treturn loadFromFile(filePath)\\n   123→}\\n   124→\\n   125→// loadFromFile loads settings from a specific file path.\\n   126→// Returns default settings if the file doesn't exist.\\n   127→func loadFromFile(filePath string) (*EntireSettings, error) {\\n   128→\\tsettings := &EntireSettings{\\n   129→\\t\\tEnabled: true, // Default to enabled\\n   130→\\t}\\n   131→\\n   132→\\tdata, err := os.ReadFile(filePath) //nolint:gosec // path is from caller\\n   133→\\tif err != nil {\\n   134→\\t\\tif os.IsNotExist(err) {\\n   135→\\t\\t\\treturn settings, nil\\n   136→\\t\\t}\\n   137→\\t\\treturn nil, fmt.Errorf(\\\"%w\\\", err)\\n   138→\\t}\\n   139→\\n   140→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   141→\\tdec.DisallowUnknownFields()\\n   142→\\tif err := dec.Decode(settings); err != nil {\\n   143→\\t\\treturn nil, fmt.Errorf(\\\"parsing settings file: %w\\\", err)\\n   144→\\t}\\n   145→\\n   146→\\t// Validate commit_linking if set\\n   147→\\tif settings.CommitLinking != \\\"\\\" && settings.CommitLinking != CommitLinkingAlways && settings.CommitLinking != CommitLinkingPrompt {\\n   148→\\t\\treturn nil, fmt.Errorf(\\\"invalid commit_linking value %q: must be %q or %q\\\", settings.CommitLinking, CommitLinkingAlways, CommitLinkingPrompt)\\n   149→\\t}\\n   150→\\n   151→\\treturn settings, nil\\n   152→}\\n   153→\\n   154→// mergeJSON merges JSON data into existing settings.\\n   155→// Only non-zero values from the JSON override existing settings.\\n   156→func mergeJSON(settings *EntireSettings, data []byte) error {\\n   157→\\t// First, validate that there are no unknown keys using strict decoding\\n   158→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   159→\\tdec.DisallowUnknownFields()\\n   160→\\tvar temp EntireSettings\\n   161→\\tif err := dec.Decode(&temp); err != nil {\\n   162→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   163→\\t}\\n   164→\\n   165→\\t// Parse into a map to check which fields are present\\n   166→\\tvar raw map[string]json.RawMessage\\n   167→\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   168→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   169→\\t}\\n   170→\\n   171→\\t// Override enabled if present\\n   172→\\tif enabledRaw, ok := raw[\\\"enabled\\\"]; ok {\\n   173→\\t\\tvar e bool\\n   174→\\t\\tif err := json.Unmarshal(enabledRaw, &e); err != nil {\\n   175→\\t\\t\\treturn fmt.Errorf(\\\"parsing enabled field: %w\\\", err)\\n   176→\\t\\t}\\n   177→\\t\\tsettings.Enabled = e\\n   178→\\t}\\n   179→\\n   180→\\t// Override local_dev if present\\n   181→\\tif localDevRaw, ok := raw[\\\"local_dev\\\"]; ok {\\n   182→\\t\\tvar ld bool\\n   183→\\t\\tif err := json.Unmarshal(localDevRaw, &ld); err != nil {\\n   184→\\t\\t\\treturn fmt.Errorf(\\\"parsing local_dev field: %w\\\", err)\\n   185→\\t\\t}\\n   186→\\t\\tsettings.LocalDev = ld\\n   187→\\t}\\n   188→\\n   189→\\t// Override absolute_git_hook_path if present\\n   190→\\tif ahpRaw, ok := raw[\\\"absolute_git_hook_path\\\"]; ok {\\n   191→\\t\\tvar ahp bool\\n   192→\\t\\tif err := json.Unmarshal(ahpRaw, &ahp); err != nil {\\n   193→\\t\\t\\treturn fmt.Errorf(\\\"parsing absolute_git_hook_path field: %w\\\", err)\\n   194→\\t\\t}\\n   195→\\t\\tsettings.AbsoluteGitHookPath = ahp\\n   196→\\t}\\n   197→\\n   198→\\t// Override log_level if present and non-empty\\n   199→\\tif logLevelRaw, ok := raw[\\\"log_level\\\"]; ok {\\n   200→\\t\\tvar ll string\\n   201→\\t\\tif err := json.Unmarshal(logLevelRaw, &ll); err != nil {\\n   202→\\t\\t\\treturn fmt.Errorf(\\\"parsing log_level field: %w\\\", err)\\n   203→\\t\\t}\\n   204→\\t\\tif ll != \\\"\\\" {\\n   205→\\t\\t\\tsettings.LogLevel = ll\\n   206→\\t\\t}\\n   207→\\t}\\n   208→\\n   209→\\t// Merge strategy_options if present\\n   210→\\tif optionsRaw, ok := raw[\\\"strategy_options\\\"]; ok {\\n   211→\\t\\tvar opts map[string]any\\n   212→\\t\\tif err := json.Unmarshal(optionsRaw, &opts); err != nil {\\n   213→\\t\\t\\treturn fmt.Errorf(\\\"parsing strategy_options field: %w\\\", err)\\n   214→\\t\\t}\\n   215→\\t\\tif settings.StrategyOptions == nil {\\n   216→\\t\\t\\tsettings.StrategyOptions = opts\\n   217→\\t\\t} else {\\n   218→\\t\\t\\tfor k, v := range opts {\\n   219→\\t\\t\\t\\tsettings.StrategyOptions[k] = v\\n   220→\\t\\t\\t}\\n   221→\\t\\t}\\n   222→\\t}\\n   223→\\n   224→\\t// Override telemetry if present\\n   225→\\tif telemetryRaw, ok := raw[\\\"telemetry\\\"]; ok {\\n   226→\\t\\tvar t bool\\n   227→\\t\\tif err := json.Unmarshal(telemetryRaw, &t); err != nil {\\n   228→\\t\\t\\treturn fmt.Errorf(\\\"parsing telemetry field: %w\\\", err)\\n   229→\\t\\t}\\n   230→\\t\\tsettings.Telemetry = &t\\n   231→\\t}\\n   232→\\n   233→\\t// Override commit_linking if present and non-empty\\n   234→\\tif commitLinkingRaw, ok := raw[\\\"commit_linking\\\"]; ok {\\n   235→\\t\\tvar cl string\\n   236→\\t\\tif err := json.Unmarshal(commitLinkingRaw, &cl); err != nil {\\n   237→\\t\\t\\treturn fmt.Errorf(\\\"parsing commit_linking field: %w\\\", err)\\n   238→\\t\\t}\\n   239→\\t\\tif cl != \\\"\\\" {\\n   240→\\t\\t\\tswitch cl {\\n   241→\\t\\t\\tcase CommitLinkingAlways, CommitLinkingPrompt:\\n   242→\\t\\t\\t\\tsettings.CommitLinking = cl\\n   243→\\t\\t\\tdefault:\\n   244→\\t\\t\\t\\treturn fmt.Errorf(\\\"invalid commit_linking value %q: must be %q or %q\\\", cl, CommitLinkingAlways, CommitLinkingPrompt)\\n   245→\\t\\t\\t}\\n   246→\\t\\t}\\n   247→\\t}\\n   248→\\n   249→\\treturn nil\\n   250→}\\n   251→\\n   252→// IsSetUp returns true if Entire has been set up in the current repository.\\n   253→// This checks if .entire/settings.json exists.\\n   254→// Use this to avoid creating files/directories in repos where Entire was never enabled.\\n   255→func IsSetUp(ctx context.Context) bool {\\n   256→\\tsettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsFile)\\n   257→\\tif err != nil {\\n   258→\\t\\treturn false\\n   259→\\t}\\n   260→\\t_, err = os.Stat(settingsFileAbs)\\n   261→\\treturn err == nil\\n   262→}\\n   263→\\n   264→// IsSetUpAndEnabled returns true if Entire is both set up and enabled.\\n   265→// This checks if .entire/settings.json exists AND has enabled: true.\\n   266→// Use this for hooks that should be no-ops when Entire is not active.\\n   267→func IsSetUpAndEnabled(ctx context.Context) bool {\\n   268→\\tif !IsSetU