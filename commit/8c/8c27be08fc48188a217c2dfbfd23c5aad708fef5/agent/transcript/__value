inking value %q: must be %q or %q\\\", settings.CommitLinking, CommitLinkingAlways, CommitLinkingPrompt)\\n   149→\\t}\\n   150→\\n   151→\\treturn settings, nil\\n   152→}\\n   153→\\n   154→// mergeJSON merges JSON data into existing settings.\\n   155→// Only non-zero values from the JSON override existing settings.\\n   156→func mergeJSON(settings *EntireSettings, data []byte) error {\\n   157→\\t// First, validate that there are no unknown keys using strict decoding\\n   158→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   159→\\tdec.DisallowUnknownFields()\\n   160→\\tvar temp EntireSettings\\n   161→\\tif err := dec.Decode(&temp); err != nil {\\n   162→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   163→\\t}\\n   164→\\n   165→\\t// Parse into a map to check which fields are present\\n   166→\\tvar raw map[string]json.RawMessage\\n   167→\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   168→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   169→\\t}\\n   170→\\n   171→\\t// Override enabled if present\\n   172→\\tif enabledRaw, ok := raw[\\\"enabled\\\"]; ok {\\n   173→\\t\\tvar e bool\\n   174→\\t\\tif err := json.Unmarshal(enabledRaw, &e); err != nil {\\n   175→\\t\\t\\treturn fmt.Errorf(\\\"parsing enabled field: %w\\\", err)\\n   176→\\t\\t}\\n   177→\\t\\tsettings.Enabled = e\\n   178→\\t}\\n   179→\\n   180→\\t// Override local_dev if present\\n   181→\\tif localDevRaw, ok := raw[\\\"local_dev\\\"]; ok {\\n   182→\\t\\tvar ld bool\\n   183→\\t\\tif err := json.Unmarshal(localDevRaw, &ld); err != nil {\\n   184→\\t\\t\\treturn fmt.Errorf(\\\"parsing local_dev field: %w\\\", err)\\n   185→\\t\\t}\\n   186→\\t\\tsettings.LocalDev = ld\\n   187→\\t}\\n   188→\\n   189→\\t// Override absolute_git_hook_path if present\\n   190→\\tif ahpRaw, ok := raw[\\\"absolute_git_hook_path\\\"]; ok {\\n   191→\\t\\tvar ahp bool\\n   192→\\t\\tif err := json.Unmarshal(ahpRaw, &ahp); err != nil {\\n   193→\\t\\t\\treturn fmt.Errorf(\\\"par