zon Q / Builder ID auth.\\n    50→\\t// On CI, ensure auth is available; locally, auth is handled by the desktop app.\\n    51→\\tif os.Getenv(\\\"CI\\\") == \\\"\\\" {\\n    52→\\t\\treturn nil\\n    53→\\t}\\n    54→\\n    55→\\tif isTruthyEnvValue(os.Getenv(\\\"AMAZON_Q_SIGV4\\\")) {\\n    56→\\t\\tif err := validateKiroSIGV4Inputs(\\n    57→\\t\\t\\tos.Getenv(\\\"AWS_REGION\\\"),\\n    58→\\t\\t\\tos.Getenv(\\\"AWS_ACCESS_KEY_ID\\\"),\\n    59→\\t\\t\\tos.Getenv(\\\"AWS_SECRET_ACCESS_KEY\\\"),\\n    60→\\t\\t); err != nil {\\n    61→\\t\\t\\treturn fmt.Errorf(\\\"kiro-cli sigv4 auth check failed: %w\\\", err)\\n    62→\\t\\t}\\n    63→\\t\\treturn nil\\n    64→\\t}\\n    65→\\n    66→\\t// Verify login status — fail fast if not authenticated.\\n    67→\\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\\n    68→\\tdefer cancel()\\n    69→\\tcmd := exec.CommandContext(ctx, \\\"kiro-cli\\\", \\\"whoami\\\", \\\"-f\\\", \\\"json\\\")\\n    70→\\tout, err := cmd.CombinedOutput()\\n    71→\\tif err != nil {\\n    72→\\t\\treturn fmt.Errorf(\\n    73→\\t\\t\\t\\\"kiro-cli auth check failed (run `kiro-cli login --use-device-flow`): %s\\\",\\n    74→\\t\\t\\tstrings.TrimSpace(string(out)),\\n    75→\\t\\t)\\n    76→\\t}\\n    77→\\tif err := validateKiroWhoamiJSON(out); err != nil {\\n    78→\\t\\treturn fmt.Errorf(\\\"kiro-cli auth check failed: %w\\\", err)\\n    79→\\t}\\n    80→\\treturn nil\\n    81→}\\n    82→\\n    83→func isTruthyEnvValue(v string) bool {\\n    84→\\tvalue := strings.TrimSpace(v)\\n    85→\\tif value == \\\"\\\" {\\n    86→\\t\\treturn false\\n    87→\\t}\\n    88→\\tlower := strings.ToLower(value)\\n    89→\\treturn lower != \\\"0\\\" && lower != \\\"false\\\"\\n    90→}\\n    91→\\n    92→func validateKiroSIGV4Inputs(region, accessKeyID, secretAccessKey string) error {\\n    93→\\tif strings.TrimSpace(region) == \\\"\\\" {\\n    94→\\t\\treturn errors.New(\\\"AWS_REGION is required when AMAZON_Q_SIGV4 is enabled\\\")\\n