me() agent.AgentName   { return agent.AgentNameOpenCode }\\n    33→func (a *OpenCodeAgent) Type() agent.AgentType   { return agent.AgentTypeOpenCode }\\n    34→func (a *OpenCodeAgent) Description() string     { return \\\"OpenCode - AI-powered terminal coding agent\\\" }\\n    35→func (a *OpenCodeAgent) IsPreview() bool         { return true }\\n    36→func (a *OpenCodeAgent) ProtectedDirs() []string { return []string{\\\".opencode\\\"} }\\n    37→\\n    38→func (a *OpenCodeAgent) DetectPresence() (bool, error) {\\n    39→\\trepoRoot, err := paths.RepoRoot()\\n    40→\\tif err != nil {\\n    41→\\t\\trepoRoot = \\\".\\\"\\n    42→\\t}\\n    43→\\t// Check for .opencode directory or opencode.json config\\n    44→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\".opencode\\\")); err == nil {\\n    45→\\t\\treturn true, nil\\n    46→\\t}\\n    47→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\"opencode.json\\\")); err == nil {\\n    48→\\t\\treturn true, nil\\n    49→\\t}\\n    50→\\treturn false, nil\\n    51→}\\n    52→\\n    53→// --- Transcript Storage ---\\n    54→\\n    55→// ReadTranscript reads the transcript for a session.\\n    56→// The sessionRef is expected to be a path to the export JSON file.\\n    57→func (a *OpenCodeAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    58→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    59→\\tif err != nil {\\n    60→\\t\\treturn nil, fmt.Errorf(\\\"failed to read opencode transcript: %w\\\", err)\\n    61→\\t}\\n    62→\\treturn data, nil\\n    63→}\\n    64→\\n    65→// ChunkTranscript splits an OpenCode export JSON transcript by distributing messages across chunks.\\n    66→// OpenCode uses JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]} structure.\\n    67→func (a *OpenCodeAgent) ChunkTranscript(content []byte, maxSize int) ([][]byte, error) {\\n    68→\\tvar session ExportSession\\n    69→\\tif err := json.Unmarshal(content, &session); err != nil {\\n    70→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse export session for chunking: %w\\\", err)\\n    71→\\t}\\n    72→\\n    73→\\tif len(session.Messages) == 0 {\\n    74→\\t\\treturn [][]byte{content}, nil\\n    75→\\t}\\n    76→\\n    77→\\t// Marshal info to calculate accurate base size\\n    78→\\tinfoBytes, err := json.Marshal(session.Info)\\n    79→\\tif err != nil {\\n    80→\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal session info for chunking: %w\\\", err)\\n    81→\\t}\\n    82→\\t// Base JSON structure size: {\\\"info\\\":<info>,\\\"messages\\\":[ ... ]}\\n    83→\\tbaseSize := len(`{\\\"info\\\":`) + len(infoBytes) + len(`,\\\"messages\\\":[]}`)\\n    84→\\n    85→\\tvar chunks [][]byte\\n    86→\\tvar currentMessages []ExportMessage\\n    87→\\tcurrentSize := baseSize\\n    88→\\n    89→\\tfor _, msg := range session.Messages {\\n    90→\\t\\t// Marshal message to get its size\\n    91→\\t\\tmsgBytes, err := json.Marshal(msg)\\n    92→\\t\\tif err != nil {\\n    93→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal message for chunking: %w\\\", err)\\n    94→\\t\\t}\\n    95→\\t\\tmsgSize := len(msgBytes) + 1 // +1 for comma separator\\n    96→\\n    97→\\t\\tif currentSize+msgSize > maxSize && len(currentMessages) > 0 {\\n    98→\\t\\t\\t// Save current chunk\\n    99→\\t\\t\\tchunkData, err := json.Marshal(ExportSession{Info: session.Info, Messages: currentMessages})\\n   100→\\t\\t\\tif err != nil {\\n   101→\\t\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal chunk: %w\\\", err)\\n   102→\\t\\t\\t}\\n   103→\\t\\t\\tchunks = append(chunks, chunkData)\\n   104→\\n   105→\\t\\t\\t// Start new chunk\\n   106→\\t\\t\\tcurrentMessages = nil\\n   107→\\t\\t\\tcurrentSize = baseSize\\n   108→\\t\\t}\\n   109→\\n   110→\\t\\tcurrentMessages = append(currentMessages, msg)\\n   111→\\t\\tcurrentSize += msgSize\\n   112→\\t}\\n   113→\\n   114→\\t// Add the last chunk\\n   115→\\tif len(currentMessages) > 0 {\\n   116→\\t\\tchunkData, err := json.Marshal(ExportSession{Info: session.Info, Messages: currentMessages})\\n   117→\\t\\tif err != nil {\\n   118→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal final chunk: %w\\\", err)\\n   119→\\t\\t}\\n   120→\\t\\tchunks = append(chunks, chunkData)\\n   121→\\t}\\n   122→\\n   123→\\tif len(chunks) == 0 {\\n   124→\\t\\treturn nil, errors.New(\\\"failed to create any chunks\\\")\\n   125→\\t}\\n   126→\\n   127→\\treturn chunks, nil\\n   128→}\\n   129→\\n   130→// ReassembleTranscript merges OpenCode export JSON chunks by combining their message arrays.\\n   131→func (a *OpenCodeAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n   132→\\tif len(chunks) == 0 {\\n   133→\\t\\treturn nil, errors.New(\\\"no chunks to reassemble\\\")\\n   134→\\t}\\n   135→\\n   136→\\tvar allMessages []ExportMessage\\n   137→\\tvar sessionInfo SessionInfo\\n   138→\\n   139→\\tfor i, chunk := range chunks {\\n   140→\\t\\tvar session ExportSession\\n   141→\\t\\tif err := json.Unmarshal(chunk, &session); err != nil {\\n   142→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal chunk %d: %w\\\", i, err)\\n   143→\\t\\t}\\n   144→\\t\\tif i == 0 {\\n   145→\\t\\t\\tsessionInfo = session.Info // Preserve session info from first chunk\\n   146→\\t\\t}\\n   147→\\t\\tallMessages = append(allMessages, session.Messages...)\\n   148→\\t}\\n   149→\\n   150→\\tresult, err := json.Marshal(ExportSession{Info: sessionInfo, Messages: allMessages})\\n   151→\\tif err != nil {\\n   152→\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal reassembled transcript: %w\\\", err)\\n   153→\\t}\\n   154→\\treturn result, nil\\n   155→}\\n   156→\\n   157→// --- Legacy methods ---\\n   158→\\n   159→func (a *OpenCodeAgent) GetSessionID(input *agent.HookInput) string {\\n   160→\\treturn input.SessionID\\n   161→}\\n   162→\\n   163→// GetSessionDir returns the directory where Entire stores OpenCode session transcripts.\\n   164→// Transcripts are ephemeral handoff files between the TS plugin and the Go hook handler.\\n   165→// Once checkpointed, the data lives on git refs and the file is disposable.\\n   166→// Stored in os.TempDir()/entire-opencode/<sanitized-path>/ to avoid squatting on\\n   167→// OpenCode's own directories (~/.opencode/ is project-level, not home-level).\\n   168→func (a *OpenCodeAgent) GetSessionDir(repoPath string) (string, error) {\\n   169→\\t// Check for test environment override\\n   170→\\tif override := os.Getenv(\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR\\\"); override != \\\"\\\" {\\n   171→\\t\\treturn override, nil\\n   172→\\t}\\n   173→\\n   174→\\tprojectDir := SanitizePathForOpenCode(repoPath)\\n   175→\\treturn filepath.Join(os.TempDir(), \\\"entire-opencode\\\", projectDir), nil\\n   176→}\\n   177→\\n   178→func (a *OpenCodeAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   179→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".json\\\")\\n   180→}\\n   181→\\n   182→func (a *OpenCodeAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   183→\\tif input.SessionRef == \\\"\\\" {\\n   184→\\t\\treturn nil, errors.New(\\\"no session ref provided\\\")\\n   185→\\t}\\n   186→\\tdata, err := os.ReadFile(input.SessionRef)\\n   187→\\tif err != nil {\\n   188→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session: %w\\\", err)\\n   189→\\t}\\n   190→\\n   191→\\t// Parse to extract computed fields\\n   192→\\tmodifiedFiles, err := ExtractModifiedFiles(data)\\n   193→\\tif err != nil {\\n   194→\\t\\t// Non-fatal: we can still return the session without modified files\\n   195→\\t\\tmodifiedFiles = nil\\n   196→\\t}\\n   197→\\n   198→\\treturn &agent.AgentSession{\\n   199→\\t\\tAgentName:     a.Name(),\\n   200→\\t\\tSessionID:     input.SessionID,\\n   201→\\t\\tSessionRef:    input.SessionRef,\\n   202→\\t\\tNativeData:    data,\\n   203→\\t\\tExportData:    data, // Export JSON is both native and export format\\n   204→\\t\\tModifiedFiles: modifiedFiles,\\n   205→\\t}, nil\\n   206→}\\n   207→\\n   208→func (a *OpenCodeAgent) WriteSession(session *agent.AgentSession) error {\\n   209→\\tif session == nil {\\n   210→\\t\\treturn errors.New(\\\"nil session\\\")\\n   211→\\t}\\n   212→\\tif session.SessionRef == \\\"\\\" {\\n   213→\\t\\treturn errors.New(\\\"no session ref to write to\\\")\\n   214→\\t}\\n   215→\\tif len(session.NativeData) == 0 {\\n   216→\\t\\treturn errors.New(\\\"no session data to write\\\")\\n   217→\\t}\\n   218→\\n   219→\\t// 1. Write export JSON file (for Entire's internal checkpoint use)\\n   220→\\tdir := filepath.Dir(session.SessionRef)\\n   221→\\t//nolint:gosec // G301: Session directory needs standard permissions\\n   222→\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   223→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   224→\\t}\\n   225→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   226→\\t\\treturn fmt.Errorf(\\\"failed to write session data: %w\\\", err)\\n   227→\\t}\\n   228→\\n   229→\\t// 2. If we have export data, import the session into OpenCode.\\n   230→\\t//    This enables `opencode -s <id>` for both resume and rewind.\\n   231→\\tif len(session.ExportData) == 0 {\\n   232→\\t\\treturn nil // No export data — skip import (graceful degradation)\\n   233→\\t}\\n   234→\\n   235→\\tif err := a.importSessionIntoOpenCode(session.SessionID, session.ExportData); err != nil {\\n   236→\\t\\t// Non-fatal: import is best-effort. The JSONL file is written,\\n   237→\\t\\t// and the user can always run `opencode import <file>` manually.\\n   238→\\t\\tfmt.Fprintf(os.Stderr, \\\"warning: could not import session into OpenCode: %v\\\\n\\\", err)\\n   239→\\t}\\n   240→\\n   241→\\treturn nil\\n   242→}\\n   243→\\n   244→// importSessionIntoOpenCode writes the export JSON to a temp file and runs\\n   245→// `opencode import` to restore the session into OpenCode's database.\\n   246→// For rewind (session already exists), the session is deleted first so the\\n   247→// reimport replaces it with the checkpoint-state messages.\\n   248→func (a *OpenCodeAgent) importSessionIntoOpenCode(sessionID string, exportData []byte) error {\\n   249→\\t// Delete existing messages first so reimport replaces them cleanly.\\n   250→\\t// opencode import uses ON CONFLICT DO NOTHING, so existing messages\\n   251→\\t// would be skipped without this step (breaking rewind).\\n   252→\\t// Uses direct SQLite delete since OpenCode CLI has no session delete command.\\n   253→\\tif err := deleteMessagesFromSQLite(sessionID); err != nil {\\n   254→\\t\\t// Non-fatal: DB might not exist yet (first session), or sqlite3 not installed.\\n   255→\\t\\t// Import will still work for new sessions; only rewind of existing sessions\\n   256→\\t\\t// would have stale messages.\\n   257→\\t\\tfmt.Fprintf(os.Stderr, \\\"warning: could not clear existing messages: %v\\\\n\\\", err)\\n   258→\\t}\\n   259→\\n   260→\\t// Write export JSON to a temp file for opencode import\\n   261→\\ttmpFile, err := os.CreateTemp(\\\"\\\", \\\"entire-opencode-export-*.json\\\")\\n   262→\\tif err != nil {\\n   263→\\t\\treturn fmt.Errorf(\\\"failed to create temp file: %w\\\", err)\\n   264→\\t}\\n   265→\\tdefer os.Remove(tmpFile.Name())\\n   266→\\n   267→\\tif _, err := tmpFile.Write(exportData); err != nil {\\n   268→\\t\\t_ = tmpFile.Close()\\n   269→\\t\\treturn fmt.Errorf(\\\"failed to write export data: %w\\\", err)\\n   270→\\t}\\n   271→\\tif err := tmpFile.Close(); err != nil {\\n   272→\\t\\treturn fmt.Errorf(\\\"failed to close temp file: %w\\\", err)\\n   273→\\t}\\n   274→\\n   275→\\treturn runOpenCodeImport(tmpFile.Name())\\n   276→}\\n   277→\\n   278→func (a *OpenCodeAgent) FormatResumeCommand(sessionID string) string {\\n   279→\\tif strings.TrimSpace(sessionID) == \\\"\\\" {\\n   280→\\t\\treturn \\\"opencode\\\"\\n   281→\\t}\\n   282→\\treturn \\\"opencode -s \\\" + sessionID\\n   283→}\\n   284→\\n   285→// nonAlphanumericRegex matches any non-alphanumeric character.\\n   286→var nonAlphanumericRegex = regexp.MustCompile(`[^a-zA-Z0-9]`)\\n   287→\\n   288→// SanitizePathForOpenCode converts a path to a safe directory name.\\n   289→// Replaces any non-alphanumeric character with a dash (same approach as Claude/Gemini).\\n   290→func SanitizePathForOpenCode(path string) string {\\n   291→\\treturn nonAlphanumericRegex.ReplaceAllString(path, \\\"-\\\")\\n   292→}\\n   293→\"}]},\"uuid\":\"d2f23d5c-2ce0-4cd8-b76f-8578ba14be01\",\"timestamp\":\"2026-02-20T17:46:29.130Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli_experiments/cmd/entire/cli/agent/opencode/opencode.go\",\"content\":\"// Package opencode implements the Agent interface for OpenCode.\\npackage opencode\\n\\nimport (\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"regexp\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n)\\n\\n//nolint:gochecknoinits // Agent self-registration is the intended pattern\\nfunc init() {\\n\\tagent.Register(agent.AgentNameOpenCode, NewOpenCodeAgent)\\n}\\n\\n//nolint:revive // OpenCodeAgent is clearer than Agent in this context\\ntype OpenCodeAgent struct{}\\n\\n// NewOpenCodeAgent creates a new OpenCode agent instance.\\nfunc NewOpenCodeAgent() agent.Agent {\\n\\treturn &OpenCodeAgent{}\\n}\\n\\n// --- Identity ---\\n\\nfunc (a *OpenCodeAgent) Name() agent.AgentName   { return agent.AgentNameOpenCode }\\nfunc (a *OpenCodeAgent) Type() agent.AgentType   { return agent.AgentTypeOpenCode }\\nfunc (a *OpenCodeAgent) Description() string     { return \\\"OpenCode - AI-powered terminal coding agent\\\" }\\nfunc (a *OpenCodeAgent) IsPreview() bool         { return true }\\nfunc (a *OpenCodeAgent) ProtectedDirs() []string { return []string{\\\".opencode\\\"} }\\n\\nfunc (a *OpenCodeAgent) DetectPresence() (bool, error) {\\n\\trepoRoot, err := paths.RepoRoot()\\n\\tif err != nil {\\n\\t\\trepoRoot = \\\".\\\"\\n\\t}\\n\\t// Check for .opencode directory or opencode.json config\\n\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\".opencode\\\")); err == nil {\\n\\t\\treturn true, nil\\n\\t}\\n\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\"opencode.json\\\")); err == nil {\\n\\t\\treturn true, nil\\n\\t}\\n\\treturn false, nil\\n}\\n\\n// --- Transcript Storage ---\\n\\n// ReadTranscript reads the transcript for a session.\\n// The sessionRef is expected to be a path to the export JSON file.\\nfunc (a *OpenCodeAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read opencode transcript: %w\\\", err)\\n\\t}\\n\\treturn data, nil\\n}\\n\\n// ChunkTranscript splits an OpenCode export JSON transcript by distributing messages across chunks.\\n// OpenCode uses JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]} structure.\\nfunc (a *OpenCodeAgent) ChunkTranscript(content []byte, maxSize int) ([][]byte, error) {\\n\\tvar session ExportSession\\n\\tif err := json.Unmarshal(content, &session); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to parse export session for chunking: %w\\\", err)\\n\\t}\\n\\n\\tif len(session.Messages) == 0 {\\n\\t\\treturn [][]byte{content}, nil\\n\\t}\\n\\n\\t// Marshal info to calculate accurate base size\\n\\tinfoBytes, err := json.Marshal(session.Info)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal session info for chunking: %w\\\", err)\\n\\t}\\n\\t// Base JSON structure size: {\\\"info\\\":<info>,\\\"messages\\\":[ ... ]}\\n\\tbaseSize := len(`{\\\"info\\\":`) + len(infoBytes) + len(`,\\\"messages\\\":[]}`)\\n\\n\\tvar chunks [][]byte\\n\\tvar currentMessages []ExportMessage\\n\\tcurrentSize := baseSize\\n\\n\\tfor _, msg := range session.Messages {\\n\\t\\t// Marshal message to get its size\\n\\t\\tmsgBytes, err := json.Marshal(msg)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal message for chunking: %w\\\", err)\\n\\t\\t}\\n\\t\\tmsgSize := len(msgBytes) + 1 // +1 for comma separator\\n\\n\\t\\tif currentSize+msgSize > maxSize && len(currentMessages) > 0 {\\n\\t\\t\\t// Save current chunk\\n\\t\\t\\tchunkData, err := json.Marshal(ExportSession{Info: session.Info, Messages: currentMessages})\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal chunk: %w\\\", err)\\n\\t\\t\\t}\\n\\t\\t\\tchunks = append(chunks, chunkData)\\n\\n\\t\\t\\t// Start new chunk\\n\\t\\t\\tcurrentMessages = nil\\n\\t\\t\\tcurrentSize = baseSize\\n\\t\\t}\\n\\n\\t\\tcurrentMessages = append(currentMessages, msg)\\n\\t\\tcurrentSize += msgSize\\n\\t}\\n\\n\\t// Add the last chunk\\n\\tif len(currentMessages) > 0 {\\n\\t\\tchunkData, err := json.Marshal(ExportSession{Info: session.Info, Messages: currentMessages})\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal final chunk: %w\\\", err)\\n\\t\\t}\\n\\t\\tchunks = append(chunks, chunkData)\\n\\t}\\n\\n\\tif len(chunks) == 0 {\\n\\t\\treturn nil, errors.New(\\\"failed to create any chunks\\\")\\n\\t}\\n\\n\\treturn chunks, nil\\n}\\n\\n// ReassembleTranscript merges OpenCode export JSON chunks by combining their message arrays.\\nfunc (a *OpenCodeAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n\\tif len(chunks) == 0 {\\n\\t\\treturn nil, errors.New(\\\"no chunks to reassemble\\\")\\n\\t}\\n\\n\\tvar allMessages []ExportMessage\\n\\tvar sessionInfo SessionInfo\\n\\n\\tfor i, chunk := range chunks {\\n\\t\\tvar session ExportSession\\n\\t\\tif err := json.Unmarshal(chunk, &session); err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal chunk %d: %w\\\", i, err)\\n\\t\\t}\\n\\t\\tif i == 0 {\\n\\t\\t\\tsessionInfo = session.Info // Preserve session info from first chunk\\n\\t\\t}\\n\\t\\tallMessages = append(allMessages, session.Messages...)\\n\\t}\\n\\n\\tresult, err := json.Marshal(ExportSession{Info: sessionInfo, Messages: allMessages})\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal reassembled transcript: %w\\\", err)\\n\\t}\\n\\treturn result, nil\\n}\\n\\n// --- Legacy methods ---\\n\\nfunc (a *OpenCodeAgent) GetSessionID(input *agent.HookInput) string {\\n\\treturn input.SessionID\\n}\\n\\n// GetSessionDir returns the directory where Entire stores OpenCode session transcripts.\\n// Transcripts are ephemeral handoff files between the TS plugin and the Go hook handler.\\n// Once checkpointed, the data lives on git refs and the file is disposable.\\n// Stored in os.TempDir()/entire-opencode/<sanitized-path>/ to avoid squatting on\\n// OpenCode's own directories (~/.opencode/ is project-level, not home-level).\\nfunc (a *OpenCodeAgent) GetSessionDir(repoPath string) (string, error) {\\n\\t// Check for test environment override\\n\\tif override := os.Getenv(\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR\\\"); override != \\\"\\\" {\\n\\t\\treturn override, nil\\n\\t}\\n\\n\\tprojectDir := SanitizePathForOpenCode(repoPath)\\n\\treturn filepath.Join(os.TempDir(), \\\"entire-opencode\\\", projectDir), nil\\n}\\n\\nfunc (a *OpenCodeAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n\\treturn filepath.Join(sessionDir, agentSessionID+\\\".json\\\")\\n}\\n\\nfunc (a *OpenCodeAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n\\tif input.SessionRef == \\\"\\\" {\\n\\t\\treturn nil, errors.New(\\\"no session ref provided\\\")\\n\\t}\\n\\tdata, err := os.ReadFile(input.SessionRef)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read session: %w\\\", err)\\n\\t}\\n\\n\\t// Parse to extract computed fields\\n\\tmodifiedFiles, err := ExtractModifiedFiles(data)\\n\\tif err != nil {\\n\\t\\t// Non-fatal: