    21→\\t\\tLong: `Remove orphaned Entire data (session state, shadow branches, checkpoint metadata, temp files) that wasn't cleaned up automatically.\\n    22→\\n    23→This command finds and removes orphaned data from any strategy:\\n    24→\\n    25→  Shadow branches (entire/<commit-hash>)\\n    26→    Created by manual-commit strategy. Normally auto-cleaned when sessions\\n    27→    are condensed during commits.\\n    28→\\n    29→  Session state files (.git/entire-sessions/)\\n    30→    Track active sessions. Orphaned when no checkpoints or shadow branches\\n    31→    reference them.\\n    32→\\n    33→  Checkpoint metadata (entire/checkpoints/v1 branch)\\n    34→    For auto-commit checkpoints: orphaned when commits are rebased/squashed\\n    35→    and no commit references the checkpoint ID anymore.\\n    36→    Manual-commit checkpoints are permanent (condensed history) and are\\n    37→    never considered orphaned.\\n    38→\\n    39→  Temporary files (.entire/tmp/)\\n    40→    Cached transcripts and other temporary data. Safe to delete when no\\n    41→    active sessions are using them.\\n    42→\\n    43→Default: shows a preview of items that would be deleted.\\n    44→With --force, actually deletes the orphaned items.\\n    45→\\n    46→The entire/checkpoints/v1 branch itself is never deleted.`,\\n    47→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    48→\\t\\t\\treturn runClean(cmd.OutOrStdout(), forceFlag)\\n    49→\\t\\t},\\n    50→\\t}\\n    51→\\n    52→\\tcmd.Flags().BoolVarP(&forceFlag, \\\"force\\\", \\\"f\\\", false, \\\"Actually delete items (default: dry run)\\\")\\n    53→\\n    54→\\treturn cmd\\n    55→}\\n    56→\\n    57→func runClean(w io.Writer, force bool) error {\\n    58→\\t// Initialize logging so structured logs go to .entire/logs/ instead of stderr.\\n    59→\\t// Error is non-fatal: if logging init fails, logs go to stderr (acceptable fallback).\\n    60→\\tlogging.SetLogLevelGetter(GetLogLevel)\\n    61→\\tif err := logging.Init(\\\"\\\"); err == nil {\\n    62→\\t\\tdefer logging.Close()\\n    63→\\t}\\n    64→\\n    65→\\t// List all cleanup items\\n    66→\\titems, err := strategy.ListAllCleanupItems()\\n    67→\\tif err != nil {\\n    68→\\t\\treturn fmt.Errorf(\\\"failed to list orphaned items: %w\\\", err)\\n    69→\\t}\\n    70→\\n    71→\\t// List temp files\\n    72→\\ttempFiles, err := listTempFiles()\\n    73→\\tif err != nil {\\n    74→\\t\\t// Non-fatal: continue with other cleanup items\\n    75→\\t\\tfmt.Fprintf(w, \\\"Warning: failed to list temp files: %v\\\\n\\\", err)\\n    76→\\t}\\n    77→\\n    78→\\treturn runCleanWithItems(w, force, items, tempFiles)\\n    79→}\\n    80→\\n    81→// listTempFiles returns all files in .entire/tmp/.\\n    82→func listTempFiles() ([]string, error) {\\n    83→\\ttmpDir, err := paths.AbsPath(paths.EntireTmpDir)\\n    84→\\tif err != nil {\\n    85→\\t\\treturn nil, fmt.Errorf(\\\"failed to get temp dir path: %w\\\", err)\\n    86→\\t}\\n    87→\\n    88→\\tentries, err := os.ReadDir(tmpDir)\\n    89→\\tif os.IsNotExist(err) {\\n    90→\\t\\treturn nil, nil\\n    91→\\t}\\n    92→\\tif err != nil {\\n    93→\\t\\treturn nil, fmt.Errorf(\\\"failed to read temp dir: %w\\\", err)\\n    94→\\t}\\n    95→\\n    96→\\tvar files []string\\n    97→\\tfor _, entry := range entries {\\n    98→\\t\\tif !entry.IsDir() {\\n    99→\\t\\t\\tfiles = append(files, entry.Name())\\n   100→\\t\\t}\\n   101→\\t}\\n   102→\\treturn files, nil\\n   103→}\\n   104→\\n   105→// TempFileDeleteError contains a file name and the error that occurred during deletion.\\n   106→type TempFileDeleteError struct {\\n   107→\\tFile string\\n   108→\\tErr  error\\n   109→}\\n   110→\\n   111→// deleteTempFiles removes all files in .entire/tmp/.\\n   112→// Returns successfully deleted files and any failures with their error reasons.\\n   113→func deleteTempFiles(files []string) (deleted []string, failed []TempFileDeleteError) {\\n   114→\\ttmpDir, err :