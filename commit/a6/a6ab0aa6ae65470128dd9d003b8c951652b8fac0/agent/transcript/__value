nch not found and no live transcript available\\\")\\n   139→\\t\\t}\\n   140→\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n   141→\\t\\tif err != nil {\\n   142→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n   143→\\t\\t}\\n   144→\\t}\\n   145→\\n   146→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   147→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   148→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   149→\\tif len(committedFiles) > 0 {\\n   150→\\t\\t// Track if we had files before filtering to distinguish between:\\n   151→\\t\\t// - Session had files but none were committed (don't fallback)\\n   152→\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n   153→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   154→\\n   155→\\t\\tif hadFilesBeforeFiltering {\\n   156→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   157→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   158→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   159→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   160→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   161→\\t\\t\\t\\t}\\n   162→\\t\\t\\t}\\n   163→\\t\\t\\tsessionData.FilesTouched = filtered\\n   164→\\t\\t}\\n   165→\\n   166→\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n   167→\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n   168→\\t\\t// the session had files that simply didn't overlap with the commit - that\\n   169→\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n   170→\\t\\t// overwritten with unrelated committed files.\\n   171→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   172→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   173→\\t\\t\\tfor f := range committedFiles {\\n   174→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   175→\\t\\t\\t}\\n   176→\\t\\t}\\n   177→\\t}\\n   178→\\n   179→\\t// Get checkpoint store\\n   180→\\tstore, err := s.getCheckpointStore()\\n   181→\\tif err != nil {\\n   182→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   183→\\t}\\n   184→\\n   185→\\t// Get author info\\n   186→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   187→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   188→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   189→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   190→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n   191→\\t// Get current branch name\\n   192→\\tbranchName := GetCurrentBranchName(repo)\\n   193→\\n   194→\\t// Generate summary if enabled\\n   195→\\tvar summary *cpkg.Summary\\n   196→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   197→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   198→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   199→\\n   200→\\t\\t// Scope transcript to this checkpoint's portion.\\n   201→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   202→\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n   203→\\t\\tvar scopedTranscript []byte\\n   204→\\t\\tswitch state.AgentType {\\n   205→\\t\\tcase agent.AgentTypeGemini:\\n   206→\\t\\t\\tscopedTranscript = geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   207→\\t\\tcase agent.AgentTypeOpenCode:\\n   208→\\t\\t\\tscopedTranscript = opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   209→\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeUnknown:\\n   210→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   211→\\t\\t}\\n   212→\\t\\tif len(scopedTranscript) > 0 {\\n   213→\\t\\t\\tvar err error\\n   214→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   215→\\t\\t\\tif err != nil {\\n   216→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   217→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   218→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   219→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   220→\\t\\t\\t} else {\\n   221→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   222→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   223→\\t\\t\\t}\\n   224→\\t\\t}\\n   225→\\t}\\n   226→\\n   227→\\t// Write checkpoint metadata using the checkpoint store\\n   228→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   229→\\t\\tCheckpointID:                checkpointID,\\n   230→\\t\\tSessionID:                   state.SessionID,\\n   231→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   232→\\t\\tBranch:                      branchName,\\n   233→\\t\\tTranscript:                  sessionData.Transcript,\\n   234→\\t\\tPrompts:                     sessionData.Prompts,\\n   235→\\t\\tContext:                     sessionData.Context,\\n   236→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   237→\\t\\tCheckpointsCount:            state.StepCount,\\n   238→\\t\\tEphemeralBranch:             shadowBranchName,\\n   239→\\t\\tAuthorName:                  authorName,\\n   240→\\t\\tAuthorEmail:                 authorEmail,\\n   241→\\t\\tAgent:                       state.AgentType,\\n   242→\\t\\tTurnID:                      state.TurnID,\\n   243→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   244→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   245→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   246→\\t\\tInitialAttribution:          attribution,\\n   247→\\t\\tSummary:                     summary,\\n   248→\\t}); err != nil {\\n   249→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   250→\\t}\\n   251→\\n   252→\\treturn &CondenseResult{\\n   253→\\t\\tCheckpointID:         checkpointID,\\n   254→\\t\\tSessionID:            state.SessionID,\\n   255→\\t\\tCheckpointsCount:     state.StepCount,\\n   256→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   257→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   258→\\t}, nil\\n   259→}\\n   260→\\n   261→func calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n   262→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   263→\\t// This uses user edits captured at each prompt start (before agent works),\\n   264→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   265→\\t//\\n   266→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   267→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   268→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   269→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   270→\\n   271→\\theadRef, headErr := repo.Head()\\n   272→\\tif headErr != nil {\\n   273→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   274→\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   275→\\t\\treturn nil\\n   276→\\t}\\n   277→\\n   278→\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   279→\\tif commitErr != nil {\\n   280→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   281→\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   282→\\t\\treturn nil\\n   283→\\t}\\n   284→\\n   285→\\theadTree, treeErr := headCommit.Tree()\\n   286→\\tif treeErr != nil {\\n   287→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   288→\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   289→\\t\\treturn nil\\n   290→\\t}\\n   291→\\n   292→\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n   293→\\tvar shadowTree *object.Tree\\n   294→\\tif shadowRef != nil {\\n   295→\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   296→\\t\\tif shadowErr != nil {\\n   297→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   298→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   299→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   300→\\t\\t\\treturn nil\\n   301→\\t\\t}\\n   302→\\t\\tvar shadowTreeErr error\\n   303→\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   304→\\t\\tif shadowTreeErr != nil {\\n   305→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   306→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   307→\\t\\t\\treturn nil\\n   308→\\t\\t}\\n   309→\\t} else {\\n   310→\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   311→\\t\\t// because the agent's work is the commit itself.\\n   312→\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   313→\\t\\tshadowTree = headTree\\n   314→\\t}\\n   315→\\n   316→\\t// Get base tree (state before session started)\\n   317→\\tvar baseTree *object.Tree\\n   318→\\tattrBase := state.AttributionBaseCommit\\n   319→\\tif attrBase == \\\"\\\" {\\n   320→\\t\\tattrBase = state.BaseCommit // backward compat\\n   321→\\t}\\n   322→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   323→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   324→\\t\\t\\tbaseTree = tree\\n   325→\\t\\t} else {\\n   326→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   327→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   328→\\t\\t}\\n   329→\\t} else {\\n   330→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   331→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   332→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   333→\\t}\\n   334→\\n   335→\\t// Log accumulated prompt attributions for debugging\\n   336→\\tvar totalUserAdded, totalUserRemoved int\\n   337→\\tfor i, pa := range state.PromptAttributions {\\n   338→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   339→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   340→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   341→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   342→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   343→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   344→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   345→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   346→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   347→\\t}\\n   348→\\n   349→\\tattribution := CalculateAttributionWithAccumulated(\\n   350→\\t\\tbaseTree,\\n   351→\\t\\tshadowTree,\\n   352→\\t\\theadTree,\\n   353→\\t\\tsessionData.FilesTouched,\\n   354→\\t\\tstate.PromptAttributions,\\n   355→\\t)\\n   356→\\n   357→\\tif attribution != nil {\\n   358→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   359→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   360→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   361→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   362→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   363→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   364→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   365→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   366→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   367→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   368→\\t}\\n   369→\\n   370→\\treturn attribution\\n   371→}\\n   372→\\n   373→// extractSessionData extracts session data from the shadow branch.\\n   374→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   375→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   376→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   377→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   378→// continued growing — the shadow branch copy would be stale.\\n   379→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   380→func (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n   381→\\tcommit, err := repo.CommitObject(shadowRef)\\n   382→\\tif err != nil {\\n   383→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   384→\\t}\\n   385→\\n   386→\\ttree, err := commit.Tree()\\n   387→\\tif err != nil {\\n   388→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   389→\\t}\\n   390→\\n   391→\\tdata := &ExtractedSessionData{}\\n   392→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   393→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   394→\\n   395→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   396→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   397→\\t// (SaveStep is only called when there are file modifications).\\n   398→\\tvar fullTranscript string\\n   399→\\tif liveTranscriptPath != \\\"\\\" {\\n   400→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   401→\\t\\t\\tfullTranscript = string(liveData)\\n   402→\\t\\t}\\n   403→\\t}\\n   404→\\tif fullTranscript == \\\"\\\" {\\n   405→\\t\\t// Fall back to shadow branch copy\\n   406→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   407→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   408→\\t\\t\\t\\tfullTranscript = content\\n   409→\\t\\t\\t}\\n   410→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   411→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   412→\\t\\t\\t\\tfullTranscript = content\\n   413→\\t\\t\\t}\\n   414→\\t\\t}\\n   415→\\t}\\n   416→\\n   417→\\t// Process transcript based on agent type\\n   418→\\tif fullTranscript != \\\"\\\" {\\n   419→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   420→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   421→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   422→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   423→\\t}\\n   424→\\n   425→\\t// Use tracked files from session state (not