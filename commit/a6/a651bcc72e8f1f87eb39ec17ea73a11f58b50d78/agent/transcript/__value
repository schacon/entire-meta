ate.\\n    68→\\t// The logs can be restored from entire/checkpoints/v1, but file state requires git checkout.\\n    69→\\tIsLogsOnly bool\\n    70→\\n    71→\\t// CheckpointID is the stable 12-hex-char identifier for logs-only points.\\n    72→\\t// Used to retrieve logs from entire/checkpoints/v1/<id[:2]>/<id[2:]>/full.jsonl\\n    73→\\t// Empty for shadow branch checkpoints (uncommitted).\\n    74→\\tCheckpointID id.CheckpointID\\n    75→\\n    76→\\t// Agent is the human-readable name of the agent that created this checkpoint\\n    77→\\t// (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n    78→\\tAgent types.AgentType\\n    79→\\n    80→\\t// SessionID is the session identifier for this checkpoint.\\n    81→\\t// Used to distinguish checkpoints from different concurrent sessions.\\n    82→\\tSessionID string\\n    83→\\n    84→\\t// SessionPrompt is the initial prompt that started this session.\\n    85→\\t// Used to help users identify which session a checkpoint belongs to.\\n    86→\\tSessionPrompt string\\n    87→\\n    88→\\t// SessionCount is the number of sessions in this checkpoint (1 for single-session).\\n    89→\\t// Only populated for logs-only points with multi-session checkpoints.\\n    90→\\tSessionCount int\\n    91→\\n    92→\\t// SessionIDs contains all session IDs when this is a multi-session checkpoint.\\n    93→\\t// The last entry is the most recent session (same as SessionID).\\n    94→\\t// Only populated for logs-only points with multi-session checkpoints.\\n    95→\\tSessionIDs []string\\n    96→\\n    97→\\t// SessionPrompts contains the first prompt for each session (parallel to SessionIDs).\\n    98→\\t// Used to display context when showing resume commands for multi-session checkpoints.\\n    99→\\tSessionPrompts []string\\n   100→}\\n   101→\\n   102→// RewindPreview describes what will happen when rewinding to a checkpoint.\\n   103→// Used to warn users about files that will be modified or deleted.\\n   104→type RewindPreview struct {\\n   105→\\t// FilesToRestore are files from the checkpoint that will be written/restored.\\n   106→\\tFilesToRestore []string\\n   107→\\n   108→\\t// FilesToDelete are untracked files that will be removed.\\n   109→\\t// These are files created after the checkpoint that aren't in the checkpoint tree\\n   110→\\t// and weren't present at session start.\\n   111→\\tFilesToDelete []string\\n   112→\\n   113→\\t// TrackedChanges are tracked files with uncommitted changes that will be reverted.\\n   114→\\t// These come from the existing CanRewind() warning.\\n   115→\\tTrackedChanges []string\\n   116→}\\n   117→\\n   118→// StepContext contains all information needed for saving a step checkpoint.\\n   119→// All file paths should be pre-filtered and normalized by the CLI layer.\\n   120→type StepContext struct {\\n   121→\\t// SessionID is the Claude Code session identifier\\n   122→\\tSessionID string\\n   123→\\n   124→\\t// ModifiedFiles is the list of files modified during the session\\n   125→\\t// (extracted from the transcript, already filtered and relative)\\n   126→\\tModifiedFiles []string\\n   127→\\n   128→\\t// NewFiles is the list of new files created during the session\\n   129→\\t// (pre-computed by CLI from pre-prompt state comparison)\\n   130→\\tNewFiles []string\\n   131→\\n   132→\\t// DeletedFiles is the list of files deleted during the session\\n   133→\\t// (tracked files that no longer exist)\\n   134→\\tDeletedFiles []string\\n   135→\\n   136→\\t// MetadataDir is the path to the session metadata directory\\n   137→\\tMetadataDir string\\n   138→\\n   139→\\t// MetadataDirAbs is the absolute path to the session metadata directory\\n   140→\\tMetadataDirAbs string\\n   141→\\n   142→\\t// CommitMessage is the generated commit message\\n   143→\\tCommitMessage string\\n   144→\\n   145→\\t// TranscriptPath is the path to the transcript file\\n   146→\\tTranscriptPath string\\n   147→\\n   148→\\t// AuthorName is the name to use for commits