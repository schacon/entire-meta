n started.\\n    35→\\n    36→The session ID is the UUID shown by 'claude --resume'.`,\\n    37→\\t\\tArgs: cobra.ExactArgs(1),\\n    38→\\t\\tRunE: func(cmd *cobra.Command, args []string) error {\\n    39→\\t\\t\\tif checkDisabledGuard(cmd.Context(), cmd.ErrOrStderr()) {\\n    40→\\t\\t\\t\\treturn nil\\n    41→\\t\\t\\t}\\n    42→\\t\\t\\treturn runAttach(cmd.Context(), cmd.OutOrStdout(), args[0])\\n    43→\\t\\t},\\n    44→\\t}\\n    45→\\treturn cmd\\n    46→}\\n    47→\\n    48→func runAttach(ctx context.Context, w io.Writer, sessionID string) error {\\n    49→\\tlogCtx := logging.WithComponent(ctx, \\\"attach\\\")\\n    50→\\n    51→\\t// Validate session ID format\\n    52→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n    53→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n    54→\\t}\\n    55→\\n    56→\\t// Ensure we're in a git repo\\n    57→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n    58→\\tif err != nil {\\n    59→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n    60→\\t}\\n    61→\\n    62→\\t// Check session isn't already tracked\\n    63→\\tstore, err := session.NewStateStore(ctx)\\n    64→\\tif err != nil {\\n    65→\\t\\treturn fmt.Errorf(\\\"failed to open session store: %w\\\", err)\\n    66→\\t}\\n    67→\\texisting, err := store.Load(ctx, sessionID)\\n    68→\\tif err != nil {\\n    69→\\t\\treturn fmt.Errorf(\\\"failed to check existing session: %w\\\", err)\\n    70→\\t}\\n    71→\\tif existing != nil {\\n    72→\\t\\treturn fmt.Errorf(\\\"session %s is already tracked by Entire\\\", sessionID)\\n    73→\\t}\\n    74→\\n    75→\\t// Resolve Claude Code agent and transcript path\\n    76→\\tag, err := agent.Get(agent.AgentNameClaudeCode)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn fmt.Errorf(\\\"Claude Code agent not available: %w\\\", err)\\n    79→\\t}\\n    80→\\n    81→\\ttranscriptPath, err := resolveTranscriptPath(ctx, sessionID, ag)\\n    82→\\tif err != nil {\\n    83→\\t