\t}\\n   402→\\n   403→\\tattribution := CalculateAttributionWithAccumulated(\\n   404→\\t\\tctx,\\n   405→\\t\\tbaseTree,\\n   406→\\t\\tshadowTree,\\n   407→\\t\\theadTree,\\n   408→\\t\\tsessionData.FilesTouched,\\n   409→\\t\\tstate.PromptAttributions,\\n   410→\\t\\to.repoDir,\\n   411→\\t\\to.attributionBaseCommit,\\n   412→\\t\\to.headCommitHash,\\n   413→\\t)\\n   414→\\n   415→\\tif attribution != nil {\\n   416→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   417→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   418→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   419→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   420→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   421→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   422→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   423→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   424→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   425→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   426→\\t}\\n   427→\\n   428→\\treturn attribution\\n   429→}\\n   430→\\n   431→// extractSessionData extracts session data from the shadow branch.\\n   432→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   433→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   434→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   435→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   436→// continued growing — the shadow branch copy would be stale.\\n   437→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   438→func (s *ManualCommitStrategy) extractSessionData(ctx context.Context, repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType types.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n   439→\\tag, _ := agent.GetByAgentType(agentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   440→\\tcommit, err := repo.CommitObject(shadowRef)\\n   441→\\tif err != nil {\\n   442→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   443→\\t}\\n   444→\\n   445→\\ttree, err := commit.Tree()\\n   446→\\tif err != nil {\\n   447→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   448→\\t}\\n   449→\\n   450→\\tdata := &ExtractedSessionData{}\\n   451→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   452→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   453→\\n   454→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   455→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   456→\\t// (SaveStep is only called when there are file modifications).\\n   457→\\tvar fullTranscript string\\n   458→\\tif liveTranscriptPath != \\\"\\\" {\\n   459→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   460→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   461→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   462→\\t\\tif isActive {\\n   463→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, liveTranscriptPath)\\n   464→\\t\\t}\\n   465→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   466→\\t\\t\\tfullTranscript = string(liveData)\\n   467→\\t\\t}\\n   468→\\t}\\n   469→\\tif fullTranscript == \\\"\\\" {\\n   470→\\t\\t// Fall back to shadow branch copy\\n   471→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   472→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   473→\\t\\t\\t\\tfullTranscript = content\\n   474→\\t\\t\\t}\\n   475→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   476→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   477→\\t\\t\\t\\tfullTranscript = content\\n   478→\\t\\t\\t}\\n   479→\\t\\t}\\n   480→\\t}\\n   481→\\n   482→\\t// Process transcript based on agent type\\n   483→\\tif fullTranscript != \\\"\\\" {\\n   484→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   485→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   486→\\t\\t// Read prompts from shadow branch tree (source of truth after SaveStep)\\n   487→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.PromptFileName); fileErr == nil {\\n   488→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil && content != \\\"\\\" {\\n   489→\\t\\t\\t\\tdata.Prompts = splitPromptContent(content)\\n   490→\\t\\t\\t}\\n   491→\\t\\t}\\n   492→\\t\\t// Filesystem fallback (written at turn start, covers mid-turn commits)\\n   493→\\t\\tif len(data.Prompts) == 0 {\\n   494→\\t\\t\\tdata.Prompts = readPromptsFromFilesystem(ctx, sessionID)\\n   495→\\t\\t}\\n   496→\\t}\\n   497→\\n   498→\\t// Use tracked files from session state (not all files in tree)\\n   499→\\tdata.FilesTouched = filesTouched\\n   500→\\n   501→\\t// Calculate token usage from the extracted transcript portion\\n   502→\\tif len(data.Transcript) > 0 {\\n   503→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ctx, ag, data.Transcript, checkpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   504→\\t}\\n   505→\\n   506→\\treturn data, nil\\n   507→}\\n   508→\\n   509→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   510→// This is used for mid-session commits where no shadow branch exists yet.\\n   511→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(ctx context.Context, state *SessionState) (*ExtractedSessionData, error) {\\n   512→\\tdata := &ExtractedSessionData{}\\n   513→\\n   514→\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   515→\\n   516→\\t// Read the live transcript\\n   517→\\tif state.TranscriptPath == \\\"\\\" {\\n   518→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   519→\\t}\\n   520→\\n   521→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   522→\\tif err != nil {\\n   523→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   524→\\t}\\n   525→\\n   526→\\tif len(liveData) == 0 {\\n   527→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   528→\\t}\\n   529→\\n   530→\\tfullTranscript := string(liveData)\\n   531→\\tdata.Transcript = liveData\\n   532→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   533→\\tdata.Prompts = readPromptsFromFilesystem(ctx, state.SessionID)\\n   534→\\n   535→\\t// Resolve files touched: prefers hook-populated state, falls back to transcript extraction\\n   536→\\tdata.FilesTouched = s.resolveFilesTouched(ctx, state)\\n   537→\\n   538→\\t// Calculate token usage from the extracted transcript portion\\n   539→\\tif len(data.Transcript) > 0 {\\n   540→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ctx, ag, data.Transcript, state.CheckpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   541→\\t}\\n   542→\\n   543→\\treturn data, nil\\n   544→}\\n   545→\\n   546→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   547→// For Claude Code and JSONL-based agents, this counts lines.\\n   548→// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n   549→// Returns 0 if the content is empty or malformed.\\n   550→func countTranscriptItems(agentType types.AgentType, content string) int {\\n   551→\\tif content == \\\"\\\" {\\n   552→\\t\\treturn 0\\n   553→\\t}\\n   554→\\n   555→\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n   556→\\tif agentType == agent.AgentTypeOpenCode {\\n   557→\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n   558→\\t\\tif err == nil && session != nil {\\n   559→\\t\\t\\treturn len(session.Messages)\\n   560→\\t\\t}\\n   561→\\t\\treturn 0\\n   562→\\t}\\n   563→\\n   564→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   565→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   566→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   567→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   568→\\t\\t\\treturn len(transcript.Messages)\\n   569→\\t\\t}\\n   570→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   571→\\t\\tif agentType == agent.AgentTypeGemini {\\n   572→\\t\\t\\treturn 0\\n   573→\\t\\t}\\n   574→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   575→\\t}\\n   576→\\n   577→\\t// Claude Code and other JSONL-based agents\\n   578→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   579→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   580→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   581→\\t\\tallLines = allLines[:len(allLines)-1]\\n   582→\\t}\\n   583→\\treturn len(allLines)\\n   584→}\\n   585→\\n   586→// extractUserPrompts extracts all user prompts from transcript content.\\n   587→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   588→func extractUserPrompts(agentType types.AgentType, content string) []string {\\n   589→\\tif content == \\\"\\\" {\\n   590→\\t\\treturn nil\\n   591→\\t}\\n   592→\\n   593→\\t// Droid has its own envelope format — use its parser to normalize first\\n   594→\\tif agentType == agent.AgentTypeFactoryAIDroid {\\n   595→\\t\\tlines, _, err := factoryaidroid.ParseDroidTranscriptFromBytes([]byte(content), 0)\\n   596→\\t\\tif err != nil {\\n   597→\\t\\t\\treturn nil\\n   598→\\t\\t}\\n   599→\\t\\tvar prompts []string\\n   600→\\t\\tfor _, line := range lines {\\n   601→\\t\\t\\tif line.Type != transcript.TypeUser {\\n   602→\\t\\t\\t\\tcontinue\\n   603→\\t\\t\\t}\\n   604→\\t\\t\\tif text := transcript.ExtractUserContent(line.Message); text != \\\"\\\" {\\n   605→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(text); stripped != \\\"\\\" {\\n   606→\\t\\t\\t\\t\\tprompts = append(prompts, stripped)\\n   607→\\t\\t\\t\\t}\\n   608→\\t\\t\\t}\\n   609→\\t\\t}\\n   610→\\t\\treturn prompts\\n   611→\\t}\\n   612→\\n   613→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   614→\\tif agentType == agent.AgentTypeOpenCode {\\n   615→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   616→\\t\\tif err == nil && len(prompts) > 0 {\\n   617→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   618→\\t\\t\\tfor _, prompt := range prompts {\\n   619→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   620→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   621→\\t\\t\\t\\t}\\n   622→\\t\\t\\t}\\n   623→\\t\\t\\treturn cleaned\\n   624→\\t\\t}\\n   625→\\t\\treturn nil\\n   626→\\t}\\n   627→\\n   628→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   629→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   630→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   631→\\t\\tif err == nil && len(prompts) > 0 {\\n   632→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   633→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   634→\\t\\t\\tfor _, prompt := range prompts {\\n   635→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   636→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   637→\\t\\t\\t\\t}\\n   638→\\t\\t\\t}\\n   639→\\t\\t\\treturn cleaned\\n   640→\\t\\t}\\n   641→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   642→\\t\\tif agentType == agent.AgentTypeGemini {\\n   643→\\t\\t\\treturn nil\\n   644→\\t\\t}\\n   645→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   646→\\t}\\n   647→\\n   648→\\t// Claude Code and other JSONL-based agents\\n   649→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   650→}\\n   651→\\n   652→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   653→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   654→func extractUserPromptsFromLines(lines []string) []string {\\n   655→\\tvar prompts []string\\n   656→\\tfor _, line := range lines {\\n   657→\\t\\tline = strings.TrimSpace(line)\\n   658→\\t\\tif line == \\\"\\\" {\\n   659→\\t\\t\\tcontinue\\n   660→\\t\\t}\\n   661→\\n   662→\\t\\tvar entry map[string]interface{}\\n   663→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   664→\\t\\t\\tcontinue\\n   665→\\t\\t}\\n   666→\\n   667→\\t\\t// Check for user message:\\n   668→\\t\\t// - Claude Code uses \\\"type\\\": \\\"human\\\" or \\\"type\\\": \\\"user\\\"\\n   669→\\t\\t// - Cursor uses \\\"role\\\": \\\"user\\\"\\n   670→\\t\\tmsgType, _ := entry[\\\"type\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   671→\\t\\tmsgRole, _ := entry[\\\"role\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   672→\\t\\tisUser := msgType == \\\"human\\\" || msgType == \\\"user\\\" || msgRole == \\\"user\\\"\\n   673→\\t\\tif !isUser {\\n   674→\\t\\t\\tcontinue\\n   675→\\t\\t}\\n   676→\\n   677→\\t\\t// Extract message content\\n   678→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   679→\\t\\tif !ok {\\n   680→\\t\\t\\tcontinue\\n   681→\\t\\t}\\n   682→\\n   683→\\t\\t// Handle string content\\n   684→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   685→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   686→\\t\\t\\tif cleaned != \\\"\\\" {\\n   687→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   688→\\t\\t\\t}\\n   689→\\t\\t\\tcontinue\\n   690→\\t\\t}\\n   691→\\n   692→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   693→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   694→\\t\\t\\tvar texts []string\\n   695→\\t\\t\\tfor _, item := range arr {\\n   696→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   697→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   698→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   699→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   700→\\t\\t\\t\\t\\t\\t}\\n   701→\\t\\t\\t\\t\\t}\\n   702→\\t\\t\\t\\t}\\n   703→\\t\\t\\t}\\n   704→\\t\\t\\tif len(texts) > 0 {\\n   705→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   706→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   707→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   708→\\t\\t\\t\\t}\\n   709→\\t\\t\\t}\\n   710→\\t\\t}\\n   711→\\t}\\n   712→\\treturn prompts\\n   713→}\\n   714→\\n   715→// splitPromptContent splits prompt.txt content on the \\\"\\\\n\\\\n---\\\\n\\\\n\\\" separator.\\n   716→// Returns nil if content is empty.\\n   717→func splitPromptContent(content string) []string {\\n   718→\\tif content == \\\"\\\" {\\n   719→\\t\\treturn nil\\n   720→\\t}\\n   721→\\tparts := strings.Split(content, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   722→\\tvar result []string\\n   723→\\tfor _, p := range parts {\\n   724→\\t\\ttrimmed := strings.TrimSpace(p)\\n   725→\\t\\tif trimmed != \\\"\\\" {\\n   726→\\t\\t\\tresult = append(result, trimmed)\\n   727→\\t\\t}\\n   728→\\t}\\n   729→\\treturn result\\n   730→}\\n   731→\\n   732→// readPromptsFromFilesystem reads prompt.txt from the filesystem session metadata directory.\\n   733→// This file is written at turn start and updated at each SaveStep, providing prompt data\\n   734→// even for mid-turn commits where the shadow branch may not have been updated.\\n   735→func readPromptsFromFilesystem(ctx context.Context, sessionID string) []string {\\n   736→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   737→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   738→\\tif err != nil {\\n   739→\\t\\treturn nil\\n   740→\\t}\\n   741→\\tdata, err := os.ReadFile(filepath.Join(sessionDirAbs, paths.PromptFileName)) //nolint:gosec // path from session ID\\n   742→\\tif err != nil || len(data) == 0 {\\n   743→\\t\\treturn nil\\n   744→\\t}\\n   745→\\treturn splitPromptContent(string(data))\\n   746→}\\n   747→\\n   748→// clearFilesystemPrompt removes the filesystem prompt.txt for a session.\\n   749→// Called after condensation so subsequent checkpoints start fresh.\\n   750→func clearFilesystemPrompt(ctx context.Context, sessionID string) {\\n   751→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   752→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   753→\\tif err != nil {\\n   754→\\t\\treturn\\n   755→\\t}\\n   756→\\tpromptPath := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   757→\\t_ = os.Remove(promptPath)\\n   758→}\\n   759→\\n   760→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   761→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   762→func (s *ManualCommitStrategy) CondenseSessionByID(ctx context.Context, sessionID string) error {\\n   763→\\tlogCtx := logging.WithComponent(ctx, \\\"condense-by-id\\\")\\n   764→\\n   765→\\t// Load session state\\n   766→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   767→\\tif err != nil {\\n   768→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   769→\\t}\\n   770→\\tif state == nil {\\n   771→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   772→\\t}\\n   773→\\n   774→\\t// Open repository\\n   775→\\trepo, err := OpenRepository(ctx)\\n   776→\\tif err != nil {\\n   777→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   778→\\t}\\n   779→\\n   780→\\t// Generate a checkpoint ID\\n   781→\\tcheckpointID, err := id.Generate()\\n   782→\\tif err != nil {\\n   783→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   784→\\t}\\n   785→\\n   786→\\t// Check if shadow branch exists (required for condensation)\\n   787→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   788→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   789→\\t_, refErr := repo.Reference(refName, true)\\n   790→\\thasShadowBranch := refErr == nil\\n   791→\\n   792→\\tif !hasShadowBranch {\\n   793→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   794→\\t\\t// Just clean up the state file.\\n   795→\\t\\tlogging.Info(logCtx, \\\"no shadow branch for session, clearing state only\\\",\\n   796→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   797→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   798→\\t\\t)\\n   799→\\t\\tif err := s.clearSessionState(ctx, sessionID); err != nil {\\n   800→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   801→\\t\\t}\\n   802→\\t