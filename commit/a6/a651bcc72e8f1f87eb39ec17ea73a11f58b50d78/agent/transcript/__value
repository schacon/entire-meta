subprocesses (v0.0.421+).\\n    59→\\t// Like Gemini, the subprocess may inherit the user's TTY but can't respond\\n    60→\\t// to interactive prompts.\\n    61→\\tif os.Getenv(\\\"COPILOT_CLI\\\") != \\\"\\\" {\\n    62→\\t\\treturn false\\n    63→\\t}\\n    64→\\n    65→\\t// GIT_TERMINAL_PROMPT=0 disables git's own terminal prompts.\\n    66→\\t// Factory AI Droid (and other non-interactive environments like CI) set this.\\n    67→\\t// Since we run as a git hook, respect it — if the environment doesn't want\\n    68→\\t// git prompting, our hook shouldn't prompt either.\\n    69→\\tif os.Getenv(\\\"GIT_TERMINAL_PROMPT\\\") == \\\"0\\\" {\\n    70→\\t\\treturn false\\n    71→\\t}\\n    72→\\n    73→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n    74→\\tif err != nil {\\n    75→\\t\\treturn false\\n    76→\\t}\\n    77→\\t_ = tty.Close()\\n    78→\\treturn true\\n    79→}\\n    80→\\n    81→// ttyResult represents the outcome of a TTY confirmation prompt.\\n    82→type ttyResult int\\n    83→\\n    84→const (\\n    85→\\tttyResultLink       ttyResult = iota // Link: add the checkpoint trailer\\n    86→\\tttyResultSkip                        // Skip: don't add the trailer\\n    87→\\tttyResultLinkAlways                  // Link and remember: add trailer + save \\\"always\\\" preference\\n    88→)\\n    89→\\n    90→// askConfirmTTY prompts the user via /dev/tty whether to link a commit to session context.\\n    91→// This requires a controlling terminal — callers must check hasTTY() first and handle\\n    92→// the no-TTY case (agent subprocesses, CI) themselves.\\n    93→//\\n    94→// header is displayed as the first line (e.g., \\\"Entire: Active Claude Code session\\\").\\n    95→// detail lines are displayed indented below the header.\\n    96→func askConfirmTTY(header string, details []string, prompt string, defaultYes bool) ttyResult {\\n    97→\\tdefaultResult := ttyResultSkip\\n    98→\\tif defaultYes {\\n    99→\\t\\tdefaultResult = ttyResultLink\\n   100→\\t}\\n   101→\\n   102→\\t// In test mode, don't try to interact with the real TTY — just use the default.\\n   103→\\t// ENTIRE_TEST_TTY=1 simulates \\\"a human is present\\\" for the hasTTY() check\\n   104→\\t// but we can't actually read from the TTY in tests.\\n   105→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   106→\\t\\treturn defaultResult\\n   107→\\t}\\n   108→\\n   109→\\t// Open /dev/tty for both reading and writing.\\n   110→\\t// This is the controlling terminal, which works even when stdin/stderr are redirected\\n   111→\\t// (e.g., human runs git commit -m where stdin is not a pipe).\\n   112→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   113→\\tif err != nil {\\n   114→\\t\\treturn defaultResult\\n   115→\\t}\\n   116→\\tdefer tty.Close()\\n   117→\\n   118→\\t// Write to tty directly, not stderr, since git hooks may redirect stderr to /dev/null\\n   119→\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", header)\\n   120→\\tfor _, line := range details {\\n   121→\\t\\tfmt.Fprintf(tty, \\\"  %s\\\\n\\\", line)\\n   122→\\t}\\n   123→\\n   124→\\t// Show prompt with option descriptions\\n   125→\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", prompt)\\n   126→\\tif defaultYes {\\n   127→\\t\\tfmt.Fprint(tty, \\\"  [Y]es / [n]o / [a]lways (remember my choice): \\\")\\n   128→\\t} else {\\n   129→\\t\\tfmt.Fprint(tty, \\\"  [y]es / [N]o / [a]lways (remember my choice): \\\")\\n   130→\\t}\\n   131→\\n   132→\\t// Read response\\n   133→\\treader := bufio.NewReader(tty)\\n   134→\\tresponse, err := reader.ReadString('\\\\n')\\n   135→\\tif err != nil {\\n   136→\\t\\treturn defaultResult\\n   137→\\t}\\n   138→\\n   139→\\tresponse = strings.TrimSpace(strings.ToLower(response))\\n   140→\\tswitch response {\\n   141→\\tcase \\\"y\\\", \\\"yes\\\":\\n   142→\\t\\treturn ttyResultLink\\n   143→\\tcase \\\"n\\\", \\\"no\\\":\\n   144→\\t\\treturn ttyResultSkip\\n   145→\\tcase \\\"a\\\", \\\"always\\\":\\n   146→\\t\\tret