rnal\",\"cwd\":\"/Users/robin/Developer/cli\",\"sessionId\":\"639237ef-b97f-4b82-b7ec-abda1e9b4bfa\",\"version\":\"2.1.49\",\"gitBranch\":\"robin/cursor-agent\",\"slug\":\"piped-tumbling-wren\",\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01MxzbCK4689fMhJqJAzoMiU\",\"type\":\"tool_result\",\"content\":\"     1→package strategy\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"encoding/json\\\"\\n     6→\\t\\\"errors\\\"\\n     7→\\t\\\"fmt\\\"\\n     8→\\t\\\"log/slog\\\"\\n     9→\\t\\\"os\\\"\\n    10→\\t\\\"strings\\\"\\n    11→\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/opencode\\\"\\n    16→\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n    22→\\t\\\"github.com/entireio/cli/cmd/entire/cli/stringutil\\\"\\n    23→\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n    25→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    26→\\n    27→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    28→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    29→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    30→)\\n    31→\\n    32→// listCheckpoints returns all checkpoints from the metadata branch.\\n    33→// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\n    34→func (s *ManualCommitStrategy) listCheckpoints() ([]CheckpointInfo, error) {\\n    35→\\tstore, err := s.getCheckpointStore()\\n    36→\\tif err != nil {\\n    37→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    38→\\t}\\n    39→\\n    40→\\tcommitted, err := store.ListCommitted(context.Background())\\n    41→\\tif err != nil {\\n    42→\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n    43→\\t}\\n    44→\\n    45→\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n    46→\\tresult := make([]CheckpointInfo, 0, len(committed))\\n    47→\\tfor _, c := range committed {\\n    48→\\t\\tresult = append(result, CheckpointInfo{\\n    49→\\t\\t\\tCheckpointID:     c.CheckpointID,\\n    50→\\t\\t\\tSessionID:        c.SessionID,\\n    51→\\t\\t\\tCreatedAt:        c.CreatedAt,\\n    52→\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n    53→\\t\\t\\tFilesTouched:     c.FilesTouched,\\n    54→\\t\\t\\tAgent:            c.Agent,\\n    55→\\t\\t\\tIsTask:           c.IsTask,\\n    56→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    57→\\t\\t\\tSessionCount:     c.SessionCount,\\n    58→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    59→\\t\\t})\\n    60→\\t}\\n    61→\\n    62→\\treturn result, nil\\n    63→}\\n    64→\\n    65→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    66→func (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n    67→\\tall, err := s.listCheckpoints()\\n    68→\\tif err != nil {\\n    69→\\t\\treturn nil, err\\n    70→\\t}\\n    71→\\n    72→\\tvar result []CheckpointInfo\\n    73→\\tfor _, cp := range all {\\n    74→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    75→\\t\\t\\tresult = append(result, cp)\\n    76→\\t\\t}\\n    77→\\t}\\n    78→\\n    79→\\tif len(result) == 0 {\\n    80→\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n    81→\\t}\\n    82→\\n    83→\\treturn result, nil\\n    84→}\\n    85→\\n    86→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    87→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    88→func (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n    89→\\tstore, err := s.getCheckpointStore()\\n    90→\\tif err != nil {\\n    91→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    92→\\t}\\n    93→\\n    94→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n    95→\\tif err != nil {\\n    96→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    97→\\t}\\n    98→\\tif content == nil {\\n    99→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n   100→\\t}\\n   101→\\tif len(content.Transcript) == 0 {\\n   102→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   103→\\t}\\n   104→\\n   105→\\treturn content.Transcript, nil\\n   106→}\\n   107→\\n   108→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   109→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   110→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   111→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   112→//\\n   113→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   114→// In this case, data is extracted from the live transcript instead.\\n   115→func (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n   116→\\t// Get shadow branch (may not exist for mid-session commits)\\n   117→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   118→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   119→\\tref, err := repo.Reference(refName, true)\\n   120→\\thasShadowBranch := err == nil\\n   121→\\n   122→\\tvar sessionData *ExtractedSessionData\\n   123→\\tif hasShadowBranch {\\n   124→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   125→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   126→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   127→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   128→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   129→\\t\\t// last turn had no code changes).\\n   130→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   131→\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n   132→\\t\\tif err != nil {\\n   133→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n   134→\\t\\t}\\n   135→\\t} else {\\n   136→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   137→\\t\\t// Extract data directly from live transcript.\\n   138→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   139→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   140→\\t\\t}\\n   141→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`)\\n   142→\\t\\tprepareTranscriptIfNeeded(state.AgentType, state.TranscriptPath)\\n   143→\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n   144→\\t\\tif err != nil {\\n   145→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n   146→\\t\\t}\\n   147→\\t}\\n   148→\\n   149→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   150→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   151→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   152→\\tif len(committedFiles) > 0 {\\n   153→\\t\\t// Track if we had files before filtering to distinguish between:\\n   154→\\t\\t// - Session had files but none were committed (don't fallback)\\n   155→\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n   156→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   157→\\n   158→\\t\\tif hadFilesBeforeFiltering {\\n   159→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   160→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   161→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   162→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   163→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   164→\\t\\t\\t\\t}\\n   165→\\t\\t\\t}\\n   166→\\t\\t\\tsessionData.FilesTouched = filtered\\n   167→\\t\\t}\\n   168→\\n   169→\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n   170→\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n   171→\\t\\t// the session had files that simply didn't overlap with the commit - that\\n   172→\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n   173→\\t\\t// overwritten with unrelated committed files.\\n   174→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   175→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   176→\\t\\t\\tfor f := range committedFiles {\\n   177→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   178→\\t\\t\\t}\\n   179→\\t\\t}\\n   180→\\t}\\n   181→\\n   182→\\t// Get checkpoint store\\n   183→\\tstore, err := s.getCheckpointStore()\\n   184→\\tif err != nil {\\n   185→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   186→\\t}\\n   187→\\n   188→\\t// Get author info\\n   189→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   190→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   191→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   192→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   193→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n   194→\\t// Get current branch name\\n   195→\\tbranchName := GetCurrentBranchName(repo)\\n   196→\\n   197→\\t// Generate summary if enabled\\n   198→\\tvar summary *cpkg.Summary\\n   199→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   200→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   201→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   202→\\n   203→\\t\\t// Scope transcript to this checkpoint's portion.\\n   204→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   205→\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n   206→\\t\\tvar scopedTranscript []byte\\n   207→\\t\\tswitch state.AgentType {\\n   208→\\t\\tcase agent.AgentTypeGemini:\\n   209→\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   210→\\t\\t\\tif sliceErr != nil {\\n   211→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n   212→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   213→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   214→\\t\\t\\t}\\n   215→\\t\\t\\tscopedTranscript = scoped\\n   216→\\t\\tcase agent.AgentTypeOpenCode:\\n   217→\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   218→\\t\\t\\tif sliceErr != nil {\\n   219→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n   220→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   221→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   222→\\t\\t\\t}\\n   223→\\t\\t\\tscopedTranscript = scoped\\n   224→\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeUnknown:\\n   225→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   226→\\t\\t}\\n   227→\\t\\tif len(scopedTranscript) > 0 {\\n   228→\\t\\t\\tvar err error\\n   229→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   230→\\t\\t\\tif err != nil {\\n   231→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   232→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   233→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   234→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   235→\\t\\t\\t} else {\\n   236→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   237→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   238→\\t\\t\\t}\\n   239→\\t\\t}\\n   240→\\t}\\n   241→\\n   242→\\t// Write checkpoint metadata using the checkpoint store\\n   243→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   244→\\t\\tCheckpointID:                checkpointID,\\n   245→\\t\\tSessionID:                   state.SessionID,\\n   246→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   247→\\t\\tBranch:                      branchName,\\n   248→\\t\\tTranscript:                  sessionData.Transcript,\\n   249→\\t\\tPrompts:                     sessionData.Prompts,\\n   250→\\t\\tContext:                     sessionData.Context,\\n   251→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   252→\\t\\tCheckpointsCount:            state.StepCount,\\n   253→\\t\\tEphemeralBranch:             shadowBranchName,\\n   254→\\t\\tAuthorName:                  authorName,\\n   255→\\t\\tAuthorEmail:                 authorEmail,\\n   256→\\t\\tAgent:                       state.AgentType,\\n   257→\\t\\tTurnID:                      state.TurnID,\\n   258→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   259→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   260→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   261→\\t\\tInitialAttribution:          attribution,\\n   262→\\t\\tSummary:                     summary,\\n   263→\\t}); err != nil {\\n   264→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   265→\\t}\\n   266→\\n   267→\\treturn &CondenseResult{\\n   268→\\t\\tCheckpointID:         checkpointID,\\n   269→\\t\\tSessionID:            state.SessionID,\\n   270→\\t\\tCheckpointsCount:     state.StepCount,\\n   271→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   272→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   273→\\t}, nil\\n   274→}\\n   275→\\n   276→func calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n   277→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   278→\\t// This uses user edits captured at each prompt start (before agent works),\\n   279→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   280→\\t//\\n   281→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   282→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   283→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   284→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   285→\\n   286→\\theadRef, headErr := repo.Head()\\n   287→\\tif headErr != nil {\\n   288→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   289→\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   290→\\t\\treturn nil\\n   291→\\t}\\n   292→\\n   293→\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   294→\\tif commitErr != nil {\\n   295→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   296→\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   297→\\t\\treturn nil\\n   298→\\t}\\n   299→\\n   300→\\theadTree, treeErr := headCommit.Tree()\\n   301→\\tif treeErr != nil {\\n   302→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   303→\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   304→\\t\\treturn nil\\n   305→\\t}\\n   306→\\n   307→\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n   308→\\tvar shadowTree *object.Tree\\n   309→\\tif shadowRef != nil {\\n   310→\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   311→\\t\\tif shadowErr != nil {\\n   312→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   313→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   314→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   315→\\t\\t\\treturn nil\\n   316→\\t\\t}\\n   317→\\t\\tvar shadowTreeErr error\\n   318→\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   319→\\t\\tif shadowTreeErr != nil {\\n   320→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   321→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   322→\\t\\t\\treturn nil\\n   323→\\t\\t}\\n   324→\\t} else {\\n   325→\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   326→\\t\\t// because the agent's work is the commit itself.\\n   327→\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   328→\\t\\tshadowTree = headTree\\n   329→\\t}\\n   330→\\n   331→\\t// Get base tree (state before session started)\\n   332→\\tvar baseTree *object.Tree\\n   333→\\tattrBase := state.AttributionBaseCommit\\n   334→\\tif attrBase == \\\"\\\" {\\n   335→\\t\\tattrBase = state.BaseCommit // backward compat\\n   336→\\t}\\n   337→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   338→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   339→\\t\\t\\tbaseTree = tree\\n   340→\\t\\t} else {\\n   341→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   342→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   343→\\t\\t}\\n   344→\\t} else {\\n   345→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   346→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   347→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   348→\\t}\\n   349→\\n   350→\\t// Log accumulated prompt attributions for debugging\\n   351→\\tvar totalUserAdded, totalUserRemoved int\\n   352→\\tfor i, pa := range state.PromptAttributions {\\n   353→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   354→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   355→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   356→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   357→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   358→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   359→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   360→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   361→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   362→\\t}\\n   363→\\n   364→\\tattribution := CalculateAttributionWithAccumulated(\\n   365→\\t\\tbaseTree,\\n   366→\\t\\tshadowTree,\\n   367→\\t\\theadTree,\\n   368→\\t\\tsessionData.FilesTouched,\\n   369→\\t\\tstate.PromptAttributions,\\n   370→\\t)\\n   371→\\n   372→\\tif attribution != nil {\\n   373→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   374→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   375→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   376→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   377→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   378→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   379→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   380→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   381→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   382→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   383→\\t}\\n   384→\\n   385→\\treturn attribution\\n   386→}\\n   387→\\n   388→// extractSessionData extracts session data from the shadow branch.\\n   389→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   390→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   391→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   392→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   393→// continued growing — the shadow branch copy would be stale.\\n   394→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   395→func (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n   396→\\tcommit, err := repo.CommitObject(shadowRef)\\n   397→\\tif err != nil {\\n   398→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   399→\\t}\\n   400→\\n   401→\\ttree, err := commit.Tree()\\n   402→\\tif err != nil {\\n   403→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   404→\\t}\\n   405→\\n   406→\\tdata := &ExtractedSessionData{}\\n   407→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   408→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   409→\\n   410→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   411→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   412→\\t// (SaveStep is only called when there are file modifications).\\n   413→\\tvar fullTranscript string\\n   414→\\tif liveTranscriptPath != \\\"\\\" {\\n   415→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`)\\n   416→\\t\\tprepareTranscriptIfNeeded(agentType, liveTranscriptPath)\\n   417→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   418→\\t\\t\\tfullTranscript = string(liveData)\\n   419→\\t\\t}\\n   420→\\t}\\n   421→\\tif fullTranscript == \\\"\\\" {\\n   422→\\t\\t// Fall back to shadow branch copy\\n   423→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   424→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   425→\\t\\t\\t\\tfullTranscript = content\\n   426→\\t\\t\\t}\\n   427→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   428→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   429→\\t\\t\\t\\tfullTranscript = content\\n   430→\\t\\t\\t}\\n   431→\\t\\t}\\n   432→\\t}\\n   433→\\n   434→\\t// Process transcript based on agent type\\n   435→\\tif fullTranscript != \\\"\\\" {\\n   436→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   437→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   438→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   439→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   440→\\t}\\n   441→\\n   442→\\t// Use tracked files from session state (not all files in tree)\\n   443→\\tdata.FilesTouched = filesTouched\\n   444→\\n   445→\\t// Calculate token usage from the extracted transcript portion\\n   446→\\tif len(data.Transcript) > 0 {\\n   447→\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n   448→\\t}\\n   449→\\n   450→\\treturn data, nil\\n   451→}\\n   452→\\n   453→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   454→// This is used for mid-session commits where no shadow branch exists yet.\\n   455→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n   456→\\tdata := &ExtractedSessionData{}\\n   457→\\n   458→\\t// Read the live transcript\\n   459→\\tif state.TranscriptPath == \\\"\\\" {\\n   460→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   461→\\t}\\n   462→\\n   463→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   464→\\tif err != nil {\\n   465→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   466→\\t}\\n   467→\\n   468→\\tif len(liveData) == 0 {\\n   469→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   470→\\t}\\n   471→\\n   472→\\tfullTranscript := string(liveData)\\n   473→\\tdata.Transcript = liveData\\n   474→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   475→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   476→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   477→\\n   478→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   479→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   480→\\tif len(state.FilesTouched) > 0 {\\n   481→\\t\\tdata.FilesTouched = state.FilesTouched\\n   482→\\t} else {\\n   483→\\t\\t// Use the shared helper which includes subagent transcripts\\n   484→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n   485→\\t}\\n   486→\\n   487→\\t// Calculate token usage from the extracted transcript portion\\n   488→\\tif len(data.Transcript) > 0 {\\n   489→\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n   490→\\t}\\n   491→\\n   492→\\treturn data, nil\\n   493→}\\n   494→\\n   495→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   496→// For Claude Code and JSONL-based agents, this counts lines.\\n   497→// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n   498→// Returns 0 if the content is empty or malformed.\\n   499→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   500→\\tif content == \\\"\\\" {\\n   501→\\t\\treturn 0\\n   502→\\t}\\n   503→\\n   504→\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n   505→\\tif agentType == agent.AgentTypeOpenCode {\\n   506→\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n   507→\\t\\tif err == nil && session != nil {\\n   508→\\t\\t\\treturn len(session.Messages)\\n   509→\\t\\t}\\n   510→\\t\\treturn 0\\n   511→\\t}\\n   512→\\n   513→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   514→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   515→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   516→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   517→\\t\\t\\treturn len(transcript.Messages)\\n   518→\\t\\t}\\n   519→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   520→\\t\\tif agentType == agent.AgentTypeGemini {\\n   521→\\t\\t\\treturn 0\\n   522→\\t\\t}\\n   523→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   524→\\t}\\n   525→\\n   526→\\t// Claude Code and other JSONL-based agents\\n   527→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   528→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   529→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   530→\\t\\tallLines = allLines[:len(allLines)-1]\\n   531→\\t}\\n   532→\\treturn len(allLines)\\n   533→}\\n   534→\\n   535→// extractUserPrompts extracts all user prompts from transcript content.\\n   536→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   537→func extractUserPrompts(agentType agent.AgentType, content string) []string {\\n   538→\\tif content == \\\"\\\" {\\n   539→\\t\\treturn nil\\n   540→\\t}\\n   541→\\n   542→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   543→\\tif agentType == agent.AgentTypeOpenCode {\\n   544→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   545→\\t\\tif err == nil && len(prompts) > 0 {\\n   546→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   547→\\t\\t\\tfor _, prompt := range prompts {\\n   548→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   549→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   550→\\t\\t\\t\\t}\\n   551→\\t\\t\\t}\\n   552→\\t\\t\\treturn cleaned\\n   553→\\t\\t}\\n   554→\\t\\treturn nil\\n   555→\\t}\\n   556→\\n   557→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   558→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   559→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   560→\\t\\tif err == nil && len(prompts) > 0 {\\n   561→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   562→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   563→\\t\\t\\tfor _, prompt := range prompts {\\n   564→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   565→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   566→\\t\\t\\t\\t}\\n   567→\\t\\t\\t}\\n   568→\\t\\t\\treturn cleaned\\n   569→\\t\\t}\\n   570→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   571→\\t\\tif agentType == agent.AgentTypeGemini {\\n   572→\\t\\t\\treturn nil\\n   573→\\t\\t}\\n   574→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   575→\\t}\\n   576→\\n   577→\\t// Claude Code and other JSONL-based agents\\n   578→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   579→}\\n   580→\\n   581→// calculateTokenUsage calculates token usage from raw transcript data.\\n   582→// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n   583→// where the current checkpoint began, allowing calculation for only the portion\\n   584→// of the transcript since the last checkpoint.\\n   585→func calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n   586→\\tif len(data) == 0 {\\n   587→\\t\\treturn &agent.TokenUsage{}\\n   588→\\t}\\n   589→\\n   590→\\t// No token usage information from Cursor yet\\n   591→\\tif agentType == agent.AgentTypeCursor {\\n   592→\\t\\treturn nil\\n   593→\\t}\\n   594→\\n   595→\\t// OpenCode uses JSONL with token info on assistant messages (different schema from Claude Code)\\n   596→\\tif agentType == agent.AgentTypeOpenCode {\\n   597→\\t\\treturn opencode.CalculateTokenUsageFromBytes(data, startOffset)\\n   598→\\t}\\n   599→\\n   600→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   601→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   602→\\t\\t// Attempt to parse as Gemini JSON\\n   603→\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n   604→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   605→\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n   606→\\t\\t}\\n   607→\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n   608→\\t\\tif agentType == agent.AgentTypeGemini {\\n   609→\\t\\t\\treturn &agent.TokenUsage{}\\n   610→\\t\\t}\\n   611→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   612→\\t}\\n   613→\\n   614→\\t// Claude Code and other JSONL-based agents\\n   615→\\tlines, err := transcript.ParseFromBytes(data)\\n   616→\\tif err != nil || len(lines) == 0 {\\n   617→\\t\\treturn &agent.TokenUsage{}\\n   618→\\t}\\n   619→\\t// Slice transcript lines to only include checkpoint portion\\n   620→\\tif startOffset > 0 && startOffset < len(lines) {\\n   621→\\t\\tlines = lines[startOffset:]\\n   622→\\t}\\n   623→\\treturn claudecode.CalculateTokenUsage(lines)\\n   624→}\\n   625→\\n   626→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   627→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   628→func extractUserPromptsFromLines(lines []string) []string {\\n   629→\\tvar prompts []string\\n   630→\\tfor _, line := range lines {\\n   631→\\t\\tline = strings.TrimSpace(line)\\n   632→\\t\\tif line == \\\"\\\" {\\n   633→\\t\\t\\tcontinue\\n   634→\\t\\t}\\n   635→\\n   636→\\t\\tvar entry map[string]interface{}\\n   637→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   638→\\t\\t\\tcontinue\\n   639→\\t\\t}\\n   640→\\n   641→\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n   642→\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n   643→\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n   644→\\t\\t\\tcontinue\\n   645→\\t\\t}\\n   646→\\n   647→\\t\\t// Extract message content\\n   648→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   649→\\t\\tif !ok {\\n   650→\\t\\t\\tcontinue\\n   651→\\t\\t}\\n   652→\\n   653→\\t\\t// Handle string content\\n   654→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   655→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   656→\\t\\t\\tif cleaned != \\\"\\\" {\\n   657→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   658→\\t\\t\\t}\\n   659→\\t\\t\\tcontinue\\n   660→\\t\\t}\\n   661→\\n   662→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   663→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   664→\\t\\t\\tvar texts []string\\n   665→\\t\\t\\tfor _, item := range arr {\\n   666→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   667→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   668→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   669→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   670→\\t\\t\\t\\t\\t\\t}\\n   671→\\t\\t\\t\\t\\t}\\n   672→\\t\\t\\t\\t}\\n   673→\\t\\t\\t}\\n   674→\\t\\t\\tif len(texts) > 0 {\\n   675→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   676→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   677→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   678→\\t\\t\\t\\t}\\n   679→\\t\\t\\t}\\n   680→\\t\\t}\\n   681→\\t}\\n   682→\\treturn prompts\\n   683→}\\n   684→\\n   685→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   686→func generateContextFromPrompts(prompts []string) []byte {\\n   687→\\tif len(prompts) == 0 {\\n   688→\\t\\treturn nil\\n   689→\\t}\\n   690→\\n   691→\\tvar buf strings.Builder\\n   692→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   693→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   694→\\n   695→\\tfor i, prompt := range prompts {\\n   696→\\t\\t// Truncate very long prompts for readability.\\n   697→\\t\\t// Use rune-based truncation to avoid splitting multi-byte UTF-8 characters (e.g. CJK).\\n   698→\\t\\tdisplayPrompt := stringutil.TruncateRunes(prompt, 500, \\\"...\\\")\\n   699→\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n   700→\\t\\tbuf.WriteString(displayPrompt)\\n   701→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   702→\\t}\\n   703→\\n   704→\\treturn []byte(buf.String())\\n   705→}\\n   706→\\n   707→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   708→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   709→func (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n   710→\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n   711→\\n   712→\\t// Load session state\\n   713→\\tstate, err := s.loadSessionState(sessionID)\\n   714→\\tif err != nil {\\n   715→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   716→\\t}\\n   717→\\tif state == nil {\\n   718→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   719→\\t}\\n   720→\\n   721→\\t// Open repository\\n   722→\\trepo, err := OpenRepository()\\n   723→\\tif err != nil {\\n   724→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   725→\\t}\\n   726→\\n   727→\\t// Generate a checkpoint ID\\n   728→\\tcheckpointID, err := id.Generate()\\n   729→\\tif err != nil {\\n   730→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   731→\\t}\\n   732→\\n   733→\\t// Check if shadow branch exists (required for condensation)\\n   734→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   735→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   736→\\t_, refErr := repo.Reference(refName, true)\\n   737→\\thasShadowBranch := refErr == nil\\n   738→\\n   739→\\tif !hasShadowBranch {\\n   740→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   741→\\t\\t// Just clean up the state file.\\n   742→\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n   743→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   744→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   745→\\t\\t)\\n   746→\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n   747→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   748→\\t\\t}\\n   749→\\t\\treturn nil\\n   750→\\t}\\n   751→\\n   752→\\t// Condense the session\\n   753→\\tresult, err := s.CondenseSession(repo, checkpointID, state, nil)\\n   754→\\tif err != nil {\\n   755→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   756→\\t}\\n   757→\\n   758→\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n   759→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   760→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   761→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   762→\\t)\\n   763→\\n   764→\\t// Update session state: reset step count and transition to idle\\n   765→\\tstate.StepCount = 0\\n   766→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   767→\\tstate.Phase = session.PhaseIdle\\n   768→\\tstate.LastCheckpointID = checkpointID\\n   769→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   770→\\tstate.PromptAttributions = nil\\n   771→\\tstate.PendingPromptAttribution = nil\\n   772→\\n   773→\\tif err := s.saveSessionState(state); err != nil {\\n   774→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   775→\\t}\\n   776→\\n   777→\\t// Clean up shadow branch if no other sessions need it\\n   778→\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n   779→\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n   780→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   781→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   782→\\t\\t)\\n   783→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   784→\\t}\\n   785→\\n   786→\\treturn nil\\n   787→}\\n   788→\\n   789→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   790→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(_ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   791→\\t// List all session states to check if any other session uses this shadow branch\\n   792→\\tallStates, err := s.listAllSessionStates()\\n   793→\\tif err != nil {\\n   794→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   795→\\t}\\n   796→\\n   797→\\tfor _, state := range allStates {\\n   798→\\t\\tif state.SessionID == excludeSessionID {\\n   799→\\t\\t\\tcontinue\\n   800→\\t\\t}\\n   801→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   802→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   803→\\t\\t\\t// Another session still needs this shadow branch\\n   804→\\t\\t\\treturn nil\\n   805→\\t\\t}\\n   806→\\t}\\n   807→\\n   808→\\t// No other sessions need it, delete the shadow branch via CLI\\n   809→\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n   810→\\tif err := DeleteBranchCLI(shadowBranchName); err != nil {\\n   811→\\t\\t// Branch already gone is not an error\\n   812→\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n   813→\\t\\t\\treturn nil\\n   814→\\t\\t}\\n   815→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n   816→\\t}\\n   817→\\treturn nil\\n   818→}\\n   819→\"}]},\"uuid\":\"3d191d33-e864-473d-8aff-e5aef9a179ce\",\"timestamp\":\"2026-02-24T12:50:23.529Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/robin/Developer/cli/cmd/entire/cli/strategy/manual_commit_condensation.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/opencode\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/stringutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// listCheckpoints returns all checkpoints from the metadata branch.\\n// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) listCheckpoints() ([]CheckpointInfo, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcommitted, err := store.ListCommitted(context.Background())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n\\t}\\n\\n\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n\\tresult := make([]CheckpointInfo, 0, len(committed))\\n\\tfor _, c := range committed {\\n\\t\\tresult = append(result, CheckpointInfo{\\n\\t\\t\\tCheckpointID:     c.CheckpointID,\\n\\t\\t\\tSessionID:        c.SessionID,\\n\\t\\t\\tCreatedAt:        c.CreatedAt,\\n\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n\\t\\t\\tFilesTouched:     c.FilesTouched,\\n\\t\\t\\tAgent:            c.Agent,\\n\\t\\t\\tIsTask:           c.IsTask,\\n\\t\\t\\tToolUseID:        c.ToolUseID,\\n\\t\\t\\tSessionCount:     c.SessionCount,\\n\\t\\t\\tSessionIDs:       c.SessionIDs,\\n\\t\\t})\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointsForSession returns all checkpoints for a session ID.\\nfunc (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n\\tall, err := s.listCheckpoints()\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tvar result []CheckpointInfo\\n\\tfor _, cp := range all {\\n\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n\\t\\t\\tresult = append(result, cp)\\n\\t\\t}\\n\\t}\\n\\n\\tif len(result) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// CondenseSession condenses a session's shadow branch to permanent storage.\\n// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n//\\n// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n// In this case, data is extracted from the live transcript instead.\\nfunc (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n\\t// Get shadow branch (may not exist for mid-session commits)\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\thasShadowBranch := err == nil\\n\\n\\tvar sessionData *ExtractedSessionData\\n\\tif hasShadowBranch {\\n\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n\\t\\t// last turn had no code changes).\\n\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n\\t\\t// Extract data directly from live transcript.\\n\\t\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n\\t\\t}\\n\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`)\\n\\t\\tprepareTranscriptIfNeeded(state.AgentType, state.TranscriptPath)\\n\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n\\t// committed in this specific commit. This ensures each checkpoint represents\\n\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n\\tif len(committedFiles) > 0 {\\n\\t\\t// Track if we had files before filtering to distinguish between:\\n\\t\\t// - Session had files but none were committed (don't fallback)\\n\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n\\n\\t\\tif hadFilesBeforeFiltering {\\n\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tsessionData.FilesTouched = filtered\\n\\t\\t}\\n\\n\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n\\t\\t// the session had files that simply didn't overlap with the commit - that\\n\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n\\t\\t// overwritten with unrelated committed files.\\n\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n\\t\\t\\tfor f := range committedFiles {\\n\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Get checkpoint store\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get author info\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Generate summary if enabled\\n\\tvar summary *cpkg.Summary\\n\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n\\n\\t\\t// Scope transcript to this checkpoint's portion.\\n\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n\\t\\tvar scopedTranscript []byte\\n\\t\\tswitch state.AgentType {\\n\\t\\tcase agent.AgentTypeGemini:\\n\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t\\tif sliceErr != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n\\t\\t\\t}\\n\\t\\t\\tscopedTranscript = scoped\\n\\t\\tcase agent.AgentTypeOpenCode:\\n\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t\\tif sliceErr != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n\\t\\t\\t}\\n\\t\\t\\tscopedTranscript = scoped\\n\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeUnknown:\\n\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t}\\n\\t\\tif len(scopedTranscript) > 0 {\\n\\t\\t\\tvar err error\\n\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t\\t// Continue without summary - non-blocking\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write checkpoint metadata using the checkpoint store\\n\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n\\t\\tCheckpointID:                checkpointID,\\n\\t\\tSessionID:                   state.SessionID,\\n\\t\\tStrategy:                    StrategyNameManualCommit,\\n\\t\\tBranch:                      branchName,\\n\\t\\tTranscript:                  sessionData.Transcript,\\n\\t\\tPrompts:                     sessionData.Prompts,\\n\\t\\tContext:                     sessionData.Context,\\n\\t\\tFilesTouched:                sessionData.FilesTouched,\\n\\t\\tCheckpointsCount:            state.StepCount,\\n\\t\\tEphemeralBranch:             shadowBranchName,\\n\\t\\tAuthorName:                  authorName,\\n\\t\\tAuthorEmail:                 authorEmail,\\n\\t\\tAgent:                       state.AgentType,\\n\\t\\tTurnID:                      state.TurnID,\\n\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n\\t\\tInitialAttribution:          attribution,\\n\\t\\tSummary:                     summary,\\n\\t}); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n\\t}\\n\\n\\treturn &CondenseResult{\\n\\t\\tCheckpointID:         checkpointID,\\n\\t\\tSessionID:            state.SessionID,\\n\\t\\tCheckpointsCount:     state.StepCount,\\n\\t\\tFilesTouched:         sessionData.FilesTouched,\\n\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n\\t}, nil\\n}\\n\\nfunc calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n\\t// Calculate initial attribution using accumulated prompt attribution data.\\n\\t// This uses user edits captured at each prompt start (before agent works),\\n\\t// plus any user edits after the final checkpoint (shadow → head).\\n\\t//\\n\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\n\\theadRef, headErr := repo.Head()\\n\\tif headErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n\\tif commitErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\theadTree, treeErr := headCommit.Tree()\\n\\tif treeErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n\\tvar shadowTree *object.Tree\\n\\tif shadowRef != nil {\\n\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n\\t\\tif shadowErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\tvar shadowTreeErr error\\n\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n\\t\\tif shadowTreeErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n\\t\\t// because the agent's work is the commit itself.\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n\\t\\tshadowTree = headTree\\n\\t}\\n\\n\\t// Get base tree (state before session started)\\n\\tvar baseTree *object.Tree\\n\\tattrBase := state.AttributionBaseCommit\\n\\tif attrBase == \\\"\\\" {\\n\\t\\tattrBase = state.BaseCommit // backward compat\\n\\t}\\n\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n\\t\\t\\tbaseTree = tree\\n\\t\\t} else {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n\\t\\t}\\n\\t} else {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n\\t}\\n\\n\\t// Log accumulated prompt attributions for debugging\\n\\tvar totalUserAdded, totalUserRemoved int\\n\\tfor i, pa := range state.PromptAttributions {\\n\\t\\ttotalUserAdded += pa.UserLinesAdded\\n\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"index\\\", i))\\n\\t}\\n\\n\\tattribution := CalculateAttributionWithAccumulated(\\n\\t\\tbaseTree,\\n\\t\\tshadowTree,\\n\\t\\theadTree,\\n\\t\\tsessionData.FilesTouched,\\n\\t\\tstate.PromptAttributions,\\n\\t)\\n\\n\\tif attribution != nil {\\n\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n\\t}\\n\\n\\treturn attribution\\n}\\n\\n// extractSessionData extracts session data from the shadow branch.\\n// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n// continued growing — the shadow branch copy would be stale.\\n// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\nfunc (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n\\tcommit, err := repo.CommitObject(shadowRef)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\tdata := &ExtractedSessionData{}\\n\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\n\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n\\t// (SaveStep is only called when there are file modifications).\\n\\tvar fullTranscript string\\n\\tif liveTranscriptPath != \\\"\\\" {\\n\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`)\\n\\t\\tprepareTranscriptIfNeeded(agentType, liveTranscriptPath)\\n\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n\\t\\t\\tfullTranscript = string(liveData)\\n\\t\\t}\\n\\t}\\n\\tif fullTranscript == \\\"\\\" {\\n\\t\\t// Fall back to shadow branch copy\\n\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Process transcript based on agent type\\n\\tif fullTranscript != \\\"\\\" {\\n\\t\\tdata.Transcript = []byte(fullTranscript)\\n\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\t}\\n\\n\\t// Use tracked files from session state (not all files in tree)\\n\\tdata.FilesTouched = filesTouched\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n// This is used for mid-session commits where no shadow branch exists yet.\\nfunc (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n\\tdata := &ExtractedSessionData{}\\n\\n\\t// Read the live transcript\\n\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n\\t}\\n\\n\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n\\t}\\n\\n\\tif len(liveData) == 0 {\\n\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n\\t}\\n\\n\\tfullTranscript := string(liveData)\\n\\tdata.Transcript = liveData\\n\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\n\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n\\t// (no SaveStep/Stop has been called yet to populate it)\\n\\tif len(state.FilesTouched) > 0 {\\n\\t\\tdata.FilesTouched = state.FilesTouched\\n\\t} else {\\n\\t\\t// Use the shared helper which includes subagent transcripts\\n\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n\\t}\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n// For Claude Code and JSONL-based agents, this counts lines.\\n// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n// Returns 0 if the content is empty or malformed.\\nfunc countTranscriptItems(agentType agent.AgentType, content string) int {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn 0\\n\\t}\\n\\n\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n\\tif agentType == agent.AgentTypeOpenCode {\\n\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n\\t\\tif err == nil && session != nil {\\n\\t\\t\\treturn len(session.Messages)\\n\\t\\t}\\n\\t\\treturn 0\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n\\t\\t\\treturn len(transcript.Messages)\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn 0\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n\\t\\tallLines = allLines[:len(allLines)-1]\\n\\t}\\n\\treturn len(allLines)\\n}\\n\\n// extractUserPrompts extracts all user prompts from transcript content.\\n// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\nfunc extractUserPrompts(agentType agent.AgentType, content string) []string {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n\\tif agentType == agent.AgentTypeOpenCode {\\n\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n\\t\\tif err == nil && len(prompts) > 0 {\\n\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n\\t\\t\\tfor _, prompt := range prompts {\\n\\t\\t\\t\\tif strippe