/cli/paths\\\"\\n    15→)\\n    16→\\n    17→const (\\n    18→\\t// EntireSettingsFile is the path to the Entire settings file\\n    19→\\tEntireSettingsFile = \\\".entire/settings.json\\\"\\n    20→\\t// EntireSettingsLocalFile is the path to the local settings override file (not committed)\\n    21→\\tEntireSettingsLocalFile = \\\".entire/settings.local.json\\\"\\n    22→)\\n    23→\\n    24→// EntireSettings represents the .entire/settings.json configuration\\n    25→type EntireSettings struct {\\n    26→\\n    27→\\t// Enabled indicates whether Entire is active. When false, CLI commands\\n    28→\\t// show a disabled message and hooks exit silently. Defaults to true.\\n    29→\\tEnabled bool `json:\\\"enabled\\\"`\\n    30→\\n    31→\\t// LocalDev indicates whether to use \\\"go run\\\" instead of the \\\"entire\\\" binary\\n    32→\\t// This is used for development when the binary is not installed\\n    33→\\tLocalDev bool `json:\\\"local_dev,omitempty\\\"`\\n    34→\\n    35→\\t// LogLevel sets the logging verbosity (debug, info, warn, error).\\n    36→\\t// Can be overridden by ENTIRE_LOG_LEVEL environment variable.\\n    37→\\t// Defaults to \\\"info\\\".\\n    38→\\tLogLevel string `json:\\\"log_level,omitempty\\\"`\\n    39→\\n    40→\\t// StrategyOptions contains strategy-specific configuration\\n    41→\\tStrategyOptions map[string]any `json:\\\"strategy_options,omitempty\\\"`\\n    42→\\n    43→\\t// Telemetry controls anonymous usage analytics.\\n    44→\\t// nil = not asked yet (show prompt), true = opted in, false = opted out\\n    45→\\tTelemetry *bool `json:\\\"telemetry,omitempty\\\"`\\n    46→}\\n    47→\\n    48→// Load loads the Entire settings from .entire/settings.json,\\n    49→// then applies any overrides from .entire/settings.local.json if it exists.\\n    50→// Returns default settings if neither file exists.\\n    51→// Works correctly from any subdirectory within the repository.\\n    52→func Load() (*EntireSettings, error) {\\n    53→\\t// Get absolute paths for settings files\\n    54→\\tsettingsFileAbs, err := paths.AbsPath(EntireSettingsFile)\\n    55→\\tif err != nil {\\n    56→\\t\\tsettingsFileAbs = EntireSettingsFile // Fallback to relative\\n    57→\\t}\\n    58→\\tlocalSettingsFileAbs, err := paths.AbsPath(EntireSettingsLocalFile)\\n    59→\\tif err != nil {\\n    60→\\t\\tlocalSettingsFileAbs = EntireSettingsLocalFile // Fallback to relative\\n    61→\\t}\\n    62→\\n    63→\\t// Load base settings\\n    64→\\tsettings, err := loadFromFile(settingsFileAbs)\\n    65→\\tif err != nil {\\n    66→\\t\\treturn nil, fmt.Errorf(\\\"reading settings file: %w\\\", err)\\n    67→\\t}\\n    68→\\n    69→\\t// Apply local overrides if they exist\\n    70→\\tlocalData, err := os.ReadFile(localSettingsFileAbs) //nolint:gosec // path is from AbsPath or constant\\n    71→\\tif err != nil {\\n    72→\\t\\tif !os.IsNotExist(err) {\\n    73→\\t\\t\\treturn nil, fmt.Errorf(\\\"reading local settings file: %w\\\", err)\\n    74→\\t\\t}\\n    75→\\t\\t// Local file doesn't exist, continue without overrides\\n    76→\\t} else {\\n    77→\\t\\tif err := mergeJSON(settings, localData); err != nil {\\n    78→\\t\\t\\treturn nil, fmt.Errorf(\\\"merging local settings: %w\\\", err)\\n    79→\\t\\t}\\n    80→\\t}\\n    81→\\n    82→\\treturn settings, nil\\n    83→}\\n    84→\\n    85→// LoadFromFile loads settings from a specific file path without merging local overrides.\\n    86→// Returns default settings if the file doesn't exist.\\n    87→// Use this when you need to display individual settings files separately.\\n    88→func LoadFromFile(filePath string) (*EntireSettings, error) {\\n    89→\\treturn loadFromFile(filePath)\\n    90→}\\n    91→\\n    92→// loadFromFile loads settings from a specific file path.\\n    93→// Returns default settings if the file doesn't exist.\\n    94→func loadFromFile(filePath string) (*EntireSettings, error) {\\n    95→\\tsettings := &EntireSettings{\\n    96→\\t\\tEnabled: tr