→var ErrNoMetadata = errors.New(\\\"commit has no entire metadata\\\")\\n    18→\\n    19→// ErrNoSession is returned when no session info is available.\\n    20→var ErrNoSession = errors.New(\\\"no session info available\\\")\\n    21→\\n    22→// ErrNotTaskCheckpoint is returned when a rewind point is not a task checkpoint.\\n    23→var ErrNotTaskCheckpoint = errors.New(\\\"not a task checkpoint\\\")\\n    24→\\n    25→// ErrEmptyRepository is returned when the repository has no commits yet.\\n    26→var ErrEmptyRepository = errors.New(\\\"repository has no commits yet\\\")\\n    27→\\n    28→// SessionInfo contains information about the current session state.\\n    29→// This is used to generate trailers for linking commits to their AI session.\\n    30→type SessionInfo struct {\\n    31→\\t// SessionID is the session identifier extracted from the latest commit's metadata\\n    32→\\tSessionID string\\n    33→\\n    34→\\t// Reference is a strategy-specific reference string.\\n    35→\\t// For manual-commit strategy: \\\"entire/abc1234\\\" (the shadow branch name)\\n    36→\\t// Empty for commit strategy (metadata is in the same commit).\\n    37→\\tReference string\\n    38→\\n    39→\\t// CommitHash is the full SHA of the commit containing the session metadata.\\n    40→\\t// Empty for commit strategy.\\n    41→\\tCommitHash string\\n    42→}\\n    43→\\n    44→// RewindPoint represents a point to which the user can rewind.\\n    45→// This abstraction allows different strategies to use different\\n    46→// identifiers (commit hashes, branch names, stash refs, etc.)\\n    47→type RewindPoint struct {\\n    48→\\t// ID is the unique identifier for this rewind point\\n    49→\\t// (commit hash, branch name, stash ref, etc.)\\n    50→\\tID string\\n    51→\\n    52→\\t// Message is the human-readable description/summary\\n    53→\\tMessage string\\n    54→\\n    55→\\t// MetadataDir is the path to the metadata directory\\n    56→\\tMetadataDir string\\n    57→\\n    58→\\t// Date is when this rewind point was created\\n    59→\\tDate time.Time\\n    60→\\n    61→\\t// IsTaskCheckpoint indicates if this is a task checkpoint (vs a session checkpoint)\\n    62→\\tIsTaskCheckpoint bool\\n    63→\\n    64→\\t// ToolUseID is the tool use ID for task checkpoints (empty for session checkpoints)\\n    65→\\tToolUseID string\\n    66→\\n    67→\\t// IsLogsOnly indicates this is a commit with session logs but no shadow branch state.\\n    68→\\t// The logs can be restored from entire/checkpoints/v1, but file state requires git checkout.\\n    69→\\tIsLogsOnly bool\\n    70→\\n    71→\\t// CheckpointID is the stable 12-hex-char identifier for logs-only points.\\n    72→\\t// Used to retrieve logs from entire/checkpoints/v1/<id[:2]>/<id[2:]>/full.jsonl\\n    73→\\t// Empty for shadow branch checkpoints (uncommitted).\\n    74→\\tCheckpointID id.CheckpointID\\n    75→\\n    76→\\t// Agent is the human-readable name of the agent that created this checkpoint\\n    77→\\t// (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n    78→\\tAgent agent.AgentType\\n    79→\\n    80→\\t// SessionID is the session identifier for this checkpoint.\\n    81→\\t// Used to distinguish checkpoints from different concurrent sessions.\\n    82→\\tSessionID string\\n    83→\\n    84→\\t// SessionPrompt is the initial prompt that started this session.\\n    85→\\t// Used to help users identify which session a checkpoint belongs to.\\n    86→\\tSessionPrompt string\\n    87→\\n    88→\\t// SessionCount is the number of sessions in this checkpoint (1 for single-session).\\n    89→\\t// Only populated for logs-only points with multi-session checkpoints.\\n    90→\\tSessionCount int\\n    91→\\n    92→\\t// SessionIDs contains all session IDs when this is a multi-session checkpoint.\\n    93→\\t// The last entry is the most recent session (same as SessionID).\\n    94→\\t// Only populated for logs-only points with multi-session checkpoints.\\n    95→\\tSessionIDs []string\\n    96→\\n    97→\\t// SessionPrompts contains the first prompt for each session (parallel to SessionIDs).\\n    98→\\t// Used to display context when showing resume commands for multi-session checkpoints.\\n    99→\\tSessionPrompts []string\\n   100→}\\n   101→\\n   102→// RewindPreview describes what will happen when rewinding to a checkpoint.\\n   103→// Used to warn users about files that will be modified or deleted.\\n   104→type RewindPreview struct {\\n   105→\\t// FilesToRestore are files from the checkpoint that will be written/restored.\\n   106→\\tFilesToRestore []string\\n   107→\\n   108→\\t// FilesToDelete are untracked files that will be removed.\\n   109→\\t// These are files created after the checkpoint that aren't in the checkpoint tree\\n   110→\\t// and weren't present at session start.\\n   111→\\tFilesToDelete []string\\n   112→\\n   113→\\t// TrackedChanges are tracked files with uncommitted changes that will be reverted.\\n   114→\\t// These come from the existing CanRewind() warning.\\n   115→\\tTrackedChanges []string\\n   116→}\\n   117→\\n   118→// StepContext contains all information needed for saving a step checkpoint.\\n   119→// All file paths should be pre-filtered and normalized by the CLI layer.\\n   120→type StepContext struct {\\n   121→\\t// SessionID is the Claude Code session identifier\\n   122→\\tSessionID string\\n   123→\\n   124→\\t// ModifiedFiles is the list of files modified during the session\\n   125→\\t// (extracted from the transcript, already filtered and relative)\\n   126→\\tModifiedFiles []string\\n   127→\\n   128→\\t// NewFiles is the list of new files created during the session\\n   129→\\t// (pre-computed by CLI from pre-prompt state comparison)\\n   130→\\tNewFiles []string\\n   131→\\n   132→\\t// DeletedFiles is the list of files deleted during the session\\n   133→\\t// (tracked files that no longer exist)\\n   134→\\tDeletedFiles []string\\n   135→\\n   136→\\t// MetadataDir is the path to the session metadata directory\\n   137→\\tMetadataDir string\\n   138→\\n   139→\\t// MetadataDirAbs is the absolute path to the session metadata directory\\n   140→\\tMetadataDirAbs string\\n   141→\\n   142→\\t// CommitMessage is the generated commit message\\n   143→\\tCommitMessage string\\n   144→\\n   145→\\t// TranscriptPath is the path to the transcript file\\n   146→\\tTranscriptPath string\\n   147→\\n   148→\\t// AuthorName is the name to use for commits\\n   149→\\tAuthorName string\\n   150→\\n   151→\\t// AuthorEmail is the email to use for commits\\n   152→\\tAuthorEmail string\\n   153→\\n   154→\\t// AgentType is the human-readable agent name (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   155→\\tAgentType agent.AgentType\\n   156→\\n   157→\\t// Transcript position at step/turn start - tracks what was added during this step\\n   158→\\tStepTranscriptIdentifier string // Last identifier when step started (UUID for Claude, message ID for Gemini)\\n   159→\\tStepTranscriptStart      int    // Transcript line count when this step/turn started\\n   160→\\n   161→\\t// TokenUsage contains the token usage for this checkpoint\\n   162→\\tTokenUsage *agent.TokenUsage\\n   163→}\\n   164→\\n   165→// TaskStepContext contains all information needed for saving a task step checkpoint.\\n   166→// This is called by the PostToolUse[Task] hook when a subagent completes.\\n   167→// The strategy is responsible for creating metadata structures and storing them\\n   168→// according to its storage approach.\\n   169→type TaskStepContext struct {\\n   170→\\t// SessionID is the Claude Code session identifier\\n   171→\\tSessionID string\\n   172→\\n   173→\\t// ToolUseID is the unique identifier for this Task tool invocation\\n   174→\\tToolUseID string\\n   175→\\n   176→\\t// AgentID is the subagent identifier (from tool_response.agentId)\\n   177→\\tAgentID string\\n   178→\\n   179→\\t// ModifiedFiles is the list of files modified by the subagent\\n   180→\\t// (extracted from the subagent's transcript)\\n   181→\\tModifiedFiles []string\\n   182→\\n   183→\\t// NewFiles is the list of new files created by the subagent\\n   184→\\t// (computed from pre-task state comparison)\\n   185→\\tNewFiles []string\\n   186→\\n   187→\\t// DeletedFiles is the list of files deleted by the subagent\\n   188→\\tDeletedFiles []string\\n   189→\\n   190→\\t// TranscriptPath is the path to the main session transcript\\n   191→\\tTranscriptPath string\\n   192→\\n   193→\\t// SubagentTranscriptPath is the path to the subagent's transcript (if available)\\n   194→\\tSubagentTranscriptPath string\\n   195→\\n   196→\\t// CheckpointUUID is the UUID for transcript truncation when rewinding\\n   197→\\tCheckpointUUID string\\n   198→\\n   199→\\t// AuthorName is the name to use for commits\\n   200→\\tAuthorName string\\n   201→\\n   202→\\t// AuthorEmail is the email to use for commits\\n   203→\\tAuthorEmail string\\n   204→\\n   205→\\t// IsIncremental indicates this is an incremental checkpoint during task execution,\\n   206→\\t// not a final task completion checkpoint. When true:\\n   207→\\t// - Writes to checkpoints/NNN-{tool-use-id}.json instead of checkpoint.json\\n   208→\\t// - Skips transcript handling\\n   209→\\t// - Uses incremental commit message\\n   210→\\tIsIncremental bool\\n   211→\\n   212→\\t// IncrementalSequence is the checkpoint sequence number (1, 2, 3, ...)\\n   213→\\t// Only used when IsIncremental is true\\n   214→\\tIncrementalSequence int\\n   215→\\n   216→\\t// IncrementalType is the tool that triggered this checkpoint (\\\"TodoWrite\\\", \\\"Edit\\\", etc.)\\n   217→\\t// Only used when IsIncremental is true\\n   218→\\tIncrementalType string\\n   219→\\n   220→\\t// IncrementalData is the tool_input payload for this checkpoint\\n   221→\\t// Only used when IsIncremental is true\\n   222→\\tIncrementalData json.RawMessage\\n   223→\\n   224→\\t// SubagentType is the type of subagent (e.g., \\\"dev\\\", \\\"reviewer\\\")\\n   225→\\t// Extracted from tool_input.subagent_type in Task tool\\n   226→\\t// Used for descriptive commit messages\\n   227→\\tSubagentType string\\n   228→\\n   229→\\t// TaskDescription is the task description provided to the subagent\\n   230→\\t// Extracted from tool_input.description in Task tool\\n   231→\\t// Used for descriptive commit messages\\n   232→\\tTaskDescription string\\n   233→\\n   234→\\t// TodoContent is the content of the in-progress todo item\\n   235→\\t// Extracted from tool_input.todos where status == \\\"in_progress\\\"\\n   236→\\t// Used for descriptive incremental checkpoint messages\\n   237→\\tTodoContent string\\n   238→\\n   239→\\t// AgentType is the human-readable agent name (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   240→\\tAgentType agent.AgentType\\n   241→}\\n   242→\\n   243→// TaskCheckpoint contains the checkpoint information written to checkpoint.json\\n   244→type TaskCheckpoint struct {\\n   245→\\tSessionID      string `json:\\\"session_id\\\"`\\n   246→\\tToolUseID      string `json:\\\"tool_use_id\\\"`\\n   247→\\tCheckpointUUID string `json:\\\"checkpoint_uuid\\\"`\\n   248→\\tAgentID        string `json:\\\"agent_id,omitempty\\\"`\\n   249→}\\n   250→\\n   251→// SubagentCheckpoint represents an intermediate checkpoint created during subagent execution.\\n   252→// These are created by PostToolUse hooks for tools like TodoWrite, Edit, Write.\\n   253→type SubagentCheckpoint struct {\\n   254→\\tType      string          `json:\\\"type\\\"`        // Tool name: \\\"TodoWrite\\\", \\\"Edit\\\", \\\"Write\\\"\\n   255→\\tToolUseID string          `json:\\\"tool_use_id\\\"` // The tool use ID that created this checkpoint\\n   256→\\tTimestamp time.Time       `json:\\\"timestamp\\\"`   // When the checkpoint was created\\n   257→\\tData      json.RawMessage `json:\\\"data\\\"`        // Type-specific payload (tool_input)\\n   258→}\\n   259→\\n   260→// TaskMetadataDir returns the path to a task's metadata directory\\n   261→// within the session metadata directory.\\n   262→func TaskMetadataDir(sessionMetadataDir, toolUseID string) string {\\n   263→\\treturn sessionMetadataDir + \\\"/tasks/\\\" + toolUseID\\n   264→}\\n   265→\\n   266→// ReadTaskCheckpoint reads the checkpoint.json file from a task metadata directory.\\n   267→// This is used during rewind to get the checkpoint UUID for transcript truncation.\\n   268→func ReadTaskCheckpoint(taskMetadataDir string) (*TaskCheckpoint, error) {\\n   269→\\tcheckpointFile := taskMetadataDir + \\\"/checkpoint.json\\\"\\n   270→\\n   271→\\tdata, err := os.ReadFile(checkpointFile) //nolint:gosec // Reading from controlled git metadata path\\n   272→\\tif err != nil {\\n   273→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   274→\\t}\\n   275→\\n   276→\\tvar checkpoint TaskCheckpoint\\n   277→\\tif err := json.Unmarshal(data, &checkpoint); err != nil {\\n   278→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   279→\\t}\\n   280→\\n   281→\\treturn &checkpoint, nil\\n   282→}\\n   283→\\n   284→// Strategy defines the interface for git operation strategies.\\n   285→// Different implementations can use commits, branches, stashes, etc.\\n   286→//\\n   287→// Note: State capture (tracking untracked files before a session) is handled\\n   288→// by the CLI layer, not the strategy. The strategy receives pre-computed\\n   289→// file lists in StepContext.\\n   290→type Strategy interface {\\n   291→\\t// Name returns the strategy identifier (e.g., \\\"commit\\\", \\\"branch\\\", \\\"stash\\\")\\n   292→\\tName() string\\n   293→\\n   294→\\t// ValidateRepository checks if the repository is in a valid state\\n   295→\\t// for this strategy to operate. Returns an error if validation fails.\\n   296→\\tValidateRepository() error\\n   297→\\n   298→\\t// SaveStep is called on Stop to save all session changes\\n   299→\\t// using this strategy's approach (commit, branch, stash, etc.)\\n   300→\\tSaveStep(ctx StepContext) error\\n   301→\\n   302→\\t// SaveTaskStep is called by PostToolUse[Task] hook when a subagent completes.\\n   303→\\t// Creates a checkpoint commit with task metadata for later rewind.\\n   304→\\t// Different strategies may handle this differently:\\n   305→\\t// - Commit strategy: commits to active branch\\n   306→\\t// - Manual-commit strategy: commits to shadow branch\\n   307→\\t// - Auto-commit strategy: commits logs to shadow only (code deferred to Stop)\\n   308→\\tSaveTaskStep(ctx TaskStepContext) error\\n   309→\\n   310→\\t// GetRewindPoints returns available points to rewind to.\\n   311→\\t// The limit parameter controls the maximum number of points to return.\\n   312→\\tGetRewindPoints(limit int) ([]RewindPoint, error)\\n   313→\\n   314→\\t// Rewind restores the repository to the given rewind point.\\n   315→\\t// The metadataDir in the point is used to restore the session transcript.\\n   316→\\tRewind(point RewindPoint) error\\n   317→\\n   318→\\t// CanRewind checks if rewinding is currently possible.\\n   319→\\t// Returns (canRewind, reason if not, error)\\n   320→\\tCanRewind() (bool, string, error)\\n   321→\\n   322→\\t// PreviewRewind returns what will happen if rewinding to the given point.\\n   323→\\t// This allows showing warnings about files that will be deleted before the rewind.\\n   324→\\t// Returns nil if preview is not supported\\n   325→\\tPreviewRewind(point RewindPoint) (*RewindPreview, error)\\n   326→\\n   327→\\t// GetTaskCheckpoint returns the task checkpoint for a given rewind point.\\n   328→\\t// For strategies that store checkpoints on disk (commit, manual-commit), this reads from the filesystem.\\n   329→\\t// Returns nil, nil if not a task checkpoint or checkpoint not found.\\n   330→\\tGetTaskCheckpoint(point RewindPoint) (*TaskCheckpoint, error)\\n   331→\\n   332→\\t// GetTaskCheckpointTranscript returns the session transcript for a task checkpoint.\\n   333→\\t// For strategies that store transcripts on disk (commit, manual-commit), this reads from the filesystem.\\n   334→\\tGetTaskCheckpointTranscript(point RewindPoint) ([]byte, error)\\n   335→\\n   336→\\t// GetSessionInfo returns session information for linking commits.\\n   337→\\t// This is used by the context command to generate trailers.\\n   338→\\t// Returns ErrNoSession if no session info is available.\\n   339→\\tGetSessionInfo() (*SessionInfo, error)\\n   340→\\n   341→\\t// NOTE: ListSessions and GetSession are standalone functions in session.go.\\n   342→\\t// They read from entire/checkpoints/v1 and merge with SessionSource if implemented.\\n   343→\\n   344→\\t// GetMetadataRef returns a reference to the metadata commit for the given checkpoint.\\n   345→\\t// Format: \\\"<branch>@<commit-sha>\\\" (e.g., \\\"entire/checkpoints/v1@abc123\\\").\\n   346→\\t// Returns empty string if not applicable (e.g., commit strategy with filesystem metadata).\\n   347→\\tGetMetadataRef(checkpoint Checkpoint) string\\n   348→\\n   349→\\t// GetSessionMetadataRef returns a reference to the most recent metadata commit for a session.\\n   350→\\t// Format: \\\"<branch>@<commit-sha>\\\" (e.g., \\\"entire/checkpoints/v1@abc123\\\").\\n   351→\\t// Returns empty string if not applicable or session not found.\\n   352→\\tGetSessionMetadataRef(sessionID string) string\\n   353→\\n   354→\\t// GetSessionContext returns the context.md content for a session.\\n   355→\\t// Returns empty string if not available.\\n   356→\\tGetSessionContext(sessionID string) string\\n   357→\\n   358→\\t// GetCheckpointLog returns the session transcript for a specific checkpoint.\\n   359→\\t// For strategies that store transcripts in git branches (manual-commit),\\n   360→\\t// this reads from the checkpoint's commit tree.\\n   361→\\t// For strategies that store on disk (commit), reads from the filesystem.\\n   362→\\t// Returns ErrNoMetadata if transcript is not available.\\n   363→\\tGetCheckpoin