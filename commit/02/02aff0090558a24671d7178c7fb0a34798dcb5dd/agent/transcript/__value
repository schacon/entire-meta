ire\\\" binary\\n    33→\\t// This is used for development when the binary is not installed\\n    34→\\tLocalDev bool `json:\\\"local_dev,omitempty\\\"`\\n    35→\\n    36→\\t// LogLevel sets the logging verbosity (debug, info, warn, error).\\n    37→\\t// Can be overridden by ENTIRE_LOG_LEVEL environment variable.\\n    38→\\t// Defaults to \\\"info\\\".\\n    39→\\tLogLevel string `json:\\\"log_level,omitempty\\\"`\\n    40→\\n    41→\\t// StrategyOptions contains strategy-specific configuration\\n    42→\\tStrategyOptions map[string]any `json:\\\"strategy_options,omitempty\\\"`\\n    43→\\n    44→\\t// Telemetry controls anonymous usage analytics.\\n    45→\\t// nil = not asked yet (show prompt), true = opted in, false = opted out\\n    46→\\tTelemetry *bool `json:\\\"telemetry,omitempty\\\"`\\n    47→\\n    48→\\t// Deprecated: no longer used. Exists to tolerate old settings files\\n    49→\\t// that still contain \\\"strategy\\\": \\\"auto-commit\\\" or similar.\\n    50→\\tStrategy string `json:\\\"strategy,omitempty\\\"`\\n    51→}\\n    52→\\n    53→// Load loads the Entire settings from .entire/settings.json,\\n    54→// then applies any overrides from .entire/settings.local.json if it exists.\\n    55→// Returns default settings if neither file exists.\\n    56→// Works correctly from any subdirectory within the repository.\\n    57→func Load() (*EntireSettings, error) {\\n    58→\\t// Get absolute paths for settings files\\n    59→\\tsettingsFileAbs, err := paths.AbsPath(EntireSettingsFile)\\n    60→\\tif err != nil {\\n    61→\\t\\tsettingsFileAbs = EntireSettingsFile // Fallback to relative\\n    62→\\t}\\n    63→\\tlocalSettingsFileAbs, err := paths.AbsPath(EntireSettingsLocalFile)\\n    64→\\tif err != nil {\\n    65→\\t\\tlocalSettingsFileAbs = EntireSettingsLocalFile // Fallback to relative\\n    66→\\t}\\n    67→\\n    68→\\t// Load base settings\\n    69→\\tsettings, err := loadFromFile(settingsFileAbs)\\n    70→\\tif err != nil {\\n    71→\\t\\treturn nil, fmt.Errorf(\\\"reading settings file: %w\\\", err)\\n    72→\\t}\\n    73→\\n    74→\\t// Apply local overrides if they exist\\n    75→\\tlocalData, err := os.ReadFile(localSettingsFileAbs) //nolint:gosec // path is from AbsPath or constant\\n    76→\\tif err != nil {\\n    77→\\t\\tif !os.IsNotExist(err) {\\n    78→\\t\\t\\treturn nil, fmt.Errorf(\\\"reading local settings file: %w\\\", err)\\n    79→\\t\\t}\\n    80→\\t\\t// Local file doesn't exist, continue without overrides\\n    81→\\t} else {\\n    82→\\t\\tif err := mergeJSON(settings, localData); err != nil {\\n    83→\\t\\t\\treturn nil, fmt.Errorf(\\\"merging local settings: %w\\\", err)\\n    84→\\t\\t}\\n    85→\\t}\\n    86→\\n    87→\\treturn settings, nil\\n    88→}\\n    89→\\n    90→// LoadFromFile loads settings from a specific file path without merging local overrides.\\n    91→// Returns default settings if the file doesn't exist.\\n    92→// Use this when you need to display individual settings files separately.\\n    93→func LoadFromFile(filePath string) (*EntireSettings, error) {\\n    94→\\treturn loadFromFile(filePath)\\n    95→}\\n    96→\\n    97→// loadFromFile loads settings from a specific file path.\\n    98→// Returns default settings if the file doesn't exist.\\n    99→func loadFromFile(filePath string) (*EntireSettings, error) {\\n   100→\\tsettings := &EntireSettings{\\n   101→\\t\\tEnabled: true, // Default to enabled\\n   102→\\t}\\n   103→\\n   104→\\tdata, err := os.ReadFile(filePath) //nolint:gosec // path is from caller\\n   105→\\tif err != nil {\\n   106→\\t\\tif os.IsNotExist(err) {\\n   107→\\t\\t\\treturn settings, nil\\n   108→\\t\\t}\\n   109→\\t\\treturn nil, fmt.Errorf(\\\"%w\\\", err)\\n   110→\\t}\\n   111→\\n   112→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   113→\\tdec.DisallowUnknownFields()\\n   114→\\tif err := dec.Decode(settings); err != nil {\\n   115→\\t\\treturn nil, fmt.Errorf(\\\"parsing settings file: %w\\\", err)\\n   116→\\t}\\n   117→\\n   118→\\treturn settings, nil\\n   119→}\\n   120→\\n   121→// mergeJSON merges JSON data into existing settings.\\n   122→// Only non-zero values from the JSON override existing settings.\\n   123→func mergeJSON(settings *EntireSettings, data []byte) error {\\n   124→\\t// First, validate that there are no unknown keys using strict decoding\\n   125→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   126→\\tdec.DisallowUnknownFields()\\n   127→\\tvar temp EntireSettings\\n   128→\\tif err := dec.Decode(&temp); err != nil {\\n   129→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   130→\\t}\\n   131→\\n   132→\\t// Parse into a map to check which fields are present\\n   133→\\tvar raw map[string]json.RawMessage\\n   134→\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   135→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   136→\\t}\\n   137→\\n   138→\\t// Override enabled if present\\n   139→\\tif enabledRaw, ok := raw[\\\"enabled\\\"]; ok {\\n   140→\\t\\tvar e bool\\n   141→\\t\\tif err := json.Unmarshal(enabledRaw, &e); err != nil {\\n   142→\\t\\t\\treturn fmt.Errorf(\\\"parsing enabled field: %w\\\", err)\\n   143→\\t\\t}\\n   144→\\t\\tsettings.Enabled = e\\n   145→\\t}\\n   146→\\n   147→\\t// Override local_dev if present\\n   148→\\tif localDevRaw, ok := raw[\\\"local_dev\\\"]; ok {\\n   149→\\t\\tvar ld bool\\n   150→\\t\\tif err := json.Unmarshal(localDevRaw, &ld); err != nil {\\n   151→\\t\\t\\treturn fmt.Errorf(\\\"parsing local_dev field: %w\\\", err)\\n   152→\\t\\t}\\n   153→\\t\\tsettings.LocalDev = ld\\n   154→\\t}\\n   155→\\n   156→\\t// Override log_level if present and non-empty\\n   157→\\tif logLevelRaw, ok := raw[\\\"log_level\\\"]; ok {\\n   158→\\t\\tvar ll string\\n   159→\\t\\tif err := json.Unmarshal(logLevelRaw, &ll); err != nil {\\n   160→\\t\\t\\treturn fmt.Errorf(\\\"parsing log_level field: %w\\\", err)\\n   161→\\t\\t}\\n   162→\\t\\tif ll != \\\"\\\" {\\n   163→\\t\\t\\tsettings.LogLevel =