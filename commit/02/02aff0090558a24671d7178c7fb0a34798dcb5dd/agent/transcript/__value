d for completion.\\n   754→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   755→\\n   756→// shellCompletionTarget returns the rc file path and completion lines for the\\n   757→// user's current shell.\\n   758→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   759→\\thome, err := os.UserHomeDir()\\n   760→\\tif err != nil {\\n   761→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   762→\\t}\\n   763→\\n   764→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   765→\\tswitch {\\n   766→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   767→\\t\\treturn \\\"Zsh\\\",\\n   768→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   769→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   770→\\t\\t\\tnil\\n   771→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   772→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   773→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   774→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   775→\\t\\t}\\n   776→\\t\\treturn \\\"Bash\\\",\\n   777→\\t\\t\\tbashRC,\\n   778→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   779→\\t\\t\\tnil\\n   780→\\tcase strings.Contains(shell, \\\"fish\\\"):\\n   781→\\t\\treturn \\\"Fish\\\",\\n   782→\\t\\t\\tfilepath.Join(home, \\\".config\\\", \\\"fish\\\", \\\"config.fish\\\"),\\n   783→\\t\\t\\t\\\"entire completion fish | source\\\",\\n   784→\\t\\t\\tnil\\n   785→\\tdefault:\\n   786→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   787→\\t}\\n   788→}\\n   789→\\n   790→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   791→// Only prompts if completion is not already configured.\\n   792→func promptShellCompletion(w io.Writer) error {\\n   793→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   794→\\tif err != 