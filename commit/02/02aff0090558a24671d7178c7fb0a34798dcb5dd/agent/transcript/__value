rn if repo has no commits yet\\n    60→\\t\\t\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n    61→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Note: This repository has no commits yet. Entire will be configured, but\\\")\\n    62→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"session checkpoints won't work until you create your first commit.\\\")\\n    63→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout())\\n    64→\\t\\t\\t}\\n    65→\\n    66→\\t\\t\\t// Non-interactive mode if --agent flag is provided\\n    67→\\t\\t\\tif cmd.Flags().Changed(\\\"agent\\\") && agentName == \\\"\\\" {\\n    68→\\t\\t\\t\\tprintMissingAgentError(cmd.ErrOrStderr())\\n    69→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n    70→\\t\\t\\t}\\n    71→\\n    72→\\t\\t\\tif agentName != \\\"\\\" {\\n    73→\\t\\t\\t\\tag, err := agent.Get(agent.AgentName(agentName))\\n    74→\\t\\t\\t\\tif err != nil {\\n    75→\\t\\t\\t\\t\\tprintWrongAgentError(cmd.ErrOrStderr(), agentName)\\n    76→\\t\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"wrong agent name\\\"))\\n    77→\\t\\t\\t\\t}\\n    78→\\t\\t\\t\\t// --agent is a targeted operation: set up this specific agent without\\n    79→\\t\\t\\t\\t// affecting other agents. Unlike the interactive path, it does not\\n    80→\\t\\t\\t\\t// uninstall hooks for other previously-enabled agents.\\n    81→\\t\\t\\t\\treturn setupAgentHooksNonInteractive(cmd.OutOrStdout(), ag, localDev, forceHooks, skipPushSessions, telemetry)\\n    82→\\t\\t\\t}\\n    83→\\t\\t\\t// Detect or prompt for agents\\n    84→\\t\\t\\tagents, err := detectOrSelectAgent(cmd.OutOrStdout(), nil)\\n    85→\\t\\t\\tif err != nil {\\n    86→\\t\\t\\t\\treturn fmt.Errorf(\\\"agent selection failed: %w\\\", err)\\n    87→\\t\\t\\t}\\n    88→\\n    89→\\t\\t\\treturn runEnableInteractive(cmd.OutOrStdout(), agents, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry)\\n    90