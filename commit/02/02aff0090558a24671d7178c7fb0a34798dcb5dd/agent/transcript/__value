treturn false\\n   216→\\t}\\n   217→\\treturn s.Enabled\\n   218→}\\n   219→\\n   220→// IsSummarizeEnabled checks if auto-summarize is enabled in settings.\\n   221→// Returns false by default if settings cannot be loaded or the key is missing.\\n   222→func IsSummarizeEnabled() bool {\\n   223→\\tsettings, err := Load()\\n   224→\\tif err != nil {\\n   225→\\t\\treturn false\\n   226→\\t}\\n   227→\\treturn settings.IsSummarizeEnabled()\\n   228→}\\n   229→\\n   230→// IsSummarizeEnabled checks if auto-summarize is enabled in this settings instance.\\n   231→func (s *EntireSettings) IsSummarizeEnabled() bool {\\n   232→\\tif s.StrategyOptions == nil {\\n   233→\\t\\treturn false\\n   234→\\t}\\n   235→\\tsummarizeOpts, ok := s.StrategyOptions[\\\"summarize\\\"].(map[string]any)\\n   236→\\tif !ok {\\n   237→\\t\\treturn false\\n   238→\\t}\\n   239→\\tenabled, ok := summarizeOpts[\\\"enabled\\\"].(bool)\\n   240→\\tif !ok {\\n   241→\\t\\treturn false\\n   242→\\t}\\n   243→\\treturn enabled\\n   244→}\\n   245→\\n   246→// IsPushSessionsDisabled checks if push_sessions is disabled in settings.\\n   247→// Returns true if push_sessions is explicitly set to false.\\n   248→func (s *EntireSettings) IsPushSessionsDisabled() bool {\\n   249→\\tif s.StrategyOptions == nil {\\n   250→\\t\\treturn false\\n   251→\\t}\\n   252→\\tval, exists := s.StrategyOptions[\\\"push_sessions\\\"]\\n   253→\\tif !exists {\\n   254→\\t\\treturn false\\n   255→\\t}\\n   256→\\tif boolVal, ok := val.(bool); ok {\\n   257→\\t\\treturn !boolVal // disabled = !push_sessions\\n   258→\\t}\\n   259→\\treturn false\\n   260→}\\n   261→\\n   262→// FilesWithDeprecatedStrategy returns the relative paths of settings files\\n   263→// that still contain the deprecated \\\"strategy\\\" field.\\n   264→func FilesWithDeprecatedStrategy() []string {\\n   265→\\tvar files []string\\n   266→\\tfor _, rel := range []string{EntireSettingsFile, EntireSettingsLocalFile} {\\n   267→\\t\\tabs, err := paths.A