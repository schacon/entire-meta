ound(), 10*time.Second)\\n   130→\\tdefer cancel()\\n   131→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"merge-base\\\", hashA, hashB)\\n   132→\\tcmd.Dir = repoPath\\n   133→\\tif err := cmd.Run(); err != nil {\\n   134→\\t\\tvar exitErr *exec.ExitError\\n   135→\\t\\tif errors.As(err, &exitErr) && exitErr.ExitCode() == 1 {\\n   136→\\t\\t\\treturn true, nil // No common ancestor — disconnected\\n   137→\\t\\t}\\n   138→\\t\\treturn false, fmt.Errorf(\\\"git merge-base failed: %w\\\", err)\\n   139→\\t}\\n   140→\\treturn false, nil // Shared ancestry\\n   141→}\\n   142→\\n   143→// collectCommitChain walks from tip to root following first parent, returns oldest-first.\\n   144→func collectCommitChain(repo *git.Repository, tip plumbing.Hash) ([]*object.Commit, error) {\\n   145→\\tvar chain []*object.Commit\\n   146→\\tcurrent := tip\\n   147→\\n   148→\\treachedRoot := false\\n   149→\\tfor range MaxCommitTraversalDepth {\\n   150→\\t\\tcommit, err := repo.CommitObject(current)\\n   151→\\t\\tif err != nil {\\n   152→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit %s: %w\\\", current, err)\\n   153→\\t\\t}\\n   154→\\t\\tchain = append(chain, commit)\\n   155→\\n   156→\\t\\tif len(commit.ParentHashes) == 0 {\\n   157→\\t\\t\\treachedRoot = true\\n   158→\\t\\t\\tbreak\\n   159→\\t\\t}\\n   160→\\t\\tcurrent = commit.ParentHashes[0]\\n   161→\\t}\\n   162→\\n   163→\\tif !reachedRoot {\\n   164→\\t\\treturn nil, fmt.Errorf(\\\"commit chain exceeded %d commits without reaching root; aborting reconciliation\\\", MaxCommitTraversalDepth)\\n   165→\\t}\\n   166→\\n   167→\\t// Reverse to oldest-first\\n   168→\\tfor i, j := 0, len(chain)-1; i < j; i, j = i+1, j-1 {\\n   169→\\t\\tchain[i], chain[j] = chain[j], chain[i]\\n   170→\\t}\\n   171→\\n   172→\\treturn chain, nil\\n   173→}\\n   174→\\n   175→// cherryPickOnto applies each commit's delta onto base, building a linear chain.\\n   176→// For each commit, it computes the full diff from its parent