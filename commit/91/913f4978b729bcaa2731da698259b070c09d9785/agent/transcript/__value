efName, true)\\n    42→\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n    43→\\t\\treturn nil // No remote branch — nothing to reconcile\\n    44→\\t}\\n    45→\\tif err != nil {\\n    46→\\t\\treturn fmt.Errorf(\\\"failed to check remote metadata branch: %w\\\", err)\\n    47→\\t}\\n    48→\\n    49→\\tlocalHash := localRef.Hash()\\n    50→\\tremoteHash := remoteRef.Hash()\\n    51→\\n    52→\\t// Same hash — nothing to do\\n    53→\\tif localHash == remoteHash {\\n    54→\\t\\treturn nil\\n    55→\\t}\\n    56→\\n    57→\\t// Check if disconnected using git merge-base\\n    58→\\trepoPath, err := getRepoPath(repo)\\n    59→\\tif err != nil {\\n    60→\\t\\treturn err\\n    61→\\t}\\n    62→\\n    63→\\tdisconnected, err := isDisconnected(repoPath, localHash.String(), remoteHash.String())\\n    64→\\tif err != nil {\\n    65→\\t\\treturn fmt.Errorf(\\\"failed to check metadata branch ancestry: %w\\\", err)\\n    66→\\t}\\n    67→\\tif !disconnected {\\n    68→\\t\\t// Shared ancestry (diverged or ancestor) — not our problem\\n    69→\\t\\treturn nil\\n    70→\\t}\\n    71→\\n    72→\\t// Disconnected — cherry-pick local commits onto remote tip\\n    73→\\tfmt.Fprintln(os.Stderr, \\\"[entire] Detected disconnected session metadata (local and remote share no common ancestor)\\\")\\n    74→\\n    75→\\t// Collect local commits oldest-first\\n    76→\\tlocalCommits, err := collectCommitChain(repo, localHash)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn fmt.Errorf(\\\"failed to collect local commits: %w\\\", err)\\n    79→\\t}\\n    80→\\n    81→\\t// Filter out empty-tree commits (the orphan bug commit)\\n    82→\\tvar dataCommits []*object.Commit\\n    83→\\tfor _, c := range localCommits {\\n    84→\\t\\ttree, treeErr := c.Tree()\\n    85→\\t\\tif treeErr != nil {\\n    86→\\t\\t\\treturn fmt.Errorf(\\\"failed to read tree for commit %s: %w\\\", c.Hash.String()[:7], treeErr)\\n    87→\\t\\t}\\n    88→\\t\\tif len(tree.Entries) > 0 {\\n    89→\\t\\t\\tda