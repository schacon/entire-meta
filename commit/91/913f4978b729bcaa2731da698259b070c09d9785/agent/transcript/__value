re pushed automatically alongside user pushes.\\n    22→// Configuration (stored in .entire/settings.json under strategy_options.push_sessions):\\n    23→//   - false: disable automatic pushing\\n    24→//   - true or not set: push automatically (default)\\n    25→func pushSessionsBranchCommon(ctx context.Context, remote, branchName string) error {\\n    26→\\t// Check if pushing is disabled\\n    27→\\tif isPushSessionsDisabled(ctx) {\\n    28→\\t\\treturn nil\\n    29→\\t}\\n    30→\\n    31→\\trepo, err := OpenRepository(ctx)\\n    32→\\tif err != nil {\\n    33→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n    34→\\t}\\n    35→\\n    36→\\t// Check if branch exists locally\\n    37→\\tbranchRef := plumbing.NewBranchReferenceName(branchName)\\n    38→\\tlocalRef, err := repo.Reference(branchRef, true)\\n    39→\\tif err != nil {\\n    40→\\t\\t// No branch, nothing to push\\n    41→\\t\\treturn nil //nolint:nilerr // Expected when no sessions exist yet\\n    42→\\t}\\n    43→\\n    44→\\t// Check if there's actually something to push (local differs from remote)\\n    45→\\tif !hasUnpushedSessionsCommon(repo, remote, localRef.Hash(), branchName) {\\n    46→\\t\\t// Nothing to push - skip silently\\n    47→\\t\\treturn nil\\n    48→\\t}\\n    49→\\n    50→\\treturn doPushSessionsBranch(ctx, remote, branchName)\\n    51→}\\n    52→\\n    53→// hasUnpushedSessionsCommon checks if the local branch differs from the remote.\\n    54→// Returns true if there's any difference that needs syncing (local ahead, remote ahead, or diverged).\\n    55→func hasUnpushedSessionsCommon(repo *git.Repository, remote string, localHash plumbing.Hash, branchName string) bool {\\n    56→\\t// Check for remote tracking ref: refs/remotes/<remote>/<branch>\\n    57→\\tremoteRefName := plumbing.NewRemoteReferenceName(remote, branchName)\\n    58→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n    59→\\tif err != nil {\\n    60→\\t\\t// Remote branch doesn't exist yet - we have content to push\\n    61→\\t\\treturn true\\n    62→\\t}\\n    63→\\n    64→\\t// If local and remote point to same commit, nothing to sync\\n    65→\\t// This is the only case where we skip - any difference needs handling\\n    66→\\treturn localHash != remoteRef.Hash()\\n    67→}\\n    68→\\n    69→// isPushSessionsDisabled checks if push_sessions is disabled in settings.\\n    70→// Returns true if push_sessions is explicitly set to false.\\n    71→func isPushSessionsDisabled(ctx context.Context) bool {\\n    72→\\ts, err := settings.Load(ctx)\\n    73→\\tif err != nil {\\n    74→\\t\\treturn false // Default: push is enabled\\n    75→\\t}\\n    76→\\treturn s.IsPushSessionsDisabled()\\n    77→}\\n    78→\\n    79→// doPushSessionsBranch pushes the sessions branch to the remote.\\n    80→func doPushSessionsBranch(ctx context.Context, remote, branchName string) error {\\n    81→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Pushing session logs to %s...\\\\n\\\", remote)\\n    82→\\n    83→\\t// Try pushing first\\n    84→\\tif err := tryPushSessionsCommon(ctx, remote, branchName); err == nil {\\n    85→\\t\\treturn nil\\n    86→\\t}\\n    87→\\n    88→\\t// Push failed - likely non-fast-forward. Try to fetch and merge.\\n    89→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Syncing with remote session logs...\\\\n\\\")\\n    90→\\n    91→\\tif err := fetchAndMergeSessionsCommon(ctx, remote, branchName); err != nil {\\n    92→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: couldn't sync sessions: %v\\\\n\\\", err)\\n    93→\\t\\treturn nil // Don't fail the main push\\n    94→\\t}\\n    95→\\n    96→\\t// Try pushing again after merge\\n    97→\\tif err := tryPushSessionsCommon(ctx, remote, branchName); err != nil {\\n    98→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to push sessions after sync: %v\\\\n\\\", err)\\n    99→\\t}\\n   100→\\n   101→\\treturn nil\\n   102→}\\n   103→\\n   104→// tryPushSessionsCommon attempts to push the sessions branch.\\n   105→func tryPushSessionsCommon(ctx context.Context, remote, branchName string) error {\\n   106→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   107→\\tdefer cancel()\\n   108→\\n   109→\\t// Use --no-verify to prevent recursive hook calls\\n   110→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"push\\\", \\\"--no-verify\\\", remote, branchName)\\n   111→\\tcmd.Stdin = nil // Disconnect stdin to prevent hanging in hook context\\n   112→\\n   113→\\toutput, err := cmd.CombinedOutput()\\n   114→\\tif err != nil {\\n   115→\\t\\t// Check if it's a non-fast-forward error (we can try to recover)\\n   116→\\t\\tif strings.Contains(string(output), \\\"non-fast-forward\\\") ||\\n   117→\\t\\t\\tstrings.Contains(string(output), \\\"rejected\\\") {\\n   118→\\t\\t\\treturn errors.New(\\\"non-fast-forward\\\")\\n   119→\\t\\t}\\n   120→\\t\\treturn fmt.Errorf(\\\"push failed: %s\\\", output)\\n   121→\\t}\\n   122→\\treturn nil\\n   123→}\\n   124→\\n   125→// fetchAndMergeSessionsCommon fetches remote sessions and merges into local using go-git.\\n   126→// Since session logs are append-only (unique cond-* directories), we just combine trees.\\n   127→func fetchAndMergeSessionsCommon(ctx context.Context, remote, branchName string) error {\\n   128→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   129→\\tdefer cancel()\\n   130→\\n   131→\\t// Use git CLI for fetch (go-git's fetch can be tricky with auth)\\n   132→\\tfetchCmd := exec.CommandContext(ctx, \\\"git\\\", \\\"fetch\\\", remote, branchName)\\n   133→\\tfetchCmd.Stdin = nil\\n   134→\\tif output, err := fetchCmd.CombinedOutput(); err != nil {\\n   135→\\t\\treturn fmt.Errorf(\\\"fetch failed: %s\\\", output)\\n   136→\\t}\\n   137→\\n   138→\\trepo, err := OpenRepository(ctx)\\n   139→\\tif err != nil {\\n   140→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   141→\\t}\\n   142→\\n   143→\\t// Get local branch\\n   144→\\tlocalRef, err := repo.Ref