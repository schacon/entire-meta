make(map[string]object.TreeEntry)\\n   211→\\t\\tfor path, entry := range commitEntries {\\n   212→\\t\\t\\tparentEntry, exists := parentEntries[path]\\n   213→\\t\\t\\tif !exists || parentEntry.Hash != entry.Hash {\\n   214→\\t\\t\\t\\tadded[path] = entry // New or modified\\n   215→\\t\\t\\t}\\n   216→\\t\\t}\\n   217→\\t\\tvar deleted []string\\n   218→\\t\\tfor path := range parentEntries {\\n   219→\\t\\t\\tif _, exists := commitEntries[path]; !exists {\\n   220→\\t\\t\\t\\tdeleted = append(deleted, path) // Removed in this commit\\n   221→\\t\\t\\t}\\n   222→\\t\\t}\\n   223→\\n   224→\\t\\tif len(added) == 0 && len(deleted) == 0 {\\n   225→\\t\\t\\tcontinue // Skip no-op commits\\n   226→\\t\\t}\\n   227→\\n   228→\\t\\t// Get current tip's tree and apply delta\\n   229→\\t\\ttipCommit, err := repo.CommitObject(currentTip)\\n   230→\\t\\tif err != nil {\\n   231→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get tip commit: %w\\\", err)\\n   232→\\t\\t}\\n   233→\\t\\ttipTree, err := tipCommit.Tree()\\n   234→\\t\\tif err != nil {\\n   235→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get tip tree: %w\\\", err)\\n   236→\\t\\t}\\n   237→\\n   238→\\t\\tmergedEntries := make(map[string]object.TreeEntry)\\n   239→\\t\\tif err := checkpoint.FlattenTree(repo, tipTree, \\\"\\\", mergedEntries); err != nil {\\n   240→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten tip tree: %w\\\", err)\\n   241→\\t\\t}\\n   242→\\t\\tfor path, entry := range added {\\n   243→\\t\\t\\tmergedEntries[path] = entry\\n   244→\\t\\t}\\n   245→\\t\\tfor _, path := range deleted {\\n   246→\\t\\t\\tdelete(mergedEntries, path)\\n   247→\\t\\t}\\n   248→\\n   249→\\t\\tmergedTreeHash, err := checkpoint.BuildTreeFromEntries(repo, mergedEntries)\\n   250→\\t\\tif err != nil {\\n   251→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to build merged tree: %w\\\", err)\\n   252→\\t\\t}\\n   253→\\n   254→\\t\\t// Create new commit on top of