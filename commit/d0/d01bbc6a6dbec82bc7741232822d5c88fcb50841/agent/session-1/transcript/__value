`. This is important because the test environment (and potentially some IDE environments) may not have a git repo root accessible via `paths.WorktreeRoot`.\\n`─────────────────────────────────────────────────`\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":1422,\"cache_read_input_tokens\":96314,\"output_tokens\":453,\"server_tool_use\":{\"web_search_requests\":0,\"web_fetch_requests\":0},\"service_tier\":\"standard\",\"cache_creation\":{\"ephemeral_1h_input_tokens\":1422,\"ephemeral_5m_input_tokens\":0},\"inference_geo\":\"\",\"iterations\":[],\"speed\":\"standard\"}},\"requestId\":\"req_011CYgvhG5sUg5qaCaiVRH6J\",\"type\":\"assistant\",\"uuid\":\"faa3a7f4-c79c-46b6-9530-952f67e24aa5\",\"timestamp\":\"2026-03-03T22:21:43.206Z\"}\n{\"parentUuid\":\"faa3a7f4-c79c-46b6-9530-952f67e24aa5\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"dd8cfcbd-53fb-4928-8e07-6bb439bff5eb\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"joyful-zooming-firefly\",\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"Stop\",\"hookName\":\"Stop\",\"command\":\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code stop\"},\"parentToolUseID\":\"6ebc4e53-5842-48a1-ab93-24ebb66693f9\",\"toolUseID\":\"6ebc4e53-5842-48a1-ab93-24ebb66693f9\",\"timestamp\":\"2026-03-03T22:21:43.231Z\",\"uuid\":\"3fd18f66-04be-4927-b198-129f821c3304\"}\n{\"parentUuid\":\"3fd18f66-04be-4927-b198-129f821c3304\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"dd8cfcbd-53fb-4928-8e07-6bb439bff5eb\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"joyful-zooming-firefly\",\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"Stop\",\"hookName\":\"Stop\",\"command\":\"${CLAUDE_PLUGIN_ROOT}/hooks/stop-hook.sh\"},\"parent