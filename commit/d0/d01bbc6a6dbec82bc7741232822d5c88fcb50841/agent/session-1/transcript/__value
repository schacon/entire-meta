x\\n    89→\\t}\\n    90→\\n    91→\\tfile := kiroAgentFile{\\n    92→\\t\\tName: \\\"entire\\\",\\n    93→\\t\\t// Include all default Kiro tools so the agent profile doesn't restrict them.\\n    94→\\t\\tTools: []string{\\n    95→\\t\\t\\t\\\"read\\\", \\\"write\\\", \\\"shell\\\", \\\"grep\\\", \\\"glob\\\",\\n    96→\\t\\t\\t\\\"aws\\\", \\\"report\\\", \\\"introspect\\\", \\\"knowledge\\\",\\n    97→\\t\\t\\t\\\"thinking\\\", \\\"todo\\\", \\\"delegate\\\",\\n    98→\\t\\t},\\n    99→\\t\\tHooks: kiroHooks{\\n   100→\\t\\t\\tAgentSpawn:       []kiroHookEntry{{Command: cmdPrefix + HookNameAgentSpawn}},\\n   101→\\t\\t\\tUserPromptSubmit: []kiroHookEntry{{Command: cmdPrefix + HookNameUserPromptSubmit}},\\n   102→\\t\\t\\tPreToolUse:       []kiroHookEntry{{Command: cmdPrefix + HookNamePreToolUse}},\\n   103→\\t\\t\\tPostToolUse:      []kiroHookEntry{{Command: cmdPrefix + HookNamePostToolUse}},\\n   104→\\t\\t\\tStop:             []kiroHookEntry{{Command: cmdPrefix + HookNameStop}},\\n   105→\\t\\t},\\n   106→\\t}\\n   107→\\n   108→\\tif err := os.MkdirAll(filepath.Dir(hooksPath), 0o750); err != nil {\\n   109→\\t\\treturn 0, fmt.Errorf(\\\"failed to create .kiro/agents directory: %w\\\", err)\\n   110→\\t}\\n   111→\\n   112→\\toutput, err := jsonutil.MarshalIndentWithNewline(file, \\\"\\\", \\\"  \\\")\\n   113→\\tif err != nil {\\n   114→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal hooks config: %w\\\", err)\\n   115→\\t}\\n   116→\\n   117→\\tif err := os.WriteFile(hooksPath, output, 0o600); err != nil {\\n   118→\\t\\treturn 0, fmt.Errorf(\\\"failed to write hooks config: %w\\\", err)\\n   119→\\t}\\n   120→\\n   121→\\t// Install IDE hooks (.kiro/hooks/*.kiro.hook)\\n   122→\\tideCount, err := installIDEHooks(worktreeRoot, cmdPrefix)\\n   123→\\tif err != nil {\\n   124→\\t\\treturn 0, fmt.Errorf(\\\"failed to install IDE hooks: %w\\\", err)\\n   125→\\t}\\n   126→\\n   127→\\treturn len(k.HookNames()) + ideCount, nil\\n   128→}\\n   129→\\n   130→// Uni