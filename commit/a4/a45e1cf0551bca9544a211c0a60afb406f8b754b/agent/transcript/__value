and, _ []string) error {\\n    38→\\t\\t\\treturn runTrailShow(cmd.OutOrStdout())\\n    39→\\t\\t},\\n    40→\\t}\\n    41→\\n    42→\\tcmd.AddCommand(newTrailListCmd())\\n    43→\\tcmd.AddCommand(newTrailCreateCmd())\\n    44→\\tcmd.AddCommand(newTrailUpdateCmd())\\n    45→\\n    46→\\treturn cmd\\n    47→}\\n    48→\\n    49→// runTrailShow shows the trail for the current branch, or falls through to list.\\n    50→func runTrailShow(w io.Writer) error {\\n    51→\\tbranch, err := GetCurrentBranch(context.Background())\\n    52→\\tif err != nil {\\n    53→\\t\\treturn runTrailListAll(w, \\\"\\\", false, false)\\n    54→\\t}\\n    55→\\n    56→\\trepo, err := strategy.OpenRepository(context.Background())\\n    57→\\tif err != nil {\\n    58→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n    59→\\t}\\n    60→\\n    61→\\tstore := trail.NewStore(repo)\\n    62→\\tmetadata, err := store.FindByBranch(branch)\\n    63→\\tif err != nil || metadata == nil {\\n    64→\\t\\treturn runTrailListAll(w, \\\"\\\", false, false)\\n    65→\\t}\\n    66→\\n    67→\\tprintTrailDetails(w, metadata)\\n    68→\\treturn nil\\n    69→}\\n    70→\\n    71→func printTrailDetails(w io.Writer, m *trail.Metadata) {\\n    72→\\tfmt.Fprintf(w, \\\"Trail: %s\\\\n\\\", m.Title)\\n    73→\\tfmt.Fprintf(w, \\\"  ID:      %s\\\\n\\\", m.TrailID)\\n    74→\\tfmt.Fprintf(w, \\\"  Branch:  %s\\\\n\\\", m.Branch)\\n    75→\\tfmt.Fprintf(w, \\\"  Base:    %s\\\\n\\\", m.Base)\\n    76→\\tfmt.Fprintf(w, \\\"  Status:  %s\\\\n\\\", m.Status)\\n    77→\\tfmt.Fprintf(w, \\\"  Author:  %s\\\\n\\\", m.Author)\\n    78→\\tif m.Body != \\\"\\\" {\\n    79→\\t\\tfmt.Fprintf(w, \\\"  Body:    %s\\\\n\\\", m.Body)\\n    80→\\t}\\n    81→\\tif len(m.Labels) > 0 {\\n    82→\\t\\tfmt.Fprintf(w, \\\"  Labels:  %s\\\\n\\\", strings.Join(m.Labels, \\\", \\\"))\\n    83→\\t}\\n    84→\\tif len(m.Assignees) > 0 {\\n    85→\\t\\tfmt.Fprintf(w, \\\"  Assignees: %s\\\\n\\\", strings.Join(m.Assignees, \\\", \\\"))\\n    86→\\t}\\n    87→\\tfmt.Fprintf(w, \\\"  Created: %s\\\\n\\\", m.CreatedAt.Format(time.RFC3339))\\n    88→\\tfmt.Fprintf(w, \\\"  Updated: %s\\\\n\\\", m.UpdatedAt.Format(time.RFC3339))\\n    89→}\\n    90→\\n    91→func newTrailListCmd() *cobra.Command {\\n    92→\\tvar statusFilter string\\n    93→\\tvar jsonOutput bool\\n    94→\\tvar showAll bool\\n    95→\\n    96→\\tcmd := &cobra.Command{\\n    97→\\t\\tUse:   \\\"list\\\",\\n    98→\\t\\tShort: \\\"List all trails\\\",\\n    99→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   100→\\t\\t\\treturn runTrailListAll(cmd.OutOrStdout(), statusFilter, jsonOutput, showAll)\\n   101→\\t\\t},\\n   102→\\t}\\n   103→\\n   104→\\tcmd.Flags().StringVar(&statusFilter, \\\"status\\\", \\\"\\\", \\\"Filter by status (draft, open, in_progress, in_review, merged, closed)\\\")\\n   105→\\tcmd.Flags().BoolVar(&jsonOutput, \\\"json\\\", false, \\\"Output as JSON\\\")\\n   106→\\tcmd.Flags().BoolVarP(&showAll, \\\"all\\\", \\\"a\\\", false, \\\"Include merged and closed trails\\\")\\n   107→\\n   108→\\treturn cmd\\n   109→}\\n   110→\\n   111→func runTrailListAll(w io.Writer, statusFilter string, jsonOutput, showAll bool) error {\\n   112→\\t// Fetch remote trails branch so we see trails from collaborators\\n   113→\\tfetchTrailsBranch()\\n   114→\\n   115→\\trepo, err := strategy.OpenRepository(context.Background())\\n   116→\\tif err != nil {\\n   117→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   118→\\t}\\n   119→\\n   120→\\tstore := trail.NewStore(repo)\\n   121→\\ttrails, err := store.List()\\n   122→\\tif err != nil {\\n   123→\\t\\treturn fmt.Errorf(\\\"failed to list trails: %w\\\", err)\\n   124→\\t}\\n   125→\\n   126→\\tif trails == nil {\\n   127→\\t\\ttrails = []*trail.Metadata{}\\n   128→\\t}\\n   129→\\n   130→\\ttotalCount := len(trails)\\n   131→\\n   132→\\t// Apply status filter\\n   133→\\tif statusFilter != \\\"\\\" {\\n   134→\\t\\tstatus := trail.Status(statusFilter)\\n   135→\\t\\tif !status.IsValid() {\\n   136→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusFilter, formatValidStatuses())\\n   137→\\t\\t}\\n   138→\\t\\tvar filtered []*trail.Metadata\\n   139→\\t\\tfor _, t := range trails {\\n   140→\\t\\t\\tif t.Status == status {\\n   141→\\t\\t\\t\\tfiltered = append(filtered, t)\\n   142→\\t\\t\\t}\\n   143→\\t\\t}\\n   144→\\t\\ttrails = filtered\\n   145→\\t} else if !showAll {\\n   146→\\t\\t// By default, hide merged and closed trails\\n   147→\\t\\tvar filtered []*trail.Metadata\\n   148→\\t\\tfor _, t := range trails {\\n   149→\\t\\t\\tif t.Status != trail.StatusMerged && t.Status != trail.StatusClosed {\\n   150→\\t\\t\\t\\tfiltered = append(filtered, t)\\n   151→\\t\\t\\t}\\n   152→\\t\\t}\\n   153→\\t\\ttrails = filtered\\n   154→\\t}\\n   155→\\n   156→\\t// Sort by updated_at descending\\n   157→\\tsort.Slice(trails, func(i, j int) bool {\\n   158→\\t\\treturn trails[i].UpdatedAt.After(trails[j].UpdatedAt)\\n   159→\\t})\\n   160→\\n   161→\\tif jsonOutput {\\n   162→\\t\\tenc := json.NewEncoder(w)\\n   163→\\t\\tenc.SetIndent(\\\"\\\", \\\"  \\\")\\n   164→\\t\\tif err := enc.Encode(trails); err != nil {\\n   165→\\t\\t\\treturn fmt.Errorf(\\\"failed to encode JSON: %w\\\", err)\\n   166→\\t\\t}\\n   167→\\t\\treturn nil\\n   168→\\t}\\n   169→\\n   170→\\tif len(trails) == 0 {\\n   171→\\t\\thiddenCount := totalCount - len(trails)\\n   172→\\t\\tif hiddenCount > 0 {\\n   173→\\t\\t\\tfmt.Fprintf(w, \\\"No active trails found. %d merged/closed trail(s) hidden — use --all to show.\\\\n\\\", hiddenCount)\\n   174→\\t\\t} else {\\n   175→\\t\\t\\tfmt.Fprintln(w, \\\"No trails found.\\\")\\n   176→\\t\\t\\tfmt.Fprintln(w)\\n   177→\\t\\t\\tfmt.Fprintln(w, \\\"Commands:\\\")\\n   178→\\t\\t\\tfmt.Fprintln(w, \\\"  entire trail create   Create a trail for the current branch\\\")\\n   179→\\t\\t\\tfmt.Fprintln(w, \\\"  entire trail list     List all trails\\\")\\n   180→\\t\\t\\tfmt.Fprintln(w, \\\"  entire trail update   Update trail metadata\\\")\\n   181→\\t\\t}\\n   182→\\t\\treturn nil\\n   183→\\t}\\n   184→\\n   185→\\t// Table output\\n   186→\\tfmt.Fprintf(w, \\\"%-30s %-40s %-13s %-15s %s\\\\n\\\", \\\"BRANCH\\\", \\\"TITLE\\\", \\\"STATUS\\\", \\\"AUTHOR\\\", \\\"UPDATED\\\")\\n   187→\\tfor _, t := range trails {\\n   188→\\t\\tbranch := stringutil.TruncateRunes(t.Branch, 30, \\\"...\\\")\\n   189→\\t\\ttitle := stringutil.TruncateRunes(t.Title, 40, \\\"...\\\")\\n   190→\\t\\tfmt.Fprintf(w, \\\"%-30s %-40s %-13s %-15s %s\\\\n\\\",\\n   191→\\t\\t\\tbranch, title, t.Status, stringutil.TruncateRunes(t.Author, 15, \\\"...\\\"), timeAgo(t.UpdatedAt))\\n   192→\\t}\\n   193→\\n   194→\\treturn nil\\n   195→}\\n   196→\\n   197→func newTrailCreateCmd() *cobra.Command {\\n   198→\\tvar title, body, base, branch, status string\\n   199→\\tvar checkout bool\\n   200→\\n   201→\\tcmd := &cobra.Command{\\n   202→\\t\\tUse:   \\\"create\\\",\\n   203→\\t\\tShort: \\\"Create a trail for the current or a new branch\\\",\\n   204→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   205→\\t\\t\\treturn runTrailCreate(cmd, title, body, base, branch, status, checkout)\\n   206→\\t\\t},\\n   207→\\t}\\n   208→\\n   209→\\tcmd.Flags().StringVar(&title, \\\"title\\\", \\\"\\\", \\\"Trail title\\\")\\n   210→\\tcmd.Flags().StringVar(&body, \\\"body\\\", \\\"\\\", \\\"Trail body\\\")\\n   211→\\tcmd.Flags().StringVar(&base, \\\"base\\\", \\\"\\\", \\\"Base branch (defaults to detected default branch)\\\")\\n   212→\\tcmd.Flags().StringVar(&branch, \\\"branch\\\", \\\"\\\", \\\"Branch for the trail (defaults to current branch)\\\")\\n   213→\\tcmd.Flags().StringVar(&status, \\\"status\\\", \\\"\\\", \\\"Initial status (defaults to draft)\\\")\\n   214→\\tcmd.Flags().BoolVar(&checkout, \\\"checkout\\\", false, \\\"Check out the branch after creating it\\\")\\n   215→\\n   216→\\treturn cmd\\n   217→}\\n   218→\\n   219→//nolint:cycl