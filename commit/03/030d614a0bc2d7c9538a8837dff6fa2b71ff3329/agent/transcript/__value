 134→\\t\\t\\treturn errors.New(\\\"non-fast-forward\\\")\\n   135→\\t\\t}\\n   136→\\t\\treturn fmt.Errorf(\\\"push failed: %s\\\", output)\\n   137→\\t}\\n   138→\\treturn nil\\n   139→}\\n   140→\\n   141→// fetchAndMergeSessionsCommon fetches remote sessions and merges into local using go-git.\\n   142→// Since session logs are append-only (unique cond-* directories), we just combine trees.\\n   143→// The target can be a remote name or a URL.\\n   144→func fetchAndMergeSessionsCommon(ctx context.Context, target, branchName string) error {\\n   145→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   146→\\tdefer cancel()\\n   147→\\n   148→\\t// Determine fetch refspec. When target is a URL, use a temp ref;\\n   149→\\t// when it's a remote name, use the standard remote-tracking ref.\\n   150→\\tvar fetchedRefName plumbing.ReferenceName\\n   151→\\tvar refSpec string\\n   152→\\tif isURL(target) {\\n   153→\\t\\ttmpRef := \\\"refs/entire-fetch-tmp/\\\" + branchName\\n   154→\\t\\trefSpec = fmt.Sprintf(\\\"+refs/heads/%s:%s\\\", branchName, tmpRef)\\n   155→\\t\\tfetchedRefName = plumbing.ReferenceName(tmpRef)\\n   156→\\t} else {\\n   157→\\t\\trefSpec = fmt.Sprintf(\\\"+refs/heads/%s:refs/remotes/%s/%s\\\", branchName, target, branchName)\\n   158→\\t\\tfetchedRefName = plumbing.NewRemoteReferenceName(target, branchName)\\n   159→\\t}\\n   160→\\n   161→\\t// Use git CLI for fetch (go-git's fetch can be tricky with auth)\\n   162→\\tfetchCmd := exec.CommandContext(ctx, \\\"git\\\", \\\"fetch\\\", target, refSpec)\\n   163→\\tfetchCmd.Stdin = nil\\n   164→\\tif output, err := fetchCmd.CombinedOutput(); err != nil {\\n   165→\\t\\treturn fmt.Errorf(\\\"fetch failed: %s\\\", output)\\n   166→\\t}\\n   167→\\n   168→\\trepo, err := OpenRepository(ctx)\\n   169→\\tif err != nil {\\n   170→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   171→\\t}\\n   172→\\n   173→\\t// Reconcile disconnected metadata branches before merging tr