    if found, searchErr := searchTranscriptInProjectDirs(agentName, sessionID, ag); searchErr == nil {\\n                 logging.Info(logCtx, \\\"found transcript in alternative project directory\\\", \\\"path\\\", found)\\n                 transcriptPath = found\\n             } else {\\n                 logging.Debug(logCtx, \\\"fallback transcript search failed\\\", \\\"error\\\", searchErr)\\n             }\\n         }\\n         // Single-line error (no embedded newline)\\n         if _, statErr := os.Stat(transcriptPath); statErr != nil {\\n             return fmt.Errorf(\\\"transcript not found at %s; is the session ID correct?\\\", transcriptPath)\\n         }\\n         // EnsureSetup is now a hard error\\n         if err := strategy.EnsureSetup(ctx); err != nil {\\n             return fmt.Errorf(\\\"failed to set up strategy: %w\\\", err)\\n         }\\n         // AbsPath is now a hard error\\n         sessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n         if err != nil {\\n             return fmt.Errorf(\\\"failed to resolve session directory path: %w\\\", err)\\n         }\\n         // Nil state after init is an error\\n         if state == nil {\\n             return fmt.Errorf(\\\"session state not found after initialization (session_id=%s)\\\", sessionID)\\n         }\\n         // condenseAndFinalizeSession now returns error\\n         checkpointIDStr, condenseErr := condenseAndFinalizeSession(logCtx, strat, sessionID)\\n         if condenseErr != nil {\\n             fmt.Fprintln(w, \\\"  Warning: checkpoint saved on shadow branch only (condensation failed)\\\")\\n         }\\n     }\\n     \\n     // Single LoadSessionState, returns condensation error\\n     func condenseAndFinalizeSession(ctx context.Context, strat *strategy.ManualCommitStrategy, sessionID string) (string, error) {\\n         var checkpointIDStr string\\n         var condenseErr error\\n         if err := strat.CondenseSessionByID(ctx, sessionID); err != nil {\\n             logging.Warn(ctx, \\\"failed to condense session\\\", \\\"error\\\", err, \\\"session_id\\\", sessionID)\\n             condenseErr = err\\n         }\\n         state, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n         if loadErr != nil {\\n             logging.Warn(ctx, \\\"failed to load session state after condensation\\\", \\\"error\\\", loadErr, \\\"session_id\\\", sessionID)\\n             return checkpointIDStr, condenseErr\\n         }\\n         if state == nil {\\n             return checkpointIDStr, condenseErr\\n         }\\n         if condenseErr == nil {\\n             checkpointIDStr = state.LastCheckpointID.String()\\n         }\\n         // ... transition and save with error values in all logging.Warn calls\\n         return checkpointIDStr, condenseErr\\n     }\\n     ```\\n   \\n   - **`cmd/entire/cli/transcript.go`** (transcript resolution helpers - extensively modified)\\n     - Contains the fallback search logic for finding transcripts across project directories\\n     - Generalized from Claude-only to support multiple agents via `agentSessionBaseDirs` map\\n     ```go\\n     var agentSessionBaseDirs = map[types.AgentName]func() (string, error){\\n         agentpkg.AgentNameClaudeCode: func() (string, error) {\\n             home, err := os.UserHomeDir()\\n             if err != nil {\\n                 return \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n             }\\n             return filepath.Join(home, \\\".claude\\\", \\\"projects\\\"), nil\\n         },\\n         agentpkg.AgentNameGemini: func() (string, error) {\\n             home, err := os.UserHomeDir()\\n             if err != nil {\\n                 return \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n             }\\n             return filepath.Join(home, \\\".gemini\\\", \\\"tmp\\\"), nil\\n         },\\n     }\\n     \\n     func searchTranscriptInProjectDirs(agentName types.AgentName, sessionID strin