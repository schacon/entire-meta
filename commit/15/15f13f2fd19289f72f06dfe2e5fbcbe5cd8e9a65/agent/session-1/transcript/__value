po_not_found\\\" };\\n    64→  }\\n    65→\\n    66→  // Apply defaults for fields that may be null in the database\\n    67→  const repo = {\\n    68→    ...repoData,\\n    69→    default_branch: repoData.default_branch ?? \\\"main\\\",\\n    70→    app_has_access: repoData.app_has_access ?? false,\\n    71→  };\\n    72→\\n    73→  // Skip app installation check when explicitly requested (e.g., local dev \\\"Fetch from GitHub\\\" button)\\n    74→  // In local dev, webhooks don't fire so app_has_access is never set\\n    75→  if (!repo.app_has_access && !options.skipAppInstallationCheck) {\\n    76→    return { status: \\\"skipped\\\", reason: \\\"no_app_access\\\" };\\n    77→  }\\n    78→\\n    79→  // Check if CHECKPOINT_BRANCH exists (quick \\\"is this repo Entire-enabled?\\\" check)\\n    80→  const branchExists = await checkBranchExists(repo.full_name, CHECKPOINT_BRANCH, token);\\n    81→  if (branchExists === null) {\\n    82→    return { status: \\\"skipped\\\", reason: \\\"branch_check_error\\\" };\\n    83→  }\\n    84→  if (branchExists === false) {\\n    85→    await db.checkpoints.updateSyncState(repoId, {});\\n    86→    return { status: \\\"skipped\\\", reason: \\\"no_sessions_branch\\\" };\\n    87→  }\\n    88→\\n    89→  const isBackfill = !repo.checkpoints_backfilled_at || options.fullBackfill;\\n    90→  const since = isBackfill ? undefined : (repo.checkpoints_sync_cursor ?? undefined);\\n    91→\\n    92→  log(\\\"sync_started\\\", {\\n    93→    repoId,\\n    94→    fullName: repo.full_name,\\n    95→    isBackfill,\\n    96→    since,\\n    97→  });\\n    98→\\n    99→  try {\\n   100→    // Step 1: Discover checkpoints from default branch via Entire-Checkpoint trailers\\n   101→    const discovered = await discoverCheckpointsFromBranch(\\n   102→      repo.full_name,\\n   103→      repo.default_branch,\\n   104→      token,\\n   105→      since\\n   106→    );\\n   107→\\n   108→    // Track which branch each checkpoint was discovered on (for commit data)\\n   109→    const discoveredBranch = new Map<string, string>();\\n   110→    for (const d of discovered) {\\n   111→      discoveredBranch.set(d.checkpointId, repo.default_branch);\\n   112→    }\\n   113→\\n   114→    // Also scan extra branches (e.g., local dev where webhooks don't fire)\\n   115→    // No `since` filter — cursor is from the default branch and doesn't apply here\\n   116→    const extraBranches = (options.extraBranches ?? []).filter(\\n   117→      (b) => b !== repo.default_branch\\n   118→    );\\n   119→    for (const branch of extraBranches) {\\n   120→      const branchDiscovered = await discoverCheckpointsFromBranch(\\n   121→        repo.full_name,\\n   122→        branch,\\n   123→        token\\n   124→      );\\n   125→      log(\\\"extra_branch_scan\\\", {\\n   126→        repoId,\\n   127→        branch,\\n   128→        found: branchDiscovered.length,\\n   129→        alreadyKnown: branchDiscovered.filter((d) => discoveredBranch.has(d.checkpointId)).length,\\n   130→      });\\n   131→      for (const d of branchDiscovered) {\\n   132→        if (!discoveredBranch.has(d.checkpointId)) {\\n   133→          discovered.push(d);\\n   134→          discoveredBranch.set(d.checkpointId, branch);\\n   135→        }\\n   136→      }\\n   137→    }\\n   138→\\n   139→    if (discovered.length === 0) {\\n   140→      await db.checkpoints.updateSyncState(repoId, {});\\n   141→      if (isBackfill) {\\n   142→        await db.checkpoints.updateSyncState(repoId, { backfilled: true });\\n   143→      }\\n   144→      log(\\\"sync_complete_no_checkpoints\\\", { repoId, fullName: repo.full_name });\\n   145→      return { status: \\\"ok\\\", checkpointsDiscovered: 0, isBackfill };\\n   146→    }\\n   147→\\n   148→    const checkpointIds = discovered.map((d) => d.checkpointId);\\n   149→    // Cursor: latest commit date from the default branch only\\n   150→    // Extra branches may have different dates that shouldn't affect the default branch cursor\\n   151→    const defaultBranchDiscovered = discovered.filter(\\n   152→      (d) => discoveredBranch.get(d.checkpointId) === repo.default_branch\\n   153→    );\\n   154→    const latestCursor = defaultBranchDiscovered[0]?.commit.date;\\n   155→\\n   156→    log(\\\"checkpoints_discovered\\\", {\\n   157→      repoId,\\n   158→      fullName: repo.full_name,\\n   159→      count: checkpointIds.length,\\n   160→    });\\n   161→\\n   162→    // Step 2: Fetch session metadata from CHECKPOINT_BRANCH tree\\n   163→    const sessionDataResult = await fetchSessionDataBatch(repo.full_name, checkpointIds, token);\\n   164→\\n   165→    if (sessionDataResult.failedItems.length > 0) {\\n   166→      log(\\\"session_data_partial_failure\\\", {\\n   167→        repoId,\\n   168→        failed: sessionDataResult.failedItems.length,\\n   169→      });\\n   170→    }\\n   171→\\n   172→    // Step 3: Upsert checkpoint metadata (before commits due to FK constraint)\\n   173→    const checkpointData: CheckpointData[] = checkpointIds.map((cpId) => {\\n   174→      const session = sessionDataResult.data.get(cpId);\\n   175→      return {\\n   176→        checkpoint_id: cpId,\\n   177→        prompt: session?.prompt ?? null,\\n   178→        agent: session?.agent ?? null,\\n   179→        steps: session?.steps ?? null,\\n   180→        session_count: session?.sessionCount ?? null,\\n   181→        strategy: session?.strategy ?? null,\\n   182→        branch: session?.branch ?? null,\\n   183→        session_id: session?.sessionId ?? null,\\n   184→        files_touched: session?.filesTouched ? JSON.stringify(session.filesTouched) : null,\\n   185→        session_ids: session?.sessionIds ? JSON.stringify(session.sessionIds) : null,\\n   186→        transcript_uuid_at_start: session?.transcriptUuidAtStart ?? null,\\n   187→        transcript_lines_at_start: session?.transcriptLinesAtStart ?? null,\\n   188→        checkpoint_transcript_start: session?.checkpointTranscriptStart ?? null,\\n   189→        input_tokens: session?.inputTokens ?? null,\\n   190→        cache_creation_tokens: session?.cacheCreationTokens ?? null,\\n   191→        cache_read_tokens: session?.cacheReadTokens ?? null,\\n   192→        output_tokens: session?.outputTokens ?? null,\\n   193→        api_call_count: session?.apiCallCount ?? null,\\n   194→        sessions: session?.sessions ? JSON.stringify(session.sessions) : null,\\n   195→        created_at: session?.createdAt ?? new Date().toISOString(),\\n   196→      };\\n   197→    });\\n   198→\\n   199→    await db.checkpoints.upsertSyncCheckpointBatch(repoId, checkpointData);\\n   200→\\n   201→    // Step 4: Upsert commit data (commit info already available from discovery)\\n   202→    // For non-backfill, skip checkpoints that already have commits on their respective branch\\n   203→    let discoveredToProcess = discovered;\\n   204→\\n   205→    if (!isBackfill) {\\n   206→      // Group checkpoints by branch to check per-branch commit existence\\n   207→      const checkpointsByBranch = new Map<string, string[]>();\\n   208→      for (const d of discovered) {\\n   209→        const branch = discoveredBranch.get(d.checkpointId) ?? repo.default_branch;\\n   210→        const existing = checkpointsByBranch.get(branch) ?? [];\\n   211→        existing.push(d.checkpointId);\\n   212→        checkpointsByBranch.set(branch, existing);\\n   213→      }\\n   214→\\n   215→      // Check which checkpoints already have commits on their respective branch\\n   216→      const existingWithCommitsOnBranch = new Set<string>();\\n   217→      for (const [branch, cpIds] of checkpointsByBranch) {\\n   218→        const existingOnBranch = await db.checkpoints.getIdsWithCommits(repoId, cpIds, branch);\\n   219→        for (const cpId of existingOnBranch) {\\n   220→          existingWithCommitsOnBranch.add(cpId);\\n   221→        }\\n   222→      }\\n   223→\\n   224→      if (existingWithCommitsOnBranch.size > 0) {\\n   225→        discoveredToProcess = discovered.filter(\\n   226→          (d) => !existingWithCommitsOnBranch.has(d.checkpointId)\\n   227→        );\\n   228→\\n   229→        log(\\\"reconciliation_optimization\\\", {\\n   230→          repoId,\\n   231→          totalCheckpoints: checkpointIds.length,\\n   232→          alreadyHaveCommits: existingWithCommitsOnBranch.size,\\n   233→          needToProcess: discoveredToProcess.length,\\n   234→        });\\n   235→      }\\n   236→    }\\n   237→\\n   238→    let commitsFound = 0;\\n   239→\\n   240→    if (discoveredToProcess.length > 0) {\\n   241→      // Fetch commit stats for new checkpoints\\n   242→      const shas = discoveredToProcess.map((d) => d.commit.sha);\\n   243→      const statsResult = await fetchCommitStatsBatch(repo.full_name, shas, token);\\n   244→\\n   245→      // Parse squash commit titles for each unique commit message\\n   246→      const squashTitlesByMessage = new Map<string, Map<string, string>>();\\n   247→      for (const d of discoveredToProcess) {\\n   248→        if (!squashTitlesByMessage.has(d.commit.message)) {\\n   249→          squashTitlesByMessage.set(d.commit.message, parseSquashCommitTitles(d.commit.message));\\n   250→        }\\n   251→      }\\n   252→\\n   253→      const commitData: CommitData[] = discoveredToProcess.map((d) => {\\n   254→        const stats = statsResult.data.get(d.commit.sha);\\n   255→        const squashTitles = squashTitlesByMessage.get(d.commit.message);\\n   256→        const commitTitle = squashTitles?.get(d.checkpointId) ?? d.commit.message.split(\\\"\\\\n\\\")[0];\\n   257→        return {\\n   258→          checkpoint_id: d.checkpointId,\\n   259→          branch: discoveredBranch.get(d.checkpointId) ?? repo.default_branch,\\n   260→          commit_sha: d.commit.sha,\\n   261→          commit_message: commitTitle,\\n   262→          commit_author: d.commit.author,\\n   263→          commit_author_username: d.commit.authorUsername ?? null,\\n   264→          commit_author_github_id: d.commit.authorId ?? null,\\n   265→          commit_date: d.commit.date,\\n   266→          additions: stats?.additions ?? 0,\\n   267→          deletions: stats?.deletions ?? 0,\\n   268→          files_changed: stats?.filesChanged ?? 0,\\n   269→          file_stats: stats?.files ?? null,\\n   270→        };\\n   271→      });\\n   272→\\n   273→      commitsFound = await db.checkpoints.upsertSyncCommitBatch(repoId, commitData);\\n   274→\\n   275→      log(\\\"commits_processed\\\", {\\n   276→        repoId,\\n   277→        branch: repo.default_branch,\\n   278→        commitsFound,\\n   279→      });\\n   280→    }\\n   281→\\n   282→    // Step 5: Reconcile stale checkpoint commits (backfill only)\\n   283→    // During a full backfill we have the complete picture of what's on each branch,\\n   284→    // so we can safely remove checkpoint commits that are no longer reachable\\n   285→    // (e.g., after force pushes that rewrote history).\\n   286→    let staleDeleted = 0;\\n   287→    if (isBackfill) {\\n   288→      // Group discovered checkpoint IDs by branch\\n   289→      const validByBranch = new Map<string, string[]>();\\n   290→      for (const d of discovered) {\\n   291→        const branch = discoveredBranch.get(d.checkpointId) ?? repo.default_branch;\\n   292→        const existing = validByBranch.get(branch) ?? [];\\n   293→        existing.push(d.checkpointId);\\n   294→        validByBranch.set(branch, existing);\\n   295→      }\\n   296→\\n   297→      // Reconcile each branch we scanned\\n   298→      const branchesToReconcile = new Set([repo.default_branch, ...extraBranches]);\\n   299→      for (const branch of branchesToReconcile) {\\n   300→        const validIds = validByBranch.get(branch) ?? [];\\n   301→        const deleted = await db.checkpoints.deleteStaleCommitsForBranch(repoId, branch, validIds);\\n   302→        staleDeleted += deleted;\\n   303→      }\\n   304→\\n   305→      if (staleDeleted > 0) {\\n   306→        await db.checkpoints.deleteOrphaned(repoId);\\n   307→        log(\\\"stale_commits_reconciled\\\", { repoId, staleDeleted });\\n   308→      }\\n   309→    }\\n   310→\\n   311→    // Step 6: Update sync state\\n   312→    await db.checkpoints.updateSyncState(repoId, {\\n   313→      cursor: latestCursor,\\n   314→      backfilled: isBackfill,\\n   315→    });\\n   316→\\n   317→    // Step 6: Recalculate checkpoint count\\n   318→    await db.checkpoints.recalculateCount(repoId);\\n   319→\\n   320→    const totalSessions = checkpointData.reduce((sum, cp) => sum + (cp.session_count ?? 0), 0);\\n   321→    const checkpointsWithSessions = checkpointData.filter((cp) => cp.sessions != null).length;\\n   322→\\n   323→    log(\\\"sync_complete\\\", {\\n   324→      repoId,\\n   325→      fullName: repo.full_name,\\n   326→      checkpointsDiscovered: checkpointIds.length,\\n   327→      checkpointsWithCommits: commitsFound,\\n   328→      totalSessions,\\n   329→      checkpointsWithSessions,\\n   330→      isBackfill,\\n   331→    });\\n   332→\\n   333→    return {\\n   334→      status: \\\"ok\\\",\\n   335→      checkpointsDiscovered: checkpointIds.length,\\n   336→      checkpointsWithCommits: commitsFound,\\n   337→      isBackfill,\\n   338→      discoveredCheckpointIds: checkpointIds,\\n   339→    };\\n   340→  } catch (err) {\\n   341→    if (err instanceof GitHubRateLimitError) {\\n   342→      throw err;\\n   343→    }\\n   344→\\n   345→    const errorMessage = errorString(err);\\n   346→    await db.checkpoints.updateSyncState(repoId, { error: errorMessage });\\n   347→\\n   348→    log(\\\"sync_error\\\", {\\n   349→      repoId,\\n   350→      fullName: repo.full_name,\\n   351→      error: errorMessage,\\n   352→    });\\n   353→\\n   354→    return { status: \\\"error\\\", reason: errorMessage };\\n   355→  }\\n   356→}\\n   357→\\n   358→// Cloudflare Queue sendBatch limits\\n   359→const QUEUE_BATCH_MAX_MESSAGES = 100;\\n   360→\\n   361→// Queue multiple repos for checkpoint sync using sendBatch\\n   362→// Respects Cloudflare Queue limits: max 100 messages per batch\\n   363→export async function queueRepoSyncBatch(\\n   364→  queue: Queue<RepoSyncMessage>,\\n   365→  repos: { id: string }[],\\n   366→  reason: RepoSyncMessage[\\\"reason\\\"],\\n   367→  priority: number = 5\\n   368→): Promise<number> {\\n   369→  if (repos.length === 0) return 0;\\n   370→\\n   371→  const queuedAt = new Date().toISOString();\\n   372→  let totalQueued = 0;\\n   373→\\n   374→  // Process in batches of 100 (Cloudflare Queue limit)\\n   375→  for (let i = 0; i < repos.length; i += QUEUE_BATCH_MAX_MESSAGES) {\\n   376→    const batch = repos.slice(i, i + QUEUE_BATCH_MAX_MESSAGES);\\n   377→    const messages = batch.map((repo) => ({\\n   378→      body: {\\n   379→        repoId: repo.id,\\n   380→        reason,\\n   381→        priority,\\n   382→        queuedAt,\\n   383→      },\\n   384→    }));\\n   385→\\n   386→    await queue.sendBatch(messages);\\n   387→    totalQueued += batch.length;\\n   388→  }\\n   389→\\n   390→  log(\\\"repos_queued_batch\\\", { count: totalQueued, reason, priority, batches: Math.ceil(repos.length / QUEUE_BATCH_MAX_MESSAGES) });\\n   391→  return totalQueued;\\n   392→}\\n   393→\\n   394→// Environment required for user-level checkpoint sync\\n   395→export interface CheckpointSyncEnv {\\n   396→  db: Db;\\n   397→  cache: KVNamespace;\\n   398→  clientId: string;\\n   399→  clientSecret: string;\\n   400→  encryptionKey: string;\\n   401→}\\n   402→\\n   403→// Result of syncing checkpoints for a user\\n   404→export interface UserCheckpointSyncResult {\\n   405→  reposChecked: number;\\n   406→  reposWithAccess: number;\\n   407→  reposSynced: number;\\n   408→  errors: number;\\n   409→}\\n   410→\\n   411→// Sync checkpoints for all repos a user has access to\\n   412→// This is the repo-centric replacement for the legacy syncCheckpointsForUser\\n   413→export async function syncCheckpointsForUser(\\n   414→  userId: string,\\n   415→  env: CheckpointSyncEnv\\n   416→): Promise<UserCheckpointSyncResult> {\\n   417→  const result: UserCheckpointSyncResult = {\\n   418→    reposChecked: 0,\\n   419→    reposWithAccess: 0,\\n   420→    reposSynced: 0,\\n   421→    errors: 0,\\n   422→  };\\n   423→\\n   424→  // Get user and their token\\n   425→  const user = await env.db.users.findById(userId);\\n   426→\\n   427→  if (!user || !user.github_token_enc) {\\n   428→    log(\\\"skip_no_token\\\", { userId });\\n   429→    return result;\\n   430→  }\\n   431→\\n   432→  // Get valid token\\n   433→  let token: string;\\n   434→  try {\\n   435→    const tokenResult = await getValidGitHubToken(env.db, user, {\\n   436→      clientId: env.clientId,\\n   437→      clientSecret: env.clientSecret,\\n   438→      encryptionKey: env.encryptionKey,\\n   439→    }, env.cache);\\n   440→    token = tokenResult.token;\\n   441→  } catch (err) {\\n   442→    log(\\\"token_error\\\", { userId, error: errorString(err) });\\n   443→    return result;\\n   444→  }\\n   445→\\n   446→  // Get all repos for this user from the repo-centric schema\\n   447→  const repos = await env.db.repos.getForUser(userId);\\n   448→  result.reposChecked = repos.length;\\n   449→\\n   450→  log(\\\"user_sync_started\\\", {\\n   451→    userId,\\n   452→    totalRepos: repos.length,\\n   453→  });\\n   454→\\n   455→  // Filter to repos where app has access\\n   456→  const accessibleRepos = repos.filter((r) => r.app_has_access);\\n   457→  result.reposWithAccess = accessibleRepos.length;\\n   458→\\n   459→  // Process repos in batches to avoid rate limits\\n   460→  const BATCH_SIZE = 5;\\n   461→  for (let i = 0; i < accessibleRepos.length; i += BATCH_SIZE) {\\n   462→    const batch = accessibleRepos.slice(i, i + BATCH_SIZE);\\n   463→\\n   464→    await Promise.all(\\n   465→      batch.map(async (repo) => {\\n   466→        try {\\n   467→          const syncResult = await syncRepoCheckpoints(env.db, repo.id, token);\\n   468→          if (syncResult.status === \\\"ok\\\") {\\n   469→            result.reposSynced++;\\n   470→          }\\n   471→        } catch (err) {\\n   472→          result.errors++;\\n   473→          log(\\\"repo_sync_error\\\", {\\n   474→            repoId: repo.id,\\n   475→            fullName: repo.full_name,\\n   476→            error: errorString(err),\\n   477→          });\\n   478→        }\\n   479→      })\\n   480→    );\\n   481→  }\\n   482→\\n   483→  log(\\\"user_sync_completed\\\", { userId, ...result });\\n   484→  return result;\\n   485→}\\n   486→\\n   487→// ============================================================================\\n   488→// Trail sync functions\\n   489→// ============================================================================\\n   490→\\n   491→export interface TrailSyncResult {\\n   492→  status: \\\"ok\\\" | \\\"skipped\\\" | \\\"error\\\";\\n   493→  reason?: string;\\n   494→  trailsDiscovered?: number;\\n   495→  trailsSynced?: number;\\n   496→}\\n   497→\\n   498→/**\\n   499→ * Sync trails for a repository\\n   500→ * Discovers trails from entire/trails/v1 branch and upserts to database\\n   501→ */\\n   502→export async function syncRepoTrails(\\n   503→  db: Db,\\n   504→  repoId: string,\\n   505→  repoFullName: string,\\n   506→  token: string,\\n   507→): Promise<TrailSyncResult> {\\n   508→  log(\\\"trails_sync_start\\\", { repoId, repoFullName });\\n   509→\\n   510→  // Check if trails branch exists\\n   511→  const branchExists = await checkBranchExists(repoFullName, TRAILS_BRANCH, token);\\n   512→  if (!branchExists) {\\n   513→    log(\\\"trails_sync_skip\\\", { repoId, reason: \\\"no_trails_branch\\\" });\\n   514→    return { status: \\\"skipped\\\", reason: \\\"no_trails_branch\\\" };\\n   515→  }\\n   516→\\n   517→  // Discover all trail IDs\\n   518→  const trailIds = await discoverTrailsFromBranch(repo