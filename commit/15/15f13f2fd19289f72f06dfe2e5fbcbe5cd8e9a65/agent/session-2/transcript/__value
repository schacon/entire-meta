0 disables git's own terminal prompts.\\n    66→\\t// Factory AI Droid (and other non-interactive environments like CI) set this.\\n    67→\\t// Since we run as a git hook, respect it — if the environment doesn't want\\n    68→\\t// git prompting, our hook shouldn't prompt either.\\n    69→\\tif os.Getenv(\\\"GIT_TERMINAL_PROMPT\\\") == \\\"0\\\" {\\n    70→\\t\\treturn false\\n    71→\\t}\\n    72→\\n    73→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n    74→\\tif err != nil {\\n    75→\\t\\treturn false\\n    76→\\t}\\n    77→\\t_ = tty.Close()\\n    78→\\treturn true\\n    79→}\\n    80→\\n    81→// ttyResult represents the outcome of a TTY confirmation prompt.\\n    82→type ttyResult int\\n    83→\\n    84→const (\\n    85→\\tttyResultLink       ttyResult = iota // Link: add the checkpoint trailer\\n    86→\\tttyResultSkip                        // Skip: don't add the trailer\\n    87→\\tttyResultLinkAlways                  // Link and remember: add trailer + save \\\"always\\\" preference\\n    88→)\\n    89→\\n    90→// askConfirmTTY prompts the user via /dev/tty whether to link a commit to session context.\\n    91→// This requires a controlling terminal — callers must check hasTTY() first and handle\\n    92→// the no-TTY case (agent subprocesses, CI) themselves.\\n    93→//\\n    94→// header is displayed as the first line (e.g., \\\"Entire: Active Claude Code session\\\").\\n    95→// detail lines are displayed indented below the header.\\n    96→func askConfirmTTY(header string, details []string, prompt string, defaultYes bool) ttyResult {\\n    97→\\tdefaultResult := ttyResultSkip\\n    98→\\tif defaultYes {\\n    99→\\t\\tdefaultResult = ttyResultLink\\n   100→\\t}\\n   101→\\n   102→\\t// In test mode, don't try to interact with the real TTY — just use the default.\\n   103→\\t// ENTIRE_TEST_TTY=1 simulates \\\"a human is present\\\" for the hasTTY() check\\n   104→\\t// but we can't actually read from the TTY in tests.\\n   105→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   106→\\t\\treturn defaultResult\\n   107→\\t}\\n   108→\\n   109→\\t// Open /dev/tty for both reading and writing.\\n   110→\\t// This is the controlling terminal, which works even when stdin/stderr are redirected\\n   111→\\t// (e.g., human runs git commit -m where stdin is not a pipe).\\n   112→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   113→\\tif err != nil {\\n   114→\\t\\treturn defaultResult\\n   115→\\t}\\n   116→\\tdefer tty.Close()\\n   117→\\n   118→\\t// Write to tty directly, not stderr, since git hooks may redirect stderr to /dev/null\\n   119→\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", header)\\n   120→\\tfor _, line := range details {\\n   121→\\t\\tfmt.Fprintf(tty, \\\"  %s\\\\n\\\", line)\\n   122→\\t}\\n   123→\\n   124→\\t// Show prompt with option descriptions\\n   125→\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", prompt)\\n   126→\\tif defaultYes {\\n   127→\\t\\tfmt.Fprint(tty, \\\"  [Y]es / [n]o / [a]lways (remember my choice): \\\")\\n   128→\\t} else {\\n   129→\\t\\tfmt.Fprint(tty, \\\"  [y]es / [N]o / [a]lways (remember my choice): \\\")\\n   130→\\t}\\n   131→\\n   132→\\t// Read response\\n   133→\\treader := bufio.NewReader(tty)\\n   134→\\tresponse, err := reader.ReadString('\\\\n')\\n   135→\\tif err != nil {\\n   136→\\t\\treturn defaultResult\\n   137→\\t}\\n   138→\\n   139→\\tresponse = strings.TrimSpace(strings.ToLower(response))\\n   140→\\tswitch response {\\n   141→\\tcase \\\"y\\\", \\\"yes\\\":\\n   142→\\t\\treturn ttyResultLink\\n   143→\\tcase \\\"n\\\", \\\"no\\\":\\n   144→\\t\\treturn ttyResultSkip\\n   145→\\tcase \\\"a\\\", \\\"always\\\":\\n   146→\\t\\treturn ttyResultLinkAlways\\n   147→\\tdefault:\\n   148→\\t\\t// Empty or invalid input - use default\\n   149→\\t\\treturn defaultResult\\n   150→\\t}\\n   151→}\\n   152→\\n   153→// saveCommitLinkingAlways persists commit_linking = \\\"always\\\" to settings.local.json.\\n   154→// Uses raw JSON merge to set only the commit_linking field without affecting other\\n   155→// fields. This avoids writing unintended defaults (e.g., enabled: true) when the\\n   156→// local settings file doesn't exist yet.\\n   157→func saveCommitLinkingAlways(ctx context.Context) error {\\n   158→\\tlocalPath, err := paths.AbsPath(ctx, settings.EntireSettingsLocalFile)\\n   159→\\tif err != nil {\\n   160→\\t\\treturn fmt.Errorf(\\\"resolving local settings path: %w\\\", err)\\n   161→\\t}\\n   162→\\n   163→\\t// Read existing file as raw JSON map to preserve all existing fields.\\n   164→\\t// If the file doesn't exist, start with an empty map so we only write commit_linking.\\n   165→\\tvar raw map[string]json.RawMessage\\n   166→\\tdata, readErr := os.ReadFile(localPath) //nolint:gosec // path is from AbsPath\\n   167→\\tif readErr == nil {\\n   168→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   169→\\t\\t\\treturn fmt.Errorf(\\\"parsing local settings: %w\\\", err)\\n   170→\\t\\t}\\n   171→\\t} else if !os.IsNotExist(readErr) {\\n   172→\\t\\treturn fmt.Errorf(\\\"reading local settings: %w\\\", readErr)\\n   173→\\t}\\n   174→\\tif raw == nil {\\n   175→\\t\\traw = make(map[string]json.RawMessage)\\n   176→\\t}\\n   177→\\n   178→\\traw[\\\"commit_linking\\\"] = json.RawMessage(`\\\"` + settings.CommitLinkingAlways + `\\\"`)\\n   179→\\n   180→\\tout, err := json.MarshalIndent(raw, \\\"\\\", \\\"  \\\")\\n   181→\\tif err != nil {\\n   182→\\t\\treturn fmt.Errorf(\\\"marshaling local settings: %w\\\", err)\\n   183→\\t}\\n   184→\\tout = append(out, '\\\\n')\\n   185→\\n   186→\\tif err := os.MkdirAll(filepath.Dir(localPath), 0o750); err != nil {\\n   187→\\t\\treturn fmt.Errorf(\\\"creating settings directory: %w\\\", err)\\n   188→\\t}\\n   189→\\t//nolint:gosec // G306: settings file is config, not secrets; 0o644 is appropriate\\n   190→\\tif err := os.WriteFile(localPath, out, 0o644); err != nil {\\n   191→\\t\\treturn fmt.Errorf(\\\"writing local settings: %w\\\", err)\\n   192→\\t}\\n   193→\\treturn nil\\n   194→}\\n   195→\\n   196→// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   197→// If the message contains only our trailer (no actual user content), strip it\\n   198→// so git will abort the commit due to empty message.\\n   199→\\n   200→func (s *ManualCommitStrategy) CommitMsg(_ context.Context, commitMsgFile string) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   201→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n   202→\\tif err != nil {\\n   203→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   204→\\t}\\n   205→\\n   206→\\tmessage := string(content)\\n   207→\\n   208→\\t// Check if our trailer is present (ParseCheckpoint validates format, so found==true means valid)\\n   209→\\tif _, found := trailers.ParseCheckpoint(message); !found {\\n   210→\\t\\t// No trailer, nothing to do\\n   211→\\t\\treturn nil\\n   212→\\t}\\n   213→\\n   214→\\t// Check if there's any user content (non-comment, non-trailer lines)\\n   215→\\tif !hasUserContent(message) {\\n   216→\\t\\t// No user content - strip the trailer so git aborts\\n   217→\\t\\tmessage = stripCheckpointTrailer(message)\\n   218→\\t\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   219→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   220→\\t\\t}\\n   221→\\t}\\n   222→\\n   223→\\treturn nil\\n   224→}\\n   225→\\n   226→// hasUserContent checks if the message has any content besides comments and our trailer.\\n   227→func hasUserContent(message string) bool {\\n   228→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   229→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   230→\\t\\ttrimmed := strings.TrimSpace(line)\\n   231→\\t\\t// Skip empty lines\\n   232→\\t\\tif trimmed == \\\"\\\" {\\n   233→\\t\\t\\tcontinue\\n   234→\\t\\t}\\n   235→\\t\\t// Skip comment lines\\n   236→\\t\\tif strings.HasPrefix(trimmed, \\\"#\\\") {\\n   237→\\t\\t\\tcontinue\\n   238→\\t\\t}\\n   239→\\t\\t// Skip our trailer line\\n   240→\\t\\tif strings.HasPrefix(trimmed, trailerPrefix) {\\n   241→\\t\\t\\tcontinue\\n   242→\\t\\t}\\n   243→\\t\\t// Found user content\\n   244→\\t\\treturn true\\n   245→\\t}\\n   246→\\treturn false\\n   247→}\\n   248→\\n   249→// stripCheckpointTrailer removes the Entire-Checkpoint trailer line from the message.\\n   250→func stripCheckpointTrailer(message string) string {\\n   251→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   252→\\tvar result []string\\n   253→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   254→\\t\\tif !strings.HasPrefix(strings.TrimSpace(line), trailerPrefix) {\\n   255→\\t\\t\\tresult = append(result, line)\\n   256→\\t\\t}\\n   257→\\t}\\n   258→\\treturn strings.Join(result, \\\"\\\\n\\\")\\n   259→}\\n   260→\\n   261→// isGitSequenceOperation checks if git is currently in the middle of a rebase,\\n   262→// cherry-pick, or revert operation. During these operations, commits are being\\n   263→// replayed and should not be linked to agent sessions.\\n   264→//\\n   265→// Detects:\\n   266→//   - rebase: .git/rebase-merge/ or .git/rebase-apply/ directories\\n   267→//   - cherry-pick: .git/CHERRY_PICK_HEAD file\\n   268→//   - revert: .git/REVERT_HEAD file\\n   269→func isGitSequenceOperation(ctx context.Context) bool {\\n   270→\\t// Get git directory (handles worktrees and relative paths correctly)\\n   271→\\tgitDir, err := GetGitDir(ctx)\\n   272→\\tif err != nil {\\n   273→\\t\\treturn false // Can't determine, assume not in sequence operation\\n   274→\\t}\\n   275→\\n   276→\\t// Check for rebase state directories\\n   277→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-merge\\\")); err == nil {\\n   278→\\t\\treturn true\\n   279→\\t}\\n   280→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-apply\\\")); err == nil {\\n   281→\\t\\treturn true\\n   282→\\t}\\n   283→\\n   284→\\t// Check for cherry-pick and revert state files\\n   285→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"CHERRY_PICK_HEAD\\\")); err == nil {\\n   286→\\t\\treturn true\\n   287→\\t}\\n   288→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"REVERT_HEAD\\\")); err == nil {\\n   289→\\t\\treturn true\\n   290→\\t}\\n   291→\\n   292→\\treturn false\\n   293→}\\n   294→\\n   295→// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   296→// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   297→// Only adds a trailer if there's actually new session content to condense.\\n   298→// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   299→// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   300→// For amended commits, preserves the existing checkpoint ID.\\n   301→//\\n   302→// The source parameter indicates how the commit was initiated:\\n   303→//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   304→//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   305→//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   306→//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   307→//\\n   308→\\n   309→func (s *ManualCommitStrategy) PrepareCommitMsg(ctx context.Context, commitMsgFile string, source string) error {\\n   310→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   311→\\n   312→\\t// Skip during rebase, cherry-pick, or revert operations\\n   313→\\t// These are replaying existing commits and should not be linked to agent sessions\\n   314→\\tif isGitSequenceOperation(ctx) {\\n   315→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n   316→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   317→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   318→\\t\\t)\\n   319→\\t\\treturn nil\\n   320→\\t}\\n   321→\\n   322→\\t// Skip for merge and squash sources\\n   323→\\t// These are auto-generated messages - not from Claude sessions\\n   324→\\tswitch source {\\n   325→\\tcase \\\"merge\\\", \\\"squash\\\":\\n   326→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n   327→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   328→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   329→\\t\\t)\\n   330→\\t\\treturn nil\\n   331→\\t}\\n   332→\\n   333→\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   334→\\tif source == \\\"commit\\\" {\\n   335→\\t\\treturn s.handleAmendCommitMsg(ctx, commitMsgFile)\\n   336→\\t}\\n   337→\\n   338→\\t_, openRepoSpan := perf.Start(ctx, \\\"open_repository\\\")\\n   339→\\trepo, err := OpenRepository(ctx)\\n   340→\\tif err != nil {\\n   341→\\t\\topenRepoSpan.RecordError(err)\\n   342→\\t\\topenRepoSpan.End()\\n   343→\\t\\treturn nil\\n   344→\\t}\\n   345→\\topenRepoSpan.End()\\n   346→\\n   347→\\t_, findSessionsSpan := perf.Start(ctx, \\\"find_sessions_for_worktree\\\")\\n   348→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   349→\\tif err != nil {\\n   350→\\t\\tfindSessionsSpan.RecordError(err)\\n   351→\\t\\tfindSessionsSpan.End()\\n   352→\\t\\treturn nil\\n   353→\\t}\\n   354→\\n   355→\\t// Find all active sessions for this worktree\\n   356→\\t// We match by worktree (not BaseCommit) because the user may have made\\n   357→\\t// intermediate commits without entering new prompts, causing HEAD to diverge\\n   358→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   359→\\tif err != nil || len(sessions) == 0 {\\n   360→\\t\\tfindSessionsSpan.RecordError(err)\\n   361→\\t\\tfindSessionsSpan.End()\\n   362→\\t\\t// No active sessions or error listing - silently skip (hooks must be resilient)\\n   363→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no active sessions\\\",\\n   364→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   365→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   366→\\t\\t)\\n   367→\\t\\treturn nil\\n   368→\\t}\\n   369→\\tfindSessionsSpan.End()\\n   370→\\n   371→\\t// Fast path: when an agent is committing (ACTIVE session + no TTY), skip\\n   372→\\t// content detection and interactive prompts. The agent can't respond to TTY\\n   373→\\t// prompts and the content detection can miss mid-session work (no shadow\\n   374→\\t// branch yet, transcript analysis may fail). Generate a checkpoint ID and\\n   375→\\t// add the trailer directly.\\n   376→\\tif !hasTTY() {\\n   377→\\t\\tfor _, state := range sessions {\\n   378→\\t\\t\\tif state.Phase.IsActive() {\\n   379→\\t\\t\\t\\treturn s.addTrailerForAgentCommit(logCtx, commitMsgFile, state, source)\\n   380→\\t\\t\\t}\\n   381→\\t\\t}\\n   382→\\t}\\n   383→\\n   384→\\t// Check if any session has new content to condense\\n   385→\\t_, filterSessionsSpan := perf.Start(ctx, \\\"filter_sessions_with_content\\\")\\n   386→\\tsessionsWithContent := s.filterSessionsWithNewContent(ctx, repo, sessions)\\n   387→\\tfilterSessionsSpan.End()\\n   388→\\n   389→\\tif len(sessionsWithContent) == 0 {\\n   390→\\t\\t// No new content — no trailer needed\\n   391→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no content to link\\\",\\n   392→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   393→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   394→\\t\\t\\tslog.Int(\\\"sessions_found\\\", len(sessions)),\\n   395→\\t\\t)\\n   396→\\t\\treturn nil\\n   397→\\t}\\n   398→\\n   399→\\t// Read current commit message\\n   400→\\t_, readCommitMessageSpan := perf.Start(ctx, \\\"read_commit_message\\\")\\n   401→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // com