lock()\\n    46→\\n    47→\\tnames := make([]types.AgentName, 0, len(registry))\\n    48→\\tfor name := range registry {\\n    49→\\t\\tnames = append(names, name)\\n    50→\\t}\\n    51→\\tslices.Sort(names)\\n    52→\\treturn names\\n    53→}\\n    54→\\n    55→// StringList returns user-facing agent names, excluding test-only agents.\\n    56→func StringList() []string {\\n    57→\\tregistryMu.RLock()\\n    58→\\tdefer registryMu.RUnlock()\\n    59→\\n    60→\\tnames := make([]string, 0, len(registry))\\n    61→\\tfor name, factory := range registry {\\n    62→\\t\\tif to, ok := factory().(TestOnly); ok && to.IsTestOnly() {\\n    63→\\t\\t\\tcontinue\\n    64→\\t\\t}\\n    65→\\t\\tnames = append(names, string(name))\\n    66→\\t}\\n    67→\\tslices.Sort(names)\\n    68→\\treturn names\\n    69→}\\n    70→\\n    71→// DetectAll returns all agents whose DetectPresence reports true.\\n    72→// Agents are checked in sorted name order (via List()) for deterministic results.\\n    73→// Returns an empty slice when no agent is detected.\\n    74→func DetectAll(ctx context.Context) []Agent {\\n    75→\\tnames := List() // sorted, lock-safe\\n    76→\\n    77→\\tvar detected []Agent\\n    78→\\tfor _, name := range names {\\n    79→\\t\\tag, err := Get(name)\\n    80→\\t\\tif err != nil {\\n    81→\\t\\t\\tcontinue\\n    82→\\t\\t}\\n    83→\\t\\tif present, err := ag.DetectPresence(ctx); err == nil && present {\\n    84→\\t\\t\\tdetected = append(detected, ag)\\n    85→\\t\\t}\\n    86→\\t}\\n    87→\\treturn detected\\n    88→}\\n    89→\\n    90→// Detect attempts to auto-detect which agent is being used.\\n    91→// Iterates registered agents in sorted name order for deterministic results.\\n    92→// Returns the first agent whose DetectPresence reports true.\\n    93→func Detect(ctx context.Context) (Agent, error) {\\n    94→\\tdetected := DetectAll(ctx)\\n    95→\\tif len(detected) == 0 {\\n    96→\\t\\treturn nil, fmt.Errorf(\\\"no agent detected (available: %v)\