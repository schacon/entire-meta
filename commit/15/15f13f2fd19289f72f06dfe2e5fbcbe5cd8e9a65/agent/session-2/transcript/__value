   651→// ParseShadowBranchName extracts the commit prefix and worktree hash from a shadow branch name.\\n   652→// Input format: \\\"entire/<commit[:7]>-<worktreeHash[:6]>\\\"\\n   653→// Returns (commitPrefix, worktreeHash, ok). Returns (\\\"\\\", \\\"\\\", false) if not a valid shadow branch.\\n   654→func ParseShadowBranchName(branchName string) (commitPrefix, worktreeHash string, ok bool) {\\n   655→\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n   656→\\t\\treturn \\\"\\\", \\\"\\\", false\\n   657→\\t}\\n   658→\\tsuffix := strings.TrimPrefix(branchName, ShadowBranchPrefix)\\n   659→\\n   660→\\t// Find the last dash - everything before is commit prefix, after is worktree hash\\n   661→\\tlastDash := strings.LastIndex(suffix, \\\"-\\\")\\n   662→\\tif lastDash == -1 || lastDash == 0 || lastDash == len(suffix)-1 {\\n   663→\\t\\t// No dash, or dash at start/end - invalid format\\n   664→\\t\\t// Could be old format \\\"entire/<commit[:7]>\\\" without worktree hash\\n   665→\\t\\treturn suffix, \\\"\\\", true // Return as commit prefix with empty worktree hash\\n   666→\\t}\\n   667→\\n   668→\\treturn suffix[:lastDash], suffix[lastDash+1:], true\\n   669→}\\n   670→\\n   671→// getOrCreateShadowBranch gets or creates the shadow branch for checkpoints.\\n   672→// Returns (parentHash, baseTreeHash, error).\\n   673→func (s *GitStore) getOrCreateShadowBranch(branchName string) (plumbing.Hash, plumbing.Hash, error) {\\n   674→\\trefName := plumbing.NewBranchReferenceName(branchName)\\n   675→\\tref, err := s.repo.Reference(refName, true)\\n   676→\\n   677→\\tif err == nil {\\n   678→\\t\\t// Branch exists\\n   679→\\t\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n   680→\\t\\tif err != nil {\\n   681→\\t\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   682→\\t\\t}\\n   683→\\t\\treturn ref.Hash(), commit.TreeHash, nil\\n   684→\\t}\\n   685→\\n   686→\\t// Branch doesn't exist, use