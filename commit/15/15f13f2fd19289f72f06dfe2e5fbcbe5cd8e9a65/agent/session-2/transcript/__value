t}\\n    67→\\n    68→\\t// Get shadow branch name\\n    69→\\tshadowBranchName := ShadowBranchNameForCommit(opts.BaseCommit, opts.WorktreeID)\\n    70→\\n    71→\\t// Get or create shadow branch\\n    72→\\tparentHash, baseTreeHash, err := s.getOrCreateShadowBranch(shadowBranchName)\\n    73→\\tif err != nil {\\n    74→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to get shadow branch: %w\\\", err)\\n    75→\\t}\\n    76→\\n    77→\\t// Get the last checkpoint's tree hash for deduplication\\n    78→\\tvar lastTreeHash plumbing.Hash\\n    79→\\tif parentHash != plumbing.ZeroHash {\\n    80→\\t\\tif lastCommit, err := s.repo.CommitObject(parentHash); err == nil {\\n    81→\\t\\t\\tlastTreeHash = lastCommit.TreeHash\\n    82→\\t\\t}\\n    83→\\t}\\n    84→\\n    85→\\t// Collect all files to include\\n    86→\\tvar allFiles []string\\n    87→\\tvar allDeletedFiles []string\\n    88→\\tif opts.IsFirstCheckpoint {\\n    89→\\t\\t// For the first checkpoint, capture all changed files (modified tracked + untracked)\\n    90→\\t\\t// using `git status --porcelain -z` which respects both repo and global .gitignore.\\n    91→\\t\\t// This is much faster than filesystem walk. The base tree from HEAD already contains\\n    92→\\t\\t// all unchanged tracked files. We also capture user's pre-existing deletions.\\n    93→\\t\\tresult, err := collectChangedFiles(ctx, s.repo)\\n    94→\\t\\tif err != nil {\\n    95→\\t\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to collect changed files: %w\\\", err)\\n    96→\\t\\t}\\n    97→\\t\\tallFiles = result.Changed\\n    98→\\t\\t// Merge user's pre-existing deletions with agent's deletions\\n    99→\\t\\tallDeletedFiles = result.Deleted\\n   100→\\t\\tallDeletedFiles = append(allDeletedFiles, opts.DeletedFiles...)\\n   101→\\t} else {\\n   102→\\t\\t// For subsequent checkpoints, only include modified/new files\\n   103→\\t\\tallFiles = make([]string, 0, len(opts.ModifiedFiles)+len(opts.NewFiles))\\n   104→\\t\\tallFiles = append(allFiles, opts.ModifiedFiles...)\\n   105→\\t\\tallFiles = append(allFiles, opts.NewFiles...)\\n   106→\\t\\tallDeletedFiles = opts.DeletedFiles\\n   107→\\t}\\n   108→\\n   109→\\t// Build tree with changes\\n   110→\\ttreeHash, err := s.buildTreeWithChanges(ctx, baseTreeHash, allFiles, allDeletedFiles, opts.MetadataDir, opts.MetadataDirAbs)\\n   111→\\tif err != nil {\\n   112→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n   113→\\t}\\n   114→\\n   115→\\t// Deduplication: skip if tree hash matches the last checkpoint\\n   116→\\tif lastTreeHash != plumbing.ZeroHash && treeHash == lastTreeHash {\\n   117→\\t\\treturn WriteTemporaryResult{\\n   118→\\t\\t\\tCommitHash: parentHash,\\n   119→\\t\\t\\tSkipped:    true,\\n   120→\\t\\t}, nil\\n   121→\\t}\\n   122→\\n   123→\\t// Create checkpoint commit with trailers\\n   124→\\tcommitMsg := trailers.FormatShadowCommit(opts.CommitMessage, opts.MetadataDir, opts.SessionID)\\n   125→\\n   126→\\tcommitHash, err := s.createCommit(treeHash, parentHash, commitMsg, opts.AuthorName, opts.AuthorEmail)\\n   127→\\tif err != nil {\\n   128→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   129→\\t}\\n   130→\\n   131→\\t// Update branch reference\\n   132→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   133→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n   134→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n   135→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to update branch reference: %w\\\", err)\\n   136→\\t}\\n   137→\\n   138→\\treturn WriteTemporaryResult{\\n   139→\\t\\tCommitHash: commitHash,\\n   140→\\t\\tSkipped:    false,\\n   141→\\t}, nil\\n   142→}\\n   143→\\n   144→// ReadTemporary reads the latest checkpoint from a shadow branch.\\n   145→// Returns nil if the shadow branch doesn't exist.\\n   146→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   147→func (s *GitStore) ReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error) {\\n   148→\\tif err := ctx.Err(); err != nil {\\n   149→\\t\\treturn nil, err //nolint:wrapcheck // Propagating context cancellation\"}]},\"uuid\":\"f889f869-99b0-41fa-a15b-84d90e3910f3\",\"timestamp\":\"2026-03-12T20:10:50.867Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a80505ffca67b4524\"},\"toolUseID\":\"agent_msg_01P5q5oZj2sgcvDTtdkcPE62\",\"parentToolUseID\":\"toolu_01AMsQk5EWpuyCKhGg4U2AZL\",\"uuid\":\"0394bcaf-1543-4e2e-aa50-f4bb26cf85c4\",\"timestamp\":\"2026-03-12T20:10:50.870Z\",\"userType\":\"external\",\"cwd\":\"/Users/ninawork/entire/devenv/cli\",\"sessionId\":\"61b0a478-d835-45a6-936a-9d30f7ba786c\",\"version\":\"2.1.74\",\"gitBranch\":\"attach-session-id\",\"slug\":\"fancy-dreaming-biscuit\"}\n{\"parentUuid\":\"0394bcaf-1543-4e2e-aa50-f4bb26cf85c4\",\"isSidechain\":false,\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-12T20:10:53.176Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01XHCqpuDDU2FrBL3WGR8gA7\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_019z88Z9L1Arwr2tp3YyNhEy\",\"name\":\"Bash\",\"input\":{\"command\":\"grep -n \\\"ShadowBranchPrefix\\\\|ShadowBranchHashLength\\\" /Users/ninawork/entire/devenv/cli/cmd/entire/cli/checkpoint/temporary.go | head -10\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":5,\"cache_creation_input_tokens\":3549,\"cache_read_input_tokens\":87465,\"cache_creation\":{\"ephemeral_5m_input_tokens\":3549,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYyo1fD3nGgHayUvi8kQt\",\"uuid\":\"d5e69ffc-404a-4f92-a59c-c5004cf975bb\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a80505ffca67b4524\"},\"toolUseID\":\"agent_msg_01P5q5oZj2sgcvDTtdkcPE62\",\"parentToolUseID\":\"toolu_01AMsQk5EWpuyCKhGg4U2AZL\",\"uuid\":\"568997ff-1b46-4a1f-9257-dbea919e9121\",\"timestamp\":\"2026-03-12T20:10:53.177Z\",\"userType\":\"external\",\"cwd\":\"/Users/ninawork/entire/devenv/cli\",\"sessionId\":\"61b0a478-d835-45a6-936a-9d30f7ba786c\",\"version\":\"2.1.74\",\"gitBranch\":\"attach-session-id\",\"slug\":\"fancy-dreaming-biscuit\"}\n{\"parentUuid\":\"568997ff-1b46-4a1f-9257-dbea919e9121\",\"isSidechain\":false,\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_019z88Z9L1Arwr2tp3YyNhEy\",\"type\":\"tool_result\",\"content\":\"34:\\t// ShadowBranchPrefix is the prefix for shadow branches.\\n35:\\tShadowBranchPrefix = \\\"entire/\\\"\\n37:\\t// ShadowBranchHashLength is the number of hex characters used in shadow branch names.\\n39:\\tShadowBranchHashLength = 7\\n195:\\t\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n644:\\tif len(baseCommit) >= ShadowBranchHashLength {\\n645:\\t\\tcommitPart = baseCommit[:ShadowBranchHashLength]\\n648:\\treturn ShadowBranchPrefix + commitPart + \\\"-\\\" + worktreeHash\\n655:\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n658:\\tsuffix := strings.TrimPrefix(branchName, ShadowBranchPrefix)\",\"is_error\":false}]},\"uuid\":\"576390ef-98c3-43e0-bbc7-3e99f16b69bf\",\"timestamp\":\"2026-03-12T20:10:53.206Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a80505ffca67b4524\"},\"toolUseID\":\"agent_msg_01P5q5oZj2sgcvDTtdkcPE62\",\"parentToolUseID\":\"toolu_01AMsQk5EWpuyCKhGg4U2AZL\",\"uuid\":\"90290981-5a28-41b0-a18b-4e9e9924c449\",\"timestamp\":\"2026-03-12T20:10:53.206Z\",\"userType\":\"external\",\"cwd\":\"/Users/ninawork/entire/devenv/cli\",\"sessionId\":\"61b0a478-d835-45a6-936a-9d30f7ba786c\",\"version\":\"2.1.74\",\"gitBranch\":\"attach-session-id\",\"slug\":\"fancy-dreaming-biscuit\"}\n{\"parentUuid\":\"90290981-5a28-41b0-a18b-4e9e9924c449\",\"isSidechain\":false,\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"PostToolUse\",\"hookName\":\"PostToolUse:Agent\",\"command\":\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code post-task\"},\"parentToolUseID\":\"toolu_016MiViboABNjhbPFNB8sASJ\",\"toolUseID\":\"toolu_016MiViboABNjhbPFNB8sASJ\",\"timestamp\":\"2026-03-12T20:11:36.622Z\",\"uuid\":\"5c90f88b-1e73-4bde-8131-74602fc65ea7\",\"userType\":\"external\",\"cwd\":\"/Users/ninawork/entire/devenv/cli\",\"sessionId\":\"61b0a478-d835-45a6-936a-9d30f7ba786c\",\"version\":\"2.1.74\",\"gitBranch\":\"attach-session-id\",\"slug\":\"fancy-dreaming-biscuit\"}\n{\"parentUuid\":\"53cd024a-03cf-442d-b5ae-473b511bfd21\",\"isSidechain\":false,\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_016MiViboABNjhbPFNB8sASJ\",\"type\":\"tool_result\",\"content\":[{\"type\":\"text\",\"text\":\"Now let me create a comprehensive summary document. Based on my exploration, I have a thorough understanding of the flows. Let me compile the findings:\\n\\n## Summary: Entire CLI Checkpoint & Push Architecture\\n\\nBased on my thorough exploration of the codebase, here's a comprehensive understanding of how checkpoints become accessible, pushed, and the attach functionality:\\n\\n### 1. **Checkpoint ID Format and Generation**\\n\\n**Location:** `/Users/ninawork/entire/devenv/cli/cmd/entire/cli/checkpoint/id/id.go`\\n\\n- **Format**: 12-character lowercase hex string (e.g., `a3b2c4d5e6f7`)\\n- **Generation**: Created via `id.Generate()` using `crypto/rand.Read(6 bytes)` then hex-encoded\\n- **Validation**: Regex pattern `^[0-9a-f]{12}$`\\n- **Sharded Path**: `<id[:2]>/<id[2:]>/` → `a3/b2c4d5e6f7/` (256 shards to avoid directory bloat)\\n- **Usage**: Links user commits to metadata via trailer, creates directory on `entire/checkpoints/v1` branch\\n\\n---\\n\\n### 2. **Push Flow: How Checkpoints Get Pushed to Remote**\\n\\n**Location:** `/Users/ninawork/entire/devenv/cli/cmd/entire/cli/strategy/manual_commit_push.go` and `push_common.go`\\n\\n#### PrePush Hook (Entry Point)\\n```\\nUser runs: git push origin main\\n↓\\nGit fires: pre-push hook\\n↓\\nStrategy.PrePush() called with remote name\\n↓\\nTwo branches pushed in parallel:\\n  1. entire/checkpoints/v1 (metadata branch)\\n  2. entire/trails/v1 (trails branch)\\n```\\n\\n#### Push Logic (push_common.go - pushBranchIfNeeded)\\n1. **Check if pushing disabled** via settings (`strategy_options.push_sessions`)\\n   - Defaults to: enabled (auto push)\\n   - Options: `\\\"auto\\\"`, `\\\"prompt\\\"` (ask user), `\\\"false\\\"`/`\\\"off\\\"`/`\\\"no\\\"` (disable)\\n\\n2. **Verify branch exists locally** (refs/heads/entire/checkpoints/v1)\\n\\n3. **Check for unpushed commits**\\n   - Compares local hash vs remote-tracking ref\\n   - If same → skip silently (nothing to push)\\n   - If different → proceed to push\\n\\n4. **Push with retry logic**\\n   - **First attempt**: `git push --no-verify origin entire/checkpoints/v1`\\n   - **On non-fast-forward failure**:\\n     - Runs: `git fetch origin` to get remote state\\n     - **Reconcile disconnected branches** (automatic if branches are orphaned)\\n     - **Build merged tree** from local + remote using checkpoint utilities\\n     - **Create merge commit** with both parents (combining local + remote checkpoints)\\n     - **Update local ref** to merged commit\\n     - **Retry push** → should succeed (now fast-forward)\\n\\n5. **Result**\\n   - Messages to stderr: `[entire] Pushing entire/checkpoints/v1 to origin...`\\n   - Non-blocking: Warnings only, doesn't fail user's push\\n   - Happens **silently in the hook** (user sees no output unless there's an issue)\\n\\n#### Key File: `/Users/ninawork/entire/devenv/cli/cmd/entire/cli/strategy/manual_commit_push.go`\\n- `PrePush(ctx, remote)` - Entry point for git pre-push hook\\n- `pushSessionsBranchCommon()` - Checks settings, gates the push\\n- `pushBranchIfNeeded()` - Main push orchestrator\\n- `doPushBranch()` - Handles push + fetch+merge recovery\\n- `tryPushSessionsCommon()` - Actual git CLI push\\n- `fetchAndMergeSessionsCommon()` - Recovery: merges remote into local before retrying\\n\\n---\\n\\n### 3. **Condensation Flow: Shadow Branch → entire/checkpoints/v1**\\n\\n**Location:** `/Users/ninawork/entire/devenv/cli/cmd/entire/cli/strategy/manual_commit_condensation.go`\\n\\n#### When Condensation Happens\\n1. **PostCommit hook** (after user commits)\\n   - If phase is IDLE or ACTIVE: triggers `EventGitCommit`\\n   - Session state machine decides action (usually `ActionCondense`)\\n\\n2. **Called explicitly** via `strat.CondenseSessionByID(sessionID)`\\n   - Used by `entire attach` command to finalize attached sessions\\n\\n#### Condensation Process: `CondenseSession(ctx, repo, checkpointID, state, committedFiles)`\\n\\n**Input:**\\n- `checkpointID`: 12-hex-char ID from trailer (or generated)\\n- `state`: SessionState with metadata\\n- `committedFiles`: Files in this specific commit (filters which files attach to this checkpoint)\\n- Optional pre-resolved git objects for perf\\n\\n**Output:**\\n- `CondenseResult` with checkpoint ID, session ID, files touched, transcript\\n\\n**Steps:**\\n\\n1. **Extract session data from shadow branch or live transcript**\\n   - Resolves shadow branch: `entire/<commit-hash[:7]>-<worktreeHash[:6]>`\\n   - If shadow exists: reads tree, extracts transcript + prompts\\n   - If no shadow (mid-turn commit): reads live transcript file\\n\\n2. **Extract transcript and filter by checkpoint scope**\\n   - Full transcript from shadow or filesystem\\n   - Slices transcript if `CheckpointTranscriptStart` set (for incremental checkpoints)\\n   - Extracts user prompts from transcript\\n\\n3. **Filter files_touched to committed files** (1:1 checkpoint model)\\n   - If `committedFiles` provided (from PostCommit):\\n     - Only keeps files that overlap with actual commit\\n     - Enables splitting changes across multiple commits\\n   - Otherwise uses session state's full FilesTouched\\n\\n4. **Calculate attribution** (user vs agent changes)\\n   - Compares base commit → shadow branch → HEAD\\n   - Detects which lines user modified vs agent added\\n   - Handles carry-forward (partial commits)\\n\\n5. **Generate summary** (if enabled)\\n   - Uses Claude to summarize transcript\\n   - Stored in metadata\\n\\n6. **Write to permanent storage**\\n   - Calls `store.WriteCommitted()` → writes to `entire/checkpoints/v1` branch\\n   - Path: `.entire/checkpoints/v1/<checkpoint_id[:2]>/<checkpoint_id[2:]>/`\\n   - Creates directory structure:\\n     ```\\n     <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n     ├── metadata.json\\n     ├── full.jsonl          (full transcript)\\n     ├── prompt.txt          (user prompts)\\n     ├── content_hash.txt    (SHA256 of transcript)\\n     └── tasks/<tool-use-id>/ (if task checkpoints exist)\\n     ```\\n\\n#### Key Data in metadata.json\\n```json\\n{\\n  \\\"checkpoint_id\\\": \\\"a3b2c4d5e6f7\\\",\\n  \\\"session_id\\\": \\\"2026-01-13-uuid\\\",\\n  \\\"session_ids\\\": [\\\"...\\\"],  // all sessions in this checkpoint\\n  \\\"session_count\\\": 1,\\n  \\\"strategy\\\": \\\"manual-commit\\\",\\n  \\\"created_at\\\": \\\"2026-01-13T12:00:00Z\\\",\\n  \\\"files_touched\\\": [\\\"file1.txt\\\", \\\"file2.txt\\\"],\\n  \\\"author_name\\\": \\\"...\\\",\\n  \\\"author_email\\\": \\\"...\\\",\\n  \\\"agent\\\": \\\"claude-code\\\",\\n  \\\"checkpoints_count\\\": 3,\\n  \\\"token_usage\\\": { \\\"input_tokens\\\": 1000, \\\"output_tokens\\\": 500 },\\n  \\\"initial_attribution\\\": { \\\"agent_lines\\\": 150, \\\"human_added\\\": 10, ... },\\n  \\\"summary\\\": { \\\"title\\\": \\\"...\\\", \\\"description\\\": \\\"...\\\" }\\n}\\n```\\n\\n**Key functions:**\\n- `extractSessionData()` - Reads from shadow branch tree\\n- `extractSessionDataFromLiveTranscript()` - For mid-turn commits\\n- `calculateSessionAttributions()` - Computes user/agent attribution\\n- `buildSessionMetrics()` - Collects performance data\\n\\n---\\n\\n### 4. **Checkpoint URL Pattern**\\n\\n**Note:** The codebase does NOT currently have web/API integration that exposes checkpoints via URLs like `https://entire.io/gh/entireio/cli/checkpoints/attach-session-id/6ffa85cf0d18`.\\n\\n**What exists:**\\n- Checkpoints are stored in Git (orphan branch `entire/checkpoints/v1`)\\n- Accessible via Git directly: clone repo, checkout branch, read tree\\n- Can be pushed to remote GitHub\\n\\n**What's missing for URL support:**\\n- No web server/API to serve checkpoints\\n- No URL generation/resolution logic\\n- No external session import via URL\\n\\n**Current workflow for external access:**\\n1. Push entire/checkpoints/v1 to GitHub\\n2. Users clone and browse Git history\\n3. Or use CLI tools to read from local git objects\\n\\n---\\n\\n### 5. **Attach Command: Import External Sessions**\\n\\n**Location:** `/Users/ninawork/entire/devenv/cli/cmd/entire/cli/attach.go`\\n\\n**Purpose:** Manually attach an existing agent session (from external IDE) that wasn't captured by hooks\\n\\n**Flow:**\\n\\n```\\n$ entire attach <session-id> [--agent claude-code] [--force]\\n↓\\n1. Validate session ID format\\n2. Check not already tracked\\n3. Resolve agent and transcript path\\n   - Uses agent.Get() to load agent plugin\\n   - Calls agent.ResolveSessionDir() to find transcript\\n   - Falls back to searching alternative project directories\\n4. Read transcript file\\n5. Extract modified files\\n   - Uses agent's TranscriptAnalyzer if available\\n   - Cross-references with git status for actual uncommitted files\\n6. Create session metadata directory\\n   - Path: .entire/sessions/<session-id>/ (in worktree)\\n   - Copy transcript file there\\n7. Initialize session state\\n   - Creates StateStore entry with SessionID, AgentType, StartedAt\\n8. SaveStep - create shadow branch checkpoint\\n   - Builds StepContext with file changes\\n   - Calls strat.SaveStep() → creates shadow branch commit\\n9. CondenseSessionByID - finalize to permanent storage\\n   - Generates checkpoint ID\\n   - Calls CondenseSession() → writes to entire/checkpoints/v1\\n   - Updates session state with LastCheckpointID\\n10. Transition session to IDLE\\n11. Output checkpoint ID\\n    - Offers to amend last commit with Entire-Checkpoint trailer\\n    - With --force: automatically amends\\n    - Without: shows trailer for user to copy\\n```\\n\\n**Key functions in attach.go:**\\n- `newAttachCmd()` - Cobra command definition\\n- `runAttach(ctx, w, sessionID, agentName, force)` - Main handler\\n- `condenseAndFinalizeSession()` - Condense + state transition + output checkpoint ID\\n- `promptAmendCommit()` - Interactive or forced amendment of last commit\\n- `extractFirstPromptFromTranscript()` - Gets first user message for commit subject\\n- `extractTextFromMessage()` - Parses transcript message JSON\\n\\n**Output example:**\\n```\\nAttached session 2026-01-13-abc123def456\\n  Checkpoint saved with 5 file(s)\\n  Session is now tracked — future prompts will be captured automatically\\n\\nLast commit: a1b2c3d Fix bug\\nAmend the last commit in this branch? Y/n: y\\nAmended commit a1b2c3d with Entire-Checkpoint: a3b2c4d5e6f7\\n\\nEntire-Checkpoint: a3b2c4d5e6f7\\n```\\n\\n---\\n\\n### 6. **Commit Trailers Used**\\n\\n**Location:** `/Users/ninawork/entire/devenv/cli/cmd/entire/cli/trailers/trailers.go`\\n\\n#### On User's Active Branch Commits\\n```\\nEntire-Checkpoint: a3b2c4d5e6f7\\n```\\n- Added by `prepare-commit-msg` hook\\n- 12-hex checkpoint ID\\n- User can remove before committing to skip linking\\n- Parsed by `trailers.ParseCheckpoint(message)`\\n\\n#### On Shadow Branch Commits\\n```\\nEntire-Session: 2026-01-13-abc123def456\\nEntire-Metadata: .entire/sessions/<session-id>/\\nEntire-Task-Metadata: .entire/sessions/<session-id>/tasks/<tool-use-id>/\\nEntire-Strategy: manual-commit\\n```\\n\\n#### On Metadata Branch Commits (entire/checkpoints/v1)\\n```\\nSubject: Checkpoint: a3b2c4d5e6f7\\n\\nEntire-Session: 2026-01-13-abc123def456\\nEntire-Strategy: manual-commit\\nEntire-Agent: claude-code (optional)\\nEphemeral-branch: entire/6ffa85cf-abc123 (optional)\\nEntire-Metadata-Task: ... (optional, for task checkpoints)\\n```\\n\\n---\\n\\n### 7. **Session State Management**\\n\\n**Location:** `/Users/ninawork/entire/devenv/cli/cmd/entire/cli/session/state.go`\\n\\n**Storage:** `.git/entire-sessions/<session-id>.json`\\n\\n**State fields relevant to push/attach:**\\n```go\\ntype State struct {\\n  SessionID string\\n  BaseCommit string\\n  WorktreeID string\\n  Phase session.Phase  // ACTIVE, IDLE, ENDED\\n  FilesTouched []string\\n  StepCount int\\n  LastCheckpointID id.CheckpointID\\n  CheckpointTranscriptStart int\\n  TranscriptPath string\\n  AgentType types.AgentType\\n  CLIVersion string\\n  LastInteractionTime *time.Time\\n  PromptAttributions []PromptAttribution\\n  // ...\\n}\\n```\\n\\n**Key operations:**\\n- `LoadSessionState(ctx, sessionID)` - Read from disk\\n- `SaveSessionState(ctx, state)` - Write to disk\\n- `ListSessionStates(ctx)` - Enumerate all sessions\\n- `FindMostRecentSession(ctx)` - For resume functionality\\n\\n---\\n\\n### 8. **Key Data Flows Diagram**\\n\\n```\\n┌─────────────────────────────────────────────────────────────────┐\\n│ User runs: git push origin main                                 │\\n└──────────────────────┬──────────────────────────────────────────┘\\n                       │\\n                       ↓\\n┌─────────────────────────────────────────────────────────────────┐\\n│ Git pre-push hook fires                                         │\\n│ → Strategy.PrePush(ctx, \\\"origin\\\")                               │\\n└──────────────────────┬──────────────────────────────────────────┘\\n                       │\\n         ┌─────────────┴──────────────┐\\n         │                            │\\n         ↓      