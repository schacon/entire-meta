or the given session ID.\\n    41→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n    42→// Stale sessions are automatically deleted by the underlying StateStore.\\n    43→func LoadSessionState(ctx context.Context, sessionID string) (*SessionState, error) {\\n    44→\\tstore, err := session.NewStateStore(ctx)\\n    45→\\tif err != nil {\\n    46→\\t\\treturn nil, fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n    47→\\t}\\n    48→\\n    49→\\tstate, err := store.Load(ctx, sessionID)\\n    50→\\tif err != nil {\\n    51→\\t\\treturn nil, fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n    52→\\t}\\n    53→\\treturn state, nil\\n    54→}\\n    55→\\n    56→// SaveSessionState saves the session state atomically.\\n    57→func SaveSessionState(ctx context.Context, state *SessionState) error {\\n    58→\\t// Validate session ID to prevent path traversal\\n    59→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n    60→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n    61→\\t}\\n    62→\\n    63→\\tstateDir, err := getSessionStateDir(ctx)\\n    64→\\tif err != nil {\\n    65→\\t\\treturn fmt.Errorf(\\\"failed to get session state directory: %w\\\", err)\\n    66→\\t}\\n    67→\\n    68→\\tif err := os.MkdirAll(stateDir, 0o750); err != nil {\\n    69→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n    70→\\t}\\n    71→\\n    72→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n    73→\\tif err != nil {\\n    74→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n    75→\\t}\\n    76→\\n    77→\\tstateFile, err := sessionStateFile(ctx, state.SessionID)\\n    78→\\tif err != nil {\\n    79→\\t\\treturn fmt.Errorf(\\\"failed to get session state file path: %w\\\", err)\\n    80→\\t}\\n    81→\\n    82→\\t// Atomic write: write to temp file, then rename\\n    83→\\ttmpFile := stateFile + \\\".tmp\\\"\\n    84→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n    85→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n    86→\\t}\\n    87→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n    88→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n    89→\\t}\\n    90→\\treturn nil\\n    91→}\\n    92→\\n    93→// ListSessionStates returns all session states from the state directory.\\n    94→// This is a package-level function that doesn't require a specific strategy instance.\\n    95→func ListSessionStates(ctx context.Context) ([]*SessionState, error) {\\n    96→\\tstore, err := session.NewStateStore(ctx)\\n    97→\\tif err != nil {\\n    98→\\t\\treturn nil, fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n    99→\\t}\\n   100→\\n   101→\\tstates, err := store.List(ctx)\\n   102→\\tif err != nil {\\n   103→\\t\\treturn nil, fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   104→\\t}\\n   105→\\treturn states, nil\\n   106→}\\n   107→\\n   108→// FindMostRecentSession returns the session ID of the most recently interacted session\\n   109→// (by LastInteractionTime) in the current worktree. Returns empty string if no sessions exist.\\n   110→// Scoping to the current worktree prevents cross-worktree pollution in log routing.\\n   111→// Falls back to unfiltered search if the worktree path can't be determined.\\n   112→func FindMostRecentSession(ctx context.Context) string {\\n   113→\\tstates, err := ListSessionStates(ctx)\\n   114→\\tif err != nil || len(states) == 0 {\\n   115→\\t\\treturn \\\"\\\"\\n   116→\\t}\\n   117→\\n   118→\\t// Scope to current worktree to prevent cross-worktree pollution.\\n   119→\\tworktreePath, wpErr := paths.WorktreeRoot(ctx)\\n   120→\\tif wpErr == nil && worktreePath != \\\"\\\" {\\n   121→\\t\\tvar filtered []*SessionState\\n   122→\\t\\tfor _, s := range states {\\n   123→\\t\\t\\tif s.WorktreePath 