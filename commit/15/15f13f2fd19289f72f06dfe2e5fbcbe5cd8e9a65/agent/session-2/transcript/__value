 98→\\tif _, statErr := os.Stat(transcriptPath); statErr != nil {\\n    99→\\t\\tif found, searchErr := searchTranscriptInProjectDirs(agentName, sessionID, ag); searchErr == nil {\\n   100→\\t\\t\\tlogging.Info(logCtx, \\\"found transcript in alternative project directory\\\", \\\"path\\\", found)\\n   101→\\t\\t\\ttranscriptPath = found\\n   102→\\t\\t} else {\\n   103→\\t\\t\\tlogging.Debug(logCtx, \\\"fallback transcript search failed\\\", \\\"error\\\", searchErr)\\n   104→\\t\\t}\\n   105→\\t}\\n   106→\\tif _, statErr := os.Stat(transcriptPath); statErr != nil {\\n   107→\\t\\treturn fmt.Errorf(\\\"transcript not found at %s; is the session ID correct?\\\", transcriptPath)\\n   108→\\t}\\n   109→\\n   110→\\t// Read transcript data\\n   111→\\ttranscriptData, err := ag.ReadTranscript(transcriptPath)\\n   112→\\tif err != nil {\\n   113→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   114→\\t}\\n   115→\\n   116→\\t// Extract modified files from transcript\\n   117→\\tvar modifiedFiles []string\\n   118→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok {\\n   119→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptPath, 0); fileErr != nil {\\n   120→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files from transcript\\\", \\\"error\\\", fileErr)\\n   121→\\t\\t} else {\\n   122→\\t\\t\\tmodifiedFiles = files\\n   123→\\t\\t}\\n   124→\\t}\\n   125→\\n   126→\\t// Detect file changes via git status (no pre-untracked filter since we don't know pre-state)\\n   127→\\tchanges, err := DetectFileChanges(ctx, nil)\\n   128→\\tif err != nil {\\n   129→\\t\\tlogging.Warn(logCtx, \\\"failed to detect file changes, checkpoint may be incomplete\\\", \\\"error\\\", err)\\n   130→\\t}\\n   131→\\n   132→\\t// Filter and normalize paths\\n   133→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   134→\\tvar relNewFiles, relDeletedFiles []string\\n   135→\\tif changes != nil {\\n   136→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   137→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   138→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   139→\\t}\\n   140→\\n   141→\\t// Filter to uncommitted files only\\n   142→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   143→\\n   144→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   145→\\t\\treturn fmt.Errorf(\\\"failed to set up strategy: %w\\\", err)\\n   146→\\t}\\n   147→\\n   148→\\t// Create session metadata directory and copy transcript\\n   149→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   150→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   151→\\tif err != nil {\\n   152→\\t\\treturn fmt.Errorf(\\\"failed to resolve session directory path: %w\\\", err)\\n   153→\\t}\\n   154→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   155→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   156→\\t}\\n   157→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   158→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   159→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   160→\\t}\\n   161→\\n   162→\\t// Get git author\\n   163→\\tauthor, err := GetGitAuthor(ctx)\\n   164→\\tif err != nil {\\n   165→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   166→\\t}\\n   167→\\n   168→\\t// Extract first prompt from transcript for the commit message\\n   169→\\tfirstPrompt := extractFirstPromptFromTranscript(transcriptData)\\n   170→\\tcommitMessage := generateCommitMessage(firstPrompt, agentType)\\n   171→\\n   172→\\t// Initialize session state BEFORE SaveStep so it exists when SaveStep loads it\\n   173→\\tstrat := GetStrategy(ctx)\\n   174→\\tif err := strat.InitializeSession(ctx, sessionID, agentType, transcriptPath, firstPrompt, \\\"\\\"); err != nil {\\n   175→\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n   176→\\t}\\n   177→\\n   178→\\t// Update the session state with attach-specific metadata\\n   179→\\tstate, err := strategy.LoadSessionState(ctx, sessionID)\\n   180→\\tif err != nil {\\n   181→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   182→\\t}\\n   183→\\tif state == nil {\\n   184→\\t\\treturn fmt.Errorf(\\\"session state not found after initialization (session_id=%s)\\\", sessionID)\\n   185→\\t}\\n   186→\\tstate.CLIVersion = versioninfo.Version\\n   187→\\tstate.TranscriptPath = transcriptPath\\n   188→\\tif err := strategy.SaveSessionState(ctx, state); err != nil {\\n   189→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   190→\\t}\\n   191→\\n   192→\\t// Build step context and save checkpoint\\n   193→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   194→\\n   195→\\tstepCtx := strategy.StepContext{\\n   196→\\t\\tSessionID:      sessionID,\\n   197→\\t\\tModifiedFiles:  relModifiedFiles,\\n   198→\\t\\tNewFiles:       relNewFiles,\\n   199→\\t\\tDeletedFiles:   relDeletedFiles,\\n   200→\\t\\tMetadataDir:    sessionDir,\\n   201→\\t\\tMetadataDirAbs: sessionDirAbs,\\n   202→\\t\\tCommitMessage:  commitMessage,\\n   203→\\t\\tTranscriptPath: transcriptPath,\\n   204→\\t\\tAuthorName:     author.Name,\\n   205→\\t\\tAuthorEmail:    author.Email,\\n   206→\\t\\tAgentType:      agentType,\\n   207→\\t}\\n   208→\\n   209→\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   210→\\t\\treturn fmt.Errorf(\\\"failed to save checkpoint: %w\\\", err)\\n   211→\\t}\\n   212→\\n   213→\\tcheckpointIDStr, condenseErr := condenseAndFinalizeSession(logCtx, strat, sessionID)\\n   214→\\n   215→\\t// Print confirmation\\n   216→\\tfmt.Fprintf(w, \\\"Attached session %s\\\\n\\\", sessionID)\\n   217→\\tif totalChanges > 0 {\\n   218→\\t\\tfmt.Fprintf(w, \\\"  Checkpoint saved with %d file(s)\\\\n\\\", totalChanges)\\n   219→\\t} else {\\n   220→\\t\\tfmt.Fprintln(w, \\\"  Checkpoint saved (transcript only, no uncommitted file changes detected)\\\")\\n   221→\\t}\\n   222→\\tif condenseErr != nil {\\n   223→\\t\\tfmt.Fprintln(w, \\\"  Warning: checkpoint saved on shadow branch only (condensation failed)\\\")\\n   224→\\t}\\n   225→\\tfmt.Fprintln(w, \\\"  Session is now tracked — future prompts will be captured automatically\\\")\\n   226→\\n   227→\\t// Offer to amend the last commit with the checkpoint trailer\\n   228→\\tif checkpointIDStr != \\\"\\\" {\\n   229→\\t\\tif err := promptAmendCommit(ctx, w, checkpointIDStr, force); err != nil {\\n   230→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to amend commit\\\", \\\"error\\\", err)\\n   231→\\t\\t\\tfmt.Fprintf(w, \\\"\\\\nCopy to your commit message to attach:\\\\n\\\\n  Entire-Checkpoint: %s\\\\n\\\", checkpointIDStr)\\n   232→\\t\\t}\\n   233→\\t}\\n   234→\\n   235→\\treturn nil\\n   236→}\\n   237→\\n   238→// condenseAndFinalizeSession condenses the session to permanent storage and transitions it to IDLE.\\n   239→// Returns the checkpoint ID string and any condensation error.\\n   240→func condenseAndFinalizeSession(ctx context.Context, strat *strategy.ManualCommitStrategy, sessionID string) (string, error) {\\n   241→\\tvar checkpointIDStr string\\n   242→\\tvar condenseErr error\\n   243→\\tif err := strat.CondenseSessionByID(ctx, sessionID); err != nil {\\n   244→\\t\\tlogging.Warn(ctx, \\\"failed to condense session\\\", \\\"error\\\", err, \\\"session_id\\\", sessionID)\\n   245→\\t\\tcondenseErr = err\\n   246→\\t}\\n   247→\\n   248→\\t// Single load serves both checkpoint ID extraction and finalization\\n   249→\\tstate, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   250→\\tif loadErr != nil {\\n   251→\\t\\tlogging.Warn(ctx, \\\"failed to load session state after condensation\\\", \\\"error\\\", loadErr, \\\"session_id\\\", sessionID)\\n   252→\\t\\treturn checkpointIDStr, condenseErr\\n   253→\\t}\\n   254→\\tif state == nil {\\n   255→\\t\\treturn checkpointIDStr, condenseErr\\n   256→\\t}\\n   257→\\n   258→\\tif condenseErr == nil {\\n   259→\\t\\tcheckpointIDStr = state.LastCheckpointID.String()\\n   260→\\t}\\n   261→\\n   262→\\tnow := time.Now()\\n   263→\\tstate.LastInteractionTime = &now\\n   264→\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   265→\\t\\tlogging.Warn(ctx, \\\"failed to transition session to idle\\\", \\\"error\\\", transErr, \\\"session_id\\\", sessionID)\\n   266→\\t}\\n   267→\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   268→\\t\\tlogging.Warn(ctx, \\\"failed to save session state after transition\\\", \\\"error\\\", saveErr, \\\"session_id\\\", sessionID)\\n   269→\\t}\\n   270→\\n   271→\\treturn checkpointIDStr, condenseErr\\n   272→}\\n   273→\\n   274→// promptAmendCommit shows the last commit and asks whether to amend it with the checkpoint trailer.\\n   275→// When force is true, it amends without prompting.\\n   276→func promptAmendCommit(ctx context.Context, w io.Writer, checkpointIDStr string, force bool) error {\\n   277→\\t// Get HEAD commit info\\n   278→\\trepo, err := openRepository(ctx)\\n   279→\\tif err != nil {\\n   280→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   281→\\t}\\n   282→\\theadRef, err := repo.Head()\\n   283→\\tif err != nil {\\n   284→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   285→\\t}\\n   286→\\theadCommit, err := repo.CommitObject(headRef.Hash())\\n   287→\\tif err != nil {\\n   288→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   289→\\t}\\n   290→\\n   291→\\tshortHash := headRef.Hash().String()[:7]\\n   292→\\tsubject := strings.SplitN(headCommit.Message, \\\"\\\\n\\\", 2)[0]\\n   293→\\n   294→\\t// Check if the commit already has this checkpoint trailer\\n   295→\\tif _, found := trailers.ParseCheckpoint(headCommit.Message); found {\\n   296→\\t\\tfmt.Fprintf(w, \\\"\\\\nLast commit already has an Entire-Checkpoint trailer.\\\\n\\\")\\n   297→\\t\\treturn nil\\n   298→\\t}\\n   299→\\n   300→\\tfmt.Fprintf(w, \\\"\\\\nLast commit: %s %s\\\\n\\\", shortHash, subject)\\n   301→\\n   302→\\tamend := true\\n   303→\\tif !force {\\n   304→\\t\\tform := NewAccessibleForm(\\n   305→\\t\\t\\thuh.NewGroup(\\n   306→\\t\\t\\t\\thuh.NewConfirm().\\n   307→\\t\\t\\t\\t\\tTitle(\\\"Amend the last commit in this branch?\\\").\\n   308→\\t\\t\\t\\t\\tAffirmative(\\\"Y\\\").\\n   309→\\t\\t\\t\\t\\tNegative(\\\"n\\\").\\n   310→\\t\\t\\t\\t\\tValue(&amend),\\n   311→\\t\\t\\t),\\n   312→\\t\\t)\\n   313→\\t\\tif err := form.Run(); err != nil {\\n   314→\\t\\t\\treturn fmt.Errorf(\\\"prompt failed: %w\\\", err)\\n   315→\\t\\t}\\n   316→\\t}\\n   317→\\n   318→\\tif !amend {\\n   319→\\t\\tfmt.Fprintf(w, \\\"\\\\nCopy to your commit message to attach:\\\\n\\\\n  Entire-Checkpoint: %s\\\\n\\\", checkpointIDStr)\\n   320→\\t\\treturn nil\\n   321→\\t}\\n   322→\\n   323→\\t// Amend the commit with the checkpoint trailer\\n   324→\\tnewMessage := fmt.Sprintf(\\\"%s\\\\n\\\\n%s: %s\\\\n\\\", strings.TrimRight(headCommit.Message, \\\"\\\\n\\\"), trailers.CheckpointTrailerKey, checkpointIDStr)\\n   325→\\n   326→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"commit\\\", \\\"--amend\\\", \\\"-m\\\", newMessage)\\n   327→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   328→\\t\\treturn fmt.Errorf(\\\"failed to amend commit: %w\\\\n%s\\\", err, output)\\n   329→\\t}\\n   330→\\n   331→\\tfmt.Fprintf(w, \\\"Amended commit %s with Entire-Checkpoint: %s\\\\n\\\", shortHash, checkpointIDStr)\\n   332→\\treturn nil\\n   333→}\\n   334→\\n   335→// extractFirstPromptFromTranscript reads transcript bytes and returns the first user prompt.\\n   336→func extractFirstPromptFromTranscript(data []byte) string {\\n   337→\\tlines, err := transcript.ParseFromBytes(data)\\n   338→\\tif err != nil {\\n   339→\\t\\treturn \\\"\\\"\\n   340→\\t}\\n   341→\\tfor _, line := range lines {\\n   342→\\t\\tif line.Type == transcript.TypeUser {\\n   343→\\t\\t\\tprompt := extractTextFromMessage(line.Message)\\n   344→\\t\\t\\tif prompt != \\\"\\\" {\\n   345→\\t\\t\\t\\treturn prompt\\n   346→\\t\\t\\t}\\n   347→\\t\\t}\\n   348→\\t}\\n   349→\\treturn \\\"\\\"\\n   350→}\\n   351→\\n   352→// extractTextFromMessage extracts the text content from a transcript message.\\n   353→func extractTextFromMessage(msg json.RawMessage) string {\\n   354→\\t// Try string content first (simple user messages)\\n   355→\\tvar simple struct {\\n   356→\\t\\tContent string `json:\\\"content\\\"`\\n   357→\\t}\\n   358→\\tif err := json.Unmarshal(msg, &simple); err == nil && simple.Content != \\\"\\\" {\\n   359→\\t\\treturn simple.Content\\n   360→\\t}\\n   361→\\n   362→\\t// Try array content (messages with tool results, text blocks, etc.)\\n   363→\\tvar array struct {\\n   364→\\t\\tContent []struct {\\n   365→\\t\\t\\tType string `json:\\\"type\\\"`\\n   366→\\t\\t\\tText string `json:\\\"text\\\"`\\n   367→\\t\\t} `json:\\\"content\\\"`\\n   368→\\t}\\n   369→\\tif err := json.Unmarshal(msg, &array); err == nil {\\n   370→\\t\\tfor _, block := range array.Content {\\n   371→\\t\\t\\tif block.Type == \\\"text\\\" && block.Text != \\\"\\\" {\\n   372→\\t\\t\\t\\treturn block.Text\\n   373→\\t\\t\\t}\\n   374→\\t\\t}\\n   375→\\t}\\n   376→\\n   377→\\treturn \\\"\\\"\\n   378→}\\n   379→\"}]},\"uuid\":\"7da34002-2b17-4ad2-832b-393d75d1a664\",\"timestamp\":\"2026-03-12T20:10:34.563Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a968defa2fa5aabb3\"},\"toolUseID\":\"agent_msg_01P5q5oZj2sgcvDTtdkcPE62\",\"parentToolUseID\":\"toolu_016MiViboABNjhbPFNB8sASJ\",\"uuid\":\"ab1efd76-eba2-458d-9613-c885ad112282\",\"timestamp\":\"2026-03-12