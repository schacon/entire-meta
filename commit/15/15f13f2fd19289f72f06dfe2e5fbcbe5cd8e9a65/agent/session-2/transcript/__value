n    12→\\t\\\"path/filepath\\\"\\n    13→\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    16→)\\n    17→\\n    18→const (\\n    19→\\t// EntireSettingsFile is the path to the Entire settings file\\n    20→\\tEntireSettingsFile = \\\".entire/settings.json\\\"\\n    21→\\t// EntireSettingsLocalFile is the path to the local settings override file (not committed)\\n    22→\\tEntireSettingsLocalFile = \\\".entire/settings.local.json\\\"\\n    23→)\\n    24→\\n    25→// Commit linking mode constants.\\n    26→const (\\n    27→\\t// CommitLinkingAlways auto-links commits to sessions without prompting.\\n    28→\\tCommitLinkingAlways = \\\"always\\\"\\n    29→\\t// CommitLinkingPrompt prompts the user on each commit (default for existing users).\\n    30→\\tCommitLinkingPrompt = \\\"prompt\\\"\\n    31→)\\n    32→\\n    33→// EntireSettings represents the .entire/settings.json configuration\\n    34→type EntireSettings struct {\\n    35→\\n    36→\\t// Enabled indicates whether Entire is active. When false, CLI commands\\n    37→\\t// show a disabled message and hooks exit silently. Defaults to true.\\n    38→\\tEnabled bool `json:\\\"enabled\\\"`\\n    39→\\n    40→\\t// LocalDev indicates whether to use \\\"go run\\\" instead of the \\\"entire\\\" binary\\n    41→\\t// This is used for development when the binary is not installed\\n    42→\\tLocalDev bool `json:\\\"local_dev,omitempty\\\"`\\n    43→\\n    44→\\t// LogLevel sets the logging verbosity (debug, info, warn, error).\\n    45→\\t// Can be overridden by ENTIRE_LOG_LEVEL environment variable.\\n    46→\\t// Defaults to \\\"info\\\".\\n    47→\\tLogLevel string `json:\\\"log_level,omitempty\\\"`\\n    48→\\n    49→\\t// StrategyOptions contains strategy-specific configuration\\n    50→\\tStrategyOptions map[string]any `json:\\\"strategy_options,omitempty\\\"`\\n    51→\\n    52→\\t// AbsoluteGitHookPath embeds the full binary path in git hooks instead of\\n    53→\\t// bare \\\"entire\\\". This is needed for GUI git clients (Xcode, Tower, etc.)\\n    54→\\t// that don't source shell profiles and can't find \\\"entire\\\" on PATH.\\n    55→\\tAbsoluteGitHookPath bool `json:\\\"absolute_git_hook_path,omitempty\\\"`\\n    56→\\n    57→\\t// Telemetry controls anonymous usage analytics.\\n    58→\\t// nil = not asked yet (show prompt), true = opted in, false = opted out\\n    59→\\tTelemetry *bool `json:\\\"telemetry,omitempty\\\"`\\n    60→\\n    61→\\t// CommitLinking controls how commits are linked to agent sessions.\\n    62→\\t// \\\"always\\\" = auto-link without prompting, \\\"prompt\\\" = ask on each commit.\\n    63→\\t// Defaults to \\\"prompt\\\" (preserves existing user behavior).\\n    64→\\tCommitLinking string `json:\\\"commit_linking,omitempty\\\"`\\n    65→\\n    66→\\t// ExternalAgents enables discovery and registration of external agent\\n    67→\\t// plugins (entire-agent-* binaries on $PATH). Defaults to false.\\n    68→\\tExternalAgents bool `json:\\\"external_agents,omitempty\\\"`\\n    69→\\n    70→\\t// Deprecated: no longer used. Exists to tolerate old settings files\\n    71→\\t// that still contain \\\"strategy\\\": \\\"auto-commit\\\" or similar.\\n    72→\\tStrategy string `json:\\\"strategy,omitempty\\\"`\\n    73→}\\n    74→\\n    75→// GetCommitLinking returns the effective commit linking mode.\\n    76→// Returns the explicit value if set, otherwise defaults to \\\"prompt\\\"\\n    77→// to preserve existing user behavior.\\n    78→func (s *EntireSettings) GetCommitLinking() string {\\n    79→\\tif s.CommitLinking != \\\"\\\" {\\n    80→\\t\\treturn s.CommitLinking\\n    81→\\t}\\n    82→\\treturn CommitLinkingPrompt\\n    83→}\\n    84→\\n    85→// Load loads the Entire settings from .entire/settings.json,\\n    86→// then applies any overrides from .entire/settings.local.json if it exists.\\n    87→// Returns default settings if neither file exists.\\n    88→// Works correctly from any subdirectory within the repository.\\n    89→func Load(ctx context.Context) (*EntireSettings, error) {\\n    90→\\t// Get absolute paths for settings files\\n    91→\\tsettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsFile)\\n    92→\\tif err != nil {\\n    93→\\t\\tsettingsFileAbs = EntireSettingsFile // Fallback to relative\\n    94→\\t}\\n    95→\\tlocalSettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsLocalFile)\\n    96→\\tif err != nil {\\n    97→\\t\\tlocalSettingsFileAbs = EntireSettingsLocalFile // Fallback to relative\\n    98→\\t}\\n    99→\\n   100→\\t// Load base settings\\n   101→\\tsettings, err := loadFromFile(settingsFileAbs)\\n   102→\\tif err != nil {\\n   103→\\t\\treturn nil, fmt.Errorf(\\\"reading settings file: %w\\\", err)\\n   104→\\t}\\n   105→\\n   106→\\t// Apply local overrides if they exist\\n   107→\\tlocalData, err := os.ReadFile(localSettingsFileAbs) //nolint:gosec // path is from AbsPath or constant\\n   108→\\tif err != nil {\\n   109→\\t\\tif !os.IsNotExist(err) {\\n   110→\\t\\t\\treturn nil, fmt.Errorf(\\\"reading local settings file: %w\\\", err)\\n   111→\\t\\t}\\n   112→\\t\\t// Local file doesn't exist, continue without overrides\\n   113→\\t} else {\\n   114→\\t\\tif err := mergeJSON(settings, localData); err != nil {\\n   115→\\t\\t\\treturn nil, fmt.Errorf(\\\"merging local settings: %w\\\", err)\\n   116→\\t\\t}\\n   117→\\t}\\n   118→\\n   119→\\treturn settings, nil\\n   120→}\\n   121→\\n   122→// LoadFromFile loads settings from a specific file path without merging local overrides.\\n   123→// Returns default settings if the file doesn't exist.\\n   124→// Use this when you need to display individual settings files separately.\\n   125→func LoadFromFile(filePath string) (*EntireSettings, error) {\\n   126→\\treturn loadFromFile(filePath)\\n   127→}\\n   128→\\n   129→// loadFromFile loads settings from a specific file path.\\n   130→// Returns default settings if the file doesn't exist.\\n   131→func loadFromFile(filePath string) (*EntireSettings, error) {\\n   132→\\tsettings := &EntireSettings{\\n   133→\\t\\tEnabled: true, // Default to enabled\\n   134→\\t}\\n   135→\\n   136→\\tdata, err := os.ReadFile(filePath) //nolint:gosec // path is from caller\\n   137→\\tif err != nil {\\n   138→\\t\\tif os.IsNotExist(err) {\\n   139→\\t\\t\\treturn settings, nil\\n   140→\\t\\t}\\n   141→\\t\\treturn nil, fmt.Errorf(\\\"%w\\\", err)\\n   142→\\t}\\n   143→\\n   144→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   145→\\tdec.DisallowUnknownFields()\\n   146→\\tif err := dec.Decode(settings); err != nil {\\n   147→\\t\\treturn nil, fmt.Errorf(\\\"parsing settings file: %w\\\", err)\\n   148→\\t}\\n   149→\\n   150→\\t// Validate commit_linking if set\\n   151→\\tif settings.CommitLinking != \\\"\\\" && settings.CommitLinking != CommitLinkingAlways && settings.CommitLinking != CommitLinkingPrompt {\\n   152→\\t\\treturn nil, fmt.Errorf(\\\"invalid commit_linking value %q: must be %q or %q\\\", settings.CommitLinking, CommitLinkingAlways, CommitLinkingPrompt)\\n   153→\\t}\\n   154→\\n   155→\\treturn settings, nil\\n   156→}\\n   157→\\n   158→// mergeJSON merges JSON data into existing settings.\\n   159→// Only non-zero values from the JSON override existing settings.\\n   160→func mergeJSON(settings *EntireSettings, data []byte) error {\\n   161→\\t// First, validate that there are no unknown keys using strict decoding\\n   162→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   163→\\tdec.DisallowUnknownFields()\\n   164→\\tvar temp EntireSettings\\n   165→\\tif err := dec.Decode(&temp); err != nil {\\n   166→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   167→\\t}\\n   168→\\n   169→\\t// Parse into a map to check which fields are present\\n   170→\\tvar raw map[string]json.RawMessage\\n   171→\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   172→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   173→\\t}\\n   174→\\n   175→\\t// Override enabled if present\\n   176→\\tif enabledRaw, ok := raw[\\\"enabled\\\"]; ok {\\n   177→\\t\\tvar e bool\\n   178→\\t\\tif err := json.Unmarshal(enabledRaw, &e); err != nil {\\n   179→\\t\\t\\treturn fmt.Errorf(\\\"parsing enabled field: %w\\\", err)\\n   180→\\t\\t}\\n   181→\\t\\tsettings.Enabled = e\\n   182→\\t}\\n   183→\\n   184→\\t// Override local_dev if present\\n   185→\\tif localDevRaw, ok := raw[\\\"local_dev\\\"]; ok {\\n   186→\\t\\tvar ld bool\\n   187→\\t\\tif err := json.Unmarshal(localDevRaw, &ld); err != nil {\\n   188→\\t\\t\\treturn fmt.Errorf(\\\"parsing local_dev field: %w\\\", err)\\n   189→\\t\\t}\\n   190→\\t\\tsettings.LocalDev = ld\\n   191→\\t}\\n   192→\\n   193→\\t// Override absolute_git_hook_path if present\\n   194→\\tif ahpRaw, ok := raw[\\\"absolute_git_hook_path\\\"]; ok {\\n   195→\\t\\tvar ahp bool\\n   196→\\t\\tif err := json.Unmarshal(ahpRaw, &ahp); err != nil {\\n   197→\\t\\t\\treturn fmt.Errorf(\\\"parsing absolute_git_hook_path field: %w\\\", err)\\n   198→\\t\\t}\\n   199→\\t\\tsettings.AbsoluteGitHookPath = ahp\\n   200→\\t}\\n   201→\\n   202→\\t// Override log_level if present and non-empty\\n   203→\\tif logLevelRaw, ok := raw[\\\"log_level\\\"]; ok {\\n   204→\\t\\tvar ll string\\n   205→\\t\\tif err := json.Unmarshal(logLevelRaw, &ll); err != nil {\\n   206→\\t\\t\\treturn fmt.Errorf(\\\"parsing log_level field: %w\\\", err)\\n   207→\\t\\t}\\n   208→\\t\\tif ll != \\\"\\\" {\\n   209→\\t\\t\\tsettings.LogLevel = ll\\n   210→\\t\\t}\\n   211→\\t}\\n   212→\\n   213→\\t// Merge strategy_options if present\\n   214→\\tif optionsRaw, ok := raw[\\\"strategy_options\\\"]; ok {\\n   215→\\t\\tvar opts map[string]any\\n   216→\\t\\tif err := json.Unmarshal(optionsRaw, &opts); err != nil {\\n   217→\\t\\t\\treturn fmt.Errorf(\\\"parsing strategy_options field: %w\\\", err)\\n   218→\\t\\t}\\n   219→\\t\\tif settings.StrategyOptions == nil {\\n   220→\\t\\t\\tsettings.StrategyOptions = opts\\n   221→\\t\\t} else {\\n   222→\\t\\t\\tfor k, v := range opts {\\n   223→\\t\\t\\t\\tsettings.StrategyOptions[k] = v\\n   224→\\t\\t\\t}\\n   225→\\t\\t}\\n   226→\\t}\\n   227→\\n   228→\\t// Override telemetry if present\\n   229→\\tif telemetryRaw, ok := raw[\\\"telemetry\\\"]; ok {\\n   230→\\t\\tvar t bool\\n   231→\\t\\tif err := json.Unmarshal(telemetryRaw, &t); err != nil {\\n   232→\\t\\t\\treturn fmt.Errorf(\\\"parsing telemetry field: %w\\\", err)\\n   233→\\t\\t}\\n   234→\\t\\tsettings.Telemetry = &t\\n   235→\\t}\\n   236→\\n   237→\\t// Override commit_linking if present and non-empty\\n   238→\\tif commitLinkingRaw, ok := raw[\\\"commit_linking\\\"]; ok {\\n   239→\\t\\tvar cl string\\n   240→\\t\\tif err := json.Unmarshal(commitLinkingRaw, &cl); err != nil {\\n   241→\\t\\t\\treturn fmt.Errorf(\\\"parsing commit_linking field: %w\\\", err)\\n   242→\\t\\t}\\n   243→\\t\\tif cl != \\\"\\\" {\\n   244→\\t\\t\\tswitch cl {\\n   245→\\t\\t\\tcase CommitLinkingAlways, CommitLinkingPrompt:\\n   246→\\t\\t\\t\\tsettings.CommitLinking = cl\\n   247→\\t\\t\\tdefault:\\n   248→\\t\\t\\t\\treturn fmt.Errorf(\\\"invalid commit_linking value %q: must be %q or %q\\\", cl, CommitLinkingAlways, CommitLinkingPrompt)\\n   249→\\t\\t\\t}\\n   250→\\t\\t}\\n   251→\\t}\\n   252→\\n   253→\\t// Override external_agents if present\\n   254→\\tif externalAgentsRaw, ok := raw[\\\"external_agents\\\"]; ok {\\n   255→\\t\\tvar ea bool\\n   256→\\t\\tif err := json.Unmarshal(externalAgentsRaw, &ea); err != nil {\\n   257→\\t\\t\\treturn fmt.Errorf(\\\"parsing external_agents field: %w\\\", err)\\n   258→\\t\\t}\\n   259→\\t\\tsettings.ExternalAgents = ea\\n   260→\\t}\\n   261→\\n   262→\\treturn nil\\n   263→}\\n   264→\\n   265→// IsSetUp returns true if Entire has been set up in the current repository.\\n   266→// This checks if .entire/settings.json exists.\\n   267→// Use this to avoid creating files/directories in repos where Entire was never enabled.\\n   268→func IsSetUp(ctx context.Context) bool {\\n   269→\\tsettingsFileAbs, err := paths.AbsPath(ctx, EntireSettingsFile)\\n   270→\\tif err != nil {\\n   271→\\t\\treturn false\\n   272→\\t}\\n   273→\\t_, err = os.Stat(settingsFileAbs)\\n   274→\\treturn err == nil\\n   275→}\\n   276→\\n   277→// IsSetUpAndEnabled returns true if Entire is both set up and enabled.\\n   278→// This checks if .entire/settings.json exists AND has enabled: true.\\n   279→// Use this for hooks that should be no-ops when Entire is not active.\\n   280→func IsSetUpAndEnabled(ctx context.Context) bool {\\n   281→\\tif !IsSetUp(ctx) {\\n   282→\\t\\treturn false\\n   283→\\t}\\n   284→\\ts, err := Load(ctx)\\n   285→\\tif err != nil {\\n   286→\\t\\treturn false\\n   287→\\t}\\n   288→\\treturn s.Enabled\\n   289→}\\n   290→\\n   291→// IsSummarizeEnabled checks if auto-summarize is enabled in settings.\\n   292→// Returns false by default if settings cannot be loaded or the key is missing.\\n   293→func IsSummarizeEnabled(ctx context.Context) bool {\\n   294→\\tsettings, err := Load(ctx)\\n   295→\\tif err != nil {\\n   296→\\t\\treturn false\\n   297→\\t}\\n   298→\\treturn settings.IsSummarizeEnabled()\\n   299→}\\n   300→\\n   301→// IsSummarizeEnabled checks if auto-summarize is enabled in this settings instance.\\n   302→func (s *EntireSettings) IsSummarizeEnabled() bool {\\n   303→\\tif s.StrategyOptions == nil {\\n   304→\\t\\treturn false\\n   305→\\t}\\n   306→\\tsummarizeOpts, ok := s.StrategyOptions[\\\"summarize\\\"].(map[string]any)\\n   307→\\tif !ok {\\n   308→\\t\\treturn false\\n   309→\\t}\\n   310→\\tenabled, ok := summarizeOpts[\\\"enabled\\\"].(bool)\\n   311→\\tif !ok {\\n   312→\\t\\treturn false\\n   313→\\t}\\n   314→\\treturn enabled\\n   315→}\\n   316→\\n   317→// IsPushSessionsDisabled checks if push_sessions is disabled in settings.\\n   318→// Returns true if push_sessions is explicitly set to false.\\n   319→func (s *EntireSettings) IsPushSessionsDisabled() bool {\\n   320→\\tif s.StrategyOptions == nil {\\n   321→\\t\\treturn false\\n   322→\\t}\\n   323→\\tval, exists := s.StrategyOptions[\\\"push_sessions\\\"]\\n   324→\\tif !exists {\\n   325→\\t\\treturn false\\n   326→\\t}\\n   327→\\tif boolVal, ok := val.(bool); ok {\\n   328→\\t\\treturn !boolVal // disabled = !push_sessions\\n   329→\\t}\\n   330→\\treturn false\\n   331→}\\n   332→\\n   333→// IsExternalAgentsEnabled checks if external agent discovery is enabled in settings.\\n   334→// Returns false by default if settings cannot be loaded or the key is missing.\\n   335→func IsExternalAgentsEnabled(ctx context.Context) bool {\\n   336→\\ts, err := Load(ctx)\\n   337→\\tif err != nil {\\n   338→\\t\\treturn false\\n   339→\\t}\\n   340→\\treturn s.ExternalAgents\\n   341→}\\n   342→\\n   343→// Save saves the settings to .entire/settings.json.\\n   344→func Save(ctx context.Context, settings *EntireSettings) error {\\n   345→\\treturn saveToFile(ctx, settings, EntireSettingsFile)\\n   346→}\\n   347→\\n   348→// SaveLocal saves the settings to .entire/settings.local.json.\\n   349→func SaveLocal(ctx context.Context, settings *EntireSettings) error {\\n   350→\\treturn saveToFile(ctx, settings, EntireSettingsLocalFile)\\n   351→}\\n   352→\\n   353→// saveToFile saves settings to the specified file path.\\n   354→func saveToFile(ctx context.Context, settings *EntireSettings, filePath string) error {\\n   355→\\t// Get absolute path for the file\\n   356→\\tfilePathAbs, err := paths.AbsPath(ctx, filePath)\\n   357→\\tif err != nil {\\n   358→\\t\\tfilePathAbs = filePath // Fallback to relative\\n   359→\\t}\\n   360→\\n   361→\\t// Ensure directory exists\\n   362→\\tdir := filepath.Dir(filePathAbs)\\n   363→\\tif err := os.MkdirAll(dir, 0o750); err != nil {\\n   364→\\t\\treturn fmt.Errorf(\\\"creating settings directory: %w\\\", err)\\n   365→\\t}\\n   366→\\n   367→\\tdata, err := jsonutil.MarshalIndentWithNewline(settings, \\\"\\\", \\\"  \\\")\\n   368→\