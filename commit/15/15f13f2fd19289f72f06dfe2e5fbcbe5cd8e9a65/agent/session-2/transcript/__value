esolve state dir for model hint\\\",\\n   252→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   253→\\t\\t\\tslog.Any(\\\"error\\\", err))\\n   254→\\t\\treturn \\\"\\\"\\n   255→\\t}\\n   256→\\n   257→\\thintPath := filepath.Join(stateDir, sessionID+\\\".model\\\")\\n   258→\\tdata, err := os.ReadFile(hintPath) //nolint:gosec // sessionID is validated above\\n   259→\\tif err != nil {\\n   260→\\t\\tif !os.IsNotExist(err) {\\n   261→\\t\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"session\\\"), \\\"failed to read model hint file\\\",\\n   262→\\t\\t\\t\\tslog.String(\\\"path\\\", hintPath),\\n   263→\\t\\t\\t\\tslog.Any(\\\"error\\\", err))\\n   264→\\t\\t}\\n   265→\\t\\treturn \\\"\\\"\\n   266→\\t}\\n   267→\\treturn strings.TrimSpace(string(data))\\n   268→}\\n   269→\\n   270→// ClearSessionState removes the session state file for the given session ID.\\n   271→func ClearSessionState(ctx context.Context, sessionID string) error {\\n   272→\\t// Validate session ID to prevent path traversal\\n   273→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   274→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   275→\\t}\\n   276→\\n   277→\\tstateDir, err := getSessionStateDir(ctx)\\n   278→\\tif err != nil {\\n   279→\\t\\treturn fmt.Errorf(\\\"failed to get session state directory: %w\\\", err)\\n   280→\\t}\\n   281→\\n   282→\\t// Remove all files for this session (state .json, .model hint, any future hint files).\\n   283→\\tmatches, _ := filepath.Glob(filepath.Join(stateDir, sessionID+\\\".*\\\")) //nolint:errcheck // pattern is always valid\\n   284→\\tfor _, f := range matches {\\n   285→\\t\\t_ = os.Remove(f)\\n   286→\\t}\\n   287→\\n   288→\\treturn nil\\n   289→}\\n   290→\"}]},\"uuid\":\"b7e54967-a6be-45e3-8cd0-f66e424f49e7\",\"timestamp\":\"2026-03-12T20:44:25.190Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a8f789aafdc6eb9cc\"},\"toolUseID\":\"agent_msg_01WGyfbFu9aawLjJuKhd3AgC\",\"parentT