SessionID:                   opts.SessionID,\\n   370→\\t\\tStrategy:                    opts.Strategy,\\n   371→\\t\\tCreatedAt:                   time.Now().UTC(),\\n   372→\\t\\tBranch:                      opts.Branch,\\n   373→\\t\\tCheckpointsCount:            opts.CheckpointsCount,\\n   374→\\t\\tFilesTouched:                opts.FilesTouched,\\n   375→\\t\\tAgent:                       opts.Agent,\\n   376→\\t\\tModel:                       opts.Model,\\n   377→\\t\\tTurnID:                      opts.TurnID,\\n   378→\\t\\tIsTask:                      opts.IsTask,\\n   379→\\t\\tToolUseID:                   opts.ToolUseID,\\n   380→\\t\\tTranscriptIdentifierAtStart: opts.TranscriptIdentifierAtStart,\\n   381→\\t\\tCheckpointTranscriptStart:   opts.CheckpointTranscriptStart,\\n   382→\\t\\tTranscriptLinesAtStart:      opts.CheckpointTranscriptStart, // Deprecated: kept for backward compat\\n   383→\\t\\tTokenUsage:                  opts.TokenUsage,\\n   384→\\t\\tSessionMetrics:              opts.SessionMetrics,\\n   385→\\t\\tInitialAttribution:          opts.InitialAttribution,\\n   386→\\t\\tSummary:                     redactSummary(opts.Summary),\\n   387→\\t\\tCLIVersion:                  versioninfo.Version,\\n   388→\\t}\\n   389→\\n   390→\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(sessionMetadata, \\\"\\\", \\\"  \\\")\\n   391→\\tif err != nil {\\n   392→\\t\\treturn filePaths, fmt.Errorf(\\\"failed to marshal session metadata: %w\\\", err)\\n   393→\\t}\\n   394→\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n   395→\\tif err != nil {\\n   396→\\t\\treturn filePaths, err\\n   397→\\t}\\n   398→\\tentries[sessionPath+paths.MetadataFileName] = object.TreeEntry{\\n   399→\\t\\tName: sessionPath + paths.MetadataFileName,\\n   400→\\t\\tMode: filemode.Regular,\\n   401→\\t\\tHash: metadataHash,\\n   402→\\t}\\n   403→\\tfilePaths.Metadata = \\\"/\\\" + sessionPath + paths.MetadataFileName\\n   404→\\n   405→\\treturn filePaths, nil\\n   406→}\\n   407→\\n   408→// writeCheckpointSummary writes the root-level CheckpointSummary with aggregated statistics.\\n   409→// sessions is the complete sessions array (already built by the caller).\\n   410→func (s *GitStore) writeCheckpointSummary(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry, sessions []SessionFilePaths) error {\\n   411→\\tcheckpointsCount, filesTouched, tokenUsage, err :=\\n   412→\\t\\ts.reaggregateFromEntries(basePath, len(sessions), entries)\\n   413→\\tif err != nil {\\n   414→\\t\\treturn fmt.Errorf(\\\"failed to aggregate session stats: %w\\\", err)\\n   415→\\t}\\n   416→\\n   417→\\tsummary := CheckpointSummary{\\n   418→\\t\\tCheckpointID:     opts.CheckpointID,\\n   419→\\t\\tCLIVersion:       versioninfo.Version,\\n   420→\\t\\tStrategy:         opts.Strategy,\\n   421→\\t\\tBranch:           opts.Branch,\\n   422→\\t\\tCheckpointsCount: checkpointsCount,\\n   423→\\t\\tFilesTouched:     filesTouched,\\n   424→\\t\\tSessions:         sessions,\\n   425→\\t\\tTokenUsage:       tokenUsage,\\n   426→\\t}\\n   427→\\n   428→\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(summary, \\\"\\\", \\\"  \\\")\\n   429→\\tif err != nil {\\n   430→\\t\\treturn fmt.Errorf(\\\"failed to marshal checkpoint summary: %w\\\", err)\\n   431→\\t}\\n   432→\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n   433→\\tif err != nil {\\n   434→\\t\\treturn err\\n   435→\\t}\\n   436→\\tentries[basePath+paths.MetadataFileName] = object.TreeEntry{\\n   437→\\t\\tName: basePath + paths.MetadataFileName,\\n   438→\\t\\tMode: filemode.Regular,\\n   439→\\t\\tHash: metadataHash,\\n   440→\\t}\\n   441→\\treturn nil\\n   442→}\\n   443→\\n   444→// findSessionIndex returns the index of an existing session with the given ID,\\n   445→// or the next available index if not found. This prevents duplicate session entries.\\n   446→func (s *GitStore) findSessionIndex(ctx context.Context, basePath string, existingSummary *CheckpointSummary, entries map[string]object.TreeEntry, sessionID string) int {\\n   447→\\tif existingSummary == nil {\\n   448→\\t\\treturn 0\\n   449→\\t}\\n   450→\\tfor i := range len(existingSummary.Sessions) {\\n   451→\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n   452→\\t\\tif entry, exists := entries[path]; exists {\\n   453→\\t\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n   454→\\t\\t\\tif err != nil {\\n   455→\\t\\t\\t\\tlogging.Warn(ctx, \\\"failed to read session metadata during dedup check\\\",\\n   456→\\t\\t\\t\\t\\tslog.Int(\\\"session_index\\\", i),\\n   457→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   458→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   459→\\t\\t\\t\\t)\\n   460→\\t\\t\\t\\tcontinue\\n   461→\\t\\t\\t}\\n   462→\\t\\t\\tif meta.SessionID == sessionID {\\n   463→\\t\\t\\t\\treturn i\\n   464→\\t\\t\\t}\\n   465→\\t\\t}\\n   466→\\t}\\n   467→\\treturn len(existingSummary.Sessions)\\n   468→}\\n   469→\\n   470→// reaggregateFromEntries reads all session metadata from the entries map and\\n   471→// reaggregates CheckpointsCount, FilesTouched, and TokenUsage.\\n   472→func (s *GitStore) reaggregateFromEntries(basePath string, sessionCount int, entries map[string]object.TreeEntry) (int, []string, *agent.TokenUsage, error) {\\n   473→\\tvar totalCount int\\n   474→\\tvar allFiles []string\\n   475→\\tvar totalTokens *agent.TokenUsage\\n   476→\\n   477→\\tfor i := range sessionCount {\\n   478→\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n   479→\\t\\tentry, exists := entries[path]\\n   480→\\t\\tif !exists {\\n   481→\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"session %d metadata not found at %s\\\", i, path)\\n   482→\\t\\t}\\n   483→\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n   484→\\t\\tif err != nil {\\n   485→\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"failed to read session %d metadata: %w\\\", i, err)\\n   486→\\t\\t}\\n   487→\\t\\ttotalCount += meta.CheckpointsCount\\n   488→\\t\\tallFiles = mergeFilesTouched(allFiles, meta.FilesTouched)\\n   489→\\t\\ttotalTokens = aggregateTokenUsage(totalTokens, meta.TokenUsage)\\n   490→\\t}\\n   491→\\n   492→\\treturn totalCount, allFiles, totalTokens, nil\\n   493→}\\n   494→\\n   495→// readJSONFromBlob reads JSON from a blob hash and decodes it to the given type.\\n   496→func readJSONFromBlob[T any](repo *git.Repository, hash plumbing.Hash) (*T, error) {\\n   497→\\tblob, err := repo.BlobObject(hash)\\n   498→\\tif err != nil {\\n   499→\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob: %w\\\", err)\\n   500→\\t}\\n   501→\\n   502→\\treader, err := blob.Reader()\\n   503→\\tif err != nil {\\n   504→\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob reader: %w\\\", err)\\n   505→\\t}\\n   506→\\tdefer reader.Close()\\n   507→\\n   508→\\tvar result T\\n   509→\\tif err := json.NewDecoder(reader).Decode(&result); err != nil {\\n   510→\\t\\treturn nil, fmt.Errorf(\\\"failed to decode: %w\\\", err)\\n   511→\\t}\\n   512→\\n   513→\\treturn &result, nil\\n   514→}\\n   515→\\n   516→// readSummaryFromBlob reads CheckpointSummary from a blob hash.\\n   517→func (s *GitStore) readSummaryFromBlob(hash plumbing.Hash) (*CheckpointSummary, error) {\\n   518→\\treturn readJSONFromBlob[CheckpointSummary](s.repo, hash)\\n   519→}\\n   520→\\n   521→// aggregateTokenUsage sums two TokenUsage structs.\\n   522→// Returns nil if both inputs are nil.\\n   523→func aggregateTokenUsage(a, b *agent.TokenUsage) *agent.TokenUsage {\\n   524→\\tif a == nil && b == nil {\\n   525→\\t\\treturn nil\\n   526→\\t}\\n   527→\\tresult := &agent.TokenUsage{}\\n   528→\\tif a != nil {\\n   529→\\t\\tresult.InputTokens = a.InputTokens\\n   530→\\t\\tresult.CacheCreationTokens = a.CacheCreationTokens\\n   531→\\t\\tresult.CacheReadTokens = a.CacheReadTokens\\n   532→\\t\\tresult.OutputTokens = a.OutputTokens\\n   533→\\t\\tresult.APICallCount = a.APICallCount\\n   534→\\t}\\n   535→\\tif b != nil {\\n   536→\\t\\tresult.InputTokens += b.InputTokens\\n   537→\\t\\tresult.CacheCreationTokens += b.CacheCreationTokens\\n   538→\\t\\tresult.CacheReadTokens += b.CacheReadTokens\\n   539→\\t\\tresult.OutputTokens += b.OutputTokens\\n   540→\\t\\tresult.APICallCount += b.APICallCount\\n   541→\\t}\\n   542→\\treturn result\\n   543→}\\n   544→\\n   545→// writeTranscript writes the transcript file from in-memory content or file path.\\n   546→// If the transcript exceeds MaxChunkSize, it's split into multiple chunk files.\\n   547→func (s *GitStore) writeTranscript(ctx context.Context, opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry) error {\\n   548→\\ttranscript := opts.Transcript\\n   549→\\tif len(transcript) == 0 && opts.TranscriptPath != \\\"\\\" {\\n   550→\\t\\tvar readErr error\\n   551→\\t\\ttranscript, readErr = os.ReadFile(opts.TranscriptPath)\\n   552→\\t\\tif readErr != nil {\\n   553→\\t\\t\\t// Non-fatal: transcript may not exist yet\\n   554→\\t\\t\\ttranscript = nil\\n   555→\\t\\t}\\n   556→\\t}\\n   557→\\tif len(transcript) == 0 {\\n   558→\\t\\treturn nil\\n   559→\\t}\\n   560→\\n   561→\\t// Redact secrets before chunking so content hash reflects redacted content\\n   562→\\ttranscript, err := redact.JSONLBytes(transcript)\\n   563→\\tif err != nil {\\n   564→\\t\\treturn fmt.Errorf(\\\"failed to redact transcript secrets: %w\\\", err)\\n   565→\\t}\\n   566→\\n   567→\\t// Chunk the transcript if it's too large\\n   568→\\tchunks, err := agent.ChunkTranscript(ctx, transcript, opts.Agent)\\n   569→\\tif err != nil {\\n   570→\\t\\treturn fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n   571→\\t}\\n   572→\\n   573→\\t// Write chunk files\\n   574→\\tfor i, chunk := range chunks {\\n   575→\\t\\tchunkPath := basePath + agent.ChunkFileName(paths.TranscriptFileName, i)\\n   576→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, chunk)\\n   577→\\t\\tif err != nil {\\n   578→\\t\\t\\treturn err\\n   579→\\t\\t}\\n   580→\\t\\tentries[chunkPath] = object.TreeEntry{\\n   581→\\t\\t\\tName: chunkPath,\\n   582→\\t\\t\\tMode: filemode.Regular,\\n   583→\\t\\t\\tHash: blobHash,\\n   584→\\t\\t}\\n   585→\\t}\\n   586→\\n   587→\\t// Content hash for deduplication (hash of full transcript)\\n   588→\\tcontentHash := fmt.Sprintf(\\\"sha256:%x\\\", sha256.Sum256(transcript))\\n   589→\\thashBlob, err := CreateBlobFromContent(s.repo, []byte(contentHash))\\n   590→\\tif err != nil {\\n   591→\\t\\treturn err\\n   592→\\t}\\n   593→\\tentries[basePath+paths.ContentHashFileName] = object.TreeEntry{\\n   594→\\t\\tName: basePath + paths.ContentHashFileName,\\n   595→\\t\\tMode: filemode.Regular,\\n   596→\\t\\tHash: hashBlob,\\n   597→\\t}\\n   598→\\treturn nil\\n   599→}\\n   600→\\n   601→// mergeFilesTouched combines two file lists, removing duplicates.\\n   602→func mergeFilesTouched(existing, additional []string) []string {\\n   603→\\tseen := make(map[string]bool)\\n   604→\\tvar result []string\\n   605→\\n   606→\\tfor _, f := range existing {\\n   607→\\t\\tif !seen[f] {\\n   608→\\t\\t\\tseen[f] = true\\n   609→\\t\\t\\tresult = append(result, f)\\n   610→\\t\\t}\\n   611→\\t}\\n   612→\\tfor _, f := range additional {\\n   613→\\t\\tif !seen[f] {\\n   614→\\t\\t\\tseen[f] = true\\n   615→\\t\\t\\tresult = append(result, f)\\n   616→\\t\\t}\\n   617→\\t}\\n   618→\\n   619→\\tsort.Strings(result)\\n   620→\\treturn result\\n   621→}\\n   622→\\n   623→// redactSummary returns a copy of the summary with text fields redacted.\\n   624→// Structural fields (Path, Line, EndLine) are preserved.\\n   625→// NOTE: When adding new text fields to Summary, LearningsSummary, or CodeLearning,\\n   626→// update this function to include them in redaction.\\n   627→func redactSummary(s *Summary) *Summary {\\n   628→\\tif s == nil {\\n   629→\\t\\treturn nil\\n   630→\\t}\\n   631→\\treturn &Summary{\\n   632→\\t\\tIntent:    redact.String(s.Intent),\\n   633→\\t\\tOutcome:   redact.String(s.Outcome),\\n   634→\\t\\tFriction:  redactStringSlice(s.Friction),\\n   635→\\t\\tOpenItems: redactStringSlice(s.OpenItems),\\n   636→\\t\\tLearnings: LearningsSummary{\\n   637→\\t\\t\\tRepo:     redactStringSlice(s.Learnings.Repo),\\n   638→\\t\\t\\tWorkflow: redactStringSlice(s.Learnings.Workflow),\\n   639→\\t\\t\\tCode:     redactCodeLearnings(s.Learnings.Code),\\n   640→\\t\\t},\\n   641→\\t}\\n   642→}\\n   643→\\n   644→// redactStringSlice applies redact.String to each element.\\n   645→func redactStringSlice(ss []string) []string {\\n   646→\\tif ss == nil {\\n   647→\\t\\treturn nil\\n   648→\\t}\\n   649→\\tout := make([]string, len(ss))\\n   650→\\tfor i, s := range ss {\\n   651→\\t\\tout[i] = redact.String(s)\\n   652→\\t}\\n   653→\\treturn out\\n   654→}\\n   655→\\n   656→// redactCodeLearnings redacts only the Finding field, preserving Path/Line/EndLine.\\n   657→func redactCodeLearnings(cls []CodeLearning) []CodeLearning {\\n   658→\\tif cls == nil {\\n   659→\\t\\treturn nil\\n   660→\\t}\\n   661→\\tout := make([]CodeLearning, len(cls))\\n   662→\\tfor i, cl := range cls {\\n   663→\\t\\tout[i] = CodeLearning{\\n   664→\\t\\t\\tPath:    cl.Path,\\n   665→\\t\\t\\tLine:    cl.Line,\\n   666→\\t\\t\\tEndLine: cl.EndLine,\\n   667→\\t\\t\\tFinding: redact.String(cl.Finding),\\n   668→\\t\\t}\\n   669→\\t}\\n   670→\\treturn out\\n   671→}\\n   672→\\n   673→// readMetadataFromBlob reads CommittedMetadata from a blob hash.\\n   674→func (s *GitStore) readMetadataFromBlob(hash plumbing.Hash) (*CommittedMetadata, error) {\\n   675→\\treturn readJSONFromBlob[CommittedMetadata](s.repo, hash)\\n   676→}\\n   677→\\n   678→// buildCommitMessage constructs the commit message with proper trailers.\\n   679→// The commit subject is always \\\"Checkpoint: <id>\\\" for consistency.\\n   680→// If CommitSubject is provided (e.g., for task checkpoints), it's included in the body.\\n   681→func (s *GitStore) buildCommitMessage(opts WriteCommittedOptions, taskMetadataPath string) string {\\n   682→\\tvar commitMsg strings.Builder\\n   683→\\n   684→\\t// Subject line is always the checkpoint ID for consistent formatting\\n   685→\\tfmt.Fprintf(&commitMsg, \\\"Checkpoint: %s\\\\n\\\\n\\\", opts.CheckpointID)\\n   686→\\n   687→\\t// Include custom description in body if provided (e.g., task checkpoint details)\\n   688→\\tif opts.CommitSubject != \\\"\\\" {\\n   689→\\t\\tcommitMsg.WriteString(opts.CommitSubject + \\\"\\\\n\\\\n\\\")\\n   690→\\t}\\n   691→\\tfmt.Fprintf(&commitMsg, \\\"%s: %s\\\\n\\\", trailers.SessionTrailerKey, opts.SessionID)\\n   692→\\tfmt.Fprintf(&commitMsg, \\\"%s: %s\\\\n\\\", trailers.StrategyTrailerKey, opts.Strategy)\\n   693→\\tif opts.Agent != \\\"\\\" {\\n   694→\\t\\tfmt.Fprintf(&commitMsg, \\\"%s: %s\\\\n\\\", trailers.AgentTrailerKey, opts.Agent)\\n   695→\\t}\\n   696→\\tif opts.EphemeralBranch != \\\"\\\" {\\n   697→\\t\\tfmt.Fprintf(&commitMsg, \\\"%s: %s\\\\n\\\", trailers.EphemeralBranchTrailerKey, opts.EphemeralBranch)\\n   698→\\t}\\n   699→\\tif taskMetadataPath != \\\"\\\" {\\n   700→\\t\\tfmt.Fprintf(&commitMsg, \\\"%s: %s\\\\n\\\", trailers.MetadataTaskTrailerKey, taskMetadataPath)\\n   701→\\t}\\n   702→\\n   703→\\treturn commitMsg.String()\\n   704→}\\n   705→\\n   706→// incrementalCheckpointData represents an incremental checkpoint during subagent execution.\\n   707→// This mirrors strategy.SubagentCheckpoint but avoids import cycles.\\n   708→type incrementalCheckpointData struct {\\n   709→\\tType      string          `json:\\\"type\\\"`\\n   710→\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   711→\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n   712→\\tData      json.RawMessage `json:\\\"data\\\"`\\n   713→}\\n   714→\\n   715→// taskCheckpointData represents a final task checkpoint.\\n   716→// This mirrors strategy.TaskCheckpoint but avoids import cycles.\\n   717→type taskCheckpointData struct {\\n   718→\\tSessionID      string `json:\\\"session_id\\\"`\\n   719→\\tToolUseID      string `json:\\\"tool_use_id\\\"`\\n   720→\\tCheckpointUUID string `json:\\\"checkpoint_uuid\\\"`\\n   721→\\tAgentID        string `json:\\\"agent_id,omitempty\\\"`\\n   722→}\\n   723→\\n   724→// ReadCommitted reads a committed checkpoint's summary by ID from the entire/checkpoints/v1 branch.\\n   725→// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n   726→// Use ReadSessionContent to read actual transcript/prompts/context.\\n   727→// Returns nil, nil if the checkpoint doesn't exist.\\n   728→//\\n   729→// The storage format uses numbered subdirectories for each session (0-based):\\n   730→//\\n   731→//\\t<checkpoint-id>/\\n   732→//\\t├── metadata.json      # CheckpointSummary with sessions map\\n   733→//\\t├── 0/                 # First session\\n   734→//\\t│   ├── metadata.json  # Session-specific metadata\\n   735→//\\t│   └── full.jsonl     # Transcript\\n   736→//\\t├── 1/                 # Second session\\n   737→//\\t└── ...\\n   738→func (s *GitStore) ReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error) {\\n   739→\\tif err := ctx.Err(); err != nil {\\n   740→\\t\\treturn nil, err //nolint:wrapcheck // Propagating context cancellation\\n   741→\\t}\\n   742→\\n   743→\\ttree, err := s.getSessionsBranchTree()\\n   744→\\tif err != nil {\\n   745→\\t\\treturn nil, nil //nolint:nilnil,nilerr // No sessions branch means no checkpoint exists\\n   746→\\t}\\n   747→\\n   748→\\tcheckpointPath := checkpointID.Path()\\n   749→\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n   750→\\tif err != nil {\\n   751→\\t\\treturn nil, nil //nolint:nilnil,nilerr // Checkpoint directory not found\\n   752→\\t}\\n   753→\\n   754→\\t// Read root metadata.json as CheckpointSummary\\n   755→\\tmetadataFile, err := checkpointTree.File(paths.Metadat