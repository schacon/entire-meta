ring the session (e.g., \\\"claude-sonnet-4-20250514\\\")\\n   375→\\tModel string `json:\\\"model,omitempty\\\"`\\n   376→\\n   377→\\t// TurnID correlates checkpoints from the same agent turn.\\n   378→\\t// When a turn's work spans multiple commits, each gets its own checkpoint\\n   379→\\t// but they share the same TurnID for future aggregation/deduplication.\\n   380→\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n   381→\\n   382→\\t// Task checkpoint fields (only populated for task checkpoints)\\n   383→\\tIsTask    bool   `json:\\\"is_task,omitempty\\\"`\\n   384→\\tToolUseID string `json:\\\"tool_use_id,omitempty\\\"`\\n   385→\\n   386→\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n   387→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"` // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n   388→\\tCheckpointTranscriptStart   int    `json:\\\"checkpoint_transcript_start,omitempty\\\"`    // Transcript line offset at start of this checkpoint's data\\n   389→\\n   390→\\t// Deprecated: Use CheckpointTranscriptStart instead. Written for backward compatibility with older CLI versions.\\n   391→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   392→\\n   393→\\t// Token usage for this checkpoint\\n   394→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   395→\\n   396→\\t// SessionMetrics contains hook-provided session metrics (duration, turns, context usage).\\n   397→\\t// Populated for agents that provide these metrics via hooks (e.g., Cursor).\\n   398→\\tSessionMetrics *SessionMetrics `json:\\\"session_metrics,omitempty\\\"`\\n   399→\\n   400→\\t// AI-generated summary of the checkpoint\\n   401→\\tSummary *Summary `json:\\\"summary,omitempty\\\"`\\n   402→\\n   403→\\t// InitialAttribution is line-level attribution calculated at commit time\\n   404→\\tInitialAttribution *InitialAttribution `json:\\\"initial_attribution,omitempty\\\"`\\n   405→}\\n   406→\\n   407→// GetTranscriptStart returns the transcript line offset at which this checkpoint's data begins.\\n   408→// Returns 0 for new checkpoints (start from beginning). For data written by older CLI versions,\\n   409→// falls back to the deprecated TranscriptLinesAtStart field.\\n   410→func (m CommittedMetadata) GetTranscriptStart() int {\\n   411→\\tif m.CheckpointTranscriptStart > 0 {\\n   412→\\t\\treturn m.CheckpointTranscriptStart\\n   413→\\t}\\n   414→\\treturn m.TranscriptLinesAtStart\\n   415→}\\n   416→\\n   417→// SessionFilePaths contains the absolute paths to session files from the git tree root.\\n   418→// Paths include the full checkpoint path prefix (e.g., \\\"/a1/b2c3d4e5f6/1/metadata.json\\\").\\n   419→// Used in CheckpointSummary.Sessions to map session IDs to their file locations.\\n   420→type SessionFilePaths struct {\\n   421→\\tMetadata    string `json:\\\"metadata\\\"`\\n   422→\\tTranscript  string `json:\\\"transcript\\\"`\\n   423→\\tContentHash string `json:\\\"content_hash\\\"`\\n   424→\\tPrompt      string `json:\\\"prompt\\\"`\\n   425→}\\n   426→\\n   427→// CheckpointSummary is the root-level metadata.json for a checkpoint.\\n   428→// It contains aggregated statistics from all sessions and a map of session IDs\\n   429→// to their file paths. Session-specific data (including initial_attribution)\\n   430→// is stored in the session's subdirectory metadata.json.\\n   431→//\\n   432→// Structure on entire/checkpoints/v1 branch:\\n   433→//\\n   434→//\\t<checkpoint-id[:2]>/<checkpoint-id[2:]>/\\n   435→//\\t├── metadata.json         # This CheckpointSummary\\n   436→//\\t├── 1/                    # First session\\n   437→//\\t│   ├── metadata.json     # Session-specific CommittedMetadata\\n   438→//\\t│   ├── full.jsonl\\n   439→//\\t│   ├── prompt.txt\\n   440→//\\t│   └── content_hash.txt\\n   441→//\\t├── 2/                    # Second