e\":\"tool_result\",\"content\":\"  1779→func (s *ManualCommitStrategy) InitializeSession(ctx context.Context, sessionID string, agentType types.AgentType, transcriptPath string, userPrompt string, model string) error {\\n  1780→\\trepo, err := OpenRepository(ctx)\\n  1781→\\tif err != nil {\\n  1782→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n  1783→\\t}\\n  1784→\\n  1785→\\t// Check if session already exists\\n  1786→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n  1787→\\tif err != nil {\\n  1788→\\t\\treturn fmt.Errorf(\\\"failed to check session state: %w\\\", err)\\n  1789→\\t}\\n  1790→\\n  1791→\\tif state != nil && state.BaseCommit != \\\"\\\" {\\n  1792→\\t\\t// Session is fully initialized — apply phase transition for TurnStart.\\n  1793→\\t\\tif transErr := TransitionAndLog(ctx, state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1794→\\t\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"hooks\\\"), \\\"turn start transition failed\\\",\\n  1795→\\t\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n  1796→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n  1797→\\t\\t}\\n  1798→\\n  1799→\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n  1800→\\t\\tturnID, err := id.Generate()\\n  1801→\\t\\tif err != nil {\\n  1802→\\t\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n  1803→\\t\\t}\\n  1804→\\t\\tstate.TurnID = turnID.String()\\n  1805→\\n  1806→\\t\\t// Set AgentType from hook context if not yet set\\n  1807→\\t\\tif state.AgentType == \\\"\\\" && agentType != \\\"\\\" {\\n  1808→\\t\\t\\tstate.AgentType = agentType\\n  1809→\\t\\t}\\n  1810→\\n  1811→\\t\\t// Update ModelName if provided (model can change between turns)\\n  1812→\\t\\tif model != \\\"\\\" {\\n  1813→\\t\\t\\tstate.ModelName = model\\n  1814→\\t\\t}\\n  1815→\\n  1816→\\t\\t// Update LastPrompt on every turn so condensa