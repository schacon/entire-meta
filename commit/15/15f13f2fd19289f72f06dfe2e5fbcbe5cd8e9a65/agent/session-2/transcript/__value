<id>.json\\n    12→\\n    13→// Message type constants for Gemini transcripts\\n    14→const (\\n    15→\\tMessageTypeUser   = \\\"user\\\"\\n    16→\\tMessageTypeGemini = \\\"gemini\\\"\\n    17→)\\n    18→\\n    19→// GeminiTranscript represents the top-level structure of a Gemini session file\\n    20→type GeminiTranscript struct {\\n    21→\\tMessages []GeminiMessage `json:\\\"messages\\\"`\\n    22→}\\n    23→\\n    24→// GeminiMessage represents a single message in the transcript\\n    25→type GeminiMessage struct {\\n    26→\\tID        string           `json:\\\"id,omitempty\\\"` // UUID for the message\\n    27→\\tType      string           `json:\\\"type\\\"`         // MessageTypeUser or MessageTypeGemini\\n    28→\\tContent   string           `json:\\\"content,omitempty\\\"`\\n    29→\\tToolCalls []GeminiToolCall `json:\\\"toolCalls,omitempty\\\"`\\n    30→}\\n    31→\\n    32→// UnmarshalJSON handles both string and array content formats in Gemini transcripts.\\n    33→// User messages use: \\\"content\\\": [{\\\"text\\\": \\\"...\\\"}] (array of objects)\\n    34→// Gemini messages use: \\\"content\\\": \\\"response text\\\" (string)\\n    35→func (m *GeminiMessage) UnmarshalJSON(data []byte) error {\\n    36→\\t// Use an alias to avoid infinite recursion\\n    37→\\ttype Alias GeminiMessage\\n    38→\\taux := &struct {\\n    39→\\t\\t*Alias\\n    40→\\n    41→\\t\\tContent json.RawMessage `json:\\\"content,omitempty\\\"`\\n    42→\\t}{\\n    43→\\t\\tAlias: (*Alias)(m),\\n    44→\\t}\\n    45→\\n    46→\\tif err := json.Unmarshal(data, aux); err != nil {\\n    47→\\t\\treturn fmt.Errorf(\\\"failed to unmarshal message: %w\\\", err)\\n    48→\\t}\\n    49→\\n    50→\\tif len(aux.Content) == 0 || string(aux.Content) == \\\"null\\\" {\\n    51→\\t\\tm.Content = \\\"\\\"\\n    52→\\t\\treturn nil\\n    53→\\t}\\n    54→\\n    55→\\t// Try string first (most common for gemini messages)\\n    56→\\tvar strContent string\\n    57→\\tif err := json.Unmarshal(aux.Content, &strContent); err == nil {\\n    58→\\t\\tm.Content = strContent\\n    59→\\t\\treturn nil\\n    60→\\t}\\n    61→\\n    62→\\t// Try array of objects with \\\"text\\\" fields (user messages)\\n    63→\\tvar parts []struct {\\n    64→\\t\\tText string `json:\\\"text\\\"`\\n    65→\\t}\\n    66→\\tif err := json.Unmarshal(aux.Content, &parts); err == nil {\\n    67→\\t\\tvar texts []string\\n    68→\\t\\tfor _, p := range parts {\\n    69→\\t\\t\\tif p.Text != \\\"\\\" {\\n    70→\\t\\t\\t\\ttexts = append(texts, p.Text)\\n    71→\\t\\t\\t}\\n    72→\\t\\t}\\n    73→\\t\\tm.Content = strings.Join(texts, \\\"\\\\n\\\")\\n    74→\\t\\treturn nil\\n    75→\\t}\\n    76→\\n    77→\\t// Unknown format - leave content empty\\n    78→\\treturn nil\\n    79→}\\n    80→\\n    81→// GeminiToolCall represents a tool call in a gemini message\\n    82→type GeminiToolCall struct {\\n    83→\\tID     string                 `json:\\\"id\\\"`\\n    84→\\tName   string                 `json:\\\"name\\\"`\\n    85→\\tArgs   map[string]interface{} `json:\\\"args\\\"`\\n    86→\\tStatus string                 `json:\\\"status,omitempty\\\"`\\n    87→}\\n    88→\\n    89→// ParseTranscript parses raw JSON content into a transcript structure\\n    90→func ParseTranscript(data []byte) (*GeminiTranscript, error) {\\n    91→\\tvar transcript GeminiTranscript\\n    92→\\tif err := json.Unmarshal(data, &transcript); err != nil {\\n    93→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    94→\\t}\\n    95→\\treturn &transcript, nil\\n    96→}\\n    97→\\n    98→// ExtractModifiedFiles extracts files modified by tool calls from transcript data\\n    99→func ExtractModifiedFiles(data []byte) ([]string, error) {\\n   100→\\ttranscript, err := ParseTranscript(data)\\n   101→\\tif err != nil {\\n   102→\\t\\treturn nil, err\\n   103→\\t}\\n   104→\\n   105→\\treturn ExtractModifiedFilesFromTranscript(transcript), nil\\n   106→}\\n   107→\\n   108→// ExtractMo