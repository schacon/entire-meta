  591→\\t)\\n   592→\\treturn nil\\n   593→}\\n   594→\\n   595→// PostCommit is called by the git post-commit hook after a commit is created.\\n   596→// Uses the session state machine to determine what action to take per session:\\n   597→//   - ACTIVE → condense immediately (each commit gets its own checkpoint)\\n   598→//   - IDLE → condense immediately\\n   599→//   - ENDED → condense if files touched, discard if empty\\n   600→//\\n   601→// After condensation for ACTIVE sessions, remaining uncommitted files are\\n   602→// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n   603→//\\n   604→// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n   605→// and were condensed during this PostCommit.\\n   606→\\n   607→// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n   608→// Each session in the loop gets its own handler with per-session context.\\n   609→// Handler methods use the *State parameter from ApplyTransition (same pointer\\n   610→// as the state being transitioned) rather than capturing state separately.\\n   611→type postCommitActionHandler struct {\\n   612→\\ts                      *ManualCommitStrategy\\n   613→\\tctx                    context.Context\\n   614→\\trepo                   *git.Repository\\n   615→\\tcheckpointID           id.CheckpointID\\n   616→\\thead                   *plumbing.Reference\\n   617→\\tcommit                 *object.Commit\\n   618→\\tnewHead                string\\n   619→\\trepoDir                string\\n   620→\\tshadowBranchName       string\\n   621→\\tshadowBranchesToDelete map[string]struct{}\\n   622→\\tcommittedFileSet       map[string]struct{}\\n   623→\\thasNew                 bool\\n   624→\\tfilesTouchedBefore     []string\\n   625→\\n   626→\\t// Cached git objects — resolved once per PostCommit invocation to avoid\\n   627→\\t// redundant reads across filesOverlapWithContent, filesWithRemainingAgentChanges,\\n   628→\\t// CondenseSession, and calculateSessionAttributions.\\n   629→\\theadTree   *object.Tree        // HEAD commit tree (shared across all sessions)\\n   630→\\tparentTree *object.Tree        // HEAD's first parent tree (shared, nil for initial commits)\\n   631→\\tshadowRef  *plumbing.Reference // Per-session shadow branch ref (nil if branch doesn't exist)\\n   632→\\tshadowTree *object.Tree        // Per-session shadow commit tree (nil if branch doesn't exist)\\n   633→\\n   634→\\t// Output: set by handler methods, read by caller after TransitionAndLog.\\n   635→\\tcondensed bool\\n   636→}\\n   637→\\n   638→func (h *postCommitActionHandler) HandleCondense(state *session.State) error {\\n   639→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   640→\\tshouldCondense := h.shouldCondenseWithOverlapCheck(state.Phase.IsActive(), state.LastInteractionTime)\\n   641→\\n   642→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondense decision\\\",\\n   643→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   644→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   645→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   646→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   647→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   648→\\t)\\n   649→\\n   650→\\tif shouldCondense {\\n   651→\\t\\th.condensed = h.s.condenseAndUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   652→\\t\\t\\tshadowRef:      h.shadowRef,\\n   653→\\t\\t\\theadTree:       h.headTree,\\n   654→\\t\\t\\trepoDir:        h.repoDir,\\n   655→\\t\\t\\theadCommitHash: h.newHead,\\n   656→\\t\\t})\\n   657→\\t} else {\\n   658→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   659→\\t}\\n   660→\\treturn nil\\n   661→}\\n   662→\\n   663→func (h *postCommitActionHandler) HandleCondenseIfFilesTouched(state *session.State) error {\\n   664→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   665→\\tshouldCondense := len(state.FilesTouched) > 0 && h.shouldCondenseWithOverlapCheck(state.Phase.IsActive(), state.LastInteractionTime)\\n   666→\\n   667→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondenseIfFilesTouched decision\\\",\\n   668→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   669→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   670→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   671→\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n   672→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   673→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   674→\\t)\\n   675→\\n   676→\\tif shouldCondense {\\n   677→\\t\\th.condensed = h.s.condenseAndUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   678→\\t\\t\\tshadowRef:      h.shadowRef,\\n   679→\\t\\t\\theadTree:       h.headTree,\\n   680→\\t\\t\\trepoDir:        h.repoDir,\\n   681→\\t\\t\\theadCommitHash: h.newHead,\\n   682→\\t\\t})\\n   683→\\t} else {\\n   684→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   685→\\t}\\n   686→\\treturn nil\\n   687→}\\n   688→\\n   689→// shouldCondenseWithOverlapCheck returns true if the session should be condensed\\n   690→// into this commit. Active sessions with recent interaction always condense\\n   691→// (bypasses overlap check). Stale ACTIVE and IDLE/ENDED sessions require\\n   692→// file overlap evidence between tracked files and committed files.\\n   693→func (h *postCommitActionHandler) shouldCondenseWithOverlapCheck(isActive bool, lastInteraction *time.Time) bool {\\n   694→\\tif !h.hasNew {\\n   695→\\t\\treturn false\\n   696→\\t}\\n   697→\\t// ACTIVE sessions with recent interaction: skip the overlap check.\\n   698→\\t// PrepareCommitMsg already validated this commit is session-related\\n   699→\\t// (added trailer). The overlap check is only meaningful when we need\\n   700→\\t// heuristic evidence that a commit was related to the session.\\n   701→\\t//\\n   702→\\t// We check LastInteractionTime to avoid condensing stale ACTIVE sessions\\n   703→\\t// (agent killed without Stop hook) into every subsequent commit. A stale\\n   704→\\t// session has no recent interaction and falls through to the overlap check.\\n   705→\\tif isActive && isRecentInteraction(lastInteraction) {\\n   706→\\t\\treturn true\\n   707→\\t}\\n   708→\\tif len(h.filesTouchedBefore) == 0 {\\n   709→\\t\\treturn false // No files tracked = no overlap evidence\\n   710→\\t}\\n   711→\\t// Only check files that were actually changed in this commit.\\n   712→\\t// Without this, files that exist in the tree but weren't changed\\n   713→\\t// would pass the \\\"modified file\\\" check in filesOverlapWithContent\\n   714→\\t// (because the file exists in the parent tree), causing stale\\n   715→\\t// sessions to be incorrectly condensed.\\n   716→\\tvar committedTouchedFiles []string\\n   717→\\tfor _, f := range h.filesTouchedBefore {\\n   718→\\t\\tif _, ok := h.committedFileSet[f]; ok {\\n   719→\\t\\t\\tcommittedTouchedFiles = append(committedTouchedFiles, f)\\n   720→\\t\\t}\\n   721→\\t}\\n   722→\\tif len(committedTouchedFiles) == 0 {\\n   723→\\t\\treturn false\\n   724→\\t}\\n   725→\\treturn filesOverlapWithContent(h.ctx, h.repo, h.shadowBranchName, h.commit, committedTouchedFiles, overlapOpts{\\n   726→\\t\\theadTree:      h.headTree,\\n   727→\\t\\tshadowTree:    h.shadowTree,\\n   728→\\t\\tparentTree:    h.parentTree,\\n   729→\\t\\thasParentTree: true,\\n   730→\\t})\\n   731→}\\n   732→\\n   733→// activeSessionInteractionThreshold is the maximum age of LastInteractionTime\\n   734→// for an ACTIVE session to be considered genuinely active. 24h is generous\\n   735→// because LastInteractionTime only updates at TurnStart, not per-tool-call.\\n   736→const activeSessionInteractionThreshold = 24 * time.Hour\\n   737→\\n   738→// isRecentInteraction returns true if lastInteraction is non-nil and within\\n   739→// activeSessionInteractionThreshold of now.\\n   740→func isRecentInteraction(lastInteraction *time.Time) bool {\\n   741→\\treturn lastInteraction != nil && time.Since(*lastInteraction) < activeSessionInteractionThreshold\\n   742→}\\n   743→\\n   744→func (h *postCommitActionHandler) HandleDiscardIfNoFiles(state *session.State) error {\\n   745→\\tif len(state.FilesTouched) == 0 {\\n   746→\\t\\tlogging.Debug(logging.WithComponent(h.ctx, \\\"checkpoint\\\"), \\\"post-commit: skipping empty ended session (no files to condense)\\\",\\n   747→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   748→\\t\\t)\\n   749→\\t}\\n   750→\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   751→\\treturn nil\\n   752→}\\n   753→\\n   754→func (h *postCommitActionHandler) HandleWarnStaleSession(_ *session.State) error {\\n   755→\\t// Not produced by EventGitCommit; no-op for exhaustiveness.\\n   756→\\treturn nil\\n   757→}\\n   758→\\n   759→// During rebase/cherry-pick/revert operations, phase transitions are skipped entirely.\\n   760→//\\n   761→\\n   762→func (s *ManualCommitStrategy) PostCommit(ctx context.Context) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   763→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   764→\\n   765→\\t_, openRepoSpan := perf.Start(ctx, \\\"open_repository_and_head\\\")\\n   766→\\trepo, err := OpenRepository(ctx)\\n   767→\\tif err != nil {\\n   768→\\t\\topenRepoSpan.RecordError(err)\\n   769→\\t\\topenRepoSpan.End()\\n   770→\\t\\treturn nil\\n   771→\\t}\\n   772→\\n   773→\\t// Get HEAD commit to check for trailer\\n   774→\\thead, err := repo.Head()\\n   775→\\tif err != nil {\\n   776→\\t\\topenRepoSpan.RecordError(err)\\n   777→\\t\\topenRepoSpan.End()\\n   778→\\t\\treturn nil\\n   779→\\t}\\n   780→\\n   781→\\tcommit, err := repo.CommitObject(head.Hash())\\n   782→\\tif err != nil {\\n   783→\\t\\topenRepoSpan.RecordError(err)\\n   784→\\t\\topenRepoSpan.End()\\n   785→\\t\\treturn nil\\n   786→\\t}\\n   787→\\n   788→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   789→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   790→\\topenRepoSpan.End()\\n   791→\\n   792→\\tif !found {\\n   793→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   794→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   795→\\t\\ts.postCommitUpdateBaseCommitOnly(ctx, head)\\n   796→\\t\\treturn nil\\n   797→\\t}\\n   798→\\n   799→\\t_, findSessionsSpan := perf.Start(ctx, \\\"find_sessions_for_worktree\\\")\\n   800→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   801→\\tif err != nil {\\n   802→\\t\\tfindSessionsSpan.RecordError(err)\\n   803→\\t\\tfindSessionsSpan.End()\\n   804→\\t\\treturn nil\\n   805→\\t}\\n   806→\\n   807→\\t// Find all active sessions for this worktree\\n   808→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   809→\\tfindSessionsSpan.RecordError(err)\\n   810→\\tfindSessionsSpan.End()\\n   811→\\n   812→\\tif err != nil || len(sessions) == 0 {\\n   813→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   814→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   815→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   816→\\t\\t)\\n   817→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   818→\\t}\\n   819→\\n   820→\\t// Build transition context\\n   821→\\tisRebase := isGitSequenceOperation(ctx)\\n   822→\\ttransitionCtx := session.TransitionContext{\\n   823→\\t\\tIsRebaseInProgress: isRebase,\\n   824→\\t}\\n   825→\\n   826→\\tif isRebase {\\n   827→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   828→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   829→\\t\\t)\\n   830→\\t}\\n   831→\\n   832→\\t// Track shadow branch names and whether they can be deleted\\n   833→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   834→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   835→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   836→\\n   837→\\tnewHead := head.Hash().String()\\n   838→\\n   839→\\t// Pre-resolve HEAD tree and parent tree once for the entire PostCommit.\\n   840→\\t// These are immutable within this hook invocation and used by multiple\\n   841→\\t// per-session functions (filesOverlapWithContent, filesWithRemainingAgentChanges,\\n   842→\\t// calculateSessionAttributions).\\n   843→\\t_, resolveTreesSpan := perf.Start(ctx, \\\"resolve_commit_trees\\\")\\n   844→\\tvar headTree *object.Tree\\n   845→\\tif t, err := commit.Tree(); err == nil {\\n   846→\\t\\theadTree = t\\n   847→\\t}\\n   848→\\tvar parentTree *object.Tree\\n   849→\\tif commit.NumParents() > 0 {\\n   850→\\t\\tif parent, err := commit.Parent(0); err == nil {\\n   851→\\t\\t\\tif t, err := parent.Tree(); err == nil {\\n   852→\\t\\t\\t\\tparentTree = t\\n   853→\\t\\t\\t}\\n   854→\\t\\t}\\n   855→\\t}\\n   856→\\n   857→\\tcommittedFileSet := filesChangedInCommit(ctx, worktreePath, commit, headTree, parentTree)\\n   858→\\tresolveTreesSpan.End()\\n   859→\\n   860→\\tfor _, state := range sessions {\\n   861→\\t\\t// Skip fully-condensed ended sessions — no work remains.\\n   862→\\t\\t// These sessions only persist for LastCheckpointID (amend trailer reuse).\\n   863→\\t\\tif state.FullyCondensed && state.Phase == session.PhaseEnded {\\n   864→\\t\\t\\tcontinue\\n   865→\\t\\t}\\n   866→\\t\\ts.postCommitProcessSession(ctx, repo, state, &transitionCtx, checkpointID,\\n   867→\\t\\t\\thead, commit, newHead, worktreePath, headTree, parentTree, committedFileSet,\\n   868→\\t\\t\\tshadowBranchesToDelete, uncondensedActiveOnBranch)\\n   869→\\t}\\n   870→\\n   871→\\t// Clean up shadow branches — only delete when ALL sessions on the branch are non-active\\n   872→\\t// or were condensed during this PostCommit.\\n   873→\\t_, cleanupBranchesSpan := perf.Start(ctx, \\\"cleanup_shadow_branches\\\")\\n   874→\\tfor shadowBranchName := range shadowBranchesToDelete {\\n   875→\\t\\tif uncondensedActiveOnBranch[shadowBranchName] {\\n   876→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: preserving shadow branch (active session exists)\\\",\\n   877→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   878→\\t\\t\\t)\\n   879→\\t\\t\\tcontinue\\n   880→\\t\\t}\\n   881→\\t\\tif err := deleteShadowBranch(ctx, repo, shadowBranchName); err != nil {\\n   882→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to clean up shadow branch\\\",\\n   883→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   884→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   885→\\t\\t} else {\\n   886→\\t\\t\\tlogging.Info(logCtx, \\\"shadow branch deleted\\\",\\n   887→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   888→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   889→\\t\\t\\t)\\n   890→\\t\\t}\\n   891→\\t}\\n   892→\\tcleanupBranchesSpan.End()\\n   893→\\n   894→\\treturn nil\\n   895→}\\n   896→\\n   897→// postCommitProcessSession handles a single session within the PostCommit loop.\\n   898→// Pre-resolved git objects (headTree, parentTree) are shared across all sessions;\\n   899→// per-session shadow ref/tree are resolved once here and threaded through sub-calls.\\n   900→func (s *ManualCommitStrategy) postCommitProcessSession(\\n   901→\\tctx context.Context,\\n   902→\\trepo *git.Repository,\\n   903→\\tstate *SessionState,\\n   904→\\ttransitionCtx *session.TransitionContext,\\n   905→\\tcheckpointID id.CheckpointID,\\n   906→\\thead *plumbing.Reference,\\n   907→\\tco