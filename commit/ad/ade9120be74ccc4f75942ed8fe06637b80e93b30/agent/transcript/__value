01→\\t// For amend, HEAD^ is the commit being amended, and HEAD is where we are now.\\n   502→\\t// We need to match sessions whose BaseCommit equals HEAD (the commit being amended\\n   503→\\t// was created from this base). This prevents stale sessions from injecting\\n   504→\\t// unrelated checkpoint IDs.\\n   505→\\trepo, repoErr := OpenRepository(ctx)\\n   506→\\tif repoErr != nil {\\n   507→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   508→\\t}\\n   509→\\thead, headErr := repo.Head()\\n   510→\\tif headErr != nil {\\n   511→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   512→\\t}\\n   513→\\tcurrentHead := head.Hash().String()\\n   514→\\n   515→\\t// Find first matching session with LastCheckpointID to restore.\\n   516→\\t// LastCheckpointID is set after condensation completes.\\n   517→\\tfor _, state := range sessions {\\n   518→\\t\\tif state.BaseCommit != currentHead {\\n   519→\\t\\t\\tcontinue\\n   520→\\t\\t}\\n   521→\\t\\tif state.LastCheckpointID.IsEmpty() {\\n   522→\\t\\t\\tcontinue\\n   523→\\t\\t}\\n   524→\\t\\tcpID := state.LastCheckpointID\\n   525→\\t\\tsource := \\\"LastCheckpointID\\\"\\n   526→\\n   527→\\t\\t// Restore the trailer\\n   528→\\t\\tmessage = addCheckpointTrailer(message, cpID)\\n   529→\\t\\tif writeErr := os.WriteFile(commitMsgFile, []byte(message), 0o600); writeErr != nil {\\n   530→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   531→\\t\\t}\\n   532→\\n   533→\\t\\tlogging.Info(logCtx, \\\"prepare-commit-msg: restored trailer on amend\\\",\\n   534→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   535→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   536→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   537→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   538→\\t\\t)\\n   539→\\t\\treturn nil\\n   540→\\t}\\n   541→\\n   542→\\t// No checkpoint ID found - leave message unchanged\\n   543→\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend with no checkpoint to restore\\\",\\n   544→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   545→\\t)\\n   546→\\treturn nil\\n   547→}\\n   548→\\n   549→// PostCommit is called by the git post-commit hook after a commit is created.\\n   550→// Uses the session state machine to determine what action to take per session:\\n   551→//   - ACTIVE → condense immediately (each commit gets its own checkpoint)\\n   552→//   - IDLE → condense immediately\\n   553→//   - ENDED → condense if files touched, discard if empty\\n   554→//\\n   555→// After condensation for ACTIVE sessions, remaining uncommitted files are\\n   556→// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n   557→//\\n   558→// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n   559→// and were condensed during this PostCommit.\\n   560→\\n   561→// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n   562→// Each session in the loop gets its own handler with per-session context.\\n   563→// Handler methods use the *State parameter from ApplyTransition (same pointer\\n   564→// as the state being transitioned) rather than capturing state separately.\\n   565→type postCommitActionHandler struct {\\n   566→\\ts                      *ManualCommitStrategy\\n   567→\\tctx                    context.Context\\n   568→\\trepo                   *git.Repository\\n   569→\\tcheckpointID           id.CheckpointID\\n   570→\\thead                   *plumbing.Reference\\n   571→\\tcommit                 *object.Commit\\n   572→\\tnewHead                string\\n   573→\\tshadowBranchName       string\\n   574→\\tshadowBranchesToDelete map[string]struct{}\\n   575→\\tcommittedFileSet       map[string]struct{}\\n   576→\\thasNew                 bool\\n   577→\\tfilesTouchedBefore     []string\\n   578→\\n   579→\\t// Cached git objects — resolved once per PostCommit invocation to avoid\\n   580→\\t// redundant reads across filesOverlapWithContent, filesWithRemainingAgentChanges,\\n   581→\\t// CondenseSession, and calculateSessionAttributions.\\n   582→\\theadTree   *object.Tree        // HEAD commit tree (shared across all sessions)\\n   583→\\tparentTree *object.Tree        // HEAD's first parent tree (shared, nil for initial commits)\\n   584→\\tshadowRef  *plumbing.Reference // Per-session shadow branch ref (nil if branch doesn't exist)\\n   585→\\tshadowTree *object.Tree        // Per-session shadow commit tree (nil if branch doesn't exist)\\n   586→\\n   587→\\t// Output: set by handler methods, read by caller after TransitionAndLog.\\n   588→\\tcondensed bool\\n   589→}\\n   590→\\n   591→func (h *postCommitActionHandler) HandleCondense(state *session.State) error {\\n   592→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   593→\\tshouldCondense := h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   594→\\n   595→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondense decision\\\",\\n   596→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   597→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   598→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   599→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   600→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   601→\\t)\\n   602→\\n   603→\\tif shouldCondense {\\n   604→\\t\\th.condensed = h.s.condenseAndUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   605→\\t\\t\\tshadowRef: h.shadowRef,\\n   606→\\t\\t\\theadTree:  h.headTree,\\n   607→\\t\\t})\\n   608→\\t} else {\\n   609→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   610→\\t}\\n   611→\\treturn nil\\n   612→}\\n   613→\\n   614→func (h *postCommitActionHandler) HandleCondenseIfFilesTouched(state *session.State) error {\\n   615→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   616→\\tshouldCondense := len(state.FilesTouched) > 0 && h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   617→\\n   618→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondenseIfFilesTouched decision\\\",\\n   619→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   620→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   621→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   622→\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n   623→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   624→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   625→\\t)\\n   626→\\n   627→\\tif shouldCondense {\\n   628→\\t\\th.condensed = h.s.condenseAndUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   629→\\t\\t\\tshadowRef: h.shadowRef,\\n   630→\\t\\t\\theadTree:  h.headTree,\\n   631→\\t\\t})\\n   632→\\t} else {\\n   633→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   634→\\t}\\n   635→\\treturn nil\\n   636→}\\n   637→\\n   638→// shouldCondenseWithOverlapCheck returns true if the session should be condensed\\n   639→// into this commit. Requires both that hasNew is true AND that the session's files\\n   640→// overlap with the committed files with matching content.\\n   641→//\\n   642→// This prevents stale sessions (ACTIVE sessions where the agent was killed, or\\n   643→// ENDED/IDLE sessions with carry-forward files) from being condensed into every\\n   644→// unrelated commit.\\n   645→//\\n   646→// filesTouchedBefore is populated from:\\n   647→//   - state.FilesTouched for IDLE/ENDED sessions (set via SaveStep/SaveTaskStep -> mergeFilesTouched)\\n   648→//   - transcript extraction for ACTIVE sessions when FilesTouched is empty\\n   649→//\\n   650→// When filesTouchedBefore is empty:\\n   651→//   - For ACTIVE sessions: fail-open (tr