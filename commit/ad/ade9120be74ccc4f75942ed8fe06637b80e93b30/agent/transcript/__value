115→\\t\\tlogging.Debug(logging.WithComponent(ctx, \\\"manual-commit\\\"),\\n  1116→\\t\\t\\t\\\"filterSessionsWithNewContent: getStagedFiles failed, skipping overlap checks\\\",\\n  1117→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1118→\\t\\t)\\n  1119→\\t\\tstagedFiles = nil\\n  1120→\\t}\\n  1121→\\n  1122→\\tfor _, state := range sessions {\\n  1123→\\t\\t// Skip fully-condensed ended sessions — no new content possible.\\n  1124→\\t\\tif state.FullyCondensed && state.Phase == session.PhaseEnded {\\n  1125→\\t\\t\\tcontinue\\n  1126→\\t\\t}\\n  1127→\\t\\thasNew, err := s.sessionHasNewContent(ctx, repo, state, contentCheckOpts{stagedFiles: stagedFiles})\\n  1128→\\t\\tif err != nil {\\n  1129→\\t\\t\\t// On error, include the session (fail open for hooks)\\n  1130→\\t\\t\\tresult = append(result, state)\\n  1131→\\t\\t\\tcontinue\\n  1132→\\t\\t}\\n  1133→\\t\\tif hasNew {\\n  1134→\\t\\t\\tresult = append(result, state)\\n  1135→\\t\\t}\\n  1136→\\t}\\n  1137→\\n  1138→\\treturn result\\n  1139→}\\n  1140→\\n  1141→// contentCheckOpts holds pre-computed values for sessionHasNewContent to avoid\\n  1142→// redundant work across multiple sessions in a single hook invocation.\\n  1143→type contentCheckOpts struct {\\n  1144→\\t// stagedFiles is the pre-computed list of staged files (from getStagedFiles).\\n  1145→\\t// nil means staged files are unavailable (error or PostCommit context where\\n  1146→\\t// files are already committed) — callers skip overlap checks and fall through\\n  1147→\\t// to other heuristics (e.g., transcript growth).\\n  1148→\\t// Non-nil empty means successfully resolved but no files are staged.\\n  1149→\\tstagedFiles []string\\n  1150→\\n  1151→\\t// shadowTree, when non-nil, is used directly to avoid redundant shadow branch\\n  1152→\\t// resolution (the shadow ref/commit/tree were already resolved by the caller).\\n  1153→\\tshadowTree *object.Tree\\n  1154→}\\n  1155→\\n  1156→// sessionHasNewContent checks if a session has