> 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   570→\\t\\tallLines = allLines[:len(allLines)-1]\\n   571→\\t}\\n   572→\\treturn len(allLines)\\n   573→}\\n   574→\\n   575→// extractCheckpointPrompts extracts user prompts from only the checkpoint portion of a transcript.\\n   576→// For JSONL agents (Claude Code, Cursor), checkpointStart is a line offset.\\n   577→// For JSON agents (Gemini, OpenCode), checkpointStart is a message index.\\n   578→func extractCheckpointPrompts(agentType types.AgentType, fullTranscript []byte, checkpointStart int) []string {\\n   579→\\tif len(fullTranscript) == 0 {\\n   580→\\t\\treturn nil\\n   581→\\t}\\n   582→\\n   583→\\t// Scope the transcript to the checkpoint portion\\n   584→\\tvar scoped []byte\\n   585→\\tswitch agentType {\\n   586→\\tcase agent.AgentTypeGemini:\\n   587→\\t\\tvar err error\\n   588→\\t\\tscoped, err = geminicli.SliceFromMessage(fullTranscript, checkpointStart)\\n   589→\\t\\tif err != nil {\\n   590→\\t\\t\\tscoped = fullTranscript // fallback to full on error\\n   591→\\t\\t}\\n   592→\\tcase agent.AgentTypeOpenCode:\\n   593→\\t\\tvar err error\\n   594→\\t\\tscoped, err = opencode.SliceFromMessage(fullTranscript, checkpointStart)\\n   595→\\t\\tif err != nil {\\n   596→\\t\\t\\tscoped = fullTranscript // fallback to full on error\\n   597→\\t\\t}\\n   598→\\tdefault:\\n   599→\\t\\t// Claude Code, Cursor, Unknown — JSONL line offset\\n   600→\\t\\tscoped = transcript.SliceFromLine(fullTranscript, checkpointStart)\"}]},\"uuid\":\"bc62d9a1-e94a-4c1a-b483-65ec61e0af2a\",\"timestamp\":\"2026-03-03T00:43:04.719Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand how prompt.txt is stored on shadow branches and how it's read during condensation.\\n\\nSpecifically:\\n1. How is prompt.txt written to the shadow branch? Search for where prompt.txt is created/written in the strategy package, particularly in SaveStep and related functions. Look for `P