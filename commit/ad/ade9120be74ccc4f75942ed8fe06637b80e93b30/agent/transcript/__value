seCommitIfChanged(h.ctx, state, h.newHead)\\n   691→\\treturn nil\\n   692→}\\n   693→\\n   694→func (h *postCommitActionHandler) HandleWarnStaleSession(_ *session.State) error {\\n   695→\\t// Not produced by EventGitCommit; no-op for exhaustiveness.\\n   696→\\treturn nil\\n   697→}\\n   698→\\n   699→// During rebase/cherry-pick/revert operations, phase transitions are skipped entirely.\\n   700→//\\n   701→\\n   702→func (s *ManualCommitStrategy) PostCommit(ctx context.Context) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   703→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   704→\\n   705→\\trepo, err := OpenRepository(ctx)\\n   706→\\tif err != nil {\\n   707→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   708→\\t}\\n   709→\\n   710→\\t// Get HEAD commit to check for trailer\\n   711→\\thead, err := repo.Head()\\n   712→\\tif err != nil {\\n   713→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   714→\\t}\\n   715→\\n   716→\\tcommit, err := repo.CommitObject(head.Hash())\\n   717→\\tif err != nil {\\n   718→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   719→\\t}\\n   720→\\n   721→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   722→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   723→\\tif !found {\\n   724→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   725→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   726→\\t\\ts.postCommitUpdateBaseCommitOnly(ctx, head)\\n   727→\\t\\treturn nil\\n   728→\\t}\\n   729→\\n   730→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   731→\\tif err != nil {\\n   732→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   733→\\t}\\n   734→\\n   735→\\t// Find all active sessions for this worktree\\n   736→\\tsessions, err := s.findSessionsForWork