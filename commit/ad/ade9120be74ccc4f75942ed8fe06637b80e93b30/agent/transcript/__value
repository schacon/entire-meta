\t\\t\\t}\\n   778→\\t\\t}\\n   779→\\t}\\n   780→\\n   781→\\tcommittedFileSet := filesChangedInCommit(commit, headTree, parentTree)\\n   782→\\n   783→\\tfor _, state := range sessions {\\n   784→\\t\\t// Skip fully-condensed ended sessions — no work remains.\\n   785→\\t\\t// These sessions only persist for LastCheckpointID (amend trailer reuse).\\n   786→\\t\\tif state.FullyCondensed && state.Phase == session.PhaseEnded {\\n   787→\\t\\t\\tcontinue\\n   788→\\t\\t}\\n   789→\\t\\ts.postCommitProcessSession(ctx, repo, state, &transitionCtx, checkpointID,\\n   790→\\t\\t\\thead, commit, newHead, headTree, parentTree, committedFileSet,\\n   791→\\t\\t\\tshadowBranchesToDelete, uncondensedActiveOnBranch)\\n   792→\\t}\\n   793→\\n   794→\\t// Clean up shadow branches — only delete when ALL sessions on the branch are non-active\\n   795→\\t// or were condensed during this PostCommit.\\n   796→\\tfor shadowBranchName := range shadowBranchesToDelete {\\n   797→\\t\\tif uncondensedActiveOnBranch[shadowBranchName] {\\n   798→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: preserving shadow branch (active session exists)\\\",\\n   799→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   800→\\t\\t\\t)\\n   801→\\t\\t\\tcontinue\\n   802→\\t\\t}\\n   803→\\t\\tif err := deleteShadowBranch(ctx, repo, shadowBranchName); err != nil {\\n   804→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to clean up shadow branch\\\",\\n   805→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   806→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   807→\\t\\t} else {\\n   808→\\t\\t\\tlogging.Info(logCtx, \\\"shadow branch deleted\\\",\\n   809→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   810→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   811→\\t\\t\\t)\\n   812→\\t\\t}\\n   813→\\t}\\n   814→\\n   815→\\treturn nil\\n   816→}\\n   817→\\n   818→// postCommitProcessSession handles a single session within the PostCommit loop.\\n   819→// Pre-resolved git objects (headTree, parentTree) are shared across all sessions;\\n   820→// per-session shadow ref/tree are resolved once here and threaded through sub-calls.\\n   821→func (s *ManualCommitStrategy) postCommitProcessSession(\\n   822→\\tctx context.Context,\\n   823→\\trepo *git.Repository,\\n   824→\\tstate *SessionState,\\n   825→\\ttransitionCtx *session.TransitionContext,\\n   826→\\tcheckpointID id.CheckpointID,\\n   827→\\thead *plumbing.Reference,\\n   828→\\tcommit *object.Commit,\\n   829→\\tnewHead string,\\n   830→\\theadTree, parentTree *object.Tree,\\n   831→\\tcommittedFileSet map[string]struct{},\\n   832→\\tshadowBranchesToDelete map[string]struct{},\\n   833→\\tuncondensedActiveOnBranch map[string]bool,\\n   834→) {\\n   835→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   836→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   837→\\n   838→\\t// Pre-resolve shadow branch ref and tree for this session.\\n   839→\\t// These are read 4+ times across sessionHasNewContent, filesOverlapWithContent,\\n   840→\\t// CondenseSession, filesWithRemainingAgentChanges, and calculateSessionAttributions.\\n   841→\\tvar shadowRef *plumbing.Reference\\n   842→\\tvar shadowTree *object.Tree\\n   843→\\tif ref, refErr := repo.Reference(plumbing.NewBranchReferenceName(shadowBranchName), true); refErr == nil {\\n   844→\\t\\tshadowRef = ref\\n   845→\\t\\tif sc, scErr := repo.CommitObject(ref.Hash()); scErr == nil {\\n   846→\\t\\t\\tif st, stErr := sc.Tree(); stErr == nil {\\n   847→\\t\\t\\t\\tshadowTree = st\\n   848→\\t\\t\\t}\\n   849→\\t\\t}\\n   850→\\t}\\n   851→\\n   852→\\t// Check for new content (needed for TransitionContext and condensation).\\n   853→\\t// Fail-open: if content check errors, assume new content exists so we\\n   854→\\t// don't silently skip data that should have been condensed.\\n   855→\\t//\\n   856→\\t// For ACTIVE sessions: the commit has a checkpoint trailer (verified above),\\n   857→\\t// meaning PrepareCommitMsg already determined this commit is session-related.\\n   858→\\t// The trailer is only added when either:\\n   859→\\t//   - No TTY (agent/subagent committing) — added unconditionally\\n   860→\\t//   - TTY (human committing) — added after content detection confirmed agent work\\n   861→\\t// In both cases, PrepareCommitMsg already validated this commit. We trust\\n   862→\\t// that decision here. Transcript-based re-validation is unreliable because\\n   863→\\t// subagent transcripts may not be available yet (subagent still running).\\n   864→\\tvar hasNew bool\\n   865→\\tif state.Phase.IsActive() {\\n   866→\\t\\thasNew = true\\n   867→\\t} else {\\n   868→\\t\\tvar contentErr error\\n   869→\\t\\thasNew, contentErr = s.sessionHasNewContent(ctx, repo, state, contentCheckOpts{shadowTree: shadowTree})\\n   870→\\t\\tif contentErr != nil {\\n   871→\\t\\t\\thasNew = true\\n   872→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: error checking session content, assuming new content\\\",\\n   873→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   874→\\t\\t\\t\\tslog.String(\\\"error\\\", contentErr.Error()),\\n   875→\\t\\t\\t)\\n   876→\\t\\t}\\n   877→\\t}\\n   878→\\ttransitionCtx.HasFilesTouched = len(state.FilesTouched) > 0\\n   879→\\n   880→\\t// Save FilesTouched BEFORE TransitionAndLog — the handler's condensation\\n   881→\\t// clears it, but we need the original list for carry-forward computation.\\n   882→\\t// For mid-session commits (ACTIVE, no shadow branch), state.FilesTouched may be empty\\n   883→\\t// because no SaveStep/Stop has been called yet. Extract files from transcript.\\n   884→\\tfilesTouchedBefore := make([]string, len(state.FilesTouched))\\n   885→\\tcopy(filesTouchedBefore, state.FilesTouched)\\n   886→\\tif len(filesTouchedBefore) == 0 && state.Phase.IsActive() && state.TranscriptPath != \\\"\\\" {\\n   887→\\t\\tfilesTouchedBefore = s.extractFilesFromLiveTranscript(ctx, state)\\n   888→\\t}\\n   889→\\n   890→\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward prep\\\",\\n   891→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   892→\\t\\tslog.Bool(\\\"is_active\\\", state.Phase.IsActive()),\\n   893→\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n   894→\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   895→\\t\\tslog.Any(\\\"files\\\", filesTouchedBefore),\\n   896→\\t)\\n   897→\\n   898→\\t// Run the state machine transition with handler for strategy-specific actions.\\n   899→\\thandler := &postCommitActionHandler{\\n   900→\\t\\ts:                      s,\\n   901→\\t\\tctx:                    ctx,\\n   902→\\t\\trepo:                   repo,\\n   903→\\t\\tcheckpointID:           checkpointID,\\n   904→\\t\\thead:                   head,\\n   905→\\t\\tcommit:                 commit,\\n   906→\\t\\tnewHead:                newHead,\\n   907→\\t\\tshadowBranchName:       shadowBranchName,\\n   908→\\t\\tshadowBranchesToDelete: shadowBranchesToDelete,\\n   909→\\t\\tcommittedFileSet:       committedFileSet,\\n   910→\\t\\thasNew:                 hasNew,\\n   911→\\t\\tfilesTouchedBefore:     filesTouchedBefore,\\n   912→\\t\\theadTree:               headTree,\\n   913→\\t\\tparentTree:             parentTree,\\n   914→\\t\\tshadowRef:              shadowRef,\\n   915→\\t\\tshadowTree:             shadowTree,\\n   916→\\t}\\n   917→\\n   918→\\tif err := TransitionAndLog(ctx, state, session.EventGitCommit, *transitionCtx, handler); err != nil {\\n   919→\\t\\tlogging.Warn(logCtx, \\\"post-commit action handler error\\\",\\n   920→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   921→\\t}\\n   922→\\n   923→\\t// Record checkpoint ID for ACTIVE sessions so HandleTurnEnd can finalize\\n   924→\\t// with full transcript. IDLE/ENDED sessions already have complete transcripts.\\n   925→\\t// NOTE: This check runs AFTER TransitionAndLog updated the phase. It relies on\\n   926→\\t// ACTIVE + GitCommit → ACTIVE (phase stays ACTIVE). If that state machine\\n   927→\\t// transition ever changed, this guard would silently stop recording IDs.\\n   928→\\tif handler.condensed && state.Phase.IsActive() {\\n   929→\\t\\tstate.TurnCheckpointIDs = append(state.TurnCheckpointIDs, checkpointID.String())\\n   930→\\t}\\n   931→\\n   932→\\t// Carry forward remaining uncommitted files so the next commit gets its\\n   933→\\t// own checkpoint ID. This applies to ALL phases — if a user splits their\\n   934→\\t// commit across two `git commit` invocations, each gets a 1:1 checkpoint.\\n   935→\\t// Uses content-aware comparison: if user did `git add -p` and committed\\n   936→\\t// partial changes, the file still has remaining agent changes to carry forward.\\n   937→\\tif handler.condensed {\\n   938→\\t\\tremainingFiles := filesWithRemainingAgentChanges(ctx, repo, shadowBranchName, commit, filesTouchedBefore, committedFileSet, overlapOpts{\\n   939→\\t\\t\\theadTree:   headTree,\\n   940→\\t\\t\\tshadowTree: shadowTree,\\n   941→\\t\\t})\\n   942→\\t\\tstate.FilesTouched = remainingFiles\\n   943→\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward decision (content-aware)\\\",\\n   944→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   945→\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   946→\\t\\t\\tslog.Int(\\\"committed_files\\\", len(committedFileSet)),\\n   947→\\t\\t\\tslog.Int(\\\"remaining_files\\\", len(remainingFiles)),\\n   948→\\t\\t\\tslog.Any(\\\"remaining\\\", remainingFiles),\\n   949→\\t\\t\\tslog.Any(\\\"committed_files\\\", committedFileSet),\\n   950→\\t\\t)\\n   951→\\t\\tif len(remainingFiles) > 0 {\\n   952→\\t\\t\\ts.carryForwardToNewShadowBranch(ctx, repo, state, remainingFiles)\\n   953→\\t\\t}\\n   954→\\t}\\n   955→\\n   956→\\t// Mark ENDED sessions as fully condensed when no carry-forward remains.\\n   957→\\t// PostCommit will skip these sessions entirely on future commits.\\n   958→\\t// They persist only for LastCheckpointID (amend trailer restoration).\\n   959→\\tif handler.condensed && state.Phase == session.PhaseEnded && len(state.FilesTouched) == 0 {\\n   960→\\t\\tstate.FullyCondensed = true\\n   961→\\t}\\n   962→\\n   963→\\t// Save the updated state\\n   964→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   965→\\t\\tlogging.Warn(logCtx, \\\"failed to update session state\\\",\\n   966→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   967→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   968→\\t}\\n   969→\\n   970→\\t// Only preserve shadow branch for active sessions that were NOT condensed.\\n   971→\\t// Condensed sessions already have their data on entire/checkpoints/v1.\\n   972→\\tif state.Phase.IsActive() && !handler.condensed {\\n   973→\\t\\tuncondensedActiveOnBranch[shadowBranchName] = true\\n   974→\\t}\\n   975→}\\n   976→\\n   977→// condenseAndUpdateState runs condensation for a session and updates state afterward.\\n   978→// Returns true if condensation succeeded.\\n   979→func (s *ManualCommitStrategy) condenseAndUpdateState(\\n   980→\\tctx context.Context,\\n   981→\\trepo *git.Repository,\\n   982→\\tcheckpointID id.CheckpointID,\\n   983→\\tstate *SessionState,\\n   984→\\thead *plumbing.Reference,\\n   985→\\tshadowBranchName string,\\n   986→\\tshadowBranchesToDelete map[string]struct{},\\n   987→\\tcommittedFiles map[string]struct{},\\n   988→\\topts ...condenseOpts,\\n   989→) bool {\\n   990→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   991→\\tresult, err := s.CondenseSession(ctx, repo, checkpointID, state, committedFiles, opts...)\\n   992→\\tif err != nil {\\n   993→\\t\\tlogging.Warn(logCtx, \\\"condensation failed\\\",\\n   994→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   995→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   996→\\t\\t)\\n   997→\\t\\treturn false\\n   998→\\t}\\n   999→\\n  1000→\\t// Track this shadow branch for cleanup\\n  1001→\\tshadowBranchesToDelete[shadowBranchName] = struct{}{}\\n  1002→\\n  1003→\\t// Update session state for the new base commit\\n  1004→\\tnewHead := head.Hash().String()\\n  1005→\\tstate.BaseCommit = newHead\\n  1006→\\tstate.AttributionBaseCommit = newHead\\n  1007→\\tstate.StepCount = 0\\n  1008→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n  1009→\\n  1010→\\t// Clear attribution tracking — condensation already used these values\\n  1011→\\tstate.PromptAttributions = nil\\n  1012→\\tstate.PendingPromptAttribution = nil\\n  1013→\\tstate.FilesTouched = nil\\n  1014→\\n  1015→\\t// Save checkpoint ID so subsequent commits can reuse it (e.g., amend restores trailer)\\n  1016→\\tstate.LastCheckpointID = checkpointID\\n  1017→\\n  1018→\\tlogging.Info(logCtx, \\\"session condensed\\\",\\n  1019→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n  1020→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1021→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n  1022→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n  1023→\\t\\tslog.Int(\\\"transcript_lines\\\", result.TotalTranscriptLines),\\n  1024→\\t)\\n  1025→\\n  1026→\\treturn true\\n  1027→}\\n  1028→\\n  1029→// updateBaseCommitIfChanged updates BaseCommit to newHead if it changed.\\n  1030→// Only updates ACTIVE sessions. IDLE/ENDED sessions should NOT have their\\n  1031→// BaseCommit updated, as this would cause them to be incorrectly associated\\n  1032→// with a new shadow branch and potentially condensed on future commits.\\n  1033→func (s *ManualCommitStrategy) updateBaseCommitIfChanged(ctx context.Context, state *SessionState, newHead string) {\\n  1034→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n  1035→\\t// Only update ACTIVE sessions. IDLE/ENDED sessions are kept around for\\n  1036→\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n  1037→\\tif !state.Phase.IsActive() {\\n  1038→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updateBaseCommitIfChanged skipped non-active session\\\",\\n  1039→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1040→\\t\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n  1041→\\t\\t)\\n  1042→\\t\\treturn\\n  1043→\\t}\\n  1044→\\tif state.BaseCommit != newHead {\\n  1045→\\t\\tstate.BaseCommit = newHead\\n  1046→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updated BaseCommit\\\",\\n  1047→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1048→\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n  1049→\\t\\t)\\n  1050→\\t}\\n  1051→}\\n  1052→\\n  1053→// postCommitUpdateBaseCommitOnly updates BaseCommit for all sessions on the current\\n  1054→// worktree when a commit has no Entire-Checkpoint trailer. This prevents BaseCommit\\n  1055→// from going stale, which would cause future PrepareCommitMsg calls to skip the\\n  1056→// session (BaseCommit != currentHeadHash filter).\\n  1057→//\\n  1058→// Unlike the full PostCommit flow, this does NOT fire EventGitCommit or trigger\\n  1059→// condensation — it only keeps BaseCommit in sync with HEAD.\\n  1060→func (s *ManualCommitStrategy) postCommitUpdateBaseCommitOnly(ctx context.Context, head *plumbing.Reference) {\\n  1061→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n  1062→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n  1063→\\tif err != nil {\\n  1064→\\t\\treturn // Silent failure — hooks must be resilient\\n  1065→\\t}\\n  1066→\\n  1067→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n  1068→\\tif err != nil || len(sessions) == 0 {\\n  1069→\\t\\treturn\\n  1070→\\t}\\n  1071→\\n  1072→\\tnewHead := head.Hash().String()\\n  1073→\\tfor _, state := range sessions {\\n  1074→\\t\\t// Only update active sessions. Idle/ended sessions are kept around for\\n  1075→\\t\\t// LastCheckpointID reuse and should not be