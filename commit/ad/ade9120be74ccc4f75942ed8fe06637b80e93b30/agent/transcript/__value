ates this session has been condensed and has no remaining\\n   119→\\t// carry-forward files. PostCommit skips fully-condensed sessions entirely.\\n   120→\\t// Set after successful condensation when no files remain for carry-forward\\n   121→\\t// and the session phase is ENDED. Cleared on session reactivation (ENDED →\\n   122→\\t// ACTIVE via TurnStart, or ENDED → IDLE via SessionStart) by ActionClearEndedAt.\\n   123→\\tFullyCondensed bool `json:\\\"fully_condensed,omitempty\\\"`\\n   124→\\n   125→\\t// AgentType identifies the agent that created this session (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\", \\\"Cursor\\\")\\n   126→\\tAgentType types.AgentType `json:\\\"agent_type,omitempty\\\"`\\n   127→\\n   128→\\t// Token usage tracking (accumulated across all checkpoints in this session)\\n   129→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   130→\\n   131→\\t// Deprecated: TranscriptLinesAtStart is replaced by CheckpointTranscriptStart.\\n   132→\\t// Kept for backward compatibility with existing state files.\\n   133→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   134→\\n   135→\\t// TranscriptIdentifierAtStart is the last transcript identifier when the session started.\\n   136→\\t// Used for identifier-based transcript scoping (UUID for Claude, message ID for Gemini).\\n   137→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"`\\n   138→\\n   139→\\t// TranscriptPath is the path to the live transcript file (for mid-session commit detection)\\n   140→\\tTranscriptPath string `json:\\\"transcript_path,omitempty\\\"`\\n   141→\\n   142→\\t// FirstPrompt is the first user prompt that started this session (truncated for display)\\n   143→\\tFirstPrompt string `json:\\\"first_prompt,omitempty\\\"`\\n   144→\\n   145→\\t// PromptAttributions tracks user and agent line changes at each prompt start.\\n   146→\\t// This enables accurate attribution by capturing user edits between checkpoints.\\n   147→\\tPromptAttributions []PromptAttribution `json:\\\"prompt_attributions,omitempty\\\"`\\n   148→\\n   149→\\t// PendingPromptAttribution holds attribution calculated at prompt start (before agent runs).\\n   150→\\t// This is moved to PromptAttributions when SaveStep is called.\\n   151→\\tPendingPromptAttribution *PromptAttribution `json:\\\"pending_prompt_attribution,omitempty\\\"`\\n   152→}\\n   153→\\n   154→// PromptAttribution captures line-level attribution data at the start of each prompt.\\n   155→// By recording what changed since the last checkpoint BEFORE the agent works,\\n   156→// we can accurately separate user edits from agent contributions.\\n   157→type PromptAttribution struct {\\n   158→\\t// CheckpointNumber is which checkpoint this was recorded before (1-indexed)\\n   159→\\tCheckpointNumber int `json:\\\"checkpoint_number\\\"`\\n   160→\\n   161→\\t// UserLinesAdded is lines added by user since the last checkpoint\\n   162→\\tUserLinesAdded int `json:\\\"user_lines_added\\\"`\\n   163→\\n   164→\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   165→\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   166→\\n   167→\\t// AgentLinesAdded is total agent lines added so far (base → last checkpoint).\\n   168→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   169→\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   170→\\n   171→\\t// AgentLinesRemoved is total agent lines removed so far (base → last checkpoint).\\n   172→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   173→\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   174→\\n   175→\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   176→\\t// This enables distinguishing user self-modifications from agent modifications.\\n   177→\\t// See docs/architecture/attribution.md for details.\\n   178→\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   179→}\\n   180→\\n   181→// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   182→// Call this after deserializing a State from JSON.\\n   183→func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   184→\\t// Normalize legacy phase values. \\\"active_committed\\\" was removed with the\\n   185→\\t// 1:1 checkpoint model in favor of the state machine handling commits\\n   186→\\t// during ACTIVE phase with immediate condensation.\\n   187→\\tif s.Phase == \\\"active_committed\\\" {\\n   188→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   189→\\t\\tlogging.Info(logCtx, \\\"migrating legacy active_committed phase to active\\\",\\n   190→\\t\\t\\tslog.String(\\\"session_id\\\", s.SessionID),\\n   191→\\t\\t)\\n   192→\\t\\ts.Phase = PhaseActive\\n   193→\\t}\\n   194→\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n   195→\\ts.Phase = PhaseFromString(string(s.Phase))\\n   196→\\n   197→\\t// Migrate transcript fields: CheckpointTranscriptStart replaces both\\n   198→\\t// CondensedTranscriptLines and TranscriptLinesAtStart from older state files.\\n   199→\\tif s.CheckpointTranscriptStart == 0 {\\n   200→\\t\\tif s.CondensedTranscriptLines > 0 {\\n   201→\\t\\t\\ts.CheckpointTranscriptStart = s.CondensedTranscriptLines\\n   202→\\t\\t} else if s.TranscriptLinesAtStart > 0 {\\n   203→\\t\\t\\ts.CheckpointTranscriptStart = s.TranscriptLinesAtStart\\n   204→\\t\\t}\\n   205→\\t}\\n   206→\\t// Clear deprecated fields so they aren't re-persisted.\\n   207→\\t// Note: this is a one-way migration. If the state is re-saved, older CLI versions\\n   208→\\t// will see 0 for these fields and fall back to scoping from the transcript start.\\n   209→\\t// This is acceptable since CLI upgrades are monotonic and the worst case is\\n   210→\\t// redundant transcript content in a condensation, not data loss.\\n   211→\\ts.CondensedTranscriptLines = 0\\n   212→\\ts.TranscriptLinesAtStart = 0\\n   213→\\n   214→\\t// Backfill AttributionBaseCommit for sessions created before this field existed.\\n   215→\\t// Without this, a mid-turn commit would migrate BaseCommit and the fallback in\\n   216→\\t// calculateSessionAttributions would use the migrated value, producing zero attribution.\\n   217→\\tif s.AttributionBaseCommit == \\\"\\\" && s.BaseCommit != \\\"\\\" {\\n   218→\\t\\ts.AttributionBaseCommit = s.BaseCommit\\n   219→\\t}\\n   220→}\\n   221→\\n   222→// IsStale returns true when the last time a session saw interaction exceeds StaleSessionThreshold.\\n   223→// If LastInteractionTime isn't set, we don't consider a session stale to avoid aggressively\\n   224→// deleting things.\\n   225→func (s *State) IsStale() bool {\\n   226→\\treturn s.LastInteractionTime != nil && time.Since(*s.LastInteractionTime) > StaleSessionThreshold\\n   227→}\\n   228→\\n   229→// StateStore provides low-level operations for managing session state files.\\n   230→//\\n   231→// StateStore is a primitive for session state persistence. It is NOT the same as\\n   232→// the Sessions interface - it only handles state files in .git/entire-sessions/,\\n   233→// not the full session data which includes checkpoint content.\\n   234→//\\n   235→// Use StateStore directly in strategies for performance-critical state operations.\\n   236→// Use the Sessions interface (when implemented) for high-level session management.\\n   237→type StateStore struct {\\n   238→\\t// stateDir is the directory where session state files are stored\\n   239→\\tstateDir string\\n   240→}\\n   241→\\n   242→// NewStateStore creates a new state store.\\n   243→// Uses the git common dir to store session state (shared across worktrees).\\n   244→func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   245→\\tcommonDir, err := getGitCommonDir(ctx)\\n   246→\\tif err != nil {\\n   247→\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   248→\\t}\\n   249→\\treturn &StateStore{\\n   250→\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   251→\\t}, nil\\n   252→}\\n   253→\\n   254→// NewStateStoreWithDir creates a new state store with a custom directory.\\n   255→// This is useful for testing.\\n   256→func NewStateStoreWithDir(stateDir string) *StateStore {\\n   257→\\treturn &StateStore{stateDir: stateDir}\\n   258→}\\n   259→\\n   260→// Load loads the session state for the given session ID.\\n   261→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   262→// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   263→func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   264→\\t// Validate session ID to prevent path traversal\\n   265→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   266→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   267→\\t}\\n   268→\\n   269→\\tstateFile := s.stateFilePath(sessionID)\\n   270→\\n   271→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is derived from sessionID\\n   272→\\tif os.IsNotExist(err) {\\n   273→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   274→\\t}\\n   275→\\tif err != nil {\\n   276→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   277→\\t}\\n   278→\\n   279→\\tvar state State\\n   280→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   281→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal session state: %w\\\", err)\\n   282→\\t}\\n   283→\\tstate.NormalizeAfterLoad(ctx)\\n   284→\\n   285→\\tif state.IsStale() {\\n   286→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   287→\\t\\tlogging.Debug(logCtx, \\\"deleting stale session state\\\",\\n   288→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   289→\\t\\t)\\n   290→\\t\\t_ = s.Clear(ctx, sessionID) //nolint:errcheck // best-effort cleanup of stale session\\n   291→\\t\\treturn nil, nil             //nolint:nilnil // stale session treated as not found\\n   292→\\t}\\n   293→\\n   294→\\treturn &state, nil\\n   295→}\\n   296→\\n   297→// Save saves the session state atomically.\\n   298→func (s *StateStore) Save(ctx context.Context, state *State) error {\\n   299→\\t_ = ctx // Reserved for future use\\n   300→\\n   301→\\t// Validate session ID to prevent path traversal\\n   302→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n   303→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   304→\\t}\\n   305→\\n   306→\\tif err := os.MkdirAll(s.stateDir, 0o750); err != nil {\\n   307→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   308→\\t}\\n   309→\\n   310→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   311→\\tif err != nil {\\n   312→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   313→\\t}\\n   314→\\n   315→\\tstateFile := s.stateFilePath(state.SessionID)\\n   316→\\n   317→\\t// Atomic write: write to temp file, then rename\\n   318→\\ttmpFile := stateFile + \\\".tmp\\\"\\n   319→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n   320→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   321→\\t}\\n   322→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n   323→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n   324→\\t}\\n   325→\\treturn nil\\n   326→}\\n   327→\\n   328→// Clear removes the session state file for the given session ID.\\n   329→func (s *StateStore) Clear(ctx context.Context, sessionID string) error {\\n   330→\\t_ = ctx // Reserved for future use\\n   331→\\n   332→\\t// Validate session ID to prevent path traversal\\n   333→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   334→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   335→\\t}\\n   336→\\n   337→\\tstateFile := s.stateFilePath(sessionID)\\n   338→\\n   339→\\tif err := os.Remove(stateFile); err != nil {\\n   340→\\t\\tif os.IsNotExist(err) {\\n   341→\\t\\t\\treturn nil // Already gone, not an error\\n   342→\\t\\t}\\n   343→\\t\\treturn fmt.Errorf(\\\"failed to remove session state file: %w\\\", err)\\n   344→\\t}\\n   345→\\treturn nil\\n   346→}\\n   347→\\n   348→// RemoveAll removes the entire session state directory.\\n   349→// This is used during uninstall to completely remove all session state.\\n   350→func (s *StateStore) RemoveAll() error {\\n   351→\\tif err := os.RemoveAll(s.stateDir); err != nil {\\n   352→\\t\\treturn fmt.Errorf(\\\"failed to remove session state directory: %w\\\", err)\\n   353→\\t}\\n   354→\\treturn nil\\n   355→}\\n   356→\\n   357→// List returns all session states.\\n   358→func (s *StateStore) List(ctx context.Context) ([]*State, error) {\\n   359→\\tentries, err := os.ReadDir(s.stateDir)\\n   360→\\tif os.IsNotExist(err) {\\n   361→\\t\\treturn nil, nil\\n   362→\\t}\\n   363→\\tif err != nil {\\n   364→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state directory: %w\\\", err)\\n   365→\\t}\\n   366→\\n   367→\\tvar states []*State\\n   368→\\tfor _, entry := range entries {\\n   369→\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   370→\\t\\t\\tcontinue\\n   371→\\t\\t}\\n   372→\\t\\tif strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   373→\\t\\t\\tcontinue // Skip temp files\\n   374→\\t\\t}\\n   375→\\n   376→\\t\\tsessionID := strings.TrimSuffix(entry.Name(), \\\".json\\\")\\n   377→\\t\\tstate, err := s.Load(ctx, sessionID)\\n   378→\\t\\tif err != nil {\\n   379→\\t\\t\\tcontinue // Skip corrupted state files\\n   380→\\t\\t}\\n   381→\\t\\tif state == nil {\\n   382→\\t\\t\\tcontinue // Not found or stale (Load handles cleanup)\\n   383→\\t\\t}\\n   384→\\n   385→\\t\\tstates = append(states, state)\\n   386→\\t}\\n   387→\\treturn states, nil\\n   388→}\\n   389→\\n   390→// stateFilePath returns the path to a session state file.\\n   391→func (s *StateStore) stateFilePath(sessionID string) string {\\n   392→\\treturn filepath.Join(s.stateDir, sessionID+\\\".json\\\")\\n   393→}\\n   394→\\n   395→// gitCommonDirCache caches the git common dir to avoid repeated subprocess calls.\\n   396→// Keyed by working directory to handle directory changes (same pattern as paths.WorktreeRoot).\\n   397→var (\\n   398→\\tgitCommonDirMu       sync.RWMutex\\n   399→\\tgitCommonDirCache    string\\n   400→\\tgitCommonDirCacheDir string\\n   401→)\\n   402→\\n   403→// ClearGitCommonDirCache clears the cached git common dir.\\n   404→// Useful for testing when changing directories.\\n   405→func ClearGitCommonDirCache() {\\n   406→\\tgitCommonDirMu.Lock()\\n   407→\\tgitCommonDirCache = \\\"\\\"\\n   408→\\tgitCommonDirCacheDir = \\\"\\\"\\n   409→\\tgitCommonDirMu.Unlock()\\n   410→}\\n   411→\\n   412→// getGitCommonDir returns the path to the shared git directory.\\n   413→// In a regular checkout, this is .git/\\n   414→// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n   415→// The result is cached per working directory.\\n   416→func getGitCommonDir(ctx context.Context) (string, error) {\\n   417→\\tcwd, err := os.Getwd() //nolint:forbidigo // used for cache key, not git-relative paths\\n   418→\\tif err != nil {\\n   419→\\t\\tcwd = \\\"\\\"\\n   420→\\t}\\n   421→\\n   422→\\t// Check cache with read lock first\\n   423→\\tgitCommonDirMu.RLock()\\n   424→\\tif gitCommonDirCache != \\\"\\\" && gitCommonDirCacheDir == cwd {\\n   425→\\t\\tcached := gitCommonDirCache\\n   426→\\t\\tgitCommonDirMu.RUnlock()\\n   427→\\t\\treturn cached, nil\\n   428→\\t}\\n   429→\\tgitCommonDirMu.RUnlock()\\n   430→\\n   431→\\t// Cache mis