e.Contents(); contentErr == nil {\\n   453→\\t\\t\\t\\tfullTranscript = content\\n   454→\\t\\t\\t}\\n   455→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   456→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   457→\\t\\t\\t\\tfullTranscript = content\\n   458→\\t\\t\\t}\\n   459→\\t\\t}\\n   460→\\t}\\n   461→\\n   462→\\t// Process transcript based on agent type\\n   463→\\tif fullTranscript != \\\"\\\" {\\n   464→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   465→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   466→\\t\\t// Use the turn prompt from session state when available — this ensures mid-turn\\n   467→\\t\\t// commits always have the correct prompt even after CheckpointTranscriptStart advances\\n   468→\\t\\t// past where the prompt lives in the transcript.\\n   469→\\t\\tif turnPrompt != \\\"\\\" {\\n   470→\\t\\t\\tdata.Prompts = []string{turnPrompt}\\n   471→\\t\\t} else {\\n   472→\\t\\t\\tdata.Prompts = extractCheckpointPrompts(agentType, data.Transcript, checkpointTranscriptStart)\\n   473→\\t\\t}\\n   474→\\t}\\n   475→\\n   476→\\t// Use tracked files from session state (not all files in tree)\\n   477→\\tdata.FilesTouched = filesTouched\\n   478→\\n   479→\\t// Calculate token usage from the extracted transcript portion\\n   480→\\tif len(data.Transcript) > 0 {\\n   481→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ctx, ag, data.Transcript, checkpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   482→\\t}\\n   483→\\n   484→\\treturn data, nil\\n   485→}\\n   486→\\n   487→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   488→// This is used for mid-session commits where no shadow branch exists yet.\\n   489→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(ctx context.Context, state *SessionStat