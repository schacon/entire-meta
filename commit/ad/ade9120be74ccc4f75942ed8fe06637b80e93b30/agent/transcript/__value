new tree hash matches the last checkpoint's tree hash, the checkpoint\\n    56→// is skipped to avoid duplicate commits (deduplication).\\n    57→func (s *GitStore) WriteTemporary(ctx context.Context, opts WriteTemporaryOptions) (WriteTemporaryResult, error) {\\n    58→\\t// Validate base commit - required for shadow branch naming\\n    59→\\tif opts.BaseCommit == \\\"\\\" {\\n    60→\\t\\treturn WriteTemporaryResult{}, errors.New(\\\"BaseCommit is required for temporary checkpoint\\\")\\n    61→\\t}\\n    62→\\n    63→\\t// Validate session ID to prevent path traversal\\n    64→\\tif err := validation.ValidateSessionID(opts.SessionID); err != nil {\\n    65→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"invalid temporary checkpoint options: %w\\\", err)\\n    66→\\t}\\n    67→\\n    68→\\t// Get shadow branch name\\n    69→\\tshadowBranchName := ShadowBranchNameForCommit(opts.BaseCommit, opts.WorktreeID)\\n    70→\\n    71→\\t// Get or create shadow branch\\n    72→\\tparentHash, baseTreeHash, err := s.getOrCreateShadowBranch(shadowBranchName)\\n    73→\\tif err != nil {\\n    74→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to get shadow branch: %w\\\", err)\\n    75→\\t}\\n    76→\\n    77→\\t// Get the last checkpoint's tree hash for deduplication\\n    78→\\tvar lastTreeHash plumbing.Hash\\n    79→\\tif parentHash != plumbing.ZeroHash {\\n    80→\\t\\tif lastCommit, err := s.repo.CommitObject(parentHash); err == nil {\\n    81→\\t\\t\\tlastTreeHash = lastCommit.TreeHash\\n    82→\\t\\t}\\n    83→\\t}\\n    84→\\n    85→\\t// Collect all files to include\\n    86→\\tvar allFiles []string\\n    87→\\tvar allDeletedFiles []string\\n    88→\\tif opts.IsFirstCheckpoint {\\n    89→\\t\\t// For the first checkpoint, capture all changed files (modified tracked + untracked)\\n    90→\\t\\t// using `git status --porcelain -z` which respects both repo and global .gitignore.\\n    91→\\t\\t// This is much faster than filesystem walk. The base tree from HEAD already contains\\n    92→\\t\\t// all unchanged tracked files. We also capture user's pre-existing deletions.\\n    93→\\t\\tresult, err := collectChangedFiles(ctx, s.repo)\\n    94→\\t\\tif err != nil {\\n    95→\\t\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to collect changed files: %w\\\", err)\\n    96→\\t\\t}\\n    97→\\t\\tallFiles = result.Changed\\n    98→\\t\\t// Merge user's pre-existing deletions with agent's deletions\\n    99→\\t\\tallDeletedFiles = result.Deleted\\n   100→\\t\\tallDeletedFiles = append(allDeletedFiles, opts.DeletedFiles...)\\n   101→\\t} else {\\n   102→\\t\\t// For subsequent checkpoints, only include modified/new files\\n   103→\\t\\tallFiles = make([]string, 0, len(opts.ModifiedFiles)+len(opts.NewFiles))\\n   104→\\t\\tallFiles = append(allFiles, opts.ModifiedFiles...)\\n   105→\\t\\tallFiles = append(allFiles, opts.NewFiles...)\\n   106→\\t\\tallDeletedFiles = opts.DeletedFiles\\n   107→\\t}\\n   108→\\n   109→\\t// Build tree with changes\\n   110→\\ttreeHash, err := s.buildTreeWithChanges(ctx, baseTreeHash, allFiles, allDeletedFiles, opts.MetadataDir, opts.MetadataDirAbs)\\n   111→\\tif err != nil {\\n   112→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n   113→\\t}\\n   114→\\n   115→\\t// Deduplication: skip if tree hash matches the last checkpoint\\n   116→\\tif lastTreeHash != plumbing.ZeroHash && treeHash == lastTreeHash {\\n   117→\\t\\treturn WriteTemporaryResult{\\n   118→\\t\\t\\tCommitHash: parentHash,\\n   119→\\t\\t\\tSkipped:    true,\\n   120→\\t\\t}, nil\\n   121→\\t}\\n   122→\\n   123→\\t// Create checkpoint commit with trailers\\n   124→\\tcommitMsg := trailers.FormatShadowCommit(opts.CommitMessage, opts.MetadataDir, opts.SessionID)\\n   125→\\n   126→\\tcommitHash, err := s.createCommit(treeHash, parentHash, commitMsg, opts.AuthorName, opts.AuthorEmail)\\n   127→\\tif err != nil {\\n   128→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   129→\\t}\\n   130→\\n   131→\\t// Update branch reference\\n   132→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   133→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n   134→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n   135→\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to update branch reference: %w\\\", err)\\n   136→\\t}\\n   137→\\n   138→\\treturn WriteTemporaryResult{\\n   139→\\t\\tCommitHash: commitHash,\\n   140→\\t\\tSkipped:    false,\\n   141→\\t}, nil\\n   142→}\\n   143→\\n   144→// ReadTemporary reads the latest checkpoint from a shadow branch.\\n   145→// Returns nil if the shadow branch doesn't exist.\\n   146→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   147→func (s *GitStore) ReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error) {\\n   148→\\tif err := ctx.Err(); err != nil {\\n   149→\\t\\treturn nil, err //nolint:wrapcheck // Propagating context cancellation\\n   150→\\t}\\n   151→\\n   152→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   153→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   154→\\n   155→\\tref, err := s.repo.Reference(refName, true)\\n   156→\\tif err != nil {\\n   157→\\t\\treturn nil, nil //nolint:nilnil,nilerr // Branch not found is an expected case\\n   158→\\t}\\n   159→\\n   160→\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n   161→\\tif err != nil {\\n   162→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   163→\\t}\\n   164→\\n   165→\\t// Extract session ID and metadata dir from commit trailers\\n   166→\\tsessionID, _ := trailers.ParseSession(commit.Message)\\n   167→\\tmetadataDir, _ := trailers.ParseMetadata(commit.Message)\\n   168→\\n   169→\\treturn &ReadTemporaryResult{\\n   170→\\t\\tCommitHash:  ref.Hash(),\\n   171→\\t\\tTreeHash:    commit.TreeHash,\\n   172→\\t\\tSessionID:   sessionID,\\n   173→\\t\\tMetadataDir: metadataDir,\\n   174→\\t\\tTimestamp:   commit.Author.When,\\n   175→\\t}, nil\\n   176→}\\n   177→\\n   178→// ListTemporary lists all shadow branches with their checkpoint info.\\n   179→func (s *GitStore) ListTemporary(ctx context.Context) ([]TemporaryInfo, error) {\\n   180→\\tif err := ctx.Err(); err != nil {\\n   181→\\t\\treturn nil, err //nolint:wrapcheck // Propagating context cancellation\\n   182→\\t}\\n   183→\\n   184→\\titer, err := s.repo.Branches()\\n   185→\\tif err != nil {\\n   186→\\t\\treturn nil, fmt.Errorf(\\\"failed to list branches: %w\\\", err)\\n   187→\\t}\\n   188→\\n   189→\\tvar results []TemporaryInfo\\n   190→\\terr = iter.ForEach(func(ref *plumbing.Reference) error {\\n   191→\\t\\tif err := ctx.Err(); err != nil {\\n   192→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   193→\\t\\t}\\n   194→\\t\\tbranchName := ref.Name().Short()\\n   195→\\t\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n   196→\\t\\t\\treturn nil\\n   197→\\t\\t}\\n   198→\\n   199→\\t\\t// Skip the sessions branch\\n   200→\\t\\tif branchName == paths.MetadataBranchName {\\n   201→\\t\\t\\treturn nil\\n   202→\\t\\t}\\n   203→\\n   204→\\t\\tcommit, commitErr := s.repo.CommitObject(ref.Hash())\\n   205→\\t\\tif commitErr != nil {\\n   206→\\t\\t\\t//nolint:nilerr // Skip branches we can't read (non-fatal)\\n   207→\\t\\t\\treturn nil\\n   208→\\t\\t}\\n   209→\\n   210→\\t\\tsessionID, _ := trailers.ParseSession(commit.Message)\\n   211→\\n   212→\\t\\t// Extract base commit from branch name (handles new \\\"entire/<commit>-<worktreeHash>\\\" format)\\n   213→\\t\\tbaseCommit, _, _ := ParseShadowBranchName(branchName)\\n   214→\\n   215→\\t\\tresults = append(results, TemporaryInfo{\\n   216→\\t\\t\\tBranchName:   branchName,\\n   217→\\t\\t\\tBaseCommit:   baseCommit,\\n   218→\\t\\t\\tLatestCommit: ref.Hash(),\\n   219→\\t\\t\\tSessionID:    sessionID,\\n   220→\\t\\t\\tTimestamp:    commit.Author.When,\\n   221→\\t\\t})\\n   222→\\n   223→\\t\\treturn nil\\n   224→\\t})\\n   225→\\n   226→\\tif err != nil {\\n   227→\\t\\treturn nil, fmt.Errorf(\\\"failed to iterate branches: %w\\\", err)\\n   228→\\t}\\n   229→\\n   230→\\treturn results, nil\\n   231→}\\n   232→\\n   233→// WriteTemporaryTask writes a task checkpoint to a shadow branch.\\n   234→// Task checkpoints include both code changes and task-specific metadata.\\n   235→// Returns the commit hash of the created checkpoint.\\n   236→func (s *GitStore) WriteTemporaryTask(ctx context.Context, opts WriteTemporaryTaskOptions) (plumbing.Hash, error) {\\n   237→\\t// Validate base commit - required for shadow branch naming\\n   238→\\tif opts.BaseCommit == \\\"\\\" {\\n   239→\\t\\treturn plumbing.ZeroHash, errors.New(\\\"BaseCommit is required for task checkpoint\\\")\\n   240→\\t}\\n   241→\\n   242→\\t// Validate identifiers to prevent path traversal and malformed data\\n   243→\\tif err := validation.ValidateSessionID(opts.SessionID); err != nil {\\n   244→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n   245→\\t}\\n   246→\\tif err := validation.ValidateToolUseID(opts.ToolUseID); err != nil {\\n   247→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n   248→\\t}\\n   249→\\tif err := validation.ValidateAgentID(opts.AgentID); err != nil {\\n   250→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n   251→\\t}\\n   252→\\n   253→\\t// Get shadow branch name\\n   254→\\tshadowBranchName := ShadowBranchNameForCommit(opts.BaseCommit, opts.WorktreeID)\\n   255→\\n   256→\\t// Get or create shadow branch\\n   257→\\tparentHash, baseTreeHash, err := s.getOrCreateShadowBranch(shadowBranchName)\\n   258→\\tif err != nil {\\n   259→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get shadow branch: %w\\\", err)\\n   260→\\t}\\n   261→\\n   262→\\t// Collect all files to include in the commit\\n   263→\\tallFiles := make([]string, 0, len(opts.ModifiedFiles)+len(opts.NewFiles))\\n   264→\\tallFiles = append(allFiles, opts.ModifiedFiles...)\\n   265→\\tallFiles = append(allFiles, opts.NewFiles...)\\n   266→\\n   267→\\t// Build new tree with code changes (no metadata dir yet)\\n   268→\\tnewTreeHash, err := s.buildTreeWithChanges(ctx, baseTreeHash, allFiles, opts.DeletedFiles, \\\"\\\", \\\"\\\")\\n   269→\\tif err != nil {\\n   270→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n   271→\\t}\\n   272→\\n   273→\\t// Add task metadata to tree\\n   274→\\tnewTreeHash, err = s.addTaskMetadataToTree(ctx, newTreeHash, opts)\\n   275→\\tif err != nil {\\n   276→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to add task metadata: %w\\\", err)\\n   277→\\t}\\n   278→\\n   279→\\t// Create the commit\\n   280→\\tcommitHash, err := s.createCommit(newTreeHash, parentHash, opts.CommitMessage, opts.AuthorName, opts.AuthorEmail)\\n   281→\\tif err != nil {\\n   282→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   283→\\t}\\n   284→\\n   285→\\t// Update shadow branch reference\\n   286→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   287→\\tref := plumbing.NewHashReference(refName, commitHash)\\n   288→\\tif err := s.repo.Storer.SetReference(ref); err != nil {\\n   289→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to update shadow branch reference: %w\\\", err)\\n   290→\\t}\\n   291→\\n   292→\\treturn commitHash, nil\\n   293→}\\n   294→\\n   295→// addTaskMetadataToTree adds task checkpoint metadata to a git tree.\\n   296→// When IsIncremental is true, only adds the incremental checkpoint file.\\n   297→//\\n   298→// Uses ApplyTreeChanges (tree surgery) instead of FlattenTree+BuildTreeFromEntries,\\n   299→// so only affected subtrees are read/rebuilt.\\n   300→func (s *GitStore) addTaskMetadataToTree(ctx context.Context, baseTreeHash plumbing.Hash, opts WriteTemporaryTaskOptions) (plumbing.Hash, error) {\\n   301→\\t// Compute metadata paths\\n   302→\\tsessionMetadataDir := paths.EntireMetadataDir + \\\"/\\\" + opts.SessionID\\n   303→\\ttaskMetadataDir := sessionMetadataDir + \\\"/tasks/\\\" + opts.ToolUseID\\n   304→\\n   305→\\tvar changes []TreeChange\\n   306→\\n   307→\\tif opts.IsIncremental {\\n   308→\\t\\t// Incremental checkpoint: only add the checkpoint file\\n   309→\\t\\tvar incData []byte\\n   310→\\t\\tvar err error\\n   311→\\t\\tif opts.IncrementalData != nil {\\n   312→\\t\\t\\tincData, err = redact.JSONLBytes(opts.IncrementalData)\\n   313→\\t\\t\\tif err != nil {\\n   314→\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to redact incremental checkpoint: %w\\\", err)\\n   315→\\t\\t\\t}\\n   316→\\t\\t}\\n   317→\\t\\tincrementalCheckpoint := struct {\\n   318→\\t\\t\\tType      string          `json:\\\"type\\\"`\\n   319→\\t\\t\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   320→\\t\\t\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n   321→\\t\\t\\tData      json.RawMessage `json:\\\"data\\\"`\\n   322→\\t\\t}{\\n   323→\\t\\t\\tType:      opts.IncrementalType,\\n   324→\\t\\t\\tToolUseID: opts.ToolUseID,\\n   325→\\t\\t\\tTimestamp: time.Now().UTC(),\\n   326→\\t\\t\\tData:      incData,\\n   327→\\t\\t}\\n   328→\\t\\tcpData, err := jsonutil.MarshalIndentWithNewline(incrementalCheckpoint, \\\"\\\", \\\"  \\\")\\n   329→\\t\\tif err != nil {\\n   330→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to marshal incremental checkpoint: %w\\\", err)\\n   331→\\t\\t}\\n   332→\\n   333→\\t\\tcpBlobHash, err := CreateBlobFromContent(s.repo, cpData)\\n   334→\\t\\tif err != nil {\\n   335→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create incremental checkpoint blob: %w\\\", err)\\n   336→\\t\\t}\\n   337→\\t\\tcpFilename := fmt.Sprintf(\\\"%03d-%s.json\\\", opts.IncrementalSequence, opts.ToolUseID)\\n   338→\\t\\tcpPath := taskMetadataDir + \\\"/checkpoints/\\\" + cpFilename\\n   339→\\t\\tchanges = append(changes, TreeChange{\\n   340→\\t\\t\\tPath:  cpPath,\\n   341→\\t\\t\\tEntry: &object.TreeEntry{Mode: filemode.Regular, Hash: cpBlobHash},\\n   342→\\t\\t})\\n   343→\\t} else {\\n   344→\\t\\t// Final checkpoint: add transcripts and checkpoint.json\\n   345→\\n   346→\\t\\t// Add session transcript (with chunking support for large transcripts)\\n   347→\\t\\tif opts.TranscriptPath != \\\"\\\" {\\n   348→\\t\\t\\tif transcriptContent, readErr := os.ReadFile(opts.TranscriptPath); readErr == nil {\\n   349→\\t\\t\\t\\tagentType := agent.DetectAgentTypeFromContent(transcriptContent)\\n   350→\\n   351→\\t\\t\\t\\t// Chunk if necessary\\n   352→\\t\\t\\t\\tchunks, chunkErr := agent.ChunkTranscript(ctx, transcriptContent, agentType)\\n   353→\\t\\t\\t\\tif chunkErr != nil {\\n   354→\\t\\t\\t\\t\\tlogging.Warn(ctx, \\\"failed to chunk transcript, checkpoint will be saved without transcript\\\",\\n   355→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", chunkErr.Error()),\\n   356→\\t\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n   357→\\t\\t\\t\\t\\t)\\n   358→\\t\\t\\t\\t} else {\\n   359→\\t\\t\\t\\t\\tfor i, chunk := range chunks {\\n   360→\\t\\t\\t\\t\\t\\tchunkPath := sessionMetadataDir + \\\"/\\\" + agent.ChunkFileName(paths.TranscriptFileName, i)\\n   361→\\t\\t\\t\\t\\t\\tblobHash, blobErr := CreateBlobFromContent(s.repo, chunk)\\n   362→\\t\\t\\t\\t\\t\\tif blobErr != nil {\\n   363→\\t\\t\\t\\t\\t\\t\\tlogging.Warn(ctx, \\\"failed to create blob for transcript chunk\\\",\\n   364→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", blobErr.Error()),\\n   365→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n   366→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"chunk_index\\\", i),\\n   367→\\t\\t\\t\\t\\t\\t\\t)\\n   368→\\t\\t\\t\\t\\t\\t\\tcontinue\\n   369→\\t\\t\\t\\t\\t\\t}\\n   370→\\t\\t\\t\\t\\t\\tchanges = append(changes, TreeChange{\\n   371→\\t\\t\\t\\t\\t\\t\\tPath:  chunkPath,\\n   372→\\t\\t\\t\\t\\t\\t\\tEntry: &object.TreeEntry{Mode: filemode.Regular, Hash: blobHash},\\n   373→\\t\\t\\t\\t\\t\\t})\\n   374→\\t\\t\\t\\t\\t}\\n   375→\\t\\t\\t\\t}\\n   376→\\t\\t\\t}\\n   377→\\t\\t}\\n   378→\\n   379→\\t\\t// Add subagent transcript if available\\n   380→\\t\\tif opts.SubagentTranscriptPath != \\\"\\\" && opts.AgentID != \\\"\\\" {\\n   381→\\t\\t\\tif agentContent, readErr := os.ReadFile(opts.SubagentTranscriptPath); readErr == nil {\\n   382→\\t\\t\\t\\tredacted, jsonlErr := redact.JSONLBytes(agentContent)\\n   383→\\t\\t\\t\\tif jsonlErr != nil {\\n   384→\\t\\t\\t\\t\\tlogging.Warn(ctx, \\\"subagent transcript is not valid JSONL, falling back to plain redaction\\\",\\n   385→\\t\\t\\t\\t\\t\\tslog.String(\\\"path\\\", opts.SubagentTranscriptPath),\\n   386→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", jsonlErr.Error()),\\n   387→\\t\\t\\t\\t\\t)\\n   388→\\t\\t\\t\\t\\tredacted = redact.Bytes(agentContent)\\n   389→\\t\\t\\t\\t}\\n   390→\\t\\t\\t\\tagentContent = redacted\\n   391→\\t\\t\\t\\tif blobHash, blobErr := CreateBlobFromContent(s.repo, agentContent); blobErr == nil {\\n   392→\\t\\t\\t\\t\\tagentPath := taskMetadataDir + \\\"/agent-\\\" + opts.AgentID + \\\".jsonl\\\"\\n   393→\\t\\t\\t\\t\\tchanges = append(changes, TreeChange{\\n   394→\\t\\t\\t\\t\\t\\tPath:  agentPath,\\n   395→\\t\\t\\t\\t\\t\\tEntry: &object.TreeEntry{Mode: filemode.Regular, Hash: blobHash},\\n   396→\\t\\t\\t\\t\\t})\\n   397→\\t\\t\\t\\t}\\n   398→\\t\\t\\t}\\n   399→\\t\\t}\\n   400→\\n   401→\\t\\t// Add checkpoint.json\\n   402→\\t\\tcheckpointJSON := fmt.Sprintf(`{\\n   403→  \\\"session_id\\\": %q,\\n   404→  \\\"tool_use_id\\\": %q,\\n   405→  \\\"checkpoint_uuid\\\": %q,\\n   406→  \\\"agent_id\\\": %q\\n   407→}`, opts.SessionID, opts.ToolUseID, opts.CheckpointUUID, opts.AgentID)\\n   408→\\n   409→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(checkpointJSON))\\n   410→\\t\\tif err != nil {\\n   411→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create checkpoint blob: %w\\\", err)\\n   412→\\t\\t}\\n   413→\\t\\tcheckpointPath := taskMetadataDir + \\\"/checkpoint.json\\\"\\n   414→\\t\\tchanges = append(changes, TreeChange{\\n   415→\\t\\t\\tPath:  checkpointPath,\\n   416→\\t\\t\\tEntry: &object.TreeEntry{Mode: filemode.Regular, Hash: blobHash},\\n   417→\\t\\t})\\n   418→\\t}\\n   419→\\n   420→\\treturn ApplyTreeChanges(s.repo, baseTreeHash, changes)\\n   421→}\\n   422→\\n   423→// ListTemporaryCheckpoints lists all checkpoint commits on a shadow branch.\\n   424→// This returns individual commits (rewind points), not just branch info.\\n   425→// The sessionID filter, if provided, limits results to commits from that session.\\n   426→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   427→func (s *GitStore) ListTemporaryCheckpoints(ctx context.Context, baseCommit, worktreeID, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   428→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   429→\\treturn s.listCheckpointsForBranch(ctx, shadowBranchName, sessionID, limit)\\n   430→}\\n   431→\\n   432→// ListCheckpointsForBranch lists checkpoint commits for a shadow branch by name.\\n   433→// Use this when you already have the full branch name (e.g., from ListTemporary).\\n   434→// The sessionID filter, if provided, limits results to commits from that session.\\n   435→func (s *GitStore) ListCheckpointsForBranch(ctx context.Context, branchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   436→\\treturn s.listCheckpointsForBranch(ctx, branchName, sessionID, limit)\\n   437→}\\n   438→\\n   439→// listCheckpointsForBranch lists checkpoint commits for a specific shadow branch name.\\n   440→// This is an internal helper used by ListTemporaryCheckpoints, ListCheckpointsForBranch, and ListAllTemporaryCheckpoints.\\n   441→func (s *GitStore) listCheckpointsForBranch(ctx context.Context, shadowBranchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   442→\\tif err := ctx.Err(); err != nil {\\n   443→\\t\\treturn nil, err //nolint:wrapcheck // Propagating context cancellation\\n   444→\\t}\\n   445→\\n   446→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   447→\\n   448→\\tref, err := s.repo.Reference(refName, true)\\n   449→\\tif err != nil {\\n   450→\\t\\treturn nil, nil //nolint:nilerr // No shadow branch is expected case\\n   451→\\t}\\n   452→\\n   453→\\titer, err := s.repo.Log(&git.LogOptions{From: ref.Hash()})\\n   454→\\tif err != nil {\\n   455→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   456→\\t}\\n   457→\\n   458→\\tvar results []TemporaryCheckpointInfo\\n   459→\\tcount := 0\\n   460→\\n   461→\\terr = iter.ForEach(func(c *object.Commit) error {\\n   462→\\t\\tif err := ctx.Err(); err != nil {\\n   463→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   464→\\t\\t}\\n   465→\\t\\tif count >= limit*5 { // Scan more to allow for session filtering\\n   466→\\t\\t\\treturn errStop\\n   467→\\t\\t}\\n   468→\\t\\tcount++\\n   469→\\n   470→\\t\\t// Verify commit belongs to target session via Entire-Session trailer\\n   471→\\t\\tcommitSessionID, hasTrailer := trailers.ParseSession(c.Message)\\n   472→\\t\\tif !hasTrailer {\\n   473→\\t\\t\\treturn nil // Skip commits without session trailer\\n   474→\\t\\t}\\n   475→\\t\\tif sessionID != \\\"\\\" && commitSessionID != sessionID {\\n   476→\\t\\t\\treturn nil // Skip commits from other sessions\\n   477→\\t\\t}\\n   478→\\n   479→\\t\\t// Get first line of message\\n   480→\\t\\tmessage := c.Message\\n   481→\\t\\tif idx := strings.Index(message, \\\"\\\\n\\\"); idx > 0 {\\n   482→\\t\\t\\tmessage = message[:idx]\\n   483→\\t\\t}\\n   484→\\n   485→\\t\\tinfo := TemporaryCheckpointInfo{\\n   486→\\t\\t\\tCommitHash: c.Hash,\\n   487→\\t\\t\\tMessage:    message,\\n   488→\\t\\t\\tSessionID:  commitSessionID,\\n   489→\\t\\t\\tTimestamp:  c.Author.When,\\n   490→\\t\\t}\\n   491→\\n   492→\\t\\t// Check for task checkpoint first\\n   493→\\t\\ttaskMetadataDir, foundTask := trailers.ParseTaskMetadata(c.Message)\\n   494→\\t\\tif foundTask {\\n   495→\\t\\t\\tinfo.IsTaskCheckpoint = true\\n   496→\\t\\t\\tinfo.MetadataDir = taskMetadataDir\\n   497→\\t\\t\\tinfo.ToolUseID = extractToolUseIDFromPath(taskMetadataDir)\\n   498→\\t\\t} else {\\n   499→\\t\\t\\tmetadataDir, found := trailers.ParseMetadata(c.Message)\\n   500→\\t\\t\\tif found {\\n   501→\\t\\t\\t\\tinfo.MetadataDir = metadataDir\\n   502→\\t\\t\\t}\\n   503→\\t\\t}\\n   504→\\n   505→\\t\\tresults = append(results, info)\\n   506→\\n   507→\\t\\tif len(results) >= limit {\\n   508→\\t\\t\\treturn errStop\\n   509→\\t\\t}\\n   510→\\t\\treturn nil\\n   511→\\t})\\n   512→\\n   513→\\tif err != nil && !errors.Is(err, errStop) {\\n   514→\\t\\treturn nil, fmt.Errorf(\\\"error iterating commits: %w\\\", err)\\n   515→\\t}\\n   516→\\n   517→\\treturn results, nil\\n   518→}\\n   519→\\n   520→// ListAllTemporaryCheckpoints lists checkpoint commits from ALL shadow branches.\\n   521→// This is used for checkpoint lookup when the base commit is unknown (e.g., HEAD advanced since session start).\\n   522→// The sessionID filter, if provided, limits results to commits from that session.\\n   523→func (s *GitStore) ListAllTemporaryCheckpoints(ctx context.Context, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   524→\\tif err := ctx.Err(); err != nil {\\n   525→\\t\\treturn nil, err //nolint:wrapcheck // Propagating context cancellation\\n   526→\\t}\\n   527→\\n   528→\\t// List all shadow branches\\n   529→\\tbranches, err := s.ListTemporary(ctx)\\n   530→\\tif err != nil {\\n   531→\\t\\treturn nil, fmt.Errorf(\\\"failed to list shadow branches: %w\\\", err)\\n   532→\\t}\\n   533→\\n   534→\\tvar results []TemporaryCheckpointInfo\\n   535→\\n   536→\\t// Iterate through each shadow branch and collect checkpoints\\n   537→\\tfor _, branch := range branches {\\n   538→\\t\\t// Use the branch name directly to get checkpoints\\n   539→\\t\\tbranchCheckpoints, branchErr := s.listCheckpointsForBranch(ctx, branch.BranchName, sessionID, limit)\\n   540→\\t\\tif branchErr != nil {\\n   541→\\t\\t\\tif errors.Is(branchErr, context.Canceled) || errors.Is(branchErr, context.DeadlineExceeded) {\\n   542→\\t\\t\\t\\treturn nil, branchErr\\n   543→\\t\\t\\t}\\n   544→\\t\\t\\tcontinue // Skip branches we can't read\\n   545→\\t\\t}\\n   546→\\t\\tresults = append(results, branchCheckpoints...)\\n   547→\\t\\tif len(results) >= limit {\\n   548→\\t\\t\\tresults = results[:limit]\\n   549→\\t\\t\\tbreak\\n   550→\\t\\t}\\n   551→\\t}\\n   552→\\n   553→\\treturn results, nil\\n   554→}\\n   555→\\n   556→// extractToolUseIDFromPath extracts the ToolUseID from a task metadata directory path.\\n   557→// Task metadata dirs have format: .entire/metadata/<session>/tasks/<toolUseID>\\n   558→func extractToolUseIDFromPath(metadataDir string) string {\\n   559→\\tparts := strings.Split(metadataDir, \\\"/\\\")\\n   560→\\tif len(parts) >= 2 && parts[len(parts)-2] == \\\"tasks\\\" {\\n   561→\\t\\treturn parts[len(parts)-1]\\n   562→\\t}\\n   563→\\treturn \\\"\\\"\\n   564→}\\n   565→\\n   566→// errStop is a sentinel error used to break out of git log iteration.\\n   567→var errStop = errors.New(\\\"stop iteration\\\")\\n   568→\\n   569→// GetTranscriptFromCommit retrieves the transcript from a specific commit's tree.\\n   570→// This is used for shadow branch checkpoints where the transcript is stored in the commit tree\\n   571→// rather than on the entire/checkpoints/v1 branch.\\n   572→// commitHash is the commit to read from, metadataDir is the path within the tree.\\n   573→// agentType is used for reassembling chunked transcripts in the correct format.\\n   574→// Handles both chunked and non-chunked transcripts.\\n   575→func (s *GitStore) GetTranscriptFromCommit(ctx context.Context, commitHash plumbing.Hash, metadataDir string, agentType types.AgentType) ([]byte, error) {\\n   576→\\tcommit, err := s.repo.CommitObject(commitHash)\\n   577→\\tif err != nil {\\n   578→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   579→\\t}\\n   580→\\n   581→\\ttree, err := commit.Tree()\\n   582→\\tif err != nil {\\n   583→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   584→\\t}\\n   585→\\n   586→\\t// Try to get the metadata subtree for chunk detection\\n   587→\\tsubTree, subTreeErr := tree.Tree(metadataDir)\\n   588→\\tif subTreeErr == nil {\\n   589→\\t\\t// Use the helper function that handles chunking\\n   590→\\t\\ttranscript, err := readTranscriptFromTree(ctx, subTree, agentType)\\n   591→\\t\\tif err == nil && transcript != nil {\\n   592→\\t\\t\\treturn transcript, nil\\n   593→\\t\\t}\\n   594→\\t}\\n   595→\\n   596→\\t// Fall back to direct file access (for backwards compatibility)\\n   597→\\ttranscriptPath := metadataDir + \\\"/\\\" + paths.TranscriptFileName\\n   598→\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n   599→\\t\\tcontent, contentErr := file.Contents()\\n   600→\\t\\tif contentErr == nil {\\n   601→\\t\\t\\treturn []byte(content), nil\\n   602→\\t\\t}\\n   603→\\t}\\n   604→\\n   605→\\ttranscriptPath = metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n   606→\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n   607→\\t\\tcontent, contentErr := file.Contents()\\n   608→\\t\\tif contentErr == nil {\\n   609→\\t\\t\\treturn []byte(content), nil\\n   610→\\t\\t}\\n   611→\\t}\\n   612→\\n   613→\\treturn nil, ErrNoTranscript\\n   614→}\\n   615→\\n   616→// ShadowBranchExists checks if a shadow branch exists for the given base commit and worktree.\\n   617→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   618→func (s *GitStore) ShadowBranchExists(baseCommit, worktreeID string) bool {\\n   619→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   620→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   621→\\t_, err := s.repo.Reference(refName, true)\\n   622→\\treturn err == nil\\n   623→}\\n   624→\\n   625→// DeleteShadowBranch deletes the shadow branch for the given base commit and worktree.\\n   626→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   627→// Uses git CLI instead of go-git's RemoveReference because go-git v5 doesn't properly\\n   628→// persist deletions with packed refs or worktrees.\\n   629→func (s *GitStore) DeleteShadowBranch(ctx context.Context, baseCommit, worktreeID string) error {\\n   630→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   631→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", shadowBranchName)\\n   632→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   633→\\t\\treturn fmt.Errorf(\\\"failed to delete shadow branch %s: %s: %w\\\", shadowBranchName, strings.TrimSpace(string(output)), err)\\n   634→\\t}\\n   635→\\treturn nil\\n   636→}\\n   637→\\n   638→// ShadowBranchNameForCommit returns the shadow branch name for a base commit hash\\n   639→// and worktree identifier. The worktree ID should be empty for the main worktree\\n   640→// or the internal git worktree name for linked worktrees.\\n   641→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   642→func ShadowBranchNameForCommit(baseCommit, worktreeID string) string {\\n   643→\\tcommitPart := baseCommit\\n   644→\\tif len(baseCommit) >= ShadowBranchHashLength {\\n   645→\\t\\tcommitPart = baseCommit[:ShadowBranchHashLength]\\n   646→\\t}\\n   647→\\tworktreeHash := HashWorktreeID(worktreeID)\\n   648→\\treturn ShadowBranchPrefix + commitPart + \\\"-\\\" + worktreeHash\\n   649→}\\n   650→\\n   651→// ParseShadowBranchName extracts the commit prefix and worktree hash from a shadow branch name.\\n   652→// Input format: \\\"entire/<commit[:7]>-<worktreeHash[:6]>\\\"\\n   653→// Returns (commitPrefix, worktreeHash, ok). Returns (\\\"\\\", \\\"\\\", false) if not a valid shadow branch.\\n   654→func ParseShadowBranchName(branchName string) (commitPrefix, worktreeHash string, ok bool) {\\n   655→\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n   656→\\t\\treturn \\\"\\\", \\\"\\\", false\\n   657→\\t}\\n   658→\\tsuffix := strings.TrimPrefix(branchName, ShadowBranchPrefix)\\n   659→\\n   660→\\t// Find the last dash - everything before is commit prefix, after is worktree hash\\n   661→\\tlastDash := strings.LastIndex(suffix, \\\"-\\\")\\n   662→\\tif lastDash == -1 || lastDash == 0 || lastDash == len(suffix)-1 {\\n   663→\\t\\t// No dash, or dash at start/end - invalid format\\n   664→\\t\\t// Could be old format \\\"entire/<commit[:7]>\\\" without worktree hash\\n   665→\\t\\treturn suffix, \\\"\\\", true // Return as commit prefix with empty worktree hash\\n   666→\\t}\\n   667→\\n   668→\\treturn suffix[:lastDash], suffix[lastDash+1:], true\\n   669→}\\n   670→\\n   671→// getOrCreateShadowBranch gets or creates the shadow branch for checkpoints.\\n   672→// Returns (parentHash, baseTreeHash, error).\\n   673→func (s *GitStore) getOrCreateShadowBranch(branchName string) (plumbing.Hash, plumbing.Hash, error) {\\n   674→\\trefName := plumbing.NewBranchReferenceName(branchName)\\n   675→\\tref, err := s.repo.Reference(refName, true)\\n   676→\\n   677→\\tif err == nil {\\n   678→\\t\\t// Branch exists\\n   679→\\t\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n   680→\\t\\tif err != nil {\\n   681→\\t\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   682→\\t\\t}\\n   683→\\t\\treturn ref.Hash(), commit.TreeHash, nil\\n   684→\\t}\\n   685→\\n   686→\\t// Branch doesn't exist, use current HEAD's tree as base\\n   687→\\thead, err := s.repo.Head()\\n   688→\\tif err != nil {\\n   689→\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   690→\\t}\\n   691→\\n   692→\\theadCommit, err := s.repo.CommitObject(head.Hash())\\n   693→\\tif err != nil {\\n   694→\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   695→\\t}\\n   696→\\n   697→\\treturn plumbing.ZeroHash, headCommit.TreeHash, nil\\n   698→}\\n   699→\\n   700→// buildTreeWithChanges builds a git tree with the given changes.\\n   701→// metadataDir is the relative path for git tree entries, metadataDirAbs is the absolute path\\n   702→// for filesystem operations (needed when CLI is run from a subdirectory).\\n   703→//\\n   704→// Uses ApplyTreeChanges (tree surgery) instead of FlattenTree+BuildTreeFromEntries,\\n   705→// so only affected subtrees are read/rebuilt — O(changed dirs) instead of O(total files).\\n   706→func (s *GitStore) buildTreeWithChanges(\\n   707→\\tctx context.Context,\\n   708→\\tbaseTreeHash plumbing.Hash,\\n   709→\\tmodifiedFiles, deletedFiles []string,\\n   710→\\tmetadataDir, metadataDirAbs string,\\n   711→) (plumbing.Hash, error) {\\n   712→\\t// Get worktree root for resolving file paths\\n   713→\\t// This is critical because fileExists() and createBlobFromFile() use os.Stat()\\n   714→\\t// which resolves relative to CWD. The modifiedFiles are repo-relative paths,\\n   715→\\t// so we must resolve them against repo root, not CWD.\\n   716→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   717→\\tif err != nil {\\n   718→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   719→\\t}\\n   720→\\n   721→\\t// Build list of tree changes\\n   722→\\tchanges := make([]TreeChange, 0, len(modifiedFiles)+len(deletedFiles))\\n   723→\\n   724→\\t// Deleted files → nil Entry means deletion\\n   725→\\tfor _, file := range deletedFiles {\\n   726→\\t\\tchanges = append(changes, TreeChange{Path: file, Entry: nil})\\n   727→\\t}\\n   728→\\n   729→\\t// Modified/new files → create blobs from disk\\n   730→\\tfor _, file := range modifiedFiles {\\n   731→\\t\\tabsPath := filepath.Join(repoRoot, file)\\n   732→\\t\\tif !fileExists(absPath) {\\n   733→\\t\\t\\t// File disappeared since detection — treat as deletion\\n   734→\\t\\t\\tchanges = append(changes, TreeChange{Path: file, Entry: nil})\\n   735→\\t\\t\\tcontinue\\n   736→\\t\\t}\\n   737→\\n   738→\\t\\tblobHash, mode, blobErr := createBlobFromFile(s.repo, absPath)\\n   739→\\t\\tif blobErr != nil {\\n   740→\\t\\t\\t// Skip files that can't be staged (may have been deleted since detection)\\n   741→\\t\\t\\tcontinue\\n   742→\\t\\t}\\n   743→\\n   744→\\t\\tchanges = append(changes, TreeChange{\\n   745→\\t\\t\\tPath: file,\\n   746→\\t\\t\\tEntry: &object.TreeEntry{\\n   747→\\t\\t\\t\\tMode: mode,\\n   748→\\t\\t\\t\\tHash: blobHash,\\n   749→\\t\\t\\t},\\n   750→\\t\\t})\\n   751→\\t}\\n   752→\\n   753→\\t// Metadata directory files\\n   754→\\tif metadataDir != \\\"\\\" && metadataDirAbs != \\\"\\\" {\\n   755→\\t\\tmetaChanges, metaErr := addDirectoryToChanges(s.repo, metadataDirAbs, metadataDir)\\n   756→\\t\\tif metaErr != nil {\\n   757→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to add metadata directory: %w\\\", metaErr)\\n   758→\\t\\t}\\n   759→\\t\\tchanges = append(changes, metaChanges...)\\n   760→\\t}\\n   761→\\n   762→\\treturn ApplyTreeChanges(s.repo, baseTreeHash, changes)\\n   763→}\\n   764→\\n   765→// createCommit creates a commit object.\\n   766→func (s *GitStore) createCommit(treeHash, parentHash plumbing.Hash, message, authorName, authorEmail string) (plumbing.Hash, error) {\\n   767→\\tnow := time.Now()\\n   768→\\tsig := object.Signature{\\n   769→\\t\\tName:  authorName,\\n   770→\\t\\tEmail: authorEmail,\\n   771→\\t\\tWhen:  now,\\n   772→\\t}\\n   773→\\n   774→\\tcommit := &object.Commit{\\n   775→\\t\\tTreeHash:  treeHash,\\n   776→\\t\\tAuthor:    sig,\\n   777→\\t\\tCommitter: sig,\\n   778→\\t\\tMessage:   message,\\n   779→\\t}\\n   780→\\n   781→\\t// Add parent if not a new branch\\n   782→\\tif parentHash != plumbing.ZeroHash {\\n   783→\\t\\tcommit.ParentHashes = []plumbing.Hash{parentHash}\\n   784→\\t}\\n   785→\\n   786→\\tobj := s.repo.Storer.NewEncodedObject()\\n   787→\\tif err := commit.Encode(obj); err != nil {\\n   788→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n   789→\\t}\\n   790→\\n   791→\\thash, err := s.repo.Storer.SetEncodedObject(obj)\\n   792→\\tif err != nil {\\n   793→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store commit: %w\\\", err)\\n   794→\\t}\\n   795→\\n   796→\\treturn hash, nil\\n   797→}\\n   798→\\n   799→// Helper functions extracted from strategy/common.go\\n   800→// These are exported for use by strategy package (push_common.go, session_test.go)\"}]},\"uuid\":\"8847dbef-ee96-4d38-b93b-40f9de3bc83a\",\"timestamp\":\"2026-03-03T00:43:02.330Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand how prompt.txt is stored on shadow branches and how it's read during condensation.\\n\\nSpecifically:\\n1. How is prompt.txt written to the shadow branch? Search for where prompt.txt is created/written in the strategy package, particularly in SaveStep and related functions. Look for `PromptFileName` or `prompt.txt` references.\\n2. How does `CondenseSession` / `extractSessionData` currently read data from the shadow branch? I need to understand the tree structure — each commit on the shadow branch has metadata under `.entire/metadata/<session-id>/`. How are the commits iterated?\\n3. In `extractSessionData`, there's already logic to read `full.jsonl` from the shadow branch tree. Is there similar logi