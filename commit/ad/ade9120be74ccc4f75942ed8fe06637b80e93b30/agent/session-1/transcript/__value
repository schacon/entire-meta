o-git/v5/plumbing/object\\\"\\n    32→\\t\\\"github.com/go-git/go-git/v5/utils/binary\\\"\\n    33→)\\n    34→\\n    35→// hasTTY checks if /dev/tty is available for interactive prompts.\\n    36→// Returns false when running as an agent subprocess (no controlling terminal).\\n    37→//\\n    38→// In test environments, ENTIRE_TEST_TTY overrides the real check:\\n    39→//   - ENTIRE_TEST_TTY=1 → simulate human (TTY available)\\n    40→//   - ENTIRE_TEST_TTY=0 → simulate agent (no TTY)\\n    41→func hasTTY() bool {\\n    42→\\tif v := os.Getenv(\\\"ENTIRE_TEST_TTY\\\"); v != \\\"\\\" {\\n    43→\\t\\treturn v == \\\"1\\\"\\n    44→\\t}\\n    45→\\n    46→\\t// Gemini CLI sets GEMINI_CLI=1 when running shell commands.\\n    47→\\t// Gemini subprocesses may have access to the user's TTY, but they can't\\n    48→\\t// actually respond to interactive prompts. Treat them as non-TTY.\\n    49→\\t// See: https://geminicli.com/docs/tools/shell/\\n    50→\\tif os.Getenv(\\\"GEMINI_CLI\\\") != \\\"\\\" {\\n    51→\\t\\treturn false\\n    52→\\t}\\n    53→\\n    54→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n    55→\\tif err != nil {\\n    56→\\t\\treturn false\\n    57→\\t}\\n    58→\\t_ = tty.Close()\\n    59→\\treturn true\\n    60→}\\n    61→\\n    62→// ttyResult represents the outcome of a TTY confirmation prompt.\\n    63→type ttyResult int\\n    64→\\n    65→const (\\n    66→\\tttyResultLink       ttyResult = iota // Link: add the checkpoint trailer\\n    67→\\tttyResultSkip                        // Skip: don't add the trailer\\n    68→\\tttyResultLinkAlways                  // Link and remember: add trailer + save \\\"always\\\" preference\\n    69→)\\n    70→\\n    71→// askConfirmTTY prompts the user via /dev/tty whether to link a commit to session context.\\n    72→// This requires a controlling terminal — callers must check hasTTY() first and handle\\n    73→// the no-TTY case (agent subprocesses, CI) themselves.\\n    74→//\\n    75→// header is