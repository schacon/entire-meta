inished task.\\n   108→//\\n   109→// Returns empty string if no completed items exist or JSON is invalid.\\n   110→func ExtractLastCompletedTodo(todosJSON []byte) string {\\n   111→\\tif len(todosJSON) == 0 {\\n   112→\\t\\treturn \\\"\\\"\\n   113→\\t}\\n   114→\\n   115→\\tvar todos []todoItem\\n   116→\\tif err := json.Unmarshal(todosJSON, &todos); err != nil {\\n   117→\\t\\treturn \\\"\\\"\\n   118→\\t}\\n   119→\\n   120→\\t// Find the last completed item - this is the work that was just finished\\n   121→\\tvar lastCompleted string\\n   122→\\tfor _, todo := range todos {\\n   123→\\t\\tif todo.Status == \\\"completed\\\" {\\n   124→\\t\\t\\tlastCompleted = todo.Content\\n   125→\\t\\t}\\n   126→\\t}\\n   127→\\treturn lastCompleted\\n   128→}\\n   129→\\n   130→// CountTodos returns the number of todo items in the JSON array.\\n   131→// Returns 0 if the JSON is invalid or empty.\\n   132→func CountTodos(todosJSON []byte) int {\\n   133→\\tif len(todosJSON) == 0 {\\n   134→\\t\\treturn 0\\n   135→\\t}\\n   136→\\n   137→\\tvar todos []todoItem\\n   138→\\tif err := json.Unmarshal(todosJSON, &todos); err != nil {\\n   139→\\t\\treturn 0\\n   140→\\t}\\n   141→\\n   142→\\treturn len(todos)\\n   143→}\\n   144→\\n   145→// ExtractInProgressTodo extracts the content of the in-progress todo item from tool_input.\\n   146→// This is used for commit messages in incremental checkpoints.\\n   147→//\\n   148→// Priority order:\\n   149→//  1. in_progress item (current work)\\n   150→//  2. first pending item (next work - fallback)\\n   151→//  3. last completed item (final work just finished)\\n   152→//  4. first item with unknown status (edge case)\\n   153→//  5. empty string (no items)\\n   154→//\\n   155→// Returns empty string if no suitable item is found or JSON is invalid.\\n   156→func ExtractInProgressTodo(todosJSON []byte) string {\\n   157→\\tif len(todosJSON) == 0 {\\n   158→\\t\\treturn \\\"\\\"\\n   159→\\t}\\n   160→\\n   161→\\tvar todos []todoIte