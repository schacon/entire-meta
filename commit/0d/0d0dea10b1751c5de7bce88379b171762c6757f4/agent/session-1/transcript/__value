ngs(settings); err != nil {\\n   610→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   611→\\t}\\n   612→\\n   613→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   614→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   615→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   616→\\t}\\n   617→\\n   618→\\tif installedHooks == 0 {\\n   619→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   620→\\t\\tif agentName == agent.AgentNameGemini {\\n   621→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   622→\\t\\t}\\n   623→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   624→\\t} else {\\n   625→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   626→\\t\\tif agentName == agent.AgentNameGemini {\\n   627→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   628→\\t\\t}\\n   629→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   630→\\t}\\n   631→\\n   632→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   633→\\n   634→\\t// Let the strategy handle its own setup requirements (creates entire/checkpoints/v1 branch, etc.)\\n   635→\\tstrat, err := strategy.Get(settings.Strategy)\\n   636→\\tif err != nil {\\n   637→\\t\\treturn fmt.Errorf(\\\"failed to get strategy: %w\\\", err)\\n   638→\\t}\\n   639→\\tif err := strat.EnsureSetup(); err != nil {\\n   640→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   641→\\t}\\n   642→\\n   643→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   644→\\n   645→\\treturn nil\\n   646→}\\n   647→\\n   648→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   649→func validateSetupFlags(useLocal, useProject bool) error {\\n   650→\\tif useLocal && useProject {\\n   651→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   652→\\t}\\n   653→\\treturn nil\\n   654→}\\n   655→\\n   656→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   657→// - Whether settings.json already exists\\n   658→// - The --local and --project flags\\n   659→// Returns (useLocal, showNotification).\\n   660→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   661→\\t// Explicit --local flag always uses local settings\\n   662→\\tif useLocal {\\n   663→\\t\\treturn true, false\\n   664→\\t}\\n   665→\\n   666→\\t// Explicit --project flag always uses project settings\\n   667→\\tif useProject {\\n   668→\\t\\treturn false, false\\n   669→\\t}\\n   670→\\n   671→\\t// No flags specified - check if settings file exists\\n   672→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   673→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   674→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   675→\\t\\treturn true, true\\n   676→\\t}\\n   677→\\n   678→\\t// Settings file doesn't exist - create it\\n   679→\\treturn false, false\\n   680→}\\n   681→\\n   682→// setupEntireDirectory creates the .entire directory and gitignore.\\n   683→// Returns true if the directory was created, false if it already existed.\\n   684→func setupEntireDirectory() (bool, error) { //nolint:unparam // already present in codebase\\n   685→\\t// Get absolute path for the .entire directory\\n   686→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   687→\\tif err != nil {\\n   688→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   689→\\t}\\n   690→\\n   691→\\t// Check if directory already exists\\n   692→\\tcreated := false\\n   693→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   694→\\t\\tcreated = true\\n   695→\\t}\\n   696→\\n   697→\\t// Create .entire directory\\n   698→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   699→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   700→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   701→\\t}\\n   702→\\n   703→\\t// Create/update .gitignore with all required entries\\n   704→\\tif err := strategy.EnsureEntireGitignore(); err != nil {\\n   705→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   706→\\t}\\n   707→\\n   708→\\treturn created, nil\\n   709→}\\n   710→\\n   711→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   712→func setupGitHook() error {\\n   713→\\t// Use shared implementation from strategy package\\n   714→\\t// The localDev setting is read from settings.json\\n   715→\\t_, err := strategy.InstallGitHook(false) // not silent - show output during setup\\n   716→\\tif err != nil {\\n   717→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   718→\\t}\\n   719→\\treturn nil\\n   720→}\\n   721→\\n   722→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   723→func newSetupGitHookCmd() *cobra.Command {\\n   724→\\tcmd := &cobra.Command{\\n   725→\\t\\tUse:    \\\"git-hook\\\",\\n   726→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   727→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   728→\\t\\tRunE: func(_ *cobra.Command, _ []string) error {\\n   729→\\t\\t\\treturn setupGitHook()\\n   730→\\t\\t},\\n   731→\\t}\\n   732→\\n   733→\\treturn cmd\\n   734→}\\n   735→\\n   736→func newCurlBashPostInstallCmd() *cobra.Command {\\n   737→\\treturn &cobra.Command{\\n   738→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   739→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   740→\\t\\tHidden: true,\\n   741→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   742→\\t\\t\\tw := cmd.OutOrStdout()\\n   743→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   744→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   745→\\t\\t\\t}\\n   746→\\t\\t\\treturn nil\\n   747→\\t\\t},\\n   748→\\t}\\n   749→}\\n   750→\\n   751→// shellCompletionComment is the comment preceding the completion line\\n   752→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   753→\\n   754→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   755→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   756→\\n   757→// shellCompletionTarget returns the rc file path and completion lines for the\\n   758→// user's current shell.\\n   759→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   760→\\thome, err := os.UserHomeDir()\\n   761→\\tif err != nil {\\n   762→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   763→\\t}\\n   764→\\n   765→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   766→\\tswitch {\\n   767→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   768→\\t\\treturn \\\"Zsh\\\",\\n   769→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   770→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   771→\\t\\t\\tnil\\n   772→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   773→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   774→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   775→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   776→\\t\\t}\\n   777→\\t\\treturn \\\"Bash\\\",\\n   778→\\t\\t\\tbashRC,\\n   779→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   780→\\t\\t\\tnil\\n   781→\\tcase strings.Contains(shell, \\\"fish\\\"):\\n   782→\\t\\treturn \\\"Fish\\\",\\n   783→\\t\\t\\tfilepath.Join(home, \\\".config\\\", \\\"fish\\\", \\\"config.fish\\\"),\\n   784→\\t\\t\\t\\\"entire completion fish | source\\\",\\n   785→\\t\\t\\tnil\\n   786→\\tdefault:\\n   787→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   788→\\t}\\n   789→}\\n   790→\\n   791→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   792→// Only prompts if completion is not already configured.\\n   793→func promptShellCompletion(w io.Writer) error {\\n   794→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   795→\\tif err != nil {\\n   796→\\t\\tif errors.Is(err, errUnsupportedShell) {\\n   797→\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion not available for your shell. Supported: zsh, bash, fish.\\\\n\\\")\\n   798→\\t\\t\\treturn nil\\n   799→\\t\\t}\\n   800→\\t\\treturn fmt.Errorf(\\\"shell completion: %w\\\", err)\\n   801→\\t}\\n   802→\\n   803→\\tif isCompletionConfigured(rcFile) {\\n   804→\\t\\tfmt.Fprintf(w, \\\"✓ Shell completion already configured in %s\\\\n\\\", rcFile)\\n   805→\\t\\treturn nil\\n   806→\\t}\\n   807→\\n   808→\\tvar selected string\\n   809→\\tform := NewAccessibleForm(\\n   810→\\t\\thuh.NewGroup(\\n   811→\\t\\t\\thuh.NewSelect[string]().\\n   812→\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Enable shell completion? (detected: %s)\\\", shellName)).\\n   813→\\t\\t\\t\\tOptions(\\n   814→\\t\\t\\t\\t\\thuh.NewOption(\\\"Yes\\\", \\\"yes\\\"),\\n   815→\\t\\t\\t\\t\\thuh.NewOption(\\\"No\\\", \\\"no\\\"),\\n   816→\\t\\t\\t\\t).\\n   817→\\t\\t\\t\\tValue(&selected),\\n   818→\\t\\t),\\n   819→\\t)\\n   820→\\n   821→\\tif err := form.Run(); err != nil {\\n   822→\\t\\t//nolint:nilerr // User cancelled - not a fatal error, just skip\\n   823→\\t\\treturn nil\\n   824→\\t}\\n   825→\\n   826→\\tif selected != \\\"yes\\\" {\\n   827→\\t\\treturn nil\\n   828→\\t}\\n   829→\\n   830→\\tif err := appendShellCompletion(rcFile, completionLine); err != nil {\\n   831→\\t\\treturn fmt.Errorf(\\\"failed to update %s: %w\\\", rcFile, err)\\n   832→\\t}\\n   833→\\n   834→\\tfmt.Fprintf(w, \\\"✓ Shell completion added to %s\\\\n\\\", rcFile)\\n   835→\\tfmt.Fprintln(w, \\\"  Restart your shell to activate\\\")\\n   836→\\n   837→\\treturn nil\\n   838→}\\n   839→\\n   840→// isCompletionConfigured checks if shell completion is already in the rc file.\\n   841→func isCompletionConfigured(rcFile string) bool {\\n   842→\\t//nolint:gosec // G304: rcFile is constructed from home dir + known filename, not user input\\n   843→\\tcontent, err := os.ReadFile(rcFile)\\n   844→\\tif err != nil {\\n   845→\\t\\treturn false // File doesn't exist or can't read, treat as not configured\\n   846→\\t}\\n   847→\\treturn strings.Contains(string(content), \\\"entire completion\\\")\\n   848→}\\n   849→\\n   850→// appendShellCompletion adds the completion line to the rc file.\\n   851→func appendShellCompletion(rcFile, completionLine string) error {\\n   852→\\tif err := os.MkdirAll(filepath.Dir(rcFile), 0o700); err != nil {\\n   853→\\t\\treturn fmt.Errorf(\\\"creating directory: %w\\\", err)\\n   854→\\t}\\n   855→\\t//nolint:gosec // G302: Shell rc files need 0644 for user readability\\n   856→\\tf, err := os.OpenFile(rcFile, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0o644)\\n   857→\\tif err != nil {\\n   858→\\t\\treturn fmt.Errorf(\\\"opening file: %w\\\", err)\\n   859→\\t}\\n   860→\\tdefer f.Close()\\n   861→\\n   862→\\t_, err = f.WriteString(\\\"\\\\n\\\" + shellCompletionComment + \\\"\\\\n\\\" + completionLine + \\\"\\\\n\\\")\\n   863→\\tif err != nil {\\n   864→\\t\\treturn fmt.Errorf(\\\"writing completion: %w\\\", err)\\n   865→\\t}\\n   866→\\treturn nil\\n   867→}\\n   868→\\n   869→// promptTelemetryConsent asks the user if they want to enable telemetry.\\n   870→// It modifies settings.Telemetry based on the user's choice or flags.\\n   871→// The caller is responsible for saving settings.\\n   872→func promptTelemetryConsent(settings *EntireSettings, telemetryFlag bool) error {\\n   873→\\t// Handle --telemetry=false flag first (always overrides existing setting)\\n   874→\\tif !telemetryFlag {\\n   875→\\t\\tf := false\\n   876→\\t\\tsettings.Telemetry = &f\\n   877→\\t\\treturn nil\\n   878→\\t}\\n   879→\\n   880→\\t// Skip if already asked\\n   881→\\tif settings.Telemetry != nil {\\n   882→\\t\\treturn nil\\n   883→\\t}\\n   884→\\n   885→\\t// Skip if env var disables telemetry (record as disabled)\\n   886→\\tif os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   887→\\t\\tf := false\\n   888→\\t\\tsettings.Telemetry = &f\\n   889→\\t\\treturn nil\\n   890→\\t}\\n   891→\\n   892→\\tconsent := true // Default to Yes\\n   893→\\tform := NewAccessibleForm(\\n   894→\\t\\thuh.NewGroup(\\n   895→\\t\\t\\thuh.NewConfirm().\\n   896→\\t\\t\\t\\tTitle(\\\"Help improve Entire CLI?\\\").\\n   897→\\t\\t\\t\\tDescription(\\\"Share anonymous usage data. No code or personal info collected.\\\").\\n   898→\\t\\t\\t\\tAffirmative(\\\"Yes\\\").\\n   899→\\t\\t\\t\\tNegative(\\\"No\\\").\\n   900→\\t\\t\\t\\tValue(&consent),\\n   901→\\t\\t),\\n   902→\\t)\\n   903→\\n   904→\\tif err := form.Run(); err != nil {\\n   905→\\t\\treturn fmt.Errorf(\\\"telemetry prompt: %w\\\", err)\\n   906→\\t}\\n   907→\\n   908→\\tsettings.Telemetry = &consent\\n   909→\\treturn nil\\n   910→}\\n   911→\\n   912→// runUninstall completely removes Entire from the repository.\\n   913→func runUninstall(w, errW io.Writer, force bool) error {\\n   914→\\t// Check if we're in a git repository\\n   915→\\tif _, err := paths.RepoRoot(); err != nil {\\n   916→\\t\\tfmt.Fprintln(errW, \\\"Not a git repository. Nothing to uninstall.\\\")\\n   917→\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n   918→\\t}\\n   919→\\n   920→\\t// Gather counts for display\\n   921→\\tsessionStateCount := countSessionStates()\\n   922→\\tshadowBranchCount := countShadowBranches()\\n   923→\\tgitHooksInstalled := strategy.IsGitHookInstalled()\\n   924→\\tclaudeHooksInstalled := checkClaudeCodeHooksInstalled()\\n   925→\\tgeminiHooksInstalled := checkGeminiCLIHooksInstalled()\\n   926→\\tentireDirExists := checkEntireDirExists()\\n   927→\\n   928→\\t// Check if there's anything to uninstall\\n   929→\\tif !entireDirExists && !gitHooksInstalled && sessionStateCount == 0 &&\\n   930→\\t\\tshadowBranchCount == 0 && !claudeHooksInstalled && !geminiHooksInstalled {\\n   931→\\t\\tfmt.Fprintln(w, \\\"Entire is not installed in this repository.\\\")\\n   932→\\t\\treturn nil\\n   933→\\t}\\n   934→\\n   935→\\t// Show confirmation prompt unless --force\\n   936→\\tif !force {\\n   937→\\t\\tfmt.Fprintln(w, \\\"\\\\nThis will completely remove Entire from this repository:\\\")\\n   938→\\t\\tif entireDirExists {\\n   939→\\t\\t\\tfmt.Fprintln(w, \\\"  - .entire/ directory\\\")\\n   940→\\t\\t}\\n   941→\\t\\tif gitHooksInstalled {\\n   942→\\t\\t\\tfmt.Fprintln(w, \\\"  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\\")\\n   943→\\t\\t}\\n   944→\\t\\tif sessionStateCount > 0 {\\n   945→\\t\\t\\tfmt.Fprintf(w, \\\"  - Session state files (%d)\\\\n\\\", sessionStateCount)\\n   946→\\t\\t}\\n   947→\\t\\tif shadowBranchCount > 0 {\\n   948→\\t\\t\\tfmt.Fprintf(w, \\\"  - Shadow branches (%d)\\\\n\\\", shadowBranchCount)\\n   949→\\t\\t}\\n   950→\\t\\tswitch {\\n   951→\\t\\tcase claudeHooksInstalled && geminiHooksInstalled:\\n   952→\\t\\t\\tfmt.Fprintln(w, \\\"  - Agent hooks (Claude Code, Gemini CLI)\\\")\\n   953→\\t\\tcase claudeHooksInstalled:\\n   954→\\t\\t\\tfmt.Fprintln(w, \\\"  - Agent hooks (Claude Code)\\\")\\n   955→\\t\\tcase geminiHooksInstalled:\\n   956→\\t\\t\\tfmt.Fprintln(w, \\\"  - Agent hooks (Gemini CLI)\\\")\\n   957→\\t\\t}\\n   958→\\t\\tfmt.Fprintln(w)\\n   959→\\n   960→\\t\\tvar confirmed bool\\n   961→\\t\\tform := NewAccessibleForm(\\n   962→\\t\\t\\thuh.NewGroup(\\n   963→\\t\\t\\t\\thuh.NewConfirm().\\n   964→\\t\\t\\t\\t\\tTitle(\\\"Are you sure you want to uninstall Entire?\\\").\\n   965→\\t\\t\\t\\t\\tAffirmative(\\\"Yes, uninstall\\\").\\n   966→\\t\\t\\t\\t\\tNegative(\\\"Cancel\\\").\\n   967→\\t\\t\\t\\t\\tValue(&confirmed),\\n   968→\\t\\t\\t),\\n   969→\\t\\t)\\n   970→\\n   971→\\t\\tif err := form.Run(); err != nil {\\n   972→\\t\\t\\treturn fmt.Errorf(\\\"confirmation cancelled: %w\\\", err)\\n   973→\\t\\t}\\n   974→\\n   975→\\t\\tif !confirmed {\\n   976→\\t\\t\\tfmt.Fprintln(w, \\\"Uninstall cancelled.\\\")\\n   977→\\t\\t\\treturn nil\\n   978→\\t\\t}\\n   979→\\t}\\n   980→\\n   981→\\tfmt.Fprintln(w, \\\"\\\\nUninstalling Entire CLI...\\\")\\n   982→\\n   983→\\t// 1. Remove agent hooks (lowest risk)\\n   984→\\tif err := removeAgentHooks(w); err != nil {\\n   985→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove agent hooks: %v\\\\n\\\", err)\\n   986→\\t}\\n   987→\\n   988→\\t// 2. Remove git hooks\\n   989→\\tremoved, err := strategy.RemoveGitHook()\\n   990→\\tif err != nil {\\n   991→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove git hooks: %v\\\\n\\\", err)\\n   992→\\t} else if removed > 0 {\\n   993→\\t\\tfmt.Fprintf(w, \\\"  Removed git hooks (%d)\\\\n\\\", removed)\\n   994→\\t}\\n   995→\\n   996→\\t// 3. Remove session state files\\n   997→\\tstatesRemoved, err := removeAllSessionStates()\\n   998→\\tif err != nil {\\n   999→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove session states: %v\\\\n\\\", err)\\n  1000→\\t} else if statesRemoved > 0 {\\n  1001→\\t\\tfmt.Fprintf(w, \\\"  Removed session states (%d)\\\\n\\\", statesRemoved)\\n  1002→\\t}\\n  1003→\\n  1004→\\t// 4. Remove .entire/ directory\\n  1005→\\tif err := removeEntireDirectory(); err != nil {\\n  1006→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove .entire directory: %v\\\\n\\\", err)\\n  1007→\\t} else if entireDirExists {\\n  1008→\\t\\tfmt.Fprintln(w, \\\"  Removed .entire directory\\\")\\n  1009→\\t}\\n  1010→\\n  1011→\\t// 5. Remove shadow branches\\n  1012→\\tbranchesRemoved, err := removeAllShadowBranches()\\n  1013→\\tif err != nil {\\n  1014→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove shadow branches: %v\\\\n\\\", err)\\n  1015→\\t} else if branchesRemoved > 0 {\\n  1016→\\t\\tfmt.Fprintf(w, \\\"  Removed %d shadow branch