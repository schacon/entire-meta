scription() string {\\n    47→\\treturn \\\"Gemini CLI - Google's AI coding assistant\\\"\\n    48→}\\n    49→\\n    50→// DetectPresence checks if Gemini CLI is configured in the repository.\\n    51→func (g *GeminiCLIAgent) DetectPresence() (bool, error) {\\n    52→\\t// Get repo root to check for .gemini directory\\n    53→\\t// This is needed because the CLI may be run from a subdirectory\\n    54→\\trepoRoot, err := paths.RepoRoot()\\n    55→\\tif err != nil {\\n    56→\\t\\t// Not in a git repo, fall back to CWD-relative check\\n    57→\\t\\trepoRoot = \\\".\\\"\\n    58→\\t}\\n    59→\\n    60→\\t// Check for .gemini directory\\n    61→\\tgeminiDir := filepath.Join(repoRoot, \\\".gemini\\\")\\n    62→\\tif _, err := os.Stat(geminiDir); err == nil {\\n    63→\\t\\treturn true, nil\\n    64→\\t}\\n    65→\\t// Check for .gemini/settings.json\\n    66→\\tsettingsFile := filepath.Join(repoRoot, \\\".gemini\\\", \\\"settings.json\\\")\\n    67→\\tif _, err := os.Stat(settingsFile); err == nil {\\n    68→\\t\\treturn true, nil\\n    69→\\t}\\n    70→\\treturn false, nil\\n    71→}\\n    72→\\n    73→// GetHookConfigPath returns the path to Gemini's hook config file.\\n    74→func (g *GeminiCLIAgent) GetHookConfigPath() string {\\n    75→\\treturn \\\".gemini/settings.json\\\"\\n    76→}\\n    77→\\n    78→// SupportsHooks returns true as Gemini CLI supports lifecycle hooks.\\n    79→func (g *GeminiCLIAgent) SupportsHooks() bool {\\n    80→\\treturn true\\n    81→}\\n    82→\\n    83→// ParseHookInput parses Gemini CLI hook input from stdin.\\n    84→func (g *GeminiCLIAgent) ParseHookInput(hookType agent.HookType, reader io.Reader) (*agent.HookInput, error) {\\n    85→\\tdata, err := io.ReadAll(reader)\\n    86→\\tif err != nil {\\n    87→\\t\\treturn nil, fmt.Errorf(\\\"failed to read input: %w\\\", err)\\n    88→\\t}\\n    89→\\n    90→\\tif len(data) == 0 {\\n    91→\\t\\treturn nil, errors.New(\\\"empty input\\\")\\n    92→\\t}\\n    93→\\n    94→\\tinput := &agent.HookInput{\\n    95→\\t\\tHookType:  hookType,\\n    96→\\t\\tTimestamp: time.Now(),\\n    97→\\t\\tRawData:   make(map[string]interface{}),\\n    98→\\t}\\n    99→\\n   100→\\t// Parse based on hook type\\n   101→\\tswitch hookType {\\n   102→\\tcase agent.HookSessionStart, agent.HookSessionEnd, agent.HookStop:\\n   103→\\t\\tvar raw sessionInfoRaw\\n   104→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   105→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse session info: %w\\\", err)\\n   106→\\t\\t}\\n   107→\\t\\tinput.SessionID = raw.SessionID\\n   108→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   109→\\t\\t// Store Gemini-specific fields in RawData\\n   110→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   111→\\t\\tinput.RawData[\\\"hook_event_name\\\"] = raw.HookEventName\\n   112→\\t\\tif raw.Source != \\\"\\\" {\\n   113→\\t\\t\\tinput.RawData[\\\"source\\\"] = raw.Source\\n   114→\\t\\t}\\n   115→\\t\\tif raw.Reason != \\\"\\\" {\\n   116→\\t\\t\\tinput.RawData[\\\"reason\\\"] = raw.Reason\\n   117→\\t\\t}\\n   118→\\n   119→\\tcase agent.HookUserPromptSubmit:\\n   120→\\t\\t// BeforeAgent is Gemini's equivalent to Claude's UserPromptSubmit\\n   121→\\t\\t// It provides the user's prompt in the \\\"prompt\\\" field\\n   122→\\t\\tvar raw agentHookInputRaw\\n   123→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   124→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse agent hook input: %w\\\", err)\\n   125→\\t\\t}\\n   126→\\t\\tinput.SessionID = raw.SessionID\\n   127→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   128→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   129→\\t\\tinput.RawData[\\\"hook_event_name\\\"] = raw.HookEventName\\n   130→\\t\\tif raw.Prompt != \\\"\\\" {\\n   131→\\t\\t\\tinput.UserPrompt = raw.Prompt\\n   132→\\t\\t\\tinput.RawData[\\\"prompt\\\"] = raw.Prompt\\n   133→\\t\\t}\\n   134→\\n   135→\\tcase agent.HookPreToolUse, agent.HookPostToolUse:\\n   136→\\t\\tvar raw toolHookInputRaw\\n   137→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   138→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse tool hook input: %w\\\", err)\\n   139→\\t\\t}\\n   140→\\t\\tinput.SessionID = raw.SessionID\\n   141→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   142→\\t\\tinput.ToolName = raw.ToolName\\n   143→\\t\\tinput.ToolInput = raw.ToolInput\\n   144→\\t\\tif hookType == agent.HookPostToolUse {\\n   145→\\t\\t\\tinput.ToolResponse = raw.ToolResponse\\n   146→\\t\\t}\\n   147→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   148→\\t\\tinput.RawData[\\\"hook_event_name\\\"] = raw.HookEventName\\n   149→\\t}\\n   150→\\n   151→\\treturn input, nil\\n   152→}\\n   153→\\n   154→// GetSessionID extracts the session ID from hook input.\\n   155→func (g *GeminiCLIAgent) GetSessionID(input *agent.HookInput) string {\\n   156→\\treturn input.SessionID\\n   157→}\\n   158→\\n   159→// ProtectedDirs returns directories that Gemini uses for config/state.\\n   160→func (g *GeminiCLIAgent) ProtectedDirs() []string { return []string{\\\".gemini\\\"} }\\n   161→\\n   162→// ResolveSessionFile returns the path to a Gemini session file.\\n   163→// Gemini names files as session-<date>-<shortid>.json where shortid is the first 8 chars\\n   164→// of the session UUID. This searches for an existing file matching the pattern, falling\\n   165→// back to <dir>/<id>.json if no match is found.\\n   166→func (g *GeminiCLIAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   167→\\t// Try to find existing file matching Gemini's naming convention:\\n   168→\\t// session-*-<first8chars>.json\\n   169→\\tshortID := agentSessionID\\n   170→\\tif len(shortID) > 8 {\\n   171→\\t\\tshortID = shortID[:8]\\n   172→\\t}\\n   173→\\n   174→\\tpattern := filepath.Join(sessionDir, \\\"session-*-\\\"+shortID+\\\".json\\\")\\n   175→\\tmatches, err := filepath.Glob(pattern)\\n   176→\\tif err == nil && len(matches) > 0 {\\n   177→\\t\\t// Return the most recent match (last alphabetically, since date is in the name)\\n   178→\\t\\treturn matches[len(matches)-1]\\n   179→\\t}\\n   180→\\n   181→\\t// Fallback: construct a default path\\n   182→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".json\\\")\\n   183→}\\n   184→\\n   185→// GetSessionDir returns the directory where Gemini stores session transcripts.\\n   186→// Gemini stores sessions in ~/.gemini/tmp/<project-hash>/chats/\\n   187→func (g *GeminiCLIAgent) GetSessionDir(repoPath string) (string, error) {\\n   188→\\t// Check for test environment override\\n   189→\\tif override := os.Getenv(\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR\\\"); override != \\\"\\\" {\\n   190→\\t\\treturn override, nil\\n   191→\\t}\\n   192→\\n   193→\\thomeDir, err := os.UserHomeDir()\\n   194→\\tif err != nil {\\n   195→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   196→\\t}\\n   197→\\n   198→\\t// Gemini uses a hash of the project path for the directory name\\n   199→\\tprojectDir := SanitizePathForGemini(repoPath)\\n   200→\\treturn filepath.Join(homeDir, \\\".gemini\\\", \\\"tmp\\\", projectDir, \\\"chats\\\"), nil\\n   201→}\\n   202→\\n   203→// ReadSession reads a session from Gemini's storage (JSON transcript file).\\n   204→// The session data is stored in NativeData as raw JSON bytes.\\n   205→func (g *GeminiCLIAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   206→\\tif input.SessionRef == \\\"\\\" {\\n   207→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   208→\\t}\\n   209→\\n   210→\\t// Read the raw JSON file\\n   211→\\tdata, err := os.ReadFile(input.SessionRef)\\n   212→\\tif err != nil {\\n   213→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   214→\\t}\\n   215→\\n   216→\\t// Parse to extract computed fields\\n   217→\\tmodifiedFiles, err := ExtractModifiedFiles(data)\\n   218→\\tif err != nil {\\n   219→\\t\\t// Non-fatal: we can still return the