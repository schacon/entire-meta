er registryMu.RUnlock()\\n    59→\\n    60→\\tfor _, factory := range registry {\\n    61→\\t\\tag := factory()\\n    62→\\t\\tif present, err := ag.DetectPresence(); err == nil && present {\\n    63→\\t\\t\\treturn ag, nil\\n    64→\\t\\t}\\n    65→\\t}\\n    66→\\treturn nil, fmt.Errorf(\\\"no agent detected (available: %v)\\\", List())\\n    67→}\\n    68→\\n    69→// AgentName is the registry key type for agents (e.g., \\\"claude-code\\\", \\\"gemini\\\").\\n    70→//\\n    71→//nolint:revive // stuttering is intentional - distinguishes from AgentType when both are used\\n    72→type AgentName string\\n    73→\\n    74→// AgentType is the display name type stored in metadata/trailers (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\").\\n    75→//\\n    76→//nolint:revive // stuttering is intentional - distinguishes from AgentName when both are used\\n    77→type AgentType string\\n    78→\\n    79→// Agent name constants (registry keys)\\n    80→const (\\n    81→\\tAgentNameClaudeCode AgentName = \\\"claude-code\\\"\\n    82→\\tAgentNameGemini     AgentName = \\\"gemini\\\"\\n    83→)\\n    84→\\n    85→// Agent type constants (type identifiers stored in metadata/trailers)\\n    86→const (\\n    87→\\tAgentTypeClaudeCode AgentType = \\\"Claude Code\\\"\\n    88→\\tAgentTypeGemini     AgentType = \\\"Gemini CLI\\\"\\n    89→\\tAgentTypeUnknown    AgentType = \\\"Agent\\\" // Fallback for backwards compatibility\\n    90→)\\n    91→\\n    92→// DefaultAgentName is the registry key for the default agent.\\n    93→const DefaultAgentName AgentName = AgentNameClaudeCode\\n    94→\\n    95→// GetByAgentType retrieves an agent by its type identifier.\\n    96→//\\n    97→// Note: This uses a linear search that instantiates agents until a match is found.\\n    98→// This is acceptable because:\\n    99→//   - Agent count is small (~2-20 agents)\\n   100→//   - Agent factories are lightweight (empty struct allocation)\\n   101→//   - Called infrequently (commit hooks, rewind