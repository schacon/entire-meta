ad existing settings to preserve other options (like strategy_options.push)\\n   256→\\tsettings, err := LoadEntireSettings()\\n   257→\\tif err != nil {\\n   258→\\t\\t// If we can't load, start with defaults\\n   259→\\t\\tsettings = &EntireSettings{}\\n   260→\\t}\\n   261→\\t// Update the specific fields\\n   262→\\tsettings.Strategy = internalStrategy\\n   263→\\tsettings.LocalDev = localDev\\n   264→\\tsettings.Enabled = true\\n   265→\\n   266→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   267→\\tif skipPushSessions {\\n   268→\\t\\tif settings.StrategyOptions == nil {\\n   269→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   270→\\t\\t}\\n   271→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   272→\\t}\\n   273→\\n   274→\\t// Handle telemetry for non-interactive mode\\n   275→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   276→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   277→\\t\\tf := false\\n   278→\\t\\tsettings.Telemetry = &f\\n   279→\\t}\\n   280→\\n   281→\\t// Determine which settings file to write to\\n   282→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   283→\\tif err != nil {\\n   284→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   285→\\t}\\n   286→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   287→\\n   288→\\tif showNotification {\\n   289→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   290→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   291→\\t}\\n   292→\\n   293→\\tconfigDisplay := configDisplayProject\\n   294→\\tif shouldUseLocal {\\n   295→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   296→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   297→\\t\\t}\\n   298→\\t\\tconfigDisplay = configDisplayLocal\\n   299→\\t} else {\\n   300→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   301→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   302→\\t\\t}\\n   303→\\t}\\n   304→\\n   305→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   306→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   307→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   308→\\t}\\n   309→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   310→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   311→\\n   312→\\t// Let the strategy handle its own setup requirements\\n   313→\\tif err := strat.EnsureSetup(); err != nil {\\n   314→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   315→\\t}\\n   316→\\n   317→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   318→\\n   319→\\treturn nil\\n   320→}\\n   321→\\n   322→// runEnableInteractive runs the interactive enable flow.\\n   323→func runEnableInteractive(w io.Writer, localDev, _, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry bool) error {\\n   324→\\t// Check if already fully enabled — show summary and return early.\\n   325→\\t// Skip early return if any configuration flags are set (user wants to reconfigure).\\n   326→\\thasConfigFlags := forceHooks || skipPushSessions || !telemetry || useLocalSettings || useProjectSettings || localDev\\n   327→\\tif !hasConfigFlags {\\n   328→\\t\\tif fullyEnabled, agentDesc, configPath := isFullyEnabled(); fullyEnabled {\\n   329→\\t\\t\\tfmt.Fprintln(w, \\\"Already enabled. Everything looks good.\\\")\\n   330→\\t\\t\\tfmt.Fprintln(w)\\n   331→\\t\\t\\tfmt.Fprintf(w, \\\"  Agent: %s\\\\n\\\", agentDesc)\\n   332→\\t\\t\\tfmt.Fprintf(w, \\\"  Config: %s\\\\n\\\", configPath)\\n   333→\\t\\t\\treturn nil\\n   334→\\t\\t}\\n   335→\\t}\\n   336→\\n   337→\\t// Detect default a