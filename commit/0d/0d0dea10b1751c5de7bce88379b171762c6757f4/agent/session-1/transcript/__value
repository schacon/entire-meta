ssage\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_019Ak4WNJRio4Ads3qLJA9wy\",\"type\":\"tool_result\",\"content\":\"     1→// Package claudecode implements the Agent interface for Claude Code.\\n     2→package claudecode\\n     3→\\n     4→import (\\n     5→\\t\\\"bufio\\\"\\n     6→\\t\\\"encoding/json\\\"\\n     7→\\t\\\"errors\\\"\\n     8→\\t\\\"fmt\\\"\\n     9→\\t\\\"io\\\"\\n    10→\\t\\\"os\\\"\\n    11→\\t\\\"path/filepath\\\"\\n    12→\\t\\\"regexp\\\"\\n    13→\\t\\\"time\\\"\\n    14→\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    18→)\\n    19→\\n    20→//nolint:gochecknoinits // Agent self-registration is the intended pattern\\n    21→func init() {\\n    22→\\tagent.Register(agent.AgentNameClaudeCode, NewClaudeCodeAgent)\\n    23→}\\n    24→\\n    25→// ClaudeCodeAgent implements the Agent interface for Claude Code.\\n    26→//\\n    27→//nolint:revive // ClaudeCodeAgent is clearer than Agent in this context\\n    28→type ClaudeCodeAgent struct{}\\n    29→\\n    30→// NewClaudeCodeAgent creates a new Claude Code agent instance.\\n    31→func NewClaudeCodeAgent() agent.Agent {\\n    32→\\treturn &ClaudeCodeAgent{}\\n    33→}\\n    34→\\n    35→// Name returns the agent registry key.\\n    36→func (c *ClaudeCodeAgent) Name() agent.AgentName {\\n    37→\\treturn agent.AgentNameClaudeCode\\n    38→}\\n    39→\\n    40→// Type returns the agent type identifier.\\n    41→func (c *ClaudeCodeAgent) Type() agent.AgentType {\\n    42→\\treturn agent.AgentTypeClaudeCode\\n    43→}\\n    44→\\n    45→// Description returns a human-readable description.\\n    46→func (c *ClaudeCodeAgent) Description() string {\\n    47→\\treturn \\\"Claude Code - Anthropic's CLI coding assistant\\\"\\n    48→}\\n    49→\\n    50→// DetectPresence checks if Claude Code is configured in the repository.\\n    51→func (c *ClaudeCodeAgent) DetectPresence() (bool, error) {\\n    52→\\t// Get repo root to check for .claude directory\\n    53→\\t// This is needed because the CLI may be run from a subdirectory\\n    54→\\trepoRoot, err := paths.RepoRoot()\\n    55→\\tif err != nil {\\n    56→\\t\\t// Not in a git repo, fall back to CWD-relative check\\n    57→\\t\\trepoRoot = \\\".\\\"\\n    58→\\t}\\n    59→\\n    60→\\t// Check for .claude directory\\n    61→\\tclaudeDir := filepath.Join(repoRoot, \\\".claude\\\")\\n    62→\\tif _, err := os.Stat(claudeDir); err == nil {\\n    63→\\t\\treturn true, nil\\n    64→\\t}\\n    65→\\t// Check for .claude/settings.json\\n    66→\\tsettingsFile := filepath.Join(repoRoot, \\\".claude\\\", \\\"settings.json\\\")\\n    67→\\tif _, err := os.Stat(settingsFile); err == nil {\\n    68→\\t\\treturn true, nil\\n    69→\\t}\\n    70→\\treturn false, nil\\n    71→}\\n    72→\\n    73→// GetHookConfigPath returns the path to Claude's hook config file.\\n    74→func (c *ClaudeCodeAgent) GetHookConfigPath() string {\\n    75→\\treturn \\\".claude/settings.json\\\"\\n    76→}\\n    77→\\n    78→// SupportsHooks returns true as Claude Code supports lifecycle hooks.\\n    79→func (c *ClaudeCodeAgent) SupportsHooks() bool {\\n    80→\\treturn true\\n    81→}\\n    82→\\n    83→// ParseHookInput parses Claude Code hook input from stdin.\\n    84→func (c *ClaudeCodeAgent) ParseHookInput(hookType agent.HookType, reader io.Reader) (*agent.HookInput, error) {\\n    85→\\tdata, err := io.ReadAll(reader)\\n    86→\\tif err != nil {\\n    87→\\t\\treturn nil, fmt.Errorf(\\\"failed to read input: %w\\\", err)\\n    88→\\t}\\n    89→\\n    90→\\tif len(data) == 0 {\\n    91→\\t\\treturn nil, errors.New(\\\"empty input\\\")\\n    92→\\t}\\n    93→\\n    94→\\tinput := &agent.HookInput{\\n    95→\\t\\tHookType:  hookType,\\n    96→\\t\\tTimestamp: time.Now(),\\n    97→\\t\\tRawData:   make(map[string]interface{}),\\n    98→\\t}\\n    99→\\n   100→\\t// Parse based on hook type\\n   101→\\tswitch hookType {\\n   102→\\tcase agent.HookUserPromptSubmit:\\n   103→\\t\\tvar raw userPromptSubmitRaw\\n   104→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   105→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse user prompt submit: %w\\\", err)\\n   106→\\t\\t}\\n   107→\\t\\tinput.SessionID = raw.SessionID\\n   108→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   109→\\t\\tinput.UserPrompt = raw.Prompt\\n   110→\\n   111→\\tcase agent.HookSessionStart, agent.HookSessionEnd, agent.HookStop:\\n   112→\\t\\tvar raw sessionInfoRaw\\n   113→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   114→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse session info: %w\\\", err)\\n   115→\\t\\t}\\n   116→\\t\\tinput.SessionID = raw.SessionID\\n   117→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   118→\\n   119→\\tcase agent.HookPreToolUse:\\n   120→\\t\\tvar raw taskHookInputRaw\\n   121→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   122→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse pre-tool input: %w\\\", err)\\n   123→\\t\\t}\\n   124→\\t\\tinput.SessionID = raw.SessionID\\n   125→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   126→\\t\\tinput.ToolUseID = raw.ToolUseID\\n   127→\\t\\tinput.ToolInput = raw.ToolInput\\n   128→\\n   129→\\tcase agent.HookPostToolUse:\\n   130→\\t\\tvar raw postToolHookInputRaw\\n   131→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   132→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse post-tool input: %w\\\", err)\\n   133→\\t\\t}\\n   134→\\t\\tinput.SessionID = raw.SessionID\\n   135→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   136→\\t\\tinput.ToolUseID = raw.ToolUseID\\n   137→\\t\\tinput.ToolInput = raw.ToolInput\\n   138→\\t\\t// Store agent ID in raw data for Task tool results\\n   139→\\t\\tif raw.ToolResponse.AgentID != \\\"\\\" {\\n   140→\\t\\t\\tinput.RawData[\\\"agent_id\\\"] = raw.ToolResponse.AgentID\\n   141→\\t\\t}\\n   142→\\t}\\n   143→\\n   144→\\treturn input, nil\\n   145→}\\n   146→\\n   147→// GetSessionID extracts the session ID from hook input.\\n   148→func (c *ClaudeCodeAgent) GetSessionID(input *agent.HookInput) string {\\n   149→\\treturn input.SessionID\\n   150→}\\n   151→\\n   152→// ResolveSessionFile returns the path to a Claude session file.\\n   153→// Claude names files directly as <id>.jsonl.\\n   154→func (c *ClaudeCodeAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   155→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".jsonl\\\")\\n   156→}\\n   157→\\n   158→// ProtectedDirs returns directories that Claude uses for config/state.\\n   159→func (c *ClaudeCodeAgent) ProtectedDirs() []string { return []string{\\\".claude\\\"} }\\n   160→\\n   161→// GetSessionDir returns the directory where Claude stores session transcripts.\\n   162→func (c *ClaudeCodeAgent) GetSessionDir(repoPath string) (string, error) {\\n   163→\\t// Check for test environment override\\n   164→\\tif override := os.Getenv(\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR\\\"); override != \\\"\\\" {\\n   165→\\t\\treturn override, nil\\n   166→\\t}\\n   167→\\n   168→\\thomeDir, err := os.UserHomeDir()\\n   169→\\tif err != nil {\\n   170→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   171→\\t}\\n   172→\\n   173→\\tprojectDir := SanitizePathForClaude(repoPath)\\n   174→\\treturn filepath.Join(homeDir, \\\".claude\\\", \\\"projects\\\", projectDir), nil\\n   175→}\\n   176→\\n   177→// ReadSession reads a session from Claude's storage (JSONL transcript file).\\n   178→// The session data is stored in NativeData as raw JSONL bytes.\\n   179→// ModifiedFiles is computed by parsing the transcript.\\n   180→func (c *ClaudeCodeAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   181→\\tif input.SessionRef == \\\"\\\" {\\n   182→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   183→\\t}\\n   184→\\n   185→\\t// Read the raw JSONL file\\n   186→\\tdata, err := os.ReadFile(input.SessionRef)\\n   187→\\tif err != nil {\\n   188→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   189→\\t}\\n   190→\\n   191→\\t// Parse to extract computed fields\\n   192→\\tlines, err := transcript.ParseFromBytes(data)\\n   193→\\tif err != nil {\\n   194→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   195→\\t}\\n   196→\\n   197→\\treturn &agent.AgentSession{\\n   198→\\t\\tSessionID:     input.SessionID,\\n   199→\\t\\tAgentName:     c.Name(),\\n   200→\\t\\tSessionRef:    input.SessionRef,\\n   201→\\t\\tStartTime:     time.Now(),\\n   202→\\t\\tNativeData:    data,\\n   203→\\t\\tModifiedFiles: ExtractModifiedFiles(lines),\\n   204→\\t}, nil\\n   205→}\\n   206→\\n   207→// WriteSession writes a session to Claude's storage (JSONL transcript file).\\n   208→// Uses the NativeData field which contains raw JSONL bytes.\\n   209→// The session must have been created by Claude Code (AgentName check).\\n   210→func (c *ClaudeCodeAgent) WriteSession(session *agent.AgentSession) error {\\n   211→\\tif session == nil {\\n   212→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   213→\\t}\\n   214→\\n   215→\\t// Verify this session belongs to Claude Code\\n   216→\\tif session.AgentName != \\\"\\\" && session.AgentName != c.Name() {\\n   217→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, c.Name())\\n   218→\\t}\\n   219→\\n   220→\\tif session.SessionRef == \\\"\\\" {\\n   221→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   222→\\t}\\n   223→\\n   224→\\tif len(session.NativeData) == 0 {\\n   225→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   226→\\t}\\n   227→\\n   228→\\t// Write the raw JSONL data\\n   229→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   230→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   231→\\t}\\n   232→\\n   233→\\treturn nil\\n   234→}\\n   235→\\n   236→// FormatResumeCommand returns the command to resume a Claude Code session.\\n   237→func (c *ClaudeCodeAgent) FormatResumeCommand(sessionID string) string {\\n   238→\\treturn \\\"claude -r \\\" + sessionID\\n   239→}\\n   240→\\n   241→// Session helper methods - work on AgentSession with Claude's native JSONL data\\n   242→\\n   243→// GetLastUserPrompt extracts the last user prompt from the session.\\n   244→// Requires NativeData to be populated (call ReadSession first).\\n   245→func (c *ClaudeCodeAgent) GetLastUserPrompt(session *agent.AgentSession) string {\\n   246→\\tif session == nil || len(session.NativeData) == 0 {\\n   247→\\t\\treturn \\\"\\\"\\n   248→\\t}\\n   249→\\n   250→\\tlines, err := transcript.ParseFromBytes(session.NativeData)\\n   251→\\tif err != nil {\\n   252→\\t\\treturn \\\"\\\"\\n   253→\\t}\\n   254→\\n   255→\\treturn ExtractLastUserPrompt(lines)\\n   256→}\\n   257→\\n   258→// TruncateAtUUID returns a new session truncated at the given UUID (inclusive).\\n   259→// This is used for rewind operations to restore transcript state.\\n   260→// Requires NativeData to be populated.\\n   261→func (c *ClaudeCodeAgent) TruncateAtUUID(session *agent.AgentSession, uuid string) (*agent.AgentSession, error) {\\n   262→\\tif session == nil {\\n   263→\\t\\treturn nil, errors.New(\\\"session is nil\\\")\\n   264→\\t}\\n   265→\\n   266→\\tif len(session.NativeData) == 0 {\\n   267→\\t\\treturn nil, errors.New(\\\"session has no native data\\\")\\n   268→\\t}\\n   269→\\n   270→\\tif uuid == \\\"\\\" {\\n   271→\\t\\t// No truncation needed, return copy\\n   272→\\t\\treturn &agent.AgentSession{\\n   273→\\t\\t\\tSessionID:     session.SessionID,\\n   274→\\t\\t\\tAgentName:     session.AgentName,\\n   275→\\t\\t\\tRepoPath:      session.RepoPath,\\n   276→\\t\\t\\tSessionRef:    session.SessionRef,\\n   277→\\t\\t\\tStartTime:     session.StartTime,\\n   278→\\t\\t\\tNativeData:    session.NativeData,\\n   279→\\t\\t\\tModifiedFiles: session.ModifiedFiles,\\n   280→\\t\\t}, nil\\n   281→\\t}\\n   282→\\n   283→\\t// Parse, truncate, re-serialize\\n   284→\\tlines, err := transcript.ParseFromBytes(session.NativeData)\\n   285→\\tif err != nil {\\n   286→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   287→\\t}\\n   288→\\n   289→\\ttruncated := TruncateAtUUID(lines, uuid)\\n   290→\\n   291→\\tnewData, err := SerializeTranscript(truncated)\\n   292→\\tif err != nil {\\n   293→\\t\\treturn nil, fmt.Errorf(\\\"failed to serialize truncated transcript: %w\\\", err)\\n   294→\\t}\\n   295→\\n   296→\\treturn &agent.AgentSession{\\n   297→\\t\\tSessionID:     session.SessionID,\\n   298→\\t\\tAgentName:     session.AgentName,\\n   299→\\t\\tRepoPath:      session.RepoPath,\\n   300→\\t\\tSessionRef:    session.SessionRef,\\n   301→\\t\\tStartTime:     session.StartTime,\\n   302→\\t\\tNativeData:    newData,\\n   303→\\t\\tModifiedFiles: ExtractModifiedFiles(truncated),\\n   304→\\t}, nil\\n   305→}\\n   306→\\n   307→// FindCheckpointUUID finds the UUID of the message containing the tool_result\\n   308→// for the given tool use ID. Used for task checkpoint rewind.\\n   309→// Returns the UUID and true if found, empty string and false otherwise.\\n   310→func (c *ClaudeCodeAgent) FindCheckpointUUID(session *agent.AgentSession, toolUseID string) (string, bool) {\\n   311→\\tif session == nil || len(session.NativeData) == 0 {\\n   312→\\t\\treturn \\\"\\\", false\\n   313→\\t}\\n   314→\\n   315→\\tlines, err := transcript.ParseFromBytes(session.NativeData)\\n   316→\\tif err != nil {\\n   317→\\t\\treturn \\\"\\\", false\\n   318→\\t}\\n   319→\\n   320→\\treturn FindCheckpointUUID(lines, toolUseID)\\n   321→}\\n   322→\\n   323→// ReadSessionFromPath is a convenience method that reads a session directly from a file path.\\n   324→// This is useful when you have the path but not a HookInput.\\n   325→func (c *ClaudeCodeAgent) ReadSessionFromPath(transcriptPath, sessionID string) (*agent.AgentSession, error) {\\n   326→\\treturn c.ReadSession(&agent.HookInput{\\n   327→\\t\\tSessionID:  sessionID,\\n   328→\\t\\tSessionRef: transcriptPath,\\n   329→\\t})\\n   330→}\\n   331→\\n   332→// SanitizePathForClaude converts a path to Claude's project directory format.\\n   333→// Claude replaces any non-alphanumeric character with a dash.\\n   334→var nonAlphanumericRegex = regexp.MustCompile(`[^a-zA-Z0-9]`)\\n   335→\\n   336→func SanitizePathForClaude(path string) string {\\n   337→\\treturn nonAlphanumericRegex.ReplaceAllString(path, \\\"-\\\")\\n   338→}\\n   339→\\n   340→// TranscriptAnalyzer interface implementation\\n   341→\\n   342→// GetTranscriptPosition returns the current line count of a Claude Code transcript.\\n   343→// Claude Code uses JSONL format, so position is the number of lines.\\n   344→// This is a lightweight operation that only counts lines without parsing JSON.\\n   345→// Uses bufio.Reader to handle arbitrarily long lines (no size limit).\\n   346→// Returns 0 if the file doesn't exist or is empty.\\n   347→func (c *ClaudeCodeAgent) GetTranscriptPosition(path string) (int, error) {\\n   348→\\tif path == \\\"\\\" {\\n   349→\\t\\treturn 0, nil\\n   350→\\t}\\n   351→\\n   352→\\tfile, err := os.Open(path) //nolint:gosec // Path comes from Claude Code transcript location\\n   353→\\tif err != nil {\\n   354→\\t\\tif os.IsNotExist(err) {\\n   355→\\t\\t\\treturn 0, nil\\n   356→\\t\\t}\\n   357→\\t\\treturn 0, fmt.Errorf(\\\"failed to open transcript file: %w\\\", err)\\n   358→\\t}\\n   359→\\tdefer file.Close()\\n   360→\\n   361→\\treader := bufio.NewReader(file)\\n   362→\\tlineCount := 0\\n   363→\\n   364→\\tfor {\\n   365→\\t\\tline, err := reader.ReadBytes('\\\\n')\\n   366→\\t\\tif err != nil {\\n   367→\\t\\t\\tif err == io.EOF {\\n   368→\\t\\t\\t\\tif len(line) > 0 {\\n   369→\\t\\t\\t\\t\\tlineCount++ // Count final line without trailing newline\\n   370→\\t\\t\\t\\t}\\n   371→\\t\\t\\t\\tbreak\\n   372→\\t\\t\\t}\\n   373→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   374→\\t\\t}\\n   375→\\t\\tlineCount++\\n   376→\\t}\\n   377→\\n   378→\\treturn lineCount, nil\\n   379→}\\n   380→\\n   381→// ExtractModifiedFilesFromOffset extracts files modified since a given line number.\\n   382→// For Claude Code (JSONL format), offset is the starting line number.\\n   383→// Uses bufio.Reader to handle arbitrarily long lines (no size limit).\\n   384→// Returns:\\n   385→//   - files: list of file paths modified by Claude (from Write/Edit tools)\\n   386→//   - currentPosition: total number of lines in the file\\n   387→//   - error: any error encountered during reading\\n   388→func (c *ClaudeCodeAgent) ExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error) {\\n   389→\\tif path == \\\"\\\" {\\n   390→\\t\\treturn nil, 0, nil\\n   391→\\t}\\n   392→\\n   393→\\tfile, openErr := os.Open(path) //nolint:gosec // Path comes from Claude Code transcript location\\n   394→\\tif openErr != nil {\\n   395→\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to open transcript file: %w\\\", openErr)\\n   396→\\t}\\n   397→\\tdefer file.Close()\\n   398→\\n   399→\\treader := bufio.NewReader(file)\\n   400→\\tvar lines []TranscriptLine\\n   401→\\tlineNum := 0\\n   402→\\n   403→\\tfor {\\n   404→\\t\\tlineData, readErr := reader.ReadBytes('\\\\n')\\n   405→\\t\\tif readErr != nil && readErr != io.EOF {\\n   406→\\t\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", readErr)\\n   407→\\t\\t}\\n   408→\\n   409→\\t\\tif len(lineData) > 0 {\\n   410→\\t\\t\\tlineNum++\\n   411→\\t\\t\\tif lineNum > startOffset {\\n   412→\\t\\t\\t\\tvar line TranscriptLine\\n   413→\\t\\t\\t\\tif parseErr := json.Unmarshal(lineData, &line); parseErr == nil {\\n   414→\\t\\t\\t\\t\\tlines = append(lines, line)\\n   415→\\t\\t\\t\\t}\\n   416→\\t\\t\\t\\t// Skip malformed lines silently\\n   417→\\t\\t\\t}\\n   418→\\t\\t}\\n   419→\\n   420→\\t\\tif readErr == io.EOF {\\n   421→\\t\\t\\tbreak\\n   422→\\t\\t}\\n   423→\\t}\\n   424→\\n   425→\\treturn ExtractModifiedFiles(lines), lineNum, nil\\n   426→}\\n   427→\\n   428→// ChunkTranscript splits a JSONL transcript at line boundaries.\\n   429→// Claude Code uses JSONL format (one JSON object per line), so chunking\\n   430→// is done at newline boundaries to preserve message integrity.\\n   431→func (c *ClaudeCodeAgent) ChunkTranscript(content []byte, maxSize int) ([][]byte, error) {\\n   432→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n   433→\\tif err != nil {\\n   434→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk JSONL transcript: %w\\\", err)\\n   435→\\t}\\n   436→\\treturn chunks, nil\\n   437→}\\n   438→\\n   439→// ReassembleTranscript concatenates JSONL chunks with newlines.\\n   440→//\\n   441→\\n   442→func (c *ClaudeCodeAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n   443→\\treturn agent.ReassembleJSONL(chunks), nil\\n   444→}\\n   445→\\n   446→// SubagentAwareExtractor interface implementation\\n   447→\\n   448→// ExtractAllModifiedFiles extracts files modified by both the main agent and any spawned subagents.\\n   449→// Claude Code spawns subagents via the Task tool; their transcripts are stored in subagentsDir.\\n   450→// Returns a deduplicated list of all modified file paths.\\n   451→func (c *ClaudeCodeAgent) ExtractAllModifiedFiles(sessionRef string, fromOffset int, subagentsDir string) ([]string, error) {\\n   452→\\treturn ExtractAllModifiedFiles(sessionRef, fromOffset, subagentsDir)\\n   453→}\\n   454→\\n   455→// CalculateTotalTokenUsage computes token usage including all spawned subagents.\\n   456→// Claude Code spawns subagents via the Task tool; their transcripts are stored in subagentsDir.\\n   457→func (c *ClaudeCodeAge