spatchLifecycleEvent) handles all lifecycle events.\\n     3→// PostTodo is the only hook that's handled directly (not via lifecycle dispatcher).\\n     4→package cli\\n     5→\\n     6→import (\\n     7→\\t\\\"context\\\"\\n     8→\\t\\\"errors\\\"\\n     9→\\t\\\"fmt\\\"\\n    10→\\t\\\"log/slog\\\"\\n    11→\\t\\\"time\\\"\\n    12→\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/cursor\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    19→\\n    20→\\t\\\"github.com/spf13/cobra\\\"\\n    21→)\\n    22→\\n    23→// agentHookLogCleanup stores the cleanup function for agent hook logging.\\n    24→// Set by PersistentPreRunE, called by PersistentPostRunE.\\n    25→var agentHookLogCleanup func()\\n    26→\\n    27→// currentHookAgentName stores the agent name for the currently executing hook.\\n    28→// Set by newAgentHookVerbCmdWithLogging before calling the handler.\\n    29→// This allows handlers to know which agent invoked the hook without guessing.\\n    30→var currentHookAgentName agent.AgentName\\n    31→\\n    32→// GetCurrentHookAgent returns the agent for the currently executing hook.\\n    33→// Returns the agent based on the hook command structure (e.g., \\\"entire hooks claude-code ...\\\")\\n    34→// rather than guessing from directory presence.\\n    35→// Falls back to GetAgent() if not in a hook context.\\n    36→func GetCurrentHookAgent() (agent.Agent, error) {\\n    37→\\tif currentHookAgentName == \\\"\\\" {\\n    38→\\t\\treturn nil, errors.New(\\\"not in a hook context: agent name not set\\\")\\n    39→\\t}\\n    40→\\n    41→\\tag, err := agent.Get(currentHookAgentName)\\n    42→\\tif err != nil {\\n    43→\\t\\treturn nil, fmt.Errorf(\\\"getting hook agent %q: %w\\\", currentHookAgentName, err)\\n    44→\\t}\\n    45→\\treturn ag, nil\\n    46→}\\n    47→\\n    48→// newAgentHooksCmd creates a hooks subcommand for an agent that implements HookHandler.\\n    49→// It dynamically creates subcommands for each hook the agent supports.\\n    50→func newAgentHooksCmd(agentName agent.AgentName, handler agent.HookHandler) *cobra.Command {\\n    51→\\tcmd := &cobra.Command{\\n    52→\\t\\tUse:    string(agentName),\\n    53→\\t\\tShort:  handler.Description() + \\\" hook handlers\\\",\\n    54→\\t\\tHidden: true,\\n    55→\\t\\tPersistentPreRunE: func(_ *cobra.Command, _ []string) error {\\n    56→\\t\\t\\tagentHookLogCleanup = initHookLogging()\\n    57→\\t\\t\\treturn nil\\n    58→\\t\\t},\\n    59→\\t\\tPersistentPostRunE: func(_ *cobra.Command, _ []string) error {\\n    60→\\t\\t\\tif agentHookLogCleanup != nil {\\n    61→\\t\\t\\t\\tagentHookLogCleanup()\\n    62→\\t\\t\\t}\\n    63→\\t\\t\\treturn nil\\n    64→\\t\\t},\\n    65→\\t}\\n    66→\\n    67→\\tfor _, hookName := range handler.GetHookNames() {\\n    68→\\t\\tcmd.AddCommand(newAgentHookVerbCmdWithLogging(agentName, hookName))\\n    69→\\t}\\n    70→\\n    71→\\treturn cmd\\n    72→}\\n    73→\\n    74→// getHookType returns the hook type based on the hook name.\\n    75→// Returns \\\"subagent\\\" for task-related hooks (pre-task, post-task, post-todo),\\n    76→// \\\"tool\\\" for tool-related hooks (before-tool, after-tool),\\n    77→// \\\"agent\\\" for all other agent hooks.\\n    78→func getHookType(hookName string) string {\\n    79→\\t// Note: Claude Code and Cursor share the same hook names (pre-task, post-task, post-todo)\\n    80→\\tswitch hookName {\\n    81→\\tcase claudecode.HookNamePreTask, claudecode.HookNamePostTask, claudecode.HookNamePostTodo:\\n    82→\\t\\treturn \\\"subagent\\\"\\n    83→\\tcase geminicli.HookNameBeforeTool, geminicli.HookNameAfterTool:\\n    84→\\t\\treturn \\\"tool\\\"\\n    85→\\tdefault:\\n    86→\\t\\treturn \\\"agent\\\"\\n    87→\\t}\\n    88→}\\n    89→\\n    90→// newAgentHookVerbCmdWithLogging creates a command for a specific hook verb with structured logging.\\n    91→// It uses the lifecycle dispatcher (ParseHookEvent → DispatchLifecycleEvent) as the primary path.\\n    92→// PostTodo is handled directly as it's Claude-specific and not part of the lifecycle dispatcher.\\n    93→func newAgentHookVerbCmdWithLogging(agentName agent.AgentName, hookName string) *cobra.Command {\\n    94→\\treturn &cobra.Command{\\n    95→\\t\\tUse:    hookName,\\n    96→\\t\\tHidden: true,\\n    97→\\t\\tShort:  \\\"Called on \\\" + hookName,\\n    98→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    99→\\t\\t\\t// Skip silently if not in a git repository - hooks shouldn't prevent the agent from working\\n   100→\\t\\t\\tif _, err := paths.RepoRoot(); err != nil {\\n   101→\\t\\t\\t\\treturn nil\\n   102→\\t\\t\\t}\\n   103→\\n   104→\\t\\t\\t// Skip if Entire is not enabled\\n   105→\\t\\t\\tenabled, err := IsEnabled()\\n   106→\\t\\t\\tif err == nil && !enabled {\\n   107→\\t\\t\\t\\treturn nil\\n   108→\\t\\t\\t}\\n   109→\\n   110→\\t\\t\\tstart := time.Now()\\n   111→\\n   112→\\t\\t\\t// Initialize logging context with agent name\\n   113→\\t\\t\\tctx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"hooks\\\"), agentName)\\n   114→\\n   115→\\t\\t\\t// Get strategy name for logging\\n   116→\\t\\t\\tstrategyName := GetStrategy().Name()\\n   117→\\n   118→\\t\\t\\thookType := getHookType(hookName)\\n   119→\\n   120→\\t\\t\\tlogging.Debug(ctx, \\\"hook invoked\\\",\\n   121→\\t\\t\\t\\tslog.String(\\\"hook\\\", hookName),\\n   122→\\t\\t\\t\\tslog.String(\\\"hook_type\\\", hookType),\\n   123→\\t\\t\\t\\tslog.String(\\\"strategy\\\", strategyName),\\n   124→\\t\\t\\t)\\n   125→\\n   126→\\t\\t\\t// Set the current hook agent so handlers can retrieve it\\n   127→\\t\\t\\tcurrentHookAgentName = agentName\\n   128→\\t\\t\\tdefer func() { currentHookAgentName = \\\"\\\" }()\\n   129→\\n   130→\\t\\t\\t// Use the lifecycle dispatcher for all hooks\\n   131→\\t\\t\\tvar hookErr error\\n   132→\\t\\t\\tag, agentErr := agent.Get(agentName)\\n   133→\\t\\t\\tif agentErr != nil {\\n   134→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to get agent %q: %w\\\", agentName, agentErr)\\n   135→\\t\\t\\t}\\n   136→\\n   137→\\t\\t\\t// Use cmd.InOrStdin() to support testing with cmd.SetIn()\\n   138→\\t\\t\\tevent, parseErr := ag.ParseHookEvent(hookName, cmd.InOrStdin())\\n   139→\\t\\t\\tif parseErr != nil {\\n   140→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to parse hook event: %w\\\", parseErr)\\n   141→\\t\\t\\t}\\n   142→\\n   143→<<<<<<< HEAD\\n   144→\\t\\t\\tswitch {\\n   145→\\t\\t\\tcase event != nil:\\n   146→\\t\\t\\t\\t// Lifecycle event — use the generic dispatcher\\n   147→\\t\\t\\t\\thookErr = DispatchLifecycleEvent(ag, event)\\n   148→\\t\\t\\tcase agentName == agent.AgentNameClaudeCode && hookName == claudecode.HookNamePostTodo:\\n   149→\\t\\t\\t\\t// PostTodo creates incremental checkpoints during subagent execution\\n   150→\\t\\t\\t\\thookErr = handleClaudeCodePostTodo()\\n   151→\\t\\t\\tcase agentName == agent.AgentNameCursor && hookName == cursor.HookNamePostTodo:\\n   152→\\t\\t\\t\\t// PostTodo creates incremental checkpoints during subagent execution\\n   153→\\t\\t\\t\\thookErr = handleCursorPostTodo()\\n   154→=======\\n   155→\\t\\t\\tif event != nil {\\n   156→\\t\\t\\t\\t// Lifecycle event — use the generic dispatcher\\n   157→\\t\\t\\t\\thookErr = DispatchLifecycleEvent(ag, event)\\n   158→\\t\\t\\t} else if agentName == agent.AgentNameClaudeCode && hookName == claudecode.HookNamePostTodo {\\n   159→\\t\\t\\t\\t// PostTodo is Claude-specific: creates incremental checkpoints during subagent execution\\n   160→\\t\\t\\t\\thookErr = handleClaudeCodePostTodo()\\n   161→>>>>>>> origin/main\\n   162→\\t\\t\\t}\\n   163→\\t\\t\\t// Other pass-through hooks (nil event, no special handl