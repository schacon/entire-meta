\\n     9→\\n    10→const (\\n    11→\\t// MaxChunkSize is the maximum size for a single transcript chunk.\\n    12→\\t// GitHub has a 100MB limit per blob, so we use 50MB to be safe.\\n    13→\\tMaxChunkSize = 50 * 1024 * 1024 // 50MB\\n    14→\\n    15→\\t// ChunkSuffix is the format for chunk file suffixes (e.g., \\\".001\\\", \\\".002\\\")\\n    16→\\tChunkSuffix = \\\".%03d\\\"\\n    17→)\\n    18→\\n    19→// ChunkTranscript splits a transcript into chunks using the appropriate agent.\\n    20→// If agentType is empty or the agent is not found, falls back to JSONL (line-based) chunking.\\n    21→func ChunkTranscript(content []byte, agentType AgentType) ([][]byte, error) {\\n    22→\\tif len(content) <= MaxChunkSize {\\n    23→\\t\\treturn [][]byte{content}, nil\\n    24→\\t}\\n    25→\\n    26→\\t// Try to get the agent by type and use its format-aware chunking\\n    27→\\tif agentType != \\\"\\\" {\\n    28→\\t\\tag, err := GetByAgentType(agentType)\\n    29→\\t\\tif err == nil {\\n    30→\\t\\t\\tchunks, chunkErr := ag.ChunkTranscript(content, MaxChunkSize)\\n    31→\\t\\t\\tif chunkErr != nil {\\n    32→\\t\\t\\t\\treturn nil, fmt.Errorf(\\\"agent chunking failed: %w\\\", chunkErr)\\n    33→\\t\\t\\t}\\n    34→\\t\\t\\treturn chunks, nil\\n    35→\\t\\t}\\n    36→\\t}\\n    37→\\n    38→\\t// Fall back to JSONL chunking (default)\\n    39→\\treturn ChunkJSONL(content, MaxChunkSize)\\n    40→}\\n    41→\\n    42→// ReassembleTranscript combines chunks back into a single transcript.\\n    43→// If agentType is empty or the agent is not found, falls back to JSONL (line-based) reassembly.\\n    44→func ReassembleTranscript(chunks [][]byte, agentType AgentType) ([]byte, error) {\\n    45→\\tif len(chunks) == 0 {\\n    46→\\t\\treturn nil, nil\\n    47→\\t}\\n    48→\\tif len(chunks) == 1 {\\n    49→\\t\\treturn chunks[0], nil\\n    50→\\t}\\n    51→\\n    52→\\t// Try to get the agent by type and use its format-aware reassembly\\n    53→\\tif agentType != \\\"\\\" {\\n    54→\\t\\tag, err := GetByAgentType(agentType)\\n    55→\\t\\tif err == nil {\\n    56→\\t\\t\\tresult, reassembleErr := ag.ReassembleTranscript(chunks)\\n    57→\\t\\t\\tif reassembleErr != nil {\\n    58→\\t\\t\\t\\treturn nil, fmt.Errorf(\\\"agent reassembly failed: %w\\\", reassembleErr)\\n    59→\\t\\t\\t}\\n    60→\\t\\t\\treturn result, nil\\n    61→\\t\\t}\\n    62→\\t}\\n    63→\\n    64→\\t// Fall back to JSONL reassembly (default)\\n    65→\\treturn ReassembleJSONL(chunks), nil\\n    66→}\\n    67→\\n    68→// ChunkJSONL splits JSONL content at line boundaries.\\n    69→// This is the default chunking for agents using JSONL format (like Claude Code).\\n    70→func ChunkJSONL(content []byte, maxSize int) ([][]byte, error) {\\n    71→\\t// Handle empty content\\n    72→\\tif len(content) == 0 {\\n    73→\\t\\treturn [][]byte{}, nil\\n    74→\\t}\\n    75→\\n    76→\\tlines := strings.Split(string(content), \\\"\\\\n\\\")\\n    77→\\tvar chunks [][]byte\\n    78→\\tvar currentChunk strings.Builder\\n    79→\\n    80→\\tfor i, line := range lines {\\n    81→\\t\\t// Check if adding this line would exceed the chunk size\\n    82→\\t\\tlineWithNewline := line + \\\"\\\\n\\\"\\n    83→\\n    84→\\t\\t// Check if a single line exceeds maxSize - this is an error since we can't split JSONL lines\\n    85→\\t\\tif len(lineWithNewline) > maxSize {\\n    86→\\t\\t\\treturn nil, fmt.Errorf(\\\"JSONL line %d exceeds maximum chunk size (%d bytes > %d bytes); cannot split a single JSON object\\\", i+1, len(lineWithNewline), maxSize)\\n    87→\\t\\t}\\n    88→\\n    89→\\t\\tif currentChunk.Len()+len(lineWithNewline) > maxSize && currentChunk.Len() > 0 {\\n    90→\\t\\t\\t// Save current chunk and start a new one\\n    91→\\t\\t\\tchunks = append(chunks, []byte(strings.TrimSuffix(currentChunk.String(), \\\"\\\\n\\\")))\\n    92→\\t\\t\\tcurrentChunk.Reset()\\n    93→\\t\\t}\\n    94→\\t\\tcurrentChunk.WriteString(lineWithNewline)\\n    95→\\t}\\n    96→\\n    97→