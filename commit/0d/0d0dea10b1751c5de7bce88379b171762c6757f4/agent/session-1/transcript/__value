 69→\\t}\\n    70→\\treturn \\\"\\\"\\n    71→}\\n    72→\\n    73→// GetLastAssistantResponse returns the last assistant message content\\n    74→func (s *AgentSession) GetLastAssistantResponse() string {\\n    75→\\tfor i := len(s.Entries) - 1; i >= 0; i-- {\\n    76→\\t\\tif s.Entries[i].Type == EntryAssistant {\\n    77→\\t\\t\\treturn s.Entries[i].Content\\n    78→\\t\\t}\\n    79→\\t}\\n    80→\\treturn \\\"\\\"\\n    81→}\\n    82→\\n    83→// TruncateAtUUID returns a new session truncated at the given UUID (inclusive)\\n    84→func (s *AgentSession) TruncateAtUUID(uuid string) *AgentSession {\\n    85→\\tif uuid == \\\"\\\" {\\n    86→\\t\\treturn s\\n    87→\\t}\\n    88→\\n    89→\\ttruncated := &AgentSession{\\n    90→\\t\\tSessionID:  s.SessionID,\\n    91→\\t\\tAgentName:  s.AgentName,\\n    92→\\t\\tRepoPath:   s.RepoPath,\\n    93→\\t\\tSessionRef: s.SessionRef,\\n    94→\\t\\tStartTime:  s.StartTime,\\n    95→\\t}\\n    96→\\n    97→\\tfor i, entry := range s.Entries {\\n    98→\\t\\ttruncated.Entries = append(truncated.Entries, entry)\\n    99→\\t\\tif entry.UUID == uuid {\\n   100→\\t\\t\\ttruncated.Entries = s.Entries[:i+1]\\n   101→\\t\\t\\tbreak\\n   102→\\t\\t}\\n   103→\\t}\\n   104→\\n   105→\\t// Recompute file lists from truncated entries\\n   106→\\tfileSet := make(map[string]bool)\\n   107→\\tfor _, entry := range truncated.Entries {\\n   108→\\t\\tfor _, f := range entry.FilesAffected {\\n   109→\\t\\t\\tif !fileSet[f] {\\n   110→\\t\\t\\t\\tfileSet[f] = true\\n   111→\\t\\t\\t\\ttruncated.ModifiedFiles = append(truncated.ModifiedFiles, f)\\n   112→\\t\\t\\t}\\n   113→\\t\\t}\\n   114→\\t}\\n   115→\\n   116→\\treturn truncated\\n   117→}\\n   118→\\n   119→// FindToolResultUUID finds the UUID of the entry containing the tool result\\n   120→// for the given tool use ID. Returns the UUID and true if found.\\n   121→func (s *AgentSession) FindToolResultUUID(toolUseID string) (string, bool) {\\n   122→\\tfor _, entry := range s.Entries {\\