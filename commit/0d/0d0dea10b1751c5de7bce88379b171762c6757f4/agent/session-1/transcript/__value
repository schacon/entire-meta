→\\t}\\n   383→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   384→\\n   385→\\tif showNotification {\\n   386→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   387→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   388→\\t}\\n   389→\\n   390→\\t// Helper to save settings to the appropriate file\\n   391→\\tsaveSettings := func() error {\\n   392→\\t\\tif shouldUseLocal {\\n   393→\\t\\t\\treturn SaveEntireSettingsLocal(settings)\\n   394→\\t\\t}\\n   395→\\t\\treturn SaveEntireSettings(settings)\\n   396→\\t}\\n   397→\\n   398→\\t// Save settings before telemetry prompt so config is persisted even if the user cancels\\n   399→\\tif err := saveSettings(); err != nil {\\n   400→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   401→\\t}\\n   402→\\n   403→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   404→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   405→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   406→\\t}\\n   407→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   408→\\n   409→\\tconfigDisplay := configDisplayProject\\n   410→\\tif shouldUseLocal {\\n   411→\\t\\tconfigDisplay = configDisplayLocal\\n   412→\\t}\\n   413→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   414→\\n   415→\\t// Ask about telemetry consent (only if not already asked)\\n   416→\\tfmt.Fprintln(w)\\n   417→\\tif err := promptTelemetryConsent(settings, telemetry); err != nil {\\n   418→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   419→\\t}\\n   420→\\t// Save again to persist telemetry choice\\n   421→\\tif err := saveSettings(); err != nil {\\n   422→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   423→\\t}\\n   424→\\n   425→\\t// Let the strategy handle its own setup requirements\\n   426→\\tstrat, err := strategy.Get(internalStrategy)\\n   427→\\tif err != nil {\\n   428→\\t\\treturn fmt.Errorf(\\\"failed to get strategy: %w\\\", err)\\n   429→\\t}\\n   430→\\tif err := strat.EnsureSetup(); err != nil {\\n   431→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   432→\\t}\\n   433→\\n   434→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   435→\\n   436→\\treturn nil\\n   437→}\\n   438→\\n   439→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   440→func runEnable(w io.Writer) error {\\n   441→\\tsettings, err := LoadEntireSettings()\\n   442→\\tif err != nil {\\n   443→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   444→\\t}\\n   445→\\n   446→\\tsettings.Enabled = true\\n   447→\\tif err := SaveEntireSettings(settings); err != nil {\\n   448→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   449→\\t}\\n   450→\\n   451→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   452→\\treturn nil\\n   453→}\\n   454→\\n   455→func runDisable(w io.Writer, useProjectSettings bool) error {\\n   456→\\tsettings, err := LoadEntireSettings()\\n   457→\\tif err != nil {\\n   458→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   459→\\t}\\n   460→\\n   461→\\tsettings.Enabled = false\\n   462→\\n   463→\\t// If --project flag is specified, always write to project settings\\n   464→\\tif useProjectSettings {\\n   465→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   466→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   467→\\t\\t}\\n   468→\\t} else {\\n   469→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   470→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   471→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   472→\\t\\t}\\n   473→\\t}\\n   474→\\n   475→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   476→\\treturn nil\\n   477→}\\n   478→\\n   479→// DisabledMessage is the message shown when Entire is disabled\\n   480→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   481→\\n   482→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   483→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   484→// On error reading settings, defaults to enabled (returns false).\\n   485→func checkDisabledGuard(w io.Writer) bool {\\n   486→\\tenabled, err := IsEnabled()\\n   487→\\tif err != nil {\\n   488→\\t\\t// Default to enabled on error\\n   489→\\t\\treturn false\\n   490→\\t}\\n   491→\\tif !enabled {\\n   492→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   493→\\t\\treturn true\\n   494→\\t}\\n   495→\\treturn false\\n   496→}\\n   497→\\n   498→// setupClaudeCodeHook sets up Claude Code hooks.\\n   499→// This is a convenience wrapper that uses the agent package.\\n   500→// Returns the number of hooks installed (0 if already installed).\\n   501→func setupClaudeCodeHook(localDev, forceHooks bool) (int, error) { //nolint:unparam // already present in codebase\\n   502→\\tag, err := agent.Get(agent.AgentNameClaudeCode)\\n   503→\\tif err != nil {\\n   504→\\t\\treturn 0, fmt.Errorf(\\\"failed to get claude-code agent: %w\\\", err)\\n   505→\\t}\\n   506→\\n   507→\\thookAgent, ok := ag.(agent.HookSupport)\\n   508→\\tif !ok {\\n   509→\\t\\treturn 0, errors.New(\\\"claude-code agent does not support hooks\\\")\\n   510→\\t}\\n   511→\\n   512→\\tcount, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   513→\\tif err != nil {\\n   514→\\t\\treturn 0, fmt.Errorf(\\\"failed to install claude-code hooks: %w\\\", err)\\n   515→\\t}\\n   516→\\n   517→\\treturn count, nil\\n   518→}\\n   519→\\n   520→// printAgentError writes an error message followed by available agents and usage.\\n   521→func printAgentError(w io.Writer, message string) {\\n   522→\\tagents := agent.List()\\n   523→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   524→\\tfmt.Fprintln(w)\\n   525→\\tfor _, a := range agents {\\n   526→\\t\\tsuffix := \\\"\\\"\\n   527→\\t\\tif a == agent.DefaultAgentName {\\n   528→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   529→\\t\\t}\\n   530→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   531→\\t}\\n   532→\\tfmt.Fprintln(w)\\n   533→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   534→}\\n   535→\\n   536→// printMissingAgentError writes a helpful error listing available agents.\\n   537→func printMissingAgentError(w io.Writer) {\\n   538→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   539→}\\n   540→\\n   541→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   542→func printWrongAgentError(w io.Writer, name string) {\\n   543→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   544→}\\n   545→\\n   546→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   547→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   548→func setupAgentHooksNonInteractive(w io.Writer, ag agent.Agent, strategyName string, localDev, forceHooks, skipPushSessions, telemetry bool) error {\\n   549→\\tagentName := ag.Name()\\n   550→\\t// Check if agent supports hooks\\n   551→\\thookAgent, ok := ag.(agent.HookSupport)\\n   552→\\tif !ok {\\n   553→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   554→\\t}\\n   555→\\n   556→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   557→\\n   558→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   559→\\tinstalledHooks, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   560→\\tif err != nil {\\n   561→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   562→\\t}\\n   563→\\n   564→\\t// Setup .entire