2→\\tvar dataCommits []*object.Commit\\n    83→\\tfor _, c := range localCommits {\\n    84→\\t\\ttree, treeErr := c.Tree()\\n    85→\\t\\tif treeErr != nil {\\n    86→\\t\\t\\tcontinue\\n    87→\\t\\t}\\n    88→\\t\\tif len(tree.Entries) > 0 {\\n    89→\\t\\t\\tdataCommits = append(dataCommits, c)\\n    90→\\t\\t}\\n    91→\\t}\\n    92→\\n    93→\\tif len(dataCommits) == 0 {\\n    94→\\t\\t// Local only had empty orphan — just point to remote\\n    95→\\t\\tref := plumbing.NewHashReference(refName, remoteHash)\\n    96→\\t\\tif err := repo.Storer.SetReference(ref); err != nil {\\n    97→\\t\\t\\treturn fmt.Errorf(\\\"failed to reset metadata branch to remote: %w\\\", err)\\n    98→\\t\\t}\\n    99→\\t\\tfmt.Fprintln(os.Stderr, \\\"[entire] Done — local had no checkpoint data, reset to remote\\\")\\n   100→\\t\\treturn nil\\n   101→\\t}\\n   102→\\n   103→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Cherry-picking %d local checkpoint(s) onto remote...\\\\n\\\", len(dataCommits))\\n   104→\\n   105→\\tnewTip, err := cherryPickOnto(repo, remoteHash, dataCommits)\\n   106→\\tif err != nil {\\n   107→\\t\\treturn fmt.Errorf(\\\"failed to cherry-pick local commits onto remote: %w\\\", err)\\n   108→\\t}\\n   109→\\n   110→\\t// Update local branch ref\\n   111→\\tref := plumbing.NewHashReference(refName, newTip)\\n   112→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   113→\\t\\treturn fmt.Errorf(\\\"failed to update metadata branch: %w\\\", err)\\n   114→\\t}\\n   115→\\n   116→\\tfmt.Fprintln(os.Stderr, \\\"[entire] Done — all local and remote checkpoints preserved\\\")\\n   117→\\treturn nil\\n   118→}\\n   119→\\n   120→// isDisconnected checks if two commits have no common ancestor using git merge-base.\\n   121→// Returns (true, nil) if disconnected, (false, nil) if they share ancestry,\\n   122→// or (false, error) if git merge-base failed for another reason.\\n   123→//\\n   124→// git merge-base exit codes:\\n   125→//   - 0: common ancestor found (shared ancestry)\\n   126→//   - 1: no common ancestor (disconnected)\\n   127→//   - 128+: error (corrupt repo, invalid hash, etc.)\\n   128→func isDisconnected(repoPath, hashA, hashB string) (bool, error) {\\n   129→\\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\\n   130→\\tdefer cancel()\\n   131→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"merge-base\\\", hashA, hashB)\\n   132→\\tcmd.Dir = repoPath\\n   133→\\tif err := cmd.Run(); err != nil {\\n   134→\\t\\tvar exitErr *exec.ExitError\\n   135→\\t\\tif errors.As(err, &exitErr) && exitErr.ExitCode() == 1 {\\n   136→\\t\\t\\treturn true, nil // No common ancestor — disconnected\\n   137→\\t\\t}\\n   138→\\t\\treturn false, fmt.Errorf(\\\"git merge-base failed: %w\\\", err)\\n   139→\\t}\\n   140→\\treturn false, nil // Shared ancestry\\n   141→}\\n   142→\\n   143→// collectCommitChain walks from tip to root following first parent, returns oldest-first.\\n   144→func collectCommitChain(repo *git.Repository, tip plumbing.Hash) ([]*object.Commit, error) {\\n   145→\\tvar chain []*object.Commit\\n   146→\\tcurrent := tip\\n   147→\\n   148→\\tfor range MaxCommitTraversalDepth {\\n   149→\\t\\tcommit, err := repo.CommitObject(current)\\n   150→\\t\\tif err != nil {\\n   151→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit %s: %w\\\", current, err)\\n   152→\\t\\t}\\n   153→\\t\\tchain = append(chain, commit)\\n   154→\\n   155→\\t\\tif len(commit.ParentHashes) == 0 {\\n   156→\\t\\t\\tbreak // Root commit\\n   157→\\t\\t}\\n   158→\\t\\tcurrent = commit.ParentHashes[0]\\n   159→\\t}\\n   160→\\n   161→\\t// Reverse to oldest-first\\n   162→\\tfor i, j := 0, len(chain)-1; i < j; i, j = i+1, j-1 {\\n   163→\\t\\tchain[i], chain[j] = chain[j], chain[i]\\n   164→\\t}\\n   165→\\n   166→\\treturn chain, nil\\n   167→}\\n   168→\\n   169→// cherryPickOnto applies each commit's delta onto base, building a linear chain.\\n   170→// For each commit, it computes the full diff from its parent (additions, modifications,\\n   171→// and deletions), then applies that delta onto the current tip's tree.\\n   172→func cherryPickOnto(repo *git.Repository, base plumbing.Hash, commits []*object.Commit) (plumbing.Hash, error) {\\n   173→\\tcurrentTip := base\\n   174→\\n   175→\\tfor _, commit := range commits {\\n   176→\\t\\t// Get the commit's tree entries\\n   177→\\t\\tcommitTree, err := commit.Tree()\\n   178→\\t\\tif err != nil {\\n   179→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get tree for commit %s: %w\\\", commit.Hash, err)\\n   180→\\t\\t}\\n   181→\\n   182→\\t\\tcommitEntries := make(map[string]object.TreeEntry)\\n   183→\\t\\tif err := checkpoint.FlattenTree(repo, commitTree, \\\"\\\", commitEntries); err != nil {\\n   184→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten commit tree: %w\\\", err)\\n   185→\\t\\t}\\n   186→\\n   187→\\t\\t// Get parent's tree entries (empty if root commit)\\n   188→\\t\\tparentEntries := make(map[string]object.TreeEntry)\\n   189→\\t\\tif len(commit.ParentHashes) > 0 {\\n   190→\\t\\t\\tparentCommit, pErr := repo.CommitObject(commit.ParentHashes[0])\\n   191→\\t\\t\\tif pErr == nil {\\n   192→\\t\\t\\t\\tparentTree, ptErr := parentCommit.Tree()\\n   193→\\t\\t\\t\\tif ptErr == nil {\\n   194→\\t\\t\\t\\t\\t_ = checkpoint.FlattenTree(repo, parentTree, \\\"\\\", parentEntries) //nolint:errcheck // best effort\\n   195→\\t\\t\\t\\t}\\n   196→\\t\\t\\t}\\n   197→\\t\\t}\\n   198→\\n   199→\\t\\t// Compute full delta: additions, modifications, and deletions\\n   200→\\t\\tadded := make(map[string]object.TreeEntry)\\n   201→\\t\\tfor path, entry := range commitEntries {\\n   202→\\t\\t\\tparentEntry, exists := parentEntries[path]\\n   203→\\t\\t\\tif !exists || parentEntry.Hash != entry.Hash {\\n   204→\\t\\t\\t\\tadded[path] = entry // New or modified\\n   205→\\t\\t\\t}\\n   206→\\t\\t}\\n   207→\\t\\tvar deleted []string\\n   208→\\t\\tfor path := range parentEntries {\\n   209