\\", role inside message) into the\\n    37→// shared transcript.Line format (type=\\\"assistant\\\"/\\\"user\\\", message=inner content).\\n    38→// Non-message entries (session_start, etc.) are skipped.\\n    39→func ParseDroidTranscript(path string, startLine int) ([]transcript.Line, int, error) {\\n    40→\\tfile, err := os.Open(path) //nolint:gosec // path is a controlled transcript file path\\n    41→\\tif err != nil {\\n    42→\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to open transcript: %w\\\", err)\\n    43→\\t}\\n    44→\\tdefer func() { _ = file.Close() }()\\n    45→\\n    46→\\treturn parseDroidTranscriptFromReader(file, startLine)\\n    47→}\\n    48→\\n    49→// ParseDroidTranscriptFromBytes parses Droid JSONL content from a byte slice.\\n    50→func ParseDroidTranscriptFromBytes(content []byte) ([]transcript.Line, error) {\\n    51→\\tlines, _, err := parseDroidTranscriptFromReader(bytes.NewReader(content), 0)\\n    52→\\treturn lines, err\\n    53→}\\n    54→\\n    55→func parseDroidTranscriptFromReader(r io.Reader, startLine int) ([]transcript.Line, int, error) {\\n    56→\\treader := bufio.NewReader(r)\\n    57→\\tvar lines []transcript.Line\\n    58→\\ttotalLines := 0\\n    59→\\n    60→\\tfor {\\n    61→\\t\\tlineBytes, err := reader.ReadBytes('\\\\n')\\n    62→\\t\\tif err != nil && err != io.EOF {\\n    63→\\t\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    64→\\t\\t}\\n    65→\\n    66→\\t\\tif len(lineBytes) == 0 {\\n    67→\\t\\t\\tif err == io.EOF {\\n    68→\\t\\t\\t\\tbreak\\n    69→\\t\\t\\t}\\n    70→\\t\\t\\tcontinue\\n    71→\\t\\t}\\n    72→\\n    73→\\t\\tif totalLines >= startLine {\\n    74→\\t\\t\\tif line, ok := parseDroidLine(lineBytes); ok {\\n    75→\\t\\t\\t\\tlines = append(lines, line)\\n    76→\\t\\t\\t}\\n    77→\\t\\t}\\n    78→\\t\\ttotalLines++\\n    79→\\n    80→\\t\\tif err == io.EOF {\\n    81→\\t\\t\\tbreak\\n    82→\\t\\t}\\n    83→\\t}\\n    84→\\n    85→\\treturn lines, totalLines, nil\\n    86→}\\n    87→\\n    88→// parseDroidLine converts a single Droid JSONL line into a normalized transcript.Line.\\n    89→// Returns false if the line is not a message entry (e.g., session_start).\\n    90→func parseDroidLine(lineBytes []byte) (transcript.Line, bool) {\\n    91→\\tvar env droidEnvelope\\n    92→\\tif err := json.Unmarshal(lineBytes, &env); err != nil {\\n    93→\\t\\treturn transcript.Line{}, false\\n    94→\\t}\\n    95→\\n    96→\\t// Only process \\\"message\\\" type entries — skip session_start, etc.\\n    97→\\tif env.Type != \\\"message\\\" {\\n    98→\\t\\treturn transcript.Line{}, false\\n    99→\\t}\\n   100→\\n   101→\\t// Extract role from the inner message\\n   102→\\tvar role droidMessageRole\\n   103→\\tif err := json.Unmarshal(env.Message, &role); err != nil {\\n   104→\\t\\treturn transcript.Line{}, false\\n   105→\\t}\\n   106→\\n   107→\\treturn transcript.Line{\\n   108→\\t\\tType:    role.Role, // \\\"assistant\\\" or \\\"user\\\"\\n   109→\\t\\tUUID:    env.ID,\\n   110→\\t\\tMessage: env.Message,\\n   111→\\t}, true\\n   112→}\\n   113→\\n   114→// SerializeTranscript converts transcript lines back to JSONL bytes.\\n   115→func SerializeTranscript(lines []TranscriptLine) ([]byte, error) {\\n   116→\\tvar buf bytes.Buffer\\n   117→\\tfor _, line := range lines {\\n   118→\\t\\tdata, err := json.Marshal(line)\\n   119→\\t\\tif err != nil {\\n   120→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal line: %w\\\", err)\\n   121→\\t\\t}\\n   122→\\t\\tbuf.Write(data)\\n   123→\\t\\tbuf.WriteByte('\\\\n')\\n   124→\\t}\\n   125→\\treturn buf.Bytes(), nil\\n   126→}\\n   127→\\n   128→// ExtractModifiedFiles extracts files modified by tool calls from transcript.\\n   129→func ExtractModifiedFiles(lines []TranscriptLine) []string {\\n   130→\\tfileSet := make(map[string]bool)\\n   131→\\tvar files []string\\n   132→\\n   133→\\tfor _, line := range lines {\\n   134→\\t\\tif line.Type != \\\"assistant\\\" {\\n   135→\\t\\t\\tcontinue\\n   136→\\t\\t}\\n   137→\\n   138→\\t\\tvar msg transcript.AssistantMessage\\n   139→\\t\\tif err := json.Unmarshal(line.Message, &msg); err != nil {\\n   140→\\t\\t\\tcontinue\\n   141→\\t\\t}\\n   142→\\n   143→\\t\\tfor _, block := range msg.Content {\\n   144→\\t\\t\\tif block.Type != \\\"tool_use\\\" || !slices.Contains(FileModificationTools, block.Name) {\\n   145→\\t\\t\\t\\tcontinue\\n   146→\\t\\t\\t}\\n   147→\\n   148→\\t\\t\\tvar input transcript.ToolInput\\n   149→\\t\\t\\tif err := json.Unmarshal(block.Input, &input); err != nil {\\n   150→\\t\\t\\t\\tcontinue\\n   151→\\t\\t\\t}\\n   152→\\n   153→\\t\\t\\tfile := input.FilePath\\n   154→\\t\\t\\tif file == \\\"\\\" {\\n   155→\\t\\t\\t\\tfile = input.NotebookPath\\n   156→\\t\\t\\t}\\n   157→\\n   158→\\t\\t\\tif file != \\\"\\\" && !fileSet[file] {\\n   159→\\t\\t\\t\\tfileSet[file] = true\\n   160→\\t\\t\\t\\tfiles = append(files, file)\\n   161→\\t\\t\\t}\\n   162→\\t\\t}\\n   163→\\t}\\n   164→\\n   165→\\treturn files\\n   166→}\\n   167→\\n   168→// CalculateTokenUsage calculates token usage from a Factory AI Droid transcript.\\n   169→// Due to streaming, multiple transcript rows may share the same message.id.\\n   170→// We deduplicate by taking the row with the highest output_tokens for each message.id.\\n   171→func CalculateTokenUsage(transcriptLines []TranscriptLine) *agent.TokenUsage {\\n   172→\\t// Map from message.id to the usage with highest output_tokens\\n   173→\\tusageByMessageID := make(map[string]messageUsage)\\n   174→\\n   175→\\tfor _, line := range transcriptLines {\\n   176→\\t\\tif line.Type != \\\"assistant\\\" {\\n   177→\\t\\t\\tcontinue\\n   178→\\t\\t}\\n   179→\\n   180→\\t\\tvar msg messageWithUsage\\n   181→\\t\\tif err := json.Unmarshal(line.Message, &msg); err != nil {\\n   182→\\t\\t\\tcontinue\\n   183→\\t\\t}\\n   184→\\n   185→\\t\\tif msg.ID == \\\"\\\" {\\n   186→\\t\\t\\tcontinue\\n   187→\\t\\t}\\n   188→\\n   189→\\t\\t// Keep the entry with highest output_tokens (final streaming state)\\n   190→\\t\\texisting, exists := usageByMessageID[msg.ID]\\n   191→\\t\\tif !exists || msg.Usage.OutputTokens > existing.OutputTokens {\\n   192→\\t\\t\\tusageByMessageID[msg.ID] = msg.Usage\\n   193→\\t\\t}\\n   194→\\t}\\n   195→\\n   196→\\t// Sum up all unique messages\\n   197→\\tusage := &agent.TokenUsage{\\n   198→\\t\\tAPICallCount: len(usageByMessageID),\\n   199→\\t}\\n   200→\\tfor _, u := range usageByMessageID {\\n   201→\\t\\tusage.InputTokens += u.InputTokens\\n   202→\\t\\tusage.CacheCreationTokens += u.CacheCreationInputTokens\\n   203→\\t\\tusage.CacheReadTokens += u.CacheReadInputTokens\\n   204→\\t\\tusage.OutputTokens += u.OutputTokens\\n   205→\\t}\\n   206→\\n   207→\\treturn usage\\n   208→}\\n   209→\\n   210→// CalculateTokenUsageFromFile calculates token usage from a transcript file.\\n   211→// If startLine > 0, only considers lines from startLine onwards.\\n   212→func CalculateTokenUsageFromFile(path string, startLine int) (*agent.TokenUsage, error) {\\n   213→\\tif path == \\\"\\\" {\\n   214→\\t\\treturn &agent.TokenUsage{}, nil\\n   215→\\t}\\n   216→\\n   217→\\tlines, _, err := ParseDroidTranscript(path, startLine)\\n   218→\\tif err != nil {\\n   219→\\t\\treturn nil, err\\n   220→\\t}\\n   221→\\n   222→\\treturn CalculateTokenUsage(lines), nil\\n   223→}\\n   224→\\n   225→// ExtractSpawnedAgentIDs extracts agent IDs from Task tool results in a transcript.\\n   226→// When a Task tool completes, the tool_result contains \\\"agentId: <id>\\\" in its content.\\n   227→// Returns a map of agentID -> toolUseID for all spawned agents.\\n   228→func ExtractSpawnedAgentIDs(transcriptLines []TranscriptLine) map[string]string {\\n   229→\\tagentIDs := make(map[string]string)\\n   230→\\n   231→\\tfor _, line := range transcriptLines {\\n   232→\\t\\tif line.Type != \\\"user\\\" {\\n   233→\\t\\t\\tcontinue\\n   234→\\t\\t}\\n   235→\\n   236→\\t\\t// Parse as array of content blocks (tool results)\\n   237→\\t\\tvar contentBlocks []struct {\\n   238→\\t\\t\\tType      string          `json:\\\"type\\\"`\\n   239→\\t\\t\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   240→\\t\\t\\tContent   json.RawMessage `json:\\\"content\\\"`\\n   241→\\t\\t}\\n   242→\\n   243→\\t\\tvar msg struct {\\n   244→\\t\\t\\tContent json.RawMessage `json:\\\"content\\\"`\\n   245→\\t\\t}\\n   246→\\t\\tif err := json.Unmarshal(line.Message, &msg); err != nil {\\n   247→\\t\\t\\tcontinue\\n   248→\\t\\t}\\n   249→\\n   250→\\t\\tif err := json.Unmarshal(msg.Content, &contentBlocks); err != nil {\\n   251→\\t\\t\\tcontinue\\n   252→\\t\\t}\\n   253→\\n   254→\\t\\tfor _, block := range contentBlocks {\\n   255→\\t\\t\\tif block.Type != \\\"tool_result\\\" {\\n   256→\\t\\t\\t\\tcontinue\\n   257→\\t\\t\\t}\\n   258→\\n   259→\\t\\t\\t// Content can be a string or array of text blocks\\n   260→\\t\\t\\tvar textContent string\\n   261→\\n   262→\\t\\t\\t// Try as array of text blocks first\\n   263→\\t\\t\\tvar textBlocks []struct {\\n   264→\\t\\t\\t\\tType string `json:\\\"type\\\"`\\n   265→\\t\\t\\t\\tText string `json:\\\"text\\\"`\\n   266→\\t\\t\\t}\\n   267→\\t\\t\\tif err := json.Unmarshal(block.Content, &textBlocks); err == nil {\\n   268→\\t\\t\\t\\tvar sb strings.Builder\\n   269→\\t\\t\\t\\tfor _, tb := range textBlocks {\\n   270→\\t\\t\\t\\t\\tif tb.Type == \\\"text\\\" {\\n   271→\\t\\t\\t\\t\\t\\tsb.WriteString(tb.Text + \\\"\\\\n\\\")\\n   272→\\t\\t\\t\\t\\t}\\n   273→\\t\\t\\t\\t}\\n   274→\\t\\t\\t\\ttextContent = sb.String()\\n   275→\\t\\t\\t} else {\\n   276→\\t\\t\\t\\t// Try as plain string\\n   277→\\t\\t\\t\\tvar str string\\n   278→\\t\\t\\t\\tif err := json.Unmarshal(block.Content, &str); err == nil {\\n   279→\\t\\t\\t\\t\\ttextContent = str\\n   280→\\t\\t\\t\\t}\\n   281→\\t\\t\\t}\\n   282→\\n   283→\\t\\t\\t// Look for agentId in the text\\n   284→\\t\\t\\tif agentID := extractAgentIDFromText(textContent); agentID != \\\"\\\" {\\n   285→\\t\\t\\t\\tagentIDs[agentID] = block.ToolUseID\\n   286→\\t\\t\\t}\\n   287→\\t\\t}\\n   288→\\t}\\n   289→\\n   290→\\treturn agentIDs\\n   291→}\\n   292→\\n   293→// extractAgentIDFromText extracts an agent ID from text containing \\\"agentId: <id>\\\".\\n   294→func extractAgentIDFromText(text string) string {\\n   295→\\tconst prefix = \\\"agentId: \\\"\\n   296→\\tidx := strings.Index(text, prefix)\\n   297→\\tif idx == -1 {\\n   298→\\t\\treturn \\\"\\\"\\n   299→\\t}\\n   300→\\n   301→\\t// Extract the ID (alphanumeric characters after the prefix)\\n   302→\\tstart := idx + len(prefix)\\n   303→\\tend := start\\n   304→\\tfor end < len(text) && (text[end] >= 'a' && text[end] <= 'z' ||\\n   305→\\t\\ttext[end] >= 'A' && text[end] <= 'Z' ||\\n   306→\\t\\ttext[end] >= '0' && text[end] <= '9') {\\n   307→\\t\\tend++\\n   308→\\t}\\n   309→\\n   310→\\tif end > start {\\n   311→\\t\\treturn text[start:end]\\n   312→\\t}\\n   313→\\treturn \\\"\\\"\\n   314→}\\n   315→\\n   316→// CalculateTotalTokenUsageFromTranscript calculates token usage for a turn, including subagents.\\n   317→// It parses the main transcript from startLine, extracts spawned agent IDs,\\n   318→// and calculates their token usage from transcripts in subagentsDir.\\n   319→func CalculateTotalTokenUsageFromTranscript(transcriptPath string, startLine int, subagentsDir string) (*agent.TokenUsage, error) {\\n   320→\\tif transcriptPath == \\\"\\\" {\\n   321→\\t\\treturn &agent.TokenUsage{}, nil\\n   322→\\t}\\n   323→\\n   324→\\t// Parse transcript once using Droid-specific parser\\n   325→\\tparsed, _, err := ParseDroidTranscript(transcriptPath, startLine)\\n   326→\\tif err != nil {\\n   327→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   328→\\t}\\n   329→\\n   330→\\t// Calculate token usage from parsed transcript\\n   331→\\tmainUsage := CalculateTokenUsage(parsed)\\n   332→\\n   333→\\t// Extract spawned agent IDs from the same parsed transcript\\n   334→\\tagentIDs := ExtractSpawnedAgentIDs(parsed)\\n   335→\\n   336→\\t// Calculate subagent token usage\\n   337→\\tif len(agentIDs) > 0 {\\n   338→\\t\\tsubagentUsage := &agent.TokenUsage{}\\n   339→\\t\\tfor agentID := range agentIDs {\\n   340→\\t\\t\\tagentPath := filepath.Join(subagentsDir, fmt.Sprintf(\\\"agent-%s.jsonl\\\", agentID))\\n   341→\\t\\t\\tagentUsage, err := CalculateTokenUsageFromFile(agentPath, 0)\\n   342→\\t\\t\\tif err != nil {\\n   343→\\t\\t\\t\\t// Agent transcript may not exist yet or may have been cleaned up\\n   344→\\t\\t\\t\\tcontinue\\n   345→\\t\\t\\t}\\n   346→\\t\\t\\tsubagentUsage.InputTokens += agentUsage.InputTokens\\n   347→\\t\\t\\tsubagentUsage.CacheCreationTokens += agentUsage.CacheCreationTokens\\n   348→\\t\\t\\tsubagentUsage.CacheReadTokens += agentUsage.CacheReadTokens\\n   349→\\t\\t\\tsubagentUsage.OutputTokens += agentUsage.OutputTokens\\n   350→\\t\\t\\tsubagentUsage.APICallCount += agentUsage.APICallCount\\n   351→\\t\\t}\\n   352→\\t\\tif subagentUsage.APICallCount > 0 {\\n   353→\\t\\t\\tmainUsage.SubagentTokens = subagentUsage\\n   354→\\t\\t}\\n   355→\\t}\\n   356→\\n   357→\\treturn mainUsage, nil\\n   358→}\\n   359→\\n   360→// ExtractAllModifiedFilesFromTranscript extracts files modified by both the main agent and\\n   361→// any subagents spawned via the Task tool. It parses the main transcript from\\n   362→// startLine, collects modified files from the main agent, then reads each\\n   363→// subagent's transcript from subagentsDir to collect their modified files too.\\n   364→// The result is a deduplicated list of all modified file paths.\\n   365→func ExtractAllModifiedFilesFromTranscript(transcriptPath string, startLine int, subagentsDir string) ([]string, error) {\\n   366→\\tif transcriptPath == \\\"\\\" {\\n   367→\\t\\treturn nil, nil\\n   368→\\t}\\n   369→\\n   370→\\t// Parse main transcript once using Droid-specific parser\\n   371→\\tparsed, _, err := ParseDroidTranscript(transcri