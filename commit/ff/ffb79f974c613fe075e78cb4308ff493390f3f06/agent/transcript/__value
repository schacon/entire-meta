specified commit ID using the CLI.\\n   598→func (env *TestEnv) Rewind(commitID string) error {\\n   599→\\tenv.T.Helper()\\n   600→\\n   601→\\t//nolint:gosec,noctx // test code, commitID is from test setup, no context needed\\n   602→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID)\\n   603→\\tcmd.Dir = env.RepoDir\\n   604→\\n   605→\\toutput, err := cmd.CombinedOutput()\\n   606→\\tif err != nil {\\n   607→\\t\\treturn errors.New(\\\"rewind failed: \\\" + string(output))\\n   608→\\t}\\n   609→\\n   610→\\tenv.T.Logf(\\\"Rewind output: %s\\\", output)\\n   611→\\treturn nil\\n   612→}\\n   613→\\n   614→// BranchExists checks if a branch exists in the repository.\\n   615→func (env *TestEnv) BranchExists(branchName string) bool {\\n   616→\\tenv.T.Helper()\\n   617→\\n   618→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   619→\\tif err != nil {\\n   620→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   621→\\t}\\n   622→\\n   623→\\trefs, err := repo.References()\\n   624→\\tif err != nil {\\n   625→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   626→\\t}\\n   627→\\n   628→\\tfound := false\\n   629→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   630→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   631→\\t\\tif ref.Name().Short() == branchName {\\n   632→\\t\\t\\tfound = true\\n   633→\\t\\t}\\n   634→\\t\\treturn nil\\n   635→\\t})\\n   636→\\n   637→\\treturn found\\n   638→}\\n   639→\\n   640→// ListBranchesWithPrefix returns all branches that start with the given prefix.\\n   641→func (env *TestEnv) ListBranchesWithPrefix(prefix string) []string {\\n   642→\\tenv.T.Helper()\\n   643→\\n   644→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   645→\\tif err != nil {\\n   646→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   647→\\t}\\n   648→\\n   649→\\trefs, err := repo.References()\\n   650→\\tif err != nil {\\n   651→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   652→\\t}\\n   653→\\n   654→\\tvar branches []string\\n   655→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   656→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   657→\\t\\tname := ref.Name().Short()\\n   658→\\t\\tif strings.HasPrefix(name, prefix) {\\n   659→\\t\\t\\tbranches = append(branches, name)\\n   660→\\t\\t}\\n   661→\\t\\treturn nil\\n   662→\\t})\\n   663→\\n   664→\\treturn branches\\n   665→}\\n   666→\\n   667→// GetCommitMessage returns the commit message for the given commit hash.\\n   668→func (env *TestEnv) GetCommitMessage(hash string) string {\\n   669→\\tenv.T.Helper()\\n   670→\\n   671→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   672→\\tif err != nil {\\n   673→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   674→\\t}\\n   675→\\n   676→\\tcommitHash := plumbing.NewHash(hash)\\n   677→\\tcommit, err := repo.CommitObject(commitHash)\\n   678→\\tif err != nil {\\n   679→\\t\\tenv.T.Fatalf(\\\"failed to get commit %s: %v\\\", hash, err)\\n   680→\\t}\\n   681→\\n   682→\\treturn commit.Message\\n   683→}\\n   684→\\n   685→// GetLatestCheckpointIDFromHistory walks backwards from HEAD and returns\\n   686→// the checkpoint ID from the first commit with an Entire-Checkpoint trailer.\\n   687→// Returns an error if no checkpoint trailer is found in any commit.\\n   688→func (env *TestEnv) GetLatestCheckpointIDFromHistory() (string, error) {\\n   689→\\tenv.T.Helper()\\n   690→\\n   691→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   692→\\tif err != nil {\\n   693→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   694→\\t}\\n   695→\\n   696→\\thead, err := repo.Head()\\n   697→\\tif err != nil {\\n   698→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   699→\\t}\\n   700→\\n   701→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   702→\\tif err != nil {\\n   703→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   704→\\t}\\n   705→\\n   706→\\tvar checkpointID string\\n   707→\\t//nolint:errcheck,gosec // ForEach callback returns error to stop iteration, not a real error\\n   708→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   709→\\t\\t// Look for Entire-Checkpoint trailer\\n   710→\\t\\tfor _, line := range strings.Split(c.Message, \\\"\\\\n\\\") {\\n   711→\\t\\t\\tline = strings.TrimSpace(line)\\n   712→\\t\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   713→\\t\\t\\t\\tcheckpointID = strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   714→\\t\\t\\t\\treturn errors.New(\\\"stop iteration\\\")\\n   715→\\t\\t\\t}\\n   716→\\t\\t}\\n   717→\\t\\treturn nil\\n   718→\\t})\\n   719→\\n   720→\\tif checkpointID == \\\"\\\" {\\n   721→\\t\\treturn \\\"\\\", errors.New(\\\"no commit with Entire-Checkpoint trailer found in history\\\")\\n   722→\\t}\\n   723→\\n   724→\\treturn checkpointID, nil\\n   725→}\\n   726→\\n   727→// GetLatestCheckpointID returns the checkpoint ID from HEAD commit, or empty string if none.\\n   728→// This is a convenience wrapper that doesn't fail the test on missing checkpoint.\\n   729→func (env *TestEnv) GetLatestCheckpointID() string {\\n   730→\\tenv.T.Helper()\\n   731→\\n   732→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   733→\\tif err != nil {\\n   734→\\t\\treturn \\\"\\\"\\n   735→\\t}\\n   736→\\n   737→\\thead, err := repo.Head()\\n   738→\\tif err != nil {\\n   739→\\t\\treturn \\\"\\\"\\n   740→\\t}\\n   741→\\n   742→\\tcommit, err := repo.CommitObject(head.Hash())\\n   743→\\tif err != nil {\\n   744→\\t\\treturn \\\"\\\"\\n   745→\\t}\\n   746→\\n   747→\\t// Look for Entire-Checkpoint trailer in HEAD commit only\\n   748→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n   749→\\t\\tline = strings.TrimSpace(line)\\n   750→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   751→\\t\\t\\treturn strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   752→\\t\\t}\\n   753→\\t}\\n   754→\\treturn \\\"\\\"\\n   755→}\\n   756→\\n   757→// safeIDPrefix returns first 12 chars of ID or the full ID if shorter.\\n   758→// Use this when logging checkpoint IDs to avoid index out of bounds panic.\\n   759→func safeIDPrefix(id string) string {\\n   760→\\tif len(id) >= 12 {\\n   761→\\t\\treturn id[:12]\\n   762→\\t}\\n   763→\\treturn id\\n   764→}\\n   765→\\n   766→// RunCLI runs the entire CLI with the given arguments and returns stdout.\\n   767→func (env *TestEnv) RunCLI(args ...string) string {\\n   768→\\tenv.T.Helper()\\n   769→\\toutput, err := env.RunCLIWithError(args...)\\n   770→\\tif err != nil {\\n   771→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   772→\\t}\\n   773→\\treturn output\\n   774→}\\n   775→\\n   776→// RunCLIWithError runs the entire CLI and returns output and error.\\n   777→func (env *TestEnv) RunCLIWithError(args ...string) (string, error) {\\n   778→\\tenv.T.Helper()\\n   779→\\n   780→\\t//nolint:gosec,noctx // test code, args are from test setup, no context needed\\n   781→\\tcmd := exec.Command(getTestBinary(), args...)\\n   782→\\tcmd.Dir = env.RepoDir\\n   783→\\n   784→\\toutput, err := cmd.CombinedOutput()\\n   785→\\treturn string(output), err\\n   786→}\\n   787→\\n   788→// RunAgent runs the agent with the given prompt and returns the result.\\n   789→func (env *TestEnv) RunAgent(prompt string) (*AgentResult, error) {\\n   790→\\tenv.T.Helper()\\n   791→\\tresult, err := env.Agent.RunPrompt(context.Background(), env.RepoDir, prompt)\\n   792→\\tif err != nil && result != nil {\\n   793→\\t\\tenv.T.Logf(\\\"Agent failed with exit code %d\\\", result.ExitCode)\\n   794→\\t\\tif result.Stderr != \\\"\\\" {\\n   795→\\t\\t\\tenv.T.Logf(\\\"Agent stderr: %s\\\", result.Stderr)\\n   796→\\t\\t}\\n   797→\\t\\tif result.Stdout != \\\"\\\"