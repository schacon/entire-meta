\n    48→\\t\\tresult = append(result, CheckpointInfo{\\n    49→\\t\\t\\tCheckpointID:     c.CheckpointID,\\n    50→\\t\\t\\tSessionID:        c.SessionID,\\n    51→\\t\\t\\tCreatedAt:        c.CreatedAt,\\n    52→\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n    53→\\t\\t\\tFilesTouched:     c.FilesTouched,\\n    54→\\t\\t\\tAgent:            c.Agent,\\n    55→\\t\\t\\tIsTask:           c.IsTask,\\n    56→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    57→\\t\\t\\tSessionCount:     c.SessionCount,\\n    58→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    59→\\t\\t})\\n    60→\\t}\\n    61→\\n    62→\\treturn result, nil\\n    63→}\\n    64→\\n    65→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    66→func (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n    67→\\tall, err := s.listCheckpoints()\\n    68→\\tif err != nil {\\n    69→\\t\\treturn nil, err\\n    70→\\t}\\n    71→\\n    72→\\tvar result []CheckpointInfo\\n    73→\\tfor _, cp := range all {\\n    74→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    75→\\t\\t\\tresult = append(result, cp)\\n    76→\\t\\t}\\n    77→\\t}\\n    78→\\n    79→\\tif len(result) == 0 {\\n    80→\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n    81→\\t}\\n    82→\\n    83→\\treturn result, nil\\n    84→}\\n    85→\\n    86→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    87→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    88→func (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n    89→\\tstore, err := s.getCheckpointStore()\\n    90→\\tif err != nil {\\n    91→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    92→\\t}\\n    93→\\n    94→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n    95→\\tif err != nil {\\n    96→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    97→\\t}\\n    98→\\tif content == nil {\\n    99→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n   100→\\t}\\n   101→\\tif len(content.Transcript) == 0 {\\n   102→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   103→\\t}\\n   104→\\n   105→\\treturn content.Transcript, nil\\n   106→}\\n   107→\\n   108→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   109→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   110→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   111→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   112→//\\n   113→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   114→// In this case, data is extracted from the live transcript instead.\\n   115→func (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n   116→\\t// Get shadow branch (may not exist for mid-session commits)\\n   117→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   118→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   119→\\tref, err := repo.Reference(refName, true)\\n   120→\\thasShadowBranch := err == nil\\n   121→\\n   122→\\tvar sessionData *ExtractedSessionData\\n   123→\\tif hasShadowBranch {\\n   124→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   125→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   126→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   127→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   128→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   129→\\t\\t// last turn had no code changes).\\n   130→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   131→\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n   132→\\t\\tif err != nil {\\n   133→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n   134→\\t\\t}\\n   135→\\t} else {\\n   136→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   137→\\t\\t// Extract data directly from live transcript.\\n   138→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   139→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   140→\\t\\t}\\n   141→\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n   142→\\t\\tif err != nil {\\n   143→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n   144→\\t\\t}\\n   145→\\t}\\n   146→\\n   147→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   148→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   149→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   150→\\tif len(committedFiles) > 0 {\\n   151→\\t\\t// Track if we had files before filtering to distinguish between:\\n   152→\\t\\t// - Session had files but none were committed (don't fallback)\\n   153→\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n   154→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   155→\\n   156→\\t\\tif hadFilesBeforeFiltering {\\n   157→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   158→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   159→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   160→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   161→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   162→\\t\\t\\t\\t}\\n   163→\\t\\t\\t}\\n   164→\\t\\t\\tsessionData.FilesTouched = filtered\\n   165→\\t\\t}\\n   166→\\n   167→\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n   168→\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n   169→\\t\\t// the session had files that simply didn't overlap with the commit - that\\n   170→\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n   171→\\t\\t// overwritten with unrelated committed files.\\n   172→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   173→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   174→\\t\\t\\tfor f := range committedFiles {\\n   175→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   176→\\t\\t\\t}\\n   177→\\t\\t}\\n   178→\\t}\\n   179→\\n   180→\\t// Get checkpoint store\\n   181→\\tstore, err := s.getCheckpointStore()\\n   182→\\tif err != nil {\\n   183→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   184→\\t}\\n   185→\\n   186→\\t// Get author info\\n   187→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   188→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   189→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   190→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   191→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n   192→\\t// Get current branch name\\n   193→\\tbranchName := GetCurrentBranchName(repo)\\n   194→\\n   195→\\t// Generate summary if enabled\\n   196→\\tvar summary *cpkg.Summary\\n   197→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   198→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   199→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   200→\\n   201→\\t\\t// Scope transcript to this checkpoint's portion.\\n   202→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   203→\\t\\t// For Gemini (JSON), CheckpointTranscriptStart is a message index.\\n   204→\\t\\tvar scopedTranscript []byte\\n   205→\\t\\tif state.AgentType == agent.AgentTypeGemini {\\n   206→\\t\\t\\tscopedTranscript = geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   207→\\t\\t} else {\\n   208→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   209→\\t\\t}\\n   210→\\t\\tif len(scopedTranscript) > 0 {\\n   211→\\t\\t\\tvar err error\\n   212→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   213→\\t\\t\\tif err != nil {\\n   214→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   215→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   216→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   217→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   218→\\t\\t\\t} else {\\n   219→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   220→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   221→\\t\\t\\t}\\n   222→\\t\\t}\\n   223→\\t}\\n   224→\\n   225→\\t// Write checkpoint metadata using the checkpoint store\\n   226→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   227→\\t\\tCheckpointID:                checkpointID,\\n   228→\\t\\tSessionID:                   state.SessionID,\\n   229→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   230→\\t\\tBranch:                      branchName,\\n   231→\\t\\tTranscript:                  sessionData.Transcript,\\n   232→\\t\\tPrompts:                     sessionData.Prompts,\\n   233→\\t\\tContext:                     sessionData.Context,\\n   234→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   235→\\t\\tCheckpointsCount:            state.StepCount,\\n   236→\\t\\tEphemeralBranch:             shadowBranchName,\\n   237→\\t\\tAuthorName:                  authorName,\\n   238→\\t\\tAuthorEmail:                 authorEmail,\\n   239→\\t\\tAgent:                       state.AgentType,\\n   240→\\t\\tTurnID:                      state.TurnID,\\n   241→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   242→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   243→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   244→\\t\\tExportData:                  sessionData.ExportData,\\n   245→\\t\\tInitialAttribution:          attribution,\\n   246→\\t\\tSummary:                     summary,\\n   247→\\t}); err != nil {\\n   248→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   249→\\t}\\n   250→\\n   251→\\treturn &CondenseResult{\\n   252→\\t\\tCheckpointID:         checkpointID,\\n   253→\\t\\tSessionID:            state.SessionID,\\n   254→\\t\\tCheckpointsCount:     state.StepCount,\\n   255→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   256→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   257→\\t}, nil\\n   258→}\\n   259→\\n   260→func calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n   261→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   262→\\t// This uses user edits captured at each prompt start (before agent works),\\n   263→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   264→\\t//\\n   265→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   266→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   267→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   268→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   269→\\n   270→\\theadRef, headErr := repo.Head()\\n   271→\\tif headErr != nil {\\n   272→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   273→\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   274→\\t\\treturn nil\\n   275→\\t}\\n   276→\\n   277→\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   278→\\tif commitErr != nil {\\n   279→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   280→\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   281→\\t\\treturn nil\\n   282→\\t}\\n   283→\\n   284→\\theadTree, treeErr := headCommit.Tree()\\n   285→\\tif treeErr != nil {\\n   286→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   287→\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   288→\\t\\treturn nil\\n   289→\\t}\\n   290→\\n   291→\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n   292→\\tvar shadowTree *object.Tree\\n   293→\\tif shadowRef != nil {\\n   294→\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   295→\\t\\tif shadowErr != nil {\\n   296→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   297→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   298→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   299→\\t\\t\\treturn nil\\n   300→\\t\\t}\\n   301→\\t\\tvar shadowTreeErr error\\n   302→\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   303→\\t\\tif shadowTreeErr != nil {\\n   304→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   305→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   306→\\t\\t\\treturn nil\\n   307→\\t\\t}\\n   308→\\t} else {\\n   309→\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   310→\\t\\t// because the agent's work is the commit itself.\\n   311→\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   312→\\t\\tshadowTree = headTree\\n   313→\\t}\\n   314→\\n   315→\\t// Get base tree (state before session started)\\n   316→\\tvar baseTree *object.Tree\\n   317→\\tattrBase := state.AttributionBaseCommit\\n   318→\\tif attrBase == \\\"\\\" {\\n   319→\\t\\tattrBase = state.BaseCommit // backward compat\\n   320→\\t}\\n   321→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   322→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   323→\\t\\t\\tbaseTree = tree\\n   324→\\t\\t} else {\\n   325→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   326→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   327→\\t\\t}\\n   328→\\t} else {\\n   329→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   330→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   331→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   332→\\t}\\n   333→\\n   334→\\t// Log accumulated prompt attributions for debugging\\n   335→\\tvar totalUserAdded, totalUserRemoved int\\n   336→\\tfor i, pa := range state.PromptAttributions {\\n   337→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   338→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   339→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   340→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   341→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   342→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   343→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   344→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   345→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   346→\\t}\\n   347→\\n   348→\\tattribution := CalculateAttributionWithAccumulated(\\n   349→\\t\\tbaseTree,\\n   350→\\t\\tshadowTree,\\n   351→\\t\\theadTree,\\n   352→\\t\\tsessionData.FilesTouched,\\n   353→\\t\\tstate.PromptAttributions,\\n   354→\\t)\\n   355→\\n   356→\\tif attribution != nil {\\n   357→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   358→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   359→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   360→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   361→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   362→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   363→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   364→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   365→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   366→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   367→\\t}\\n   368→\\n   369→\\treturn attribution\\n   370→}\\n   371→\\n   372→// extractSessionData extracts session data from the shadow branch.\\n   373→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   374→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   375→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   376→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   377→// continued growing — the shadow branch copy would be stale.\\n   378→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   379→func (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n   380→\\tcommit, err := repo.CommitObject(shadowRef)\\n   381→\\tif err != nil {\\n   382→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   383→\\t}\\n   384→\\n   385→\\ttree, err := commit.Tree()\\n   386→\\tif err != nil {\\n   387→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   388→\\t}\\n   389→\\n   390→\\tdata := &ExtractedSessionData{}\\n   391→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   392→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   393→\\n   394→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   395→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   396→\\t// (SaveStep is only called when there are file modifications).\\n   397→\\tvar fullTranscript string\\n   398→\\tif liveTranscriptPath != \\\"\\\" {\\n   399→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   400→\\t\\t\\tfullTranscript = string(liveData)\\n   401→\\t\\t}\\n   402→\\t}\\n   403→\\tif fullTranscript == \\\"\\\" {\\n   404→\\t\\t// Fall back to shadow branch copy\\n   405→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   406→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   407→\\t\\t\\t\\tfullTranscript = content\\n   408→\\t\\t\\t}\\n   409→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   410→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   411→\\t\\t\\t\\tfullTranscript = content\\n   412→\\t\\t\\t}\\n   413→\\t\\t}\\n   414→\\t}\\n   415→\\n   416→\\t// Process transcript based on agent type\\n   417→\\tif fullTranscript != \\\"\\\" {\\n   418→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   419→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   420→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   421→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   422→\\t}\\n   423→\\n   424→\\t// Use tracked files from session state (not all files in tree)\\n   425→\\tdata.FilesTouched = filesTouched\\n   426→\\n   427→\\t// Read export data from local metadata directory (e.g., OpenCode SQLite export).\\n   428→\\t// This is written by lifecycle.go during TurnEnd and must be stored in the\\n   429→\\t// committed checkpoint so resume/rewind can re-import the session.\\n   430→\\texportRelPath := metadataDir + \\\"/\\\" + paths.ExportDataFileName\\n   431→\\tif exportAbsPath, absErr := paths.AbsPath(exportRelPath); absErr == nil {\\n   432→\\t\\tif exportBytes, readErr := os.ReadFile(exportAbsPath); readErr == nil && len(exportBytes) > 0 { //nolint:gosec // path from session metadata\\n   433→\\t\\t\\tdata.ExportData = exportBytes\\n   434→\\t\\t}\\n   435→\\t}\\n   436→\\n   437→\\t// Calculate token usage from the extracted transcript portion\\n   438→\\tif len(data.Transcript) > 0 {\\n   439→\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n   440→\\t}\\n   441→\\n   442→\\treturn data, nil\\n   443→}\\n   444→\\n   445→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   446→// This is used for mid-session commits where no shadow branch exists yet.\\n   447→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n   448→\\tdata := &ExtractedSessionData{}\\n   449→\\n   450→\\t// Read the live transcript\\n   451→\\tif state.TranscriptPath == \\\"\\\" {\\n   452→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   453→\\t}\\n   454→\\n   455→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   456→\\tif err != nil {\\n   457→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   458→\\t}\\n   459→\\n   460→\\tif len(liveData) == 0 {\\n   461→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   462→\\t}\\n   463→\\n   464→\\tfullTranscript := string(liveData)\\n   465→\\tdata.Transcript = liveData\\n   466→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   467→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   468→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   469→\\n   470→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   471→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   472→\\tif len(state.FilesTouched) > 0 {\\n   473→\\t\\tdata.FilesTouched = state.FilesTouched\\n   474→\\t} else {\\n   475→\\t\\t// Use the shared helper which includes subagent transcripts\\n   476→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n   477→\\t}\\n   478→\\n   479→\\t// Read export data from local metadata directory\\n   480→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(state.SessionID)\\n   481→\\texportRelPath := metadataDir + \\\"/\\\" + paths.ExportDataFileName\\n   482→\\tif exportAbsPath, absErr := paths.AbsPath(exportRelPath); absErr == nil {\\n   483→\\t\\tif exportBytes, readErr := os.ReadFile(exportAbsPath); readErr == nil && len(exportBytes) > 0 { //nolint:gosec // path from session metadata\\n   484→\\t\\t\\tdata.ExportData = exportBytes\\n   485→\\t\\t}\\n   486→\\t}\\n   487→\\n   488→\\t// Calculate token usage from the extracted transcript portion\\n   489→\\tif len(data.Transcript) > 0 {\\n   490→\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n   491→\\t}\\n   492→\\n   493→\\treturn data, nil\\n   494→}\\n   495→\\n   496→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   497→// For Claude Code and JSONL-based agents, this counts lines.\\n   498→// For Gemini CLI and JSON-based agents, this counts messages.\\n   499→// Returns 0 if the content is empty or malformed.\\n   500→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   501→\\tif content == \\\"\\\" {\\n   502→\\t\\treturn 0\\n   503→\\t}\\n   504→\\n   505→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   506→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   507→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   508→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   509→\\t\\t\\treturn len(transcript.Messages)\\n   510→\\t\\t}\\n   511→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   512→\\t\\tif agentType == agent.AgentTypeGemini {\\n   513→\\t\\t\\treturn 0\\n   514→\\t\\t}\\n   515→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   516→\\t}\\n   517→\\n   518→\\t// Claude Code and other JSONL-based agents\\n   519→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   520→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   521→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   522→\\t\\tallLines = allLines[:len(allLines)-1]\\n   523→\\t}\\n   524→\\treturn len(allLines)\\n   525→}\\n   526→\\n   527→// extractUserPrompts extracts all user prompts from