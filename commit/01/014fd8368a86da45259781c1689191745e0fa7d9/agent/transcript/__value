e/checkpoints/v1\\\")\\n    98→\\n    99→\\t\\t// Second prompt: modify same file and commit again.\\n   100→\\t\\ts.Send(t, session, \\\"add another stanza to poem.txt about debugging, then create a NEW commit (do not amend). Do not ask for confirmation.\\\")\\n   101→\\t\\ts.WaitFor(t, session, prompt, 90*time.Second)\\n   102→\\t\\ttestutil.AssertNewCommits(t, s, 2)\\n   103→\\n   104→\\t\\ttestutil.WaitForCheckpointAdvanceFrom(t, s.Dir, cpBranch1, 15*time.Second)\\n   105→\\t\\tcpID2 := testutil.AssertHasCheckpointTrailer(t, s.Dir, \\\"HEAD\\\")\\n   106→\\t\\tsm := testutil.WaitForSessionMetadata(t, s.Dir, cpID2, 0, 10*time.Second)\\n   107→\\n   108→\\t\\tassert.Greater(t, sm.InitialAttribution.AgentLines, 0,\\n   109→\\t\\t\\t\\\"agent lines should be > 0 on second commit\\\")\\n   110→\\t\\tassert.Greater(t, sm.InitialAttribution.TotalCommitted, 0,\\n   111→\\t\\t\\t\\\"total committed should be > 0 on second commit\\\")\\n   112→\\t\\tassert.Greater(t, sm.InitialAttribution.AgentPercentage, 50.0,\\n   113→\\t\\t\\t\\\"agent wrote all content, percentage should be > 50%%\\\")\\n   114→\\t\\ttestutil.AssertNoShadowBranches(t, s.Dir)\\n   115→\\t})\\n   116→}\\n   117→\\n   118→// TestShadowBranchCleanedAfterAgentCommit: after an agent creates a file\\n   119→// and commits it, there should be no lingering shadow branches. Shadow\\n   120→// branches match entire/* but are not entire/checkpoints/*.\\n   121→func TestShadowBranchCleanedAfterAgentCommit(t *testing.T) {\\n   122→\\ttestutil.ForEachAgent(t, 3*time.Minute, func(t *testing.T, s *testutil.RepoState, ctx context.Context) {\\n   123→\\t\\tprompt := s.Agent.PromptPattern()\\n   124→\\n   125→\\t\\tsession := s.StartSession(t, ctx)\\n   126→\\t\\tif session == nil {\\n   127→\\t\\t\\tt.Skipf(\\\"agent %s does not support interactive mode\\\", s.Agent.Name())\\n   128→\\t\\t}\\n   129→\\n   130→\\t\\ts.WaitFor(t, session, prompt, 30*time.Second)\\n   131→\\n   132→\\t\\ts.Send(t, session, \\\"create a fil