eturn 0, err\\n   290→\\t}\\n   291→\\n   292→\\tremoved := 0\\n   293→\\tvar removeErrors []string\\n   294→\\n   295→\\tfor _, hook := range gitHookNames {\\n   296→\\t\\thookPath := filepath.Join(hooksDir, hook)\\n   297→\\t\\tbackupPath := hookPath + backupSuffix\\n   298→\\n   299→\\t\\t// Remove the hook if it contains our marker\\n   300→\\t\\tdata, err := os.ReadFile(hookPath) //nolint:gosec // path is controlled\\n   301→\\t\\thookIsOurs := err == nil && strings.Contains(string(data), entireHookMarker)\\n   302→\\t\\thookExists := err == nil\\n   303→\\n   304→\\t\\tif hookIsOurs {\\n   305→\\t\\t\\tif err := os.Remove(hookPath); err != nil {\\n   306→\\t\\t\\t\\tremoveErrors = append(removeErrors, fmt.Sprintf(\\\"%s: %v\\\", hook, err))\\n   307→\\t\\t\\t\\tcontinue\\n   308→\\t\\t\\t}\\n   309→\\t\\t\\tremoved++\\n   310→\\t\\t}\\n   311→\\n   312→\\t\\t// Restore .pre-entire backup if it exists\\n   313→\\t\\tif fileExists(backupPath) {\\n   314→\\t\\t\\tif hookExists && !hookIsOurs {\\n   315→\\t\\t\\t\\t// A non-Entire hook is present — don't overwrite it with the backup\\n   316→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: %s was modified since install; backup %s%s left in place\\\\n\\\", hook, hook, backupSuffix)\\n   317→\\t\\t\\t} else {\\n   318→\\t\\t\\t\\tif err := os.Rename(backupPath, hookPath); err != nil {\\n   319→\\t\\t\\t\\t\\tremoveErrors = append(removeErrors, fmt.Sprintf(\\\"restore %s%s: %v\\\", hook, backupSuffix, err))\\n   320→\\t\\t\\t\\t}\\n   321→\\t\\t\\t}\\n   322→\\t\\t}\\n   323→\\t}\\n   324→\\n   325→\\tif len(removeErrors) > 0 {\\n   326→\\t\\treturn removed, fmt.Errorf(\\\"failed to remove hooks: %s\\\", strings.Join(removeErrors, \\\"; \\\"))\\n   327→\\t}\\n   328→\\treturn removed, nil\\n   329→}\\n   330→\\n   331→// generateChainedContent appends a chain call to the base hook content,\\n   332→// so the pre-existing hook (backed up to .pre-entire) is called after our hook.\\n   333→func generateChainedCo