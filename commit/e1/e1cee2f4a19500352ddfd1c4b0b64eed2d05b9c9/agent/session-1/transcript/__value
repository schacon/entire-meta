    41→If the branch doesn't exist locally but exists on origin, you'll be prompted\\n    42→to fetch it.\\n    43→\\n    44→If newer commits without checkpoints exist on the branch (e.g., after merging main\\n    45→or cherry-picking from elsewhere), this operation will reset your Git status to the\\n    46→most recent commit with a checkpoint.  You'll be prompted to confirm resuming in this case.`,\\n    47→\\t\\tArgs: cobra.ExactArgs(1),\\n    48→\\t\\tRunE: func(cmd *cobra.Command, args []string) error {\\n    49→\\t\\t\\tif checkDisabledGuard(cmd.Context(), cmd.OutOrStdout()) {\\n    50→\\t\\t\\t\\treturn nil\\n    51→\\t\\t\\t}\\n    52→\\t\\t\\treturn runResume(cmd.Context(), args[0], force)\\n    53→\\t\\t},\\n    54→\\t}\\n    55→\\n    56→\\tcmd.Flags().BoolVarP(&force, \\\"force\\\", \\\"f\\\", false, \\\"Resume from older checkpoint without confirmation\\\")\\n    57→\\n    58→\\treturn cmd\\n    59→}\\n    60→\\n    61→func runResume(ctx context.Context, branchName string, force bool) error {\\n    62→\\t// Check if we're already on this branch\\n    63→\\tcurrentBranch, err := GetCurrentBranch(ctx)\\n    64→\\tif err == nil && currentBranch == branchName {\\n    65→\\t\\t// Already on the branch, skip checkout\\n    66→\\t\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n    67→\\t}\\n    68→\\n    69→\\t// Check if branch exists locally\\n    70→\\texists, err := BranchExistsLocally(ctx, branchName)\\n    71→\\tif err != nil {\\n    72→\\t\\treturn fmt.Errorf(\\\"failed to check branch: %w\\\", err)\\n    73→\\t}\\n    74→\\n    75→\\tif !exists {\\n    76→\\t\\t// Branch doesn't exist locally, check if it exists on remote\\n    77→\\t\\tremoteExists, err := BranchExistsOnRemote(ctx, branchName)\\n    78→\\t\\tif err != nil {\\n    79→\\t\\t\\treturn fmt.Errorf(\\\"failed to check remote branch: %w\\\", err)\\n    80→\\t\\t}\\n    81→\\n    82→\\t\\tif !remoteExists {\\n    83→\\t\\t\\treturn fmt.Errorf(\\\"branch '%s' not found locally or on origin\\\", branchName)\\n    84→\\t\\t}\\n    85→\\n    86→\\t\\t// Ask user if they want to fetch from remote\\n    87→\\t\\tshouldFetch, err := promptFetchFromRemote(branchName)\\n    88→\\t\\tif err != nil {\\n    89→\\t\\t\\treturn err\\n    90→\\t\\t}\\n    91→\\t\\tif !shouldFetch {\\n    92→\\t\\t\\treturn nil\\n    93→\\t\\t}\\n    94→\\n    95→\\t\\t// Fetch and checkout the remote branch\\n    96→\\t\\tfmt.Fprintf(os.Stderr, \\\"Fetching branch '%s' from origin...\\\\n\\\", branchName)\\n    97→\\t\\tif err := FetchAndCheckoutRemoteBranch(ctx, branchName); err != nil {\\n    98→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n    99→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   100→\\t\\t}\\n   101→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   102→\\t} else {\\n   103→\\t\\t// Branch exists locally, check for uncommitted changes before checkout\\n   104→\\t\\thasChanges, err := HasUncommittedChanges(ctx)\\n   105→\\t\\tif err != nil {\\n   106→\\t\\t\\treturn fmt.Errorf(\\\"failed to check for uncommitted changes: %w\\\", err)\\n   107→\\t\\t}\\n   108→\\t\\tif hasChanges {\\n   109→\\t\\t\\treturn errors.New(\\\"you have uncommitted changes. Please commit or stash them first\\\")\\n   110→\\t\\t}\\n   111→\\n   112→\\t\\t// Checkout the branch\\n   113→\\t\\tif err := CheckoutBranch(ctx, branchName); err != nil {\\n   114→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n   115→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   116→\\t\\t}\\n   117→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   118→\\t}\\n   119→\\n   120→\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n   121→}\\n   122→\\n   123→func resumeFromCurrentBranch(ctx context.Context, branchName string, force bool) error {\\n   124→\\trepo, err := openRepository(ctx)\\n   125→\\tif err != nil {\\n   126→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   127→\\t}\\n   128→\\n   129→\\t// Find a commit with an Entire-Checkpoint trailer, looking at branch-only commits\\n   130→\\tresult, err := findBranchCheckpoint(repo, branchName)\\n   131→\\tif err != nil {\\n   132→\\t\\treturn err\\n   133→\\t}\\n   134→\\tif len(result.checkpointIDs) == 0 {\\n   135→\\t\\tfmt.Fprintf(os.Stderr, \\\"No Entire checkpoint found on branch '%s'\\\\n\\\", branchName)\\n   136→\\t\\treturn nil\\n   137→\\t}\\n   138→\\n   139→\\t// If there are newer commits without checkpoints, ask for confirmation.\\n   140→\\t// Merge commits (e.g., from merging main) don't count as \\\"work\\\" and are skipped silently.\\n   141→\\tif result.newerCommitsExist && !force {\\n   142→\\t\\tfmt.Fprintf(os.Stderr, \\\"Found checkpoint in an older commit.\\\\n\\\")\\n   143→\\t\\tfmt.Fprintf(os.Stderr, \\\"There are %d newer commit(s) on this branch without checkpoints.\\\\n\\\", result.newerCommitCount)\\n   144→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint from: %s %s\\\\n\\\\n\\\", result.commitHash[:7], firstLine(result.commitMessage))\\n   145→\\n   146→\\t\\tshouldResume, err := promptResumeFromOlderCheckpoint()\\n   147→\\t\\tif err != nil {\\n   148→\\t\\t\\treturn err\\n   149→\\t\\t}\\n   150→\\t\\tif !shouldResume {\\n   151→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled.\\\\n\\\")\\n   152→\\t\\t\\treturn nil\\n   153→\\t\\t}\\n   154→\\t}\\n   155→\\n   156→\\t// Multiple checkpoints (squash merge): restore all sessions\\n   157→\\tif len(result.checkpointIDs) > 1 {\\n   158→\\t\\treturn resumeMultipleCheckpoints(ctx, repo, result.checkpointIDs, force)\\n   159→\\t}\\n   160→\\n   161→\\t// Single checkpoint: existing behavior (unchanged)\\n   162→\\tcheckpointID := result.checkpointIDs[0]\\n   163→\\n   164→\\t// Get metadata branch tree for lookups\\n   165→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   166→\\tif err != nil {\\n   167→\\t\\t// No local metadata branch, check if remote has it\\n   168→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   169→\\t}\\n   170→\\n   171→\\t// Look up metadata from sharded path\\n   172→\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n   173→\\tif err != nil {\\n   174→\\t\\t// Checkpoint exists in commit but no local metadata - check remote\\n   175→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   176→\\t}\\n   177→\\n   178→\\treturn resumeSession(ctx, metadata.SessionID, checkpointID, force)\\n   179→}\\n   180→\\n   181→// resumeMultipleCheckpoints restores sessions from multiple checkpoint IDs.\\n   182→// This handles squash merge commits where multiple Entire-Checkpoint trailers\\n   183→// are present in a single commit message. Each checkpoint is looked up independently\\n   184→// and missing metadata is skipped (best-effort).\\n   185→func resumeMultipleCheckpoints(ctx context.Context, repo *git.Repository, checkpointIDs []id.CheckpointID, force bool) error {\\n   186→\\tlogCtx := logging.WithComponent(ctx, \\\"resume\\\")\\n   187→\\n   188→\\t// Get metadata branch tree (try local first, then remote)\\n   189→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   190→\\tif err != nil {\\n   191→\\t\\t// Try fetching from remote\\n   192→\\t\\tlogging.Debug(logCtx, \\\"metadata branch not available locally, trying remote\\\")\\n   193→\\t\\tif fetchErr := FetchMetadataBranch(ctx); fetchErr != nil {\\n   194→\\t\\t\\t// If fetch also fails, try remote tree directly\\n   195→\\t\\t\\tremoteTree, remoteErr := strategy.GetRemoteMetadataBranchTree(repo)\\n   196→\\t\\t\\tif remoteErr != nil {\\n   197→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint metadata not available locally or on remote\\\\n\\\")\\n   198→\\t\\t\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   199→\\t\\t\\t}\\n   200→\\t\\t\\tmetadataTree = remoteTree\\n   201→\\t\\t} else {\\n   202→\\t\\t\\tmetadataTree, err = strategy.GetMetadataBranchTree(repo)\\n   203→\\t\\t\\tif err != nil {\\n   204→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint metadata not available after fetch\\\\n\\\")\\n   205→\\t\\t\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   206→\\t\\t\\t}\\n   207→\\t\\t}\\n   208→\\t}\\n   209→\\n   210→\\tstrat := GetStrategy(ctx)\\n   211→\\tvar allSessions []strategy.RestoredSession\\n   212→\\n   213→\\tfor _, cpID := range checkpointIDs {\\n   214→\\t\\tmetadata, metaErr := strategy.ReadCheckpointMetadata(metadataTree, cpID.Path())\\n   215→\\t\\tif metaErr != nil {\\n   216→\\t\\t\\tlogging.Debug(logCtx, \\\"skipping checkpoint without metadata\\\",\\n   217→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   218→\\t\\t\\t\\tslog.String(\\\"error\\\", metaErr.Error()),\\n   219→\\t\\t\\t)\\n   220→\\t\\t\\tcontinue\\n   221→\\t\\t}\\n   222→\\n   223→\\t\\tpoint := strategy.RewindPoint{\\n   224→\\t\\t\\tIsLogsOnly:   true,\\n   225→\\t\\t\\tCheckpointID: cpID,\\n   226→\\t\\t\\tAgent:        metadata.Agent,\\n   227→\\t\\t}\\n   228→\\n   229→\\t\\tsessions, restoreErr := strat.RestoreLogsOnly(ctx, point, force)\\n   230→\\t\\tif restoreErr != nil {\\n   231→\\t\\t\\tlogging.Debug(logCtx, \\\"skipping checkpoint: restore failed\\\",\\n   232→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   233→\\t\\t\\t\\tslog.String(\\\"error\\\", restoreErr.Error()),\\n   234→\\t\\t\\t)\\n   235→\\t\\t\\tcontinue\\n   236→\\t\\t}\\n   237→\\t\\tif len(sessions) == 0 {\\n   238→\\t\\t\\tlogging.Debug(logCtx, \\\"skipping checkpoint: no sessions restored\\\",\\n   239→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   240→\\t\\t\\t)\\n   241→\\t\\t\\tcontinue\\n   242→\\t\\t}\\n   243→\\n   244→\\t\\tallSessions = append(allSessions, sessions...)\\n   245→\\t}\\n   246→\\n   247→\\tif len(allSessions) == 0 {\\n   248→\\t\\tfmt.Fprintf(os.Stderr, \\\"No session metadata found for checkpoints in this commit\\\\n\\\")\\n   249→\\t\\treturn nil\\n   250→\\t}\\n   251→\\n   252→\\tlogging.Debug(logCtx, \\\"resume multiple checkpoints completed\\\",\\n   253→\\t\\tslog.Int(\\\"checkpoint_count\\\", len(checkpointIDs)),\\n   254→\\t\\tslog.Int(\\\"session_count\\\", len(allSessions)),\\n   255→\\t)\\n   256→\\n   257→\\treturn displayRestoredSessions(allSessions)\\n   258→}\\n   259→\\n   260→// branchCheckpointResult contains the result of searching for a checkpoint on a branch.\\n   261→type branchCheckpointResult struct {\\n   262→\\tcheckpointIDs     []id.CheckpointID\\n   263→\\tcommitHash        string\\n   264→\\tcommitMessage     string\\n   265→\\tnewerCommitsExist bool // true if there are branch-only commits (not merge commits) without checkpoints\\n   266→\\tnewerCommitCount  int  // count of branch-only commits without checkpoints\\n   267→}\\n   268→\\n   269→// findBranchCheckpoint finds the most recent commit with an Entire-Checkpoint trailer\\n   270→// among commits that are unique to this branch (not reachable from the default branch).\\n   271→// This handles the case where main has been merged into the feature branch.\\n   272→func findBranchCheckpoint(repo *git.Repository, branchName string) (*branchCheckpointResult, error) {\\n   273→\\tresult := &branchCheckpointResult{}\\n   274→\\n   275→\\t// Get HEAD commit\\n   276→\\thead, err := repo.Head()\\n   277→\\tif err != nil {\\n   278→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   279→\\t}\\n   280→\\n   281→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   282→\\tif err != nil {\\n   283→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   284→\\t}\\n   285→\\n   286→\\t// First, check if HEAD itself has a checkpoint (most common case)\\n   287→\\tif cpIDs := trailers.ParseAllCheckpoints(headCommit.Message); len(cpIDs) > 0 {\\n   288→\\t\\tresult.checkpointIDs = cpIDs\\n   289→\\t\\tresult.commitHash = head.Hash().String()\\n   290→\\t\\tresult.commitMessage = headCommit.Message\\n   291→\\t\\tresult.newerCommitsExist = false\\n   292→\\t\\treturn result, nil\\n   293→\\t}\\n   294→\\n   295→\\t// HEAD doesn't have a checkpoint - find branch-only commits\\n   296→\\t// Get the default branch name\\n   297→\\tdefaultBranch := getDefaultBranchFromRemote(repo)\\n   298→\\tif defaultBranch == \\\"\\\" {\\n   299→\\t\\t// Fallback: try common names\\n   300→\\t\\tfor _, name := range []string{\\\"main\\\", \\\"master\\\"} {\\n   301→\\t\\t\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(name), true); err == nil {\\n   302→\\t\\t\\t\\tdefaultBranch = name\\n   303→\\t\\t\\t\\tbreak\\n   304→\\t\\t\\t}\\n   305→\\t\\t}\\n   306→\\t}\\n   307→\\n   308→\\t// If we can't find a default branch, or we're on it, just walk all commits\\n   309→\\tif defaultBranch == \\\"\\\" || defaultBranch == branchName {\\n   310→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil\\n   311→\\t}\\n   312→\\n   313→\\t// Get the default branch reference\\n   314→\\tdefaultRef, err := repo.Reference(plumbing.NewBranchReferenceName(defaultBranch), true)\\n   315→\\tif err != nil {\\n   316→\\t\\t// Default branch doesn't exist locally, fall back to walking all commits\\n   317→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   318→\\t}\\n   319→\\n   320→\\tdefaultCommit, err := repo.CommitObject(defaultRef.Hash())\\n   321→\\tif err != nil {\\n   322→\\t\\t// Can't get default commit, fall back to walking all commits\\n   323→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   324→\\t}\\n   325→\\n   326→\\t// Find merge base\\n   327→\\tmergeBase, err := headCommit.MergeBase(defaultCommit)\\n   328→\\tif err != nil || len(mergeBase) == 0 {\\n   329→\\t\\t// No common ancestor, fall back to walking all commits\\n   330→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   331→\\t}\\n   332→\\n   333→\\t// Walk from HEAD to merge base, looking for checkpoint\\n   334→\\treturn findCheckpointInHistory(headCommit, &mergeBase[0].Hash), nil\\n   335→}\\n   336→\\n   337→// findCheckpointInHistory walks commit history from start looking for a checkpoint trailer.\\n   338→// If stopAt is provided, stops when reaching that commit (exclusive).\\n   339→// Returns the first checkpoint found and info about commits between HEAD and the checkpoint.\\n   340→// It distinguishes between merge commits (bringing in other branches) and regular commits\\n   341→// (actual branch work) to avoid false warnings after merging main.\\n   342→func findCheckpointInHistory(start *object.Commit, stopAt *plumbing.Hash) *branchCheckpointResult {\\n   343→\\tresult := &branchCheckpointResult{}\\n   344→\\tbranchWorkCommits := 0 // Regular commits without checkpoints (actual work)\\n   345→\\tconst maxCommits = 100 // Limit search depth\\n   346→\\ttotalChecked := 0\\n   347→\\n   348→\\tcurrent := start\\n   349→\\tfor current != nil && totalChecked < maxCommits {\\n   350→\\t\\t// Stop if we've reached the boundary\\n   351→\\t\\tif stopAt != nil && current.Hash == *stopAt {\\n   352→\\t\\t\\tbreak\\n   353→\\t\\t}\\n   354→\\n   355→\\t\\t// Check for checkpoint trailer\\n   356→\\t\\tif cpIDs := trailers.ParseAllCheckpoints(current.Message); len(cpIDs) > 0 {\\n   357→\\t\\t\\tresult.checkpointIDs = cpIDs\\n   358→\\t\\t\\tresult.commitHash = current.Hash.String()\\n   359→\\t\\t\\tresult.commitMessage = current.Message\\n   360→\\t\\t\\t// Only warn about branch work commits, not merge commits\\n   361→\\t\\t\\tresult.newerCommitsExist = branchWorkCommits > 0\\n   362→\\t\\t\\tresult.newerCommitCount = branchWorkCommits\\n   363→\\t\\t\\treturn result\\n   364→\\t\\t}\\n   365→\\n   366→\\t\\t// Only count regular commits (not merge commits) as \\\"branch work\\\"\\n   367→\\t\\tif current.NumParents() <= 1 {\\n   368→\\t\\t\\tbranchWorkCommits++\\n   369→\\t\\t}\\n   370→\\n   371→\\t\\ttotalChecked++\\n   372→\\n   373→\\t\\t// Move to parent (first parent for merge commits - follows the main line)\\n   374→\\t\\tif current.NumParents() == 0 {\\n   375→\\t\\t\\tbreak\\n   376→\\t\\t}\\n   377→\\t\\tparent, err := current.Parent(0)\\n   378→\\t\\tif err != nil {\\n   379→\\t\\t\\t// Can't get parent, treat as end of history\\n   380→\\t\\t\\tbreak\\n   381→\\t\\t}\\n   382→\\t\\tcurrent = parent\\n   383→\\t}\\n   384→\\n   385→\\t// No checkpoint found\\n   386→\\treturn result\\n   387→}\\n   388→\\n   389→// promptResumeFromOlderCheckpoint asks the user if they want to resume from an older checkpoint.\\n   390→func promptResumeFromOlderCheckpoint() (bool, error) {\\n   391→\\tvar confirmed bool\\n   392→\\n   393→\\tform := NewAccessibleForm(\\n   394→\\t\\thuh.NewGroup(\\n   395→\\t\\t\\thuh.NewConfirm().\\n   396→\\t\\t\\t\\tTitle(\\\"Resume from this older checkpoint?\\\").\\n   397→\\t\\t\\t\\tValue(&confirmed),\\n   398→\\t\\t),\\n   399→\\t)\\n   400→\\n   401→\\tif err := form.Run(); err != nil {\\n   402→\\t\\tif errors.Is(err, huh.ErrUserAborted) {\\n   403→\\t\\t\\treturn false, nil\\n   404→\\t\\t}\\n   405→\\t\\treturn false, fmt.Errorf(\\\"failed to get confirmation: %w\\\", err)\\n   406→\\t}\\n   407→\\n   408→\\treturn confirmed, nil\\n   409→}\\n   410→\\n   411→// checkRemoteMetadata checks if checkpoint metadata exists on origin/entire/checkpoints/v1\\n   412→// and automatically fetches it if available.\\n   413→func checkRemoteMetadata(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID) error {\\n   414→\\t// Try to get remote metadata branch tree\\n   415→\\tremoteTree, err := strategy.GetRemoteMetadataBranchTree(repo)\\n   416→\\tif err != nil {\\n   417→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   418→\\t\\t