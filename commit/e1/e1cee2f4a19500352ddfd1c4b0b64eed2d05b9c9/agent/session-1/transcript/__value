// Read checkpoint summary to get session count\\n   598→\\tsummary, err := store.ReadCommitted(ctx, point.CheckpointID)\\n   599→\\tif err != nil {\\n   600→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   601→\\t}\\n   602→\\tif summary == nil {\\n   603→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", point.CheckpointID)\\n   604→\\t}\\n   605→\\n   606→\\t// Get worktree root for agent session directory lookup\\n   607→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   608→\\tif err != nil {\\n   609→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   610→\\t}\\n   611→\\n   612→\\t// Check for newer local logs if not forcing\\n   613→\\tif !force {\\n   614→\\t\\tsessions := s.classifySessionsForRestore(ctx, repoRoot, store, point.CheckpointID, summary)\\n   615→\\t\\thasConflicts := false\\n   616→\\t\\tfor _, sess := range sessions {\\n   617→\\t\\t\\tif sess.Status == StatusLocalNewer {\\n   618→\\t\\t\\t\\thasConflicts = true\\n   619→\\t\\t\\t\\tbreak\\n   620→\\t\\t\\t}\\n   621→\\t\\t}\\n   622→\\t\\tif hasConflicts {\\n   623→\\t\\t\\tshouldOverwrite, promptErr := PromptOverwriteNewerLogs(sessions)\\n   624→\\t\\t\\tif promptErr != nil {\\n   625→\\t\\t\\t\\treturn nil, promptErr\\n   626→\\t\\t\\t}\\n   627→\\t\\t\\tif !shouldOverwrite {\\n   628→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled. Local session logs preserved.\\\\n\\\")\\n   629→\\t\\t\\t\\treturn nil, nil\\n   630→\\t\\t\\t}\\n   631→\\t\\t}\\n   632→\\t}\\n   633→\\n   634→\\t// Count sessions to restore\\n   635→\\ttotalSessions := len(summary.Sessions)\\n   636→\\tif totalSessions > 1 {\\n   637→\\t\\tfmt.Fprintf(os.Stderr, \\\"Restoring %d sessions from checkpoint:\\\\n\\\", totalSessions)\\n   638→\\t}\\n   639→\\n   640→\\t// Restore all sessions (oldest to newest, using 0-based indexing)\\n   641→\\tvar restored []RestoredSession\\n   642→\\tfor i := range totalSessions {\\n   643→\\t\\tcontent, readErr := store.ReadSessionContent(ctx, point.CheckpointID, i)\\n   644→\\t\\tif readErr != nil {\\n   645→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: failed to read session %d: %v\\\\n\\\", i, readErr)\\n   646→\\t\\t\\tcontinue\\n   647→\\t\\t}\\n   648→\\t\\tif content == nil || len(content.Transcript) == 0 {\\n   649→\\t\\t\\tcontinue\\n   650→\\t\\t}\\n   651→\\n   652→\\t\\tsessionID := content.Metadata.SessionID\\n   653→\\t\\tif sessionID == \\\"\\\" {\\n   654→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d has no session ID, skipping\\\\n\\\", i)\"}]},\"uuid\":\"f67e01d0-c6a9-4f4c-a929-366dff67d3eb\",\"timestamp\":\"2026-02-26T23:27:06.154Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"## Code Review Request\\n\\n**What was implemented:** Multi-checkpoint resume support for squash merges. When a squash merge combines multiple commits that each had `Entire-Checkpoint` trailers, the resume command now parses ALL checkpoint IDs from the squash merge commit message and restores sessions from each one.\\n\\n**Plan/Requirements:** \\n- Parse all `Entire-Checkpoint` trailers from a commit (not just the first one)\\n- Support resuming multiple checkpoints in a single `entire resume` operation  \\n- Display restored sessions from each checkpoint clearly\\n- Handle cases where some checkpoints fail to restore gracefully\\n- Support for `branchCheckpointResult` returning multiple checkpoint IDs\\n\\n**Base SHA:** 91f9ab4fb115936efe70f481b4bbb08ca3cc273f (merge-base with main)\\n**HEAD SHA:** 3c80fab2ac08fddbdb5d5b225f7d74024f567b30\\n\\n**Description:** This branch adds multi-checkpoint resume capability. Key changes:\\n\\n1. **New `trailers` package** (`cmd/entire/cli/trailers/`) - `ParseAllCheckpoints()` extracts all `Entire-Checkpoint` trailer values from a commit message\\n2. **`resumeMultipleCheckpoints()`** in `resume.go` - orchestrates restoring sessions from multiple checkpoint IDs\\n3. **`displayRestoredSessions()`** extracted he