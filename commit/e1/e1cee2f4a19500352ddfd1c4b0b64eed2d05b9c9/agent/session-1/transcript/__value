ession(ctx, metadata.SessionID, checkpointID, false)\\n   456→}\\n   457→\\n   458→// resumeSession restores and displays the resume command for a specific session.\\n   459→// For multi-session checkpoints, restores ALL sessions and shows commands for each.\\n   460→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   461→func resumeSession(ctx context.Context, sessionID string, checkpointID id.CheckpointID, force bool) error {\\n   462→\\t// Read checkpoint metadata first to get agent type (matching rewind pattern)\\n   463→\\trepo, err := openRepository(ctx)\\n   464→\\tif err != nil {\\n   465→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   466→\\t}\\n   467→\\n   468→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   469→\\tif err != nil {\\n   470→\\t\\treturn fmt.Errorf(\\\"failed to get metadata branch: %w\\\", err)\\n   471→\\t}\\n   472→\\n   473→\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n   474→\\tif err != nil {\\n   475→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint metadata: %w\\\", err)\\n   476→\\t}\\n   477→\\n   478→\\t// Resolve agent from checkpoint metadata (same as rewind)\\n   479→\\tag, err := strategy.ResolveAgentForRewind(metadata.Agent)\\n   480→\\tif err != nil {\\n   481→\\t\\treturn fmt.Errorf(\\\"failed to resolve agent: %w\\\", err)\\n   482→\\t}\\n   483→\\n   484→\\t// Initialize logging context with agent\\n   485→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"resume\\\"), ag.Name())\\n   486→\\n   487→\\tlogging.Debug(logCtx, \\\"resume session started\\\",\\n   488→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   489→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   490→\\t)\\n   491→\\n   492→\\t// Get worktree root for session directory lookup\\n   493→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   494→\\tif err != nil {\\n   495→\\t\\treturn fmt.Errorf(\\\