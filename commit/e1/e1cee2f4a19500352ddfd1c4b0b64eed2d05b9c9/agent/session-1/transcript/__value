tif err != nil {\\n   127→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   128→\\t}\\n   129→\\n   130→\\t// Find a commit with an Entire-Checkpoint trailer, looking at branch-only commits\\n   131→\\tresult, err := findBranchCheckpoint(repo, branchName)\\n   132→\\tif err != nil {\\n   133→\\t\\treturn err\\n   134→\\t}\\n   135→\\tif len(result.checkpointIDs) == 0 {\\n   136→\\t\\tfmt.Fprintf(os.Stderr, \\\"No Entire checkpoint found on branch '%s'\\\\n\\\", branchName)\\n   137→\\t\\treturn nil\\n   138→\\t}\\n   139→\\n   140→\\t// If there are newer commits without checkpoints, ask for confirmation.\\n   141→\\t// Merge commits (e.g., from merging main) don't count as \\\"work\\\" and are skipped silently.\\n   142→\\tif result.newerCommitsExist && !force {\\n   143→\\t\\tfmt.Fprintf(os.Stderr, \\\"Found checkpoint in an older commit.\\\\n\\\")\\n   144→\\t\\tfmt.Fprintf(os.Stderr, \\\"There are %d newer commit(s) on this branch without checkpoints.\\\\n\\\", result.newerCommitCount)\\n   145→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint from: %s %s\\\\n\\\\n\\\", result.commitHash[:7], firstLine(result.commitMessage))\\n   146→\\n   147→\\t\\tshouldResume, err := promptResumeFromOlderCheckpoint()\\n   148→\\t\\tif err != nil {\\n   149→\\t\\t\\treturn err\\n   150→\\t\\t}\\n   151→\\t\\tif !shouldResume {\\n   152→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled.\\\\n\\\")\\n   153→\\t\\t\\treturn nil\\n   154→\\t\\t}\\n   155→\\t}\\n   156→\\n   157→\\t// Multiple checkpoints (squash merge): restore all sessions\\n   158→\\tif len(result.checkpointIDs) > 1 {\\n   159→\\t\\treturn resumeMultipleCheckpoints(ctx, repo, result.checkpointIDs, force)\\n   160→\\t}\\n   161→\\n   162→\\t// Single checkpoint: existing behavior (unchanged)\\n   163→\\tcheckpointID := result.checkpointIDs[0]\\n   164→\\n   165→\\t// Get metadata branch tree for lookups\\n   166→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   167→\\tif err != nil {\\n   168→\\t\\t// No local metadata branch, check if remote has it\\n   169→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   170→\\t}\\n   171→\\n   172→\\t// Look up metadata from sharded path\\n   173→\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n   174→\\tif err != nil {\\n   175→\\t\\t// Checkpoint exists in commit but no local metadata - check remote\\n   176→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   177→\\t}\\n   178→\\n   179→\\treturn resumeSession(ctx, metadata.SessionID, checkpointID, force)\\n   180→}\\n   181→\\n   182→// resumeMultipleCheckpoints restores sessions from multiple checkpoint IDs.\\n   183→// This handles squash merge commits where multiple Entire-Checkpoint trailers\\n   184→// are present in a single commit message. Each checkpoint is looked up independently\\n   185→// and missing metadata is skipped (best-effort).\\n   186→func resumeMultipleCheckpoints(ctx context.Context, repo *git.Repository, checkpointIDs []id.CheckpointID, force bool) error {\\n   187→\\tlogCtx := logging.WithComponent(ctx, \\\"resume\\\")\\n   188→\\n   189→\\t// Get metadata branch tree (try local first, then remote)\\n   190→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   191→\\tif err != nil {\\n   192→\\t\\t// Try fetching from remote\\n   193→\\t\\tlogging.Debug(logCtx, \\\"metadata branch not available locally, trying remote\\\")\\n   194→\\t\\tif fetchErr := FetchMetadataBranch(ctx); fetchErr != nil {\\n   195→\\t\\t\\t// If fetch also fails, try remote tree directly\\n   196→\\t\\t\\tremoteTree, remoteErr := strategy.GetRemoteMetadataBranchTree(repo)\\n   197→\\t\\t\\tif remoteErr != nil {\\n   198→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint metadata not available locally or on remote\\\\n\\\")\\n   199→\\t\\t\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   200→\\t\\t\\t}\\n   201→\\t\\t\\tmetadataTree = remoteTree\\n   202→\\t\\t} else {\\n   203→\\t\\t\\tmetadataTree, err = strategy.GetMetadataBranchTree(repo)\\n   204→\\t\\t\\tif err != nil {\\n   205→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint metadata not available after fetch\\\\n\\\")\\n   206→\\t\\t\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   207→\\t\\t\\t}\\n   208→\\t\\t}\\n   209→\\t}\\n   210→\\n   211→\\ttype sessionEntry struct {\\n   212→\\t\\tindex     int\\n   213→\\t\\tCreatedAt time.Time\\n   214→\\t}\\n   215→\\n   216→\\tstrat := GetStrategy(ctx)\\n   217→\\tvar allSessions []strategy.RestoredSession\\n   218→\\tseen := make(map[string]sessionEntry)\\n   219→\\n   220→\\tfor _, cpID := range checkpointIDs {\\n   221→\\t\\tmetadata, metaErr := strategy.ReadCheckpointMetadata(metadataTree, cpID.Path())\\n   222→\\t\\tif metaErr != nil {\\n   223→\\t\\t\\tlogging.Debug(logCtx, \\\"skipping checkpoint without metadata\\\",\\n   224→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   225→\\t\\t\\t\\tslog.String(\\\"error\\\", metaErr.Error()),\\n   226→\\t\\t\\t)\\n   227→\\t\\t\\tcontinue\\n   228→\\t\\t}\\n   229→\\n   230→\\t\\tpoint := strategy.RewindPoint{\\n   231→\\t\\t\\tIsLogsOnly:   true,\\n   232→\\t\\t\\tCheckpointID: cpID,\\n   233→\\t\\t\\tAgent:        metadata.Agent,\\n   234→\\t\\t}\\n   235→\\n   236→\\t\\tsessions, restoreErr := strat.RestoreLogsOnly(ctx, point, force)\\n   237→\\t\\tif restoreErr != nil {\\n   238→\\t\\t\\tlogging.Debug(logCtx, \\\"skipping checkpoint: restore failed\\\",\\n   239→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   240→\\t\\t\\t\\tslog.String(\\\"error\\\", restoreErr.Error()),\\n   241→\\t\\t\\t)\\n   242→\\t\\t\\tcontinue\\n   243→\\t\\t}\\n   244→\\t\\tif len(sessions) == 0 {\\n   245→\\t\\t\\tlogging.Debug(logCtx, \\\"skipping checkpoint: no sessions restored\\\",\\n   246→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   247→\\t\\t\\t)\\n   248→\\t\\t\\tcontinue\\n   249→\\t\\t}\\n   250→\\n   251→\\t\\tfor _, sess := range sessions {\\n   252→\\t\\t\\tif prev, exists := seen[sess.SessionID]; exists {\\n   253→\\t\\t\\t\\t// Keep the one with the later CreatedAt (more complete transcript)\\n   254→\\t\\t\\t\\tif sess.CreatedAt.After(prev.CreatedAt) {\\n   255→\\t\\t\\t\\t\\tallSessions[seen[sess.SessionID].index] = sess\\n   256→\\t\\t\\t\\t}\\n   257→\\t\\t\\t} else {\\n   258→\\t\\t\\t\\tseen[sess.SessionID] = sessionEntry{index: len(allSessions), CreatedAt: sess.CreatedAt}\\n   259→\\t\\t\\t\\tallSessions = append(allSessions, sess)\\n   260→\\t\\t\\t}\\n   261→\\t\\t}\\n   262→\\t}\\n   263→\\n   264→\\tif len(allSessions) == 0 {\\n   265→\\t\\tfmt.Fprintf(os.Stderr, \\\"No session metadata found for checkpoints in this commit\\\\n\\\")\\n   266→\\t\\treturn nil\\n   267→\\t}\\n   268→\\n   269→\\tlogging.Debug(logCtx, \\\"resume multiple checkpoints completed\\\",\\n   270→\\t\\tslog.Int(\\\"checkpoint_count\\\", len(checkpointIDs)),\\n   271→\\t\\tslog.Int(\\\"session_count\\\", len(allSessions)),\\n   272→\\t)\\n   273→\\n   274→\\treturn displayRestoredSessions(allSessions)\\n   275→}\\n   276→\\n   277→// branchCheckpointResult contains the result of searching for a checkpoint on a branch.\\n   278→type branchCheckpointResult struct {\\n   279→\\tcheckpointIDs     []id.CheckpointID\\n   280→\\tcommitHash        string\\n   281→\\tcommitMessage     string\\n   282→\\tnewerCommitsExist bool // true if there are branch-only commits (not merge commits) without checkpoints\\n   283→\\tnewerCommitCount  int  // count of branch-only commits without checkpoints\\n   284→}\\n   285→\\n   286→// findBranchCheckpoint finds the most recent commit with an Entire-Checkpoint trailer\\n   287→// among commits that are unique to this branch (not reachable from the default branch).\\n   288→// This handles the case where main has been merged into the feature branch.\\n   289→func findBranchCheckpoint(repo *git.Repository, branchName string) (*branchCheckpointResult, error) {\\n   290→\\tresult := &branchCheckpointResult{}\\n   291→\\n   292→\\t// Get HEAD commit\\n   293→\\thead, err := repo.Head()\\n   294→\\tif err != nil {\\n   295→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   296→\\t}\\n   297→\\n   298→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   299→\\tif err != nil {\\n   300→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   301→\\t}\\n   302→\\n   303→\\t// First, check if HEAD itself has a checkpoint (most common case)\\n   304→\\tif cpIDs := trailers.ParseAllCheckpoints(headCommit.Message); len(cpIDs) > 0 {\\n   305→\\t\\tresult.checkpointIDs = cpIDs\\n   306→\\t\\tresult.commitHash = head.Hash().String()\\n   307→\\t\\tresult.commitMessage = headCommit.Message\\n   308→\\t\\tresult.newerCommitsExist = false\\n   309→\\t\\treturn result, nil\\n   310→\\t}\\n   311→\\n   312→\\t// HEAD doesn't have a checkpoint - find branch-only commits\\n   313→\\t// Get the default branch name\\n   314→\\tdefaultBranch := getDefaultBranchFromRemote(repo)\\n   315→\\tif defaultBranch == \\\"\\\" {\\n   316→\\t\\t// Fallback: try common names\\n   317→\\t\\tfor _, name := range []string{\\\"main\\\", \\\"master\\\"} {\\n   318→\\t\\t\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(name), true); err == nil {\\n   319→\\t\\t\\t\\tdefaultBranch = name\\n   320→\\t\\t\\t\\tbreak\\n   321→\\t\\t\\t}\\n   322→\\t\\t}\\n   323→\\t}\\n   324→\\n   325→\\t// If we can't find a default branch, or we're on it, just walk all commits\\n   326→\\tif defaultBranch == \\\"\\\" || defaultBranch == branchName {\\n   327→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil\\n   328→\\t}\\n   329→\\n   330→\\t// Get the default branch reference\\n   331→\\tdefaultRef, err := repo.Reference(plumbing.NewBranchReferenceName(defaultBranch), true)\\n   332→\\tif err != nil {\\n   333→\\t\\t// Default branch doesn't exist locally, fall back to walking all commits\\n   334→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   335→\\t}\\n   336→\\n   337→\\tdefaultCommit, err := repo.CommitObject(defaultRef.Hash())\\n   338→\\tif err != nil {\\n   339→\\t\\t// Can't get default commit, fall back to walking all commits\\n   340→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   341→\\t}\\n   342→\\n   343→\\t// Find merge base\\n   344→\\tmergeBase, err := headCommit.MergeBase(defaultCommit)\\n   345→\\tif err != nil || len(mergeBase) == 0 {\\n   346→\\t\\t// No common ancestor, fall back to walking all commits\\n   347→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   348→\\t}\\n   349→\\n   350→\\t// Walk from HEAD to merge base, looking for checkpoint\\n   351→\\treturn findCheckpointInHistory(headCommit, &mergeBase[0].Hash), nil\\n   352→}\\n   353→\\n   354→// findCheckpointInHistory walks commit history from start looking for a checkpoint trailer.\\n   355→// If stopAt is provided, stops when reaching that commit (exclusive).\\n   356→// Returns the first checkpoint found and info about commits between HEAD and the checkpoint.\\n   357→// It distinguishes between merge commits (bringing in other branches) and regular commits\\n   358→// (actual branch work) to avoid false warnings after merging main.\\n   359→func findCheckpointInHistory(start *object.Commit, stopAt *plumbing.Hash) *branchCheckpointResult {\\n   360→\\tresult := &branchCheckpointResult{}\\n   361→\\tbranchWorkCommits := 0 // Regular commits without checkpoints (actual work)\\n   362→\\tconst maxCommits = 100 // Limit search depth\\n   363→\\ttotalChecked := 0\\n   364→\\n   365→\\tcurrent := start\\n   366→\\tfor current != nil && totalChecked < maxCommits {\\n   367→\\t\\t// Stop if we've reached the boundary\\n   368→\\t\\tif stopAt != nil && current.Hash == *stopAt {\\n   369→\\t\\