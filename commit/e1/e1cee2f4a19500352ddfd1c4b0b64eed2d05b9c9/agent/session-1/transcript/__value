// MetadataTrailerKey points to the metadata directory within a commit tree.\\n    17→\\tMetadataTrailerKey = \\\"Entire-Metadata\\\"\\n    18→\\n    19→\\t// MetadataTaskTrailerKey points to the task metadata directory for subagent checkpoints.\\n    20→\\tMetadataTaskTrailerKey = \\\"Entire-Metadata-Task\\\"\\n    21→\\n    22→\\t// StrategyTrailerKey indicates which strategy created the commit.\\n    23→\\tStrategyTrailerKey = \\\"Entire-Strategy\\\"\\n    24→\\n    25→\\t// BaseCommitTrailerKey links shadow commits to their base code commit.\\n    26→\\tBaseCommitTrailerKey = \\\"Base-Commit\\\"\\n    27→\\n    28→\\t// SessionTrailerKey identifies which session created a commit.\\n    29→\\tSessionTrailerKey = \\\"Entire-Session\\\"\\n    30→\\n    31→\\t// CondensationTrailerKey identifies the condensation ID for a commit (legacy).\\n    32→\\tCondensationTrailerKey = \\\"Entire-Condensation\\\"\\n    33→\\n    34→\\t// SourceRefTrailerKey links code commits to their metadata on a shadow/metadata branch.\\n    35→\\t// Format: \\\"<branch>@<commit-hash>\\\" e.g. \\\"entire/metadata@abc123def456\\\"\\n    36→\\tSourceRefTrailerKey = \\\"Entire-Source-Ref\\\"\\n    37→\\n    38→\\t// CheckpointTrailerKey links commits to their checkpoint metadata on entire/checkpoints/v1.\\n    39→\\t// Format: 12 hex characters e.g. \\\"a3b2c4d5e6f7\\\"\\n    40→\\t// This trailer survives git amend and rebase operations.\\n    41→\\tCheckpointTrailerKey = \\\"Entire-Checkpoint\\\"\\n    42→\\n    43→\\t// EphemeralBranchTrailerKey identifies the shadow branch that a checkpoint originated from.\\n    44→\\t// Used in manual-commit strategy checkpoint commits on entire/checkpoints/v1 branch.\\n    45→\\t// Format: full branch name e.g. \\\"entire/2b4c177\\\"\\n    46→\\tEphemeralBranchTrailerKey = \\\"Ephemeral-branch\\\"\\n    47→\\n    48→\\t// AgentTrailerKey identifies the agent that created a checkpoint.\\n    49→\\t// Format: human-readable agent name e.g. \\\"Claude Code\\\", \\\"Cursor\\\"\\n    50→\\tAgentTrailerKey = \\\"Entire-Agent\\\"\\n    51→)\\n    52→\\n    53→// Pre-compiled regexes for trailer parsing.\\n    54→var (\\n    55→\\t// Trailer parsing regexes.\\n    56→\\tstrategyTrailerRegex     = regexp.MustCompile(StrategyTrailerKey + `:\\\\s*(.+)`)\\n    57→\\tmetadataTrailerRegex     = regexp.MustCompile(MetadataTrailerKey + `:\\\\s*(.+)`)\\n    58→\\ttaskMetadataTrailerRegex = regexp.MustCompile(MetadataTaskTrailerKey + `:\\\\s*(.+)`)\\n    59→\\tbaseCommitTrailerRegex   = regexp.MustCompile(BaseCommitTrailerKey + `:\\\\s*([a-f0-9]{40})`)\\n    60→\\tcondensationTrailerRegex = regexp.MustCompile(CondensationTrailerKey + `:\\\\s*(.+)`)\\n    61→\\tsessionTrailerRegex      = regexp.MustCompile(SessionTrailerKey + `:\\\\s*(.+)`)\\n    62→\\tcheckpointTrailerRegex   = regexp.MustCompile(CheckpointTrailerKey + `:\\\\s*(` + checkpointID.Pattern + `)(?:\\\\s|$)`)\\n    63→)\\n    64→\\n    65→// ParseStrategy extracts strategy from commit message.\\n    66→// Returns the strategy name and true if found, empty string and false otherwise.\\n    67→func ParseStrategy(commitMessage string) (string, bool) {\\n    68→\\tmatches := strategyTrailerRegex.FindStringSubmatch(commitMessage)\\n    69→\\tif len(matches) > 1 {\\n    70→\\t\\treturn strings.TrimSpace(matches[1]), true\\n    71→\\t}\\n    72→\\treturn \\\"\\\", false\\n    73→}\\n    74→\\n    75→// ParseMetadata extracts metadata dir from commit message.\\n    76→// Returns the metadata directory and true if found, empty string and false otherwise.\\n    77→func ParseMetadata(commitMessage string) (string, bool) {\\n    78→\\tmatches := metadataTrailerRegex.FindStringSubmatch(commitMessage)\\n    79→\\tif len(matches) > 1 {\\n    80→\\t\\treturn strings.TrimSpace(matches[1]), true\\n    81→\\t}\\n    82→\\treturn \\\"\\\", false\\n    83→}\\n    84→\\n    85→// ParseTaskMetadata extracts task metadata dir from commit message.\\n    86→// Returns the task metadata directory and true if found, empty string and false otherwise.\\n    87→func ParseTaskMetadata(commitMessage string) (string, bool) {\\n    88→\\tmatches := taskMetadataTrailerRegex.FindStringSubmatch(commitMessage)\\n    89→\\tif len(matches) > 1 {\\n    90→\\t\\treturn strings.TrimSpace(matches[1]), true\\n    91→\\t}\\n    92→\\treturn \\\"\\\", false\\n    93→}\\n    94→\\n    95→// ParseBaseCommit extracts the base commit SHA from a commit message.\\n    96→// Returns the full SHA and true if found, empty string and false otherwise.\\n    97→func ParseBaseCommit(commitMessage string) (string, bool) {\\n    98→\\tmatches := baseCommitTrailerRegex.FindStringSubmatch(commitMessage)\\n    99→\\tif len(matches) > 1 {\\n   100→\\t\\treturn matches[1], true\\n   101→\\t}\\n   102→\\treturn \\\"\\\", false\\n   103→}\\n   104→\\n   105→// ParseCondensation extracts the condensation ID from a commit message.\\n   106→// Returns the condensation ID and true if found, empty string and false otherwise.\\n   107→func ParseCondensation(commitMessage string) (string, bool) {\\n   108→\\tmatches := condensationTrailerRegex.FindStringSubmatch(commitMessage)\\n   109→\\tif len(matches) > 1 {\\n   110→\\t\\treturn strings.TrimSpace(matches[1]), true\\n   111→\\t}\\n   112→\\treturn \\\"\\\", false\\n   113→}\\n   114→\\n   115→// ParseSession extracts the session ID from a commit message.\\n   116→// Returns the session ID and true if found, empty string and false otherwise.\\n   117→// Note: If multiple Entire-Session trailers exist, this returns only the first one.\\n   118→// Use ParseAllSessions to get all session IDs.\\n   119→func ParseSession(commitMessage string) (string, bool) {\\n   120→\\tmatches := sessionTrailerRegex.FindStringSubmatch(commitMessage)\\n   121→\\tif len(matches) > 1 {\\n   122→\\t\\treturn strings.TrimSpace(matches[1]), true\\n   123→\\t}\\n   124→\\treturn \\\"\\\", false\\n   125→}\\n   126→\\n   127→// ParseCheckpoint extracts the checkpoint ID from a commit message.\\n   128→// Returns the CheckpointID and true if found, empty ID and false otherwise.\\n   129→func ParseCheckpoint(commitMessage string) (checkpointID.CheckpointID, bool) {\\n   130→\\tmatches := checkpointTrailerRegex.FindStringSubmatch(commitMessage)\\n   131→\\tif len(matches) > 1 {\\n   132→\\t\\tidStr := strings.TrimSpace(matches[1])\\n   133→\\t\\t// Validate it's a proper checkpoint ID\\n   134→\\t\\tif cpID, err := checkpointID.NewCheckpointID(idStr); err == nil {\\n   135→\\t\\t\\treturn cpID, true\\n   136→\\t\\t}\\n   137→\\t}\\n   138→\\treturn checkpointID.EmptyCheckpointID, false\\n   139→}\\n   140→\\n   141→// ParseAllCheckpoints extracts all checkpoint IDs from a commit message.\\n   142→// Returns a slice of CheckpointIDs (may be empty if none found).\\n   143→// Duplicate IDs are deduplicated while preserving order.\\n   144→// This is useful for squash merge commits that contain multiple Entire-Checkpoint trailers.\\n   145→func ParseAllCheckpoints(commitMessage string) []checkpointID.CheckpointID {\\n   146→\\tmatches := checkpointTrailerRegex.FindAllStringSubmatch(commitMessage, -1)\\n   147→\\tif len(matches) == 0 {\\n   148→\\t\\treturn nil\\n   149→\\t}\\n   150→\\n   151→\\tseen := make(map[string]bool)\\n   152→\\tids := make([]checkpointID.CheckpointID, 0, len(matches))\\n   153→\\tfor _, match := range matches {\\n   154→\\t\\tif len(match) > 1 {\\n   155→\\t\\t\\tidStr := strings.TrimSpace(match[1])\\n   156→\\t\\t\\tif !seen[idStr] {\\n   157→\\t\\t\\t\\tif cpID, err := checkpointID.NewCheckpointID(idStr); err == nil {\\n   158→\\t\\t\\t\\t\\tseen[idStr] = true\\n   159→\\t\\t\\t\\t\\tids = append(ids, cpID)\\n   160→\\t\\t\\t\\t}\\n   161→\\t\\t\\t}\\n   162→\\t\\t}\\n   163→\\t}\\n   164→\\treturn ids\\n   165→}\\n   166→\\n   167→// ParseAllSessions extracts all session IDs from a commit message.\\n   168→// Returns a slice of session IDs (may be empty if none found).\\n   169→// Duplicate session IDs are deduplicated while preserving order.\\n   170→// This is useful for commits that may have multiple Entire-Session trailers.\\n   171→func ParseAllSessions(commitMessage string) []string {\\n   172→\\tmatches := sessionTrailerRegex.FindAllStringSubmatch(commitMessage, -1)\\n   173→\\tif len(matches) == 0 {\\n   174→\\t\\treturn nil\\n   175→\\t}\\n   176→\\n   177→\\tseen := make(map[string]bool)\\n   178→\\tsessionIDs := make([]string, 0, len(matches))\\n   179→\\tfor _, match := range matches {\\n   180→\\t\\tif len(match) > 1 {\\n   181→\\t\\t\\tsessionID := strings.TrimSpace(match[1])\\n   182→\\t\\t\\tif !seen[sessionID] {\\n   183→\\t\\t\\t\\tseen[sessionID] = true\\n   184→\\t\\t\\t\\tsessionIDs = append(sessionIDs, sessionID)\\n   185→\\t\\t\\t}\\n   186→\\t\\t}\\n   187→\\t}\\n   188→\\treturn sessionIDs\\n   189→}\\n   190→\\n   191→// FormatStrategy creates a commit message with just the strategy trailer.\\n   192→func FormatStrategy(message, strategy string) string {\\n   193→\\treturn fmt.Sprintf(\\\"%s\\\\n\\\\n%s: %s\\\\n\\\", message, StrategyTrailerKey, strategy)\\n   194→}\\n   195→\\n   196→// FormatTaskMetadata creates a commit message with task metadata trailer.\\n   197→func FormatTaskMetadata(message, taskMetadataDir string) string {\\n   198→\\treturn fmt.Sprintf(\\\"%s\\\\n\\\\n%s: %s\\\\n\\\", message, MetadataTaskTrailerKey, taskMetadataDir)\\n   199→}\\n   200→\\n   201→// FormatTaskMetadataWithStrategy creates a commit message with task metadata and strategy trailers.\\n   202→func FormatTaskMetadataWithStrategy(message, taskMetadataDir, strategy string) string {\\n   203→\\treturn fmt.Sprintf(\\\"%s\\\\n\\\\n%s: %s\\\\n%s: %s\\\\n\\\", message, MetadataTaskTrailerKey, taskMetadataDir, StrategyTrailerKey, strategy)\\n   204→}\\n   205→\\n   206→// FormatSourceRef creates a formatted source ref string for the trailer.\\n   207→// Format: \\\"<branch>@<commit-hash-prefix>\\\" (hash truncated to ShortIDLength chars)\\n   208→func FormatSourceRef(branch, commitHash string) string {\\n   209→\\tshortHash := commitHash\\n   210→\\tif len(shortHash) > checkpointID.ShortIDLength {\\n   211→\\t\\tshortHash = shortHash[:checkpointID.ShortIDLength]\\n   212→\\t}\\n   213→\\treturn fmt.Sprintf(\\\"%s@%s\\\", branch, shortHash)\\n   214→}\\n   215→\\n   216→// FormatMetadata creates a commit message with metadata trailer.\\n   217→func FormatMetadata(message, metadataDir string) string {\\n   218→\\treturn fmt.Sprintf(\\\"%s\\\\n\\\\n%s: %s\\\\n\\\", message, MetadataTrailerKey, metadataDir)\\n   219→}\\n   220→\\n   221→// FormatMetadataWithStrategy creates a commit message with metadata and strategy trailers.\\n   222→func FormatMetadataWithStrategy(message, metadataDir, strategy string) string {\\n   223→\\treturn fmt.Sprintf(\\\"%s\\\\n\\\\n%s: %s\\\\n%s: %s\\\\n\\\", message, MetadataTrailerKey, metadataDir, StrategyTrailerKey, strategy)\\n   224→}\\n   225→\\n   226→// FormatShadowCommit creates a commit message for manual-commit strategy checkpoints.\\n   227→// Includes Entire-Metadata, Entire-Session, and Entire-Strategy trailers.\\n   228→func FormatShadowCommit(message, metadataDir, sessionID string) string {\\n   229→\\tvar sb strings.Builder\\n   230→\\tsb.WriteString(message)\\n   231→\\tsb.WriteString(\\\"\\\\n\\\\n\\\")\\n   232→\\tfmt.Fprintf(&sb, \\\"%s: %s\\\\n\\\", MetadataTrailerKey, metadataDir)\\n   233→\\tfmt.Fprintf(&sb, \\\"%s: %s\\\\n\\\", SessionTrailerKey, sessionID)\\n   234→\\tfmt.Fprintf(&sb, \\\"%s: %s\\\\n\\\", StrategyTrailerKey, \\\"manual-commit\\\")\\n   235→\\treturn sb.String()\\n   236→}\\n   237→\\n   238→// FormatShadowTaskCommit creates a commit message for manual-commit task checkpoints.\\n   239→// Includes Entire-Metadata-Task, Entire-Session, and Entire-Strategy trailers.\\n   240→func FormatShadowTaskCommit(message, taskMetadataDir, sessionID string) string {\\n   241→\\tvar sb strings.Builder\\n   242→\\tsb.WriteString(message)\\n   243→\\tsb.WriteString(\\\"\\\\n\\\\n\\\")\\n   244→\\tfmt.Fprintf(&sb, \\\"%s: %s\\\\n\\\", MetadataTaskTrailerKey, taskMetadataDir)\\n   245→\\tfmt.Fprintf(&sb, \\\"%s: %s\\\\n\\\", SessionTrailerKey, sessionID)\\n   246→\\tfmt.Fprintf(&sb, \\\"%s: %s\\\\n\\\", StrategyTrailerKey, \\\"manual-commit\\\")\\n   247→\\treturn sb.String()\\n   248→}\\n   249→\\n   250→// FormatCheckpoint creates a commit message with a checkpoint trailer.\\n   251→// This links user commits to their checkpoint metadata on entire/checkpoints/v1 branch.\\n   252→func FormatCheckpoint(message string, cpID checkpointID.CheckpointID) string {\\n   253→\\treturn fmt.Sprintf(\\\"%s\\\\n\\\\n%s: %s\\\\n\\\", message, CheckpointTrailerKey, cpID.String())\\n   254→}\\n   255→\"}]},\"uuid\":\"5510b435-0057-4c28-afaf-72fe183d1ca6\",\"timestamp\":\"2026-02-26T23:26:40.988Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"## Code Review Request\\n\\n**What was implemented:** Multi-checkpoint resume support for squash merges. When a squash merge combines multiple commits that each had `Entire-Checkpoint` trailers, the resume command now parses ALL checkpoint IDs from the squash merge commit message and restores sessions from each one.\\n\\n**Plan/Requirements:** \\n- Parse all `Entire-Checkpoint` trailers from a commit (not just the first one)\\n- Support resuming multiple checkpoints in a single `entire resume` operation  \\n- Display restored sessions from each checkpoint clearly\\n- Handle cases where some checkpoints fail to restore gracefully\\n- Support for `branchCheckpointResult` returning multiple checkpoint IDs\\n\\n**Base SHA:** 91f9ab4fb115936efe70f481b4bbb08ca3cc273f (merge-base with main)\\n**HEAD SHA:** 3c80fab2ac08fddbdb5d5b225f7d74024f567b30\\n\\n**Description:** This branch adds multi-checkpoint resume capability. Key changes:\\n\\n1. **New `trailers` package** (`cmd/entire/cli/trailers/`) - `ParseAllCheckpoints()` extracts all `Entire-Checkpoint` trailer values from a commit message\\n2. **`resumeMultipleChe