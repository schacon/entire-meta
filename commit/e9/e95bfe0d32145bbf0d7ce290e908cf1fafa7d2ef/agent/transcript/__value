entire] Backed up existing %s to %s%s\\\\n\\\", spec.name, spec.name, backupSuffix)\\n   195→\\t\\t\\t} else {\\n   196→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: replacing %s (backup %s%s already exists from a previous install)\\\\n\\\", spec.name, spec.name, backupSuffix)\\n   197→\\t\\t\\t}\\n   198→\\t\\t\\tbackupExists = true\\n   199→\\t\\t}\\n   200→\\n   201→\\t\\t// Chain to backup if one exists\\n   202→\\t\\tcontent := spec.content\\n   203→\\t\\tif backupExists {\\n   204→\\t\\t\\tcontent = generateChainedContent(spec.content, spec.name)\\n   205→\\t\\t}\\n   206→\\n   207→\\t\\twritten, err := writeHookFile(hookPath, content)\\n   208→\\t\\tif err != nil {\\n   209→\\t\\t\\treturn installedCount, fmt.Errorf(\\\"failed to install %s hook: %w\\\", spec.name, err)\\n   210→\\t\\t}\\n   211→\\t\\tif written {\\n   212→\\t\\t\\tinstalledCount++\\n   213→\\t\\t}\\n   214→\\t}\\n   215→\\n   216→\\tif !silent {\\n   217→\\t\\tfmt.Println(\\\"✓ Installed git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\\")\\n   218→\\t\\tfmt.Println(\\\"  Hooks delegate to the current strategy at runtime\\\")\\n   219→\\t}\\n   220→\\n   221→\\treturn installedCount, nil\\n   222→}\\n   223→\\n   224→// writeHookFile writes a hook file if it doesn't exist or has different content.\\n   225→// Returns true if the file was written, false if it already had the same content.\\n   226→func writeHookFile(path, content string) (bool, error) {\\n   227→\\t// Check if file already exists with same content\\n   228→\\texisting, err := os.ReadFile(path) //nolint:gosec // path is controlled\\n   229→\\tif err == nil && string(existing) == content {\\n   230→\\t\\treturn false, nil // Already up to date\\n   231→\\t}\\n   232→\\n   233→\\t// Git hooks must be executable (0o755)\\n   234→\\tif err := os.WriteFile(path, []byte(content), 0o755); err != nil { //nolint:gosec // Git hooks require executable permissions\\n   235→\\t\\treturn false, fmt.Errorf(\\\"fa