    1→package claudecode\\n     2→\\n     3→import (\\n     4→\\t\\\"encoding/json\\\"\\n     5→\\t\\\"fmt\\\"\\n     6→\\t\\\"os\\\"\\n     7→\\t\\\"path/filepath\\\"\\n     8→\\t\\\"slices\\\"\\n     9→\\t\\\"strings\\\"\\n    10→\\n    11→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    14→)\\n    15→\\n    16→// Ensure ClaudeCodeAgent implements HookSupport\\n    17→var _ agent.HookSupport = (*ClaudeCodeAgent)(nil)\\n    18→\\n    19→// Claude Code hook names - these become subcommands under `entire hooks claude-code`\\n    20→const (\\n    21→\\tHookNameSessionStart     = \\\"session-start\\\"\\n    22→\\tHookNameSessionEnd       = \\\"session-end\\\"\\n    23→\\tHookNameStop             = \\\"stop\\\"\\n    24→\\tHookNameUserPromptSubmit = \\\"user-prompt-submit\\\"\\n    25→\\tHookNamePreTask          = \\\"pre-task\\\"\\n    26→\\tHookNamePostTask         = \\\"post-task\\\"\\n    27→\\tHookNamePostTodo         = \\\"post-todo\\\"\\n    28→)\\n    29→\\n    30→// ClaudeSettingsFileName is the settings file used by Claude Code.\\n    31→// This is Claude-specific and not shared with other agents.\\n    32→const ClaudeSettingsFileName = \\\"settings.json\\\"\\n    33→\\n    34→// metadataDenyRule blocks Claude from reading Entire session metadata\\n    35→const metadataDenyRule = \\\"Read(./.entire/metadata/**)\\\"\\n    36→\\n    37→// entireHookPrefixes are command prefixes that identify Entire hooks (both old and new formats)\\n    38→var entireHookPrefixes = []string{\\n    39→\\t\\\"entire \\\",\\n    40→\\t\\\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go \\\",\\n    41→}\\n    42→\\n    43→// InstallHooks installs Claude Code hooks in .claude/settings.json.\\n    44→// If force is true, removes existing Entire hooks before installing.\\n    45→// Returns the number of hooks installed.\\n    46→func (c *ClaudeCodeAgent) InstallHooks(localDev bool, force bool) (int, error) {\\n    47→\\t// Use repo root instead of CWD to find .claude directory\\n    48→\\t// This ensures hooks are installed correctly when run from a subdirectory\\n    49→\\trepoRoot, err := paths.RepoRoot()\\n    50→\\tif err != nil {\\n    51→\\t\\t// Fallback to CWD if not in a git repo (e.g., during tests)\\n    52→\\t\\trepoRoot, err = os.Getwd() //nolint:forbidigo // Intentional fallback when RepoRoot() fails (tests run outside git repos)\\n    53→\\t\\tif err != nil {\\n    54→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to get current directory: %w\\\", err)\\n    55→\\t\\t}\\n    56→\\t}\\n    57→\\n    58→\\tsettingsPath := filepath.Join(repoRoot, \\\".claude\\\", ClaudeSettingsFileName)\\n    59→\\n    60→\\t// Read existing settings if they exist\\n    61→\\tvar rawSettings map[string]json.RawMessage\\n    62→\\n    63→\\t// rawHooks preserves unknown hook types (e.g., \\\"Notification\\\", \\\"SubagentStop\\\")\\n    64→\\tvar rawHooks map[string]json.RawMessage\\n    65→\\n    66→\\t// rawPermissions preserves unknown permission fields (e.g., \\\"ask\\\")\\n    67→\\tvar rawPermissions map[string]json.RawMessage\\n    68→\\n    69→\\texistingData, readErr := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from cwd + fixed path\\n    70→\\tif readErr == nil {\\n    71→\\t\\tif err := json.Unmarshal(existingData, &rawSettings); err != nil {\\n    72→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse existing settings.json: %w\\\", err)\\n    73→\\t\\t}\\n    74→\\t\\tif hooksRaw, ok := rawSettings[\\\"hooks\\\"]; ok {\\n    75→\\t\\t\\tif err := json.Unmarshal(hooksRaw, &rawHooks); err != nil {\\n    76→\\t\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse hooks in settings.json: %w\\\", err)\\n    77→\\t\\t\\t}\\n    78→\\t\\t}\\n    79→\\t\\tif permRaw, ok := rawSettings[\\\"permissions\\\"]; ok {\\n    80→\\t\\t\\tif err := json.Unmarshal(permRaw, &rawPermissions); err != nil {\\n    81→\\t\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse permissions in settings.json: %w\\\", err)\\n    82→\\t\\t\\t}\\n    83→\\t\\t}\\n    84→\\t} else {\\n    85→\\t\\trawSettings = make(map[string]json.RawMessage)\\n    86→\\t}\\n    87→\\n    88→\\tif rawHooks == nil {\\n    89→\\t\\trawHooks = make(map[string]json.RawMessage)\\n    90→\\t}\\n    91→\\tif rawPermissions == nil {\\n    92→\\t\\trawPermissions = make(map[string]json.RawMessage)\\n    93→\\t}\\n    94→\\n    95→\\t// Parse only the hook types we need to modify\\n    96→\\tvar sessionStart, sessionEnd, stop, userPromptSubmit, preToolUse, postToolUse []ClaudeHookMatcher\\n    97→\\tparseHookType(rawHooks, \\\"SessionStart\\\", &sessionStart)\\n    98→\\tparseHookType(rawHooks, \\\"SessionEnd\\\", &sessionEnd)\\n    99→\\tparseHookType(rawHooks, \\\"Stop\\\", &stop)\\n   100→\\tparseHookType(rawHooks, \\\"UserPromptSubmit\\\", &userPromptSubmit)\\n   101→\\tparseHookType(rawHooks, \\\"PreToolUse\\\", &preToolUse)\\n   102→\\tparseHookType(rawHooks, \\\"PostToolUse\\\", &postToolUse)\\n   103→\\n   104→\\t// If force is true, remove all existing Entire hooks first\\n   105→\\tif force {\\n   106→\\t\\tsessionStart = removeEntireHooks(sessionStart)\\n   107→\\t\\tsessionEnd = removeEntireHooks(sessionEnd)\\n   108→\\t\\tstop = removeEntireHooks(stop)\\n   109→\\t\\tuserPromptSubmit = removeEntireHooks(userPromptSubmit)\\n   110→\\t\\tpreToolUse = removeEntireHooksFromMatchers(preToolUse)\\n   111→\\t\\tpostToolUse = removeEntireHooksFromMatchers(postToolUse)\\n   112→\\t}\\n   113→\\n   114→\\t// Define hook commands\\n   115→\\tvar sessionStartCmd, sessionEndCmd, stopCmd, userPromptSubmitCmd, preTaskCmd, postTaskCmd, postTodoCmd string\\n   116→\\tif localDev {\\n   117→\\t\\tsessionStartCmd = \\\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code session-start\\\"\\n   118→\\t\\tsessionEndCmd = \\\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code session-end\\\"\\