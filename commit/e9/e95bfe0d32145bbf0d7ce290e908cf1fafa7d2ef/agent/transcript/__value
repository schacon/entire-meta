t\\n    18→//   - Transcript Storage (3 methods): ReadTranscript, ChunkTranscript, ReassembleTranscript\\n    19→//   - Legacy (8 methods): Will be moved to optional interfaces or removed in a future phase\\n    20→type Agent interface {\\n    21→\\t// --- Identity ---\\n    22→\\n    23→\\t// Name returns the agent registry key (e.g., \\\"claude-code\\\", \\\"gemini\\\")\\n    24→\\tName() AgentName\\n    25→\\n    26→\\t// Type returns the agent type identifier (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\")\\n    27→\\t// This is stored in metadata and trailers.\\n    28→\\tType() AgentType\\n    29→\\n    30→\\t// Description returns a human-readable description for UI\\n    31→\\tDescription() string\\n    32→\\n    33→\\t// IsPreview returns whether the agent integration is in preview or stable\\n    34→\\tIsPreview() bool\\n    35→\\n    36→\\t// DetectPresence checks if this agent is configured in the repository\\n    37→\\tDetectPresence() (bool, error)\\n    38→\\n    39→\\t// ProtectedDirs returns repo-root-relative directories that should never be\\n    40→\\t// modified or deleted during rewind or other destructive operations.\\n    41→\\t// Examples: [\\\".claude\\\"] for Claude, [\\\".gemini\\\"] for Gemini.\\n    42→\\tProtectedDirs() []string\\n    43→\\n    44→\\t// --- Event Mapping ---\\n    45→\\n    46→\\t// HookNames returns the hook verbs this agent supports.\\n    47→\\t// These become subcommands under `entire hooks <agent>`.\\n    48→\\t// e.g., [\\\"stop\\\", \\\"user-prompt-submit\\\", \\\"session-start\\\", \\\"session-end\\\"]\\n    49→\\tHookNames() []string\\n    50→\\n    51→\\t// ParseHookEvent translates an agent-native hook into a normalized lifecycle Event.\\n    52→\\t// Returns nil if the hook has no lifecycle significance (e.g., pass-through hooks).\\n    53→\\t// This is the core contribution surface for new agent implementations.\\n    54→\\tParseHookEvent(hookName string, stdin io.Reader) (*Event, error)\\n    55→\\n    56→\\t// --- Transcript Storage ---\\n    57→\\n    58→\\t// ReadTranscript reads the raw transcript bytes for a session.\\n    59→\\tReadTranscript(sessionRef string) ([]byte, error)\\n    60→\\n    61→\\t// ChunkTranscript splits a transcript into chunks if it exceeds maxSize.\\n    62→\\t// Returns a slice of chunks. If the transcript fits in one chunk, returns single-element slice.\\n    63→\\t// The chunking is format-aware: JSONL splits at line boundaries, JSON splits message arrays.\\n    64→\\tChunkTranscript(content []byte, maxSize int) ([][]byte, error)\\n    65→\\n    66→\\t// ReassembleTranscript combines chunks back into a single transcript.\\n    67→\\t// Handles format-specific reassembly (JSONL concatenation, JSON message merging).\\n    68→\\tReassembleTranscript(chunks [][]byte) ([]byte, error)\\n    69→\\n    70→\\t// --- Legacy methods (will move to optional interfaces in Phase 4) ---\\n    71→\\n    72→\\t// GetSessionID extracts session ID from hook input.\\n    73→\\tGetSessionID(input *HookInput) string\\n    74→\\n    75→\\t// GetSessionDir returns where agent stores session data for this repo.\\n    76→\\tGetSessionDir(repoPath string) (string, error)\\n    77→\\n    78→\\t// ResolveSessionFile returns the path to the session transcript file.\\n    79→\\tResolveSessionFile(sessionDir, agentSessionID string) string\\n    80→\\n    81→\\t// ReadSession reads session data from agent's storage.\\n    82→\\tReadSession(input *HookInput) (*AgentSession, error)\\n    83→\\n    84→\\t// WriteSession writes session data for resumption.\\n    85→\\tWriteSession(session *AgentSession) error\\n    86→\\n    87→\\t// FormatResumeCommand returns command to resume a session.\\n    88→\\tFormatResumeCommand(sessionID string) string\\n    89→}\\n    90→\\n    91→// HookSupport is implemented by agents with lifecycle hooks.\\n    92→// This optional interface allows agents like Claude Code and Cursor to\\n    93→// install and manage hooks that notify Entire of agent events.\\n    94→type HookSupport interface {\\n    95→\\tAgent\\n    96→\\n    97→\\t// InstallHooks installs agent-specific hooks.\\n    98→\\t// If localDev is true, hooks point to local development build.\\n    99→\\t// If force is true, removes existing Entire hooks before installing.\\n   100→\\t// Returns the number of hooks installed.\\n   101→\\tInstallHooks(localDev bool, force bool) (int, error)\\n   102→\\n   103→\\t// UninstallHooks removes installed hooks\\n   104→\\tUninstallHooks() error\\n   105→\\n   106→\\t// AreHooksInstalled checks if hooks are currently installed\\n   107→\\tAreHooksInstalled() bool\\n   108→}\\n   109→\\n   110→// FileWatcher is implemented by agents that use file-based detection.\\n   111→// Agents like Aider that don't support hooks can use file watching\\n   112→// to detect session activity.\\n   113→type FileWatcher interface {\\n   114→\\tAgent\\n   115→\\n   116→\\t// GetWatchPaths returns paths to watch for session changes\\n   117→\\tGetWatchPaths() ([]string, error)\\n   118→\\n   119→\\t// OnFileChange handles a detected file change and returns session info\\n   120→\\tOnFileChange(path string) (*SessionChange, error)\\n   121→}\\n   122→\\n   123→// TranscriptAnalyzer provides format-specific transcript parsing.\\n   124→// Agents that implement this get richer checkpoints (transcript-derived file lists,\\n   125→// prompts, summaries). Agents that don't still participate in the checkpoint lifecycle\\n   126→// via git-status-based file detection and raw transcript storage.\\n   127→type TranscriptAnalyzer interface {\\n   128→\\tAgent\\n   129→\\n   130→\\t// GetTranscriptPosition returns the current position (length) of a transcript.\\n   131→\\t// For JSONL formats (Claude Code), this is the line count.\\n   132→\\t// For JSON formats (Gemini CLI), this is the message count.\\n   133→\\t// Returns 0 if the file doesn't exist or is empty.\\n   134→\\tGetTranscriptPosition(path string) (int, error)\\n   135→\\n   136→\\t// ExtractModifiedFilesFromOffset extracts files modified since a given offset.\\n   137→\\t// For JSONL formats (Claude Code), offset is the starting line number.\\n   138→\\t// For JSON formats (Gemini CLI), offset is the starting message index.\\n   139→\\t// Returns:\\n   140→\\t//   - files: list of file paths modified by the agent (from Write/Edit tools)\\n   141→\\t//   - currentPosition: the current position (line count or message count)\\n   142→\\t//   - error: any error encountered during reading\\n   143→\\tExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error)\\n   144→\\n   145→\\t// ExtractPrompts extracts user prompts from the transcript starting at the given offset.\\n   146→\\tExtractPrompts(sessionRef string, fromOffset int) ([]string, error)\\n   147→\\n   148→\\t// ExtractSummary extracts a summary of the session from the transcript.\\n   149→\\tExtractSummary(sessionRef string) (string, error)\\n   150→}\\n   151→\\n   152→// TranscriptPreparer is called before ReadTranscript to handle agent-specific\\n   153→// flush/sync requirements (e.g., Claude Code's async transcript writing).\\n   154→// The framework calls PrepareTranscript before ReadTranscript if implemented.\\n   155→type TranscriptPreparer interface {\\n   156→\\tAgent\\n   157→\\n   158→\\t// PrepareTranscript ensures the transcript is ready to read.\\n   159→\\t// For Claude Code, this waits for the async transcript flush to complete.\\n   160→\\tPrepareTranscript(sessionRef string) error\\n   161→}\\n   162→\\n   163→// TokenCalculator provides token usage calculation for a session.\\n   164→// The framework calls this during step save and checkpoint if implemented.\\n   165→type TokenCalculator interface {\\n   166→\\tAgent\\n   167→\\n   168→\\t// CalculateTokenUsage computes token usage from the transcript starting at the given offset.\\n   169→\\tCalculateTokenUsage(sessionRef string, fromOffset int) (*TokenUsage, error)\\n   170→}\\n   171→\\n   172→// SubagentAwareExtractor provides methods for extracting files and tokens including subagents.\\n   173→// Agents that support spawning subagents (like Claude Code's Task tool) should implement this\\n   174→// to ensure subagent contributions are included in checkpoints.\\n   175→type SubagentAwareExtractor interface {\\n   176→\\tAgent\\n   177→\\n   178→\\t// ExtractAllModifiedFiles extracts files modified by both the main agent and any spawned subagents.\\n   179→\\t// The subagentsDir parameter specifies where subagent transcripts are stored.\\n   180→\\t// Returns a deduplicated list of all modified file paths.\\n   181→\\tExtractAllModifiedFiles(sessionRef string, fromOffset int, subagentsDir string) ([]string, error)\\n   182→\\n   183→\\t// CalculateTotalTokenUsage computes token usage including all spawned subagents.\\n   184→\\t// The subagentsDir parameter specifies where subagent transcripts are stored.\\n   185→\\tCalculateTotalTokenUsage(sessionRef string, fromOffset int, subagentsDir string) (*TokenUsage, error)\\n   186→}\\n   187→\"}]},\"uuid\":\"51d2bc89-0a7d-46f0-800e-7c759bd3d5aa\",\"timestamp\":\"2026-02-20T11:36:51.265Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Investigate the `entire enable` command to understand how agent selection works, specifically:\\n\\n1. How does it determine which agents are pre-selected when showing the selection form?\\n2. How does it persist which agents are enabled/disabled?\\n3. What happens when a user deselects an agent - how are hooks uninstalled?\\n\\nLook at:\\n- The enable command implementation in `cmd/entire/cli/commands/`\\n- Agent detection/discovery code\\n- Settings persistence\\n- Hook installation/uninstallation logic\\n\\nBe very thorough - search for \\\"enable\\\", \\\"agent\\\", \\\"select\\\", \\\"hook\\\", \\\"install\\\", \\\"uninstall\\\" patterns. I need to understand the full flow from showing the selection form to p