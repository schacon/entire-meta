\"strings\\\"\\n    11→\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    16→\\n    17→\\t\\\"github.com/charmbracelet/huh\\\"\\n    18→\\t\\\"github.com/spf13/cobra\\\"\\n    19→\\t\\\"github.com/spf13/pflag\\\"\\n    20→)\\n    21→\\n    22→// Strategy display names for user-friendly selection\\n    23→const (\\n    24→\\tstrategyDisplayManualCommit = \\\"manual-commit\\\"\\n    25→\\tstrategyDisplayAutoCommit   = \\\"auto-commit\\\"\\n    26→)\\n    27→\\n    28→// Config path display strings\\n    29→const (\\n    30→\\tconfigDisplayProject = \\\".entire/settings.json\\\"\\n    31→\\tconfigDisplayLocal   = \\\".entire/settings.local.json\\\"\\n    32→)\\n    33→\\n    34→// strategyDisplayToInternal maps user-friendly names to internal strategy names\\n    35→var strategyDisplayToInternal = map[string]string{\\n    36→\\tstrategyDisplayManualCommit: strategy.StrategyNameManualCommit,\\n    37→\\tstrategyDisplayAutoCommit:   strategy.StrategyNameAutoCommit,\\n    38→}\\n    39→\\n    40→// strategyInternalToDisplay maps internal strategy names to user-friendly names\\n    41→var strategyInternalToDisplay = map[string]string{\\n    42→\\tstrategy.StrategyNameManualCommit: strategyDisplayManualCommit,\\n    43→\\tstrategy.StrategyNameAutoCommit:   strategyDisplayAutoCommit,\\n    44→}\\n    45→\\n    46→func newEnableCmd() *cobra.Command {\\n    47→\\tvar localDev bool\\n    48→\\tvar ignoreUntracked bool\\n    49→\\tvar useLocalSettings bool\\n    50→\\tvar useProjectSettings bool\\n    51→\\tvar agentName string\\n    52→\\tvar strategyFlag string\\n    53→\\tvar forceHooks bool\\n    54→\\tvar skipPushSessions bool\\n    55→\\tvar telemetry bool\\n    56→\\n    57→\\tcmd := &cobra.Command{\\n    58→\\t\\tUse:   \\\"enable\\\",\\n    59→\\t\\tShort: \\\"Enable Entire in current project\\\",\\n    60→\\t\\tLong: `Enable Entire with session tracking for your AI agent workflows.\\n    61→\\n    62→Uses the manual-commit strategy by default. To use a different strategy:\\n    63→\\n    64→  entire enable --strategy auto-commit\\n    65→\\n    66→Strategies: manual-commit (default), auto-commit`,\\n    67→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    68→\\t\\t\\t// Check if we're in a git repository first - this is a prerequisite error,\\n    69→\\t\\t\\t// not a usage error, so we silence Cobra's output and use SilentError\\n    70→\\t\\t\\t// to prevent duplicate error output in main.go\\n    71→\\t\\t\\tif _, err := paths.RepoRoot(); err != nil {\\n    72→\\t\\t\\t\\tfmt.Fprintln(cmd.ErrOrStderr(), \\\"Not a git repository. Please run 'entire enable' from within a git repository.\\\")\\n    73→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n    74→\\t\\t\\t}\\n    75→\\n    76→\\t\\t\\tif err := validateSetupFlags(useLocalSettings, useProjectSettings); err != nil {\\n    77→\\t\\t\\t\\treturn err\\n    78→\\t\\t\\t}\\n    79→\\n    80→\\t\\t\\t// Warn if repo has no commits yet\\n    81→\\t\\t\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n    82→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Note: This repository has no commits yet. Entire will be configured, but\\\")\\n    83→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"session checkpoints won't work until you create your first commit.\\\")\\n    84→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout())\\n    85→\\t\\t\\t}\\n    86→\\n    87→\\t\\t\\t// Non-interactive mode if --agent flag is provided\\n    88→\\t\\t\\tif cmd.Flags().Changed(\\\"agent\\\") && agentName == \\\"\\\" {\\n    89→\\t\\t\\t\\tprintMissingAgentError(cmd.ErrOrStderr())\\n    90→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n    91→\\t\\t\\t}\\n    92→\\n    93→\\t\\t\\tif agentName != \\\"\\\" {\\n    94→\\t\\t\\t\\tag, err := agent.Get(agent.AgentName(agentName))\\n    95→\\t\\t\\t\\tif err != nil {\\n    96→\\t\\t\\t\\t\\tprintWrongAgentError(cmd.ErrOrStderr(), agentName)\\n    97→\\t\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"wrong agent name\\\"))\\n    98→\\t\\t\\t\\t}\\n    99→\\t\\t\\t\\t// --agent is a targeted operation: set up this specific agent without\\n   100→\\t\\t\\t\\t// affecting other agents. Unlike the interactive path, it does not\\n   101→\\t\\t\\t\\t// uninstall hooks for other previously-enabled agents.\\n   102→\\t\\t\\t\\treturn setupAgentHooksNonInteractive(cmd.OutOrStdout(), ag, strategyFlag, localDev, forceHooks, skipPushSessions, telemetry)\\n   103→\\t\\t\\t}\\n   104→\\t\\t\\t// Detect or prompt for agents\\n   105→\\t\\t\\tagents, err := detectOrSelectAgent(cmd.OutOrStdout(), nil)\\n   106→\\t\\t\\tif err != nil {\\n   107→\\t\\t\\t\\treturn fmt.Errorf(\\\"agent selection failed: %w\\\", err)\\n   108→\\t\\t\\t}\\n   109→\\n   110→\\t\\t\\tif strategyFlag != \\\"\\\" {\\n   111→\\t\\t\\t\\treturn runEnableWithStrategy(cmd.OutOrStdout(), agents, strategyFlag, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry)\\n   112→\\t\\t\\t}\\n   113→\\t\\t\\treturn runEnableInteractive(cmd.OutOrStdout(), agents, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry)\\n   114→\\t\\t},\\n   115→\\t}\\n   116→\\n   117→\\tcmd.Flags().BoolVar(&localDev, \\\"local-dev\\\", false, \\\"Use go run instead of entire binary for hooks\\\")\\n   118→\\tcmd.Flags().MarkHidden(\\\"local-dev\\\") //nolint:errcheck,gosec // flag is defined above\\n   119→\\tcmd.Flags().BoolVar(&ignoreUntracked, \\\"ignore-untracked\\\", false, \\\"Commit all new files without tracking pre-existing untracked files\\\")\\n   120→\\tcmd.Flags().MarkHidden(\\\"ignore-untracked\\\") //nolint:errcheck,gosec // flag is defined above\\n   121→\\tcmd.Flags().BoolVar(&useLocalSettings, \\\"local\\\", false, \\\"Write settings to .entire/settings.local.json instead of .entire/settings.json\\\")\\n   122→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Write settings to .entire/settings.json even if it already exists\\\")\\n   123→\\tcmd.Flags().StringVar(&agentName, \\\"agent\\\", \\\"\\\", \\\"Agent to setup hooks for (e.g., claude-code). Enables non-interactive mode.\\\")\\n   124→\\tcmd.Flags().StringVar(&strategyFlag, \\\"strategy\\\", \\\"\\\", \\\"Strategy to use (manual-commit or auto-commit)\\\")\\n   125→\\tcmd.Flags().BoolVarP(&forceHooks, \\\"force\\\", \\\"f\\\", false, \\\"Force reinstall hooks (removes existing Entire hooks first)\\\")\\n   126→\\tcmd.Flags().BoolVar(&skipPushSessions, \\\"skip-push-sessions\\\", false, \\\"Disable automatic pushing of session logs on git push\\\")\\n   127→\\tcmd.Flags().BoolVar(&telemetry, \\\"telemetry\\\", true, \\\"Enable anonymous usage analytics\\\")\\n   128→\\t//nolint:errcheck,gosec // completion is optional, flag is defined above\\n   129→\\tcmd.RegisterFlagCompletionFunc(\\\"strategy\\\", func(_ *cobra.Command, _ []string, _ string) ([]string, cobra.ShellCompDirective) {\\n   130→\\t\\treturn []string{strategyDisplayManualCommit, strategyDisplayAutoCommit}, cobra.ShellCompDirectiveNoFileComp\\n   131→\\t})\\n   132→\\n   133→\\t// Provide a helpful error when --agent is used without a value\\n   134→\\tdefaultFlagErr := cmd.FlagErrorFunc()\\n   135→\\tcmd.SetFlagErrorFunc(func(c *cobra.Command, err error) error {\\n   136→\\t\\tvar valErr *pflag.ValueRequiredError\\n   137→\\t\\tif errors.As(err, &valErr) && valErr.GetSpecifiedName() == \\\"agent\\\" {\\n   138→\\t\\t\\tprintMissingAgentError(c.ErrOrStderr())\\n   139→\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n   140→\\t\\t}\\n   141→\\t\\treturn defaultFlagErr(c, err)\\n   142→\\t})\\n   143→\\n   144→\\t// Add subcommands for automation/testing\\n   145→\\tcmd.AddCommand(newSetupGitHookCmd())\\n   146→\\n   147→\\treturn cmd\\n   148→}\\n   149→\\n   150→func newDisableCmd() *cobra.Command {\\n   151→\\tvar useProjectSettings bool\\n   152→\\tvar uninstall bool\\n   153→\\tvar force bool\\n   154→\\n   155→\\tcmd := &cobra.Command{\\n   156→\\t\\tUse:   \\\"disable\\\",\\n   157→\\t\\tShort: \\\"Disable Entire in current project\\\",\\n   158→\\t\\tLong: `Disable Entire integrations in the current project.\\n   159→\\n   160→By default, this command will disable Entire. Hooks will exit silently and commands will\\n   161→show a disabled message.\\n   162→\\n   163→To completely remove Entire integrations from this repository, use --uninstall:\\n   164→  - .entire/ directory (settings, logs, metadata)\\n   165→  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\n   166→  - Session state files (.git/entire-sessions/)\\n   167→  - Shadow branches (entire/<hash>)\\n   168→  - Agent hooks (Claude Code, Gemini CLI, OpenCode)`,\\n   169→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   170→\\t\\t\\tif uninstall {\\n   171→\\t\\t\\t\\treturn runUninstall(cmd.OutOrStdout(), cmd.ErrOrStderr(), force)\\n   172→\\t\\t\\t}\\n   173→\\t\\t\\treturn runDisable(cmd.OutOrStdout(), useProjectSettings)\\n   174→\\t\\t},\\n   175→\\t}\\n   176→\\n   177→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Update .entire/settings.json instead of .entire/settings.local.json\\\")\\n   178→\\tcmd.Flags().BoolVar(&uninstall, \\\"uninstall\\\", false, \\\"Completely remove Entire from this repository\\\")\\n   179→\\tcmd.Flags().BoolVar(&force, \\\"force\\\", false, \\\"Skip confirmation prompt (use with --uninstall)\\\")\\n   180→\\n   181→\\treturn cmd\\n   182→}\\n   183→\\n   184→// runEnableWithStrategy enables Entire with a specified strategy (non-interactive).\\n   185→// The selectedStrategy can be either a display name (manual-commit, auto-commit)\\n   186→// or an internal name (manual-commit, auto-commit).\\n   187→// agents must be provided by the caller (via detectOrSelectAgent).\\n   188→func runEnableWithStrategy(w io.Writer, agents []agent.Agent, selectedStrategy string, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry bool) error {\\n   189→\\t// Map the strategy to internal name if it's a display name\\n   190→\\tinternalStrategy := selectedStrategy\\n   191→\\tif mapped, ok := strategyDisplayToInternal[selectedStrategy]; ok {\\n   192→\\t\\tinternalStrategy = mapped\\n   193→\\t}\\n   194→\\n   195→\\t// Validate the strategy exists\\n   196→\\tstrat, err := strategy.Get(internalStrategy)\\n   197→\\tif err != nil {\\n   198→\\t\\treturn fmt.Errorf(\\\"unknown strategy: %s (use manual-commit or auto-commit)\\\", selectedStrategy)\\n   199→\\t}\\n   200→\\n   201→\\t// Uninstall hooks for agents that were previously active but are no longer selected\\n   202→\\tif err := uninstallDeselectedAgentHooks(w, agents); err != nil {\\n   203→\\t\\treturn fmt.Errorf(\\\"failed to clean up deselected agents: %w\\\", err)\\n   204→\\t}\\n   205→\\n   206→\\t// Setup agent hooks for all selected agents\\n   207→\\tfor _, ag := range agents {\\n   208→\\t\\tif _, err := setupAgentHooks(ag, localDev, forceHooks); err != nil {\\n   209→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   210→\\t\\t}\\n   211→\\t}\\n   212→\\n   213→\\t// Setup .entire directory\\n   214→\\tif _, err := setupEntireDirectory(); err != nil {\\n   215→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   216→\\t}\\n   217→\\n   218→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   219→\\tsettings, err := LoadEntireSettings()\\n   220→\\tif err != nil {\\n   221→\\t\\t// If we can't load, start with defaults\\n   222→\\t\\tsettings = &EntireSettings{}\\n   223→\\t}\\n   224→\\t// Update the specific fields\\n   225→\\tsettings.Strategy = internalStrategy\\n   226→\\tsettings.LocalDev = localDev\\n   227→\\tsettings.Enabled = true\\n   228→\\n   229→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   230→\\tif skipPushSessions {\\n   231→\\t\\tif settings.StrategyOptions == nil {\\n   232→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   233→\\t\\t}\\n   234→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   235→\\t}\\n   236→\\n   237→\\t// Handle telemetry for non-interactive mode\\n   238→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   239→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   240→\\t\\tf := false\\n   241→\\t\\tsettings.Telemetry = &f\\n   242→\\t}\\n   243→\\n   244→\\t// Determine which settings file to write to\\n   245→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   246→\\tif err != nil {\\n   247→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   248→\\t}\\n   249→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   250→\\n   251→\\tif showNotification {\\n   252→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   253→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   254→\\t}\\n   255→\\n   256→\\tconfigDisplay := configDisplayProject\\n   257→\\tif shouldUseLocal {\\n   258→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   259→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   260→\\t\\t}\\n   261→\\t\\tconfigDisplay = configDisplayLocal\\n   262→\\t} else {\\n   263→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   264→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   265→\\t\\t}\\n   266→\\t}\\n   267→\\n   268→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   269→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   270→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   271→\\t}\\n   272→\\tstrategy.CheckAndWarnHookManagers(w)\\n   273→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   274→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   275→\\n   276→\\t// Let the strategy handle its own setup requirements\\n   277→\\tif err := strat.EnsureSetup(); err != nil {\\n   278→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   279→\\t}\\n   280→\\n   281→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   282→\\n   283→\\treturn nil\\n   284→}\\n   285→\\n   286→// runEnableInteractive runs the interactive enable flow.\\n   287→// agents must be provided by the caller (via detectOrSelectAgent).\\n   288→func runEnableInteractive(w io.Writer, agents []agent.Agent, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry bool) error {\\n   289→\\t// Uninstall hooks for agents that were previously active but are no longer selected\\n   290→\\tif err := uninstallDeselectedAgentHooks(w, agents); err != nil {\\n   291→\\t\\treturn fmt.Errorf(\\\"failed to clean up deselected agents: %w\\\", err)\\n   292→\\t}\\n   293→\\n   294→\\t// Setup agent hooks for all selected agents\\n   295→\\tfor _, ag := range agents {\\n   296→\\t\\tif _, err := setupAgentHooks(ag, localDev, forceHooks); err != nil {\\n   297→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   298→\\t\\t}\\n   299→\\t}\\n   300→\\n   301→\\t// Setup .entire directory\\n   302→\\tif _, err := setupEntireDirectory(); err != nil {\\n   303→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   304→\\t}\\n   305→\\n   306→\\t// Use the default strategy (manual-commit)\\n   307→\\tinternalStrategy := strategy.DefaultStrategyName\\n   308→\\n   309→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   310→\\tsettings, err := LoadEntireSettings()\\n   311→\\tif err != nil {\\n   312→\\t\\t// If we can't load, start with defaults\\n   313→\\t\\tsettings = &EntireSettings{}\\n   314→\\t}\\n   315→\\t// Update the specific fields\\n   316→\\tsettings.Strategy = internalStrategy\\n   317→\\tsettings.LocalDev = localDev\\n   318→\\tsettings.Enabled = true\\n   319→\\n   320→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   321→\\tif skipPushSessions {\\n   322→\\t\\tif settings.StrategyOptions == nil {\\n   323→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   324→\\t\\t}\\n   325→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   326→\\t}\\n   327→\\n   328→\\t// Determine which settings file to write to\\n   329→\\t// First run always creates settings.json (no prompt)\\n   330→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   331→\\tif err != nil {\\n   332→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   333→\\t}\\n   334→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   335→\\n   336→\\tif showNotification {\\n   337→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   338→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   339→\\t}\\n   340→\\n   341→\\t// Helper to save settings to the appropriate file\\n   342→\\tsaveSettings := func() error {\\n   343→\\t\\tif shouldUseLocal {\\n   344→\\t\\t\\treturn SaveEntireSettingsLocal(settings)\\n   345→\\t\\t}\\n   346→\\t\\treturn SaveEntireSettings(settings)\\n   347→\\t}\\n   348→\\n   349→\\t// Save settings before telemetry prompt so config is persisted even if the user cancels\\n   350→\\tif err := saveSettings(); err != nil {\\n   351→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   352→\\t}\\n   353→\\n   354→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   355→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   356→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   357→\\t}\\n   358→\\tstrategy.CheckAndWarnHookManagers(w)\\n   359→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   360→\\n   361→\\tconfigDisplay := configDisplayProject\\n   362→\\tif shouldUseLocal {\\n   363→\\t\\tconfigDisplay = configDisplayLocal\\n   364→\\t}\\n   365→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   366→\\n   367→\\t// Ask about telemetry consent (only if not already asked)\\n   368→\\tfmt.Fprintln(w)\\n   369→\\tif err := promptTelemetryConsent(settings, telemetry); err != nil {\\n   370→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   371→\\t}\\n   372→\\t// Save again to persist telemetry choice\\n   373→\\tif err := saveSettings(); err != nil {\\n   374→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   375→\\t}\\n   376→\\n   377→\\t// Let the strategy handle its own setup requirements\\n   378→\\tstrat, err := strategy.Get(internalStrategy)\\n   379→\\tif err != nil {\\n   380→\\t\\treturn fmt.Errorf(\\\"failed to get strategy: %w\\\", err)\\n   381→\\t}\\n   382→\\tif err := strat.EnsureSetup(); err != nil {\\n   383→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   384→\\t}\\n   385→\\n   386→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   387→\\n   388→\\treturn nil\\n   389→}\\n   390→\\n   391→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   392→func runEnable(w io.Writer) error {\\n   393→\\tsettings, err := LoadEntireSettings()\\n   394→\\tif err != nil {\\n   395→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   396→\\t}\\n   397→\\n   398→\\tsettings.Enabled = true\\n   399→\\tif err := SaveEntireSettings(settings); err != nil {\\n   400→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   401→\\t}\\n   402→\\n   403→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   404→\\treturn nil\\n   405→}\\n   406→\\n   407→func runDisable(w io.Writer, useProjectSettings bool) error {\\n   408→\\tsettings, err := LoadEntireSettings()\\n   409→\\tif err != nil {\\n   410→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   411→\\t}\\n   412→\\n   413→\\tsettings.Enabled = false\\n   414→\\n   415→\\t// If --project flag is specified, always write to project settings\\n   416→\\tif useProjectSettings {\\n   417→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   418→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   419→\\t\\t}\\n   420→\\t} else {\\n   421→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   422→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   423→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   424→\\t\\t}\\n   425→\\t}\\n   426→\\n   427→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   428→\\treturn nil\\n   429→}\\n   430→\\n   431→// DisabledMessage is the message shown when Entire is disabled\\n   432→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   433→\\n   434→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   435→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   436→// On error reading settings, defaults to enabled (returns false).\\n   437→func checkDisabledGuard(w io.Writer) bool {\\n   438→\\tenabled, err := IsEnabled()\\n   439→\\tif err != nil {\\n   440→\\t\\t// Default to enabled on error\\n   441→\\t\\treturn false\\n   442→\\t}\\n   443→\\tif !enabled {\\n   444→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   445→\\t\\treturn true\\n   446→\\t}\\n   447→\\treturn false\\n   448→}\\n   449→\\n   450→// uninstallDeselectedAgentHooks removes hooks for agents that were previously\\n   451→// installed but are not in the selected list. This handles the case where a user\\n   452→// re-runs `entire enable` and deselects an agent.\\n   453→func uninstallDeselectedAgentHooks(w io.Writer, selectedAgents []agent.Agent) error {\\n   454→\\tinstalledNames := GetAgentsWithHooksInstalled()\\n   455→\\tif len(installedNames) == 0 {\\n   456→\\t\\treturn nil\\n   457→\\t}\\n   458→\\n   459→\\tselectedSet := make(map[agent.AgentName]struct{}, len(selectedAgents))\\n   460→\\tfor _, ag := range selectedAgents {\\n   461→\\t\\tselectedSet[ag.Name()] = struct{}{}\\n   462→\\t}\\n   463→\\n   464→\\tvar errs []error\\n   465→\\tfor _, name := range installedNames {\\n   466→\\t\\tif _, selected := selectedSet[name]; selected {\\n   467→\\t\\t\\tcontinue\\n   468→\\t\\t}\\n   469→\\t\\tag, err := agent.Get(name)\\n   470→\\t\\tif err != nil {\\n   471→\\t\\t\\tcontinue\\n   472→\\t\\t}\\n   473→\\t\\thookAgent, ok := ag.(agent.HookSupport)\\n   474→\\t\\tif !ok {\\n   475→\\t\\t\\tcontinue\\n   476→\\t\\t}\\n   477→\\t\\tif err := hookAgent.UninstallHooks(); err != nil {\\n   478→\\t\\t\\terrs = append(errs, fmt.Errorf(\\\"failed to uninstall %s hooks: %w\\\", ag.Type(), err))\\n   479→\\t\\t} else {\\n   480→\\t\\t\\tfmt.Fprintf(w, \\\"Removed %s hooks\\\\n\\\", ag.Type())\\n   481→\\t\\t}\\n   482→\\t}\\n   483→\\treturn errors.Join(errs...)\\n   484→}\\n   485→\\n   486→// setupAgentHooks sets up hooks for a given agent.\\n   487→// Returns the number of hooks installed (0 if already installed).\\n   488→func setupAgentHooks(ag agent.Agent, localDev, forceHooks bool) (int, error) { //nolint:unparam // return value used by setupAgentHooksNonInteractive\\n   489→\\thookAgent, ok := ag.(agent.HookSupport)\\n   490→\\tif !ok {\\n   491→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   492→\\t}\\n   493→\\n   494→\\tcount, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   495→\\tif err != nil {\\n   496→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   497→\\t}\\n   498→\\n   499→\\treturn count, nil\\n   500→}\\n   501→\\n   502→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   503→// Returns the detected/selected agents and any error.\\n   504→//\\n   505→// On first run (no hooks installed):\\n   506→//   - Single detected agent: used automatically\\n   507→//   - Multiple/no detected agents: interactive multi-select prompt\\n   508→//\\n   509→// On re-run (hooks already installed):\\n   510→//   - Always shows the interactive multi-select\\n   511→//   - Pre-selects agents that have hooks installed + any newly detected agents\\n   512→//\\n   513→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   514→// It receives available agent names and returns the selected names.\\n   515→func detectOrSelectAgent(w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   516→\\t// Check for agents with hooks already installed (re-run detection)\\n   517→\\tinstalledAgentNames := GetAgentsWithHooksInstalled()\\n   518→\\thasInstalledHooks := len(installedAgentNames) > 0\\n   519→\\n   520→\\t// Try auto-detection\\n   521→\\tdetected := agent.DetectAll()\\n   522→\\n   523→\\t// First run: use existing auto-detect shortcuts\\n   524→\\tif !hasInstalledHooks {\\n   525→\\t\\tswitch {\\n   526→\\t\\tcase len(detected) == 1:\\n   527→\\t\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   528→\\t\\t\\treturn detected, nil\\n   529→\\n   530→\\t\\tcase len(detected) > 1:\\n   531→\\t\\t\\tagentTypes := make([]string, 0, len(detected))\\n   532→\\t\\t\\tfor _, ag := range detected {\\n   533→\\t\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   534→\\t\\t\\t}\\n   535→\\t\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   536→\\t\\t\\tfmt.Fprintln(w)\\n   537→\\t\\t}\\n   538→\\t}\\n   539→\\n   540→\\t// Check if we can prompt interactively\\n   541→\\tif !canPromptInteractively() {\\n   542→\\t\\tif hasInstalledHooks {\\n   543→\\t\\t\\t// Re-run without TTY — keep currently installed agents\\n   544→\\t\\t\\tagents := make([]agent.Agent, 0, len(installedAgentNames))\\n   545→\\t\\t\\tfor _, name := range installedAgentNames {\\n   546→\\t\\t\\t\\tag, err := agent.Get(name)\\n   547→\\t\\t\\t\\tif err != nil {\\n   548→\\t\\t\\t\\t\\tcontinue\\n   549→\\t\\t\\t\\t}\\n   550→\\t\\t\\t\\tagents = append(agents, ag)\\n   551→\\t\\t\\t}\\n   552→\\t\\t\\treturn agents, nil\\n   553→\\t\\t}\\n   554→\\t\\tif len(detected) > 0 {\\n   555→\\t\\t\\treturn detected, nil\\n   556→\\t\\t}\\n   557→\\t\\tdefaultAgent := agent.Default()\\n   558→\\t\\tif defaultAgent == nil {\\n   559→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   560→\\t\\t}\\n   561→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   562→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   563→\\t}\\n   564→\\n   565→\\tif !hasInstalledHooks && len(detected) == 0 {\\n   566→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., .claude or .gemini directory).\\\")\\n   567→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   568→\\t\\tfmt.Fprintln(w)\\n   569→\\t}\\n   570→\\n   571→\\t// Build pre-selection set: installed agents (always) + detected agents\\n   572→\\tpreSelectedSet := make(map[agent.AgentName]struct{})\\n   573→\\tfor _, name := range installedAgentNames {\\n   574→\\t\\tpreSelectedSet[name] = struct{}{}\\n   575→\\t}\\n   576→\\tfor _, ag := range detected {\\n   577→\\t\\tpreSelectedSet[ag.Name()] = struct{}{}\\n   578→\\t}\\n   579→\\n   580→\\t// Build options from registered agents\\n   581→\\tagentNames := agent.List()\\n   582→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   583→\\tfor _, name := range agentNames {\\n   584→\\t\\tag, err := agent.Get(name)\\n   585→\\t\\tif err != nil {\\n   586→\\t\\t\\tcontinue\\n   587→\\t\\t}\\n   588→\\t\\t// Only show agents that support hooks\\n   589→\\t\\tif _, ok := ag.(agent.HookSupport); !ok {\\n   590→\\t\\t\\tcontinue\\n   591→\\t\\t}\\n   592→\\t\\tlabel := string(ag.Type())\\n   593→\\t\\tif name == agent.DefaultAgentName {\\n   594→\\t\\t\\tlabel += \\\" (default)\\\"\\n   595→\\t\\t}\\n   596→\\t\\topt := huh.NewOption(label, string(name))\\n   597→\\t\\tif _, isPreSelected := preSelectedSet[name]; isPreSelected {\\n   598→\\t\\t\\topt = opt.Selected(true)\\n   599→\\t\\t}\\n   600→\\t\\toptions = append(options, opt)\\n   601→\\t}\\n   602→\\n   603→\\tif len(options) == 0 {\\n   604→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   605→\\t}\\n   606→\\n   607→\\t// Collect available agent names for the selector\\n   608→\\tavailableNames := make([]string, 0, len(options))\\n   609→\\tfor _, opt := range options {\\n   610→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   611→\\t}\\n   612→\\n   613→\\tvar selectedAgentNames []string\\n   614→\\tif selectFn != nil {\\n   615→\\t\\tvar err error\\n   616→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   617→\\t\\tif err != nil {\\n   618→\\t\\t\\treturn nil, err\\n   619→\\t\\t}\\n   620→\\t} else {\\n   621→\\t\\tform := NewAccessibleForm(\\n   622→\\t\\t\\thuh.NewGroup(\\n   623→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   624→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   625→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   626→\\t\\t\\t\\t\\tOptions(options...).\\n   627→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   628→\\t\\t\\t),\\n   629→\\t\\t)\\n   630→\\t\\tif err := form.Run(); err != nil {\\n   631→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   632→\\t\\t}\\n   633→\\t}\\n   634→\\n   635→\\tif len(selectedAgentNames) == 0 {\\n   636→\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   637→\\t}\\n   638→\\n   639→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   640→\\tfor _, name := range selectedAgentNames {\\n   641→\\t\\tselectedAgent, err := agent.Get(agent.AgentName(name))\\n   642→\\t\\tif err != nil {\\n   643→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   644→\\t\\t}\\n   645→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   646→\\t}\\n   647→\\n   648→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   649→\\tfor _, ag := range selectedAgents {\\n   650→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   651→\\t}\\n   652→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   653→\\treturn selectedAgents, nil\\n   654→}\\n   655→\\n   656→// canPromptInteractively checks if we can show interactive prompts.\\n   657→// Returns false when running in CI, tests, or other non-interactive environments.\\n   658→func canPromptInteractively() bool {\\n   659→\\t// Check for test environment\\n   660→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   661→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   662→\\t}\\n   663→\\n   664→\\t// Check if /dev/tty is available\\n   665→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   666→\\tif err != nil {\\n   667→\\t\\treturn false\\n   668→\\t}\\n   669→\\t_ = tty.Close()\\n   670→\\treturn true\\n   671→}\\n   672→\\n   673→// printAgentError writes an error message followed by available agents and usage.\\n   674→func printAgentError(w io.Writer, message string) {\\n   675→\\tagents := agent.List()\\n   676→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   677→\\tfmt.Fprintln(w)\\n   678→\\tfor _, a := range agents {\\n   679→\\t\\tsuffix := \\\"\\\"\\n   680→\\t\\tif a == agent.DefaultAgentName {\\n   681→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   682→\\t\\t}\\n   683→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   684→\\t}\\n   685→\\tfmt.Fprintln(w)\\n   686→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   687→}\\n   688→\\n   689→// printMissingAgentError writes a helpful error listing available agents.\\n   690→func printMissingAgentError(w io.Writer) {\\n   691→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   692→}\\n   693→\\n   694→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   695→func printWrongAgentError(w io.Writer, name string) {\\n   696→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   697→}\\n   698→\\n   699→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   700→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   701→func setupAgentHooksNonInteractive(w io.Writer, ag agent.Agent, strategyName string, localDev, forceHooks, skipPushSessions, telemetry bool) error {\\n   702→\\tagentName := ag.Name()\\n   703→\\t// Check if agent supports hooks\\n   704→\\thookAgent, ok := ag.(agent.HookSupport)\\n   705→\\tif !ok {\\n   706→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   707→\\t}\\n   708→\\n   709→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   710→\\n   711→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   712→\\tinstalledHooks, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   713→\\tif err != nil {\\n   714→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   715→\\t}\\n   716→\\n   717→\\t// Setup .entire directory\\n   718→\\tif _, err := setupEntireDirectory(); err != nil {\\n   719→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   720→\\t}\\n   721→\\n   722→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   723→\\tsettings, err := LoadEntireSettings()\\n   724→\\tif err != nil {\\n   725→\\t\\t// If we can't load, start with defaults\\n   726→\\t\\tsettings = &EntireSettings{Strategy: strategy.DefaultStrategyName}\\n   727→\\t}\\n   728→\\tsettings.Enabled = true\\n   729→\\tif localDev {\\n   730→\\t\\tsettings.LocalDev = localDev\\n   731→\\t}\\n   732→\\n   733→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   734→\\tif skipPushSessions {\\n   735→\\t\\tif settings.StrategyOptions == nil {\\n   736→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   737→\\t\\t}\\n   738→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   739→\\t}\\n   740→\\n   741→\\t// Set strategy if provided\\n   742→\\tif strategyName != \\\"\\\" {\\n   743→\\t\\t// Map display name to internal name if needed\\n   744→\\t\\tinternalStrategy := strategyName\\n   745→\\t\\tif mapped, ok := strategyDisplayToInternal[strategyName]; ok {\\n   746→\\t\\t\\tinternalStrategy = mapped\\n   747→\\t\\t}\\n   748→\\t\\t// Validate the strategy exists\\n   749→\\t\\tif _, err := strategy.Get(internalStrategy); err != nil {\\n   750→\\t\\t\\treturn fmt.Errorf(\\\"unknown strategy: %s (use manual-commit or auto-commit)\\\", strategyName)\\n   751→\\t\\t}\\n   752→\\t\\tsettings.Strategy = internalStrategy\\n   753→\\t}\\n   754→\\n   755→\\t// Handle telemetry for non-interactive mode\\n   756→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   757→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   758→\\t\\tf := false\\n   759→\\t\\tsettings.Telemetry = &f\\n   760→\\t}\\n   761→\\n   762→\\tif err := SaveEntireSettings(settings); err != nil {\\n   763→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   764→\\t}\\n   765→\\n   766→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   767→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   768→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   769→\\t}\\n   770→\\tstrategy.CheckAndWarnHookManagers(w)\\n   771→\\n   772→\\tif installedHooks == 0 {\\n   773→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   774→\\t\\tif ag.IsPreview() {\\n   775→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   776→\\t\\t}\\n   777→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   778→\\t} else {\\n   779→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   780→\\t\\tif ag.IsPreview() {\\n   781→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   782→\\t\\t}\\n   783→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   784→\\t}\\n   785→\\n   786→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   787→\\n   788→\\t// Let the strategy handle its own setup requirements (creates entire/checkpoints/v1 branch, etc.)\\n   789→\\tstrat, err := strategy.Get(settings.Strategy)\\n   790→\\tif err != nil {\\n   791→\\t\\treturn fmt.Errorf(\\\"failed to get strategy: %w\\\", err)\\n   792→\\t}\\n   793→\\tif err := strat.EnsureSetup(); err != nil {\\n   794→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   795→\\t}\\n   796→\\n   797→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   798→\\n   799→\\treturn nil\\n   800→}\\n   801→\\n   802→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   803→func validateSetupFlags(useLocal, useProject bool) error {\\n   804→\\tif useLocal && useProject {\\n   805→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   806→\\t}\\n   807→\\treturn nil\\n   808→}\\n   809→\\n   810→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   811→// - Whether settings.json already exists\\n   812→// - The --local and --project flags\\n   813→// Returns (useLocal, showNotification).\\n   814→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   815→\\t// Explicit --local flag always uses local settings\\n   816→\\tif useLocal {\\n   817→\\t\\treturn true, false\\n   818→\\t}\\n   819→\\n   820→\\t// Explicit --project flag always uses project settings\\n   821→\\tif useProject {\\n   822→\\t\\treturn false, false\\n   823→\\t}\\n   824→\\n   825→\\t// No flags specified - check if settings file exists\\n   826→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   827→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   828→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   829→\\t\\treturn true, true\\n   830→\\t}\\n   831→\\n   832→\\t// Settings file doesn't exist - create it\\n   833→\\treturn false, false\\n   834→}\\n   835→\\n   836→// setupEntireDirectory creates the .entire directory and gitignore.\\n   837→// Returns true if the directory was created, false if it already existed.\\n   838→func setupEntireDirectory() (bool, error) { //nolint:unparam // already present in codebase\\n   839→\\t// Get absolute path for the .entire directory\\n   840→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   841→\\tif err != nil {\\n   842→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   843→\\t}\\n   844→\\n   845→\\t// Check if directory already exists\\n   846→\\tcreated := false\\n   847→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   848→\\t\\tcreated = true\\n   849→\\t}\\n   850→\\n   851→\\t// Create .entire directory\\n   852→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   853→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   854→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   855→\\t}\\n   856→\\n   857→\\t// Create/update .gitignore with all required entries\\n   858→\\tif err := strategy.EnsureEntireGitignore(); err != nil {\\n   859→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   860→\\t}\\n   861→\\n   862→\\treturn created, nil\\n   863→}\\n   864→\\n   865→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   866→func setupGitHook() error {\\n   867→\\t// Use shared implementation from strategy package\\n   868→\\t// The localDev setting is read from settings.json\\n   869→\\t_, err := strategy.InstallGitHook(false) // not silent - show output during setup\\n   870→\\tif err != nil {\\n   871→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   872→\\t}\\n   873→\\tstrategy.CheckAndWarnHookManagers(os.Stderr)\\n   874→\\treturn nil\\n   875→}\\n   876→\\n   877→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   878→func newSetupGitHookCmd() *cobra.Command {\\n   879→\\tcmd := &cobra.Command{\\n   880→\\t\\tUse:    \\\"git-hook\\\",\\n   881→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   882→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   883→\\t\\tRunE: func(_ *cobra.Command, _ []string) error {\\n   884→\\t\\t\\treturn setupGitHook()\\n   885→\\t\\t},\\n   886→\\t}\\n   887→\\n   888→\\treturn cmd\\n   889→}\\n   890→\\n   891→func newCurlBashPostInstallCmd() *cobra.Command {\\n   892→\\treturn &cobra.Command{\\n   893→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   894→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   895→\\t\\tHidden: true,\\n   896→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   897→\\t\\t\\tw := cmd.OutOrStdout()\\n   898→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   899→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   900→\\t\\t\\t}\\n   901→\\t\\t\\treturn nil\\n   902→\\t\\t},\\n   903→\\t}\\n   904→}\\n   905→\\n   906→// shellCompletionComment is the comment preceding the completion line\\n   907→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   908→\\n   909→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   910→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   911→\\n   912→// shellCompletionTarget returns the rc file path and completion lines for the\\n   913→// user's current shell.\\n   914→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   915→\\thome, err := os.UserHomeDir()\\n   916→\\tif err != nil {\\n   917→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   918→\\t}\\n   919→\\n   920→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   921→\\tswitch {\\n   922→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   923→\\t\\treturn \\\"Zsh\\\",\\n   924→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   925→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   926→\\t\\t\\tnil\\n   927→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   928→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   929→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   930→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   931→\\t\\t}\\n   932→\\t\\treturn \\\"Bash\\\",\\n   933→\\t\\t\\tbashRC,\\n   934→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   935→\\t\\t\\tnil\\n   936→\\tcase strings.Contains(shell, \\\"fish\\\"):\\n   937→\\t\\treturn \\\"Fish\\\",\\n   938→\\t\\t\\tfilepath.Join(home, \\\".config\\\", \\\"fish\\\", \\\"config.fish\\\"),\\n   939→\\t\\t\\t\\\"entire completion fish | source\\\",\\n   940→\\t\\t\\tnil\\n   941→\\tdefault:\\n   942→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   943→\\t}\\n   944→}\\n   945→\\n   946→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   947→// Only prompts if completion is not already configured.\\n   948→func promptShellCompletion(w io.Writer) error {\\n   949→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   950→\\tif err != nil {\\n   951→\\t\\tif errors.Is(err, errUnsupportedShell) {\\n   952→\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion not available for your shell. Supported: zsh, bash, fish.\\\\n\\\")\\n   953→\\t\\t\\treturn nil\\n   954→\\t\\t}\\n   955→\\t\\treturn fmt.Errorf(\\\"shell completion: %w\\\", err)\\n   956→\\t}\\n   957→\\n   958→\\tif isCompletionConfigured(rcFile) {\\n   959→\\t\\tfmt.Fprintf(w, \\\"✓ Shell completion already configured in %s\\\\n\\\", rcFile)\\n   960→\\t\\treturn nil\\n   961→\\t}\\n   962→\\n   963→\\tvar selected string\\n   964→\\tform := NewAccessibleForm(\\n   965→\\t\\thuh.NewGroup(\\n   966→\\t\\t\\thuh.NewSelect[string]().\\n   967→\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Enable shell completion? (detected: %s)\\\", shellName)).\\n   968→\\t\\t\\t\\tOptions(\\n   969→\\t\\t\\t\\t\\thuh.NewOption(\\\"Yes\\\", \\\"yes\\\"),\\n   970→\\t\\t\\t\\t\\thuh.NewOption(\\\"No\\\", \\\"no\\\"),\\n   971→\\t\\t\\t\\t).\\n   972→\\t\\t\\t\\tValue(&selected),\\n   973→\\t\\t),\\n   974→\\t)\\n   975→\\n   976→\\tif err := form.Run(); err != nil {\\n   977→\\t\\t//nolint:nilerr // User cancelled - not a fatal error, just skip\\n   978→\\t\\treturn nil\\n   979→\\t}\\n   980→\\n   981→\\tif selected != \\\"yes\\\" {\\n   982→\\t\\treturn nil\\n   983→\\t}\\n   984→\\n   985→\\tif err := appendShellCompletion(rcFile, completionLine); err != nil {\\n   986→\\t\\treturn fmt.Errorf(\\\"failed to update %s: %w\\\", rcFile, err)\\n   987→\\t}\\n   988→\\n   989→\\tfmt.Fprintf(w, \\\"✓ Shell completion added to %s\\\\n\\\", rcFile)\\n   990→\\tfmt.Fprintln(w, \\\"  Restart your shell to activate\\\")\\n   991→\\n   992→\\treturn nil\\n   993→}\\n   994→\\n   995→// isCompletionConfigured checks if shell completion is already in the rc file.\\n   996→func