LocalFile is the path to the local settings override file (not committed)\\n    25→\\tEntireSettingsLocalFile = \\\".entire/settings.local.json\\\"\\n    26→)\\n    27→\\n    28→// EntireSettings represents the .entire/settings.json configuration\\n    29→type EntireSettings struct {\\n    30→\\t// Strategy is the name of the git strategy to use\\n    31→\\tStrategy string `json:\\\"strategy\\\"`\\n    32→\\n    33→\\t// Enabled indicates whether Entire is active. When false, CLI commands\\n    34→\\t// show a disabled message and hooks exit silently. Defaults to true.\\n    35→\\tEnabled bool `json:\\\"enabled\\\"`\\n    36→\\n    37→\\t// LocalDev indicates whether to use \\\"go run\\\" instead of the \\\"entire\\\" binary\\n    38→\\t// This is used for development when the binary is not installed\\n    39→\\tLocalDev bool `json:\\\"local_dev,omitempty\\\"`\\n    40→\\n    41→\\t// LogLevel sets the logging verbosity (debug, info, warn, error).\\n    42→\\t// Can be overridden by ENTIRE_LOG_LEVEL environment variable.\\n    43→\\t// Defaults to \\\"info\\\".\\n    44→\\tLogLevel string `json:\\\"log_level,omitempty\\\"`\\n    45→\\n    46→\\t// StrategyOptions contains strategy-specific configuration\\n    47→\\tStrategyOptions map[string]any `json:\\\"strategy_options,omitempty\\\"`\\n    48→\\n    49→\\t// Telemetry controls anonymous usage analytics.\\n    50→\\t// nil = not asked yet (show prompt), true = opted in, false = opted out\\n    51→\\tTelemetry *bool `json:\\\"telemetry,omitempty\\\"`\\n    52→}\\n    53→\\n    54→// Load loads the Entire settings from .entire/settings.json,\\n    55→// then applies any overrides from .entire/settings.local.json if it exists.\\n    56→// Returns default settings if neither file exists.\\n    57→// Works correctly from any subdirectory within the repository.\\n    58→func Load() (*EntireSettings, error) {\\n    59→\\t// Get absolute paths for settings files\\n    60→\\tsettingsFileAbs, err := paths.AbsPath(EntireSettingsFile)\\n    61→\\tif err != nil {\\n    62→\\t\\tsettingsFileAbs = EntireSettingsFile // Fallback to relative\\n    63→\\t}\\n    64→\\tlocalSettingsFileAbs, err := paths.AbsPath(EntireSettingsLocalFile)\\n    65→\\tif err != nil {\\n    66→\\t\\tlocalSettingsFileAbs = EntireSettingsLocalFile // Fallback to relative\\n    67→\\t}\\n    68→\\n    69→\\t// Load base settings\\n    70→\\tsettings, err := loadFromFile(settingsFileAbs)\\n    71→\\tif err != nil {\\n    72→\\t\\treturn nil, fmt.Errorf(\\\"reading settings file: %w\\\", err)\\n    73→\\t}\\n    74→\\n    75→\\t// Apply local overrides if they exist\\n    76→\\tlocalData, err := os.ReadFile(localSettingsFileAbs) //nolint:gosec // path is from AbsPath or constant\\n    77→\\tif err != nil {\\n    78→\\t\\tif !os.IsNotExist(err) {\\n    79→\\t\\t\\treturn nil, fmt.Errorf(\\\"reading local settings file: %w\\\", err)\\n    80→\\t\\t}\\n    81→\\t\\t// Local file doesn't exist, continue without overrides\\n    82→\\t} else {\\n    83→\\t\\tif err := mergeJSON(settings, localData); err != nil {\\n    84→\\t\\t\\treturn nil, fmt.Errorf(\\\"merging local settings: %w\\\", err)\\n    85→\\t\\t}\\n    86→\\t}\\n    87→\\n    88→\\tapplyDefaults(settings)\\n    89→\\n    90→\\treturn settings, nil\\n    91→}\\n    92→\\n    93→// LoadFromFile loads settings from a specific file path without merging local overrides.\\n    94→// Returns default settings if the file doesn't exist.\\n    95→// Use this when you need to display individual settings files separately.\\n    96→func LoadFromFile(filePath string) (*EntireSettings, error) {\\n    97→\\treturn loadFromFile(filePath)\\n    98→}\\n    99→\\n   100→// loadFromFile loads settings from a specific file path.\\n   101→// Returns default settings if the file doesn't exist.\\n   102→func loadFromFile(filePath string) (*EntireSettings, error) {\\n   103→\\tsettings := &EntireSettings{\\n   104→\\t\\tStrategy: DefaultStrategyName,\\n   105→\\t\\tEnabled:  true, // Defa