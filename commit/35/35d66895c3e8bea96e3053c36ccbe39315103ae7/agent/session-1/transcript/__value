transcript\\\"\\n    25→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    26→\\t\\\"github.com/entireio/cli/perf\\\"\\n    27→)\\n    28→\\n    29→// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n    30→// Returns nil if the event was handled successfully.\\n    31→func DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    32→\\tif ag == nil {\\n    33→\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    34→\\t}\\n    35→\\tif event == nil {\\n    36→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    37→\\t}\\n    38→\\n    39→\\tswitch event.Type {\\n    40→\\tcase agent.SessionStart:\\n    41→\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n    42→\\tcase agent.TurnStart:\\n    43→\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n    44→\\tcase agent.TurnEnd:\\n    45→\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n    46→\\tcase agent.Compaction:\\n    47→\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n    48→\\tcase agent.SessionEnd:\\n    49→\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n    50→\\tcase agent.SubagentStart:\\n    51→\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n    52→\\tcase agent.SubagentEnd:\\n    53→\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n    54→\\tcase agent.ModelUpdate:\\n    55→\\t\\treturn handleLifecycleModelUpdate(ctx, ag, event)\\n    56→\\tcase agent.FileEdit:\\n    57→\\t\\treturn handleLifecycleFileEdit(ctx, ag, event)\\n    58→\\tdefault:\\n    59→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    60→\\t}\\n    61→}\\n    62→\\n    63→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    64→// fires state machine transition.\\n    65→func handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    66→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n    67→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    68→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    69→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    70→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    71→\\t\\tslog.String(\\\"model\\\", event.Model),\\n    72→\\t)\\n    73→\\n    74→\\tif event.SessionID == \\\"\\\" {\\n    75→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    76→\\t}\\n    77→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    78→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    79→\\t}\\n    80→\\n    81→\\t// Build informational message\\n    82→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    83→\\n    84→\\t// Check for concurrent sessions and append count if any\\n    85→\\t_, countSessionsSpan := perf.Start(ctx, \\\"count_active_sessions\\\")\\n    86→\\tstrat := GetStrategy(ctx)\\n    87→\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n    88→\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    89→\\t}\\n    90→\\tcountSessionsSpan.End()\\n    91→\\n    92→\\t// Output informational message if the agent supports hook responses.\\n    93→\\t// Claude Code reads JSON from stdout; agents that don't implement\\n    94→\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n    95→\\t_, hookResponseSpan := perf.Start(ctx, \\\"write_hook_response\\\")\\n    96→\\tif event.ResponseMessage != \\\"\\\" {\\n    97→\\t\\tmessage = event.ResponseMessage\\n    98→\\t}\\n    99→\\tif writer, ok := agent.AsHookResponseWriter(ag); ok {\\n   100→\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n   101→\\t\\t\\thookResponseSpan.RecordError(err)\\n   102→\\t\\t\\thookResponseSpan.End()\\n   103→\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n   104→\\t\\t}\\n   105→\\t}\\n   106→\\thookResponseSpan.End()\\n   107→\\n   108→\\t// Store model hint if the agent provided model info on SessionStart\\n   109→\\tif event.Model != \\\"\\\" {\\n   110→\\t\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n   111→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint on session start\\\",\\n   112→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   113→\\t\\t}\\n   114→\\t}\\n   115→\\n   116→\\t// Fire EventSessionStart for the current session (if state exists).\\n   117→\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n   118→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n   119→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   120→\\t} else if state != nil {\\n   121→\\t\\tpersistEventMetadataToState(event, state)\\n   122→\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   123→\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n   124→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   125→\\t\\t}\\n   126→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   127→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n   128→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   129→\\t\\t}\\n   130→\\t}\\n   131→\\n   132→\\treturn nil\\n   133→}\\n   134→\\n   135→// handleLifecycleModelUpdate persists the model name for the current session.\\n   136→//\\n   137→// If the session state file already exists (e.g., Gemini's BeforeModel fires\\n   138→// after TurnStart), the model is