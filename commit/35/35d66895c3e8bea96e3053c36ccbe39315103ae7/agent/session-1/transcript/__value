tionally lightweight — no JSON state loading, just a file append.\\n   178→func handleLifecycleFileEdit(ctx context.Context, _ agent.Agent, event *agent.Event) error {\\n   179→\\tif event.SessionID == \\\"\\\" || event.FilePath == \\\"\\\" {\\n   180→\\t\\treturn nil\\n   181→\\t}\\n   182→\\n   183→\\t// Normalize to repo-relative path\\n   184→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   185→\\tif err != nil {\\n   186→\\t\\treturn nil //nolint:nilerr // can't normalize path outside git repo, skip silently\\n   187→\\t}\\n   188→\\n   189→\\trelPath := paths.ToRelativePath(event.FilePath, repoRoot)\\n   190→\\tif relPath == \\\"\\\" {\\n   191→\\t\\treturn nil // path outside repo, skip\\n   192→\\t}\\n   193→\\n   194→\\tstore, err := session.NewStateStore(ctx)\\n   195→\\tif err != nil {\\n   196→\\t\\treturn nil //nolint:nilerr // can't access state store, skip silently\\n   197→\\t}\\n   198→\\n   199→\\tif appendErr := store.AppendFileTouched(ctx, event.SessionID, relPath); appendErr != nil {\\n   200→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   201→\\t\\tlogging.Warn(logCtx, \\\"failed to track file edit\\\",\\n   202→\\t\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   203→\\t\\t\\tslog.String(\\\"file_path\\\", relPath),\\n   204→\\t\\t\\tslog.String(\\\"error\\\", appendErr.Error()),\\n   205→\\t\\t)\\n   206→\\t}\\n   207→\\n   208→\\treturn nil\\n   209→}\\n   210→\\n   211→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   212→// ensures strategy setup, initializes session.\\n   213→func handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   214→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   215→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   216→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   217→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   218→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   219→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   220→\\t)\\n   221→\\n   222→\\tsessionID := event.SessionID\\n   223→\\tif sessionID == \\\"\\\" {\\n   224→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   225→\\t}\\n   226→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   227→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   228→\\t}\\n   229→\\n   230→\\t// Fill model from hint file if the agent didn't provide it on this hook\\n   231→\\tif event.Model == \\\"\\\" {\\n   232→\\t\\tif hint := strategy.LoadModelHint(ctx, sessionID); hint != \\\"\\\" {\\n   233→\\t\\t\\tevent.Model = hint\\n   234→\\t\\t\\tlogging.Debug(logCtx, \\\"loaded model from hint file\\\",\\n   235→\\t\\t\\t\\tslog.String(\\\"model\\\", hint))\\n   236→\\t\\t}\\n   237→\\t}\\n   238→\\n   239→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   240→\\t_, captureSpan := perf.Start(ctx, \\\"capture_pre_prompt_state\\\")\\n   241→\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n   242→\\t\\tcaptureSpan.RecordError(err)\\n   243→\\t\\tcaptureSpan.End()\\n   244→\\t\\treturn err\\n   245→\\t}\\n   246→\\tcaptureSpan.End()\\n   247→\\n   248→\\t// Append prompt to prompt.txt on filesystem so it's available for\\n   249→\\t// mid-turn commits (before SaveStep writes it to the shadow branch).\\n   250→\\t// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\" to support multiple turns.\\n   251→\\tif event.Prompt != \\\"\\\" {\\n   252→\\t\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   253→\\t\\tif sessionDirAbs, absErr := paths.AbsPath(ctx, sessionDir); absErr == nil {\\n   254→\\t\\t\\tif mkErr := os.MkdirAll(sessionDirAbs, 0o750); mkErr == nil {\\n   255→\\t\\t\\t\\tpromptPath := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   256→\\t\\t\\t\\texisting, readErr := os.ReadFile(promptPath) //nolint:gosec // session metadata path\\n   257→\\t\\t\\t\\tvar content string\\n   258→\\t\\t\\t\\tif readErr == nil && len(existing) > 0 {\\n   259→\\t\\t\\t\\t\\tcontent = string(existing) + \\\"\\\\n\\\\n---\\\\n\\\\n\\\" + event.Prompt\\n   260→\\t\\t\\t\\t} else {\\n   261→\\t\\t\\t\\t\\tcontent = event.Prompt\\n   262→\\t\\t\\t\\t}\\n   263→\\t\\t\\t\\tif writeErr := os.WriteFile(promptPath, []byte(content), 0o600); writeErr != nil {\\n   264→\\t\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to write prompt.txt\\\",\\n   265→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", writeErr.Error()))\\n   266→\\t\\t\\t\\t}\\n   267→\\t\\t\\t}\\n   268→\\t\\t}\\n   269→\\t}\\n   270→\\n   271→\\t// Ensure strategy setup and initialize session\\n   272→\\t_, initSpan := perf.Start(ctx, \\\"init_session\\\")\\n   273→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   274→\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n   275→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   276→\\t}\\n   277→\\n   278→\\tstrat := GetStrategy(ctx)\\n   279→\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt, event.Model); err != nil {\\n   280→\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n   281→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   282→\\t}\\n   283→\\tinitSpan.End()\\n   284→\\n   285→\\treturn nil\\n   286→}\\n   287→\\n   288→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   289→// detects file changes, saves step + checkpoint, transitions phase.\\n   290→//\\n   291→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   292→func handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   293→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   294→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   295→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   296→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   297→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   298→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   299→\\t)\\n   300→\\n   301→\\tsessionID := event.SessionID\\n   302→\\tif sessionID == \\\"\\\" {\\n   303→\\t\\tsessionID = unknownSessionID\\n   304→\\t}\\n   305→\\n   306→\\t// Fill model from hint file if the agent didn't provide it on this hook\\n   307→\\tif event.Model == \\\"\\\" && sessionID != unknownSessionID {\\n   308→\\t\\tif hint := strategy.LoadModelHint(ctx, sessionID); hint != \\\"\\\" {\\n   309→\\t\\t\\tevent.Model = hint\\n   310→\\t\\t\\tlogging.Debug(logCtx, \\\"loaded model from hint file\\\",\\n   311→\\t\\t\\t\\tslog.String(\\\"model\\\", hint))\\n   312→\\t\\t}\\n   313→\\t}\\n   314→\\n   315→\\ttranscriptRef := event.SessionRef\\n   316→\\tif transcriptRef == \\\"\\\" {\\n   317→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   318→\\t}\\n   319→\\n   320→\\t// If agent implements TranscriptPreparer, materialize the transcript file.\\n   321→\\t// This must run BEFORE fileExists: agents like OpenCode lazily fetch transcripts\\n   322→\\t// via `opencode export`, so the file doesn't exist until PrepareTranscript creates it.\\n   323→\\t// Claude Code's PrepareTranscript just flushes (always succeeds). Agents without\\n   324→\\t// TranscriptPreparer (Gemini, Droid) are unaffected.\\n   325→\\t_, prepareSpan := perf.Start(ctx, \\\"prepare_and_validate_transcript\\\")\\n   326→\\tif preparer, ok := agent.AsTranscriptPreparer(ag); ok {\\n   327→\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n   328→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n   329→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   330→\\t\\t}\\n   331→\\t}\\n   332→\\n   333→\\tif !fileExists(transcriptRef) {\\n   334→\\t\\tprepareSpan.RecordError(fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef))\\n   335→\\t\\tprepareSpan.End()\\n   336→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   337→\\t}\\n   338→\\n   339→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   340→\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n   341→\\t\\tprepareSpan.RecordError(strategy.ErrEmptyRepository)\\n   342→\\t\\tprepareSpan.End()\\n   343→\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n   344→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   345→\\t}\\n   346→\\tprepareSpan.End()\\n   347→\\n   348→\\t// Create session metadata directory\\n   349→\\t_, copySpan := perf.Start(ctx, \\\"copy_transcript\\\")\\n   350→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   351→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   352→\\tif err != nil {\\n   353→\\t\\tsessionDirAbs = sessionDir\\n   354→\\t}\\n   355→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   356→\\t\\tcopySpan.RecordError(err)\\n   357→\\t\\tcopySpan.End()\\n   358→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   359→\\t}\\n   360→\\n   361→\\t// Copy transcript to session directory\\n   362→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   363→\\tif err != nil {\\n   364→\\t\\tcopySpan.RecordError(err)\\n   365→\\t\\tcopySpan.End()\\n   366→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   367→\\t}\\n   368→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   369→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   370→\\t\\tcopySpan.RecordError(err)\\n   371→\\t\\tcopySpan.End()\\n   372→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   373→\\t}\\n   374→\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n   375→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n   376→\\tcopySpan.End()\\n   377→\\n   378→\\t// Load pre-prompt state (captured on TurnStart)\\n   379→\\t_, extractSpan := perf.Start(ctx, \\\"extract_metadata\\\")\\n   380→\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n   381→\\tif err != nil {\\n   382→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n   383→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   384→\\t}\\n   385→\\n   386→\\t// Determine transcript offset\\n   387→\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n   388→\\n   389→\\t// Compute subagents directory for agents that support subagent extraction.\\n   390→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   391→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   392→\\n   393→\\t// Extract metadata via agent interface (modified files)\\n   394→\\tvar modifiedFiles []string\\n   395→\\n   396→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok {\\n   397→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   398→\\t\\tif subagentExtractor, subOk := agent.AsSubagentAwareExtractor(ag); subOk {\\n   399→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n   400→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n   401→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   402→\\t\\t\\t} else {\\n   403→\\t\\t\\t\\tmodifiedFiles = files\\n   404→\\t\\t\\t}\\n   405→\\t\\t} else {\\n   406→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   407→\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   408→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n   409→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   410→\\t\\t\\t} else {\\n   411→\\t\\t\\t\\tmodifiedFiles = files\\n   412→\\t\\t\\t}\\n   413→\\t\\t}\\n   414→\\t}\\n   415→\\textractSpan.End()\\n   416→\\n   417→\\t// Generate commit message from last prompt (read from session state, set at TurnStart)\\n   418→\\t_, commitMsgSpan := perf.Start(ctx, \\\"generate_commit_message\\\")\\n   419→\\tlastPrompt := \\\"\\\"\\n   420→\\tif sessionState, stateErr := strategy.LoadSessionState(ctx, sessionID); stateErr == nil && sessionState != nil {\\n   421→\\t\\tlastPrompt = sessionState.LastPrompt\\n   422→\\t}\\n   423→\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n   424→\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n   425→\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n   426→\\tcommitMsgSpan.End()\\n   427→\\n   428→\\t// Get worktree root for path normalization\\n   429→\\t_, detectSpan := perf.Start(ctx, \\\"detect_file_changes\\\")\\n   430→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   431→\\tif err != nil {\\n   432→\\t\\tdetectSpan.RecordError(err)\\n   433→\\t\\tdetectSpan.End()\\n   434→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   435→\\t}\\n   436→\\n   437→\\tvar preUntrackedFiles []string\\n   438→\\tif preState != nil {\\n   439→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n   440→\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n   441→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   442→\\t}\\n   443→\\n   444→\\t// Detect file changes via git status\\n   445→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   446→\\tif err != nil {\\n   447→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   448→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   449→\\t}\\n   450→\\tdetectSpan.End()\\n   451→\\n   452→\\t// Filter and normalize all paths\\n   453→\\t_, normalizeSpan := perf.Start(ctx, \\\"filter_and_normalize_paths\\\")\\n   454→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   455→\\tvar relNewFiles, relDeletedFiles []string\\n   456→\\tif changes != nil {\\n   457→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   458→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   459→\\n   460→\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n   461→\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n   462→\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n   463→\\t\\t// Git status catches any tracked file with working-tree changes.\\n   464→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   465→\\t}\\n   466→\\n   467→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   468→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   469→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   470→\\t// if it exists in HEAD with the same content as the working tree.\\n   471→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   472→\\tnormalizeSpan.End()\\n   473→\\n   474→\\t// Check if there are any changes\\n   475→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   476→\\tif totalChanges == 0 {\\n   477→\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n   478→\\t\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n   479→\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   