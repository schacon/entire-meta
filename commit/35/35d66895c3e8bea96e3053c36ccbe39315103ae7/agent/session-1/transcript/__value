43→\\tinfo, err := os.Stat(transcriptPath)\\n   244→\\tif err != nil {\\n   245→\\t\\t// Most likely the file doesn't exist; other errors (permission, etc.)\\n   246→\\t\\t// would also prevent polling, so skip the wait either way.\\n   247→\\t\\treturn\\n   248→\\t}\\n   249→\\tfileAge := time.Since(info.ModTime())\\n   250→\\tif fileAge > staleThreshold {\\n   251→\\t\\tlogging.Debug(logCtx, \\\"transcript file is stale, skipping sentinel wait\\\",\\n   252→\\t\\t\\tslog.Duration(\\\"file_age\\\", fileAge),\\n   253→\\t\\t)\\n   254→\\t\\treturn\\n   255→\\t}\\n   256→\\n   257→\\tdeadline := time.Now().Add(maxWait)\\n   258→\\tfor time.Now().Before(deadline) {\\n   259→\\t\\tif checkStopSentinel(transcriptPath, tailBytes, hookStartTime, maxSkew) {\\n   260→\\t\\t\\tlogging.Debug(logCtx, \\\"transcript flush sentinel found\\\",\\n   261→\\t\\t\\t\\tslog.Duration(\\\"wait\\\", time.Since(hookStartTime)),\\n   262→\\t\\t\\t)\\n   263→\\t\\t\\treturn\\n   264→\\t\\t}\\n   265→\\t\\ttime.Sleep(pollInterval)\\n   266→\\t}\\n   267→\\tlogging.Warn(logCtx, \\\"transcript flush sentinel not found within timeout, proceeding\\\",\\n   268→\\t\\tslog.Duration(\\\"timeout\\\", maxWait),\\n   269→\\t)\\n   270→}\\n   271→\\n   272→// checkStopSentinel reads the tail of the transcript file and looks for the sentinel.\\n   273→func checkStopSentinel(path string, tailBytes int64, hookStartTime time.Time, maxSkew time.Duration) bool {\\n   274→\\tf, err := os.Open(path) //nolint:gosec // path comes from agent hook input\\n   275→\\tif err != nil {\\n   276→\\t\\treturn false\\n   277→\\t}\\n   278→\\tdefer f.Close()\\n   279→\\n   280→\\tinfo, err := f.Stat()\\n   281→\\tif err != nil {\\n   282→\\t\\treturn false\\n   283→\\t}\\n   284→\\toffset := info.Size() - tailBytes\\n   285→\\tif offset < 0 {\\n   286→\\t\\toffset = 0\\n   287→\\t}\\n   288→\\tbuf := make([]byte, info.Size()-offset)\\n   289→\\tif _, err := f.ReadAt(buf, offset); err != nil {\\n   290→\\t\\treturn false\\n