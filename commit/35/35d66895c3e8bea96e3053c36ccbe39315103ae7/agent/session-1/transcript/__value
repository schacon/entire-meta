urn &agent.Event{\\n   149→\\t\\tType:       agent.SessionEnd,\\n   150→\\t\\tSessionID:  raw.SessionID,\\n   151→\\t\\tSessionRef: raw.TranscriptPath,\\n   152→\\t\\tTimestamp:  time.Now(),\\n   153→\\t}, nil\\n   154→}\\n   155→\\n   156→func (c *ClaudeCodeAgent) parseSubagentStart(stdin io.Reader) (*agent.Event, error) {\\n   157→\\traw, err := agent.ReadAndParseHookInput[taskHookInputRaw](stdin)\\n   158→\\tif err != nil {\\n   159→\\t\\treturn nil, err\\n   160→\\t}\\n   161→\\treturn &agent.Event{\\n   162→\\t\\tType:       agent.SubagentStart,\\n   163→\\t\\tSessionID:  raw.SessionID,\\n   164→\\t\\tSessionRef: raw.TranscriptPath,\\n   165→\\t\\tToolUseID:  raw.ToolUseID,\\n   166→\\t\\tToolInput:  raw.ToolInput,\\n   167→\\t\\tTimestamp:  time.Now(),\\n   168→\\t}, nil\\n   169→}\\n   170→\\n   171→func (c *ClaudeCodeAgent) parseSubagentEnd(stdin io.Reader) (*agent.Event, error) {\\n   172→\\traw, err := agent.ReadAndParseHookInput[postToolHookInputRaw](stdin)\\n   173→\\tif err != nil {\\n   174→\\t\\treturn nil, err\\n   175→\\t}\\n   176→\\tevent := &agent.Event{\\n   177→\\t\\tType:       agent.SubagentEnd,\\n   178→\\t\\tSessionID:  raw.SessionID,\\n   179→\\t\\tSessionRef: raw.TranscriptPath,\\n   180→\\t\\tToolUseID:  raw.ToolUseID,\\n   181→\\t\\tToolInput:  raw.ToolInput,\\n   182→\\t\\tTimestamp:  time.Now(),\\n   183→\\t}\\n   184→\\tif raw.ToolResponse.AgentID != \\\"\\\" {\\n   185→\\t\\tevent.SubagentID = raw.ToolResponse.AgentID\\n   186→\\t}\\n   187→\\treturn event, nil\\n   188→}\\n   189→\\n   190→// fileEditToolInput extracts file_path from Write/Edit tool input.\\n   191→type fileEditToolInput struct {\\n   192→\\tFilePath string `json:\\\"file_path\\\"`\\n   193→}\\n   194→\\n   195→func (c *ClaudeCodeAgent) parseFileEdit(stdin io.Reader) (*agent.Event, error) {\\n   196→\\traw, err := agent.ReadAndParseHookInput[postToolHookInputRaw](stdin)\\n   197→\\tif err != nil {\\n   198→\\t\\treturn nil, err\\n   199→\\t}\\n   200→\\n   201→\\tv