eCommit is the commit used as the reference point for attribution calculations.\\n    48→\\t// Unlike BaseCommit (which tracks the shadow branch and moves with migration), this field\\n    49→\\t// preserves the original base commit so deferred condensation can correctly calculate\\n    50→\\t// agent vs human line attribution. Updated only after successful condensation.\\n    51→\\tAttributionBaseCommit string `json:\\\"attribution_base_commit,omitempty\\\"`\\n    52→\\n    53→\\t// WorktreePath is the absolute path to the worktree root\\n    54→\\tWorktreePath string `json:\\\"worktree_path,omitempty\\\"`\\n    55→\\n    56→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n    57→\\t// Derived from .git/worktrees/<name>/, stable across git worktree move\\n    58→\\tWorktreeID string `json:\\\"worktree_id,omitempty\\\"`\\n    59→\\n    60→\\t// StartedAt is when the session was started\\n    61→\\tStartedAt time.Time `json:\\\"started_at\\\"`\\n    62→\\n    63→\\t// EndedAt is when the session was explicitly closed by the user.\\n    64→\\t// nil means the session is still active or was not cleanly closed.\\n    65→\\tEndedAt *time.Time `json:\\\"ended_at,omitempty\\\"`\\n    66→\\n    67→\\t// Phase is the lifecycle stage of this session (see phase.go).\\n    68→\\t// Empty means idle (backward compat with pre-state-machine files).\\n    69→\\tPhase Phase `json:\\\"phase,omitempty\\\"`\\n    70→\\n    71→\\t// TurnID is a unique identifier for the current agent turn.\\n    72→\\t// Lifecycle:\\n    73→\\t//   - Generated fresh in InitializeSession at each turn start\\n    74→\\t//   - Shared across all checkpoints within the same turn\\n    75→\\t//   - Used to correlate related checkpoints when a turn's work spans multiple commits\\n    76→\\t//   - Persists until the next InitializeSession call generates a new one\\n    77→\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n    78→\\n    79→\\t// TurnCheckpointIDs tracks all checkpoint IDs condensed during the current turn.\\n    80→\\t// Lifecycle:\\n    81→\\t//   - Set in PostCommit when a checkpoint is condensed for an ACTIVE session\\n    82→\\t//   - Consumed in HandleTurnEnd to finalize all checkpoints with the full transcript\\n    83→\\t//   - Cleared in HandleTurnEnd after finalization completes\\n    84→\\t//   - Cleared in InitializeSession when a new prompt starts\\n    85→\\t//   - Cleared when session is reset (ResetSession deletes the state file entirely)\\n    86→\\tTurnCheckpointIDs []string `json:\\\"turn_checkpoint_ids,omitempty\\\"`\\n    87→\\n    88→\\t// LastInteractionTime is updated on agent-interaction events (TurnStart,\\n    89→\\t// TurnEnd, SessionStop, Compaction) but NOT on git commit hooks.\\n    90→\\t// Used for stale session detection in \\\"entire doctor\\\".\\n    91→\\tLastInteractionTime *time.Time `json:\\\"last_interaction_time,omitempty\\\"`\\n    92→\\n    93→\\t// StepCount is the number of checkpoints/steps created in this session.\\n    94→\\t// JSON tag kept as \\\"checkpoint_count\\\" for backward compatibility with existing state files.\\n    95→\\tStepCount int `json:\\\"checkpoint_count\\\"`\\n    96→\\n    97→\\t// CheckpointTranscriptStart is the transcript line offset where the current\\n    98→\\t// checkpoint cycle began. Set to 0 at session start, updated to current\\n    99→\\t// transcript length after each condensation. Used to scope the transcript\\n   100→\\t// for checkpoint condensation: \\\"everything since last checkpoint\\\".\\n   101→\\tCheckpointTranscriptStart int `json:\\\"checkpoint_transcript_start,omitempty\\\"`\\n   102→\\n   103→\\t// Deprecated: CondensedTranscriptLines is replaced by CheckpointTranscriptStart.\\n   104→\\t// Kept for backward compatibility with existing state files.\\n   105→\\t// Use NormalizeAfterLoad() to migrate.\\n   106→\\tCondensedTranscriptLines int `json:\\\"condensed_transcript_lines,omitempty\\\"`\\n   107→\\n   108→\\t// UntrackedFilesAtStart tracks files that existed at session start (to preserve during rewind)\\n   109→\\tUntrackedFilesAtStart []string `json:\\\"untracked_files_at_start,omitempty\\\"`\\n   110→\\n   111→\\t// FilesTouched tracks files modified/created/deleted during this session\\n   112→\\tFilesTouched []string `json:\\\"files_touched,omitempty\\\"`\\n   113→\\n   114→\\t// LastCheckpointID is the checkpoint ID from the most recent condensation.\\n   115→\\t// Used to restore the Entire-Checkpoint trailer on amend and to identify\\n   116→\\t// sessions that have been condensed at least once. Cleared on new prompt.\\n   117→\\tLastCheckpointID id.CheckpointID `json:\\\"last_checkpoint_id,omitempty\\\"`\\n   118→\\n   119→\\t// FullyCondensed indicates this session has been condensed and has no remaining\\n   120→\\t// carry-forward files. PostCommit skips fully-condensed sessions entirely.\\n   121→\\t// Set after successful condensation when no files remain for carry-forward\\n   122→\\t// and the session phase is ENDED. Cleared on session reactivation (ENDED →\\n   123→\\t// ACTIVE via TurnStart, or ENDED → IDLE via SessionStart) by ActionClearEndedAt.\\n   124→\\tFullyCondensed bool `json:\\\"fully_condensed,omitempty\\\"`\\n   125→\\n   126→\\t// AgentType identifies the agent that created this session (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\", \\\"Cursor\\\")\\n   127→\\tAgentType types.AgentType `json:\\\"agent_type,omitempty\\\"`\\n   128→\\n   129→\\t// ModelName is the LLM model used in this session (e.g., \\\"claude-sonnet-4-20250514\\\", \\\"gpt-4o\\\").\\n   130→\\t// Set from hook data when the agent provides it.\\n   131→\\tModelName string `json:\\\"model_name,omitempty\\\"`\\n   132→\\n   133→\\t// Token usage tracking (accumulated across all checkpoints in this session)\\n   134→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   135→\\n   136→\\t// Hook-provided session metrics (for agents like Cursor that report via hooks)\\n   137→\\tSessionDurationMs int64 `json:\\\"session_duration_ms,omitempty\\\"`\\n   138→\\tSessionTurnCount  int   `json:\\\"session_turn_count,omitempty\\\"`\\n   139→\\tContextTokens     int   `json:\\\"context_tokens,omitempty\\\"`\\n   140→\\tContextWindowSize int   `json:\\\"context_window_size,omitempty\\\"`\\n   141→\\n   142→\\t// Deprecated: TranscriptLinesAtStart is replaced by CheckpointTranscriptStart.\\n   143→\\t// Kept for backward compatibility with existing state files.\\n   144→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   145→\\n   146→\\t// TranscriptIdentifierAtStart is the last transcript identifier when the session started.\\n   147→\\t// Used for identifier-based transcript scoping (UUID for Claude, message ID for Gemini).\\n   148→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"`\\n   149→\\n   150→\\t// TranscriptPath is the path to the live transcript file (for mid-session commit detection)\\n   151→\\tTranscriptPath string `json:\\\"transcript_path,omitempty\\\"`\\n   152→\\n   153→\\t// LastPrompt is the most recent user prompt for this session (truncated for display).\\n   154→\\t// Updated on every turn start (UserPromptSubmit). JSON tag kept as \\\"first_prompt\\\"\\n   155→\\t// for backward compatibility with existing state files.\\n   156→\\tLastPrompt string `json:\\\"last_prompt,omitempty\\\"`\\n   157→\\n   158→\\t// PromptAttributions tracks user and agent line changes at each prompt start.\\n   159→\\t// This enables accurate attribution by capturing user edits between checkpoints.\\n   160→\\tPromptAttributions []PromptAttribution `json:\\\"prompt_attributions,omitempty\\\"`\\n   161→\\n   162→\\t// PendingPromptAttribution holds attribution calculated at prompt start (before agent runs).\\n   163→\\t// This is moved to PromptAttributions when SaveStep is called.\\n   164→\\tPendingPromptAttribution *PromptAttribution `json:\\\"pending_prompt_attribution,omitempty\\\"`\\n   165→}\\n   166→\\n   167→// PromptAttribution captures line-level attribution data at the start of each prompt.\\n   168→// By recording what changed since the last checkpoint BEFORE the agent works,\\n   169→// we can accurately separate user edits from agent contributions.\\n   170→type PromptAttribution struct {\\n   171→\\t// CheckpointNumber is which checkpoint this was recorded before (1-indexed)\\n   172→\\tCheckpointNumber int `json:\\\"checkpoint_number\\\"`\\n   173→\\n   174→\\t// UserLinesAdded is lines added by user since the last checkpoint\\n   175→\\tUserLinesAdded int `json:\\\"user_lines_added\\\"`\\n   176→\\n   177→\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   178→\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   179→\\n   180→\\t// AgentLinesAdded is total agent lines added so far (base → last checkpoint).\\n   181→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   182→\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   183→\\n   184→\\t// AgentLinesRemoved is total agent lines removed so far (base → last checkpoint).\\n   185→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   186→\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   187→\\n   188→\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   189→\\t// This enables distinguishing user self-modifications from agent modifications.\\n   190→\\t// See docs/architecture/attribution.md for details.\\n   191→\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   192→}\\n   193→\\n   194→// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   195→// Call this after deserializing a State from JSON.\\n   196→func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   197→\\t// Normalize legacy phase values. \\\"active_committed\\\" was removed with the\\n   198→\\t// 1:1 checkpoint model in favor of the state machine handling commits\\n   199→\\t// during ACTIVE phase with immediate condensation.\\n   200→\\tif s.Phase == \\\"active_committed\\\" {\\n   201→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   202→\\t\\tlogging.Info(logCtx, \\\"migrating legacy active_committed phase to active\\\",\\n   203→\\t\\t\\tslog.String(\\\"session_id\\\", s.SessionID),\\n   204→\\t\\t)\\n   205→\\t\\ts.Phase = PhaseActive\\n   206→\\t}\\n   207→\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n   208→\\ts.Phase = PhaseFromString(string(s.Phase))\\n   209→\\n   210→\\t// Migrate transcript fields: CheckpointTranscriptStart replaces both\\n   211→\\t// CondensedTranscriptLines and TranscriptLinesAtStart from older state files.\\n   212→\\tif s.CheckpointTranscriptStart == 0 {\\n   213→\\t\\tif s.CondensedTranscriptLines > 0 {\\n   214→\\t\\t\\ts.CheckpointTranscriptStart = s.CondensedTranscriptLines\\n   215→\\t\\t} else if s.TranscriptLinesAtStart > 0 {\\n   216→\\t\\t\\ts.CheckpointTranscriptStart = s.TranscriptLinesAtStart\\n   217→\\t\\t}\\n   218→\\t}\\n   219→\\t// Clear deprecated fields so they aren't re-persisted.\\n   220→\\t// Note: this is a one-way migration. If the state is re-saved, older CLI versions\\n   221→\\t// will see 0 for these fields and fall back to scoping from the transcript start.\\n   222→\\t// This is acceptable since CLI upgrades are monotonic and the worst case is\\n   223→\\t// redundant transcript content in a condensation, not data loss.\\n   224→\\ts.CondensedTranscriptLines = 0\\n   225→\\ts.TranscriptLinesAtStart = 0\\n   226→\\n   227→\\t// Backfill AttributionBaseCommit for sessions created before this field existed.\\n   228→\\t// Without this, a mid-turn commit would migrate BaseCommit and the fallback in\\n   229→\\t// calculateSessionAttributions would use the migrated value, producing zero attribution.\\n   230→\\tif s.AttributionBaseCommit == \\\"\\\" && s.BaseCommit != \\\"\\\" {\\n   231→\\t\\ts.AttributionBaseCommit = s.BaseCommit\\n   232→\\t}\\n   233→}\\n   234→\\n   235→// IsStale returns true when a session hasn't seen interaction for longer than\\n   236→// StaleSessionThreshold. Falls back to StartedAt when LastInteractionTime is\\n   237→// nil (sessions created before interaction tracking was added).\\n   238→func (s *State) IsStale() bool {\\n   239→\\tvar since time.Duration\\n   240→\\tif s.LastInteractionTime != nil {\\n   241→\\t\\tsince = time.Since(*s.LastInteractionTime)\\n   242→\\t} else {\\n   243→\\t\\tsince = time.Since(s.StartedAt)\\n   244→\\t}\\n   245→\\treturn since > StaleSessionThreshold\\n   246→}\\n   247→\\n   248→// StateStore provides low-level operations for managing session state files.\\n   249→//\\n   250→// StateStore is a primitive for session state persistence. It is NOT the same as\\n   251→// the Sessions interface - it only handles state files in .git/entire-sessions/,\\n   252→// not the full session data which includes checkpoint content.\\n   253→//\\n   254→// Use StateStore directly in strategies for performance-critical state operations.\\n   255→// Use the Sessions interface (when implemented) for high-level session management.\\n   256→type StateStore struct {\\n   257→\\t// stateDir is the directory where session state files are stored\\n   258→\\tstateDir string\\n   259→}\\n   260→\\n   261→// NewStateStore creates a new state store.\\n   262→// Uses the git common dir to store session state (shared across worktrees).\\n   263→func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   264→\\tcommonDir, err := getGitCommonDir(ctx)\\n   265→\\tif err != nil {\\n   266→\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   267→\\t}\\n   268→\\treturn &StateStore{\\n   269→\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   270→\\t}, nil\\n   271→}\\n   272→\\n   273→// NewStateStoreWithDir creates a new state store with a custom directory.\\n   274→// This is useful for testing.\\n   275→func NewStateStoreWithDir(stateDir string) *StateStore {\\n   276→\\treturn &StateStore{stateDir: stateDir}\\n   277→}\\n   278→\\n   279→// Load loads the session state for the given session ID.\\n   280→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   281→// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   282→func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   283→\\t// Validate session ID to prevent path traversal\\n   284→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   285→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   286→\\t}\\n   287→\\n   288→\\tstateFile := s.stateFilePath(sessionID)\\n   289→\\n   290→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is derived from sessionID\\n   291→\\tif os.IsNotExist(err) {\\n   292→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   293→\\t}\\n   294→\\tif err != nil {\\n   295→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   296→\\t}\\n   297→\\n   298→\\tvar state State\\n   299→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   300→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal session state: %w\\\", err)\\n   301→\\t}\\n   302→\\tstate.NormalizeAfterLoad(ctx)\\n   303→\\n   304→\\tif state.IsStale() {\\n   305→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   306→\\t\\tlogging.Debug(logCtx, \\\"deleting stale session state\\\",\\n   307→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   308→\\t\\t)\\n   309→\\t\\t_ = s.Clear(ctx, sessionID) //nolint:errcheck // best-effort cleanup of stale session\\n   310→\\t\\treturn nil, nil             //nolint:nilnil //