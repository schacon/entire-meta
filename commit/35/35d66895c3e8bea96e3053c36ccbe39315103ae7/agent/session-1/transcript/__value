e\\n   277\\t\\t}\\n   278\\t\\tdefer f.Close()\\n   279\\t\\n   280\\t\\tinfo, err := f.Stat()\\n   281\\t\\tif err != nil {\\n   282\\t\\t\\treturn false\\n   283\\t\\t}\\n   284\\t\\toffset := info.Size() - tailBytes\\n   285\\t\\tif offset < 0 {\\n   286\\t\\t\\toffset = 0\\n   287\\t\\t}\\n   288\\t\\tbuf := make([]byte, info.Size()-offset)\\n   289\\t\\tif _, err := f.ReadAt(buf, offset); err != nil {\\n   290\\t\\t\\treturn false\\n   291\\t\\t}\\n   292\\t\\n   293\\t\\tlines := strings.Split(string(buf), \\\"\\\\n\\\")\\n   294\\t\\tfor _, line := range lines {\\n   295\\t\\t\\tline = strings.TrimSpace(line)\\n   296\\t\\t\\tif line == \\\"\\\" || !strings.Contains(line, stopHookSentinel) {\\n   297\\t\\t\\t\\tcontinue\\n   298\\t\\t\\t}\\n   299\\t\\n   300\\t\\t\\tvar entry struct {\\n   301\\t\\t\\t\\tTimestamp string `json:\\\"timestamp\\\"`\\n   302\\t\\t\\t}\\n   303\\t\\t\\tif json.Unmarshal([]byte(line), &entry) != nil || entry.Timestamp == \\\"\\\" {\\n   304\\t\\t\\t\\tcontinue\\n   305\\t\\t\\t}\\n   306\\t\\t\\tts, err := time.Parse(time.RFC3339Nano, entry.Timestamp)\\n   307\\t\\t\\tif err != nil {\\n   308\\t\\t\\t\\tts, err = time.Parse(time.RFC3339, entry.Timestamp)\\n   309\\t\\t\\t\\tif err != nil {\\n   310\\t\\t\\t\\t\\tcontinue\\n   311\\t\\t\\t\\t}\\n   312\\t\\t\\t}\\n   313\\t\\t\\t// Validate timestamp is within acceptable range:\\n   314\\t\\t\\t// - Not too far in the past (before hook started minus skew)\\n   315\\t\\t\\t// - Not too far in the future (after hook started plus skew)\\n   316\\t\\t\\tlowerBound := hookStartTime.Add(-maxSkew)\\n   317\\t\\t\\tupperBound := hookStartTime.Add(maxSkew)\\n   318\\t\\t\\tif ts.After(lowerBound) && ts.Before(upperBound) {\\n   319\\t\\t\\t\\treturn true\\n   320\\t\\t\\t}\\n   321\\t\\t}\\n   322\\t\\treturn false\\n   323\\t}\",\"stderr\":\"\",\"interrupted\":false,\"isImage\":false,\"noOutputExpected\":false},\"sourceToolAssistantUUID\":\"071864db-01fe-4e16-a6de-ffc667915d41\"}\n{\"pare