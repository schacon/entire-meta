n    36→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    37→\\t}\\n    38→\\n    39→\\tswitch event.Type {\\n    40→\\tcase agent.SessionStart:\\n    41→\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n    42→\\tcase agent.TurnStart:\\n    43→\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n    44→\\tcase agent.TurnEnd:\\n    45→\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n    46→\\tcase agent.Compaction:\\n    47→\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n    48→\\tcase agent.SessionEnd:\\n    49→\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n    50→\\tcase agent.SubagentStart:\\n    51→\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n    52→\\tcase agent.SubagentEnd:\\n    53→\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n    54→\\tcase agent.ModelUpdate:\\n    55→\\t\\treturn handleLifecycleModelUpdate(ctx, ag, event)\\n    56→\\tcase agent.FileEdit:\\n    57→\\t\\treturn handleLifecycleFileEdit(ctx, ag, event)\\n    58→\\tdefault:\\n    59→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    60→\\t}\\n    61→}\\n    62→\\n    63→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    64→// fires state machine transition.\\n    65→func handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    66→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n    67→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    68→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    69→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    70→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    71→\\t\\tslog.String(\\\"model\\\", event.Model),\\n    72→\\t)\\n    73→\\n    74→\\tif event.SessionID == \\\"\\\" {\\n    75→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    76→\\t}\\n    77→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    78→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    79→\\t}\\n    80→\\n    81→\\t// Build informational message\\n    82→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    83→\\n    84→\\t// Check for concurrent sessions and append count if any\\n    85→\\t_, countSessionsSpan := perf.Start(ctx, \\\"count_active_sessions\\\")\\n    86→\\tstrat := GetStrategy(ctx)\\n    87→\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n    88→\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    89→\\t}\\n    90→\\tcountSessionsSpan.End()\\n    91→\\n    92→\\t// Output informational message if the agent supports hook responses.\\n    93→\\t// Claude Code reads JSON from stdout; agents that don't implement\\n    94→\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n    95→\\t_, hookResponseSpan := perf.Start(ctx, \\\"write_hook_response\\\")\\n    96→\\tif event.ResponseMessage != \\\"\\\" {\\n    97→\\t\\tmessage = event.ResponseMessage\\n    98→\\t}\\n    99→\\tif writer, ok := agent.AsHookResponseWriter(ag); ok {\\n   100→\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n   101→\\t\\t\\thookResponseSpan.RecordError(err)\\n   102→\\t\\t\\thookResponseSpan.End()\\n   103→\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n   104→\\t\\t}\\n   105→\\t}\\n   106→\\thookResponseSpan.End()\\n   107→\\n   108→\\t// Store model hint if the agent provided model info on SessionStart\\n   109→\\tif event.Model != \\\"\\\" {\\n   110→\\t\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n   111→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint on session start\\\",\\n   112→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   113→\\t\\t}\\n   114→\\t}\\n   115→\\n   116→\\t// Fire EventSessionStart for the current session (if state exists).\\n   117→\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n   118→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n   119→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   120→\\t} else if state != nil {\\n   121→\\t\\tpersistEventMetadataToState(event, state)\\n   122→\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   123→\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n   124→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   125→\\t\\t}\\n   126→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   127→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n   128→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   129→\\t\\t}\\n   130→\\t}\\n   131→\\n   132→\\treturn nil\\n   133→}\\n   134→\\n   135→// handleLifecycleModelUpdate persists the model name for the current session.\\n   136→//\\n   137→// If the session state file already exists (e.g., Gemini's BeforeModel fires\\n   138→// after TurnStart), the model is written directly to state.ModelName — no hint\\n   139→// file needed. Otherwise falls back to StoreModelHint for cross-process\\n   140→// persistence (see its doc comment for the full rationale).\\n   141→func handleLifecycleModelUpdate(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   142→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   143→\\tlogging.Info(logCtx, \\\"model-update\\\",\\n   144→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   145→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   146→\\t)\\n   147→\\n   148→\\tif event.SessionID == \\\"\\\" || event.Model == \\\"\\\" {\\n   149→\\t\\treturn nil\\n   150→\\t}\\n   151→\\n   152→\\t// Prefer writing directly to session state when it exists\\n   153→\\tstate, loadErr := strategy.LoadSessionState(ctx, event.SessionID)\\n   154→\\tif loadErr != nil {\\n   155→\\t\\tlogging.Debug(logCtx, \\\"could not load session state for model update, using hint file\\\",\\n   156→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   157→\\t}\\n   158→\\tif loadErr == nil && state != nil {\\n   159→\\t\\tstate.ModelName = event.Model\\n   160→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   161→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state with model\\\",\\n   162→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   163→\\t\\t}\\n   164→\\t\\treturn nil\\n   165→\\t}\\n   166→\\n   167→\\t// State doesn't exist yet (or failed to load) — use hint file (see StoreModelHint doc)\\n   168→\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n   169→\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint\\\",\\n   170→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   171→\\t}\\n   172→\\n   173→\\treturn nil\\n   174→}\\n   175→\\n   176→// handleLifecycleFileEdit appends a file path to the session's tracking file.\\n   177→// This is intentionally lightweight — no JSON state loading, just a file append.\\n   178→func handleLifecycleFileEdit(ctx context.Context, _ agent.Agent, event *agent.Event) error {\\n   179→\\tif event.SessionID == \\\"\\\" || event.FilePath == \\\"\\\" {\\n   180→\\t\\treturn nil\\n   181→\\t}\\n   182→\\n   183→\\t// Normalize to repo-relative path\\n   184→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   185→\\tif err != nil {\\n   186→\\t\\treturn nil //nolint:nilerr // can't normalize path outside git repo, skip silently\\n   187→\\t}\\n   188→\\n   189→\\trelPath := paths.ToRelativePath(event.FilePath, repoRoot)\\n   190→\\tif relPath == \\\"\\\" {\\n   191→\\t\\treturn nil // path outside repo, skip\\n   192→\\t}\\n   193→\\n   194→\\tstore, err := session.NewStateStore(ctx)\\n   195→\\tif err != nil {\\n   196→\\t\\treturn nil //nolint:nilerr // can't access state store, skip silently\\n   197→\\t}\\n   198→\\n   199→\\tif appendErr := store.AppendFileTouched(ctx, event.SessionID, relPath); appendErr != nil {\\n   200→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   201→\\t\\tlogging.Warn(logCtx, \\\"failed to track file edit\\\",\\n   202→\\t\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   203→\\t\\t\\tslog.String(\\\"file_path\\\", relPath),\\n   204→\\t\\t\\tslog.String(\\\"error\\\", appendErr.Error()),\\n   205→\\t\\t)\\n   206→\\t}\\n   207→\\n   208→\\treturn nil\\n   209→}\\n   210→\\n   211→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   212→// ensures strategy setup, initializes session.\\n   213→func handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   214→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   215→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   216→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   217→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   218→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   219→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   220→\\t)\\n   221→\\n   222→\\tsessionID := event.SessionID\\n   223→\\tif sessionID == \\\"\\\" {\\n   224→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   225→\\t}\\n   226→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   227→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   228→\\t}\\n   229→\\n   230→\\t// Fill model from hint file if the agent didn't provide it on this hook\\n   231→\\tif event.Model == \\\"\\\" {\\n   232→\\t\\tif hint := strategy.LoadModelHint(ctx, sessionID); hint != \\\"\\\" {\\n   233→\\t\\t\\tevent.Model = hint\\n   234→\\t\\t\\tlogging.Debug(logCtx, \\\"loaded model from hint file\\\",\\n   235→\\t\\t\\t\\tslog.String(\\\"model\\\", hint))\\n   236→\\t\\t}\\n   237→\\t}\\n   238→\\n   239→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   240→\\t_, captureSpan := perf.Start(ctx, \\\"capture_pre_prompt_state\\\")\\n   241→\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n   242→\\t\\tcaptureSpan.RecordError(err)\\n   243→\\t\\tcaptureSpan.End()\\n   244→\\t\\treturn err\\n   245→\\t}\\n   246→\\tcaptureSpan.End()\\n   247→\\n   248→\\t// Append prompt to prompt.txt on filesystem so it's available for\\n   249→\\t// mid-turn commits (before SaveStep writes it to the shadow branch).\\n   250→\\t// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\" to support multiple turns.\\n   251→\\tif event.Prompt != \\\"\\\" {\\n   252→\\t\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   253→\\t\\tif sessionDirAbs, absErr := paths.AbsPath(ctx, sessionDir); absErr == nil {\\n   254→\\t\\t\\tif mkErr := os.MkdirAll(sessionDirAbs, 0o750); mkErr == nil {\\n   255→\\t\\t\\t\\tpromptPath := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   256→\\t\\t\\t\\texisting, readErr := os.ReadFile(promptPath) //nolint:gosec // session metadata path\\n   257→\\t\\t\\t\\tvar content string\\n   258→\\t\\t\\t\\tif readErr == nil && len(existing) > 0 {\\n   259→\\t\\t\\t\\t\\tcontent = string(existing) + \\\"\\\\n\\\\n---\\\\n\\\\n\\\" + event.Prompt\\n   260→\\t\\t\\t\\t} else {\\n   261→\\t\\t\\t\\t\\tcontent = event.Prompt\\n   262→\\t\\t\\t\\t}\\n   263→\\t\\t\\t\\tif writeErr := os.WriteFile(promptPath, []byte(content), 0o600); writeErr != nil {\\n   264→\\t\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to write prompt.txt\\\",\\n   265→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", writeErr.Error()))\\n   266→\\t\\t\\t\\t}\\n   267→\\t\\t\\t}\\n   268→\\t\\t}\\n   269→\\t}\\n   270→\\n   271→\\t// Ensure strategy setup and initialize session\\n   272→\\t_, initSpan := perf.Start(ctx, \\\"init_session\\\")\\n   273→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   274→\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n   275→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   276→\\t}\\n   277→\\n   278→\\tstrat := GetStrategy(ctx)\\n   279→\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt, event.Model); err != nil {\\n   280→\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n   281→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   282→\\t}\\n   283→\\tinitSpan.End()\\n   284→\\n   285→\\treturn nil\\n   286→}\\n   287→\\n   288→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   289→// detects file changes, saves step + checkpoint, transitions phase.\\n   290→//\\n   291→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   292→func handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   293→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   294→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   295→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   296→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   297→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   298→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   299→\\t)\\n   300→\\n   301→\\tsessionID := event.SessionID\\n   302→\\tif sessionID == \\\"\\\" {\\n   303→\\t\\tsessionID = unknownSessionID\\n   304→\\t}\\n   305→\\n   306→\\t// Fill model from hint file if the agent didn't provide it on this hook\\n   307→\\tif event.Model == \\\"\\\" && sessionID != unknownSessionID {\\n   308→\\t\\tif hint := strategy.LoadModelHint(ctx, sessionID); hint != \\\"\\\" {\\n   309→\\t\\t\\tevent.Model = hint\\n   310→\\t\\t\\tlogging.Debug(logCtx, \\\"loaded model from hint file\\\",\\n   311→\\t\\t\\t\\tslog.String(\\\"model\\\", hint))\\n   312→\\t\\t}\\n   313→\\t}\\n   314→\\n   315→\\ttranscriptRef := event.SessionRef\\n   316→\\tif transcriptRef == \\\"\\\" {\\n   317→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   318→\\t}\\n   319→\\n   320→\\t// If agent implements TranscriptPreparer, materialize the transcript file.\\n   321→\\t// This must run BEFORE fileExists: agents like OpenCode lazily fetch transcripts\\n   322→\\t// via `opencode export`, so the file doesn't exist until PrepareTranscript creates it.\\n   323→\\t// Claude Code's PrepareTranscript just flushes (always succeeds). Agents without\\n   324→\\t// TranscriptPreparer (Gemini, Droid) are unaffected.\\n   325→\\t_, prepareSpan := perf.Start(ctx, \\\"prepare_and_validate_transcript\\\")\\n   326→\\tif preparer, ok := agent.AsTranscriptPreparer(ag); ok {\\n   327→\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n   328→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n   329→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   330→\\t\\t}\\n   331→\\t}\\n   332→\\n   333→\\tif !fileExists(transcriptRef) {\\n   334→\\t\\tprepareSpan.RecordError(fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef))\\n   335→\\t\\tprepareSpan.End()\\n   336→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   337→\\t}\\n   338→\\n   339→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   340→\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n   341→\\t\\tprepareSpan.RecordError(strategy.ErrEmptyRepository)\\n   342→\\t\\tprepareSpan.End()\\n   343→\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n   344→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   345→\\t}\\n   346→\\tprepareSpan.End()\\n   347→\\n   348→\\t// Create session metadata directory\\n   349→\\t_, copySpan := perf.Start(ctx, \\\"copy_transcript\\\")\\n   350→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   351→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   352→\\tif err != nil {\\n   353→\\t\\tsessionDirAbs = sessionDir\\n   354→\\t}\\n   355→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   356→\\t\\tcopySpan.RecordError(err)\\n   357→\\t\\tcopySpan.End()\\n   358→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   359→\\t}\\n   360→\\n   361→\\t// Copy transcript to session directory\\n   362→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   363→\\tif err != nil {\\n   364→\\t\\tcopySpan.RecordError(err)\\n   365→\\t\\tcopySpan.End()\\n   366→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   367→\\t}\\n   368→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   369→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   370→\\t\\tcopySpan.RecordError(err)\\n   371→\\t\\tcopySpan.End()\\n   372→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   373→\\t}\\n   374→\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n   375→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n   376→\\tcopySpan.End()\\n   377→\\n   378→\\t// Load pre-prompt state (captured on TurnStart)\\n   379→\\t_, extractSpan := perf.Start(ctx, \\\"extract_metadata\\\")\\n   380→\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n   381→\\tif err != nil {\\n   382→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n   383→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   384→\\t}\\n   385→\\n   386→\\t// Determine transcript offset\\n   387→\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n   388→\\n   389→\\t// Compute subagents directory for agents that support subagent extraction.\\n   390→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   391→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   392→\\n   393→\\t// Extract metadata via agent interface (modified files)\\n   394→\\tvar modifiedFiles []string\\n   395→\\n   396→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok {\\n   397→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   398→\\t\\tif subagentExtractor, subOk := agent.AsSubagentAwareExtractor(ag); subOk {\\n   399→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n   400→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n   401→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   402→\\t\\t\\t} else {\\n   403→\\t\\t\\t\\tmodifiedFiles = files\\n   404→\\t\\t\\t}\\n   405→\\t\\t} else {\\n   406→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   407→\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   408→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n   409→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   410→\\t\\t\\t} else {\\n   411→\\t\\t\\t\\tmodifiedFiles = files\\n   412→\\t\\t\\t}\\n   413→\\t\\t}\\n   414→\\t}\\n   415→\\textractSpan.End()\\n   416→\\n   417→\\t// Generate commit message from last prompt (read from session state, set at TurnStart)\\n   418→\\t_, commitMsgSpan := perf.Start(ctx, \\\"generate_commit_message\\\")\\n   419→\\tlastPrompt := \\\"\\\"\\n   420→\\tif sessionState, stateErr := strategy.LoadSessionState(ctx, sessionID); stateErr == nil && sessionState != nil {\\n   421→\\t\\tlastPrompt = sessionState.LastPrompt\\n   422→\\t}\\n   423→\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n   424→\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n   425→\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n   426→\\tcommitMsgSpan.End()\\n   427→\\n   428→\\t// Get worktree root for path normalization\\n   429→\\t_, detectSpan := perf.Start(ctx, \\\"detect_file_changes\\\")\\n   430→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   431→\\tif err != nil {\\n   432→\\t\\tdetectSpan.RecordError(err)\\n   433→\\t\\tdetectSpan.End()\\n   434→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   435→\\t}\\n   436→\\n   437→\\tvar preUntrackedFiles []string\\n   438→\\tif preState != nil {\\n   439→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n   440→\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n   441→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   442→\\t}\\n   443→\\n   444→\\t// Detect file changes via git status\\n   445→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   446→\\tif err != nil {\\n   447→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   448→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   449→\\t}\\n   450→\\tdetectSpan.End()\\n   451→\\n   452→\\t// Filter and normalize all paths\\n   453→\\t_, normalizeSpan := perf.Start(ctx, \\\"filter_and_normalize_paths\\\")\\n   454→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   455→\\tvar relNewFiles, relDeletedFiles []string\\n   456→\\tif changes != nil {\\n   457→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   458→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   459→\\n   460→\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n   461→\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n   462→\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n   463→\\t\\t// Git status catches any tracked file with working-tree changes.\\n   464→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   465→\\t}\\n   466→\\n   467→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   468→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   469→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   470→\\t// if it exists in HEAD with the same content as the working tree.\\n   471→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   472→\\tnormalizeSpan.End()\\n   473→\\n   474→\\t// Check if there are any changes\\n   475→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   476→\\tif totalChanges == 0 {\\n   477→\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n   478→\\t\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n   479→\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   480→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   481→\\t\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   482→\\t\\t}\\n   483→\\t\\treturn nil\\n   484→\\t}\\n   485→\\n   486→\\t// Log file changes\\n   487→\\tlogFileChanges(ctx, relModifiedFiles, relNewFiles, relDeletedFiles)\\n   488→\\n   489→\\t// Get git author\\n   490→\\tauthor, err := GetGitAuthor(ctx)\\n   491→\\tif err != nil {\\n   492→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   493→\\t}\\n   494→\\n   495→\\t// Get strategy and agent type\\n   496→\\tstrat := GetStrategy(ctx)\\n   497→\\tagentType := ag.Type()\\n   498→\\n   499→\\t// Get transcript position/identifier from pre-prompt state\\n   500→\\tvar transcriptIdentifierAtStart string\\n   501→\\tvar transcriptLinesAtStart int\\n   502→\\tif preState != nil {\\n   503→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   504→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   505→\\t}\\n   506→\\n   507→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   508→\\ttokenUsage := agent.CalculateTokenUsage(ctx, ag, transcriptData, transcriptLinesAtStart, subagentsDir)\\n   509→\\n   510→\\t// Build fully-populated step context and delegate to strategy\\n   511→\\tstepCtx := strategy.StepContext{\\n   512→\\t\\tSessionID:                sessionID,\\n   513→\\t\\tModifiedFiles:            relModifiedFiles,\\n   514→\\t\\tNewFiles:                 relNewFiles,\\n   515→\\t\\tDeletedFiles:             relDeletedFiles,\\n   516→\\t\\tMetadataDir:              sessionDir,\\n   517→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   518→\\t\\tCommitMessage:            commitMessage,\\n   519→\\t\\tTranscriptPath:           transcriptRef,\\n   520→\\t\\tAuthorName:               author.Name,\\n   521→\\t\\tAuthorEmail:              author.Email,\\n   522→\\t\\tAgentType:                agentType,\\n   523→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   524→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   525→\\t\\tTokenUsage:               tokenUsage,\\n   526→\\t}\\n   527→\\n   528→\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   529→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   530→\\t}\\n   531→\\n   532→\\t// Transition session phase and cleanup\\n   533→\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n   534→\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   535→\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   536→\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   537→\\t}\\n   538→\\n   539→\\treturn nil\\n   540→}\\n   541→\\n   542→// handleLifecycleCompaction handles context compaction: saves current progress\\n   543→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   544→// Also resets the transcript offset since the transcript may be truncated.\\n   545→func handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   546→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   547→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   548→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   549→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   550→\\t)\\n   551→\\n   552→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   553→\\tsessionID := event.SessionID\\n   554→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   555→\\tif loadErr != nil {\\n   556→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for compaction\\\",\\n   557→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   558→\\t}\\n   559→\\tif sessionState != nil {\\n   560→\\t\\tpersistEventMetadataToState(event, sessionState)\\n   561→\\n   562→\\t\\tif transErr := strategy.TransitionAndLog(ctx, sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   563→\\t\\t\\tlogging.Warn(logCtx, \\\"compaction transition failed\\\",\\n   564→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   565→\\t\\t}\\n   566→\\n   567→\\t\\tif saveErr := strategy.SaveSessionState(ctx, sessionState); saveErr != nil {\\n   568→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to save session state after compaction\\\",\\n   569→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   570→\\t\\t}\\n   571→\\t}\\n   572→\\n   573→\\tlogging.Info(logCtx, \\\"context compaction detected\\\")\\n   574→\\treturn nil\\n   575→}\\n   576→\\n   577→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   578→func handleLifecycleSessionEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   579→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   580→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   581→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   582→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   583→\\t)\\n   584→\\n   585→\\tif event.SessionID == \\\"\\\" {\\n   586→\\t\\treturn nil // No session to update\\n   587→\\t}\\n   588→\\n   589→\\t// Note: We intentionally don't clean up cached transcripts here.\\n   590→\\t// Post-session commits (carry-forward in ENDED phase) may still need\\n   591→\\t// the transcript to extract file changes. Cleanup is handled by\\n   592→\\t// `entire clean` or when the session state is fully removed.\\n   593→\\n   594→\\tif err := markSessionEnded(ctx, event, event.SessionID); err != nil {\\n   595→\\t\\tlogging.Warn(logCtx, \\\"failed to mark session ended\\\",\\n   596→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   597→\\t}\\n   598→\\treturn nil\\n   599→}\\n   600→\\n   601→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   602→func handleLifecycleSubagentStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   603→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   604→\\tlogging.Info(logCtx, \\\"subagent started\\\",\\n   605→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   606→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   607→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   608→\\t\\tslog.String(\\\"transcript\\\", event.SessionRef),\\n   609→\\t)\\n   610→\\n   611→\\t// Capture pre-task state\\n   612→\\tif err := CapturePreTaskState(ctx, event.ToolUseID); err != nil {\\n   613→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   614→\\t}\\n   615→\\n   616→\\treturn nil\\n   617→}\\n   618→\\n   619→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   620→func handleLifecycleSubagentEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   621→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   622→\\tif event.SubagentType == \\\"\\\" && event.TaskDescription == \\\"\\\" {\\n   623→\\t\\t// Extract subagent type and description from tool input\\n   624→\\t\\tevent.SubagentType, event.TaskDescription = ParseSubagentTypeAndDescription(event.ToolInput)\\n   625→\\t}\\n   626→\\n   627→\\t// Determine subagent transcript path\\n   628→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   629→\\tvar subagentTranscriptPath string\\n   630→\\tif event.SubagentID != \\\"\\\" {\\n   631→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   632→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   633→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   634→\\t\\t}\\n   635→\\t}\\n   636→\\n   637→\\t// Log context\\n   638→\\tsubagentEndAttrs := []any{\\n   639→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   640→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   641→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   642→\\t}\\n   643→\\tif event.SubagentID != \\\"\\\" {\\n   644→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"agent_id\\\", event.SubagentID))\\n   645→\\t}\\n   646→\\tif subagentTranscriptPath != \\\"\\\" {\\n   647→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"subagent_transcript\\\", subagentTranscriptPath))\\n   648→\\t}\\n   649→\\tlogging.Info(logCtx, \\\"subagent completed\\\", subagentEndAttrs...)\\n   650→\\n   651→\\t// Extract modified files from hook payload and/or subagent transcript\\n   652→\\tvar modifiedFiles []string\\n   653→\\tmodifiedFiles = append(modifiedFiles, event.ModifiedFiles...)\\n   654→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok {\\n   655→\\t\\ttranscriptToScan := event.SessionRef\\n   656→\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n   657→\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n   658→\\t\\t}\\n   659→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n   660→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files from subagent\\\",\\n   661→\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   662→\\t\\t} else {\\n   663→\\t\\t\\tmodifiedFiles = mergeUnique(modifiedFiles, files)\\n   664→\\t\\t}\\n   665→\\t}\\n   666→\\n   667→\\t// Load pre-task state and detect file changes.\\n   668→\\t// If no pre-task state exists (agent doesn't support pre-task hook), fall back\\n   669→\\t// to the session's pre-prompt state. Without either, DetectFileChanges receives\\n   670→\\t// nil and treats ALL untracked files as new — which would create spurious task\\n   671→\\t// checkpoints for pre-existing untracked files (e.g., .github/hooks/entire.json).\\n   672→\\tpreState, err := LoadPreTaskState(ctx, event.ToolUseID)\\n   673→\\tif err != nil {\\n   674→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-task state\\\",\\n   675→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   676→\\t}\\n   677→\\tvar preUntrackedFiles []string\\n   678→\\tif preState != nil {\\n   679→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   680→\\t}\\n   681→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   682→\\tif err != nil {\\n   683→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   684→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   685→\\t}\\n   686→\\n   687→\\t// Get worktree root and normalize paths\\n   688→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   689→\\tif err != nil {\\n   690→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   691→\\t}\\n   692→\\n   693→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   694→\\tvar relNewFiles, relDeletedFiles []string\\n   695→\\tif changes != nil {\\n   696→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   697→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   698→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   699→\\t}\\n   700→\\n   701→\\t// If no changes, skip\\n   702→\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n   703→\\t\\tlogging.Info(logCtx, \\\"no file changes detected, skipping task checkpoint\\\")\\n   704→\\t\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   705→\\t\\treturn nil\\n   706→\\t}\\n   707→\\n   708→\\t// Find checkpoint UUID from main transcript (best-effort)\\n   709→\\tvar checkpointUUID string\\n   710→\\t// Use the existing CLI-level checkpoint UUID finder\\n   711→\\tmainLines, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n   712→\\tif mainLines != nil {\\n   713→\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n   714→\\t}\\n   715→\\n   716→\\t// Get git author\\n   717→\\tauthor, err := GetGitAuthor(ctx)\\n   718→\\tif err != nil {\\n   719→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   720→\\t}\\n   721→\\n   722→\\t// Build task checkpoint context\\n   723→\\tstrat := GetStrategy(ctx)\\n   724→\\tagentType := ag.Type()\\n   725→\\n   726→\\ttaskStepCtx := strategy.TaskStepContext{\\n   727→\\t\\tSessionID:              event.SessionID,\\n   728→\\t\\tToolUseID:              event.ToolUseID,\\n   729→\\t\\tAgentID:                event.SubagentID,\\n   730→\\t\\tModifiedFiles:          relModifiedFiles,\\n   731→\\t\\tNewFiles:               relNewFiles,\\n   732→\\t\\tDeletedFiles:           relDeletedFiles,\\n   733→\\t\\tTranscriptPath:         event.SessionRef,\\n   734→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   735→\\t\\tCheckpointUUID:         checkpointUUID,\\n   736→\\t\\tAuthorName:             author.Name,\\n   737→\\t\\tAuthorEmail:            author.Email,\\n   738→\\t\\tSubagentType:           event.SubagentType,\\n   739→\\t\\tTaskDescription:        event.TaskDescription,\\n   740→\\t\\tAgentType:              agentType,\\n   741→\\t}\\n   742→\\n   743→\\tif err := strat.SaveTaskStep(ctx, taskStepCtx); err != nil {\\n   744→\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n   745→\\t}\\n   746→\\n   747→\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   748→\\treturn nil\\n   749→}\\n   750→\\n   751→// --- Helper functions ---\\n   752→\\n   753→// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n   754→// Prefers pre-prompt state, falls back to session state.\\n   755→func resolveTranscriptOffset(ctx context.Context, preState *PrePromptState, sessionID string) int {\\n   756→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   757→\\tif preState != nil && preState.TranscriptOffset > 0 {\\n   758→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state found, parsing transcript from offset\\\",\\n   759→\\t\\t\\tslog.Int(\\\"offset\\\", preState.TranscriptOffset))\\n   760→\\t\\treturn preState.TranscriptOffset\\n   761→\\t}\\n   762→\\n   763→\\t// Fall back to session state\\n   764→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   765→\\tif loadErr != nil {\\n   766→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state\\\",\\n   767→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   768→\\t\\treturn 0\\n   769→\\t}\\n   770→\\tif sessionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n   771→\\t\\tlogging.Debug(logCtx, \\\"session state found, parsing transcript from offset\\\",\\n   772→\\t\\t\\tslog.Int(\\\"offset\\\", sessionState.CheckpointTranscriptStart))\\n   773→\\t\\treturn sessionState.CheckpointTranscriptStart\\n   774→\\t}\\n   775→\\n   776→\\treturn 0\\n   777→}\\n   778→\\n   779→// parseTranscriptForCheckpointUUID is a thin wrapper around transcript parsing for checkpoint UUID lookup.\\n   780→// Returns parsed transcript lines for use with FindCheckpointUUID.\\n   781→func parseTranscriptForCheckpointUUID(transcriptPath string) ([]transcriptLine, error) {\\n   782→\\tlines, err := transcript.ParseFromFileAtLine(transcriptPath, 0)\\n   783→\\tif err != nil {\\n   784→\\t\\treturn nil, fmt.Errorf(\\\"parsing transcript for checkpoint UUID: %w\\\", err)\\n   785→\\t}\\n   786→\\treturn lines, nil\\n   787→}\\n   788→\\n   789→// transitionSessionTurnEnd transitions the session phase to IDLE and dispatches turn-end actions.\\n   790→func transitionSessionTurnEnd(ctx context.Context, sessionID string, event *agent.Event) {\\n   791→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   792→\\tturnState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   793→\\tif loadErr != nil {\\n   794→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for turn end\\\",\\n   795→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   796→\\t\\treturn\\n   797→\\t}\\n   798→\\tif turnState == nil {\\n   799→\\t\\treturn\\n   800→\\t}\\n   801→\\n   802→\\tpersistEventMetadataToState(event, turnState)\\n   803→\\n   804→\\tif err := strategy.TransitionAndLog(ctx, turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   805→\\t\\tlogging.Warn(logCtx, \\\"turn-end transition failed\\\",\\n   806→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   807→\\t}\\n   808→\\n   809→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   810→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   811→\\tstrat := GetStrategy(ctx)\\n   812→\\tif err := strat.HandleTurnEnd(ctx, turnState); err != nil {\\n   813→\\t\\tlogging.Warn(logCtx, \\\"turn-end action dispatch failed\\\",\\n   814→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   815→\\t}\\n   816→\\n   817→\\tif updateErr := strategy.SaveSessionState(ctx, turnState); updateErr != nil {\\n   818→\\t\\tlogging.Warn(logCtx, \\\"failed to update session phase on turn end\\\",\\n   819→\\t\\t\\tslog.String(\\\"error\\\", updateErr.Error()))\\n   820→\\t}\\n   821→}\\n   822→\\n   823→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   824→// If event is non-nil, hook-provided metrics are persisted to state before saving.\\n   825→func markSessionEnded(ctx context.Context, event *agent.Event, sessionID string) error {\\n   826→\\tstate, err := strategy.LoadSessionState(ctx, sessionID)\\n   827→\\tif err != nil {\\n   828→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   829→\\t}\\n   830→\\tif state == nil {\\n   831→\\t\\treturn nil // No state file, nothing to update\\n   832→\\t}\\n   833→\\n   834→\\tif event != nil {\\n   835→\\t\\tpersistEventMetadataToState(event, state)\\n   836→\\t}\\n   837→\\n   838→\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStop, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   839→\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"lifecycle\\\"), \\\"session stop transition failed\\\",\\n   840→\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   841→\\t}\\n   842→\\n   843→\\tnow := time.Now()\\n   844→\\tstate.EndedAt = &now\\n   845→\\n   846→\\tif err := strategy.SaveSessionState(ctx, state); err != nil {\\n   847→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   848→\\t}\\n   849→\\treturn nil\\n   850→}\\n   851→\\n   852→// logFileChanges logs the files modified, created, and deleted during a session.\\n   853→func logFileChanges(ctx context.Context, modified, newFiles, deleted []string) {\\n   854→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   855→\\tlogging.Debug(logCtx, \\\"files changed during session\\\",\\n   856→\\t\\tslog.Int(\\\"modified\\\", len(modified)),\\n   857→\\t\\tslog.Int(\\\"new\\\", len(newFiles)),\\n   858→\\t\\tslog.Int(\\\"deleted\\\", len(deleted)))\\n   859→}\\n   860→\\n   861→func persistEventMetadataToState(event *agent.Event, state *strategy.SessionState) {\\n   862→\\t// Update ModelName if provided (model is known by turn-end even on first turn)\\n   863→\\tif event.Model != \\\"\\\" {\\n   864→\\t\\tstate.ModelName = event.Model\\n   865→\\t}\\n   866→\\n   867→\\t// Persist hook-provided session metrics (e.g., from Cursor hooks)\\n   868→\\tif event.DurationMs > 0 {\\n   869→\\t\\tstate.SessionDurationMs = event.DurationMs\\n   870→\\t}\\n   871→\\t// Use hook-reported turn count if available (take max); otherwise\\n   872→\\t// increment on each TurnEnd event to count turns ourselves.\\n   873→\\tif event.TurnCount > 0 {\\n   874→\\t\\tif event.TurnCount > state.SessionTurnCount {\\n   875→\\t\\t\\tstate.SessionTurnCount = event.TurnCount\\n   876→\\t\\t}\\n   877→\\t} else if event.Type == agent.TurnEnd {\\n   878→\\t\\tstate.SessionTurnCount++\\n   879→\\t}\\n   880→\\tif event.ContextTokens > 0 {\\n   881→\\t\\tstate.ContextTokens = event.ContextTokens\\n   882→\\t}\\n   883→\\tif event.ContextWindowSize > 0 {\\n   884→\\t\\tstate.ContextWindowSize = event.ContextWindowSize\\n   885→\\t}\\n   886→}\\n   887→\"}]},\"uuid\":\"adebd0d8-fedd-49e8-99ea-b4bdf85908c0\",\"timestamp\":\"2026-03-06T11:36:30.911Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alex/workspace/cli/.worktrees/3/cmd/entire/cli/lifecycle.go\",\"content\":\"// lifecycle.go implements the generic lifecycle event dispatcher.\\n// It routes normalized events from any agent to the appropriate framework actions.\\n//\\n// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n// the dispatcher handles all orchestration: state transitions, strategy calls,\\n// file change detection, metadata generation.\\npackage cli\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n\\t\\\"github.com/entireio/cli/perf\\\"\\n)\\n\\n// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n// Returns nil if the event was handled successfully.\\nfunc DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tif ag == nil {\\n\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n\\t}\\n\\tif event == nil {\\n\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n\\t}\\n\\n\\tswitch event.Type {\\n\\tcase agent.SessionStart:\\n\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n\\tcase agent.TurnStart:\\n\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n\\tcase agent.TurnEnd:\\n\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n\\tcase agent.Compaction:\\n\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n\\tcase agent.SessionEnd:\\n\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n\\tcase agent.SubagentStart:\\n\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n\\tcase agent.SubagentEnd:\\n\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n\\tcase agent.ModelUpdate:\\n\\t\\treturn handleLifecycleModelUpdate(ctx, ag, event)\\n\\tcase agent.FileEdit:\\n\\t\\treturn handleLifecycleFileEdit(ctx, ag, event)\\n\\tdefault:\\n\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n\\t}\\n}\\n\\n// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n// fires state machine transition.\\nfunc handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"session-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t\\tslog.String(\\\"model\\\", event.Model),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Build informational message\\n\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n\\n\\t// Check for concurrent sessions and append count if any\\n\\t_, countSessionsSpan := perf.Start(ctx, \\\"count_active_sessions\\\")\\n\\tstrat := GetStrategy(ctx)\\n\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n\\t}\\n\\tcountSessionsSpan.End()\\n\\n\\t// Output informational message if the agent supports hook responses.\\n\\t// Claude Code reads JSON from stdout; agents that don't implement\\n\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n\\t_, hookResponseSpan := perf.Start(ctx, \\\"write_hook_response\\\")\\n\\tif event.ResponseMessage != \\\"\\\" {\\n\\t\\tmessage = event.ResponseMessage\\n\\t}\\n\\tif writer, ok := agent.AsHookResponseWriter(ag); ok {\\n\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n\\t\\t\\thookResponseSpan.RecordError(err)\\n\\t\\t\\thookResponseSpan.End()\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\thookResponseSpan.End()\\n\\n\\t// Store model hint if the agent provided model info on SessionStart\\n\\tif event.Model != \\\"\\\" {\\n\\t\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint on session start\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\t// Fire EventSessionStart for the current session (if state exists).\\n\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n\\t} else if state != nil {\\n\\t\\tpersistEventMetadataToState(event, state)\\n\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n\\t\\t}\\n\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleModelUpdate persists the model name for the current session.\\n//\\n// If the session state file already exists (e.g., Gemini's BeforeModel fires\\n// after TurnStart), the model is written directly to state.ModelName — no hint\\n// file needed. Otherwise falls back to StoreModelHint for cross-process\\n// persistence (see its doc comment for the full rationale).\\nfunc handleLifecycleModelUpdate(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"model-update\\\",\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"model\\\", event.Model),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" || event.Model == \\\"\\\" {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Prefer writing directly to session state when it exists\\n\\tstate, loadErr := strategy.LoadSessionState(ctx, event.SessionID)\\n\\tif loadErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"could not load session state for model update, using hint file\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n\\t}\\n\\tif loadErr == nil && state != nil {\\n\\t\\tstate.ModelName = event.Model\\n\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state with model\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// State doesn't exist yet (or failed to load) — use hint file (see StoreModelHint doc)\\n\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleFileEdit appends a file path to the session's tracking file.\\n// This is intentionally lightweight — no JSON state loading, just a file append.\\nfunc handleLifecycleFileEdit(ctx context.Context, _ agent.Agent, event *agent.Event) error {\\n\\tif event.SessionID == \\\"\\\" || event.FilePath == \\\"\\\" {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Normalize to repo-relative path\\n\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // can't normalize path outside git repo, skip silently\\n\\t}\\n\\n\\trelPath := paths.ToRelativePath(event.FilePath, repoRoot)\\n\\tif relPath == \\\"\\\" {\\n\\t\\treturn nil // path outside repo, skip\\n\\t}\\n\\n\\tstore, err := session.NewStateStore(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // can't access state store, skip silently\\n\\t}\\n\\n\\tif appendErr := store.AppendFileTouched(ctx, event.SessionID, relPath); appendErr != nil {\\n\\t\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n\\t\\tlogging.Warn(logCtx, \\\"failed to track file edit\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\t\\tslog.String(\\\"file_path\\\", relPath),\\n\\t\\t\\tslog.String(\\\"error\\\", appendErr.Error()),\\n\\t\\t)\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n// ensures strategy setup, initializes session.\\nfunc handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t\\tslog.String(\\\"model\\\", event.Model),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Fill model from hint file if the agent didn't provide it on this hook\\n\\tif event.Model == \\\"\\\" {\\n\\t\\tif hint := strategy.LoadModelHint(ctx, sessionID); hint != \\\"\\\" {\\n\\t\\t\\tevent.Model = hint\\n\\t\\t\\tlogging.Debug(logCtx, \\\"loaded model from hint file\\\",\\n\\t\\t\\t\\tslog.String(\\\"model\\\", hint))\\n\\t\\t}\\n\\t}\\n\\n\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n\\t_, captureSpan := perf.Start(ctx, \\\"capture_pre_prompt_state\\\")\\n\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n\\t\\tcaptureSpan.RecordError(err)\\n\\t\\tcaptureSpan.End()\\n\\t\\treturn err\\n\\t}\\n\\tcaptureSpan.End()\\n\\n\\t// Append prompt to prompt.txt on filesystem so it's available for\\n\\t// mid-turn commits (before SaveStep writes it to the shadow branch).\\n\\t// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\" to support multiple turns.\\n\\tif event.Prompt != \\\"\\\" {\\n\\t\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\t\\tif sessionDirAbs, absErr := paths.AbsPath(ctx, sessionDir); absErr == nil {\\n\\t\\t\\tif mkErr := os.MkdirAll(sessionDirAbs, 0o750); mkErr == nil {\\n\\t\\t\\t\\tpromptPath := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n\\t\\t\\t\\texisting, readErr := os.ReadFile(promptPath) //nolint:gosec // session metadata path\\n\\t\\t\\t\\tvar content string\\n\\t\\t\\t\\tif readErr == nil && len(existing) > 0 {\\n\\t\\t\\t\\t\\tcontent = string(existing) + \\\"\\\\n\\\\n---\\\\n\\\\n\\\" + event.Prompt\\n\\t\\t\\t\\t} else {\\n\\t\\t\\t\\t\\tcontent = event.Prompt\\n\\t\\t\\t\\t}\\n\\t\\t\\t\\tif writeErr := os.WriteFile(promptPath, []byte(content), 0o600); writeErr != nil {\\n\\t\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to write prompt.txt\\\",\\n\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", writeErr.Error()))\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Ensure strategy setup and initialize session\\n\\t_, initSpan := perf.Start(ctx, \\\"init_session\\\")\\n\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\tstrat := GetStrategy(ctx)\\n\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt, event.Model); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\tinitSpan.End()\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n// detects file changes, saves step + checkpoint, transitions phase.\\n//\\n//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\nfunc handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t\\tslog.String(\\\"model\\\", event.Model),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\tsessionID = unknownSessionID\\n\\t}\\n\\n\\t// Fill model from hint file if the agent didn't provide it on this hook\\n\\tif event.Model == \\\"\\\" && sessionID != unknownSessionID {\\n\\t\\tif hint := strategy.LoadModelHint(ctx, sessionID); hint != \\\"\\\" {\\n\\t\\t\\tevent.Model = hint\\n\\t\\t\\tlogging.Debug(logCtx, \\\"loaded model from hint file\\\",\\n\\t\\t\\t\\tslog.String(\\\"model\\\", hint))\\n\\t\\t}\\n\\t}\\n\\n\\ttranscriptRef := event.SessionRef\\n\\tif transcriptRef == \\\"\\\" {\\n\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n\\t}\\n\\n\\t// If agent implements TranscriptPreparer, materialize the transcript file.\\n\\t// This must run BEFORE fileExists: agents like OpenCode lazily fetch transcripts\\n\\t// via `opencode export`, so the file doesn't exist until PrepareTranscript creates it.\\n\\t// Claude Code's PrepareTranscript just flushes (always succeeds). Agents without\\n\\t// TranscriptPreparer (Gemini, Droid) are unaffected.\\n\\t_, prepareSpan := perf.Start(ctx, \\\"prepare_and_validate_transcript\\\")\\n\\tif preparer, ok := agent.AsTranscriptPreparer(ag); ok {\\n\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\tif !fileExists(transcriptRef) {\\n\\t\\tprepareSpan.RecordError(fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef))\\n\\t\\tprepareSpan.End()\\n\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n\\t}\\n\\n\\t// Early check: bail out quickly if the repo has no commits yet.\\n\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n\\t\\tprepareSpan.RecordError(strategy.ErrEmptyRepository)\\n\\t\\tprepareSpan.End()\\n\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n\\t}\\n\\tprepareSpan.End()\\n\\n\\t// Create session metadata directory\\n\\t_, copySpan := perf.Start(ctx, \\\"copy_transcript\\\")\\n\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n\\tif err != nil {\\n\\t\\tsessionDirAbs = sessionDir\\n\\t}\\n\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n\\t\\tcopySpan.RecordError(err)\\n\\t\\tcopySpan.End()\\n\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n\\t}\\n\\n\\t// Copy transcript to session directory\\n\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n\\tif err != nil {\\n\\t\\tcopySpan.RecordError(err)\\n\\t\\tcopySpan.End()\\n\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n\\t}\\n\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n\\t\\tcopySpan.RecordError(err)\\n\\t\\tcopySpan.End()\\n\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n\\tcopySpan.End()\\n\\n\\t// Load pre-prompt state (captured on TurnStart)\\n\\t_, extractSpan := perf.Start(ctx, \\\"extract_metadata\\\")\\n\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\t// Determine transcript offset\\n\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n\\n\\t// Compute subagents directory for agents that support subagent extraction.\\n\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n\\n\\t// Extract metadata via agent interface (modified files)\\n\\tvar modifiedFiles []string\\n\\n\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok {\\n\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n\\t\\tif subagentExtractor, subOk := agent.AsSubagentAwareExtractor(ag); subOk {\\n\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t}\\n\\t\\t} else {\\n\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\textractSpan.End()\\n\\n\\t// Generate commit message from last prompt (read from session state, set at TurnStart)\\n\\t_, commitMsgSpan := perf.Start(ctx, \\\"generate_commit_message\\\")\\n\\tlastPrompt := \\\"\\\"\\n\\tif sessionState, stateErr := strategy.LoadSessionState(ctx, sessionID); stateErr == nil && sessionState != nil {\\n\\t\\tlastPrompt = sessionState.LastPrompt\\n\\t}\\n\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n\\tcommitMsgSpan.End()\\n\\n\\t// Get worktree root for path normalization\\n\\t_, detectSpan := perf.Start(ctx, \\\"detect_file_changes\\\")\\n\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n\\tif err != nil {\\n\\t\\tdetectSpan.RecordError(err)\\n\\t\\tdetectSpan.End()\\n\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n\\t}\\n\\n\\tvar preUntrackedFiles []string\\n\\tif preState != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n\\t}\\n\\n\\t// Detect file changes via git status\\n\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\tdetectSpan.End()\\n\\n\\t// Filter and normalize all paths\\n\\t_, normalizeSpan := perf.Start(ctx, \\\"filter_and_normalize_paths\\\")\\n\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n\\tvar relNewFiles, relDeletedFiles []string\\n\\tif changes != nil {\\n\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n\\n\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n\\t\\t// Git status catches any tracked file with working-tree changes.\\n\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n\\t}\\n\\n\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n\\t// if it exists in HEAD with the same content as the working tree.\\n\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n\\tnormalizeSpan.End()\\n\\n\\t// Check if there are any changes\\n\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n\\tif totalChanges == 0 {\\n\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n\\t\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Log file