ng %d sessions from checkpoint:\\\\\\\\n\\\\\\\", totalSessions)\\\\n   619→\\\\t}\\\\n   620→\\\\n   621→\\\\t// Restore all sessions (oldest to newest, using 0-based indexing)\\\\n   622→\\\\tvar restored []RestoredSession\\\\n   623→\\\\tfor i := range totalSessions {\\\\n   624→\\\\t\\\\tcontent, readErr := store.ReadSessionContent(context.Background(), point.CheckpointID, i)\\\\n   625→\\\\t\\\\tif readErr != nil {\\\\n   626→\\\\t\\\\t\\\\tfmt.Fprintf(os.Stderr, \\\\\\\"  Warning: failed to read session %d: %v\\\\\\\\n\\\\\\\", i, readErr)\\\\n   627→\\\\t\\\\t\\\\tcontinue\\\\n   628→\\\\t\\\\t}\\\\n   629→\\\\t\\\\tif content == nil || len(content.Transcript) == 0 {\\\\n   630→\\\\t\\\\t\\\\tcontinue\\\\n   631→\\\\t\\\\t}\\\\n   632→\\\\n   633→\\\\t\\\\tsessionID := content.Metadata.SessionID\\\\n   634→\\\\t\\\\tif sessionID == \\\\\\\"\\\\\\\" {\\\\n   635→\\\\t\\\\t\\\\tfmt.Fprintf(os.Stderr, \\\\\\\"  Warning: session %d has no session ID, skipping\\\\\\\\n\\\\\\\", i)\\\\n   636→\\\\t\\\\t\\\\tcontinue\\\\n   637→\\\\t\\\\t}\\\\n   638→\\\\n   639→\\\\t\\\\t// Resolve per-session agent from metadata — skip if agent is unknown\\\\n   640→\\\\t\\\\tif content.Metadata.Agent == \\\\\\\"\\\\\\\" {\\\\n   641→\\\\t\\\\t\\\\tfmt.Fprintf(os.Stderr, \\\\\\\"  Warning: session %d (%s) has no agent metadata, skipping (cannot determine target directory)\\\\\\\\n\\\\\\\", i, sessionID)\\\\n   642→\\\\t\\\\t\\\\tcontinue\\\\n   643→\\\\t\\\\t}\\\\n   644→\\\\t\\\\tsessionAgent, agErr := ResolveAgentForRewind(content.Metadata.Agent)\\\\n   645→\\\\t\\\\tif agErr != nil {\\\\n   646→\\\\t\\\\t\\\\tfmt.Fprintf(os.Stderr, \\\\\\\"  Warning: session %d (%s) has unknown agent %q, skipping\\\\\\\\n\\\\\\\", i, sessionID, content.Metadata.Agent)\\\\n   647→\\\\t\\\\t\\\\tcontinue\\\\n   648→\\\\t\\\\t}\\\\n   649→\\\\n   650→\\\\t\\\\t// Compute transcript path from current repo location for cross-machine portability.\\\\n   651→\\\\t\\\\tsessionAgentDir, dirErr := sessionAgent.GetSessionDir(repoRoot)\\\\n   652→\\\\t\\\\tif dirErr != nil {\\\\n   653→\\\\t\\\\t\\\\tfmt.Fprintf(os.Stderr, \\\\\\\"  Warning: failed to get session dir for session %d: %v\\\\\\\\n\\\\\\\", i, dirErr)\\\\n   654→\\\\t\\\\t\\\\tcontinue\\\\n   655→\\\\t\\\\t}\\\\n   656→\\\\t\\\\tsessionFile := sessionAgent.ResolveSessionFile(sessionAgentDir, sessionID)\\\\n   657→\\\\n   658→\\\\t\\\\t// Get first prompt for display\\\\n   659→\\\\t\\\\tpromptPreview := ExtractFirstPrompt(content.Prompts)\\\\n   660→\\\\n   661→\\\\t\\\\tif totalSessions > 1 {\\\\n   662→\\\\t\\\\t\\\\tisLatest := i == totalSessions-1\\\\n   663→\\\\t\\\\t\\\\tif promptPreview != \\\\\\\"\\\\\\\" {\\\\n   664→\\\\t\\\\t\\\\t\\\\tif isLatest {\\\\n   665→\\\\t\\\\t\\\\t\\\\t\\\\tfmt.Fprintf(os.Stderr, \\\\\\\"  Session %d (latest): %s\\\\\\\\n\\\\\\\", i+1, promptPreview)\\\\n   666→\\\\t\\\\t\\\\t\\\\t} else {\\\\n   667→\\\\t\\\\t\\\\t\\\\t\\\\tfmt.Fprintf(os.Stderr, \\\\\\\"  Session %d: %s\\\\\\\\n\\\\\\\", i+1, promptPreview)\\\\n   668→\\\\t\\\\t\\\\t\\\\t}\\\\n   669→\\\\t\\\\t\\\\t}\\\\n   670→\\\\t\\\\t\\\\tfmt.Fprintf(os.Stderr, \\\\\\\"    Writing to: %s\\\\\\\\n\\\\\\\", sessionFile)\\\\n   671→\\\\t\\\\t} else {\\\\n   672→\\\\t\\\\t\\\\tfmt.Fprintf(os.Stderr, \\\\\\\"Writing transcript to: %s\\\\\\\\n\\\\\\\", sessionFile)\\\\n   673→\\\\t\\\\t}\\\\n   674→\\\\n   675→\\\\t\\\\t// Ensure parent directory exists (session file may be in a different dir than sessionAgentDir)\\\\n   676→\\\\t\\\\tif mkdirErr := os.MkdirAll(filepath.Dir(sessionFile), 0o750); mkdirErr != nil {\\\\n   677→\\\\t\\\\t\\\\tfmt.Fprintf(os.Stderr, \\\\\\\"    Warning: failed to create directory: %v\\\\\\\\n\\\\\\\", mkdirErr)\\\\n   678→\\\\t\\\\t\\\\tcontinue\\\\n   679→\\\\t\\\\t}\\\\n   680→\\\\n   681→\\\\t\\\\tif writeErr := os.WriteFile(sessionFile, content.Transcript, 0o600); writeErr != nil {\\\\n   682→\\\\t\\\\t\\\\tif totalSessions > 1 {\\\\n   683→\\\\t\\\\t\\\\t\\\\tfmt.Fprintf(os.Stderr, \\\\\\\"    Warning: failed to write transcript: %v\\\\\\\\n\\\\\\\", writeErr)\\\\n   684→\\\\t\\\\t\\\\t\\\\tcontinue\\\\n   685→\\\\t\\\\t\\\\t}\\\\n   686→\\\\t\\\\t\\\\treturn nil, fmt.Errorf(\\\\\\\"failed to write transcript: %w\\\\\\\", writeErr)\\\\n   687→\\\\t\\\\t}\\\\n   688→\\\\n   689→\\\\t\\\\trestored = append(restored, RestoredSession{\\\\n   690→\\\\t\\\\t\\\\tSessionID: sessionID,\\\\n   691→\\\\t\\\\t\\\\tAgent:     sessionAgent.Type(),\\\\n   692→\\\\t\\\\t\\\\tPrompt:    promptPreview,\\\\n   693→\\\\t\\\\t})\\\\n   694→\\\\t}\\\\n   695→\\\\n   696→\\\\treturn restored, nil\\\\n   697→}\\\\n   698→\\\\n   699→// ResolveAgentForRewind resolves the agent from checkpoint metadata.\\\\n   700→// Falls back to the default agent (Claude) for old checkpoints that lack agent info.\\\\n   701→func ResolveAgentForRewind(agentType agent.AgentType) (agent.Agent, error) {\\\\n   702→\\\\tif !isSpecificAgentType(agentType) {\\\\n   703→\\\\t\\\\tag := agent.Default()\\\\n   704→\\\\t\\\\tif ag == nil {\\\\n   705→\\\\t\\\\t\\\\treturn nil, errors.New(\\\\\\\"no default agent registered\\\\\\\")\\\\n   706→\\\\t\\\\t}\\\\n   707→\\\\t\\\\treturn ag, nil\\\\n   708→\\\\t}\\\\n   709→\\\\tag, err := agent.GetByAgentType(agentType)\\\\n   710→\\\\tif err != nil {\\\\n   711→\\\\t\\\\treturn nil, fmt.Errorf(\\\\\\\"resolving agent %q: %w\\\\\\\", agentType, err)\\\\n   712→\\\\t}\\\\n   713→\\\\treturn ag, nil\\\\n   714→}\\\\n   715→\\\\n   716→// readSessionPrompt reads the first prompt from the session's prompt.txt file stored in git.\\\\n   717→// Returns an empty string if the prompt cannot be read.\\\\n   718→func readSessionPrompt(repo *git.Repository, commitHash plumbing.Hash, metadataDir string) string {\\\\n   719→\\\\t// Get the commit and its tree\\\\n   720→\\\\tcommit, err := repo.CommitObject(commitHash)\\\\n   721→\\\\tif err != nil {\\\\n   722→\\\\t\\\\treturn \\\\\\\"\\\\\\\"\\\\n   723→\\\\t}\\\\n   724→\\\\n   725→\\\\ttree, err := commit.Tree()\\\\n   726→\\\\tif err != nil {\\\\n   727→\\\\t\\\\treturn \\\\\\\"\\\\\\\"\\\\n   728→\\\\t}\\\\n   729→\\\\n   730→\\\\t// Look for prompt.txt in the metadata directory\\\\n   731→\\\\tpromptPath := metadataDir + \\\\\\\"/\\\\\\\" + paths.PromptFileName\\\\n   732→\\\\tpromptEntry, err := tree.File(promptPath)\\\\n   733→\\\\tif err != nil {\\\\n   734→\\\\t\\\\treturn \\\\\\\"\\\\\\\"\\\\n   735→\\\\t}\\\\n   736→\\\\n   737→\\\\tcontent, err := promptEntry.Contents()\\\\n   738→\\\\tif err != nil {\\\\n   739→\\\\t\\\\treturn \\\\\\\"\\\\\\\"\\\\n   740→\\\\t}\\\\n   741→\\\\n   742→\\\\treturn ExtractFirstPrompt(content)\\\\n   743→}\\\\n   744→\\\\n   745→// SessionRestoreStatus represents the status of a session being restored.\\\\n   746→type SessionRestoreStatus int\\\\n   747→\\\\n   748→const (\\\\n   749→\\\\tStatusNew             SessionRestoreStatus = iota // Local file doesn't exist\\\\n   750→\\\\tStatusUnchanged                                   // Local and checkpoint are the same\\\\n   751→\\\\tStatusCheckpointNewer                             // Checkpoint has newer entries\\\\n   752→\\\\tStatusLocalNewer                                  // Local has newer entries (conflict)\\\\n   753→)\\\\n   754→\\\\n   755→// SessionRestoreInfo contains information about a session being restored.\\\\n   756→type SessionRestoreInfo struct {\\\\n   757→\\\\tSessionID      string\\\\n   758→\\\\tPrompt         string               // First prompt preview for display\\\\n   759→\\\\tStatus         SessionRestoreStatus // Status of this session\\\\n   760→\\\\tLocalTime      time.Time\\\\n   761→\\\\tCheckpointTime time.Time\\\\n   762→}\\\\n   763→\\\\n   764→// classifySessionsForRestore checks all sessions in a checkpoint and returns info\\\\n   765→// about each session, including whether local logs have newer timestamps.\\\\n   766→// repoRoot is used to compute per-session agent directories.\\\\n   767→// Sessions without agent metadata are skipped (