pts from archived folders (0/, 1/, etc.) and root\\\\n   505→\\\\tprompts := make([]string, len(sessionIDs))\\\\n   506→\\\\n   507→\\\\t// Read archived session prompts (folders 0, 1, ... N-2)\\\\n   508→\\\\tfor i := range sessionCount - 1 {\\\\n   509→\\\\t\\\\tarchivedPath := fmt.Sprintf(\\\\\\\"%s/%d\\\\\\\", checkpointPath, i)\\\\n   510→\\\\t\\\\tprompts[i] = ReadSessionPromptFromTree(tree, archivedPath)\\\\n   511→\\\\t}\\\\n   512→\\\\n   513→\\\\t// Read the most recent session prompt (at root level)\\\\n   514→\\\\tprompts[len(prompts)-1] = ReadSessionPromptFromTree(tree, checkpointPath)\\\\n   515→\\\\n   516→\\\\treturn prompts\\\\n   517→}\\\\n   518→\\\\n   519→// GetRemoteMetadataBranchTree returns the tree object for origin/entire/checkpoints/v1.\\\\n   520→func GetRemoteMetadataBranchTree(repo *git.Repository) (*object.Tree, error) {\\\\n   521→\\\\trefName := plumbing.NewRemoteReferenceName(\\\\\\\"origin\\\\\\\", paths.MetadataBranchName)\\\\n   522→\\\\tref, err := repo.Reference(refName, true)\\\\n   523→\\\\tif err != nil {\\\\n   524→\\\\t\\\\treturn nil, fmt.Errorf(\\\\\\\"failed to get remote metadata branch reference: %w\\\\\\\", err)\\\\n   525→\\\\t}\\\\n   526→\\\\n   527→\\\\tcommit, err := repo.CommitObject(ref.Hash())\\\\n   528→\\\\tif err != nil {\\\\n   529→\\\\t\\\\treturn nil, fmt.Errorf(\\\\\\\"failed to get remote metadata branch commit: %w\\\\\\\", err)\\\\n   530→\\\\t}\\\\n   531→\\\\n   532→\\\\ttree, err := commit.Tree()\\\\n   533→\\\\tif err != nil {\\\\n   534→\\\\t\\\\treturn nil, fmt.Errorf(\\\\\\\"failed to get remote metadata branch tree: %w\\\\\\\", err)\\\\n   535→\\\\t}\\\\n   536→\\\\treturn tree, nil\\\\n   537→}\\\\n   538→\\\\n   539→// OpenRepository opens the git repository with linked worktree support enabled.\\\\n   540→// It uses git.PlainOpenWithOptions with EnableDotGitCommonDir set to true,\\\\n   541→// which is required for proper operation in git worktrees created via 'git worktree add'.\\\\n   542→//\\\\n   543→// Without EnableDotGitCommonDir, go-git operations in worktrees can silently fail:\\\\n   544→// - Commits appear to succeed but are not persisted\\\\n   545→// - Refs are written to incorrect locations\\\\n   546→// - The worktree's HEAD/index don't get updated properly\\\\n   547→//\\\\n   548→// This happens because worktrees use .git as a file (pointing to the main repo)\\\\n   549→// rather than a directory, and go-git needs to route paths correctly between\\\\n   550→// shared (.git/) and per-worktree (.git/worktrees/<name>/) locations.\\\\n   551→//\\\\n   552→// The function first uses 'git rev-parse --show-toplevel' to find the repository\\\\n   553→// root, which works correctly even when called from a subdirectory within the repo.\\\\n   554→func OpenRepository() (*git.Repository, error) {\\\\n   555→\\\\t// First, find the repository root using git rev-parse --show-toplevel\\\\n   556→\\\\t// This works correctly from any subdirectory within the repository\\\\n   557→\\\\trepoRoot, err := GetWorktreePath()\\\\n   558→\\\\tif err != nil {\\\\n   559→\\\\t\\\\t// Fallback to current directory if git command fails\\\\n   560→\\\\t\\\\t// (e.g., if git is not installed or we're not in a repo)\\\\n   561→\\\\t\\\\trepoRoot = \\\\\\\".\\\\\\\"\\\\n   562→\\\\t}\\\\n   563→\\\\n   564→\\\\trepo, err := git.PlainOpenWithOptions(repoRoot, &git.PlainOpenOptions{\\\\n   565→\\\\t\\\\tEnableDotGitCommonDir: true,\\\\n   566→\\\\t})\\\\n   567→\\\\tif err != nil {\\\\n   568→\\\\t\\\\treturn nil, fmt.Errorf(\\\\\\\"failed to open repository: %w\\\\\\\", err)\\\\n   569→\\\\t}\\\\n   570→\\\\treturn repo, nil\\\\n   571→}\\\\n   572→\\\\n   573→// IsInsideWorktree returns true if the current directory is inside a git worktree\\\\n   574→// (as opposed to the main repository). Worktrees have .git as a file pointing\\\\n   575→// to the main repo, while the main repo has .git as a directory.\\\\n   576→// This function works correctly from any subdirectory within the repository.\\\\n   577→func IsInsideWorktree() bool {\\\\n   578→\\\\t// First find the repository root\\\\n   579→\\\\trepoRoot, err := GetWorktreePath()\\\\n   580→\\\\tif err != nil {\\\\n   581→\\\\t\\\\treturn false\\\\n   582→\\\\t}\\\\n   583→\\\\n   584→\\\\tgitPath := filepath.Join(repoRoot, gitDir)\\\\n   585→\\\\tgitInfo, err := os.Stat(gitPath)\\\\n   586→\\\\tif err != nil {\\\\n   587→\\\\t\\\\treturn false\\\\n   588→\\\\t}\\\\n   589→\\\\treturn !gitInfo.IsDir()\\\\n   590→}\\\\n   591→\\\\n   592→// GetMainRepoRoot returns the root directory of the main repository.\\\\n   593→// In the main repo, this is the worktree path (repo root).\\\\n   594→// In a worktree, this parses the .git file to find the main repo.\\\\n   595→// This function works correctly from any subdirectory within the repository.\\\\n   596→//\\\\n   597→// Per gitrepository-layout(5), a worktree's .git file is a \\\\\\\"gitfile\\\\\\\" containing\\\\n   598→// \\\\\\\"gitdir: <path>\\\\\\\" pointing to $GIT_DIR/worktrees/<id> in the main repository.\\\\n   599→// See: https://git-scm.com/docs/gitrepository-layout\\\\n   600→func GetMainRepoRoot() (string, error) {\\\\n   601→\\\\t// First find the worktree/repo root\\\\n   602→\\\\trepoRoot, err := GetWorktreePath()\\\\n   603→\\\\tif err != nil {\\\\n   604→\\\\t\\\\treturn \\\\\\\"\\\\\\\", fmt.Errorf(\\\\\\\"failed to get worktree path: %w\\\\\\\", err)\\\\n   605→\\\\t}\\\\n   606→\\\\n   607→\\\\tif !IsInsideWorktree() {\\\\n   608→\\\\t\\\\treturn repoRoot, nil\\\\n   609→\\\\t}\\\\n   610→\\\\n   611→\\\\t// Worktree .git file contains: \\\\\\\"gitdir: /path/to/main/.git/worktrees/<id>\\\\\\\"\\\\n   612→\\\\tgitFilePath := filepath.Join(repoRoot, gitDir)\\\\n   613→\\\\tcontent, err := os.ReadFile(gitFilePath) //nolint:gosec // G304: gitFilePath is constructed from repo root, not user input\\\\n   614→\\\\tif err != nil {\\\\n   615→\\\\t\\\\treturn \\\\\\\"\\\\\\\", fmt.Errorf(\\\\\\\"failed to read .git file: %w\\\\\\\", err)\\\\n   616→\\\\t}\\\\n   617→\\\\n   618→\\\\tgitdir := strings.TrimSpace(string(content))\\\\n   619→\\\\tgitdir = strings.TrimPrefix(gitdir, \\\\\\\"gitdir: \\\\\\\")\\\\n   620→\\\\n   621→\\\\t// Extract main repo root: everything before \\\\\\\"/.git/\\\\\\\"\\\\n   622→\\\\tidx := strings.LastIndex(gitdir, \\\\\\\"/.git/\\\\\\\")\\\\n   623→\\\\tif idx < 0 {\\\\n   624→\\\\t\\\\treturn \\\\\\\"\\\\\\\", fmt.Errorf(\\\\\\\"unexpected gitdir format: %s\\\\\\\", gitdir)\\\\n   625→\\\\t}\\\\n   626→\\\\treturn gitdir[:idx], nil\\\\n   627→}\\\\n   628→\\\\n   629→// GetGitCommonDir returns the path to the shared git directory.\\\\n   630→// In a regular checkout, this is .git/\\\\n   631→// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\\\n   632→// Uses git rev-parse --git-common-dir for reliable handling of worktrees.\\\\n   633→func GetGitCommonDir() (string, error) {\\\\n   634→\\\\tctx := context.Background()\\\\n   635→\\\\tcmd := exec.CommandContext(ctx, \\\\\\\"git\\\\\\\", \\\\\\\"rev-parse\\\\\\\", \\\\\\\"--git-common-dir\\\\\\\")\\\\n   636→\\\\tcmd.Dir = \\\\\\\".\\\\\\\"\\\\n   637→\\\\toutput, err := cmd.Output()\\\\n   638→\\\\tif err != nil {\\\\n   639→\\\\t\\\\treturn \\\\\\\"\\\\\\\", fmt.Errorf(\\\\\\\"failed to get git common dir: %w\\\\\\\", err)\\\\n   640→\\\\t}\\\\n   641→\\\\n   642→\\\\tcommonDir := strings.TrimSpace(string(output))\\\\n   643→\\\\n   644→\\\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\\\n   645→\\\\t// so we need to make it absolute if it isn't already\\\\n   646→\\\\tif !filepath.IsAbs(commonDir) {\\\\n   647→\\\\t\\\\tcommonDir = filepath.Join(\\\\\\\".\\\\\\\", commonDir)\\\\n   648→\\\\t}\\\\n   649→\\\\n   650→\\\\treturn filepath.Clean(commonDir), nil\\\\n   651→}\\\\n   652→\\\\n   653→// GetWorktreePath returns the absolute path to the current worktree root.\\\\n   654→// This is the working directory path, not the git directory.\\\\n   655→func GetWorktreePath() (string, error) {\\\\n   656→\\\\tctx := context.Background()\\\\n   657→\\\\tcmd := exec.CommandContext(ctx, \\\\\\\"git\\\\\\\", \\\\\\\"rev-parse\\\\\\\", \\\\\\\"--show-toplevel\\\\\\\")\\\\n   658→\\\\toutput, err := cmd.Output()\\\\n   659→\\\\tif err != nil {\\\\n   660→\\\\t\\\\treturn \\\\\\\"\\\\\\\", fmt.Errorf(\\\\\\\"failed to get worktree path: %w\\\\\\\", err)\\\\n   661→\\\\t}\\\\n   662→\\\\treturn strings.TrimSpace(string(output)), nil\\\\n   663→}\\\\n   664→\\\\n   665→// EnsureEntireGitignore ensures all required entries are in .entire/.gitignore\\\\n   666→// Works correctly from any subdirectory within the repository.\\\\n   667→func EnsureEntireGitignore() error {\\\\n   668→\\\\t// Get absolute path for the gitignore file\\\\n   669→\\\\tgitignoreAbs, err := paths.AbsPath(entireGitignore)\\\\n   670→\\\\tif err != nil {\\\\n   671→\\\\t\\\\tgitignoreAbs = entireGitignore // Fallback to relative\\\\n   672→\\\\t}\\\\n   673→\\\\n   674→\\\\t// Read existing content\\\\n   675→\\\\tvar content string\\\\n   676→\\\\tif data, err := os.ReadFile(gitignoreAbs); err == nil { //nolint:gosec // path is from AbsPath or constant\\\\n   677→\\\\t\\\\tcontent = string(data)\\\\n   678→\\\\t}\\\\n   679→\\\\n   680→\\\\t// All entries that should be in .entire/.gitignore\\\\n   681→\\\\trequiredEntries := []string{\\\\n   682→\\\\t\\\\t\\\\\\\"tmp/\\\\\\\",\\\\n   683→\\\\t\\\\t\\\\\\\"settings.local.json\\\\\\\",\\\\n   684→\\\\t\\\\t\\\\\\\"metadata/\\\\\\\",\\\\n   685→\\\\t\\\\t\\\\\\\"logs/\\\\\\\",\\\\n   686→\\\\t}\\\\n   687→\\\\n   688→\\\\t// Track what needs to be added\\\\n   689→\\\\tvar toAdd []string\\\\n   690→\\\\tfor _, entry := range requiredEntries {\\\\n   691→\\\\t\\\\tif !strings.Contains(content, entry) {\\\\n   692→\\\\t\\\\t\\\\ttoAdd = append(toAdd, entry)\\\\n   693→\\\\t\\\\t}\\\\n   694→\\\\t}\\\\n   695→\\\\n   696→\\\\t// Nothing to add\\\\n   697→\\\\tif len(toAdd) == 0 {\\\\n   698→\\\\t\\\\treturn nil\\\\n   699→\\\\t}\\\\n   700→\\\\n   701→\\\\t// Ensure .entire directory exists\\\\n   702→\\\\tif err := os.MkdirAll(filepath.Dir(gitignoreAbs), 0o750); err != nil {\\\\n   703→\\\\t\\\\treturn fmt.Errorf(\\\\\\\"failed to create .entire directory: %w\\\\\\\", err)\\\\n   704→\\\\t}\\\\n   705→\\\\n   706→\\\\t// Append missing entries to gitignore\\\\n   707→\\\\tvar sb strings.Builder\\\\n   708→\\\\tfor _, entry := range toAdd {\\\\n   709→\\\\t\\\\tsb.WriteString(entry + \\\\\\\"\\\\\\\\n\\\\\\\")\\\\n   710→\\\\t}\\\\n   711→\\\\tcontent += sb.String()\\\\n   712→\\\\n   713→\\\\tif err := os.WriteFile(gitignoreAbs, []byte(content), 0o644); err != nil { //nolint:gosec // path is from AbsPath or constant\\\\n   714→\\\\t\\\\treturn fmt.Errorf(\\\\\\\"failed to write gitignore: %w\\\\\\\", err)\\\\n   715→\\\\t}\\\\n   716→\\\\treturn nil\\\\n   717→}\\\\n   718→\\\\n   719→// checkCanRewind checks if working directory is clean enough for rewind.\\\\n   720→// Returns (canRewind, reason, error). Shared by shadow and linear-shadow strategies.\\\\n   721→func checkCanRewind() (bool, string, error) {\\\\n   722→\\\\trepo, err := OpenRepository()\\\\n   723→\\\\tif err != nil {\\\\n   724→\\\\t\\\\treturn false, \\\\\\\"\\\\\\\", fmt.Errorf(\\\\\\\"failed to open git repository: %w\\\\\\\", err)\\\\n   725→\\\\t}\\\\n   726→\\\\n   727→\\\\tworktree, err := repo.Worktree()\\\\n   728→\\\\tif err != nil {\\\\n   729→\\\\t\\\\treturn false, \\\\\\\"\\\\\\\", fmt.Errorf(\\\\\\\"failed to get worktree: %w\\\\\\\", err)\\\\n   730→\\\\t}\\\\n   731→\\\\n   732→\\\\tstatus, err := worktree.Status()\\\\n   733→\\\\tif err != nil {\\\\n   734→\\\\t\\\\treturn false, \\\\\\\"\\\\\\\", fmt.Errorf(\\\\\\\"failed to get status: %w\\\\\\\", err)\\\\n   735→\\\\t}\\\\n   736→\\\\n   737→\\\\tif status.IsClean() {\\\\n   738→\\\\t\\\\treturn true, \\\\\\\"\\\\\\\", nil\\\\n   739→\\\\t}\\\\n   740→\\\\n   741→\\\\tvar modified, added, deleted []string\\\\n   742→\\\\tfor file, st := range status {\\\\n   743→\\\\t\\\\t// Skip .entire directory\\\\n   744→\\\\t\\\\tif paths.IsInfrastructurePath(file) {\\\\n   745→\\\\t\\\\t\\\\tcontinue\\\\n   746→\\\\t\\\\t}\\\\n   747→\\\\n   748→\\\\t\\\\t// Skip untracked files\\\\n   749→\\\\t\\\\tif st.Worktree == git.Untracked {\\\\n   750→\\\\t\\\\t\\\\tcontinue\\\\n   751→\\\\t\\\\t}\\\\n   752→\\\\n   753→\\\\t\\\\tswitch {\\\\n   754→\\\\t\\\\tcase st.Staging == git.Added || st.Worktree == git.Added:\\\\n   755→\\\\t\\\\t\\\\tadded = append(added, file)\\\\n   756→\\\\t\\\\tcase st.Staging == git.Deleted || st.Worktree == git.Deleted:\\\\n   757→\\\\t\\\\t\\\\tdeleted = append(deleted, file)\\\\n   758→\\\\t\\\\tcase st.Staging == git.Modified || st.Worktree == git.Modified:\\\\n   759→\\\\t\\\\t\\\\tmodified = append(modified, file)\\\\n   760→\\\\t\\\\t}\\\\n   761→\\\\t}\\\\n   762→\\\\n   763→\\\\tif len(modified) == 0 && len(added) == 0 && len(deleted) == 0 {\\\\n   764→\\\\t\\\\treturn true, \\\\\\\"\\\\\\\", nil\\\\n   765→\\\\t}\\\\n   766→\\\\n   767→\\\\tvar msg strings.Builder\\\\n   768→\\\\tmsg.WriteString(\\\\\\\"You have uncommitted changes:\\\\\\\\n\\\\\\\")\\\\n   769→\\\\tfor _, f := range modified {\\\\n   770→\\\\t\\\\tmsg.WriteString(fmt.Sprintf(\\\\\\\"  modified:   %s\\\\\\\\n\\\\\\\", f))\\\\n   771→\\\\t}\\\\n   772→\\\\tfor _, f := range added {\\\\n   773→\\\\t\\\\tmsg.WriteString(fmt.Sprintf(\\\\\\\"  added:      %s\\\\\\\\n\\\\\\\", f))\\\\n   774→\\\\t}\\\\n   775→\\\\tfor _, f := range deleted {\\\\n   776→\\\\t\\\\tmsg.WriteString(fmt.Sprintf(\\\\\\\"  deleted:    %s\\\\\\\\n\\\\\\\", f))\\\\n   777→\\\\t}\\\\n   778→\\\\tmsg.WriteString(\\\\\\\"\\\\\\\\nPlease commit or stash your changes before rewinding.\\\\\\\")\\\\n   779→\\\\n   780→\\\\treturn false, msg.String(), nil\\\\n   781→}\\\\n   782→\\\\n   783→// checkCanRewindWithWarning checks working directory and returns a warning with diff stats.\\\\n   784→// Unlike checkCanRewind, 