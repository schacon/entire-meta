\\\\\\\n\\\\\\\\n\\\\\\\")\\\\n   417→\\\\tvar firstPrompt string\\\\n   418→\\\\tfor _, p := range prompts {\\\\n   419→\\\\t\\\\tcleaned := strings.TrimSpace(p)\\\\n   420→\\\\t\\\\t// Skip empty prompts or prompts that are just dashes/separators\\\\n   421→\\\\t\\\\tif cleaned == \\\\\\\"\\\\\\\" || isOnlySeparators(cleaned) {\\\\n   422→\\\\t\\\\t\\\\tcontinue\\\\n   423→\\\\t\\\\t}\\\\n   424→\\\\t\\\\tfirstPrompt = cleaned\\\\n   425→\\\\t\\\\tbreak\\\\n   426→\\\\t}\\\\n   427→\\\\n   428→\\\\tif firstPrompt == \\\\\\\"\\\\\\\" {\\\\n   429→\\\\t\\\\treturn \\\\\\\"\\\\\\\"\\\\n   430→\\\\t}\\\\n   431→\\\\n   432→\\\\treturn TruncateDescription(firstPrompt, MaxDescriptionLength)\\\\n   433→}\\\\n   434→\\\\n   435→// ReadSessionPromptFromTree reads the first meaningful prompt from a checkpoint's prompt.txt file in a git tree.\\\\n   436→// Returns an empty string if the prompt cannot be read.\\\\n   437→func ReadSessionPromptFromTree(tree *object.Tree, checkpointPath string) string {\\\\n   438→\\\\tpromptPath := checkpointPath + \\\\\\\"/\\\\\\\" + paths.PromptFileName\\\\n   439→\\\\tfile, err := tree.File(promptPath)\\\\n   440→\\\\tif err != nil {\\\\n   441→\\\\t\\\\treturn \\\\\\\"\\\\\\\"\\\\n   442→\\\\t}\\\\n   443→\\\\n   444→\\\\tcontent, err := file.Contents()\\\\n   445→\\\\tif err != nil {\\\\n   446→\\\\t\\\\treturn \\\\\\\"\\\\\\\"\\\\n   447→\\\\t}\\\\n   448→\\\\n   449→\\\\treturn ExtractFirstPrompt(content)\\\\n   450→}\\\\n   451→\\\\n   452→// ReadAgentTypeFromTree reads the agent type from a checkpoint's metadata.json file in a git tree.\\\\n   453→// If metadata.json doesn't exist (shadow branches), it falls back to detecting the agent\\\\n   454→// from the presence of agent-specific config files (.gemini/settings.json or .claude/).\\\\n   455→// Returns agent.AgentTypeUnknown if the agent type cannot be determined.\\\\n   456→func ReadAgentTypeFromTree(tree *object.Tree, checkpointPath string) agent.AgentType {\\\\n   457→\\\\t// First, try to read from metadata.json (present in condensed/committed checkpoints)\\\\n   458→\\\\tmetadataPath := checkpointPath + \\\\\\\"/\\\\\\\" + paths.MetadataFileName\\\\n   459→\\\\tif file, err := tree.File(metadataPath); err == nil {\\\\n   460→\\\\t\\\\tif content, err := file.Contents(); err == nil {\\\\n   461→\\\\t\\\\t\\\\tvar metadata checkpoint.CommittedMetadata\\\\n   462→\\\\t\\\\t\\\\tif err := json.Unmarshal([]byte(content), &metadata); err == nil && metadata.Agent != \\\\\\\"\\\\\\\" {\\\\n   463→\\\\t\\\\t\\\\t\\\\treturn metadata.Agent\\\\n   464→\\\\t\\\\t\\\\t}\\\\n   465→\\\\t\\\\t}\\\\n   466→\\\\t}\\\\n   467→\\\\n   468→\\\\t// Fall back to detecting agent from config files (shadow branches don't have metadata.json)\\\\n   469→\\\\t// Check for Gemini config\\\\n   470→\\\\tif _, err := tree.File(\\\\\\\".gemini/settings.json\\\\\\\"); err == nil {\\\\n   471→\\\\t\\\\treturn agent.AgentTypeGemini\\\\n   472→\\\\t}\\\\n   473→\\\\t// Check for Claude config (either settings.local.json or settings.json in .claude/)\\\\n   474→\\\\tif _, err := tree.Tree(\\\\\\\".claude\\\\\\\"); err == nil {\\\\n   475→\\\\t\\\\treturn agent.AgentTypeClaudeCode\\\\n   476→\\\\t}\\\\n   477→\\\\n   478→\\\\treturn agent.AgentTypeUnknown\\\\n   479→}\\\\n   480→\\\\n   481→// isOnlySeparators checks if a string contains only dashes, spaces, and newlines.\\\\n   482→func isOnlySeparators(s string) bool {\\\\n   483→\\\\tfor _, r := range s {\\\\n   484→\\\\t\\\\tif r != '-' && r != ' ' && r != '\\\\\\\\n' && r != '\\\\\\\\r' && r != '\\\\\\\\t' {\\\\n   485→\\\\t\\\\t\\\\treturn false\\\\n   486→\\\\t\\\\t}\\\\n   487→\\\\t}\\\\n   488→\\\\treturn true\\\\n   489→}\\\\n   490→\\\\n   491→// ReadAllSessionPromptsFromTree reads the first prompt for all sessions in a multi-session checkpoint.\\\\n   492→// Returns a slice of prompts parallel to sessionIDs (oldest to newest).\\\\n   493→// For single-session checkpoints, returns a slice with just the root prompt