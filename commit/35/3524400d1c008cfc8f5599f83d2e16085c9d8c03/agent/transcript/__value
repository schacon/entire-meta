   274→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to reset shadow branch: %v\\\\n\\\", err)\\n   275→\\t}\\n   276→\\n   277→\\t// Load session state to get untracked files that existed at session start\\n   278→\\tsessionID, hasSessionTrailer := trailers.ParseSession(commit.Message)\\n   279→\\tvar preservedUntrackedFiles map[string]bool\\n   280→\\tif hasSessionTrailer {\\n   281→\\t\\tstate, stateErr := s.loadSessionState(sessionID)\\n   282→\\t\\tif stateErr == nil && state != nil && len(state.UntrackedFilesAtStart) > 0 {\\n   283→\\t\\t\\tpreservedUntrackedFiles = make(map[string]bool)\\n   284→\\t\\t\\tfor _, f := range state.UntrackedFilesAtStart {\\n   285→\\t\\t\\t\\tpreservedUntrackedFiles[f] = true\\n   286→\\t\\t\\t}\\n   287→\\t\\t}\\n   288→\\t}\\n   289→\\n   290→\\t// Build set of files in the checkpoint tree (excluding metadata)\\n   291→\\tcheckpointFiles := make(map[string]bool)\\n   292→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   293→\\t\\tif !strings.HasPrefix(f.Name, entireDir) {\\n   294→\\t\\t\\tcheckpointFiles[f.Name] = true\\n   295→\\t\\t}\\n   296→\\t\\treturn nil\\n   297→\\t})\\n   298→\\tif err != nil {\\n   299→\\t\\treturn fmt.Errorf(\\\"failed to list checkpoint files: %w\\\", err)\\n   300→\\t}\\n   301→\\n   302→\\t// Get HEAD tree to identify tracked files\\n   303→\\thead, err := repo.Head()\\n   304→\\tif err != nil {\\n   305→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   306→\\t}\\n   307→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   308→\\tif err != nil {\\n   309→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   310→\\t}\\n   311→\\theadTree, err := headCommit.Tree()\\n   312→\\tif err != nil {\\n   313→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD tree: %w\\\", err)\\n   314→\\t}\\n   315→\\n   316→\\t// Build set of files tracked in HEAD\\n   317→\\ttrackedFiles := make(map[string]bool)\\n   318→\\t//nolint:errcheck // Error is not critical for rewind\\n   319→\\t_ = headTree.Files().ForEach(func(f *object.File) error {\\n   320→\\t\\ttrackedFiles[f.Name] = true\\n   321→\\t\\treturn nil\\n   322→\\t})\\n   323→\\n   324→\\t// Get repository root to walk from there\\n   325→\\trepoRoot, err := GetWorktreePath()\\n   326→\\tif err != nil {\\n   327→\\t\\trepoRoot = \\\".\\\" // Fallback to current directory\\n   328→\\t}\\n   329→\\n   330→\\t// Find and delete untracked files that aren't in the checkpoint\\n   331→\\t// These are likely files created by the agent in later checkpoints\\n   332→\\terr = filepath.Walk(repoRoot, func(path string, info os.FileInfo, walkErr error) error {\\n   333→\\t\\tif walkErr != nil {\\n   334→\\t\\t\\treturn nil //nolint:nilerr // Skip filesystem errors during walk\\n   335→\\t\\t}\\n   336→\\n   337→\\t\\t// Get path relative to repo root\\n   338→\\t\\trelPath, relErr := filepath.Rel(repoRoot, path)\\n   339→\\t\\tif relErr != nil {\\n   340→\\t\\t\\treturn nil //nolint:nilerr // Skip paths we can't make relative\\n   341→\\t\\t}\\n   342→\\n   343→\\t\\t// Skip directories and protected paths\\n   344→\\t\\tif info.IsDir() {\\n   345→\\t\\t\\tif isProtectedPath(relPath) {\\n   346→\\t\\t\\t\\treturn filepath.SkipDir\\n   347→\\t\\t\\t}\\n   348→\\t\\t\\treturn nil\\n   349→\\t\\t}\\n   350→\\n   351→\\t\\t// Skip files in protected directories\\n   352→\\t\\tif isProtectedPath(relPath) {\\n   353→\\t\\t\\treturn nil\\n   354→\\t\\t}\\n   355→\\n   356→\\t\\t// If file is in checkpoint, it will be restored\\n   357→\\t\\tif checkpointFiles[relPath] {\\n   358→\\t\\t\\treturn nil\\n   359→\\t\\t}\\n   360→\\n   361→\\t\\t// If file is tracked in HEAD, don't delete (user's committed work)\\n   362→\\t\\tif trackedFiles[relPath] {\\n   363→\\t\\t\\treturn nil\\n   364→\\t\\t}\\n   365→\\n   366→\\t\\t// If file existed at session start, preserve it (untracked user files)\\n   367→\\t\\tif preservedUntrackedFiles[relPath] {\\n   368→\\t\\t\\treturn nil\\n   369→\\t\\t}\\n   370→\\n   371→\\t\\t// File is untracked and not in checkpoint - delete it (use absolute path)\\n   372→\\t\\tif removeErr := os.Remove(path); removeErr == nil {\\n   373→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Deleted: %s\\\\n\\\", relPath)\\n   374→\\t\\t}\\n   375→\\n   376→\\t\\treturn nil\\n   377→\\t})\\n   378→\\tif err != nil {\\n   379→\\t\\t// Non-fatal - continue with restoration\\n   380→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: error walking directory: %v\\\\n\\\", err)\\n   381→\\t}\\n   382→\\n   383→\\t// Restore files from checkpoint\\n   384→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   385→\\t\\t// Skip metadata directories - these are for checkpoint storage, not working dir\\n   386→\\t\\tif strings.HasPrefix(f.Name, entireDir) {\\n   387→\\t\\t\\treturn nil\\n   388→\\t\\t}\\n   389→\\n   390→\\t\\tcontents, err := f.Contents()\\n   391→\\t\\tif err != nil {\\n   392→\\t\\t\\treturn fmt.Errorf(\\\"failed to read file %s: %w\\\", f.Name, err)\\n   393→\\t\\t}\\n   394→\\n   395→\\t\\t// Ensure directory exists\\n   396→\\t\\tdir := filepath.Dir(f.Name)\\n   397→\\t\\tif dir != \\\".\\\" {\\n   398→\\t\\t\\t//nolint:gosec // G301: Need 0o755 for user directories during rewind\\n   399→\\t\\t\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   400→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to create directory %s: %w\\\", dir, err)\\n   401→\\t\\t\\t}\\n   402→\\t\\t}\\n   403→\\n   404→\\t\\t// Write file with appropriate permissions\\n   405→\\t\\tvar perm os.FileMode = 0o644\\n   406→\\t\\tif f.Mode == filemode.Executable {\\n   407→\\t\\t\\tperm = 0o755\\n   408→\\t\\t}\\n   409→\\t\\tif err := os.WriteFile(f.Name, []byte(contents), perm); err != nil {\\n   410→\\t\\t\\treturn fmt.Errorf(\\\"failed to write file %s: %w\\\", f.Name, err)\\n   411→\\t\\t}\\n   412→\\n   413→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Restored: %s\\\\n\\\", f.Name)\\n   414→\\t\\treturn nil\\n   415→\\t})\\n   416→\\tif err != nil {\\n   417→\\t\\treturn fmt.Errorf(\\\"failed to iterate tree files: %w\\\", err)\\n   418→\\t}\\n   419→\\n   420→\\tfmt.Println()\\n   421→\\tif len(point.ID) >= 7 {\\n   422→\\t\\tfmt.Printf(\\\"Restored files from shadow commit %s\\\\n\\\", point.ID[:7])\\n   423→\\t} else {\\n   424→\\t\\tfmt.Printf(\\\"Restored files from shadow commit %s\\\\n\\\", point.ID)\\n   425→\\t}\\n   426→\\tfmt.Println()\\n   427→\\n   428→\\treturn nil\\n   429→}\\n   430→\\n   431→// resetShadowBranchToCheckpoint resets the shadow branch HEAD to the given checkpoint.\\n   432→// This ensures that when the user commits after rewinding, the next checkpoint will only\\n   433→// include prompts from the rewound point, not prompts from later checkpoints.\\n   434→func (s *ManualCommitStrategy) resetShadowBranchToCheckpoint(repo *git.Repository, commit *object.Commit) error {\\n   435→\\t// Extract session ID from the checkpoint commit's Entire-Session trailer\\n   436→\\tsessionID, found := trailers.ParseSession(commit.Message)\\n   437→\\tif !found {\\n   438→\\t\\treturn errors.New(\\\"checkpoint has no Entire-Session trailer\\\")\\n   439→\\t}\\n   440→\\n   441→\\t// Load session state to get the shadow branch name\\n   442→\\tstate, err := s.loadSessionState(sessionID)\\n   443→\\tif err != nil {\\n   444→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   445→\\t}\\n   446→\\tif state == nil {\\n   447→\\t\\treturn fmt.Errorf(\\\"session %s not found\\\", sessionID)\\n   448→\\t}\\n   449→\\n   450→\\t// Reset the shadow branch to the checkpoint commit\\n   451→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   452→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   453→\\n   454→\\t// Update the reference to point to the checkpoint commit\\n   455→\\tref := plumbing.NewHashReference(refName, commit.Hash)\\n   456→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   457→\\t\\treturn fmt.Errorf(\\\"failed to update shadow branch: %w\\\", err)\\n   458→\\t}\\n   459→\\n   460→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Reset shadow branch %s to checkpoint %s\\\\n\\\", shadowBranchName, commit.Hash.String()[:7])\\n   461→\\treturn nil\\n   462→}\\n   463→\\n   464→// CanRewind checks if rewinding is possible.\\n   465→// For manual-commit strategy, rewind restores files from a checkpoint - uncommitted changes are expected\\n   466→// and will be replaced by the checkpoint contents. Returns true with a warning message showing\\n   467→// what changes will be reverted.\\n   468→func (s *ManualCommitStrategy) CanRewind() (bool, string, error) {\\n   469→\\treturn checkCanRewindWithWarning()\\n   470→}\\n   471→\\n   472→// PreviewRewind returns what will happen if rewinding to the given point.\\n   473→// This allows showing warnings about untracked files that will be deleted.\\n   474→func (s *ManualCommitStrategy) PreviewRewind(point RewindPoint) (*RewindPreview, error) {\\n   475→\\t// Logs-only points don't modify the working directory\\n   476→\\tif point.IsLogsOnly {\\n   477→\\t\\treturn &RewindPreview{}, nil\\n   478→\\t}\\n   479→\\n   480→\\trepo, err := OpenRepository()\\n   481→\\tif err != nil {\\n   482→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   483→\\t}\\n   484→\\n   485→\\t// Get the checkpoint commit\\n   486→\\tcommitHash := plumbing.NewHash(point.ID)\\n   487→\\tcommit, err := repo.CommitObject(commitHash)\\n   488→\\tif err != nil {\\n   489→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   490→\\t}\\n   491→\\n   492→\\ttree, err := commit.Tree()\\n   493→\\tif err != nil {\\n   494→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n   495→\\t}\\n   496→\\n   497→\\t// Load session state to get untracked files that existed at session start\\n   498→\\tsessionID, hasSessionTrailer := trailers.ParseSession(commit.Message)\\n   499→\\tvar preservedUntrackedFiles map[string]bool\\n   500→\\tif hasSessionTrailer {\\n   501→\\t\\tstate, stateErr := s.loadSessionState(sessionID)\\n   502→\\t\\tif stateErr == nil && state != nil && len(state.UntrackedFilesAtStart) > 0 {\\n   503→\\t\\t\\tpreservedUntrackedFiles = make(map[string]bool)\\n   504→\\t\\t\\tfor _, f := range state.UntrackedFilesAtStart {\\n   505→\\t\\t\\t\\tpreservedUntrackedFiles[f] = true\\n   506→\\t\\t\\t}\\n   507→\\t\\t}\\n   508→\\t}\\n   509→\\n   510→\\t// Build set of files in the checkpoint tree (excluding metadata)\\n   511→\\tcheckpointFiles := make(map[string]bool)\\n   512→\\tvar filesToRestore []string\\n   513→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   514→\\t\\tif !strings.HasPrefix(f.Name, entireDir) {\\n   515→\\t\\t\\tcheckpointFiles[f.Name] = true\\n   516→\\t\\t\\tfilesToRestore = append(filesToRestore, f.Name)\\n   517→\\t\\t}\\n   518→\\t\\treturn nil\\n   519→\\t})\\n   520→\\tif err != nil {\\n   521→\\t\\treturn nil, fmt.Errorf(\\\"failed to list checkpoint files: %w\\\", err)\\n   522→\\t}\\n   523→\\n   524→\\t// Get HEAD tree to identify tracked files\\n   525→\\thead, err := repo.Head()\\n   526→\\tif err != nil {\\n   527→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   528→\\t}\\n   529→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   530→\\tif err != nil {\\n   531→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   532→\\t}\\n   533→\\theadTree, err := headCommit.Tree()\\n   534→\\tif err != nil {\\n   535→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD tree: %w\\\", err)\\n   536→\\t}\\n   537→\\n   538→\\t// Build set of files tracked in HEAD\\n   539→\\ttrackedFiles := make(map[string]bool)\\n   540→\\t//nolint:errcheck // Error is not critical for preview\\n   541→\\t_ = headTree.Files().ForEach(func(f *object.File) error {\\n   542→\\t\\ttrackedFiles[f.Name] = true\\n   543→\\t\\treturn nil\\n   544→\\t})\\n   545→\\n   546→\\t// Get repository root to walk from there\\n   547→\\trepoRoot, err := GetWorktreePath()\\n   548→\\tif err != nil {\\n   549→\\t\\trepoRoot = \\\".\\\"\\n   550→\\t}\\n   551→\\n   552→\\t// Find untracked files that would be deleted\\n   553→\\tvar filesToDelete []string\\n   554→\\terr = filepath.Walk(repoRoot, func(path string, info os.FileInfo, walkErr error) error {\\n   555→\\t\\tif walkErr != nil {\\n   556→\\t\\t\\treturn nil //nolint:nilerr // Skip filesystem errors during walk\\n   557→\\t\\t}\\n   558→\\n   559→\\t\\trelPath, relErr := filepath.Rel(repoRoot, path)\\n   560→\\t\\tif relErr != nil {\\n   561→\\t\\t\\treturn nil //nolint:nilerr // Skip paths we can't make relative\\n   562→\\t\\t}\\n   563→\\n   564→\\t\\t// Skip directories and protected paths\\n   565→\\t\\tif info.IsDir() {\\n   566→\\t\\t\\tif isProtectedPath(relPath) {\\n   567→\\t\\t\\t\\treturn filepath.SkipDir\\n   568→\\t\\t\\t}\\n   569→\\t\\t\\treturn nil\\n   570→\\t\\t}\\n   571→\\n   572→\\t\\t// Skip files in protected directories\\n   573→\\t\\tif isProtectedPath(relPath) {\\n   574→\\t\\t\\treturn nil\\n   575→\\t\\t}\\n   576→\\n   577→\\t\\t// If file is in checkpoint, it will be restored (not deleted)\\n   578→\\t\\tif checkpointFiles[relPath] {\\n   579→\\t\\t\\treturn nil\\n   580→\\t\\t}\\n   581→\\n   582→\\t\\t// If file is tracked in HEAD, don't delete (user's committed work)\\n   583→\\t\\tif trackedFiles[relPath] {\\n   584→\\t\\t\\treturn nil\\n   585→\\t\\t}\\n   586→\\n   587→\\t\\t// If file existed at session start, preserve it (untracked user files)\\n   588→\\t\\tif preservedUntrackedFiles[relPath] {\\n   589→\\t\\t\\treturn nil\\n   590→\\t\\t}\\n   591→\\n   592→\\t\\t// File is untracked and not in checkpoint - will be deleted\\n   593→\\t\\tfilesToDelete = append(filesToDelete, relPath)\\n   594→\\t\\treturn nil\\n   595→\\t})\\n   596→\\tif err != nil {\\n   597→\\t\\t// Non-fatal, return what we have\\n   598→\\t\\treturn &RewindPreview{ //nolint:nilerr // Partial result is still useful\\n   599→\\t\\t\\tFilesToRestore: filesToRestore,\\n   600→\\t\\t\\tFilesToDelete:  filesToDelete,\\n   601→\\t\\t}, nil\\n   602→\\t}\\n   603→\\n   604→\\t// Sort for consistent output\\n   605→\\tsort.Strings(filesToRestore)\\n   606→\\tsort.Strings(filesToDelete)\\n   607→\\n   608→\\treturn &RewindPreview{\\n   609→\\t\\tFilesToRestore: filesToRestore,\\n   610→\\t\\tFilesToDelete:  filesToDelete,\\n   611→\\t}, nil\\n   612→}\\n   613→\\n   614→// RestoreLogsOnly restores session logs from a logs-only rewind point.\\n   615→// This fetches the transcript from entire/checkpoints/v1 and writes it to the agent's session directory.\\n   616→// Does not modify the working directory.\\n   617→// When multiple sessions were condensed to the same checkpoint, ALL sessions are restored.\\n   618→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   619→// Returns info about each restored session so callers can print correct per-session resume commands.\\n   620→func (s *ManualCommitStrategy) RestoreLogsOnly(point RewindPoint, force bool) ([]RestoredSession, error) {\\n   621→\\tif !point.IsLogsOnly {\\n   622→\\t\\treturn nil, errors.New(\\\"not a logs-only rewind point\\\")\\n   623→\\t}\\n   624→\\n   625→\\tif point.CheckpointID.IsEmpty() {\\n   626→\\t\\treturn nil, errors.New(\\\"missing checkpoint ID\\\")\\n   627→\\t}\\n   628→\\n   629→\\t// Get checkpoint store\\n   630→\\tstore, err := s.getCheckpointStore()\\n   631→\\tif err != nil {\\n   632→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   633→\\t}\\n   634→\\n   635→\\t// Read checkpoint summary to get session count\\n   636→\\tsummary, err := store.ReadCommitted(context.Background(), point.CheckpointID)\\n   637→\\tif err != nil {\\n   638→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   639→\\t}\\n   640→\\tif summary == nil {\\n   641→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", point.CheckpointID)\\n   642→\\t}\\n   643→\\n   644→\\t// Get repo root for agent session directory lookup\\n   645→\\trepoRoot, err := paths.RepoRoot()\\n   646→\\tif err != nil {\\n   647→\\t\\treturn nil, fmt.Errorf(\\\"failed to get repository root: %w\\\", err)\\n   648→\\t}\\n   649→\\n   650→\\t// Check for newer local logs if not forcing\\n   651→\\tif !force {\\n   652→\\t\\tsessions := s.classifySessionsForRestore(context.Background(), repoRoot, store, point.CheckpointID, summary)\\n   653→\\t\\thasConflicts := false\\n   654→\\t\\tfor _, sess := range sessions {\\n   655→\\t\\t\\tif sess.Status == StatusLocalNewer {\\n   656→\\t\\t\\t\\thasConflicts = true\\n   657→\\t\\t\\t\\tbreak\\n   658→\\t\\t\\t}\\n   659→\\t\\t}\\n   660→\\t\\tif hasConflicts {\\n   661→\\t\\t\\tshouldOverwrite, promptErr := PromptOverwriteNewerLogs(sessions)\\n   662→\\t\\t\\tif promptErr != nil {\\n   663→\\t\\t\\t\\treturn nil, promptErr\\n   664→\\t\\t\\t}\\n   665→\\t\\t\\tif !shouldOverwrite {\\n   666→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled. Local session logs preserved.\\\\n\\\")\\n   667→\\t\\t\\t\\treturn nil, nil\\n   668→\\t\\t\\t}\\n   669→\\t\\t}\\n   670→\\t}\\n   671→\\n   672→\\t// Count sessions to restore\\n   673→\\ttotalSessions := len(summary.Sessions)\\n   674→\\tif totalSessions > 1 {\\n   675→\\t\\tfmt.Fprintf(os.Stderr, \\\"Restoring %d sessions from checkpoint:\\\\n\\\", totalSessions)\\n   676→\\t}\\n   677→\\n   678→\\t// Restore all sessions (oldest to newest, using 0-based indexing)\\n   679→\\tvar restored []RestoredSession\\n   680→\\tfor i := range totalSessions {\\n   681→\\t\\tcontent, readErr := store.ReadSessionContent(context.Background(), point.CheckpointID, i)\\n   682→\\t\\tif readErr != nil {\\n   683→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: failed to read session %d: %v\\\\n\\\", i, readErr)\\n   684→\\t\\t\\tcontinue\\n   685→\\t\\t}\\n   686→\\t\\tif content == nil || len(content.Transcript) == 0 {\\n   687→\\t\\t\\tcontinue\\n   688→\\t\\t}\\n   689→\\n   690→\\t\\tsessionID := content.Metadata.SessionID\\n   691→\\t\\tif sessionID == \\\"\\\" {\\n   692→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d has no session ID, skipping\\\\n\\\", i)\\n   693→\\t\\t\\tcontinue\\n   694→\\t\\t}\\n   695→\\n   696→\\t\\t// Resolve per-session agent from metadata — skip if agent is unknown\\n   697→\\t\\tif content.Metadata.Agent == \\\"\\\" {\\n   698→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d (%s) has no agent metadata, skipping (cannot determine target directory)\\\\n\\\", i, sessionID)\\n   699→\\t\\t\\tcontinue\\n   700→\\t\\t}\\n   701→\\t\\tsessionAgent, agErr := ResolveAgentForRewind(content.Metadata.Agent)\\n   702→\\t\\tif agErr != nil {\\n   703→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d (%s) has unknown agent %q, skipping\\\\n\\\", i, sessionID, content.Metadata.Agent)\\n   704→\\t\\t\\tcontinue\\n   705→\\t\\t}\\n   706→\\n   707→\\t\\t// Compute transcript path from current repo location for cross-machine portability.\\n   708→\\t\\tsessionAgentDir, dirErr := sessionAgent.GetSessionDir(repoRoot)\\n   709→\\t\\tif dirErr != nil {\\n   710→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: failed to get session dir for session %d: %v\\\\n\\\", i, dirErr)\\n   711→\\t\\t\\tcontinue\\n   712→\\t\\t}\\n   713→\\t\\tsessionFile := sessionAgent.ResolveSessionFile(sessionAgentDir, sessionID)\\n   714→\\n   715→\\t\\t// Get first prompt for display\\n   716→\\t\\tpromptPreview := ExtractFirstPrompt(content.Prompts)\\n   717→\\n   718→\\t\\tif totalSessions > 1 {\\n   719→\\t\\t\\tisLatest := i == totalSessions-1\\n   720→\\t\\t\\tif promptPreview != \\\"\\\" {\\n   721→\\t\\t\\t\\tif isLatest {\\n   722→\\t\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Session %d (latest): %s\\\\n\\\", i+1, promptPreview)\\n   723→\\t\\t\\t\\t} else {\\n   724→\\t\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Session %d: %s\\\\n\\\", i+1, promptPreview)\\n   725→\\t\\t\\t\\t}\\n   726→\\t\\t\\t}\\n   727→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"    Writing to: %s\\\\n\\\", sessionFile)\\n   728→\\t\\t} else {\\n   729→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Writing transcript to: %s\\\\n\\\", sessionFile)\\n   730→\\t\\t}\\n   731→\\n   732→\\t\\t// Ensure parent directory exists (session file may be in a different dir than sessionAgentDir)\\n   733→\\t\\tif mkdirErr := os.MkdirAll(filepath.Dir(sessionFile), 0o750); mkdirErr != nil {\\n   734→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"    Warning: failed to create directory: %v\\\\n\\\", mkdirErr)\\n   735→\\t\\t\\tcontinue\\n   736→\\t\\t}\\n   737→\\n   738→\\t\\tif writeErr := os.WriteFile(sessionFile, content.Transcript, 0o600); writeErr != nil {\\n   739→\\t\\t\\tif totalSessions > 1 {\\n   740→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"    Warning: failed to write transcript: %v\\\\n\\\", writeErr)\\n   741→\\t\\t\\t\\tcontinue\\n   742→\\t\\t\\t}\\n   743→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to write transcript: %w\\\", writeErr)\\n   744→\\t\\t}\\n   745→\\n   746→\\t\\trestored = append(restored, RestoredSession{\\n   747→\\t\\t\\tSessionID: sessionID,\\n   748→\\t\\t\\tAgent:     sessionAgent.Type(),\\n   749→\\t\\t\\tPrompt:    promptPreview,\\n   750→\\t\\t})\\n   751→\\t}\\n   752→\\n   753→\\treturn restored, nil\\n   754→}\\n   755→\\n   756→// ResolveAgentForRewind resolves the agent from checkpoint metadata.\\n   757→// Falls back to the default agent (Claude) for old checkpoints that lack agent info.\\n   758→func ResolveAgentForRewind(agentType agent.AgentType) (agent.Agent, error) {\\n   759→\\tif !isSpecificAgentType(agentType) {\\n   760→\\t\\tag := agent.Default()\\n   761→\\t\\tif ag == nil {\\n   762→\\t\\t\\treturn nil, errors.New(\\\"no default agent registered\\\")\\n   763→\\t\\t}\\n   764→\\t\\treturn ag, nil\\n   765→\\t}\\n   766→\\tag, err := agent.GetByAgentType(agentType)\\n   767→\\tif err != nil {\\n   768→\\t\\treturn nil, fmt.Errorf(\\\"resolving agent %q: %w\\\", agentType, err)\\n   769→\\t}\\n   770→\\treturn ag, nil\\n   771→}\\n   772→\\n   773→// readSessionPrompt reads the first prompt from the session's prompt.txt file stored in git.\\n   774→// Returns an empty string if the prompt cannot be read.\\n   775→func readSessionPrompt(repo *git.Repository, commitHash plumbing.Hash, metadataDir string) string {\\n   776→\\t// Get the commit and its tree\\n   777→\\tcommit, err := repo.CommitObject(commitHash)\\n   778→\\tif err != nil {\\n   779→\\t\\treturn \\\"\\\"\\n   780→\\t}\\n   781→\\n   782→\\ttree, err := commit.Tree()\\n   783→\\tif err != nil {\\n   784→\\t\\treturn \\\"\\\"\\n   785→\\t}\\n   786→\\n   787→\\t// Look for prompt.txt in the metadata directory\\n   788→\\tpromptPath := metadataDir + \\\"/\\\" + paths.PromptFileName\\n   789→\\tpromptEntry, err := tree.File(promptPath)\\n   790→\\tif err != nil {\\n   791→\\t\\treturn \\\"\\\"\\n   792→\\t}\\n   793→\\n   794→\\tcontent, err := promptEntry.Contents()\\n   795→\\tif err != nil {\\n   796→\\t\\treturn \\\"\\\"\\n   797→\\t}\\n   798→\\n   799→\\treturn ExtractFirstPrompt(content)\\n   800→}\\n   801→\\n   802→// SessionRestoreStatus represents the status of a session being restored.\\n   803→type SessionRestoreStatus int\\n   804→\\n   805→const (\\n   806→\\tStatusNew             SessionRestoreStatus = iota // Local file doesn't exist\\n   807→\\tStatusUnchanged                                   // Local and checkpoint are the same\\n   808→\\tStatusCheckpointNewer                             // Checkpoint has newer entries\\n   809→\\tStatusLocalNewer                                  // Local has newer entries (conflict)\\n   810→)\\n   811→\\n   812→// SessionRestoreInfo contains information about a session being restored.\\n   813→type SessionRestoreInfo struct {\\n   814→\\tSessionID      string\\n   815→\\tPrompt         string               // First prompt preview for display\\n   816→\\tStatus         SessionRestoreStatus // Status of this session\\n   817→\\tLocalTime      time.Time\\n   818→\\tCheckpointTime time.Time\\n   819→}\\n   820→\\n   821→// classifySessionsForRestore checks all sessions in a checkpoint and returns info\\n   822→// about each session, including whether local logs have newer timestamps.\\n   823→// repoRoot is used to compute per-session agent directories.\\n   824→// Sessions without agent metadata are skipped (cannot determine target directory).\\n   825→func (s *ManualCommitStrategy) classifySessionsForRestore(ctx context.Context, repoRoot string, store cpkg.Store, checkpointID id.CheckpointID, summary *cpkg.CheckpointSummary) []SessionRestoreInfo {\\n   826→\\tvar sessions []SessionRestoreInfo\\n   827→\\n   828→\\ttotalSessions := len(summary.Sessions)\\n   829→\\t// Check all sessions (0-based indexing)\\n   830→\\tfor i := range totalSessions {\\n   831→\\t\\tcontent, err := store.ReadSessionContent(ctx, checkpointID, i)\\n   832→\\t\\tif err != nil || content == nil || len(content.Transcript) == 0 {\\n   833→\\t\\t\\tcontinue\\n   834→\\t\\t}\\n   835→\\n   836→\\t\\tsessionID := content.Metadata.SessionID\\n   837→\\t\\tif sessionID == \\\"\\\" || content.Metadata.Agent == \\\"\\\" {\\n   838→\\t\\t\\tcontinue\\n   839→\\t\\t}\\n   840→\\n   841→\\t\\tsessionAgent, agErr := ResolveAgentForRewind(content.Metadata.Agent)\\n   842→\\t\\tif agErr != nil {\\n   843→\\t\\t\\tcontinue\\n   844→\\t\\t}\\n   845→\\n   846→\\t\\t// Compute transcript path from current repo location for cross-machine portability.\\n   847→\\t\\tsessionAgentDir, dirErr := sessionAgent.GetSessionDir(repoRoot)\\n   848→\\t\\tif dirErr != nil {\\n   849→\\t\\t\\tcontinue\\n   850→\\t\\t}\\n   851→\\t\\tlocalPath := sessionAgent.ResolveSessionFile(sessionAgentDir, sessionID)\\n   852→\\n   853→\\t\\tlocalTime := paths.GetLastTimestampFromFile(localPath)\\n   854→\\t\\tcheckpointTime := paths.GetLastTimestampFromBytes(content.Transcript)\\n   855→\\t\\tstatus := ClassifyTimestamps(localTime, checkpointTime)\\n   856→\\n   857→\\t\\tsessions = append(sessions, SessionRestoreInfo{\\n   858→\\t\\t\\tSessionID:      sessionID,\\n   859→\\t\\t\\tPrompt:         ExtractFirstPrompt(content.Prompts),\\n   860→\\t\\t\\tStatus:         status,\\n   861→\\t\\t\\tLocalTime:      localTime,\\n   862→\\t\\t\\tCheckpointTime: checkpointTime,\\n   863→\\t\\t})\\n   864→\\t}\\n   865→\\n   866→\\treturn sessions\\n   867→}\\n   868→\\n   869→// ClassifyTimestamps determines the restore status based on local and checkpoint timestamps.\\n   870→func ClassifyTimestamps(localTime, checkpointTime time.Time) SessionRestoreStatus {\\n   871→\\t// Local file doesn't exist (no timestamp found)\\n   872→\\tif localTime.IsZero() {\\n   873→\\t\\treturn StatusNew\\n   874→\\t}\\n   875→\\n   876→\\t// Can't determine checkpoint time - treat as new/safe\\n   877→\\tif checkpointTime.IsZero() {\\n   878→\\t\\treturn StatusNew\\n   879→\\t}\\n   880→\\n   881→\\t// Compare timestamps\\n   882→\\tif localTime.After(checkpointTime) {\\n   883→\\t\\treturn StatusLocalNewer\\n   884→\\t}\\n   885→\\tif checkpointTime.After(localTime) {\\n   886→\\t\\treturn StatusCheckpointNewer\\n   887→\\t}\\n   888→\\treturn StatusUnchanged\\n   889→}\\n   890→\\n   891→// StatusToText returns a human-readable status string.\\n   892→func StatusToText(status SessionRestoreStatus) string {\\n   893→\\tswitch status {\\n   894→\\tcase StatusNew:\\n   895→\\t\\treturn \\\"(new)\\\"\\n   896→\\tcase StatusUnchanged:\\n   897→\\t\\treturn \\\"(unchanged)\\\"\\n   898→\\tcase StatusCheckpointNewer:\\n   899→\\t\\treturn \\\"(checkpoint is newer)\\\"\\n   900→\\tcase StatusLocalNewer:\\n   901→\\t\\treturn \\\"(local is newer)\\\" // shouldn't appear in non-conflict list\\n   902→\\tdefault:\\n   903→\\t\\treturn \\\"\\\"\\n   904→\\t}\\n   905→}\\n   906→\\n   907→// PromptOverwriteNewerLogs asks the user for confirmation to overwrite local\\n   908→// session logs that have newer timestamps than the checkpoint versions.\\n   909→func PromptOverwriteNewerLogs(sessions []SessionRestoreInfo) (bool, error) {\\n   910→\\t// Separate conflicting and non-conflicting sessions\\n   911→\\tvar conflicting, nonConflicting []SessionRestoreInfo\\n   912→\\tfor _, s := range sessions {\\n   913→\\t\\tif s.Status == StatusLocalNewer {\\n   914→\\t\\t\\tconflicting = append(conflicting, s)\\n   915→\\t\\t} else {\\n   916→\\t\\t\\tnonConflicting = append(nonConflicting, s)\\n   917→\\t\\t}\\n   918→\\t}\\n   919→\\n   920→\\tfmt.Fprintf(os.Stderr, \\\"\\\\nWarning: Local session log(s) have newer entries than the checkpoint:\\\\n\\\")\\n   921→\\tfor _, info := range conflicting {\\n   922→\\t\\t// Show prompt if available, otherwise fall back to session ID\\n   923→\\t\\tif info.Prompt != \\\"\\\" {\\n   924→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  \\\\\\\"%s\\\\\\\"\\\\n\\\", info.Prompt)\\n   925→\\t\\t} else {\\n   926→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Session: %s\\\\n\\\", info.SessionID)\\n   927→\\t\\t}\\n   928→\\t\\tfmt.Fprintf(os.Stderr, \\\"    Local last entry:      %s\\\\n\\\", info.LocalTime.Local().Format(\\\"2006-01-02 15:04:05\\\"))\\n   929→\\t\\tfmt.Fprintf(os.Stderr, \\\"    Checkpoint last entry: %s\\\\n\\\", info.CheckpointTime.Local().Format(\\\"2006-01-02 15:04:05\\\"))\\n   930→\\t}\\n   931→\\n   932→\\t// Show non-conflicting sessions with their status\\n   933→\\tif len(nonConflicting) > 0 {\\n   934→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nThese other session(s) will also be restored:\\\\n\\\")\\n   935→\\t\\tfor _, info := range nonConflicting {\\n   936→\\t\\t\\tstatusText := StatusToText(info.Status)\\n   937→\\t\\t\\tif info.Prompt != \\\"\\\" {\\n   938→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  \\\\\\\"%s\\\\\\\" %s\\\\n\\\", info.Prompt, statusText)\\n   939→\\t\\t\\t} else {\\n   940→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Session: %s %s\\\\n\\\", info.SessionID, statusText)\\n   941→\\t\\t\\t}\\n   942→\\t\\t}\\n   943→\\t}\\n   944→\\n   945→\\tfmt.Fprintf(os.Stderr, \\\"\\\\nOverwriting will lose the newer local entries.\\\\n\\\\n\\\")\\n   946→\\n   947→\\tvar confirmed bool\\n   948→\\tform := huh.NewForm(\\n   949→\\t\\thuh.NewGroup(\\n   950→\\t\\t\\thuh.NewConfirm().\\n   951→\\t\\t\\t\\tTitle(\\\"Overwrite local session logs with checkpoint versions?\\\").\\n   952→\\t\\t\\t\\tValue(&confirmed),\\n   953→\\t\\t),\\n   954→\\t)\\n   955→\\tif isAccessibleMode() {\\n   956→\\t\\tform = form.WithAccessible(true)\\n   957→\\t}\\n   958→\\n   959→\\tif err := form.Run(); err != nil {\\n   960→\\t\\tif errors.Is(err, huh.ErrUserAborted) {\\n   961→\\t\\t\\treturn false, nil\\n   962→\\t\\t}\\n   963→\\t\\treturn false, fmt.Errorf(\\\"failed to get confirmation: %w\\\", err)\\n   964→\\t}\\n   965→\\n   966→\\treturn confirmed, nil\\n   967→}\\n   968→\"}]},\"uuid\":\"f13cbcd2-fe28-4829-90ef-ed94321f5b48\",\"timestamp\":\"2026-02-19T15:14:16.953Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/strategy/manual_commit_rewind.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"sort\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n\\n\\t\\\"github.com/charmbracelet/huh\\\"\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/filemode\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// GetRewindPoints returns available rewind points.\\n// Uses checkpoint.GitStore.ListTemporaryCheckpoints for reading from shadow branches.\\nfunc (s *ManualCommitStrategy) GetRewindPoints(limit int) ([]RewindPoint, error) {\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n\\t}\\n\\n\\t// Get checkpoint store\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get current HEAD to find matching shadow branch\\n\\thead, err := repo.Head()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n\\t}\\n\\n\\t// Find sessions for current HEAD\\n\\tsessions, err := s.findSessionsForCommit(head.Hash().String())\\n\\tif err != nil {\\n\\t\\t// Log error but continue to check for logs-only points\\n\\t\\tsessions = nil\\n\\t}\\n\\n\\tvar allPoints []RewindPoint\\n\\n\\t// Collect checkpoint points from active sessions using checkpoint.GitStore\\n\\t// Cache session prompts by session ID to avoid re-reading the same prompt file\\n\\tsessionPrompts := make(map[string]string)\\n\\n\\tfor _, state := range sessions {\\n\\t\\tcheckpoints, err := store.ListTemporaryCheckpoints(context.Background(), state.BaseCommit, state.WorktreeID, state.SessionID, limit)\\n\\t\\tif err != nil {\\n\\t\\t\\tcontinue // Error reading checkpoints, skip this session\\n\\t\\t}\\n\\n\\t\\tfor _, cp := range checkpoints {\\n\\t\\t\\t// Get session prompt (cached by session ID)\\n\\t\\t\\tsessionPrompt, ok := sessionPrompts[cp.SessionID]\\n\\t\\t\\tif !ok {\\n\\t\\t\\t\\tsessionPrompt = readSessionPrompt(repo, cp.CommitHash, cp.MetadataDir)\\n\\t\\t\\t\\tsessionPrompts[cp.SessionID] = sessionPrompt\\n\\t\\t\\t}\\n\\n\\t\\t\\tallPoints = append(allPoints, RewindPoint{\\n\\t\\t\\t\\tID:               cp.CommitHash.String(),\\n\\t\\t\\t\\tMessage:          cp.Message,\\n\\t\\t\\t\\tMetadataDir:      cp.MetadataDir,\\n\\t\\t\\t\\tDate:             cp.Timestamp,\\n\\t\\t\\t\\tIsTaskCheckpoint: cp.IsTaskCheckpoint,\\n\\t\\t\\t\\tToolUseID:        cp.ToolUseID,\\n\\t\\t\\t\\tSessionID:        cp.SessionID,\\n\\t\\t\\t\\tSessionPrompt:    sessionPrompt,\\n\\t\\t\\t\\tAgent:            state.AgentType,\\n\\t\\t\\t})\\n\\t\\t}\\n\\t}\\n\\n\\t// Sort by date, most recent first\\n\\tsort.Slice(allPoints, func(i, j int) bool {\\n\\t\\treturn allPoints[i].Date.After(allPoints[j].Date)\\n\\t})\\n\\n\\tif len(allPoints) > limit {\\n\\t\\tallPoints = allPoints[:limit]\\n\\t}\\n\\n\\t// Also include logs-only points from commit history\\n\\tlogsOnlyPoints, err := s.GetLogsOnlyRewindPoints(limit)\\n\\tif err == nil && len(logsOnlyPoints) > 0 {\\n\\t\\t// Build set of existing point IDs for deduplication\\n\\t\\texistingIDs := make(map[string]bool)\\n\\t\\tfor _, p := range allPoints {\\n\\t\\t\\texistingIDs[p.ID] = true\\n\\t\\t}\\n\\n\\t\\t// Add logs-only points that aren't already in the list\\n\\t\\tfor _, p := range logsOnlyPoints {\\n\\t\\t\\tif !existingIDs[p.ID] {\\n\\t\\t\\t\\tallPoints = append(allPoints, p)\\n\\t\\t\\t}\\n\\t\\t}\\n\\n\\t\\t// Re-sort by date\\n\\t\\tsort.Slice(allPoints, func(i, j int) bool {\\n\\t\\t\\treturn allPoints[i].Date.After(allPoints[j].Date)\\n\\t\\t})\\n\\n\\t\\t// Re-trim to limit\\n\\t\\tif len(allPoints) > limit {\\n\\t\\t\\tallPoints = allPoints[:limit]\\n\\t\\t}\\n\\t}\\n\\n\\treturn allPoints, nil\\n}\\n\\n// GetLogsOnlyRewindPoints finds commits in the current branch's history that have\\n// condensed session logs on the entire/checkpoints/v1 branch. These are commits that\\n// were created with session data but the shadow branch has been condensed.\\n//\\n// The function works by:\\n// 1. Getting all checkpoints from the entire/checkpoints/v1 branch\\n// 2. Building a map of checkpoint ID -> checkpoint info\\n// 3. Scanning the current branch history for commits with Entire-Checkpoint trailers\\n// 4. Matching by checkpoint ID (stable across amend/rebase)\\nfunc (s *ManualCommitStrategy) GetLogsOnlyRewindPoints(limit int) ([]RewindPoint, error) {\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\t// Get all checkpoints from entire/checkpoints/v1 branch\\n\\tcheckpoints, err := s.listCheckpoints()\\n\\tif err != nil {\\n\\t\\t// No checkpoints yet is fine\\n\\t\\treturn nil, nil //nolint:nilerr // Expected when no checkpoints exist\\n\\t}\\n\\n\\tif len(checkpoints) == 0 {\\n\\t\\treturn nil, nil\\n\\t}\\n\\n\\t// Build map of checkpoint ID -> checkpoint info\\n\\t// Checkpoint ID is the stable link from Entire-Checkpoint trailer\\n\\tcheckpointInfoMap := make(map[id.CheckpointID]CheckpointInfo)\\n\\tfor _, cp := range checkpoints {\\n\\t\\tif !cp.CheckpointID.IsEmpty() {\\n\\t\\t\\tcheckpointInfoMap[cp.CheckpointID] = cp\\n\\t\\t}\\n\\t}\\n\\n\\t// Get metadata branch tree for reading session prompts (best-effort, ignore errors)\\n\\tmetadataTree, _ := GetMetadataBranchTree(repo) //nolint:errcheck // Best-effort for session prompts\\n\\n\\thead, err := repo.Head()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n\\t}\\n\\n\\t// Use LogOptions with Order=LogOrderCommitterTime to traverse all parents of merge commits.\\n\\titer, err := repo.Log(&git.LogOptions{\\n\\t\\tFrom:  head.Hash(),\\n\\t\\tOrder: git.LogOrderCommitterTime,\\n\\t})\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n\\t}\\n\\n\\tvar points []RewindPoint\\n\\tcount := 0\\n\\n\\terr = iter.ForEach(func(c *object.Commit) error {\\n\\t\\tif count >= logsOnlyScanLimit {\\n\\t\\t\\treturn errStop\\n\\t\\t}\\n\\t\\tcount++\\n\\n\\t\\t// Extract checkpoint ID from Entire-Checkpoint trailer (ParseCheckpoint validates format)\\n\\t\\tcpID, found := trailers.ParseCheckpoint(c.Message)\\n\\t\\tif !found {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\t// Check if this checkpoint ID has metadata on entire/checkpoints/v1\\n\\t\\tcpInfo, found := checkpointInfoMap[cpID]\\n\\t\\tif !found {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\t// Create logs-only rewind point\\n\\t\\tmessage := strings.Split(c.Message, \\\"\\\\n\\\")[0]\\n\\n\\t\\t// Read session prompts from metadata tree\\n\\t\\tvar sessionPrompt string\\n\\t\\tvar sessionPrompts []string\\n\\t\\tif metadataTree != nil {\\n\\t\\t\\tcheckpointPath := paths.CheckpointPath(cpInfo.CheckpointID) //nolint:staticcheck // already present in codebase\\n\\t\\t\\t// For multi-session checkpoints, read all prompts\\n\\t\\t\\tif cpInfo.SessionCount > 1 && len(cpInfo.SessionIDs) > 1 {\\n\\t\\t\\t\\tsessionPrompts = ReadAllSessionPromptsFromTree(metadataTree, checkpointPath, cpInfo.SessionCount, cpInfo.SessionIDs)\\n\\t\\t\\t\\t// Use the last (most recent) prompt as the main session prompt\\n\\t\\t\\t\\tif len(sessionPrompts) > 0 {\\n\\t\\t\\t\\t\\tsessionPrompt = sessionPrompts[len(sessionPrompts)-1]\\n\\t\\t\\t\\t}\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tsessionPrompt = ReadSessionPromptFromTree(metadataTree, checkpointPath)\\n\\t\\t\\t\\tif sessionPrompt != \\\"\\\" {\\n\\t\\t\\t\\t\\tsessionPrompts = []string{sessionPrompt}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\n\\t\\tpoints = append(points, RewindPoint{\\n\\t\\t\\tID:             c.Hash.String(),\\n\\t\\t\\tMessage:        message,\\n\\t\\t\\tDate:           c.Author.When,\\n\\t\\t\\tIsLogsOnly:     true,\\n\\t\\t\\tCheckpointID:   cpInfo.CheckpointID,\\n\\t\\t\\tAgent:          cpInfo.Agent,\\n\\t\\t\\tSessionID:      cpInfo.SessionID,\\n\\t\\t\\tSessionPrompt:  sessionPrompt,\\n\\t\\t\\tSessionCount:   cpInfo.SessionCount,\\n\\t\\t\\tSessionIDs:     cpInfo.SessionIDs,\\n\\t\\t\\tSessionPrompts: sessionPrompts,\\n\\t\\t})\\n\\n\\t\\treturn nil\\n\\t})\\n\\n\\tif err != nil && !errors.Is(err, errStop) {\\n\\t\\treturn nil, fmt.Errorf(\\\"error iterating commits: %w\\\", err)\\n\\t}\\n\\n\\tif len(points) > limit {\\n\\t\\tpoints = points[:limit]\\n\\t}\\n\\n\\treturn points, nil\\n}\\n\\n// Rewind restores the working directory to a checkpoint.\\n//\\n\\nfunc (s *ManualCommitStrategy) Rewind(point RewindPoint) err