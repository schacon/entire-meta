\\n    83→}\\n    84→\\n    85→// CapturePrePromptState captures current untracked files and transcript position before a prompt\\n    86→// and saves them to a state file.\\n    87→//\\n    88→// The agent parameter is used to determine the transcript position via TranscriptAnalyzer.\\n    89→// If the agent does not implement TranscriptAnalyzer, the transcript offset will be 0.\\n    90→// The sessionRef parameter is optional — if empty, transcript position won't be captured.\\n    91→//\\n    92→// Works correctly from any subdirectory within the repository.\\n    93→func CapturePrePromptState(ctx context.Context, ag agent.Agent, sessionID, sessionRef string) error {\\n    94→\\tif sessionID == \\\"\\\" {\\n    95→\\t\\tsessionID = unknownSessionID\\n    96→\\t}\\n    97→\\n    98→\\t// Get absolute path for tmp directory\\n    99→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   100→\\tif err != nil {\\n   101→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   102→\\t}\\n   103→\\n   104→\\t// Create tmp directory if it doesn't exist\\n   105→\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   106→\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n   107→\\t}\\n   108→\\n   109→\\t// Get list of untracked files (excluding .entire directory itself)\\n   110→\\tuntrackedFiles, err := getUntrackedFilesForState(ctx)\\n   111→\\tif err != nil {\\n   112→\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n   113→\\t}\\n   114→\\n   115→\\t// Get transcript position using TranscriptAnalyzer if available\\n   116→\\tvar transcriptOffset int\\n   117→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok && sessionRef != \\\"\\\" {\\n   118→\\t\\tpos, posErr := analyzer.GetTranscriptPosition(sessionRef)\\n   119→\\t\\tif posErr != nil {\\n   120→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to get transcript position: %v\\\\n\\\", posErr)\\n   121→\\t\\t} else {\\n   122→\\t\\t\\ttranscriptOffset = pos\\n   123→\\t\\t}\\n   124→\\t}\\n   125→\\n   126→\\t// Create state file\\n   127→\\tstateFile := prePromptStateFile(ctx, sessionID)\\n   128→\\tstate := PrePromptState{\\n   129→\\t\\tSessionID:        sessionID,\\n   130→\\t\\tTimestamp:        time.Now().UTC().Format(time.RFC3339),\\n   131→\\t\\tUntrackedFiles:   untrackedFiles,\\n   132→\\t\\tTranscriptOffset: transcriptOffset,\\n   133→\\t}\\n   134→\\n   135→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   136→\\tif err != nil {\\n   137→\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n   138→\\t}\\n   139→\\n   140→\\tif err := os.WriteFile(stateFile, data, 0o600); err != nil {\\n   141→\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   142→\\t}\\n   143→\\n   144→\\tfmt.Fprintf(os.Stderr, \\\"Captured state before prompt: %d untracked files, transcript offset: %d\\\\n\\\",\\n   145→\\t\\tlen(untrackedFiles), transcriptOffset)\\n   146→\\treturn nil\\n   147→}\\n   148→\\n   149→// LoadPrePromptState loads previously captured state.\\n   150→// Returns nil if no state file exists.\\n   151→func LoadPrePromptState(ctx context.Context, sessionID string) (*PrePromptState, error) {\\n   152→\\tstateFile := prePromptStateFile(ctx, sessionID)\\n   153→\\n   154→\\tif !fileExists(stateFile) {\\n   155→\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   156→\\t}\\n   157→\\n   158→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // Reading from controlled git metadata path\\n   159→\\tif err != nil {\\n   160→\\t\\treturn nil, fmt.Errorf(\\\"failed to read state file: %w\\\", err)\\n   161→\\t}\\n   162→\\n   163→\\tvar state PrePromptState\\n   164→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   165→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal state: %w\\\", err)\\n   166→\\t}\\n   167→\\n   168→\\tstate.normalizePrePromptState()\\n   169→\\n   170→\\treturn &state, nil\\n   171→}\\n   172→\\n   173→// CleanupPrePromptState removes the state file after use\\n   174→func CleanupPrePromptState(ctx context.Context, sessionID string) error {\\n   175→\\tstateFile := prePromptStateFile(ctx, sessionID)\\n   176→\\tif fileExists(stateFile) {\\n   177→\\t\\treturn os.Remove(stateFile) //nolint:wrapcheck // already present in codebase\\n   178→\\t}\\n   179→\\treturn nil\\n   180→}\\n   181→\\n   182→// FileChanges holds categorized file changes from git status.\\n   183→type FileChanges struct {\\n   184→\\tModified []string // Modified or staged files\\n   185→\\tNew      []string // Untracked files (filtered if previouslyUntracked provided)\\n   186→\\tDeleted  []string // Deleted files (staged or unstaged)\\n   187→}\\n   188→\\n   189→// DetectFileChanges returns categorized file changes from the current git status.\\n   190→//\\n   191→// previouslyUntracked controls new-file detection:\\n   192→//   - nil: all untracked files go into New\\n   193→//   - non-nil: only untracked files NOT in the pre-existing set go into New\\n   194→//\\n   195→// Modified includes both worktree and staging modified/added files.\\n   196→// Deleted includes both staged and unstaged deletions.\\n   197→// All results exclude .entire/ directory.\\n   198→func DetectFileChanges(ctx context.Context, previouslyUntracked []string) (*FileChanges, error) {\\n   199→\\trepo, err := openRepository(ctx)\\n   200→\\tif err != nil {\\n   201→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   202→\\t}\\n   203→\\n   204→\\tworktree, err := repo.Worktree()\\n   205→\\tif err != nil {\\n   206→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   207→\\t}\\n   208→\\n   209→\\tstatus, err := worktree.Status()\\n   210→\\tif err != nil {\\n   211→\\t\\treturn nil, fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n   212→\\t}\\n   213→\\n   214→\\t// Build set of pre-existing untracked files for quick lookup\\n   215→\\tvar preExisting map[string]bool\\n   216→\\tif previouslyUntracked != nil {\\n   217→\\t\\tpreExisting = make(map[string]bool, len(previouslyUntracked))\\n   218→\\t\\tfor _, f := range previouslyUntracked {\\n   219→\\t\\t\\tpreExisting[f] = true\\n   220→\\t\\t}\\n   221→\\t}\\n   222→\\n   223→\\tvar changes FileChanges\\n   224→\\tfor file, st := range status {\\n   225→\\t\\tif paths.IsInfrastructurePath(file) {\\n   226→\\t\\t\\tcontinue\\n   227→\\t\\t}\\n   228→\\n   229→\\t\\tswitch {\\n   230→\\t\\tcase st.Worktree == git.Untracked:\\n   231→\\t\\t\\tif preExisting != nil {\\n   232→\\t\\t\\t\\tif !preExisting[file] {\\n   233→\\t\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   234→\\t\\t\\t\\t}\\n   235→\\t\\t\\t} else {\\n   236→\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   237→\\t\\t\\t}\\n   238→\\t\\tcase st.Worktree == git.Deleted || st.Staging == git.Deleted:\\n   239→\\t\\t\\tchanges.Deleted = append(changes.Deleted, file)\\n   240→\\t\\tcase st.Worktree == git.Modified || st.Staging == git.Modified ||\\n   241→\\t\\t\\tst.Worktree == git.Added || st.Staging == git.Added:\\n   242→\\t\\t\\tchanges.Modified = append(changes.Modified, file)\\n   243→\\t\\t}\\n   244→\\t}\\n   245→\\n   246→\\treturn &changes, nil\\n   247→}\\n   248→\\n   249→// filterToUncommittedFiles removes files from the list that are already committed to HEAD\\n   250→// with matching content. This prevents re-adding files that an agent committed mid-turn\\n   251→// (already condensed by PostCommit) back to FilesTouched via SaveStep. Files not in\\n   252→// HEAD or with different content in the working tree are kept. Fails open: if any git\\n   253→// operation errors, returns the original list unchanged.\\n   254→func filterToUncommittedFiles(ctx context.Context, files []string, repoRoot string) []string {\\n   255→\\tif len(files) == 0 {\\n   256→\\t\\treturn files\\n   257→\\t}\\n   258→\\n   259→\\trepo, err := openRepository(ctx)\\n   260→\\tif err != nil {\\n   261→\\t\\treturn files // fail open\\n   262→\\t}\\n   263→\\n   264→\\thead, err := repo.Head()\\n   265→\\tif err != nil {\\n   266→\\t\\treturn files // fail open (empty repo, detached HEAD, etc.)\\n   267→\\t}\\n   268→\\n   269→\\tcommit, err := repo.CommitObject(head.Hash())\\n   270→\\tif err != nil {\\n   271→\\t\\treturn files // fail open\\n   272→\\t}\\n   273→\\n   274→\\theadTree, err := commit.Tree()\\n   275→\\tif err != nil {\\n   276→\\t\\treturn files // fail open\\n   277→\\t}\\n   278→\\n   279→\\tvar result []string\\n   280→\\tfor _, relPath := range files {\\n   281→\\t\\theadFile, err := headTree.File(relPath)\\n   282→\\t\\tif err != nil {\\n   283→\\t\\t\\t// File not in HEAD — it's uncommitted\\n   284→\\t\\t\\tresult = append(result, relPath)\\n   285→\\t\\t\\tcontinue\\n   286→\\t\\t}\\n   287→\\n   288→\\t\\t// File is in HEAD — compare content with working tree\\n   289→\\t\\tabsPath := filepath.Join(repoRoot, relPath)\\n   290→\\t\\tworkingContent, err := os.ReadFile(absPath) //nolint:gosec // path from controlled source\\n   291→\\t\\tif err != nil {\\n   292→\\t\\t\\t// Can't read working tree file (deleted?) — keep it\\n   293→\\t\\t\\tresult = append(result, relPath)\\n   294→\\t\\t\\tcontinue\\n   295→\\t\\t}\\n   296→\\n   297→\\t\\theadContent, err := headFile.Contents()\\n   298→\\t\\tif err != nil {\\n   299→\\t\\t\\tresult = append(result, relPath)\\n   300→\\t\\t\\tcontinue\\n   301→\\t\\t}\\n   302→\\n   303→\\t\\tif string(workingContent) != headContent {\\n   304→\\t\\t\\t// Working tree differs from HEAD — uncommitted changes\\n   305→\\t\\t\\tresult = append(result, relPath)\\n   306→\\t\\t}\\n   307→\\t\\t// else: content matches HEAD — already committed, skip\\n   308→\\t}\\n   309→\\n   310→\\treturn result\\n   311→}\\n   312→\\n   313→// FilterAndNormalizePaths converts absolute paths to relative and filters out\\n   314→// infrastructure paths and paths outside the repo.\\n   315→func FilterAndNormalizePaths(files []string, cwd string) []string {\\n   316→\\tvar result []string\\n   317→\\tfor _, file := range files {\\n   318→\\t\\trelPath := paths.ToRelativePath(file, cwd)\\n   319→\\t\\tif relPath == \\\"\\\" {\\n   320→\\t\\t\\tcontinue // outside repo\\n   321→\\t\\t}\\n   322→\\t\\tif paths.IsInfrastructurePath(relPath) {\\n   323→\\t\\t\\tcontinue // skip .entire directory\\n   324→\\t\\t}\\n   325→\\t\\tresult = append(result, relPath)\\n   326→\\t}\\n   327→\\treturn result\\n   328→}\\n   329→\\n   330→// mergeUnique appends elements from extra into base, skipping duplicates already in base.\\n   331→func mergeUnique(base, extra []string) []string {\\n   332→\\tif len(extra) == 0 {\\n   333→\\t\\treturn base\\n   334→\\t}\\n   335→\\tseen := make(map[string]bool, len(base))\\n   336→\\tfor _, s := range base {\\n   337→\\t\\tseen[s] = true\\n   338→\\t}\\n   339→\\tfor _, s := range extra {\\n   340→\\t\\tif !seen[s] {\\n   341→\\t\\t\\tseen[s] = true\\n   342→\\t\\t\\tbase = append(base, s)\\n   343→\\t\\t}\\n   344→\\t}\\n   345→\\treturn base\\n   346→}\\n   347→\\n   348→// prePromptStateFile returns the absolute path to the pre-prompt state file for a session.\\n   349→// Works correctly from any subdirectory within the repository.\\n   350→func prePromptStateFile(ctx context.Context, sessionID string) string {\\n   351→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   352→\\tif err != nil {\\n   353→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   354→\\t}\\n   355→\\treturn filepath.Join(tmpDirAbs, fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID))\\n   356→}\\n   357→\\n   358→// getUntrackedFilesForState returns a list of untracked files using go-git\\n   359→// Excludes .entire directory\\n   360→func getUntrackedFilesForState(ctx context.Context) ([]string, error) {\\n   361→\\trepo, err := openRepository(ctx)\\n   362→\\tif err != nil {\\n   363→\\t\\treturn nil, err\\n   364→\\t}\\n   365→\\n   366→\\tworktree, err := repo.Worktree()\\n   367→\\tif err != nil {\\n   368→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   369→\\t}\\n   370→\\n   371→\\tstatus, err := worktree.Status()\\n   372→\\tif err != nil {\\n   373→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   374→\\t}\\n   375→\\n   376→\\tuntrackedFiles := []string{}\\n   377→\\tfor file, st := range status {\\n   378→\\t\\tif st.Worktree == git.Untracked {\\n   379→\\t\\t\\t// Exclude .entire directory\\n   380→\\t\\t\\tif !strings.HasPrefix(file, paths.EntireDir+\\\"/\\\") && file != paths.EntireDir {\\n   381→\\t\\t\\t\\tuntrackedFiles = append(untrackedFiles, file)\\n   382→\\t\\t\\t}\\n   383→\\t\\t}\\n   384→\\t}\\n   385→\\n   386→\\treturn untrackedFiles, nil\\n   387→}\\n   388→\\n   389→// PreTaskState stores the state captured before a task execution\\n   390→type PreTaskState struct {\\n   391→\\tToolUseID      string   `json:\\\"tool_use_id\\\"`\\n   392→\\tTimestamp      string   `json:\\\"timestamp\\\"`\\n   393→\\tUntrackedFiles []string `json:\\\"untracked_files\\\"`\\n   394→}\\n   395→\\n   396→// PreUntrackedFiles returns the untracked files list, or nil if the receiver is nil.\\n   397→// See PrePromptState.PreUntrackedFiles for nil-vs-empty semantics.\\n   398→func (s *PreTaskState) PreUntrackedFiles() []string {\\n   399→\\tif s == nil {\\n   400→\\t\\treturn nil\\n   401→\\t}\\n   402→\\tif s.UntrackedFiles == nil {\\n   403→\\t\\treturn []string{}\\n   404→\\t}\\n   405→\\treturn s.UntrackedFiles\\n   406→}\\n   407→\\n   408→// CapturePreTaskState captures current untracked files before a Task execution\\n   409→// and saves them to a state file.\\n   410→// Works correctly from any subdirectory within the repository.\\n   411→func CapturePreTaskState(ctx context.Context, toolUseID string) error {\\n   412→\\tif toolUseID == \\\"\\\" {\\n   413→\\t\\treturn errors.New(\\\"tool_use_id is required\\\")\\n   414→\\t}\\n   415→\\n   416→\\t// Get absolute path for tmp directory\\n   417→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   418→\\tif err != nil {\\n   419→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   420→\\t}\\n   421→\\n   422→\\t// Create tmp directory if it doesn't exist\\n   423→\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   424→\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n   425→\\t}\\n   426→\\n   427→\\t// Get list of untracked files (excluding .entire directory itself)\\n   428→\\tuntrackedFiles, err := getUntrackedFilesForState(ctx)\\n   429→\\tif err != nil {\\n   430→\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n   431→\\t}\\n   432→\\n   433→\\t// Create state file\\n   434→\\tstateFile := preTaskStateFile(ctx, toolUseID)\\n   435→\\tstate := PreTaskState{\\n   436→\\t\\tToolUseID:      toolUseID,\\n   437→\\t\\tTimestamp:      time.Now().UTC().Format(time.RFC3339),\\n   438→\\t\\tUntrackedFiles: untrackedFiles,\\n   439→\\t}\\n   440→\\n   441→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   442→\\tif err != nil {\\n   443→\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n   444→\\t}\\n   445→\\n   446→\\tif err := os.WriteFile(stateFile, data, 0o600); err != nil {\\n   447→\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   448→\\t}\\n   449→\\n   450→\\tfmt.Fprintf(os.Stderr, \\\"Captured state before task: %d untracked files\\\\n\\\", len(untrackedFiles))\\n   451→\\treturn nil\\n   452→}\\n   453→\\n   454→// LoadPreTaskState loads previously captured task state.\\n   455→// Returns nil if no state file exists.\\n   456→func LoadPreTaskState(ctx context.Context, toolUseID string) (*PreTaskState, error) {\\n   457→\\tstateFile := preTaskStateFile(ctx, toolUseID)\\n   458→\\n   459→\\tif !fileExists(stateFile) {\\n   460→\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   461→\\t}\\n   462→\\n   463→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // Reading from controlled git metadata path\\n   464→\\tif err != nil {\\n   465→\\t\\treturn nil, fmt.Errorf(\\\"failed to read state file: %w\\\", err)\\n   466→\\t}\\n   467→\\n   468→\\tvar state PreTaskState\\n   469→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   470→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal state: %w\\\", err)\\n   471→\\t}\\n   472→\\n   473→\\treturn &state, nil\\n   474→}\\n   475→\\n   476→// CleanupPreTaskState removes the task state file after use\\n   477→func CleanupPreTaskState(ctx context.Context, toolUseID string) error {\\n   478→\\tstateFile := preTaskStateFile(ctx, toolUseID)\\n   479→\\tif fileExists(stateFile) {\\n   480→\\t\\treturn os.Remove(stateFile) //nolint:wrapcheck // already present in codebase\\n   481→\\t}\\n   482→\\treturn nil\\n   483→}\\n   484→\\n   485→// preTaskStateFile returns the absolute path to the pre-task state file for a tool use.\\n   486→// Works correctly from any subdirectory within the repository.\\n   487→func preTaskStateFile(ctx context.Context, toolUseID string) string {\\n   488→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   489→\\tif err != nil {\\n   490→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   491→\\t}\\n   492→\\treturn filepath.Join(tmpDirAbs, fmt.Sprintf(\\\"pre-task-%s.json\\\", toolUseID))\\n   493→}\\n   494→\\n   495→// preTaskFilePrefix is the prefix for pre-task state files\\n   496→const preTaskFilePrefix = \\\"pre-task-\\\"\\n   497→\\n   498→// FindActivePreTaskFile finds an active pre-task file in .entire/tmp/ and returns\\n   499→// the parent Task's tool_use_id. Returns (\\\"\\\", false) if no pre-task file exists.\\n   500→// When multiple pre-task files exist (nested subagents), returns the most recently\\n   501→// modified one.\\n   502→// Works correctly from any subdirectory within the repository.\\n   503→func FindActivePreTaskFile(ctx context.Context) (taskToolUseID string, found bool) {\\n   504→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   505→\\tif err != nil {\\n   506→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   507→\\t}\\n   508→\\tentries, err := os.ReadDir(tmpDirAbs)\\n   509→\\tif err != nil {\\n   510→\\t\\treturn \\\"\\\", false\\n   511→\\t}\\n   512→\\n   513→\\tvar latestFile string\\n   514→\\tvar latestTime time.Time\\n   515→\\n   516→\\tfor _, entry := range entries {\\n   517→\\t\\tif entry.IsDir() {\\n   518→\\t\\t\\tcontinue\\n   519→\\t\\t}\\n   520→\\t\\tname := entry.Name()\\n   521→\\t\\tif !strings.HasPrefix(name, preTaskFilePrefix) || !strings.HasSuffix(name, \\\".json\\\") {\\n   522→\\t\\t\\tcontinue\\n   523→\\t\\t}\\n   524→\\n   525→\\t\\t// Check modification time for nested subagent handling\\n   526→\\t\\tinfo, err := entry.Info()\\n   527→\\t\\tif err != nil {\\n   528→\\t\\t\\tcontinue\\n   529→\\t\\t}\\n   530→\\t\\tif latestFile == \\\"\\\" || info.ModTime().After(latestTime) {\\n   531→\\t\\t\\tlatestFile = name\\n   532→\\t\\t\\tlatestTime = info.ModTime()\\n   533→\\t\\t}\\n   534→\\t}\\n   535→\\n   536→\\tif latestFile == \\\"\\\" {\\n   537→\\t\\treturn \\\"\\\", false\\n   538→\\t}\\n   539→\\n   540→\\t// Extract tool_use_id from filename: pre-task-<tool_use_id>.json\\n   541→\\ttoolUseID := strings.TrimPrefix(latestFile, preTaskFilePrefix)\\n   542→\\ttoolUseID = strings.TrimSuffix(toolUseID, \\\".json\\\")\\n   543→\\treturn toolUseID, true\\n   544→}\\n   545→\\n   546→// GetNextCheckpointSequence returns the next sequence number for incremental checkpoints.\\n   547→// It counts existing checkpoint files in the task metadata checkpoints directory.\\n   548→// Returns 1 if no checkpoints exist yet.\\n   549→func GetNextCheckpointSequence(sessionID, taskToolUseID string) int {\\n   550→\\t// Use the session ID directly as the metadata directory name\\n   551→\\tsessionMetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   552→\\ttaskMetadataDir := strategy.TaskMetadataDir(sessionMetadataDir, taskToolUseID)\\n   553→\\tcheckpointsDir := filepath.Join(taskMetadataDir, \\\"checkpoints\\\")\\n   554→\\n   555→\\tentries, err := os.ReadDir(checkpointsDir)\\n   556→\\tif err != nil {\\n   557→\\t\\t// Directory doesn't exist or can't be read - start at 1\\n   558→\\t\\treturn 1\\n   559→\\t}\\n   560→\\n   561→\\t// Count JSON files (checkpoints)\\n   562→\\tcount := 0\\n   563→\\tfor _, entry := range entries {\\n   564→\\t\\tif !entry.IsDir() && strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   565→\\t\\t\\tcount++\\n   566→\\t\\t}\\n   567→\\t}\\n   568→\\n   569→\\treturn count + 1\\n   570→}\\n   571→\"}]},\"uuid\":\"6258ccd0-c6c8-4c51-8f32-6b20ba9a5cc1\",\"timestamp\":\"2026-02-27T05:05:14.660Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/gtrrz-victor/wks/cli/old-prs/cmd/entire/cli/state.go\",\"content\":\"package cli\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n)\\n\\n// PrePromptState stores the state captured before a user prompt\\ntype PrePromptState struct {\\n\\tSessionID      string   `json:\\\"session_id\\\"`\\n\\tTimestamp      string   `json:\\\"timestamp\\\"`\\n\\tUntrackedFiles []string `json:\\\"untracked_files\\\"`\\n\\n\\t// TranscriptOffset is the unified transcript position when this state was captured.\\n\\t// For Claude Code (JSONL), this is the line count.\\n\\t// For Gemini CLI (JSON), this is the message count.\\n\\t// Zero means not set or session just started.\\n\\tTranscriptOffset int `json:\\\"transcript_offset,omitempty\\\"`\\n\\n\\t// LastTranscriptIdentifier is the agent-specific identifier at the transcript position.\\n\\t// UUID for Claude Code, message ID for Gemini CLI. Optional metadata.\\n\\tLastTranscriptIdentifier string `json:\\\"last_transcript_identifier,omitempty\\\"`\\n\\n\\t// Deprecated: StartMessageIndex is the old Gemini-specific field.\\n\\t// Migrated to TranscriptOffset on load.\\n\\tStartMessageIndex int `json:\\\"start_message_index,omitempty\\\"`\\n\\n\\t// Deprecated: StepTranscriptStart is the old Claude-specific field.\\n\\t// Migrated to TranscriptOffset on load.\\n\\tStepTranscriptStart int `json:\\\"step_transcript_start,omitempty\\\"`\\n\\n\\t// Deprecated: LastTranscriptLineCount is the oldest name for transcript position.\\n\\t// Migrated to TranscriptOffset on load.\\n\\tLastTranscriptLineCount int `json:\\\"last_transcript_line_count,omitempty\\\"`\\n}\\n\\n// PreUntrackedFiles returns the untracked files list, or nil if the receiver is nil.\\n// This nil-vs-empty distinction lets DetectFileChanges know whether to skip new-file detection.\\n// When the receiver is non-nil but UntrackedFiles is nil (e.g., old state files deserialized with\\n// \\\"untracked_files\\\": null), returns an empty non-nil slice so that all current untracked files\\n// are correctly treated as new.\\nfunc (s *PrePromptState) PreUntrackedFiles() []string {\\n\\tif s == nil {\\n\\t\\treturn nil\\n\\t}\\n\\tif s.UntrackedFiles == nil {\\n\\t\\treturn []string{}\\n\\t}\\n\\treturn s.UntrackedFiles\\n}\\n\\n// normalizePrePromptState migrates deprecated fields after loading from JSON.\\nfunc (s *PrePromptState) normalizePrePromptState() {\\n\\t// Migrate the oldest field to the intermediate field first\\n\\tif s.StepTranscriptStart == 0 && s.LastTranscriptLineCount > 0 {\\n\\t\\ts.StepTranscriptStart = s.LastTranscriptLineCount\\n\\t}\\n\\ts.LastTranscriptLineCount = 0\\n\\n\\t// Migrate all deprecated fields to the unified TranscriptOffset\\n\\tif s.TranscriptOffset == 0 {\\n\\t\\tif s.StepTranscriptStart > 0 {\\n\\t\\t\\ts.TranscriptOffset = s.StepTranscriptStart\\n\\t\\t} else if s.StartMessageIndex > 0 {\\n\\t\\t\\ts.TranscriptOffset = s.StartMessageIndex\\n\\t\\t}\\n\\t}\\n\\ts.StepTranscriptStart = 0\\n\\ts.StartMessageIndex = 0\\n}\\n\\n// CapturePrePromptState captures current untracked files and transcript position before a prompt\\n// and saves them to a state file.\\n//\\n// The agent parameter is used to determine the transcript position via TranscriptAnalyzer.\\n// If the agent does not implement TranscriptAnalyzer, the transcript offset will be 0.\\n// The sessionRef parameter is optional — if empty, transcript position won't be captured.\\n//\\n// Works correctly from any subdirectory within the repository.\\nfunc CapturePrePromptState(ctx context.Context, ag agent.Agent, sessionID, sessionRef string) error {\\n\\tif sessionID == \\\"\\\" {\\n\\t\\tsessionID = unknownSessionID\\n\\t}\\n\\n\\t// Get absolute path for tmp directory\\n\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n\\tif err != nil {\\n\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n\\t}\\n\\n\\t// Create tmp directory if it doesn't exist\\n\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n\\t}\\n\\n\\t// Get list of untracked files (excluding .entire directory itself)\\n\\tuntrackedFiles, err := getUntrackedFilesForState(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n\\t}\\n\\n\\t// Get transcript position using TranscriptAnalyzer if available\\n\\tvar transcriptOffset int\\n\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok && sessionRef != \\\"\\\" {\\n\\t\\tpos, posErr := analyzer.GetTranscriptPosition(sessionRef)\\n\\t\\tif posErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to get transcript position: %v\\\\n\\\", posErr)\\n\\t\\t} else {\\n\\t\\t\\ttranscriptOffset = pos\\n\\t\\t}\\n\\t}\\n\\n\\t// Create state file\\n\\tstateFile := prePromptStateFile(ctx, sessionID)\\n\\tstate := PrePromptState{\\n\\t\\tSessionID:        sessionID,\\n\\t\\tTimestamp:        time.Now().UTC().Format(time.RFC3339),\\n\\t\\tUntrackedFiles:   untrackedFiles,\\n\\t\\tTranscriptOffset: transcriptOffset,\\n\\t}\\n\\n\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n\\t}\\n\\n\\tif err := os.WriteFile(stateFile, data, 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n\\t}\\n\\n\\tfmt.Fprintf(os.Stderr, \\\"Captured state before prompt: %d untracked files, transcript offset: %d\\\\n\\\",\\n\\t\\tlen(untrackedFiles), transcriptOffset)\\n\\treturn nil\\n}\\n\\n// LoadPrePromptState loads previously captured state.\\n// Returns nil if no state file exists.\\nfunc LoadPrePromptState(ctx context.Context, sessionID string) (*PrePromptState, error) {\\n\\tstateFile := prePromptStateFile(ctx, sessionID)\\n\\n\\tif !fileExists(stateFile) {\\n\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n\\t}\\n\\n\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // Reading from controlled git metadata path\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read state file: %w\\\", err)\\n\\t}\\n\\n\\tvar state PrePromptState\\n\\tif err := json.Unmarshal(data, &state); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal state: %w\\\", err)\\n\\t}\\n\\n\\tstate.normalizePrePromptState()\\n\\n\\treturn &state, nil\\n}\\n\\n// CleanupPrePromptState removes the state file after use\\nfunc CleanupPrePromptState(ctx context.Context, sessionID string) error {\\n\\tstateFile := prePromptStateFile(ctx, sessionID)\\n\\tif fileExists(stateFile) {\\n\\t\\treturn os.Remove(stateFile) //nolint:wrapcheck // already present in codebase\\n\\t}\\n\\treturn nil\\n}\\n\\n// FileChanges holds categorized file changes from git status.\\ntype FileChanges struct {\\n\\tModified []string // Modified or staged files\\n\\tNew      []string // Untracked files (filtered if previouslyUntracked provided)\\n\\tDeleted  []string // Deleted files (staged or unstaged)\\n}\\n\\n// DetectFileChanges returns categorized file changes from the current git status.\\n//\\n// previouslyUntracked controls new-file detection:\\n//   - nil: all untracked files go into New\\n//   - non-nil: only untracked files NOT in the pre-existing set go into New\\n//\\n// Modified includes both worktree and staging modified/added files.\\n// Deleted includes both staged and unstaged deletions.\\n// All results exclude .entire/ directory.\\nfunc DetectFileChanges(ctx context.Context, previouslyUntracked []string) (*FileChanges, error) {\\n\\trepo, err := openRepository(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\tworktree, err := repo.Worktree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n\\t}\\n\\n\\tstatus, err := worktree.Status()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n\\t}\\n\\n\\t// Build set of pre-existing untracked files for quick lookup\\n\\tvar preExisting map[string]bool\\n\\tif previouslyUntracked != nil {\\n\\t\\tpreExisting = make(map[string]bool, len(previouslyUntracked))\\n\\t\\tfor _, f := range previouslyUntracked {\\n\\t\\t\\tpreExisting[f] = true\\n\\t\\t}\\n\\t}\\n\\n\\tvar changes FileChanges\\n\\tfor file, st := range status {\\n\\t\\tif paths.IsInfrastructurePath(file) {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tswitch {\\n\\t\\tcase st.Worktree == git.Untracked:\\n\\t\\t\\tif preExisting != nil {\\n\\t\\t\\t\\tif !preExisting[file] {\\n\\t\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n\\t\\t\\t\\t}\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n\\t\\t\\t}\\n\\t\\tcase st.Worktree == git.Deleted || st.Staging == git.Deleted:\\n\\t\\t\\tchanges.Deleted = append(changes.Deleted, file)\\n\\t\\tcase st.Worktree == git.Modified || st.Staging == git.Modified ||\\n\\t\\t\\tst.Worktree == git.Added || st.Staging == git.Added:\\n\\t\\t\\tchanges.Modified = append(changes.Modified, file)\\n\\t\\t}\\n\\t}\\n\\n\\treturn &changes, nil\\n}\\n\\n// filterToUncommittedFiles removes files from the list that are already committed to HEAD\\n// with matching content. This prevents re-adding files that an agent committed mid-turn\\n// (already condensed by PostCommit) back to FilesTouched via SaveStep. Files not in\\n// HEAD or with different content in the working tree are kept. Fails open: if any git\\n// operation errors, returns the original list unchanged.\\nfunc filterToUncommittedFiles(ctx context.Context, files []string, repoRoot string) []string {\\n\\tif len(files) == 0 {\\n\\t\\treturn files\\n\\t}\\n\\n\\trepo, err := openRepository(ctx)\\n\\tif err != nil {\\n\\t\\treturn files // fail open\\n\\t}\\n\\n\\thead, err := repo.Head()\\n\\tif err != nil {\\n\\t\\treturn files // fail open (empty repo, detached HEAD, etc.)\\n\\t}\\n\\n\\tcommit, err := repo.CommitObject(head.Hash())\\n\\tif err != nil {\\n\\t\\treturn files // fail open\\n\\t}\\n\\n\\theadTree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn files // fail open\\n\\t}\\n\\n\\tvar result []string\\n\\tfor _, relPath := range files {\\n\\t\\theadFile, err := headTree.File(relPath)\\n\\t\\tif err != nil {\\n\\t\\t\\t// File not in HEAD — it's uncommitted\\n\\t\\t\\tresult = append(result, relPath)\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// File is in HEAD — compare content with working tree\\n\\t\\tabsPath := filepath.Join(repoRoot, relPath)\\n\\t\\tworkingContent, err := os.ReadFile(absPath) //nolint:gosec // path from controlled source\\n\\t\\tif err != nil {\\n\\t\\t\\t// Can't read working tree file (deleted?) — keep it\\n\\t\\t\\tresult = append(result, relPath)\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\theadContent, err := headFile.Contents()\\n\\t\\tif err != nil {\\n\\t\\t\\tresult = append(result, relPath)\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tif string(workingContent) != headContent {\\n\\t\\t\\t// Working tree differs from HEAD — uncommitted changes\\n\\t\\t\\tresult = append(result, relPath)\\n\\t\\t}\\n\\t\\t// else: content matches HEAD — already committed, skip\\n\\t}\\n\\n\\treturn result\\n}\\n\\n// FilterAndNormalizePaths converts absolute paths to relative and filters out\\n// infrastructure paths and paths outside the repo.\\nfunc FilterAndNormalizePaths(files []string, cwd string) []string {\\n\\tvar result []string\\n\\tfor _, file := range files {\\n\\t\\trelPath := paths.ToRelativePath(file, cwd)\\n\\t\\tif relPath == \\\"\\\" {\\n\\t\\t\\tcontinue // outside repo\\n\\t\\t}\\n\\t\\tif paths.IsInfrastructurePath(relPath) {\\n\\t\\t\\tcontinue // skip .entire directory\\n\\t\\t}\\n\\t\\tresult = append(result, relPath)\\n\\t}\\n\\treturn result\\n}\\n\\n// mergeUnique appends elements from extra into base, skipping duplicates already in base.\\nfunc mergeUnique(base, extra []string) []string {\\n\\tif len(extra) == 0 {\\n\\t\\treturn base\\n\\t}\\n\\tseen := make(map[string]bool, len(base))\\n\\tfor _, s := range base {\\n\\t\\tseen[s] = true\\n\\t}\\n\\tfor _, s := range extra {\\n\\t\\tif !seen[s] {\\n\\t\\t\\tseen[s] = true\\n\\t\\t\\tbase = append(base, s)\\n\\t\\t}\\n\\t}\\n\\treturn base\\n}\\n\\n// prePromptStateFile returns the absolute path to the pre-prompt state file for a session.\\n// Works correctly from any subdirectory within the repository.\\nfunc prePromptStateFile(ctx context.Context, sessionID string) string {\\n\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n\\tif err != nil {\\n\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n\\t}\\n\\treturn filepath.Join(tmpDirAbs, fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID))\\n}\\n\\n// getUntrackedFilesForState returns a list of untracked files using go-git\\n// Excludes .entire directory\\nfunc getUntrackedFilesForState(ctx context.Context) ([]string, error) {\\n\\trepo, err := openRepository(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tworktree, err := repo.Worktree()\\n\\tif err != nil {\\n\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n\\t}\\n\\n\\tstatus, err := worktree.Status()\\n\\tif err != nil {\\n\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n\\t}\\n\\n\\tuntrackedFiles := []string{}\\n\\tfor file, st := range status {\\n\\t\\tif st.Worktree == git.Untracked {\\n\\t\\t\\t// Exclude .entire directory\\n\\t\\t\\tif !strings.HasPrefix(file, paths.EntireDir+\\\"/\\\") && file != paths.EntireDir {\\n\\t\\t\\t\\tuntrackedFiles = append(untrackedFiles, file)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\treturn untrackedFiles, nil\\n}\\n\\n// PreTaskState stores the state captured before a task execution\\ntype PreTaskState struct {\\n\\tToolUseID      string   `json:\\\"tool_use_id\\\"`\\n\\tTimestamp      string   `json:\\\"timestamp\\\"`\\n\\tUntrackedFiles []string `json:\\\"untracked_files\\\"`\\n}\\n\\n// PreUntrackedFiles returns the untracked files list, or nil if the receiver is nil.\\n// See PrePromptState.PreUntrackedFiles for nil-vs-empty semantics.\\nfunc (s *PreTaskState) PreUntrackedFiles() []string {\\n\\tif s == nil {\\n\\t\\treturn nil\\n\\t}\\n\\tif s.UntrackedFiles == nil {\\n\\t\\treturn []string{}\\n\\t}\\n\\treturn s.UntrackedFiles\\n}\\n\\n// CapturePreTaskState captures current untracked files before a Task execution\\n// and saves them to a state file.\\n// Works correctly from any subdirectory within the repository.\\nfunc CapturePreTaskState(ctx context.Context, toolUseID string) error {\\n\\tif toolUseID == \\\"\\\" {\\n\\t\\treturn errors.New(\\\"tool_use_id is required\\\")\\n\\t}\\n\\n\\t// Get