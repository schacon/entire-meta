a tool call) and migrate if needed\\n    48→\\tif err := s.migrateAndPersistIfNeeded(ctx, repo, state); err != nil {\\n    49→\\t\\treturn err\\n    50→\\t}\\n    51→\\n    52→\\t// Get checkpoint store\\n    53→\\tstore, err := s.getCheckpointStore()\\n    54→\\tif err != nil {\\n    55→\\t\\treturn fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    56→\\t}\\n    57→\\n    58→\\t// Check if shadow branch exists to report whether we created it\\n    59→\\tshadowBranchName := checkpoint.ShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n    60→\\tbranchExisted := store.ShadowBranchExists(state.BaseCommit, state.WorktreeID)\\n    61→\\n    62→\\t// Use the pending attribution calculated at prompt start (in InitializeSession)\\n    63→\\t// This was calculated BEFORE the agent made changes, so it accurately captures user edits\\n    64→\\tvar promptAttr PromptAttribution\\n    65→\\tif state.PendingPromptAttribution != nil {\\n    66→\\t\\tpromptAttr = *state.PendingPromptAttribution\\n    67→\\t\\tstate.PendingPromptAttribution = nil // Clear after use\\n    68→\\t} else {\\n    69→\\t\\t// No pending attribution (e.g., first checkpoint or session initialized without it)\\n    70→\\t\\tpromptAttr = PromptAttribution{CheckpointNumber: state.StepCount + 1}\\n    71→\\t}\\n    72→\\n    73→\\t// Log the prompt attribution for debugging\\n    74→\\tattrLogCtx := logging.WithComponent(ctx, \\\"attribution\\\")\\n    75→\\tlogging.Debug(attrLogCtx, \\\"prompt attribution at checkpoint save\\\",\\n    76→\\t\\tslog.Int(\\\"checkpoint_number\\\", promptAttr.CheckpointNumber),\\n    77→\\t\\tslog.Int(\\\"user_added\\\", promptAttr.UserLinesAdded),\\n    78→\\t\\tslog.Int(\\\"user_removed\\\", promptAttr.UserLinesRemoved),\\n    79→\\t\\tslog.Int(\\\"agent_added\\\", promptAttr.AgentLinesAdded),\\n    80→\\t\\tslog.Int(\\\"agent_removed\\\", promptAttr.AgentLinesRemoved),\\n    81→\\t\\tslog.String(\\\"session_id\\\", sessionID))\\n    82→\\n    83→\\t// Use WriteTemporary to create the checkpoint\\n    84→\\tisFirstCheckpointOfSession := state.StepCount == 0\\n    85→\\tresult, err := store.WriteTemporary(ctx, checkpoint.WriteTemporaryOptions{\\n    86→\\t\\tSessionID:         sessionID,\\n    87→\\t\\tBaseCommit:        state.BaseCommit,\\n    88→\\t\\tWorktreeID:        state.WorktreeID,\\n    89→\\t\\tModifiedFiles:     step.ModifiedFiles,\\n    90→\\t\\tNewFiles:          step.NewFiles,\\n    91→\\t\\tDeletedFiles:      step.DeletedFiles,\\n    92→\\t\\tMetadataDir:       step.MetadataDir,\\n    93→\\t\\tMetadataDirAbs:    step.MetadataDirAbs,\\n    94→\\t\\tCommitMessage:     step.CommitMessage,\\n    95→\\t\\tAuthorName:        step.AuthorName,\\n    96→\\t\\tAuthorEmail:       step.AuthorEmail,\\n    97→\\t\\tIsFirstCheckpoint: isFirstCheckpointOfSession,\\n    98→\\t})\\n    99→\\tif err != nil {\\n   100→\\t\\treturn fmt.Errorf(\\\"failed to write temporary checkpoint: %w\\\", err)\\n   101→\\t}\\n   102→\\n   103→\\t// If checkpoint was skipped due to deduplication (no changes), return early\\n   104→\\tif result.Skipped {\\n   105→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   106→\\t\\tlogging.Info(logCtx, \\\"checkpoint skipped (no changes)\\\",\\n   107→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   108→\\t\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"session\\\"),\\n   109→\\t\\t\\tslog.Int(\\\"checkpoint_count\\\", state.StepCount),\\n   110→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   111→\\t\\t)\\n   112→\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipped checkpoint (no changes since last checkpoint)\\\\n\\\")\\n   113→\\t\\treturn nil\\n   114→\\t}\\n   115→\\n   116→\\t// Update session state\\n   117→\\tstate.StepCount++\\n   118→\\n   119→\\t// Note: LastCheckpointID is intentionally NOT cleared here.\\n   120→\\t// It is set during condensation and used by handleAmendCommitMsg\\n   121→\\t// to restore checkpoint trailers on amend operations.\\n   122→\\n   123→\\t// Store the prompt attribution we calculated before saving\\n   124→\\tstate.PromptAttributions = append(state.PromptAttributions, promptAttr)\\n   125→\\n   126→\\t// Track touched files (modified, new, and deleted)\\n   127→\\tstate.FilesTouched = mergeFilesTouched(state.FilesTouched, step.ModifiedFiles, step.NewFiles, step.DeletedFiles)\\n   128→\\n   129→\\t// On first checkpoint, record the transcript identifier for this session\\n   130→\\tif state.StepCount == 1 {\\n   131→\\t\\tstate.TranscriptIdentifierAtStart = step.StepTranscriptIdentifier\\n   132→\\t}\\n   133→\\n   134→\\t// Accumulate token usage\\n   135→\\tif step.TokenUsage != nil {\\n   136→\\t\\tstate.TokenUsage = accumulateTokenUsage(state.TokenUsage, step.TokenUsage)\\n   137→\\t}\\n   138→\\n   139→\\t// Save updated state\\n   140→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   141→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   142→\\t}\\n   143→\\n   144→\\tif !branchExisted {\\n   145→\\t\\tfmt.Fprintf(os.Stderr, \\\"Created shadow branch '%s' and committed changes\\\\n\\\", shadowBranchName)\\n   146→\\t} else {\\n   147→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed changes to shadow branch '%s'\\\\n\\\", shadowBranchName)\\n   148→\\t}\\n   149→\\n   150→\\t// Log checkpoint creation\\n   151→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   152→\\tlogging.Info(logCtx, \\\"checkpoint saved\\\",\\n   153→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   154→\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"session\\\"),\\n   155→\\t\\tslog.Int(\\\"checkpoint_count\\\", state.StepCount),\\n   156→\\t\\tslog.Int(\\\"modified_files\\\", len(step.ModifiedFiles)),\\n   157→\\t\\tslog.Int(\\\"new_files\\\", len(step.NewFiles)),\\n   158→\\t\\tslog.Int(\\\"deleted_files\\\", len(step.DeletedFiles)),\\n   159→\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   160→\\t\\tslog.Bool(\\\"b