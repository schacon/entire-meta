rr != nil {\\n   231→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract summary: %v\\\\n\\\", sumErr)\\n   232→\\t\\t} else {\\n   233→\\t\\t\\tsummary = s\\n   234→\\t\\t}\\n   235→\\n   236→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   237→\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n   238→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n   239→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files (with subagents): %v\\\\n\\\", fileErr)\\n   240→\\t\\t\\t} else {\\n   241→\\t\\t\\t\\tmodifiedFiles = files\\n   242→\\t\\t\\t}\\n   243→\\t\\t} else {\\n   244→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   245→\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   246→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files: %v\\\\n\\\", fileErr)\\n   247→\\t\\t\\t} else {\\n   248→\\t\\t\\t\\tmodifiedFiles = files\\n   249→\\t\\t\\t}\\n   250→\\t\\t}\\n   251→\\t}\\n   252→\\n   253→\\t// Write prompts file\\n   254→\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   255→\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   256→\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   257→\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   258→\\t}\\n   259→\\tfmt.Fprintf(os.Stderr, \\\"Extracted %d prompt(s) to: %s\\\\n\\\", len(allPrompts), sessionDir+\\\"/\\\"+paths.PromptFileName)\\n   260→\\n   261→\\t// Write summary file\\n   262→\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   263→\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   264→\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   265→\\t}\\n   266→\\tfmt.Fprintf(os.Stderr, \\\"Extracted summary to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName)\\n   267→\\n   268→\\t// Generate commit message from last prompt\\n   269→\\tlastPrompt := \\\"\\\"\\n   270→\\tif len(allPrompts) > 0 {\\n   271→\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   272→\\t}\\n   273→\\tcommitMessage := generateCommitMessage(lastPrompt)\\n   274→\\tfmt.Fprintf(os.Stderr, \\\"Using commit message: %s\\\\n\\\", commitMessage)\\n   275→\\n   276→\\t// Get worktree root for path normalization\\n   277→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   278→\\tif err != nil {\\n   279→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   280→\\t}\\n   281→\\n   282→\\tvar preUntrackedFiles []string\\n   283→\\tif preState != nil {\\n   284→\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state: %d pre-existing untracked files\\\\n\\\", len(preState.UntrackedFiles))\\n   285→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   286→\\t}\\n   287→\\n   288→\\t// Detect file changes via git status\\n   289→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   290→\\tif err != nil {\\n   291→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   292→\\t}\\n   293→\\n   294→\\t// Filter and normalize all paths\\n   295→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   296→\\tvar relNewFiles, relDeletedFiles []string\\n   297→\\tif changes != nil {\\n   298→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   299→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   300→\\n   301→\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n   302→\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n   303→\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n   304→\\t\\t// Git status catches any tracked file with working-tree changes.\\n   305→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   306→\\t}\\n   307→\\n   308→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   309→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   310→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   311→\\t// if it exists in HEAD with the same content as the working tree.\\n   312→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   313→\\n   314→\\t// Check if there are any changes\\n   315→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   316→\\tif totalChanges == 0 {\\n   317→\\t\\tfmt.Fprintf(os.Stderr, \\\"No files were modified during this session\\\\n\\\")\\n   318→\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipping commit\\\\n\\\")\\n   319→\\t\\ttransitionSessionTurnEnd(ctx, sessionID)\\n   320→\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   321→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   322→\\t\\t}\\n   323→\\t\\treturn nil\\n   324→\\t}\\n   325→\\n   326→\\t// Log file changes\\n   327→\\tlogFileChanges(relModifiedFiles, relNewFiles, relDeletedFiles)\\n   328→\\n   329→\\t// Create context file\\n   330→\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n   331→\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n   332→\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n   333→\\t}\\n   334→\\tfmt.Fprintf(os.Stderr, \\\"Created context file: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.ContextFileName)\\n   335→\\n   336→\\t// Get git author\\n   337→\\tauthor, err := GetGitAuthor(ctx)\\n   338→\\tif err != nil {\\n   339→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   340→\\t}\\n   341→\\n   342→\\t// Get strategy and agent type\\n   343→\\tstrat := GetStrategy(ctx)\\n   344→\\tagentType := ag.Type()\\n   345→\\n   346→\\t// Get transcript position/identifier from pre-prompt state\\n   347→\\tvar transcriptIdentifierAtStart string\\n   348→\\tvar transcriptLinesAtStart int\\n   349→\\tif preState != nil {\\n   350→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   351→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   352→\\t}\\n   353→\\n   354→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   355→\\ttokenUsage := agent.CalculateTokenUsage(ag, transcriptData, transcriptLinesAtStart, subagentsDir)\\n   356→\\n   357→\\t// Build fully-populated step context and delegate to strategy\\n   358→\\tstepCtx := strategy.StepContext{\\n   359→\\t\\tSessionID:                sessionID,\\n   360→\\t\\tModifiedFiles:            relModifiedFiles,\\n   361→\\t\\tNewFiles:                 relNewFiles,\\n   362→\\t\\tDeletedFiles:             relDeletedFiles,\\n   363→\\t\\tMetadataDir:              sessionDir,\\n   364→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   365→\\t\\tCommitMessage:            commitMessage,\\n   366→\\t\\tTranscriptPath:           transcriptRef,\\n   367→\\t\\tAuthorName:               author.Name,\\n   368→\\t\\tAuthorEmail:              author.Email,\\n   369→\\t\\tAgentType:                agentType,\\n   370→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   371→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   372→\\t\\tTokenUsage:               tokenUsage,\\n   373→\\t}\\n   374→\\n   375→\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   376→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   377→\\t}\\n   378→\\n   379→\\t// Transition session phase and cleanup\\n   380→\\ttransitionSessionTurnEnd(ctx, sessionID)\\n   381→\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   382→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   383→\\t}\\n   384→\\n   385→\\treturn nil\\n   386→}\\n   387→\\n   388→// handleLifecycleCompaction handles context compaction: saves current progress\\n   389→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   390→// Also resets the transcript offset since the transcript may be truncated.\\n   391→func handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   392→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   393→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   394→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   395→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   396→\\t)\\n   397→\\n   398→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   399→\\tsessionID := event.SessionID\\n   400→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   401→\\tif loadErr != nil {\\n   402→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for compaction: %v\\\\n\\\", loadErr)\\n   403→\\t}\\n   404→\\tif sessionState != nil {\\n   405→\\t\\tif transErr := strategy.TransitionAndLog(ctx, sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   406→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: compaction transition failed: %v\\\\n\\\", transErr)\\n   407→\\t\\t}\\n   408→\\n   409→\\t\\tif saveErr := strategy.SaveSessionState(ctx, sessionState); saveErr != nil {\\n   410→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to save session state after compaction: %v\\\\n\\\", saveErr)\\n   411→\\t\\t}\\n   412→\\t}\\n   413→\\n   414→\\tfmt.Fprintf(os.Stderr, \\\"Context compaction detected\\\\n\\\")\\n   415→\\treturn nil\\n   416→}\\n   417→\\n   418→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   419→func handleLifecycleSessionEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   420→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   421→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   422→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   423→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   424→\\t)\\n   425→\\n   426→\\tif event.SessionID == \\\"\\\" {\\n   427→\\t\\treturn nil // No session to update\\n   428→\\t}\\n   429→\\n   430→\\t// Note: We intentionally don't clean up cached transcripts here.\\n   431→\\t// Post-session commits (carry-forward in ENDED phase) may still need\\n   432→\\t// the transcript to extract file changes. Cleanup is handled by\\n   433→\\t// `entire clean` or when the session state is fully removed.\\n   434→\\n   435→\\tif err := markSessionEnded(ctx, event.SessionID); err != nil {\\n   436→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to mark session ended: %v\\\\n\\\", err)\\n   437→\\t}\\n   438→\\treturn nil\\n   439→}\\n   440→\\n   441→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   442→func handleLifecycleSubagentStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   443→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   444→\\tlogging.Info(logCtx, \\\"subagent-start\\\",\\n   445→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   446→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   447→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   448→\\t)\\n   449→\\n   450→\\t// Log context\\n   451→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent started\\\\n\\\")\\n   452→\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n   453→\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n   454→\\tfmt.Fprintf(os.Stderr, \\\"  Transcript: %s\\\\n\\\", event.SessionRef)\\n   455→\\n   456→\\t// Capture pre-task state\\n   457→\\tif err := CapturePreTaskState(ctx, event.ToolUseID); err != nil {\\n   458→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   459→\\t}\\n   460→\\n   461→\\treturn nil\\n   462→}\\n   463→\\n   464→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   465→func handleLifecycleSubagentEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   466→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   467→\\tlogging.Info(logCtx, \\\"subagent-end\\\",\\n   468→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   469→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   470→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   471→\\t\\tslog.String(\\\"subagent_id\\\", event.SubagentID),\\n   472→\\t)\\n   473→\\n   474→\\tif event.SubagentType == \\\"\\\" && event.TaskDescription == \\\"\\\" {\\n   475→\\t\\t// Extract subagent type and description from tool input\\n   476→\\t\\tevent.SubagentType, event.TaskDescription = ParseSubagentTypeAndDescription(event.ToolInput)\\n   477→\\t}\\n   478→\\n   479→\\t// Determine subagent transcript path\\n   480→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   481→\\tvar subagentTranscriptPath string\\n   482→\\tif event.SubagentID != \\\"\\\" {\\n   483→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   484→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   485→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   486→\\t\\t}\\n   487→\\t}\\n   488→\\n   489→\\t// Log context\\n   490→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent completed\\\\n\\\")\\n   491→\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: