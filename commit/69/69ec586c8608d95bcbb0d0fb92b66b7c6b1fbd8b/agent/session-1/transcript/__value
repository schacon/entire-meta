t))\\n   100→\\t\\t}\\n   101→\\t}\\n   102→\\treturn prompts, nil\\n   103→}\\n   104→\\n   105→// ExtractSummary extracts the last assistant message as a session summary.\\n   106→func (f *FactoryAIDroidAgent) ExtractSummary(sessionRef string) (string, error) {\\n   107→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n   108→\\tif err != nil {\\n   109→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   110→\\t}\\n   111→\\tlines, err := ParseDroidTranscriptFromBytes(data, 0)\\n   112→\\tif err != nil {\\n   113→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   114→\\t}\\n   115→\\n   116→\\tfor i := len(lines) - 1; i >= 0; i-- {\\n   117→\\t\\tif lines[i].Type != transcript.TypeAssistant {\\n   118→\\t\\t\\tcontinue\\n   119→\\t\\t}\\n   120→\\t\\tvar msg transcript.AssistantMessage\\n   121→\\t\\tif err := json.Unmarshal(lines[i].Message, &msg); err != nil {\\n   122→\\t\\t\\tcontinue\\n   123→\\t\\t}\\n   124→\\t\\tfor _, block := range msg.Content {\\n   125→\\t\\t\\tif block.Type == transcript.ContentTypeText && block.Text != \\\"\\\" {\\n   126→\\t\\t\\t\\treturn block.Text, nil\\n   127→\\t\\t\\t}\\n   128→\\t\\t}\\n   129→\\t}\\n   130→\\treturn \\\"\\\", nil\\n   131→}\\n   132→\\n   133→// --- TokenCalculator ---\\n   134→\\n   135→// CalculateTokenUsage computes token usage from the transcript starting at the given line offset.\\n   136→func (f *FactoryAIDroidAgent) CalculateTokenUsage(sessionRef string, fromOffset int) (*agent.TokenUsage, error) {\\n   137→\\treturn CalculateTotalTokenUsageFromTranscript(sessionRef, fromOffset, \\\"\\\")\\n   138→}\\n   139→\\n   140→// --- SubagentAwareExtractor ---\\n   141→\\n   142→// ExtractAllModifiedFiles extracts files modified by both the main agent and any spawned subagents.\\n   143→func (f *FactoryAIDroidAgent) ExtractAllModifiedFiles(sessionRef string, fromOffset int, subagentsDir string) ([]string,