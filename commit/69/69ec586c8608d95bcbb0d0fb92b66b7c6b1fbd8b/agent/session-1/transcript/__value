23→const AgentNameFactoryAIDroid = \\\"factoryai-droid\\\"\\n    24→\\n    25→// AgentNameOpenCode is the name for OpenCode agent.\\n    26→const AgentNameOpenCode = \\\"opencode\\\"\\n    27→\\n    28→// AgentRunner abstracts invoking a coding agent for e2e tests.\\n    29→// This follows the multi-agent pattern from cmd/entire/cli/agent/agent.go.\\n    30→type AgentRunner interface {\\n    31→\\t// Name returns the agent name (e.g., \\\"claude-code\\\", \\\"gemini-cli\\\")\\n    32→\\tName() string\\n    33→\\n    34→\\t// IsAvailable checks if the agent CLI is installed and authenticated\\n    35→\\tIsAvailable() (bool, error)\\n    36→\\n    37→\\t// RunPrompt executes a prompt and returns the result\\n    38→\\tRunPrompt(ctx context.Context, workDir string, prompt string) (*AgentResult, error)\\n    39→\\n    40→\\t// RunPromptWithTools executes with specific allowed tools\\n    41→\\tRunPromptWithTools(ctx context.Context, workDir string, prompt string, tools []string) (*AgentResult, error)\\n    42→}\\n    43→\\n    44→// AgentResult holds the result of an agent invocation.\\n    45→type AgentResult struct {\\n    46→\\tStdout   string\\n    47→\\tStderr   string\\n    48→\\tExitCode int\\n    49→\\tDuration time.Duration\\n    50→}\\n    51→\\n    52→// AgentRunnerConfig holds configuration for agent runners.\\n    53→type AgentRunnerConfig struct {\\n    54→\\tModel   string        // Model to use (e.g., \\\"haiku\\\" for Claude)\\n    55→\\tTimeout time.Duration // Timeout per prompt\\n    56→}\\n    57→\\n    58→// NewAgentRunner creates an agent runner based on the agent name.\\n    59→//\\n    60→//nolint:ireturn // factory pattern intentionally returns interface\\n    61→func NewAgentRunner(name string, config AgentRunnerConfig) AgentRunner {\\n    62→\\tswitch name {\\n    63→\\tcase AgentNameClaudeCode:\\n    64→\\t\\treturn NewClaudeCodeRunner(config)\\n    65→\\tcase AgentNameGemini:\\n    66→\\t\\treturn NewGeminiCLIRunner(config)\\n    67→\\tcase