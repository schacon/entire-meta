rsed, err := time.ParseDuration(envTimeout); err == nil {\\n   117→\\t\\t\\t\\ttimeout = parsed\\n   118→\\t\\t\\t}\\n   119→\\t\\t}\\n   120→\\t\\tif timeout == 0 {\\n   121→\\t\\t\\ttimeout = 2 * time.Minute\\n   122→\\t\\t}\\n   123→\\t}\\n   124→\\n   125→\\treturn &ClaudeCodeRunner{\\n   126→\\t\\tModel:        model,\\n   127→\\t\\tTimeout:      timeout,\\n   128→\\t\\tAllowedTools: []string{\\\"Edit\\\", \\\"Read\\\", \\\"Write\\\", \\\"Bash\\\", \\\"Glob\\\", \\\"Grep\\\"},\\n   129→\\t}\\n   130→}\\n   131→\\n   132→func (r *ClaudeCodeRunner) Name() string {\\n   133→\\treturn AgentNameClaudeCode\\n   134→}\\n   135→\\n   136→// IsAvailable checks if Claude CLI is installed and responds to --version.\\n   137→// Note: This does NOT verify authentication status. Claude Code uses OAuth\\n   138→// authentication (via `claude login`), not ANTHROPIC_API_KEY. If the CLI is\\n   139→// installed but not logged in, tests will fail at RunPrompt time.\\n   140→func (r *ClaudeCodeRunner) IsAvailable() (bool, error) {\\n   141→\\t// Check if claude CLI is in PATH\\n   142→\\tif _, err := exec.LookPath(\\\"claude\\\"); err != nil {\\n   143→\\t\\treturn false, fmt.Errorf(\\\"claude CLI not found in PATH: %w\\\", err)\\n   144→\\t}\\n   145→\\n   146→\\t// Check if claude is working (--version doesn't require auth)\\n   147→\\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\\n   148→\\tdefer cancel()\\n   149→\\n   150→\\tcmd := exec.CommandContext(ctx, \\\"claude\\\", \\\"--version\\\")\\n   151→\\tif err := cmd.Run(); err != nil {\\n   152→\\t\\treturn false, fmt.Errorf(\\\"claude CLI not working: %w\\\", err)\\n   153→\\t}\\n   154→\\n   155→\\treturn true, nil\\n   156→}\\n   157→\\n   158→func (r *ClaudeCodeRunner) RunPrompt(ctx context.Context, workDir string, prompt string) (*AgentResult, error) {\\n   159→\\treturn r.RunPromptWithTools(ctx, workDir, prompt, r.AllowedTools)\\n   160→}\\n   161→\\n   162→func (r *ClaudeCodeRunner) RunPromp