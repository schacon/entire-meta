t\\\"path/filepath\\\"\\n     9→\\t\\\"regexp\\\"\\n    10→\\t\\\"time\\\"\\n    11→\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    14→)\\n    15→\\n    16→// nonAlphanumericRegex matches any non-alphanumeric character for path sanitization.\\n    17→// Same pattern as claudecode.SanitizePathForClaude — duplicated to avoid cross-package dependency.\\n    18→var nonAlphanumericRegex = regexp.MustCompile(`[^a-zA-Z0-9]`)\\n    19→\\n    20→func sanitizeRepoPath(path string) string {\\n    21→\\treturn nonAlphanumericRegex.ReplaceAllString(path, \\\"-\\\")\\n    22→}\\n    23→\\n    24→//nolint:gochecknoinits // Agent self-registration is the intended pattern\\n    25→func init() {\\n    26→\\tagent.Register(agent.AgentNameFactoryAIDroid, NewFactoryAIDroidAgent)\\n    27→}\\n    28→\\n    29→// FactoryAIDroidAgent implements the agent.Agent interface for Factory AI Droid.\\n    30→//\\n    31→//nolint:revive // FactoryAIDroidAgent is clearer than Agent in this context\\n    32→type FactoryAIDroidAgent struct{}\\n    33→\\n    34→// NewFactoryAIDroidAgent creates a new Factory AI Droid agent instance.\\n    35→func NewFactoryAIDroidAgent() agent.Agent {\\n    36→\\treturn &FactoryAIDroidAgent{}\\n    37→}\\n    38→\\n    39→// Name returns the agent registry key.\\n    40→func (f *FactoryAIDroidAgent) Name() agent.AgentName { return agent.AgentNameFactoryAIDroid }\\n    41→\\n    42→// Type returns the agent type identifier.\\n    43→func (f *FactoryAIDroidAgent) Type() agent.AgentType { return agent.AgentTypeFactoryAIDroid }\\n    44→\\n    45→// Description returns a human-readable description.\\n    46→func (f *FactoryAIDroidAgent) Description() string {\\n    47→\\treturn \\\"Factory AI Droid - agent-native development platform\\\"\\n    48→}\\n    49→\\n    50→// IsPreview returns true as Factory AI Droid integration is in preview.\\n    51→func (f *FactoryAIDroidAgent) IsPreview() bool { return true }\\n    52→\\n    53→// ProtectedDirs returns directories that Factory AI Droid uses for config/state.\\n    54→func (f *FactoryAIDroidAgent) ProtectedDirs() []string { return []string{\\\".factory\\\"} }\\n    55→\\n    56→// DetectPresence checks if Factory AI Droid is configured in the repository.\\n    57→func (f *FactoryAIDroidAgent) DetectPresence() (bool, error) {\\n    58→\\trepoRoot, err := paths.WorktreeRoot()\\n    59→\\tif err != nil {\\n    60→\\t\\trepoRoot = \\\".\\\"\\n    61→\\t}\\n    62→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\".factory\\\")); err == nil {\\n    63→\\t\\treturn true, nil\\n    64→\\t}\\n    65→\\treturn false, nil\\n    66→}\\n    67→\\n    68→// ReadTranscript reads the raw JSONL transcript bytes for a session.\\n    69→func (f *FactoryAIDroidAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    70→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n    71→\\tif err != nil {\\n    72→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    73→\\t}\\n    74→\\treturn data, nil\\n    75→}\\n    76→\\n    77→// ChunkTranscript splits a JSONL transcript at line boundaries.\\n    78→func (f *FactoryAIDroidAgent) ChunkTranscript(content []byte, maxSize int) ([][]byte, error) {\\n    79→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    80→\\tif err != nil {\\n    81→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n    82→\\t}\\n    83→\\treturn chunks, nil\\n    84→}\\n    85→\\n    86→// ReassembleTranscript concatenates JSONL chunks with newlines.\\n    87→func (f *FactoryAIDroidAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    88→\\treturn agent.ReassembleJSONL(chunks), nil\\n    89→}\\n    90→\\n    91→// GetSessionID extracts the session ID from hook input.\\n    92→func (f *FactoryAIDroidAgent) GetSessionID(input *agent.HookInput) string { return input.SessionID }\\n    93→\\n    94→// GetSessionDir returns the directory where Factory AI Droid stores session transcripts.\\n    95→// Path: ~/.factory/sessions/<sanitized-repo-path>/\\n    96→func (f *FactoryAIDroidAgent) GetSessionDir(repoPath string) (string, error) {\\n    97→\\tif override := os.Getenv(\\\"ENTIRE_TEST_DROID_PROJECT_DIR\\\"); override != \\\"\\\" {\\n    98→\\t\\treturn override, nil\\n    99→\\t}\\n   100→\\thomeDir, err := os.UserHomeDir()\\n   101→\\tif err != nil {\\n   102→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   103→\\t}\\n   104→\\tprojectDir := sanitizeRepoPath(repoPath)\\n   105→\\treturn filepath.Join(homeDir, \\\".factory\\\", \\\"sessions\\\", projectDir), nil\\n   106→}\\n   107→\\n   108→// ResolveSessionFile returns the path to a Factory AI Droid session file.\\n   109→func (f *FactoryAIDroidAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   110→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".jsonl\\\")\\n   111→}\\n   112→\\n   113→// ReadSession reads a session from Factory AI Droid's storage (JSONL transcript file).\\n   114→// The session data is stored in NativeData as raw JSONL bytes.\\n   115→// ModifiedFiles is computed by parsing the transcript.\\n   116→func (f *FactoryAIDroidAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   117→\\tif input.SessionRef == \\\"\\\" {\\n   118→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   119→\\t}\\n   120→\\n   121→\\tdata, err := os.ReadFile(input.SessionRef)\\n   122→\\tif err != nil {\\n   123→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   124→\\t}\\n   125→\\n   126→\\tlines, err := ParseDroidTranscriptFromBytes(data, 0)\\n   127→\\tif err != nil {\\n   128→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   129→\\t}\\n   130→\\n   131→\\treturn &agent.AgentSession{\\n   132→\\t\\tSessionID:     input.SessionID,\\n   133→\\t\\tAgentName:     f.Name(),\\n   134→\\t\\tSessionRef:    input.SessionRef,\\n   135→\\t\\tStartTime:     time.Now(),\\n   136→\\t\\tNativeData:    data,\\n   137→\\t\\tModifiedFiles: ExtractModifiedFiles(lines),\\n   138→\\t}, nil\\n   139→}\\n   140→\\n   141→// WriteSession writes a session to Factory AI Droid's storage (JSONL transcript file).\\n   142→// Uses the NativeData field which contains raw JSONL bytes.\\n   143→func (f *FactoryAIDroidAgent) WriteSession(session *agent.AgentSession) error {\\n   144→\\tif session == nil {\\n   145→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   146→\\t}\\n   147→\\n   148→\\tif session.AgentName != \\\"\\\" && session.AgentName != f.Name() {\\n   149→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, f.Name())\\n   150→\\t}\\n   151→\\n   152→\\tif session.SessionRef == \\\"\\\" {\\n   153→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   154→\\t}\\n   155→\\n   156→\\tif len(session.NativeData) == 0 {\\n   157→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   158→\\t}\\n   159→\\n   160→\\tif err := os.MkdirAll(filepath.Dir(session.SessionRef), 0o750); err != nil {\\n   161→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   162→\\t}\\n   163→\\n   164→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   165→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   166→\\t}\\n   167→\\n   168→\\treturn nil\\n   169→}\\n   170→\\n   171→// FormatResumeCommand returns the command to resume a Factory AI Droid session.\\n   172→func (f *FactoryAIDroidAgent) FormatResumeCommand(sessionID string) string {\\n   173→\\treturn \\\"droid --session-id \\\" + sessionID\\n   174→}\\n   175→\"}]},\"uuid\":\"dc1b8279-a5ad-4ef3-af0b-5876e2bf3f41\",\"timestamp\":\"2026-02-25T21:12:31.151Z\"},\"normalizedMessages\":[],\"type\":\"