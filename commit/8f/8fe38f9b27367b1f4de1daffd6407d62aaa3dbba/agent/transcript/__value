43→\\n    44→type assistantMessageData struct {\\n    45→\\tContent string `json:\\\"content\\\"`\\n    46→}\\n    47→\\n    48→// modelChangeData is the data payload for session.model_change events.\\n    49→// Copilot CLI emits this early in the transcript with the LLM model being used.\\n    50→type modelChangeData struct {\\n    51→\\tNewModel string `json:\\\"newModel\\\"`\\n    52→}\\n    53→\\n    54→type toolExecCompleteData struct {\\n    55→\\tToolCallID    string        `json:\\\"toolCallId\\\"`\\n    56→\\tModel         string        `json:\\\"model\\\"`\\n    57→\\tToolTelemetry toolTelemetry `json:\\\"toolTelemetry\\\"`\\n    58→}\\n    59→\\n    60→type toolTelemetry struct {\\n    61→\\tMetrics    toolMetrics    `json:\\\"metrics\\\"`\\n    62→\\tProperties toolProperties `json:\\\"properties\\\"`\\n    63→}\\n    64→\\n    65→type toolMetrics struct {\\n    66→\\tLinesAdded   int `json:\\\"linesAdded\\\"`\\n    67→\\tLinesRemoved int `json:\\\"linesRemoved\\\"`\\n    68→}\\n    69→\\n    70→// toolProperties contains string-encoded metadata from tool execution.\\n    71→// filePaths is a JSON-encoded string array, e.g. \\\"[\\\\\\\"path/to/file.txt\\\\\\\"]\\\".\\n    72→type toolProperties struct {\\n    73→\\tFilePaths string `json:\\\"filePaths\\\"`\\n    74→}\\n    75→\\n    76→// parseEventsFromBytes scans JSONL data and returns all parsed events.\\n    77→// Malformed lines are silently skipped.\\n    78→func parseEventsFromBytes(data []byte) ([]copilotEvent, error) {\\n    79→\\treturn parseEventsFromOffset(data, 0)\\n    80→}\\n    81→\\n    82→// parseEventsFromOffset scans JSONL data and returns events starting after\\n    83→// the first startOffset lines. Malformed lines are silently skipped.\\n    84→func parseEventsFromOffset(data []byte, startOffset int) ([]copilotEvent, error) {\\n    85→\\tvar events []copilotEvent\\n    86→\\tscanner := bufio.NewScanner(bytes.NewReader(data))\\n    87→\\tscanner.Buffer(make([]byte, 0, bufio.MaxScanTokenSize), 10*1024*1024) // 10 MB max line\\n    88→\\tlineNum := 0\\n    89→\\n    90→\\tfor scanner.Scan() {\\n    91→\\t\\tlineNum++\\n    92→\\t\\tif lineNum <= startOffset {\\n    93→\\t\\t\\tcontinue\\n    94→\\t\\t}\\n    95→\\n    96→\\t\\tline := scanner.Bytes()\\n    97→\\t\\tif len(line) == 0 {\\n    98→\\t\\t\\tcontinue\\n    99→\\t\\t}\\n   100→\\n   101→\\t\\tvar ev copilotEvent\\n   102→\\t\\tif err := json.Unmarshal(line, &ev); err != nil {\\n   103→\\t\\t\\tcontinue // skip malformed lines\\n   104→\\t\\t}\\n   105→\\t\\tevents = append(events, ev)\\n   106→\\t}\\n   107→\\n   108→\\tif err := scanner.Err(); err != nil {\\n   109→\\t\\treturn events, fmt.Errorf(\\\"transcript scanner error: %w\\\", err)\\n   110→\\t}\\n   111→\\n   112→\\treturn events, nil\\n   113→}\\n   114→\\n   115→// extractModifiedFilesFromEvents collects file paths from tool.execution_complete\\n   116→// events and returns a deduplicated list.\\n   117→func extractModifiedFilesFromEvents(events []copilotEvent) []string {\\n   118→\\tseen := make(map[string]bool)\\n   119→\\tvar files []string\\n   120→\\n   121→\\tfor i := range events {\\n   122→\\t\\tif events[i].Type != eventTypeToolExecDone {\\n   123→\\t\\t\\tcontinue\\n   124→\\t\\t}\\n   125→\\n   126→\\t\\tvar data toolExecCompleteData\\n   127→\\t\\tif err := json.Unmarshal(events[i].Data, &data); err != nil {\\n   128→\\t\\t\\tcontinue\\n   129→\\t\\t}\\n   130→\\n   131→\\t\\t// filePaths is a JSON-encoded string array in properties, e.g. \\\"[\\\\\\\"path/to/file\\\\\\\"]\\\"\\n   132→\\t\\tif data.ToolTelemetry.Properties.FilePaths == \\\"\\\" {\\n   133→\\t\\t\\tcontinue\\n   134→\\t\\t}\\n   135→\\t\\tvar paths []string\\n   136→\\t\\tif err := json.Unmarshal([]byte(data.ToolTelemetry.Properties.FilePaths), &paths); err != nil {\\n   137→\\t\\t\\tcontinue\\n   138→\\t\\t}\\n   139→\\t\\tfor _, fp := range paths {\\n   140→\\t\\t\\tif fp != \\\"\\\" && !seen[fp] {\\n   141→\\t\\t\\t\\tseen[fp] = true\\n   142→\\t\\t\\t\\tfiles = append(files, fp)\\n   143→\\t\\t\\t}\\n   144→\\t\\t}\\n   145→\\t}\\n   146→\\n   147→\\treturn files\\n   148→}\\n   149→\\n   150→// extractPromptsFromEvents collects content from user.message events.\\n   151→func extractPromptsFromEvents(events []copilotEvent) []string {\\n   152→\\tvar prompts []string\\n   153→\\n   154→\\tfor i := range events {\\n   155→\\t\\tif events[i].Type != eventTypeUserMessage {\\n   156→\\t\\t\\tcontinue\\n   157→\\t\\t}\\n   158→\\n   159→\\t\\tvar data userMessageData\\n   160→\\t\\tif err := json.Unmarshal(events[i].Data, &data); err != nil {\\n   161→\\t\\t\\tcontinue\\n   162→\\t\\t}\\n   163→\\n   164→\\t\\tif data.Content != \\\"\\\" {\\n   165→\\t\\t\\tprompts = append(prompts, data.Content)\\n   166→\\t\\t}\\n   167→\\t}\\n   168→\\n   169→\\treturn prompts\\n   170→}\\n   171→\\n   172→// extractSummaryFromEvents returns the content of the last assistant.message event.\\n   173→func extractSummaryFromEvents(events []copilotEvent) string {\\n   174→\\tfor i := len(events) - 1; i >= 0; i-- {\\n   175→\\t\\tif events[i].Type != eventTypeAssistantMsg {\\n   176→\\t\\t\\tcontinue\\n   177→\\t\\t}\\n   178→\\n   179→\\t\\tvar data assistantMessageData\\n   180→\\t\\tif err := json.Unmarshal(events[i].Data, &data); err != nil {\\n   181→\\t\\t\\tcontinue\\n   182→\\t\\t}\\n   183→\\n   184→\\t\\tif data.Content != \\\"\\\" {\\n   185→\\t\\t\\treturn data.Content\\n   186→\\t\\t}\\n   187→\\t}\\n   188→\\n   189→\\treturn \\\"\\\"\\n   190→}\\n   191→\\n   192→// extractModelFromEvents returns the model from transcript events.\\n   193→// First checks session.model_change events, then falls back to the model field\\n   194→// in tool.execution_complete events (Copilot CLI includes model per tool call).\\n   195→func extractModelFromEvents(events []copilotEvent) string {\\n   196→\\t// Primary: session.model_change (explicit model declaration)\\n   197→\\tfor i := len(events) - 1; i >= 0; i-- {\\n   198→\\t\\tif events[i].Type != eventTypeModelChange {\\n   199→\\t\\t\\tcontinue\\n   200→\\t\\t}\\n   201→\\n   202→\\t\\tvar data modelChangeData\\n   203→\\t\\tif err := json.Unmarshal(events[i].Data, &data); err != nil {\\n   204→\\t\\t\\tcontinue\\n   205→\\t\\t}\\n   206→\\n   207→\\t\\tif data.NewModel != \\\"\\\" {\\n   208→\\t\\t\\treturn data.NewModel\\n   209→\\t\\t}\\n   210→\\t}\\n   211→\\n   212→\\t// Fallback: tool.execution_complete events include a model field\\n   213→\\tfor i := len(events) - 1; i >= 0; i-- {\\n   214→\\t\\tif events[i].Type != eventTypeToolExecDone {\\n   215→\\t\\t\\tcontinue\\n   216→\\t\\t}\\n   217→\\n   218→\\t\\tvar data toolExecCompleteData\\n   219→\\t\\tif err := json.Unmarshal(events[i].Data, &data); err != nil {\\n   220→\\t\\t\\tcontinue\\n   221→\\t\\t}\\n   222→\\n   223→\\t\\tif data.Model != \\\"\\\" {\\n   224→\\t\\t\\treturn data.Model\\n   225→\\t\\t}\\n   226→\\t}\\n   227→\\n   228→\\treturn \\\"\\\"\\n   229→}\\n   230→\\n   231→// sessionShutdownData is the data payload for session.shutdown events.\\n   232→// Contains aggregate model metrics for the entire session.\\n   233→type sessionShutdownData struct {\\n   234→\\tModelMetrics []modelMetric `json:\\\"modelMetrics\\\"`\\n   235→}\\n   236→\\n   237→// modelMetric contains per-model token usage aggregates.\\n   238→type modelMetric struct {\\n   239→\\tModelID  string        `json:\\\"modelId\\\"`\\n   240→\\tRequests modelRequests `json:\\\"requests\\\"`\\n   241→\\tUsage    modelUsage    `json:\\\"usage\\\"`\\n   242→}\\n   243→\\n   244→type modelRequests struct {\\n   245→\\tCount int `json:\\\"count\\\"`\\n   246→}\\n   247→\\n   248→type modelUsage struct {\\n   249→\\tInputTokens      int `json:\\\"inputTokens\\\"`\\n   250→\\tOutputTokens     int `json:\\\"outputTokens\\\"`\\n   251→\\tCacheReadTokens  int `json:\\\"cacheReadTokens\\\"`\\n   252→\\tCacheWriteTokens int `json:\\\"cacheWriteTokens\\\"`\\n   253→}\\n   254→\\n   255→// assistantMessageTokenData is used as a fallback when session.shutdown is not\\n   256→// yet available. Each assistant.message may carry an outputTokens field.\\n   257→type assistantMessageTokenData struct {\\n   258→\\tOutputTokens int `json:\\\"outputTokens\\\"`\\n   259→}\\n   260→\\n   261→const eventTypeSessionShutdown = \\\"session.shutdown\\\"\\n   262→\\n   263→// CalculateTokenUsage computes token usage from the Copilot CLI JSONL transcript.\\n   264→// It prefers session.shutdown events (which contain session-wide aggregates) and\\n   265→// falls back to summing per-message outputTokens from assistant.message events.\\n   266→func (c *CopilotCLIAgent) CalculateTokenUsage(transcriptData []byte, fromOffset int) (*agent.TokenUsage, error) {\\n   267→\\tevents, err := parseEventsFromOffset(transcriptData, fromOffset)\\n   268→\\tif err != nil {\\n   269→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript for token usage: %w\\\", err)\\n   270→\\t}\\n   271→\\n   272→\\treturn extractTokenUsageFromEvents(events), nil\\n   273→}\\n   274→\\n   275→// extractTokenUsageFromEvents extracts token usage from parsed events.\\n   276→// Prefers session.shutdown aggregate; falls back to per-message outputTokens.\\n   277→func extractTokenUsageFromEvents(events []copilotEvent) *agent.TokenUsage {\\n   278→\\t// Try session.shutdown first — authoritative session-wide aggregate\\n   279→\\tfor i := len(events) - 1; i >= 0; i-- {\\n   280→\\t\\tif events[i].Type != eventTypeSessionShutdown {\\n   281→\\t\\t\\tcontinue\\n   282→\\t\\t}\\n   283→\\n   284→\\t\\tvar data sessionShutdownData\\n   285→\\t\\tif err := json.Unmarshal(events[i].Data, &data); err != nil {\\n   286→\\t\\t\\tcontinue\\n   287→\\t\\t}\\n   288→\\n   289→\\t\\tif len(data.ModelMetrics) == 0 {\\n   290→\\t\\t\\tcontinue\\n   291→\\t\\t}\\n   292→\\n   293→\\t\\t// Sum across all models\\n   294→\\t\\tusage := &agent.TokenUsage{}\\n   295→\\t\\tfor _, m := range data.ModelMetrics {\\n   296→\\t\\t\\tusage.InputToken