for chunking: %w\\\", err)\\n    75→\\t}\\n    76→\\n    77→\\tif len(session.Messages) == 0 {\\n    78→\\t\\treturn [][]byte{content}, nil\\n    79→\\t}\\n    80→\\n    81→\\t// Marshal info to calculate accurate base size\\n    82→\\tinfoBytes, err := json.Marshal(session.Info)\\n    83→\\tif err != nil {\\n    84→\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal session info for chunking: %w\\\", err)\\n    85→\\t}\\n    86→\\t// Base JSON structure size: {\\\"info\\\":<info>,\\\"messages\\\":[ ... ]}\\n    87→\\tbaseSize := len(`{\\\"info\\\":`) + len(infoBytes) + len(`,\\\"messages\\\":[]}`)\\n    88→\\n    89→\\tvar chunks [][]byte\\n    90→\\tvar currentMessages []ExportMessage\\n    91→\\tcurrentSize := baseSize\\n    92→\\n    93→\\tfor _, msg := range session.Messages {\\n    94→\\t\\t// Marshal message to get its size\\n    95→\\t\\tmsgBytes, err := json.Marshal(msg)\\n    96→\\t\\tif err != nil {\\n    97→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal message for chunking: %w\\\", err)\\n    98→\\t\\t}\\n    99→\\t\\tmsgSize := len(msgBytes) + 1 // +1 for comma separator\\n   100→\\n   101→\\t\\tif currentSize+msgSize > maxSize && len(currentMessages) > 0 {\\n   102→\\t\\t\\t// Save current chunk\\n   103→\\t\\t\\tchunkData, err := json.Marshal(ExportSession{Info: session.Info, Messages: currentMessages})\\n   104→\\t\\t\\tif err != nil {\\n   105→\\t\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal chunk: %w\\\", err)\\n   106→\\t\\t\\t}\\n   107→\\t\\t\\tchunks = append(chunks, chunkData)\\n   108→\\n   109→\\t\\t\\t// Start new chunk\\n   110→\\t\\t\\tcurrentMessages = nil\\n   111→\\t\\t\\tcurrentSize = baseSize\\n   112→\\t\\t}\\n   113→\\n   114→\\t\\tcurrentMessages = append(currentMessages, msg)\\n   115→\\t\\tcurrentSize += msgSize\\n   116→\\t}\\n   117→\\n   118→\\t// Add the last chunk\\n   119→\\tif len(currentMessages) > 0 {\\n   120→\\t\\tchunkData, err := json.Marshal(ExportSession{Info: session.Info, Messages: currentMessages