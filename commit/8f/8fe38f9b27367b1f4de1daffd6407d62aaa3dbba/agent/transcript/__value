& len(currentMessages) > 0 {\\n   335→\\t\\t\\t// Save current chunk\\n   336→\\t\\t\\tchunkData, err := json.Marshal(GeminiTranscript{Messages: currentMessages})\\n   337→\\t\\t\\tif err != nil {\\n   338→\\t\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal chunk: %w\\\", err)\\n   339→\\t\\t\\t}\\n   340→\\t\\t\\tchunks = append(chunks, chunkData)\\n   341→\\n   342→\\t\\t\\t// Start new chunk\\n   343→\\t\\t\\tcurrentMessages = nil\\n   344→\\t\\t\\tcurrentSize = len(`{\\\"messages\\\":[]}`)\\n   345→\\t\\t}\\n   346→\\n   347→\\t\\tcurrentMessages = append(currentMessages, msg)\\n   348→\\t\\tcurrentSize += msgSize\\n   349→\\t}\\n   350→\\n   351→\\t// Add the last chunk\\n   352→\\tif len(currentMessages) > 0 {\\n   353→\\t\\tchunkData, err := json.Marshal(GeminiTranscript{Messages: currentMessages})\\n   354→\\t\\tif err != nil {\\n   355→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal final chunk: %w\\\", err)\\n   356→\\t\\t}\\n   357→\\t\\tchunks = append(chunks, chunkData)\\n   358→\\t}\\n   359→\\n   360→\\t// Ensure we created at least one chunk (could be empty if all messages failed to marshal)\\n   361→\\tif len(chunks) == 0 {\\n   362→\\t\\treturn nil, errors.New(\\\"failed to create any chunks: all messages failed to marshal\\\")\\n   363→\\t}\\n   364→\\n   365→\\treturn chunks, nil\\n   366→}\\n   367→\\n   368→// ReassembleTranscript merges Gemini JSON chunks by combining their message arrays.\\n   369→func (g *GeminiCLIAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n   370→\\tvar allMessages []GeminiMessage\\n   371→\\n   372→\\tfor _, chunk := range chunks {\\n   373→\\t\\tvar transcript GeminiTranscript\\n   374→\\t\\tif err := json.Unmarshal(chunk, &transcript); err != nil {\\n   375→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal chunk: %w\\\", err)\\n   376→\\t\\t}\\n   377→\\t\\tallMessages = append(allMessages, transcript.Messages...)\\n   378→\\t}\\n   379→\\n   380→\\tresult, err := json.Marshal(Gemini