\\\"\\n    17→)\\n    18→\\n    19→// DeepCheckpointValidation contains expected values for comprehensive checkpoint validation.\\n    20→type DeepCheckpointValidation struct {\\n    21→\\tCheckpointID              string\\n    22→\\tStrategy                  string\\n    23→\\tFilesTouched              []string\\n    24→\\tExpectedPrompts           []string\\n    25→\\tExpectedTranscriptContent []string\\n    26→}\\n    27→\\n    28→var hexIDPattern = regexp.MustCompile(`^[0-9a-f]{12}$`)\\n    29→\\n    30→// AssertFileExists asserts that at least one file matches the glob pattern\\n    31→// relative to dir.\\n    32→func AssertFileExists(t *testing.T, dir string, glob string) {\\n    33→\\tt.Helper()\\n    34→\\tmatches, err := filepath.Glob(filepath.Join(dir, glob))\\n    35→\\trequire.NoError(t, err)\\n    36→\\tassert.NotEmpty(t, matches, \\\"expected files matching %s in %s\\\", glob, dir)\\n    37→}\\n    38→\\n    39→// WaitForFileExists polls until at least one file matches the glob pattern\\n    40→// relative to dir, or fails the test after timeout. Handles the race where an\\n    41→// interactive agent's prompt pattern appears before file writes land on disk.\\n    42→func WaitForFileExists(t *testing.T, dir string, glob string, timeout time.Duration) {\\n    43→\\tt.Helper()\\n    44→\\tpattern := filepath.Join(dir, glob)\\n    45→\\tdeadline := time.Now().Add(timeout)\\n    46→\\tfor {\\n    47→\\t\\tmatches, err := filepath.Glob(pattern)\\n    48→\\t\\trequire.NoError(t, err)\\n    49→\\t\\tif len(matches) > 0 {\\n    50→\\t\\t\\treturn\\n    51→\\t\\t}\\n    52→\\t\\tif time.Now().After(deadline) {\\n    53→\\t\\t\\tt.Fatalf(\\\"expected files matching %s in %s within %s\\\", glob, dir, timeout)\\n    54→\\t\\t}\\n    55→\\t\\ttime.Sleep(500 * time.Millisecond)\\n    56→\\t}\\n    57→}\\n    58→\\n    59→// AssertNewCommits polls until at least `atLeast` new commits exist since setup,\\n    60→// or fails after 20 seconds. Polling handles the race where an interactive\\n    61→// agent's prompt pattern appears before its git commit lands on disk.\\n    62→func AssertNewCommits(t *testing.T, s *RepoState, atLeast int) {\\n    63→\\tt.Helper()\\n    64→\\tdeadline := time.Now().Add(20 * time.Second)\\n    65→\\tfor {\\n    66→\\t\\tout := GitOutput(t, s.Dir, \\\"log\\\", \\\"--oneline\\\", s.HeadBefore+\\\"..HEAD\\\")\\n    67→\\t\\tvar lines []string\\n    68→\\t\\tif out != \\\"\\\" {\\n    69→\\t\\t\\tlines = strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\")\\n    70→\\t\\t}\\n    71→\\t\\tif len(lines) >= atLeast {\\n    72→\\t\\t\\treturn\\n    73→\\t\\t}\\n    74→\\t\\tif time.Now().After(deadline) {\\n    75→\\t\\t\\tt.Fatalf(\\\"expected at least %d new commit(s), got %d after 20s\\\", atLeast, len(lines))\\n    76→\\t\\t}\\n    77→\\t\\ttime.Sleep(500 * time.Millisecond)\\n    78→\\t}\\n    79→}\\n    80→\\n    81→// WaitForCheckpoint polls until the checkpoint branch advances from its\\n    82→// initial state, or fails the test after timeout. Use this before any\\n    83→// assertions that depend on the checkpoint branch (post-commit hook is async).\\n    84→func WaitForCheckpoint(t *testing.T, s *RepoState, timeout time.Duration) {\\n    85→\\tt.Helper()\\n    86→\\tdeadline := time.Now().Add(timeout)\\n    87→\\tfor time.Now().Before(deadline) {\\n    88→\\t\\tafter := GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n    89→\\t\\tif after != s.CheckpointBefore {\\n    90→\\t\\t\\treturn\\n    91→\\t\\t}\\n    92→\\t\\ttime.Sleep(200 * time.Millisecond)\\n    93→\\t}\\n    94→\\tt.Fatalf(\\\"checkpoint branch did not advance within %s\\\", timeout)\\n    95→}\\n    96→\\n    97→// shadowBranches returns all shadow branches (entire/*) excluding entire/checkpoints/*.\\n    98→func shadowBranches(t *testing.T, dir string) []string {\\n    99→\\tt.Helper()\\n   100→\\tbranches := GitOutput(t, dir, \\\"for-each-ref\\\", \\\"--format=%(refname:short)\\\", \\\"refs/heads/entire/\\