dex.\\n   546→func ReadSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int) SessionMetadata {\\n   547→\\tt.Helper()\\n   548→\\n   549→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   550→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   551→\\n   552→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   553→\\n   554→\\tvar meta SessionMetadata\\n   555→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   556→\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   557→\\t}\\n   558→\\n   559→\\treturn meta\\n   560→}\\n   561→\\n   562→// WaitForSessionMetadata polls until session metadata exists on the checkpoint\\n   563→// branch for the given checkpoint ID and session index, then returns it.\\n   564→// This handles the race where the checkpoint branch advances before session\\n   565→// metadata is fully committed.\\n   566→func WaitForSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int, timeout time.Duration) SessionMetadata {\\n   567→\\tt.Helper()\\n   568→\\n   569→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   570→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   571→\\n   572→\\tdeadline := time.Now().Add(timeout)\\n   573→\\tfor time.Now().Before(deadline) {\\n   574→\\t\\traw := gitOutputSafe(dir, \\\"show\\\", blob)\\n   575→\\t\\tif raw != \\\"\\\" {\\n   576→\\t\\t\\tvar meta SessionMetadata\\n   577→\\t\\t\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   578→\\t\\t\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   579→\\t\\t\\t}\\n   580→\\t\\t\\treturn meta\\n   581→\\t\\t}\\n   582→\\t\\ttime.Sleep(500 * time.Millisecond)\\n   583→\\t}\\n   584→\\tt.Fatalf(\\\"session metadata %s did not appear within %s\\\", blob, timeout)\\n   585→\\treturn SessionMetadata{}\\n   586→}\\n   587→\\n   588→// SetupBareRemote creates a bare git repo, adds it as \\\"origin\\\", and pushes\\n   589→// the initial commit. Returns the bare repo path.\\n   590→func SetupBareRemote(t *testing.T, s *RepoState) string {\\n   591→\\tt.Helper()\\n   592→\\n   593→\\tvar bareDir string\\n   594→\\tif os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\" {\\n   595→\\t\\tvar err error\\n   596→\\t\\tbareDir, err = os.MkdirTemp(\\\"\\\", \\\"e2e-bare-*\\\")\\n   597→\\t\\tif err != nil {\\n   598→\\t\\t\\tt.Fatalf(\\\"create bare remote dir: %v\\\", err)\\n   599→\\t\\t}\\n   600→\\t\\tt.Logf(\\\"E2E_KEEP_REPOS: bare remote will be preserved at %s\\\", bareDir)\\n   601→\\t} else {\\n   602→\\t\\tbareDir = t.TempDir()\\n   603→\\t}\\n   604→\\n   605→\\tGit(t, bareDir, \\\"init\\\", \\\"--bare\\\")\\n   606→\\tGit(t, s.Dir, \\\"remote\\\", \\\"add\\\", \\\"origin\\\", bareDir)\\n   607→\\tGit(t, s.Dir, \\\"push\\\", \\\"-u\\\", \\\"origin\\\", \\\"HEAD\\\")\\n   608→\\treturn bareDir\\n   609→}\\n   610→\\n   611→// GitOutputErr runs a git command and returns (output, error) without\\n   612→// failing the test. For commands expected to fail.\\n   613→func GitOutputErr(dir string, args ...string) (string, error) {\\n   614→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   615→\\tif dir != \\\"\\\" {\\n   616→\\t\\tcmd.Dir = dir\\n   617→\\t}\\n   618→\\tout, err := cmd.CombinedOutput()\\n   619→\\treturn strings.TrimSpace(string(out)), err\\n   620→}\\n   621→\\n   622→// GetCheckpointTrailer extracts the Entire-Checkpoint trailer value from a\\n   623→// code commit. Returns the trimmed trailer value, or an empty string if the\\n   624→// trailer is not present.\\n   625→func GetCheckpointTrailer(t *testing.T, dir string, ref string) string {\\n   626→\\tt.Helper()\\n   627→\\n   628→\\treturn GitOutput(t, dir, \\\"log\\\", \\\"-1\\\", \\\"--format=%(trailers:key=Entire-Checkpoint,valueonly)\\\", ref)\\n   629→}\\n   630→\"}]},\"uuid\":\"17118398-3a79-4956-b40d-eef4c25e757d\",\"timestamp\":\"2026-