I errors\\\", maxScenarioRestarts+1)\\n   321→\\t\\t\\t\\t}\\n   322→\\t\\t\\t\\tt.Logf(\\\"transient error, restarting scenario (attempt %d/%d)\\\", attempt+2, maxScenarioRestarts+1)\\n   323→\\t\\t\\t}\\n   324→\\t\\t})\\n   325→\\t}\\n   326→}\\n   327→\\n   328→// runScenario runs the test function and recovers from errScenarioRestart\\n   329→// panics triggered by transient API errors in RunPrompt. Returns true if\\n   330→// the scenario should be restarted with a fresh repository.\\n   331→func runScenario(t *testing.T, s *RepoState, ctx context.Context, fn func(t *testing.T, s *RepoState, ctx context.Context)) (restarted bool) {\\n   332→\\tt.Helper()\\n   333→\\tdefer func() {\\n   334→\\t\\tif r := recover(); r != nil {\\n   335→\\t\\t\\tif _, ok := r.(errScenarioRestart); ok {\\n   336→\\t\\t\\t\\trestarted = true\\n   337→\\t\\t\\t\\treturn\\n   338→\\t\\t\\t}\\n   339→\\t\\t\\tpanic(r) // re-panic for unexpected panics\\n   340→\\t\\t}\\n   341→\\t}()\\n   342→\\tfn(t, s, ctx)\\n   343→\\treturn false\\n   344→}\\n   345→\\n   346→const maxScenarioRestarts = 2 // restart up to 2 times = 3 total attempts\\n   347→\\n   348→// errScenarioRestart is panicked by RunPrompt when a transient API error is\\n   349→// detected. ForEachAgent recovers from this panic and restarts the test\\n   350→// scenario with a fresh repository, avoiding stale CLI state from the failed\\n   351→// attempt.\\n   352→type errScenarioRestart struct {\\n   353→\\tmsg string\\n   354→}\\n   355→\\n   356→// RunPrompt runs an agent prompt, logs the command and output to ConsoleLog,\\n   357→// and returns the result. If the agent reports a transient API error, it\\n   358→// panics with errScenarioRestart to trigger a full scenario restart in\\n   359→// ForEachAgent (see runScenario).\\n   360→func (s *RepoState) RunPrompt(t *testing.T, ctx context.Context, prompt string, opts ...agents.Option) (agents.Output, error) {\\n   361→\\tt.Helper()\\n   362→\\tout, err := s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n   363→\\ts.logPromptResult(out)\\n   364→\\n   365→\\tif err != nil && s.Agent.IsTransientError(out, err) {\\n   366→\\t\\terrMsg := fmt.Sprintf(\\\"transient API error (stderr: %s)\\\", strings.TrimSpace(out.Stderr))\\n   367→\\t\\tt.Logf(\\\"%s — restarting scenario\\\", errMsg)\\n   368→\\t\\tfmt.Fprintf(s.ConsoleLog, \\\"> [transient] %s — restarting scenario\\\\n\\\", errMsg)\\n   369→\\t\\tpanic(errScenarioRestart{msg: errMsg})\\n   370→\\t}\\n   371→\\n   372→\\treturn out, err\\n   373→}\\n   374→\\n   375→func (s *RepoState) logPromptResult(out agents.Output) {\\n   376→\\ts.ConsoleLog.WriteString(\\\"> \\\" + out.Command + \\\"\\\\n\\\")\\n   377→\\ts.ConsoleLog.WriteString(\\\"stdout:\\\\n\\\" + out.Stdout + \\\"\\\\n\\\")\\n   378→\\ts.ConsoleLog.WriteString(\\\"stderr:\\\\n\\\" + out.Stderr + \\\"\\\\n\\\")\\n   379→}\\n   380→\\n   381→// Git runs a git command in the repo and logs it to ConsoleLog.\\n   382→func (s *RepoState) Git(t *testing.T, args ...string) {\\n   383→\\tt.Helper()\\n   384→\\ts.ConsoleLog.WriteString(\\\"> git \\\" + strings.Join(args, \\\" \\\") + \\\"\\\\n\\\")\\n   385→\\tGit(t, s.Dir, args...)\\n   386→}\\n   387→\\n   388→// StartSession starts an interactive session and registers it for pane\\n   389→// capture in artifacts. Returns nil if the agent does not support interactive\\n   390→// mode. The session is closed automatically during test cleanup.\\n   391→func (s *RepoState) StartSession(t *testing.T, ctx context.Context) agents.Session {\\n   392→\\tt.Helper()\\n   393→\\tsession, err := s.Agent.StartSession(ctx, s.Dir)\\n   394→\\tif err != nil {\\n   395→\\t\\tt.Fatalf(\\\"start session: %v\\\", err)\\n   396→\\t}\\n   397→\\tif session == nil {\\n   398→\\t\\treturn nil\\n   399→\\t}\\n   400→\\ts.session = session\\n   401→\\treturn session\\n   402→}\\n   403→\\n   404→// WaitFor waits for a pattern in the interactive session's pane and logs the\\n   405→// pane content to ConsoleLog after the wait completes (success or failure).\\n   406→func (s *RepoState) WaitFor(t *testing.T, session agents.Session, pattern string, timeout time.Duration) {\\n   407→\\tt.Helper()\\n   408→\\tcontent, err := session.WaitFor(pattern, timeout)\\n   409→\\tfmt.Fprintf(s.ConsoleLog, \\\"> pane after WaitFor(%q):\\\\n%s\\\\n\\\", pattern, content)\\n   410→\\tif err != nil {\\n   411→\\t\\tt.Fatalf(\\\"WaitFor(%q): %v\\\", pattern, err)\\n   412→\\t}\\n   413→}\\n   414→\\n   415→// Send sends input to an interactive session and logs it to ConsoleLog.\\n   416→// Fails the test on error.\\n   417→func (s *RepoState) Send(t *testing.T, session agents.Session, input string) {\\n   418→\\tt.Helper()\\n   419→\\ts.ConsoleLog.WriteString(\\\"> send: \\\" + input + \\\"\\\\n\\\")\\n   420→\\tif err := session.Send(input); err != nil {\\n   421→\\t\\tt.Fatalf(\\\"send failed: %v\\\", err)\\n   422→\\t}\\n   423→}\\n   424→\\n   425→// PatchSettings merges extra keys into .entire/settings.json.\\n   426→func PatchSettings(t *testing.T, dir string, extra map[string]any) {\\n   427→\\tt.Helper()\\n   428→\\tpath := filepath.Join(dir, \\\".entire\\\", \\\"settings.json\\\")\\n   429→\\tdata, err := os.ReadFile(path)\\n   430→\\tif err != nil {\\n   431→\\t\\tt.Fatalf(\\\"read settings: %v\\\", err)\\n   432→\\t}\\n   433→\\tvar settings map[string]any\\n   434→\\tif err := json.Unmarshal(data, &settings); err != nil {\\n   435→\\t\\tt.Fatalf(\\\"parse settings: %v\\\", err)\\n   436→\\t}\\n   437→\\tfor k, v := range extra {\\n   438→\\t\\tsettings[k] = v\\n   439→\\t}\\n   440→\\tout, err := json.MarshalIndent(settings, \\\"\\\", \\\"  \\\")\\n   441→\\tif err != nil {\\n   442→\\t\\tt.Fatalf(\\\"marshal settings: %v\\\", err)\\n   443→\\t}\\n   444→\\tif err := os.WriteFile(path, out, 0o644); err != nil {\\n   445→\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n   446→\\t}\\n   447→}\\n   448→\\n   449→// Git runs a git command in the given directory and fails the test if it\\n   450→// returns a non-zero exit code.\\n   451→func Git(t *testing.T, dir string, args ...string) {\\n   452→\\tt.Helper()\\n   453→\\n   454→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   455→\\tif dir != \\\"\\\" {\\n   456→\\t\\tcmd.Dir = dir\\n   457→\\t}\\n   458→\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   459→\\n   460→\\tout, err := cmd.CombinedOutput()\\n   461→\\tif err != nil {\\n   462→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n   463→\\t}\\n   464→}\\n   465→\\n   466→// GitOutput runs a git command in the given directory, returns its trimmed\\n   467→// stdout, and fails the test on error.\\n   468→func GitOutput(t *testing.T, dir string, args ...string) string {\\n   469→\\tt.Helper()\\n   470→\\n   471→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   472→\\tif dir != \\\"\\\" {\\n   473→\\t\\tcmd.Dir = dir\\n   474→\\t}\\n   475→\\n   476→\\tout, err := cmd.Output()\\n   477→\\tif err != nil {\\n   478→\\t\\tvar stderr string\\n   479→\\t\\tee := &exec.ExitError{}\\n   480→\\t\\tif errors.As(err, &ee) {\\n   481→\\t\\t\\tstderr = string(ee.Stderr)\\n   482→\\t\\t}\\n   483→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, stderr)\\n   484→\\t}\\n   485→\\n   486→\\treturn strings.TrimSpace(string(out))\\n   487→}\\n   488→\\n   489→// NewCheckpointCommits returns the SHAs of commits added to the\\n   490→// entire/checkpoints/v1 branch since the test was set up, oldest first.\\n   491→func NewCheckpointCommits(t *testing.T, s *RepoState) []string {\\n   492→\\tt.Helper()\\n   493→\\n   494→\\tlog := GitOutput(t, s.Dir, \\\"log\\\", \\\"--reverse\\\", \\\"--format=%H\\\", s.CheckpointBefore+\\\"..entire/checkpoints/v1\\\")\\n   495→\\tif log == \\\"\\\" {\\n   496→\\t\\treturn nil\\n   497→\\t}\\n   498→\\treturn strings.Split(log, \\\"\\\\n\\\")\\n   499→}\\n   500→\\n   501→// CheckpointIDs lists all checkpoint IDs from the tree