n \\\"SessionStart\\\"\\n    77→\\tcase EventSessionStop:\\n    78→\\t\\treturn \\\"SessionStop\\\"\\n    79→\\tcase EventCompaction:\\n    80→\\t\\treturn \\\"Compaction\\\"\\n    81→\\tdefault:\\n    82→\\t\\treturn fmt.Sprintf(\\\"Event(%d)\\\", int(e))\\n    83→\\t}\\n    84→}\\n    85→\\n    86→// Action represents a side effect that should be performed after a transition.\\n    87→// The caller is responsible for executing these -- the state machine only declares them.\\n    88→type Action int\\n    89→\\n    90→const (\\n    91→\\tActionCondense               Action = iota // Condense session data to permanent storage\\n    92→\\tActionCondenseIfFilesTouched               // Condense only if FilesTouched is non-empty\\n    93→\\tActionDiscardIfNoFiles                     // Discard session if FilesTouched is empty\\n    94→\\tActionWarnStaleSession                     // Warn user about stale session(s)\\n    95→\\tActionClearEndedAt                         // Clear EndedAt timestamp (session re-entering)\\n    96→\\tActionUpdateLastInteraction                // Update LastInteractionTime\\n    97→)\\n    98→\\n    99→// String returns a human-readable name for the action.\\n   100→func (a Action) String() string {\\n   101→\\tswitch a {\\n   102→\\tcase ActionCondense:\\n   103→\\t\\treturn \\\"Condense\\\"\\n   104→\\tcase ActionCondenseIfFilesTouched:\\n   105→\\t\\treturn \\\"CondenseIfFilesTouched\\\"\\n   106→\\tcase ActionDiscardIfNoFiles:\\n   107→\\t\\treturn \\\"DiscardIfNoFiles\\\"\\n   108→\\tcase ActionWarnStaleSession:\\n   109→\\t\\treturn \\\"WarnStaleSession\\\"\\n   110→\\tcase ActionClearEndedAt:\\n   111→\\t\\treturn \\\"ClearEndedAt\\\"\\n   112→\\tcase ActionUpdateLastInteraction:\\n   113→\\t\\treturn \\\"UpdateLastInteraction\\\"\\n   114→\\tdefault:\\n   115→\\t\\treturn fmt.Sprintf(\\\"Action(%d)\\\", int(a))\\n   116→\\t}\\n   117→}\\n   118→\\n   119→// TransitionContext provides read-only context for transitions that need\\n   120→// to inspect session state without mutating it.\\n   121→type TransitionContext struct {\\n   122→\\tHasFilesTouched    bool // len(FilesTouched) > 0\\n   123→\\tIsRebaseInProgress bool // .git/rebase-merge/ or .git/rebase-apply/ exists\\n   124→}\\n   125→\\n   126→// TransitionResult holds the outcome of a state machine transition.\\n   127→type TransitionResult struct {\\n   128→\\tNewPhase Phase\\n   129→\\tActions  []Action\\n   130→}\\n   131→\\n   132→// Transition computes the next phase and required actions given the current\\n   133→// phase and an event. This is a pure function with no side effects.\\n   134→//\\n   135→// Empty or unknown phase values are normalized to PhaseIdle for backward\\n   136→// compatibility with session state files created before phase tracking.\\n   137→func Transition(current Phase, event Event, ctx TransitionContext) TransitionResult {\\n   138→\\t// Normalize empty/unknown phase to idle for backward compatibility.\\n   139→\\tcurrent = PhaseFromString(string(current))\\n   140→\\n   141→\\tswitch current {\\n   142→\\tcase PhaseIdle:\\n   143→\\t\\treturn transitionFromIdle(event, ctx)\\n   144→\\tcase PhaseActive:\\n   145→\\t\\treturn transitionFromActive(event, ctx)\\n   146→\\tcase PhaseEnded:\\n   147→\\t\\treturn transitionFromEnded(event, ctx)\\n   148→\\tdefault:\\n   149→\\t\\t// PhaseFromString guarantees we only get known phases, but the\\n   150→\\t\\t// exhaustive linter requires handling the default case.\\n   151→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   152→\\t}\\n   153→}\\n   154→\\n   155→func transitionFromIdle(event Event, ctx TransitionContext) TransitionResult {\\n   156→\\tswitch event {\\n   157→\\tcase EventTurnStart:\\n   158→\\t\\treturn TransitionResult{\\n   159→\\t\\t\\tNewPhase: PhaseActive,\\n   160→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   161→\\t\\t}\\n   162→\\tcase EventTurnEnd:\\n   163→\\t\\t// Turn end while idle is a no-op (no active turn to end).\\n   164→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   165→\\tcase EventGitCommit:\\n   166→\\t\\tif ctx.IsRebaseInProgress {\\n   167→\\t\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   168→\\t\\t}\\n   169→\\t\\treturn TransitionResult{\\n   170→\\t\\t\\tNewPhase: PhaseIdle,\\n   171→\\t\\t\\tActions:  []Action{ActionCondense},\\n   172→\\t\\t}\\n   173→\\tcase EventSessionStart:\\n   174→\\t\\t// Already condensable, no-op.\\n   175→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   176→\\tcase EventSessionStop:\\n   177→\\t\\treturn TransitionResult{\\n   178→\\t\\t\\tNewPhase: PhaseEnded,\\n   179→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   180→\\t\\t}\\n   181→\\tcase EventCompaction:\\n   182→\\t\\t// Compaction while idle shouldn't happen, but condense if there's work.\\n   183→\\t\\treturn TransitionResult{\\n   184→\\t\\t\\tNewPhase: PhaseIdle,\\n   185→\\t\\t\\tActions:  []Action{ActionCondenseIfFilesTouched, ActionUpdateLastInteraction},\\n   186→\\t\\t}\\n   187→\\tdefault:\\n   188→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   189→\\t}\\n   190→}\\n   191→\\n   192→func transitionFromActive(event Event, ctx TransitionContext) TransitionResult {\\n   193→\\tswitch event {\\n   194→\\tcase EventTurnStart:\\n   195→\\t\\t// Ctrl-C recovery: agent crashed or user interrupted mid-turn.\\n   196→\\t\\treturn TransitionResult{\\n   197→\\t\\t\\tNewPhase: PhaseActive,\\n   198→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   199→\\t\\t}\\n   200→\\tcase EventTurnEnd:\\n   201→\\t\\treturn TransitionResult{\\n   202→\\t\\t\\tNewPhase: PhaseIdle,\\n   203→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   204→\\t\\t}\\n   205→\\tcase EventGitCommit:\\n   206→\\t\\tif ctx.IsRebaseInProgress {\\n   207→\\t\\t\\treturn TransitionResult{NewPhase: PhaseActive}\\n   208→\\t\\t}\\n   209→\\t\\treturn TransitionResult{\\n   210→\\t\\t\\tNewPhase: PhaseActive,\\n   211→\\t\\t\\tActions:  []Acti