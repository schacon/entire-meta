}\\n   387→\\n   388→\\tstateFile := filepath.Join(sessionStateDir, stateFiles[0].Name())\\n   389→\\tstateData, err := os.ReadFile(stateFile)\\n   390→\\tif err != nil {\\n   391→\\t\\tt.Fatalf(\\\"Failed to read session state file: %v\\\", err)\\n   392→\\t}\\n   393→\\tstateContent := string(stateData)\\n   394→\\tt.Logf(\\\"Session state:\\\\n%s\\\", stateContent)\\n   395→\\n   396→\\t// Gitignored files should NOT be in session state\\n   397→\\tif strings.Contains(stateContent, \\\"node_modules\\\") {\\n   398→\\t\\tt.Error(\\\"node_modules should NOT be in UntrackedFilesAtStart (gitignored)\\\")\\n   399→\\t}\\n   400→\\tif strings.Contains(stateContent, \\\"build/app.js\\\") {\\n   401→\\t\\tt.Error(\\\"build/app.js should NOT be in UntrackedFilesAtStart (gitignored)\\\")\\n   402→\\t}\\n   403→\\tif strings.Contains(stateContent, \\\"debug.log\\\") {\\n   404→\\t\\tt.Error(\\\"debug.log should NOT be in UntrackedFilesAtStart (gitignored via *.log)\\\")\\n   405→\\t}\\n   406→\\n   407→\\t// Legitimate untracked files SHOULD be in session state\\n   408→\\tif !strings.Contains(stateContent, \\\"config.local.json\\\") {\\n   409→\\t\\tt.Error(\\\"config.local.json should be in UntrackedFilesAtStart (not gitignored)\\\")\\n   410→\\t}\\n   411→\\tif !strings.Contains(stateContent, \\\"notes.txt\\\") {\\n   412→\\t\\tt.Error(\\\"notes.txt should be in UntrackedFilesAtStart (not gitignored)\\\")\\n   413→\\t}\\n   414→}\\n   415→\\n   416→// TestShadow_GitignoredFilesPreservedDuringRewind tests that gitignored files\\n   417→// are not accidentally deleted during rewind, even though they are not tracked\\n   418→// in UntrackedFilesAtStart (since they're excluded by .gitignore).\\n   419→func TestShadow_GitignoredFilesPreservedDuringRewind(t *testing.T) {\\n   420→\\tt.Parallel()\\n   421→\\tenv := NewTestEnv(t)\\n   422→\\tdefer env.Cleanup()\\n   423→\\n   424→\\tenv.InitRepo()\\n   425→\\n   426→\\t// Create initial commit with .gitignore\\n   427→\\tenv.Wri