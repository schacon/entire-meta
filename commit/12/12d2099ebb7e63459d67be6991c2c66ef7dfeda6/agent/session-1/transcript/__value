  45→\\tfor _, c := range committed {\\n    46→\\t\\tresult = append(result, CheckpointInfo{\\n    47→\\t\\t\\tCheckpointID:     c.CheckpointID,\\n    48→\\t\\t\\tSessionID:        c.SessionID,\\n    49→\\t\\t\\tCreatedAt:        c.CreatedAt,\\n    50→\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n    51→\\t\\t\\tFilesTouched:     c.FilesTouched,\\n    52→\\t\\t\\tAgent:            c.Agent,\\n    53→\\t\\t\\tIsTask:           c.IsTask,\\n    54→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    55→\\t\\t\\tSessionCount:     c.SessionCount,\\n    56→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    57→\\t\\t})\\n    58→\\t}\\n    59→\\n    60→\\treturn result, nil\\n    61→}\\n    62→\\n    63→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    64→func (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n    65→\\tall, err := s.listCheckpoints()\\n    66→\\tif err != nil {\\n    67→\\t\\treturn nil, err\\n    68→\\t}\\n    69→\\n    70→\\tvar result []CheckpointInfo\\n    71→\\tfor _, cp := range all {\\n    72→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    73→\\t\\t\\tresult = append(result, cp)\\n    74→\\t\\t}\\n    75→\\t}\\n    76→\\n    77→\\tif len(result) == 0 {\\n    78→\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n    79→\\t}\\n    80→\\n    81→\\treturn result, nil\\n    82→}\\n    83→\\n    84→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    85→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    86→func (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n    87→\\tstore, err := s.getCheckpointStore()\\n    88→\\tif err != nil {\\n    89→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    90→\\t}\\n    91→\\n    92→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n    93→\\tif err != nil {\\n    94→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    95→\\t}\\n    96→\\tif content == nil {\\n    97→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n    98→\\t}\\n    99→\\tif len(content.Transcript) == 0 {\\n   100→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   101→\\t}\\n   102→\\n   103→\\treturn content.Transcript, nil\\n   104→}\\n   105→\\n   106→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   107→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   108→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   109→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   110→//\\n   111→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   112→// In this case, data is extracted from the live transcript instead.\\n   113→func (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n   114→\\t// Get shadow branch (may not exist for mid-session commits)\\n   115→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   116→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   117→\\tref, err := repo.Reference(refName, true)\\n   118→\\thasShadowBranch := err == nil\\n   119→\\n   120→\\tvar sessionData *ExtractedSessionData\\n   121→\\tif hasShadowBranch {\\n   122→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   123→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   124→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   125→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   126→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   127→\\t\\t// last turn had no code changes).\\n   128→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   129→\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n   130→\\t\\tif err != nil {\\n   131→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n   132→\\t\\t}\\n   133→\\t} else {\\n   134→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   135→\\t\\t// Extract data directly from live transcript.\\n   136→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   137→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   138→\\t\\t}\\n   139→\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n   140→\\t\\tif err != nil {\\n   141→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n   142→\\t\\t}\\n   143→\\t}\\n   144→\\n   145→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   146→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   147→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   148→\\tif len(committedFiles) > 0 {\\n   149→\\t\\tif len(sessionData.FilesTouched) > 0 {\\n   150→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   151→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   152→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   153→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   154→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   155→\\t\\t\\t\\t}\\n   156→\\t\\t\\t}\\n   157→\\t\\t\\tsessionData.FilesTouched = filtered\\n   158→\\t\\t}\\n   159→\\n   160→\\t\\t// If extraction failed or returned empty, use committedFiles as fallback.\\n   161→\\t\\t// This handles mid-session commits where transcript parsing may not find files\\n   162→\\t\\t// but we know what was committed.\\n   163→\\t\\tif len(sessionData.FilesTouched) == 0 {\\n   164→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   165→\\t\\t\\tfor f := range committedFiles {\\n   166→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   167→\\t\\t\\t}\\n   168→\\t\\t}\\n   169→\\t}\\n   170→\\n   171→\\t// Get checkpoint store\\n   172→\\tstore, err := s.getCheckpointStore()\\n   173→\\tif err != nil {\\n   174→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   175→\\t}\\n   176→\\n   177→\\t// Get author info\\n   178→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   179→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   180→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   181→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   182→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n   183→\\t// Get current branch name\\n   184→\\tbranchName := GetCurrentBranchName(repo)\\n   185→\\n   186→\\t// Generate summary if enabled\\n   187→\\tvar summary *cpkg.Summary\\n   188→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   189→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   190→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   191→\\n   192→\\t\\t// Scope transcript to this checkpoint's portion.\\n   193→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   194→\\t\\t// For Gemini (JSON), CheckpointTranscriptStart is a message index.\\n   195→\\t\\tvar scopedTranscript []byte\\n   196→\\t\\tif state.AgentType == agent.AgentTypeGemini {\\n   197→\\t\\t\\tscopedTranscript = geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   198→\\t\\t} else {\\n   199→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   200→\\t\\t}\\n   201→\\t\\tif len(scopedTranscript) > 0 {\\n   202→\\t\\t\\tvar err error\\n   203→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   204→\\t\\t\\tif err != nil {\\n   205→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   206→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   207→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   208→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   209→\\t\\t\\t} else {\\n   210→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   211→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   212→\\t\\t\\t}\\n   213→\\t\\t}\\n   214→\\t}\\n   215→\\n   216→\\t// Write checkpoint metadata using the checkpoint store\\n   217→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   218→\\t\\tCheckpointID:                checkpointID,\\n   219→\\t\\tSessionID:                   state.SessionID,\\n   220→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   221→\\t\\tBranch:                      branchName,\\n   222→\\t\\tTranscript:                  sessionData.Transcript,\\n   223→\\t\\tPrompts:                     sessionData.Prompts,\\n   224→\\t\\tContext:                     sessionData.Context,\\n   225→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   226→\\t\\tCheckpointsCount:            state.StepCount,\\n   227→\\t\\tEphemeralBranch:             shadowBranchName,\\n   228→\\t\\tAuthorName:                  authorName,\\n   229→\\t\\tAuthorEmail:                 authorEmail,\\n   230→\\t\\tAgent:                       state.AgentType,\\n   231→\\t\\tTurnID:                      state.TurnID,\\n   232→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   233→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   234→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   235→\\t\\tInitialAttribution:          attribution,\\n   236→\\t\\tSummary:                     summary,\\n   237→\\t}); err != nil {\\n   238→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   239→\\t}\\n   240→\\n   241→\\treturn &CondenseResult{\\n   242→\\t\\tCheckpointID:         checkpointID,\\n   243→\\t\\tSessionID:            state.SessionID,\\n   244→\\t\\tCheckpointsCount:     state.StepCount,\\n   245→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   246→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   247→\\t}, nil\\n   248→}\\n   249→\\n   250→func calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n   251→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   252→\\t// This uses user edits captured at each prompt start (before agent works),\\n   253→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   254→\\t//\\n   255→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   256→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   257→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   258→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   259→\\n   260→\\theadRef, headErr := repo.Head()\\n   261→\\tif headErr != nil {\\n   262→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   263→\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   264→\\t\\treturn nil\\n   265→\\t}\\n   266→\\n   267→\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   268→\\tif commitErr != nil {\\n   269→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   270→\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   271→\\t\\treturn nil\\n   272→\\t}\\n   273→\\n   274→\\theadTree, treeErr := headCommit.Tree()\\n   275→\\tif treeErr != nil {\\n   276→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   277→\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   278→\\t\\treturn nil\\n   279→\\t}\\n   280→\\n   281→\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n   282→\\tvar shadowTree *object.Tree\\n   283→\\tif shadowRef != nil {\\n   284→\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   285→\\t\\tif shadowErr != nil {\\n   286→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   287→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   288→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   289→\\t\\t\\treturn nil\\n   290→\\t\\t}\\n   291→\\t\\tvar shadowTreeErr error\\n   292→\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   293→\\t\\tif shadowTreeErr != nil {\\n   294→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   295→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   296→\\t\\t\\treturn nil\\n   297→\\t\\t}\\n   298→\\t} else {\\n   299→\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   300→\\t\\t// because the agent's work is the commit itself.\\n   301→\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   302→\\t\\tshadowTree = headTree\\n   303→\\t}\\n   304→\\n   305→\\t// Get base tree (state before session started)\\n   306→\\tvar baseTree *object.Tree\\n   307→\\tattrBase := state.AttributionBaseCommit\\n   308→\\tif attrBase == \\\"\\\" {\\n   309→\\t\\tattrBase = state.BaseCommit // backward compat\\n   310→\\t}\\n   311→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   312→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   313→\\t\\t\\tbaseTree = tree\\n   314→\\t\\t} else {\\n   315→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   316→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   317→\\t\\t}\\n   318→\\t} else {\\n   319→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   320→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   321→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   322→\\t}\\n   323→\\n   324→\\t// Log accumulated prompt attributions for debugging\\n   325→\\tvar totalUserAdded, totalUserRemoved int\\n   326→\\tfor i, pa := range state.PromptAttributions {\\n   327→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   328→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   329→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   330→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   331→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   332→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   333→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   334→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   335→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   336→\\t}\\n   337→\\n   338→\\tattribution := CalculateAttributionWithAccumulated(\\n   339→\\t\\tbaseTree,\\n   340→\\t\\tshadowTree,\\n   341→\\t\\theadTree,\\n   342→\\t\\tsessionData.FilesTouched,\\n   343→\\t\\tstate.PromptAttributions,\\n   344→\\t)\\n   345→\\n   346→\\tif attribution != nil {\\n   347→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   348→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   349→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   350→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   351→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   352→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   353→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   354→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   355→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   356→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   357→\\t}\\n   358→\\n   359→\\treturn attribution\\n   360→}\\n   361→\\n   362→// extractSessionData extracts session data from the shadow branch.\\n   363→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   364→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   365→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   366→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   367→// continued growing — the shadow branch copy would be stale.\\n   368→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   369→func (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n   370→\\tcommit, err := repo.CommitObject(shadowRef)\\n   371→\\tif err != nil {\\n   372→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   373→\\t}\\n   374→\\n   375→\\ttree, err := commit.Tree()\\n   376→\\tif err != nil {\\n   377→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   378→\\t}\\n   379→\\n   380→\\tdata := &ExtractedSessionData{}\\n   381→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   382→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   383→\\n   384→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   385→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   386→\\t// (SaveStep is only called when there are file modifications).\\n   387→\\tvar fullTranscript string\\n   388→\\tif liveTranscriptPath != \\\"\\\" {\\n   389→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   390→\\t\\t\\tfullTranscript = string(liveData)\\n   391→\\t\\t}\\n   392→\\t}\\n   393→\\tif fullTranscript == \\\"\\\" {\\n   394→\\t\\t// Fall back to shadow branch copy\\n   395→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   396→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   397→\\t\\t\\t\\tfullTranscript = content\\n   398→\\t\\t\\t}\\n   399→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   400→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   401→\\t\\t\\t\\tfullTranscript = content\\n   402→\\t\\t\\t}\\n   403→\\t\\t}\\n   404→\\t}\\n   405→\\n   406→\\t// Process transcript based on agent type\\n   407→\\tif fullTranscript != \\\"\\\" {\\n   408→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   409→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   410→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   411→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   412→\\t}\\n   413→\\n   414→\\t// Use tracked files from session state (not all files in tree)\\n   415→\\tdata.FilesTouched = filesTouched\\n   416→\\n   417→\\t// Calculate token usage from the extracted transcript portion\\n   418→\\tif len(data.Transcript) > 0 {\\n   419→\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n   420→\\t}\\n   421→\\n   422→\\treturn data, nil\\n   423→}\\n   424→\\n   425→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   426→// This is used for mid-session commits where no shadow branch exists yet.\\n   427→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n   428→\\tdata := &ExtractedSessionData{}\\n   429→\\n   430→\\t// Read the live transcript\\n   431→\\tif state.TranscriptPath == \\\"\\\" {\\n   432→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   433→\\t}\\n   434→\\n   435→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   436→\\tif err != nil {\\n   437→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   438→\\t}\\n   439→\\n   440→\\tif len(liveData) == 0 {\\n   441→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   442→\\t}\\n   443→\\n   444→\\tfullTranscript := string(liveData)\\n   445→\\tdata.Transcript = liveData\\n   446→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   447→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   448→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   449→\\n   450→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   451→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   452→\\tif len(state.FilesTouched) > 0 {\\n   453→\\t\\tdata.FilesTouched = state.FilesTouched\\n   454→\\t} else {\\n   455→\\t\\t// Use the shared helper which includes subagent transcripts\\n   456→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n   457→\\t}\\n   458→\\n   459→\\t// Calculate token usage from the extracted transcript portion\\n   460→\\tif len(data.Transcript) > 0 {\\n   461→\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n   462→\\t}\\n   463→\\n   464→\\treturn data, nil\\n   465→}\\n   466→\\n   467→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   468→// For Claude Code and JSONL-based agents, this counts lines.\\n   469→// For Gemini CLI and JSON-based agents, this counts messages.\\n   470→// Returns 0 if the content is empty or malformed.\\n   471→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   472→\\tif content == \\\"\\\" {\\n   473→\\t\\treturn 0\\n   474→\\t}\\n   475→\\n   476→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   477→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   478→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   479→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   480→\\t\\t\\treturn len(transcript.Messages)\\n   481→\\t\\t}\\n   482→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   483→\\t\\tif agentType == agent.AgentTypeGemini {\\n   484→\\t\\t\\treturn 0\\n   485→\\t\\t}\\n   486→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   487→\\t}\\n   488→\\n   489→\\t// Claude Code and other JSONL-based agents\\n   490→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   491→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   492→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   493→\\t\\tallLines = allLines[:len(allLines)-1]\\n   494→\\t}\\n   495→\\treturn len(allLines)\\n   496→}\\n   497→\\n   498→// extractUserPrompts extracts all user prompts from transcript content.\\n   499→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   500→func extractUserPrompts(agentType agent.AgentType, content string) []string {\\n   501→\\tif content == \\\"\\\" {\\n   502→\\t\\treturn nil\\n   503→\\t}\\n   504→\\n   505→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   506→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   507→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   508→\\t\\tif err == nil && len(prompts) > 0 {\\n   509→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   510→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   511→\\t\\t\\tfor _, prompt := range prompts {\\n   512→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   513→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   514→\\t\\t\\t\\t}\\n   515→\\t\\t\\t}\\n   516→\\t\\t\\treturn cleaned\\n   517→\\t\\t}\\n   518→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   519→\\t\\tif agentType == agent.AgentTypeGemini {\\n   520→\\t\\t\\treturn nil\\n   521→\\t\\t}\\n   522→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   523→\\t}\\n   524→\\n   525→\\t// Claude Code and other JSONL-based agents\\n   526→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   527→}\\n   528→\\n   529→// calculateTokenUsage calculates token usage from raw transcript data.\\n   530→// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n   531→// where the current checkpoint began, allowing calculation for only the portion\\n   532→// of the transcript since the last checkpoint.\\n   533→func calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n   534→\\tif len(data) == 0 {\\n   535→\\t\\treturn &agent.TokenUsage{}\\n   536→\\t}\\n   537→\\n   538→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   539→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   540→\\t\\t// Attempt to parse as Gemini JSON\\n   541→\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n   542→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   543→\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n   544→\\t\\t}\\n   545→\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n   546→\\t\\tif agentType == agent.AgentTypeGemini {\\n   547→\\t\\t\\treturn &agent.TokenUsage{}\\n   548→\\t\\t}\\n   549→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   550→\\t}\\n   551→\\n   552→\\t// Claude Code and other JSONL-based agents\\n   553→\\tlines, err := transcript.ParseFromBytes(data)\\n   554→\\tif err != nil || len(lines) == 0 {\\n   555→\\t\\treturn &agent.TokenUsage{}\\n   556→\\t}\\n   557→\\t// Slice transcript lines to only include checkpoint portion\\n   558→\\tif startOffset > 0 && startOffset < len(lines) {\\n   559→\\t\\tlines = lines[startOffset:]\\n   560→\\t}\\n   561→\\treturn claudecode.CalculateTokenUsage(lines)\\n   562→}\\n   563→\\n   564→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   565→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   566→func extractUserPromptsFromLines(lines []string) []string {\\n   567→\\tvar prompts []string\\n   568→\\tfor _, line := range lines {\\n   569→\\t\\tline = strings.TrimSpace(line)\\n   570→\\t\\tif line == \\\"\\\" {\\n   571→\\t\\t\\tcontinue\\n   572→\\t\\t}\\n   573→\\n   574→\\t\\tvar entry map[string]interface{}\\n   575→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   576→\\t\\t\\tcontinue\\n   577→\\t\\t}\\n   578→\\n   579→\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n   580→\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n   581→\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n   582→\\t\\t\\tcontinue\\n   583→\\t\\t}\\n   584→\\n   585→\\t\\t// Extract message content\\n   586→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   587→\\t\\tif !ok {\\n   588→\\t\\t\\tcontinue\\n   589→\\t\\t}\\n   590→\\n   591→\\t\\t// Handle string content\\n   592→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   593→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   594→\\t\\t\\tif cleaned != \\\"\\\" {\\n   595→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   596→\\t\\t\\t}\\n   597→\\t\\t\\tcontinue\\n   598→\\t\\t}\\n   599→\\n   600→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   601→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   602→\\t\\t\\tvar texts []string\\n   603→\\t\\t\\tfor _, item := range arr {\\n   604→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   605→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   606→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   607→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   608→\\t\\t\\t\\t\\t\\t}\\n   609→\\t\\t\\t\\t\\t}\\n   610→\\t\\t\\t\\t}\\n   611→\\t\\t\\t}\\n   612→\\t\\t\\tif len(texts) > 0 {\\n   613→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   614→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   615→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   616→\\t\\t\\t\\t}\\n   617→\\t\\t\\t}\\n   618→\\t\\t}\\n   619→\\t}\\n   620→\\treturn prompts\\n   621→}\\n   622→\\n   623→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   624→func generateContextFromPrompts(prompts []string) []byte {\\n   625→\\tif len(prompts) == 0 {\\n   626→\\t\\treturn nil\\n   627→\\t}\\n   628→\\n   629→\\tvar buf strings.Builder\\n   630→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   631→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   632→\\n   633→\\tfor i, prompt := range prompts {\\n   634→\\t\\t// Truncate very long prompts for readability\\n   635→\\t\\tdisplayPrompt := prompt\\n   636→\\t\\tif len(displayPrompt) > 500 {\\n   637→\\t\\t\\tdisplayPrompt = displayPrompt[:500] + \\\"...\\\"\\n   638→\\t\\t}\\n   639→\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n   640→\\t\\tbuf.WriteString(displayPrompt)\\n   641→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   642→\\t}\\n   643→\\n   644→\\treturn []byte(buf.String())\\n   645→}\\n   646→\\n   647→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   648→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   649→func (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n   650→\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n   651→\\n   652→\\t// Load session state\\n   653→\\tstate, err := s.loadSessionState(sessionID)\\n   654→\\tif err != nil {\\n   655→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   656→\\t}\\n   657→\\tif state == nil {\\n   658→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   659→\\t}\\n   660→\\n   661→\\t// Open repository\\n   662→\\trepo, err := OpenRepository()\\n   663→\\tif err != nil {\\n   664→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   665→\\t}\\n   666→\\n   667→\\t// Generate a checkpoint ID\\n   668→\\tcheckpointID, err := id.Generate()\\n   669→\\tif err != nil {\\n   670→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   671→\\t}\\n   672→\\n   673→\\t// Check if shadow branch exists (required for condensation)\\n   674→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   675→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   676→\\t_, refErr := repo.Reference(refName, true)\\n   677→\\thasShadowBranch := refErr == nil\\n   678→\\n   679→\\tif !hasShadowBranch {\\n   680→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   681→\\t\\t// Just clean up the state file.\\n   682→\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n   683→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   684→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   685→\\t\\t)\\n   686→\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n   687→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   688→\\t\\t}\\n   689→\\t\\treturn nil\\n   690→\\t}\\n   691→\\n   692→\\t// Condense the session\\n   693→\\tresult, err := s.CondenseSession(repo, checkpointID, state, nil)\\n   694→\\tif err != nil {\\n   695→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   696→\\t}\\n   697→\\n   698→\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n   699→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   700→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   701→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   702→\\t)\\n   703→\\n   704→\\t// Update session state: reset step count and transition to idle\\n   705→\\tstate.StepCount = 0\\n   706→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   707→\\tstate.Phase = session.PhaseIdle\\n   708→\\tstate.LastCheckpointID = checkpointID\\n   709→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   710→\\tstate.PromptAttributions = nil\\n   711→\\tstate.PendingPromptAttribution = nil\\n   712→\\n   713→\\tif err := s.saveSessionState(state); err != nil {\\n   714→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   715→\\t}\\n   716→\\n   717→\\t// Clean up shadow branch if no other sessions need it\\n   718→\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n   719→\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n   720→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   721→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   722→\\t\\t)\\n   723→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   724→\\t}\\n   725→\\n   726→\\treturn nil\\n   727→}\\n   728→\\n   729→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   730→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(_ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   731→\\t// List all session states to check if any other session uses this shadow branch\\n   732→\\tallStates, err := s.listAllSessionStates()\\n   733→\\tif err != nil {\\n   734→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   735→\\t}\\n   736→\\n   737→\\tfor _, state := range allStates {\\n   738→\\t\\tif state.SessionID == excludeSessionID {\\n   739→\\t\\t\\tcontinue\\n   740→\\t\\t}\\n   741→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   742→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   743→\\t\\t\\t// Another session still needs this shadow branch\\n   744→\\t\\t\\treturn nil\\n   745→\\t\\t}\\n   746→\\t}\\n   747→\\n   748→\\t// No other sessions need it, delete the shadow branch via CLI\\n   749→\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n   750→\\tif err := DeleteBranchCLI(shadowBranchName); err != nil {\\n   751→\\t\\t// Branch already gone is not an error\\n   752→\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n   753→\\t\\t\\treturn nil\\n   754→\\t\\t}\\n   755→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n   756→\\t}\\n   757→\\treturn nil\\n   758→}\\n   759→\"}]},\"uuid\":\"d5184ffd-aa83-4d9c-aeb1-36820e1729de\",\"timestamp\":\"2026-02-20T19:40:07.937Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alisha/Projects/wt/factoryai-agent/cmd/entire/cli/strategy/manual_commit_condensation.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// listCheckpoints returns all checkpoints from the metadata branch.\\n// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) listCheckpoints() ([]CheckpointInfo, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcommitted, err := store.ListCommitted(context.Background())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n\\t}\\n\\n\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n\\tresult := make([]CheckpointInfo, 0, len(committed))\\n\\tfor _, c := range committed {\\n\\t\\tresult = append(result, CheckpointInfo{\\n\\t\\t\\tCheckpointID:     c.CheckpointID,\\n\\t\\t\\tSessionID:        c.SessionID,\\n\\t\\t\\tCreatedAt:        c.CreatedAt,\\n\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n\\t\\t\\tFilesTouched:     c.FilesTouched,\\n\\t\\t\\tAgent:            c.Agent,\\n\\t\\t\\tIsTask:           c.IsTask,\\n\\t\\t\\tToolUseID:        c.ToolUseID,\\n\\t\\t\\tSessionCount:     c.SessionCount,\\n\\t\\t\\tSessionIDs:       c.SessionIDs,\\n\\t\\t})\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointsForSession returns all checkpoints for a session ID.\\nfunc (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n\\tall, err := s.listCheckpoints()\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tvar result []CheckpointInfo\\n\\tfor _, cp := range all {\\n\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n\\t\\t\\tresult = append(result, cp)\\n\\t\\t}\\n\\t}\\n\\n\\tif len(result) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// CondenseSession condenses a session's shadow branch to permanent storage.\\n// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n//\\n// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n// In this case, data is extracted from the live transcript instead.\\nfunc (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n\\t// Get shadow branch (may not exist for mid-session commits)\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\thasShadowBranch := err == nil\\n\\n\\tvar sessionData *ExtractedSessionData\\n\\tif hasShadowBranch {\\n\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n\\t\\t// last turn had no code changes).\\n\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n\\t\\t// Extract data directly from live transcript.\\n\\t\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n\\t\\t}\\n\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n\\t// committed in this specific commit. This ensures each checkpoint represents\\n\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n\\tif len(committedFiles) > 0 {\\n\\t\\tif len(sessionData.FilesTouched) > 0 {\\n\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tsessionData.FilesTouched = filtered\\n\\t\\t}\\n\\n\\t\\t// If extraction failed or returned empty, use committedFiles as fallback.\\n\\t\\t// This handles mid-session commits where transcript parsing may not find files\\n\\t\\t// but we know what was committed.\\n\\t\\tif len(sessionData.FilesTouched) == 0 {\\n\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n\\t\\t\\tfor f := range committedFiles {\\n\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Get checkpoint store\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get author info\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Generate summary if enabled\\n\\tvar summary *cpkg.Summary\\n\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n\\n\\t\\t// Scope transcript to this checkpoint's portion.\\n\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n\\t\\t// For Gemini (JSON), CheckpointTranscriptStart is a message index.\\n\\t\\tvar scopedTranscript []byte\\n\\t\\tif state.AgentType == agent.AgentTypeGemini {\\n\\t\\t\\tscopedTranscript = geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t} else {\\n\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t}\\n\\t\\tif len(scopedTranscript) > 0 {\\n\\t\\t\\tvar err error\\n\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t\\t// Continue without summary - non-blocking\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write checkpoint metadata using the checkpoint store\\n\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n\\t\\tCheckpointID:                checkpointID,\\n\\t\\tSessionID:                   state.SessionID,\\n\\t\\tStrategy:                    StrategyNameManualCommit,\\n\\t\\tBranch:                      branchName,\\n\\t\\tTranscript:                  sessionData.Transcript,\\n\\t\\tPrompts:                     sessionData.Prompts,\\n\\t\\tContext:                     sessionData.Context,\\n\\t\\tFilesTouched:                sessionData.FilesTouched,\\n\\t\\tCheckpointsCount:            state.StepCount,\\n\\t\\tEphemeralBranch:             shadowBranchName,\\n\\t\\tAuthorName:                  authorName,\\n\\t\\tAuthorEmail:                 authorEmail,\\n\\t\\tAgent:                       state.AgentType,\\n\\t\\tTurnID:                      state.TurnID,\\n\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n\\t\\tInitialAttribution:          attribution,\\n\\t\\tSummary:                     summary,\\n\\t}); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n\\t}\\n\\n\\treturn &CondenseResult{\\n\\t\\tCheckpointID:         checkpointID,\\n\\t\\tSessionID:            state.SessionID,\\n\\t\\tCheckpointsCount:     state.StepCount,\\n\\t\\tFilesTouched:         sessionData.FilesTouched,\\n\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n\\t}, nil\\n}\\n\\nfunc calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n\\t// Calculate initial attribution using accumulated prompt attribution data.\\n\\t// This uses user edits captured at each prompt start (before agent works),\\n\\t// plus any user edits after the final checkpoint (shadow → head).\\n\\t//\\n\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\n\\theadRef, headErr := repo.Head()\\n\\tif headErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n\\tif commitErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\theadTree, treeErr := headCommit.Tree()\\n\\tif treeErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n\\tvar shadowTree *object.Tree\\n\\tif shadowRef != nil {\\n\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n\\t\\tif shadowErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\tvar shadowTreeErr error\\n\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n\\t\\tif shadowTreeErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n\\t\\t// because the agent's work is the commit itself.\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n\\t\\tshadowTree = headTree\\n\\t}\\n\\n\\t// Get base tree (state before session started)\\n\\tvar baseTree *object.Tree\\n\\tattrBase := state.AttributionBaseCommit\\n\\tif attrBase == \\\"\\\" {\\n\\t\\tattrBase = state.BaseCommit // backward compat\\n\\t}\\n\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n\\t\\t\\tbaseTree = tree\\n\\t\\t} else {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n\\t\\t}\\n\\t} else {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n\\t}\\n\\n\\t// Log accumulated prompt attributions for debugging\\n\\tvar totalUserAdded, totalUserRemoved int\\n\\tfor i, pa := range state.PromptAttributions {\\n\\t\\ttotalUserAdded += pa.UserLinesAdded\\n\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"index\\\", i))\\n\\t}\\n\\n\\tattribution := CalculateAttributionWithAccumulated(\\n\\t\\tbaseTree,\\n\\t\\tshadowTree,\\n\\t\\theadTree,\\n\\t\\tsessionData.FilesTouched,\\n\\t\\tstate.PromptAttributions,\\n\\t)\\n\\n\\tif attribution != nil {\\n\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n\\t}\\n\\n\\treturn attribution\\n}\\n\\n// extractSessionData extracts session data from the shadow branch.\\n// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n// continued growing — the shadow branch copy would be stale.\\n// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\nfunc (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n\\tcommit, err := repo.CommitObject(shadowRef)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\tdata := &ExtractedSessionData{}\\n\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\n\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n\\t// (SaveStep is only called when there are file modifications).\\n\\tvar fullTranscript string\\n\\tif liveTranscriptPath != \\\"\\\" {\\n\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n\\t\\t\\tfullTranscript = string(liveData)\\n\\t\\t}\\n\\t}\\n\\tif fullTranscript == \\\"\\\" {\\n\\t\\t// Fall back to shadow branch copy\\n\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Process transcript based on agent type\\n\\tif fullTranscript != \\\"\\\" {\\n\\t\\tdata.Transcript = []byte(fullTranscript)\\n\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\t}\\n\\n\\t// Use tracked files from session state (not all files in tree)\\n\\tdata.FilesTouched = filesTouched\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n// This is used for mid-session commits where no shadow branch exists yet.\\nfunc (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n\\tdata := &ExtractedSessionData{}\\n\\n\\t// Read the live transcript\\n\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n\\t}\\n\\n\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n\\t}\\n\\n\\tif len(liveData) == 0 {\\n\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n\\t}\\n\\n\\tfullTranscript := string(liveData)\\n\\tdata.Transcript = liveData\\n\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\n\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n\\t// (no SaveStep/Stop has been called yet to populate it)\\n\\tif len(state.FilesTouched) > 0 {\\n\\t\\tdata.FilesTouched = state.FilesTouched\\n\\t} else {\\n\\t\\t// Use the shared helper which includes subagent transcripts\\n\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n\\t}\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n// For Claude Code and JSONL-based agents, this counts lines.\\n// For Gemini CLI and JSON-based agents, this counts messages.\\n// Returns 0 if the content is empty or malformed.\\nfunc countTranscriptItems(agentType agent.AgentType, content string) int {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn 0\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n\\t\\t\\treturn len(transcript.Messages)\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn 0\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n\\t\\tallLines = allLines[:len(allLines)-1]\\n\\t}\\n\\treturn len(allLines)\\n}\\n\\n// extractUserPrompts extracts all user prompts from transcript content.\\n// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\nfunc extractUserPrompts(agentType agent.AgentType, content string) []string {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n\\t\\tif err == nil && len(prompts) > 0 {\\n\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n\\t\\t\\tfor _, prompt := range prompts {\\n\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\treturn cleaned\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n}\\n\\n// calculateTokenUsage calculates token usage from raw transcript data.\\n// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n// where the current checkpoint began, allowing calculation for only the portion\\n// of the transcript since the last checkpoint.\\nfunc calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n\\tif len(data) == 0 {\\n\\t\\treturn &agent.TokenUsage{}\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\t// Attempt to parse as Gemini JSON\\n\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn &agent.TokenUsage{}\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\tlines, err := transcript.ParseFromBytes(data)\\n\\tif err != nil || len(lines) == 0 {\\n\\t\\treturn &agent.TokenUsage{}\\n\\t}\\n\\t// Slice transcript lines to only include checkpoint portion\\n\\tif startOffset > 0 && startOffset < len(lines) {\\n\\t\\tlines = lines[startOffset:]\\n\\t}\\n\\treturn claudecode.CalculateTokenUsage(lines)\\n}\\n\\n// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\nfunc extractUserPromptsFromLines(lines []string) []string {\\n\\tvar prompts []string\\n\\tfor _, line := range lines {\\n\\t\\tline = strings.TrimSpace(line)\\n\\t\\tif line == \\\"\\\" {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tvar entry map[string]interface{}\\n\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Extract message content\\n\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n\\t\\tif !ok {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Handle string content\\n\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n\\t\\t\\tif cleaned != \\\"\\\" {\\n\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n\\t\\t\\t}\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n\\t\\t\\tvar texts []string\\n\\t\\t\\tfor _, item := range arr {\\n\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tif len(texts) > 0 {\\n\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\treturn prompts\\n}\\n\\n// generateContextFromPrompts generates context.md content from a list of prompts.\\nfunc generateContextFromPrompts(prompts []string) []byte {\\n\\tif len(prompts) == 0 {\\n\\t\\treturn nil\\n\\t}\\n\\n\\tvar buf strings.Builder\\n\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n\\n\\tfor i, prompt := range prompts {\\n\\t\\t// Truncate very long prompts for readability\\n\\t\\tdisplayPrompt := prompt\\n\\t\\tif len(displayPrompt) > 500 {\\n\\t\\t\\tdisplayPrompt = displayPrompt[:500] + \\\"...\\\"\\n\\t\\t}\\n\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n\\t\\tbuf.WriteString(displayPrompt)\\n\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n\\t}\\n\\n\\treturn []byte(buf.String())\\n}\\n\\n// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\nfunc (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n\\n\\t// Load session state\\n\\tstate, err := s.loadSessionState(sessionID)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n\\t}\\n\\tif state == nil {\\n\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n\\t}\\n\\n\\t// Open repository\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\t// Generate a checkpoint ID\\n\\tcheckpointID, err := id.Generate()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n\\t}\\n\\n\\t// Check if shadow branch exists (required for condensation)\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\t_, refErr := repo.Reference(refName, true)\\n\\thasShadowBranch := refErr == nil\\n\\n\\tif !hasShadowBranch {\\n\\t\\t// No shadow branch means no checkpoint data to condense.\\n\\t\\t// Just clean up the state file.\\n\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n\\t\\t)\\n\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Condense the session\\n\\tresult, err := s.CondenseSession(repo, checkpointID, state, nil)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n\\t}\\n\\n\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n\\t)\\n\\n\\t// Update session state: reset step count and transition to idle\\n\\tstate.StepCount = 0\\n\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n\\tstate.Phase = session.PhaseIdle\\n\\tstate.LastCheckpointID = checkpointID\\n\\tstate.AttributionBaseCommit = state.BaseCommit\\n\\tstate.PromptAttributions = nil\\n\\tstate.PendingPromptAttribution = nil\\n\\n\\tif err := s.saveSessionState(state); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n\\t}\\n\\n\\t// Clean up shadow branch if no other sessions need it\\n\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n\\t\\t)\\n\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\nfunc (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(_ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n\\t// List all session states to check if any other session uses this shadow branch\\n\\tallStates, err := s.listAllSessionStates()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n\\t}\\n\\n\\tfor _, state := range allStates {\\n\\t\\tif state.SessionID == excludeSessionID {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n\\t\\t\\t// Another session still needs this shadow branch\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t}\\n\\n\\t// No other sessions need it, delete the shadow branch via CLI\\n\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n\\tif err := DeleteBranchCLI(shadowBranchName); err != nil {\\n\\t\\t// Branch already gone is not an error\\n\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n\\t}\\n\\treturn nil\\n}\\n\",\"numLines\":759,\"startLine\":1,\"totalLines\":759}},\"sourceToolAssistantUUID\":\"236b9788-c188-4055-9d9d-10810ffa01fd\"}\n{\"parentUuid\":\"d5184ffd-aa83-4d9c-aeb1-36820e1729de\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/factoryai-agent\",\"sessionId\":\"22266b86-af98-4794-a6a8-7c7287c079a1\",\"version\":\"2.1.49\",\"gitBranch\":\"alisha/factoryai-agent\",\"slug\":\"structured-brewing-shore\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_011CQsDXgydXUrAi4EsLfasN\",\"type\":\"message\",\"role\":