\n     4→import (\\n     5→\\t\\\"context\\\"\\n     6→\\t\\\"encoding/json\\\"\\n     7→\\t\\\"errors\\\"\\n     8→\\t\\\"fmt\\\"\\n     9→\\t\\\"strings\\\"\\n    10→\\n    11→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    15→)\\n    16→\\n    17→// GenerateFromTranscript generates a summary from raw transcript bytes.\\n    18→// This is the shared implementation used by both explain --generate and auto-summarize.\\n    19→//\\n    20→// Parameters:\\n    21→//   - ctx: context for cancellation\\n    22→//   - transcriptBytes: raw transcript bytes (JSONL or JSON format depending on agent)\\n    23→//   - filesTouched: list of files modified during the session\\n    24→//   - agentType: the agent type to determine transcript format\\n    25→//   - generator: summary generator to use (if nil, uses default ClaudeGenerator)\\n    26→//\\n    27→// Returns nil, error if transcript is empty or cannot be parsed.\\n    28→func GenerateFromTranscript(ctx context.Context, transcriptBytes []byte, filesTouched []string, agentType agent.AgentType, generator Generator) (*checkpoint.Summary, error) {\\n    29→\\tif len(transcriptBytes) == 0 {\\n    30→\\t\\treturn nil, errors.New(\\\"empty transcript\\\")\\n    31→\\t}\\n    32→\\n    33→\\t// Build condensed transcript for summarization\\n    34→\\tcondensed, err := BuildCondensedTranscriptFromBytes(transcriptBytes, agentType)\\n    35→\\tif err != nil {\\n    36→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    37→\\t}\\n    38→\\tif len(condensed) == 0 {\\n    39→\\t\\treturn nil, errors.New(\\\"transcript has no content to summarize\\\")\\n    40→\\t}\\n    41→\\n    42→\\tinput := Input{\\n    43→\\t\\tTranscript:   condensed,\\n    44→\\t\\tFilesTouched: filesTouched,\\n    45→\\t}\\n    46→\\n    47→\\t// Use default generator if none provided\\n    48→\\tif generator == nil {\\n    49→\\t\\tgenerator = &ClaudeGenerator{}\\n    50→\\t}\\n    51→\\n    52→\\tsummary, err := generator.Generate(ctx, input)\\n    53→\\tif err != nil {\\n    54→\\t\\treturn nil, fmt.Errorf(\\\"failed to generate summary: %w\\\", err)\\n    55→\\t}\\n    56→\\n    57→\\treturn summary, nil\\n    58→}\\n    59→\\n    60→// Generator generates checkpoint summaries using an LLM.\\n    61→type Generator interface {\\n    62→\\t// Generate creates a summary from checkpoint data.\\n    63→\\t// Returns the generated summary or an error if generation fails.\\n    64→\\tGenerate(ctx context.Context, input Input) (*checkpoint.Summary, error)\\n    65→}\\n    66→\\n    67→// Input contains condensed checkpoint data for summarization.\\n    68→type Input struct {\\n    69→\\t// Transcript is the condensed transcript entries\\n    70→\\tTranscript []Entry\\n    71→\\n    72→\\t// FilesTouched are the files modified during the session\\n    73→\\tFilesTouched []string\\n    74→}\\n    75→\\n    76→// EntryType represents the type of a transcript entry.\\n    77→type EntryType string\\n    78→\\n    79→const (\\n    80→\\t// EntryTypeUser indicates a user prompt entry.\\n    81→\\tEntryTypeUser EntryType = \\\"user\\\"\\n    82→\\t// EntryTypeAssistant indicates an assistant response entry.\\n    83→\\tEntryTypeAssistant EntryType = \\\"assistant\\\"\\n    84→\\t// EntryTypeTool indicates a tool call entry.\\n    85→\\tEntryTypeTool EntryType = \\\"tool\\\"\\n    86→)\\n    87→\\n    88→// Entry represents one item in the condensed transcript.\\n    89→type Entry struct {\\n    90→\\t// Type is the entry type (user, assistant, tool)\\n    91→\\tType EntryType\\n    92→\\n    93→\\t// Content is the text content for user/assistant entries\\n    94→\\tContent string\\n    95→\\n    96→\\t// ToolName is the name of the tool (for tool entries)\\n    97→\\tToolName string\\n    98→\\n    99→\\t// ToolDetail is a description or file path (for tool entries)\\n   100→\\tToolDetail string\\n   101→}\\n   102→\\n   103→// minimalDetailTools lists tools that should show only essential details in summaries.\\n   104→// These tools often have verbose outputs that don't add value to summarization.\\n   105→// The detail shown is typically just a path, URL, or identifier rather than full content.\\n   106→var minimalDetailTools = map[string]bool{\\n   107→\\t\\\"Skill\\\":    true, // Show skill name only, not loaded content\\n   108→\\t\\\"Read\\\":     true, // Show file path only, not file contents\\n   109→\\t\\\"WebFetch\\\": true, // Show URL only, not fetched content\\n   110→}\\n   111→\\n   112→// BuildCondensedTranscriptFromBytes parses transcript bytes and extracts a condensed view.\\n   113→// This is a convenience function that combines parsing and condensing.\\n   114→// The agentType parameter determines which parser to use (Claude JSONL vs Gemini JSON).\\n   115→func BuildCondensedTranscriptFromBytes(content []byte, agentType agent.AgentType) ([]Entry, error) {\\n   116→\\tswitch agentType {\\n   117→\\tcase agent.AgentTypeGemini:\\n   118→\\t\\treturn buildCondensedTranscriptFromGemini(content)\\n   119→\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeFactoryAIDroid, agent.AgentTypeUnknown:\\n   120→\\t\\t// Claude format - fall through to shared logic below\\n   121→\\t}\\n   122→\\t// Claude format (JSONL) - handles Claude Code, Unknown, and any future agent types\\n   123→\\tlines, err := transcript.ParseFromBytes(content)\\n   124→\\tif err != nil {\\n   125→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   126→\\t}\\n   127→\\treturn BuildCondensedTranscript(lines), nil\\n   128→}\\n   129→\\n   130→// buildCondensedTranscriptFromGemini parses Gemini JSON transcript and extracts a condensed view.\\n   131→func buildCondensedTranscriptFromGemini(content []byte) ([]Entry, error) {\\n   132→\\tgeminiTranscript, err := geminicli.ParseTranscript(content)\\n   133→\\tif err != nil {\\n   134→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse Gemini transcript: %w\\\", err)\\n   135→\\t}\\n   136→\\n   137→\\tvar entries []Entry\\n   138→\\tfor _, msg := range geminiTranscript.Messages {\\n   139→\\t\\tswitch msg.Type {\\n   140→\\t\\tcase geminicli.MessageTypeUser:\\n   141→\\t\\t\\tif msg.Content != \\\"\\\" {\\n   142→\\t\\t\\t\\tentries = append(entries, Entry{\\n   143→\\t\\t\\t\\t\\tType:    EntryTypeUser,\\n   144→\\t\\t\\t\\t\\tContent: msg.Content,\\n   145→\\t\\t\\t\\t})\\n   146→\\t\\t\\t}\\n   147→\\t\\tcase geminicli.MessageTypeGemini:\\n   148→\\t\\t\\t// Add assistant content\\n   149→\\t\\t\\tif msg.Content != \\\"\\\" {\\n   150→\\t\\t\\t\\tentries = append(entries, Entry{\\n   151→\\t\\t\\t\\t\\tType:    EntryTypeAssistant,\\n   152→\\t\\t\\t\\t\\tContent: msg.Content,\\n   153→\\t\\t\\t\\t})\\n   154→\\t\\t\\t}\\n   155→\\t\\t\\t// Add tool calls\\n   156→\\t\\t\\tfor _, tc := range msg.ToolCalls {\\n   157→\\t\\t\\t\\tentries = append(entries, Entry{\\n   158→\\t\\t\\t\\t\\tType:       EntryTypeTool,\\n   159→\\t\\t\\t\\t\\tToolName:   tc.Name,\\n   160→\\t\\t\\t\\t\\tToolDetail: extractGeminiToolDetail(tc.Args),\\n   161→\\t\\t\\t\\t})\\n   162→\\t\\t\\t}\\n   163→\\t\\t}\\n   164→\\t}\\n   165→\\n   166→\\treturn entries, nil\\n   167→}\\n   168→\\n   169→// extractGeminiToolDetail extracts an appropriate detail string from Gemini tool args.\\n   170→func extractGeminiToolDetail(args map[string]interface{}) string {\\n   171→\\t// Check common fields in order of preference\\n   172→\\tfor _, key := range []string{\\\"description\\\", \\\"command\\\", \\\"file_path\\\", \\\"path\\\", \\\"pattern\\\"} {\\n   173→\\t\\tif v, ok := args[key].(string); ok && v != \\\"\\\" {\\n   174→\\t\\t\\treturn v\\n   175→\\t\\t}\\n   176→\\t}\\n   177→\\treturn \\\"\\\"\\n   178→}\\n   179→\\n   180→// BuildCondensedTranscript extracts a condensed view 