ate human (this tests the editor flow where\\n  1079→\\t// the user removes the trailer before committing).\\n  1080→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile)\\n  1081→\\tprepCmd.Dir = env.RepoDir\\n  1082→\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n  1083→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n  1084→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n  1085→\\t}\\n  1086→\\n  1087→\\t// Read the modified message (with trailer added by hook)\\n  1088→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n  1089→\\tif err != nil {\\n  1090→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n  1091→\\t}\\n  1092→\\n  1093→\\t// REMOVE the Entire-Checkpoint trailer (simulating user editing the message)\\n  1094→\\tlines := strings.Split(string(modifiedMsg), \\\"\\\\n\\\")\\n  1095→\\tvar cleanedLines []string\\n  1096→\\tfor _, line := range lines {\\n  1097→\\t\\t// Skip the trailer and the comments about it\\n  1098→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n  1099→\\t\\t\\tcontinue\\n  1100→\\t\\t}\\n  1101→\\t\\tif strings.Contains(line, \\\"Remove the Entire-Checkpoint trailer\\\") {\\n  1102→\\t\\t\\tcontinue\\n  1103→\\t\\t}\\n  1104→\\t\\tif strings.Contains(line, \\\"trailer will be added to your next commit\\\") {\\n  1105→\\t\\t\\tcontinue\\n  1106→\\t\\t}\\n  1107→\\t\\tcleanedLines = append(cleanedLines, line)\\n  1108→\\t}\\n  1109→\\tcleanedMsg := strings.TrimRight(strings.Join(cleanedLines, \\\"\\\\n\\\"), \\\"\\\\n\\\") + \\\"\\\\n\\\"\\n  1110→\\n  1111→\\t// Create the commit using go-git with the cleaned message (no trailer)\\n  1112→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1113→\\tif err != nil {\\n  1114→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1115→\\t}\\n  1116→\\n  1117→\\tworktree, err := repo.Worktree()\\n  1118→\\tif err != nil {\\n  1119→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n  1120→\\t}\\n  1121→\\n  1122→\\t_, err = worktree.Commit(cleanedMsg, &git.CommitOptions{\\n  1123→\\t\\tAuthor: &object.Signature{\\n  1124→\\t\\t\\tName:  \\\"Test User\\\",\\n  1125→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n  1126→\\t\\t\\tWhen:  time.Now(),\\n  1127→\\t\\t},\\n  1128→\\t})\\n  1129→\\tif err != nil {\\n  1130→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n  1131→\\t}\\n  1132→\\n  1133→\\t// Run post-commit hook - since trailer was removed, no condensation should happen\\n  1134→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n  1135→\\tpostCmd.Dir = env.RepoDir\\n  1136→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n  1137→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n  1138→\\t}\\n  1139→}\\n  1140→\\n  1141→// GitRm stages file deletions using git rm.\\n  1142→func (env *TestEnv) GitRm(paths ...string) {\\n  1143→\\tenv.T.Helper()\\n  1144→\\n  1145→\\targs := append([]string{\\\"rm\\\", \\\"--\\\"}, paths...)\\n  1146→\\tcmd := exec.Command(\\\"git\\\", args...)\\n  1147→\\tcmd.Dir = env.RepoDir\\n  1148→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1149→\\t\\tenv.T.Fatalf(\\\"git rm failed: %v\\\\nOutput: %s\\\", err, output)\\n  1150→\\t}\\n  1151→}\\n  1152→\\n  1153→// GitCommitStagedWithShadowHooks commits whatever is already staged (without adding files first),\\n  1154→// running the prepare-commit-msg and post-commit hooks like a real workflow.\\n  1155→// Use this after GitRm or when files are already staged.\\n  1156→func (env *TestEnv) GitCommitStagedWithShadowHooks(message string) {\\n  1157→\\tenv.T.Helper()\\n  1158→\\tenv.gitCommitStagedWithShadowHooks(message, true)\\n  1159→}\\n  1160→\\n  1161→// gitCommitStagedWithShadowHooks is the shared implementation for committing staged changes with hooks.\\n  1162→func (env *TestEnv) gitCommitStagedWithShadowHooks(message string, si