98→\\t}\\n   499→}\\n   500→\\n   501→// GitCommitWithMultipleSessions creates a commit with multiple Entire-Session trailers.\\n   502→// This simulates merge commits that combine work from multiple sessions.\\n   503→func (env *TestEnv) GitCommitWithMultipleSessions(message string, sessionIDs []string) {\\n   504→\\tenv.T.Helper()\\n   505→\\n   506→\\t// Format message with multiple session trailers\\n   507→\\tfullMessage := message + \\\"\\\\n\\\\n\\\"\\n   508→\\tvar fullMessageSb404 strings.Builder\\n   509→\\tfor _, sessionID := range sessionIDs {\\n   510→\\t\\tfullMessageSb404.WriteString(\\\"Entire-Session: \\\" + sessionID + \\\"\\\\n\\\")\\n   511→\\t}\\n   512→\\tfullMessage += fullMessageSb404.String()\\n   513→\\n   514→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   515→\\tif err != nil {\\n   516→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   517→\\t}\\n   518→\\n   519→\\tworktree, err := repo.Worktree()\\n   520→\\tif err != nil {\\n   521→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   522→\\t}\\n   523→\\n   524→\\t_, err = worktree.Commit(fullMessage, &git.CommitOptions{\\n   525→\\t\\tAuthor: &object.Signature{\\n   526→\\t\\t\\tName:  \\\"Test User\\\",\\n   527→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   528→\\t\\t\\tWhen:  time.Now(),\\n   529→\\t\\t},\\n   530→\\t})\\n   531→\\tif err != nil {\\n   532→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   533→\\t}\\n   534→}\\n   535→\\n   536→// GetHeadHash returns the current HEAD commit hash.\\n   537→func (env *TestEnv) GetHeadHash() string {\\n   538→\\tenv.T.Helper()\\n   539→\\n   540→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   541→\\tif err != nil {\\n   542→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   543→\\t}\\n   544→\\n   545→\\thead, err := repo.Head()\\n   546→\\tif err != nil {\\n   547→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   548→\\t}\\n   549→\\n   550→\\treturn head.Hash().String()\\n   551→}\\n   552→\\n   553→// GetShadowBranchName returns the worktree-specific shadow branch name for the current HEAD.\\n   554→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   555→func (env *TestEnv) GetShadowBranchName() string {\\n   556→\\tenv.T.Helper()\\n   557→\\n   558→\\theadHash := env.GetHeadHash()\\n   559→\\tworktreeID, err := paths.GetWorktreeID(env.RepoDir)\\n   560→\\tif err != nil {\\n   561→\\t\\tenv.T.Fatalf(\\\"failed to get worktree ID: %v\\\", err)\\n   562→\\t}\\n   563→\\treturn checkpoint.ShadowBranchNameForCommit(headHash, worktreeID)\\n   564→}\\n   565→\\n   566→// GetShadowBranchNameForCommit returns the worktree-specific shadow branch name for a given commit.\\n   567→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   568→func (env *TestEnv) GetShadowBranchNameForCommit(commitHash string) string {\\n   569→\\tenv.T.Helper()\\n   570→\\n   571→\\tworktreeID, err := paths.GetWorktreeID(env.RepoDir)\\n   572→\\tif err != nil {\\n   573→\\t\\tenv.T.Fatalf(\\\"failed to get worktree ID: %v\\\", err)\\n   574→\\t}\\n   575→\\treturn checkpoint.ShadowBranchNameForCommit(commitHash, worktreeID)\\n   576→}\\n   577→\\n   578→// GetGitLog returns a list of commit hashes from HEAD.\\n   579→func (env *TestEnv) GetGitLog() []string {\\n   580→\\tenv.T.Helper()\\n   581→\\n   582→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   583→\\tif err != nil {\\n   584→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   585→\\t}\\n   586→\\n   587→\\thead, err := repo.Head()\\n   588→\\tif err != nil {\\n   589→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   590→\\t}\\n   591→\\n   592→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   593→\\tif err != nil {\\n   594→\\t\\tenv.T.Fatalf(\\\"failed to get log: %v\\\", err)\\n   595→\\t}\\n   596→\\n   597→\\tvar commits []string\\n   598→\\terr = commitIter.ForEach(func(c *object.Commit) error {\\n   599→\\t\\tcommits = append(commits, c.Hash.