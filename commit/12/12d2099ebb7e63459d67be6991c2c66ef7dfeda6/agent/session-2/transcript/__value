 *FactoryAIDroidAgent) InstallHooks(localDev bool, force bool) (int, error) {\\n    68→\\t// Use repo root instead of CWD to find .factory directory\\n    69→\\t// This ensures hooks are installed correctly when run from a subdirectory\\n    70→\\trepoRoot, err := paths.RepoRoot()\\n    71→\\tif err != nil {\\n    72→\\t\\t// Fallback to CWD if not in a git repo (e.g., during tests)\\n    73→\\t\\trepoRoot, err = os.Getwd() //nolint:forbidigo // Intentional fallback when RepoRoot() fails (tests run outside git repos)\\n    74→\\t\\tif err != nil {\\n    75→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to get current directory: %w\\\", err)\\n    76→\\t\\t}\\n    77→\\t}\\n    78→\\n    79→\\tsettingsPath := filepath.Join(repoRoot, \\\".factory\\\", FactorySettingsFileName)\\n    80→\\n    81→\\t// Read existing settings if they exist\\n    82→\\tvar rawSettings map[string]json.RawMessage\\n    83→\\n    84→\\t// rawHooks preserves unknown hook types\\n    85→\\tvar rawHooks map[string]json.RawMessage\\n    86→\\n    87→\\t// rawPermissions preserves unknown permission fields (e.g., \\\"ask\\\")\\n    88→\\tvar rawPermissions map[string]json.RawMessage\\n    89→\\n    90→\\texistingData, readErr := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from cwd + fixed path\\n    91→\\tif readErr == nil {\\n    92→\\t\\tif err := json.Unmarshal(existingData, &rawSettings); err != nil {\\n    93→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse existing settings.json: %w\\\", err)\\n    94→\\t\\t}\\n    95→\\t\\tif hooksRaw, ok := rawSettings[\\\"hooks\\\"]; ok {\\n    96→\\t\\t\\tif err := json.Unmarshal(hooksRaw, &rawHooks); err != nil {\\n    97→\\t\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse hooks in settings.json: %w\\\", err)\\n    98→\\t\\t\\t}\\n    99→\\t\\t}\\n   100→\\t\\tif permRaw, ok := rawSettings[\\\"permissions\\\"]; ok {\\n   101→\\t\\t\\tif err := json.Unmarshal(permRaw, &rawPermissions); err != nil {\\n   102→\\t\\t\\t\\treturn 0, fmt.Erro