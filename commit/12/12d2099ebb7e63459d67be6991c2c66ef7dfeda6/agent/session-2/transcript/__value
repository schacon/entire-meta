00→\\tfor _, u := range usageByMessageID {\\n   201→\\t\\tusage.InputTokens += u.InputTokens\\n   202→\\t\\tusage.CacheCreationTokens += u.CacheCreationInputTokens\\n   203→\\t\\tusage.CacheReadTokens += u.CacheReadInputTokens\\n   204→\\t\\tusage.OutputTokens += u.OutputTokens\\n   205→\\t}\\n   206→\\n   207→\\treturn usage\\n   208→}\\n   209→\\n   210→// CalculateTokenUsageFromFile calculates token usage from a transcript file.\\n   211→// If startLine > 0, only considers lines from startLine onwards.\\n   212→func CalculateTokenUsageFromFile(path string, startLine int) (*agent.TokenUsage, error) {\\n   213→\\tif path == \\\"\\\" {\\n   214→\\t\\treturn &agent.TokenUsage{}, nil\\n   215→\\t}\\n   216→\\n   217→\\tlines, _, err := ParseDroidTranscript(path, startLine)\\n   218→\\tif err != nil {\\n   219→\\t\\treturn nil, err\\n   220→\\t}\\n   221→\\n   222→\\treturn CalculateTokenUsage(lines), nil\\n   223→}\\n   224→\\n   225→// ExtractSpawnedAgentIDs extracts agent IDs from Task tool results in a transcript.\\n   226→// When a Task tool completes, the tool_result contains \\\"agentId: <id>\\\" in its content.\\n   227→// Returns a map of agentID -> toolUseID for all spawned agents.\\n   228→func ExtractSpawnedAgentIDs(transcriptLines []TranscriptLine) map[string]string {\\n   229→\\tagentIDs := make(map[string]string)\\n   230→\\n   231→\\tfor _, line := range transcriptLines {\\n   232→\\t\\tif line.Type != \\\"user\\\" {\\n   233→\\t\\t\\tcontinue\\n   234→\\t\\t}\\n   235→\\n   236→\\t\\t// Parse as array of content blocks (tool results)\\n   237→\\t\\tvar contentBlocks []struct {\\n   238→\\t\\t\\tType      string          `json:\\\"type\\\"`\\n   239→\\t\\t\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   240→\\t\\t\\tContent   json.RawMessage `json:\\\"content\\\"`\\n   241→\\t\\t}\\n   242→\\n   243→\\t\\tvar msg struct {\\n   244→\\t\\t\\tContent json.RawMessage `json:\\\"content\\\"`\\n   245→\\t\\t}\\n   246→\\t\\tif err := json.Unmarshal