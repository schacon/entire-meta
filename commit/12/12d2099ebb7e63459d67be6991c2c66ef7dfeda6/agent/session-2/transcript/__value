ry to PATH so hooks can find it.\\n    55→\\t// This is safe because:\\n    56→\\t// 1. TestMain runs once before any tests (no parallel conflict with os.Setenv)\\n    57→\\t// 2. Each test package gets its own TestMain execution\\n    58→\\t// 3. PATH is restored in the same TestMain after m.Run() completes\\n    59→\\t// 4. The binary path is unique per test run (temp dir)\\n    60→\\torigPath := os.Getenv(\\\"PATH\\\")\\n    61→\\tos.Setenv(\\\"PATH\\\", tmpDir+string(os.PathListSeparator)+origPath)\\n    62→\\n    63→\\t// Run tests\\n    64→\\tcode := m.Run()\\n    65→\\n    66→\\t// Cleanup\\n    67→\\tos.Setenv(\\\"PATH\\\", origPath)\\n    68→\\tos.RemoveAll(tmpDir)\\n    69→\\tos.Exit(code)\\n    70→}\\n    71→\\n    72→// findModuleRoot finds the Go module root by walking up from the current file.\\n    73→func findModuleRoot() string {\\n    74→\\t_, thisFile, _, ok := runtime.Caller(0)\\n    75→\\tif !ok {\\n    76→\\t\\tpanic(\\\"failed to get current file path via runtime.Caller\\\")\\n    77→\\t}\\n    78→\\tdir := filepath.Dir(thisFile)\\n    79→\\n    80→\\tfor {\\n    81→\\t\\tif _, err := os.Stat(filepath.Join(dir, \\\"go.mod\\\")); err == nil {\\n    82→\\t\\t\\treturn dir\\n    83→\\t\\t}\\n    84→\\t\\tparent := filepath.Dir(dir)\\n    85→\\t\\tif parent == dir {\\n    86→\\t\\t\\tpanic(\\\"could not find go.mod starting from \\\" + thisFile)\\n    87→\\t\\t}\\n    88→\\t\\tdir = parent\\n    89→\\t}\\n    90→}\\n    91→\"}]},\"uuid\":\"f74352fa-d6d6-4534-bb58-e99a5399fdd7\",\"timestamp\":\"2026-02-20T19:44:14.867Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Explore the E2E test suite in `cmd/entire/cli/e2e_test/` to understand:\\n\\n1. How `agent_runner.go` defines the `AgentRunner` interface and how `ClaudeCodeRunner` and `GeminiCLIRunner` implement it\\n2. How `setup_test.go` checks agent availability and skips tests\\n3. How the actual E2E test scenarios work - read `scenario_basic_workflow_test.go` and `scenario_c