!= nil {\\n  1208→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n  1209→\\t}\\n  1210→\\n  1211→\\t// Run post-commit hook\\n  1212→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n  1213→\\tpostCmd.Dir = env.RepoDir\\n  1214→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n  1215→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n  1216→\\t}\\n  1217→}\\n  1218→\\n  1219→// ListBranchesWithPrefix returns all branches that start with the given prefix.\\n  1220→func (env *TestEnv) ListBranchesWithPrefix(prefix string) []string {\\n  1221→\\tenv.T.Helper()\\n  1222→\\n  1223→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1224→\\tif err != nil {\\n  1225→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1226→\\t}\\n  1227→\\n  1228→\\trefs, err := repo.References()\\n  1229→\\tif err != nil {\\n  1230→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n  1231→\\t}\\n  1232→\\n  1233→\\tvar branches []string\\n  1234→\\t_ = refs.ForEach(func(ref *plumbing.Reference) error {\\n  1235→\\t\\tname := ref.Name().Short()\\n  1236→\\t\\tif len(name) >= len(prefix) && name[:len(prefix)] == prefix {\\n  1237→\\t\\t\\tbranches = append(branches, name)\\n  1238→\\t\\t}\\n  1239→\\t\\treturn nil\\n  1240→\\t})\\n  1241→\\n  1242→\\treturn branches\\n  1243→}\\n  1244→\\n  1245→// GetLatestCheckpointID returns the most recent checkpoint ID from the entire/checkpoints/v1 branch.\\n  1246→// This is used by tests that previously extracted the checkpoint ID from commit message trailers.\\n  1247→// Now that active branch commits are clean (no trailers), we get the ID from the sessions branch.\\n  1248→// Fatals if the checkpoint ID cannot be found, with detailed context about what was found.\\n  1249→func (env *TestEnv) GetLatestCheckpointID() string {\\n  1250→\\tenv.T.Helper()\\n  1251→\\n  1252→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1253→\\tif err != nil {\\n  1254→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1255→\\t}\\n  1256→\\n  1257→\\t// Get the entire/checkpoints/v1 branch\\n  1258→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1259→\\tref, err := repo.Reference(refName, true)\\n  1260→\\tif err != nil {\\n  1261→\\t\\tenv.T.Fatalf(\\\"failed to get %s branch: %v\\\", paths.MetadataBranchName, err)\\n  1262→\\t}\\n  1263→\\n  1264→\\tcommit, err := repo.CommitObject(ref.Hash())\\n  1265→\\tif err != nil {\\n  1266→\\t\\tenv.T.Fatalf(\\\"failed to get commit: %v\\\", err)\\n  1267→\\t}\\n  1268→\\n  1269→\\t// Extract checkpoint ID from commit message\\n  1270→\\t// Format: \\\"Checkpoint: <12-hex-char-id>\\\\n\\\\nSession: ...\\\\nStrategy: ...\\\"\\n  1271→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n  1272→\\t\\tline = strings.TrimSpace(line)\\n  1273→\\t\\tif strings.HasPrefix(line, \\\"Checkpoint: \\\") {\\n  1274→\\t\\t\\treturn strings.TrimPrefix(line, \\\"Checkpoint: \\\")\\n  1275→\\t\\t}\\n  1276→\\t}\\n  1277→\\n  1278→\\tenv.T.Fatalf(\\\"could not find checkpoint ID in %s branch commit message:\\\\n%s\\\",\\n  1279→\\t\\tpaths.MetadataBranchName, commit.Message)\\n  1280→\\treturn \\\"\\\"\\n  1281→}\\n  1282→\\n  1283→// TryGetLatestCheckpointID returns the most recent checkpoint ID from the entire/checkpoints/v1 branch.\\n  1284→// Returns empty string if the branch doesn't exist or has no checkpoint commits yet.\\n  1285→// Use this when you need to check if a checkpoint exists without failing the test.\\n  1286→func (env *TestEnv) TryGetLatestCheckpointID() string {\\n  1287→\\tenv.T.Helper()\\n  1288→\\n  1289→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1290→\\tif err != nil {\\n  1291→\\t\\treturn \\\"\\\"\\n  1292→\\t}\\n  1293→\\n  1294→\\t// Get the entire/checkpoints/v1 branch\\n  1295→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1296→\\tref, err := repo.Reference(refName, true)\\n  1297→\\tif err != nil {\\n  1298→\\t\\treturn \\\"\\\"\\n  1299→\\t}\\n  1300→\\n  1301→\\tcommit, err := repo.CommitObject(ref.Hash())\\n  1302→\\tif err != nil {\\n  1303→\\t\\treturn \\\"\\\"\\n  1304→\\t}\\n  1305→\\n  1306→\\t// Extract checkpoint ID from commit message\\n  1307→\\t// Format: \\\"Checkpoint: <12-hex-char-id>\\\\n\\\\nSession: ...\\\\nStrategy: ...\\\"\\n  1308→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n  1309→\\t\\tline = strings.TrimSpace(line)\\n  1310→\\t\\tif strings.HasPrefix(line, \\\"Checkpoint: \\\") {\\n  1311→\\t\\t\\treturn strings.TrimPrefix(line, \\\"Checkpoint: \\\")\\n  1312→\\t\\t}\\n  1313→\\t}\\n  1314→\\n  1315→\\treturn \\\"\\\"\\n  1316→}\\n  1317→\\n  1318→// GetLatestCondensationID is an alias for GetLatestCheckpointID for backwards compatibility.\\n  1319→func (env *TestEnv) GetLatestCondensationID() string {\\n  1320→\\treturn env.GetLatestCheckpointID()\\n  1321→}\\n  1322→\\n  1323→// GetCheckpointIDFromCommitMessage extracts the Entire-Checkpoint trailer from a commit message.\\n  1324→// Returns empty string if no trailer found.\\n  1325→func (env *TestEnv) GetCheckpointIDFromCommitMessage(commitSHA string) string {\\n  1326→\\tenv.T.Helper()\\n  1327→\\n  1328→\\tmsg := env.GetCommitMessage(commitSHA)\\n  1329→\\tcpID, found := trailers.ParseCheckpoint(msg)\\n  1330→\\tif !found {\\n  1331→\\t\\treturn \\\"\\\"\\n  1332→\\t}\\n  1333→\\treturn cpID.String()\\n  1334→}\\n  1335→\\n  1336→// GetLatestCheckpointIDFromHistory walks backwards from HEAD on the active branch\\n  1337→// and returns the checkpoint ID from the first commit that has an Entire-Checkpoint trailer.\\n  1338→// This verifies that condensation actually happened (commit has trailer) without relying\\n  1339→// on timestamp-based matching.\\n  1340→func (env *TestEnv) GetLatestCheckpointIDFromHistory() string {\\n  1341→\\tenv.T.Helper()\\n  1342→\\n  1343→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1344→\\tif err != nil {\\n  1345→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1346→\\t}\\n  1347→\\n  1348→\\thead, err := repo.Head()\\n  1349→\\tif err != nil {\\n  1350→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n  1351→\\t}\\n  1352→\\n  1353→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n  1354→\\tif err != nil {\\n  1355→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n  1356→\\t}\\n  1357→\\n  1358→\\tvar checkpointID string\\n  1359→\\t//nolint:errcheck // ForEach callback handles errors\\n  1360→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n  1361→\\t\\tif cpID, found := trailers.ParseCheckpoint(c.Message); found {\\n  1362→\\t\\t\\tcheckpointID = cpID.String()\\n  1363→\\t\\t\\treturn errors.New(\\\"stop iteration\\\") // Found it, stop\\n  1364→\\t\\t}\\n  1365→\\t\\treturn nil\\n  1366→\\t})\\n  1367→\\n  1368→\\tif checkpointID == \\\"\\\" {\\n  1369→\\t\\tenv.T.Fatalf(\\\"no commit with Entire-Checkpoint trailer found in history\\\")\\n  1370→\\t}\\n  1371→\\n  1372→\\treturn checkpointID\\n  1373→}\\n  1374→\\n  1375→// ShardedCheckpointPath returns the sharded path for a checkpoint ID.\\n  1376→// Format: <id[:2]>/<id[2:]>\\n  1377→// Delegates to id.CheckpointID.Path() for consistency.\\n  1378→func ShardedCheckpointPath(checkpointID string) string {\\n  1379→\\treturn id.CheckpointID(checkpointID).Path()\\n  1380→}\\n  1381→\\n  1382→// SessionFilePath returns the path to a session file within a checkpoint.\\n  1383→// Session files are stored in numbered subdirectories using 0-based indexing (e.g., 0/full.jsonl).\\n  1384→// This function constructs the path for the first (default) session.\\n  1385→func SessionFilePath(checkpointID string, fileName string) string {\\n  1386→\\treturn id.CheckpointID(checkpointID).Path() + \\\"/0/\\\" + fileName\\n  1387→}\\n  1388→\\n  1389→// CheckpointSummaryPath returns the path to the root metadata.json (CheckpointSummary) for a checkpoint.\\n  1390→func CheckpointSummaryPath(checkpointID string) string {\\n  1391→\\treturn id.CheckpointID(checkpointID).Path() + \\\"/\\\" + paths.MetadataFileName\\n  1392→}\\n  1393→\\n  1394→// SessionMetadataPath returns the path to the session-level metadata.json for a checkpoint.\\n  1395→func SessionMetadataPath(checkpointID string) string {\\n  1396→\\treturn SessionFilePath(checkpointID, paths.MetadataFileName)\\n  1397→}\\n  1398→\\n  1399→// CheckpointValidation contains expected values for checkpoint validation.\\n  1400→type CheckpointValidation struct {\\n  1401→\\t// CheckpointID is the expected checkpoint ID\\n  1402→\\tCheckpointID string\\n  1403→\\n  1404→\\t// SessionID is the expected session ID\\n  1405→\\tSessionID string\\n  1406→\\n  1407→\\t// Strategy is the expected strategy name\\n  1408→\\tStrategy string\\n  1409→\\n  1410→\\t// FilesTouched are the expected files in files_touched\\n  1411→\\tFilesTouched []string\\n  1412→\\n  1413→\\t// ExpectedPrompts are strings that should appear in prompt.txt\\n  1414→\\tExpectedPrompts []string\\n  1415→\\n  1416→\\t// ExpectedTranscriptContent are strings that should appear in full.jsonl\\n  1417→\\tExpectedTranscriptContent []string\\n  1418→\\n  1419→\\t// CheckpointsCount is the expected checkpoint count (0 means don't validate)\\n  1420→\\tCheckpointsCount int\\n  1421→}\\n  1422→\\n  1423→// ValidateCheckpoint performs comprehensive validation of a checkpoint on the metadata branch.\\n  1424→// It validates:\\n  1425→// - Root metadata.json (CheckpointSummary) structure and expected fields\\n  1426→// - Session metadata.json (CommittedMetadata) structure and expected fields\\n  1427→// - Transcript file (full.jsonl) is valid JSONL and contains expected content\\n  1428→// - Content hash file (content_hash.txt) matches SHA256 of transcript\\n  1429→// - Prompt file (prompt.txt) contains expected prompts\\n  1430→func (env *TestEnv) ValidateCheckpoint(v CheckpointValidation) {\\n  1431→\\tenv.T.Helper()\\n  1432→\\n  1433→\\t// Validate root metadata.json (CheckpointSummary)\\n  1434→\\tenv.validateCheckpointSummary(v)\\n  1435→\\n  1436→\\t// Validate session metadata.json (CommittedMetadata)\\n  1437→\\tenv.validateSessionMetadata(v)\\n  1438→\\n  1439→\\t// Validate transcript is valid JSONL\\n  1440→\\tenv.validateTranscriptJSONL(v.CheckpointID, v.ExpectedTranscriptContent)\\n  1441→\\n  1442→\\t// Validate content hash matches transcript\\n  1443→\\tenv.validateContentHash(v.CheckpointID)\\n  1444→\\n  1445→\\t// Validate prompt.txt contains expected prompts\\n  1446→\\tif len(v.ExpectedPrompts) > 0 {\\n  1447→\\t\\tenv.validatePromptContent(v.CheckpointID, v.ExpectedPrompts)\\n  1448→\\t}\\n  1449→}\\n  1450→\\n  1451→// validateCheckpointSummary validates the root metadata.json (CheckpointSummary).\\n  1452→func (env *TestEnv) validateCheckpointSummary(v CheckpointValidation) {\\n  1453→\\tenv.T.Helper()\\n  1454→\\n  1455→\\tsummaryPath := CheckpointSummaryPath(v.CheckpointID)\\n  1456→\\tcontent, found := env.ReadFileFromBranch(paths.MetadataBranchName, summaryPath)\\n  1457→\\tif !found {\\n  1458→\\t\\tenv.T.Fatalf(\\\"CheckpointSummary not found at %s\\\", summaryPath)\\n  1459→\\t}\\n  1460→\\n  1461→\\tvar summary checkpoint.CheckpointSummary\\n  1462→\\tif err := json.Unmarshal([]byte(content), &summary); err != nil {\\n  1463→\\t\\tenv.T.Fatalf(\\\"Failed to parse CheckpointSummary: %v\\\\nContent: %s\\\", err, content)\\n  1464→\\t}\\n  1465→\\n  1466→\\t// Validate checkpoint_id\\n  1467→\\tif summary.CheckpointID.String() != v.CheckpointID {\\n  1468→\\t\\tenv.T.Errorf(\\\"CheckpointSummary.CheckpointID = %q, want %q\\\", summary.CheckpointID, v.CheckpointID)\\n  1469→\\t}\\n  1470→\\n  1471→\\t// Validate strategy\\n  1472→\\tif v.Strategy != \\\"\\\" && summary.Strategy != v.Strategy {\\n  1473→\\t\\tenv.T.Errorf(\\\"CheckpointSummary.Strategy = %q, want %q\\\", summary.Strategy, v.Strategy)\\n  1474→\\t}\\n  1475→\\n  1476→\\t// Validate sessions array is populated\\n  1477→\\tif len(summary.Sessions) == 0 {\\n  1478→\\t\\tenv.T.Error(\\\"CheckpointSummary.Sessions should have at least one entry\\\")\\n  1479→\\t}\\n  1480→\\n  1481→\\t// Validate files_touched\\n  1482→\\tif len(v.FilesTouched) > 0 {\\n  1483→\\t\\ttouchedSet := make(map[string]bool)\\n  1484→\\t\\tfor _, f := range summary.FilesTouched {\\n  1485→\\t\\t\\ttouchedSet[f] = true\\n  1486→\\t\\t}\\n  1487→\\t\\tfor _, expected := range v.FilesTouched {\\n  1488→\\t\\t\\tif !touchedSet[expected] {\\n  1489→\\t\\t\\t\\tenv.T.Errorf(\\\"CheckpointSummary.FilesTouched missing %q, got %v\\\", expected, summary.FilesTouched)\\n  1490→\\t\\t\\t}\\n  1491→\\t\\t}\\n  1492→\\t}\\n  1493→\\n  1494→\\t// Validate checkpoints_count\\n  1495→\\tif v.CheckpointsCount > 0 && summary.CheckpointsCount != v.CheckpointsCount {\\n  1496→\\t\\tenv.T.Errorf(\\\"CheckpointSummary.CheckpointsCount = %d, want %d\\\", summary.CheckpointsCount, v.CheckpointsCount)\\n  1497→\\t}\\n  1498→}\\n  1499→\\n  1500→// validateSessionMetadata validates the session-level metadata.json (CommittedMetadata).\\n  1501→func (env *TestEnv) validateSessionMetadata(v CheckpointValidation) {\\n  1502→\\tenv.T.Helper()\\n  1503→\\n  1504→\\tmetadataPath := SessionMetadataPath(v.CheckpointID)\\n  1505→\\tcontent, found := env.ReadFileFromBranch(paths.MetadataBranchName, metadataPath)\\n  1506→\\tif !found {\\n  1507→\\t\\tenv.T.Fatalf(\\\"Session metadata not found at %s\\\", metadataPath)\\n  1508→\\t}\\n  1509→\\n  1510→\\tvar metadata checkpoint.CommittedMetadata\\n  1511→\\tif err := json.Unmarshal([]byte(content), &metadata); err != nil {\\n  1512→\\t\\tenv.T.Fatalf(\\\"Failed to parse CommittedMetadata: %v\\\\nContent: %s\\\", err, content)\\n  1513→\\t}\\n  1514→\\n  1515→\\t// Validate checkpoint_id\\n  1516→\\tif metadata.CheckpointID.String() != v.CheckpointID {\\n  1517→\\t\\tenv.T.Errorf(\\\"CommittedMetadata.CheckpointID = %q, want %q\\\", metadata.CheckpointID, v.CheckpointID)\\n  15