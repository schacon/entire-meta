Name string, inputJSON []byte) HookOutput {\\n   559→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n   560→\\tcmd.Dir = r.RepoDir\\n   561→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   562→\\tcmd.Env = append(os.Environ(),\\n   563→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n   564→\\t)\\n   565→\\n   566→\\tvar stdout, stderr bytes.Buffer\\n   567→\\tcmd.Stdout = &stdout\\n   568→\\tcmd.Stderr = &stderr\\n   569→\\n   570→\\terr := cmd.Run()\\n   571→\\treturn HookOutput{\\n   572→\\t\\tStdout: stdout.Bytes(),\\n   573→\\t\\tStderr: stderr.Bytes(),\\n   574→\\t\\tErr:    err,\\n   575→\\t}\\n   576→}\\n   577→\\n   578→// SimulateGeminiBeforeAgent simulates the BeforeAgent hook for Gemini CLI.\\n   579→// This is equivalent to Claude Code's UserPromptSubmit.\\n   580→func (r *GeminiHookRunner) SimulateGeminiBeforeAgent(sessionID string) error {\\n   581→\\tr.T.Helper()\\n   582→\\n   583→\\tinput := map[string]string{\\n   584→\\t\\t\\\"session_id\\\":      sessionID,\\n   585→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   586→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   587→\\t\\t\\\"hook_event_name\\\": \\\"BeforeAgent\\\",\\n   588→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   589→\\t\\t\\\"prompt\\\":          \\\"test prompt\\\",\\n   590→\\t}\\n   591→\\n   592→\\treturn r.runGeminiHookWithInput(\\\"before-agent\\\", input)\\n   593→}\\n   594→\\n   595→// SimulateGeminiBeforeAgentWithOutput simulates the BeforeAgent hook and returns the output.\\n   596→func (r *GeminiHookRunner) SimulateGeminiBeforeAgentWithOutput(sessionID string) HookOutput {\\n   597→\\tr.T.Helper()\\n   598→\\n   599→\\tinput := map[string]string{\\n   600→\\t\\t\\\"session_id\\\":      sessionID,\\n   601→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   602→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   603→\\t\\t\\\"hook_event_name\\\": \\\"BeforeAgent\\\",\\n   604→\\t\\t\\\"timestamp\\\":       \\\"2025-0