\t// Create a temp file for the commit message\\n   424→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n   425→\\t//nolint:gosec // test code, permissions are intentionally standard\\n   426→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n   427→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n   428→\\t}\\n   429→\\n   430→\\t// Run prepare-commit-msg hook\\n   431→\\t//nolint:gosec,noctx // test code, args are from trusted test setup, no context needed\\n   432→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile)\\n   433→\\tprepCmd.Dir = env.RepoDir\\n   434→\\tprepCmd.Env = append(os.Environ(),\\n   435→\\t\\t\\\"ENTIRE_TEST_TTY=1\\\",\\n   436→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".claude\\\"),\\n   437→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".gemini\\\"),\\n   438→\\t)\\n   439→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n   440→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n   441→\\t}\\n   442→\\n   443→\\t// Read the modified message (with trailer added by hook)\\n   444→\\t//nolint:gosec // test code, path is from test setup\\n   445→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n   446→\\tif err != nil {\\n   447→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n   448→\\t}\\n   449→\\n   450→\\t// REMOVE the Entire-Checkpoint trailer (simulating user editing the message)\\n   451→\\tlines := strings.Split(string(modifiedMsg), \\\"\\\\n\\\")\\n   452→\\tvar cleanedLines []string\\n   453→\\tfor _, line := range lines {\\n   454→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   455→\\t\\t\\tcontinue\\n   456→\\t\\t}\\n   457→\\t\\tif strings.Contains(line, \\\"Remove the Entire-Checkpoint trailer\\\") {\\n   458→\\t\\t\\tcontinue\\n   459→\\t\\t}\\n   460→\\t\\ti