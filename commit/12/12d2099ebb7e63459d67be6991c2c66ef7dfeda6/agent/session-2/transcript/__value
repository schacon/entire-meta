ewindPoints returns available rewind points using the CLI.\\n   656→func (env *TestEnv) GetRewindPoints() []RewindPoint {\\n   657→\\tenv.T.Helper()\\n   658→\\n   659→\\t// Run rewind --list using the shared binary\\n   660→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--list\\\")\\n   661→\\tcmd.Dir = env.RepoDir\\n   662→\\tcmd.Env = env.cliEnv()\\n   663→\\n   664→\\toutput, err := cmd.CombinedOutput()\\n   665→\\tif err != nil {\\n   666→\\t\\tenv.T.Fatalf(\\\"rewind --list failed: %v\\\\nOutput: %s\\\", err, output)\\n   667→\\t}\\n   668→\\n   669→\\t// Parse JSON output\\n   670→\\tvar jsonPoints []struct {\\n   671→\\t\\tID               string `json:\\\"id\\\"`\\n   672→\\t\\tMessage          string `json:\\\"message\\\"`\\n   673→\\t\\tMetadataDir      string `json:\\\"metadata_dir\\\"`\\n   674→\\t\\tDate             string `json:\\\"date\\\"`\\n   675→\\t\\tIsTaskCheckpoint bool   `json:\\\"is_task_checkpoint\\\"`\\n   676→\\t\\tToolUseID        string `json:\\\"tool_use_id\\\"`\\n   677→\\t\\tIsLogsOnly       bool   `json:\\\"is_logs_only\\\"`\\n   678→\\t\\tCondensationID   string `json:\\\"condensation_id\\\"`\\n   679→\\t}\\n   680→\\n   681→\\tif err := json.Unmarshal(output, &jsonPoints); err != nil {\\n   682→\\t\\tenv.T.Fatalf(\\\"failed to parse rewind points: %v\\\\nOutput: %s\\\", err, output)\\n   683→\\t}\\n   684→\\n   685→\\tpoints := make([]RewindPoint, len(jsonPoints))\\n   686→\\tfor i, jp := range jsonPoints {\\n   687→\\t\\tdate, _ := time.Parse(time.RFC3339, jp.Date)\\n   688→\\t\\tpoints[i] = RewindPoint{\\n   689→\\t\\t\\tID:               jp.ID,\\n   690→\\t\\t\\tMessage:          jp.Message,\\n   691→\\t\\t\\tMetadataDir:      jp.MetadataDir,\\n   692→\\t\\t\\tDate:             date,\\n   693→\\t\\t\\tIsTaskCheckpoint: jp.IsTaskCheckpoint,\\n   694→\\t\\t\\tToolUseID:        jp.ToolUseID,\\n   695→\\t\\t\\tIsLogsOnly:       jp.IsLogsOnly,\\n   696→\\t\\t\\tCondensationID:   jp.CondensationID,\\n   697→\\t\\t}\\n   698→\\t}\\n   699→\\n   700→\\treturn points\\n   701→}\\n   702→\\n   703→// Rewind performs a rewind to the specified commit ID using the CLI.\\n   704→func (env *TestEnv) Rewind(commitID string) error {\\n   705→\\tenv.T.Helper()\\n   706→\\n   707→\\t// Run rewind --to <commitID> using the shared binary\\n   708→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID)\\n   709→\\tcmd.Dir = env.RepoDir\\n   710→\\tcmd.Env = env.cliEnv()\\n   711→\\n   712→\\toutput, err := cmd.CombinedOutput()\\n   713→\\tif err != nil {\\n   714→\\t\\treturn errors.New(\\\"rewind failed: \\\" + string(output))\\n   715→\\t}\\n   716→\\n   717→\\tenv.T.Logf(\\\"Rewind output: %s\\\", output)\\n   718→\\treturn nil\\n   719→}\\n   720→\\n   721→// RewindLogsOnly performs a logs-only rewind using the CLI.\\n   722→// This restores session logs without modifying the working directory.\\n   723→func (env *TestEnv) RewindLogsOnly(commitID string) error {\\n   724→\\tenv.T.Helper()\\n   725→\\n   726→\\t// Run rewind --to <commitID> --logs-only using the shared binary\\n   727→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID, \\\"--logs-only\\\")\\n   728→\\tcmd.Dir = env.RepoDir\\n   729→\\tcmd.Env = env.cliEnv()\\n   730→\\n   731→\\toutput, err := cmd.CombinedOutput()\\n   732→\\tif err != nil {\\n   733→\\t\\treturn errors.New(\\\"rewind logs-only failed: \\\" + string(output))\\n   734→\\t}\\n   735→\\n   736→\\tenv.T.Logf(\\\"Rewind logs-only output: %s\\\", output)\\n   737→\\treturn nil\\n   738→}\\n   739→\\n   740→// RewindReset performs a reset rewind using the CLI.\\n   741→// This resets the branch to the specified commit (destructive).\\n   742→func (env *TestEnv) RewindReset(commitID string) error {\\n   743→\\tenv.T.Helper()\\n   744→\\n   745→\\t// Run rewind --to <commitID> --reset using the shared binary\\n   746→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID, \\\"--reset\\\")\\n   7