→\\t\\tsessionEndCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid session-end\\\"\\n   142→\\t\\tstopCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid stop\\\"\\n   143→\\t\\tuserPromptSubmitCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid user-prompt-submit\\\"\\n   144→\\t\\tpreTaskCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid pre-tool-use\\\"\\n   145→\\t\\tpostTaskCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid post-tool-use\\\"\\n   146→\\t\\tpreCompactCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid pre-compact\\\"\\n   147→\\t} else {\\n   148→\\t\\tsessionStartCmd = \\\"entire hooks factoryai-droid session-start\\\"\\n   149→\\t\\tsessionEndCmd = \\\"entire hooks factoryai-droid session-end\\\"\\n   150→\\t\\tstopCmd = \\\"entire hooks factoryai-droid stop\\\"\\n   151→\\t\\tuserPromptSubmitCmd = \\\"entire hooks factoryai-droid user-prompt-submit\\\"\\n   152→\\t\\tpreTaskCmd = \\\"entire hooks factoryai-droid pre-tool-use\\\"\\n   153→\\t\\tpostTaskCmd = \\\"entire hooks factoryai-droid post-tool-use\\\"\\n   154→\\t\\tpreCompactCmd = \\\"entire hooks factoryai-droid pre-compact\\\"\\n   155→\\t}\\n   156→\\n   157→\\tcount := 0\\n   158→\\n   159→\\t// Add hooks if they don't exist\\n   160→\\tif !hookCommandExists(sessionStart, sessionStartCmd) {\\n   161→\\t\\tsessionStart = addHookToMatcher(sessionStart, \\\"\\\", sessionStartCmd)\\n   162→\\t\\tcount++\\n   163→\\t}\\n   164→\\tif !hookCommandExists(sessionEnd, sessionEndCmd) {\\n   165→\\t\\tsessionEnd = addHookToMatcher(sessionEnd, \\\"\\\", sessionEndCmd)\\n   166→\\t\\tcount++\\n   167→\\t}\\n   168→\\tif !hookCommandExists(stop, stopCmd) {\\n   169→\\t\\tstop = addHookToMatcher(stop, \\\"\\\", stopCmd)\\n   170→\\t\\tcount++\\n   171→\\t}\\n   172→\\tif !hookCommandExists(userPromptSubmit, userPromptSubmi