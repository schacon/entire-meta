kage factoryaidroid\\n     2→\\n     3→import (\\n     4→\\t\\\"bufio\\\"\\n     5→\\t\\\"bytes\\\"\\n     6→\\t\\\"encoding/json\\\"\\n     7→\\t\\\"fmt\\\"\\n     8→\\t\\\"io\\\"\\n     9→\\t\\\"os\\\"\\n    10→\\t\\\"path/filepath\\\"\\n    11→\\t\\\"slices\\\"\\n    12→\\t\\\"strings\\\"\\n    13→\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    16→)\\n    17→\\n    18→// TranscriptLine is an alias to the shared transcript.Line type.\\n    19→type TranscriptLine = transcript.Line\\n    20→\\n    21→// droidEnvelope is the top-level structure of a Factory AI Droid JSONL line.\\n    22→// Droid wraps messages as {\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"...\\\",\\\"message\\\":{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":[...]}},\\n    23→// unlike Claude Code which uses {\\\"type\\\":\\\"assistant\\\",\\\"uuid\\\":\\\"...\\\",\\\"message\\\":{\\\"content\\\":[...]}}.\\n    24→type droidEnvelope struct {\\n    25→\\tType    string          `json:\\\"type\\\"`\\n    26→\\tID      string          `json:\\\"id\\\"`\\n    27→\\tMessage json.RawMessage `json:\\\"message\\\"`\\n    28→}\\n    29→\\n    30→// droidMessageRole extracts just the role from the inner message.\\n    31→type droidMessageRole struct {\\n    32→\\tRole string `json:\\\"role\\\"`\\n    33→}\\n    34→\\n    35→// ParseDroidTranscript parses a Droid JSONL file into normalized transcript.Line entries.\\n    36→// It transforms the Droid envelope format (type=\\\"message\\\", role inside message) into the\\n    37→// shared transcript.Line format (type=\\\"assistant\\\"/\\\"user\\\", message=inner content).\\n    38→// Non-message entries (session_start, etc.) are skipped.\\n    39→func ParseDroidTranscript(path string, startLine int) ([]transcript.Line, int, error) {\\n    40→\\tfile, err := os.Open(path) //nolint:gosec // path is a controlled transcript file path\\n    41→\\tif err != nil {\\n    42→\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to open transcript: %w\\\", err)\\n    43→\\t}\\n    44→\\tdefer func() { _ = file.Close() }()\\n    45→\\n    46→\\treturn parseDroidTranscriptFromReader(file, startLine)\\n    47→}\\n    48→\\n    49→// ParseDroidTranscriptFromBytes parses Droid JSONL content from a byte slice.\\n    50→func ParseDroidTranscriptFromBytes(content []byte) ([]transcript.Line, error) {\\n    51→\\tlines, _, err := parseDroidTranscriptFromReader(bytes.NewReader(content), 0)\\n    52→\\treturn lines, err\\n    53→}\\n    54→\\n    55→func parseDroidTranscriptFromReader(r io.Reader, startLine int) ([]transcript.Line, int, error) {\\n    56→\\treader := bufio.NewReader(r)\\n    57→\\tvar lines []transcript.Line\\n    58→\\ttotalLines := 0\\n    59→\\n    60→\\tfor {\\n    61→\\t\\tlineBytes, err := reader.ReadBytes('\\\\n')\\n    62→\\t\\tif err != nil && err != io.EOF {\\n    63→\\t\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    64→\\t\\t}\\n    65→\\n    66→\\t\\tif len(lineBytes) == 0 {\\n    67→\\t\\t\\tif err == io.EOF {\\n    68→\\t\\t\\t\\tbreak\\n    69→\\t\\t\\t}\\n    70→\\t\\t\\tcontinue\\n    71→\\t\\t}\\n    72→\\n    73→\\t\\tif totalLines >= startLine {\\n    74→\\t\\t\\tif line, ok := parseDroidLine(lineBytes); ok {\\n    75→\\t\\t\\t\\tlines = append(lines, line)\\n    76→\\t\\t\\t}\\n    77→\\t\\t}\\n    78→\\t\\ttotalLines++\\n    79→\\n    80→\\t\\tif err == io.EOF {\\n    81→\\t\\t\\tbreak\\n    82→\\t\\t}\\n    83→\\t}\\n    84→\\n    85→\\treturn lines, totalLines, nil\\n    86→}\\n    87→\\n    88→// parseDroidLine converts a single Droid JSONL line into a normalized transcript.Line.\\n    89→// Returns false if the line is not a message entry (e.g., session_start).\\n    90→func parseDroidLine(lineBytes []byte) (transcript.Line, bool) {\\n    91→\\tvar env droidEnvelope\\n    92→\\tif err := json.Unmarshal(lineBytes, &env); err != nil {\\n    93→\\t\\treturn transcript.Line{}, false\\n    94→\\t}\\n    95→\\n    96→\\t// Only process \\\"message\\\" type entries — skip session_start, etc.\\n    97→\\tif env.Type != \\\"message\\\" {\\n    98→\\t\\treturn transcript.Line{}, false\\n    99→\\t}\\n   100→\\n   101→\\t// Extract role from the inner message\\n   102→\\tvar role droidMessageRole\\n   103→\\tif err := json.Unmarshal(env.Message, &role); err != nil {\\n   104→\\t\\treturn transcript.Line{}, false\\n   105→\\t}\\n   106→\\n   107→\\treturn transcript.Line{\\n   108→\\t\\tType:    role.Role, // \\\"assistant\\\" or \\\"user\\\"\\n   109→\\t\\tUUID:    env.ID,\\n   110→\\t\\tMessage: env.Message,\\n   111→\\t}, true\\n   112→}\\n   113→\\n   114→// SerializeTranscript converts transcript lines back to JSONL bytes.\\n   115→func SerializeTranscript(lines []TranscriptLine) ([]byte, error) {\\n   116→\\tvar buf bytes.Buffer\\n   117→\\tfor _, line := range lines {\\n   118→\\t\\tdata, err := json.Marshal(line)\\n   119→\\t\\tif err != nil {\\n   120→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal line: %w\\\", err)\\n   121→\\t\\t}\\n   122→\\t\\tbuf.Write(data)\\n   123→\\t\\tbuf.WriteByte('\\\\n')\\n   124→\\t}\\n   125→\\treturn buf.Bytes(), nil\\n   126→}\\n   127→\\n   128→// ExtractModifiedFiles extracts files modified by tool calls from transcript.\\n   129→func ExtractModifiedFiles(lines []TranscriptLine) []string {\\n   130→\\tfileSet := make(map[string]bool)\\n   131→\\tvar files []string\\n   132→\\n   133→\\tfor _, line := range lines {\\n   134→\\t\\tif line.Type != \\\"assistant\\\" {\\n   135→\\t\\t\\tcontinue\\n   136→\\t\\t}\\n   137→\\n   138→\\t\\tvar msg transcript.AssistantMessage\\n   139→\\t\\tif err := json.Unmarshal(line.Message, &msg); err != nil {\\n   140→\\t\\t\\tcontinue\\n   141→\\t\\t}\\n   142→\\n   143→\\t\\tfor _, block := range msg.Content {\\n   144→\\t\\t\\tif block.Type != \\\"tool_use\\\" || !slices.Contains(FileModificationTools, block.Name) {\\n   145→\\t\\t\\t\\tcontinue\\n   146→\\t\\t\\t}\\n   147→