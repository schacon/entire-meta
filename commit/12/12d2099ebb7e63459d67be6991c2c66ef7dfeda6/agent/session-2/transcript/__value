args, output)\\n   121→\\t}\\n   122→\\treturn output\\n   123→}\\n   124→\\n   125→// RunCLIWithError runs the entire CLI and returns output and error.\\n   126→func (env *TestEnv) RunCLIWithError(args ...string) (string, error) {\\n   127→\\tenv.T.Helper()\\n   128→\\n   129→\\t// Run CLI using the shared binary\\n   130→\\tcmd := exec.Command(getTestBinary(), args...)\\n   131→\\tcmd.Dir = env.RepoDir\\n   132→\\tcmd.Env = env.cliEnv()\\n   133→\\n   134→\\toutput, err := cmd.CombinedOutput()\\n   135→\\treturn string(output), err\\n   136→}\\n   137→\\n   138→// RunCLIWithStdin runs the CLI with stdin input.\\n   139→func (env *TestEnv) RunCLIWithStdin(stdin string, args ...string) string {\\n   140→\\tenv.T.Helper()\\n   141→\\n   142→\\t// Run CLI with stdin using the shared binary\\n   143→\\tcmd := exec.Command(getTestBinary(), args...)\\n   144→\\tcmd.Dir = env.RepoDir\\n   145→\\tcmd.Env = env.cliEnv()\\n   146→\\tcmd.Stdin = strings.NewReader(stdin)\\n   147→\\n   148→\\toutput, err := cmd.CombinedOutput()\\n   149→\\tif err != nil {\\n   150→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   151→\\t}\\n   152→\\treturn string(output)\\n   153→}\\n   154→\\n   155→// NewRepoEnv creates a TestEnv with an initialized git repo and Entire.\\n   156→// This is a convenience factory for tests that need a basic repo setup.\\n   157→func NewRepoEnv(t *testing.T, strategy string) *TestEnv {\\n   158→\\tt.Helper()\\n   159→\\tenv := NewTestEnv(t)\\n   160→\\tenv.InitRepo()\\n   161→\\tenv.InitEntire(strategy)\\n   162→\\treturn env\\n   163→}\\n   164→\\n   165→// NewRepoWithCommit creates a TestEnv with a git repo, Entire, and an initial commit.\\n   166→// The initial commit contains a README.md and .gitignore (excluding .entire/).\\n   167→func NewRepoWithCommit(t *testing.T, strategy string) *TestEnv {\\n   168→\\tt.Helper()\\n   169→\\tenv := NewRepoEnv(t, strategy)\\n   170→\\tenv.WriteFile(\\\".gitignore\\\", \\\".entire/\\\\n\\\")\\n   171→\\tenv.WriteFile(\\\"README.md\\\", \\\"# Test Repository\\\")\\n   172→\\tenv.GitAdd(\\\".gitignore\\\")\\n   173→\\tenv.GitAdd(\\\"README.md\\\")\\n   174→\\tenv.GitCommit(\\\"Initial commit\\\")\\n   175→\\treturn env\\n   176→}\\n   177→\\n   178→// NewFeatureBranchEnv creates a TestEnv ready for session testing.\\n   179→// It initializes the repo, creates an initial commit on main,\\n   180→// and checks out a feature branch. This is the most common setup\\n   181→// for session and rewind tests since Entire tracking skips main/master.\\n   182→func NewFeatureBranchEnv(t *testing.T, strategyName string) *TestEnv {\\n   183→\\tt.Helper()\\n   184→\\tenv := NewRepoWithCommit(t, strategyName)\\n   185→\\tenv.GitCheckoutNewBranch(\\\"feature/test-branch\\\")\\n   186→\\treturn env\\n   187→}\\n   188→\\n   189→// AllStrategies returns all strategy names for parameterized tests.\\n   190→func AllStrategies() []string {\\n   191→\\treturn []string{\\n   192→\\t\\tstrategy.StrategyNameAutoCommit,\\n   193→\\t\\tstrategy.StrategyNameManualCommit,\\n   194→\\t}\\n   195→}\\n   196→\\n   197→// RunForAllStrategies runs a test function for each strategy in parallel.\\n   198→// This reduces boilerplate for tests that need to verify behavior across all strategies.\\n   199→// Each subtest gets its own TestEnv with a feature branch ready for testing.\\n   200→func RunForAllStrategies(t *testing.T, testFn func(t *testing.T, env *TestEnv, strategyName string)) {\\n   201→\\tt.Helper()\\n   202→\\tfor _, strat := range AllStrategies() {\\n   203→\\t\\tstrat := strat // capture for parallel\\n   204→\\t\\tt.Run(strat, func(t *testing.T) {\\n   205→\\t\\t\\tt.Parallel()\\n   206→\\t\\t\\tenv := NewFeatureBranchEnv(t, strat)\\n   207→\\t\\t\\ttestFn(t, env, strat)\\n   208→\\t\\t})\\n   209→\\t}\\n   210→}\\n   211→\\n   212→// RunForAllStrategiesWithRepoEnv runs a test function for each strategy in parallel,\\n   213→// using NewRepoWithCommit