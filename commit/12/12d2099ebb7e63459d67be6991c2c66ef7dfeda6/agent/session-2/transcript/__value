ts with real agent calls.\\n    32→type TestEnv struct {\\n    33→\\tT       *testing.T\\n    34→\\tRepoDir string\\n    35→\\tAgent   AgentRunner\\n    36→}\\n    37→\\n    38→// getTestBinary returns the path to the shared test binary.\\n    39→// It panics if TestMain hasn't run (testBinaryPath is empty).\\n    40→func getTestBinary() string {\\n    41→\\tif testBinaryPath == \\\"\\\" {\\n    42→\\t\\tpanic(\\\"testBinaryPath not set - TestMain must run before tests\\\")\\n    43→\\t}\\n    44→\\treturn testBinaryPath\\n    45→}\\n    46→\\n    47→// NewTestEnv creates a new isolated E2E test environment.\\n    48→func NewTestEnv(t *testing.T) *TestEnv {\\n    49→\\tt.Helper()\\n    50→\\n    51→\\t// Resolve symlinks on macOS where /var -> /private/var\\n    52→\\trepoDir := t.TempDir()\\n    53→\\tif resolved, err := filepath.EvalSymlinks(repoDir); err == nil {\\n    54→\\t\\trepoDir = resolved\\n    55→\\t}\\n    56→\\n    57→\\t// Create agent runner\\n    58→\\tagent := NewAgentRunner(defaultAgent, AgentRunnerConfig{})\\n    59→\\n    60→\\treturn &TestEnv{\\n    61→\\t\\tT:       t,\\n    62→\\t\\tRepoDir: repoDir,\\n    63→\\t\\tAgent:   agent,\\n    64→\\t}\\n    65→}\\n    66→\\n    67→// NewFeatureBranchEnv creates an E2E test environment ready for testing.\\n    68→// It initializes the repo, creates an initial commit on main,\\n    69→// checks out a feature branch, and sets up agent hooks.\\n    70→func NewFeatureBranchEnv(t *testing.T, strategyName string) *TestEnv {\\n    71→\\tt.Helper()\\n    72→\\n    73→\\tenv := NewTestEnv(t)\\n    74→\\tenv.InitRepo()\\n    75→\\tenv.WriteFile(\\\"README.md\\\", \\\"# Test Repository\\\\n\\\\nThis is a test repository for E2E testing.\\\\n\\\")\\n    76→\\tenv.GitAdd(\\\"README.md\\\")\\n    77→\\tenv.GitCommit(\\\"Initial commit\\\")\\n    78→\\tenv.GitCheckoutNewBranch(\\\"feature/e2e-test\\\")\\n    79→\\n    80→\\t// Use `entire enable` to set up everything (hooks, settings, etc.)\\n    81→\\t// This sets up .entire/settings.json and .claude/settings.json with hooks\\n    82→\\tenv.RunEntireEnable(strategyName)\\n    83→\\n    84→\\t// Commit all files created by `entire enable` so they survive git stash -u operations.\\n    85→\\t// Without this, stash operations would stash away the hooks config and entire settings,\\n    86→\\t// causing hooks to not fire for subsequent prompts and stash pop conflicts.\\n    87→\\t// Using \\\"git add .\\\" is safe in test repos since we control all content.\\n    88→\\tenv.GitAddAll()\\n    89→\\tenv.GitCommit(\\\"Add entire and agent config\\\")\\n    90→\\n    91→\\treturn env\\n    92→}\\n    93→\\n    94→// RunEntireEnable runs `entire enable` to set up the project with hooks.\\n    95→// Uses the configured defaultAgent (from E2E_AGENT env var or \\\"claude-code\\\").\\n    96→func (env *TestEnv) RunEntireEnable(strategyName string) {\\n    97→\\tenv.T.Helper()\\n    98→\\n    99→\\targs := []string{\\n   100→\\t\\t\\\"enable\\\",\\n   101→\\t\\t\\\"--agent\\\", defaultAgent,\\n   102→\\t\\t\\\"--strategy\\\", strategyName,\\n   103→\\t\\t\\\"--telemetry=false\\\",\\n   104→\\t\\t\\\"--force\\\", // Force reinstall hooks in case they exist\\n   105→\\t}\\n   106→\\n   107→\\t//nolint:gosec,noctx // test code, args are static\\n   108→\\tcmd := exec.Command(getTestBinary(), args...)\\n   109→\\tcmd.Dir = env.RepoDir\\n   110→\\n   111→\\toutput, err := cmd.CombinedOutput()\\n   112→\\tif err != nil {\\n   113→\\t\\tenv.T.Fatalf(\\\"entire enable failed: %v\\\\nOutput: %s\\\", err, output)\\n   114→\\t}\\n   115→\\tenv.T.Logf(\\\"entire enable output: %s\\\", output)\\n   116→}\\n   117→\\n   118→// InitRepo initializes a git repository in the test environment.\\n   119→func (env *TestEnv) InitRepo() {\\n   120→\\tenv.T.Helper()\\n   121→\\n   122→\\trepo, err := git.PlainInit(env.RepoDir, false)\\n   123→\\tif err != nil {\\n   124→\\t\\tenv.T.Fatalf(\\\"failed to init git repo: %v\\\", err)\\n   125→\\t}\\n   126→\\n   127→\\t// Configure git user for commits\\n   128→\\tcfg, err := repo.Config()\\n   129→\\tif err != nil {\\n   130→\\t\\tenv.T.Fatalf(\\\"failed to get repo config: %v\\\", err)\\n   131→\\t}\\n   132→\\tcfg.User.Name = \\\"E2E Test User\\\"\\n   133→\\tcfg.User.Email = \\\"e2e-test@example.com\\\"\\n   134→\\n   135→\\t// Disable GPG signing for test commits\\n   136→\\tif cfg.Raw == nil {\\n   137→\\t\\tcfg.Raw = config.New()\\n   138→\\t}\\n   139→\\tcfg.Raw.Section(\\\"commit\\\").SetOption(\\\"gpgsign\\\", \\\"false\\\")\\n   140→\\n   141→\\tif err := repo.SetConfig(cfg); err != nil {\\n   142→\\t\\tenv.T.Fatalf(\\\"failed to set repo config: %v\\\", err)\\n   143→\\t}\\n   144→}\\n   145→\\n   146→// WriteFile creates a file with the given content in the test repo.\\n   147→func (env *TestEnv) WriteFile(path, content string) {\\n   148→\\tenv.T.Helper()\\n   149→\\n   150→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   151→\\n   152→\\t// Create parent directories\\n   153→\\tdir := filepath.Dir(fullPath)\\n   154→\\t//nolint:gosec // test code, permissions are intentionally standard\\n   155→\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   156→\\t\\tenv.T.Fatalf(\\\"failed to create directory %s: %v\\\", dir, err)\\n   157→\\t}\\n   158→\\n   159→\\t//nolint:gosec // test code, permissions are intentionally standard\\n   160→\\tif err := os.WriteFile(fullPath, []byte(content), 0o644); err != nil {\\n   161→\\t\\tenv.T.Fatalf(\\\"failed to write file %s: %v\\\", path, err)\\n   162→\\t}\\n   163→}\\n   164→\\n   165→// ReadFile reads a file from the test repo.\\n   166→func (env *TestEnv) ReadFile(path string) string {\\n   167→\\tenv.T.Helper()\\n   168→\\n   169→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   170→\\t//nolint:gosec // test code, path is from test setup\\n   171→\\tdata, err := os.ReadFile(fullPath)\\n   172→\\tif err != nil {\\n   173→\\t\\tenv.T.Fatalf(\\\"failed to read file %s: %v\\\", path, err)\\n   174→\\t}\\n   175→\\tre