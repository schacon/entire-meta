== -1 {\\n   298→\\t\\treturn \\\"\\\"\\n   299→\\t}\\n   300→\\n   301→\\t// Extract the ID (alphanumeric characters after the prefix)\\n   302→\\tstart := idx + len(prefix)\\n   303→\\tend := start\\n   304→\\tfor end < len(text) && (text[end] >= 'a' && text[end] <= 'z' ||\\n   305→\\t\\ttext[end] >= 'A' && text[end] <= 'Z' ||\\n   306→\\t\\ttext[end] >= '0' && text[end] <= '9') {\\n   307→\\t\\tend++\\n   308→\\t}\\n   309→\\n   310→\\tif end > start {\\n   311→\\t\\treturn text[start:end]\\n   312→\\t}\\n   313→\\treturn \\\"\\\"\\n   314→}\\n   315→\\n   316→// CalculateTotalTokenUsageFromTranscript calculates token usage for a turn, including subagents.\\n   317→// It parses the main transcript from startLine, extracts spawned agent IDs,\\n   318→// and calculates their token usage from transcripts in subagentsDir.\\n   319→func CalculateTotalTokenUsageFromTranscript(transcriptPath string, startLine int, subagentsDir string) (*agent.TokenUsage, error) {\\n   320→\\tif transcriptPath == \\\"\\\" {\\n   321→\\t\\treturn &agent.TokenUsage{}, nil\\n   322→\\t}\\n   323→\\n   324→\\t// Parse transcript once using Droid-specific parser\\n   325→\\tparsed, _, err := ParseDroidTranscript(transcriptPath, startLine)\\n   326→\\tif err != nil {\\n   327→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   328→\\t}\\n   329→\\n   330→\\t// Calculate token usage from parsed transcript\\n   331→\\tmainUsage := CalculateTokenUsage(parsed)\\n   332→\\n   333→\\t// Extract spawned agent IDs from the same parsed transcript\\n   334→\\tagentIDs := ExtractSpawnedAgentIDs(parsed)\\n   335→\\n   336→\\t// Calculate subagent token usage\\n   337→\\tif len(agentIDs) > 0 {\\n   338→\\t\\tsubagentUsage := &agent.TokenUsage{}\\n   339→\\t\\tfor agentID := range agentIDs {\\n   340→\\t\\t\\tagentPath := filepath.Join(subagentsDir, fmt.Sprintf(\\\"agent-%s.jsonl\\\", agentID))\\n   341→\\t\\t\\tagentUsage, err := CalculateTokenUsageFromFile(agentPath, 0)\\n   342