→\\t//nolint:wrapcheck // test helper, caller handles error\\n   796→\\treturn result, err\\n   797→}\\n   798→\\n   799→// RunAgentWithTools runs the agent with specific tools enabled.\\n   800→func (env *TestEnv) RunAgentWithTools(prompt string, tools []string) (*AgentResult, error) {\\n   801→\\tenv.T.Helper()\\n   802→\\tresult, err := env.Agent.RunPromptWithTools(context.Background(), env.RepoDir, prompt, tools)\\n   803→\\tif err != nil && result != nil {\\n   804→\\t\\tenv.T.Logf(\\\"Agent failed with exit code %d\\\", result.ExitCode)\\n   805→\\t\\tif result.Stderr != \\\"\\\" {\\n   806→\\t\\t\\tenv.T.Logf(\\\"Agent stderr: %s\\\", result.Stderr)\\n   807→\\t\\t}\\n   808→\\t\\tif result.Stdout != \\\"\\\" {\\n   809→\\t\\t\\tenv.T.Logf(\\\"Agent stdout: %s\\\", result.Stdout)\\n   810→\\t\\t}\\n   811→\\t}\\n   812→\\t//nolint:wrapcheck // test helper, caller handles error\\n   813→\\treturn result, err\\n   814→}\\n   815→\\n   816→// GitStash runs git stash to save uncommitted changes.\\n   817→// Uses -u flag to include untracked files (new files created by agent).\\n   818→func (env *TestEnv) GitStash() {\\n   819→\\tenv.T.Helper()\\n   820→\\n   821→\\t//nolint:noctx // test code, no context needed for git stash\\n   822→\\tcmd := exec.Command(\\\"git\\\", \\\"stash\\\", \\\"-u\\\")\\n   823→\\tcmd.Dir = env.RepoDir\\n   824→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   825→\\t\\tenv.T.Fatalf(\\\"git stash failed: %v\\\\nOutput: %s\\\", err, output)\\n   826→\\t}\\n   827→}\\n   828→\\n   829→// GitStashPop runs git stash pop to restore stashed changes.\\n   830→func (env *TestEnv) GitStashPop() {\\n   831→\\tenv.T.Helper()\\n   832→\\n   833→\\t//nolint:noctx // test code, no context needed for git stash pop\\n   834→\\tcmd := exec.Command(\\\"git\\\", \\\"stash\\\", \\\"pop\\\")\\n   835→\\tcmd.Dir = env.RepoDir\\n   836→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   837→\\t\\tenv.T.Fatalf(\\\"git stash pop failed: %v\\\\nOutput: %s\\\", err, output)\\n   838→\\t}\\n   839→}\\n   840→\\n   841→// GitCheckoutFile reverts a file to its committed state.\\n   842→func (env *TestEnv) GitCheckoutFile(path string) {\\n   843→\\tenv.T.Helper()\\n   844→\\n   845→\\t//nolint:gosec,noctx // test code, path is from test setup, no context needed\\n   846→\\tcmd := exec.Command(\\\"git\\\", \\\"checkout\\\", \\\"--\\\", path)\\n   847→\\tcmd.Dir = env.RepoDir\\n   848→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   849→\\t\\tenv.T.Fatalf(\\\"git checkout -- %s failed: %v\\\\nOutput: %s\\\", path, err, output)\\n   850→\\t}\\n   851→}\\n   852→\\n   853→// DeleteFile removes a file from the test repo.\\n   854→func (env *TestEnv) DeleteFile(path string) {\\n   855→\\tenv.T.Helper()\\n   856→\\n   857→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   858→\\tif err := os.Remove(fullPath); err != nil {\\n   859→\\t\\tenv.T.Fatalf(\\\"failed to delete file %s: %v\\\", path, err)\\n   860→\\t}\\n   861→}\\n   862→\\n   863→// GetCommitCount returns the number of commits on the current branch.\\n   864→func (env *TestEnv) GetCommitCount() int {\\n   865→\\tenv.T.Helper()\\n   866→\\n   867→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   868→\\tif err != nil {\\n   869→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   870→\\t}\\n   871→\\n   872→\\thead, err := repo.Head()\\n   873→\\tif err != nil {\\n   874→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   875→\\t}\\n   876→\\n   877→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   878→\\tif err != nil {\\n   879→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   880→\\t}\\n   881→\\n   882→\\tcount := 0\\n   883→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   884→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   885→\\t\\tcount++\\n   886→\\t\\treturn nil\\n   887→\\t})\\n   888→\\n   889→\\treturn count\\n   890→}\