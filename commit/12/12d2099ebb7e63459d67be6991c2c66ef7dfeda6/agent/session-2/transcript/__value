 := config.Timeout\\n   222→\\tif timeout == 0 {\\n   223→\\t\\tif envTimeout := os.Getenv(\\\"E2E_TIMEOUT\\\"); envTimeout != \\\"\\\" {\\n   224→\\t\\t\\tif parsed, err := time.ParseDuration(envTimeout); err == nil {\\n   225→\\t\\t\\t\\ttimeout = parsed\\n   226→\\t\\t\\t}\\n   227→\\t\\t}\\n   228→\\t\\tif timeout == 0 {\\n   229→\\t\\t\\ttimeout = 2 * time.Minute\\n   230→\\t\\t}\\n   231→\\t}\\n   232→\\n   233→\\treturn &GeminiCLIRunner{\\n   234→\\t\\tModel:   model,\\n   235→\\t\\tTimeout: timeout,\\n   236→\\t}\\n   237→}\\n   238→\\n   239→func (r *GeminiCLIRunner) Name() string {\\n   240→\\treturn AgentNameGemini\\n   241→}\\n   242→\\n   243→// IsAvailable checks if Gemini CLI is installed and authenticated.\\n   244→func (r *GeminiCLIRunner) IsAvailable() (bool, error) {\\n   245→\\t// Check if gemini CLI is in PATH\\n   246→\\tif _, err := exec.LookPath(\\\"gemini\\\"); err != nil {\\n   247→\\t\\treturn false, fmt.Errorf(\\\"gemini CLI not found in PATH: %w\\\", err)\\n   248→\\t}\\n   249→\\n   250→\\t// Check if gemini is working (--version doesn't require auth)\\n   251→\\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\\n   252→\\tdefer cancel()\\n   253→\\n   254→\\tcmd := exec.CommandContext(ctx, \\\"gemini\\\", \\\"--version\\\")\\n   255→\\tif err := cmd.Run(); err != nil {\\n   256→\\t\\treturn false, fmt.Errorf(\\\"gemini CLI not working: %w\\\", err)\\n   257→\\t}\\n   258→\\n   259→\\treturn true, nil\\n   260→}\\n   261→\\n   262→func (r *GeminiCLIRunner) RunPrompt(ctx context.Context, workDir string, prompt string) (*AgentResult, error) {\\n   263→\\treturn r.RunPromptWithTools(ctx, workDir, prompt, nil)\\n   264→}\\n   265→\\n   266→func (r *GeminiCLIRunner) RunPromptWithTools(ctx context.Context, workDir string, prompt string, tools []string) (*AgentResult, error) {\\n   267→\\t// Build command: gemini -m <model> -p \\\"<prompt>\\\" --approval-mode auto_edit --allowed-tools <tools>\\n   268→\\t// --approval-m