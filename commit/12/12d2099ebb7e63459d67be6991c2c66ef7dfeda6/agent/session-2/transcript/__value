mulated Gemini CLI session.\\n   650→type GeminiSession struct {\\n   651→\\tID             string // Raw model session ID (e.g., \\\"gemini-session-1\\\")\\n   652→\\tTranscriptPath string\\n   653→\\tenv            *TestEnv\\n   654→}\\n   655→\\n   656→// NewGeminiSession creates a new simulated Gemini session.\\n   657→func (env *TestEnv) NewGeminiSession() *GeminiSession {\\n   658→\\tenv.T.Helper()\\n   659→\\n   660→\\tenv.SessionCounter++\\n   661→\\tsessionID := fmt.Sprintf(\\\"gemini-session-%d\\\", env.SessionCounter)\\n   662→\\ttranscriptPath := filepath.Join(env.RepoDir, \\\".entire\\\", \\\"tmp\\\", sessionID+\\\".json\\\")\\n   663→\\n   664→\\treturn &GeminiSession{\\n   665→\\t\\tID:             sessionID,\\n   666→\\t\\tTranscriptPath: transcriptPath,\\n   667→\\t\\tenv:            env,\\n   668→\\t}\\n   669→}\\n   670→\\n   671→// CreateGeminiTranscript creates a Gemini JSON transcript file for the session.\\n   672→func (s *GeminiSession) CreateGeminiTranscript(prompt string, changes []FileChange) string {\\n   673→\\t// Build Gemini-format transcript (JSON, not JSONL)\\n   674→\\tmessages := []map[string]interface{}{\\n   675→\\t\\t{\\n   676→\\t\\t\\t\\\"type\\\":    \\\"user\\\",\\n   677→\\t\\t\\t\\\"content\\\": prompt,\\n   678→\\t\\t},\\n   679→\\t\\t{\\n   680→\\t\\t\\t\\\"type\\\":    \\\"assistant\\\",\\n   681→\\t\\t\\t\\\"content\\\": \\\"I'll help you with that.\\\",\\n   682→\\t\\t},\\n   683→\\t}\\n   684→\\n   685→\\tfor _, change := range changes {\\n   686→\\t\\tmessages = append(messages, map[string]interface{}{\\n   687→\\t\\t\\t\\\"type\\\": \\\"tool_use\\\",\\n   688→\\t\\t\\t\\\"name\\\": \\\"write_file\\\",\\n   689→\\t\\t\\t\\\"input\\\": map[string]string{\\n   690→\\t\\t\\t\\t\\\"path\\\":    change.Path,\\n   691→\\t\\t\\t\\t\\\"content\\\": change.Content,\\n   692→\\t\\t\\t},\\n   693→\\t\\t})\\n   694→\\t\\tmessages = append(messages, map[string]interface{}{\\n   695→\\t\\t\\t\\\"type\\\":   \\\"tool_result\\\",\\