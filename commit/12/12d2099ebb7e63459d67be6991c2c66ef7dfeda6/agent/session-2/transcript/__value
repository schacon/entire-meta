\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    50→\\t}\\n    51→}\\n    52→\\n    53→// --- TranscriptAnalyzer ---\\n    54→\\n    55→// GetTranscriptPosition returns the current line count of the JSONL transcript.\\n    56→func (f *FactoryAIDroidAgent) GetTranscriptPosition(path string) (int, error) {\\n    57→\\t_, pos, err := ParseDroidTranscript(path, 0)\\n    58→\\tif err != nil {\\n    59→\\t\\treturn 0, err\\n    60→\\t}\\n    61→\\treturn pos, nil\\n    62→}\\n    63→\\n    64→// ExtractModifiedFilesFromOffset extracts files modified since a given line offset.\\n    65→func (f *FactoryAIDroidAgent) ExtractModifiedFilesFromOffset(path string, startOffset int) ([]string, int, error) {\\n    66→\\tlines, currentPos, err := ParseDroidTranscript(path, startOffset)\\n    67→\\tif err != nil {\\n    68→\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    69→\\t}\\n    70→\\tfiles := ExtractModifiedFiles(lines)\\n    71→\\treturn files, currentPos, nil\\n    72→}\\n    73→\\n    74→// ExtractPrompts extracts user prompts from the transcript starting at the given line offset.\\n    75→func (f *FactoryAIDroidAgent) ExtractPrompts(sessionRef string, fromOffset int) ([]string, error) {\\n    76→\\tlines, _, err := ParseDroidTranscript(sessionRef, fromOffset)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    79→\\t}\\n    80→\\n    81→\\tvar prompts []string\\n    82→\\tfor i := range lines {\\n    83→\\t\\tif lines[i].Type != transcript.TypeUser {\\n    84→\\t\\t\\tcontinue\\n    85→\\t\\t}\\n    86→\\t\\tcontent := transcript.ExtractUserContent(lines[i].Message)\\n    87→\\t\\tif content != \\\"\\\" {\\n    88→\\t\\t\\tprompts = append(prompts, textutil.StripIDEContextTags(content))\\n    89→\\t\\t}\\n    90→\\t}\\n    91→\\treturn prompts, nil\\n    92→}\\n    93→\\n    94→// ExtractSummary extracts the last assistant message as a session summary.\\n    95→func (f *FactoryAIDroidAgent) ExtractSummary(sessionRef string) (string, error) {\\n    96→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n    97→\\tif err != nil {\\n    98→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    99→\\t}\\n   100→\\tlines, err := ParseDroidTranscriptFromBytes(data)\\n   101→\\tif err != nil {\\n   102→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   103→\\t}\\n   104→\\n   105→\\tfor i := len(lines) - 1; i >= 0; i-- {\\n   106→\\t\\tif lines[i].Type != transcript.TypeAssistant {\\n   107→\\t\\t\\tcontinue\\n   108→\\t\\t}\\n   109→\\t\\tvar msg transcript.AssistantMessage\\n   110→\\t\\tif err := json.Unmarshal(lines[i].Message, &msg); err != nil {\\n   111→\\t\\t\\tcontinue\\n   112→\\t\\t}\\n   113→\\t\\tfor _, block := range msg.Content {\\n   114→\\t\\t\\tif block.Type == transcript.ContentTypeText && block.Text != \\\"\\\" {\\n   115→\\t\\t\\t\\treturn block.Text, nil\\n   116→\\t\\t\\t}\\n   117→\\t\\t}\\n   118→\\t}\\n   119→\\treturn \\\"\\\", nil\\n   120→}\\n   121→\\n   122→// --- TokenCalculator ---\\n   123→\\n   124→// CalculateTokenUsage computes token usage from the transcript starting at the given line offset.\\n   125→func (f *FactoryAIDroidAgent) CalculateTokenUsage(sessionRef string, fromOffset int) (*agent.TokenUsage, error) {\\n   126→\\treturn CalculateTotalTokenUsageFromTranscript(sessionRef, fromOffset, \\\"\\\")\\n   127→}\\n   128→\\n   129→// --- SubagentAwareExtractor ---\\n   130→\\n   131→// ExtractAllModifiedFiles extracts files modified by both the main agent and any spawned subagents.\\n   132→func (f *FactoryAIDroidAgent) ExtractAllModifiedFiles(sessionRef string, fromOffset int, subagentsDir string) ([]string, error) {\\n   133→\\treturn ExtractAllModifiedFilesFromTranscript(sessionRef, fromOffset, subagentsDir)\\n   134→}\\n   135→\\n   136→// CalculateTotalTokenUsage