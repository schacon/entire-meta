/ Get the branch reference\\n   939→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   940→\\tif err != nil {\\n   941→\\t\\t// Try as a remote-style ref\\n   942→\\t\\tref, err = repo.Reference(plumbing.ReferenceName(\\\"refs/heads/\\\"+branchName), true)\\n   943→\\t\\tif err != nil {\\n   944→\\t\\t\\treturn \\\"\\\", false\\n   945→\\t\\t}\\n   946→\\t}\\n   947→\\n   948→\\t// Get the commit\\n   949→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   950→\\tif err != nil {\\n   951→\\t\\treturn \\\"\\\", false\\n   952→\\t}\\n   953→\\n   954→\\t// Get the tree\\n   955→\\ttree, err := commit.Tree()\\n   956→\\tif err != nil {\\n   957→\\t\\treturn \\\"\\\", false\\n   958→\\t}\\n   959→\\n   960→\\t// Get the file\\n   961→\\tfile, err := tree.File(filePath)\\n   962→\\tif err != nil {\\n   963→\\t\\treturn \\\"\\\", false\\n   964→\\t}\\n   965→\\n   966→\\t// Get the content\\n   967→\\tcontent, err := file.Contents()\\n   968→\\tif err != nil {\\n   969→\\t\\treturn \\\"\\\", false\\n   970→\\t}\\n   971→\\n   972→\\treturn content, true\\n   973→}\\n   974→\\n   975→// CheckpointValidation contains expected values for checkpoint validation.\\n   976→type CheckpointValidation struct {\\n   977→\\t// CheckpointID is the expected checkpoint ID\\n   978→\\tCheckpointID string\\n   979→\\n   980→\\t// Strategy is the expected strategy name (optional)\\n   981→\\tStrategy string\\n   982→\\n   983→\\t// FilesTouched are the expected files in files_touched (optional)\\n   984→\\tFilesTouched []string\\n   985→\\n   986→\\t// ExpectedPrompts are strings that should appear in prompt.txt (optional)\\n   987→\\tExpectedPrompts []string\\n   988→\\n   989→\\t// ExpectedTranscriptContent are strings that should appear in full.jsonl (optional)\\n   990→\\tExpectedTranscriptContent []string\\n   991→}\\n   992→\\n   993→// ValidateCheckpoint performs comprehensive validation of a checkpoint on the metadata branch.\\n   994→func (env *TestEnv) ValidateCheckpoint(v CheckpointValidation) {\\n   995→\\tenv.T.Helper()\\n   996→\\n   997→\\tmetadataBranch := \\\"entire/checkpoints/v1\\\"\\n   998→\\n   999→\\t// Compute sharded path: <id[:2]>/<id[2:]>/\\n  1000→\\tif len(v.CheckpointID) < 3 {\\n  1001→\\t\\tenv.T.Fatalf(\\\"Checkpoint ID too short: %s\\\", v.CheckpointID)\\n  1002→\\t}\\n  1003→\\tshardedPath := v.CheckpointID[:2] + \\\"/\\\" + v.CheckpointID[2:]\\n  1004→\\n  1005→\\t// Validate root metadata.json exists and has expected fields\\n  1006→\\tsummaryPath := shardedPath + \\\"/metadata.json\\\"\\n  1007→\\tsummaryContent, found := env.ReadFileFromBranch(metadataBranch, summaryPath)\\n  1008→\\tif !found {\\n  1009→\\t\\tenv.T.Errorf(\\\"CheckpointSummary not found at %s\\\", summaryPath)\\n  1010→\\t} else {\\n  1011→\\t\\tvar summary map[string]any\\n  1012→\\t\\tif err := json.Unmarshal([]byte(summaryContent), &summary); err != nil {\\n  1013→\\t\\t\\tenv.T.Errorf(\\\"Failed to parse CheckpointSummary: %v\\\", err)\\n  1014→\\t\\t} else {\\n  1015→\\t\\t\\t// Validate checkpoint_id\\n  1016→\\t\\t\\tif cpID, ok := summary[\\\"checkpoint_id\\\"].(string); !ok || cpID != v.CheckpointID {\\n  1017→\\t\\t\\t\\tenv.T.Errorf(\\\"CheckpointSummary.checkpoint_id = %v, want %s\\\", summary[\\\"checkpoint_id\\\"], v.CheckpointID)\\n  1018→\\t\\t\\t}\\n  1019→\\t\\t\\t// Validate strategy if specified\\n  1020→\\t\\t\\tif v.Strategy != \\\"\\\" {\\n  1021→\\t\\t\\t\\tif strategy, ok := summary[\\\"strategy\\\"].(string); !ok || strategy != v.Strategy {\\n  1022→\\t\\t\\t\\t\\tenv.T.Errorf(\\\"CheckpointSummary.strategy = %v, want %s\\\", summary[\\\"strategy\\\"], v.Strategy)\\n  1023→\\t\\t\\t\\t}\\n  1024→\\t\\t\\t}\\n  1025→\\t\\t\\t// Validate sessions array exists\\n  1026→\\t\\t\\tif sessions, ok := summary[\\\"sessions\\\"].([]any); !ok || len(sessions) == 0 {\\n  1027→\\t\\t\\t\\tenv.T.Error(\\\"CheckpointSummary.sessions should have at least one entry\\\")\\n  1028→\\t\\t\\t}\\n  1029→\\t\\t\\t// Validate files_touched if specified\\n  1030→\\t\\t\\tif len(v.FilesTouched) > 0 {\\n  1031→\\t\\t\\t\\tif filesTouched, ok := summary[\\\"files_touched\\\"].([]any); ok {\\n  1032→\\t\\t\\t\\t\\ttouchedSet := make(map[string]bool)\\n  1033→\\t\\t\\t\\t\\tfor _, f := range filesTouched {\\n  1034→\\t\\t\\t\\t\\t\\tif s, ok := f.(string); ok {\\n  1035→\\t\\t\\t\\t\\t\\t\\ttouchedSet[s] = true\\n  1036→\\t\\t\\t\\t\\t\\t}\\n  1037→\\t\\t\\t\\t\\t}\\n  1038→\\t\\t\\t\\t\\tfor _, expected := range v.FilesTouched {\\n  1039→\\t\\t\\t\\t\\t\\tif !touchedSet[expected] {\\n  1040→\\t\\t\\t\\t\\t\\t\\tenv.T.Errorf(\\\"CheckpointSummary.files_touched missing %q\\\", expected)\\n  1041→\\t\\t\\t\\t\\t\\t}\\n  1042→\\t\\t\\t\\t\\t}\\n  1043→\\t\\t\\t\\t}\\n  1044→\\t\\t\\t}\\n  1045→\\t\\t}\\n  1046→\\t}\\n  1047→\\n  1048→\\t// Validate session metadata.json exists\\n  1049→\\tsessionMetadataPath := shardedPath + \\\"/0/metadata.json\\\"\\n  1050→\\tsessionContent, found := env.ReadFileFromBranch(metadataBranch, sessionMetadataPath)\\n  1051→\\tif !found {\\n  1052→\\t\\tenv.T.Errorf(\\\"Session metadata not found at %s\\\", sessionMetadataPath)\\n  1053→\\t} else {\\n  1054→\\t\\tvar metadata map[string]any\\n  1055→\\t\\tif err := json.Unmarshal([]byte(sessionContent), &metadata); err != nil {\\n  1056→\\t\\t\\tenv.T.Errorf(\\\"Failed to parse session metadata: %v\\\", err)\\n  1057→\\t\\t} else {\\n  1058→\\t\\t\\t// Validate checkpoint_id matches\\n  1059→\\t\\t\\tif cpID, ok := metadata[\\\"checkpoint_id\\\"].(string); !ok || cpID != v.CheckpointID {\\n  1060→\\t\\t\\t\\tenv.T.Errorf(\\\"Session metadata.checkpoint_id = %v, want %s\\\", metadata[\\\"checkpoint_id\\\"], v.CheckpointID)\\n  1061→\\t\\t\\t}\\n  1062→\\t\\t\\t// Validate created_at exists\\n  1063→\\t\\t\\tif _, ok := metadata[\\\"created_at\\\"].(string); !ok {\\n  1064→\\t\\t\\t\\tenv.T.Error(\\\"Session metadata.created_at should exist\\\")\\n  1065→\\t\\t\\t}\\n  1066→\\t\\t}\\n  1067→\\t}\\n  