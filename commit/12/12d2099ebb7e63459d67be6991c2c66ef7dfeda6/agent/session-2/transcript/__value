rds from HEAD and returns\\n   680→// the checkpoint ID from the first commit with an Entire-Checkpoint trailer.\\n   681→// Returns an error if no checkpoint trailer is found in any commit.\\n   682→func (env *TestEnv) GetLatestCheckpointIDFromHistory() (string, error) {\\n   683→\\tenv.T.Helper()\\n   684→\\n   685→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   686→\\tif err != nil {\\n   687→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   688→\\t}\\n   689→\\n   690→\\thead, err := repo.Head()\\n   691→\\tif err != nil {\\n   692→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   693→\\t}\\n   694→\\n   695→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   696→\\tif err != nil {\\n   697→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   698→\\t}\\n   699→\\n   700→\\tvar checkpointID string\\n   701→\\t//nolint:errcheck,gosec // ForEach callback returns error to stop iteration, not a real error\\n   702→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   703→\\t\\t// Look for Entire-Checkpoint trailer\\n   704→\\t\\tfor _, line := range strings.Split(c.Message, \\\"\\\\n\\\") {\\n   705→\\t\\t\\tline = strings.TrimSpace(line)\\n   706→\\t\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   707→\\t\\t\\t\\tcheckpointID = strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   708→\\t\\t\\t\\treturn errors.New(\\\"stop iteration\\\")\\n   709→\\t\\t\\t}\\n   710→\\t\\t}\\n   711→\\t\\treturn nil\\n   712→\\t})\\n   713→\\n   714→\\tif checkpointID == \\\"\\\" {\\n   715→\\t\\treturn \\\"\\\", errors.New(\\\"no commit with Entire-Checkpoint trailer found in history\\\")\\n   716→\\t}\\n   717→\\n   718→\\treturn checkpointID, nil\\n   719→}\\n   720→\\n   721→// GetLatestCheckpointID returns the checkpoint ID from HEAD commit, or empty string if none.\\n   722→// This is a convenience wrapper that doesn't fail the test on missing checkpoint.\\n   723→func (env *TestEnv) GetLatestCheckpointID() string {\\n   724→\\tenv.T.Helper()\\n   725→\\n   726→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   727→\\tif err != nil {\\n   728→\\t\\treturn \\\"\\\"\\n   729→\\t}\\n   730→\\n   731→\\thead, err := repo.Head()\\n   732→\\tif err != nil {\\n   733→\\t\\treturn \\\"\\\"\\n   734→\\t}\\n   735→\\n   736→\\tcommit, err := repo.CommitObject(head.Hash())\\n   737→\\tif err != nil {\\n   738→\\t\\treturn \\\"\\\"\\n   739→\\t}\\n   740→\\n   741→\\t// Look for Entire-Checkpoint trailer in HEAD commit only\\n   742→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n   743→\\t\\tline = strings.TrimSpace(line)\\n   744→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   745→\\t\\t\\treturn strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   746→\\t\\t}\\n   747→\\t}\\n   748→\\treturn \\\"\\\"\\n   749→}\\n   750→\\n   751→// safeIDPrefix returns first 12 chars of ID or the full ID if shorter.\\n   752→// Use this when logging checkpoint IDs to avoid index out of bounds panic.\\n   753→func safeIDPrefix(id string) string {\\n   754→\\tif len(id) >= 12 {\\n   755→\\t\\treturn id[:12]\\n   756→\\t}\\n   757→\\treturn id\\n   758→}\\n   759→\\n   760→// RunCLI runs the entire CLI with the given arguments and returns stdout.\\n   761→func (env *TestEnv) RunCLI(args ...string) string {\\n   762→\\tenv.T.Helper()\\n   763→\\toutput, err := env.RunCLIWithError(args...)\\n   764→\\tif err != nil {\\n   765→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   766→\\t}\\n   767→\\treturn output\\n   768→}\\n   769→\\n   770→// RunCLIWithError runs the entire CLI and returns output and error.\\n   771→func (env *TestEnv) RunCLIWithError(args ...string) (string, error) {\\n   772→\\tenv.T.Helper()\\n   773→\\n   774→\\t//nolint:gosec,noctx // test code, args are from test setup, no context needed\\n   775→\\tcmd := exec.Command(getTestBinary(), args...)\\n   776→\\tcmd.Dir = env.RepoDir\\n   777→\\n   778→\\toutput, err := cmd.CombinedOutput()\\n   779→\\treturn string(output), err\\n   780→}\\n   781→\\n   782→// RunAgent runs the agent with the given prompt and returns the result.\\n   783→func (env *TestEnv) RunAgent(prompt string) (*AgentResult, error) {\\n   784→\\tenv.T.Helper()\\n   785→\\tresult, err := env.Agent.RunPrompt(context.Background(), env.RepoDir, prompt)\\n   786→\\tif err != nil && result != nil {\\n   787→\\t\\tenv.T.Logf(\\\"Agent failed with exit code %d\\\", result.ExitCode)\\n   788→\\t\\tif result.Stderr != \\\"\\\" {\\n   789→\\t\\t\\tenv.T.Logf(\\\"Agent stderr: %s\\\", result.Stderr)\\n   790→\\t\\t}\\n   791→\\t\\tif result.Stdout != \\\"\\\" {\\n   792→\\t\\t\\tenv.T.Logf(\\\"Agent stdout: %s\\\", result.Stdout)\\n   793→\\t\\t}\\n   794→\\t}\\n   795→\\t//nolint:wrapcheck // test helper, caller handles error\\n   796→\\treturn result, err\\n   797→}\\n   798→\\n   799→// RunAgentWithTools runs the agent with specific tools enabled.\\n   800→func (env *TestEnv) RunAgentWithTools(prompt string, tools []string) (*AgentResult, error) {\\n   801→\\tenv.T.Helper()\\n   802→\\tresult, err := env.Agent.RunPromptWithTools(context.Background(), env.RepoDir, prompt, tools)\\n   803→\\tif err != nil && result != nil {\\n   804→\\t\\tenv.T.Logf(\\\"Agent failed with exit code %d\\\", result.ExitCode)\\n   805→\\t\\tif result.Stderr != \\\"\\\" {\\n   806→\\t\\t\\tenv.T.Logf(\\\"Agent stderr: %s\\\", result.Stderr)\\n   807→\\t\\t}\\n   808→\\t\\tif result.Stdout != \\\"\\\" {\\n   809→\\t\\t\\tenv.T.Logf(\\\"Agent stdout: %s\\\", result.Stdout)\\n   810→\\t\\t}\\n   811→\\t}\\n   812→\\t//nolint:wrapcheck // test helper, caller handles error\\n   813→\\treturn result, err\\n   814→}\\n   815→\\n   816→// GitStash runs git stash to save uncommitted changes.\\n   817→// Uses -u flag to include untracked files (new files created by agent).\\n   818→func (env *TestEnv) GitStash