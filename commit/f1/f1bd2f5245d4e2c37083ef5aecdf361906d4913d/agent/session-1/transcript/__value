g             { return \\\"agent\\\" }\\n    31→func (a *CursorCLI) EntireAgent() string        { return \\\"cursor\\\" }\\n    32→func (a *CursorCLI) TimeoutMultiplier() float64 { return 1.5 }\\n    33→\\n    34→// PromptPattern returns a regex matching the Cursor CLI's TUI input prompt.\\n    35→// The CLI shows a styled input box with placeholder text when ready for input.\\n    36→func (a *CursorCLI) PromptPattern() string { return `/ commands` }\\n    37→\\n    38→func (a *CursorCLI) IsTransientError(out Output, err error) bool {\\n    39→\\tif err == nil {\\n    40→\\t\\treturn false\\n    41→\\t}\\n    42→\\tif errors.Is(err, context.DeadlineExceeded) {\\n    43→\\t\\treturn true\\n    44→\\t}\\n    45→\\tcombined := out.Stdout + out.Stderr\\n    46→\\tfor _, p := range []string{\\n    47→\\t\\t\\\"overloaded\\\",\\n    48→\\t\\t\\\"rate limit\\\",\\n    49→\\t\\t\\\"429\\\",\\n    50→\\t\\t\\\"503\\\",\\n    51→\\t\\t\\\"529\\\",\\n    52→\\t\\t\\\"ECONNRESET\\\",\\n    53→\\t\\t\\\"ETIMEDOUT\\\",\\n    54→\\t\\t\\\"server error\\\",\\n    55→\\t\\t\\\"Internal Server Error\\\",\\n    56→\\t} {\\n    57→\\t\\tif strings.Contains(combined, p) {\\n    58→\\t\\t\\treturn true\\n    59→\\t\\t}\\n    60→\\t}\\n    61→\\treturn false\\n    62→}\\n    63→\\n    64→func (a *CursorCLI) Bootstrap() error {\\n    65→\\t// The Cursor CLI authenticates via CURSOR_API_KEY env var or OAuth.\\n    66→\\t// On CI, ensure CURSOR_API_KEY is set. Locally, OAuth/keychain works.\\n    67→\\tif os.Getenv(\\\"CI\\\") != \\\"\\\" && os.Getenv(\\\"CURSOR_API_KEY\\\") == \\\"\\\" {\\n    68→\\t\\treturn errors.New(\\\"CURSOR_API_KEY must be set on CI for cursor-cli E2E tests\\\")\\n    69→\\t}\\n    70→\\treturn nil\\n    71→}\\n    72→\\n    73→func (a *CursorCLI) RunPrompt(ctx context.Context, dir string, prompt string, opts ...Option) (Output, error) {\\n    74→\\tcfg := &runConfig{}\\n    75→\\tfor _, o := range opts {\\n    76→\\t\\to(cfg)\\n    77→\\t}\\n    78→\\n    79→\\ttime