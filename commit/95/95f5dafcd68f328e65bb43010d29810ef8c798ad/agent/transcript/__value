kInput)\\n   193→}\\n   194→\\n   195→func (r *HookRunner) runHookWithInput(flag string, input interface{}) error {\\n   196→\\tr.T.Helper()\\n   197→\\n   198→\\tinputJSON, err := json.Marshal(input)\\n   199→\\tif err != nil {\\n   200→\\t\\treturn fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n   201→\\t}\\n   202→\\n   203→\\treturn r.runHookInRepoDir(flag, inputJSON)\\n   204→}\\n   205→\\n   206→func (r *HookRunner) runHookInRepoDir(hookName string, inputJSON []byte) error {\\n   207→\\t// Run using the shared test binary\\n   208→\\t// Command structure: entire hooks claude-code <hook-name>\\n   209→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"claude-code\\\", hookName)\\n   210→\\tcmd.Dir = r.RepoDir\\n   211→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   212→\\tcmd.Env = append(os.Environ(),\\n   213→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+r.ClaudeProjectDir,\\n   214→\\t)\\n   215→\\n   216→\\toutput, err := cmd.CombinedOutput()\\n   217→\\tif err != nil {\\n   218→\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n   219→\\t\\t\\thookName, err, inputJSON, output)\\n   220→\\t}\\n   221→\\n   222→\\tr.T.Logf(\\\"Hook %s output: %s\\\", hookName, output)\\n   223→\\treturn nil\\n   224→}\\n   225→\\n   226→// Session represents a simulated Claude Code session.\\n   227→type Session struct {\\n   228→\\tID                string // Raw model session ID (e.g., \\\"test-session-1\\\")\\n   229→\\tTranscriptPath    string\\n   230→\\tTranscriptBuilder *TranscriptBuilder\\n   231→\\tenv               *TestEnv\\n   232→}\\n   233→\\n   234→// FileChange represents a file modification in a session.\\n   235→type FileChange struct {\\n   236→\\tPath    string\\n   237→\\tContent string\\n   238→}\\n   239→\\n   240→// NewSession creates a new simulated session.\\n   241→func (env *TestEnv) NewSession() *Session {\\n   242→\\tenv.T.Helper()\\n   243→\\n   244→\\tenv.SessionCounter++\\n   245→\\tsessionI