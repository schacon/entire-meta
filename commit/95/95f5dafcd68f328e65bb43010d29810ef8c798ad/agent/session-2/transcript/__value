    43→\\t\\treturn handleLifecycleTurnStart(ag, event)\\n    44→\\tcase agent.TurnEnd:\\n    45→\\t\\treturn handleLifecycleTurnEnd(ag, event)\\n    46→\\tcase agent.Compaction:\\n    47→\\t\\treturn handleLifecycleCompaction(ag, event)\\n    48→\\tcase agent.SessionEnd:\\n    49→\\t\\treturn handleLifecycleSessionEnd(ag, event)\\n    50→\\tcase agent.SubagentStart:\\n    51→\\t\\treturn handleLifecycleSubagentStart(ag, event)\\n    52→\\tcase agent.SubagentEnd:\\n    53→\\t\\treturn handleLifecycleSubagentEnd(ag, event)\\n    54→\\tdefault:\\n    55→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    56→\\t}\\n    57→}\\n    58→\\n    59→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    60→// fires state machine transition.\\n    61→func handleLifecycleSessionStart(ag agent.Agent, event *agent.Event) error {\\n    62→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n    63→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    64→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    65→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    66→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    67→\\t)\\n    68→\\n    69→\\tif event.SessionID == \\\"\\\" {\\n    70→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    71→\\t}\\n    72→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    74→\\t}\\n    75→\\n    76→\\t// Build informational message\\n    77→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    78→\\n    79→\\t// Check for concurrent sessions and append count if any\\n    80→\\tstrat := GetStrategy()\\n    81→\\tif concurrentChecker, ok := strat.(strategy.ConcurrentSessionChecker); ok {\\n    82→\\t\\tif count, err := concurrentChecker.CountOtherActiveSessionsWithCheckpoints(event.SessionID); err == nil && count > 0 {\\n    83→\\t\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    84→\\t\\t}\\n    85→\\t}\\n    86→\\n    87→\\t// Output informational message\\n    88→\\tif event.ResponseMessage != \\\"\\\" {\\n    89→\\t\\tmessage = event.ResponseMessage\\n    90→\\t}\\n    91→\\tif err := outputHookResponse(message); err != nil {\\n    92→\\t\\treturn err\\n    93→\\t}\\n    94→\\n    95→\\t// Fire EventSessionStart for the current session (if state exists).\\n    96→\\tif state, loadErr := strategy.LoadSessionState(event.SessionID); loadErr != nil {\\n    97→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state on start: %v\\\\n\\\", loadErr)\\n    98→\\t} else if state != nil {\\n    99→\\t\\tif transErr := strategy.TransitionAndLog(state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   100→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: session start transition failed: %v\\\\n\\\", transErr)\\n   101→\\t\\t}\\n   102→\\t\\tif saveErr := strategy.SaveSessionState(state); saveErr != nil {\\n   103→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session state on start: %v\\\\n\\\", saveErr)\\n   104→\\t\\t}\\n   105→\\t}\\n   106→\\n   107→\\treturn nil\\n   108→}\\n   109→\\n   110→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   111→// ensures strategy setup, initializes session.\\n   112→func handleLifecycleTurnStart(ag agent.Agent, event *agent.Event) error {\\n   113→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   114→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   115→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   116→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   117→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   118→\\t)\\n   119→\\n   120→\\tsessionID := event.SessionID\\n   121→\\tif sessionID == \\\"\\\" {\\n   122→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   123→\\t}\\n   124→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   125→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   126→\\t}\\n   127→\\n   128→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   129→\\tif err := CapturePrePromptState(ag, sessionID, event.SessionRef); err != nil {\\n   130→\\t\\treturn err\\n   131→\\t}\\n   132→\\n   133→\\t// Ensure strategy setup and initialize session\\n   134→\\tstrat := GetStrategy()\\n   135→\\n   136→\\tif err := strat.EnsureSetup(); err != nil {\\n   137→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to ensure strategy setup: %v\\\\n\\\", err)\\n   138→\\t}\\n   139→\\n   140→\\tif initializer, ok := strat.(strategy.SessionInitializer); ok {\\n   141→\\t\\tagentType := ag.Type()\\n   142→\\t\\tif err := initializer.InitializeSession(sessionID, agentType, event.SessionRef, event.Prompt); err != nil {\\n   143→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to initialize session state: %v\\\\n\\\", err)\\n   144→\\t\\t}\\n   145→\\t}\\n   146→\\n   147→\\treturn nil\\n   148→}\\n   149→\\n   150→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   151→// detects file changes, saves step + checkpoint, transitions phase.\\n   152→//\\n   153→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   154→func handleLifecycleTurnEnd(ag agent.Agent, event *agent.Event) error {\\n   155→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   156→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   157→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   158→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   159→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   160→\\t)\\n   161→\\n   162→\\tsessionID := event.SessionID\\n   163→\\tif sessionID == \\\"\\\" {\\n   164→\\t\\tsessionID = unknownSessionID\\n   165→\\t}\\n   166→\\n   167→\\ttranscriptRef := event.SessionRef\\n   168→\\tif transcriptRef == \\\"\\\" {\\n   169→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   170→\\t}\\n   171→\\tif !fileExists(transcriptRef) {\\n   172→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   173→\\t}\\n   174→\\n   175→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   176→\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n   177→\\t\\tfmt.Fprintln(os.Stderr, \\\"Entire: skipping checkpoint. Will activate after first commit.\\\")\\n   178→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   179→\\t}\\n   180→\\n   181→\\t// Create session metadata directory\\n   182→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   183→\\tsessionDirAbs, err := paths.AbsPath(sessionDir)\\n   184→\\tif err != nil {\\n   185→\\t\\tsessionDirAbs = sessionDir\\n   186→\\t}\\n   187→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   188→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   189→\\t}\\n   190→\\n   191→\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n   192→\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n   193→\\t\\tif err := preparer.PrepareTranscript(transcriptRef); err != nil {\\n   194→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to prepare transcript: %v\\\\n\\\", err)\\n   195→\\t\\t}\\n   196→\\t}\\n   197→\\n   198→\\t// Copy transcript to session directory\\n   199→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   200→\\tif err != nil {\\n   201→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   202→\\t}\\n   203→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   204→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   205→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   206→\\t}\\n   207→\\tfmt.Fprintf(os.Stderr, \\\"Copied transcript to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName)\\n   208→\\n   209→\\t// Load pre-prompt state (captured on TurnStart)\\n   210→\\tpreState, err := LoadPrePromptState(sessionID)\\n   211→\\tif err != nil {\\n   212→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-prompt state: %v\\\\n\\\", err)\\n   213→\\t}\\n   214→\\n   215→\\t// Determine transcript offset\\n   216→\\ttranscriptOffset := resolveTranscriptOffset(preState, sessionID)\\n   217→\\n   218→\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n   219→\\tvar allPrompts []string\\n   220→\\tvar summary string\\n   221→\\tvar modifiedFiles []string\\n   222→\\tvar newTranscriptPosition int\\n   223→\\n   224→\\t// Compute subagents directory for agents that support subagent extraction.\\n   225→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   226→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   227→\\n   228→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   229→\\t\\t// Extract prompts\\n   230→\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n   231→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract prompts: %v\\\\n\\\", promptErr)\\n   232→\\t\\t} else {\\n   233→\\t\\t\\tallPrompts = prompts\\n   234→\\t\\t}\\n   235→\\n   236→\\t\\t// Extract summary\\n   237→\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n   238→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract summary: %v\\\\n\\\", sumErr)\\n   239→\\t\\t} else {\\n   240→\\t\\t\\tsummary = s\\n   241→\\t\\t}\\n   242→\\n   243→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   244→\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n   245→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptRef, transcriptOffset, subagentsDir); fileErr != nil {\\n   246→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files (with subagents): %v\\\\n\\\", fileErr)\\n   247→\\t\\t\\t} else {\\n   248→\\t\\t\\t\\tmodifiedFiles = files\\n   249→\\t\\t\\t}\\n   250→\\t\\t\\t// Get position from basic analyzer\\n   251→\\t\\t\\tif _, pos, posErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); posErr == nil {\\n   252→\\t\\t\\t\\tnewTranscriptPosition = pos\\n   253→\\t\\t\\t}\\n   254→\\t\\t} else {\\n   255→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   256→\\t\\t\\tif files, pos, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   257→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files: %v\\\\n\\\", fileErr)\\n   258→\\t\\t\\t} else {\\n   259→\\t\\t\\t\\tmodifiedFiles = files\\n   260→\\t\\t\\t\\tnewTranscriptPosition = pos\\n   261→\\t\\t\\t}\\n   262→\\t\\t}\\n   263→\\t}\\n   264→\\n   265→\\t// Write prompts file\\n   266→\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   267→\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   268→\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   269→\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   270→\\t}\\n   271→\\tfmt.Fprintf(os.Stderr, \\\"Extracted %d prompt(s) to: %s\\\\n\\\", len(allPrompts), sessionDir+\\\"/\\\"+paths.PromptFileName)\\n   272→\\n   273→\\t// Write summary file\\n   274→\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   275→\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   276→\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   277→\\t}\\n   278→\\tfmt.Fprintf(os.Stderr, \\\"Extracted summary to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName)\\n   279→\\n   280→\\t// Generate commit message from last prompt\\n   281→\\tlastPrompt := \\\"\\\"\\n   282→\\tif len(allPrompts) > 0 {\\n   283→\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   284→\\t}\\n   285→\\tcommitMessage := generateCommitMessage(lastPrompt)\\n   286→\\tfmt.Fprintf(os.Stderr, \\\"Using commit message: %s\\\\n\\\", commitMessage)\\n   287→\\n   288→\\t// Get repo root for path normalization\\n   289→\\trepoRoot, err := paths.RepoRoot()\\n   290→\\tif err != nil {\\n   291→\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   292→\\t}\\n   293→\\n   294→\\tvar preUntrackedFiles []string\\n   295→\\tif preState != nil {\\n   296→\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state: %d pre-existing untracked files\\\\n\\\", len(preState.UntrackedFiles))\\n   297→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   298→\\t}\\n   299→\\n   300→\\t// Detect file changes via git status\\n   301→\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n   302→\\tif err != nil {\\n   303→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   304→\\t}\\n   305→\\n   306→\\t// Filter and normalize all paths\\n   307→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   308→\\tvar relNewFiles, relDeletedFiles []string\\n   309→\\tif changes != nil {\\n   310→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   311→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   312→\\t}\\n   313→\\n   314→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   315→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   316→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   317→\\t// if it exists in HEAD with the same content as the working tree.\\n   318→\\trelModifiedFiles = filterToUncommittedFiles(relModifiedFiles, repoRoot)\\n   319→\\n   320→\\t// Check if there are any changes\\n   321→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   322→\\tif totalChanges == 0 {\\n   323→\\t\\tfmt.Fprintf(os.Stderr, \\\"No files were modified during this session\\\\n\\\")\\n   324→\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipping commit\\\\n\\\")\\n   325→\\t\\ttransitionSessionTurnEnd(sessionID)\\n   326→\\t\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n   327→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   328→\\t\\t}\\n   329→\\t\\treturn nil\\n   330→\\t}\\n   331→\\n   332→\\t// Log file changes\\n   333→\\tlogFileChanges(relModifiedFiles, relNewFiles, relDeletedFiles)\\n   334→\\n   335→\\t// Create context file\\n   336→\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n   337→\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n   338→\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n   339→\\t}\\n   340→\\tfmt.Fprintf(os.Stderr, \\\"Created context file: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.ContextFileName)\\n   341→\\n   342→\\t// Get git author\\n   343→\\tauthor, err := GetGitAuthor()\\n   344→\\tif err != nil {\\n   345→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   346→\\t}\\n   347→\\n   348→\\t// Get strategy and agent type\\n   349→\\tstrat := GetStrategy()\\n   350→\\tagentType := ag.Type()\\n   351→\\n   352→\\t// Get transcript position/identifier from pre-prompt state\\n   353→\\tvar transcriptIdentifierAtStart string\\n   354→\\tvar transcriptLinesAtStart int\\n   355→\\tif preState != nil {\\n   356→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   357→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   358→\\t}\\n   359→\\n   360→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   361→\\tvar tokenUsage *agent.TokenUsage\\n   362→\\tif subagentExtractor, ok := ag.(agent.SubagentAwareExtractor); ok {\\n   363→\\t\\tusage, tokenErr := subagentExtractor.CalculateTotalTokenUsage(transcriptRef, transcriptLinesAtStart, subagentsDir)\\n   364→\\t\\tif tokenErr != nil {\\n   365→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage (with subagents): %v\\\\n\\\", tokenErr)\\n   366→\\t\\t} else {\\n   367→\\t\\t\\ttokenUsage = usage\\n   368→\\t\\t}\\n   369→\\t} else if calculator, ok := ag.(agent.TokenCalculator); ok {\\n   370→\\t\\t// Fall back to basic token calculation (main transcript only)\\n   371→\\t\\tusage, tokenErr := calculator.CalculateTokenUsage(transcriptRef, transcriptLinesAtStart)\\n   372→\\t\\tif tokenErr != nil {\\n   373→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage: %v\\\\n\\\", tokenErr)\\n   374→\\t\\t} else {\\n   375→\\t\\t\\ttokenUsage = usage\\n   376→\\t\\t}\\n   377→\\t}\\n   378→\\n   379→\\t// Build fully-populated step context and delegate to strategy\\n   380→\\tctx := strategy.StepContext{\\n   381→\\t\\tSessionID:                sessionID,\\n   382→\\t\\tModifiedFiles:            relModifiedFiles,\\n   383→\\t\\tNewFiles:                 relNewFiles,\\n   384→\\t\\tDeletedFiles:             relDeletedFiles,\\n   385→\\t\\tMetadataDir:              sessionDir,\\n   386→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   387→\\t\\tCommitMessage:            commitMessage,\\n   388→\\t\\tTranscriptPath:           transcriptRef,\\n   389→\\t\\tAuthorName:               author.Name,\\n   390→\\t\\tAuthorEmail:              author.Email,\\n   391→\\t\\tAgentType:                agentType,\\n   392→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   393→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   394→\\t\\tTokenUsage:               tokenUsage,\\n   395→\\t}\\n   396→\\n   397→\\tif err := strat.SaveStep(ctx); err != nil {\\n   398→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   399→\\t}\\n   400→\\n   401→\\t// Update session state transcript position for auto-commit strategy\\n   402→\\tif strat.Name() == strategy.StrategyNameAutoCommit && newTranscriptPosition > 0 {\\n   403→\\t\\tupdateAutoCommitTranscriptPosition(sessionID, newTranscriptPosition)\\n   404→\\t}\\n   405→\\n   406→\\t// Transition session phase and cleanup\\n   407→\\ttransitionSessionTurnEnd(sessionID)\\n   408→\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n   409→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   410→\\t}\\n   411→\\n   412→\\treturn nil\\n   413→}\\n   414→\\n   415→// handleLifecycleCompaction handles context compaction: saves current progress\\n   416→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   417→// Also resets the transcript offset since the transcript may be truncated.\\n   418→func handleLifecycleCompaction(ag agent.Agent, event *agent.Event) error {\\n   419→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   420→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   421→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   422→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   423→\\t)\\n   424→\\n   425→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   426→\\tsessionID := event.SessionID\\n   427→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   428→\\tif loadErr != nil {\\n   429→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for compaction: %v\\\\n\\\", loadErr)\\n   430→\\t}\\n   431→\\tif sessionState != nil {\\n   432→\\t\\tif transErr := strategy.TransitionAndLog(sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   433→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: compaction transition failed: %v\\\\n\\\", transErr)\\n   434→\\t\\t}\\n   435→\\n   436→\\t\\t// Reset transcript offset since the transcript may be truncated/reorganized\\n   437→\\t\\tsessionState.CheckpointTranscriptStart = 0\\n   438→\\n   439→\\t\\tif saveErr := strategy.SaveSessionState(sessionState); saveErr != nil {\\n   440→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to save session state after compaction: %v\\\\n\\\", saveErr)\\n   441→\\t\\t}\\n   442→\\t}\\n   443→\\n   444→\\tfmt.Fprintf(os.Stderr, \\\"Context compaction: transcript offset reset\\\\n\\\")\\n   445→\\treturn nil\\n   446→}\\n   447→\\n   448→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   449→func handleLifecycleSessionEnd(ag agent.Agent, event *agent.Event) error {\\n   450→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   451→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   452→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   453→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   454→\\t)\\n   455→\\n   456→\\tif event.SessionID == \\\"\\\" {\\n   457→\\t\\treturn nil // No session to update\\n   458→\\t}\\n   459→\\n   460→\\tif err := markSessionEnded(event.SessionID); err != nil {\\n   461→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to mark session ended: %v\\\\n\\\", err)\\n   462→\\t}\\n   463→\\treturn nil\\n   464→}\\n   465→\\n   466→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   467→func handleLifecycleSubagentStart(ag agent.Agent, event *agent.Event) error {\\n   468→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   469→\\tlogging.Info(logCtx, \\\"subagent-start\\\",\\n   470→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   471→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   472→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   473→\\t)\\n   474→\\n   475→\\t// Log context\\n   476→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent started\\\\n\\\")\\n   477→\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n   478→\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n   479→\\tfmt.Fprintf(os.Stderr, \\\"  Transcript: %s\\\\n\\\", event.SessionRef)\\n   480→\\n   481→\\t// Capture pre-task state\\n   482→\\tif err := CapturePreTaskState(event.ToolUseID); err != nil {\\n   483→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   484→\\t}\\n   485→\\n   486→\\treturn nil\\n   487→}\\n   488→\\n   489→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   490→func handleLifecycleSubagentEnd(ag agent.Agent, event *agent.Event) error {\\n   491→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   492→\\tlogging.Info(logCtx, \\\"subagent-end\\\",\\n   493→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   494→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   495→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   496→\\t\\tslog.String(\\\"subagent_id\\\", event.SubagentID),\\n   497→\\t)\\n   498→\\n   499→\\t// Extract subagent type and description from tool input\\n   500→\\tsubagentType, taskDescription := ParseSubagentTypeAndDescription(event.ToolInput)\\n   501→\\n   502→\\t// Determine subagent transcript path\\n   503→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   504→\\tvar subagentTranscriptPath string\\n   505→\\tif event.SubagentID != \\\"\\\" {\\n   506→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   507→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   508→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   509→\\t\\t}\\n   510→\\t}\\n   511→\\n   512→\\t// Log context\\n   513→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent completed\\\\n\\\")\\n   514→\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n   515→\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n   516→\\tif event.SubagentID != \\\"\\\" {\\n   517→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Agent ID: %s\\\\n\\\", event.SubagentID)\\n   518→\\t}\\n   519→\\tif subagentTranscriptPath != \\\"\\\" {\\n   520→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Subagent Transcript: %s\\\\n\\\", subagentTranscriptPath)\\n   521→\\t}\\n   522→\\n   523→\\t// Extract modified files from subagent transcript\\n   524→\\tvar modifiedFiles []string\\n   525→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   526→\\t\\ttranscriptToScan := event.SessionRef\\n   527→\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n   528→\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n   529→\\t\\t}\\n   530→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n   531→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files from subagent: %v\\\\n\\\", fileErr)\\n   532→\\t\\t} else {\\n   533→\\t\\t\\tmodifiedFiles = files\\n   534→\\t\\t}\\n   535→\\t}\\n   536→\\n   537→\\t// Load pre-task state and detect file changes\\n   538→\\tpreState, err := LoadPreTaskState(event.ToolUseID)\\n   539→\\tif err != nil {\\n   540→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-task state: %v\\\\n\\\", err)\\n   541→\\t}\\n   542→\\tvar preUntrackedFiles []string\\n   543→\\tif preState != nil {\\n   544→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   545→\\t}\\n   546→\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n   547→\\tif err != nil {\\n   548→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   549→\\t}\\n   550→\\n   551→\\t// Get repo root and normalize paths\\n   552→\\trepoRoot, err := paths.RepoRoot()\\n   553→\\tif err != nil {\\n   554→\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   555→\\t}\\n   556→\\n   557→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   558→\\tvar relNewFiles, relDeletedFiles []string\\n   559→\\tif changes != nil {\\n   560→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   561→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   562→\\t}\\n   563→\\n   564→\\t// If no changes, skip\\n   565→\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n   566→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] No file changes detected, skipping task checkpoint\\\\n\\\")\\n   567→\\t\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   568→\\t\\treturn nil\\n   569→\\t}\\n   570→\\n   571→\\t// Find checkpoint UUID from main transcript (best-effort)\\n   572→\\tvar checkpointUUID string\\n   573→\\t// Use the existing CLI-level checkpoint UUID finder\\n   574→\\tmainLines, _, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n   575→\\tif mainLines != nil {\\n   576→\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n   577→\\t}\\n   578→\\n   579→\\t// Get git author\\n   580→\\tauthor, err := GetGitAuthor()\\n   581→\\tif err != nil {\\n   582→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   583→\\t}\\n   584→\\n   585→\\t// Build task checkpoint context\\n   586→\\tstrat := GetStrategy()\\n   587→\\tagentType := ag.Type()\\n   588→\\n   589→\\tctx := strategy.TaskStepContext{\\n   590→\\t\\tSessionID:              event.SessionID,\\n   591→\\t\\tToolUseID:              event.ToolUseID,\\n   592→\\t\\tAgentID:                event.SubagentID,\\n   593→\\t\\tModifiedFiles:          relModifiedFiles,\\n   594→\\t\\tNewFiles:               relNewFiles,\\n   595→\\t\\tDeletedFiles:           relDeletedFiles,\\n   596→\\t\\tTranscriptPath:         event.SessionRef,\\n   597→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   598→\\t\\tCheckpointUUID:         checkpointUUID,\\n   599→\\t\\tAuthorName:             author.Name,\\n   600→\\t\\tAuthorEmail:            author.Email,\\n   601→\\t\\tSubagentType:           subagentType,\\n   602→\\t\\tTaskDescription:        taskDescription,\\n   603→\\t\\tAgentType:              agentType,\\n   604→\\t}\\n   605→\\n   606→\\tif err := strat.SaveTaskStep(ctx); err != nil {\\n   607→\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n   608→\\t}\\n   609→\\n   610→\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   611→\\treturn nil\\n   612→}\\n   613→\\n   614→// --- Helper functions ---\\n   615→\\n   616→// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n   617→// Prefers pre-prompt state, falls back to session state.\\n   618→func resolveTranscriptOffset(preState *PrePromptState, sessionID string) int {\\n   619→\\tif preState != nil && preState.TranscriptOffset > 0 {\\n   620→\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state found: parsing transcript from offset %d\\\\n\\\", preState.TranscriptOffset)\\n   621→\\t\\treturn preState.TranscriptOffset\\n   622→\\t}\\n   623→\\n   624→\\t// Fall back to session state (e.g., auto-commit strategy updates it after each save)\\n   625→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   626→\\tif loadErr != nil {\\n   627→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state: %v\\\\n\\\", loadErr)\\n   628→\\t\\treturn 0\\n   629→\\t}\\n   630→\\tif sessionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n   631→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session state found: parsing transcript from offset %d\\\\n\\\", sessionState.CheckpointTranscriptStart)\\n   632→\\t\\treturn sessionState.CheckpointTranscriptStart\\n   633→\\t}\\n   634→\\n   635→\\treturn 0\\n   636→}\\n   637→\\n   638→// updateAutoCommitTranscriptPosition updates the session state with the new transcript position\\n   639→// for the auto-commit strategy.\\n   640→func updateAutoCommitTranscriptPosition(sessionID string, newPosition int) {\\n   641→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   642→\\tif loadErr != nil {\\n   643→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state: %v\\\\n\\\", loadErr)\\n   644→\\t\\treturn\\n   645→\\t}\\n   646→\\tif sessionState == nil {\\n   647→\\t\\tsessionState = &strategy.SessionState{\\n   648→\\t\\t\\tSessionID: sessionID,\\n   649→\\t\\t}\\n   650→\\t}\\n   651→\\tsessionState.CheckpointTranscriptStart = newPosition\\n   652→\\tsessionState.StepCount++\\n   653→\\tif updateErr := strategy.SaveSessionState(sessionState); updateErr != nil {\\n   654→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session state: %v\\\\n\\\", updateErr)\\n   655→\\t} else {\\n   656→\\t\\tfmt.Fprintf(os.Stderr, \\\"Updated session state: transcript position=%d, checkpoint=%d\\\\n\\\",\\n   657→\\t\\t\\tnewPosition, sessionState.StepCount)\\n   658→\\t}\\n   659→}\\n   660→\\n   661→// createContextFile creates a context.md file for the session checkpoint.\\n   662→// This is a unified version that works for all agents.\\n   663→func createContextFile(contextFile, commitMessage, sessionID string, prompts []string, summary string) error {\\n   664→\\tvar sb strings.Builder\\n   665→\\n   666→\\tsb.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   667→\\tfmt.Fprintf(&sb, \\\"Session ID: %s\\\\n\\\", sessionID)\\n   668→\\tfmt.Fprintf(&sb, \\\"Commit Message: %s\\\\n\\\\n\\\", commitMessage)\\n   669→\\n   670→\\tif len(prompts) > 0 {\\n   671→\\t\\tsb.WriteString(\\\"## Prompts\\\\n\\\\n\\\")\\n   672→\\t\\tfor i, p := range prompts {\\n   673→\\t\\t\\tfmt.Fprintf(&sb, \\\"### Prompt %d\\\\n\\\\n%s\\\\n\\\\n\\\", i+1, p)\\n   674→\\t\\t}\\n   675→\\t}\\n   676→\\n   677→\\tif summary != \\\"\\\" {\\n   678→\\t\\tsb.WriteString(\\\"## Summary\\\\n\\\\n\\\")\\n   679→\\t\\tsb.WriteString(summary)\\n   680→\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   681→\\t}\\n   682→\\n   683→\\tif err := os.WriteFile(contextFile, []byte(sb.String()), 0o600); err != nil {\\n   684→\\t\\treturn fmt.Errorf(\\\"failed to write context file: %w\\\", err)\\n   685→\\t}\\n   686→\\treturn nil\\n   687→}\\n   688→\\n   689→// parseTranscriptForCheckpointUUID is a thin wrapper around transcript parsing for checkpoint UUID lookup.\\n   690→// Returns parsed transcript lines for use with FindCheckpointUUID.\\n   691→func parseTranscriptForCheckpointUUID(transcriptPath string) ([]transcriptLine, int, error) {\\n   692→\\tlines, total, err := transcript.ParseFromFileAtLine(transcriptPath, 0)\\n   693→\\tif err != nil {\\n   694→\\t\\treturn nil, 0, fmt.Errorf(\\\"parsing transcript for checkpoint UUID: %w\\\", err)\\n   695→\\t}\\n   696→\\treturn lines, total, nil\\n   697→}\\n   698→\\n   699→// transitionSessionTurnEnd transitions the session phase to IDLE and dispatches turn-end actions.\\n   700→func transitionSessionTurnEnd(sessionID string) {\\n   701→\\tturnState, loadErr := strategy.LoadSessionState(sessionID)\\n   702→\\tif loadErr != nil {\\n   703→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for turn end: %v\\\\n\\\", loadErr)\\n   704→\\t\\treturn\\n   705→\\t}\\n   706→\\tif turnState == nil {\\n   707→\\t\\treturn\\n   708→\\t}\\n   709→\\tif err := strategy.TransitionAndLog(turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   710→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: turn-end transition failed: %v\\\\n\\\", err)\\n   711→\\t}\\n   712→\\n   713→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   714→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   715→\\tstrat := GetStrategy()\\n   716→\\tif handler, ok := strat.(strategy.TurnEndHandler); ok {\\n   717→\\t\\tif err := handler.HandleTurnEnd(turnState); err != nil {\\n   718→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: turn-end action dispatch failed: %v\\\\n\\\", err)\\n   719→\\t\\t}\\n   720→\\t}\\n   721→\\n   722→\\tif updateErr := strategy.SaveSessionState(turnState); updateErr != nil {\\n   723→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session phase on turn end: %v\\\\n\\\", updateErr)\\n   724→\\t}\\n   725→}\\n   726→\\n   727→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   728→func markSessionEnded(sessionID string) error {\\n   729→\\tstate, err := strategy.LoadSessionState(sessionID)\\n   730→\\tif err != nil {\\n   731→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   732→\\t}\\n   733→\\tif state == nil {\\n   734→\\t\\treturn nil // No state file, nothing to update\\n   735→\\t}\\n   736→\\n   737→\\tif transErr := strategy.TransitionAndLog(state, session.EventSessionStop, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   738→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: session stop transition failed: %v\\\\n\\\", transErr)\\n   739→\\t}\\n   740→\\n   741→\\tnow := time.Now()\\n   742→\\tstate.EndedAt = &now\\n   743→\\n   744→\\tif err := strategy.SaveSessionState(state); err != nil {\\n   745→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   746→\\t}\\n   747→\\treturn nil\\n   748→}\\n   749→\\n   750→// logFileChanges logs the files modified, created, and deleted during a session.\\n   751→func logFileChanges(modified, newFiles, deleted []string) {\\n   752→\\tfmt.Fprintf(os.Stderr, \\\"Files modified during session (%d):\\\\n\\\", len(modified))\\n   753→\\tfor _, file := range modified {\\n   754→\\t\\tfmt.Fprintf(os.Stderr, \\\"  - %s\\\\n\\\", file)\\n   755→\\t}\\n   756→\\tif len(newFiles) > 0 {\\n   757→\\t\\tfmt.Fprintf(os.Stderr, \\\"New files created (%d):\\\\n\\\", len(newFiles))\\n   758→\\t\\tfor _, file := range newFiles {\\n   759→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  - %s\\\\n\\\", file)\\n   760→\\t\\t}\\n   761→\\t}\\n   762→\\tif len(deleted) > 0 {\\n   763→\\t\\tfmt.Fprintf(os.Stderr, \\\"Files deleted (%d):\\\\n\\\", len(deleted))\\n   764→\\t\\tfor _, file := range deleted {\\n   765→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  - %s\\\\n\\\", file)\\n   766→\\t\\t}\\n   767→\\t}\\n   768→}\\n   769→\"}]},\"uuid\":\"df00ddfd-d8c1-4a6a-91b0-b5b4a5c8ee36\",\"timestamp\":\"2026-02-19T03:56:56.547Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/gtrrz-victor/wks/cli/cli/cmd/entire/cli/lifecycle.go\",\"content\":\"// lifecycle.go implements the generic lifecycle event dispatcher.\\n// It routes normalized events from any agent to the appropriate framework actions.\\n//\\n// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n// the dispatcher handles all orchestration: state transitions, strategy calls,\\n// file change detection, metadata generation.\\npackage cli\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n)\\n\\n// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n// Returns nil if the event was handled successfully.\\nfunc DispatchLifecycleEvent(ag agent.Agent, event *agent.Event) error {\\n\\tif ag == nil {\\n\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n\\t}\\n\\tif event == nil {\\n\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n\\t}\\n\\n\\tswitch event.Type {\\n\\tcase agent.SessionStart:\\n\\t\\treturn handleLifecycleSessionStart(ag, event)\\n\\tcase agent.TurnStart:\\n\\t\\treturn handleLifecycleTurnStart(ag, event)\\n\\tcase agent.TurnEnd:\\n\\t\\treturn handleLifecycleTurnEnd(ag, event)\\n\\tcase agent.Compaction:\\n\\t\\treturn handleLifecycleCompaction(ag, event)\\n\\tcase agent.SessionEnd:\\n\\t\\treturn handleLifecycleSessionEnd(ag, event)\\n\\tcase agent.SubagentStart:\\n\\t\\treturn handleLifecycleSubagentStart(ag, event)\\n\\tcase agent.SubagentEnd:\\n\\t\\treturn handleLifecycleSubagentEnd(ag, event)\\n\\tdefault:\\n\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n\\t}\\n}\\n\\n// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n// fires state machine transition.\\nfunc handleLifecycleSessionStart(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"session-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Build informational message\\n\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n\\n\\t// Check for concurrent sessions and append count if any\\n\\tstrat := GetStrategy()\\n\\tif concurrentChecker, ok := strat.(strategy.ConcurrentSessionChecker); ok {\\n\\t\\tif count, err := concurrentChecker.CountOtherActiveSessionsWithCheckpoints(event.SessionID); err == nil && count > 0 {\\n\\t\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n\\t\\t}\\n\\t}\\n\\n\\t// Output informational message\\n\\tif event.ResponseMessage != \\\"\\\" {\\n\\t\\tmessage = event.ResponseMessage\\n\\t}\\n\\tif err := outputHookResponse(message); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Fire EventSessionStart for the current session (if state exists).\\n\\tif state, loadErr := strategy.LoadSessionState(event.SessionID); loadErr != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state on start: %v\\\\n\\\", loadErr)\\n\\t} else if state != nil {\\n\\t\\tif transErr := strategy.TransitionAndLog(state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: session start transition failed: %v\\\\n\\\", transErr)\\n\\t\\t}\\n\\t\\tif saveErr := strategy.SaveSessionState(state); saveErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session state on start: %v\\\\n\\\", saveErr)\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n// ensures strategy setup, initializes session.\\nfunc handleLifecycleTurnStart(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n\\tif err := CapturePrePromptState(ag, sessionID, event.SessionRef); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Ensure strategy setup and initialize session\\n\\tstrat := GetStrategy()\\n\\n\\tif err := strat.EnsureSetup(); err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to ensure strategy setup: %v\\\\n\\\", err)\\n\\t}\\n\\n\\tif initializer, ok := strat.(strategy.SessionInitializer); ok {\\n\\t\\tagentType := ag.Type()\\n\\t\\tif err := initializer.InitializeSession(sessionID, agentType, event.SessionRef, event.Prompt); err != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to initialize session state: %v\\\\n\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n// detects file changes, saves step + checkpoint, transitions phase.\\n//\\n//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\nfunc handleLifecycleTurnEnd(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\tsessionID = unknownSessionID\\n\\t}\\n\\n\\ttranscriptRef := event.SessionRef\\n\\tif transcriptRef == \\\"\\\" {\\n\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n\\t}\\n\\tif !fileExists(transcriptRef) {\\n\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n\\t}\\n\\n\\t// Early check: bail out quickly if the repo has no commits yet.\\n\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n\\t\\tfmt.Fprintln(os.Stderr, \\\"Entire: skipping checkpoint. Will activate after first commit.\\\")\\n\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n\\t}\\n\\n\\t// Create session metadata directory\\n\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\tsessionDirAbs, err := paths.AbsPath(sessionDir)\\n\\tif err != nil {\\n\\t\\tsessionDirAbs = sessionDir\\n\\t}\\n\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n\\t}\\n\\n\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n\\t\\tif err := preparer.PrepareTranscript(transcriptRef); err != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to prepare transcript: %v\\\\n\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// Copy transcript to session directory\\n\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n\\t}\\n\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n\\t}\\n\\tfmt.Fprintf(os.Stderr, \\\"Copied transcript to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName)\\n\\n\\t// Load pre-prompt state (captured on TurnStart)\\n\\tpreState, err := LoadPrePromptState(sessionID)\\n\\tif err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-prompt state: %v\\\\n\\\", err)\\n\\t}\\n\\n\\t// Determine transcript offset\\n\\ttranscriptOffset := resolveTranscriptOffset(preState, sessionID)\\n\\n\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n\\tvar allPrompts []string\\n\\tvar summary string\\n\\tvar modifiedFiles []string\\n\\tvar newTranscriptPosition int\\n\\n\\t// Compute subagents directory for agents that support subagent extraction.\\n\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n\\n\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n\\t\\t// Extract prompts\\n\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract prompts: %v\\\\n\\\", promptErr)\\n\\t\\t} else {\\n\\t\\t\\tallPrompts = prompts\\n\\t\\t}\\n\\n\\t\\t// Extract summary\\n\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract summary: %v\\\\n\\\", sumErr)\\n\\t\\t} else {\\n\\t\\t\\tsummary = s\\n\\t\\t}\\n\\n\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptRef, transcriptOffset, subagentsDir); fileErr != nil {\\n\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files (with subagents): %v\\\\n\\\", fileErr)\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t}\\n\\t\\t\\t// Get position from basic analyzer\\n\\t\\t\\tif _, pos, posErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); posErr == nil {\\n\\t\\t\\t\\tnewTranscriptPosition = pos\\n\\t\\t\\t}\\n\\t\\t} else {\\n\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n\\t\\t\\tif files, pos, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files: %v\\\\n\\\", fileErr)\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t\\tnewTranscriptPosition = pos\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write prompts file\\n\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n\\t}\\n\\tfmt.Fprintf(os.Stderr, \\\"Extracted %d prompt(s) to: %s\\\\n\\\", len(allPrompts), sessionDir+\\\"/\\\"+paths.PromptFileName)\\n\\n\\t// Write summary file\\n\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n\\t}\\n\\tfmt.Fprintf(os.Stderr, \\\"Extracted summary to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName)\\n\\n\\t// Generate commit message from last prompt\\n\\tlastPrompt := \\\"\\\"\\n\\tif len(allPrompts) > 0 {\\n\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n\\t}\\n\\tcommitMessage := generateCommitMessage(lastPrompt)\\n\\tfmt.Fprintf(os.Stderr, \\\"Using commit message: %s\\\\n\\\", commitMessage)\\n\\n\\t// Get repo root for path normalization\\n\\trepoRoot, err := paths.RepoRoot()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n\\t}\\n\\n\\tvar preUntrackedFiles []string\\n\\tif preState != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state: %d pre-existing untracked files\\\\n\\\", len(preState.UntrackedFiles))\\n\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n\\t}\\n\\n\\t// Detect file changes via git status\\n\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n\\tif err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n\\t}\\n\\n\\t// Filter and normalize all paths\\n\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n\\tvar relNewFiles, relDeletedFiles []string\\n\\tif changes != nil {\\n\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n\\t}\\n\\n\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n\\t// if it exists in HEAD with the same content as the working tree.\\n\\trelModifiedFiles = filterToUncommittedFiles(relModifiedFiles, repoRoot)\\n\\n\\t// Check if there are any changes\\n\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n\\tif totalChanges == 0 {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"No files were modified during this session\\\\n\\\")\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipping commit\\\\n\\\")\\n\\t\\ttransitionSessionTurnEnd(sessionID)\\n\\t\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Log file changes\\n\\tlogFileChanges(relModifiedFiles, relNewFiles, relDeletedFiles)\\n\\n\\t// Create context file\\n\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n\\t}\\n\\tfmt.Fprintf(os.Stderr, \\\"Created context file: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.ContextFileName)\\n\\n\\t// Get git author\\n\\tauthor, err := GetGitAuthor()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n\\t}\\n\\n\\t// Get strategy and agent type\\n\\tstrat := GetStrategy()\\n\\tagentType := ag.Type()\\n\\n\\t// Get transcript position/identifier from pre-prompt state\\n\\tvar transcriptIdentifierAtStart string\\n\\tvar transcriptLinesAtStart int\\n\\tif preState != nil {\\n\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n\\t}\\n\\n\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n\\tvar tokenUsage *agent.TokenUsage\\n\\tif subagentExtractor, ok := ag.(agent.SubagentAwareExtractor); ok {\\n\\t\\tusage, tokenErr := subagentExtractor.CalculateTotalTokenUsage(transcriptRef, transcriptLinesAtStart, subagentsDir)\\n\\t\\tif tokenErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage (with subagents): %v\\\\n\\\", tokenErr)\\n\\t\\t} else {\\n\\t\\t\\ttokenUsage = usage\\n\\t\\t}\\n\\t} else if calculator, ok := ag.(agent.TokenCalculator); ok {\\n\\t\\t// Fall back to basic token calculation (main transcript only)\\n\\t\\tusage, tokenErr := calculator.CalculateTokenUsage(transcriptRef, transcriptLinesAtStart)\\n\\t\\tif tokenErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage: %v\\\\n\\\", tokenErr)\\n\\t\\t} else {\\n\\t\\t\\ttokenUsage = usage\\n\\t\\t}\\n\\t}\\n\\n\\t// Build fully-populated step context and delegate to strategy\\n\\tctx := strategy.StepContext{\\n\\t\\tSessionID:                sessionID,\\n\\t\\tModifiedFiles:            relModifiedFiles,\\n\\t\\tNewFiles:                 relNewFiles,\\n\\t\\tDeletedFiles:             relDeletedFiles,\\n\\t\\tMetadataDir:              sessionDir,\\n\\t\\tMetadataDirAbs:           sessionDirAbs,\\n\\t\\tCommitMessage:            commitMessage,\\n\\t\\tTranscriptPath:           transcriptRef,\\n\\t\\tAuthorName:               author.Name,\\n\\t\\tAuthorEmail:              author.Email,\\n\\t\\tAgentType:                agentType,\\n\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n\\t\\tTokenUsage:               tokenUsage,\\n\\t}\\n\\n\\tif err := strat.SaveStep(ctx); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n\\t}\\n\\n\\t// Update session state transcript position for auto-commit strategy\\n\\tif strat.Name() == strategy.StrategyNameAutoCommit && newTranscriptPosition > 0 {\\n\\t\\tupdateAutoCommitTranscriptPosition(sessionID, newTranscriptPosition)\\n\\t}\\n\\n\\t// Transition session phase and cleanup\\n\\ttransitionSessionTurnEnd(sessionID)\\n\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleCompaction handles context compaction: saves current progress\\n// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n// Also resets the transcript offset since the transcript may be truncated.\\nfunc handleLifecycleCompaction(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"compaction\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t)\\n\\n\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n\\tsessionID := event.SessionID\\n\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n\\tif loadErr != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for compaction: %v\\\\n\\\", loadErr)\\n\\t}\\n\\tif sessionState != nil {\\n\\t\\tif transErr := strategy.TransitionAndLog(sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: compaction transition failed: %v\\\\n\\\", transErr)\\n\\t\\t}\\n\\n\\t\\t// Reset transcript offset since the transcript may be truncated/reorganized\\n\\t\\tsessionState.CheckpointTranscriptStart = 0\\n\\n\\t\\tif saveErr := strategy.SaveSessionState(sessionState); saveErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to save session state after compaction: %v\\\\n\\\", saveErr)\\n\\t\\t}\\n\\t}\\n\\n\\tfmt.Fprintf(os.Stderr, \\\"Context compaction: transcript offset reset\\\\n\\\")\\n\\treturn nil\\n}\\n\\n// handleLifecycleSessionEnd handles session end: marks the session as ended.\\nfunc handleLifecycleSessionEnd(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"session-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" {\\n\\t\\treturn nil // No session to update\\n\\t}\\n\\n\\tif err := markSessionEnded(event.SessionID); err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to mark session ended: %v\\\\n\\\", err)\\n\\t}