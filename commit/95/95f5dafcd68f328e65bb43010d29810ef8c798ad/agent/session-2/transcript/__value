51→// Returns true for yes, false for no. If TTY is unavailable, returns the default.\\n    52→// If context is non-empty, it is displayed on a separate line before the prompt.\\n    53→func askConfirmTTY(prompt string, context string, defaultYes bool) bool {\\n    54→\\t// In test mode, don't try to interact with the real TTY — just use the default.\\n    55→\\t// ENTIRE_TEST_TTY=1 simulates \\\"a human is present\\\" for the hasTTY() check\\n    56→\\t// but we can't actually read from the TTY in tests.\\n    57→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n    58→\\t\\treturn defaultYes\\n    59→\\t}\\n    60→\\n    61→\\t// Open /dev/tty for both reading and writing\\n    62→\\t// This is the controlling terminal, which works even when stdin/stderr are redirected\\n    63→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n    64→\\tif err != nil {\\n    65→\\t\\t// Can't open TTY (e.g., running in CI), use default\\n    66→\\t\\treturn defaultYes\\n    67→\\t}\\n    68→\\tdefer tty.Close()\\n    69→\\n    70→\\t// Show context if provided\\n    71→\\tif context != \\\"\\\" {\\n    72→\\t\\tfmt.Fprintf(tty, \\\"%s\\\\n\\\", context)\\n    73→\\t}\\n    74→\\n    75→\\t// Show prompt with default indicator\\n    76→\\t// Write to tty directly, not stderr, since git hooks may redirect stderr to /dev/null\\n    77→\\tvar hint string\\n    78→\\tif defaultYes {\\n    79→\\t\\thint = \\\"[Y/n]\\\"\\n    80→\\t} else {\\n    81→\\t\\thint = \\\"[y/N]\\\"\\n    82→\\t}\\n    83→\\tfmt.Fprintf(tty, \\\"%s %s \\\", prompt, hint)\\n    84→\\n    85→\\t// Read response\\n    86→\\treader := bufio.NewReader(tty)\\n    87→\\tresponse, err := reader.ReadString('\\\\n')\\n    88→\\tif err != nil {\\n    89→\\t\\treturn defaultYes\\n    90→\\t}\\n    91→\\n    92→\\tresponse = strings.TrimSpace(strings.ToLower(response))\\n    93→\\tswitch response {\\n    94→\\tcase \\\"y\\\", \\\"yes\\\":\\n    95→\\t\\treturn true\\n    96→\\tcase \\\"n\\\", \\\"no\\\":\\n    97→\\t\\treturn false\\n    98→\\tdefault:\\n    99→\\t\\t// Empty or invalid input - use default\\n   100→\\t\\treturn defaultYes\\n   101→\\t}\\n   102→}\\n   103→\\n   104→// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   105→// If the message contains only our trailer (no actual user content), strip it\\n   106→// so git will abort the commit due to empty message.\\n   107→//\\n   108→//nolint:unparam // error return required by interface but hooks must return nil\\n   109→func (s *ManualCommitStrategy) CommitMsg(commitMsgFile string) error {\\n   110→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n   111→\\tif err != nil {\\n   112→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   113→\\t}\\n   114→\\n   115→\\tmessage := string(content)\\n   116→\\n   117→\\t// Check if our trailer is present (ParseCheckpoint validates format, so found==true means valid)\\n   118→\\tif _, found := trailers.ParseCheckpoint(message); !found {\\n   119→\\t\\t// No trailer, nothing to do\\n   120→\\t\\treturn nil\\n   121→\\t}\\n   122→\\n   123→\\t// Check if there's any user content (non-comment, non-trailer lines)\\n   124→\\tif !hasUserContent(message) {\\n   125→\\t\\t// No user content - strip the trailer so git aborts\\n   126→\\t\\tmessage = stripCheckpointTrailer(message)\\n   127→\\t\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   128→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   129→\\t\\t}\\n   130→\\t}\\n   131→\\n   132→\\treturn nil\\n   133→}\\n   134→\\n   135→// hasUserContent checks if the message has any content besides comments and our trailer.\\n   136→func hasUserContent(message string) bool {\\n   137→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   138→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   139→\\t\\ttrimmed := strings.TrimSpace(line)\\n   140→\\t\\t// Skip empty lines\\n   141→\\t\\tif trimmed == \\\"\\\" {\\n   142→\\t\\t\\tcontinue\\n   143→\\t\\t}\\n   144→\\t\\t// Skip comment lines\\n   145→\\t\\tif strings.HasPrefix(trimmed, \\\"#\\\") {\\n   146→\\t\\t\\tcontinue\\n   147→\\t\\t}\\n   148→\\t\\t// Skip our trailer line\\n   149→\\t\\tif strings.HasPrefix(trimmed, trailerPrefix) {\\n   150→\\t\\t\\tcontinue\\n   151→\\t\\t}\\n   152→\\t\\t// Found user content\\n   153→\\t\\treturn true\\n   154→\\t}\\n   155→\\treturn false\\n   156→}\\n   157→\\n   158→// stripCheckpointTrailer removes the Entire-Checkpoint trailer line from the message.\\n   159→func stripCheckpointTrailer(message string) string {\\n   160→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   161→\\tvar result []string\\n   162→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   163→\\t\\tif !strings.HasPrefix(strings.TrimSpace(line), trailerPrefix) {\\n   164→\\t\\t\\tresult = append(result, line)\\n   165→\\t\\t}\\n   166→\\t}\\n   167→\\treturn strings.Join(result, \\\"\\\\n\\\")\\n   168→}\\n   169→\\n   170→// isGitSequenceOperation checks if git is currently in the middle of a rebase,\\n   171→// cherry-pick, or revert operation. During these operations, commits are being\\n   172→// replayed and should not be linked to agent sessions.\\n   173→//\\n   174→// Detects:\\n   175→//   - rebase: .git/rebase-merge/ or .git/rebase-apply/ directories\\n   176→//   - cherry-pick: .git/CHERRY_PICK_HEAD file\\n   177→//   - revert: .git/REVERT_HEAD file\\n   178→func isGitSequenceOperation() bool {\\n   179→\\t// Get git directory (handles worktrees and relative paths correctly)\\n   180→\\tgitDir, err := GetGitDir()\\n   181→\\tif err != nil {\\n   182→\\t\\treturn false // Can't determine, assume not in sequence operation\\n   183→\\t}\\n   184→\\n   185→\\t// Check for rebase state directories\\n   186→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-merge\\\")); err == nil {\\n   187→\\t\\treturn true\\n   188→\\t}\\n   189→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-apply\\\")); err == nil {\\n   190→\\t\\treturn true\\n   191→\\t}\\n   192→\\n   193→\\t// Check for cherry-pick and revert state files\\n   194→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"CHERRY_PICK_HEAD\\\")); err == nil {\\n   195→\\t\\treturn true\\n   196→\\t}\\n   197→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"REVERT_HEAD\\\")); err == nil {\\n   198→\\t\\treturn true\\n   199→\\t}\\n   200→\\n   201→\\treturn false\\n   202→}\\n   203→\\n   204→// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   205→// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   206→// Only adds a trailer if there's actually new session content to condense.\\n   207→// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   208→// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   209→// For amended commits, preserves the existing checkpoint ID.\\n   210→//\\n   211→// The source parameter indicates how the commit was initiated:\\n   212→//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   213→//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   214→//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   215→//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   216→//\\n   217→\\n   218→func (s *ManualCommitStrategy) PrepareCommitMsg(commitMsgFile string, source string) error {\\n   219→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   220→\\n   221→\\t// Skip during rebase, cherry-pick, or revert operations\\n   222→\\t// These are replaying existing commits and should not be linked to agent sessions\\n   223→\\tif isGitSequenceOperation() {\\n   224→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n   225→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   226→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   227→\\t\\t)\\n   228→\\t\\treturn nil\\n   229→\\t}\\n   230→\\n   231→\\t// Skip for merge and squash sources\\n   232→\\t// These are auto-generated messages - not from Claude sessions\\n   233→\\tswitch source {\\n   234→\\tcase \\\"merge\\\", \\\"squash\\\":\\n   235→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n   236→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   237→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   238→\\t\\t)\\n   239→\\t\\treturn nil\\n   240→\\t}\\n   241→\\n   242→\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   243→\\tif source == \\\"commit\\\" {\\n   244→\\t\\treturn s.handleAmendCommitMsg(logCtx, commitMsgFile)\\n   245→\\t}\\n   246→\\n   247→\\trepo, err := OpenRepository()\\n   248→\\tif err != nil {\\n   249→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   250→\\t}\\n   251→\\n   252→\\tworktreePath, err := GetWorktreePath()\\n   253→\\tif err != nil {\\n   254→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   255→\\t}\\n   256→\\n   257→\\t// Find all active sessions for this worktree\\n   258→\\t// We match by worktree (not BaseCommit) because the user may have made\\n   259→\\t// intermediate commits without entering new prompts, causing HEAD to diverge\\n   260→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   261→\\tif err != nil || len(sessions) == 0 {\\n   262→\\t\\t// No active sessions or error listing - silently skip (hooks must be resilient)\\n   263→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no active sessions\\\",\\n   264→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   265→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   266→\\t\\t)\\n   267→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   268→\\t}\\n   269→\\n   270→\\t// Fast path: when an agent is committing (ACTIVE session + no TTY), skip\\n   271→\\t// content detection and interactive prompts. The agent can't respond to TTY\\n   272→\\t// prompts and the content detection can miss mid-session work (no shadow\\n   273→\\t// branch yet, transcript analysis may fail). Generate a checkpoint ID and\\n   274→\\t// add the trailer directly.\\n   275→\\tif !hasTTY() {\\n   276→\\t\\tfor _, state := range sessions {\\n   277→\\t\\t\\tif state.Phase.IsActive() {\\n   278→\\t\\t\\t\\treturn s.addTrailerForAgentCommit(logCtx, commitMsgFile, state, source)\\n   279→\\t\\t\\t}\\n   280→\\t\\t}\\n   281→\\t}\\n   282→\\n   283→\\t// Check if any session has new content to condense\\n   284→\\tsessionsWithContent := s.filterSessionsWithNewContent(repo, sessions)\\n   285→\\n   286→\\tif len(sessionsWithContent) == 0 {\\n   287→\\t\\t// No new content — no trailer needed\\n   288→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no content to link\\\",\\n   289→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   290→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   291→\\t\\t\\tslog.Int(\\\"sessions_found\\\", len(sessions)),\\n   292→\\t\\t)\\n   293→\\t\\treturn nil\\n   294→\\t}\\n   295→\\n   296→\\t// Read current commit message\\n   297→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   298→\\tif err != nil {\\n   299→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   300→\\t}\\n   301→\\n   302→\\tmessage := string(content)\\n   303→\\n   304→\\t// Check if trailer already exists (ParseCheckpoint validates format, so found==true means valid)\\n   305→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   306→\\t\\t// Trailer already exists (e.g., amend) - keep it\\n   307→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: trailer already exists\\\",\\n   308→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   309→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   310→\\t\\t\\tslog.String(\\\"existing_checkpoint_id\\\", existingCpID.String()),\\n   311→\\t\\t)\\n   312→\\t\\treturn nil\\n   313→\\t}\\n   314→\\n   315→\\t// Generate a fresh checkpoint ID\\n   316→\\tcheckpointID, err := id.Generate()\\n   317→\\tif err != nil {\\n   318→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   319→\\t}\\n   320→\\n   321→\\t// Determine agent type and last prompt from session\\n   322→\\tagentType := DefaultAgentType // default for backward compatibility\\n   323→\\tvar lastPrompt string\\n   324→\\tif len(sessionsWithContent) > 0 {\\n   325→\\t\\tfirstSession := sessionsWithContent[0]\\n   326→\\t\\tif firstSession.AgentType != \\\"\\\" {\\n   327→\\t\\t\\tagentType = firstSession.AgentType\\n   328→\\t\\t}\\n   329→\\t\\tlastPrompt = s.getLastPrompt(repo, firstSession)\\n   330→\\t}\\n   331→\\n   332→\\t// Prepare prompt for display: collapse newlines/whitespace, then truncate (rune-safe)\\n   333→\\tdisplayPrompt := stringutil.TruncateRunes(stringutil.CollapseWhitespace(lastPrompt), 80, \\\"...\\\")\\n   334→\\n   335→\\t// Add trailer differently based on commit source\\n   336→\\tswitch source {\\n   337→\\tcase \\\"message\\\":\\n   338→\\t\\t// Using -m or -F: ask user interactively whether to add trailer\\n   339→\\t\\t// (comments won't be stripped by git in this mode)\\n   340→\\n   341→\\t\\t// Build context string for interactive prompt\\n   342→\\t\\tvar promptContext string\\n   343→\\t\\tif displayPrompt != \\\"\\\" {\\n   344→\\t\\t\\tpromptContext = \\\"You have an active \\\" + string(agentType) + \\\" session.\\\\nLast Prompt: \\\" + displayPrompt\\n   345→\\t\\t}\\n   346→\\n   347→\\t\\tif !askConfirmTTY(\\\"Link this commit to \\\"+string(agentType)+\\\" session context?\\\", promptContext, true) {\\n   348→\\t\\t\\t// User declined - don't add trailer\\n   349→\\t\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: user declined trailer\\\",\\n   350→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   351→\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n   352→\\t\\t\\t)\\n   353→\\t\\t\\treturn nil\\n   354→\\t\\t}\\n   355→\\t\\tmessage = addCheckpointTrailer(message, checkpointID)\\n   356→\\tdefault:\\n   357→\\t\\t// Normal editor flow: add trailer with explanatory comment (will be stripped by git)\\n   358→\\t\\tmessage = addCheckpointTrailerWithComment(message, checkpointID, string(agentType), displayPrompt)\\n   359→\\t}\\n   360→\\n   361→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: trailer added\\\",\\n   362→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   363→\\t\\tslog.String(\\\"source\\\", source),\\n   364→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   365→\\t)\\n   366→\\n   367→\\t// Write updated message back\\n   368→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   369→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   370→\\t}\\n   371→\\n   372→\\treturn nil\\n   373→}\\n   374→\\n   375→// handleAmendCommitMsg handles the prepare-commit-msg hook for amend operations\\n   376→// (source=\\\"commit\\\"). It preserves existing trailers or restores from LastCheckpointID.\\n   377→func (s *ManualCommitStrategy) handleAmendCommitMsg(logCtx context.Context, commitMsgFile string) error {\\n   378→\\t// Read current commit message\\n   379→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   380→\\tif err != nil {\\n   381→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   382→\\t}\\n   383→\\n   384→\\tmessage := string(content)\\n   385→\\n   386→\\t// If message already has a trailer, keep it unchanged\\n   387→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   388→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend preserves existing trailer\\\",\\n   389→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   390→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", existingCpID.String()),\\n   391→\\t\\t)\\n   392→\\t\\treturn nil\\n   393→\\t}\\n   394→\\n   395→\\t// No trailer in message — check if any session has LastCheckpointID to restore\\n   396→\\tworktreePath, err := GetWorktreePath()\\n   397→\\tif err != nil {\\n   398→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   399→\\t}\\n   400→\\n   401→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   402→\\tif err != nil || len(sessions) == 0 {\\n   403→\\t\\treturn nil //nolint:nilerr // No sessions - nothing to restore\\n   404→\\t}\\n   405→\\n   406→\\t// For amend, HEAD^ is the commit being amended, and HEAD is where we are now.\\n   407→\\t// We need to match sessions whose BaseCommit equals HEAD (the commit being amended\\n   408→\\t// was created from this base). This prevents stale sessions from injecting\\n   409→\\t// unrelated checkpoint IDs.\\n   410→\\trepo, repoErr := OpenRepository()\\n   411→\\tif repoErr != nil {\\n   412→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   413→\\t}\\n   414→\\thead, headErr := repo.Head()\\n   415→\\tif headErr != nil {\\n   416→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   417→\\t}\\n   418→\\tcurrentHead := head.Hash().String()\\n   419→\\n   420→\\t// Find first matching session with LastCheckpointID to restore.\\n   421→\\t// LastCheckpointID is set after condensation completes.\\n   422→\\tfor _, state := range sessions {\\n   423→\\t\\tif state.BaseCommit != currentHead {\\n   424→\\t\\t\\tcontinue\\n   425→\\t\\t}\\n   426→\\t\\tif state.LastCheckpointID.IsEmpty() {\\n   427→\\t\\t\\tcontinue\\n   428→\\t\\t}\\n   429→\\t\\tcpID := state.LastCheckpointID\\n   430→\\t\\tsource := \\\"LastCheckpointID\\\"\\n   431→\\n   432→\\t\\t// Restore the trailer\\n   433→\\t\\tmessage = addCheckpointTrailer(message, cpID)\\n   434→\\t\\tif writeErr := os.WriteFile(commitMsgFile, []byte(message), 0o600); writeErr != nil {\\n   435→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   436→\\t\\t}\\n   437→\\n   438→\\t\\tlogging.Info(logCtx, \\\"prepare-commit-msg: restored trailer on amend\\\",\\n   439→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   440→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   441→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   442→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   443→\\t\\t)\\n   444→\\t\\treturn nil\\n   445→\\t}\\n   446→\\n   447→\\t// No checkpoint ID found - leave message unchanged\\n   448→\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend with no checkpoint to restore\\\",\\n   449→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   450→\\t)\\n   451→\\treturn nil\\n   452→}\\n   453→\\n   454→// PostCommit is called by the git post-commit hook after a commit is created.\\n   455→// Uses the session state machine to determine what action to take per session:\\n   456→//   - ACTIVE → condense immediately (each commit gets its own checkpoint)\\n   457→//   - IDLE → condense immediately\\n   458→//   - ENDED → condense if files touched, discard if empty\\n   459→//\\n   460→// After condensation for ACTIVE sessions, remaining uncommitted files are\\n   461→// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n   462→//\\n   463→// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n   464→// and were condensed during this PostCommit.\\n   465→\\n   466→// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n   467→// Each session in the loop gets its own handler with per-session context.\\n   468→// Handler methods use the *State parameter from ApplyTransition (same pointer\\n   469→// as the state being transitioned) rather than capturing state separately.\\n   470→type postCommitActionHandler struct {\\n   471→\\ts                      *ManualCommitStrategy\\n   472→\\tlogCtx                 context.Context\\n   473→\\trepo                   *git.Repository\\n   474→\\tcheckpointID           id.CheckpointID\\n   475→\\thead                   *plumbing.Reference\\n   476→\\tcommit                 *object.Commit\\n   477→\\tnewHead                string\\n   478→\\tshadowBranchName       string\\n   479→\\tshadowBranchesToDelete map[string]struct{}\\n   480→\\tcommittedFileSet       map[string]struct{}\\n   481→\\thasNew                 bool\\n   482→\\n   483→\\t// Output: set by handler methods, read by caller after TransitionAndLog.\\n   484→\\tcondensed bool\\n   485→}\\n   486→\\n   487→func (h *postCommitActionHandler) HandleCondense(state *session.State) error {\\n   488→\\t// For ACTIVE sessions, any commit during the turn is session-related.\\n   489→\\t// For IDLE/ENDED sessions (e.g., carry-forward), also require that the\\n   490→\\t// committed files overlap with the session's remaining files AND have\\n   491→\\t// matching content — otherwise an unrelated commit (or a commit with\\n   492→\\t// completely replaced content) would incorrectly get this session's checkpoint.\\n   493→\\tshouldCondense := h.hasNew\\n   494→\\tif shouldCondense && !state.Phase.IsActive() {\\n   495→\\t\\tshouldCondense = filesOverlapWithContent(h.repo, h.shadowBranchName, h.commit, state.FilesTouched)\\n   496→\\t}\\n   497→\\n   498→\\tlogging.Debug(h.logCtx, \\\"post-commit: HandleCondense decision\\\",\\n   499→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   500→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   501→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   502→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   503→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   504→\\t)\\n   505→\\n   506→\\tif shouldCondense {\\n   507→\\t\\th.condensed = h.s.condenseAndUpdateState(h.logCtx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet)\\n   508→\\t} else {\\n   509→\\t\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n   510→\\t}\\n   511→\\treturn nil\\n   512→}\\n   513→\\n   514→func (h *postCommitActionHandler) HandleCondenseIfFilesTouched(state *session.State) error {\\n   515→\\tshouldCondense := len(state.FilesTouched) > 0 && h.hasNew\\n   516→\\n   517→\\tlogging.Debug(h.logCtx, \\\"post-commit: HandleCondenseIfFilesTouched decision\\\",\\n   518→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   519→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   520→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   521→\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n   522→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   523→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   524→\\t)\\n   525→\\n   526→\\tif shouldCondense {\\n   527→\\t\\th.condensed = h.s.condenseAndUpdateState(h.logCtx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet)\\n   528→\\t} else {\\n   529→\\t\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n   530→\\t}\\n   531→\\treturn nil\\n   532→}\\n   533→\\n   534→func (h *postCommitActionHandler) HandleDiscardIfNoFiles(state *session.State) error {\\n   535→\\tif len(state.FilesTouched) == 0 {\\n   536→\\t\\tlogging.Debug(h.logCtx, \\\"post-commit: skipping empty ended session (no files to condense)\\\",\\n   537→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   538→\\t\\t)\\n   539→\\t}\\n   540→\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n   541→\\treturn nil\\n   542→}\\n   543→\\n   544→func (h *postCommitActionHandler) HandleWarnStaleSession(_ *session.State) error {\\n   545→\\t// Not produced by EventGitCommit; no-op for exhaustiveness.\\n   546→\\treturn nil\\n   547→}\\n   548→\\n   549→// During rebase/cherry-pick/revert operations, phase transitions are skipped entirely.\\n   550→//\\n   551→//nolint:unparam // error return required by interface but hooks must return nil\\n   552→func (s *ManualCommitStrategy) PostCommit() error {\\n   553→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   554→\\n   555→\\trepo, err := OpenRepository()\\n   556→\\tif err != nil {\\n   557→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   558→\\t}\\n   559→\\n   560→\\t// Get HEAD commit to check for trailer\\n   561→\\thead, err := repo.Head()\\n   562→\\tif err != nil {\\n   563→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   564→\\t}\\n   565→\\n   566→\\tcommit, err := repo.CommitObject(head.Hash())\\n   567→\\tif err != nil {\\n   568→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   569→\\t}\\n   570→\\n   571→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   572→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   573→\\tif !found {\\n   574→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   575→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   576→\\t\\ts.postCommitUpdateBaseCommitOnly(logCtx, head)\\n   577→\\t\\treturn nil\\n   578→\\t}\\n   579→\\n   580→\\tworktreePath, err := GetWorktreePath()\\n   581→\\tif err != nil {\\n   582→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   583→\\t}\\n   584→\\n   585→\\t// Find all active sessions for this worktree\\n   586→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   587→\\tif err != nil || len(sessions) == 0 {\\n   588→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   589→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   590→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   591→\\t\\t)\\n   592→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   593→\\t}\\n   594→\\n   595→\\t// Build transition context\\n   596→\\tisRebase := isGitSequenceOperation()\\n   597→\\ttransitionCtx := session.TransitionContext{\\n   598→\\t\\tIsRebaseInProgress: isRebase,\\n   599→\\t}\\n   600→\\n   601→\\tif isRebase {\\n   602→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   603→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   604→\\t\\t)\\n   605→\\t}\\n   606→\\n   607→\\t// Track shadow branch names and whether they can be deleted\\n   608→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   609→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   610→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   611→\\n   612→\\tnewHead := head.Hash().String()\\n   613→\\tcommittedFileSet := filesChangedInCommit(commit)\\n   614→\\n   615→\\tfor _, state := range sessions {\\n   616→\\t\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   617→\\n   618→\\t\\t// Check for new content (needed for TransitionContext and condensation).\\n   619→\\t\\t// Fail-open: if content check errors, assume new content exists so we\\n   620→\\t\\t// don't silently skip data that should have been condensed.\\n   621→\\t\\t//\\n   622→\\t\\t// For ACTIVE sessions: the commit has a checkpoint trailer (verified above),\\n   623→\\t\\t// meaning PrepareCommitMsg already determined this commit is session-related.\\n   624→\\t\\t// The trailer is only added when either:\\n   625→\\t\\t//   - No TTY (agent/subagent committing) — added unconditionally\\n   626→\\t\\t//   - TTY (human committing) — added after content detection confirmed agent work\\n   627→\\t\\t// In both cases, PrepareCommitMsg already validated this commit. We trust\\n   628→\\t\\t// that decision here. Transcript-based re-validation is unreliable because\\n   629→\\t\\t// subagent transcripts may not be available yet (subagent still running).\\n   630→\\t\\tvar hasNew bool\\n   631→\\t\\tif state.Phase.IsActive() {\\n   632→\\t\\t\\thasNew = true\\n   633→\\t\\t} else {\\n   634→\\t\\t\\tvar contentErr error\\n   635→\\t\\t\\thasNew, contentErr = s.sessionHasNewContent(repo, state)\\n   636→\\t\\t\\tif contentErr != nil {\\n   637→\\t\\t\\t\\thasNew = true\\n   638→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: error checking session content, assuming new content\\\",\\n   639→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   640→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", contentErr.Error()),\\n   641→\\t\\t\\t\\t)\\n   642→\\t\\t\\t}\\n   643→\\t\\t}\\n   644→\\t\\ttransitionCtx.HasFilesTouched = len(state.FilesTouched) > 0\\n   645→\\n   646→\\t\\t// Save FilesTouched BEFORE TransitionAndLog — the handler's condensation\\n   647→\\t\\t// clears it, but we need the original list for carry-forward computation.\\n   648→\\t\\t// For mid-session commits (ACTIVE, no shadow branch), state.FilesTouched may be empty\\n   649→\\t\\t// because no SaveStep/Stop has been called yet. Extract files from transcript.\\n   650→\\t\\tfilesTouchedBefore := make([]string, len(state.FilesTouched))\\n   651→\\t\\tcopy(filesTouchedBefore, state.FilesTouched)\\n   652→\\t\\tif len(filesTouchedBefore) == 0 && state.Phase.IsActive() && state.TranscriptPath != \\\"\\\" {\\n   653→\\t\\t\\tfilesTouchedBefore = s.extractFilesFromLiveTranscript(state)\\n   654→\\t\\t}\\n   655→\\n   656→\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward prep\\\",\\n   657→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   658→\\t\\t\\tslog.Bool(\\\"is_active\\\", state.Phase.IsActive()),\\n   659→\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n   660→\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   661→\\t\\t\\tslog.Any(\\\"files\\\", filesTouchedBefore),\\n   662→\\t\\t)\\n   663→\\n   664→\\t\\t// Run the state machine transition with handler for strategy-specific actions.\\n   665→\\t\\thandler := &postCommitActionHandler{\\n   666→\\t\\t\\ts:                      s,\\n   667→\\t\\t\\tlogCtx:                 logCtx,\\n   668→\\t\\t\\trepo:                   repo,\\n   669→\\t\\t\\tcheckpointID:           checkpointID,\\n   670→\\t\\t\\thead:                   head,\\n   671→\\t\\t\\tcommit:                 commit,\\n   672→\\t\\t\\tnewHead:                newHead,\\n   673→\\t\\t\\tshadowBranchName:       shadowBranchName,\\n   674→\\t\\t\\tshadowBranchesToDelete: shadowBranchesToDelete,\\n   675→\\t\\t\\tcommittedFileSet:       committedFileSet,\\n   676→\\t\\t\\thasNew:                 hasNew,\\n   677→\\t\\t}\\n   678→\\n   679→\\t\\tif err := TransitionAndLog(state, session.EventGitCommit, transitionCtx, handler); err != nil {\\n   680→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: post-commit action handler error: %v\\\\n\\\", err)\\n   681→\\t\\t}\\n   682→\\n   683→\\t\\t// Record checkpoint ID for ACTIVE sessions so HandleTurnEnd can finalize\\n   684→\\t\\t// with full transcript. IDLE/ENDED sessions already have complete transcripts.\\n   685→\\t\\t// NOTE: This check runs AFTER TransitionAndLog updated the phase. It relies on\\n   686→\\t\\t// ACTIVE + GitCommit → ACTIVE (phase stays ACTIVE). If that state machine\\n   687→\\t\\t// transition ever changed, this guard would silently stop recording IDs.\\n   688→\\t\\tif handler.condensed && state.Phase.IsActive() {\\n   689→\\t\\t\\tstate.TurnCheckpointIDs = append(state.TurnCheckpointIDs, checkpointID.String())\\n   690→\\t\\t}\\n   691→\\n   692→\\t\\t// Carry forward remaining uncommitted files so the next commit gets its\\n   693→\\t\\t// own checkpoint ID. This applies to ALL phases — if a user splits their\\n   694→\\t\\t// commit across two `git commit` invocations, each gets a 1:1 checkpoint.\\n   695→\\t\\t// Uses content-aware comparison: if user did `git add -p` and committed\\n   696→\\t\\t// partial changes, the file still has remaining agent changes to carry forward.\\n   697→\\t\\tif handler.condensed {\\n   698→\\t\\t\\tremainingFiles := filesWithRemainingAgentChanges(repo, shadowBranchName, commit, filesTouchedBefore, committedFileSet)\\n   699→\\t\\t\\tstate.FilesTouched = remainingFiles\\n   700→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward decision (content-aware)\\\",\\n   701→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   702→\\t\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   703→\\t\\t\\t\\tslog.Int(\\\"committed_files\\\", len(committedFileSet)),\\n   704→\\t\\t\\t\\tslog.Int(\\\"remaining_files\\\", len(remainingFiles)),\\n   705→\\t\\t\\t\\tslog.Any(\\\"remaining\\\", remainingFiles),\\n   706→\\t\\t\\t\\tslog.Any(\\\"committed_files\\\", committedFileSet),\\n   707→\\t\\t\\t)\\n   708→\\t\\t\\tif len(remainingFiles) > 0 {\\n   709→\\t\\t\\t\\ts.carryForwardToNewShadowBranch(logCtx, repo, state, remainingFiles)\\n   710→\\t\\t\\t}\\n   711→\\t\\t}\\n   712→\\n   713→\\t\\t// Save the updated state\\n   714→\\t\\tif err := s.saveSessionState(state); err != nil {\\n   715→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to update session state: %v\\\\n\\\", err)\\n   716→\\t\\t}\\n   717→\\n   718→\\t\\t// Only preserve shadow branch for active sessions that were NOT condensed.\\n   719→\\t\\t// Condensed sessions already have their data on entire/checkpoints/v1.\\n   720→\\t\\tif state.Phase.IsActive() && !handler.condensed {\\n   721→\\t\\t\\tuncondensedActiveOnBranch[shadowBranchName] = true\\n   722→\\t\\t}\\n   723→\\t}\\n   724→\\n   725→\\t// Clean up shadow branches — only delete when ALL sessions on the branch are non-active\\n   726→\\t// or were condensed during this PostCommit.\\n   727→\\tfor shadowBranchName := range shadowBranchesToDelete {\\n   728→\\t\\tif uncondensedActiveOnBranch[shadowBranchName] {\\n   729→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: preserving shadow branch (active session exists)\\\",\\n   730→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   731→\\t\\t\\t)\\n   732→\\t\\t\\tcontinue\\n   733→\\t\\t}\\n   734→\\t\\tif err := deleteShadowBranch(repo, shadowBranchName); err != nil {\\n   735→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to clean up %s: %v\\\\n\\\", shadowBranchName, err)\\n   736→\\t\\t} else {\\n   737→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Cleaned up shadow branch: %s\\\\n\\\", shadowBranchName)\\n   738→\\t\\t\\tlogging.Info(logCtx, \\\"shadow branch deleted\\\",\\n   739→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   740→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   741→\\t\\t\\t)\\n   742→\\t\\t}\\n   743→\\t}\\n   744→\\n   745→\\treturn nil\\n   746→}\\n   747→\\n   748→// condenseAndUpdateState runs condensation for a session and updates state afterward.\\n   749→// Returns true if condensation succeeded.\\n   750→func (s *ManualCommitStrategy) condenseAndUpdateState(\\n   751→\\tlogCtx context.Context,\\n   752→\\trepo *git.Repository,\\n   753→\\tcheckpointID id.CheckpointID,\\n   754→\\tstate *SessionState,\\n   755→\\thead *plumbing.Reference,\\n   756→\\tshadowBranchName string,\\n   757→\\tshadowBranchesToDelete map[string]struct{},\\n   758→\\tcommittedFiles map[string]struct{},\\n   759→) bool {\\n   760→\\tresult, err := s.CondenseSession(repo, checkpointID, state, committedFiles)\\n   761→\\tif err != nil {\\n   762→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: condensation failed for session %s: %v\\\\n\\\",\\n   763→\\t\\t\\tstate.SessionID, err)\\n   764→\\t\\tlogging.Warn(logCtx, \\\"post-commit: condensation failed\\\",\\n   765→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   766→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   767→\\t\\t)\\n   768→\\t\\treturn false\\n   769→\\t}\\n   770→\\n   771→\\t// Track this shadow branch for cleanup\\n   772→\\tshadowBranchesToDelete[shadowBranchName] = struct{}{}\\n   773→\\n   774→\\t// Update session state for the new base commit\\n   775→\\tnewHead := head.Hash().String()\\n   776→\\tstate.BaseCommit = newHead\\n   777→\\tstate.AttributionBaseCommit = newHead\\n   778→\\tstate.StepCount = 0\\n   779→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   780→\\n   781→\\t// Clear attribution tracking — condensation already used these values\\n   782→\\tstate.PromptAttributions = nil\\n   783→\\tstate.PendingPromptAttribution = nil\\n   784→\\tstate.FilesTouched = nil\\n   785→\\n   786→\\t// Save checkpoint ID so subsequent commits can reuse it (e.g., amend restores trailer)\\n   787→\\tstate.LastCheckpointID = checkpointID\\n   788→\\n   789→\\tshortID := state.SessionID\\n   790→\\tif len(shortID) > 8 {\\n   791→\\t\\tshortID = shortID[:8]\\n   792→\\t}\\n   793→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Condensed session %s: %s (%d checkpoints)\\\\n\\\",\\n   794→\\t\\tshortID, result.CheckpointID, result.CheckpointsCount)\\n   795→\\n   796→\\tlogging.Info(logCtx, \\\"session condensed\\\",\\n   797→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   798→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   799→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   800→\\t\\tslog.Int(\\\"transcript_lines\\\", result.TotalTranscriptLines),\\n   801→\\t)\\n   802→\\n   803→\\treturn true\\n   804→}\\n   805→\\n   806→// updateBaseCommitIfChanged updates BaseCommit to newHead if it changed.\\n   807→// Only updates ACTIVE sessions. IDLE/ENDED sessions should NOT have their\\n   808→// BaseCommit updated, as this would cause them to be incorrectly associated\\n   809→// with a new shadow branch and potentially condensed on future commits.\\n   810→func (s *ManualCommitStrategy) updateBaseCommitIfChanged(logCtx context.Context, state *SessionState, newHead string) {\\n   811→\\t// Only update ACTIVE sessions. IDLE/ENDED sessions are kept around for\\n   812→\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n   813→\\tif !state.Phase.IsActive() {\\n   814→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updateBaseCommitIfChanged skipped non-active session\\\",\\n   815→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   816→\\t\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   817→\\t\\t)\\n   818→\\t\\treturn\\n   819→\\t}\\n   820→\\tif state.BaseCommit != newHead {\\n   821→\\t\\tstate.BaseCommit = newHead\\n   822→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updated BaseCommit\\\",\\n   823→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   824→\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n   825→\\t\\t)\\n   826→\\t}\\n   827→}\\n   828→\\n   829→// postCommitUpdateBaseCommitOnly updates BaseCommit for all sessions on the current\\n   830→// worktree when a commit has no Entire-Checkpoint trailer. This prevents BaseCommit\\n   831→// from going stale, which would cause future PrepareCommitMsg calls to skip the\\n   832→// session (BaseCommit != currentHeadHash filter).\\n   833→//\\n   834→// Unlike the full PostCommit flow, this does NOT fire EventGitCommit or trigger\\n   835→// condensation — it only keeps BaseCommit in sync with HEAD.\\n   836→func (s *ManualCommitStrategy) postCommitUpdateBaseCommitOnly(logCtx context.Context, head *plumbing.Reference) {\\n   837→\\tworktreePath, err := GetWorktreePath()\\n   838→\\tif err != nil {\\n   839→\\t\\treturn // Silent failure — hooks must be resilient\\n   840→\\t}\\n   841→\\n   842→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   843→\\tif err != nil || len(sessions) == 0 {\\n   844→\\t\\treturn\\n   845→\\t}\\n   846→\\n   847→\\tnewHead := head.Hash().String()\\n   848→\\tfor _, state := range sessions {\\n   849→\\t\\t// Only update active sessions. Idle/ended sessions are kept around for\\n   850→\\t\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n   851→\\t\\tif !state.Phase.IsActive() {\\n   852→\\t\\t\\tcontinue\\n   853→\\t\\t}\\n   854→\\t\\tif state.BaseCommit != newHead {\\n   855→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit (no trailer): updating BaseCommit\\\",\\n   856→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   857→\\t\\t\\t\\tslog.String(\\\"old_base\\\", truncateHash(state.BaseCommit)),\\n   858→\\t\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n   859→\\t\\t\\t)\\n   860→\\t\\t\\tstate.BaseCommit = newHead\\n   861→\\t\\t\\tif err := s.saveSessionState(state); err != nil {\\n   862→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to update session state: %v\\\\n\\\", err)\\n   863→\\t\\t\\t}\\n   864→\\t\\t}\\n   865→\\t}\\n   866→}\\n   867→\\n   868→// truncateHash safely truncates a git hash to 7 chars for logging.\\n   869→func truncateHash(h string) string {\\n   870→\\tif len(h) > 7 {\\n   871→\\t\\treturn h[:7]\\n   872→\\t}\\n   873→\\treturn h\\n   874→}\\n   875→\\n   876→// filterSessionsWithNewContent returns sessions that have new transcript content\\n   877→// beyond what was already condensed.\\n   878→func (s *ManualCommitStrategy) filterSessionsWithNewContent(repo *git.Repository, sessions []*SessionState) []*SessionState {\\n   879→\\tvar result []*SessionState\\n   880→\\n   881→\\tfor _, state := range sessions {\\n   882→\\t\\thasNew, err := s.sessionHasNewContent(repo, state)\\n   883→\\t\\tif err != nil {\\n   884→\\t\\t\\t// On error, include the session (fail open for hooks)\\n   885→\\t\\t\\tresult = append(result, state)\\n   886→\\t\\t\\tcontinue\\n   887→\\t\\t}\\n   888→\\t\\tif hasNew {\\n   889→\\t\\t\\tresult = append(result, state)\\n   890→\\t\\t}\\n   891→\\t}\\n   892→\\n   893→\\treturn result\\n   894→}\\n   895→\\n   896→// sessionHasNewContent checks if a session has new transcript content\\n   897→// beyond what was already condensed.\\n   898→func (s *ManualCommitStrategy) sessionHasNewContent(repo *git.Repository, state *SessionState) (bool, error) {\\n   899→\\tlogCtx := logging.WithComponent(context.Background(), \\\"manual-commit\\\")\\n   900→\\n   901→\\t// Get shadow branch\\n   902→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   903→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   904→\\tref, err := repo.Reference(refName, true)\\n   905→\\tif err != nil {\\n   906→\\t\\t// No shadow branch means no Stop has happened since the last condensation.\\n   907→\\t\\t// However, the agent may have done work (including commits) without a Stop.\\n   908→\\t\\t// Check the live transcript to detect this scenario.\\n   909→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no shadow branch, checking live transcript\\\",\\n   910→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   911→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   912→\\t\\t)\\n   913→\\t\\treturn s.sessionHasNewContentFromLiveTranscript(repo, state)\\n   914→\\t}\\n   915→\\n   916→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   917→\\tif err != nil {\\n   918→\\t\\treturn false, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   919→\\t}\\n   920→\\n   921→\\ttree, err := commit.Tree()\\n   922→\\tif err != nil {\\n   923→\\t\\treturn false, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   924→\\t}\\n   925→\\n   926→\\t// Look for transcript file\\n   927→\\tmetadataDir := paths.EntireMetadataDir + \\\"/\\\" + state.SessionID\\n   928→\\tvar transcriptLines int\\n   929→\\tvar hasTranscriptFile bool\\n   930→\\n   931→\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   932→\\t\\thasTranscriptFile = true\\n   933→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   934→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n   935→\\t\\t}\\n   936→\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   937→\\t\\thasTranscriptFile = true\\n   938→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   939→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n   940→\\t\\t}\\n   941→\\t}\\n   942→\\n   943→\\t// If shadow branch exists but has no transcript (e.g., carry-forward from mid-session commit),\\n   944→\\t// check if the session has FilesTouched. Carry-forward sets FilesTouched with remaining files.\\n   945→\\tif !hasTranscriptFile {\\n   946→\\t\\tif len(state.FilesTouched) > 0 {\\n   947→\\t\\t\\t// Shadow branch has files from carry-forward - check if staged files overlap\\n   948→\\t\\t\\t// AND have matching content (content-aware check).\\n   949→\\t\\t\\tstagedFiles := getStagedFiles(repo)\\n   950→\\t\\t\\tif len(stagedFiles) > 0 {\\n   951→\\t\\t\\t\\t// PrepareCommitMsg context: check staged files overlap with content\\n   952→\\t\\t\\t\\tresult := stagedFilesOverlapWithContent(repo, tree, stagedFiles, state.FilesTouched)\\n   953→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript, carry-forward with staged files\\\",\\n   954→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   955→\\t\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n   956→\\t\\t\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n   957→\\t\\t\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n   958→\\t\\t\\t\\t)\\n   959→\\t\\t\\t\\treturn result, nil\\n   960→\\t\\t\\t}\\n   961→\\t\\t\\t// PostCommit context: no staged files, but we have carry-forward files.\\n   962→\\t\\t\\t// Return true and let the caller do the overlap check with committed files.\\n   963→\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript, carry-forward without staged files (post-commit context)\\\",\\n   964→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   965→\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n   966→\\t\\t\\t)\\n   967→\\t\\t\\treturn true, nil\\n   968→\\t\\t}\\n   969→\\t\\t// No transcript and no FilesTouched - fall back to live transcript check\\n   970→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript and no files touched, checking live transcript\\\",\\n   971→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   972→\\t\\t)\\n   973→\\t\\treturn s.sessionHasNewContentFromLiveTranscript(repo, state)\\n   974→\\t}\\n   975→\\n   976→\\t// Check if there's new content to condense. Two cases:\\n   977→\\t// 1. Transcript has grown since last condensation (new prompts/responses)\\n   978→\\t// 2. FilesTouched has files not yet committed (carry-forward scenario)\\n   979→\\t//\\n   980→\\t// For PrepareCommitMsg context, we verify staged files overlap with session's files\\n   981→\\t// using content-aware matching to detect reverted files.\\n   982→\\t// For PostCommit context, getStagedFiles() is empty (files already committed),\\n   983→\\t// so we return true and let the caller do the overlap check via filesOverlapWithContent.\\n   984→\\n   985→\\thasTranscriptGrowth := transcriptLines > state.CheckpointTranscriptStart\\n   986→\\thasUncommittedFiles := len(state.FilesTouched) > 0\\n   987→\\n   988→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: transcript check\\\",\\n   989→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   990→\\t\\tslog.Int(\\\"transcript_lines\\\", transcriptLines),\\n   991→\\t\\tslog.Int(\\\"checkpoint_transcript_start\\\", state.CheckpointTranscriptStart),\\n   992→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n   993→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n   994→\\t)\\n   995→\\n   996→\\tif !hasTranscriptGrowth && !hasUncommittedFiles {\\n   997→\\t\\treturn false, nil // No new content and no carry-forward files\\n   998→\\t}\\n   999→\\n  1000→\\t// Check if staged files overlap with session's files with content-aware matching.\\n  1001→\\t// This is primarily for PrepareCommitMsg; in PostCommit, stagedFiles is empty.\\n  1002→\\tstagedFiles := getStagedFiles(repo)\\n  1003→\\tif len(stagedFiles) > 0 {\\n  1004→\\t\\tresult := stagedFilesOverlapWithContent(repo, tree, stagedFiles, state.FilesTouched)\\n  1005→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: staged files overlap check\\\",\\n  1006→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1007→\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1008→\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n  1009→\\t\\t)\\n  1010→\\t\\treturn result, nil\\n  1011→\\t}\\n  1012→\\n  1013→\\t// No staged files - either PostCommit context or edge case.\\n  1014→\\t// Return transcript growth status. For PostCommit with hasTranscriptFile=true,\\n  1015→\\t// if there's no transcript growth, the session hasn't done new work since last checkpoint.\\n  1016→\\t// (Carry-forward creates a shadow branch WITHOUT transcript, handled in the block above.)\\n  1017→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no staged files, returning transcript growth\\\",\\n  1018→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1019→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1020→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1021→\\t)\\n  1022→\\treturn hasTranscriptGrowth, nil\\n  1023→}\\n  1024→\\n  1025→// sessionHasNewContentFromLiveTranscript checks if a session has new content\\n  1026→// by examining the live transcript file. This is used when no shadow branch exists\\n  1027→// (i.e., no Stop has happened yet) but the agent may have done work.\\n  1028→//\\n  1029→// Returns true if:\\n  1030→//  1. The transcript has grown since the last condensation, AND\\n  1031→//  2. The new transcript portion contains file modifications, AND\\n  1032→//  3. At least one modified file overlaps with the currently staged files\\n  1033→//\\n  1034→// The overlap check ensures we don't add checkpoint trailers to commits that are\\n  1035→// unrelated to the agent's recent changes.\\n  1036→//\\n  1037→// This handles the scenario where the agent commits mid-session before Stop.\\n  1038→func (s *ManualCommitStrategy) sessionHasNewContentFromLiveTranscript(repo *git.Repository, state *SessionState) (bool, error) {\\n  1039→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1040→\\n  1041→\\tmodifiedFiles, ok := s.extractNewModifiedFilesFromLiveTranscript(state)\\n  1042→\\tif !ok || len(modifiedFiles) == 0 {\\n  1043→\\t\\treturn false, nil\\n  1044→\\t}\\n  1045→\\n  1046→\\tlogging.Debug(logCtx, \\\"live transcript check: found file modifications\\\",\\n  1047→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1048→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1049→\\t)\\n  1050→\\n  1051→\\t// Check if any modified files overlap with currently staged files\\n  1052→\\t// This ensures we only add checkpoint trailers to commits that include\\n  1053→\\t// files the agent actually modified\\n  1054→\\tstagedFiles := getStagedFiles(repo)\\n  1055→\\n  1056→\\tlogging.Debug(logCtx, \\\"live transcript check: comparing staged vs modified\\\",\\n  1057→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1058→\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1059→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1060→\\t)\\n  1061→\\n  1062→\\tif !hasOverlappingFiles(stagedFiles, modifiedFiles) {\\n  1063→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no overlap between staged and modified files\\\",\\n  1064→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1065→\\t\\t)\\n  1066→\\t\\treturn false, nil // No overlap - staged files are unrelated to agent's work\\n  1067→\\t}\\n  1068→\\n  1069→\\treturn true, nil\\n  1070→}\\n  1071→\\n  1072→// extractFilesFromLiveTranscript extracts modified file paths from the live transcript.\\n  1073→// Returns empty slice if extraction fails (fail-open behavior for hooks).\\n  1074→// Extracts files from the transcript starting at CheckpointTranscriptStart, which gives\\n  1075→// files touched since the last condensation — used for carry-forward computation.\\n  1076→func (s *ManualCommitStrategy) extractFilesFromLiveTranscript(state *SessionState) []string {\\n  1077→\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n  1078→}\\n  1079→\\n  1080→// extractNewModifiedFilesFromLiveTranscript extracts modified files from the live\\n  1081→// transcript that are NEW since the last condensation. Returns the normalized file list\\n  1082→// and whether the extraction succeeded. Used by sessionHasNewContentFromLiveTranscript\\n  1083→// to detect agent work.\\n  1084→func (s *ManualCommitStrategy) extractNewModifiedFilesFromLiveTranscript(state *SessionState) ([]string, bool) {\\n  1085→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1086→\\n  1087→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1088→\\t\\treturn nil, false\\n  1089→\\t}\\n  1090→\\n  1091→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1092→\\tif err != nil {\\n  1093→\\t\\treturn nil, false\\n  1094→\\t}\\n  1095→\\n  1096→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1097→\\tif !ok {\\n  1098→\\t\\treturn nil, false\\n  1099→\\t}\\n  1100→\\n  1101→\\t// Check if transcript has grown since last condensation\\n  1102→\\tcurrentPos, err := analyzer.GetTranscriptPosition(state.TranscriptPath)\\n  1103→\\tif err != nil {\\n  1104→\\t\\treturn nil, false\\n  1105→\\t}\\n  1106→\\tif currentPos <= state.CheckpointTranscriptStart {\\n  1107→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no new content\\\",\\n  1108→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1109→\\t\\t\\tslog.Int(\\\"current_pos\\\", currentPos),\\n  1110→\\t\\t\\tslog.Int(\\\"start_offset\\\", state.CheckpointTranscriptStart),\\n  1111→\\t\\t)\\n  1112→\\t\\treturn nil, true // No new content, but extraction succeeded\\n  1113→\\t}\\n  1114→\\n  1115→\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart), true\\n  1116→}\\n  1117→\\n  1118→// extractModifiedFilesFromLiveTranscript extracts modified files from the live transcript\\n  1119→// (including subagent transcripts) starting from the given offset, and normalizes them\\n  1120→// to repo-relative paths. Returns the normalized file list.\\n  1121→func (s *ManualCommitStrategy) extractModifiedFilesFromLiveTranscript(state *SessionState, offset int) []string {\\n  1122→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1123→\\n  1124→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1125→\\t\\treturn nil\\n  1126→\\t}\\n  1127→\\n  1128→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1129→\\tif err != nil {\\n  1130→\\t\\treturn nil\\n  1131→\\t}\\n  1132→\\n  1133→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1134→\\tif !ok {\\n  1135→\\t\\treturn nil\\n  1136→\\t}\\n  1137→\\n  1138→\\tvar modifiedFiles []string\\n  1139→\\n  1140→\\t// For Claude Code, use ExtractAllModifiedFiles which parses the main transcript\\n  1141→\\t// AND subagent transcripts in a single pass, avoiding redundant parsing.\\n  1142→\\tif state.AgentType == agent.AgentTypeClaudeCode {\\n  1143→\\t\\tsubagentsDir := filepath.Join(filepath.Dir(state.TranscriptPath), state.SessionID, \\\"subagents\\\")\\n  1144→\\t\\tallFiles, extractErr := claudecode.ExtractAllModifiedFiles(state.TranscriptPath, offset, subagentsDir)\\n  1145→\\t\\tif extractErr != nil {\\n  1146→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: extraction failed\\\",\\n  1147→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1148→\\t\\t\\t\\tslog.String(\\\"error\\\", extractErr.Error()),\\n  1149→\\t\\t\\t)\\n  1150→\\t\\t} else {\\n  1151→\\t\\t\\tmodifiedFiles = allFiles\\n  1152→\\t\\t}\\n  1153→\\t} else {\\n  1154→\\t\\tfiles, _, err := analyzer.ExtractModifiedFilesFromOffset(state.TranscriptPath, offset)\\n  1155→\\t\\tif err != nil {\\n  1156→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: main transcript extraction failed\\\",\\n  1157→\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1158→\\t\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1159→\\t\\t\\t)\\n  1160→\\t\\t} else {\\n  1161→\\t\\t\\tmodifiedFiles = files\\n  1162→\\t\\t}\\n  1163→\\t}\\n  1164→\\n  1165→\\tif len(modifiedFiles) == 0 {\\n  1166→\\t\\treturn nil\\n  1167→\\t}\\n  1168→\\n  1169→\\t// Normalize to repo-relative paths.\\n  1170→\\t// Transcript tool_use entries contain absolute paths (e.g., /Users/alex/project/src/main.go)\\n  1171→\\t// but getStagedFiles/committedFiles use repo-relative paths (e.g., src/main.go).\\n  1172→\\tbasePath := state.WorktreePath\\n  1173→\\tif basePath == \\\"\\\" {\\n  1174→\\t\\tif wp, wpErr := GetWorktreePath(); wpErr == nil {\\n  1175→\\t\\t\\tbasePath = wp\\n  1176→\\t\\t}\\n  1177→\\t}\\n  1178→\\tif basePath != \\\"\\\" {\\n  1179→\\t\\tnormalized := make([]string, 0, len(modifiedFiles))\\n  1180→\\t\\tfor _, f := range modifiedFiles {\\n  1181→\\t\\t\\tif rel := paths.ToRelativePath(f, basePath); rel != \\\"\\\" {\\n  1182→\\t\\t\\t\\tnormalized = append(normalized, rel)\\n  1183→\\t\\t\\t} else {\\n  1184→\\t\\t\\t\\tnormalized = append(normalized, f)\\n  1185→\\t\\t\\t}\\n  1186→\\t\\t}\\n  1187→\\t\\tmodifiedFiles = normalized\\n  1188→\\t}\\n  1189→\\n  1190→\\treturn modifiedFiles\\n  1191→}\\n  1192→\\n  1193→// addTrailerForAgentCommit handles the fast path when an agent is committing\\n  1194→// (ACTIVE session + no TTY). Generates a checkpoint ID and adds the trailer\\n  1195→// directly, bypassing content detection and interactive prompts.\\n  1196→func (s *ManualCommitStrategy) addTrailerForAgentCommit(logCtx context.Context, commitMsgFile string, state *SessionState, source string) error {\\n  1197→\\tcpID, err := id.Generate()\\n  1198→\\tif err != nil {\\n  1199→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1200→\\t}\\n  1201→\\n  1202→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n  1203→\\tif err != nil {\\n  1204→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1205→\\t}\\n  1206→\\n  1207→\\tmessage := string(content)\\n  1208→\\n  1209→\\t// Don't add if trailer already exists\\n  1210→\\tif _, found := trailers.ParseCheckpoint(message); found {\\n  1211→\\t\\treturn nil\\n  1212→\\t}\\n  1213→\\n  1214→\\tmessage = addCheckpointTrailer(message, cpID)\\n  1215→\\n  1216→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: agent commit trailer added\\\",\\n  1217→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n  1218→\\t\\tslog.String(\\\"source\\\", source),\\n  1219→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n  1220→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1221→\\t)\\n  1222→\\n  1223→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n  1224→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1225→\\t}\\n  1226→\\treturn nil\\n  1227→}\\n  1228→\\n  1229→// addCheckpointTrailer adds the Entire-Checkpoint trailer to a commit message.\\n  1230→// Handles proper trailer formatting (blank line before trailers if needed).\\n  1231→func addCheckpointTrailer(message string, checkpointID id.CheckpointID) string {\\n  1232→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1233→\\n  1234→\\t// If message already ends with trailers (lines starting with key:), just append\\n  1235→\\t// Otherwise, add a blank line first\\n  1236→\\tlines := strings.Split(strings.TrimRight(message, \\\"\\\\n\\\"), \\\"\\\\n\\\")\\n  1237→\\n  1238→\\t// Check if the message already ends with a trailer paragraph.\\n  1239→\\t// Git trailers must be in a separate paragraph (preceded by a blank line).\\n  1240→\\t// A single-paragraph message (e.g., just a subject line) cannot have trailers,\\n  1241→\\t// even if the subject contains \\\": \\\" (like conventional commits: \\\"docs: Add foo\\\").\\n  1242→\\t//\\n  1243→\\t// Scan from the bottom: find the last paragraph of non-comment content,\\n  1244→\\t// then check if it looks like trailers AND has a blank line above it.\\n  1245→\\thasTrailers := false\\n  1246→\\ti := len(lines) - 1\\n  1247→\\n  1248→\\t// Skip trailing comment lines\\n  1249→\\tfor i >= 0 && strings.HasPrefix(strings.TrimSpace(lines[i]), \\\"#\\\") {\\n  1250→\\t\\ti--\\n  1251→\\t}\\n  1252→\\n  1253→\\t// Check if the last non-comment line looks like a trailer\\n  1254→\\tif i >= 0 {\\n  1255→\\t\\tline := strings.TrimSpace(lines[i])\\n  1256→\\t\\tif line != \\\"\\\" && strings.Contains(line, \\\": \\\") {\\n  1257→\\t\\t\\t// Found a trailer-like line. Now scan upward past the trailer block\\n  1258→\\t\\t\\t// to verify there's a blank line (paragraph separator) above it.\\n  1259→\\t\\t\\tfor i > 0 {\\n  1260→\\t\\t\\t\\ti--\\n  1261→\\t\\t\\t\\tabove := strings.TrimSpace(lines[i])\\n  1262→\\t\\t\\t\\tif strings.HasPrefix(above, \\\"#\\\") {\\n  1263→\\t\\t\\t\\t\\tcontinue\\n  1264→\\t\\t\\t\\t}\\n  1265→\\t\\t\\t\\tif above == \\\"\\\" {\\n  1266→\\t\\t\\t\\t\\t// Blank line found above trailer block — real trailers\\n  1267→\\t\\t\\t\\t\\thasTrailers = true\\n  1268→\\t\\t\\t\\t\\tbr