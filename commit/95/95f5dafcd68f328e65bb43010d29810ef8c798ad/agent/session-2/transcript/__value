trequire.GreaterOrEqual(t, len(checkpointIDsAfterSecondCommit), 2, \\\"Should have two checkpoints\\\")\\n   173→\\tcheckpointCD := checkpointIDsAfterSecondCommit[0] // Most recent (C,D commit) is first\\n   174→\\tt.Logf(\\\"Checkpoint for C,D commit: %s\\\", checkpointCD)\\n   175→\\n   176→\\t// Each commit should have its own unique checkpoint ID (1:1 model)\\n   177→\\tassert.NotEqual(t, checkpointAB, checkpointCD,\\n   178→\\t\\t\\\"Each commit should have its own unique checkpoint ID\\\")\\n   179→\\n   180→\\t// Verify metadata branch exists\\n   181→\\tassert.True(t, env.BranchExists(\\\"entire/checkpoints/v1\\\"),\\n   182→\\t\\t\\\"entire/checkpoints/v1 branch should exist\\\")\\n   183→\\n   184→\\t// Both checkpoints are from the same session where agent created all 4 files.\\n   185→\\t// The transcript should contain all file names since it's the same agent work.\\n   186→\\tallFiles := []string{\\\"fileA.go\\\", \\\"fileB.go\\\", \\\"fileC.go\\\", \\\"fileD.go\\\"}\\n   187→\\n   188→\\t// Validate first checkpoint (files A, B committed)\\n   189→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   190→\\t\\tCheckpointID:              checkpointAB,\\n   191→\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   192→\\t\\tFilesTouched:              []string{\\\"fileA.go\\\", \\\"fileB.go\\\"},\\n   193→\\t\\tExpectedTranscriptContent: allFiles, // Full session transcript\\n   194→\\t})\\n   195→\\n   196→\\t// Validate second checkpoint (files C, D committed)\\n   197→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   198→\\t\\tCheckpointID:              checkpointCD,\\n   199→\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   200→\\t\\tFilesTouched:              []string{\\\"fileC.go\\\", \\\"fileD.go\\\"},\\n   201→\\t\\tExpectedTranscriptContent: allFiles, // Full session transcript\\n   202→\\t})\\n   203→\\n   204→\\t// CRITICAL: After all carry-forward files are committed, no shadow branches\\n   205→\\t// should remain. Only entire/checkpoints/v1 should exist. Extra shadow\\n   206→\\t// branches (entire/<hash>-<hash>) indicate a regression in carry-forward cleanup.\\n   207→\\tentireBranches := env.ListBranchesWithPrefix(\\\"entire/\\\")\\n   208→\\tfor _, b := range entireBranches {\\n   209→\\t\\tassert.Equal(t, \\\"entire/checkpoints/v1\\\", b,\\n   210→\\t\\t\\t\\\"Unexpected shadow branch after all files committed: %s\\\", b)\\n   211→\\t}\\n   212→\\tt.Logf(\\\"Entire branches after all commits: %v\\\", entireBranches)\\n   213→}\\n   214→\\n   215→// TestE2E_Scenario5_PartialCommitStashNextPrompt tests partial commit, stash, then new prompt.\\n   216→//\\n   217→// Scenario 5: Partial Commit → Stash → Next Prompt\\n   218→// - Agent makes changes to A, B, C\\n   219→// - User commits A only\\n   220→// - User stashes B, C\\n   221→// - User runs another prompt (creates D, E)\\n   222→// - User commits D, E\\n   223→// - FilesTouched accumulates across prompts\\n   224→func TestE2E_Scenario5_PartialCommitStashNextPrompt(t *testing.T) {\\n   225→\\tt.Parallel()\\n   226→\\n   227→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   228→\\n   229→\\t// Prompt 1: Agent creates files A, B, C\\n   230→\\tt.Log(\\\"Prompt 1: Creating files A, B, C\\\")\\n   231→\\tprompt1 := `Create these files:\\n   232→1. stash_a.go with content: package main; func StashA() {}\\n   233→2. stash_b.go with content: package main; func StashB() {}\\n   234→3. stash_c.go with content: package main; func StashC() {}\\n   235→Create all three files, nothing else.`\\n   236→\\n   237→\\tresult, err := env.RunAgent(prompt1)\\n   238→\\trequire.NoError(t, err)\\n   239→\\tAssertAgentSuccess(t, result, err)\\n   240→\\n   241→\\trequire.True(t, env.FileExists(\\\"stash_a.go\\\"))\\n   242→\\trequire.True(t, env.FileExists(\\\"stash_b.go\\\"))\\n   243→\\trequire.True(t, env.FileExists(\\\"stash_c.go\\\"))\\n   244→\\n   245→\\t// User commits A only\\n   246→\\tt.Log(\\\"Committing stash_a.go only\\\")\\n   247→\\tenv.GitCommitWithShadowHooks(\\\"Add stash_a\\\", \\\"stash_a.go\\\")\\n   248→\\n   249→\\t// User stashes B, C\\n   250→\\tt.Log(\\\"Stashing remaining files\\\")\\n   251→\\tenv.GitStash()\\n   252→\\n   253→\\t// Verify B, C are no longer in working directory\\n   254→\\tassert.False(t, env.FileExists(\\\"stash_b.go\\\"), \\\"stash_b.go should be stashed\\\")\\n   255→\\tassert.False(t, env.FileExists(\\\"stash_c.go\\\"), \\\"stash_c.go should be stashed\\\")\\n   256→\\n   257→\\t// Prompt 2: Agent creates files D, E\\n   258→\\tt.Log(\\\"Prompt 2: Creating files D, E\\\")\\n   259→\\tprompt2 := `Create these files:\\n   260→1. stash_d.go with content: package main; func StashD() {}\\n   261→2. stash_e.go with content: package main; func StashE() {}\\n   262→Create both files, nothing else.`\\n   263→\\n   264→\\tresult, err = env.RunAgent(prompt2)\\n   265→\\trequire.NoError(t, err)\\n   266→\\tAssertAgentSuccess(t, result, err)\\n   267→\\n   268→\\trequire.True(t, env.FileExists(\\\"stash_d.go\\\"))\\n   269→\\trequire.True(t, env.FileExists(\\\"stash_e.go\\\"))\\n   270→\\n   271→\\t// User commits D, E\\n   272→\\tt.Log(\\\"Committing stash_d.go and stash_e.go\\\")\\n   273→\\tenv.GitCommitWithShadowHooks(\\\"Add stash_d and stash_e\\\", \\\"stash_d.go\\\", \\\"stash_e.go\\\")\\n   274→\\n   275→\\t// Verify checkpoint was created for D, E\\n   276→\\tcheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n   277→\\trequire.GreaterOrEqual(t, len(checkpointIDs), 2, \\\"Should have checkpoints for both commits\\\")\\n   278→\\tt.Logf(\\\"Checkpoint IDs: %v\\\", checkpointIDs)\\n   279→\\n   280→\\t// Verify metadata branch exists\\n   281→\\tassert.True(t, env.BranchExists(\\\"entire/checkpoints/v1\\\"),\\n   282→\\t\\t\\\"entire/checkpoints/v1 branch should exist\\\")\\n   283→\\n   284→\\t// Validate checkpoints have proper metadata\\n   285→\\t// checkpointIDs[0] is the most recent (D, E commit from prompt 2)\\n   286→\\t// checkpointIDs[1] is the earlier commit (A only from prompt 1)\\n   287→\\t//\\n   288→\\t// Note: We don't validate transcript content here because:\\n   289→\\t// 1. Claude's response text varies and may not contain exact file names\\n   290→\\t// 2. Multi-session checkpoints have multiple session folders, making validation complex\\n   291→\\t// The key validation is that files_touched is correct for each checkpoint.\\n   292→\\tif len(checkpointIDs) >= 2 {\\n   293→\\t\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   294→\\t\\t\\tCheckpointID: checkpointIDs[0],\\n   295→\\t\\t\\tStrategy:     \\\"manual-commit\\\",\\n   296→\\t\\t\\tFilesTouched: []string{\\\"stash_d.go\\\", \\\"stash_e.go\\\"},\\n   297→\\t\\t})\\n   298→\\t\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   299→\\t\\t\\tCheckpointID: checkpointIDs[1],\\n   300→\\t\\t\\tStrategy:     \\\"manual-commit\\\",\\n   301→\\t\\t\\tFilesTouched: []string{\\\"stash_a.go\\\"},\\n   302→\\t\\t})\\n   303→\\t}\\n   304→\\n   305→\\t// Note: stash_b.go and stash_c.go are still stashed (never committed),\\n   306→\\t// so a shadow branch may remain for the session that still has pending files.\\n   307→\\tentireBranches := env.ListBranchesWithPrefix(\\\"entire/\\\")\\n   308→\\tt.Logf(\\\"Entire branches after commits: %v\\\", entireBranches)\\n   309→}\\n   310→\\n   311→// TestE2E_Scenario6_StashSecondPromptUnstashCommitAll tests stash, new prompt, unstash, commit all.\\n   312→//\\n   313→// Scenario 6: Stash → Second Prompt → Unstash → Commit All\\n   314→// - Agent makes changes to A, B, C\\n   315→// - User commits A only\\n   316→// - User stashes B, C\\n   317→// - User runs another prompt (creates D, E)\\n   318→// - User unstashes B, C\\n   319→// - User commits ALL (B, C, D, E) together\\n   320→// - All files link to single checkpoint\\n   321→func TestE2E_Scenario6_StashSecondPromptUnstashCommitAll(t *testing.T) {\\n   322→\\tt.Parallel()\\n   323→\\n   324→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   325→\\n   326→\\t// Prompt 1: Agent creates files A, B, C\\n   327→\\tt.Log(\\\"Prompt 1: Creating files A, B, C\\\")\\n   328→\\tprompt1 := `Create these files:\\n   329→1. combo_a.go with content: package main; func ComboA() {}\\n   330→2. combo_b.go with content: package main; func ComboB() {}\\n   331→3. combo_c.go with content: package main; func ComboC() {}\\n   332→Create all three files, nothing else.`\\n   333→\\n   334→\\tresult, err := env.RunAgent(prompt1)\\n   335→\\trequire.NoError(t, err)\\n   336→\\tAssertAgentSuccess(t, result, err)\\n   337→\\n   338→\\trequire.True(t, env.FileExists(\\\"combo_a.go\\\"))\\n   339→\\trequire.True(t, env.FileExists(\\\"combo_b.go\\\"))\\n   340→\\trequire.True(t, env.FileExists(\\\"combo_c.go\\\"))\\n   341→\\n   342→\\t// User commits A only\\n   343→\\tt.Log(\\\"Committing combo_a.go only\\\")\\n   344→\\tenv.GitCommitWithShadowHooks(\\\"Add combo_a\\\", \\\"combo_a.go\\\")\\n   345→\\n   346→\\t// User stashes B, C\\n   347→\\tt.Log(\\\"Stashing remaining files B, C\\\")\\n   348→\\tenv.GitStash()\\n   349→\\n   350→\\t// Verify B, C are no longer in working directory\\n   351→\\tassert.False(t, env.FileExists(\\\"combo_b.go\\\"), \\\"combo_b.go should be stashed\\\")\\n   352→\\tassert.False(t, env.FileExists(\\\"combo_c.go\\\"), \\\"combo_c.go should be stashed\\\")\\n   353→\\n   354→\\t// Prompt 2: Agent creates files D, E\\n   355→\\tt.Log(\\\"Prompt 2: Creating files D, E\\\")\\n   356→\\tprompt2 := `Create these files:\\n   357→1. combo_d.go with content: package main; func ComboD() {}\\n   358→2. combo_e.go with content: package main; func ComboE() {}\\n   359→Create both files, nothing else.`\\n   360→\\n   361→\\tresult, err = env.RunAgent(prompt2)\\n   362→\\trequire.NoError(t, err)\\n   363→\\tAssertAgentSuccess(t, result, err)\\n   364→\\n   365→\\trequire.True(t, env.FileExists(\\\"combo_d.go\\\"))\\n   366→\\trequire.True(t, env.FileExists(\\\"combo_e.go\\\"))\\n   367→\\n   368→\\t// User unstashes B, C\\n   369→\\tt.Log(\\\"Unstashing B, C\\\")\\n   370→\\tenv.GitStashPop()\\n   371→\\n   372→\\t// Verify B, C are back\\n   373→\\tassert.True(t, env.FileExists(\\\"combo_b.go\\\"), \\\"combo_b.go should be back after unstash\\\")\\n   374→\\tassert.True(t, env.FileExists(\\\"combo_c.go\\\"), \\\"combo_c.go should be back after unstash\\\")\\n   375→\\n   376→\\t// User commits ALL files together (B, C, D, E)\\n   377→\\tt.Log(\\\"Committing all remaining files together\\\")\\n   378→\\tenv.GitCommitWithShadowHooks(\\\"Add combo_b, combo_c, combo_d, combo_e\\\",\\n   379→\\t\\t\\\"combo_b.go\\\", \\\"combo_c.go\\\", \\\"combo_d.go\\\", \\\"combo_e.go\\\")\\n   380→\\n   381→\\t// Verify checkpoint was created\\n   382→\\tcheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n   383→\\trequire.GreaterOrEqual(t, len(checkpointIDs), 2, \\\"Should have checkpoints\\\")\\n   384→\\tt.Logf(\\\"Checkpoint IDs: %v\\\", checkpointIDs)\\n   385→\\n   386→\\t// The second commit should have all 4 files linked to a single checkpoint\\n   387→\\t// Verify metadata branch exists\\n   388→\\tassert.True(t, env.BranchExists(\\\"entire/checkpoints/v1\\\"),\\n   389→\\t\\t\\\"entire/checkpoints/v1 branch should exist\\\")\\n   390→\\n   391→\\t// Validate checkpoints have proper metadata\\n   392→\\t// checkpointIDs[0] is the most recent (B, C, D, E combined commit)\\n   393→\\t// checkpointIDs[1] is the earlier commit (A only)\\n   394→\\t//\\n   395→\\t// Prompt 1 created A, B, C. User committed A, then stashed B, C.\\n   396→\\t// Prompt 2 created D, E. User unstashed B, C, then committed all 4 together.\\n   397→\\t//\\n   398→\\t// Note: We don't validate transcript content here because:\\n   399→\\t// 1. Claude's response text varies and may not contain exact file names\\n   400→\\t// 2. Multi-session checkpoints have multiple session folders, making validation complex\\n   401→\\t// The key validation is that files_touched is correct for each checkpoint.\\n   402→\\tif len(checkpointIDs) >= 2 {\\n   403→\\t\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   404→\\t\\t\\tCheckpointID: checkpointIDs[0],\\n   405→\\t\\t\\tStrategy:     \\\"manual-commit\\\",\\n   406→\\t\\t\\tFilesTouched: []string{\\\"combo_b.go\\\", \\\"combo_c.go\\\", \\\"combo_d.go\\\", \\\"combo_e.go\\\"},\\n   407→\\t\\t})\\n   408→\\t\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   409→\\t\\t\\tCheckpointID: checkpointIDs[1],\\n   410→\\t\\t\\tStrategy:     \\\"manual-commit\\\",\\n   411→\\t\\t\\tFilesTouched: []string{\\\"combo_a.go\\\"},\\n   412→\\t\\t})\\n   413→\\t}\\n   414→\\n   415→\\t// No shadow branches should remain after all files committed\\n   416→\\tentireBranches := env.ListBranchesWithPrefix(\\\"entire/\\\")\\n   417→\\tfor _, b := range entireBranches {\\n   418→\\t\\tassert.Equal(t, \\\"entire/checkpoints/v1\\\", b,\\n   419→\\t\\t\\t\\\"Unexpected shadow branch after all files committed: %s\\\", b)\\n   420→\\t}\\n   421→}\\n   422→\\n   423→// TestE2E_Scenario7_PartialStagingWithGitAddP tests partial staging with git add -p.\\n   424→//\\n   425→// Scenario 7: Partial Staging with `git add -p`\\n   426→// - Agent makes multiple changes to a single file\\n   427→// - User stages only part of the changes (simulated with partial write)\\n   428→// - Content-aware carry-forward detects partial commit\\n   429→// - Remaining changes carried forward to next commit\\n   430→func TestE2E_Scenario7_PartialStagingSimulated(t *testing.T) {\\n   431→\\tt.Parallel()\\n   432→\\n   433→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   434→\\n   435→\\t// Create partial.go as an existing tracked file first.\\n   436→\\t// For MODIFIED files (vs NEW files), content-aware detection always\\n   437→\\t// creates checkpoints regardless of content changes. This allows us\\n   438→\\t// to test the partial staging scenario.\\n   439→\\tenv.WriteFile(\\\"partial.go\\\", \\\"package main\\\\n\\\\n// placeholder\\\\n\\\")\\n   440→\\tenv.GitAdd(\\\"partial.go\\\")\\n   441→\\tenv.GitCommit(\\\"Add placeholder partial.go\\\")\\n   442→\\n   443→\\t// Agent modifies the file with multiple functions\\n   444→\\tt.Log(\\\"Agent modifying file with multiple functions\\\")\\n   445→\\tmultiLinePrompt := `Replace the contents of partial.go with this exact content:\\n   446→package main\\n   447→\\n   448→func First() int {\\n   449→\\treturn 1\\n   450→}\\n   451→\\n   452→func Second() int {\\n   453→\\treturn 2\\n   454→}\\n   455→\\n   456→func Third() int {\\n   457→\\treturn 3\\n   458→}\\n   459→\\n   460→func Fourth() int {\\n   461→\\treturn 4\\n   462→}\\n   463→\\n   464→Replace the file with exactly this content, nothing else.`\\n   465→\\n   466→\\tresult, err := env.RunAgent(multiLinePrompt)\\n   467→\\trequire.NoError(t, err)\\n   468→\\tAssertAgentSuccess(t, result, err)\\n   469→\\n   470→\\trequire.True(t, env.FileExists(\\\"partial.go\\\"))\\n   471→\\n   472→\\t// Check rewind points before commit\\n   473→\\tpointsBefore := env.GetRewindPoints()\\n   474→\\tt.Logf(\\\"Rewind points before commit: %d\\\", len(pointsBefore))\\n   475→\\n   476→\\t// Simulate partial staging by temporarily replacing file with partial content\\n   477→\\t// Save the full content\\n   478→\\tfullContent := env.ReadFile(\\\"partial.go\\\")\\n   479→\\tt.Logf(\\\"Full content length: %d bytes\\\", len(fullContent))\\n   480→\\n   481→\\t// Write partial content (only first two functions)\\n   482→\\tpartialContent := `package main\\n   483→\\n   484→func First() int {\\n   485→\\treturn 1\\n   486→}\\n   487→\\n   488→func Second() int {\\n   489→\\treturn 2\\n   490→}\\n   491→`\\n   492→\\tenv.WriteFile(\\\"partial.go\\\", partialContent)\\n   493→\\n   494→\\t// Commit the partial content\\n   495→\\tt.Log(\\\"Committing partial content (First and Second functions)\\\")\\n   496→\\tenv.GitCommitWithShadowHooks(\\\"Add first two functions\\\", \\\"partial.go\\\")\\n   497→\\n   498→\\t// Verify first checkpoint was created\\n   499→\\tcheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n   500→\\trequire.GreaterOrEqual(t, len(checkpointIDs), 1, \\\"Should have first checkpoint\\\")\\n   501→\\tt.Logf(\\\"First checkpoint ID: %s\\\", checkpointIDs[0])\\n   502→\\n   503→\\t// Restore the full content (simulating remaining changes still in worktree)\\n   504→\\tenv.WriteFile(\\\"partial.go\\\", fullContent)\\n   505→\\n   506→\\t// Commit the remaining content\\n   507→\\tt.Log(\\\"Committing full content (all functions)\\\")\\n   508→\\tenv.GitCommitWithShadowHooks(\\\"Add remaining functions\\\", \\\"partial.go\\\")\\n   509→\\n   510→\\t// Verify second checkpoint was created\\n   511→\\tcheckpointIDsAfter := env.GetAllCheckpointIDsFromHistory()\\n   512→\\trequire.GreaterOrEqual(t, len(checkpointIDsAfter), 2, \\\"Should have two checkpoints\\\")\\n   513→\\tt.Logf(\\\"Checkpoint IDs: %v\\\", checkpointIDsAfter)\\n   514→\\n   515→\\t// Each commit should have its own unique checkpoint ID\\n   516→\\tassert.NotEqual(t, checkpointIDsAfter[0], checkpointIDsAfter[1],\\n   517→\\t\\t\\\"Each commit should have its own unique checkpoint ID\\\")\\n   518→\\n   519→\\t// Validate checkpoints have proper metadata and transcripts\\n   520→\\t// checkpointIDsAfter[0] is the most recent (full content commit)\\n   521→\\t// checkpointIDsAfter[1] is the earlier commit (partial content)\\n   522→\\t//\\n   523→\\t// Both commits are from the same session (single prompt), so both have\\n   524→\\t// the same full transcript referencing partial.go and the function names.\\n   525→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   526→\\t\\tCheckpointID:              checkpointIDsAfter[0],\\n   527→\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   528→\\t\\tFilesTouched:              []string{\\\"partial.go\\\"},\\n   529→\\t\\tExpectedTranscriptContent: []string{\\\"partial.go\\\", \\\"First\\\", \\\"Second\\\", \\\"Third\\\", \\\"Fourth\\\"},\\n   530→\\t})\\n   531→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   532→\\t\\tCheckpointID:              checkpointIDsAfter[1],\\n   533→\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   534→\\t\\tFilesTouched:              []string{\\\"partial.go\\\"},\\n   535→\\t\\tExpectedTranscriptContent: []string{\\\"partial.go\\\", \\\"First\\\", \\\"Second\\\", \\\"Third\\\", \\\"Fourth\\\"},\\n   536→\\t})\\n   537→}\\n   538→\\n   539→// TestE2E_ContentAwareOverlap_RevertAndReplace tests content-aware overlap detection\\n   540→// when user reverts session changes and writes different content.\\n   541→//\\n   542→// Content-Aware Overlap Detection:\\n   543→// - Agent creates file X with content \\\"hello\\\"\\n   544→// - User reverts X (git checkout -- X)\\n   545→// - User writes completely different content\\n   546→// - User commits\\n   547→// - Content mismatch → NO checkpoint trailer added\\n   548→func TestE2E_ContentAwareOverlap_RevertAndReplace(t *testing.T) {\\n   549→\\tt.Parallel()\\n   550→\\n   551→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   552→\\n   553→\\t// Agent creates a file\\n   554→\\tt.Log(\\\"Agent creating file with specific content\\\")\\n   555→\\tcreatePrompt := `Create a file called overlap_test.go with this exact content:\\n   556→package main\\n   557→\\n   558→func OverlapOriginal() string {\\n   559→\\treturn \\\"original content from agent\\\"\\n   560→}\\n   561→\\n   562→Create only this file.`\\n   563→\\n   564→\\tresult, err := env.RunAgent(createPrompt)\\n   565→\\trequire.NoError(t, err)\\n   566→\\tAssertAgentSuccess(t, result, err)\\n   567→\\n   568→\\trequire.True(t, env.FileExists(\\\"overlap_test.go\\\"))\\n   569→\\toriginalContent := env.ReadFile(\\\"overlap_test.go\\\")\\n   570→\\tt.Logf(\\\"Original content: %s\\\", originalContent)\\n   571→\\n   572→\\t// Verify rewind points exist (session tracked the change)\\n   573→\\tpoints := env.GetRewindPoints()\\n   574→\\trequire.GreaterOrEqual(t, len(points), 1, \\\"Should have rewind points\\\")\\n   575→\\n   576→\\t// User reverts the file and writes completely different content\\n   577→\\tt.Log(\\\"User reverting file and writing different content\\\")\\n   578→\\tdifferentContent := `package main\\n   579→\\n   580→func CompletelyDifferent() string {\\n   581→\\treturn \\\"user wrote this, not the agent\\\"\\n   582→}\\n   583→`\\n   584→\\tenv.WriteFile(\\\"overlap_test.go\\\", differentContent)\\n   585→\\n   586→\\t// Verify content is different\\n   587→\\tcurrentContent := env.ReadFile(\\\"overlap_test.go\\\")\\n   588→\\tassert.NotEqual(t, originalContent, currentContent)\\n   589→\\n   590→\\t// Commits before this test\\n   591→\\tcommitsBefore := env.GetCommitCount()\\n   592→\\n   593→\\t// User commits the different content\\n   594→\\tt.Log(\\\"Committing user-written content\\\")\\n   595→\\tenv.GitCommitWithShadowHooks(\\\"Add overlap test file\\\", \\\"overlap_test.go\\\")\\n   596→\\n   597→\\t// Verify commit was made\\n   598→\\tcommitsAfter := env.GetCommitCount()\\n   599→\\tassert.Equal(t, commitsBefore+1, commitsAfter, \\\"Should have one new commit\\\")\\n   600→\\n   601→\\t// Check for checkpoint trailer\\n   602→\\t// With content-aware overlap detection, if the user completely replaced\\n   603→\\t// the agent's content (new file with different hash), there should be\\n   604→\\t// NO checkpoint trailer added. This is documented in checkpoint-scenarios.md\\n   605→\\t// under \\\"Content-Aware Overlap Detection\\\".\\n   606→\\tcheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n   607→\\tt.Logf(\\\"Checkpoint IDs found: %v\\\", checkpointIDs)\\n   608→\\n   609→\\t// The first commit (Initial commit from NewFeatureBranchEnv) doesn't have a checkpoint.\\n   610→\\t// Only agent-assisted commits should have checkpoint trailers.\\n   611→\\t// When user completely replaces agent content, content-aware detection should\\n   612→\\t// prevent the checkpoint trailer from being added.\\n   613→\\t//\\n   614→\\t// Per docs/architecture/checkpoint-scenarios.md:\\n   615→\\t// - New file + content hash mismatch → No overlap → No checkpoint trailer\\n   616→\\tassert.Empty(t, checkpointIDs,\\n   617→\\t\\t\\\"Content-aware detection should prevent checkpoint trailer when user completely replaces agent content\\\")\\n   618→}\\n   619→\\n   620→// TestE2E_Scenario1_BasicFlow verifies the simplest workflow matches the documented scenario.\\n   621→//\\n   622→// Scenario 1: Prompt → Changes → Prompt Finishes → User Commits\\n   623→// This test explicitly verifies the documented flow.\\n   624→func TestE2E_Scenario1_BasicFlow(t *testing.T) {\\n   625→\\tt.Parallel()\\n   626→\\n   627→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   628→\\n   629→\\t// 1. User submits prompt (triggers UserPromptSubmit hook → InitializeSession)\\n   630→\\tt.Log(\\\"Step 1: User submits prompt\\\")\\n   631→\\n   632→\\t// 2. Claude makes changes (creates files)\\n   633→\\tprompt := `Create a file called scenario1.go with this content:\\n   634→package main\\n   635→func Scenario1() {}\\n   636→Create only this file.`\\n   637→\\n   638→\\tresult, err := env.RunAgent(prompt)\\n   639→\\trequire.NoError(t, err)\\n   640→\\tAssertAgentSuccess(t, result, err)\\n   641→\\n   642→\\t// Verify file was created\\n   643→\\trequire.True(t, env.FileExists(\\\"scenario1.go\\\"))\\n   644→\\n   645→\\t// 3. After stop hook: checkpoint is saved, FilesTouched is set\\n   646→\\tt.Log(\\\"Step 3: Checking rewind points after stop\\\")\\n   647→\\tpoints := env.GetRewindPoints()\\n   648→\\trequire.GreaterOrEqual(t, len(points), 1, \\\"Should have rewind point after stop\\\")\\n   649→\\tt.Logf(\\\"Rewind points: %d\\\", len(points))\\n   650→\\n   651→\\t// 4. User commits (triggers prepare-commit-msg and post-commit hooks)\\n   652→\\tt.Log(\\\"Step 4: User commits\\\")\\n   653→\\tenv.GitCommitWithShadowHooks(\\\"Add scenario1 file\\\", \\\"scenario1.go\\\")\\n   654→\\n   655→\\t// 5. Verify checkpoint was created with trailer\\n   656→\\tcheckpointID, err := env.GetLatestCheckpointIDFromHistory()\\n   657→\\trequire.NoError(t, err, \\\"Should find checkpoint in commit history\\\")\\n   658→\\tassert.NotEmpty(t, checkpointID, \\\"Commit should have Entire-Checkpoint trailer\\\")\\n   659→\\tt.Logf(\\\"Checkpoint ID: %s\\\", checkpointID)\\n   660→\\n   661→\\t// 6. Verify shadow branch was cleaned up and metadata branch exists\\n   662→\\tassert.True(t, env.BranchExists(\\\"entire/checkpoints/v1\\\"),\\n   663→\\t\\t\\\"entire/checkpoints/v1 branch should exist after condensation\\\")\\n   664→\\n   665→\\t// 7. Validate checkpoint has proper metadata and transcript\\n   666→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   667→\\t\\tCheckpointID:              checkpointID,\\n   668→\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   669→\\t\\tFilesTouched:              []string{\\\"scenario1.go\\\"},\\n   670→\\t\\tExpectedTranscriptContent: []string{\\\"scenario1.go\\\"},\\n   671→\\t})\\n   672→}\\n   673→\\n   674→// TestE2E_Scenario2_AgentCommitsDuringTurn verifies the deferred finalization flow.\\n   675→//\\n   676→// Scenario 2: Prompt Commits Within Single Turn\\n   677→// - Agent commits during ACTIVE phase\\n   678→// - PostCommit saves provisional transcript\\n   679→// - HandleTurnEnd (Stop hook) finalizes with full transcript\\n   680→func TestE2E_Scenario2_AgentCommitsDuringTurn(t *testing.T) {\\n   681→\\tt.Parallel()\\n   682→\\n   683→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   684→\\n   685→\\tcommitsBefore := env.GetCommitCount()\\n   686→\\n   687→\\t// Agent creates file and commits it\\n   688→\\tt.Log(\\\"Agent creating file and committing\\\")\\n   689→\\tcommitPrompt := `Create a file called agent_commit.go with this content:\\n   690→package main\\n   691→func AgentCommit() {}\\n   692→\\n   693→Then commit it with: git add agent_commit.go && git commit -m \\\"Agent adds file\\\"\\n   694→\\n   695→Create the file first, then run the git commands.`\\n   696→\\n   697→\\tresult, err := env.RunAgentWithTools(commitPrompt, []string{\\\"Write\\\", \\\"Bash\\\"})\\n   698→\\trequire.NoError(t, err)\\n   699→\\tAssertAgentSuccess(t, result, err)\\n   700→\\n   701→\\t// Verify file was created\\n   702→\\trequire.True(t, env.FileExists(\\\"agent_commit.go\\\"))\\n   703→\\n   704→\\t// Verify commit was made\\n   705→\\tcommitsAfter := env.GetCommitCount()\\n   706→\\tassert.Greater(t, commitsAfter, commitsBefore, \\\"Agent should have made a commit\\\")\\n   707→\\n   708→\\t// Check commit message\\n   709→\\theadMsg := env.GetCommitMessage(env.GetHeadHash())\\n   710→\\tt.Logf(\\\"HEAD commit message: %s\\\", headMsg)\\n   711→\\n   712→\\t// Check for checkpoint trailer\\n   713→\\tcheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n   714→\\tt.Logf(\\\"Checkpoint IDs: %v\\\", checkpointIDs)\\n   715→\\n   716→\\t// Verify metadata branch exists (if checkpoint was created)\\n   717→\\tif len(checkpointIDs) > 0 {\\n   718→\\t\\tassert.True(t, env.BranchExists(\\\"entire/checkpoints/v1\\\"),\\n   719→\\t\\t\\t\\\"entire/checkpoints/v1 branch should exist\\\")\\n   720→\\n   721→\\t\\t// Validate checkpoint has proper metadata and transcript\\n   722→\\t\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   723→\\t\\t\\tCheckpointID:              checkpointIDs[0],\\n   724→\\t\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   725→\\t\\t\\tFilesTouched:              []string{\\\"agent_commit.go\\\"},\\n   726→\\t\\t\\tExpectedTranscriptContent: []string{\\\"agent_commit.go\\\"},\\n   727→\\t\\t})\\n   728→\\t}\\n   729→}\\n   730→\\n   731→// =============================================================================\\n   732→// Tests for MODIFYING EXISTING FILES (not just creating new ones)\\n   733→// =============================================================================\\n   734→// These tests ensure checkpoints work correctly when the agent modifies\\n   735→// tracked files that already exist in the repository, which behaves differently\\n   736→// from creating new (untracked) files with respect to git stash, staging, etc.\\n   737→\\n   738→// TestE2E_ExistingFiles_ModifyAndCommit tests basic workflow where agent\\n   739→// modifies an existing tracked file instead of creating a new one.\\n   740→func TestE2E_ExistingFiles_ModifyAndCommit(t *testing.T) {\\n   741→\\tt.Parallel()\\n   742→\\n   743→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   744→\\n   745→\\t// Create and commit an existing file first\\n   746→\\tenv.WriteFile(\\\"config.go\\\", `package main\\n   747→\\n   748→var Config = map[string]string{\\n   749→\\t\\\"version\\\": \\\"1.0\\\",\\n   750→}\\n   751→`)\\n   752→\\tenv.GitCommitWithShadowHooks(\\\"Add initial config\\\", \\\"config.go\\\")\\n   753→\\n   754→\\t// Agent modifies the existing file\\n   755→\\tt.Log(\\\"Agent modifying existing config.go\\\")\\n   756→\\tprompt := `Modify the file config.go to add a new config key \\\"debug\\\" with value \\\"true\\\".\\n   757→Keep the existing content and just add the new key. Only modify this one file.`\\n   758→\\n   759→\\tresult, err := env.RunAgent(prompt)\\n   760→\\trequire.NoError(t, err)\\n   761→\\tAssertAgentSuccess(t, result, err)\\n   762→\\n   763→\\t// Verify file was modified\\n   764→\\tcontent := env.ReadFile(\\\"config.go\\\")\\n   765→\\tassert.Contains(t, content, \\\"debug\\\", \\\"config.go should contain debug key\\\")\\n   766→\\n   767→\\t// User commits the modification\\n   768→\\tt.Log(\\\"User committing modified config.go\\\")\\n   769→\\tenv.GitCommitWithShadowHooks(\\\"Add debug config\\\", \\\"config.go\\\")\\n   770→\\n   771→\\t// Verify checkpoint was created\\n   772→\\tcheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n   773→\\t// First commit (initial config) may or may not have checkpoint depending on session state\\n   774→\\t// The agent's modification commit should have a checkpoint\\n   775→\\trequire.NotEmpty(t, checkpointIDs, \\\"Should have at least one checkpoint\\\")\\n   776→\\tt.Logf(\\\"Checkpoint IDs: %v\\\", checkpointIDs)\\n   777→}\\n   778→\\n   779→// TestE2E_ExistingFiles_StashModifications tests stashing modifications to\\n   780→// tracked files (not new untracked files). This exercises the standard git stash\\n   781→// behavior (without -u flag) since modifications to tracked files are stashable.\\n   782→func TestE2E_ExistingFiles_StashModifications(t *testing.T) {\\n   783→\\tt.Parallel()\\n   784→\\n   785→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   786→\\n   787→\\t// Create and commit two existing files\\n   788→\\tenv.WriteFile(\\\"fileA.go\\\", \\\"package main\\\\n\\\\nfunc A() { /* original */ }\\\\n\\\")\\n   789→\\tenv.WriteFile(\\\"fileB.go\\\", \\\"package main\\\\n\\\\nfunc B() { /* original */ }\\\\n\\\")\\n   790→\\tenv.GitCommitWithShadowHooks(\\\"Add initial files\\\", \\\"fileA.go\\\", \\\"fileB.go\\\")\\n   791→\\n   792→\\t// Agent modifies both files\\n   793→\\tt.Log(\\\"Agent modifying fileA.go and fileB.go\\\")\\n   794→\\tprompt := `Modify these files:\\n   795→1. In fileA.go, change the comment from \\\"original\\\" to \\\"modified by agent\\\"\\n   796→2. In fileB.go, change the comment from \\\"original\\\" to \\\"modified by agent\\\"\\n   797→Only modify these two files.`\\n   798→\\n   799→\\tresult, err := env.RunAgent(prompt)\\n   800→\\trequire.NoError(t, err)\\n   801→\\tAssertAgentSuccess(t, result, err)\\n   802→\\n   803→\\t// Verify both files were modified\\n   804→\\tcontentA := env.ReadFile(\\\"fileA.go\\\")\\n   805→\\tcontentB := env.ReadFile(\\\"fileB.go\\\")\\n   806→\\tassert.Contains(t, contentA, \\\"modified by agent\\\", \\\"fileA.go should be modified\\\")\\n   807→\\tassert.Contains(t, contentB, \\\"modified by agent\\\", \\\"fileB.go should be modified\\\")\\n   808→\\n   809→\\t// User commits only fileA.go\\n   810→\\tt.Log(\\\"Committing only fileA.go\\\")\\n   811→\\tenv.GitCommitWithShadowHooks(\\\"Update fileA\\\", \\\"fileA.go\\\")\\n   812→\\tcheckpoint1 := env.GetLatestCheckpointID()\\n   813→\\trequire.NotEmpty(t, checkpoint1, \\\"First commit should have checkpoint\\\")\\n   814→\\n   815→\\t// User stashes fileB.go modifications (tracked file, standard stash works)\\n   816→\\tt.Log(\\\"Stashing fileB.go modifications\\\")\\n   817→\\tenv.GitStash()\\n   818→\\n   819→\\t// Verify fileB.go is reverted to original\\n   820→\\tcontentB = env.ReadFile(\\\"fileB.go\\\")\\n   821→\\tassert.Contains(t, contentB, \\\"original\\\", \\\"fileB.go should be reverted after stash\\\")\\n   822→\\tassert.NotContains(t, contentB, \\\"modified by agent\\\", \\\"fileB.go should not have agent changes\\\")\\n   823→\\n   824→\\t// User pops the stash and commits fileB.go\\n   825→\\tt.Log(\\\"Popping stash and committing fileB.go\\\")\\n   826→\\tenv.GitStashPop()\\n   827→\\tcontentB = env.ReadFile(\\\"fileB.go\\\")\\n   828→\\tassert.Contains(t, contentB, \\\"modified by agent\\\", \\\"fileB.go should have agent changes after stash pop\\\")\\n   829→\\n   830→\\tenv.GitCommitWithShadowHooks(\\\"Update fileB\\\", \\\"fileB.go\\\")\\n   831→\\tcheckpoint2 := env.GetLatestCheckpointID()\\n   832→\\n   833→\\t// Both commits should have checkpoints\\n   834→\\trequire.NotEmpty(t, checkpoint2, \\\"Second commit should have checkpoint\\\")\\n   835→\\tassert.NotEqual(t, checkpoint1, checkpoint2, \\\"Checkpoints should be different\\\")\\n   836→\\n   837→\\tt.Logf(\\\"Checkpoint 1: %s, Checkpoint 2: %s\\\", checkpoint1, checkpoint2)\\n   838→}\\n   839→\\n   840→// TestE2E_ExistingFiles_SplitCommits tests user splitting agent's modifications\\n   841→// to multiple existing files into separate commits.\\n   842→func TestE2E_ExistingFiles_SplitCommits(t *testing.T) {\\n   843→\\tt.Parallel()\\n   844→\\n   845→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   846→\\n   847→\\t// Create and commit multiple existing files\\n   848→\\tenv.WriteFile(\\\"model.go\\\", \\\"package main\\\\n\\\\ntype Model struct{}\\\\n\\\")\\n   849→\\tenv.WriteFile(\\\"view.go\\\", \\\"package main\\\\n\\\\ntype View struct{}\\\\n\\\")\\n   850→\\tenv.WriteFile(\\\"controller.go\\\", \\\"package main\\\\n\\\\ntype Controller struct{}\\\\n\\\")\\n   851→\\tenv.GitCommitWithShadowHooks(\\\"Add MVC scaffolding\\\", \\\"model.go\\\", \\\"view.go\\\", \\\"controller.go\\\")\\n   852→\\n   853→\\t// Agent modifies all three files\\n   854→\\tt.Log(\\\"Agent modifying model.go, view.go, controller.go\\\")\\n   855→\\tprompt := `Add a Name field (string type) to each struct in these files:\\n   856→1. model.go - add Name string to Model struct\\n   857→2. view.go - add Name string to View struct\\n   858→3. controller.go - add Name string to Controller struct\\n   859→Only modify these three files.`\\n   860→\\n   861→\\tresult, err := env.RunAgent(prompt)\\n   862→\\trequire.NoError(t, err)\\n   863→\\tAssertAgentSuccess(t, result, err)\\n   864→\\n   865→\\t// User commits each file separately\\n   866→\\tt.Log(\\\"Committing model.go\\\")\\n   867→\\tenv.GitCommitWithShadowHooks(\\\"Add Name to Model\\\", \\\"model.go\\\")\\n   868→\\tcheckpointModel := env.GetLatestCheckpointID()\\n   869→\\trequire.NotEmpty(t, checkpointModel, \\\"Model commit should have checkpoint\\\")\\n   870→\\n   871→\\tt.Log(\\\"Committing view.go\\\")\\n   872→\\tenv.GitCommitWithShadowHooks(\\\"Add Name to View\\\", \\\"view.go\\\")\\n   873→\\tcheckpointView := env.GetLatestCheckpointID()\\n   874→\\trequire.NotEmpty(t, checkpointView, \\\"View commit should have checkpoint\\\")\\n   875→\\n   876→\\tt.Log(\\\"Committing controller.go\\\")\\n   877→\\tenv.GitCommitWithShadowHooks(\\\"Add Name to Controller\\\", \\\"controller.go\\\")\\n   878→\\tcheckpointController := env.GetLatestCheckpointID()\\n   879→\\trequire.NotEmpty(t, checkpointController, \\\"Controller commit should have checkpoint\\\")\\n   880→\\n   881→\\t// All three checkpoints should be different\\n   882→\\tassert.NotEqual(t, checkpointModel, checkpointView)\\n   883→\\tassert.NotEqual(t, checkpointView, checkpointController)\\n   884→\\tassert.NotEqual(t, checkpointModel, checkpointController)\\n   885→\\n   886→\\tt.Logf(\\\"Checkpoints: model=%s, view=%s, controller=%s\\\",\\n   887→\\t\\tcheckpointModel, checkpointView, checkpointController)\\n   888→\\n   889→\\t// Validate each checkpoint has the correct files_touched\\n   890→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   891→\\t\\tCheckpointID: checkpointModel,\\n   892→\\t\\tStrategy:     \\\"manual-commit\\\",\\n   893→\\t\\tFilesTouched: []string{\\\"model.go\\\"},\\n   894→\\t})\\n   895→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   896→\\t\\tCheckpointID: checkpointView,\\n   897→\\t\\tStrategy:     \\\"manual-commit\\\",\\n   898→\\t\\tFilesTouched: []string{\\\"view.go\\\"},\\n   899→\\t})\\n   900→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   901→\\t\\tCheckpointID: checkpointController,\\n   902→\\t\\tStrategy:     \\\"manual-commit\\\",\\n   903→\\t\\tFilesTouched: []string{\\\"controller.go\\\"},\\n   904→\\t})\\n   905→\\n   906→\\t// No shadow branches should remain after all files committed\\n   907→\\tentireBranches := env.ListBranchesWithPrefix(\\\"entire/\\\")\\n   908→\\tfor _, b := range entireBranches {\\n   909→\\t\\tassert.Equal(t, \\\"entire/checkpoints/v1\\\", b,\\n   910→\\t\\t\\t\\\"Unexpected shadow branch after all files committed: %s\\\", b)\\n   911→\\t}\\n   912→}\\n   913→\\n   914→// TestE2E_ExistingFiles_RevertModification tests that modifying an existing file\\n   915→// that was touched by the session ALWAYS gets a checkpoint, even if the user writes\\n   916→// completely different content.\\n   917→//\\n   918→// This is intentional behavior: for files that already exist in HEAD (modified files),\\n   919→// we always count as overlap because the user is editing a file the session worked on.\\n   920→// Content-aware detection only applies to NEW files (don't exist in HEAD).\\n   921→//\\n   922→// See content_overlap.go for the rationale.\\n   923→func TestE2E_ExistingFiles_RevertModification(t *testing.T) {\\n   924→\\tt.Parallel()\\n   925→\\n   926→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   927→\\n   928→\\t// Create and commit an existing file\\n   929→\\toriginalContent := `package main\\n   930→\\n   931→// placeholder\\n   932→`\\n   933→\\tenv.WriteFile(\\\"calc.go\\\", originalContent)\\n   934→\\tenv.GitCommitWithShadowHooks(\\\"Add placeholder\\\", \\\"calc.go\\\")\\n   935→\\n   936→\\t// Agent modifies the existing file\\n   937→\\tt.Log(\\\"Agent modifying calc.go\\\")\\n   938→\\tprompt := `Replace the contents of calc.go with this exact code:\\n   939→package main\\n   940→\\n   941→func AgentMultiply(a, b int) int {\\n   942→\\treturn a * b\\n   943→}\\n   944→\\n   945→Only modify calc.go, nothing else.`\\n   946→\\n   947→\\tresult, err := env.RunAgent(prompt)\\n   948→\\trequire.NoError(t, err)\\n   949→\\tAssertAgentSuccess(t, result, err)\\n   950→\\n   951→\\t// Verify agent modified the file\\n   952→\\tmodifiedContent := env.ReadFile(\\\"calc.go\\\")\\n   953→\\tassert.Contains(t, modifiedContent, \\\"AgentMultiply\\\", \\\"calc.go should have AgentMultiply function\\\")\\n   954→\\n   955→\\t// User reverts and writes completely different content\\n   956→\\tt.Log(\\\"User reverting and writing completely different content\\\")\\n   957→\\tuserContent := `package main\\n   958→\\n   959→func UserAdd(x, y int) int {\\n   960→\\treturn x + y\\n   961→}\\n   962→`\\n   963→\\tenv.WriteFile(\\\"calc.go\\\", userContent)\\n   964→\\n   965→\\t// User commits their changes\\n   966→\\tt.Log(\\\"Committing user's changes\\\")\\n   967→\\tenv.GitCommitWithShadowHooks(\\\"Add user functions\\\", \\\"calc.go\\\")\\n   968→\\n   969→\\t// For MODIFIED files (existing in HEAD), we always count as overlap.\\n   970→\\t// The checkpoint SHOULD be created even though content is different.\\n   971→\\t// This is because the session touched this file, so any commit to it\\n   972→\\t// should be linked to preserve the editing history.\\n   973→\\tcheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n   974→\\tt.Logf(\\\"Checkpoint IDs: %v\\\", checkpointIDs)\\n   975→\\n   976→\\tlatestCheckpoint := env.GetLatestCheckpointID()\\n   977→\\tassert.NotEmpty(t, latestCheckpoint,\\n   978→\\t\\t\\\"Modified files should always get checkpoint (content-aware only applies to new files)\\\")\\n   979→}\\n   980→\\n   981→// TestE2E_ExistingFiles_MixedNewAndModified tests a scenario where the agent\\n   982→// both creates new files AND modifies existing files in the same session.\\n   983→func TestE2E_ExistingFiles_MixedNewAndModified(t *testing.T) {\\n   984→\\tt.Parallel()\\n   985→\\n   986→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   987→\\n   988→\\t// Create and commit an existing file\\n   989→\\tenv.WriteFile(\\\"main.go\\\", `package main\\n   990→\\n   991→func main() {\\n   992→\\t// TODO: add imports\\n   993→}\\n   994→`)\\n   995→\\tenv.GitCommitWithShadowHooks(\\\"Add main.go\\\", \\\"main.go\\\")\\n   996→\\n   997→\\t// Agent modifies existing file AND creates new files\\n   998→\\tt.Log(\\\"Agent modifying main.go and creating new files\\\")\\n   999→\\tprompt := `Do these tasks:\\n  1000→1. Create a new file utils.go with: package main; func Helper() string { return \\\"helper\\\" }\\n  1001→2. Create a new file types.go with: package main; type Config struct { Name string }\\n  1002→3. Modify main.go to add a comment \\\"// imports utils and types\\\" at the top (after package main)\\n  1003→Complete all three tasks.`\\n  1004→\\n  1005→\\tresult, err := env.RunAgent(prompt)\\n  1006→\\trequire.NoError(t, err)\\n  1007→\\tAssertAgentSuccess(t, result, err)\\n  1008→\\n  1009→\\t// Verify all changes\\n  1010→\\trequire.True(t, env.FileExists(\\\"utils.go\\\"), \\\"utils.go should exist\\\")\\n  1011→\\trequire.True(t, env.FileExists(\\\"types.go\\\"), \\\"types.go should exist\\\")\\n  1012→\\tmainContent := env.ReadFile(\\\"main.go\\\")\\n  1013→\\tassert.Contains(t, mainContent, \\\"imports utils and types\\\", \\\"main.go should be modified\\\")\\n  1014→\\n  1015→\\t// User commits existing file modification first\\n  1016→\\tt.Log(\\\"Committing main.go modification\\\")\\n  1017→\\tenv.GitCommitWithShadowHooks(\\\"Update main.go imports comment\\\", \\\"main.go\\\")\\n  1018→\\tcheckpoint1 := env.GetLatestCheckpointID()\\n  1019→\\trequire.NotEmpty(t, checkpoint1, \\\"main.go commit should have checkpoint\\\")\\n  1020→\\n  1021→\\t// User commits new files together\\n  1022→\\tt.Log(\\\"Committing new files utils.go and types.go\\\")\\n  1023→\\tenv.GitCommitWithShadowHooks(\\\"Add utils and types\\\", \\\"utils.go\\\", \\\"types.go\\\")\\n  1024→\\tcheckpoint2 := env.GetLatestCheckpointID()\\n  1025→\\trequire.NotEmpty(t, checkpoint2, \\\"New files commit should have checkpoint\\\")\\n  1026→\\n  1027→\\tassert.NotEqual(t, checkpoint1, checkpoint2, \\\"Checkpoints should be different\\\")\\n  1028→\\tt.Logf(\\\"Checkpoint 1 (modified): %s, Checkpoint 2 (new): %s\\\", checkpoint1, checkpoint2)\\n  1029→}\\n  1030→\\n  1031→// TestE2E_EndedSession_UserCommitsAfterExit tests that after agent exits\\n  1032→// (session naturally ends), user commits still get checkpoint trailers.\\n  1033→// This exercises the ENDED + GitCommit → ActionCondenseIfFilesTouched path.\\n  1034→func TestE2E_EndedSession_UserCommitsAfterExit(t *testing.T) {\\n  1035→\\tt.Parallel()\\n  1036→\\n  1037→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n  1038→\\n  1039→\\t// Agent creates files A, B, C — session ends when agent exits\\n  1040→\\tprompt := `Create these files:\\n  1041→1. ended_a.go with content: package main; func EndedA() {}\\n  1042→2. ended_b.go with content: package main; func EndedB() {}\\n  1043→3. ended_c.go with content: package main; func EndedC() {}\\n  1044→Create all three files, nothing else.`\\n  1045→\\n  1046→\\tresult, err := env.RunAgent(prompt)\\n  1047→\\trequire.NoError(t, err)\\n  1048→\\tAssertAgentSuccess(t, result, err)\\n  1049→\\n  1050→\\trequire.True(t, env.FileExists(\\\"ended_a.go\\\"), \\\"ended_a.go should exist\\\")\\n  1051→\\trequire.True(t, env.FileExists(\\\"ended_b.go\\\"), \\\"ended_b.go should exist\\\")\\n  1052→\\trequire.True(t, env.FileExists(\\\"ended_c.go\\\"), \\\"ended_c.go should exist\\\")\\n  1053→\\n  1054→\\t// User commits A and B together\\n  1055→\\tt.Log(\\\"Committing ended_a.go and ended_b.go\\\")\\n  1056→\\tenv.GitCommitWithShadowHooks(\\\"Add ended files A and B\\\", \\\"ended_a.go\\\", \\\"ended_b.go\\\")\\n  1057→\\tcheckpointIDsAfterFirst := env.GetAllCheckpointIDsFromHistory()\\n  1058→\\trequire.GreaterOrEqual(t, len(checkpointIDsAfterFirst), 1, \\\"Should have first checkpoint\\\")\\n  1059→\\tcheckpointAB := checkpointIDsAfterFirst[0]\\n  1060→\\tt.Logf(\\\"Checkpoint for A,B: %s\\\", checkpointAB)\\n  1061→\\n  1062→\\t// User commits C\\n  1063→\\tt.Log(\\\"Committing ended_c.go\\\")\\n  1064→\\tenv.GitCommitWithShadowHooks(\\\"Add ended file C\\\", \\\"ended_c.go\\\")\\n  1065→\\tcheckpointIDsAfterSecond := env.GetAllCheckpointIDsFromHistory()\\n  1066→\\trequire.GreaterOrEqual(t, len(checkpointIDsAfterSecond), 2, \\\"Should have two checkpoints\\\")\\n  1067→\\tcheckpointC := checkpointIDsAfterSecond[0]\\n  1068→\\tt.Logf(\\\"Checkpoint for C: %s\\\", checkpointC)\\n  1069→\\n  1070→\\t// Checkpoint IDs must be unique\\n  1071→\\tassert.NotEqual(t, checkpointAB, checkpointC,\\n  1072→\\t\\t\\\"Each commit should have its own unique checkpoint ID\\\")\\n  1073→\\n  1074→\\t// Validate both checkpoints\\n  1075→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n  1076→\\t\\tCheckpointID: checkpointAB,\\n  1077→\\t\\tStrategy:     \\\"manual-commit\\\",\\n  1078→\\t\\tFilesTouched: []string{\\\"ended_a.go\\\", \\\"ended_b.go\\\"},\\n  1079→\\t})\\n  1080→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n  1081→\\t\\tCheckpointID: checkpointC,\\n  1082→\\t\\tStrategy:     \\\"manual-commit\\\",\\n  1083→\\t\\tFilesTouched: []string{\\\"ended_c.go\\\"},\\n  1084→\\t})\\n  1085→\\n  1086→\\t// No shadow branches should remain\\n  1087→\\tentireBranches := env.ListBranchesWithPrefix(\\\"entire/\\\")\\n  1088→\\tfor _, b := range entireBranches {\\n  1089→\\t\\tassert.Equal(t, \\\"entire/checkpoints/v1\\\", b,\\n  1090→\\t\\t\\t\\\"Unexpected shadow branch after all files committed: %s\\\", b)\\n  1091→\\t}\\n  1092→}\\n  1093→\\n  1094→// TestE2E_DeletedFiles_CommitDeletion tests that deleting a file that was tracked\\n  1095→// in the session gets handled properly when committed via git rm.\\n  1096→func TestE2E_DeletedFiles_CommitDeletion(t *testing.T) {\\n  1097→\\tt.Parallel()\\n  1098→\\n  1099→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n  1100→\\n  1101→\\t// Pre-commit a file that will be deleted\\n  1102→\\tenv.WriteFile(\\\"to_delete.go\\\", \\\"package main\\\\n\\\\nfunc ToDelete() {}\\\\n\\\")\\n  1103→\\tenv.GitCommitWithShadowHooks(\\\"Add to_delete.go\\\", \\\"to_delete.go\\\")\\n  1104→\\n  1105→\\t// Agent deletes it and creates a replacement\\n  1106→\\tprompt := `Do these two tasks:\\n  1107→1. Delete the file to_delete.go (use: rm to_delete.go)\\n  1108→2. Create a new file replacement.go with content: package main; func Replacement() {}\\n  1109→\\n  1110→Do both tasks.`\\n  1111→\\n  1112→\\tresult, err := env.RunAgentWithTools(prompt, []string{\\\"Write\\\", \\\"Bash\\\"})\\n  1113→\\trequire.NoError(t, err)\\n  1114→\\tAssertAgentSuccess(t, result, err)\\n  1115→\\n  1116→\\t// to_delete.go should be gone, replacement.go should exist\\n  1117→\\tassert.False(t, env.FileExists(\\\"to_delete.go\\\"), \\\"to_delete.go should be deleted\\\")\\n  1118→\\trequire.True(t, env.FileExists(\\\"replacement.go\\\"), \\\"replacement.go should exist\\\")\\n  1119→\\n  1120→\\t// Commit the replacement file first\\n  1121→\\tt.Log(\\\"Committing replacement.go\\\")\\n  1122→\\tenv.GitCommitWithShadowHooks(\\\"Add replacement\\\", \\\"replacement.go\\\")\\n  1123→\\tcheckpointIDsAfterFirst := env.GetAllCheckpointIDsFromHistory()\\n  1124→\\trequire.GreaterOrEqual(t, len(checkpointIDsAfterFirst), 1, \\\"Should have checkpoint for replacement\\\")\\n  1125→\\tcheckpointReplacement := checkpointIDsAfterFirst[0]\\n  1126→\\tt.Logf(\\\"Checkpoint for replacement: %s\\\", checkpointReplacement)\\n  1127→\\n  1128→\\t// Commit the deletion via git rm\\n  1129→\\tt.Log(\\\"Committing deletion of to_delete.go\\\")\\n  1130→\\tenv.GitRm(\\\"to_delete.go\\\")\\n  1131→\\tenv.GitCommitStagedWithShadowHooks(\\\"Remove to_delete.go\\\")\\n  1132→\\n  1133→\\t// Check if deletion got a checkpoint trailer\\n  1134→\\tcheckpointIDsAfterSecond := env.GetAllCheckpointIDsFromHistory()\\n  1135→\\tif len(checkpointIDsAfterSecond) > len(checkpointIDsAfterFirst) {\\n  1136→\\t\\tcheckpointDeletion := checkpointIDsAfterSecond[0]\\n  1137→\\t\\tt.Logf(\\\"Checkpoint for deletion: %s (carry-forward for deleted file)\\\", checkpointDeletion)\\n  1138→\\t\\tassert.NotEqual(t, checkpointReplacement, checkpointDeletion,\\n  1139→\\t\\t\\t\\\"Checkpoint IDs should be unique\\\")\\n  1140→\\t\\tenv.ValidateCheckpoint(CheckpointValidation{\\n  1141→\\t\\t\\tCheckpointID: checkpointDeletion,\\n  1142→\\t\\t\\tStrategy:     \\\"manual-commit\\\",\\n  1143→\\t\\t})\\n  1144→\\t} else {\\n  1145→\\t\\tt.Log(\\\"Deletion commit has no checkpoint trailer (deleted files may not carry forward)\\\")\\n  1146→\\t}\\n  1147→\\n  1148→\\t// Validate the replacement checkpoint\\n  1149→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n  1150→\\t\\tCheckpointID: checkpointReplacement,\\n  1151→\\t\\tStrategy:     \\\"manual-commit\\\",\\n  1152→\\t})\\n  1153→}\\n  1154→\\n  1155→// TestE2E_AgentCommitsMidTurn_UserCommitsRemainder tests that when the agent\\n  1156→// commits some files during its turn and the user commits the rest after,\\n  1157→// both get valid checkpoint trailers.\\n  1158→func TestE2E_AgentCommitsMidTurn_UserCommitsRemainder(t *testing.T) {\\n  1159→\\tt.Parallel()\\n  1160→\\n  1161→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n  1162→\\n  1163→\\tcommitsBefore := env.GetCommitCount()\\n  1164→\\n  1165→\\t// Agent creates 3 files and commits 2 mid-turn\\n  1166→\\tprompt := `Do these tasks in order:\\n  1167→1. Create file agent_mid1.go with content: package main; func AgentMid1() {}\\n  1168→2. Create file agent_mid2.go with content: package main; func AgentMid2() {}\\n  1169→3. Commit these two files: git add agent_mid1.go agent_mid2.go && git commit -m \\\"Agent adds mid1 and mid2\\\"\\n  1170→4. Create file user_remainder.go with content: package main; func UserRemainder() {}\\n  1171→\\n  1172→Do all tasks in order. Create each file, then commit the first two, then create the third.`\\n  1173→\\n  1174→\\tresult, err := env.RunAgentWithTools(prompt, []string{\\\"Write\\\", \\\"Bash\\\"})\\n  1175→\\trequire.NoError(t, err)\\n  1176→\\tAssertAgentSuccess(t, result, err)\\n  1177→\\n  1178→\\t// Verify all files were created\\n  1179→\\trequire.True(t, env.FileExists(\\\"agent_mid1.go\\\"), \\\"agent_mid1.go should exist\\\")\\n  1180→\\trequire.True(t, env.FileExists(\\\"agent_mid2.go\\\"), \\\"agent_mid2.go should exist\\\")\\n  1181→\\trequire.True(t, env.FileExists(\\\"user_remainder.go\\\"), \\\"user_remainder.go should exist\\\")\\n  1182→\\n  1183→\\t// Verify agent made a commit\\n  1184→\\tcommitsAfter := env.GetCommitCount()\\n  1185→\\tassert.Greater(t, commitsAfter, commitsBefore, \\\"Agent should have made a commit\\\")\\n  1186→\\n  1187→\\t// Get agent checkpoint IDs\\n  1188→\\tagentCheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n  1189→\\tt.Logf(\\\"Agent checkpoint IDs: %v\\\", agentCheckpointIDs)\\n  1190→\\n  1191→\\t// U