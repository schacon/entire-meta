lock starts (first # line)\\n  1306→\\tcommentStart := -1\\n  1307→\\tfor i, line := range lines {\\n  1308→\\t\\tif strings.HasPrefix(line, \\\"#\\\") {\\n  1309→\\t\\t\\tcommentStart = i\\n  1310→\\t\\t\\tbreak\\n  1311→\\t\\t}\\n  1312→\\t}\\n  1313→\\n  1314→\\tif commentStart == -1 {\\n  1315→\\t\\t// No git comments, append trailer at the end\\n  1316→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\"\\n  1317→\\t}\\n  1318→\\n  1319→\\t// Split into user content and git comments\\n  1320→\\tuserContent := strings.Join(lines[:commentStart], \\\"\\\\n\\\")\\n  1321→\\tgitComments := strings.Join(lines[commentStart:], \\\"\\\\n\\\")\\n  1322→\\n  1323→\\t// Build result: user content, blank line, trailer, comment, blank line, git comments\\n  1324→\\tuserContent = strings.TrimRight(userContent, \\\"\\\\n\\\")\\n  1325→\\tif userContent == \\\"\\\" {\\n  1326→\\t\\t// No user content yet - leave space for them to type, then trailer\\n  1327→\\t\\t// Two newlines: first for user's message line, second for blank separator\\n  1328→\\t\\treturn \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1329→\\t}\\n  1330→\\treturn userContent + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1331→}\\n  1332→\\n  1333→// InitializeSession creates session state for a new session or updates an existing one.\\n  1334→// This implements the optional SessionInitializer interface.\\n  1335→// Called during UserPromptSubmit to allow git hooks to detect active sessions.\\n  1336→//\\n  1337→// If the session already exists and HEAD has moved (e.g., user committed), updates\\n  1338→// BaseCommit to the new HEAD so future checkpoints go to the correct shadow branch.\\n  1339→//\\n  1340→// If there's an existing shadow branch with commits from a different session ID,\\n  1341→// returns a SessionIDConflictError to prevent orphaning existing session work.\\n  1342→//\\n  1343→// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n  1344→// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n  1345→// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\n  1346→func (s *ManualCommitStrategy) InitializeSession(sessionID string, agentType agent.AgentType, transcriptPath string, userPrompt string) error {\\n  1347→\\trepo, err := OpenRepository()\\n  1348→\\tif err != nil {\\n  1349→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n  1350→\\t}\\n  1351→\\n  1352→\\t// Check if session already exists\\n  1353→\\tstate, err := s.loadSessionState(sessionID)\\n  1354→\\tif err != nil {\\n  1355→\\t\\treturn fmt.Errorf(\\\"failed to check session state: %w\\\", err)\\n  1356→\\t}\\n  1357→\\n  1358→\\tif state != nil && state.BaseCommit != \\\"\\\" {\\n  1359→\\t\\t// Session is fully initialized — apply phase transition for TurnStart.\\n  1360→\\t\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1361→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1362→\\t\\t}\\n  1363→\\n  1364→\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n  1365→\\t\\tturnID, err := id.Generate()\\n  1366→\\t\\tif err != nil {\\n  1367→\\t\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n  1368→\\t\\t}\\n  1369→\\t\\tstate.TurnID = turnID.String()\\n  1370→\\n  1371→\\t\\t// Backfill AgentType if empty or set to the generic default \\\"Agent\\\"\\n  1372→\\t\\tif !isSpecificAgentType(state.AgentType) && agentType != \\\"\\\" {\\n  1373→\\t\\t\\tstate.AgentType = agentType\\n  1374→\\t\\t}\\n  1375→\\n  1376→\\t\\t// Backfill FirstPrompt if empty (for sessions created before the fir