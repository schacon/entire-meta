l\\n  1410→\\t}\\n  1411→\\t// If state exists but BaseCommit is empty, it's a partial state from concurrent warning\\n  1412→\\t// Continue below to properly initialize it\\n  1413→\\n  1414→\\t// Initialize new session\\n  1415→\\tstate, err = s.initializeSession(repo, sessionID, agentType, transcriptPath, userPrompt)\\n  1416→\\tif err != nil {\\n  1417→\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n  1418→\\t}\\n  1419→\\n  1420→\\t// Apply phase transition: new session starts as ACTIVE.\\n  1421→\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1422→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1423→\\t}\\n  1424→\\n  1425→\\t// Calculate attribution for pre-prompt edits\\n  1426→\\t// This captures any user edits made before the first prompt\\n  1427→\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n  1428→\\tstate.PendingPromptAttribution = &promptAttr\\n  1429→\\tif err = s.saveSessionState(state); err != nil {\\n  1430→\\t\\treturn fmt.Errorf(\\\"failed to save attribution: %w\\\", err)\\n  1431→\\t}\\n  1432→\\n  1433→\\tfmt.Fprintf(os.Stderr, \\\"Initialized shadow session: %s\\\\n\\\", sessionID)\\n  1434→\\treturn nil\\n  1435→}\\n  1436→\\n  1437→// calculatePromptAttributionAtStart calculates attribution at prompt start (before agent runs).\\n  1438→// This captures user changes since the last checkpoint - no filtering needed since\\n  1439→// the agent hasn't made any changes yet.\\n  1440→//\\n  1441→// IMPORTANT: This reads from the worktree (not staging area) to match what WriteTemporary\\n  1442→// captures in checkpoints. If we read staged content but checkpoints capture worktree content,\\n  1443→// unstaged changes would be in the checkpoint but not counted in PromptAttribution, causing\\n  1444→// them to be incorrectly attributed to the agent