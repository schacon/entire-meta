n    81→\\treturn result, nil\\n    82→}\\n    83→\\n    84→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    85→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    86→func (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n    87→\\tstore, err := s.getCheckpointStore()\\n    88→\\tif err != nil {\\n    89→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    90→\\t}\\n    91→\\n    92→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n    93→\\tif err != nil {\\n    94→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    95→\\t}\\n    96→\\tif content == nil {\\n    97→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n    98→\\t}\\n    99→\\tif len(content.Transcript) == 0 {\\n   100→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   101→\\t}\\n   102→\\n   103→\\treturn content.Transcript, nil\\n   104→}\\n   105→\\n   106→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   107→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   108→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   109→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   110→//\\n   111→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   112→// In this case, data is extracted from the live transcript instead.\\n   113→func (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n   114→\\t// Get shadow branch (may not exist for mid-session commits)\\n   115→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   116→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   117→\\tref, err := repo.Reference(refName, true)\\n   118→\\thasShadowBranch := err == nil\\n   119→\\n   120→\\tvar sessionData *ExtractedSessionData\\n   121→\\tif hasShadowBranch {\\n   122→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   123→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   124→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   125→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   126→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   127→\\t\\t// last turn had no code changes).\\n   128→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   129→\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n   130→\\t\\tif err != nil {\\n   131→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n   132→\\t\\t}\\n   133→\\t} else {\\n   134→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   135→\\t\\t// Extract data directly from live transcript.\\n   136→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   137→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   138→\\t\\t}\\n   139→\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n   140→\\t\\tif err != nil {\\n   141→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n   142→\\t\\t}\\n   143→\\t}\\n   144→\\n   145→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   146→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   147→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   148→\\tif len(committedFiles) > 0 {\\n   149→\\t\\tif len(sessionData.FilesTouched) > 0 {\\n   150→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   151→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   152→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   153→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   154→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   155→\\t\\t\\t\\t}\\n   156→\\t\\t\\t}\\n   157→\\t\\t\\tsessionData.FilesTouched = filtered\\n   158→\\t\\t}\\n   159→\\n   160→\\t\\t// If extraction failed or returned empty, use committedFiles as fallback.\\n   161→\\t\\t// This handles mid-session commits where transcript parsing may not find files\\n   162→\\t\\t// but we know what was committed.\\n   163→\\t\\tif len(sessionData.FilesTouched) == 0 {\\n   164→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   165→\\t\\t\\tfor f := range committedFiles {\\n   166→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   167→\\t\\t\\t}\\n   168→\\t\\t}\\n   169→\\t}\\n   170→\\n   171→\\t// Get checkpoint store\\n   172→\\tstore, err := s.getCheckpointStore()\\n   173→\\tif err != nil {\\n   174→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   175→\\t}\\n   176→\\n   177→\\t// Get author info\\n   178→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   179→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   180→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   181→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   182→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n   183→\\t// Get current branch name\\n   184→\\tbranchName := GetCurrentBranchName(repo)\\n   185→\\n   186→\\t// Generate summary if enabled\\n   187→\\tvar summary *cpkg.Summary\\n   188→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   189→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   190→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   191→\\n   192→\\t\\t// Scope transcript to this checkpoint's portion.\\n   193→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   194→\\t\\t// For Gemini (JSON), CheckpointTranscriptStart is a message index.\\n   195→\\t\\tvar scopedTranscript []byte\\n   196→\\t\\tif state.AgentType == agent.AgentTypeGemini {\\n   197→\\t\\t\\tscopedTranscript = geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   198→\\t\\t} else {\\n   199→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   200→\\t\\t}\\n   201→\\t\\tif len(scopedTranscript) > 0 {\\n   202→\\t\\t\\tvar err error\\n   203→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   204→\\t\\t\\tif err != nil {\\n   205→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   206→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   207→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   208→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   209→\\t\\t\\t} else {\\n   210→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   211→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   212→\\t\\t\\t}\\n   213→\\t\\t}\\n   214→\\t}\\n   215→\\n   216→\\t// Write checkpoint metadata using the checkpoint store\\n   217→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   218→\\t\\tCheckpointID:                checkpointID,\\n   219→\\t\\tSessionID:                   state.SessionID,\\n   220→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   221→\\t\\tBranch:                      branchName,\\n   222→\\t\\tTranscript:                  sessionData.Transcript,\\n   223→\\t\\tPrompts:                     sessionData.Prompts,\\n   224→\\t\\tContext:                     sessionData.Context,\\n   225→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   226→\\t\\tCheckpointsCount:            state.StepCount,\\n   227→\\t\\tEphemeralBranch:             shadowBranchName,\\n   228→\\t\\tAuthorName:                  authorName,\\n   229→\\t\\tAuthorEmail:                 authorEmail,\\n   230→\\t\\tAgent:                       state.AgentType,\\n   231→\\t\\tTurnID:                      state.TurnID,\\n   232→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   233→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   234→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   235→\\t\\tInitialAttribution:          attribution,\\n   236→\\t\\tSummary:                     summary,\\n   237→\\t\\tSessionTranscriptPath:       homeRelativePath(state.TranscriptPath),\\n   238→\\t}); err != nil {\\n   239→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   240→\\t}\\n   241→\\n   242→\\treturn &CondenseResult{\\n   243→\\t\\tCheckpointID:         checkpointID,\\n   244→\\t\\tSessionID:            state.SessionID,\\n   245→\\t\\tCheckpointsCount:     state.StepCount,\\n   246→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   247→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   248→\\t}, nil\\n   249→}\\n   250→\\n   251→func calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n   252→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   253→\\t// This uses user edits captured at each prompt start (before agent works),\\n   254→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   255→\\t//\\n   256→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   257→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   258→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   259→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   260→\\n   261→\\theadRef, headErr := repo.Head()\\n   262→\\tif headErr != nil {\\n   263→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   264→\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   265→\\t\\treturn nil\\n   266→\\t}\\n   267→\\n   268→\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   269→\\tif commitErr != nil {\\n   270→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   271→\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   272→\\t\\treturn nil\\n   273→\\t}\\n   274→\\n   275→\\theadTree, treeErr := headCommit.Tree()\\n   276→\\tif treeErr != nil {\\n   277→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   278→\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   279→\\t\\treturn nil\\n   280→\\t}\\n   281→\\n   282→\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n   283→\\tvar shadowTree *object.Tree\\n   284→\\tif shadowRef != nil {\\n   285→\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   286→\\t\\tif shadowErr != nil {\\n   287→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   288→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   289→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   290→\\t\\t\\treturn nil\\n   291→\\t\\t}\\n   292→\\t\\tvar shadowTreeErr error\\n   293→\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   294→\\t\\tif shadowTreeErr != nil {\\n   295→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   296→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   297→\\t\\t\\treturn nil\\n   298→\\t\\t}\\n   299→\\t} else {\\n   300→\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   301→\\t\\t// because the agent's work is the commit itself.\\n   302→\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   303→\\t\\tshadowTree = headTree\\n   304→\\t}\\n   305→\\n   306→\\t// Get base tree (state before session started)\\n   307→\\tvar baseTree *object.Tree\\n   308→\\tattrBase := state.AttributionBaseCommit\\n   309→\\tif attrBase == \\\"\\\" {\\n   310→\\t\\tattrBase = state.BaseCommit // backward compat\\n   311→\\t}\\n   312→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   313→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   314→\\t\\t\\tbaseTree = tree\\n   315→\\t\\t} else {\\n   316→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   317→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   318→\\t\\t}\\n   319→\\t} else {\\n   320→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   321→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   322→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   323→\\t}\\n   324→\\n   325→\\t// Log accumulated prompt attributions for debugging\\n   326→\\tvar totalUserAdded, totalUserRemoved int\\n   327→\\tfor i, pa := range state.PromptAttributions {\\n   328→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   329→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   330→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   331→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   332→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   333→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   334→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   335→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   336→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   337→\\t}\\n   338→\\n   339→\\tattribution := CalculateAttributionWithAccumulated(\\n   340→\\t\\tbaseTree,\\n   341→\\t\\tshadowTree,\\n   342→\\t\\theadTree,\\n   343→\\t\\tsessionData.FilesTouched,\\n   344→\\t\\tstate.PromptAttributions,\\n   345→\\t)\\n   346→\\n   347→\\tif attribution != nil {\\n   348→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   349→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   350→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   351→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   352→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   353→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   354→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   355→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   356→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   357→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   358→\\t}\\n   359→\\n   360→\\treturn attribution\\n   361→}\\n   362→\\n   363→// extractSessionData extracts session data from the shadow branch.\\n   364→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   365→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   366→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   367→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   368→// continued growing — the shadow branch copy would be stale.\\n   369→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   370→func (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n   371→\\tcommit, err := repo.CommitObject(shadowRef)\\n   372→\\tif err != nil {\\n   373→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   374→\\t}\\n   375→\\n   376→\\ttree, err := commit.Tree()\\n   377→\\tif err != nil {\\n   378→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   379→\\t}\\n   380→\\n   381→\\tdata := &ExtractedSessionData{}\\n   382→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   383→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   384→\\n   385→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   386→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   387→\\t// (SaveStep is only called when there are file modifications).\\n   388→\\tvar fullTranscript string\\n   389→\\tif liveTranscriptPath != \\\"\\\" {\\n   390→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   391→\\t\\t\\tfullTranscript = string(liveData)\\n   392→\\t\\t}\\n   393→\\t}\\n   394→\\tif fullTranscript == \\\"\\\" {\\n   395→\\t\\t// Fall back to shadow branch copy\\n   396→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   397→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   398→\\t\\t\\t\\tfullTranscript = content\\n   399→\\t\\t\\t}\\n   400→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   401→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   402→\\t\\t\\t\\tfullTranscript = content\\n   403→\\t\\t\\t}\\n   404→\\t\\t}\\n   405→\\t}\\n   406→\\n   407→\\t// Process transcript based on agent type\\n   408→\\tif fullTranscript != \\\"\\\" {\\n   409→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   410→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   411→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   412→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   413→\\t}\\n   414→\\n   415→\\t// Use tracked files from session state (not all files in tree)\\n   416→\\tdata.FilesTouched = filesTouched\\n   417→\\n   418→\\t// Calculate token usage from the extracted transcript portion\\n   419→\\tif len(data.Transcript) > 0 {\\n   420→\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n   421→\\t}\\n   422→\\n   423→\\treturn data, nil\\n   424→}\\n   425→\\n   426→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   427→// This is used for mid-session commits where no shadow branch exists yet.\\n   428→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n   429→\\tdata := &ExtractedSessionData{}\\n   430→\\n   431→\\t// Read the live transcript\\n   432→\\tif state.TranscriptPath == \\\"\\\" {\\n   433→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   434→\\t}\\n   435→\\n   436→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   437→\\tif err != nil {\\n   438→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   439→\\t}\\n   440→\\n   441→\\tif len(liveData) == 0 {\\n   442→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   443→\\t}\\n   444→\\n   445→\\tfullTranscript := string(liveData)\\n   446→\\tdata.Transcript = liveData\\n   447→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   448→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   449→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   450→\\n   451→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   452→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   453→\\tif len(state.FilesTouched) > 0 {\\n   454→\\t\\tdata.FilesTouched = state.FilesTouched\\n   455→\\t} else {\\n   456→\\t\\t// Use the shared helper which includes subagent transcripts\\n   457→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n   458→\\t}\\n   459→\\n   460→\\t// Calculate token usage from the extracted transcript portion\\n   461→\\tif len(data.Transcript) > 0 {\\n   462→\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n   463→\\t}\\n   464→\\n   465→\\treturn data, nil\\n   466→}\\n   467→\\n   468→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   469→// For Claude Code and JSONL-based agents, this counts lines.\\n   470→// For Gemini CLI and JSON-based agents, this counts messages.\\n   471→// Returns 0 if the content is empty or malformed.\\n   472→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   473→\\tif content == \\\"\\\" {\\n   474→\\t\\treturn 0\\n   475→\\t}\\n   476→\\n   477→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   478→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   479→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   480→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   481→\\t\\t\\treturn len(transcript.Messages)\\n   482→\\t\\t}\\n   483→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   484→\\t\\tif agentType == agent.AgentTypeGemini {\\n   485→\\t\\t\\treturn 0\\n   486→\\t\\t}\\n   487→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   488→\\t}\\n   489→\\n   490→\\t// Claude Code and other JSONL-based agents\\n   491→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   492→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   493→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   494→\\t\\tallLines = allLines[:len(allLines)-1]\\n   495→\\t}\\n   496→\\treturn len(allLines)\\n   497→}\\n   498→\\n   499→// extractUserPrompts extracts all user prompts from transcript content.\\n   500→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   501→func extractUserPrompts(agentType agent.AgentType, content string) []string {\\n   502→\\tif content == \\\"\\\" {\\n   503→\\t\\treturn nil\\n   504→\\t}\\n   505→\\n   506→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   507→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   508→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   509→\\t\\tif err == nil && len(prompts) > 0 {\\n   510→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   511→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   512→\\t\\t\\tfor _, prompt := range prompts {\\n   513→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   514→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   515→\\t\\t\\t\\t}\\n   516→\\t\\t\\t}\\n   517→\\t\\t\\treturn cleaned\\n   518→\\t\\t}\\n   519→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   520→\\t\\tif agentType == agent.AgentTypeGemini {\\n   521→\\t\\t\\treturn nil\\n   522→\\t\\t}\\n   523→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   524→\\t}\\n   525→\\n   526→\\t// Claude Code and other JSONL-based agents\\n   527→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   528→}\\n   529→\\n   530→// calculateTokenUsage calculates token usage from raw transcript data.\\n   531→// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n   532→// where the current checkpoint began, allowing calculation for only the portion\\n   533→// of the transcript since the last checkpoint.\\n   534→func calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n   535→\\tif len(data) == 0 {\\n   536→\\t\\treturn &agent.TokenUsage{}\\n   537→\\t}\\n   538→\\n   539→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   540→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   541→\\t\\t// Attempt to parse as Gemini JSON\\n   542→\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n   543→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   544→\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n   545→\\t\\t}\\n   546→\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n   547→\\t\\tif agentType == agent.AgentTypeGemini {\\n   548→\\t\\t\\treturn &agent.TokenUsage{}\\n   549→\\t\\t}\\n   550→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   551→\\t}\\n   552→\\n   553→\\t// Claude Code and other JSONL-based agents\\n   554→\\tlines, err := transcript.ParseFromBytes(data)\\n   555→\\tif err != nil || len(lines) == 0 {\\n   556→\\t\\treturn &agent.TokenUsage{}\\n   557→\\t}\\n   558→\\t// Slice transcript lines to only include checkpoint portion\\n   559→\\tif startOffset > 0 && startOffset < len(lines) {\\n   560→\\t\\tlines = lines[startOffset:]\\n   561→\\t}\\n   562→\\treturn claudecode.CalculateTokenUsage(lines)\\n   563→}\\n   564→\\n   565→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   566→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   567→func extractUserPromptsFromLines(lines []string) []string {\\n   568→\\tvar prompts []string\\n   569→\\tfor _, line := range lines {\\n   570→\\t\\tline = strings.TrimSpace(line)\\n   571→\\t\\tif line == \\\"\\\" {\\n   572→\\t\\t\\tcontinue\\n   573→\\t\\t}\\n   574→\\n   575→\\t\\tvar entry map[string]interface{}\\n   576→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   577→\\t\\t\\tcontinue\\n   578→\\t\\t}\\n   579→\\n   580→\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n   581→\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n   582→\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n   583→\\t\\t\\tcontinue\\n   584→\\t\\t}\\n   585→\\n   586→\\t\\t// Extract message content\\n   587→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   588→\\t\\tif !ok {\\n   589→\\t\\t\\tcontinue\\n   590→\\t\\t}\\n   591→\\n   592→\\t\\t// Handle string content\\n   593→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   594→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   595→\\t\\t\\tif cleaned != \\\"\\\" {\\n   596→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   597→\\t\\t\\t}\\n   598→\\t\\t\\tcontinue\\n   599→\\t\\t}\\n   600→\\n   601→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   602→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   603→\\t\\t\\tvar texts []string\\n   604→\\t\\t\\tfor _, item := range arr {\\n   605→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   606→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   607→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   608→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   609→\\t\\t\\t\\t\\t\\t}\\n   610→\\t\\t\\t\\t\\t}\\n   611→\\t\\t\\t\\t}\\n   612→\\t\\t\\t}\\n   613→\\t\\t\\tif len(texts) > 0 {\\n   614→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   615→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   616→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   617→\\t\\t\\t\\t}\\n   618→\\t\\t\\t}\\n   619→\\t\\t}\\n   620→\\t}\\n   621→\\treturn prompts\\n   622→}\\n   623→\\n   624→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   625→func generateContextFromPrompts(prompts []string) []byte {\\n   626→\\tif len(prompts) == 0 {\\n   627→\\t\\treturn nil\\n   628→\\t}\\n   629→\\n   630→\\tvar buf strings.Builder\\n   631→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   632→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   633→\\n   634→\\tfor i, prompt := range prompts {\\n   635→\\t\\t// Truncate very long prompts for readability\\n   636→\\t\\tdisplayPrompt := prompt\\n   637→\\t\\tif len(displayPrompt) > 500 {\\n   638→\\t\\t\\tdisplayPrompt = displayPrompt[:500] + \\\"...\\\"\\n   639→\\t\\t}\\n   640→\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n   641→\\t\\tbuf.WriteString(displayPrompt)\\n   642→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   643→\\t}\\n   644→\\n   645→\\treturn []byte(buf.String())\\n   646→}\\n   647→\\n   648→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   649→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   650→func (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n   651→\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n   652→\\n   653→\\t// Load session state\\n   654→\\tstate, err := s.loadSessionState(sessionID)\\n   655→\\tif err != nil {\\n   656→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   657→\\t}\\n   658→\\tif state == nil {\\n   659→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   660→\\t}\\n   661→\\n   662→\\t// Open repository\\n   663→\\trepo, err := OpenRepository()\\n   664→\\tif err != nil {\\n   665→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   666→\\t}\\n   667→\\n   668→\\t// Generate a checkpoint ID\\n   669→\\tcheckpointID, err := id.Generate()\\n   670→\\tif err != nil {\\n   671→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   672→\\t}\\n   673→\\n   674→\\t// Check if shadow branch exists (required for condensation)\\n   675→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   676→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   677→\\t_, refErr := repo.Reference(refName, true)\\n   678→\\thasShadowBranch := refErr == nil\\n   679→\\n   680→\\tif !hasShadowBranch {\\n   681→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   682→\\t\\t// Just clean up the state file.\\n   683→\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n   684→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   685→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   686→\\t\\t)\\n   687→\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n   688→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   689→\\t\\t}\\n   690→\\t\\treturn nil\\n   691→\\t}\\n   692→\\n   693→\\t// Condense the session\\n   694→\\tresult, err := s.CondenseSession(repo, checkpointID, state, nil)\\n   695→\\tif err != nil {\\n   696→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   697→\\t}\\n   698→\\n   699→\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n   700→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   701→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   702→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   703→\\t)\\n   704→\\n   705→\\t// Update session state: reset step count and transition to idle\\n   706→\\tstate.StepCount = 0\\n   707→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   708→\\tstate.Phase = session.PhaseIdle\\n   709→\\tstate.LastCheckpointID = checkpointID\\n   710→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   711→\\tstate.PromptAttributions = nil\\n   712→\\tstate.PendingPromptAttribution = nil\\n   713→\\n   714→\\tif err := s.saveSessionState(state); err != nil {\\n   715→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   716→\\t}\\n   717→\\n   718→\\t// Clean up shadow branch if no other sessions need it\\n   719→\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n   720→\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n   721→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   722→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   723→\\t\\t)\\n   724→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   725→\\t}\\n   726→\\n   727→\\treturn nil\\n   728→}\\n   729→\\n   730→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   731→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(_ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   732→\\t// List all session states to check if any other session uses this shadow branch\\n   733→\\tallStates, err := s.listAllSessionStates()\\n   734→\\tif err != nil {\\n   735→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   736→\\t}\\n   737→\\n   738→\\tfor _, state := range allStates {\\n   739→\\t\\tif state.SessionID == excludeSessionID {\\n   740→\\t\\t\\tcontinue\\n   741→\\t\\t}\\n   742→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   743→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   744→\\t\\t\\t// Another session still needs this shadow branch\\n   745→\\t\\t\\treturn nil\\n   746→\\t\\t}\\n   747→\\t}\\n   748→\\n   749→\\t// No other sessions need it, delete the shadow branch via CLI\\n   750→\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n   751→\\tif err := DeleteBranchCLI(shadowBranchName); err != nil {\\n   752→\\t\\t// Branch already gone is not an error\\n   753→\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n   754→\\t\\t\\treturn nil\\n   755→\\t\\t}\\n   756→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n   757→\\t}\\n   758→\\treturn nil\\n   759→}\\n   760→\"}]},\"uuid\":\"df93eb6c-5960-4ff9-a6f1-a7c673276307\",\"timestamp\":\"2026-02-19T03:51:59.706Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/gtrrz-victor/wks/cli/cli/cmd/entire/cli/strategy/manual_commit_condensation.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// listCheckpoints returns all checkpoints from the metadata branch.\\n// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) listCheckpoints() ([]CheckpointInfo, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcommitted, err := store.ListCommitted(context.Background())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n\\t}\\n\\n\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n\\tresult := make([]CheckpointInfo, 0, len(committed))\\n\\tfor _, c := range committed {\\n\\t\\tresult = append(result, CheckpointInfo{\\n\\t\\t\\tCheckpointID:     c.CheckpointID,\\n\\t\\t\\tSessionID:        c.SessionID,\\n\\t\\t\\tCreatedAt:        c.CreatedAt,\\n\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n\\t\\t\\tFilesTouched:     c.FilesTouched,\\n\\t\\t\\tAgent:            c.Agent,\\n\\t\\t\\tIsTask:           c.IsTask,\\n\\t\\t\\tToolUseID:        c.ToolUseID,\\n\\t\\t\\tSessionCount:     c.SessionCount,\\n\\t\\t\\tSessionIDs:       c.SessionIDs,\\n\\t\\t})\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointsForSession returns all checkpoints for a session ID.\\nfunc (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n\\tall, err := s.listCheckpoints()\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tvar result []CheckpointInfo\\n\\tfor _, cp := range all {\\n\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n\\t\\t\\tresult = append(result, cp)\\n\\t\\t}\\n\\t}\\n\\n\\tif len(result) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// CondenseSession condenses a session's shadow branch to permanent storage.\\n// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n//\\n// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n// In this case, data is extracted from the live transcript instead.\\nfunc (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n\\t// Get shadow branch (may not exist for mid-session commits)\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\thasShadowBranch := err == nil\\n\\n\\tvar sessionData *ExtractedSessionData\\n\\tif hasShadowBranch {\\n\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n\\t\\t// last turn had no code changes).\\n\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n\\t\\t// Extract data directly from live transcript.\\n\\t\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n\\t\\t}\\n\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n\\t// committed in this specific commit. This ensures each checkpoint represents\\n\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n\\tif len(committedFiles) > 0 {\\n\\t\\tif len(sessionData.FilesTouched) > 0 {\\n\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tsessionData.FilesTouched = filtered\\n\\t\\t}\\n\\n\\t\\t// If extraction failed or returned empty, use committedFiles as fallback.\\n\\t\\t// This handles mid-session commits where transcript parsing may not find files\\n\\t\\t// but we know what was committed.\\n\\t\\tif len(sessionData.FilesTouched) == 0 {\\n\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n\\t\\t\\tfor f := range committedFiles {\\n\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Get checkpoint store\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get author info\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Generate summary if enabled\\n\\tvar summary *cpkg.Summary\\n\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n\\n\\t\\t// Scope transcript to this checkpoint's portion.\\n\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n\\t\\t// For Gemini (JSON), CheckpointTranscriptStart is a message index.\\n\\t\\tvar scopedTranscript []byte\\n\\t\\tif state.AgentType == agent.AgentTypeGemini {\\n\\t\\t\\tscopedTranscript = geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t} else {\\n\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t}\\n\\t\\tif len(scopedTranscript) > 0 {\\n\\t\\t\\tvar err error\\n\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t\\t// Continue without summary - non-blocking\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write checkpoint metadata using the checkpoint store\\n\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n\\t\\tCheckpointID:                checkpointID,\\n\\t\\tSessionID:                   state.SessionID,\\n\\t\\tStrategy:                    StrategyNameManualCommit,\\n\\t\\tBranch:                      branchName,\\n\\t\\tTranscript:                  sessionData.Transcript,\\n\\t\\tPrompts:                     sessionData.Prompts,\\n\\t\\tContext:                     sessionData.Context,\\n\\t\\tFilesTouched:                sessionData.FilesTouched,\\n\\t\\tCheckpointsCount:            state.StepCount,\\n\\t\\tEphemeralBranch:             shadowBranchName,\\n\\t\\tAuthorName:                  authorName,\\n\\t\\tAuthorEmail:                 authorEmail,\\n\\t\\tAgent:                       state.AgentType,\\n\\t\\tTurnID:                      state.TurnID,\\n\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n\\t\\tInitialAttribution:          attribution,\\n\\t\\tSummary:                     summary,\\n\\t\\tSessionTranscriptPath:       homeRelativePath(state.TranscriptPath),\\n\\t}); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n\\t}\\n\\n\\treturn &CondenseResult{\\n\\t\\tCheckpointID:         checkpointID,\\n\\t\\tSessionID:            state.SessionID,\\n\\t\\tCheckpointsCount:     state.StepCount,\\n\\t\\tFilesTouched:         sessionData.FilesTouched,\\n\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n\\t}, nil\\n}\\n\\nfunc calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n\\t// Calculate initial attribution using accumulated prompt attribution data.\\n\\t// This uses user edits captured at each prompt start (before agent works),\\n\\t// plus any user edits after the final checkpoint (shadow → head).\\n\\t//\\n\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\n\\theadRef, headErr := repo.Head()\\n\\tif headErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n\\tif commitErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\theadTree, treeErr := headCommit.Tree()\\n\\tif treeErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n\\tvar shadowTree *object.Tree\\n\\tif shadowRef != nil {\\n\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n\\t\\tif shadowErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\tvar shadowTreeErr error\\n\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n\\t\\tif shadowTreeErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n\\t\\t// because the agent's work is the commit itself.\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n\\t\\tshadowTree = headTree\\n\\t}\\n\\n\\t// Get base tree (state before session started)\\n\\tvar baseTree *object.Tree\\n\\tattrBase := state.AttributionBaseCommit\\n\\tif attrBase == \\\"\\\" {\\n\\t\\tattrBase = state.BaseCommit // backward compat\\n\\t}\\n\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n\\t\\t\\tbaseTree = tree\\n\\t\\t} else {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n\\t\\t}\\n\\t} else {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n\\t}\\n\\n\\t// Log accumulated prompt attributions for debugging\\n\\tvar totalUserAdded, totalUserRemoved int\\n\\tfor i, pa := range state.PromptAttributions {\\n\\t\\ttotalUserAdded += pa.UserLinesAdded\\n\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"index\\\", i))\\n\\t}\\n\\n\\tattribution := CalculateAttributionWithAccumulated(\\n\\t\\tbaseTree,\\n\\t\\tshadowTree,\\n\\t\\theadTree,\\n\\t\\tsessionData.FilesTouched,\\n\\t\\tstate.PromptAttributions,\\n\\t)\\n\\n\\tif attribution != nil {\\n\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n\\t}\\n\\n\\treturn attribution\\n}\\n\\n// extractSessionData extracts session data from the shadow branch.\\n// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n// continued growing — the shadow branch copy would be stale.\\n// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\nfunc (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n\\tcommit, err := repo.CommitObject(shadowRef)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\tdata := &ExtractedSessionData{}\\n\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\n\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n\\t// (SaveStep is only called when there are file modifications).\\n\\tvar fullTranscript string\\n\\tif liveTranscriptPath != \\\"\\\" {\\n\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n\\t\\t\\tfullTranscript = string(liveData)\\n\\t\\t}\\n\\t}\\n\\tif fullTranscript == \\\"\\\" {\\n\\t\\t// Fall back to shadow branch copy\\n\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Process transcript based on agent type\\n\\tif fullTranscript != \\\"\\\" {\\n\\t\\tdata.Transcript = []byte(fullTranscript)\\n\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\t}\\n\\n\\t// Use tracked files from session state (not all files in tree)\\n\\tdata.FilesTouched = filesTouched\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n// This is used for mid-session commits where no shadow branch exists yet.\\nfunc (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n\\tdata := &ExtractedSessionData{}\\n\\n\\t// Read the live transcript\\n\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n\\t}\\n\\n\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n\\t}\\n\\n\\tif len(liveData) == 0 {\\n\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n\\t}\\n\\n\\tfullTranscript := string(liveData)\\n\\tdata.Transcript = liveData\\n\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\n\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n\\t// (no SaveStep/Stop has been called yet to populate it)\\n\\tif len(state.FilesTouched) > 0 {\\n\\t\\tdata.FilesTouched = state.FilesTouched\\n\\t} else {\\n\\t\\t// Use the shared helper which includes subagent transcripts\\n\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n\\t}\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n// For Claude Code and JSONL-based agents, this counts lines.\\n// For Gemini CLI and JSON-based agents, this counts messages.\\n// Returns 0 if the content is empty or malformed.\\nfunc countTranscriptItems(agentType agent.AgentType, content string) int {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn 0\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n\\t\\t\\treturn len(transcript.Messages)\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn 0\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n\\t\\tallLines = allLines[:len(allLines)-1]\\n\\t}\\n\\treturn len(allLines)\\n}\\n\\n// extractUserPrompts extracts all user prompts from transcript content.\\n// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\nfunc extractUserPrompts(agentType agent.AgentType, content string) []string {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n\\t\\tif err == nil && len(prompts) > 0 {\\n\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n\\t\\t\\tfor _, prompt := range prompts {\\n\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\treturn cleaned\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n}\\n\\n// calculateTokenUsage calculates token usage from raw transcript data.\\n// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n// where the current checkpoint began, allowing calculation for only the portion\\n// of the transcript since the last checkpoint.\\nfunc calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n\\tif len(data) == 0 {\\n\\t\\treturn &agent.TokenUsage{}\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\t// Attempt to parse as Gemini JSON\\n\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn &agent.TokenUsage{}\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\tlines, err := transcript.ParseFromBytes(data)\\n\\tif err != nil || len(lines) == 0 {\\n\\t\\treturn &agent.TokenUsage{}\\n\\t}\\n\\t// Slice transcript lines to only include checkpoint portion\\n\\tif startOffset > 0 && startOffset < len(lines) {\\n\\t\\tlines = lines[startOffset:]\\n\\t}\\n\\treturn claudecode.CalculateTokenUsage(lines)\\n}\\n\\n// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\nfunc extractUserPromptsFromLines(lines []string) []string {\\n\\tvar prompts []string\\n\\tfor _, line := range lines {\\n\\t\\tline = strings.TrimSpace(line)\\n\\t\\tif line == \\\"\\\" {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tvar entry map[string]interface{}\\n\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Extract message content\\n\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n\\t\\tif !ok {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Handle string content\\n\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n\\t\\t\\tif cleaned != \\\"\\\" {\\