ointFromMap(cpIDs []id.CheckpointID, infoMap map[id.CheckpointID]CheckpointInfo, metadataTree *object.Tree) (CheckpointInfo, bool) {\\n   260→\\t// Filter to IDs that have metadata\\n   261→\\tvar validIDs []id.CheckpointID\\n   262→\\tfor _, cpID := range cpIDs {\\n   263→\\t\\tif _, ok := infoMap[cpID]; ok {\\n   264→\\t\\t\\tvalidIDs = append(validIDs, cpID)\\n   265→\\t\\t}\\n   266→\\t}\\n   267→\\tif len(validIDs) == 0 {\\n   268→\\t\\treturn CheckpointInfo{}, false\\n   269→\\t}\\n   270→\\tif len(validIDs) == 1 {\\n   271→\\t\\treturn infoMap[validIDs[0]], true\\n   272→\\t}\\n   273→\\n   274→\\t// Multiple checkpoints: resolve by CreatedAt using metadata tree\\n   275→\\tif metadataTree != nil {\\n   276→\\t\\tsorted := CollectCheckpointsByAge(metadataTree, validIDs)\\n   277→\\t\\tif len(sorted) > 0 {\\n   278→\\t\\t\\tlatest := sorted[len(sorted)-1]\\n   279→\\t\\t\\tif info, ok := infoMap[latest.CheckpointID]; ok {\\n   280→\\t\\t\\t\\treturn info, true\\n   281→\\t\\t\\t}\\n   282→\\t\\t}\\n   283→\\t}\\n   284→\\n   285→\\t// Fallback: use the info map's CreatedAt for ordering\\n   286→\\tinfo := infoMap[validIDs[0]]\\n   287→\\tfor _, cpID := range validIDs[1:] {\\n   288→\\t\\tif candidate := infoMap[cpID]; candidate.CreatedAt.After(info.CreatedAt) {\\n   289→\\t\\t\\tinfo = candidate\\n   290→\\t\\t}\\n   291→\\t}\\n   292→\\treturn info, true\\n   293→}\\n   294→\\n   295→// Rewind restores the working directory to a checkpoint.\\n   296→//\\n   297→\\n   298→func (s *ManualCommitStrategy) Rewind(ctx context.Context, point RewindPoint) error {\\n   299→\\trepo, err := OpenRepository(ctx)\\n   300→\\tif err != nil {\\n   301→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   302→\\t}\\n   303→\\n   304→\\t// Get the checkpoint commit\\n   305→\\tcommitHash := plumbing.NewHash(point.ID)\\n   306→\\tcommit, err := repo.CommitObject(commitHash)\\n   307→\\tif err != nil {\\n   308→\\t\\treturn fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   309→\\t}\\n   310→\\n   311→\\ttree, err := commit.Tree()\\n   312→\\tif err != nil {\\n   313→\\t\\treturn fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n   314→\\t}\\n   315→\\n   316→\\t// Reset the shadow branch to the rewound checkpoint\\n   317→\\t// This ensures the next checkpoint will only include prompts from this point forward\\n   318→\\tif err := s.resetShadowBranchToCheckpoint(ctx, repo, commit); err != nil {\\n   319→\\t\\t// Log warning but don't fail - file restoration is the primary operation\\n   320→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to reset shadow branch: %v\\\\n\\\", err)\\n   321→\\t}\\n   322→\\n   323→\\t// Load session state to get untracked files that existed at session start\\n   324→\\tsessionID, hasSessionTrailer := trailers.ParseSession(commit.Message)\\n   325→\\tvar preservedUntrackedFiles map[string]bool\\n   326→\\tif hasSessionTrailer {\\n   327→\\t\\tstate, stateErr := s.loadSessionState(ctx, sessionID)\\n   328→\\t\\tif stateErr == nil && state != nil && len(state.UntrackedFilesAtStart) > 0 {\\n   329→\\t\\t\\tpreservedUntrackedFiles = make(map[string]bool)\\n   330→\\t\\t\\tfor _, f := range state.UntrackedFilesAtStart {\\n   331→\\t\\t\\t\\tpreservedUntrackedFiles[f] = true\\n   332→\\t\\t\\t}\\n   333→\\t\\t}\\n   334→\\t}\\n   335→\\n   336→\\t// Build set of files in the checkpoint tree (excluding metadata)\\n   337→\\tcheckpointFiles := make(map[string]bool)\\n   338→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   339→\\t\\tif err := ctx.Err(); err != nil {\\n   340→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   341→\\t\\t}\\n   342→\\t\\tif !strings.HasPrefix(f.Name, entireDir) {\\n   343→\\t\\t\\tcheckpointFiles[f.Name] = true\\n   344→\\t\\t}\\n   345→\\t\\treturn nil\\n   346→\\t})\\n   347→\\tif err != nil {\\n   348→\\t\\treturn fmt.Errorf(\\\"failed to list checkpoint files: %w\\\", err)\\n   349→\\t}\\n   350→\\n   351→\\t// Get HEAD tree to identify tracked files\\n   352→\\thead, err := repo.Head()\\n   353→\\tif err != nil {\\n   354→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   355→\\t}\\n   356→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   357→\\tif err != nil {\\n   358→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   359→\\t}\\n   360→\\theadTree, err := headCommit.Tree()\\n   361→\\tif err != nil {\\n   362→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD tree: %w\\\", err)\\n   363→\\t}\\n   364→\\n   365→\\t// Build set of files tracked in HEAD\\n   366→\\ttrackedFiles := make(map[string]bool)\\n   367→\\t//nolint:errcheck // Error is not critical for rewind\\n   368→\\t_ = headTree.Files().ForEach(func(f *object.File) error {\\n   369→\\t\\tif err := ctx.Err(); err != nil {\\n   370→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   371→\\t\\t}\\n   372→\\t\\ttrackedFiles[f.Name] = true\\n   373→\\t\\treturn nil\\n   374→\\t})\\n   375→\\n   376→\\t// Get repository root to walk from there\\n   377→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   378→\\tif err != nil {\\n   379→\\t\\trepoRoot = \\\".\\\" // Fallback to current directory\\n   380→\\t}\\n   381→\\n   382→\\t// Find and delete untracked files that aren't in the checkpoint.\\n   383→\\t// Uses git ls-files to only consider non-ignored files, avoiding walks through\\n   384→\\t// large ignored directories like node_modules/.\\n   385→\\tuntrackedNow, err := collectUntrackedFiles(ctx)\\n   386→\\tif err != nil {\\n   387→\\t\\t// Non-fatal - continue with restoration\\n   388→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: error listing untracked files: %v\\\\n\\\", err)\\n   389→\\t}\\n   390→\\tfor _, relPath := range untrackedNow {\\n   391→\\t\\t// If file is in checkpoint, it will be restored\\n   392→\\t\\tif checkpointFiles[relPath] {\\n   393→\\t\\t\\tcontinue\\n   394→\\t\\t}\\n   395→\\n   396→\\t\\t// If file is tracked in HEAD, don't delete (user's committed work)\\n   397→\\t\\tif trackedFiles[relPath] {\\n   398→\\t\\t\\tcontinue\\n   399→\\t\\t}\\n   400→\\n   401→\\t\\t// If file existed at session start, preserve it (untracked user files)\\n   402→\\t\\tif preservedUntrackedFiles[relPath] {\\n   403→\\t\\t\\tcontinue\\n   404→\\t\\t}\\n   405→\\n   406→\\t\\t// File is untracked and not in checkpoint - delete it\\n   407→\\t\\tabsPath := filepath.Join(repoRoot, relPath)\\n   408→\\t\\tif removeErr := os.Remove(absPath); removeErr == nil {\\n   409→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Deleted: %s\\\\n\\\", relPath)\\n   410→\\t\\t}\\n   411→\\t}\\n   412→\\n   413→\\t// Restore files from checkpoint\\n   414→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   415→\\t\\tif err := ctx.Err(); err != nil {\\n   416→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   417→\\t\\t}\\n   418→\\t\\t// Skip metadata directories - these are for checkpoint storage, not working dir\\n   419→\\t\\tif strings.HasPrefix(f.Name, entireDir) {\\n   420→\\t\\t\\treturn nil\\n   421→\\t\\t}\\n   422→\\n   423→\\t\\tcontents, err := f.Contents()\\n   424→\\t\\tif err != nil {\\n   425→\\t\\t\\treturn fmt.Errorf(\\\"failed to read file %s: %w\\\", f.Name, err)\\n   426→\\t\\t}\\n   427→\\n   428→\\t\\t// Ensure directory exists\\n   429→\\t\\tdir := filepath.Dir(f.Name)\\n   430→\\t\\tif dir != \\\".\\\" {\\n   431→\\t\\t\\t//nolint:gosec // G301: Need 0o755 for user directories during rewind\\n   432→\\t\\t\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   433→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to create directory %s: %w\\\", dir, err)\\n   434→\\t\\t\\t}\\n   435→\\t\\t}\\n   436→\\n   437→\\t\\t// Write file with appropriate permissions\\n   438→\\t\\tvar perm os.FileMode = 0o644\\n   439→\\t\\tif f.Mode == filemode.Executable {\\n   440→\\t\\t\\tperm = 0o755\\n   441→\\t\\t}\\n   442→\\t\\tif err := os.WriteFile(f.Name, []byte(contents), perm); err != nil {\\n   443→\\t\\t\\treturn fmt.Errorf(\\\"failed to write file %s: %w\\\", f.Name, err)\\n   444→\\t\\t}\\n   445→\\n   446→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Restored: %s\\\\n\\\", f.Name)\\n   447→\\t\\treturn nil\\n   448→\\t})\\n   449→\\tif err != nil {\\n   450→\\t\\treturn fmt.Errorf(\\\"failed to iterate tree files: %w\\\", err)\\n   451→\\t}\\n   452→\\n   453→\\tfmt.Println()\\n   454→\\tif len(point.ID) >= 7 {\\n   455→\\t\\tfmt.Printf(\\\"Restored files from shadow commit %s\\\\n\\\", point.ID[:7])\\n   456→\\t} else {\\n   457→\\t\\tfmt.Printf(\\\"Restored files from shadow commit %s\\\\n\\\", point.ID)\\n   458→\\t}\\n   459→\\tfmt.Println()\\n   460→\\n   461→\\treturn nil\\n   462→}\\n   463→\\n   464→// resetShadowBranchToCheckpoint resets the shadow branch HEAD to the given checkpoint.\\n   465→// This ensures that when the user commits after rewinding, the next checkpoint will only\\n   466→// include prompts from the rewound point, not prompts from later checkpoints.\\n   467→func (s *ManualCommitStrategy) resetShadowBranchToCheckpoint(ctx context.Context, repo *git.Repository, commit *object.Commit) error {\\n   468→\\t// Extract session ID from the checkpoint commit's Entire-Session trailer\\n   469→\\tsessionID, found := trailers.ParseSession(commit.Message)\\n   470→\\tif !found {\\n   471→\\t\\treturn errors.New(\\\"checkpoint has no Entire-Session trailer\\\")\\n   472→\\t}\\n   473→\\n   474→\\t// Load session state to get the shadow branch name\\n   475→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   476→\\tif err != nil {\\n   477→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   478→\\t}\\n   479→\\tif state == nil {\\n   480→\\t\\treturn fmt.Errorf(\\\"session %s not found\\\", sessionID)\\n   481→\\t}\\n   482→\\n   483→\\t// Reset the shadow branch to the checkpoint commit\\n   484→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   485→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   486→\\n   487→\\t// Update the reference to point to the checkpoint commit\\n   488→\\tref := plumbing.NewHashReference(refName, commit.Hash)\\n   489→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   490→\\t\\treturn fmt.Errorf(\\\"failed to update shadow branch: %w\\\", err)\\n   491→\\t}\\n   492→\\n   493→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Reset shadow branch %s to checkpoint %s\\\\n\\\", shadowBranchName, commit.Hash.String()[:7])\\n   494→\\treturn nil\\n   495→}\\n   496→\\n   497→// CanRewind checks if rewinding is possible.\\n   498→// For manual-commit strategy, rewind restores files from a checkpoint - uncommitted changes are expected\\n   499→// and will be replaced by the checkpoint contents. Returns true with a warning message showing\\n   500→// what changes will be reverted.\\n   501→func (s *ManualCommitStrategy) CanRewind(ctx context.Context) (bool, string, error) {\\n   502→\\treturn checkCanRewindWithWarning(ctx)\\n   503→}\\n   504→\\n   505→// PreviewRewind returns what will happen if rewinding to the given point.\\n   506→// This allows showing warnings about untracked files that will be deleted.\\n   507→func (s *ManualCommitStrategy) PreviewRewind(ctx context.Context, point RewindPoint) (*RewindPreview, error) {\\n   508→\\t// Logs-only points don't modify the working directory\\n   509→\\tif point.IsLogsOnly {\\n   510→\\t\\treturn &RewindPreview{}, nil\\n   511→\\t}\\n   512→\\n   513→\\trepo, err := OpenRepository(ctx)\\n   514→\\tif err != nil {\\n   515→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   516→\\t}\\n   517→\\n   518→\\t// Get the checkpoint commit\\n   519→\\tcommitHash := plumbing.NewHash(point.ID)\\n   520→\\tcommit, err := repo.CommitObject(commitHash)\\n   521→\\tif err != nil {\\n   522→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   523→\\t}\\n   524→\\n   525→\\ttree, err := commit.Tree(