firmation\\\")\\n    57→\\n    58→\\treturn cmd\\n    59→}\\n    60→\\n    61→func runResume(ctx context.Context, branchName string, force bool) error {\\n    62→\\t// Check if we're already on this branch\\n    63→\\tcurrentBranch, err := GetCurrentBranch(ctx)\\n    64→\\tif err == nil && currentBranch == branchName {\\n    65→\\t\\t// Already on the branch, skip checkout\\n    66→\\t\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n    67→\\t}\\n    68→\\n    69→\\t// Check if branch exists locally\\n    70→\\texists, err := BranchExistsLocally(ctx, branchName)\\n    71→\\tif err != nil {\\n    72→\\t\\treturn fmt.Errorf(\\\"failed to check branch: %w\\\", err)\\n    73→\\t}\\n    74→\\n    75→\\tif !exists {\\n    76→\\t\\t// Branch doesn't exist locally, check if it exists on remote\\n    77→\\t\\tremoteExists, err := BranchExistsOnRemote(ctx, branchName)\\n    78→\\t\\tif err != nil {\\n    79→\\t\\t\\treturn fmt.Errorf(\\\"failed to check remote branch: %w\\\", err)\\n    80→\\t\\t}\\n    81→\\n    82→\\t\\tif !remoteExists {\\n    83→\\t\\t\\treturn fmt.Errorf(\\\"branch '%s' not found locally or on origin\\\", branchName)\\n    84→\\t\\t}\\n    85→\\n    86→\\t\\t// Ask user if they want to fetch from remote\\n    87→\\t\\tshouldFetch, err := promptFetchFromRemote(branchName)\\n    88→\\t\\tif err != nil {\\n    89→\\t\\t\\treturn err\\n    90→\\t\\t}\\n    91→\\t\\tif !shouldFetch {\\n    92→\\t\\t\\treturn nil\\n    93→\\t\\t}\\n    94→\\n    95→\\t\\t// Fetch and checkout the remote branch\\n    96→\\t\\tfmt.Fprintf(os.Stderr, \\\"Fetching branch '%s' from origin...\\\\n\\\", branchName)\\n    97→\\t\\tif err := FetchAndCheckoutRemoteBranch(ctx, branchName); err != nil {\\n    98→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n    99→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   100→\\t\\t}\\n   101→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   102→\\t} else {\\n   103→\\t\\t// Branch exists locally, check for uncommitted changes before checkout\\n   104→\\t\\thasChanges, err := HasUncommittedChanges(ctx)\\n   105→\\t\\tif err != nil {\\n   106→\\t\\t\\treturn fmt.Errorf(\\\"failed to check for uncommitted changes: %w\\\", err)\\n   107→\\t\\t}\\n   108→\\t\\tif hasChanges {\\n   109→\\t\\t\\treturn errors.New(\\\"you have uncommitted changes. Please commit or stash them first\\\")\\n   110→\\t\\t}\\n   111→\\n   112→\\t\\t// Checkout the branch\\n   113→\\t\\tif err := CheckoutBranch(ctx, branchName); err != nil {\\n   114→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n   115→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   116→\\t\\t}\\n   117→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   118→\\t}\\n   119→\\n   120→\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n   121→}\\n   122→\\n   123→func resumeFromCurrentBranch(ctx context.Context, branchName string, force bool) error {\\n   124→\\trepo, err := openRepository(ctx)\\n   125→\\tif err != nil {\\n   126→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   127→\\t}\\n   128→\\n   129→\\t// Find a commit with an Entire-Checkpoint trailer, looking at branch-only commits\\n   130→\\tresult, err := findBranchCheckpoints(repo, branchName)\\n   131→\\tif err != nil {\\n   132→\\t\\treturn err\\n   133→\\t}\\n   134→\\tif len(result.checkpointIDs) == 0 {\\n   135→\\t\\tfmt.Fprintf(os.Stderr, \\\"No Entire checkpoint found on branch '%s'\\\\n\\\", branchName)\\n   136→\\t\\treturn nil\\n   137→\\t}\\n   138→\\n   139→\\t// If there are newer commits without checkpoints, ask for confirmation.\\n   140→\\t// Merge commits (e.g., from merging main) don't count as \\\"work\\\" and are skipped silently.\\n   141→\\tif result.newerCommitsExist && !force {\\n   142→\\t\\tfmt.Fprintf(os.Stderr, \\\"Found checkpoint in an older commit.\\\\n\\\")\\n   143→\\t\\tfmt.Fprintf(os.Stderr, \\\"There are %d newer commit(s) on this branch without checkpoints.\\\\n\\\", result.newerCommitCount)\\n   144→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint from: %s %s\\\\n\\\\n\\\", result.commitHash[:7], firstLine(result.commitMessage))\\n   145→\\n   146→\\t\\tshouldResume, err := promptResumeFromOlderCheckpoint()\\n   147→\\t\\tif err != nil {\\n   148→\\t\\t\\treturn err\\n   149→\\t\\t}\\n   150→\\t\\tif !shouldResume {\\n   151→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled.\\\\n\\\")\\n   152→\\t\\t\\treturn nil\\n   153→\\t\\t}\\n   154→\\t}\\n   155→\\n   156→\\tcheckpointID := result.checkpointIDs[0]\\n   157→\\n   158→\\t// Multiple checkpoints (squash merge): resolve latest by CreatedAt timestamp.\\n   159→\\t// resolveLatestCheckpoint also returns the metadata tree so we can reuse it\\n   160→\\t// for the ReadCheckpointMetadata call below without a redundant lookup.\\n   161→\\tvar metadataTree *object.Tree\\n   162→\\tif len(result.checkpointIDs) > 1 {\\n   163→\\t\\tlatest, tree, err := resolveLatestCheckpoint(ctx, repo, result.checkpointIDs)\\n   164→\\t\\tif err != nil {\\n   165→\\t\\t\\t// No metadata available — nothing to resume from\\n   166→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Found %d checkpoints for commit %s but metadata is not available\\\\n\\\",\\n   167→\\t\\t\\t\\tlen(result.checkpointIDs), result.commitHash[:7])\\n   168→\\t\\t\\treturn checkRemoteMetadata(ctx, repo, result.checkpointIDs[0])\\n   169→\\t\\t}\\n   170→\\t\\tskipped := len(result.checkpointIDs) - 1\\n   171→\\t\\tfmt.Fprintf(os.Stderr, \\\"Found %d checkpoints for commit %s, resuming from the latest (%d older checkpoints skipped)\\\\n\\\",\\n   172→\\t\\t\\tlen(result.checkpointIDs), result.commitHash[:7], skipped)\\n   173→\\t\\tcheckpointID = latest\\n   174→\\t\\tmetadataTree = tree\\n   175→\\t}\\n   176→\\n   177→\\t// Get metadata branch tree for lookups (reuse from resolveLatestCheckpoint if available)\\n   178→\\tif metadataTree == nil {\\n   179→\\t\\tvar err error\\n   180→\\t\\tmetadataTree, err = strategy.GetMetadataBranchTree(repo)\\n   181→\\t\\tif err != nil {\\n   182→\\t\\t\\t// No local metadata branch, check if remote has it\\n   183→\\t\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   184→\\t\\t}\\n   185→\\t}\\n   186→\\n   187→\\t// Look up metadata from sharded path\\n   188→\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n   189→\\tif err != nil {\\n   190→\\t\\t// Checkpoint exists in commit but no local metadata - check remote\\n   191→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   192→\\t}\\n   193→\\n   194→\\treturn resumeSession(ctx, metadata, force)\\n   195→}\\n   196→\\n   197→// resolveLatestCheckpoint reads metadata for each checkpoint ID and returns\\n   198→// the one with the latest CreatedAt, along with the metadata tree for reuse.\\n   199→// It tries the local metadata branch first, then fetches from remote, then\\n   200→// falls back to the remote tree directly.\\n   201→func resolveLatestCheckpoint(ctx context.Context, repo *git.Repository, checkpointIDs []id.CheckpointID) (id.CheckpointID, *object.Tree, error) {\\n   202→\\tmetadataTree, err := getMetadataTree(ctx, repo)\\n   203→\\tif err != nil {\\n   204→\\t\\treturn id.EmptyCheckpointID, nil, err\\n   205→\\t}\\n   206→\\tsorted := collectCheckpointsByAge(metadataTree, checkpointIDs)\\n   207→\\tif len(sorted) == 0 {\\n   208→\\t\\treturn id.EmptyCheckpointID, nil, errors.New(\\\"no checkpoint metadata found\\\")\\n   209→\\t}\\n   210→\\treturn sorted[len(sorted)-1].CheckpointID, metadataTree, nil\\n   211→}\\n   212→\\n   213→// getMetadataTree returns the metadata branch tree, trying local first,\\n   214→// then fetching from remote, then falling back to the remote tree directly.\\n   215→func getMetadataTree(ctx context.Context, repo *git.Repository) (*object.Tree, error) {\\n   216→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   217→\\tif err == nil {\\n   218→\\t\\treturn metadataTree, nil\\n   219→\\t}\\n   220→\\n   221→\\t// Try fetching from remote\\n   222→\\tif fetchErr := FetchMetadataBranch(ctx); fetchErr == nil {\\n   223→\\t\\tmetadataTree, err = strategy.GetMetadataBranchTree(repo)\\n   224→\\t\\tif err == nil {\\n   225→\\t\\t\\treturn metadataTree, nil\\n   226→\\t\\t}\\n   227→\\t}\\n   228→\\n   229→\\t// Try remote tree directly\\n   230→\\tremoteTree, remoteErr := strategy.GetRemoteMetadataBranchTree(repo)\\n   231→\\tif remoteErr != nil {\\n   232→\\t\\treturn nil, fmt.Errorf(\\\"metadata branch not available: %w\\\", remoteErr)\\n   233→\\t}\\n   234→\\treturn remoteTree, nil\\n   235→}\\n   236→\\n   237→// collectCheckpointsByAge reads metadata for each checkpoint ID from the tree,\\n   238→// skips any that can't be read, and returns them sorted by CreatedAt ascending.\\n   239→// Sorting ensures the newest checkpoint is restored last and wins on disk,\\n   240→// regardless of trailer order in the commit message.\\n   241→func collectCheckpointsByAge(tree *object.Tree, checkpointIDs []id.CheckpointID) []*strategy.CheckpointInfo {\\n   242→\\tvar checkpoints []*strategy.CheckpointInfo\\n   243→\\tfor _, cpID := range checkpointIDs {\\n   244→\\t\\tmetadata, err := strategy.ReadCheckpointMetadata(tree, cpID.Path())\\n   245→\\t\\tif err != nil {\\n   246→\\t\\t\\tcontinue\\n   247→\\t\\t}\\n   248→\\t\\tcheckpoints = append(checkpoints, metadata)\\n   249→\\t}\\n   250→\\tsort.Slice(checkpoints, func(i, j int) bool {\\n   251→\\t\\treturn checkpoints[i].CreatedAt.Before(checkpoints[j].CreatedAt)\\n   252→\\t})\\n   253→\\treturn checkpoints\\n   254→}\\n   255→\\n   256→// branchCheckpointsResult contains the result of searching for checkpoints on a branch.\\n   257→type branchCheckpointsResult struct {\\n   258→\\tcheckpointIDs     []id.CheckpointID\\n   259→\\tcommitHash        string\\n   260→\\tcommitMessage     string\\n   261→\\tnewerCommitsExist bool // true if there are branch-only commits (not merge commits) without checkpoints\\n   262→\\tnewerCommitCount  int  // count of branch-only commits without checkpoints\\n   263→}\\n   264→\\n   265→// findBranchCheckpoints finds the most recent commit with an Entire-Checkpoint trailer\\n   266→// among commits that are unique to this branch (not reachable from the default branch).\\n   267→// This handles the case where main has been merged into the feature branch.\\n   268→func findBranchCheckpoints(repo *git.Repository, branchName string) (*branchCheckpointsResult, error) {\\n   269→\\tresult := &branchCheckpointsResult{}\\n   270→\\n   271→\\t// Get HEAD commit\\n   272→\\thead, err := repo.Head()\\n   273→\\tif err != nil {\\n   274→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   275→\\t}\\n   276→\\n   277→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   278→\\tif err != nil {\\n   279→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   280→\\t}\\n   281→\\n   282→\\t// First, check if HEAD itself has a checkpoint (most common case)\\n   283→\\tif cpIDs := trailers.ParseAllCheckpoints(headCommit.Message); len(cpIDs) > 0 {\\n   284→\\t\\tresult.checkpointIDs = cpIDs\\n   285→\\t\\tresult.commitHash = head.Hash().String()\\n   286→\\t\\tresult.commitMessage = headCommit.Message\\n   287→\\t\\tresult.newerCommitsExist = false\\n   288→\\t\\treturn result, nil\\n   289→\\t}\\n   290→\\n   291→\\t// HEAD doesn't have a checkpoint - find branch-only commits\\n   292→\\t// Get the default branch name\\n   293→\\tdefaultBranch := getDefaultBranchFromRemote(repo)\\n   294→\\tif defaultBranch == \\\"\\\" {\\n   295→\\t\\t// Fallback: try common names\\n   296→\\t\\tfor _, name := range []string{\\\"main\\\", \\\"master\\\"} {\\n   297→\\t\\t\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(name), true); err == nil {\\n   298→\\t\\t\\t\\tdefaultBranch = name\\n   299→\\t\\t\\t\\tbreak\\n   300→\\t\\t\\t}\\n   301→\\t\\t}\\n   302→\\t}\\n   303→\\n   304→\\t// If we can't find a default branch, or we're on it, just walk all commits\\n   305→\\tif defaultBranch == \\\"\\\" || defaultBranch == branchName {\\n   306→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil\\n   307→\\t}\\n   308→\\n   309→\\t// Get the default branch reference\\n   310→\\tdefaultRef, err := repo.Reference(plumbing.NewBranchReferenceName(defaultBranch), true)\\n   311→\\tif err != nil {\\n   312→\\t\\t// Default branch doesn't exist locally, fall back to walking all commits\\n   313→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   314→\\t}\\n   315→\\n   316→\\tdefaultCommit, err := repo.CommitObject(defaultRef.Hash())\\n   317→\\tif err != nil {\\n   318→\\t\\t// Can't get default commit, fall back to walking all commits\\n   319→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   320→\\t}\\n   321→\\n   322→\\t// Find merge base\\n   323→\\tmergeBase, err := headCommit.MergeBase(defaultCommit)\\n   324→\\tif err != nil || len(mergeBase) == 0 {\\n   325→\\t\\t// No common ancestor, fall back to walking all commits\\n   326→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   327→\\t}\\n   328→\\n   329→\\t// Walk from HEAD to merge base, looking for checkpoint\\n   330→\\treturn findCheckpointInHistory(headCommit, &mergeBase[0].Hash), nil\\n   331→}\\n   332→\\n   333→// findCheckpointInHistory walks commit history from start looking for a checkpoint trailer.\\n   334→// If stopAt is provided, stops when reaching that commit (exclusive).\\n   335→// Returns the first checkpoint found and info about commits between HEAD and the checkpoint.\\n   336→// It distinguishes between merge commits (bringing in other branches) and regular commits\\n   337→// (actual branch work) to avoid false warnings after merging main.\\n   338→func findCheckpointInHistory(start *object.Commit, stopAt *plumbing.Hash) *branchCheckpointsResult {\\n   339→\\tresult := &branchCheckpointsResult{}\\n   340→\\tbranchWorkCommits := 0 // Regular commits without checkpoints (actual work)\\n   341→\\tconst maxCommits = 100 // Limit search depth\\n   342→\\ttotalChecked := 0\\n   343→\\n   344→\\tcurrent := start\\n   345→\\tfor current != nil && totalChecked < maxCommits {\\n   346→\\t\\t// Stop if we've reached the boundary\\n   347→\\t\\tif stopAt != nil && current.Hash == *stopAt {\\n   348→\\t\\t\\tbreak\\n   349→\\t\\t}\\n   350→\\n   351→\\t\\t// Check for checkpoint trailer\\n   352→\\t\\tif cpIDs := trailers.ParseAllCheckpoints(current.Message); len(cpIDs) > 0 {\\n   353→\\t\\t\\tresult.checkpointIDs = cpIDs\\n   354→\\t\\t\\tresult.commitHash = current.Hash.String()\\n   355→\\t\\t\\tresult.commitMessage = current.Message\\n   356→\\t\\t\\t// Only warn about branch work commits, not merge commits\\n   357→\\t\\t\\tresult.newerCommitsExist = branchWorkCommits > 0\\n   358→\\t\\t\\tresult.newerCommitCount = branchWorkCommits\\n   359→\\t\\t\\treturn result\\n   360→\\t\\t}\\n   361→\\n   362→\\t\\t// Only count regular commits (not merge commits) as \\\"branch work\\\"\\n   363→\\t\\tif current.NumParents() <= 1 {\\n   364→\\t\\t\\tbranchWorkCommits++\\n   365→\\t\\t}\\n   366→\\n   367→\\t\\ttotalChecked++\\n   368→\\n   369→\\t\\t// Move to parent (first parent for merge commits - follows the main line)\\n   370→\\t\\tif current.NumParents() == 0 {\\n   371→\\t\\t\\tbreak\\n   372→\\t\\t}\\n   373→\\t\\tparent, err := current.Parent(0)\\n   374→\\t\\tif err != nil {\\n   375→\\t\\t\\t// Can't get parent, treat as end of history\\n   376→\\t\\t\\tbreak\\n   377→\\t\\t}\\n   378→\\t\\tcurrent = parent\\n   379→\\t}\\n   380→\\n   381→\\t// No checkpoint found\\n   382→\\treturn result\\n   383→}\\n   384→\\n   385→// promptResumeFromOlderCheckpoint asks the user if they want to resume from an older checkpoint.\\n   386→func promptResumeFromOlderCheckpoint() (bool, error) {\\n   387→\\tvar confirmed bool\\n   388→\\n   389→\\tform := NewAccessibleForm(\\n   390→\\t\\thuh.NewGroup(\\n   391→\\t\\t\\thuh.NewConfirm().\\n   392→\\t\\t\\t\\tTitle(\\\"Resume from this older checkpoint?\\\").\\n   393→\\t\\t\\t\\tValue(&confirmed),\\n   394→\\t\\t),\\n   395→\\t)\\n   396→\\n   397→\\tif err := form.Run(); err != nil {\\n   398→\\t\\tif errors.Is(err, huh.ErrUserAborted) {\\n   399→\\t\\t\\treturn false, nil\\n   400→\\t\\t}\\n   401→\\t\\treturn false, fmt.Errorf(\\\"failed to get confirmation: %w\\\", err)\\n   402→\\t}\\n   403→\\n   404→\\treturn confirmed, nil\\n   405→}\\n   406→\\n   407→// checkRemoteMetadata checks if checkpoint metadata exists on origin/entire/checkpoints/v1\\n   408→// and automatically fetches it if available.\\n   409→func checkRemoteMetadata(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID) error {\\n   410→\\t// Try to get remote metadata branch tree\\n   411→\\tremoteTree, err := strategy.GetRemoteMetadataBranchTree(repo)\\n   412→\\tif err != nil {\\n   413→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   414→\\t\\tfmt.Fprintf(os.Stderr, \\\"The entire/checkpoints/v1 branch may not exist locally or on the remote.\\\\n\\\")\\n   415→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   416→\\t}\\n   417→\\n   418→\\t// Check if the checkpoint exists on the remote\\n   419→\\tmetadata, err := strategy.ReadCheckpointMetadata(remoteTree, checkpointID.Path())\\n   420→\\tif err != nil {\\n   421→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   422→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   423→\\t}\\n   424→\\n   425→\\t// Metadata exists on remote but not locally - fetch it automatically\\n   426→\\tfmt.Fprintf(os.Stderr, \\\"Fetching session metadata from origin...\\\\n\\\")\\n   427→\\tif err := FetchMetadataBranch(ctx); err != nil {\\n   428→\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to fetch metadata: %v\\\\n\\\", err)\\n   429→\\t\\tfmt.Fprintf(os.Stderr, \\\"You can try manually: git fetch origin entire/checkpoints/v1:entire/checkpoints/v1\\\\n\\\")\\n   430→\\t\\treturn NewSilentError(errors.New(\\\"failed to fetch metadata\\\"))\\n   431→\\t}\\n   432→\\n   433→\\t// Now resume the session with the fetched metadata\\n   434→\\treturn resumeSession(ctx, metadata, false)\\n   435→}\\n   436→\\n   437→// resumeSession restores and displays the resume command for a specific session.\\n   438→// For multi-session checkpoints, restores ALL sessions and shows commands for each.\\n   439→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   440→// The caller must provide the already-resolved checkpoint metadata to avoid redundant lookups\\n   441→// and to support both local and remote metadata trees.\\n   442→func resumeSession(ctx context.Context, metadata *strategy.CheckpointInfo, force bool) error {\\n   443→\\tcheckpointID := metadata.CheckpointID\\n   444→\\tsessionID := metadata.SessionID\\n   445→\\n   446→\\t// Resolve agent from checkpoint metadata (same as rewind)\\n   447→\\tag, err := strategy.ResolveAgentForRewind(metadata.Agent)\\n   448→\\tif err != nil {\\n   449→\\t\\treturn fmt.Errorf(\\\"failed to resolve agent: %w\\\", err)\\n   450→\\t}\\n   451→\\n   452→\\t// Initialize logging context with agent\\n   453→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"resume\\\"), ag.Name())\\n   454→\\n   455→\\tlogging.Debug(logCtx, \\\"resume session started\\\",\\n   456→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   457→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   458→\\t)\\n   459→\\n   460→\\t// Get worktree root for session directory lookup\\n   461→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   462→\\tif err != nil {\\n   463→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   464→\\t}\\n   465→\\n   466→\\tsessionDir, err := ag.GetSessionDir(repoRoot)\\n   467→\\tif err != nil {\\n   468→\\t\\treturn fmt.Errorf(\\\"failed to determine session directory: %w\\\", err)\\n   469→\\t}\\n   470→\\n   471→\\t// Create directory if it doesn't exist\\n   472→\\tif err := os.MkdirAll(sessionDir, 0o700); err != nil {\\n   473→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   474→\\t}\\n   475→\\n   476→\\t// Get strategy and restore sessions using full checkpoint data\\n   477→\\tstrat := GetStrategy(ctx)\\n   478→\\n   479→\\t// Use RestoreLogsOnly via LogsOnlyRestorer interface for multi-session support\\n   480→\\t// Create a logs-only rewind point with Agent populated (same as rewind)\\n   481→\\tpoint := strategy.RewindPoint{\\n   482→\\t\\tIsLogsOnly:   true,\\n   483→\\t\\tCheckpointID: checkpointID,\\n   484→\\t\\tAgent:        metadata.Agent,\\n   485→\\t}\\n   486→\\n   487→\\tsessions, restoreErr := strat.RestoreLogsOnly(ctx, point, force)\\n   488→\\tif restoreErr != nil || len(sessions) == 0 {\\n   489→\\t\\t// Fall back to single-session restore (e.g., old checkpoints without agent metadata)\\n   490→\\t\\treturn resumeSingleSession(ctx, ag, sessionID, checkpointID, repoRoot, force)\\n   491→\\t}\\n   492→\\n   493→\\tlogging.Debug(logCtx, \\\"resume session completed\\\",\\n   494→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   495→\\t\\tslog.Int(\\\"session_count\\\", len(sessions)),\\n   496→\\t)\\n   497→\\n   498→\\treturn displayRestoredSessions(sessions)\\n   499→}\\n   500→\\n   501→// displayRestoredSessions sorts sessions by CreatedAt and prints resume commands.\\n   502→func displayRestoredSessions(sessions []strategy.RestoredSession) error {\\n   503→\\tsort.SliceStable(sessions, func(i, j int) bool {\\n   504→\\t\\treturn sessions[i].CreatedAt.Before(sessions[j].CreatedAt)\\n   505→\\t})\\n   506→\\n   507→\\tif len(sessions) > 1 {\\n   508→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nRestored %d sessions. To continue, run:\\\\n\\\", len(sessions))\\n   509→\\t} else if len(sessions) == 1 {\\n   510→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session: %s\\\\n\\\", sessions[0].SessionID)\\n   511→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   512→\\t}\\n   513→\\n   514→\\tfor i, sess := range sessions {\\n   515→\\t\\tsessionAgent, err := strategy.ResolveAgentForRewind(sess.Agent)\\n   516→\\t\\tif err != nil {\\n   517→\\t\\t\\treturn fmt.Errorf(\\\"failed to resolve agent for session %s: %w\\\", sess.SessionID, err)\\n   518→\\t\\t}\\n   519→\\t\\tcmd := sessionAgent.FormatResumeCommand(sess.SessionID)\\n   520→\\n   521→\\t\\tisLast := i == len(sessions)-1\\n   522→\\t\\tswitch {\\n   523→\\t\\tcase len(sessions) > 1 && isLast && sess.Prompt != \\\"\\\":\\n   524→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # %s (most recent)\\\\n\\\", cmd, sess.Prompt)\\n   525→\\t\\tcase len(sessions) > 1 && isLast:\\n   526→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # (most recent)\\\\n\\\", cmd)\\n   527→\\t\\tcase sess.Prompt != \\\"\\\":\\n   528→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # %s\\\\n\\\", cmd, sess.Prompt)\\n   529→\\t\\tdefault:\\n   530→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", cmd)\\n   531→\\t\\t}\\n   532→\\t}\\n   533→\\n   534→\\treturn nil\\n   535→}\\n   536→\\n   537→// resumeSingleSession restores a single session (fallback when multi-session restore fails).\\n   538→// Always overwrites existing session logs to ensure consistency with checkpoint state.\\n   539→// If force is false, prompts for confirmation when local log has newer timestamps.\\n   540→func resumeSingleSession(ctx context.Context, ag agent.Agent, sessionID string, checkpointID id.CheckpointID, repoRoot string, force bool) error {\\n   541→\\tsessionLogPath, err := resolveTranscriptPath(ctx, sessionID, ag)\\n   542→\\tif err != nil {\\n   543→\\t\\treturn fmt.Errorf(\\\"failed to resolve transcript path: %w\\\", err)\\n   544→\\t}\\n   545→\\n   546→\\tif checkpointID.IsEmpty() {\\n   547→\\t\\tlogging.Debug(ctx, \\\"resume session: empty checkpoint ID\\\",\\n   548→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   549→\\t\\t)\\n   550→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session '%s' found in commit trailer but session log not available\\\\n\\\", sessionID)\\n   551→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   552→\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", ag.FormatResumeCommand(sessionID))\\n   553→\\t\\treturn nil\\n   554→\\t}\\n   555→\\n   556→\\tlogContent, _, err := checkpoint.LookupSessionLog(ctx, checkpointID)\\n   557→\\tif err != nil {\\n   558→\\t\\tif errors.Is(err, checkpoint.ErrCheckpointNotFound) || errors.Is(err, checkpoint.ErrNoTranscript) {\\n   559→\\t\\t\\tlogging.Debug(ctx, \\\"resume session completed (no metadata)\\\",\\n   560→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   561→\\t\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   562→\\t\\t\\t)\\n   563→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Session '%s' found in commit trailer but session log not available\\\\n\\\", sessionID)\\n   564→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   565→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", ag.FormatResumeCommand(sessionID))\\n   566→\\t\\t\\treturn nil\\n   567→\\t\\t}\\n   568→\\t\\tlogging.Error(ctx, \\\"resume session failed\\\",\\n   569→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   570→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   571→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   572→\\t\\t)\\n   573→\\t\\treturn fmt.Errorf(\\\"failed to get session log: %w\\\", err)\\n   574→\\t}\\n   575→\\n   576→\\t// 