 839→\\n   840→\\treturn nil\\n   841→}\\n   842→\\n   843→// postCommitProcessSession handles a single session within the PostCommit loop.\\n   844→// Pre-resolved git objects (headTree, parentTree) are shared across all sessions;\\n   845→// per-session shadow ref/tree are resolved once here and threaded through sub-calls.\\n   846→func (s *ManualCommitStrategy) postCommitProcessSession(\\n   847→\\tctx context.Context,\\n   848→\\trepo *git.Repository,\\n   849→\\tstate *SessionState,\\n   850→\\ttransitionCtx *session.TransitionContext,\\n   851→\\tcheckpointID id.CheckpointID,\\n   852→\\thead *plumbing.Reference,\\n   853→\\tcommit *object.Commit,\\n   854→\\tnewHead string,\\n   855→\\trepoDir string,\\n   856→\\theadTree, parentTree *object.Tree,\\n   857→\\tcommittedFileSet map[string]struct{},\\n   858→\\tshadowBranchesToDelete map[string]struct{},\\n   859→\\tuncondensedActiveOnBranch map[string]bool,\\n   860→) {\\n   861→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   862→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   863→\\n   864→\\t// Pre-resolve shadow branch ref and tree for this session.\\n   865→\\t// These are read 4+ times across sessionHasNewContent, filesOverlapWithContent,\\n   866→\\t// CondenseSession, filesWithRemainingAgentChanges, and calculateSessionAttributions.\\n   867→\\tvar shadowRef *plumbing.Reference\\n   868→\\tvar shadowTree *object.Tree\\n   869→\\tif ref, refErr := repo.Reference(plumbing.NewBranchReferenceName(shadowBranchName), true); refErr == nil {\\n   870→\\t\\tshadowRef = ref\\n   871→\\t\\tif sc, scErr := repo.CommitObject(ref.Hash()); scErr == nil {\\n   872→\\t\\t\\tif st, stErr := sc.Tree(); stErr == nil {\\n   873→\\t\\t\\t\\tshadowTree = st\\n   874→\\t\\t\\t}\\n   875→\\t\\t}\\n   876→\\t}\\n   877→\\n   878→\\t// Check for new content (needed for TransitionContext and condensation).\\n   879→\\t// Fail-open: if content check errors, assume new con