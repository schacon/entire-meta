 err != nil {\\n   789→\\t\\treturn \\\"\\\"\\n   790→\\t}\\n   791→\\n   792→\\t// Look for prompt.txt in the metadata directory\\n   793→\\tpromptPath := metadataDir + \\\"/\\\" + paths.PromptFileName\\n   794→\\tpromptEntry, err := tree.File(promptPath)\\n   795→\\tif err != nil {\\n   796→\\t\\treturn \\\"\\\"\\n   797→\\t}\\n   798→\\n   799→\\tcontent, err := promptEntry.Contents()\\n   800→\\tif err != nil {\\n   801→\\t\\treturn \\\"\\\"\\n   802→\\t}\\n   803→\\n   804→\\treturn ExtractFirstPrompt(content)\\n   805→}\\n   806→\\n   807→// SessionRestoreStatus represents the status of a session being restored.\\n   808→type SessionRestoreStatus int\\n   809→\\n   810→const (\\n   811→\\tStatusNew             SessionRestoreStatus = iota // Local file doesn't exist\\n   812→\\tStatusUnchanged                                   // Local and checkpoint are the same\\n   813→\\tStatusCheckpointNewer                             // Checkpoint has newer entries\\n   814→\\tStatusLocalNewer                                  // Local has newer entries (conflict)\\n   815→)\\n   816→\\n   817→// SessionRestoreInfo contains information about a session being restored.\\n   818→type SessionRestoreInfo struct {\\n   819→\\tSessionID      string\\n   820→\\tPrompt         string               // First prompt preview for display\\n   821→\\tStatus         SessionRestoreStatus // Status of this session\\n   822→\\tLocalTime      time.Time\\n   823→\\tCheckpointTime time.Time\\n   824→}\\n   825→\\n   826→// classifySessionsForRestore checks all sessions in a checkpoint and returns info\\n   827→// about each session, including whether local logs have newer timestamps.\\n   828→// repoRoot is used to compute per-session agent directories.\\n   829→// Sessions without agent metadata are skipped (cannot determine target directory).\\n   830→func (s *ManualCommitStrategy) classifySessionsForRestore(ctx context.Context, repoRoot string, store cpkg.Store, checkpointID id.CheckpointID, summary *cpkg.CheckpointSummary) []SessionRestoreInfo {\\n   831→\\tvar sessions []SessionRestoreInfo\\n   832→\\n   833→\\ttotalSessions := len(summary.Sessions)\\n   834→\\t// Check all sessions (0-based indexing)\\n   835→\\tfor i := range totalSessions {\\n   836→\\t\\tcontent, err := store.ReadSessionContent(ctx, checkpointID, i)\\n   837→\\t\\tif err != nil || content == nil || len(content.Transcript) == 0 {\\n   838→\\t\\t\\tcontinue\\n   839→\\t\\t}\\n   840→\\n   841→\\t\\tsessionID := content.Metadata.SessionID\\n   842→\\t\\tif sessionID == \\\"\\\" || content.Metadata.Agent == \\\"\\\" {\\n   843→\\t\\t\\tcontinue\\n   844→\\t\\t}\\n   845→\\n   846→\\t\\tsessionAgent, agErr := ResolveAgentForRewind(content.Metadata.Agent)\\n   847→\\t\\tif agErr != nil {\\n   848→\\t\\t\\tcontinue\\n   849→\\t\\t}\\n   850→\\n   851→\\t\\t// Compute transcript path from current repo location for cross-machine portability.\\n   852→\\t\\tsessionAgentDir, dirErr := sessionAgent.GetSessionDir(repoRoot)\\n   853→\\t\\tif dirErr != nil {\\n   854→\\t\\t\\tcontinue\\n   855→\\t\\t}\\n   856→\\t\\tlocalPath := sessionAgent.ResolveSessionFile(sessionAgentDir, sessionID)\\n   857→\\n   858→\\t\\tlocalTime := paths.GetLastTimestampFromFile(localPath)\\n   859→\\t\\tcheckpointTime := paths.GetLastTimestampFromBytes(content.Transcript)\\n   860→\\t\\tstatus := ClassifyTimestamps(localTime, checkpointTime)\\n   861→\\n   862→\\t\\tsessions = append(sessions, SessionRestoreInfo{\\n   863→\\t\\t\\tSessionID:      sessionID,\\n   864→\\t\\t\\tPrompt:         ExtractFirstPrompt(content.Prompts),\\n   865→\\t\\t\\tStatus:         status,\\n   866→\\t\\t\\tLocalTime:      localTime,\\n   867→\\t\\t\\tCheckpointTime: checkpointTime,\\n   868→\\t\\t})\\n   869→\\t}\\n   870→\\n   871→\\treturn sessions\\n   872→}\\n   873→\\n   874→// ClassifyTimestamps determines the restore status based on local and checkpoint timestamps.\\n   875→func ClassifyTimestamps(localTime, checkpointTime time.T