iptPath = metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n   606→\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n   607→\\t\\tcontent, contentErr := file.Contents()\\n   608→\\t\\tif contentErr == nil {\\n   609→\\t\\t\\treturn []byte(content), nil\\n   610→\\t\\t}\\n   611→\\t}\\n   612→\\n   613→\\treturn nil, ErrNoTranscript\\n   614→}\\n   615→\\n   616→// ShadowBranchExists checks if a shadow branch exists for the given base commit and worktree.\\n   617→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   618→func (s *GitStore) ShadowBranchExists(baseCommit, worktreeID string) bool {\\n   619→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   620→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   621→\\t_, err := s.repo.Reference(refName, true)\\n   622→\\treturn err == nil\\n   623→}\\n   624→\\n   625→// DeleteShadowBranch deletes the shadow branch for the given base commit and worktree.\\n   626→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   627→// Uses git CLI instead of go-git's RemoveReference because go-git v5 doesn't properly\\n   628→// persist deletions with packed refs or worktrees.\\n   629→func (s *GitStore) DeleteShadowBranch(ctx context.Context, baseCommit, worktreeID string) error {\\n   630→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   631→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", shadowBranchName)\\n   632→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   633→\\t\\treturn fmt.Errorf(\\\"failed to delete shadow branch %s: %s: %w\\\", shadowBranchName, strings.TrimSpace(string(output)), err)\\n   634→\\t}\\n   635→\\treturn nil\\n   636→}\\n   637→\\n   638→// ShadowBranchNameForCommit returns the shadow branch name for a base commit hash\\n   639→// and worktree id