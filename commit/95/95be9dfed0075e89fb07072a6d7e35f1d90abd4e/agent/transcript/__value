fter logs-only rewind, file should STILL be at version 2, but got: %s\\\", content)\\n   300→\\t}\\n   301→\\n   302→\\t// HEAD should still be at commit 2\\n   303→\\tcurrentHead := env.GetHeadHash()\\n   304→\\tif currentHead == commit1Hash {\\n   305→\\t\\tt.Error(\\\"HEAD should NOT change after logs-only rewind\\\")\\n   306→\\t}\\n   307→\\n   308→\\t// Branch should still be feature/no-modify-test (not detached)\\n   309→\\tcurrentBranch := env.GetCurrentBranch()\\n   310→\\tif currentBranch != \\\"feature/no-modify-test\\\" {\\n   311→\\t\\tt.Errorf(\\\"Should still be on feature branch, got: %s\\\", currentBranch)\\n   312→\\t}\\n   313→}\\n   314→\\n   315→// TestLogsOnlyRewind_DeduplicationWithCheckpoints verifies that a commit\\n   316→// that still has an active checkpoint is NOT shown as logs-only.\\n   317→func TestLogsOnlyRewind_DeduplicationWithCheckpoints(t *testing.T) {\\n   318→\\tt.Parallel()\\n   319→\\tenv := NewTestEnv(t)\\n   320→\\tdefer env.Cleanup()\\n   321→\\n   322→\\t// Setup\\n   323→\\tenv.InitRepo()\\n   324→\\tenv.WriteFile(\\\"README.md\\\", \\\"# Test Repository\\\")\\n   325→\\tenv.GitAdd(\\\"README.md\\\")\\n   326→\\tenv.GitCommit(\\\"Initial commit\\\")\\n   327→\\tenv.GitCheckoutNewBranch(\\\"feature/dedup-test\\\")\\n   328→\\tenv.InitEntire()\\n   329→\\n   330→\\tt.Log(\\\"Phase 1: Create checkpoint (but don't commit yet)\\\")\\n   331→\\n   332→\\tsession := env.NewSession()\\n   333→\\tif err := env.SimulateUserPromptSubmit(session.ID); err != nil {\\n   334→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   335→\\t}\\n   336→\\n   337→\\tcontent := \\\"package main\\\\n\\\\nfunc dedup() {}\\\\n\\\"\\n   338→\\tenv.WriteFile(\\\"dedup.go\\\", content)\\n   339→\\tsession.CreateTranscript(\\\"Create dedup function\\\", []FileChange{{Path: \\\"dedup.go\\\", Content: content}})\\n   340→\\n   341→\\tif err := env.SimulateStop(session.ID, session.TranscriptPath); err != nil {\\n   342→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   343→\\t}\\n   344→\\n   345→\\t// Verify we have 1 checkpoint point (not logs-only)\\n   346→\\tpoints := env.GetRewindPoints()\\n   347→\\tif len(points) != 1 {\\n   348→\\t\\tt.Fatalf(\\\"Expected 1 rewind point, got %d\\\", len(points))\\n   349→\\t}\\n   350→\\tif points[0].IsLogsOnly {\\n   351→\\t\\tt.Error(\\\"Before commit, point should be checkpoint (not logs-only)\\\")\\n   352→\\t}\\n   353→\\tt.Logf(\\\"Checkpoint point: %s\\\", points[0].ID[:7])\\n   354→\\n   355→\\tt.Log(\\\"Phase 2: User commits - checkpoint condensed, becomes logs-only\\\")\\n   356→\\n   357→\\tenv.GitCommitWithShadowHooks(\\\"Add dedup function\\\", \\\"dedup.go\\\")\\n   358→\\tcommitHash := env.GetHeadHash()\\n   359→\\n   360→\\t// After commit, the checkpoint is condensed\\n   361→\\t// We should see either:\\n   362→\\t// 1. A logs-only point (if shadow branch was pruned)\\n   363→\\t// 2. A checkpoint point (if shadow branch still exists)\\n   364→\\t// But NOT both for the same commit\\n   365→\\n   366→\\tpoints = env.GetRewindPoints()\\n   367→\\n   368→\\t// Count how many points reference this commit hash\\n   369→\\tmatchingPoints := 0\\n   370→\\tvar foundLogsOnly, foundCheckpoint bool\\n   371→\\tfor _, p := range points {\\n   372→\\t\\tif p.ID == commitHash {\\n   373→\\t\\t\\tmatchingPoints++\\n   374→\\t\\t\\tif p.IsLogsOnly {\\n   375→\\t\\t\\t\\tfoundLogsOnly = true\\n   376→\\t\\t\\t} else {\\n   377→\\t\\t\\t\\tfoundCheckpoint = true\\n   378→\\t\\t\\t}\\n   379→\\t\\t}\\n   380→\\t}\\n   381→\\n   382→\\t// Should not have duplicates\\n   383→\\tif matchingPoints > 1 {\\n   384→\\t\\tt.Errorf(\\\"Commit %s should not appear multiple times in rewind list (found %d)\\\", commitHash[:7], matchingPoints)\\n   385→\\t}\\n   386→\\n   387→\\t// Should have exactly one representation\\n   388→\\tif foundLogsOnly && foundCheckpoint {\\n   389→\\t\\tt.Error(\\\"Same commit should not appear as both checkpoint AND logs-only\\\")\\n   390→\\t}\\n   391→\\n   392→\\tt.Logf(\\\"Found points: logsOnly=%v, checkpoint=%v, total=%d\\\", foundLogsOnly, foundCheckpoint, len(points))\\n   393→}\\n   394→\\n   395→// TestLogsOnlyRewind_MultipleCommits verifies logs-only points from\\n   396→// multiple commits in history.\\n   397→func TestLogsOnlyRewind_MultipleCommits(t *testing.T) {\\n   398→\\tt.Parallel()\\n   399→\\tenv := NewTestEnv(t)\\n   400→\\tdefer env.Cleanup()\\n   401→\\n   402→\\t// Setup\\n   403→\\tenv.InitRepo()\\n   404→\\tenv.WriteFile(\\\"README.md\\\", \\\"# Test Repository\\\")\\n   405→\\tenv.GitAdd(\\\"README.md\\\")\\n   406→\\tenv.GitCommit(\\\"Initial commit\\\")\\n   407→\\tenv.GitCheckoutNewBranch(\\\"feature/multi-commit-test\\\")\\n   408→\\tenv.InitEntire()\\n   409→\\n   410→\\tvar commitHashes []string\\n   411→\\n   412→\\t// Create 3 sessions, each followed by a commit\\n   413→\\tfor i := 1; i <= 3; i++ {\\n   414→\\t\\tt.Logf(\\\"Creating session %d and committing\\\", i)\\n   415→\\n   416→\\t\\tsession := env.NewSession()\\n   417→\\t\\tif err := env.SimulateUserPromptSubmit(session.ID); err != nil {\\n   418→\\t\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   419→\\t\\t}\\n   420→\\n   421→\\t\\tfilename := \\\"file\\\" + string(rune('0'+i)) + \\\".go\\\"\\n   422→\\t\\tcontent := \\\"package main\\\\n\\\\n// File \\\" + string(rune('0'+i)) + \\\"\\\\n\\\"\\n   423→\\t\\tenv.WriteFile(filename, content)\\n   424→\\t\\tsession.CreateTranscript(\\\"Create \\\"+filename, []FileChange{{Path: filename, Content: content}})\\n   425→\\n   426→\\t\\tif err := env.SimulateStop(session.ID, session.TranscriptPath); err != nil {\\n   427→\\t\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   428→\\t\\t}\\n   429→\\n   430→\\t\\tenv.GitCommitWithShadowHooks(\\\"Add \\\"+filename, filename)\\n   431→\\t\\tcommitHashes = append(commitHashes, env.GetHeadHash())\\n   432→\\n   433→\\t\\t// Clear session state to simulate session completion (avoids concurrent session warning)\\n   434→\\t\\tif err := env.ClearSessionState(session.ID); err != nil {\\n   435→\\t\\t\\tt.Fatalf(\\\"ClearSessionState failed: %v\\\", err)\\n   436→\\t\\t}\\n   437→\\t}\\n   438→\\n   439→\\tt.Log(\\\"Verify all 3 commits appear as logs-only points\\\")\\n   440→\\n   441→\\tpoints := env.GetRewindPoints()\\n   442→\\n   443→\\t// Check each commit hash appears\\n   444→\\tfor _, hash := range commitHashes {\\n   445→\\t\\tfound := false\\n   446→\\t\\tfor _, p := range points {\\n   447→\\t\\t\\tif p.ID == hash && p.IsLogsOnly {\\n   448→\\t\\t\\t\\tfound = true\\n   449→\\t\\t\\t\\tt.Logf(\\\"Found logs-only point for commit %s: %s\\\", hash[:7], p.Message)\\n   450→\\t\\t\\t\\tbreak\\n   451→\\t\\t\\t}\\n   452→\\t\\t}\\n   453→\\t\\tif !found {\\n   454→\\t\\t\\tt.Errorf(\\\"Commit %s should appear as logs-only point\\\", hash[:7])\\n   455→\\t\\t}\\n   456→\\t}\\n   457→}\\n   458→\\n   459→// filterLogsOnlyPoints returns only logs-only points from the rewind points.\\n   460→func filterLogsOnlyPoints(points []RewindPoint) []RewindPoint {\\n   461→\\tvar logsOnly []RewindPoint\\n   462→\\tfor _, p := range points {\\n   463→\\t\\tif p.IsLogsOnly {\\n   464→\\t\\t\\tlogsOnly = append(logsOnly, p)\\n   465→\\t\\t}\\n   466→\\t}\\n   467→\\treturn logsOnly\\n   468→}\\n   469→\\n   470→// TestLogsOnlyRewind_Reset verifies that --reset flag performs git reset --hard.\\n   471→func TestLogsOnlyRewind_Reset(t *testing.T) {\\n   472→\\tt.Parallel()\\n   473→\\tenv := NewTestEnv(t)\\n   474→\\tdefer env.Cleanup()\\n   475→\\n   476→\\t// Setup\\n   477→\\tenv.InitRepo()\\n   478→\\tenv.WriteFile(\\\"README.md\\\", \\\"# Test Repository\\\")\\n   479→\\tenv.GitAdd(\\\"README.md\\\")\\n   480→\\tenv.GitCommit(\\\"Initial commit\\\")\\n   481→\\tenv.GitCheckoutNewBranch(\\\"feature/reset-test\\\")\\n   482→\\tenv.InitEntire()\\n   483→\\n   484→\\tt.Log(\\\"Phase 1: Create session 1 and commit\\\")\\n   485→\\n   486→\\tsession1 := env.NewSession()\\n   487→\\tif err := env.SimulateUserPromptSubmit(session1.ID); err != nil {\\n   488→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   489→\\t}\\n   490→\\n   491→\\tv1Content := \\\"version 1 content\\\"\\n   492→\\tenv.WriteFile(\\\"file.txt\\\", v1Content)\\n   493→\\tsession1.CreateTranscript(\\\"Create file with version 1\\\", []FileChange{{Path: \\\"file.txt\\\", Content: v1Content}})\\n   494→\\n   495→\\tif err := env.SimulateStop(session1.ID, session1.TranscriptPath); err != nil {\\n   496→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   497→\\t}\\n   498→\\n   499→\\tenv.GitCommitWithShadowHooks(\\\"Add file version 1\\\", \\\"file.txt\\\")\\n   500→\\tcommit1Hash := env.GetHeadHash()\\n   501→\\tt.Logf(\\\"Commit 1: %s\\\", commit1Hash[:7])\\n   502→\\n   503→\\t// Clear session 1 state to simulate session completion (avoids concurrent session warning)\\n   504→\\tif err := env.ClearSessionState(session1.ID); err != nil {\\n   505→\\t\\tt.Fatalf(\\\"ClearSessionState failed: %v\\\", err)\\n   506→\\t}\\n   507→\\n   508→\\tt.Log(\\\"Phase 2: Create session 2 and commit\\\")\\n   509→\\n   510→\\tsession2 := env.NewSession()\\n   511→\\tif err := env.SimulateUserPromptSubmit(session2.ID); err != nil {\\n   512→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   513→\\t}\\n   514→\\n   515→\\tv2Content := \\\"version 2 content\\\"\\n   516→\\tenv.WriteFile(\\\"file.txt\\\", v2Content)\\n   517→\\tsession2.CreateTranscript(\\\"Update file to version 2\\\", []FileChange{{Path: \\\"file.txt\\\", Content: v2Content}})\\n   518→\\n   519→\\tif err := env.SimulateStop(session2.ID, session2.TranscriptPath); err != nil {\\n   520→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   521→\\t}\\n   522→\\n   523→\\tenv.GitCommitWithShadowHooks(\\\"Update file to version 2\\\", \\\"file.txt\\\")\\n   524→\\tcommit2Hash := env.GetHeadHash()\\n   525→\\tt.Logf(\\\"Commit 2: %s\\\", commit2Hash[:7])\\n   526→\