 successful condensation.\\n    50→\\tAttributionBaseCommit string `json:\\\"attribution_base_commit,omitempty\\\"`\\n    51→\\n    52→\\t// WorktreePath is the absolute path to the worktree root\\n    53→\\tWorktreePath string `json:\\\"worktree_path,omitempty\\\"`\\n    54→\\n    55→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n    56→\\t// Derived from .git/worktrees/<name>/, stable across git worktree move\\n    57→\\tWorktreeID string `json:\\\"worktree_id,omitempty\\\"`\\n    58→\\n    59→\\t// StartedAt is when the session was started\\n    60→\\tStartedAt time.Time `json:\\\"started_at\\\"`\\n    61→\\n    62→\\t// EndedAt is when the session was explicitly closed by the user.\\n    63→\\t// nil means the session is still active or was not cleanly closed.\\n    64→\\tEndedAt *time.Time `json:\\\"ended_at,omitempty\\\"`\\n    65→\\n    66→\\t// Phase is the lifecycle stage of this session (see phase.go).\\n    67→\\t// Empty means idle (backward compat with pre-state-machine files).\\n    68→\\tPhase Phase `json:\\\"phase,omitempty\\\"`\\n    69→\\n    70→\\t// TurnID is a unique identifier for the current agent turn.\\n    71→\\t// Lifecycle:\\n    72→\\t//   - Generated fresh in InitializeSession at each turn start\\n    73→\\t//   - Shared across all checkpoints within the same turn\\n    74→\\t//   - Used to correlate related checkpoints when a turn's work spans multiple commits\\n    75→\\t//   - Persists until the next InitializeSession call generates a new one\\n    76→\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n    77→\\n    78→\\t// TurnCheckpointIDs tracks all checkpoint IDs condensed during the current turn.\\n    79→\\t// Lifecycle:\\n    80→\\t//   - Set in PostCommit when a checkpoint is condensed for an ACTIVE session\\n    81→\\t//   - Consumed in HandleTurnEnd to finalize all checkpoints with the full transcript\\n    82→\\t//   - Cleared in HandleTurnEnd after finalization completes\\n    83→\\t//   - Cleared in InitializeSession when a new prompt starts\\n    84→\\t//   - Cleared when session is reset (ResetSession deletes the state file entirely)\\n    85→\\tTurnCheckpointIDs []string `json:\\\"turn_checkpoint_ids,omitempty\\\"`\\n    86→\\n    87→\\t// LastInteractionTime is updated on agent-interaction events (TurnStart,\\n    88→\\t// TurnEnd, SessionStop, Compaction) but NOT on git commit hooks.\\n    89→\\t// Used for stale session detection in \\\"entire doctor\\\".\\n    90→\\tLastInteractionTime *time.Time `json:\\\"last_interaction_time,omitempty\\\"`\\n    91→\\n    92→\\t// StepCount is the number of checkpoints/steps created in this session.\\n    93→\\t// JSON tag kept as \\\"checkpoint_count\\\" for backward compatibility with existing state files.\\n    94→\\tStepCount int `json:\\\"checkpoint_count\\\"`\\n    95→\\n    96→\\t// CheckpointTranscriptStart is the transcript line offset where the current\\n    97→\\t// checkpoint cycle began. Set to 0 at session start, updated to current\\n    98→\\t// transcript length after each condensation. Used to scope the transcript\\n    99→\\t// for checkpoint condensation: \\\"everything since last checkpoint\\\".\\n   100→\\tCheckpointTranscriptStart int `json:\\\"checkpoint_transcript_start,omitempty\\\"`\\n   101→\\n   102→\\t// Deprecated: CondensedTranscriptLines is replaced by CheckpointTranscriptStart.\\n   103→\\t// Kept for backward compatibility with existing state files.\\n   104→\\t// Use NormalizeAfterLoad() to migrate.\\n   105→\\tCondensedTranscriptLines int `json:\\\"condensed_transcript_lines,omitempty\\\"`\\n   106→\\n   107→\\t// UntrackedFilesAtStart tracks files that existed at session start (to preserve during rewind)\\n   108→\\tUntrackedFilesAtStart []string `json:\\\"untracked_files_at_start,omitempty\\\"`\\n   109→\\n   110→\\t// FilesTouched tracks files modified/created/deleted during this session\\n   111→\\tFilesTouched []string `json:\\\"files_touched,omitempty\\\"`\\n   112→\\n   113→\\t// LastCheckpointID is the checkpoint ID from the most recent condensation.\\n   114→\\t// Used to restore the Entire-Checkpoint trailer on amend and to identify\\n   115→\\t// sessions that have been condensed at least once. Cleared on new prompt.\\n   116→\\tLastCheckpointID id.CheckpointID `json:\\\"last_checkpoint_id,omitempty\\\"`\\n   117→\\n   118→\\t// FullyCondensed indicates this session has been condensed and has no remaining\\n   119→\\t// carry-forward files. PostCommit skips fully-condensed sessions entirely.\\n   120→\\t// Set after successful condensation when no files remain for carry-forward\\n   121→\\t// and the session phase is ENDED. Cleared on session reactivation (ENDED →\\n   122→\\t// ACTIVE via TurnStart, or ENDED → IDLE via SessionStart) by ActionClearEndedAt.\\n   123→\\tFullyCondensed bool `json:\\\"fully_condensed,omitempty\\\"`\\n   124→\\n   125→\\t// AgentType identifies the agent that created this session (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\", \\\"Cursor\\\")\\n   126→\\tAgentType types.AgentType `json:\\\"agent_type,omitempty\\\"`\\n   127→\\n   128→\\t// ModelName is the LLM model used in this session (e.g., \\\"claude-sonnet-4-20250514\\\", \\\"gpt-4o\\\").\\n   129→\\t// Set from hook data when the agent provides it.\\n   130→\\tModelName string `json:\\\"model_name,omitempty\\\"`\\n   131→\\n   132→\\t// Token usage tracking (accumulated across all checkpoints in this session)\\n   133→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   134→\\n   135→\\t// Deprecated: TranscriptLinesAtStart is replaced by CheckpointTranscriptStart.\\n   136→\\t// Kept for backward compatibility with existing state files.\\n   137→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   138→\\n   139→\\t// TranscriptIdentifierAtStart is the last transcript identifier when the session started.\\n   140→\\t// Used for identifier-based transcript scoping (UUID for Claude, message ID for Gemini).\\n   141→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"`\\n   142→\\n   143→\\t// TranscriptPath is the path to the live transcript file (for mid-session commit detection)\\n   144→\\tTranscriptPath string `json:\\\"transcript_path,omitempty\\\"`\\n   145→\\n   146→\\t// LastPrompt is the most recent user prompt for this session (truncated for display).\\n   147→\\t// Updated on every turn start (UserPromptSubmit). JSON tag kept as \\\"first_prompt\\\"\\n   148→\\t// for backward compatibility with existing state files.\\n   149→\\tLastPrompt string `json:\\\"last_prompt,omitempty\\\"`\\n   150→\\n   151→\\t// PromptAttributions tracks user and agent line changes at each prompt start.\\n   152→\\t// This enables accurate attribution by capturing user edits between checkpoints.\\n   153→\\tPromptAttributions []PromptAttribution `json:\\\"prompt_attributions,omitempty\\\"`\\n   154→\\n   155→\\t// PendingPromptAttribution holds attribution calculated at prompt start (before agent runs).\\n   156→\\t// This is moved to PromptAttributions when SaveStep is called.\\n   157→\\tPendingPromptAttribution *PromptAttribution `json:\\\"pending_prompt_attribution,omitempty\\\"`\\n   158→}\\n   159→\\n   160→// PromptAttribution captures line-level attribution data at the start of each prompt.\\n   161→// By recording what changed since the last checkpoint BEFORE the agent works,\\n   162→// we can accurately separate user edits from agent contributions.\\n   163→type PromptAttribution struct {\\n   164→\\t// CheckpointNumber is which checkpoint this was recorded before (1-indexed)\\n   165→\\tCheckpointNumber int `json:\\\"checkpoint_number\\\"`\\n   166→\\n   167→\\t// UserLinesAdded is lines added by user since the last checkpoint\\n   168→\\tUserLinesAdded int `json:\\\"user_lines_added\\\"`\\n   169→\\n   170→\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   171→\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   172→\\n   173→\\t// AgentLinesAdded is total agent lines added so far (base → last checkpoint).\\n   174→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   175→\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   176→\\n   177→\\t// AgentLinesRemoved is total agent lines removed so far (base → last checkpoint).\\n   178→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   179→\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   180→\\n   181→\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   182→\\t// This enables distinguishing user self-modifications from agent modifications.\\n   183→\\t// See docs/architecture/attribution.md for details.\\n   184→\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   185→}\\n   186→\\n   187→// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   188→// Call this after deserializing a State from JSON.\\n   189→func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   190→\\t// Normalize legacy phase values. \\\"active_committed\\\" was removed with the\\n   191→\\t// 1:1 checkpoint model in favor of the state machine handling commits\\n   192→\\t// during ACTIVE phase with immediate condensation.\\n   193→\\tif s.Phase == \\\"active_committed\\\" {\\n   194→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   195→\\t\\tlogging.Info(logCtx, \\\"migrating legacy active_committed phase to active\\\",\\n   196→\\t\\t\\tslog.String(\\\"session_id\\\", s.SessionID),\\n   197→\\t\\t)\\n   198→\\t\\ts.Phase = PhaseActive\\n   199→\\t}\\n   200→\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n   201→\\ts.Phase = PhaseFromString(string(s.Phase))\\n   202→\\n   203→\\t// Migrate transcript fields: CheckpointTranscriptStart replaces both\\n   204→\\t// CondensedTranscriptLines and TranscriptLinesAtStart from older state files.\\n   205→\\tif s.CheckpointTranscriptStart == 0 {\\n   206→\\t\\tif s.CondensedTranscriptLines > 0 {\\n   207→\\t\\t\\ts.CheckpointTranscriptStart = s.CondensedTranscriptLines\\n   208→\\t\\t} else if s.TranscriptLinesAtStart > 0 {\\n   209→\\t\\t\\ts.CheckpointTranscriptStart = s.TranscriptLinesAtStart\\n   210→\\t\\t}\\n   211→\\t}\\n   212→\\t// Clear deprecated fields so they aren't re-persisted.\\n   213→\\t// Note: this is a one-way migration. If the state is re-saved, older CLI versions\\n   214→\\t// will see 0 for these fields and fall back to scoping from the transcript start.\\n   215→\\t// This is acceptable since CLI upgrades are monotonic and the worst case is\\n   216→\\t// redundant transcript content in a condensation, not data loss.\\n   217→\\ts.CondensedTranscriptLines = 0\\n   218→\\ts.TranscriptLinesAtStart = 0\\n   219→\\n   220→\\t// Backfill AttributionBaseCommit for sessions created before this field existed.\\n   221→\\t// Without this, a mid-turn commit would migrate BaseCommit and the fallback in\\n   222→\\t// calculateSessionAttributions would use the migrated value, producing zero attribution.\\n   223→\\tif s.AttributionBaseCommit == \\\"\\\" && s.BaseCommit != \\\"\\\" {\\n   224→\\t\\ts.AttributionBaseCommit = s.BaseCommit\\n   225→\\t}\\n   226→}\\n   227→\\n   228→// IsStale returns true when the last time a session saw interaction exceeds StaleSessionThreshold.\\n   229→// If LastInteractionTime isn't set, we don't consider a session stale to avoid aggressively\\n   230→// deleting things.\\n   231→func (s *State) IsStale() bool {\\n   232→\\treturn s.LastInteractionTime != nil && time.Since(*s.LastInteractionTime) > StaleSessionThreshold\\n   233→}\\n   234→\\n   235→// StateStore provides low-level operations for managing session state files.\\n   236→//\\n   237→// StateStore is a primitive for session state persistence. It is NOT the same as\\n   238→// the Sessions interface - it only handles state files in .git/entire-sessions/,\\n   239→// not the full session data which includes checkpoint content.\\n   240→//\\n   241→// Use StateStore directly in strategies for performance-critical state operations.\\n   242→// Use the Sessions interface (when implemented) for high-level session management.\\n   243→type StateStore struct {\\n   244→\\t// stateDir is the directory where session state files are stored\\n   245→\\tstateDir string\\n   246→}\\n   247→\\n   248→// NewStateStore creates a new state store.\\n   249→// Uses the git common dir to store session state (shared across worktrees).\\n   250→func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   251→\\tcommonDir, err := getGitCommonDir(ctx)\\n   252→\\tif err != nil {\\n   253→\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   254→\\t}\\n   255→\\treturn &StateStore{\\n   256→\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   257→\\t}, nil\\n   258→}\\n   259→\\n   260→// NewStateStoreWithDir creates a new state store with a custom directory.\\n   261→// This is useful for testing.\\n   262→func NewStateStoreWithDir(stateDir string) *StateStore {\\n   263→\\treturn &StateStore{stateDir: stateDir}\\n   264→}\\n   265→\\n   266→// Load loads the session state for the given session ID.\\n   267→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   268→// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   269→func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   270→\\t// Validate session ID to prevent path traversal\\n   271→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   272→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   273→\\t}\\n   274→\\n   275→\\tstateFile := s.stateFilePath(sessionID)\\n   276→\\n   277→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is derived from sessionID\\n   278→\\tif os.IsNotExist(err) {\\n   279→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   280→\\t}\\n   281→\\tif err != nil {\\n   282→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   283→\\t}\\n   284→\\n   285→\\tvar state State\\n   286→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   287→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal session state: %w\\\", err)\\n   288→\\t}\\n   289→\\tstate.NormalizeAfterLoad(ctx)\\n   290→\\n   291→\\tif state.IsStale() {\\n   292→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   293→\\t\\tlogging.Debug(logCtx, \\\"deleting stale session state\\\",\\n   294→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   295→\\t\\t)\\n   296→\\t\\t_ = s.Clear(ctx, sessionID) //nolint:errcheck // best-effort cleanup of stale session\\n   297→\\t\\treturn nil, nil             //nolint:nilnil // stale session treated as not found\\n   298→\\t}\\n   299→\\n   300→\\treturn &state, nil\\n   301→}\\n   302→\\n   303→// Save saves the session state atomically.\\n   304→func (s *StateStore) Save(ctx context.Context, state *State) error {\\n   305→\\t_ = ctx // Reserved for future use\\n   306→\\n   307→\\t// Validate session ID to prevent path traversal\\n   308→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n   309→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   310→\\t}\\n   311→\\n   312→\\tif err := os.MkdirAll(s.stateDir, 0o750); err != nil {\\n   313→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   314→\\t}\\n   315→\\n   316→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   317→\\tif err != nil {\\n   318→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   319→\\t}\\n   320→\\n   321→\\tstateFile := s.stateFilePath(state.SessionID)\\n   322→\\n   323→\\t// Atomic write: write to temp file, then rename\\n   324→\\ttmpFile := stateFile + \\\".tmp\\\"\\n   325→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n   326→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   327→\\t}\\n   328→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n   329→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n   330→\\t}\\n   331→\\treturn nil\\n   332→}\\n   333→\\n   334→// Clear removes the session state file for the given session ID.\\n   335→func (s *StateStore) Clear(ctx context.Context, sessionID string) error {\\n   336→\\t_ = ctx // Reserved for future use\\n   337→\\n   338→\\t// Validate session ID to prevent path traversal\\n   339→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   340→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   341→\\t}\\n   342→\\n   343→\\tstateFile := s.stateFilePath(sessionID)\\n   344→\\n   345→\\tif err := os.Remove(stateFile); err != nil {\\n   346→\\t\\tif os.IsNotExist(err) {\\n   347→\\t\\t\\treturn nil // Already gone, not an error\\n   348→\\t\\t}\\n   349→\\t\\treturn fmt.Errorf(\\\"failed to remove session state file: %w\\\", err)\\n   350→\\t}\\n   351→\\treturn nil\\n   352→}\\n   353→\\n   354→// RemoveAll removes the entire session state directory.\\n   355→// This is used during uninstall to completely remove all session state.\\n   356→func (s *StateStore) RemoveAll() error {\\n   357→\\tif err := os.RemoveAll(s.stateDir); err != nil {\\n   358→\\t\\treturn fmt.Errorf(\\\"failed to remove session state directory: %w\\\", err)\\n   359→\\t}\\n   360→\\treturn nil\\n   361→}\\n   362→\\n   363→// List returns all session states.\\n   364→func (s *StateStore) List(ctx context.Context) ([]*State, error) {\\n   365→\\tentries, err := os.ReadDir(s.stateDir)\\n   366→\\tif os.IsNotExist(err) {\\n   367→\\t\\treturn nil, nil\\n   368→\\t}\\n   369→\\tif err != nil {\\n   370→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state directory: %w\\\", err)\\n   371→\\t}\\n   372→\\n   373→\\tvar states []*State\\n   374→\\tfor _, entry := range entries {\\n   375→\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   376→\\t\\t\\tcontinue\\n   377→\\t\\t}\\n   378→\\t\\tif strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   379→\\t\\t\\tcontinue // Skip temp files\\n   380→\\t\\t}\\n   381→\\n   382→\\t\\tsessionID := strings.TrimSuffix(entry.Name(), \\\".json\\\")\\n   383→\\t\\tstate, err := s.Load(ctx, sessionID)\\n   384→\\t\\tif err != nil {\\n   385→\\t\\t\\tcontinue // Skip corrupted state files\\n   386→\\t\\t}\\n   387→\\t\\tif state == nil {\\n   388→\\t\\t\\tcontinue // Not found or stale (Load handles cleanup)\\n   389→\\t\\t}\\n   390→\\n   391→\\t\\tstates = append(states, state)\\n   392→\\t}\\n   393→\\treturn states, nil\\n   394→}\\n   395→\\n   396→// stateFilePath returns the path to a session state file.\\n   397→func (s *StateStore) stateFilePath(sessionID string) string {\\n   398→\\treturn filepath.Join(s.stateDir, sessionID+\\\".json\\\")\\n   399→}\\n   400→\\n   401→// gitCommonDirCache caches the git common dir to avoid repeated subprocess calls.\\n   402→// Keyed by working directory to handle directory changes (same pattern as paths.WorktreeRoot).\\n   403→var (\\n   404→\\tgitCommonDirMu       sync.RWMutex\\n   405→\\tgitCommonDirCache    string\\n   406→\\tgitCommonDirCacheDir string\\n   407→)\\n   408→\\n   409→// ClearGitCommonDirCache clears the cached git common dir.\\n   410→// Useful for testing when changing directories.\\n   411→func ClearGitCommonDirCache() {\\n   412→\\tgitCommonDirMu.Lock()\\n   413→\\tgitCommonDirCache = \\\"\\\"\\n   414→\\tgitCommonDirCacheDir = \\\"\\\"\\n   415→\\tgitCommonDirMu.Unlock()\\n   416→}\\n   417→\\n   418→// getGitCommonDir returns the path to the s