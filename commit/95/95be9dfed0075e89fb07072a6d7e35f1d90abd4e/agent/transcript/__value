453→}\\n   454→\\n   455→// CanRewind checks if rewinding is possible.\\n   456→// For manual-commit strategy, rewind restores files from a checkpoint - uncommitted changes are expected\\n   457→// and will be replaced by the checkpoint contents. Returns true with a warning message showing\\n   458→// what changes will be reverted.\\n   459→func (s *ManualCommitStrategy) CanRewind(ctx context.Context) (bool, string, error) {\\n   460→\\treturn checkCanRewindWithWarning(ctx)\\n   461→}\\n   462→\\n   463→// PreviewRewind returns what will happen if rewinding to the given point.\\n   464→// This allows showing warnings about untracked files that will be deleted.\\n   465→func (s *ManualCommitStrategy) PreviewRewind(ctx context.Context, point RewindPoint) (*RewindPreview, error) {\\n   466→\\t// Logs-only points don't modify the working directory\\n   467→\\tif point.IsLogsOnly {\\n   468→\\t\\treturn &RewindPreview{}, nil\\n   469→\\t}\\n   470→\\n   471→\\trepo, err := OpenRepository(ctx)\\n   472→\\tif err != nil {\\n   473→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   474→\\t}\\n   475→\\n   476→\\t// Get the checkpoint commit\\n   477→\\tcommitHash := plumbing.NewHash(point.ID)\\n   478→\\tcommit, err := repo.CommitObject(commitHash)\\n   479→\\tif err != nil {\\n   480→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   481→\\t}\\n   482→\\n   483→\\ttree, err := commit.Tree()\\n   484→\\tif err != nil {\\n   485→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n   486→\\t}\\n   487→\\n   488→\\t// Load session state to get untracked files that existed at session start\\n   489→\\tsessionID, hasSessionTrailer := trailers.ParseSession(commit.Message)\\n   490→\\tvar preservedUntrackedFiles map[string]bool\\n   491→\\tif hasSessionTrailer {\\n   492→\\t\\tstate, stateErr := s.loadSessionState(ctx, sessionID)\\n   493→\\t\\tif stateErr == nil && state != nil && len(state.UntrackedFilesAtStart