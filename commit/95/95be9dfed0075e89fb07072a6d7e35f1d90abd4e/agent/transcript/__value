pository) bool {\\n    53→\\t_, err := repo.Head()\\n    54→\\treturn errors.Is(err, plumbing.ErrReferenceNotFound)\\n    55→}\\n    56→\\n    57→// EnsureSetup ensures the strategy is properly set up.\\n    58→func EnsureSetup(ctx context.Context) error {\\n    59→\\tif err := EnsureEntireGitignore(ctx); err != nil {\\n    60→\\t\\treturn err\\n    61→\\t}\\n    62→\\n    63→\\t// Ensure the entire/checkpoints/v1 orphan branch exists for permanent session storage\\n    64→\\trepo, err := OpenRepository(ctx)\\n    65→\\tif err != nil {\\n    66→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n    67→\\t}\\n    68→\\tif err := EnsureMetadataBranch(repo); err != nil {\\n    69→\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n    70→\\t}\\n    71→\\n    72→\\t// Install generic hooks (they delegate to strategy at runtime)\\n    73→\\tif !IsGitHookInstalled(ctx) {\\n    74→\\t\\tlocalDev, absoluteHookPath := hookSettingsFromConfig(ctx)\\n    75→\\t\\tif _, err := InstallGitHook(ctx, true, localDev, absoluteHookPath); err != nil {\\n    76→\\t\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n    77→\\t\\t}\\n    78→\\t}\\n    79→\\treturn nil\\n    80→}\\n    81→\\n    82→// IsAncestorOf checks if commit is an ancestor of (or equal to) target.\\n    83→// Returns true if target can reach commit by following parent links.\\n    84→// Limits search to MaxCommitTraversalDepth commits to avoid excessive traversal.\\n    85→func IsAncestorOf(ctx context.Context, repo *git.Repository, commit, target plumbing.Hash) bool {\\n    86→\\tif commit == target {\\n    87→\\t\\treturn true\\n    88→\\t}\\n    89→\\n    90→\\titer, err := repo.Log(&git.LogOptions{From: target})\\n    91→\\tif err != nil {\\n    92→\\t\\treturn false\\n    93→\\t}\\n    94→\\tdefer iter.Close()\\n    95→\\n    96→\\tfound := false\\n    97→\\tcount := 0\\n    98→\\t_ = iter.ForEach(func(c *object.Commit) error { //nolint:errcheck // Best-effort search, errors are non-fatal\\n    99→\\t\\tif err := ctx.Err(); err != nil {\\n   100→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   101→\\t\\t}\\n   102→\\t\\tcount++\\n   103→\\t\\tif count > MaxCommitTraversalDepth {\\n   104→\\t\\t\\treturn errStop\\n   105→\\t\\t}\\n   106→\\t\\tif c.Hash == commit {\\n   107→\\t\\t\\tfound = true\\n   108→\\t\\t\\treturn errStop\\n   109→\\t\\t}\\n   110→\\t\\treturn nil\\n   111→\\t})\\n   112→\\n   113→\\treturn found\\n   114→}\\n   115→\\n   116→// ListCheckpoints returns all checkpoints from the entire/checkpoints/v1 branch.\\n   117→// Scans sharded paths: <id[:2]>/<id[2:]>/ directories containing metadata.json.\\n   118→func ListCheckpoints(ctx context.Context) ([]CheckpointInfo, error) {\\n   119→\\trepo, err := OpenRepository(ctx)\\n   120→\\tif err != nil {\\n   121→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   122→\\t}\\n   123→\\n   124→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   125→\\tref, err := repo.Reference(refName, true)\\n   126→\\tif err != nil {\\n   127→\\t\\t//nolint:nilerr // No sessions branch yet is expected, return empty list\\n   128→\\t\\treturn []CheckpointInfo{}, nil\\n   129→\\t}\\n   130→\\n   131→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   132→\\tif err != nil {\\n   133→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   134→\\t}\\n   135→\\n   136→\\ttree, err := commit.Tree()\\n   137→\\tif err != nil {\\n   138→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   139→\\t}\\n   140→\\n   141→\\tvar checkpoints []CheckpointInfo\\n   142→\\n   143→\\t// Scan sharded structure: <2-char-prefix>/<remaining-id>/metadata.json\\n   144→\\t// The tree has 2-character directories (hex buckets)\\n   145→\\tfor _, bucketEntry := range tree.Entries {\\n   146→\\t\\tif bucketEntry.Mode != filemode.Dir {\\n   147→\\t\\t\\tcontinue\\n   148→\\t\\t}\\n   149→\\t\\t// Bucket should be 2 hex chars\\n   150→\\t\\tif len(bucketEntry.Name) != 2 {\\n   151→\\t\\t\\tcontinue\\n   152→\\t\\t}\\n   153→\\n   154→\\t\\tbucketTree, treeErr := repo.TreeObject(bucketEntry.Hash)\\n   155→\\t\\tif treeErr != nil {\\n   156→\\t\\t\\tcontinue\\n   157→\\t\\t}\\n   158→\\n   159→\\t\\t// Each entry in the bucket is the remaining part of the checkpoint ID\\n   160→\\t\\tfor _, checkpointEntry := range bucketTree.Entries {\\n   161→\\t\\t\\tif checkpointEntry.Mode != filemode.Dir {\\n   162→\\t\\t\\t\\tcontinue\\n   163→\\t\\t\\t}\\n   164→\\n   165→\\t\\t\\tcheckpointTree, cpTreeErr := repo.TreeObject(checkpointEntry.Hash)\\n   166→\\t\\t\\tif cpTreeErr != nil {\\n   167→\\t\\t\\t\\tcontinue\\n   168→\\t\\t\\t}\\n   169→\\n   170→\\t\\t\\t// Reconstruct checkpoint ID: <bucket><remaining>\\n   171→\\t\\t\\tcheckpointIDStr := bucketEntry.Name + checkpointEntry.Name\\n   172→\\t\\t\\tcheckpointID, cpErr := id.NewCheckpointID(checkpointIDStr)\\n   173→\\t\\t\\tif cpErr != nil {\\n   174→\\t\\t\\t\\t// Skip invalid checkpoint IDs\\n   175→\\t\\t\\t\\tcontinue\\n   176→\\t\\t\\t}\\n   177→\\n   178→\\t\\t\\tinfo := CheckpointInfo{\\n   179→\\t\\t\\t\\tCheckpointID: checkpointID,\\n   180→\\t\\t\\t}\\n   181→\\n   182→\\t\\t\\t// Get details from metadata file (CheckpointSummary format)\\n   183→\\t\\t\\tif metadataFile, fileErr := checkpointTree.File(paths.MetadataFileName); fileErr == nil {\\n   184→\\t\\t\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n   185→\\t\\t\\t\\t\\tvar summary checkpoint.CheckpointSummary\\n   186→\\t\\t\\t\\t\\tif json.Unmarshal([]byte(content), &summary) == nil && len(summary.Sessions) > 0 {\\n   187→\\t\\t\\t\\t\\t\\tinfo.CheckpointsCount = summary.CheckpointsCount\\n   188→\\t\\t\\t\\t\\t\\tinfo.FilesTouched = summary.FilesTouched\\n   189→\\t\\t\\t\\t\\t\\tinfo.SessionCount = len(summary.Sessions)\\n   190→\\n   191→\\t\\t\\t\\t\\t\\t// Read session-level metadata for Agent, SessionID, CreatedAt, SessionIDs\\n   192→\\t\\t\\t\\t\\t\\tfor i, sessionPaths := range summary.Sessions {\\n   193→\\t\\t\\t\\t\\t\\t\\tif sessionPaths.Metadata != \\\"\\\" {\\n   194→\\t\\t\\t\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n   195→\\t\\t\\t\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n   196→\\t\\t\\t\\t\\t\\t\\t\\tsessionMetadataPath := strings.TrimPrefix(sessionPaths.Metadata, \\\"/\\\")\\n   197→\\t\\t\\t\\t\\t\\t\\t\\tif sessionFile, sErr := tree.File(sessionMetadataPath); sErr == nil {\\n   198→\\t\\t\\t\\t\\t\\t\\t\\t\\tif sessionContent, scErr := sessionFile.Contents(); scErr == nil {\\n   199→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata checkpoint.CommittedMetadata\\n   200→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   201→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionIDs = append(info.SessionIDs, sessionMetadata.SessionID)\\n   202→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t// Use first session's metadata for Agent, SessionID, CreatedAt\\n   203→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif i == 0 {\\n   204→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   205→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   206→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   207→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.IsTask = sessionMetadata.IsTask\\n   208→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.ToolUseID = sessionMetadata.ToolUseID\\n   209→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   210→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   211→\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   212→\\t\\t\\t\\t\\t\\t\\t\\t}\\n   213→\\t\\t\\t\\t\\t\\t\\t}\\n   214→\\t\\t\\t\\t\\t\\t}\\n   215→\\t\\t\\t\\t\\t}\\n   216→\\t\\t\\t\\t}\\n   217→\\t\\t\\t}\\n   218→\\n   219→\\t\\t\\tcheckpoints = append(checkpoints, info)\\n   220→\\t\\t}\\n   221→\\t}\\n   222→\\n   223→\\t// Sort by time (most recent first)\\n   224→\\tsort.Slice(checkpoints, func(i, j int) bool {\\n   225→\\t\\treturn checkpoints[i].CreatedAt.After(checkpoints[j].CreatedAt)\\n   226→\\t})\\n   227→\\n   228→\\treturn checkpoints, nil\\n   229→}\\n   230→\\n   231→const (\\n   232→\\tentireGitignore    = \\\".entire/.gitignore\\\"\\n   233→\\tentireDir          = \\\".entire\\\"\\n   234→\\tgitDir             = \\\".git\\\"\\n   235→\\tshadowBranchPrefix = \\\"entire/\\\"\\n   236→)\\n   237→\\n   238→// isProtectedPath returns true if relPath is inside a directory that should\\n   239→// never be modified or deleted during rewind or other destructive operations.\\n   240→// Protected directories include git internals, entire metadata, and all\\n   241→// registered agent config directories.\\n   242→func isProtectedPath(relPath string) bool {\\n   243→\\tfor _, dir := range protectedDirs() {\\n   244→\\t\\tif relPath == dir || strings.HasPrefix(relPath, dir+string(filepath.Separator)) {\\n   245→\\t\\t\\treturn true\\n   246→\\t\\t}\\n   247→\\t}\\n   248→\\treturn false\\n   249→}\\n   250→\\n   251→// protectedDirs returns the list of directories to protect. This combines\\n   252→// static infrastructure dirs with agent-reported dirs from the registry.\\n   253→// The result is cached via sync.Once since it's called per-file when filtering untracked files.\\n   254→//\\n   255→// NOTE: The cache is never invalidated. In production this is fine (the agent registry\\n   256→// is populated at init time and never changes). However, tests that mutate the agent\\n   257→// registry after the first call to protectedDirs/isProtectedPath will see stale results.\\n   258→// If you need to test isProtectedPath with a custom registry, either:\\n   259→//   - run those tests in a separate process, or\\n   260→//   - call resetProtectedDirsForTest() to clear the cache.\\n   261→func protectedDirs() []string {\\n   262→\\tprotectedDirsOnce.Do(func() {\\n   263→\\t\\tprotectedDirsCache = append([]string{gitDir, entireDir}, agent.AllProtectedDirs()...)\\n   264→\\t})\\n   265→\\treturn protectedDirsCache\\n   266→}\\n   267→\\n   268→var (\\n   269→\\tprotectedDirsOnce  sync.Once\\n   270→\\tprotectedDirsCache []string\\n   271→)\\n   272→\\n   273→// resolveAgentType picks the best agent type from the context and existing state.\\n   274→// Priority: existing state > context value.\\n   275→func resolveAgentType(ctxAgentType types.AgentType, state *SessionState) types.AgentType {\\n   276→\\tif state != nil && state.AgentType != \\\"\\\" {\\n   277→\\t\\treturn state.AgentType\\n   278→\\t}\\n   279→\\treturn ctxAgentType\\n   280→}\\n   281→\\n   282→// EnsureMetadataBranch creates the local entire/checkpoints/v1 branch if it doesn't exist.\\n   283→// If the remote-tracking branch (origin/entire/checkpoints/v1) exists, creates the local\\n   284→// branch from it to preserve existing checkpoint data. Otherwise creates an empty orphan.\\n   285→func EnsureMetadataBranch(repo *git.Repository) error {\\n   286→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   287→\\n   288→\\t// Check if local branch already exists\\n   289→\\t_, err := repo.Reference(refName, true)\\n   290→\\tif err == nil {\\n   291→\\t\\treturn nil\\n   292→\\t}\\n   293→\\tif !errors.Is(err, plumbing.ErrReferenceNotFound) {\\n   294→\\t\\treturn fmt.Errorf(\\\"failed to check metadata branch: %w\\\", err)\\n   295→\\t}\\n   296→\\n   297→\\t// Local branch doesn't exist — create from remote if available\\n   298→\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n   299→\\tremoteRef, remoteErr := repo.Reference(remoteRefName, true)\\n   300→\\tif remoteErr != nil && !errors.Is(remoteErr, plumbing.ErrReferenceNotFound) {\\n   301→\\t\\treturn fmt.Errorf(\\\"failed to check remote metadata branch: %w\\\", remoteErr)\\n   302→\\t}\\n   303→\\tif remoteErr == nil {\\n   304→\\t\\tref := plumbing.NewHashReference(refName, remoteRef.Hash())\\n   305→\\t\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   306→\\t\\t\\treturn fmt.Errorf(\\\"failed to create metadata branch from remote: %w\\\", err)\\n   307→\\t\\t}\\n   308→\\t\\tfmt.Fprintf(os.Stderr, \\\"✓ Created local branch '%s' from origin\\\\n\\\", paths.MetadataBranchName)\\n   309→\\t\\treturn nil\\n   310→\\t}\\n   311→\\n   312→\\t// No local or remote branch — create empty orphan\\n   313→\\temptyTree := &object.Tree{Entries: []object.TreeEntry{}}\\n   314→\\tobj := repo.Storer.NewEncodedObject()\\n   315→\\tif err := emptyTree.Encode(obj); err != nil {\\n   316→\\t\\treturn fmt.Errorf(\\\"failed to encode empty tree: %w\\\", err)\\n   317→\\t}\\n   318→\\temptyTreeHash, err := repo.Storer.SetEncodedObject(obj)\\n   319→\\tif err != nil {\\n   320→\\t\\treturn fmt.Errorf(\\\"failed to store empty tree: %w\\\", err)\\n   321→\\t}\\n   322→\\n   323→\\t// Create orphan commit (no parent)\\n   324→\\tnow := time.Now()\\n   325→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   326→\\tsig := object.Signature{\\n   327→\\t\\tName:  authorName,\\n   328→\\t\\tEmail: authorEmail,\\n   329→\\t\\tWhen:  now,\\n   330→\\t}\\n   331→\\n   332→\\tcommit := &object.Commit{\\n   333→\\t\\tTreeHash:  emptyTreeHash,\\n   334→\\t\\tAuthor:    sig,\\n   335→\\t\\tCommitter: sig,\\n   336→\\t\\tMessage:   \\\"Initialize metadata branch\\\\n\\\\nThis branch stores session metadata.\\\\n\\\",\\n   337→\\t}\\n   338→\\t// Note: No ParentHashes - this is an orphan commit\\n   339→\\n   340→\\tcommitObj := repo.Storer.NewEncodedObject()\\n   341→\\tif err := commit.Encode(commitObj); err != nil {\\n   342→\\t\\treturn fmt.Errorf(\\\"failed to encode orphan commit: %w\\\", err)\\n   343→\\t}\\n   344→\\tcommitHash, err := repo.Storer.SetEncodedObject(commitObj)\\n   345→\\tif err != nil {\\n   346→\\t\\treturn fmt.Errorf(\\\"failed to store orphan commit: %w\\\", err)