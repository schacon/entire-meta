n    89→\\t\\treturn fmt.Errorf(\\\"failed to check for uncommitted changes: %w\\\", err)\\n    90→\\t}\\n    91→\\tif !canRewind {\\n    92→\\t\\tfmt.Println(changeMsg)\\n    93→\\t\\treturn nil\\n    94→\\t}\\n    95→\\n    96→\\t// Get rewind points from strategy\\n    97→\\tpoints, err := start.GetRewindPoints(ctx, 20)\\n    98→\\tif err != nil {\\n    99→\\t\\treturn fmt.Errorf(\\\"failed to find rewind points: %w\\\", err)\\n   100→\\t}\\n   101→\\n   102→\\tif len(points) == 0 {\\n   103→\\t\\tfmt.Println(\\\"No rewind points found.\\\")\\n   104→\\t\\tfmt.Println(\\\"Rewind points are created automatically when agent sessions end.\\\")\\n   105→\\t\\treturn nil\\n   106→\\t}\\n   107→\\n   108→\\t// Check if there are multiple sessions (to show session identifier)\\n   109→\\tsessionIDs := make(map[string]bool)\\n   110→\\tfor _, p := range points {\\n   111→\\t\\tif p.SessionID != \\\"\\\" {\\n   112→\\t\\t\\tsessionIDs[p.SessionID] = true\\n   113→\\t\\t}\\n   114→\\t}\\n   115→\\thasMultipleSessions := len(sessionIDs) > 1\\n   116→\\n   117→\\t// Build options for the select menu\\n   118→\\toptions := make([]huh.Option[string], 0, len(points)+1)\\n   119→\\tfor _, p := range points {\\n   120→\\t\\tvar label string\\n   121→\\t\\ttimestamp := p.Date.Format(\\\"2006-01-02 15:04\\\")\\n   122→\\n   123→\\t\\t// Build session identifier for display when multiple sessions exist\\n   124→\\t\\tsessionLabel := \\\"\\\"\\n   125→\\t\\tif hasMultipleSessions && p.SessionPrompt != \\\"\\\" {\\n   126→\\t\\t\\t// Show truncated prompt to identify the session\\n   127→\\t\\t\\tsessionLabel = fmt.Sprintf(\\\" [%s]\\\", sanitizeForTerminal(p.SessionPrompt))\\n   128→\\t\\t}\\n   129→\\n   130→\\t\\tswitch {\\n   131→\\t\\tcase p.IsLogsOnly:\\n   132→\\t\\t\\t// Committed checkpoint - show commit sha (this is the real user commit)\\n   133→\\t\\t\\tshortID := p.ID\\n   134→\\t\\t\\tif len(shortID) >= 7 {\\n   135→\\t\\t\\t\\tshortID = shortID[:7]\\n   136→\\t\\t\\t}\\n   137→\\t\\t\\tlabel = fmt.Sprintf(\\\"%s (%s) %s%s\\\", shortID, timestamp, sanitizeForTerminal(p.Message), sessionLabel)\\n   138→\\t\\tcase p.IsTaskCheckpoint:\\n   139→\\t\\t\\t// Task checkpoint (uncommitted) - no sha shown\\n   140→\\t\\t\\tlabel = fmt.Sprintf(\\\"        (%s) [Task] %s%s\\\", timestamp, sanitizeForTerminal(p.Message), sessionLabel)\\n   141→\\t\\tdefault:\\n   142→\\t\\t\\t// Shadow checkpoint (uncommitted) - no sha shown (internal commit)\\n   143→\\t\\t\\tlabel = fmt.Sprintf(\\\"        (%s) %s%s\\\", timestamp, sanitizeForTerminal(p.Message), sessionLabel)\\n   144→\\t\\t}\\n   145→\\t\\toptions = append(options, huh.NewOption(label, p.ID))\\n   146→\\t}\\n   147→\\toptions = append(options, huh.NewOption(\\\"Cancel\\\", \\\"cancel\\\"))\\n   148→\\n   149→\\tvar selectedID string\\n   150→\\tform := NewAccessibleForm(\\n   151→\\t\\thuh.NewGroup(\\n   152→\\t\\t\\thuh.NewSelect[string]().\\n   153→\\t\\t\\t\\tTitle(\\\"Select a checkpoint to restore\\\").\\n   154→\\t\\t\\t\\tDescription(\\\"Your working directory will be restored to this checkpoint's state\\\").\\n   155→\\t\\t\\t\\tOptions(options...).\\n   156→\\t\\t\\t\\tValue(&selectedID),\\n   157→\\t\\t),\\n   158→\\t)\\n   159→\\n   160→\\tif err := form.Run(); err != nil {\\n   161→\\t\\treturn fmt.Errorf(\\\"selection cancelled: %w\\\", err)\\n   162→\\t}\\n   163→\\n   164→\\tif selectedID == \\\"cancel\\\" {\\n   165→\\t\\tfmt.Println(\\\"Rewind cancelled.\\\")\\n   166→\\t\\treturn nil\\n   167→\\t}\\n   168→\\n   169→\\t// Find the selected point\\n   170→\\tvar selectedPoint *strategy.RewindPoint\\n   171→\\tfor _, p := range points {\\n   172→\\t\\tif p.ID == selectedID {\\n   173→\\t\\t\\tpointCopy := p\\n   174→\\t\\t\\tselectedPoint = &pointCopy\\n   175→\\t\\t\\tbreak\\n   176→\\t\\t}\\n   177→\\t}\\n   178→\\n   179→\\tif selectedPoint == nil {\\n   180→\\t\\treturn errors.New(\\\"rewind point not found\\\")\\n   181→\\t}\\n   182→\\n   183→\\tshortID := selectedPoint.ID\\n   184→\\tif len(shortID) > 7 {\\n   185→\\t\\tshortID = shortID[:7]\\n   186→\\t}\\n   187→\\n   188→\\t// Show what was selected\\n   189→\\tswitch {\\n   190→\\tcase selectedPoint.IsLogsOnly:\\n   191→\\t\\t// Committed checkpoint - show sha\\n   192→\\t\\tfmt.Printf(\\\"\\\\nSelected: %s %s\\\\n\\\", shortID, sanitizeForTerminal(selectedPoint.Message))\\n   193→\\tcase selectedPoint.IsTaskCheckpoint:\\n   194→\\t\\t// Task checkpoint - no sha\\n   195→\\t\\tfmt.Printf(\\\"\\\\nSelected: [Task] %s\\\\n\\\", sanitizeForTerminal(selectedPoint.Message))\\n   196→\\tdefault:\\n   197→\\t\\t// Shadow checkpoint - no sha\\n   198→\\t\\tfmt.Printf(\\\"\\\\nSelected: %s\\\\n\\\", sanitizeForTerminal(selectedPoint.Message))\\n   199→\\t}\\n   200→\\n   201→\\t// Handle logs-only points with a sub-choice menu\\n   202→\\tif selectedPoint.IsLogsOnly {\\n   203→\\t\\treturn handleLogsOnlyRewindInteractive(ctx, start, *selectedPoint, shortID)\\n   204→\\t}\\n   205→\\n   206→\\t// Preview rewind to show warnings about files that will be deleted\\n   207→\\tpreview, previewErr := start.PreviewRewind(ctx, *selectedPoint)\\n   208→\\tif previewErr == nil && preview != nil && len(preview.FilesToDelete) > 0 {\\n   209→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nWarning: The following untracked files will be DELETED:\\\\n\\\")\\n   210→\\t\\tfor _, f := range preview.FilesToDelete {\\n   211→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  - %s\\\\n\\\", f)\\n   212→\\t\\t}\\n   213→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\n\\\")\\n   214→\\t}\\n   215→\\n   216→\\t// Confirm rewind\\n   217→\\tvar confirm bool\\n   218→\\tdescription := fmt.Sprintf(\\\"This will reset to: %s\\\\nChanges after this point may be lost!\\\", selectedPoint.Message)\\n   219→\\tconfirmForm := NewAccessibleForm(\\n   220→\\t\\thuh.NewGroup(\\n   221→\\t\\t\\thuh.NewConfirm().\\n   222→\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Reset to %s?\\\", shortID)).\\n   223→\\t\\t\\t\\tDescription(description).\\n   224→\\t\\t\\t\\tValue(&confirm),\\n   225→\\t\\t),\\n   226→\\t)\\n   227→\\n   228→\\tif err := confirmForm.Run(); err != nil {\\n   229→\\t\\treturn fmt.Errorf(\\\"confirmation cancelled: %w\\\", err)\\n   230→\\t}\\n   231→\\n   232→\\tif !confirm {\\n   233→\\t\\tfmt.Println(\\\"Rewind cancelled.\\\")\\n   234→\\t\\treturn nil\\n   235→\\t}\\n   236→\\n   237→\\t// Resolve agent once for use throughout\\n   238→\\tagent, err := getAgent(selectedPoint.Agent)\\n   239→\\tif err != nil {\\n   240→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   241→\\t}\\n   242→\\n   243→\\t// Initialize logging context with agent from checkpoint\\n   244→\\tlogCtx := logging.WithComponent(ctx, \\\"rewind\\\")\\n   245→\\tlogCtx = logging.WithAgent(logCtx, agent.Name())\\n   246→\\n   247→\\tlogging.Debug(logCtx, \\\"rewind started\\\",\\n   248→\\t\\tslog.String(\\\"checkpoint_id\\\", selectedPoint.ID),\\n   249→\\t\\tslog.String(\\\"session_id\\\", selectedPoint.SessionID),\\n   250→\\t\\tslog.Bool(\\\"is_task_checkpoint\\\", selectedPoint.IsTaskCheckpoint),\\n   251→\\t)\\n   252→\\n   253→\\t// Perform the rewind using strategy\\n   254→\\tif err := start.Rewind(ctx, *selectedPoint); err != nil {\\n   255→\\t\\tlogging.Error(logCtx, \\\"rewind failed\\\",\\n   256→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", selectedPoint.ID),\\n   257→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   258→\\t\\t)\\n   259→\\t\\treturn err //nolint:wrapcheck // already present in codebase\\n   260→\\t}\\n   261→\\n   262→\\tlogging.Debug(logCtx, \\\"rewind completed\\\",\\n   263→\\t\\tslog.String(\\\"checkpoint_id\\\", selectedPoint.ID),\\n   264→\\t)\\n   265→\\n   266→\\t// Handle transcript restoration differently for task checkpoints\\n   267→\\tvar sessionID string\\n   268→\\tvar transcriptFile string\\n   269→\\n   270→\\tif selectedPoint.IsTaskCheckpoint {\\n   271→\\t\\t// For task checkpoint: read checkpoint.json to get UUID and truncate transcript\\n   272→\\t\\tcheckpoint, err :