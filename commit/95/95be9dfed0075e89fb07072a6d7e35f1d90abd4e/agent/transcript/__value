\n   765→// SessionRestoreStatus represents the status of a session being restored.\\n   766→type SessionRestoreStatus int\\n   767→\\n   768→const (\\n   769→\\tStatusNew             SessionRestoreStatus = iota // Local file doesn't exist\\n   770→\\tStatusUnchanged                                   // Local and checkpoint are the same\\n   771→\\tStatusCheckpointNewer                             // Checkpoint has newer entries\\n   772→\\tStatusLocalNewer                                  // Local has newer entries (conflict)\\n   773→)\\n   774→\\n   775→// SessionRestoreInfo contains information about a session being restored.\\n   776→type SessionRestoreInfo struct {\\n   777→\\tSessionID      string\\n   778→\\tPrompt         string               // First prompt preview for display\\n   779→\\tStatus         SessionRestoreStatus // Status of this session\\n   780→\\tLocalTime      time.Time\\n   781→\\tCheckpointTime time.Time\\n   782→}\\n   783→\\n   784→// classifySessionsForRestore checks all sessions in a checkpoint and returns info\\n   785→// about each session, including whether local logs have newer timestamps.\\n   786→// repoRoot is used to compute per-session agent directories.\\n   787→// Sessions without agent metadata are skipped (cannot determine target directory).\\n   788→func (s *ManualCommitStrategy) classifySessionsForRestore(ctx context.Context, repoRoot string, store cpkg.Store, checkpointID id.CheckpointID, summary *cpkg.CheckpointSummary) []SessionRestoreInfo {\\n   789→\\tvar sessions []SessionRestoreInfo\\n   790→\\n   791→\\ttotalSessions := len(summary.Sessions)\\n   792→\\t// Check all sessions (0-based indexing)\\n   793→\\tfor i := range totalSessions {\\n   794→\\t\\tcontent, err := store.ReadSessionContent(ctx, checkpointID, i)\\n   795→\\t\\tif err != nil || content == nil || len(content.Transcript) == 0 {\\n   796→\\t\\t\\tcontinue\\n   797→\\t\\t}\\n   798→\\n   799→\\t\\tsessionID := content.Metadata.SessionID\\n   800→\\t\