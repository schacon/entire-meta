tadataTaskTrailerKey, taskMetadataDir)\\n   199→}\\n   200→\\n   201→// FormatTaskMetadataWithStrategy creates a commit message with task metadata and strategy trailers.\\n   202→func FormatTaskMetadataWithStrategy(message, taskMetadataDir, strategy string) string {\\n   203→\\treturn fmt.Sprintf(\\\"%s\\\\n\\\\n%s: %s\\\\n%s: %s\\\\n\\\", message, MetadataTaskTrailerKey, taskMetadataDir, StrategyTrailerKey, strategy)\\n   204→}\\n   205→\\n   206→// FormatSourceRef creates a formatted source ref string for the trailer.\\n   207→// Format: \\\"<branch>@<commit-hash-prefix>\\\" (hash truncated to ShortIDLength chars)\\n   208→func FormatSourceRef(branch, commitHash string) string {\\n   209→\\tshortHash := commitHash\\n   210→\\tif len(shortHash) > checkpointID.ShortIDLength {\\n   211→\\t\\tshortHash = shortHash[:checkpointID.ShortIDLength]\\n   212→\\t}\\n   213→\\treturn fmt.Sprintf(\\\"%s@%s\\\", branch, shortHash)\\n   214→}\\n   215→\\n   216→// FormatMetadata creates a commit message with metadata trailer.\\n   217→func FormatMetadata(message, metadataDir string) string {\\n   218→\\treturn fmt.Sprintf(\\\"%s\\\\n\\\\n%s: %s\\\\n\\\", message, MetadataTrailerKey, metadataDir)\\n   219→}\\n   220→\\n   221→// FormatMetadataWithStrategy creates a commit message with metadata and strategy trailers.\\n   222→func FormatMetadataWithStrategy(message, metadataDir, strategy string) string {\\n   223→\\treturn fmt.Sprintf(\\\"%s\\\\n\\\\n%s: %s\\\\n%s: %s\\\\n\\\", message, MetadataTrailerKey, metadataDir, StrategyTrailerKey, strategy)\\n   224→}\\n   225→\\n   226→// FormatShadowCommit creates a commit message for manual-commit strategy checkpoints.\\n   227→// Includes Entire-Metadata, Entire-Session, and Entire-Strategy trailers.\\n   228→func FormatShadowCommit(message, metadataDir, sessionID string) string {\\n   229→\\tvar sb strings.Builder\\n   230→\\tsb.WriteString(message)\\n   231→\\tsb.WriteString(\\\"\\\\n\\\\n\\\")\\n   232→\\tfmt.Fprintf(&sb, \\\"%s: %s\