l) {\\n\\t// Filter to IDs that have metadata\\n\\tvar validIDs []id.CheckpointID\\n\\tfor _, cpID := range cpIDs {\\n\\t\\tif _, ok := infoMap[cpID]; ok {\\n\\t\\t\\tvalidIDs = append(validIDs, cpID)\\n\\t\\t}\\n\\t}\\n\\tif len(validIDs) == 0 {\\n\\t\\treturn id.EmptyCheckpointID, CheckpointInfo{}, false\\n\\t}\\n\\tif len(validIDs) == 1 {\\n\\t\\tinfo := infoMap[validIDs[0]]\\n\\t\\treturn validIDs[0], info, true\\n\\t}\\n\\n\\t// Multiple checkpoints: resolve by CreatedAt using metadata tree\\n\\tif metadataTree != nil {\\n\\t\\tsorted := CollectCheckpointsByAge(metadataTree, validIDs)\\n\\t\\tif len(sorted) > 0 {\\n\\t\\t\\tlatest := sorted[len(sorted)-1]\\n\\t\\t\\t// Return the info from our map (enriched with all fields from listCheckpoints)\\n\\t\\t\\tif info, ok := infoMap[latest.CheckpointID]; ok {\\n\\t\\t\\t\\treturn latest.CheckpointID, info, true\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Fallback: use the info map's CreatedAt for ordering\\n\\tinfo := infoMap[validIDs[0]]\\n\\tfor _, cpID := range validIDs[1:] {\\n\\t\\tif candidate := infoMap[cpID]; candidate.CreatedAt.After(info.CreatedAt) {\\n\\t\\t\\tinfo = candidate\\n\\t\\t}\\n\\t}\\n\\treturn info.CheckpointID, info, true\\n}\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":\"tool_use\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":644,\"cache_read_input_tokens\":99729,\"output_tokens\":1302,\"server_tool_use\":{\"web_search_requests\":0,\"web_fetch_requests\":0},\"service_tier\":\"standard\",\"cache_creation\":{\"ephemeral_1h_input_tokens\":644,\"ephemeral_5m_input_tokens\":0},\"inference_geo\":\"\",\"iterations\":[],\"speed\":\"standard\"}},\"requestId\":\"req_011CYizeJfYDyniNYbM8eMNc\",\"type\":\"assistant\",\"uuid\":\"d1dea2fc-2900-4fbc-903a-11772b1a7c77\",\"timestamp\":\"2026-03-05T00:34:45.680Z\"}\n{\"parentUuid\":\"d1dea2fc-2900-4fbc-903a-11772b1a7c77\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/pfleidi/entire/cli/.worktree