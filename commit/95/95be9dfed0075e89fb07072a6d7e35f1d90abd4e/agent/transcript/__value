oint.ID) == 40 {\\n   515→\\t\\t// Try shadow branch for uncommitted checkpoints (ID is a 40-char commit hash)\\n   516→\\t\\tif returnedSessionID, err := restoreSessionTranscriptFromShadow(ctx, selectedPoint.ID, selectedPoint.MetadataDir, sessionID, agent); err == nil {\\n   517→\\t\\t\\tsessionID = returnedSessionID\\n   518→\\t\\t\\trestored = true\\n   519→\\t\\t}\\n   520→\\t}\\n   521→\\n   522→\\tif !restored {\\n   523→\\t\\t// Fall back to local file\\n   524→\\t\\tif err := restoreSessionTranscript(ctx, transcriptFile, sessionID, agent); err != nil {\\n   525→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to restore session transcript: %v\\\\n\\\", err)\\n   526→\\t\\t}\\n   527→\\t}\\n   528→\\n   529→\\tfmt.Printf(\\\"Rewound to %s. %s\\\\n\\\", selectedPoint.ID[:7], agent.FormatResumeCommand(sessionID))\\n   530→\\treturn nil\\n   531→}\\n   532→\\n   533→// handleLogsOnlyRewindNonInteractive handles logs-only rewind in non-interactive mode.\\n   534→// Defaults to restoring logs only (no checkout) for safety.\\n   535→func handleLogsOnlyRewindNonInteractive(ctx context.Context, start *strategy.ManualCommitStrategy, point strategy.RewindPoint) error {\\n   536→\\t// Resolve agent once for use throughout\\n   537→\\tagent, err := getAgent(point.Agent)\\n   538→\\tif err != nil {\\n   539→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   540→\\t}\\n   541→\\n   542→\\t// Initialize logging context with agent from checkpoint\\n   543→\\tlogCtx := logging.WithComponent(ctx, \\\"rewind\\\")\\n   544→\\tlogCtx = logging.WithAgent(logCtx, agent.Name())\\n   545→\\n   546→\\tlogging.Debug(logCtx, \\\"logs-only rewind started\\\",\\n   547→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   548→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   549→\\t)\\n   550→\\n   551→\\tsessions, err := start.RestoreLogsOnly(ctx, point, true) // force=true for explicit rewind\\n   552→\\tif err != nil {\\n   553→\\t\\tlogging.Error(logCtx, \\\"logs-only rewind failed\\\",\\n   554→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   555→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   556→\\t\\t)\\n   557→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   558→\\t}\\n   559→\\n   560→\\tlogging.Debug(logCtx, \\\"logs-only rewind completed\\\",\\n   561→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   562→\\t)\\n   563→\\n   564→\\t// Show resume commands for all sessions\\n   565→\\tprintMultiSessionResumeCommands(sessions)\\n   566→\\n   567→\\tfmt.Println(\\\"Note: Working directory unchanged. Use interactive mode for full checkout.\\\")\\n   568→\\treturn nil\\n   569→}\\n   570→\\n   571→// handleLogsOnlyResetNonInteractive handles reset in non-interactive mode.\\n   572→// This performs a git reset --hard to the target commit.\\n   573→func handleLogsOnlyResetNonInteractive(ctx context.Context, start *strategy.ManualCommitStrategy, point strategy.RewindPoint) error {\\n   574→\\t// Resolve agent once for use throughout\\n   575→\\tagent, err := getAgent(point.Agent)\\n   576→\\tif err != nil {\\n   577→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   578→\\t}\\n   579→\\n   580→\\t// Initialize logging context with agent from checkpoint\\n   581→\\tlogCtx := logging.WithComponent(ctx, \\\"rewind\\\")\\n   582→\\tlogCtx = logging.WithAgent(logCtx, agent.Name())\\n   583→\\n   584→\\tlogging.Debug(logCtx, \\\"logs-only reset started\\\",\\n   585→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   586→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   587→\\t)\\n   588→\\n   589→\\t// Get current HEAD before reset (for recovery message)\\n   590→\\tcurrentHead, headErr := getCurrentHeadHash(ctx)\\n   591→\\tif headErr != nil {\\n   592→\\t\\tcurrentHead = \\\"\\\"\\n   593→\\t}\\n   594→\\n   595→\\t// Restore logs first\\n   596→\\tsessions, err := start.RestoreLogsOnly(ctx, point, true) // force=true for explicit rewind\\n   597→\\tif err != nil {\\n   598→\\t\\tlogging.Error(logCtx, \\\"logs-only reset failed during log restoration\\\",\\n   599→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   600→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   601→\\t\\t)\\n   602→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   603→\\t}\\n   604→\\n   605→\\t// Perform git reset --hard\\n   606→\\tif err := performGitResetHard(ctx, point.ID); err != nil {\\n   607→\\t\\tlogging.Error(logCtx, \\\"logs-only reset failed during git reset\\\",\\n   608→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   609→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   610→\\t\\t)\\n   611→\\t\\treturn fmt.Errorf(\\\"failed to reset branch: %w\\\", err)\\n   612→\\t}\\n   613→\\n   614→\\tlogging.Debug(logCtx, \\\"logs-only reset completed\\\",\\n   615→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   616→\\t)\\n   617→\\n   618→\\tshortID := point.ID\\n   619→\\tif len(shortID) > 7 {\\n   620→\\t\\tshortID = shortID[:7]\\n   621→\\t}\\n   622→\\n   623→\\tfmt.Printf(\\\"Reset branch to %s.\\\\n\\\", shortID)\\n   624→\\n   625→\\t// Show resume commands for all sessions\\n   626→\\tprintMultiSessionResumeCommands(sessions)\\n   627→\\n   628→\\t// Show recovery instructions\\n   629→\\tif currentHead != \\\"\\\" && currentHead != point.ID {\\n   630→\\t\\tcurrentShort := currentHead\\n   631→\\t\\tif len(currentShort) > 7 {\\n   632→\\t\\t\\tcurrentShort = currentShort[:7]\\n   633→\\t\\t}\\n   634→\\t\\tfmt.Printf(\\\"\\\\nTo undo this reset: git reset --hard %s\\\\n\\\", currentShort)\\n   635→\\t}\\n   636→\\n   637→\\treturn nil\\n   638→}\\n   639→\\n   640→func restoreSessionTranscript(ctx context.Context, transcriptFile, sessionID string, agent agentpkg.Agent) error {\\n   641→\\tsessionFile, err := resolveTranscriptPath(ctx, sessionID, agent)\\n   642→\\tif err != nil {\\n   643→\\t\\treturn err\\n   644→\\t}\\n   645→\\n   646→\\t// Ensure parent directory exists\\n   647→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   648→\\t\\treturn fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   649→\\t}\\n   650→\\n   651→\\tfmt.Fprintf(os.Stderr, \\\"Copying transcript:\\\\n  From: %s\\\\n  To: %s\\\\n\\\", transcriptFile, sessionFile)\\n   652→\\tif err := copyFile(transcriptFile, sessionFile); err != nil {\\n   653→\\t\\treturn fmt.Errorf(\\\"failed to copy transcript: %w\\\", err)\\n   654→\\t}\\n   655→\\n   656→\\treturn nil\\n   657→}\\n   658→\\n   659→// restoreSessionTranscriptFromStrategy restores a session transcript from checkpoint storage.\\n   660→// This is used for strategies that store transcripts in git branches rather than local files.\\n   661→// Returns the session ID that was actually used (may differ from input if checkpoint provides one).\\n   662→func restoreSessionTranscriptFromStrategy(ctx context.Context, cpID id.CheckpointID, sessionID string, agent agentpkg.Agent) (string, error) {\\n   663→\\t// Get transcript content from checkpoint storage\\n   664→\\tcontent, returnedSessionID, err := checkpoint.LookupSessionLog(ctx, cpID)\\n   665→\\tif err != nil {\\n   666→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get session log: %w\\\", err)\\n   667→\\t}\\n   668→\\n   669→\\t// Use session ID returned from checkpoint if available\\n   670→\\t// Otherwise fall back to the passed-in sessionID\\n   671→\\tif returnedSessionID != \\\"\\\" {\\n   672→\\t\\tsessionID = returnedSessionID\\n   673→\\t}\\n   674→\\n   675→\\tsessionFile, err := resolveTranscriptPath(ctx, sessionID, agent)\\n   676→\\tif err != nil {\\n   677→\\t\\treturn \\\"\\\", err\\n   678→\\t}\\n   679→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   680→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   681→\\t}\\n   682→\\tagentSession := &agentpkg.AgentSession{\\n   683→\\t\\tSessionID:  sessionID,\\n   684→\\t\\tAgentName:  agent.Name(),\\n   685→\\t\\tSessionRef: sessionFile,\\n   686→\\t\\tNativeData: content,\\n   687→\\t}\\n   688→\\tif err := agent.WriteSession(ctx, agentSession); err != nil {\\n   689→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write session: %w\\\", err)\\n   690→\\t}\\n   691→\\treturn sessionID, nil\\n   692→}\\n   693→\\n   694→// restoreSessionTranscriptFromShadow restores a session transcript from a shadow branch commit.\\n   695→// This is used for uncommitted checkpoints where the transcript is stored in the shadow branch tree.\\n   696→func restoreSessionTranscriptFromShadow(ctx context.Context, commitHash, metadataDir, sessionID string, agent agentpkg.Agent) (string, error) {\\n   697→\\t// Open repository\\n   698→\\trepo, err := git.PlainOpenWithOptions(\\\".\\\", &git.PlainOpenOptions{DetectDotGit: true})\\n   699→\\tif err != nil {\\n   700→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   701→\\t}\\n   702→\\n   703→\\t// Parse commit hash\\n   704→\\thash := plumbing.NewHash(commitHash)\\n   705→\\tif hash.IsZero() {\\n   706→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"invalid commit hash: %s\\\", commitHash)\\n   707→\\t}\\n   708→\\n   709→\\t// Get transcript from shadow branch commit tree\\n   710→\\tstore := checkpoint.NewGitStore(repo)\\n   711→\\tcontent, err := store.GetTranscriptFromCommit(ctx, hash, metadataDir, agent.Type())\\n   712→\\tif err != nil {\\n   713→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get transcript from shadow branch: %w\\\", err)\\n   714→\\t}\\n   715→\\n   716→\\tsessionFile, err := resolveTranscriptPath(ctx, sessionID, agent)\\n   717→\\tif err != nil {\\n   718→\\t\\treturn \\\"\\\", err\\n   719→\\t}\\n   720→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   721→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   722→\\t}\\n   723→\\tagentSession := &agentpkg.AgentSession{\\n   724→\\t\\tSessionID:  sessionID,\\n   725→\\t\\tAgentName:  agent.Name(),\\n   726→\\t\\tSessionRef: sessionFile,\\n   727→\\t\\tNativeData: content,\\n   728→\\t}\\n   729→\\tif err := agent.WriteSession(ctx, agentSession); err != nil {\\n   730→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write session: %w\\\", err)\\n   731→\\t}\\n   732→\\treturn sessionID, nil\\n   733→}\\n   734→\\n   735→// restoreTaskCheckpointTranscript restores a truncated transcript for a task checkpoint.\\n   736→// Uses GetTaskCheckpointTranscript to fetch the transcript from the strategy.\\n   737→//\\n   738→// NOTE: The transcript parsing/truncation/writing pipeline (transcript.ParseFromBytes,\\n   739→// TruncateTranscriptAtUUID, writeTranscript) assumes Claude's JSONL format.\\n   740→// This is acceptable because task checkpoints are currently only created by Claude Code's\\n   741→// PostToolUse hook. If other agents gain sub-agent support, this will need a\\n   742→// format-aware refactor (agent-specific parsing, truncation, and serialization).\\n   743→func restoreTaskCheckpointTranscript(ctx context.Context, strat *strategy.ManualCommitStrategy, point strategy.RewindPoint, sessionID, checkpointUUID string, agent agentpkg.Agent) error {\\n   744→\\t// Get transcript content from strategy\\n   745→\\tcontent, err := strat.GetTaskCheckpointTranscript(ctx, point)\\n   746→\\tif err != nil {\\n   747→\\t\\treturn fmt.Errorf(\\\"failed to get task checkpoint transcript: %w\\\", err)\\n   748→\\t}\\n   749→\\n   750→\\t// Parse the transcript\\n   751→\\tparsed, err := transcript.ParseFromBytes(content)\\n   752→\\tif err != nil {\\n   753→\\t\\treturn fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   754→\\t}\\n   755→\\n   756→\\t// Truncate at checkpoint UUID\\n   757→\\ttruncated := TruncateTranscriptAtUUID(parsed, checkpointUUID)\\n   758→\\n   759→\\tsessionFile, err := resolveTranscriptPath(ctx, sessionID, agent)\\n   760→\\tif err != nil {\\n   761→\\t\\treturn err\\n   762→\\t}\\n   763→\\n   764→\\t// Ensure parent directory exists\\n   765→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   766→\\t\\treturn fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   767→\\t}\\n   768→\\n   769→\\tfmt.Fprintf(os.Stderr, \\\"Writing truncated transcript to: %s\\\\n\\\", sessionFile)\\n   770→\\n   771→\\tif err := writeTranscript(sessionFile, truncated); err != nil {\\n   772→\\t\\treturn fmt.Errorf(\\\"failed to write truncated transcript: %w\\\", err)\\n   773→\\t}\\n   774→\\n   775→\\treturn nil\\n   776→}\\n   777→\\n   778→// handleLogsOnlyRewindInteractive handles rewind for logs-only points with a sub-choice menu.\\n   779→func handleLogsOnlyRewindInteractive(ctx context.Context, start *strategy.ManualCommitStrategy, point strategy.RewindPoint, shortID string) error {\\n   780→\\tvar action string\\n   781→\\n   782→\\tform := NewAccessibleForm(\\n   783→\\t\\thuh.NewGroup(\\n   784→\\t\\t\\thuh.NewSelect[string]().\\n   785→\\t\\t\\t\\tTitle(\\\"Logs-only point: \\\"+shortID).\\n   786→\\t\\t\\t\\tDescription(\\\"This commit has session logs but no checkpoint state. Choose an action:\\\").\\n   787→\\t\\t\\t\\tOptions(\\n   788→\\t\\t\\t\\t\\thuh.NewOption(\\\"Restore logs only (keep current files)\\\", \\\"logs\\\"),\\n   789→\\t\\t\\t\\t\\thuh.NewOption(\\\"Checkout commit (detached HEAD, for viewing)\\\", \\\"checkout\\\"),\\n   790→\\t\\t\\t\\t\\thuh.NewOption(\\\"Reset branch to this commit (destructive!)\\\", \\\"reset\\\"),\\n   791→\\t\\t\\t\\t\\thuh.NewOption(\\\"Cancel\\\", \\\"cancel\\\"),\\n   792→\\t\\t\\t\\t).\\n   793→\\t\\t\\t\\tValue(&action),\\n   794→\\t\\t),\\n   795→\\t)\\n   796→\\n   797→\\tif err := form.Run(); err != nil {\\n   798→\\t\\treturn fmt.Errorf(\\\"action selection cancelled: %w\\\", err)\\n   799→\\t}\\n   800→\\n   801→\\tswitch action {\\n   802→\\tcase \\\"logs\\\":\\n   803→\\t\\treturn handleLogsOnlyRestore(ctx, start, point)\\n   804→\\tcase \\\"checkout\\\":\\n   805→\\t\\treturn handleLogsOnlyCheckout(ctx, start, point, shortID)\\n   806→\\tcase \\\"reset\\\":\\n   807→\\t\\treturn handleLogsOnlyReset(ctx, start, point, shortID)\\n   808→\\tcase \\\"cancel\\\":\\n   809→\\t\\tfmt.Println(\\\"Rewind cancelled.\\\")\\n   810→\\t\\treturn nil\\n   811→\\t}\\n   812→\\n   813→\\treturn nil\\n   814→}\\n   815→\\n   816→// handleLogsOnlyRestore restores only the session logs without changing files.\\n   817→func handleLogsOnlyRestore(ctx context.Context, start *strategy.ManualCommitStrategy, point strategy.RewindPoint) error {\\n   818→\\t// Resolve agent once for use throughout\\n   819→\\tagent, err := getAgent(point.Agent)\\n   820→\\tif err != nil {\\n   821→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   822→\\t}\\n   823→\\n   824→\\t// Initialize logging context with agent from checkpoint\\n   825→\\tlogCtx := logging.WithComponent(ctx, \\\"rewind\\\")\\n   826→\\tlogCtx = logging.WithAgent(logCtx, agent.Name())\\n   827→\\n   828→\\tlogging.Debug(logCtx, \\\"logs-only restore started\\\",\\n   829→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   830→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   831→\\t)\\n   832→\\n   833→\\t// Restore logs\\n   834→\\tsessions, err := start.RestoreLogsOnly(ctx, point, true) // force=true for explicit rewind\\n   835→\\tif err != nil {\\n   836→\\t\\tlogging.Error(logCtx, \\\"logs-only restore failed\\\",\\n   837→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   838→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   839→\\t\\t)\\n   840→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   841→\\t}\\n   842→\\n   843→\\tlogging.Debug(logCtx, \\\"logs-only restore completed\\\",\\n   844→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   845→\\t)\\n   846→\\n   847→\\t// Show resume commands for all sessions\\n   848→\\tfmt.Println(\\\"Restored session logs.\\\")\\n   849→\\tprintMultiSessionResumeCommands(sessions)\\n   850→\\treturn nil\\n   851→}\\n   852→\\n   853→// handleLogsOnlyCheckout restores logs and checks out the commit (detached HEAD).\\n   854→func handleLogsOnlyCheckout(ctx context.Context, start *strategy.ManualCommitStrategy, point strategy.RewindPoint, shortID string) error {\\n   855→\\t// Resolve agent once for use throughout\\n   856→\\tagent, err := getAgent(point.Agent)\\n   857→\\tif err != nil {\\n   858→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   859→\\t}\\n   860→\\n   861→\\t// Initialize logging context with agent from checkpoint\\n   862→\\tlogCtx := logging.WithComponent(ctx, \\\"rewind\\\")\\n   863→\\tlogCtx = logging.WithAgent(logCtx, agent.Name())\\n   864→\\n   865→\\tlogging.Debug(logCtx, \\\"logs-only checkout started\\\",\\n   866→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   867→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   868→\\t)\\n   869→\\n   870→\\tsessions, err := start.RestoreLogsOnly(ctx, point, true) // force=true for explicit rewind\\n   871→\\tif err != nil {\\n   872→\\t\\tlogging.Error(logCtx, \\\"logs-only checkout failed during log restoration\\\",\\n   873→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   874→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   875→\\t\\t)\\n   876→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   877→\\t}\\n   878→\\n   879→\\t// Show warning about detached HEAD\\n   880→\\tvar confirm bool\\n   881→\\tconfirmForm := NewAccessibleForm(\\n   882→\\t\\thuh.NewGroup(\\n   883→\\t\\t\\thuh.NewConfirm().\\n   884→\\t\\t\\t\\tTitle(\\\"Create detached HEAD?\\\").\\n   885→\\t\\t\\t\\tDescription(\\\"This will checkout the commit directly. You'll be in 'detached HEAD' state.\\\\nAny uncommitted changes will be lost!\\\").\\n   886→\\t\\t\\t\\tValue(&confirm),\\n   887→\\t\\t),\\n   888→\\t)\\n   889→\\n   890→\\tif err := confirmForm.Run(); err != nil {\\n   891→\\t\\treturn fmt.Errorf(\\\"confirmation cancelled: %w\\\", err)\\n   892→\\t}\\n   893→\\n   894→\\tif !confirm {\\n   895→\\t\\tfmt.Println(\\\"Checkout cancelled. Session logs were still restored.\\\")\\n   896→\\t\\tprintMultiSessionResumeCommands(sessions)\\n   897→\\t\\treturn nil\\n   898→\\t}\\n   899→\\n   900→\\t// Perform git checkout\\n   901→\\tif err := CheckoutBranch(ctx, point.ID); err != nil {\\n   902→\\t\\tlogging.Error(logCtx, \\\"logs-only checkout failed during git checkout\\\",\\n   903→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   904→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   905→\\t\\t)\\n   906→\\t\\treturn fmt.Errorf(\\\"failed to checkout commit: %w\\\", err)\\n   907→\\t}\\n   908→\\n   909→\\tlogging.Debug(logCtx, \\\"logs-only checkout completed\\\",\\n   910→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   911→\\t)\\n   912→\\n   913→\\tfmt.Printf(\\\"Checked out %s (detached HEAD).\\\\n\\\", shortID)\\n   914→\\tprintMultiSessionResumeCommands(sessions)\\n   915→\\treturn nil\\n   916→}\\n   917→\\n   918→// handleLogsOnlyReset restores logs and resets the branch to the commit (destructive).\\n   919→func handleLogsOnlyReset(ctx context.Context, start *strategy.ManualCommitStrategy, point strategy.RewindPoint, shortID string) error {\\n   920→\\t// Resolve agent once for use throughout\\n   921→\\tagent, agentErr := getAgent(point.Agent)\\n   922→\\tif agentErr != nil {\\n   923→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", agentErr)\\n   924→\\t}\\n   925→\\n   926→\\t// Initialize logging context with agent from checkpoint\\n   927→\\tlogCtx := logging.WithComponent(ctx, \\\"rewind\\\")\\n   928→\\tlogCtx = logging.WithAgent(logCtx, agent.Name())\\n   929→\\n   930→\\tlogging.Debug(logCtx, \\\"logs-only reset (interactive) started\\\",\\n   931→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   932→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   933→\\t)\\n   934→\\n   935→\\tsessions, restoreErr := start.RestoreLogsOnly(ctx, point, true) // force=true for explicit rewind\\n   936→\\tif restoreErr != nil {\\n   937→\\t\\tlogging.Error(logCtx, \\\"logs-only reset failed during log restoration\\\",\\n   938→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   939→\\t\\t\\tslog.String(\\\"error\\\", restoreErr.Error()),\\n   940→\\t\\t)\\n   941→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", restoreErr)\\n   942→\\t}\\n   943→\\n   944→\\t// Get current HEAD before reset (for recovery message)\\n   945→\\tcurrentHead, err := getCurrentHeadHash(ctx)\\n   946→\\tif err != nil {\\n   947→\\t\\t// Non-fatal - just won't show recovery message\\n   948→\\t\\tcurrentHead = \\\"\\\"\\n   949→\\t}\\n   950→\\n   951→\\t// Get detailed uncommitted changes warning from strategy\\n   952→\\tvar uncommittedWarning string\\n   953→\\tif _, warn, err := start.CanRewind(ctx); err == nil {\\n   954→\\t\\tuncommittedWarning = warn\\n   955→\\t}\\n   956→\\n   957→\\t// Check for safety issues\\n   958→\\twarnings, err := checkResetSafety(ctx, point.ID, uncommittedWarning)\\n   959→\\tif err != nil {\\n   960→\\t\\treturn fmt.Errorf(\\\"failed to check reset safety: %w\\\", err)\\n   961→\\t}\\n   962→\\n   963→\\t// Build confirmation message based on warnings\\n   964→\\tvar confirmTitle, confirmDesc string\\n   965→\\tif len(warnings) > 0 {\\n   966→\\t\\tconfirmTitle = \\\"⚠️  Reset branch with warnings?\\\"\\n   967→\\t\\tconfirmDesc = \\\"WARNING - the following issues were detected:\\\\n\\\" +\\n   968→\\t\\t\\tstrings.Join(warnings, \\\"\\\\n\\\") +\\n   969→\\t\\t\\t\\\"\\\\n\\\\nThis will move your branch to \\\" + shortID + \\\" and DISCARD commits after it!\\\"\\n   970→\\t} else {\\n   971→\\t\\tconfirmTitle = \\\"Reset branch to \\\" + shortID + \\\"?\\\"\\n   972→\\t\\tconfirmDesc = \\\"This will move your branch pointer to this commit.\\\\nCommits after this point will be orphaned (but recoverable via reflog).\\\"\