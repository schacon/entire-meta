File)\\n   210→}\\n   211→\\n   212→// TestLogsOnlyRewind_DoesNotModifyWorkingDirectory verifies that logs-only\\n   213→// rewind does NOT modify the working directory files.\\n   214→func TestLogsOnlyRewind_DoesNotModifyWorkingDirectory(t *testing.T) {\\n   215→\\tt.Parallel()\\n   216→\\tenv := NewTestEnv(t)\\n   217→\\tdefer env.Cleanup()\\n   218→\\n   219→\\t// Setup\\n   220→\\tenv.InitRepo()\\n   221→\\tenv.WriteFile(\\\"README.md\\\", \\\"# Test Repository\\\")\\n   222→\\tenv.GitAdd(\\\"README.md\\\")\\n   223→\\tenv.GitCommit(\\\"Initial commit\\\")\\n   224→\\tenv.GitCheckoutNewBranch(\\\"feature/no-modify-test\\\")\\n   225→\\tenv.InitEntire()\\n   226→\\n   227→\\tt.Log(\\\"Phase 1: Create session 1 and commit\\\")\\n   228→\\n   229→\\tsession1 := env.NewSession()\\n   230→\\tif err := env.SimulateUserPromptSubmit(session1.ID); err != nil {\\n   231→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   232→\\t}\\n   233→\\n   234→\\tv1Content := \\\"version 1\\\"\\n   235→\\tenv.WriteFile(\\\"file.txt\\\", v1Content)\\n   236→\\tsession1.CreateTranscript(\\\"Create file with version 1\\\", []FileChange{{Path: \\\"file.txt\\\", Content: v1Content}})\\n   237→\\n   238→\\tif err := env.SimulateStop(session1.ID, session1.TranscriptPath); err != nil {\\n   239→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   240→\\t}\\n   241→\\n   242→\\tenv.GitCommitWithShadowHooks(\\\"Add file version 1\\\", \\\"file.txt\\\")\\n   243→\\tcommit1Hash := env.GetHeadHash()\\n   244→\\tt.Logf(\\\"Commit 1: %s\\\", commit1Hash[:7])\\n   245→\\n   246→\\t// Clear session 1 state to simulate session completion (avoids concurrent session warning)\\n   247→\\tif err := env.ClearSessionState(session1.ID); err != nil {\\n   248→\\t\\tt.Fatalf(\\\"ClearSessionState failed: %v\\\", err)\\n   249→\\t}\\n   250→\\n   251→\\tt.Log(\\\"Phase 2: Create session 2 and commit\\\")\\n   252→\\n   253→\\tsession2 := env.NewSession()\\n   254→\\tif err := env.Simulate