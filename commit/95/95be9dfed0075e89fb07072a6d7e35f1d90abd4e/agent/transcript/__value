\"no transcript found for checkpoint\\\")\\n    28→)\\n    29→\\n    30→// Checkpoint represents a save point within a session.\\n    31→type Checkpoint struct {\\n    32→\\t// ID is the unique checkpoint identifier\\n    33→\\tID string\\n    34→\\n    35→\\t// SessionID is the session this checkpoint belongs to\\n    36→\\tSessionID string\\n    37→\\n    38→\\t// Timestamp is when this checkpoint was created\\n    39→\\tTimestamp time.Time\\n    40→\\n    41→\\t// Type indicates temporary (full state) or committed (metadata only)\\n    42→\\tType Type\\n    43→\\n    44→\\t// Message is a human-readable description of the checkpoint\\n    45→\\tMessage string\\n    46→}\\n    47→\\n    48→// Type indicates the storage location and lifecycle of a checkpoint.\\n    49→type Type int\\n    50→\\n    51→const (\\n    52→\\t// Temporary checkpoints contain full state (code + metadata) and are stored\\n    53→\\t// on shadow branches (entire/<commit-hash>). Used for intra-session rewind.\\n    54→\\tTemporary Type = iota\\n    55→\\n    56→\\t// Committed checkpoints contain metadata + commit reference and are stored\\n    57→\\t// on the entire/checkpoints/v1 branch. They are the permanent record.\\n    58→\\tCommitted\\n    59→)\\n    60→\\n    61→// Store provides low-level primitives for reading and writing checkpoints.\\n    62→// This is used by strategies to implement their storage approach.\\n    63→//\\n    64→// The interface matches the GitStore implementation signatures directly:\\n    65→// - WriteTemporary takes WriteTemporaryOptions and returns a result with commit hash and skip status\\n    66→// - ReadTemporary takes baseCommit (not sessionID) since shadow branches are keyed by commit\\n    67→// - List methods return implementation-specific info types for richer data\\n    68→type Store interface {\\n    69→\\t// WriteTemporary writes a temporary checkpoint (full state) to a shadow branch.\\n    70→\\t// Shadow branches are named entire/<base-commit-short-hash>.\\n    71→\\t// Returns a result containing the commit hash and whether the checkpoint was skipped.\\n    72→\\t// Checkpoints are skipped (deduplicated) when the tree hash matches the previous checkpoint.\\n    73→\\tWriteTemporary(ctx context.Context, opts WriteTemporaryOptions) (WriteTemporaryResult, error)\\n    74→\\n    75→\\t// ReadTemporary reads the latest checkpoint from a shadow branch.\\n    76→\\t// baseCommit is the commit hash the session is based on.\\n    77→\\t// worktreeID is the internal git worktree identifier (empty for main worktree).\\n    78→\\t// Returns nil, nil if the shadow branch doesn't exist.\\n    79→\\tReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error)\\n    80→\\n    81→\\t// ListTemporary lists all shadow branches with their checkpoint info.\\n    82→\\tListTemporary(ctx context.Context) ([]TemporaryInfo, error)\\n    83→\\n    84→\\t// WriteCommitted writes a committed checkpoint to the entire/checkpoints/v1 branch.\\n    85→\\t// Checkpoints are stored at sharded paths: <id[:2]>/<id[2:]>/\\n    86→\\tWriteCommitted(ctx context.Context, opts WriteCommittedOptions) error\\n    87→\\n    88→\\t// ReadCommitted reads a committed checkpoint's summary by ID.\\n    89→\\t// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n    90→\\t// Use ReadSessionContent to read actual transcript/prompts.\\n    91→\\t// Returns nil, nil if the checkpoint does not exist.\\n    92→\\tReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error)\\n    93→\\n    94→\\t// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n    95→\\t// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n    96→\\t// Returns the session's metadata, transcript, and prompts.\\n    97→\\tReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error)\\n    98→\\n    99→\\t// ReadSessionContentByID reads a session's content by its session ID.\\n   100→\\t// Useful when you have the session ID but don't know its index within the checkpoint.\\n   101→\\tReadSessionContentByID(ctx context.Context, checkpointID id.CheckpointID, sessionID string) (*SessionContent, error)\\n   102→\\n   103→\\t// ListCommitted lists all committed checkpoints.\\n   104→\\tListCommitted(ctx context.Context) ([]CommittedInfo, error)\\n   105→\\n   106→\\t// UpdateCommitted replaces the transcript and prompts for an existing\\n   107→\\t// committed checkpoint. Used at stop time to finalize checkpoints with the full\\n   108→\\t// session transcript (prompt to stop event).\\n   109→\\t// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   110→\\tUpdateCommitted(ctx context.Context, opts UpdateCommittedOptions) error\\n   111→}\\n   112→\\n   113→// WriteTemporaryResult contains the result of writing a temporary checkpoint.\\n   114→type WriteTemporaryResult struct {\\n   115→\\t// CommitHash is the hash of the created or existing checkpoint commit\\n   116→\\tCommitHash plumbing.Hash\\n   117→\\n   118→\\t// Skipped is true if the checkpoint was skipped due to no changes\\n   119→\\t// (tree hash matched the previous checkpoint)\\n   120→\\tSkipped bool\\n   121→}\\n   122→\\n   123→// WriteTemporaryOptions contains options for writing a temporary checkpoint.\\n   124→type WriteTemporaryOptions struct {\\n   125→\\t// SessionID is the session identifier\\n   126→\\tSessionID string\\n   127→\\n   128→\\t// BaseCommit is the commit hash this session is based on\\n   129→\\tBaseCommit string\\n   130→\\n   131→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n   132→\\t// Used to create worktree-specific shadow branch names\\n   133→\\tWorktreeID string\\n   134→\\n   135→\\t// ModifiedFiles are files that have been modified (relative paths)\\n   136→\\tModifiedFiles []string\\n   137→\\n   138→\\t// NewFiles are files that have been created (relative paths)\\n   139→\\tNewFiles []string\\n   140→\\n   141→\\t// DeletedFiles are files that have been deleted (relative paths)\\n   142→\\tDeletedFiles []string\\n   143→\\n   144→\\t// MetadataDir is the relative path to the metadata directory\\n   145→\\tMetadataDir string\\n   146→\\n   147→\\t// MetadataDirAbs is the absolute path to the metadata directory\\n   148→\\tMetadataDirAbs string\\n   149→\\n   150→\\t// CommitMessage is the commit subject line\\n   151→\\tCommitMessage string\\n   152→\\n   153→\\t// AuthorName is the name to use for commits\\n   154→\\tAuthorName string\\n   155→\\n   156→\\t// AuthorEmail is the email to use for commits\\n   157→\\tAuthorEmail string\\n   158→\\n   159→\\t// IsFirstCheckpoint indicates if this is the first checkpoint of the session\\n   160→\\t// When true, all working directory files are captured (not just modified)\\n   161→\\tIsFirstCheckpoint bool\\n   162→}\\n   163→\\n   164→// ReadTemporaryResult contains the result of reading a temporary checkpoint.\\n   165→type ReadTemporaryResult struct {\\n   166→\\t// CommitHash is the hash of the checkpoint commit\\n   167→\\tCommitHash plumbing.Hash\\n   168→\\n   169→\\t// TreeHash is the hash of the tree containing the checkpoint state\\n   170→\\tTreeHash plumbing.Hash\\n   171→\\n   172→\\t// SessionID is the session identifier from the commit trailer\\n   173→\\tSessionID string\\n   174→\\n   175→\\t// MetadataDir is the metadata directory path from the commit trailer\\n   176→\\tMetadataDir string\\n   177→\\n   178→\\t// Timestamp is when the checkpoint was created\\n   179→\\tTimestamp time.Time\\n   180→}\\n   181→\\n   182→// TemporaryInfo contains summary information about a shadow branch.\\n   183→type TemporaryInfo struct {\\n   184→\\t// BranchName is the full branch name (e.g., \\\"entire/abc1234\\\")\\n   185→\\tBranchName string\\n   186→\\n   187→\\t// BaseCommit is the short commit hash this branch is based on\\n   188→\\tBaseCommit string\\n   189→\\n   190→\\t// LatestCommit is the hash of the latest commit on the branch\\n   191→\\tLatestCommit plumbing.Hash\\n   192→\\n   193→\\t// SessionID is the session identifier from the latest commit\\n   194→\\tSessionID string\\n   195→\\n   196→\\t// Timestamp is when the latest checkpoint was created\\n   197→\\tTimestamp time.Time\\n   198→}\\n   199→\\n   200→// WriteCommittedOptions contains options for writing a committed checkpoint.\\n   201→type WriteCommittedOptions struct {\\n   202→\\t// CheckpointID is the stable 12-hex-char identifier\\n   203→\\tCheckpointID id.CheckpointID\\n   204→\\n   205→\\t// SessionID is the session identifier\\n   206→\\tSessionID string\\n   207→\\n   208→\\t// Strategy is the name of the strategy that created this checkpoint\\n   209→\\tStrategy string\\n   210→\\n   211→\\t// Branch is the branch name where the checkpoint was created (empty if detached HEAD)\\n   212→\\tBranch string\\n   213→\\n   214→\\t// Transcript is the session transcript content (full.jsonl)\\n   215→\\tTranscript []byte\\n   216→\\n   217→\\t// Prompts contains user prompts from the session\\n   218→\\tPrompts []string\\n   219→\\n   220→\\t// FilesTouched are files modified during the session\\n   221→\\tFilesTouched []string\\n   222→\\n   223→\\t// CheckpointsCount is the number of checkpoints in this session\\n   224→\\tCheckpointsCount int\\n   225→\\n   226→\\t// EphemeralBranch is the shadow branch name (for manual-commit strategy)\\n   227→\\tEphemeralBranch string\\n   228→\\n   229→\\t// AuthorName is the name to use for commits\\n   230→\\tAuthorName string\\n   231→\\n   232→\\t// AuthorEmail is the email to use for commits\\n   233→\\tAuthorEmail string\\n   234→\\n   235→\\t// MetadataDir is a directory containing additional metadata files to copy\\n   236→\\t// If set, all files in this directory will be copied to the checkpoint path\\n   237→\\t// This is useful for copying task metadata files, subagent transcripts, etc.\\n   238→\\tMetadataDir string\\n   239→\\n   240→\\t// Task checkpoint fields (for task/subagent checkpoints)\\n   241→\\tIsTask    bool   // Whether this is a task checkpoint\\n   242→\\tToolUseID string // Tool use ID for task checkpoints\\n   243→\\n   244→\\t// Additional task checkpoint fields for subagent checkpoints\\n   245→\\tAgentID                string // Subagent identifier\\n   246→\\tCheckpointUUID         string // UUID for transcript truncation when rewinding\\n   247→\\tTranscriptPath         string // Path to session transcript file (alternative to in-memory Transcript)\\n   248→\\tSubagentTranscriptPath string // Path to subagent's transcript file\\n   249→\\n   250→\\t// Incremental checkpoint fields\\n   251→\\tIsIncremental       bool   // Whether this is an incremental checkpoint\\n   252→\\tIncrementalSequence int    // Checkpoint sequence number\\n   253→\\tIncrementalType     string // Tool type that triggered this checkpoint\\n   254→\\tIncrementalData     []byte // Tool input payload for this checkpoint\\n   255→\\n   256→\\t// Commit message fields (used for task checkpoints)\\n   257→\\tCommitSubject string // Subject line for the metadata commit (overrides default)\\n   258→\\n   259→\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   260→\\tAgent types.AgentType\\n   261→\\n   262→\\t// TurnID correlates checkpoints from the same agent turn.\\n   263→\\tTurnID string\\n   264→\\n   265→\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n   266→\\tTranscriptIdentifierAtStart string // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n   267→\\tCheckpointTranscriptStart   int    // Transcript line offset at start of this checkpoint's data\\n   268→\\n   269→\\t// CheckpointTranscriptStart is written to both CommittedMetadata.CheckpointTranscriptStart\\n   270→\\t// and the deprecated CommittedMetadata.TranscriptLinesAtStart for backward compatibility.\\n   271→\\n   272→\\t// TokenUsage contains the token usage for this checkpoint\\n   273→\\tTokenUsage *agent.TokenUsage\\n   274→\\n   275→\\t// InitialAttribution is line-level attribution calculated at commit time\\n   276→\\t// comparing checkpoint tree (agent work) to committed tree (may include human edits)\\n   277→\\tInitialAttribution *InitialAttribution\\n   278→\\n   279→\\t// Summary is an optional AI-generated summary for this checkpoint.\\n   280→\\t// This field may be nil when:\\n   281→\\t//   - summarization is disabled in settings\\n   282→\\t//   - summary generation failed (non-blocking, logged as warning)\\n   283→\\t//   - the transcript was empty or too short to summarize\\n   284→\\t//   - the checkpoint predates the summarization feature\\n   285→\\tSummary *Summary\\n   286→}\\n   287→\\n   288→// UpdateCommittedOptions contains options for updating an existing committed checkpoint.\\n   289→// Uses replace semantics: the transcript and prompts are fully replaced,\\n   290→// not appended. At stop time we have the complete session transcript and want every\\n   291→// checkpoint to contain it identically.\\n   292→type UpdateCommittedOptions struct {\\n   293→\\t// CheckpointID identifies the checkpoint to update\\n   294→\\tCheckpointID id.CheckpointID\\n   295→\\n   296→\\t// SessionID identifies which session slot to update within the checkpoint\\n   297→\\tSessionID string\\n   298→\\n   299→\\t// Transcript is the full session transcript (replaces existing)\\n   300→\\tTranscript []byte\\n   301→\\n   302→\\t// Prompts contains all user prompts (replaces existing)\\n   303→\\tPrompts []string\\n   304→\\n   305→\\t// Agent identifies the agent type (needed for transcript chunking)\\n   306→\\tAgent types.AgentType\\n   307→}\\n   308→\\n   309→// CommittedInfo contains summary information about a committed checkpoint.\\n   310→type CommittedInfo struct {\\n   311→\\t// CheckpointID is the stable 12-hex-char identifier\\n   312→\\tCheckpointID id.CheckpointID\\n   313→\\n   314→\\t// SessionID is the session identifier (most recent session for multi-session checkpoints)\\n   315→\\tSessionID string\\n   316→\\n   317→\\t// CreatedAt is when the checkpoint was created\\n   318→\\tCreatedAt time.Time\\n   319→\\n   320→\\t// CheckpointsCount is the total number of checkpoints across all sessions\\n   321→\\tCheckpointsCount int\\n   322→\\n   323→\\t// FilesTouched are files modified during all sessions\\n   324→\\tFilesTouched []string\\n   325→\\n   326→\\t// Agent identifies the agent that created this checkpoint\\n   327→\\tAgent types.AgentType\\n   328→\\n   329→\\t// IsTask indicates if this is a task checkpoint\\n   330→\\tIsTask bool\\n   331→\\n   332→\\t// ToolUseID is the tool use ID for task checkpoints\\n   333→\\tToolUseID string\\n   334→\\n   335→\\t// Multi-session support\\n   336→\\tSessionCount int      // Number of sessions (1 if single session)\\n   337→\\tSessionIDs   []string // All session IDs that contributed\\n   338→}\\n   339→\\n   340→// SessionContent contains the actual content for a session.\\n   341→// This is used when reading full session data (transcript, prompts, context)\\n   342→// as opposed to just the metadata/summary.\\n   343→type SessionContent struct {\\n   344→\\t// Metadata contains the session-specific metadata\\n   345→\\tMetadata CommittedMetadata\\n   346→\\n   347→\\t// Transcript is the session transcript content\\n   348→\\tTranscript []byte\\n   349→\\n   350→\\t// Prompts contains user prompts from this session\\n   351→\\tPrompts string\\n   352→}\\n   353→\\n   354→// CommittedMetadata contains the metadata stored in metadata.json for each checkpoint.\\n   355→type CommittedMetadata struct {\\n   356→\\tCLIVersion       string          `json:\\\"cli_version,omitempty\\\"`\\n   357→\\tCheckpointID     id.CheckpointID `json:\\\"checkpoint_id\\\"`\\n   358→\\tSessionID        string          `json:\\\"session_id\\\"`\\n   359→\\tStrategy         string          `json:\\\"strategy\\\"`\\n   360→\\tCreatedAt        time.Time       `json:\\\"created_at\\\"`\\n   361→\\tBranch           string          `json:\\\"branch,omitempty\\\"` // Branch where checkpoint was created (empty if detached HEAD)\\n   362→\\tCheckpointsCount int             `json:\\\"checkpoints_count\\\"`\\n   363→\\tFilesTouched     []string        `json:\\\"files_touched\\\"`\\n   364→\\n   365→\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   366→\\tAgent types.AgentType `json:\\\"agent,omitempty\\\"`\\n   367→\\n   368→\\t// TurnID correlates checkpoints from the same agent turn.\\n   369→\\t// When a turn's work spans multiple commits, each gets its own checkpoint\\n   370→\\t// but they share the same TurnID for future aggregation/deduplication.\\n   371→\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n   372→\\n   373→\\t// Task checkpoint fields (only populated for task checkpoints)\\n   374→\\tIsTask    bool   `json:\\\"is_task,omitempty\\\"`\\n   375→\\tToolUseID string `json:\\\"tool_use_id,omitempty\\\"`\\n   376→\\n   377→\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n   378→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"` // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n   379→\\tCheckpointTranscriptStart   int    `json:\\\"checkpoint_transcript_start,omitempty\\\"`    // Transcript line offset at start of this checkpoint's data\\n   380→\\n   381→\\t// Deprecated: Use CheckpointTranscriptStart instead. Written for backward compatibility with older CLI versions.\\n   382→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   383→\\n   384→\\t// Token usage for this checkpoint\\n   385→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   386→\\n   387→\\t// AI-generated summary of the checkpoint\\n   388→\\tSummary *Summary `json:\\\"summary,omitempty\\\"`\\n   389→\\n   390→\\t// InitialAttribution is line-level attribution calculated at commit time\\n   391→\\tInitialAttribution *InitialAttribution `json:\\\"initial_attribution,omitempty\\\"`\\n   392→}\\n   393→\\n   394→// GetTranscriptStart returns the transcript line offset at which this checkpoint's data begins.\\n   395→// Returns 0 for new checkpoints (start from beginning). For data written by older CLI versions,\\n   396→// falls back to the deprecated TranscriptLinesAtStart field.\\n   397→func (m CommittedMetadata) GetTranscriptStart() int {\\n   398→\\tif m.CheckpointTranscriptStart > 0 {\\n   399→\\t\\treturn m.CheckpointTranscriptStart\\n   400→\\t}\\n   401→\\treturn m.TranscriptLinesAtStart\\n   402→}\\n   403→\\n   404→// SessionFilePaths contains the absolute paths to session files from the git tree root.\\n   405→// Paths include the full checkpoint path prefix (e.g., \\\"/a1/b2c3d4e5f6/1/metadata.json\\\").\\n   406→// Used in CheckpointSummary.Sessions to map session IDs to their file locations.\\n   407→type SessionFilePaths struct {\\n   408→\\tMetadata    string `json:\\\"metadata\\\"`\\n   409→\\tTranscript  string `json:\\\"transcript\\\"`\\n   410→\\tContentHash string `json:\\\"content_hash\\\"`\\n   411→\\tPrompt      string `json:\\\"prompt\\\"`\\n   412→}\\n   413→\\n   414→// CheckpointSummary is the root-level metadata.json for a checkpoint.\\n   415→// It contains aggregated statistics from all sessions and a map of session IDs\\n   416→// to their file paths. Session-specific data (including initial_attribution)\\n   417→// is stored in the session's subdirectory metadata.json.\\n   418→//\\n   419→// Structure on entire/checkpoints/v1 branch:\\n   420→//\\n   421→//\\t<checkpoint-id[:2]>/<checkpoint-id[2:]>/\\n   422→//\\t├── metadata.json         # This CheckpointSummary\\n   423→//\\t├── 1/                    # First session\\n   424→//\\t│   ├── metadata.json     # Session-specific CommittedMetadata\\n   425→//\\t│   ├── full.jsonl\\n   426→//\\t│   ├── prompt.txt\\n   427→//\\t│   └── content_hash.txt\\n   428→//\\t├── 2/                    # Second session\\n   429→//\\t└── 3/                    # Third session...\\n   430→//\\n   431→//nolint:revive // Named CheckpointSummary to avoid conflict with existing Summary struct\\n   432→type CheckpointSummary struct {\\n   433→\\tCLIVersion       string             `json:\\\"cli_version,omitempty\\\"`\\n   434→\\tCheckpointID     id.CheckpointID    `json:\\\"checkpoint_id\\\"`\\n   435→\\tStrategy         string             `json:\\\"strategy\\\"`\\n   436→\\tBranch           string             `json:\\\"branch,omitempty\\\"`\\n   437→\\tCheckpointsCount int                `json:\\\"checkpoints_count\\\"`\\n   438→\\tFilesTouched     []string           `json:\\\"files_touched\\\"`\\n   439→\\tSessions         []SessionFilePaths `json:\\\"sessions\\\"`\\n   440→\\tTokenUsage       *agent.TokenUsage  `json:\\\"token_usage,omitempty\\\"`\\n   441→}\\n   442→\\n   443→// Summary contains AI-generated summary of a checkpoint.\\n   444→type Summary struct {\\n   445→\\tIntent    string           `json:\\\"intent\\\"`     // What user wanted to accomplish\\n   446→\\tOutcome   string           `json:\\\"outcome\\\"`    // What was achieved\\n   447→\\tLearnings LearningsSummary `json:\\\"learnings\\\"`  // Categorized learnings\\n   448→\\tFriction  []string         `json:\\\"friction\\\"`   // Problems/annoyances encountered\\n   449→\\tOpenItems []string         `json:\\\"open_items\\\"` // Tech debt, unfinished work\\n   450→}\\n   451→\\n   452→// LearningsSummary contains learnings grouped by scope.\\n   453→type LearningsSummary struct {\\n   454→\\tRepo     []string       `json:\\\"repo\\\"`     // Codebase-specific patterns/conventions\\n   455→\\tCode     []CodeLearning `json:\\\"code\\\"`     // File/module specific findings\\n   456→\\tWorkflow []string       `json:\\\"workflow\\\"` // General dev practices\\n   457→}\\n   458→\\n   459→// CodeLearning captures a learning tied to a specific code location.\\n   460→type CodeLearning struct {\\n   461→\\tPath    string `json:\\\"path\\\"`               // File path\\n   462→\\tLine    int    `json:\\\"line,omitempty\\\"`     // Start line number\\n   463→\\tEndLine int    `json:\\\"end_line,omitempty\\\"` // End line for ranges (optional)\\n   464→\\tFinding string `json:\\\"finding\\\"`            // What was learned\\n   465→}\\n   466→\\n   467→// InitialAttribution captures line-level attribution metrics at commit time.\\n   468→// This is a point-in-time snapshot comparing the checkpoint tree (agent work)\\n   469→// against the committed tree (may include human edits).\\n   470→//\\n   471→// Attribution Metrics:\\n   472→//   - TotalCommitted measures \\\"net additions\\\" (lines added that remain in the commit)\\n   473→//   - AgentPercentage represents \\\"of the new code added, what percentage came from the agent\\\"\\n   474→//   - Deletion work is tracked separately in HumanRemoved (not included in percentage)\\n   475→//\\n   476→// Deletion-Only Commits:\\n   477→// For commits with only deletions (no additions), TotalCommitted will be 0 and\\n   478→// AgentPercentage will be 0. This is by design - the percentage metric is only\\n   479→// meaningful for commits that add code. Deletion contributions are captured in\\n   480→// the HumanRemoved field but don't affect the attribution percentage.\\n   481→type InitialAttribution struct {\\n   482→\\tCalculatedAt    time.Time `json:\\\"calculated_at\\\"`\\n   483→\\tAgentLines      int       `json:\\\"agent_lines\\\"`      // Lines added by agent (base → shadow diff)\\n   484→\\tHumanAdded      int       `json:\\\"human_added\\\"`      // Lines added by human (excluding modifications)\\n   485→\\tHumanModified   int    