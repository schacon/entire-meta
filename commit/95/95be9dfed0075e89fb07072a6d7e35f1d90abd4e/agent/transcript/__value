This function reads the summary and extracts relevant fields into CheckpointInfo,\\n   362→// also reading session-level metadata for IsTask/ToolUseID fields.\\n   363→func ReadCheckpointMetadata(tree *object.Tree, checkpointPath string) (*CheckpointInfo, error) {\\n   364→\\tmetadataPath := checkpointPath + \\\"/metadata.json\\\"\\n   365→\\tfile, err := tree.File(metadataPath)\\n   366→\\tif err != nil {\\n   367→\\t\\treturn nil, fmt.Errorf(\\\"failed to find metadata at %s: %w\\\", metadataPath, err)\\n   368→\\t}\\n   369→\\n   370→\\tcontent, err := file.Contents()\\n   371→\\tif err != nil {\\n   372→\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata: %w\\\", err)\\n   373→\\t}\\n   374→\\n   375→\\t// Try to parse as CheckpointSummary first (new format)\\n   376→\\tvar summary checkpoint.CheckpointSummary\\n   377→\\tif err := json.Unmarshal([]byte(content), &summary); err == nil {\\n   378→\\t\\t// If we have sessions array, this is the new format\\n   379→\\t\\tif len(summary.Sessions) > 0 {\\n   380→\\t\\t\\tinfo := &CheckpointInfo{\\n   381→\\t\\t\\t\\tCheckpointID:     summary.CheckpointID,\\n   382→\\t\\t\\t\\tCheckpointsCount: summary.CheckpointsCount,\\n   383→\\t\\t\\t\\tFilesTouched:     summary.FilesTouched,\\n   384→\\t\\t\\t\\tSessionCount:     len(summary.Sessions),\\n   385→\\t\\t\\t}\\n   386→\\n   387→\\t\\t\\t// Read all sessions' metadata to populate SessionIDs and get other fields from first session\\n   388→\\t\\t\\tvar sessionIDs []string\\n   389→\\t\\t\\tfor i, sessionPaths := range summary.Sessions {\\n   390→\\t\\t\\t\\tif sessionPaths.Metadata != \\\"\\\" {\\n   391→\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n   392→\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n   393→\\t\\t\\t\\t\\tsessionMetadataPath := strings.TrimPrefix(sessionPaths.Metadata, \\\"/\\\")\\n   394→\\t\\t\\t\\t\\tif sessionFile, err := tree.File(sessionMetadataPath); err == nil {\\n   395→\\t\\t\\t\\t\\t\\tif sessionContent, err := sessionFile.Contents(); err == nil {\\n   396→\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata checkpoint.CommittedMetadata\\n   397→\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   398→\\t\\t\\t\\t\\t\\t\\t\\tsessionIDs = append(sessionIDs, sessionMetadata.SessionID)\\n   399→\\t\\t\\t\\t\\t\\t\\t\\t// Use first session for Agent, SessionID, CreatedAt, IsTask, ToolUseID\\n   400→\\t\\t\\t\\t\\t\\t\\t\\tif i == 0 {\\n   401→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   402→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   403→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   404→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.IsTask = sessionMetadata.IsTask\\n   405→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.ToolUseID = sessionMetadata.ToolUseID\\n   406→\\t\\t\\t\\t\\t\\t\\t\\t}\\n   407→\\t\\t\\t\\t\\t\\t\\t}\\n   408→\\t\\t\\t\\t\\t\\t}\\n   409→\\t\\t\\t\\t\\t}\\n   410→\\t\\t\\t\\t}\\n   411→\\t\\t\\t}\\n   412→\\t\\t\\tinfo.SessionIDs = sessionIDs\\n   413→\\n   414→\\t\\t\\treturn info, nil\\n   415→\\t\\t}\\n   416→\\t}\\n   417→\\n   418→\\t// Fall back to parsing as CheckpointInfo (old format or direct info)\\n   419→\\tvar metadata CheckpointInfo\\n   420→\\tif err := json.Unmarshal([]byte(content), &metadata); err != nil {\\n   421→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata: %w\\\", err)\\n   422→\\t}\\n   423→\\n   424→\\treturn &metadata, nil\\n   425→}\\n   426→\\n   427→// GetMetadataBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\n   428→func GetMetadataBranchTree(repo *git.Repository) (*object.Tree, error) {\\n   429→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   430→\\tref, err := repo.Reference(refName, true)\\n   431→\\tif err != nil {\\n   432→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch reference: %w\\\", err)\\n   433→\\t}\\n   434→\\n   435→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   436→\\tif err != nil {\\n   437→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch commit: %w\\\", err)\\n   438→\\t}\\n   439→\\n   440→\\ttree, err := commit.Tree()\\n   441→\\tif err != nil {\\n   442→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch tree: %w\\\", err)\\n   443→\\t}\\n   444→\\treturn tree, nil\\n   445→}\\n   446→\\n   447→// ExtractFirstPrompt extracts and truncates the first meaningful prompt from prompt content.\\n   448→// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\". Skips empty prompts and separator-only content.\\n   449→// Returns empty string if no valid prompt is found.\\n   450→func ExtractFirstPrompt(content string) string {\\n   451→\\tif content == \\\"\\\" {\\n   452→\\t\\treturn \\\"\\\"\\n   453→\\t}\\n   454→\\n   455→\\t// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\"\\n   456→\\t// Find the first non-empty prompt\\n   457→\\tprompts := strings.Split(content, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   458→\\tvar firstPrompt string\\n   459→\\tfor _, p := range prompts {\\n   460→\\t\\tcleaned := strings.TrimSpace(p)\\n   461→\\t\\t// Skip empty prompts or prompts that are just dashes/separators\\n   462→\\t\\tif cleaned == \\\"\\\" || isOnlySeparators(cleaned) {\\n   463→\\t\\t\\tcontinue\\n   464→\\t\\t}\\n   465→\\t\\tfirstPrompt = cleaned\\n   466→\\t\\tbreak\\n   467→\\t}\\n   468→\\n   469→\\tif firstPrompt == \\\"\\\" {\\n   470→\\t\\treturn \\\"\\\"\\n   471→\\t}\\n   472→\\n   473→\\treturn TruncateDescription(firstPrompt, MaxDescriptionLength)\\n   474→}\\n   475→\\n   476→// ReadSessionPromptFromTree reads the first meaningful prompt from a checkpoint's prompt.txt file in a git tree.\\n   477→// Returns an empty string if the prompt cannot be read.\\n   478→func ReadSessionPromptFromTree(tree *object.Tree, checkpointPath string) string {\\n   479→\\tpromptPath := checkpointPath + \\\"/\\\" + paths.PromptFileName\\n   480→\\tfile, err := tree.File(promptPath)\\n   481→\\tif err != nil {\\n   482→\\t\\treturn \\\"\\\"\\n   483→\\t}\\n   484→\\n   485→\\tcontent, err := file.Contents()\\n   486→\\tif err != nil {\\n   487→\\t\\treturn \\\"\\\"\\n   488→\\t}\\n   489→\\n   490→\\treturn ExtractFirstPrompt(content)\\n   491→}\\n   492→\\n   493→// ReadAgentTypeFromTree reads the agent type from a checkpoint's metadata.json file in a git tree.\\n   494→// If metadata.json doesn't exist (shadow branches), it falls back to detecting the agent\\n   495→// from the presence of agent-specific config files (.gemini/settings.json or .claude/).\\n   496→// Returns agent.AgentTypeUnknown if the agent type cannot be determined.\\n   497→func ReadAgentTypeFromTree(tree *object.Tree, checkpointPath string) types.AgentType {\\n   498→\\t// First, try to read from metadata.json (present in condensed/committed checkpoints)\\n   499→\\tmetadataPath := checkpointPath + \\\"/\\\" + paths.MetadataFileName\\n   500→\\tif file, err := tree.File(metadataPath); err == nil {\\n   501→\\t\\tif content, err := file.Contents(); err == nil {\\n   502→\\t\\t\\tvar metadata checkpoint.CommittedMetadata\\n   503→\\t\\t\\tif err := json.Unmarshal([]byte(content), &metadata); err == nil && metadata.Agent != \\\"\\\" {\\n   504→\\t\\t\\t\\treturn metadata.Agent\\n   505→\\t\\t\\t}\\n   506→\\t\\t}\\n   507→\\t}\\n   508→\\n   509→\\t// Fall back to detecting agent from config files (shadow branches don't have metadata.json).\\n   510→\\t// Order: Gemini (most specific check), Claude (established default), OpenCode (newest/preview).\\n   511→\\tif _, err := tree.File(\\\".gemini/settings.json\\\"); err == nil {\\n   512→\\t\\treturn agent.AgentTypeGemini\\n   513→\\t}\\n   514→\\tif _, err := tree.Tree(\\\".claude\\\"); err == nil {\\n   515→\\t\\treturn agent.AgentTypeClaudeCode\\n   516→\\t}\\n   517→\\t// OpenCode: .opencode directory or opencode.json config\\n   518→\\tif _, err := tree.Tree(\\\".opencode\\\"); err == nil {\\n   519→\\t\\treturn agent.AgentTypeOpenCode\\n   520→\\t}\\n   521→\\tif _, err := tree.File(\\\"opencode.json\\\"); err == nil {\\n   522→\\t\\treturn agent.AgentTypeOpenCode\\n   523→\\t}\\n   524→\\n   525→\\treturn agent.AgentTypeUnknown\\n   526→}\\n   527→\\n   528→// isOnlySeparators checks if a string contains only dashes, spaces, and newlines.\\n   529→func isOnlySeparators(s string) bool {\\n   530→\\tfor _, r := range s {\\n   531→\\t\\tif r != '-' && r != ' ' && r != '\\\\n' && r != '\\\\r' && r != '\\\\t' {\\n   532→\\t\\t\\treturn false\\n   533→\\t\\t}\\n   534→\\t}\\n   535→\\treturn true\\n   536→}\\n   537→\\n   538→// ReadLatestSessionPromptFromCommittedTree reads the first prompt from a committed checkpoint's\\n   539→// latest session on the metadata branch tree. This navigates the sharded directory layout:\\n   540→// <cpID.Path()>/<latestSessionIndex>/prompt.txt\\n   541→//\\n   542→// This is an O(1) tree lookup that avoids reading the full transcript.\\n   543→// sessionCount is the number of sessions in the checkpoint (from CommittedInfo.SessionCount).\\n   544→func ReadLatestSessionPromptFromCommittedTree(tree *object.Tree, cpID id.CheckpointID, sessionCount int) string {\\n   545→\\tcpPath := cpID.Path()\\n   546→\\tcpTree, err := tree.Tree(cpPath)\\n   547→\\tif err != nil {\\n   548→\\t\\treturn \\\"\\\"\\n   549→\\t}\\n   550→\\n   551→\\t// Find the latest session subdirectory.\\n   552→\\t// Sessions use 0-based indexing: 0/, 1/, 2/, etc.\\n   553→\\tlatestIndex := sessionCount - 1\\n   554→\\tif latestIndex < 0 {\\n   555→\\t\\tlatestIndex = 0\\n   556→\\t}\\n   557→\\tsessionPath := strconv.Itoa(latestIndex)\\n   558→\\tsessionTree, err := cpTree.Tree(sessionPath)\\n   559→\\tif err != nil {\\n   560→\\t\\t// Fall back to session 0 if the computed index doesn't exist\\n   561→\\t\\tsessionTree, err = cpTree.Tree(\\\"0\\\")\\n   562→\\t\\tif err != nil {\\n   563→\\t\\t\\treturn \\