→\\trefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n   611→\\tref, err := repo.Reference(refName, true)\\n   612→\\tif err != nil {\\n   613→\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch reference: %w\\\", err)\\n   614→\\t}\\n   615→\\n   616→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   617→\\tif err != nil {\\n   618→\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch commit: %w\\\", err)\\n   619→\\t}\\n   620→\\n   621→\\ttree, err := commit.Tree()\\n   622→\\tif err != nil {\\n   623→\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch tree: %w\\\", err)\\n   624→\\t}\\n   625→\\treturn tree, nil\\n   626→}\\n   627→\\n   628→// OpenRepository opens the git repository with linked worktree support enabled.\\n   629→// It uses git.PlainOpenWithOptions with EnableDotGitCommonDir set to true,\\n   630→// which is required for proper operation in git worktrees created via 'git worktree add'.\\n   631→//\\n   632→// Without EnableDotGitCommonDir, go-git operations in worktrees can silently fail:\\n   633→// - Commits appear to succeed but are not persisted\\n   634→// - Refs are written to incorrect locations\\n   635→// - The worktree's HEAD/index don't get updated properly\\n   636→//\\n   637→// This happens because worktrees use .git as a file (pointing to the main repo)\\n   638→// rather than a directory, and go-git needs to route paths correctly between\\n   639→// shared (.git/) and per-worktree (.git/worktrees/<name>/) locations.\\n   640→//\\n   641→// The function first uses 'git rev-parse --show-toplevel' to find the repository\\n   642→// root, which works correctly even when called from a subdirectory within the repo.\\n   643→func OpenRepository(ctx context.Context) (*git.Repository, error) {\\n   644→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   645→\\tif err != nil {\\n   646→\\t\\t// Fallback to current directory if git command fails\\n   647