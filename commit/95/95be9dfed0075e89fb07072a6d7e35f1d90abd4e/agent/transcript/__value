\n   570→\\tif err != nil {\\n   571→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD tree: %w\\\", err)\\n   572→\\t}\\n   573→\\n   574→\\t// Build set of files tracked in HEAD\\n   575→\\ttrackedFiles := make(map[string]bool)\\n   576→\\t//nolint:errcheck // Error is not critical for preview\\n   577→\\t_ = headTree.Files().ForEach(func(f *object.File) error {\\n   578→\\t\\tif err := ctx.Err(); err != nil {\\n   579→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   580→\\t\\t}\\n   581→\\t\\ttrackedFiles[f.Name] = true\\n   582→\\t\\treturn nil\\n   583→\\t})\\n   584→\\n   585→\\t// Find untracked files that would be deleted.\\n   586→\\t// Uses git ls-files to only consider non-ignored files.\\n   587→\\tvar filesToDelete []string\\n   588→\\tuntrackedNow, untrackedErr := collectUntrackedFiles(ctx)\\n   589→\\tif untrackedErr != nil {\\n   590→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: could not list untracked files for preview: %v\\\\n\\\", untrackedErr)\\n   591→\\t\\treturn &RewindPreview{\\n   592→\\t\\t\\tFilesToRestore: filesToRestore,\\n   593→\\t\\t\\tFilesToDelete:  filesToDelete,\\n   594→\\t\\t}, nil\\n   595→\\t}\\n   596→\\tfor _, relPath := range untrackedNow {\\n   597→\\t\\tif checkpointFiles[relPath] {\\n   598→\\t\\t\\tcontinue\\n   599→\\t\\t}\\n   600→\\t\\tif trackedFiles[relPath] {\\n   601→\\t\\t\\tcontinue\\n   602→\\t\\t}\\n   603→\\t\\tif preservedUntrackedFiles[relPath] {\\n   604→\\t\\t\\tcontinue\\n   605→\\t\\t}\\n   606→\\t\\tfilesToDelete = append(filesToDelete, relPath)\\n   607→\\t}\\n   608→\\n   609→\\t// Sort for consistent output\\n   610→\\tsort.Strings(filesToRestore)\\n   611→\\tsort.Strings(filesToDelete)\\n   612→\\n   613→\\treturn &RewindPreview{\\n   614→\\t\\tFilesToRestore: filesToRestore,\\n   615→\\t\\tFilesToDelete:  filesToDelete,\\n   616→\\t}, nil\\n   617→}\\n   618→\\n   619→// RestoreLogsOnly restores session logs from a logs-only rewind point.\\n   620→// This fetches the