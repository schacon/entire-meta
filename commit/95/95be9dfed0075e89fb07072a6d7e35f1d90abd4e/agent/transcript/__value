x, limit)\\n    99→\\tif err == nil && len(logsOnlyPoints) > 0 {\\n   100→\\t\\t// Build set of existing point IDs for deduplication\\n   101→\\t\\texistingIDs := make(map[string]bool)\\n   102→\\t\\tfor _, p := range allPoints {\\n   103→\\t\\t\\texistingIDs[p.ID] = true\\n   104→\\t\\t}\\n   105→\\n   106→\\t\\t// Add logs-only points that aren't already in the list\\n   107→\\t\\tfor _, p := range logsOnlyPoints {\\n   108→\\t\\t\\tif !existingIDs[p.ID] {\\n   109→\\t\\t\\t\\tallPoints = append(allPoints, p)\\n   110→\\t\\t\\t}\\n   111→\\t\\t}\\n   112→\\n   113→\\t\\t// Re-sort by date\\n   114→\\t\\tsort.Slice(allPoints, func(i, j int) bool {\\n   115→\\t\\t\\treturn allPoints[i].Date.After(allPoints[j].Date)\\n   116→\\t\\t})\\n   117→\\n   118→\\t\\t// Re-trim to limit\\n   119→\\t\\tif len(allPoints) > limit {\\n   120→\\t\\t\\tallPoints = allPoints[:limit]\\n   121→\\t\\t}\\n   122→\\t}\\n   123→\\n   124→\\treturn allPoints, nil\\n   125→}\\n   126→\\n   127→// GetLogsOnlyRewindPoints finds commits in the current branch's history that have\\n   128→// condensed session logs on the entire/checkpoints/v1 branch. These are commits that\\n   129→// were created with session data but the shadow branch has been condensed.\\n   130→//\\n   131→// The function works by:\\n   132→// 1. Getting all checkpoints from the entire/checkpoints/v1 branch\\n   133→// 2. Building a map of checkpoint ID -> checkpoint info\\n   134→// 3. Scanning the current branch history for commits with Entire-Checkpoint trailers\\n   135→// 4. Matching by checkpoint ID (stable across amend/rebase)\\n   136→func (s *ManualCommitStrategy) GetLogsOnlyRewindPoints(ctx context.Context, limit int) ([]RewindPoint, error) {\\n   137→\\trepo, err := OpenRepository(ctx)\\n   138→\\tif err != nil {\\n   139→\\t\\treturn nil, err\\n   140→\\t}\\n   141→\\n   142→\\t// Get all checkpoints from entire/checkpoints/v1 branch\\n   143→\\tcheckpoints, err := s.listCheckpoints(ctx)\\n   144→\\tif err != nil {\\n   145→\\t\\t// No checkpoints yet is fine\\n   146→\\t\\treturn nil, nil //nolint:nilerr // Expected when no checkpoints exist\\n   147→\\t}\\n   148→\\n   149→\\tif len(checkpoints) == 0 {\\n   150→\\t\\treturn nil, nil\\n   151→\\t}\\n   152→\\n   153→\\t// Build map of checkpoint ID -> checkpoint info\\n   154→\\t// Checkpoint ID is the stable link from Entire-Checkpoint trailer\\n   155→\\tcheckpointInfoMap := make(map[id.CheckpointID]CheckpointInfo)\\n   156→\\tfor _, cp := range checkpoints {\\n   157→\\t\\tif !cp.CheckpointID.IsEmpty() {\\n   158→\\t\\t\\tcheckpointInfoMap[cp.CheckpointID] = cp\\n   159→\\t\\t}\\n   160→\\t}\\n   161→\\n   162→\\t// Get metadata branch tree for reading session prompts (best-effort, ignore errors)\\n   163→\\tmetadataTree, _ := GetMetadataBranchTree(repo) //nolint:errcheck // Best-effort for session prompts\\n   164→\\n   165→\\thead, err := repo.Head()\\n   166→\\tif err != nil {\\n   167→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   168→\\t}\\n   169→\\n   170→\\t// Use LogOptions with Order=LogOrderCommitterTime to traverse all parents of merge commits.\\n   171→\\titer, err := repo.Log(&git.LogOptions{\\n   172→\\t\\tFrom:  head.Hash(),\\n   173→\\t\\tOrder: git.LogOrderCommitterTime,\\n   174→\\t})\\n   175→\\tif err != nil {\\n   176→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   177→\\t}\\n   178→\\n   179→\\tvar points []RewindPoint\\n   180→\\tcount := 0\\n   181→\\n   182→\\terr = iter.ForEach(func(c *object.Commit) error {\\n   183→\\t\\tif err := ctx.Err(); err != nil {\\n   184→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   185→\\t\\t}\\n   186→\\t\\tif count >= logsOnlyScanLimit {\\n   187→\\t\\t\\treturn errStop\\n   188→\\t\\t}\\n   189→\\t\\tcount++\\n   190→\\n   191→\\t\\t// Extract checkpoint ID from Entire-Checkpoint trailer (ParseCheckpoint validates format)\\n   192→\\t\\tcpID, found := trailers.ParseCheckpoint(c.Message)\\n   193→\\t\\tif !found {\\n   194→\\t\\t\\treturn nil\\n   195→\\t\\t}\\n   196→\\t\\t// Check if this checkpoint ID has metadata on entire/checkpoints/v1\\n   197→\\t\\tcpInfo, found := checkpointInfoMap[cpID]\\n   198→\\t\\tif !found {\\n   199→\\t\\t\\treturn nil\\n   200→\\t\\t}\\n   201→\\n   202→\\t\\t// Create logs-only rewind point\\n   203→\\t\\tmessage := strings.Split(c.Message, \\\"\\\\n\\\")[0]\\n   204→\\n   205→\\t\\t// Read session prompts from metadata tree\\n   206→\\t\\tvar sessionPrompt string\\n   207→\\t\\tvar sessionPrompts []string\\n   208→\\t\\tif metadataTree != nil {\\n   209→\\t\\t\\tcheckpointPath := paths.CheckpointPath(cpInfo.CheckpointID) //nolint:staticcheck // already present in codebase\\n   210→\\t\\t\\t// For multi-session checkpoints, read all prompts\\n   211→\\t\\t\\tif cpInfo.SessionCount > 1 && len(cpInfo.SessionIDs) > 1 {\\n   212→\\t\\t\\t\\tsessionPrompts = ReadAllSessionPromptsFromTree(metadataTree, checkpointPath, cpInfo.SessionCount, cpInfo.SessionIDs)\\n   213→\\t\\t\\t\\t// Use the last (most recent) prompt as the main session prompt\\n   214→\\t\\t\\t\\tif len(sessionPrompts) > 0 {\\n   215→\\t\\t\\t\\t\\tsessionPrompt = sessionPrompts[len(sessionPrompts)-1]\\n   216→\\t\\t\\t\\t}\\n   217→\\t\\t\\t} else {\\n   218→\\t\\t\\t\\tsessionPrompt = ReadSessionPromptFromTree(metadataTree, checkpointPath)\\n   219→\\t\\t\\t\\tif sessionPrompt != \\\"\\\" {\\n   220→\\t\\t\\t\\t\\tsessionPrompts = []string{sessionPrompt}\\n   221→\\t\\t\\t\\t}\\n   222→\\t\\t\\t}\\n   223→\\t\\t}\\n   224→\\n   225→\\t\\tpoints = append(points, RewindPoint{\\n   226→\\t\\t\\tID:             c.Hash.String(),\\n   227→\\t\\t\\tMessage:        message,\\n   228→\\t\\t\\tDate:           c.Author.When,\\n   229→\\t\\t\\tIsLogsOnly:     true,\\n   230→\\t\\t\\tCheckpointID:   cpInfo.CheckpointID,\\n   231→\\t\\t\\tAgent:          cpInfo.Agent,\\n   232→\\t\\t\\tSessionID:      cpInfo.SessionID,\\n   233→\\t\\t\\tSessionPrompt:  sessionPrompt,\\n   234→\\t\\t\\tSessionCount:   cpInfo.SessionCount,\\n   235→\\t\\t\\tSessionIDs:     cpInfo.SessionIDs,\\n   236→\\t\\t\\tSessionPrompts: sessionPrompts,\\n   237→\\t\\t})\\n   238→\\n   239→\\t\\treturn nil\\n   240→\\t})\\n   241→\\n   242→\\tif err != nil && !errors.Is(err, errStop) {\\n   243→\\t\\treturn nil, fmt.Errorf(\\\"error iterating commits: %w\\\", err)\\n   244→\\t}\\n   245→\\n   246→\\tif len(points) > limit {\\n   247→\\t\\tpoints = points[:limit]\\n   248→\\t}\\n   249→\\n   250→\\treturn points, nil\\n   251→}\\n   252→\\n   253→// Rewind restores the working directory to a checkpoint.\\n   254→//\\n   255→\\n   256→func (s *ManualCommitStrategy) Rewind(ctx context.Context, point RewindPoint) error {\\n   257→\\trepo, err := OpenRepository(ctx)\\n   258→\\tif err != nil {\\n   259→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   260→\\t}\\n   261→\\n   262→\\t// Get the checkpoint commit\\n   263→\\tcommitHash := plumbing.NewHash(point.ID)\\n   264→\\tcommit, err := repo.CommitObject(commitHash)\\n   265→\\tif err != nil {\\n   266→\\t\\treturn fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   267→\\t}\\n   268→\\n   269→\\ttree, err := commit.Tree()\\n   270→\\tif err != nil {\\n   271→\\t\\treturn fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n   272→\\t}\\n   273→\\n   274→\\t// Reset the shadow branch to the rewound checkpoint\\n   275→\\t// This ensures the next checkpoint will only include prompts from this point forward\\n   276→\\tif err := s.resetShadowBranchToCheckpoint(ctx, repo, commit); err != nil {\\n   277→\\t\\t// Log warning but don't fail - file restoration is the primary operation\\n   278→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to reset shadow branch: %v\\\\n\\\", err)\\n   279→\\t}\\n   280→\\n   281→\\t// Load session state to get untracked files that existed at session start\\n   282→\\tsessionID, hasSessionTrailer := trailers.ParseSession(commit.Message)\\n   283→\\tvar preservedUntrackedFiles map[string]bool\\n   284→\\tif hasSessionTrailer {\\n   285→\\t\\tstate, stateErr := s.loadSessionState(ctx, sessionID)\\n   286→\\t\\tif stateErr == nil && state != nil && len(state.UntrackedFilesAtStart) > 0 {\\n   287→\\t\\t\\tpreservedUntrackedFiles = make(map[string]bool)\\n   288→\\t\\t\\tfor _, f := range state.UntrackedFilesAtStart {\\n   289→\\t\\t\\t\\tpreservedUntrackedFiles[f] = true\\n   290→\\t\\t\\t}\\n   291→\\t\\t}\\n   292→\\t}\\n   293→\\n   294→\\t// Build set of files in the checkpoint tree (excluding metadata)\\n   295→\\tcheckpointFiles := make(map[string]bool)\\n   296→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   297→\\t\\tif err := ctx.Err(); err != nil {\\n   298→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   299→\\t\\t}\\n   300→\\t\\tif !strings.HasPrefix(f.Name, entireDir) {\\n   301→\\t\\t\\tcheckpointFiles[f.Name] = true\\n   302→\\t\\t}\\n   303→\\t\\treturn nil\\n   304→\\t})\\n   305→\\tif err != nil {\\n   306→\\t\\treturn fmt.Errorf(\\\"failed to list checkpoint files: %w\\\", err)\\n   307→\\t}\\n   308→\\n   309→\\t// Get HEAD tree to identify tracked files\\n   310→\\thead, err := repo.Head()\\n   311→\\tif err != nil {\\n   312→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   313→\\t}\\n   314→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   315→\\tif err != nil {\\n   316→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   317→\\t}\\n   318→\\theadTree, err := headCommit.Tree()\\n   319→\\tif err != nil {\\n   320→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD tree: %w\\\", err)\\n   321→\\t}\\n   322→\\n   323→\\t// Build set of files tracked in HEAD\\n   324→\\ttrackedFiles := make(map[string]bool)\\n   325→\\t//nolint:errcheck // Error is not critical for rewind\\n   326→\\t_ = headTree.Files().ForEach(func(f *object.File) error {\\n   327→\\t\\tif err := ctx.Err(); err != nil {\\n   328→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   329→\\t\\t}\\n   330→\\t\\ttrackedFiles[f.Name] = true\\n   331→\\t\\treturn nil\\n   332→\\t})\\n   333→\\n   334→\\t// Get repository root to walk from there\\n   335→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   336→\\tif err != nil {\\n   337→\\t\\trepoRoot = \\\".\\\" // Fallback to current directory\\n   338→\\t}\\n   339→\\n   340→\\t// Find and delete untracked files that aren't in the checkpoint.\\n   341→\\t// Uses git ls-files to only consider non-ignored files, avoiding walks through\\n   342→\\t// large ignored directories like node_modules/.\\n   343→\\tuntrackedNow, err := collectUntrackedFiles(ctx)\\n   344→\\tif err != nil {\\n   345→\\t\\t// Non-fatal - continue with restoration\\n   346→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: error listing untracked files: %v\\\\n\\\", err)\\n   347→\\t}\\n   348→\\tfor _, relPath := range untrackedNow {\\n   349→\\t\\t// If file is in checkpoint, it will be restored\\n   350→\\t\\tif checkpointFiles[relPath] {\\n   351→\\t\\t\\tcontinue\\n   352→\\t\\t}\\n   353→\\n   354→\\t\\t// If file is tracked in HEAD, don't delete (user's committed work)\\n   355→\\t\\tif trackedFiles[relPath] {\\n   356→\\t\\t\\tcontinue\\n   357→\\t\\t}\\n   358→\\n   359→\\t\\t// If file existed at session start, preserve it (untracked user files)\\n   360→\\t\\tif preservedUntrackedFiles[relPath] {\\n   361→\\t\\t\\tcontinue\\n   362→\\t\\t}\\n   363→\\n   364→\\t\\t// File is untracked and not in checkpoint - delete it\\n   365→\\t\\tabsPath := filepath.Join(repoRoot, relPath)\\n   366→\\t\\tif removeErr := os.Remove(absPath); removeErr == nil {\\n   367→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Deleted: %s\\\\n\\\", relPath)\\n   368→\\t\\t}\\n   369→\\t}\\n   370→\\n   371→\\t// Restore files from checkpoint\\n   372→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   373→\\t\\tif err := ctx.Err(); err != nil {\\n   374→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   375→\\t\\t}\\n   376→\\t\\t// Skip metadata directories - these are for checkpoint storage, not working dir\\n   377→\\t\\tif strings.HasPrefix(f.Name, entireDir) {\\n   378→\\t\\t\\treturn nil\\n   379→\\t\\t}\\n   380→\\n   381→\\t\\tcontents, err := f.Contents()\\n   382→\\t\\tif err != nil {\\n   383→\\t\\t\\treturn fmt.Errorf(\\\"failed to read file %s: %w\\\", f.Name, err)\\n   384→\\t\\t}\\n   385→\\n   386→\\t\\t// Ensure directory exists\\n   387→\\t\\tdir := filepath.Dir(f.Name)\\n   388→\\t\\tif dir != \\\".\\\" {\\n   389→\\t\\t\\t//nolint:gosec // G301: Need 0o755 for user directories during rewind\\n   390→\\t\\t\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   391→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to create directory %s: %w\\\", dir, err)\\n   392→\\t\\t\\t}\\n   393→\\t\\t}\\n   394→\\n   395→\\t\\t// Write file with appropriate permissions\\n   396→\\t\\tvar perm os.FileMode = 0o644\\n   397→\\t\\tif f.Mode == filemode.Executable {\\n   398→\\t\\t\\tperm = 0o755\\n   399→\\t\\t}\\n   400→\\t\\tif err := os.WriteFile(f.Name, []byte(contents), perm); err != nil {\\n   401→\\t\\t\\treturn fmt.Errorf(\\\"failed to write file %s: %w\\\", f.Name, err)\\n   402→\\t\\t}\\n   403→\\n   404→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Restored: %s\\\\n\\\", f.Name)\\n   405→\\t\\treturn nil\\n   406→\\t})\\n   407→\\tif err != nil {\\n   408→\\t\\treturn fmt.Errorf(\\\"failed to iterate tree files: %w\\\", err)\\n   409→\\t}\\n   410→\\n   411→\\tfmt.Println()\\n   412→\\tif len(point.ID) >= 7 {\\n   413→\\t\\tfmt.Printf(\\\"Restored files from shadow commit %s\\\\n\\\", point.ID[:7])\\n   414→\\t} else {\\n   415→\\t\\tfmt.Printf(\\\"Restored files from shadow commit %s\\\\n\\\", point.ID)\\n   416→\\t}\\n   417→\\tfmt.Println()\\n   418→\\n   419→\\treturn nil\\n   420→}\\n   421→\\n   422→// resetShadowBranchToCheckpoint resets the shadow branch HEAD to the given checkpoint.\\n   423→// This ensures that when the user commits after rewinding, the next checkpoint will only\\n   424→// include prompts from the rewound point, not prompts from later checkpoints.\\n   425→func (s *ManualCommitStrategy) resetShadowBranchToCheckpoint(ctx context.Context, repo *git.Repository, commit *object.Commit) error {\\n   426→\\t// Extract session ID from the checkpoint commit's Entire-Session trailer\\n   427→\\tsessionID, found := trailers.ParseSession(commit.Message)\\n   428→\\tif !found {\\n   429→\\t\\treturn errors.New(\\\"checkpoint has no Entire-Session trailer\\\")\\n   430→\\t}\\n   431→\\n   432→\\t// Load session state to get the shadow branch name\\n   433→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   434→\\tif err != nil {\\n   435→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   436→\\t}\\n   437→\\tif state == nil {\\n   438→\\t\\treturn fmt.Errorf(\\\"session %s not found\\\", sessionID)\\n   439→\\t}\\n   440→\\n   441→\\t// Reset the shadow branch to the checkpoint commit\\n   442→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   443→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   444→\\n   445→\\t// Update the reference to point to the checkpoint commit\\n   446→\\tref := plumbing.NewHashReference(refName, commit.Hash)\\n   447→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   448→\\t\\treturn fmt.Errorf(\\\"failed to update shadow branch: %w\\\", err)\\n   449→\\t}\\n   450→\\n   451→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Reset shadow branch %s to checkpoint %s\\\\n\\\", shadowBranchName, commit.Hash.String()[:7])\\n   452→\\treturn nil\\n   453→}\\n   454→\\n   455→// CanRewind checks if rewinding is possible.\\n   456→// For manual-commit strategy, rewind restores files from a checkpoint - uncommitted changes are expected\\n   457→// and will be replaced by the checkpoint contents. Returns true with a warning message showing\\n   458→// what changes will be reverted.\\n   459→func (s *ManualCommitStrategy) CanRewind(ctx context.Context) (bool, string, error) {\\n   460→\\treturn checkCanRewindWithWarning(ctx)\\n   461→}\\n   462→\\n   463→// PreviewRewind returns what will happen if rewinding to the given point.\\n   464→// This allows showing warnings about untracked files that will be deleted.\\n   465→func (s *ManualCommitStrategy) PreviewRewind(ctx context.Context, point RewindPoint) (*RewindPreview, error) {\\n   466→\\t// Logs-only points don't modify the working directory\\n   467→\\tif point.IsLogsOnly {\\n   468→\\t\\treturn &RewindPreview{}, nil\\n   469→\\t}\\n   470→\\n   471→\\trepo, err := OpenRepository(ctx)\\n   472→\\tif err != nil {\\n   473→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   474→\\t}\\n   475→\\n   476→\\t// Get the checkpoint commit\\n   477→\\tcommitHash := plumbing.NewHash(point.ID)\\n   478→\\tcommit, err := repo.CommitObject(commitHash)\\n   479→\\tif err != nil {\\n   480→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   481→\\t}\\n   482→\\n   483→\\ttree, err := commit.Tree()\\n   484→\\tif err != nil {\\n   485→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n   486→\\t}\\n   487→\\n   488→\\t// Load session state to get untracked files that existed at session start\\n   489→\\tsessionID, hasSessionTrailer := trailers.ParseSession(commit.Message)\\n   490→\\tvar preservedUntrackedFiles map[string]bool\\n   491→\\tif hasSessionTrailer {\\n   492→\\t\\tstate, stateErr := s.loadSessionState(ctx, sessionID)\\n   493→\\t\\tif stateErr == nil && state != nil && len(state.UntrackedFilesAtStart) > 0 {\\n   494→\\t\\t\\tpreservedUntrackedFiles = make(map[string]bool)\\n   495→\\t\\t\\tfor _, f := range state.UntrackedFilesAtStart {\\n   496→\\t\\t\\t\\tpreservedUntrackedFiles[f] = true\\n   497→\\t\\t\\t}\\n   498→\\t\\t}\\n   499→\\t}\\n   500→\\n   501→\\t// Build set of files in the checkpoint tree (excluding metadata)\\n   502→\\tcheckpointFiles := make(map[string]bool)\\n   503→\\tvar filesToRestore []string\\n   504→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   505→\\t\\tif err := ctx.Err(); err != nil {\\n   506→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   507→\\t\\t}\\n   508→\\t\\tif !strings.HasPrefix(f.Name, entireDir) {\\n   509→\\t\\t\\tcheckpointFiles[f.Name] = true\\n   510→\\t\\t\\tfilesToRestore = append(filesToRestore, f.Name)\\n   511→\\t\\t}\\n   512→\\t\\treturn nil\\n   513→\\t})\\n   514→\\tif err != nil {\\n   515→\\t\\treturn nil, fmt.Errorf(\\\"failed to list checkpoint files: %w\\\", err)\\n   516→\\t}\\n   517→\\n   518→\\t// Get HEAD tree to identify tracked files\\n   519→\\thead, err := repo.Head()\\n   520→\\tif err != nil {\\n   521→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   522→\\t}\\n   523→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   524→\\tif err != nil {\\n   525→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   526→\\t}\\n   527→\\theadTree, err := headCommit.Tree()\\n   528→\\tif err != nil {\\n   529→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD tree: %w\\\", err)\\n   530→\\t}\\n   531→\\n   532→\\t// Build set of files tracked in HEAD\\n   533→\\ttrackedFiles := make(map[string]bool)\\n   534→\\t//nolint:errcheck // Error is not critical for preview\\n   535→\\t_ = headTree.Files().ForEach(func(f *object.File) error {\\n   536→\\t\\tif err := ctx.Err(); err != nil {\\n   537→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   538→\\t\\t}\\n   539→\\t\\ttrackedFiles[f.Name] = true\\n   540→\\t\\treturn nil\\n   541→\\t})\\n   542→\\n   543→\\t// Find untracked files that would be deleted.\\n   544→\\t// Uses git ls-files to only consider non-ignored files.\\n   545→\\tvar filesToDelete []string\\n   546→\\tuntrackedNow, untrackedErr := collectUntrackedFiles(ctx)\\n   547→\\tif untrackedErr != nil {\\n   548→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: could not list untracked files for preview: %v\\\\n\\\", untrackedErr)\\n   549→\\t\\treturn &RewindPreview{\\n   550→\\t\\t\\tFilesToRestore: filesToRestore,\\n   551→\\t\\t\\tFilesToDelete:  filesToDelete,\\n   552→\\t\\t}, nil\\n   553→\\t}\\n   554→\\tfor _, relPath := range untrackedNow {\\n   555→\\t\\tif checkpointFiles[relPath] {\\n   556→\\t\\t\\tcontinue\\n   557→\\t\\t}\\n   558→\\t\\tif trackedFiles[relPath] {\\n   559→\\t\\t\\tcontinue\\n   560→\\t\\t}\\n   561→\\t\\tif preservedUntrackedFiles[relPath] {\\n   562→\\t\\t\\tcontinue\\n   563→\\t\\t}\\n   564→\\t\\tfilesToDelete = append(filesToDelete, relPath)\\n   565→\\t}\\n   566→\\n   567→\\t// Sort for consistent output\\n   568→\\tsort.Strings(filesToRestore)\\n   569→\\tsort.Strings(filesToDelete)\\n   570→\\n   571→\\treturn &RewindPreview{\\n   572→\\t\\tFilesToRestore: filesToRestore,\\n   573→\\t\\tFilesToDelete:  filesToDelete,\\n   574→\\t}, nil\\n   575→}\\n   576→\\n   577→// RestoreLogsOnly restores session logs from a logs-only rewind point.\\n   578→// This fetches the transcript from entire/checkpoints/v1 and writes it to the agent's session directory.\\n   579→// Does not modify the working directory.\\n   580→// When multiple sessions were condensed to the same checkpoint, ALL sessions are restored.\\n   581→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   582→// Returns info about each restored session so callers can print correct per-session resume commands.\\n   583→func (s *ManualCommitStrategy) RestoreLogsOnly(ctx context.Context, point RewindPoint, force bool) ([]RestoredSession, error) {\\n   584→\\tif !point.IsLogsOnly {\\n   585→\\t\\treturn nil, errors.New(\\\"not a logs-only rewind point\\\")\\n   586→\\t}\\n   587→\\n   588→\\tif point.CheckpointID.IsEmpty() {\\n   589→\\t\\treturn nil, errors.New(\\\"missing checkpoint ID\\\")\\n   590→\\t}\\n   591→\\n   592→\\t// Get checkpoint store\\n   593→\\tstore, err := s.getCheckpointStore()\\n   594→\\tif err != nil {\\n   595→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   596→\\t}\\n   597→\\n   598→\\t// Read checkpoint summary to get session count\\n   599→\\tsummary, err := store.ReadCommitted(ctx, point.CheckpointID)\\n   600→\\tif err != nil {\\n   601→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   602→\\t}\\n   603→\\tif summary == nil {\\n   604→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", point.CheckpointID)\\n   605→\\t}\\n   606→\\n   607→\\t// Get worktree root for agent session directory lookup\\n   608→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   609→\\tif err != nil {\\n   610→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   611→\\t}\\n   612→\\n   613→\\t// Check for newer local logs if not forcing\\n   614→\\tif !force {\\n   615→\\t\\tsessions := s.classifySessionsForRestore(ctx, repoRoot, store, point.CheckpointID, summary)\\n   616→\\t\\thasConflicts := false\\n   617→\\t\\tfor _, sess := range sessions {\\n   618→\\t\\t\\tif sess.Status == StatusLocalNewer {\\n   619→\\t\\t\\t\\thasConflicts = true\\n   620→\\t\\t\\t\\tbreak\\n   621→\\t\\t\\t}\\n   622→\\t\\t}\\n   623→\\t\\tif hasConflicts {\\n   624→\\t\\t\\tshouldOverwrite, promptErr := PromptOverwriteNewerLogs(sessions)\\n   625→\\t\\t\\tif promptErr != nil {\\n   626→\\t\\t\\t\\treturn nil, promptErr\\n   627→\\t\\t\\t}\\n   628→\\t\\t\\tif !shouldOverwrite {\\n   629→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled. Local session logs preserved.\\\\n\\\")\\n   630→\\t\\t\\t\\treturn nil, nil\\n   631→\\t\\t\\t}\\n   632→\\t\\t}\\n   633→\\t}\\n   634→\\n   635→\\t// Count sessions to restore\\n   636→\\ttotalSessions := len(summary.Sessions)\\n   637→\\tif totalSessions > 1 {\\n   638→\\t\\tfmt.Fprintf(os.Stderr, \\\"Restoring %d sessions from checkpoint:\\\\n\\\", totalSessions)\\n   639→\\t}\\n   640→\\n   641→\\t// Restore all sessions (oldest to newest, using 0-based indexing)\\n   642→\\tvar restored []RestoredSession\\n   643→\\tfor i := range totalSessions {\\n   644→\\t\\tcontent, readErr := store.ReadSessionContent(ctx, point.CheckpointID, i)\\n   645→\\t\\tif readErr != nil {\\n   646→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: failed to read session %d: %v\\\\n\\\", i, readErr)\\n   647→\\t\\t\\tcontinue\\n   648→\\t\\t}\\n   649→\\t\\tif content == nil || len(content.Transcript) == 0 {\\n   650→\\t\\t\\tcontinue\\n   651→\\t\\t}\\n   652→\\n   653→\\t\\tsessionID := content.Metadata.SessionID\\n   654→\\t\\tif sessionID == \\\"\\\" {\\n   655→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d has no session ID, skipping\\\\n\\\", i)\\n   656→\\t\\t\\tcontinue\\n   657→\\t\\t}\\n   658→\\n   659→\\t\\t// Resolve per-session agent from metadata — skip if agent is unknown\\n   660→\\t\\tif content.Metadata.Agent == \\\"\\\" {\\n   661→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d (%s) has no agent metadata, skipping (cannot determine target directory)\\\\n\\\", i, sessionID)\\n   662→\\t\\t\\tcontinue\\n   663→\\t\\t}\\n   664→\\t\\tsessionAgent, agErr := ResolveAgentForRewind(content.Metadata.Agent)\\n   665→\\t\\tif agErr != nil {\\n   666→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d (%s) has unknown agent %q, skipping\\\\n\\\", i, sessionID, content.Metadata.Agent)\\n   667→\\t\\t\\tcontinue\\n   668→\\t\\t}\\n   669→\\n   670→\\t\\t// Compute transcript path from current repo location for cross-machine portability.\\n   671→\\t\\tsessionAgentDir, dirErr := sessionAgent.GetSessionDir(repoRoot)\\n   672→\\t\\tif dirErr != nil {\\n   673→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: failed to get session dir for session %d: %v\\\\n\\\", i, dirErr)\\n   674→\\t\\t\\tcontinue\\n   675→\\t\\t}\\n   676→\\t\\tsessionFile := sessionAgent.ResolveSessionFile(sessionAgentDir, sessionID)\\n   677→\\n   678→\\t\\t// Get first prompt for display\\n   679→\\t\\tpromptPreview := ExtractFirstPrompt(content.Prompts)\\n   680→\\n   681→\\t\\tif totalSessions > 1 {\\n   682→\\t\\t\\tisLatest := i == totalSessions-1\\n   683→\\t\\t\\tif promptPreview != \\\"\\\" {\\n   684→\\t\\t\\t\\tif isLatest {\\n   685→\\t\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Session %d (latest): %s\\\\n\\\", i+1, promptPreview)\\n   686→\\t\\t\\t\\t} else {\\n   687→\\t\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Session %d: %s\\\\n\\\", i+1, promptPreview)\\n   688→\\t\\t\\t\\t}\\n   689→\\t\\t\\t}\\n   690→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"    Writing to: %s\\\\n\\\", sessionFile)\\n   691→\\t\\t} else {\\n   692→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Writing transcript to: %s\\\\n\\\", sessionFile)\\n   693→\\t\\t}\\n   694→\\n   695→\\t\\t// Ensure parent directory exists (session file may be in a different dir than sessionAgentDir)\\n   696→\\t\\tif mkdirErr := os.MkdirAll(filepath.Dir(sessionFile), 0o750); mkdirErr != nil {\\n   697→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"    Warning: failed to create directory: %v\\\\n\\\", mkdirErr)\\n   698→\\t\\t\\tcontinue\\n   699→\\t\\t}\\n   700→\\n   701→\\t\\tagentSession := &agent.AgentSession{\\n   702→\\t\\t\\tSessionID:  sessionID,\\n   703→\\t\\t\\tAgentName:  sessionAgent.Name(),\\n   704→\\t\\t\\tRepoPath:   repoRoot,\\n   705→\\t\\t\\tSessionRef: sessionFile,\\n   706→\\t\\t\\tNativeData: content.Transcript,\\n   707→\\t\\t}\\n   708→\\t\\tif writeErr := sessionAgent.WriteSession(ctx, agentSession); writeErr != nil {\\n   709→\\t\\t\\tif totalSessions > 1 {\\n   710→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"    Warning: failed to write session: %v\\\\n\\\", writeErr)\\n   711→\\t\\t\\t\\tcontinue\\n   712→\\t\\t\\t}\\n   713→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to write session: %w\\\", writeErr)\\n   714→\\t\\t}\\n   715→\\n   716→\\t\\trestored = append(restored, RestoredSession{\\n   717→\\t\\t\\tSessionID: sessionID,\\n   718→\\t\\t\\tAgent:     sessionAgent.Type(),\\n   719→\\t\\t\\tPrompt:    promptPreview,\\n   720→\\t\\t\\tCreatedAt: content.Metadata.CreatedAt,\\n   721→\\t\\t})\\n   722→\\t}\\n   723→\\n   724→\\treturn restored, nil\\n   725→}\\n   726→\\n   727→// ResolveAgentForRewind resolves the agent from checkpoint metadata.\\n   728→func ResolveAgentForRewind(agentType types.AgentType) (agent.Agent, error) {\\n   729→\\tag, err := agent.GetByAgentType(agentType)\\n   730→\\tif err != nil {\\n   731→\\t\\treturn nil, fmt.Errorf(\\\"resolving agent %q: %w\\\", agentType, err)\\n   732→\\t}\\n   733→\\treturn ag, nil\\n   734→}\\n   735→\\n   736→// readSessionPrompt reads the first prompt from the session's prompt.txt file stored in git.\\n   737→// Returns an empty string if the prompt cannot be read.\\n   738→func readSessionPrompt(repo *git.Repository, commitHash plumbing.Hash, metadataDir string) string {\\n   739→\\t// Get the commit and its tree\\n   740→\\tcommit, err := repo.CommitObject(commitHash)\\n   741→\\tif err != nil {\\n   742→\\t\\treturn \\\"\\\"\\n   743→\\t}\\n   744→\\n   745→\\ttree, err := commit.Tree()\\n   746→\\tif err != nil {\\n   747→\\t\\treturn \\\"\\\"\\n   748→\\t}\\n   749→\\n   750→\\t// Look for prompt.txt in the metadata directory\\n   751→\\tpromptPath := metadataDir + \\\"/\\\" + paths.PromptFileName\\n   752→\\tpromptEntry, err := tree.File(promptPath)\\n   753→\\tif err != nil {\\n   754→\\t\\treturn \\\"\\\"\\n   755→\\t}\\n   756→\\n   757→\\tcontent, err := promptEntry.Contents()\\n   758→\\tif err != nil {\\n   759→\\t\\treturn \\\"\\\"\\n   760→\\t}\\n   761→\\n   762→\\treturn ExtractFirstPrompt(content)\\n   763→}\\n   764→\\n   765→// SessionRestoreStatus represents the status of a session being restored.\\n   766→type SessionRestoreStatus int\\n   767→\\n   768→const (\\n   769→\\tStatusNew             SessionRestoreStatus = iota // Local file doesn't exist\\n   770→\\tStatusUnchanged                                   // Local and checkpoint are the same\\n   771→\\tStatusCheckpointNewer                             // Checkpoint has newer entries\\n   772→\\tStatusLocalNewer                                  // Local has newer entries (conflict)\\n   773→)\\n   774→\\n   775→// SessionRestoreInfo contains information about a session being restored.\\n   776→type SessionRestoreInfo struct {\\n   777→\\tSessionID      string\\n   778→\\tPrompt         string               // First prompt preview for display\\n   779→\\tStatus         SessionRestoreStatus // Status of this session\\n   780→\\tLocalTime      time.Time\\n   781→\\tCheckpointTime time.Time\\n   782→}\\n   783→\\n   784→// classifySessionsForRestore checks all sessions in a checkpoint and returns info\\n   785→// about each session, including whether local logs have newer timestamps.\\n   786→// repoRoot is used to compute per-session agent directories.\\n   787→// Sessions without agent metadata are skipped (cannot determine target directory).\\n   788→func (s *ManualCommitStrategy) classifySessionsForRestore(ctx context.Context, repoRoot string, store cpkg.Store, checkpointID id.CheckpointID, summary *cpkg.CheckpointSummary) []SessionRestoreInfo {\\n   789→\\tvar sessions []SessionRestoreInfo\\n   790→\\n   791→\\ttotalSessions := len(summary.Sessions)\\n   792→\\t// Check all sessions (0-based indexing)\\n   793→\\tfor i := range totalSessions {\\n   794→\\t\\tcontent, err := store.ReadSessionContent(ctx, checkpointID, i)\\n   795→\\t\\tif err != nil || content == nil || len(content.Transcript) == 0 {\\n   796→\\t\\t\\tcontinue\\n   797→\\t\\t}\\n   798→\\n   799→\\t\\tsessionID := content.Metadata.SessionID\\n   800→\\t\\tif sessionID == \\\"\\\" || content.Metadata.Agent == \\\"\\\" {\\n   801→\\t\\t\\tcontinue\\n   802→\\t\\t}\\n   803→\\n   804→\\t\\tsessionAgent, agErr := ResolveAgentForRewind(content.Metadata.Agent)\\n   805→\\t\\tif agErr != nil {\\n   806→\\t\\t\\tcontinue\\n   807→\\t\\t}\\n   808→\\n   809→\\t\\t// Compute transcript path from current repo location for cross-machine portability.\\n   810→\\t\\tsessionAgentDir, dirErr := sessionAgent.GetSessionDir(repoRoot)\\n   811→\\t\\tif dirErr != nil {\\n   812→\\t\\t\\tcontinue\\n   813→\\t\\t}\\n   814→\\t\\tlocalPath := sessionAgent.ResolveSessionFile(sessionAgentDir, sessionID)\\n   815→\\n   816→\\t\\tlocalTime := paths.GetLastTimestampFromFile(localPath)\\n   817→\\t\\tcheckpointTime := paths.GetLastTimestampFromBytes(content.Transcript)\\n   818→\\t\\tstatus := ClassifyTimestamps(localTime, checkpointTime)\\n   819→\\n   820→\\t\\tsessions = append(sessions, SessionRestoreInfo{\\n   821→\\t\\t\\tSessionID:      sessionID,\\n   822→\\t\\t\\tPrompt:         ExtractFirstPrompt(content.Prompts),\\n   823→\\t\\t\\tStatus:         status,\\n   824→\\t\\t\\tLocalTime:      localTime,\\n   825→\\t\\t\\tCheckpointTime: checkpointTime,\\n   826→\\t\\t})\\n   827→\\t}\\n   828→\\n   829→\\treturn sessions\\n   830→}\\n   831→\\n   832→// ClassifyTimestamps determines the restore status based on local and checkpoint timestamps.\\n   833→func ClassifyTimestamps(localTime, checkpointTime time.Time) SessionRestoreStatus {\\n   834→\\t// Local file doesn't exist (no timestamp found)\\n   835→\\tif localTime.IsZero() {\\n   836→\\t\\treturn StatusNew\\n   837→\\t}\\n   838→\\n   839→\\t// Can't determine checkpoint time - treat as new/safe\\n   840→\\tif checkpointTime.IsZero() {\\n   841→\\t\\treturn StatusNew\\n   842→\\t}\\n   843→\\n   844→\\t// Compare timestamps\\n   845→\\tif localTime.After(checkpointTime) {\\n   846→\\t\\treturn StatusLocalNewer\\n   847→\\t}\\n   848→\\tif checkpointTime.After(localTime) {\\n   849→\\t\\treturn StatusCheckpointNewer\\n   850→\\t}\\n   851→\\treturn StatusUnchanged\\n   852→}\\n   853→\\n   854→// StatusToText returns a human-readable status string.\\n   855→func StatusToText(status SessionRestoreStatus) string {\\n   856→\\tswitch status {\\n   857→\\tcase StatusNew:\\n   858→\\t\\treturn \\\"(new)\\\"\\n   859→\\tcase StatusUnchanged:\\n   860→\\t\\treturn \\\"(unchanged)\\\"\\n   861→\\tcase StatusCheckpointNewer:\\n   862→\\t\\treturn \\\"(checkpoint is newer)\\\"\\n   863→\\tcase StatusLocalNewer:\\n   864→\\t\\treturn \\\"(local is newer)\\\" // shouldn't appear in non-conflict list\\n   865→\\tdefault:\\n   866→\\t\\treturn \\\"\\\"\\n   867→\\t}\\n   868→}\\n   869→\\n   870→// PromptOverwriteNewerLogs asks the user for confirmation to overwrite local\\n   871→// session logs that have newer timestamps than the checkpoint versions.\\n   872→func PromptOverwriteNewerLogs(sessions []SessionRestoreInfo) (bool, error) {\\n   873→\\t// Separate conflicting and non-conflicting sessions\\n   874→\\tvar conflicting, nonConflicting []SessionRestoreInfo\\n   875→\\tfor _, s := range sessions {\\n   876→\\t\\tif s.Status == StatusLocalNewer {\\n   877→\\t\\t\\tconflicting = append(conflicting, s)\\n   878→\\t\\t} else {\\n   879→\\t\\t\\tnonConflicting = append(nonConflicting, s)\\n   880→\\t\\t}\\n   881→\\t}\\n   882→\\n   883→\\tfmt.Fprintf(os.Stderr, \\\"\\\\nWarning: Local session log(s) have newer entries than the checkpoint:\\\\n\\\")\\n   884→\\tfor _, info := range conflicting {\\n   885→\\t\\t// Show prompt if available, otherwise fall back to session ID\\n   886→\\t\\tif info.Prompt != \\\"\\\" {\\n   887→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  \\\\\\\"%s\\\\\\\"\\\\n\\\", info.Prompt)\\n   888→\\t\\t} else {\\n   889→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Session: %s\\\\n\\\", info.SessionID)\\n   890→\\t\\t}\\n   891→\\t\\tfmt.Fprintf(os.Stderr, \\\"    Local last entry:      %s\\\\n\\\", info.LocalTime.Local().Format(\\\"2006-01-02 15:04:05\\\"))\\n   892→\\t\\tfmt.Fprintf(os.Stderr, \\\"    Checkpoint last entry: %s\\\\n\\\", info.CheckpointTime.Local().Format(\\\"2006-01-02 15:04:05\\\"))\\n   893→\\t}\\n   894→\\n   895→\\t// Show non-conflicting sessions with their status\\n   896→\\tif len(nonConflicting) > 0 {\\n   897→\\t\\tfmt.F