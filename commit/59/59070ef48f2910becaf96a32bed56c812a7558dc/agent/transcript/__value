es) > 3 {\\n   115→\\t\\tlines = lines[:len(lines)-3]\\n   116→\\t}\\n   117→\\treturn strings.Join(lines, \\\"\\\\n\\\")\\n   118→}\\n   119→\\n   120→func (s *TmuxSession) WaitFor(pattern string, timeout time.Duration) (string, error) {\\n   121→\\tre, err := regexp.Compile(pattern)\\n   122→\\tif err != nil {\\n   123→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"invalid pattern: %w\\\", err)\\n   124→\\t}\\n   125→\\n   126→\\tdeadline := time.Now().Add(timeout)\\n   127→\\tvar matchedAt time.Time\\n   128→\\tvar lastStable string\\n   129→\\tcontentChanged := s.stableAtSend == \\\"\\\" // skip change requirement for initial waits\\n   130→\\n   131→\\tfor time.Now().Before(deadline) {\\n   132→\\t\\tcontent := s.Capture()\\n   133→\\t\\tstable := stableContent(content)\\n   134→\\n   135→\\t\\t// Bail early if the process has exited and the pattern doesn't match.\\n   136→\\t\\t// remain-on-exit keeps the pane alive, so without this check we'd\\n   137→\\t\\t// poll a dead pane for the full timeout duration.\\n   138→\\t\\tif !re.MatchString(content) {\\n   139→\\t\\t\\tif s.IsPaneDead() {\\n   140→\\t\\t\\t\\treturn content, fmt.Errorf(\\\"process exited while waiting for %q\\\\n--- pane content ---\\\\n%s\\\\n--- end pane content ---\\\", pattern, content)\\n   141→\\t\\t\\t}\\n   142→\\t\\t\\t// Pattern lost — reset\\n   143→\\t\\t\\tmatchedAt = time.Time{}\\n   144→\\t\\t\\tlastStable = \\\"\\\"\\n   145→\\t\\t\\ttime.Sleep(pollInterval)\\n   146→\\t\\t\\tcontinue\\n   147→\\t\\t}\\n   148→\\n   149→\\t\\t// Detect content change since Send was called\\n   150→\\t\\tif !contentChanged && stable != s.stableAtSend {\"}]},\"uuid\":\"ac0d6a0f-bdb7-44a2-bfff-b0b9546b3c7a\",\"timestamp\":\"2026-03-16T08:48:22.235Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"adb21441cd21363f7\"},\"toolUseID\":\"agent_msg_01GsUghYiGvsH78ajkViyFFd\",\"parentToolUseID\":\"toolu_01VqhZ6YnLWjw7rSK8mNWUKw\",\"uuid\":\"29049cdf-9fd8-4a45-9908-db97f902332d\",\"timestamp\":\"2026-