g {\\n    57→\\tregistryMu.RLock()\\n    58→\\tdefer registryMu.RUnlock()\\n    59→\\n    60→\\tnames := make([]string, 0, len(registry))\\n    61→\\tfor name, factory := range registry {\\n    62→\\t\\tif to, ok := factory().(TestOnly); ok && to.IsTestOnly() {\\n    63→\\t\\t\\tcontinue\\n    64→\\t\\t}\\n    65→\\t\\tnames = append(names, string(name))\\n    66→\\t}\\n    67→\\tslices.Sort(names)\\n    68→\\treturn names\\n    69→}\\n    70→\\n    71→// DetectAll returns all agents whose DetectPresence reports true.\\n    72→// Agents are checked in sorted name order (via List()) for deterministic results.\\n    73→// Returns an empty slice when no agent is detected.\\n    74→func DetectAll(ctx context.Context) []Agent {\\n    75→\\tnames := List() // sorted, lock-safe\\n    76→\\n    77→\\tvar detected []Agent\\n    78→\\tfor _, name := range names {\\n    79→\\t\\tag, err := Get(name)\\n    80→\\t\\tif err != nil {\\n    81→\\t\\t\\tcontinue\\n    82→\\t\\t}\\n    83→\\t\\tif present, err := ag.DetectPresence(ctx); err == nil && present {\\n    84→\\t\\t\\tdetected = append(detected, ag)\\n    85→\\t\\t}\\n    86→\\t}\\n    87→\\treturn detected\\n    88→}\\n    89→\\n    90→// Detect attempts to auto-detect which agent is being used.\\n    91→// Iterates registered agents in sorted name order for deterministic results.\\n    92→// Returns the first agent whose DetectPresence reports true.\\n    93→func Detect(ctx context.Context) (Agent, error) {\\n    94→\\tdetected := DetectAll(ctx)\\n    95→\\tif len(detected) == 0 {\\n    96→\\t\\treturn nil, fmt.Errorf(\\\"no agent detected (available: %v)\\\", List())\\n    97→\\t}\\n    98→\\treturn detected[0], nil\\n    99→}\\n   100→\\n   101→// Agent name constants (registry keys)\\n   102→const (\\n   103→\\tAgentNameClaudeCode     types.AgentName = \\\"claude-code\\\"\\n   104→\\tAgentNameCopilotCLI     types.AgentName = \\\"copilot-cli\\\"\\n   105→\\tAgentNameCursor         types.AgentName = \\\"cursor\\\"\\n   106→\\tAgentNameFactoryAIDroid types.AgentName = \\\"factoryai-droid\\\"\\n   107→\\tAgentNameGemini         types.AgentName = \\\"gemini\\\"\\n   108→\\tAgentNameOpenCode       types.AgentName = \\\"opencode\\\"\\n   109→)\\n   110→\\n   111→// Agent type constants (type identifiers stored in metadata/trailers)\\n   112→const (\\n   113→\\tAgentTypeClaudeCode     types.AgentType = \\\"Claude Code\\\"\\n   114→\\tAgentTypeCopilotCLI     types.AgentType = \\\"Copilot CLI\\\"\\n   115→\\tAgentTypeCursor         types.AgentType = \\\"Cursor\\\"\\n   116→\\tAgentTypeFactoryAIDroid types.AgentType = \\\"Factory AI Droid\\\"\\n   117→\\tAgentTypeGemini         types.AgentType = \\\"Gemini CLI\\\"\\n   118→\\tAgentTypeOpenCode       types.AgentType = \\\"OpenCode\\\"\\n   119→\\tAgentTypeUnknown        types.AgentType = \\\"Agent\\\" // Fallback for backwards compatibility\\n   120→)\\n   121→\\n   122→// DefaultAgentName is the registry key for the default agent.\\n   123→const DefaultAgentName types.AgentName = AgentNameClaudeCode\\n   124→\\n   125→// GetByAgentType retrieves an agent by its type identifier.\\n   126→//\\n   127→// Note: This uses a linear search that instantiates agents until a match is found.\\n   128→// This is acceptable because:\\n   129→//   - Agent count is small (~2-20 agents)\\n   130→//   - Agent factories are lightweight (empty struct allocation)\\n   131→//   - Called infrequently (commit hooks, rewind, debug commands - not hot paths)\\n   132→//   - Cost is ~400ns worst case vs milliseconds for I/O operations\\n   133→//\\n   134→// Only optimize if agent count exceeds 100 or profiling shows this as a bottleneck.\\n   135→func GetByAgentType(agentType types.AgentType) (Agent, error) {\\n   136→\\tregistryMu.RLock()\\n   137→\\tdefer registryMu.RUnlock()\\n   138→\\n   139→\\tfor _, factory := range registry {\\n   140→\\t\\tag := factory()\\n   141→\\t\\tif ag.Type() == agentType {\\n   142→\\t\\t\\treturn ag, nil\\n   143→\\t\\t}\\n   144→\\t}\\n   145→\\n   146→\\treturn nil, fmt.Errorf(\\\"unknown agent type: %s\\\", agentType)\\n   147→}\\n   148→\\n   149→// AllProtectedDirs returns the union of ProtectedDirs from all registered agents.\\n   150→func AllProtectedDirs() []string {\\n   151→\\t// Copy factories under the lock, then release before calling external code.\\n   152→\\tregistryMu.RLock()\\n   153→\\tfactories := make([]Factory, 0, len(registry))\\n   154→\\tfor _, f := range registry {\\n   155→\\t\\tfactories = append(factories, f)\\n   156→\\t}\\n   157→\\tregistryMu.RUnlock()\\n   158→\\n   159→\\tseen := make(map[string]struct{})\\n   160→\\tvar dirs []string\\n   161→\\tfor _, factory := range factories {\\n   162→\\t\\tfor _, d := range factory().ProtectedDirs() {\\n   163→\\t\\t\\tif _, ok := seen[d]; !ok {\\n   164→\\t\\t\\t\\tseen[d] = struct{}{}\\n   165→\\t\\t\\t\\tdirs = append(dirs, d)\\n   166→\\t\\t\\t}\\n   167→\\t\\t}\\n   168→\\t}\\n   169→\\tslices.Sort(dirs)\\n   170→\\treturn dirs\\n   171→}\\n   172→\\n   173→// Default returns the default agent.\\n   174→// Returns nil if the default agent is not registered.\\n   175→//\\n   176→//nolint:errcheck // Factory pattern returns interface; error is acceptable to ignore for default\\n   177→func Default() Agent {\\n   178→\\ta, _ := Get(DefaultAgentName)\\n   179→\\treturn a\\n   180→}\\n   181→\"}]},\"uuid\":\"1a4c4332-1dfa-4a21-ba6e-abf138630ad0\",\"timestamp\":\"2026-03-16T08:47:55.980Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"adb21441cd21363f7\"},\"toolUseID\":\"agent_msg_01GsUghYiGvsH78ajkViyFFd\",\"parentToolUseID\":\"toolu_01VqhZ6YnLWjw7rSK8mNWUKw\",\"uuid\":\"1f7c4582-abd6-431f-bf56-972d287733a9\",\"timestamp\":\"2026-03-16T08:47:55.984Z\",\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"1389d7d7-e618-4144-8a22-a19bc90b3c54\",\"version\":\"2.1.76\",\"gitBranch\":\"main\",\"slug\":\"delegated-fluttering-corbato\"}\n{\"parentUuid\":\"1f7c4582-abd6-431f-bf56-972d287733a9\