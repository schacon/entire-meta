\", err)\\n   281→\\t\\t\\t}\\n   282→\\t\\t\\tdefer agents.ReleaseSlot(agent)\\n   283→\\n   284→\\t\\t\\t// Per-test timeout starts after slot is acquired, scaled\\n   285→\\t\\t\\t// by the agent's multiplier (e.g. 2.5× for gemini).\\n   286→\\t\\t\\tscaled := time.Duration(float64(timeout) * agent.TimeoutMultiplier())\\n   287→\\n   288→\\t\\t\\tvar prevState *RepoState\\n   289→\\t\\t\\tfor attempt := range maxScenarioRestarts + 1 {\\n   290→\\t\\t\\t\\ts := SetupRepo(t, agent)\\n   291→\\t\\t\\t\\tctx, cancel := context.WithTimeout(context.Background(), scaled)\\n   292→\\n   293→\\t\\t\\t\\t// On restart, suppress artifact capture from the previous\\n   294→\\t\\t\\t\\t// failed attempt so it doesn't overwrite the final one.\\n   295→\\t\\t\\t\\tif prevState != nil {\\n   296→\\t\\t\\t\\t\\tprevState.skipArtifacts = true\\n   297→\\t\\t\\t\\t}\\n   298→\\n   299→\\t\\t\\t\\trestarted := runScenario(t, s, ctx, fn)\\n   300→\\t\\t\\t\\tcancel()\\n   301→\\n   302→\\t\\t\\t\\tif !restarted {\\n   303→\\t\\t\\t\\t\\treturn\\n   304→\\t\\t\\t\\t}\\n   305→\\t\\t\\t\\tprevState = s\\n   306→\\t\\t\\t\\tif attempt >= maxScenarioRestarts {\\n   307→\\t\\t\\t\\t\\tt.Fatalf(\\\"exhausted %d scenario attempts due to transient API errors\\\", maxScenarioRestarts+1)\\n   308→\\t\\t\\t\\t}\\n   309→\\t\\t\\t\\tt.Logf(\\\"transient error, restarting scenario (attempt %d/%d)\\\", attempt+2, maxScenarioRestarts+1)\\n   310→\\t\\t\\t}\\n   311→\\t\\t})\\n   312→\\t}\\n   313→}\\n   314→\\n   315→// runScenario runs the test function and recovers from errScenarioRestart\\n   316→// panics triggered by transient API errors in RunPrompt. Returns true if\\n   317→// the scenario should be restarted with a fresh repository.\\n   318→func runScenario(t *testing.T, s *RepoState, ctx context.Context, fn func(t *testing.T, s *RepoState, ctx context.Context)) (restarted bool) {\\n   319→\\tt.Helper()\\n   320→\\tdefer func() {\\n   321→\\t\\tif r := recover(); r != nil {\\n   322→\\t\\t