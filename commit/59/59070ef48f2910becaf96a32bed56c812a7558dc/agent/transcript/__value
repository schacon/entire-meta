oks (lowest risk)\\n  1052→\\tif err := removeAgentHooks(ctx, w); err != nil {\\n  1053→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove agent hooks: %v\\\\n\\\", err)\\n  1054→\\t}\\n  1055→\\n  1056→\\t// 2. Remove git hooks\\n  1057→\\tremoved, err := strategy.RemoveGitHook(ctx)\\n  1058→\\tif err != nil {\\n  1059→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove git hooks: %v\\\\n\\\", err)\\n  1060→\\t} else if removed > 0 {\\n  1061→\\t\\tfmt.Fprintf(w, \\\"  Removed git hooks (%d)\\\\n\\\", removed)\\n  1062→\\t}\\n  1063→\\n  1064→\\t// 3. Remove session state files\\n  1065→\\tstatesRemoved, err := removeAllSessionStates(ctx)\\n  1066→\\tif err != nil {\\n  1067→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove session states: %v\\\\n\\\", err)\\n  1068→\\t} else if statesRemoved > 0 {\\n  1069→\\t\\tfmt.Fprintf(w, \\\"  Removed session states (%d)\\\\n\\\", statesRemoved)\\n  1070→\\t}\\n  1071→\\n  1072→\\t// 4. Remove .entire/ directory\\n  1073→\\tif err := removeEntireDirectory(ctx); err != nil {\\n  1074→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove .entire directory: %v\\\\n\\\", err)\\n  1075→\\t} else if entireDirExists {\\n  1076→\\t\\tfmt.Fprintln(w, \\\"  Removed .entire directory\\\")\\n  1077→\\t}\\n  1078→\\n  1079→\\t// 5. Remove shadow branches\\n  1080→\\tbranchesRemoved, err := removeAllShadowBranches(ctx)\\n  1081→\\tif err != nil {\\n  1082→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove shadow branches: %v\\\\n\\\", err)\\n  1083→\\t} else if branchesRemoved > 0 {\\n  1084→\\t\\tfmt.Fprintf(w, \\\"  Removed %d shadow branches\\\\n\\\", branchesRemoved)\\n  1085→\\t}\\n  1086→\\n  1087→\\tfmt.Fprintln(w, \\\"\\\\nEntire CLI uninstalled successfully.\\\")\\n  1088→\\treturn nil\\n  1089→}\\n  1090→\\n  1091→// countSessionStates returns the number of active session state files.\\n  1092→func countSessionStates(ctx context.Context) int {\\n  1093→\\tstore, err := session.NewStateStore(ctx)\\n  1094→\\tif err !=