\\t}\\n    64→\\t}\\n    65→}\\n    66→\\n    67→// parseCheckpointRemoteFlag parses a \\\"provider:owner/repo\\\" string into its components.\\n    68→// Supported providers: \\\"github\\\".\\n    69→func parseCheckpointRemoteFlag(value string) (provider, repo string, err error) {\\n    70→\\tparts := strings.SplitN(value, \\\":\\\", 2)\\n    71→\\tif len(parts) != 2 || parts[0] == \\\"\\\" || parts[1] == \\\"\\\" {\\n    72→\\t\\treturn \\\"\\\", \\\"\\\", fmt.Errorf(\\\"expected format provider:owner/repo (e.g., github:org/checkpoints-repo), got %q\\\", value)\\n    73→\\t}\\n    74→\\n    75→\\tprovider = parts[0]\\n    76→\\trepo = parts[1]\\n    77→\\n    78→\\tswitch provider {\\n    79→\\tcase \\\"github\\\":\\n    80→\\t\\t// valid\\n    81→\\tdefault:\\n    82→\\t\\treturn \\\"\\\", \\\"\\\", fmt.Errorf(\\\"unsupported provider %q (supported: github)\\\", provider)\\n    83→\\t}\\n    84→\\n    85→\\trepoParts := strings.SplitN(repo, \\\"/\\\", 2)\\n    86→\\tif len(repoParts) != 2 || repoParts[0] == \\\"\\\" || repoParts[1] == \\\"\\\" {\\n    87→\\t\\treturn \\\"\\\", \\\"\\\", fmt.Errorf(\\\"repo must be in owner/name format, got %q\\\", repo)\\n    88→\\t}\\n    89→\\n    90→\\treturn provider, repo, nil\\n    91→}\\n    92→\\n    93→func newEnableCmd() *cobra.Command {\\n    94→\\tvar opts EnableOptions\\n    95→\\tvar ignoreUntracked bool\\n    96→\\tvar agentName string\\n    97→\\n    98→\\tcmd := &cobra.Command{\\n    99→\\t\\tUse:   \\\"enable\\\",\\n   100→\\t\\tShort: \\\"Enable Entire in current project\\\",\\n   101→\\t\\tLong: `Enable Entire with session tracking for your AI agent workflows.\\n   102→\\n   103→Uses the manual-commit strategy, which creates session checkpoints without\\n   104→modifying your active branch.`,\\n   105→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   106→\\t\\t\\tctx := cmd.Context()\\n   107→\\t\\t\\t// Check if we're in a git repository first - this is a prerequisite error,\\n   108→\\t\\t\\t// not a usage error, so we silence Cobra's output and use SilentError\\n   109→\\t\\t\\t// to prevent duplicate error output in main.go\\n   110→\\t\\t\\tif _, err := paths.WorktreeRoot(ctx); err != nil {\\n   111→\\t\\t\\t\\tfmt.Fprintln(cmd.ErrOrStderr(), \\\"Not a git repository. Please run 'entire enable' from within a git repository.\\\")\\n   112→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n   113→\\t\\t\\t}\\n   114→\\n   115→\\t\\t\\tif err := validateSetupFlags(opts.UseLocalSettings, opts.UseProjectSettings); err != nil {\\n   116→\\t\\t\\t\\treturn err\\n   117→\\t\\t\\t}\\n   118→\\n   119→\\t\\t\\t// Discover external agent plugins so they appear in agent selection.\\n   120→\\t\\t\\texternal.DiscoverAndRegister(ctx)\\n   121→\\n   122→\\t\\t\\t// Warn if repo has no commits yet\\n   123→\\t\\t\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n   124→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Note: This repository has no commits yet. Entire will be configured, but\\\")\\n   125→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"session checkpoints won't work until you create your first commit.\\\")\\n   126→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout())\\n   127→\\t\\t\\t}\\n   128→\\n   129→\\t\\t\\t// Non-interactive mode if --agent flag is provided\\n   130→\\t\\t\\tif cmd.Flags().Changed(\\\"agent\\\") && agentName == \\\"\\\" {\\n   131→\\t\\t\\t\\tprintMissingAgentError(cmd.ErrOrStderr())\\n   132→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n   133→\\t\\t\\t}\\n   134→\\n   135→\\t\\t\\tif agentName != \\\"\\\" {\\n   136→\\t\\t\\t\\tag, err := agent.Get(types.AgentName(agentName))\\n   137→\\t\\t\\t\\tif err != nil {\\n   138→\\t\\t\\t\\t\\tprintWrongAgentError(cmd.ErrOrStderr(), agentName)\\n   139→\\t\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"wrong agent name\\\"))\\n   140→\\t\\t\\t\\t}\\n   141→\\t\\t\\t\\t// --agent is a targeted