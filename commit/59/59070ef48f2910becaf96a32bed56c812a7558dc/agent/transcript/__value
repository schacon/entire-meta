ent) InstallHooks(ctx context.Context, localDev bool, force bool) (int, error) {\\n   232→\\targs := []string{\\\"install-hooks\\\"}\\n   233→\\tif localDev {\\n   234→\\t\\targs = append(args, \\\"--local-dev\\\")\\n   235→\\t}\\n   236→\\tif force {\\n   237→\\t\\targs = append(args, \\\"--force\\\")\\n   238→\\t}\\n   239→\\tstdout, err := e.run(ctx, nil, args...)\\n   240→\\tif err != nil {\\n   241→\\t\\treturn 0, fmt.Errorf(\\\"install-hooks: %w\\\", err)\\n   242→\\t}\\n   243→\\tvar resp HooksInstalledCountResponse\\n   244→\\tif err := json.Unmarshal(stdout, &resp); err != nil {\\n   245→\\t\\treturn 0, fmt.Errorf(\\\"install-hooks: invalid JSON: %w\\\", err)\\n   246→\\t}\\n   247→\\treturn resp.HooksInstalled, nil\\n   248→}\\n   249→\\n   250→func (e *Agent) UninstallHooks(ctx context.Context) error {\\n   251→\\t_, err := e.run(ctx, nil, \\\"uninstall-hooks\\\")\\n   252→\\tif err != nil {\\n   253→\\t\\treturn fmt.Errorf(\\\"uninstall-hooks: %w\\\", err)\\n   254→\\t}\\n   255→\\treturn nil\\n   256→}\\n   257→\\n   258→func (e *Agent) AreHooksInstalled(ctx context.Context) bool {\\n   259→\\tstdout, err := e.run(ctx, nil, \\\"are-hooks-installed\\\")\\n   260→\\tif err != nil {\\n   261→\\t\\treturn false\\n   262→\\t}\\n   263→\\tvar resp AreHooksInstalledResponse\\n   264→\\tif err := json.Unmarshal(stdout, &resp); err != nil {\\n   265→\\t\\treturn false\\n   266→\\t}\\n   267→\\treturn resp.Installed\\n   268→}\\n   269→\\n   270→// --- TranscriptAnalyzer methods ---\\n   271→\\n   272→func (e *Agent) GetTranscriptPosition(path string) (int, error) {\\n   273→\\tstdout, err := e.run(context.Background(), nil, \\\"get-transcript-position\\\", \\\"--path\\\", path)\\n   274→\\tif err != nil {\\n   275→\\t\\treturn 0, fmt.Errorf(\\\"get-transcript-position: %w\\\", err)\\n   276→\\t}\\n   277→\\tvar resp TranscriptPositionResponse\\n   278→\\tif err := json.Unmarshal(stdout, &resp); err != nil {\\n   279→\\t\\treturn 0, fmt.Errorf(\\\"get-transcript-position: invalid JSON: %w\\\", err)\\n   280→\\t}\\n   281→\\treturn resp.Position, nil\\n   282→}\\n   283→\\n   284→func (e *Agent) ExtractModifiedFilesFromOffset(path string, startOffset int) ([]string, int, error) {\\n   285→\\tstdout, err := e.run(context.Background(), nil, \\\"extract-modified-files\\\",\\n   286→\\t\\t\\\"--path\\\", path, \\\"--offset\\\", strconv.Itoa(startOffset))\\n   287→\\tif err != nil {\\n   288→\\t\\treturn nil, 0, fmt.Errorf(\\\"extract-modified-files: %w\\\", err)\\n   289→\\t}\\n   290→\\tvar resp ExtractFilesResponse\\n   291→\\tif err := json.Unmarshal(stdout, &resp); err != nil {\\n   292→\\t\\treturn nil, 0, fmt.Errorf(\\\"extract-modified-files: invalid JSON: %w\\\", err)\\n   293→\\t}\\n   294→\\treturn resp.Files, resp.CurrentPosition, nil\\n   295→}\\n   296→\\n   297→func (e *Agent) ExtractPrompts(sessionRef string, fromOffset int) ([]string, error) {\\n   298→\\tstdout, err := e.run(context.Background(), nil, \\\"extract-prompts\\\",\\n   299→\\t\\t\\\"--session-ref\\\", sessionRef, \\\"--offset\\\", strconv.Itoa(fromOffset))\\n   300→\\tif err != nil {\\n   301→\\t\\treturn nil, fmt.Errorf(\\\"extract-prompts: %w\\\", err)\\n   302→\\t}\\n   303→\\tvar resp ExtractPromptsResponse\\n   304→\\tif err := json.Unmarshal(stdout, &resp); err != nil {\\n   305→\\t\\treturn nil, fmt.Errorf(\\\"extract-prompts: invalid JSON: %w\\\", err)\\n   306→\\t}\\n   307→\\treturn resp.Prompts, nil\\n   308→}\\n   309→\\n   310→func (e *Agent) ExtractSummary(sessionRef string) (string, error) {\\n   311→\\tstdout, err := e.run(context.Background(), nil, \\\"extract-summary\\\", \\\"--session-ref\\\", sessionRef)\\n   312→\\tif err != nil {\\n   313→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"extract-summary: %w\\\", err)\\n   314→\\t}\\n   315→\\tvar resp ExtractSummaryResponse\\n   316→\\tif err := json.Unmarshal(stdout, &resp); err != nil {\\n   317→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"extract-summary: invalid JSON: %w\\\", err)\\n   318→\\t}\\n   319→\\treturn resp.Summary, nil\\n   320→}\\n   321→\\n   322→// --- TranscriptPreparer methods ---\\n   323→\\n   324→func (e *Agent) PrepareTranscript(ctx context.Context, sessionRef string) error {\\n   325→\\t_, err := e.run(ctx, nil, \\\"prepare-transcript\\\", \\\"--session-ref\\\", sessionRef)\\n   326→\\tif err != nil {\\n   327→\\t\\treturn fmt.Errorf(\\\"prepare-transcript: %w\\\", err)\\n   328→\\t}\\n   329→\\treturn nil\\n   330→}\\n   331→\\n   332→// --- TokenCalculator methods ---\\n   333→\\n   334→func (e *Agent) CalculateTokenUsage(transcriptData []byte, fromOffset int) (*agent.TokenUsage, error) {\\n   335→\\tstdout, err := e.run(context.Background(), transcriptData,\\n   336→\\t\\t\\\"calculate-tokens\\\", \\\"--offset\\\", strconv.Itoa(fromOffset))\\n   337→\\tif err != nil {\\n   338→\\t\\treturn nil, fmt.Errorf(\\\"calculate-tokens: %w\\\", err)\\n   339→\\t}\\n   340→\\tvar resp TokenUsageResponse\\n   341→\\tif err := json.Unmarshal(stdout, &resp); err != nil {\\n   342→\\t\\treturn nil, fmt.Errorf(\\\"calculate-tokens: invalid JSON: %w\\\", err)\\n   343→\\t}\\n   344→\\treturn convertTokenUsage(&resp), nil\\n   345→}\\n   346→\\n   347→// --- TextGenerator methods ---\\n   348→\\n   349→func (e *Agent) GenerateText(ctx context.Context, prompt string, model string) (string, error) {\\n   350→\\tstdout, err := e.run(ctx, []byte(prompt), \\\"generate-text\\\", \\\"--model\\\", model)\\n   351→\\tif err != nil {\\n   352→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"generate-text: %w\\\", err)\\n   353→\\t}\\n   354→\\tvar resp GenerateTextResponse\\n   355→\\tif err := json.Unmarshal(stdout, &resp); err != nil {\\n   356→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"generate-text: invalid JSON: %w\\\", err)\\n   357→\\t}\\n   358→\\treturn resp.Text, nil\\n   359→}\\n   360→\\n   361→// --- HookResponseWriter methods ---\\n   362→\\n   363→func (e *Agent) WriteHookResponse(message string) error {\\n   364→\\t_, err := e.run(context.Background(), nil, \\\"write-hook-response\\\", \\\"--message\\\", message)\\n   365→\\tif err != nil {\\n   366→\\t\\treturn fmt.Errorf(\\\"write-hook-response: %w\\\", err)\\n   367→\\t}\\n   368→\\treturn nil\\n   369→}\\n   370→\\n   371→// --- SubagentAwareExtractor methods ---\\n   372→\\n   373→func (e *Agent) ExtractAllModifiedFiles(transcriptData []byte, fromOffset int, subagentsDir string) ([]string, error) {\\n   374→\\tstdout, err := e.run(context.Background(), transcriptData,\\n   375→\\t\\t\\\"extract-all-modified-files\\\", \\\"--offset\\\", strconv.Itoa(fromOffset), \\\"--subagents-dir\\\", subagentsDir)\\n   376→\\tif err != nil {\\n   377→\\t\\treturn nil, fmt.Errorf(\\\"extract-all-modified-files: %w\\\", err)\\n   378→\\t}\\n   379→\\tvar resp ExtractFilesResponse\\n   380→\\tif err := json.Unmarshal(stdout, &resp); err != nil {\\n   381→\\t\\treturn nil, fmt.Errorf(\\\"extract-all-modified-files: invalid JSON: %w\\\", err)\\n   382→\\t}\\n   383→\\treturn resp.Files, nil\\n   384→}\\n   385→\\n   386→func (e *Agent) CalculateTotalTokenUsage(transcriptData []byte, fromOffset int, subagentsDir string) (*agent.TokenUsage, error) {\\n   387→\\tstdout, err := e.run(context.Background(), transcriptData,\\n   388→\\t\\t\\\"calculate-total-tokens\\\", \\\"--offset\\\", strconv.Itoa(fromOffset), \\\"--subagents-dir\\\", subagentsDir)\\n   389→\\tif err != nil {\\n   390→\\t\\treturn nil, fmt.Errorf(\\\"calculate-total-tokens: %w\\\", err)\\n   391→\\t}\\n   392→\\tvar resp TokenUsageResponse\\n   393→\\tif err := json.Unmarshal(stdout, &resp); err != nil {\\n   394→\\t\\treturn nil, fmt.Errorf(\\\"calculate-total-tokens: invalid JSON: %w\\\", err)\\n   395→\\t}\\n   396→\\treturn convertTokenUsage(&resp), nil\\n   397→}\\n   398→\\n   399→// run executes a subcommand on the external binary and returns stdout bytes.\\n   400→// If stdin is non-nil it is piped to the process. On non-zero exit, stderr is\\n   401→// included in the returned error.\\n   402→func (e *Agent) run(ctx context.Context, stdin []byte, args ...string) ([]byte, error) {\\n   403→\\t// Apply a default timeout when the caller hasn't set a deadline, so a hung\\n   404→\\t// external binary can't block the CLI (or git hooks) indefinitely.\\n   405→\\tif _, ok := ctx.Deadline(); !ok {\\n   406→\\t\\tvar cancel context.CancelFunc\\n   407→\\t\\tctx, cancel = context.WithTimeout(ctx, defaultRunTimeout)\\n   408→\\t\\tdefer cancel()\\n   409→\\t}\\n   410→\\tcmd := exec.CommandContext(ctx, e.binaryPath, args...)\\n   411→\\t// Ensure I/O goroutines are released shortly after the process is killed,\\n   412→\\t// so cmd.Run() doesn't block waiting for pipe reads.\\n   413→\\tcmd.WaitDelay = 3 * time.Second\\n   414→\\n   415→\\t// Set environment: repo root + protocol version\\n   416→\\tcmd.Env = append(cmd.Environ(),\\n   417→\\t\\t\\\"ENTIRE_PROTOCOL_VERSION=\\\"+strconv.Itoa(ProtocolVersion),\\n   418→\\t)\\n   419→\\tif repoRoot, err := paths.WorktreeRoot(ctx); err == nil {\\n   420→\\t\\tcmd.Env = append(cmd.Env, \\\"ENTIRE_REPO_ROOT=\\\"+repoRoot)\\n   421→\\t\\tcmd.Dir = repoRoot\\n   422→\\t}\\n   423→\\n   424→\\tif stdin != nil {\\n   425→\\t\\tcmd.Stdin = bytes.NewReader(stdin)\\n   426→\\t}\\n   427→\\n   428→\\tconst maxOutputBytes = 10 * 1024 * 1024 // 10 MB\\n   429→\\n   430→\\tvar stdoutBuf, stderrBuf bytes.Buffer\\n   431→\\tstdoutLW := &limitedWriter{buf: &stdoutBuf, limit: maxOutputBytes}\\n   432→\\tstderrLW := &limitedWriter{buf: &stderrBuf, limit: maxOutputBytes}\\n   433→\\tcmd.Stdout = stdoutLW\\n   434→\\tcmd.Stderr = stderrLW\\n   435→\\n   436→\\tif err := cmd.Run(); err != nil {\\n   437→\\t\\terrMsg := strings.TrimSpace(stderrBuf.String())\\n   438→\\t\\tif errMsg != \\\"\\\" {\\n   439→\\t\\t\\treturn nil, fmt.Errorf(\\\"%s: %s\\\", args[0], errMsg)\\n   440→\\t\\t}\\n   441→\\t\\treturn nil, fmt.Errorf(\\\"%s: %w\\\", args[0], err)\\n   442→\\t}\\n   443→\\n   444→\\tif stdoutLW.truncated {\\n   445→\\t\\treturn nil, fmt.Errorf(\\\"%s: output exceeded %d byte limit\\\", args[0], maxOutputBytes)\\n   446→\\t}\\n   447→\\n   448→\\treturn stdoutBuf.Bytes(), nil\\n   449→}\\n   450→\\n   451→// --- Helpers ---\\n   452→\\n   453→// limitedWriter wraps a bytes.Buffer and stops writing after limit bytes,\\n   454→// preventing unbounded memory growth from external process output.\\n   455→type limitedWriter struct {\\n   456→\\tbuf       *bytes.Buffer\\n   457→\\tlimit     int\\n   458→\\ttruncated bool\\n   459→}\\n   460→\\n   461→func (w *limitedWriter) Write(p []byte) (int, error) {\\n   462→\\tremaining := w.limit - w.buf.Len()\\n   463→\\tif remaining <= 0 {\\n   464→\\t\\tw.truncated = true\\n   465→\\t\\treturn len(p), nil // discard, but report success so the process isn't killed\\n   466→\\t}\\n   467→\\tif len(p) > remaining {\\n   468→\\t\\tp = p[:remaining]\\n   469→\\t\\tw.truncated = true\\n   470→\\t}\\n   471→\\tn, err := w.buf.Write(p)\\n   472→\\tif err != nil {\\n   473→\\t\\treturn n, fmt.Errorf(\\\"writing to limited buffer: %w\\\", err)\\n   474→\\t}\\n   475→\\treturn n, nil\\n   476→}\\n   477→\\n   478→func marshalHookInput(input *agent.HookInput) ([]byte, error) {\\n   479→\\tif input == nil {\\n   480→\\t\\treturn []byte(\\\"{}\\\"), nil\\n   481→\\t}\\n   482→\\tj := HookInputJSON{\\n   483→\\t\\tHookType:   string(input.HookType),\\n   484→\\t\\tSessionID:  input.SessionID,\\n   485→\\t\\tSessionRef: input.SessionRef,\\n   486→\\t\\tTimestamp:  input.Timestamp.Format(time.RFC3339),\\n   487→\\t\\tUserPrompt: input.UserPrompt,\\n   488→\\t\\tToolName:   input.ToolName,\\n   489→\\t\\tToolUseID:  input.ToolUseID,\\n   490→\\t\\tToolInput:  input.ToolInput,\\n   491→\\t\\tRawData:    input.RawData,\\n   492→\\t}\\n   493→\\tdata, err := json.Marshal(j)\\n   494→\\tif err != nil {\\n   495→\\t\\treturn nil, fmt.Errorf(\\\"marshal hook input: %w\\\", err)\\n   496→\\t}\\n   497→\\treturn data, nil\\n   498→}\\n   499→\\n   500→func marshalAgentSession(s *agent.AgentSession) ([]byte, error) {\\n   501→\\tj := AgentSessionJSON{\\n   502→\\t\\tSessionID:     s.SessionID,\\n   503→\\t\\tAgentName:     string(s.AgentName),\\n   504→\\t\\tRepoPath:      s.RepoPath,\\n   505→\\t\\tSessionRef:    s.SessionRef,\\n   506→\\t\\tStartTime:     s.StartTime.Format(time.RFC3339),\\n   507→\\t\\tNativeData:    s.NativeData,\\n   508→\\t\\tModifiedFiles: s.ModifiedFiles,\\n   509→\\t\\tNewFiles:      s.NewFiles,\\n   510→\\t\\tDeletedFiles:  s.DeletedFiles,\\n   511→\\t}\\n   512→\\tdata, err := json.Marshal(j)\\n   513→\\tif err != nil {\\n   514→\\t\\treturn nil, fmt.Errorf(\\\"marshal agent session: %w\\\", err)\\n   515→\\t}\\n   516→\\treturn data, nil\\n   517→}\\n   518→\\n   519→func unmarshalAgentSession(j *AgentSessionJSON) (*agent.AgentSession, error) {\\n   520→\\tvar startTime time.Time\\n   521→\\tif j.StartTime != \\\"\\\" {\\n   522→\\t\\tvar err error\\n   523→\\t\\tstartTime, err = time.Parse(time.RFC3339, j.StartTime)\\n   524→\\t\\tif err != nil {\\n   525→\\t\\t\\treturn nil, fmt.Errorf(\\\"invalid start_time: %w\\\", err)\\n   526→\\t\\t}\\n   527→\\t}\\n   528→\\treturn &agent.AgentSession{\\n   529→\\t\\tSessionID:     j.SessionID,\\n   530→\\t\\tAgentName:     types.AgentName(j.AgentName),\\n   531→\\t\\tRepoPath:      j.RepoPath,\\n   532→\\t\\tSessionRef:    j.SessionRef,\\n   533→\\t\\tStartTime:     startTime,\\n   534→\\t\\tNativeData:    j.NativeData,\\n   535→\\t\\tModifiedFiles: j.ModifiedFiles,\\n   536→\\t\\tNewFiles:      j.NewFiles,\\n   537→\\t\\tDeletedFiles:  j.DeletedFiles,\\n   538→\\t}, nil\\n   539→}\\n   540→\\n   541→func convertTokenUsage(r *TokenUsageResponse) *agent.TokenUsage {\\n   542→\\tif r == nil {\\n   543→\\t\\treturn nil\\n   544→\\t}\\n   545→\\tusage := &agent.TokenUsage{\\n   546→\\t\\tInputTokens:         r.InputTokens,\\n   547→\\t\\tCacheCreationTokens: r.CacheCreationTokens,\\n   548→\\t\\tCacheReadTokens:     r.CacheReadTokens,\\n   549→\\t\\tOutputTokens:        r.OutputTokens,\\n   550→\\t\\tAPICallCount:        r.APICallCount,\\n   551→\\t}\\n   552→\\tif r.SubagentTokens != nil {\\n   553→\\t\\tusage.SubagentTokens = convertTokenUsage(r.SubagentTokens)\\n   554→\\t}\\n   555→\\treturn usage\\n   556→}\\n   557→\"}]},\"uuid\":\"6fd54184-1b63-4614-b7d8-0a215f0bd07e\",\"timestamp\":\"2026-03-16T08:47:58.507Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"adb21441cd21363f7\"},\"toolUseID\":\"agent_msg_01GsUghYiGvsH78ajkViyFFd\",\"parentToolUseID\":\"toolu_01VqhZ6YnLWjw7rSK8mNWUKw\",\"uuid\":\"3b08add2-4dd7-42c5-8c28-c5e9fa414389\",\"timestamp\":\"2026-03-16T08:47:58.508Z\",\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"1389d7d7-e618-4144-8a22-a19bc90b3c54\",\"version\":\"2.1.76\",\"gitBranch\":\"main\",\"slug\":\"delegated-fluttering-corbato\"}\n{\"parentUuid\":\"3b08add2-4dd7-42c5-8c28-c5e9fa414389\",\"isSidechain\":false,\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-16T08:47:59.412Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01EKTsV9rg9vR4kdjCF5MTkD\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01HF4LYUecfDZTQaTBAAAaPZ\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/nodo/work/cli/docs/architecture/external-agent-protocol.md\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":2,\"cache_creation_input_tokens\":288,\"cache_read_input_tokens\":31664,\"cache_creation\":{\"ephemeral_5m_input_tokens\":288,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":25,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CZ6UB4rfNhyGFdHTzZEiG\",\"uuid\":\"db18aa8e-35d2-4e13-ab69-7de063b22c8f\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"abf3b3d48a450055c\"},\"toolUseID\":\"agent_msg_01GsUghYiGvsH78ajkViyFFd\",\"parentToolUseID\":\"toolu_01SN1FF6ejnUamrWMgteU41C\",\"uuid\":\"f39c63a9-84e0-4856-b676-be24db6294d3\",\"timestamp\":\"2026-03-16T08:47:59.412Z\",\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"1389d7d7-e618-4144-8a22-a19bc90b3c54\",\"version\":\"2.1.76\",\"gitBranch\":\"main\",\"slug\":\"delegated-fluttering-corbato\"}\n{\"parentUuid\":\"f39c63a9-84e0-4856-b676-be24db6294d3\",\"isSidechain\":false,\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01HF4LYUecfDZTQaTBAAAaPZ\",\"type\":\"tool_result\",\"content\":\"     1→# External Agent Plugin Protocol\\n     2→\\n     3→## Overview\\n     4→\\n     5→The Entire CLI supports external agent plugins — standalone binaries that implement the Agent interface via a subcommand-based protocol over stdin/stdout. This allows third-party agents to integrate with the CLI without modifying the main repository.\\n     6→\\n     7→## Discovery\\n     8→\\n     9→The CLI discovers external agents by scanning `$PATH` for executables matching the pattern `entire-agent-<name>`. For example, `entire-agent-cursor` would register as the \\\"cursor\\\" agent.\\n    10→\\n    11→- Binaries whose `<name>` conflicts with an already-registered built-in agent are skipped.\\n    12→- Discovery runs once during CLI initialization (before building the hooks command tree).\\n    13→- The binary must be executable and respond to the `info` subcommand.\\n    14→\\n    15→## Environment\\n    16→\\n    17→Every subcommand invocation sets:\\n    18→\\n    19→| Variable | Description |\\n    20→|---|---|\\n    21→| `ENTIRE_REPO_ROOT` | Absolute path to the git repository root |\\n    22→| `ENTIRE_PROTOCOL_VERSION` | Protocol version (`1`) |\\n    23→\\n    24→The working directory is set to the repository root.\\n    25→\\n    26→## Communication Model\\n    27→\\n    28→- **Subcommand-based:** Each Agent interface method maps to a CLI subcommand.\\n    29→- **JSON over stdin/stdout:** Structured data uses JSON. Transcripts use raw bytes.\\n    30→- **Stateless:** Each invocation is independent — no persistent connection.\\n    31→- **Exit codes:** `0` = success, non-zero = error. Error messages go to stderr.\\n    32→\\n    33→## Subcommands\\n    34→\\n    35→### Always Required\\n    36→\\n    37→#### `info`\\n    38→\\n    39→Returns agent metadata and declared capabilities.\\n    40→\\n    41→**Arguments:** None\\n    42→\\n    43→**Output (stdout):** JSON\\n    44→\\n    45→```json\\n    46→{\\n    47→  \\\"protocol_version\\\": 1,\\n    48→  \\\"name\\\": \\\"cursor\\\",\\n    49→  \\\"type\\\": \\\"Cursor\\\",\\n    50→  \\\"description\\\": \\\"Cursor - AI-powered code editor\\\",\\n    51→  \\\"is_preview\\\": true,\\n    52→  \\\"protected_dirs\\\": [\\\".cursor\\\"],\\n    53→  \\\"hook_names\\\": [\\\"session-start\\\", \\\"session-end\\\", \\\"stop\\\"],\\n    54→  \\\"capabilities\\\": {\\n    55→    \\\"hooks\\\": true,\\n    56→    \\\"transcript_analyzer\\\": true,\\n    57→    \\\"transcript_preparer\\\": false,\\n    58→    \\\"token_calculator\\\": false,\\n    59→    \\\"text_generator\\\": false,\\n    60→    \\\"hook_response_writer\\\": false,\\n    61→    \\\"subagent_aware_extractor\\\": false\\n    62→  }\\n    63→}\\n    64→```\\n    65→\\n    66→The `capabilities` object determines which optional subcommands the CLI will call. If a capability is `false` or missing, the CLI will never invoke the corresponding subcommands.\\n    67→\\n    68→#### `detect`\\n    69→\\n    70→Checks whether the agent is present/usable in the current environment.\\n    71→\\n    72→**Arguments:** None\\n    73→\\n    74→**Output (stdout):** JSON\\n    75→\\n    76→```json\\n    77→{\\\"present\\\": true}\\n    78→```\\n    79→\\n    80→#### `get-session-id`\\n    81→\\n    82→Extracts the session ID from a hook input event.\\n    83→\\n    84→**Input (stdin):** JSON — the [HookInput object](#hookinput-object)\\n    85→\\n    86→**Output (stdout):** JSON\\n    87→\\n    88→```json\\n    89→{\\\"session_id\\\": \\\"abc123\\\"}\\n    90→```\\n    91→\\n    92→#### `get-session-dir --repo-path <path>`\\n    93→\\n    94→Returns the directory where agent sessions are stored.\\n    95→\\n    96→**Arguments:**\\n    97→- `--repo-path` — Absolute path to the repository\\n    98→\\n    99→**Output (stdout):** JSON\\n   100→\\n   101→```json\\n   102→{\\\"session_dir\\\": \\\"/path/to/sessions\\\"}\\n   103→```\\n   104→\\n   105→#### `resolve-session-file --session-dir <dir> --session-id <id>`\\n   106→\\n   107→Resolves the session file path from a session directory and ID.\\n   108→\\n   109→**Arguments:**\\n   110→- `--session-dir` — Session directory path\\n   111→- `--session-id` — Session identifier\\n   112→\\n   113→**Output (stdout):** JSON\\n   114→\\n   115→```json\\n   116→{\\\"session_file\\\": \\\"/path/to/session/file.jsonl\\\"}\\n   117→```\\n   118→\\n   119→#### `read-session`\\n   120→\\n   121→Reads session data from a hook input event.\\n   122→\\n   123→**Input (stdin):** JSON — the [HookInput object](#hookinput-object)\\n   124→\\n   125→**Output (stdout):** JSON — [AgentSession object](#agentsession-object)\\n   126→\\n   127→```json\\n   128→{\\n   129→  \\\"session_id\\\": \\\"abc123\\\",\\n   130→  \\\"agent_name\\\": \\\"cursor\\\",\\n   131→  \\\"repo_path\\\": \\\"/path/to/repo\\\",\\n   132→  \\\"session_ref\\\": \\\"/path/to/file.jsonl\\\",\\n   133→  \\\"start_time\\\": \\\"2026-01-13T12:00:00Z\\\",\\n   134→  \\\"native_data\\\": null,\\n   135→  \\\"modified_files\\\": [\\\"src/main.go\\\"],\\n   136→  \\\"new_files\\\": [],\\n   137→  \\\"deleted_files\\\": []\\n   138→}\\n   139→```\\n   140→\\n   141→#### `write-session`\\n   142→\\n   143→Writes/updates session data.\\n   144→\\n   145→**Input (stdin):** JSON — the [AgentSession object](#agentsession-object)\\n   146→\\n   147→**Output:** Exit 0 on success.\\n   148→\\n   149→#### `read-transcript --session-ref <path>`\\n   150→\\n   151→Reads a transcript file and returns its raw bytes.\\n   152→\\n   153→**Arguments:**\\n   154→- `--session-ref` — Path to the transcript file\\n   155→\\n   156→**Output (stdout):** Raw transcript bytes.\\n   157→\\n   158→#### `chunk-transcript --max-size <n>`\\n   159→\\n   160→Splits a transcript into chunks for storage.\\n   161→\\n   162→**Input (stdin):** Raw transcript bytes.\\n   163→\\n   164→**Arguments:**\\n   165→- `--max-size` — Maximum chunk size in bytes\\n   166→\\n   167→**Output (stdout):** JSON\\n   168→\\n   169→```json\\n   170→{\\\"chunks\\\": [\\\"<base64-encoded-chunk>\\\", \\\"...\\\"]}\\n   171→```\\n   172→\\n   173→#### `reassemble-transcript`\\n   174→\\n   175→Reassembles transcript chunks back into a full transcript.\\n   176→\\n   177→**Input (stdin):** JSON\\n   178→\\n   179→```json\\n   180→{\\\"chunks\\\": [\\\"<base64-encoded-chunk>\\\", \\\"...\\\"]}\\n   181→```\\n   182→\\n   183→**Output (stdout):** Raw transcript bytes.\\n   184→\\n   185→#### `format-resume-command --session-id <id>`\\n   186→\\n   187→Returns the command a user can run to resume a session.\\n   188→\\n   189→**Arguments:**\\n   190→- `--session-id` — Session identifier\\n   191→\\n   192→**Output (stdout):** JSON\\n   193→\\n   194→```json\\n   195→{\\\"command\\\": \\\"cursor --resume abc123\\\"}\\n   196→```\\n   197→\\n   198→### Capability: `hooks`\\n   199→\\n   200→These subcommands are required when `capabilities.hooks` is `true`.\\n   201→\\n   202→#### `parse-hook --hook <name>`\\n   203→\\n   204→Parses a raw agent hook payload into a structured event.\\n   205→\\n   206→**Arguments:**\\n   207→- `--hook` — Hook name (e.g., \\\"stop\\\", \\\"session-start\\\")\\n   208→\\n   209→**Input (stdin):** Raw agent hook payload bytes.\\n   210→\\n   211→**Output (stdout):** JSON — the parsed [Event object](#event-object), or `null` if the payload is not relevant.\\n   212→\\n   213→#### `install-hooks [--local-dev] [--force]`\\n   214→\\n   215→Installs agent hooks for Entire integration.\\n   216→\\n   217→**Arguments:**\\n   218→- `--local-dev` — Use local development binary path (optional)\\n   219→- `--force` — Overwrite existing hooks (optional)\\n   220→\\n   221→**Output (stdout):** JSON\\n   222→\\n   223→```json\\n   224→{\\\"hooks_installed\\\": 3}\\n   225→```\\n   226→\\n   227→#### `uninstall-hooks`\\n   228→\\n   229→Removes installed agent hooks.\\n   230→\\n   231→**Arguments:** None\\n   232→\\n   233→**Output:** Exit 0 on success.\\n   234→\\n   235→#### `are-hooks-installed`\\n   236→\\n   237→Checks whether hooks are currently installed.\\n   238→\\n   239→**Arguments:** None\\n   240→\\n   241→**Output (stdout):** JSON\\n   242→\\n   243→```json\\n   244→{\\\"installed\\\": true}\\n   245→```\\n   246→\\n   247→### Capability: `transcript_analyzer`\\n   248→\\n   249→Required when `capabilities.transcript_analyzer` is `true`.\\n   250→\\n   251→#### `get-transcript-position --path <path>`\\n   252→\\n   253→Returns the current byte position/size of a transcript file.\\n   254→\\n   255→**Arguments:**\\n   256→- `--path` — Path to the transcript file\\n   257→\\n   258→**Output (stdout):** JSON\\n   259→\\n   260→```json\\n   261→{\\\"position\\\": 12345}\\n   262→```\\n   263→\\n   264→#### `extract-modified-files --path <path> --offset <n>`\\n   265→\\n   266→Extracts the list of files modified by the agent from a transcript.\\n   267→\\n   268→**Arguments:**\\n   269→- `--path` — Path to the transcript file\\n   270→- `--offset` — Byte offset to start reading from\\n   271→\\n   272→**Output (stdout):** JSON\\n   273→\\n   274→```json\\n   275→{\\\"files\\\": [\\\"path/to/file1.go\\\", \\\"path/to/file2.go\\\"], \\\"current_position\\\": 12345}\\n   276→```\\n   277→\\n   278→The `current_position` field returns the transcript position after extraction, allowing the caller to resume from that point on subsequent calls.\\n   279→\\n   280→#### `extract-prompts --session-ref <path> --offset <n>`\\n   281→\\n   282→Extracts user prompts from a transcript.\\n   283→\\n   284→**Arguments:**\\n   285→- `--session-ref` — Path to the transcript file\\n   286→- `--offset` — Byte offset to start reading from\\n   287→\\n   288→**Output (stdout):** JSON\\n   289→\\n   290→```json\\n   291→{\\\"prompts\\\": [\\\"first prompt text\\\", \\\"second prompt text\\\"]}\\n   292→```\\n   293→\\n   294→#### `extract-summary --session-ref <path>`\\n   295→\\n   296→Extracts an AI-generated summary from a transcript.\\n   297→\\n   298→**Arguments:**\\n   299→- `--session-ref` — Path to the transcript file\\n   300→\\n   301→**Output (stdout):** JSON\\n   302→\\n   303→```json\\n   304→{\\\"summary\\\": \\\"Summary text here\\\", \\\"has_summary\\\": true}\\n   305→```\\n   306→\\n   307→### Capability: `transcript_preparer`\\n   308→\\n   309→Required when `capabilities.transcript_preparer` is `true`.\\n   310→\\n   311→#### `prepare-transcript --session-ref <path>`\\n   312→\\n   313→Prepares/processes a transcript file (e.g., converting from raw format).\\n   314→\\n   315→**Arguments:**\\n   316→- `--session-ref` — Path to the transcript file\\n   317→\\n   318→**Output:** Exit 0 on success.\\n   319→\\n   320→### Capability: `token_calculator`\\n   321→\\n   322→Required when `capabilities.token_calculator` is `true`.\\n   323→\\n   324→#### `calculate-tokens --offset <n>`\\n   325→\\n   326→Calculates token usage from a transcript.\\n   327→\\n   328→**Input (stdin):** Raw transcript bytes.\\n   329→\\n   330→**Arguments:**\\n   331→- `--offset` — Byte offset to start calculating from\\n   332→\\n   333→**Output (stdout):** JSON\\n   334→\\n   335→```json\\n   336→{\\n   337→  \\\"input_tokens\\\": 1500,\\n   338→  \\\"cache_creation_tokens\\\": 0,\\n   339→  \\\"cache_read_tokens\\\": 200,\\n   340→  \\\"output_tokens\\\": 500,\\n   341→  \\\"api_call_count\\\": 3,\\n   342→  \\\"subagent_tokens\\\": null\\n   343→}\\n   344→```\\n   345→\\n   346→Only `input_tokens` and `output_tokens` are required. The optional fields (`cache_creation_tokens`, `cache_read_tokens`, `api_call_count`) default to `0` if omitted. `subagent_tokens` is an optional nested object with the same structure, for agents that spawn subagents.\\n   347→\\n   348→### Capability: `text_generator`\\n   349→\\n   350→Required when `capabilities.text_generator` is `true`.\\n   351→\\n   352→#### `generate-text --model <model>`\\n   353→\\n   354→Generates text using the agent's underlying LLM.\\n   355→\\n   356→**Input (stdin):** Prompt text.\\n   357→\\n   358→**Arguments:**\\n   359→- `--model` — Model to use for generation\\n   360→\\n   361→**Output (stdout):** JSON\\n   362→\\n   363→```json\\n   364→{\\\"text\\\": \\\"Generated response text\\\"}\\n   365→```\\n   366→\\n   367→### Capability: `hook_response_writer`\\n   368→\\n   369→Required when `capabilities.hook_response_writer` is `true`.\\n   370→\\n   371→#### `write-hook-response --message <message>`\\n   372→\\n   373→Writes a message in the agent's native hook response format.\\n   374→\\n   375→**Arguments:**\\n   376→- `--message` — Message to write\\n   377→\\n   378→**Output (stdout):** Agent-native format bytes (e.g., JSONL for Claude Code).\\n   379→\\n   380→### Capability: `subagent_aware_extractor`\\n   381→\\n   382→Required when `capabilities.subagent_aware_extractor` is `true`.\\n   383→\\n   384→#### `extract-all-modified-files --offset <n> --subagents-dir <dir>`\\n   385→\\n   386→Extracts modified files from both the main transcript and any subagent transcripts.\\n   387→\\n   388→**Input (stdin):** Raw main transcript bytes.\\n   389→\\n   390→**Arguments:**\\n   391→- `--offset` — Byte offset for the main transcript\\n   392→- `--subagents-dir` — Directory containing subagent transcripts\\n   393→\\n   394→**Output (stdout):** JSON\\n   395→\\n   396→```json\\n   397→{\\\"files\\\": [\\\"file1.go\\\", \\\"file2.go\\\"]}\\n   398→```\\n   399→\\n   400→#### `calculate-total-tokens --offset <n> --subagents-dir <dir>`\\n   401→\\n   402→Calculates total token usage across main transcript and subagent transcripts.\\n   403→\\n   404→**Input (stdin):** Raw main transcript bytes.\\n   405→\\n   406→**Arguments:**\\n   407→- `--offset` — Byte offset for the main transcript\\n   408→- `--subagents-dir` — Directory containing subagent transcripts\\n   409→\\n   410→**Output (stdout):** JSON\\n   411→\\n   412→```json\\n   413→{\\n   414→  \\\"input_tokens\\\": 5000,\\n   415→  \\\"cache_creation_tokens\\\": 0,\\n   416→  \\\"cache_read_tokens\\\": 1000,\\n   417→  \\\"output_tokens\\\": 2000,\\n   418→  \\\"api_call_count\\\": 8,\\n   419→  \\\"subagent_tokens\\\": {\\n   420→    \\\"input_tokens\\\": 2000,\\n   421→    \\\"output_tokens\\\": 800\\n   422→  }\\n   423→}\\n   424→```\\n   425→\\n   426→Same token usage format as `calculate-tokens`. The `subagent_tokens` field aggregates usage from all subagents.\\n   427→\\n   428→## Shared Object Definitions\\n   429→\\n   430→### HookInput Object\\n   431→\\n   432→The HookInput object is passed via stdin to `get-session-id` and `read-session`.\\n   433→\\n   434→```json\\n   435→{\\n   436→  \\\"hook_type\\\": \\\"stop\\\",\\n   437→  \\\"session_id\\\": \\\"abc123\\\",\\n   438→  \\\"session_ref\\\": \\\"/path/to/transcript.jsonl\\\",\\n   439→  \\\"timestamp\\\": \\\"2026-01-13T12:00:00Z\\\",\\n   440→  \\\"user_prompt\\\": \\\"Fix the login bug\\\",\\n   441→  \\\"tool_name\\\": \\\"Write\\\",\\n   442→  \\\"tool_use_id\\\": \\\"toolu_abc123\\\",\\n   443→  \\\"tool_input\\\": {\\\"path\\\": \\\"/src/main.go\\\"},\\n   444→  \\\"raw_data\\\": {\\\"custom_field\\\": \\\"value\\\"}\\n   445→}\\n   446→```\\n   447→\\n   448→| Field | Type | Description |\\n   449→|---|---|---|\\n   450→| `hook_type` | string | Hook type: `session_start`, `session_end`, `user_prompt_submit`, `stop`, `pre_tool_use`, `post_tool_use` |\\n   451→| `session_id` | string | Agent session identifier |\\n   452→| `session_ref` | string | Agent-specific session reference (typically a file path) |\\n   453→| `timestamp` | string | RFC 3339 timestamp |\\n   454→| `user_prompt` | string | User's prompt text (from `user_prompt_submit` hooks). Optional. |\\n   455→| `tool_name` | string | Tool name (from `pre_tool_use`/`post_tool_use` hooks). Optional. |\\n   456→| `tool_use_id` | string | Tool invocation ID. Optional. |\\n   457→| `tool_input` | object | Raw tool input JSON. Optional. |\\n   458→| `raw_data` | object | Agent-specific data for extension. Optional. |\\n   459→\\n   460→### AgentSession Object\\n   461→\\n   462→Used as input to `write-session` and output from `read-session`.\\n   463→\\n   464→```json\\n   465→{\\n   466→  \\\"session_id\\\": \\\"abc123\\\",\\n   467→  \\\"agent_name\\\": \\\"cursor\\\",\\n   468→  \\\"repo_path\\\": \\\"/path/to/repo\\\",\\n   469→  \\\"session_ref\\\": \\\"/path/to/transcript.jsonl\\\",\\n   470→  \\\"start_time\\\": \\\"2026-01-13T12:00:00Z\\\",\\n   471→  \\\"native_data\\\": null,\\n   472→  \\\"modified_files\\\": [\\\"src/main.go\\\"],\\n   473→  \\\"new_files\\\": [\\\"src/new_file.go\\\"],\\n   474→  \\\"deleted_files\\\": []\\n   475→}\\n   476→```\\n   477→\\n   478→| Field | Type | Description |\\n   479→|---|---|---|\\n   480→| `session_id` | string | Agent session identifier |\\n   481→| `agent_name` | string | Agent registry name |\\n   482→| `repo_path` | string | Absolute path to the repository |\\n   483→| `session_ref` | string | Path/reference to session in agent's storage |\\n   484→| `start_time` | string | RFC 3339 timestamp of session start |\\n   485→| `native_data` | bytes/null | Session content in agent's native format (opaque to CLI) |\\n   486→| `modified_files` | string[] | Files modified during the session |\\n   487→| `new_files` | string[] | Files created during the session |\\n   488→| `deleted_files` | string[] | Files deleted during the session |\\n   489→\\n   490→### Event Object\\n   491→\\n   492→Returned by `parse-hook`. Represents a normalized lifecycle event.\\n   493→\\n   494→```json\\n   495→{\\n   496→  \\\"type\\\": 3,\\n   497→  \\\"session_id\\\": \\\"abc123\\\",\\n   498→  \\\"session_ref\\\": \\\"/path/to/transcript.jsonl\\\",\\n   499→  \\\"prompt\\\": \\\"Fix the login bug\\\",\\n   500→  \\\"model\\\": \\\"claude-sonnet-4-20250514\\\",\\n   501→  \\\"timestamp\\\": \\\"2026-01-13T12:00:00Z\\\"\\n   502→}\\n   503→```\\n   504→\\n   505→| Field | Type | Description |\\n   506→|---|---|---|\\n   507→| `type` | int | **Required.** Event type (see table below) |\\n   508→| `session_id` | string | **Required.** Agent session identifier |\\n   509→| `previous_session_id` | string | Non-empty when this event represents a session continuation/handoff. Optional. |\\n   510→| `session_ref` | string | Agent-specific transcript reference. Optional. |\\n   511→| `prompt` | string | User's prompt text (on `TurnStart` events). Optional. |\\n   512→| `model` | string | LLM model identifier. Optional. |\\n   513→| `timestamp` | string | RFC 3339 timestamp. Optional. |\\n   514→| `tool_use_id` | string | Tool invocation ID (for `SubagentStart`/`SubagentEnd`). Optional. |\\n   515→| `subagent_id` | string | Subagent instance ID (for `SubagentEnd`). Optional. |\\n   516→| `tool_input` | object | Raw tool input JSON (for subagent type/description extraction). Optional. |\\n   517→| `subagent_type` | string | Kind of subagent (for `SubagentStart`/`SubagentEnd`). Optional. |\\n   518→| `task_description` | string | Subagent task description. Optional. |\\n   519→| `response_message` | string | Message to display to the user via the agent. Optional. |\\n   520→| `metadata` | object | Agent-specific state preserved across events. Optional. |\\n   521→\\n   522→**Event types:**\\n   523→\\n   524→| Value | Name | Description |\\n   525→|---|---|---|\\n   526→| 1 | SessionStart | Agent session has begun |\\n   527→| 2 | TurnStart | User submitted a prompt, agent is about to work |\\n   528→| 3 | TurnEnd | Agent finished responding to a prompt |\\n   529→| 4 | Compaction | Agent is compressing its context window (triggers save + offset reset) |\\n   530→| 5 | SessionEnd | Session has been terminated |\\n   531→| 6 | SubagentStart | A subagent (task) has been spawned |\\n   532→| 7 | SubagentEnd | A subagent (task) has completed |\\n   533→\\n   534→## Error Handling\\n   535→\\n   536→- Exit code `0` indicates success.\\n   537→- Any non-zero exit code indicates an error.\\n   538→- Error messages should be written to stderr.\\n   539→- The CLI captures stderr and wraps it in a Go error.\\n   540→- If the binary is not found in PATH, the agent is simply not registered.\\n   541→- If `info` fails or returns invalid JSON, the binary is skipped during discovery.\\n   542→\\n   543→## Versioning\\n   544→\\n   545→The protocol version is declared in the `info` response (`protocol_version` field) and set via `ENTIRE_PROTOCOL_VERSION` environment variable. The CLI checks that the binary's protocol version matches its expected version before registering the agent.\\n   546→\\n   547→Future protocol versions may add new subcommands or capabilities. Existing subcommands will maintain backwards compatibility within a major version.\\n   548→\"}]},\"uuid\":\"9fba496d-d6f4-46f0-ab58-047412f0fdf3\",\"timestamp\":\"2026-03-16T08:47:59.422Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"abf3b3d48a450055c\"},\"toolUseID\":\"agent_msg_01GsUghYiGvsH78ajkViyFFd\",\"parentToolUseID\":\"toolu_01SN1FF6ejnUamrWMgteU41C\",\"uuid\":\"46598840-1449-43d5-ba2f-b7f82c2db314\",\"timestamp\":\"2026-03-16T08:47:59.424Z\",\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"1389d7d7-e618-4144-8a22-a19bc90b3c54\",\"version\":\"2.1.76\",\"gitBranch\":\"main\",\"slug\":\"delegated-fluttering-corbato\"}\n{\"parentUuid\":\"46598840-1449-43d5-ba2f-b7f82c2db314\",\"isSidechain\":false,\"type\":\"progress\",\"data\":{\"message\":{\"type