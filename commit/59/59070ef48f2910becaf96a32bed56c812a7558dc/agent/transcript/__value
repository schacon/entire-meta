th string) (*Agent, error) {\\n    35→\\tea := &Agent{binaryPath: binaryPath}\\n    36→\\n    37→\\tstdout, err := ea.run(ctx, nil, \\\"info\\\")\\n    38→\\tif err != nil {\\n    39→\\t\\treturn nil, fmt.Errorf(\\\"info: %w\\\", err)\\n    40→\\t}\\n    41→\\n    42→\\tvar info InfoResponse\\n    43→\\tif err := json.Unmarshal(stdout, &info); err != nil {\\n    44→\\t\\treturn nil, fmt.Errorf(\\\"info: invalid JSON: %w\\\", err)\\n    45→\\t}\\n    46→\\n    47→\\tif info.ProtocolVersion != ProtocolVersion {\\n    48→\\t\\treturn nil, fmt.Errorf(\\\"protocol version mismatch: binary reports %d, expected %d\\\",\\n    49→\\t\\t\\tinfo.ProtocolVersion, ProtocolVersion)\\n    50→\\t}\\n    51→\\n    52→\\tea.info = &info\\n    53→\\treturn ea, nil\\n    54→}\\n    55→\\n    56→// Info returns the cached info response.\\n    57→func (e *Agent) Info() *InfoResponse {\\n    58→\\treturn e.info\\n    59→}\\n    60→\\n    61→// --- Agent interface: Identity ---\\n    62→\\n    63→func (e *Agent) Name() types.AgentName {\\n    64→\\treturn types.AgentName(e.info.Name)\\n    65→}\\n    66→\\n    67→func (e *Agent) Type() types.AgentType {\\n    68→\\treturn types.AgentType(e.info.Type)\\n    69→}\\n    70→\\n    71→func (e *Agent) Description() string {\\n    72→\\treturn e.info.Description\\n    73→}\\n    74→\\n    75→func (e *Agent) IsPreview() bool {\\n    76→\\treturn e.info.IsPreview\\n    77→}\\n    78→\\n    79→func (e *Agent) DetectPresence(ctx context.Context) (bool, error) {\\n    80→\\tstdout, err := e.run(ctx, nil, \\\"detect\\\")\\n    81→\\tif err != nil {\\n    82→\\t\\treturn false, fmt.Errorf(\\\"detect: %w\\\", err)\\n    83→\\t}\\n    84→\\tvar resp DetectResponse\\n    85→\\tif err := json.Unmarshal(stdout, &resp); err != nil {\\n    86→\\t\\treturn false, fmt.Errorf(\\\"detect: invalid JSON: %w\\\", err)\\n    87→\\t}\\n    88→\\treturn resp.Present, nil\\n    89→}\\n    90→\\n    91→func (e *Agent) ProtectedDirs() []string {\\n    92→\\treturn e.info.P