          `json:\\\"tool_use_id,omitempty\\\"`\\n   129→\\tSubagentID        string            `json:\\\"subagent_id,omitempty\\\"`\\n   130→\\tToolInput         json.RawMessage   `json:\\\"tool_input,omitempty\\\"`\\n   131→\\tSubagentType      string            `json:\\\"subagent_type,omitempty\\\"`\\n   132→\\tTaskDescription   string            `json:\\\"task_description,omitempty\\\"`\\n   133→\\tResponseMessage   string            `json:\\\"response_message,omitempty\\\"`\\n   134→\\tMetadata          map[string]string `json:\\\"metadata,omitempty\\\"`\\n   135→}\\n   136→\\n   137→func (ej *eventJSON) toEvent() (*agent.Event, error) {\\n   138→\\tev := &agent.Event{\\n   139→\\t\\tType:              agent.EventType(ej.Type),\\n   140→\\t\\tSessionID:         ej.SessionID,\\n   141→\\t\\tPreviousSessionID: ej.PreviousSessionID,\\n   142→\\t\\tSessionRef:        ej.SessionRef,\\n   143→\\t\\tPrompt:            ej.Prompt,\\n   144→\\t\\tModel:             ej.Model,\\n   145→\\t\\tToolUseID:         ej.ToolUseID,\\n   146→\\t\\tSubagentID:        ej.SubagentID,\\n   147→\\t\\tToolInput:         ej.ToolInput,\\n   148→\\t\\tSubagentType:      ej.SubagentType,\\n   149→\\t\\tTaskDescription:   ej.TaskDescription,\\n   150→\\t\\tResponseMessage:   ej.ResponseMessage,\\n   151→\\t\\tMetadata:          ej.Metadata,\\n   152→\\t}\\n   153→\\tif ej.Timestamp != \\\"\\\" {\\n   154→\\t\\tt, err := time.Parse(time.RFC3339, ej.Timestamp)\\n   155→\\t\\tif err != nil {\\n   156→\\t\\t\\treturn nil, fmt.Errorf(\\\"invalid timestamp: %w\\\", err)\\n   157→\\t\\t}\\n   158→\\t\\tev.Timestamp = t\\n   159→\\t}\\n   160→\\treturn ev, nil\\n   161→}\\n   162→\\n   163→// HookInputJSON is the JSON representation of agent.HookInput for stdin/stdout transfer.\\n   164→type HookInputJSON struct {\\n   165→\\tHookType   string                 `json:\\\"hook_type\\\"`\\n   166→\\tSessionID  string                 `json:\\\"session_id\\\"`\\n   167→\\tSessionRef string                 `