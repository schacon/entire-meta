263→\\trepo, err := openRepository(ctx)\\n   264→\\tif err != nil {\\n   265→\\t\\treturn files // fail open\\n   266→\\t}\\n   267→\\n   268→\\thead, err := repo.Head()\\n   269→\\tif err != nil {\\n   270→\\t\\treturn files // fail open (empty repo, detached HEAD, etc.)\\n   271→\\t}\\n   272→\\n   273→\\tcommit, err := repo.CommitObject(head.Hash())\\n   274→\\tif err != nil {\\n   275→\\t\\treturn files // fail open\\n   276→\\t}\\n   277→\\n   278→\\theadTree, err := commit.Tree()\\n   279→\\tif err != nil {\\n   280→\\t\\treturn files // fail open\\n   281→\\t}\\n   282→\\n   283→\\tvar result []string\\n   284→\\tfor _, relPath := range files {\\n   285→\\t\\theadFile, err := headTree.File(relPath)\\n   286→\\t\\tif err != nil {\\n   287→\\t\\t\\t// File not in HEAD — it's uncommitted\\n   288→\\t\\t\\tresult = append(result, relPath)\\n   289→\\t\\t\\tcontinue\\n   290→\\t\\t}\\n   291→\\n   292→\\t\\t// File is in HEAD — compare content with working tree\\n   293→\\t\\tabsPath := filepath.Join(repoRoot, relPath)\\n   294→\\t\\tworkingContent, err := os.ReadFile(absPath) //nolint:gosec // path from controlled source\\n   295→\\t\\tif err != nil {\\n   296→\\t\\t\\t// Can't read working tree file (deleted?) — keep it\\n   297→\\t\\t\\tresult = append(result, relPath)\\n   298→\\t\\t\\tcontinue\\n   299→\\t\\t}\\n   300→\\n   301→\\t\\theadContent, err := headFile.Contents()\\n   302→\\t\\tif err != nil {\\n   303→\\t\\t\\tresult = append(result, relPath)\\n   304→\\t\\t\\tcontinue\\n   305→\\t\\t}\\n   306→\\n   307→\\t\\tif string(workingContent) != headContent {\\n   308→\\t\\t\\t// Working tree differs from HEAD — uncommitted changes\\n   309→\\t\\t\\tresult = append(result, relPath)\\n   310→\\t\\t}\\n   311→\\t\\t// else: content matches HEAD — already committed, skip\\n   312→\\t}\\n   313→\\n   314→\\treturn result\\n   315→}\\n   316→\\n   317→// FilterAndNormalizePaths converts absolute paths to relative and filters out\\n   318→// infrastructure paths and paths outside the repo.\\n   319→func FilterAndNormalizePaths(files []string, cwd string) []string {\\n   320→\\tvar result []string\\n   321→\\tfor _, file := range files {\\n   322→\\t\\trelPath := paths.ToRelativePath(file, cwd)\\n   323→\\t\\tif relPath == \\\"\\\" {\\n   324→\\t\\t\\tcontinue // outside repo\\n   325→\\t\\t}\\n   326→\\t\\tif paths.IsInfrastructurePath(relPath) {\\n   327→\\t\\t\\tcontinue // skip .entire directory\\n   328→\\t\\t}\\n   329→\\t\\tresult = append(result, relPath)\\n   330→\\t}\\n   331→\\treturn result\\n   332→}\\n   333→\\n   334→// mergeUnique appends elements from extra into base, skipping duplicates already in base.\\n   335→func mergeUnique(base, extra []string) []string {\\n   336→\\tif len(extra) == 0 {\\n   337→\\t\\treturn base\\n   338→\\t}\\n   339→\\tseen := make(map[string]bool, len(base))\\n   340→\\tfor _, s := range base {\\n   341→\\t\\tseen[s] = true\\n   342→\\t}\\n   343→\\tfor _, s := range extra {\\n   344→\\t\\tif !seen[s] {\\n   345→\\t\\t\\tseen[s] = true\\n   346→\\t\\t\\tbase = append(base, s)\\n   347→\\t\\t}\\n   348→\\t}\\n   349→\\treturn base\\n   350→}\\n   351→\\n   352→// prePromptStateFile returns the absolute path to the pre-prompt state file for a session.\\n   353→// Works correctly from any subdirectory within the repository.\\n   354→func prePromptStateFile(ctx context.Context, sessionID string) string {\\n   355→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   356→\\tif err != nil {\\n   357→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   358→\\t}\\n   359→\\treturn filepath.Join(tmpDirAbs, fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID))\\n   360→}\\n   361→\\n   362→// getUntrackedFilesForState returns a list of untracked files using go-git\\n   363→// Excludes .entire directory\\n   364→func getUntrackedFilesForState(ctx context.Context) ([]string, error) {\\n   365→\\trepo, err := openRepository(ctx)\\n   366→\\tif err != nil {\\n   367→\\t\\treturn nil, err\\n   368→\\t}\\n   369→\\n   370→\\tworktree, err := repo.Worktree()\\n   371→\\tif err != nil {\\n   372→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   373→\\t}\\n   374→\\n   375→\\tstatus, err := worktree.Status()\\n   376→\\tif err != nil {\\n   377→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   378→\\t}\\n   379→\\n   380→\\tuntrackedFiles := []string{}\\n   381→\\tfor file, st := range status {\\n   382→\\t\\tif st.Worktree == git.Untracked {\\n   383→\\t\\t\\t// Exclude .entire directory\\n   384→\\t\\t\\tif !strings.HasPrefix(file, paths.EntireDir+\\\"/\\\") && file != paths.EntireDir {\\n   385→\\t\\t\\t\\tuntrackedFiles = append(untrackedFiles, file)\\n   386→\\t\\t\\t}\\n   387→\\t\\t}\\n   388→\\t}\\n   389→\\n   390→\\treturn untrackedFiles, nil\\n   391→}\\n   392→\\n   393→// PreTaskState stores the state captured before a task execution\\n   394→type PreTaskState struct {\\n   395→\\tToolUseID      string   `json:\\\"tool_use_id\\\"`\\n   396→\\tTimestamp      string   `json:\\\"timestamp\\\"`\\n   397→\\tUntrackedFiles []string `json:\\\"untracked_files\\\"`\\n   398→}\\n   399→\\n   400→// PreUntrackedFiles returns the untracked files list, or nil if the receiver is nil.\\n   401→// See PrePromptState.PreUntrackedFiles for nil-vs-empty semantics.\\n   402→func (s *PreTaskState) PreUntrackedFiles() []string {\\n   403→\\tif s == nil {\\n   404→\\t\\treturn nil\\n   405→\\t}\\n   406→\\tif s.UntrackedFiles == nil {\\n   407→\\t\\treturn []string{}\\n   408→\\t}\\n   409→\\treturn s.UntrackedFiles\\n   410→}\\n   411→\\n   412→// CapturePreTaskState captures current untracked files before a Task execution\\n   413→// and saves them to a state file.\\n   414→// Works correctly from any subdirectory within the repository.\\n   415→func CapturePreTaskState(ctx context.Context, toolUseID string) error {\\n   416→\\tif toolUseID == \\\"\\\" {\\n   417→\\t\\treturn errors.New(\\\"tool_use_id is required\\\")\\n   418→\\t}\\n   419→\\n   420→\\t// Get absolute path for tmp directory\\n   421→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   422→\\tif err != nil {\\n   423→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   424→\\t}\\n   425→\\n   426→\\t// Create tmp directory if it doesn't exist\\n   427→\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   428→\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n   429→\\t}\\n   430→\\n   431→\\t// Get list of untracked files (excluding .entire directory itself)\\n   432→\\tuntrackedFiles, err := getUntrackedFilesForState(ctx)\\n   433→\\tif err != nil {\\n   434→\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n   435→\\t}\\n   436→\\n   437→\\t// Create state file\\n   438→\\tstateFile := preTaskStateFile(ctx, toolUseID)\\n   439→\\tstate := PreTaskState{\\n   440→\\t\\tToolUseID:      toolUseID,\\n   441→\\t\\tTimestamp:      time.Now().UTC().Format(time.RFC3339),\\n   442→\\t\\tUntrackedFiles: untrackedFiles,\\n   443→\\t}\\n   444→\\n   445→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   446→\\tif err != nil {\\n   447→\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n   448→\\t}\\n   449→\\n   450→\\tif err := os.WriteFile(stateFile, data, 0o600); err != nil {\\n   451→\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   452→\\t}\\n   453→\\n   454→\\tlogging.Debug(logging.WithComponent(ctx, \\\"state\\\"), \\\"captured state before task\\\",\\n   455→\\t\\tslog.Int(\\\"untracked_files\\\", len(untrackedFiles)))\\n   456→\\treturn nil\\n   457→}\\n   458→\\n   459→// LoadPreTaskState loads previously captured task state.\\n   460→// Returns nil if no state file exists.\\n   461→func LoadPreTaskState(ctx context.Context, toolUseID string) (*PreTaskState, error) {\\n   462→\\tstateFile := preTaskStateFile(ctx, toolUseID)\\n   463