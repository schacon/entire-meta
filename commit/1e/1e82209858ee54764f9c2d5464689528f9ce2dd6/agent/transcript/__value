oolUseBlocks(message.content);\\n   206→      for (const tu of toolUses) {\\n   207→        const toolData = toolUseById.get(tu.id);\\n   208→        if (toolData) {\\n   209→          const toolCall: ToolCall = {\\n   210→            id: tu.id,\\n   211→            name: tu.name,\\n   212→            input: tu.input,\\n   213→            timestamp: toolData.timestamp,\\n   214→            result: toolResultById.get(tu.id),\\n   215→          };\\n   216→          toolCallsPerTurn.push(toolCall);\\n   217→        }\\n   218→      }\\n   219→\\n   220→      // Also extract text content for the message\\n   221→      const { text, images } = extractTextContent(message.content);\\n   222→      const content = text.trim();\\n   223→      const requestId = (parsed.requestId as string) || (message.id as string);\\n   224→      if (!requestId) continue;\\n   225→\\n   226→      const existingIdx = assistantByRequestId.get(requestId);\\n   227→      if (existingIdx !== undefined) {\\n   228→        // Streaming update: replace with latest content\\n   229→        if (content) {\\n   230→          messages[existingIdx].content = content;\\n   231→          messages[existingIdx].timestamp = timestamp;\\n   232→        }\\n   233→        if (images.length > 0) {\\n   234→          messages[existingIdx].images = images;\\n   235→        }\\n   236→      } else {\\n   237→        assistantByRequestId.set(requestId, messages.length);\\n   238→        messages.push({\\n   239→          role: \\\"assistant\\\",\\n   240→          content,\\n   241→          images,\\n   242→          timestamp,\\n   243→          id: (message.id as string) || crypto.randomUUID(),\\n   244→        });\\n   245→      }\\n   246→    } else {\\n   247→      // User message\\n   248→      const { text, images, hasToolResults } = extractTextContent(\\n   249→        message.content,\\n   250→      );\\n   251→      const content = text.trim();\\n   252→\\n   253→      // Skip user messages that are only tool results and have no text/images\\n   254→      if ((!content && images.length === 0) || hasToolResults) continue;\\n   255→\\n   256→      messages.push({\\n   257→        role: \\\"user\\\",\\n   258→        content,\\n   259→        images,\\n   260→        timestamp,\\n   261→        id: (parsed.uuid as string) || crypto.randomUUID(),\\n   262→      });\\n   263→    }\\n   264→  }\\n   265→\\n   266→  // Sort by timestamp\\n   267→  messages.sort(\\n   268→    (a, b) => new Date(a.timestamp).getTime() - new Date(b.timestamp).getTime(),\\n   269→  );\\n   270→\\n   271→  // Sort tool calls by timestamp for proper ordering\\n   272→  toolCallsPerTurn.sort(\\n   273→    (a, b) => new Date(a.timestamp).getTime() - new Date(b.timestamp).getTime(),\\n   274→  );\\n   275→\\n   276→  // Build result: keep only the last assistant before each user (and final assistant)\\n   277→  // Attach tool calls that happened between user messages to the assistant response\\n   278→  const result: TranscriptMessage[] = [];\\n   279→  let lastAssistant: (InternalMessage & { toolCalls?: ToolCall[] }) | null =\\n   280→    null;\\n   281→  let lastUserTimestamp: string | null = null;\\n   282→\\n   283→  const hasContent = (m: InternalMessage) => m.content || m.images.length > 0;\\n   284→\\n   285→  // Helper to get tool calls between two timestamps\\n   286→  const getToolCallsInRange = (\\n   287→    startTs: string | null,\\n   288→    endTs: string,\\n   289→  ): ToolCall[] => {\\n   290→    return toolCallsPerTurn.filter((tc) => {\\n   291→      const tcTime = new Date(tc.timestamp).getTime();\\n   292→      const endTime = new Date(endTs).getTime();\\n   293→      if (startTs === null) {\\n   294→        return tcTime <= endTime;\\n   295→      }\\n   296→      const startTime = new Date(startTs).getTime();\\n   297→      return tcTime > startTime && tcTime <= endTime;\\n   298→    });\\n   299→  };\\n   300→\\n   301→  for (const msg of messages) {\\n   302→    if (msg.role