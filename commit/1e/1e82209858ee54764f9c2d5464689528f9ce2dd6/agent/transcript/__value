ly\\n   506→// modified one.\\n   507→// Works correctly from any subdirectory within the repository.\\n   508→func FindActivePreTaskFile(ctx context.Context) (taskToolUseID string, found bool) {\\n   509→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   510→\\tif err != nil {\\n   511→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   512→\\t}\\n   513→\\tentries, err := os.ReadDir(tmpDirAbs)\\n   514→\\tif err != nil {\\n   515→\\t\\treturn \\\"\\\", false\\n   516→\\t}\\n   517→\\n   518→\\tvar latestFile string\\n   519→\\tvar latestTime time.Time\\n   520→\\n   521→\\tfor _, entry := range entries {\\n   522→\\t\\tif entry.IsDir() {\\n   523→\\t\\t\\tcontinue\\n   524→\\t\\t}\\n   525→\\t\\tname := entry.Name()\\n   526→\\t\\tif !strings.HasPrefix(name, preTaskFilePrefix) || !strings.HasSuffix(name, \\\".json\\\") {\\n   527→\\t\\t\\tcontinue\\n   528→\\t\\t}\\n   529→\\n   530→\\t\\t// Check modification time for nested subagent handling\\n   531→\\t\\tinfo, err := entry.Info()\\n   532→\\t\\tif err != nil {\\n   533→\\t\\t\\tcontinue\\n   534→\\t\\t}\\n   535→\\t\\tif latestFile == \\\"\\\" || info.ModTime().After(latestTime) {\\n   536→\\t\\t\\tlatestFile = name\\n   537→\\t\\t\\tlatestTime = info.ModTime()\\n   538→\\t\\t}\\n   539→\\t}\\n   540→\\n   541→\\tif latestFile == \\\"\\\" {\\n   542→\\t\\treturn \\\"\\\", false\\n   543→\\t}\\n   544→\\n   545→\\t// Extract tool_use_id from filename: pre-task-<tool_use_id>.json\\n   546→\\ttoolUseID := strings.TrimPrefix(latestFile, preTaskFilePrefix)\\n   547→\\ttoolUseID = strings.TrimSuffix(toolUseID, \\\".json\\\")\\n   548→\\treturn toolUseID, true\\n   549→}\\n   550→\\n   551→// GetNextCheckpointSequence returns the next sequence number for incremental checkpoints.\\n   552→// It counts existing checkpoint files in the task metadata checkpoints directory.\\n   553→// Returns 1 if no checkpoints exist yet.\\n   554→func GetNextCheckpointSequence(sessionID, taskToolUseID string