if err := validation.ValidateSessionID(sessionID); err != nil {\\n    65→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n    66→\\t}\\n    67→\\n    68→\\t// Ensure we're in a git repo\\n    69→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n    70→\\tif err != nil {\\n    71→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n    72→\\t}\\n    73→\\n    74→\\t// Check session isn't already tracked\\n    75→\\tstore, err := session.NewStateStore(ctx)\\n    76→\\tif err != nil {\\n    77→\\t\\treturn fmt.Errorf(\\\"failed to open session store: %w\\\", err)\\n    78→\\t}\\n    79→\\texisting, err := store.Load(ctx, sessionID)\\n    80→\\tif err != nil {\\n    81→\\t\\treturn fmt.Errorf(\\\"failed to check existing session: %w\\\", err)\\n    82→\\t}\\n    83→\\tif existing != nil {\\n    84→\\t\\treturn fmt.Errorf(\\\"session %s is already tracked by Entire\\\", sessionID)\\n    85→\\t}\\n    86→\\n    87→\\t// Resolve agent and transcript path\\n    88→\\tag, err := agent.Get(agentName)\\n    89→\\tif err != nil {\\n    90→\\t\\treturn fmt.Errorf(\\\"agent %q not available: %w\\\", agentName, err)\\n    91→\\t}\\n    92→\\tagentType := ag.Type()\\n    93→\\n    94→\\ttranscriptPath, err := resolveAndValidateTranscript(logCtx, sessionID, agentName, ag)\\n    95→\\tif err != nil {\\n    96→\\t\\treturn err\\n    97→\\t}\\n    98→\\n    99→\\t// Read transcript data\\n   100→\\ttranscriptData, err := ag.ReadTranscript(transcriptPath)\\n   101→\\tif err != nil {\\n   102→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   103→\\t}\\n   104→\\n   105→\\t// Extract modified files from transcript\\n   106→\\tvar modifiedFiles []string\\n   107→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok {\\n   108→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptPath, 0); fileErr != nil {\\n   109→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files from transcript\\\", \\\"error\\\", fileErr)\\n   110→\\t\\t} else {\\n   111→\\t\\t\\tmodifiedFiles = files\\n   112→\\t\\t}\\n   113→\\t}\\n   114→\\n   115→\\t// Detect file changes via git status (no pre-untracked filter since we don't know pre-state)\\n   116→\\tchanges, err := DetectFileChanges(ctx, nil)\\n   117→\\tif err != nil {\\n   118→\\t\\tlogging.Warn(logCtx, \\\"failed to detect file changes, checkpoint may be incomplete\\\", \\\"error\\\", err)\\n   119→\\t}\\n   120→\\n   121→\\t// Filter and normalize paths\\n   122→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   123→\\tvar relNewFiles, relDeletedFiles []string\\n   124→\\tif changes != nil {\\n   125→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   126→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   127→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   128→\\t}\\n   129→\\n   130→\\t// Filter to uncommitted files only\\n   131→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   132→\\n   133→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   134→\\t\\treturn fmt.Errorf(\\\"failed to set up strategy: %w\\\", err)\\n   135→\\t}\\n   136→\\n   137→\\t// Create session metadata directory and copy transcript\\n   138→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   139→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   140→\\tif err != nil {\\n   141→\\t\\treturn fmt.Errorf(\\\"failed to resolve session directory path: %w\\\", err)\\n   142→\\t}\\n   143→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   144→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   145→\\t}\\n   146→\\t// Normalize Gemini transcripts so the content field is a plain string\\n   147→\\t// (Gemini user messages use [{\\\"text\\\":\\\"...\\\"}] arrays, which the UI can't render).\\n   148→\\tstoredTranscript := transcriptData\\n   149→\\tif agentType == agent.AgentTypeGemini {\\n   150→\\t\\tif normalized, normErr := normalizeGeminiTranscript(transcriptData); normErr == nil {\\n   151→\\t\\t\\tstoredTranscript = normalized\\n   152→\\t\\t} else {\\n   153→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to normalize Gemini transcript, storing raw\\\", \\\"error\\\", normErr)\\n   154→\\t\\t}\\n   155→\\t}\\n   156→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   157→\\tif err := os.WriteFile(logFile, storedTranscript, 0o600); err != nil {\\n   158→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   159→\\t}\\n   160→\\n   161→\\t// Get git author\\n   162→\\tauthor, err := GetGitAuthor(ctx)\\n   163→\\tif err != nil {\\n   164→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   165→\\t}\\n   166→\\n   167→\\t// Extract first prompt from transcript for the commit message\\n   168→\\tfirstPrompt := extractFirstPromptFromTranscript(transcriptData)\\n   169→\\tcommitMessage := generateCommitMessage(firstPrompt, agentType)\\n   170→\\n   171→\\t// Write prompt.txt so SaveStep includes it on the shadow branch\\n   172→\\t// and CondenseSession can read it for the checkpoint metadata.\\n   173→\\tif firstPrompt != \\\"\\\" {\\n   174→\\t\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   175→\\t\\tif err := os.WriteFile(promptFile, []byte(firstPrompt), 0o600); err != nil {\\n   176→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to write prompt file\\\", \\\"error\\\", err)\\n   177→\\t\\t}\\n   178→\\t}\\n   179→\\n   180→\\t// Initialize session state BEFORE SaveStep so it exists when SaveStep loads it\\n   181→\\tstrat := GetStrategy(ctx)\\n   182→\\tif err := strat.InitializeSession(ctx, sessionID, agentType, transcriptPath, firstPrompt, \\\"\\\"); err != nil {\\n   183→\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n   184→\\t}\\n   185→\\n   186→\\t// Enrich session state with transcript-derived metadata\\n   187→\\tif err := enrichSessionState(logCtx, sessionID, ag, transcriptData, transcriptPath); err != nil {\\n   188→\\t\\treturn err\\n   189→\\t}\\n   190→\\n   191→\\t// Build step context and save checkpoint\\n   192→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   193→\\n   194→\\tstepCtx := strategy.StepContext{\\n   195→\\t\\tSessionID:      sessionID,\\n   196→\\t\\tModifiedFiles:  relModifiedFiles,\\n   197→\\t\\tNewFiles:       relNewFiles,\\n   198→\\t\\tDeletedFiles:   relDeletedFiles,\\n   199→\\t\\tMetadataDir:    sessionDir,\\n   200→\\t\\tMetadataDirAbs: sessionDirAbs,\\n   201→\\t\\tCommitMessage:  commitMessage,\\n   202→\\t\\tTranscriptPath: transcriptPath,\\n   203→\\t\\tAuthorName:     author.Name,\\n   204→\\t\\tAuthorEmail:    author.Email,\\n   205→\\t\\tAgentType:      agentType,\\n   206→\\t}\\n   207→\\n   208→\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   209→\\t\\treturn fmt.Errorf(\\\"failed to save checkpoint: %w\\\", err)\\n   210→\\t}\\n   211→\\n   212→\\tcheckpointIDStr, condenseErr := condenseAndFinalizeSession(logCtx, strat, sessionID)\\n   213→\\n   214→\\t// Print confirmation\\n   215→\\tfmt.Fprintf(w, \\\"Attached session %s\\\\n\\\", sessionID)\\n   216→\\tif totalChanges > 0 {\\n   217→\\t\\tfmt.Fprintf(w, \\\"  Checkpoint saved with %d file(s)\\\\n\\\", totalChanges)\\n   218→\\t} else {\\n   219→\\t\\tfmt.Fprintln(w, \\\"  Checkpoint saved (transcript only, no uncommitted file changes detected)\\\")\\n   220→\\t}\\n   221→\\tif condenseErr != nil {\\n   222→\\t\\tfmt.Fprintln(w, \\\"  Warning: checkpoint saved on shadow branch only (condensation failed)\\\")\\n   223→\\t}\\n   224→\\tfmt.Fprintln(w, \\\"  Session is now tracked — future prompts will be captured automatically\\\")\\n   225→\\n   226→\\t// Offer to amend the last commit with the checkpoint trailer\\n   227→\\tif checkpointIDStr != \\\"\\\" {\\n   228→\\t\\tif err := promptAmendCommit(ctx, w, checkpointIDStr, force); err != nil {\\n   229→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to amend commit\\\", \\\"error\\\", err)\\n   230→\\t\\t\\tfmt.Fprintf(w, \\\"\\\\nCopy to your commit message to attach:\\\\n\\\\n  Entire-Checkpoint: %s\\\\n\\\", checkpointIDStr)\\n   231→\\t\\t}\\n   232→\\t}\\n   233→\\n   234→\\treturn nil\\n   235→}\\n   236→\\n   237→// enrichSessionState loads the session state after initialization and populates it with\\n   238→// transcript-derived metadata (token usage, turn count, model name, duration).\\n   239→func enrichSessionState(ctx context.Context, sessionID string, ag agent.Agent, transcriptData []byte, transcriptPath string) error {\\n   240→\\tstate, err := strategy.LoadSessionState(ctx, sessionID)\\n   241→\\tif err != nil {\\n   242→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   243→\\t}\\n   244→\\tif state == nil {\\n   245→\\t\\treturn fmt.Errorf(\\\"session state not found after initialization (session_id=%s)\\\", sessionID)\\n   246→\\t}\\n   247→\\tstate.CLIVersion = versioninfo.Version\\n   248→\\tstate.TranscriptPath = transcriptPath\\n   249→\\n   250→\\tif usage := agent.CalculateTokenUsage(ctx, ag, transcriptData, 0, \\\"\\\"); usage != nil {\\n   251→\\t\\tstate.TokenUsage = usage\\n   252→\\t}\\n   253→\\tif turns := countUserTurns(transcriptData); turns > 0 {\\n   254→\\t\\tstate.SessionTurnCount = turns\\n   255→\\t}\\n   256→\\tif model := extractModelFromTranscript(transcriptData); model != \\\"\\\" {\\n   257→\\t\\tstate.ModelName = model\\n   258→\\t}\\n   259→\\tif dur := estimateSessionDuration(transcriptData); dur > 0 {\\n   260→\\t\\tstate.SessionDurationMs = dur\\n   261→\\t}\\n   262→\\n   263→\\tif err := strategy.SaveSessionState(ctx, state); err != nil {\\n   264→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   265→\\t}\\n   266→\\treturn nil\\n   267→}\\n   268→\\n   269→// condenseAndFinalizeSession condenses the session to permanent storage and transitions it to IDLE.\\n   270→// Returns the checkpoint ID string and any condensation error.\\n   271→func condenseAndFinalizeSession(ctx context.Context, strat *strategy.ManualCommitStrategy, sessionID string) (string, error) {\\n   272→\\tvar checkpointIDStr string\\n   273→\\tvar condenseErr error\\n   274→\\tif err := strat.CondenseSessionByID(ctx, sessionID); err != nil {\\n   275→\\t\\tlogging.Warn(ctx, \\\"failed to condense session\\\", \\\"error\\\", err, \\\"session_id\\\", sessionID)\\n   276→\\t\\tcondenseErr = err\\n   277→\\t}\\n   278→\\n   279→\\t// Single load serves both checkpoint ID extraction and finalization\\n   280→\\tstate, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   281→\\tif loadErr != nil {\\n   282→\\t\\tlogging.Warn(ctx, \\\"failed to load session state after condensation\\\", \\\"error\\\", loadErr, \\\"session_id\\\", sessionID)\\n   283→\\t\\treturn checkpointIDStr, condenseErr\\n   284→\\t}\\n   285→\\tif state == nil {\\n   286→\\t\\treturn checkpointIDStr, condenseErr\\n   287→\\t}\\n   288→\\n   289→\\tif condenseErr == nil {\\n   290→\\t\\tcheckpointIDStr = state.LastCheckpointID.String()\\n   291→\\t}\\n   292→\\n   293→\\tnow := time.Now()\\n   294→\\tstate.LastInteractionTime = &now\\n   295→\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   296→\\t\\tlogging.Warn(ctx, \\\"failed to transition session to idle\\\", \\\"error\\\", transErr, \\\"session_id\\\", sessionID)\\n   297→\\t}\\n   298→\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   299→\\t\\tlogging.Warn(ctx, \\\"failed to save session state after transition\\\", \\\"error\\\", saveErr, \\\"session_id\\\", sessionID)\\n   300→\\t}\\n   301→\\n   302→\\treturn checkpointIDStr, condenseErr\\n   303→}\\n   304→\\n   305→// resolveAndValidateTranscript finds the transcript file for a session, searching alternative\\n   306→// project directories if needed.\\n   307→func resolveAndValidateTranscript(ctx context.Context, sessionID string, agentName types.AgentName, ag agent.Agent) (string, error) {\\n   308→\\ttranscriptPath, err := resolveTranscriptPath(ctx, sessionID, ag)\\n   309→\\tif err != nil {\\n   310→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to resolve transcript path: %w\\\", err)\\n   311→\\t}\\n   312→\\t// Agents use cwd-derived project directories, so the transcript may be stored under\\n   313→\\t// a different project directory if the session was started from a different working directory.\\n   314→\\tif _, statErr := os.Stat(transcriptPath); statErr != nil {\\n   315→\\t\\tif found, searchErr := searchTranscriptInProjectDirs(agentName, sessionID, ag); searchErr == nil {\\n   316→\\t\\t\\tlogging.Info(ctx, \\\"found transcript in alternative project directory\\\", \\\"path\\\", found)\\n   317→\\t\\t\\ttranscriptPath = found\\n   318→\\t\\t} else {\\n   319→\\t\\t\\tlogging.Debug(ctx, \\\"fallback transcript search failed\\\", \\\"error\\\", searchErr)\\n   320→\\t\\t}\\n   321→\\t}\\n   322→\\tif _, statErr := os.Stat(transcriptPath); statErr != nil {\\n   323→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"transcript not found for agent %q with session %s; is the session ID correct?\\\", agentName, sessionID)\\n   324→\\t}\\n   325→\\treturn transcriptPath, nil\\n   326→}\\n   327→\\n   328→// promptAmendCommit shows the last commit and asks whether to amend it with the checkpoint trailer.\\n   329→// When force is true, it amends without prompting.\\n   330→func promptAmendCommit(ctx context.Context, w io.Writer, checkpointIDStr string, force bool) error {\\n   331→\\t// Get HEAD commit info\\n   332→\\trepo, err := openRepository(ctx)\\n   333→\\tif err != nil {\\n   334→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   335→\\t}\\n   336→\\theadRef, err := repo.Head()\\n   337→\\tif err != nil {\\n   338→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   339→\\t}\\n   340→\\theadCommit, err := repo.CommitObject(headRef.Hash())\\n   341→\\tif err != nil {\\n   342→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   343→\\t}\\n   344→\\n   345→\\tshortHash := headRef.Hash().String()[:7]\\n   346→\\tsubject := strings.SplitN(headCommit.Message, \\\"\\\\n\\\", 2)[0]\\n   347→\\n   348→\\tfmt.Fprintf(w, \\\"\\\\nLast commit: %s %s\\\\n\\\", shortHash, subject)\\n   349→\\n   350→\\tamend := true\\n   351→\\tif !force {\\n   352→\\t\\tform := NewAccessibleForm(\\n   353→\\t\\t\\thuh.NewGroup(\\n   354→\\t\\t\\t\\thuh.NewConfirm().\\n   355→\\t\\t\\t\\t\\tTitle(\\\"Amend the last commit in this branch?\\\").\\n   356→\\t\\t\\t\\t\\tAffirmative(\\\"Y\\\").\\n   357→\\t\\t\\t\\t\\tNegative(\\\"n\\\").\\n   358→\\t\\t\\t\\t\\tValue(&amend),\\n   359→\\t\\t\\t),\\n   360→\\t\\t)\\n   361→\\t\\tif err := form.Run(); err != nil {\\n   362→\\t\\t\\treturn fmt.Errorf(\\\"prompt failed: %w\\\", err)\\n   363→\\t\\t}\\n   364→\\t}\\n   365→\\n   366→\\tif !amend {\\n   367→\\t\\tfmt.Fprintf(w, \\\"\\\\nCopy to your commit message to attach:\\\\n\\\\n  Entire-Checkpoint: %s\\\\n\\\", checkpointIDStr)\\n   368→\\t\\treturn nil\\n   369→\\t}\\n   370→\\n   371→\\t// Amend the commit with the checkpoint trailer.\\n   372→\\t// If the message already has trailers, append on a new line; otherwise add a blank line first.\\n   373→\\ttrimmed := strings.TrimRight(headCommit.Message, \\\"\\\\n\\\")\\n   374→\\ttrailer := fmt.Sprintf(\\\"%s: %s\\\", trailers.CheckpointTrailerKey, checkpointIDStr)\\n   375→\\tvar newMessage string\\n   376→\\tif _, found := trailers.ParseCheckpoint(headCommit.Message); found {\\n   377→\\t\\t// Already has at least one Entire-Checkpoint trailer — append directly\\n   378→\\t\\tnewMessage = fmt.Sprintf(\\\"%s\\\\n%s\\\\n\\\", trimmed, trailer)\\n   379→\\t} else {\\n   380→\\t\\tnewMessage = fmt.Sprintf(\\\"%s\\\\n\\\\n%s\\\\n\\\", trimmed, trailer)\\n   381→\\t}\\n   382→\\n   383→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"commit\\\", \\\"--amend\\\", \\\"-m\\\", newMessage)\\n   384→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   385→\\t\\treturn fmt.Errorf(\\\"failed to amend commit: %w\\\\n%s\\\", err, output)\\n   386→\\t}\\n   387→\\n   388→\\tfmt.Fprintf(w, \\\"Amended commit %s with Entire-Checkpoint: %s\\\\n\\\", shortHash, checkpointIDStr)\\n   389→\\treturn nil\\n   390→}\\n   391→\\n   392→// extractFirstPromptFromTranscript reads transcript bytes and returns the first user prompt.\\n   393→// Supports both JSONL format (Claude Code, Cursor, OpenCode) and Gemini JSON format.\\n   394→func extractFirstPromptFromTranscript(data []byte) string {\\n   395→\\t// Try JSONL format first (Claude Code, Cursor, OpenCode, etc.)\\n   396→\\tlines, err := transcript.ParseFromBytes(data)\\n   397→\\tif err == nil {\\n   398→\\t\\tfor _, line := range lines {\\n   399→\\t\\t\\tif line.Type == transcript.TypeUser {\\n   400→\\t\\t\\t\\tprompt := extractTextFromMessage(line.Message)\\n   401→\\t\\t\\t\\tif prompt != \\\"\\\" {\\n   402→\\t\\t\\t\\t\\treturn prompt\\n   403→\\t\\t\\t\\t}\\n   404→\\t\\t\\t}\\n   405→\\t\\t}\\n   406→\\t}\\n   407→\\n   408→\\t// Fallback: try Gemini JSON format {\\\"messages\\\": [...]}\\n   409→\\tif prompts, gemErr := geminicli.ExtractAllUserPrompts(data); gemErr == nil && len(prompts) > 0 {\\n   410→\\t\\treturn prompts[0]\\n   411→\\t}\\n   412→\\n   413→\\treturn \\\"\\\"\\n   414→}\\n   415→\\n   416→// extractTextFromMessage extracts the text content from a transcript message.\\n   417→func extractTextFromMessage(msg json.RawMessage) string {\\n   418→\\t// Try string content first (simple user messages)\\n   419→\\tvar simple struct {\\n   420→\\t\\tContent string `json:\\\"content\\\"`\\n   421→\\t}\\n   422→\\tif err := json.Unmarshal(msg, &simple); err == nil && simple.Content != \\\"\\\" {\\n   423→\\t\\treturn simple.Content\\n   424