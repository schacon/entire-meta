ent-%s.jsonl\\\", agentID))\\n   101→}\\n   102→\\n   103→// toolResultBlock represents a tool_result in a user message\\n   104→type toolResultBlock struct {\\n   105→\\tType      string `json:\\\"type\\\"`\\n   106→\\tToolUseID string `json:\\\"tool_use_id\\\"`\\n   107→}\\n   108→\\n   109→// userMessageWithToolResults represents a user message that may contain tool results\\n   110→type userMessageWithToolResults struct {\\n   111→\\tContent []toolResultBlock `json:\\\"content\\\"`\\n   112→}\\n   113→\\n   114→// FindCheckpointUUID finds the UUID of the message containing the tool_result\\n   115→// for the given tool_use_id. This is used to find the checkpoint point for\\n   116→// transcript truncation when rewinding to a task.\\n   117→// Returns the UUID and true if found, empty string and false otherwise.\\n   118→func FindCheckpointUUID(transcript []transcriptLine, toolUseID string) (string, bool) {\\n   119→\\tfor _, line := range transcript {\\n   120→\\t\\tif line.Type != transcriptTypeUser {\\n   121→\\t\\t\\tcontinue\\n   122→\\t\\t}\\n   123→\\n   124→\\t\\tvar msg userMessageWithToolResults\\n   125→\\t\\tif err := json.Unmarshal(line.Message, &msg); err != nil {\\n   126→\\t\\t\\tcontinue\\n   127→\\t\\t}\\n   128→\\n   129→\\t\\tfor _, block := range msg.Content {\\n   130→\\t\\t\\tif block.Type == \\\"tool_result\\\" && block.ToolUseID == toolUseID {\\n   131→\\t\\t\\t\\treturn line.UUID, true\\n   132→\\t\\t\\t}\\n   133→\\t\\t}\\n   134→\\t}\\n   135→\\treturn \\\"\\\", false\\n   136→}\\n   137→\\n   138→// TruncateTranscriptAtUUID returns transcript lines up to and including the\\n   139→// line with the given UUID. If the UUID is not found or is empty, returns\\n   140→// the entire transcript.\\n   141→//\\n   142→//nolint:revive // Exported for testing purposes\\n   143→func TruncateTranscriptAtUUID(transcript []transcriptLine, uuid string) []transcriptLine {\\n   144→\\tif uuid == \\\"\\\" {\\n   145→\\t\\treturn transcript\\n   146→\\t}\\n   147→\\n   148→\\tfor i, line := range transcript {\\n   149→\\t\\tif line.UUID == uuid {\\n   150→\\t\\t\\treturn transcript[:i+1]\\n   151→\\t\\t}\\n   152→\\t}\\n   153→\\n   154→\\t// UUID not found, return full transcript\\n   155→\\treturn transcript\\n   156→}\\n   157→\\n   158→// writeTranscript writes transcript lines to a file in JSONL format.\\n   159→func writeTranscript(path string, transcript []transcriptLine) error {\\n   160→\\tfile, err := os.Create(path) //nolint:gosec // Writing to controlled git metadata path\\n   161→\\tif err != nil {\\n   162→\\t\\treturn fmt.Errorf(\\\"failed to create file: %w\\\", err)\\n   163→\\t}\\n   164→\\tdefer func() { _ = file.Close() }()\\n   165→\\n   166→\\tfor _, line := range transcript {\\n   167→\\t\\tdata, err := json.Marshal(line)\\n   168→\\t\\tif err != nil {\\n   169→\\t\\t\\treturn fmt.Errorf(\\\"failed to marshal line: %w\\\", err)\\n   170→\\t\\t}\\n   171→\\t\\tif _, err := file.Write(data); err != nil {\\n   172→\\t\\t\\treturn fmt.Errorf(\\\"failed to write line: %w\\\", err)\\n   173→\\t\\t}\\n   174→\\t\\tif _, err := file.WriteString(\\\"\\\\n\\\"); err != nil {\\n   175→\\t\\t\\treturn fmt.Errorf(\\\"failed to write newline: %w\\\", err)\\n   176→\\t\\t}\\n   177→\\t}\\n   178→\\n   179→\\treturn nil\\n   180→}\\n   181→\\n   182→// TranscriptPosition contains the position information for a transcript file.\\n   183→type TranscriptPosition struct {\\n   184→\\tLastUUID  string // Last non-empty UUID (from user/assistant messages)\\n   185→\\tLineCount int    // Total number of lines\\n   186→}\\n   187→\\n   188→// GetTranscriptPosition reads a transcript file and returns the last UUID and line count.\\n   189→// Returns empty position if file doesn't exist or is empty.\\n   190→// Only considers UUIDs from actual messages (user/assistant), not summary rows which use leafUuid.\\n   191→func GetTranscriptPosition(path string) (TranscriptPosition, error) {\\n   192→\\tif path == \\\"\\\" {\\n   193→\\t\\treturn TranscriptPosition{}, nil\\n   194→\\t}\\n   195→\\n   196→\\tfile, err := os.Open(path) //nolint:gosec // Reading from controlled transcript path\\n   197→\\tif err != nil {\\n   198→\\t\\tif os.IsNotExist(err) {\\n   199→\\t\\t\\treturn TranscriptPosition{}, nil\\n   200→\\t\\t}\\n   201→\\t\\treturn TranscriptPosition{}, fmt.Errorf(\\\"failed to open transcript: %w\\\", err)\\n   202→\\t}\\n   203→\\tdefer func() { _ = file.Close() }()\\n   204→\\n   205→\\tvar pos TranscriptPosition\\n   206→\\treader := bufio.NewReader(file)\\n   207→\\n   208→\\tfor {\\n   209→\\t\\tlineBytes, err := reader.ReadBytes('\\\\n')\\n   210→\\t\\tif err != nil && err != io.EOF {\\n   211→\\t\\t\\treturn TranscriptPosition{}, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   212→\\t\\t}\\n   213→\\n   214→\\t\\tif len(lineBytes) == 0 {\\n   215→\\t\\t\\tif err == io.EOF {\\n   216→\\t\\t\\t\\tbreak\\n   217→\\t\\t\\t}\\n   218→\\t\\t\\tcontinue\\n   219→\\t\\t}\\n   220→\\n   221→\\t\\tpos.LineCount++\\n   222→\\n   223→\\t\\t// Parse line to extract UUID (only from user/assistant messages, not summaries)\\n   224→\\t\\tvar line transcriptLine\\n   225→\\t\\tif err := json.Unmarshal(lineBytes, &line); err == nil {\\n   226→\\t\\t\\tif line.UUID != \\\"\\\" {\\n   227→\\t\\t\\t\\tpos.LastUUID = line.UUID\\n   228→\\t\\t\\t}\\n   229→\\t\\t}\\n   230→\\n   231→\\t\\tif err == io.EOF {\\n   232→\\t\\t\\tbreak\\n   233→\\t\\t}\\n   234→\\t}\\n   235→\\n   236→\\treturn pos, nil\\n   237→}\\n   238→\"}]},\"uuid\":\"68a3d9c2-6973-4110-b29d-d1638123394d\",\"timestamp\":\"2026-03-13T18:26:45.036Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"ab806b740d56e5b83\"},\"toolUseID\":\"agent_msg_01RFvXM9kgyWXNWiJhh2AxgX\",\"parentToolUseID\":\"toolu_01HwtJjQ6WDXnD3jKWoTZFf2\",\"uuid\":\"0e4f615d-123a-4be3-9c12-6380eb160549\",\"timestamp\":\"2026-03-13T18:26:45.474Z\",\"userType\":\"external\",\"cwd\":\"/Users/ninawork/entire/devenv/cli\",\"sessionId\":\