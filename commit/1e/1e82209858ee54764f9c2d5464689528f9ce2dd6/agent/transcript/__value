  text += (b.text as string) || \\\"\\\";\\n      } else if (b.type === \\\"tool_result\\\") {\\n        hasToolResults = true;\\n      } else if (b.type === \\\"image\\\") {\\n        const source = b.source as Record<string, unknown> | undefined;\\n        if (source?.type === \\\"base64\\\" && source.data && source.media_type) {\\n          images.push({\\n            mediaType: source.media_type as string,\\n            data: source.data as string,\\n          });\\n        }\\n      }\\n    }\\n  }\\n  // Strip image reference markers from text (see comment above)\\n  text = text.replace(IMAGE_REFERENCE_PATTERN, \\\"\\\").trim();\\n\\n  return { text, images, hasToolResults };\\n}\\n\\n// Extract tool_use blocks from message content\\nfunction extractToolUseBlocks(content: unknown): ToolUseBlock[] {\\n  if (!Array.isArray(content)) return [];\\n\\n  const toolUses: ToolUseBlock[] = [];\\n  for (const block of content) {\\n    if (typeof block === \\\"object\\\" && block !== null) {\\n      const b = block as Record<string, unknown>;\\n      if (b.type === \\\"tool_use\\\" && b.id && b.name) {\\n        toolUses.push({\\n          id: b.id as string,\\n          name: b.name as string,\\n          input: (b.input as Record<string, unknown>) || {},\\n        });\\n      }\\n    }\\n  }\\n  return toolUses;\\n}\\n\\n// Extract tool_result metadata from a tool result record\\nfunction extractToolResultMetadata(\\n  parsed: Record<string, unknown>,\\n): ToolCallResult | undefined {\\n  const toolUseResult = parsed.toolUseResult as\\n    | Record<string, unknown>\\n    | undefined;\\n  if (!toolUseResult) return undefined;\\n\\n  const result: ToolCallResult = {\\n    type: (toolUseResult.type as \\\"text\\\" | \\\"error\\\") || \\\"text\\\",\\n  };\\n\\n  // For file reads\\n  const file = toolUseResult.file as Record<string, unknown> | undefined;\\n  if (file) {\\n    result.file = {\\n      filePath: file.filePath as string,\\n      numLines: file.numLines as numb