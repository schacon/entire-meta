ng/json\\\"\\n     6→\\t\\\"errors\\\"\\n     7→\\t\\\"fmt\\\"\\n     8→\\t\\\"log/slog\\\"\\n     9→\\t\\\"os\\\"\\n    10→\\t\\\"path/filepath\\\"\\n    11→\\t\\\"strings\\\"\\n    12→\\t\\\"time\\\"\\n    13→\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    19→\\n    20→\\t\\\"github.com/go-git/go-git/v6\\\"\\n    21→)\\n    22→\\n    23→// PrePromptState stores the state captured before a user prompt\\n    24→type PrePromptState struct {\\n    25→\\tSessionID      string   `json:\\\"session_id\\\"`\\n    26→\\tTimestamp      string   `json:\\\"timestamp\\\"`\\n    27→\\tUntrackedFiles []string `json:\\\"untracked_files\\\"`\\n    28→\\n    29→\\t// TranscriptOffset is the unified transcript position when this state was captured.\\n    30→\\t// For Claude Code (JSONL), this is the line count.\\n    31→\\t// For Gemini CLI (JSON), this is the message count.\\n    32→\\t// Zero means not set or session just started.\\n    33→\\tTranscriptOffset int `json:\\\"transcript_offset,omitempty\\\"`\\n    34→\\n    35→\\t// LastTranscriptIdentifier is the agent-specific identifier at the transcript position.\\n    36→\\t// UUID for Claude Code, message ID for Gemini CLI. Optional metadata.\\n    37→\\tLastTranscriptIdentifier string `json:\\\"last_transcript_identifier,omitempty\\\"`\\n    38→\\n    39→\\t// Deprecated: StartMessageIndex is the old Gemini-specific field.\\n    40→\\t// Migrated to TranscriptOffset on load.\\n    41→\\tStartMessageIndex int `json:\\\"start_message_index,omitempty\\\"`\\n    42→\\n    43→\\t// Deprecated: StepTranscriptStart is the old Claude-specific field.\\n    44→\\t// Migrated to TranscriptOffset on load.\\n    45→\\tStepTranscriptStart int `json:\\\"step_transcript_start,omitempty\\\"`\\n    46→\\n    47→\\t// Deprecated: LastTranscriptLineCount is the oldest name for transcript position.\\n    48→\\t// Migrated to TranscriptOffset on load.\\n    49→\\tLastTranscriptLineCount int `json:\\\"last_transcript_line_count,omitempty\\\"`\\n    50→}\\n    51→\\n    52→// PreUntrackedFiles returns the untracked files list, or nil if the receiver is nil.\\n    53→// This nil-vs-empty distinction lets DetectFileChanges know whether to skip new-file detection.\\n    54→// When the receiver is non-nil but UntrackedFiles is nil (e.g., old state files deserialized with\\n    55→// \\\"untracked_files\\\": null), returns an empty non-nil slice so that all current untracked files\\n    56→// are correctly treated as new.\\n    57→func (s *PrePromptState) PreUntrackedFiles() []string {\\n    58→\\tif s == nil {\\n    59→\\t\\treturn nil\\n    60→\\t}\\n    61→\\tif s.UntrackedFiles == nil {\\n    62→\\t\\treturn []string{}\\n    63→\\t}\\n    64→\\treturn s.UntrackedFiles\\n    65→}\\n    66→\\n    67→// normalizePrePromptState migrates deprecated fields after loading from JSON.\\n    68→func (s *PrePromptState) normalizePrePromptState() {\\n    69→\\t// Migrate the oldest field to the intermediate field first\\n    70→\\tif s.StepTranscriptStart == 0 && s.LastTranscriptLineCount > 0 {\\n    71→\\t\\ts.StepTranscriptStart = s.LastTranscriptLineCount\\n    72→\\t}\\n    73→\\ts.LastTranscriptLineCount = 0\\n    74→\\n    75→\\t// Migrate all deprecated fields to the unified TranscriptOffset\\n    76→\\tif s.TranscriptOffset == 0 {\\n    77→\\t\\tif s.StepTranscriptStart > 0 {\\n    78→\\t\\t\\ts.TranscriptOffset = s.StepTranscriptStart\\n    79→\\t\\t} else if s.StartMessageIndex > 0 {\\n    80→\\t\\t\\ts.TranscriptOffset = s.StartMessageIndex\\n    81→\\t\\t}\\n    82→\\t}\\n    83→\\ts.StepTranscriptStart = 0\\n    84→\\ts.StartMessageIndex = 0\\n    85→}\\n    86→\\n    87→// CapturePrePromptState captures current untracked files and transcript position before a prompt\\n    88→// and saves them to a state file.\\n    89→//\\n    90→// The agent parameter is used to determine the transcript position via TranscriptAnalyzer.\\n    91→// If the agent does not implement TranscriptAnalyzer, the transcript offset will be 0.\\n    92→// The sessionRef parameter is optional — if empty, transcript position won't be captured.\\n    93→//\\n    94→// Works correctly from any subdirectory within the repository.\\n    95→func CapturePrePromptState(ctx context.Context, ag agent.Agent, sessionID, sessionRef string) error {\\n    96→\\tif sessionID == \\\"\\\" {\\n    97→\\t\\tsessionID = unknownSessionID\\n    98→\\t}\\n    99→\\n   100→\\t// Get absolute path for tmp directory\\n   101→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   102→\\tif err != nil {\\n   103→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   104→\\t}\\n   105→\\n   106→\\t// Create tmp directory if it doesn't exist\\n   107→\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   108→\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n   109→\\t}\\n   110→\\n   111→\\t// Get list of untracked files (excluding .entire directory itself)\\n   112→\\tuntrackedFiles, err := getUntrackedFilesForState(ctx)\\n   113→\\tif err != nil {\\n   114→\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n   115→\\t}\\n   116→\\n   117→\\t// Get transcript position using TranscriptAnalyzer if available\\n   118→\\tvar transcriptOffset int\\n   119→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok && sessionRef != \\\"\\\" {\\n   120→\\t\\tpos, posErr := analyzer.GetTranscriptPosition(sessionRef)\\n   121→\\t\\tif posErr != nil {\\n   122→\\t\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"state\\\"), \\\"failed to get transcript position\\\",\\n   123→\\t\\t\\t\\tslog.String(\\\"error\\\", posErr.Error()))\\n   124→\\t\\t} else {\\n   125→\\t\\t\\ttranscriptOffset = pos\\n   126→\\t\\t}\\n   127→\\t}\\n   128→\\n   129→\\t// Create state file\\n   130→\\tstateFile := prePromptStateFile(ctx, sessionID)\\n   131→\\tstate := PrePromptState{\\n   132→\\t\\tSessionID:        sessionID,\\n   133→\\t\\tTimestamp:        time.Now().UTC().Format(time.RFC3339),\\n   134→\\t\\tUntrackedFiles:   untrackedFiles,\\n   135→\\t\\tTranscriptOffset: transcriptOffset,\\n   136→\\t}\\n   137→\\n   138→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   139→\\tif err != nil {\\n   140→\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n   141→\\t}\\n   142→\\n   143→\\tif err := os.WriteFile(stateFile, data, 0o600); err != nil {\\n   144→\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   145→\\t}\\n   146→\\n   147→\\tlogging.Debug(logging.WithComponent(ctx, \\\"state\\\"), \\\"captured state before prompt\\\",\\n   148→\\t\\tslog.Int(\\\"untracked_files\\\", len(untrackedFiles)),\\n   149→\\t\\tslog.Int(\\\"transcript_offset\\\", transcriptOffset))\\n   150→\\treturn nil\\n   151→}\\n   152→\\n   153→// LoadPrePromptState loads previously captured state.\\n   154→// Returns nil if no state file exists.\\n   155→func LoadPrePromptState(ctx context.Context, sessionID string) (*PrePromptState, error) {\\n   156→\\tstateFile := prePromptStateFile(ctx, sessionID)\\n   157→\\n   158→\\tif !fileExists(stateFile) {\\n   159→\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   160→\\t}\\n   161→\\n   162→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // Reading from controlled git metadata path\\n   163→\\tif err != nil {\\n   164→\\t\\treturn nil, fmt.Errorf(\\\"failed to read state file: %w\\\", err)\\n   165→\\t}\\n   166→\\n   167→\\tvar state PrePromptState\\n   168→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   169→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal state: %w\\\", err)\\n   170→\\t}\\n   171→\\n   172→\\tstate.normalizePrePromptState()\\n   173→\\n   174→\\treturn &state, nil\\n   175→}\\n   176→\\n   177→// CleanupPrePromptState removes the state file after use\\n   178→func CleanupPrePromptState(ctx context.Context, sessionID string) error {\\n   179→\\tstateFile := prePromptStateFile(ctx, sessionID)\\n   180→\\tif fileExists(stateFile) {\\n   181→\\t\\treturn os.Remove(stateFile) //nolint:wrapcheck // already present in codebase\\n   182→\\t}\\n   183→\\treturn nil\\n   184→}\\n   185→\\n   186→// FileChanges holds categorized file changes from git status.\\n   187→type FileChanges struct {\\n   188→\\tModified []string // Modified or staged files\\n   189→\\tNew      []string // Untracked files (filtered if previouslyUntracked provided)\\n   190→\\tDeleted  []string // Deleted files (staged or unstaged)\\n   191→}\\n   192→\\n   193→// DetectFileChanges returns categorized file changes from the current git status.\\n   194→//\\n   195→// previouslyUntracked controls new-file detection:\\n   196→//   - nil: all untracked files go into New\\n   197→//   - non-nil: only untracked files NOT in the pre-existing set go into New\\n   198→//\\n   199→// Modified includes both worktree and staging modified/added files.\\n   200→// Deleted includes both staged and unstaged deletions.\\n   201→// All results exclude .entire/ directory.\\n   202→func DetectFileChanges(ctx context.Context, previouslyUntracked []string) (*FileChanges, error) {\\n   203→\\trepo, err := openRepository(ctx)\\n   204→\\tif err != nil {\\n   205→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   206→\\t}\\n   207→\\n   208→\\tworktree, err := repo.Worktree()\\n   209→\\tif err != nil {\\n   210→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   211→\\t}\\n   212→\\n   213→\\tstatus, err := worktree.Status()\\n   214→\\tif err != nil {\\n   215→\\t\\treturn nil, fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n   216→\\t}\\n   217→\\n   218→\\t// Build set