_PATTERN = /\\\\[Image: source: [^\\\\]]+\\\\]/g;\\n    15→\\n    16→function extractTextContent(content: unknown): ExtractedContent {\\n    17→  if (typeof content === \\\"string\\\") {\\n    18→    return {\\n    19→      text: content.replace(IMAGE_REFERENCE_PATTERN, \\\"\\\").trim(),\\n    20→      images: [],\\n    21→      hasToolResults: false,\\n    22→    };\\n    23→  }\\n    24→  if (!Array.isArray(content)) {\\n    25→    return { text: \\\"\\\", images: [], hasToolResults: false };\\n    26→  }\\n    27→\\n    28→  let text = \\\"\\\";\\n    29→  const images: Array<{ mediaType: string; data: string }> = [];\\n    30→  let hasToolResults = false;\\n    31→\\n    32→  for (const block of content) {\\n    33→    if (typeof block === \\\"object\\\" && block !== null) {\\n    34→      const b = block as Record<string, unknown>;\\n    35→      if (b.type === \\\"text\\\") {\\n    36→        text += (b.text as string) || \\\"\\\";\\n    37→      } else if (b.type === \\\"tool_result\\\") {\\n    38→        hasToolResults = true;\\n    39→      } else if (b.type === \\\"image\\\") {\\n    40→        const source = b.source as Record<string, unknown> | undefined;\\n    41→        if (source?.type === \\\"base64\\\" && source.data && source.media_type) {\\n    42→          images.push({\\n    43→            mediaType: source.media_type as string,\\n    44→            data: source.data as string,\\n    45→          });\\n    46→        }\\n    47→      }\\n    48→    }\\n    49→  }\\n    50→  // Strip image reference markers from text (see comment above)\\n    51→  text = text.replace(IMAGE_REFERENCE_PATTERN, \\\"\\\").trim();\\n    52→\\n    53→  return { text, images, hasToolResults };\\n    54→}\\n    55→\\n    56→// Extract tool_use blocks from message content\\n    57→function extractToolUseBlocks(content: unknown): ToolUseBlock[] {\\n    58→  if (!Array.isArray(content)) return [];\\n    59→\\n    60→  const toolUses: ToolUseBlock[] = [];\\n    61→  for (const block of content) {\\n    62→    if (typeof block === \\\"object\\\" && block !== null) {\\n    63→      const b = block as Record<string, unknown>;\\n    64→      if (b.type === \\\"tool_use\\\" && b.id && b.name) {\\n    65→        toolUses.push({\\n    66→          id: b.id as string,\\n    67→          name: b.name as string,\\n    68→          input: (b.input as Record<string, unknown>) || {},\\n    69→        });\\n    70→      }\\n    71→    }\\n    72→  }\\n    73→  return toolUses;\\n    74→}\\n    75→\\n    76→// Extract tool_result metadata from a tool result record\\n    77→function extractToolResultMetadata(\\n    78→  parsed: Record<string, unknown>,\\n    79→): ToolCallResult | undefined {\\n    80→  const toolUseResult = parsed.toolUseResult as\\n    81→    | Record<string, unknown>\\n    82→    | undefined;\\n    83→  if (!toolUseResult) return undefined;\\n    84→\\n    85→  const result: ToolCallResult = {\\n    86→    type: (toolUseResult.type as \\\"text\\\" | \\\"error\\\") || \\\"text\\\",\\n    87→  };\\n    88→\\n    89→  // For file reads\\n    90→  const file = toolUseResult.file as Record<string, unknown> | undefined;\\n    91→  if (file) {\\n    92→    result.file = {\\n    93→      filePath: file.filePath as string,\\n    94→      numLines: file.numLines as number | undefined,\\n    95→    };\\n    96→  }\\n    97→\\n    98→  // For errors\\n    99→  if (toolUseResult.error) {\\n   100→    result.error = toolUseResult.error as string;\\n   101→    result.type = \\\"error\\\";\\n   102→  }\\n   103→\\n   104→  // For AskUserQuestion - extract user's answers\\n   105→  const answers = toolUseResult.answers as Record<string, string> | undefined;\\n   106→  if (answers) {\\n   107→    result.answers = answers;\\n   108→  }\\n   109→\\n   110→  return result;\\n   111→}\\n   112→\\n   113→/**\\n   114→ * Parse Claude Code JSONL transcript into TranscriptMessage[].\\n   115→ * Returns a natural conversation: user prompt -> final assistant