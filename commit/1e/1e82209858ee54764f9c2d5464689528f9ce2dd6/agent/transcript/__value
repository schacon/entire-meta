n   708→\\tbaseTreeHash plumbing.Hash,\\n   709→\\tmodifiedFiles, deletedFiles []string,\\n   710→\\tmetadataDir, metadataDirAbs string,\\n   711→) (plumbing.Hash, error) {\\n   712→\\t// Get worktree root for resolving file paths\\n   713→\\t// This is critical because fileExists() and createBlobFromFile() use os.Stat()\\n   714→\\t// which resolves relative to CWD. The modifiedFiles are repo-relative paths,\\n   715→\\t// so we must resolve them against repo root, not CWD.\\n   716→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   717→\\tif err != nil {\\n   718→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   719→\\t}\\n   720→\\n   721→\\t// Build list of tree changes\\n   722→\\tchanges := make([]TreeChange, 0, len(modifiedFiles)+len(deletedFiles))\\n   723→\\n   724→\\t// Deleted files → nil Entry means deletion\\n   725→\\tfor _, file := range deletedFiles {\\n   726→\\t\\tchanges = append(changes, TreeChange{Path: file, Entry: nil})\\n   727→\\t}\\n   728→\\n   729→\\t// Modified/new files → create blobs from disk\\n   730→\\tfor _, file := range modifiedFiles {\\n   731→\\t\\tabsPath := filepath.Join(repoRoot, file)\\n   732→\\t\\tif !fileExists(absPath) {\\n   733→\\t\\t\\t// File disappeared since detection — treat as deletion\\n   734→\\t\\t\\tchanges = append(changes, TreeChange{Path: file, Entry: nil})\\n   735→\\t\\t\\tcontinue\\n   736→\\t\\t}\\n   737→\\n   738→\\t\\tblobHash, mode, blobErr := createBlobFromFile(s.repo, absPath)\\n   739→\\t\\tif blobErr != nil {\\n   740→\\t\\t\\t// Skip files that can't be staged (may have been deleted since detection)\\n   741→\\t\\t\\tcontinue\\n   742→\\t\\t}\\n   743→\\n   744→\\t\\tchanges = append(changes, TreeChange{\\n   745→\\t\\t\\tPath: file,\\n   746→\\t\\t\\tEntry: &object.TreeEntry{\\n   747→\\t\\t\\t\\tMode: mode,\\n   748→\\t\\t\\t\\tHash: blobHash,\\n   749→\\t\\t\\t},\\n   750→\\t\\t})\\n   751→\\t}\\n   752→\\n   753→\\t// Metadata directory files\\n  