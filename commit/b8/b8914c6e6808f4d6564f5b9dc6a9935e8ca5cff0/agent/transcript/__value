→\\t)\\n   255→}\\n   256→\\n   257→// checkStopSentinel reads the tail of the transcript file and looks for the sentinel.\\n   258→func checkStopSentinel(path string, tailBytes int64, hookStartTime time.Time, maxSkew time.Duration) bool {\\n   259→\\tf, err := os.Open(path) //nolint:gosec // path comes from agent hook input\\n   260→\\tif err != nil {\\n   261→\\t\\treturn false\\n   262→\\t}\\n   263→\\tdefer f.Close()\\n   264→\\n   265→\\tinfo, err := f.Stat()\\n   266→\\tif err != nil {\\n   267→\\t\\treturn false\\n   268→\\t}\\n   269→\\toffset := info.Size() - tailBytes\\n   270→\\tif offset < 0 {\\n   271→\\t\\toffset = 0\\n   272→\\t}\\n   273→\\tbuf := make([]byte, info.Size()-offset)\\n   274→\\tif _, err := f.ReadAt(buf, offset); err != nil {\\n   275→\\t\\treturn false\\n   276→\\t}\\n   277→\\n   278→\\tlines := strings.Split(string(buf), \\\"\\\\n\\\")\\n   279→\\tfor _, line := range lines {\\n   280→\\t\\tline = strings.TrimSpace(line)\\n   281→\\t\\tif line == \\\"\\\" || !strings.Contains(line, stopHookSentinel) {\\n   282→\\t\\t\\tcontinue\\n   283→\\t\\t}\\n   284→\\n   285→\\t\\tvar entry struct {\\n   286→\\t\\t\\tTimestamp string `json:\\\"timestamp\\\"`\\n   287→\\t\\t}\\n   288→\\t\\tif json.Unmarshal([]byte(line), &entry) != nil || entry.Timestamp == \\\"\\\" {\\n   289→\\t\\t\\tcontinue\\n   290→\\t\\t}\\n   291→\\t\\tts, err := time.Parse(time.RFC3339Nano, entry.Timestamp)\\n   292→\\t\\tif err != nil {\\n   293→\\t\\t\\tts, err = time.Parse(time.RFC3339, entry.Timestamp)\\n   294→\\t\\t\\tif err != nil {\\n   295→\\t\\t\\t\\tcontinue\\n   296→\\t\\t\\t}\\n   297→\\t\\t}\\n   298→\\t\\t// Validate timestamp is within acceptable range:\\n   299→\\t\\t// - Not too far in the past (before hook started minus skew)\\n   300→\\t\\t// - Not too far in the future (after hook started plus skew)\\n   301→\\t\\tlowerBound := hookStartTime.Add(-maxSkew)\\n   302→\\t\\tupperBound := hookStartTime.Add(maxSkew)\\n   303→\\t\\tif ts.After(lowerBound) &