  44→\\treturn \\\"Cursor - AI-powered code editor\\\"\\n    45→}\\n    46→\\n    47→func (c *CursorAgent) IsPreview() bool { return true }\\n    48→\\n    49→// DetectPresence checks if Cursor is configured in the repository.\\n    50→func (c *CursorAgent) DetectPresence(ctx context.Context) (bool, error) {\\n    51→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    52→\\tif err != nil {\\n    53→\\t\\tworktreeRoot = \\\".\\\"\\n    54→\\t}\\n    55→\\n    56→\\tcursorDir := filepath.Join(worktreeRoot, \\\".cursor\\\")\\n    57→\\tif _, err := os.Stat(cursorDir); err == nil {\\n    58→\\t\\treturn true, nil\\n    59→\\t}\\n    60→\\treturn false, nil\\n    61→}\\n    62→\\n    63→// GetSessionID extracts the session ID from hook input.\\n    64→func (c *CursorAgent) GetSessionID(input *agent.HookInput) string {\\n    65→\\treturn input.SessionID\\n    66→}\\n    67→\\n    68→// ResolveSessionFile returns the path to a Cursor session file.\\n    69→// Cursor uses JSONL format like Claude Code.\\n    70→func (c *CursorAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n    71→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".jsonl\\\")\\n    72→}\\n    73→\\n    74→// ProtectedDirs returns directories that Cursor uses for config/state.\\n    75→func (c *CursorAgent) ProtectedDirs() []string { return []string{\\\".cursor\\\"} }\\n    76→\\n    77→// GetSessionDir returns the directory where Cursor stores session transcripts.\\n    78→func (c *CursorAgent) GetSessionDir(repoPath string) (string, error) {\\n    79→\\tif override := os.Getenv(\\\"ENTIRE_TEST_CURSOR_PROJECT_DIR\\\"); override != \\\"\\\" {\\n    80→\\t\\treturn override, nil\\n    81→\\t}\\n    82→\\n    83→\\thomeDir, err := os.UserHomeDir()\\n    84→\\tif err != nil {\\n    85→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n    86→\\t}\\n    87→\\n    88→\\tprojectDir := sanitizePathForCursor(repoPath)\\n    89→\\treturn filepath.Join(homeDir, \\\".cursor\\\", \\\"projects\\\", projectDir), nil\\n    90→}\\n    91→\\n    92→// ReadSession reads a session from Cursor's storage (JSONL transcript file).\\n    93→// Note: ModifiedFiles is left empty because Cursor's transcript format does not\\n    94→// contain tool_use blocks. File detection relies on git status instead.\\n    95→func (c *CursorAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n    96→\\tif input.SessionRef == \\\"\\\" {\\n    97→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n    98→\\t}\\n    99→\\n   100→\\tdata, err := os.ReadFile(input.SessionRef)\\n   101→\\tif err != nil {\\n   102→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   103→\\t}\\n   104→\\n   105→\\treturn &agent.AgentSession{\\n   106→\\t\\tSessionID:  input.SessionID,\\n   107→\\t\\tAgentName:  c.Name(),\\n   108→\\t\\tSessionRef: input.SessionRef,\\n   109→\\t\\tStartTime:  time.Now(),\\n   110→\\t\\tNativeData: data,\\n   111→\\t}, nil\\n   112→}\\n   113→\\n   114→// WriteSession writes a session to Cursor's storage (JSONL transcript file).\\n   115→func (c *CursorAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   116→\\tif session == nil {\\n   117→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   118→\\t}\\n   119→\\n   120→\\tif session.AgentName != \\\"\\\" && session.AgentName != c.Name() {\\n   121→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, c.Name())\\n   122→\\t}\\n   123→\\n   124→\\tif session.SessionRef == \\\"\\\" {\\n   125→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   126→\\t}\\n   127→\\n   128→\\tif len(session.NativeData) == 0 {\\n   129→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   130→\\t}\\n   131→\\n   132→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   133→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   134→\\t}\\n   135→\\n   136→\\treturn nil\\n   137→}\\n   138→\\n   139→// FormatResumeCommand returns an instruction to resume a Cursor session.\\n   140→// Cursor is a GUI IDE, so there's no CLI command to resume a session directly.\\n   141→func (c *CursorAgent) FormatResumeCommand(_ string) string {\\n   142→\\treturn \\\"Open this project in Cursor IDE to continue the session.\\\"\\n   143→}\\n   144→\\n   145→// sanitizePathForCursor converts a path to Cursor's project directory format.\\n   146→var nonAlphanumericRegex = regexp.MustCompile(`[^a-zA-Z0-9]`)\\n   147→\\n   148→func sanitizePathForCursor(path string) string {\\n   149→\\treturn nonAlphanumericRegex.ReplaceAllString(path, \\\"-\\\")\\n   150→}\\n   151→\\n   152→// ChunkTranscript splits a JSONL transcript at line boundaries.\\n   153→func (c *CursorAgent) ChunkTranscript(_ context.Context, content []byte, maxSize int) ([][]byte, error) {\\n   154→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n   155→\\tif err != nil {\\n   156→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk JSONL transcript: %w\\\", err)\\n   157→\\t}\\n   158→\\treturn chunks, nil\\n   159→}\\n   160→\\n   161→// ReassembleTranscript concatenates JSONL chunks with newlines.\\n   162→func (c *CursorAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n   163→\\treturn agent.ReassembleJSONL(chunks), nil\\n   164→}\\n   165→\"}]},\"uuid\":\"5cfc65ad-fb6d-466c-b76c-d7976a4ff50f\",\"timestamp\":\"2026-02-26T12:57:18.746Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to find and read several files. Please:\\n\\n1. Read the Gemini CLI agent's `ResolveSessionFile` method - look in `cmd/entire/cli/agent/geminicli/` for the file containing it\\n2. Read the OpenCode agent's lifecycle.go to see how it resolves transcript paths when they're missing from hook input - look in `cmd/entire/cli/agent/opencode/`\\n3. Read `cmd/entir