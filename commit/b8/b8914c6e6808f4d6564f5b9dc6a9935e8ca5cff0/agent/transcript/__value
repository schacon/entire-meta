\"encoding/json\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"io\\\"\\n     8→\\t\\\"os\\\"\\n     9→\\t\\\"time\\\"\\n    10→\\n    11→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    12→)\\n    13→\\n    14→// Compile-time interface assertions for new interfaces.\\n    15→var (\\n    16→\\t_ agent.TranscriptAnalyzer = (*GeminiCLIAgent)(nil)\\n    17→\\t_ agent.TokenCalculator    = (*GeminiCLIAgent)(nil)\\n    18→)\\n    19→\\n    20→// HookNames returns the hook verbs Gemini CLI supports.\\n    21→// These become subcommands: entire hooks gemini <verb>\\n    22→func (g *GeminiCLIAgent) HookNames() []string {\\n    23→\\treturn []string{\\n    24→\\t\\tHookNameSessionStart,\\n    25→\\t\\tHookNameSessionEnd,\\n    26→\\t\\tHookNameBeforeAgent,\\n    27→\\t\\tHookNameAfterAgent,\\n    28→\\t\\tHookNameBeforeModel,\\n    29→\\t\\tHookNameAfterModel,\\n    30→\\t\\tHookNameBeforeToolSelection,\\n    31→\\t\\tHookNameBeforeTool,\\n    32→\\t\\tHookNameAfterTool,\\n    33→\\t\\tHookNamePreCompress,\\n    34→\\t\\tHookNameNotification,\\n    35→\\t}\\n    36→}\\n    37→\\n    38→// ParseHookEvent translates a Gemini CLI hook into a normalized lifecycle Event.\\n    39→// Returns nil if the hook has no lifecycle significance (e.g., pass-through hooks).\\n    40→func (g *GeminiCLIAgent) ParseHookEvent(_ context.Context, hookName string, stdin io.Reader) (*agent.Event, error) {\\n    41→\\tswitch hookName {\\n    42→\\tcase HookNameSessionStart:\\n    43→\\t\\treturn g.parseSessionStart(stdin)\\n    44→\\tcase HookNameBeforeAgent:\\n    45→\\t\\treturn g.parseTurnStart(stdin)\\n    46→\\tcase HookNameAfterAgent:\\n    47→\\t\\treturn g.parseTurnEnd(stdin)\\n    48→\\tcase HookNameSessionEnd:\\n    49→\\t\\treturn g.parseSessionEnd(stdin)\\n    50→\\tcase HookNamePreCompress:\\n    51→\\t\\treturn g.parseCompaction(stdin)\\n    52→\\tcase HookNameBeforeTool, HookNameAfterTool, HookNameBeforeModel,\\n    53→\\t\\tHookNameAfterModel, HookNameBeforeToolSelection, Hoo