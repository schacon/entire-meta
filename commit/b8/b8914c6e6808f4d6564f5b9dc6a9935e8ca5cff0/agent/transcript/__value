"2.1.49\",\"gitBranch\":\"rwr/tests-for-cursor-agent-cli\",\"slug\":\"gleaming-hopping-ripple\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01KAks24S317K61E9nGKiGmg\",\"type\":\"tool_result\",\"content\":\"     1→package opencode\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"encoding/json\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"io\\\"\\n     8→\\t\\\"os\\\"\\n     9→\\t\\\"path/filepath\\\"\\n    10→\\t\\\"strings\\\"\\n    11→\\t\\\"time\\\"\\n    12→\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    15→)\\n    16→\\n    17→// Hook name constants — these become CLI subcommands under `entire hooks opencode`.\\n    18→const (\\n    19→\\tHookNameSessionStart = \\\"session-start\\\"\\n    20→\\tHookNameSessionEnd   = \\\"session-end\\\"\\n    21→\\tHookNameTurnStart    = \\\"turn-start\\\"\\n    22→\\tHookNameTurnEnd      = \\\"turn-end\\\"\\n    23→\\tHookNameCompaction   = \\\"compaction\\\"\\n    24→)\\n    25→\\n    26→// HookNames returns the hook verbs this agent supports.\\n    27→func (a *OpenCodeAgent) HookNames() []string {\\n    28→\\treturn []string{\\n    29→\\t\\tHookNameSessionStart,\\n    30→\\t\\tHookNameSessionEnd,\\n    31→\\t\\tHookNameTurnStart,\\n    32→\\t\\tHookNameTurnEnd,\\n    33→\\t\\tHookNameCompaction,\\n    34→\\t}\\n    35→}\\n    36→\\n    37→// ParseHookEvent translates OpenCode hook calls into normalized lifecycle events.\\n    38→func (a *OpenCodeAgent) ParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*agent.Event, error) {\\n    39→\\tswitch hookName {\\n    40→\\tcase HookNameSessionStart:\\n    41→\\t\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n    42→\\t\\tif err != nil {\\n    43→\\t\\t\\treturn nil, err\\n    44→\\t\\t}\\n    45→\\t\\treturn &agent.Event{\\n    46→\\t\\t\\tType:      agent.SessionStart,\\n    47→\\t\\t\\tSessionID: raw.SessionID,\\n    48→\\t\\t\\tTimestamp: time.Now(),\\n    49→\\t\\t}, nil\\n    50→\\n    51→\\tcase HookNameTurnStart:\\n    52→\\t\\traw, err := agent.ReadAndParseHookInput[turnStartRaw](stdin)\\n    53→\\t\\tif err != nil {\\n    54→\\t\\t\\treturn nil, err\\n    55→\\t\\t}\\n    56→\\t\\t// Get the temp file path for this session (may not exist yet, but needed for pre-prompt state).\\n    57→\\t\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n    58→\\t\\tif err != nil {\\n    59→\\t\\t\\trepoRoot = \\\".\\\"\\n    60→\\t\\t}\\n    61→\\t\\ttmpDir := filepath.Join(repoRoot, paths.EntireTmpDir)\\n    62→\\t\\ttranscriptPath := filepath.Join(tmpDir, raw.SessionID+\\\".json\\\")\\n    63→\\t\\treturn &agent.Event{\\n    64→\\t\\t\\tType:       agent.TurnStart,\\n    65→\\t\\t\\tSessionID:  raw.SessionID,\\n    66→\\t\\t\\tSessionRef: transcriptPath,\\n    67→\\t\\t\\tPrompt:     raw.Prompt,\\n    68→\\t\\t\\tTimestamp:  time.Now(),\\n    69→\\t\\t}, nil\\n    70→\\n    71→\\tcase HookNameTurnEnd:\\n    72→\\t\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n    73→\\t\\tif err != nil {\\n    74→\\t\\t\\treturn nil, err\\n    75→\\t\\t}\\n    76→\\t\\t// Call `opencode export` to get the transcript and write to temp file\\n    77→\\t\\ttranscriptPath, exportErr := a.fetchAndCacheExport(ctx, raw.SessionID)\\n    78→\\t\\tif exportErr != nil {\\n    79→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to export session: %w\\\", exportErr)\\n    80→\\t\\t}\\n    81→\\t\\treturn &agent.Event{\\n    82→\\t\\t\\tType:       agent.TurnEnd,\\n    83→\\t\\t\\tSessionID:  raw.SessionID,\\n    84→\\t\\t\\tSessionRef: transcriptPath,\\n    85→\\t\\t\\tTimestamp:  time.Now(),\\n    86→\\t\\t}, nil\\n    87→\\n    88→\\tcase HookNameCompaction:\\n    89→\\t\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n    90→\\t\\tif err != nil {\\n    91→\\t\\t\\treturn nil, err\\n    92→\\t\\t}\\n    93→\\t\\treturn &agent.Event{\\n    94→\\t\\t\\tType:      agent.Compaction,\\n    95→\\t\\t\\tSessionID: raw.SessionID,\\n    96→\\t\\t\\tTimestamp: time.Now(),\\n    97→\\t\\t}, nil\\n    98→\\n    99→\\tcase HookNameSessionEnd:\\n   100→\\t\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   101→\\t\\tif err != nil {\\n   102→\\t\\t\\treturn nil, err\\n   103→\\t\\t}\\n   104→\\t\\treturn &agent.Event{\\n   105→\\t\\t\\tType:      agent.SessionEnd,\\n   106→\\t\\t\\tSessionID: raw.SessionID,\\n   107→\\t\\t\\tTimestamp: time.Now(),\\n   108→\\t\\t}, nil\\n   109→\\n   110→\\tdefault:\\n   111→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action for unknown hooks\\n   112→\\t}\\n   113→}\\n   114→\\n   115→// PrepareTranscript ensures the OpenCode transcript file is up-to-date by calling `opencode export`.\\n   116→// OpenCode's transcript is created/updated via `opencode export`, but condensation may need fresh\\n   117→// data mid-turn (e.g., during mid-turn commits or resumed sessions where the cached file is stale).\\n   118→// This method always refreshes the transcript to ensure the latest agent activity is captured.\\n   119→func (a *OpenCodeAgent) PrepareTranscript(ctx context.Context, sessionRef string) error {\\n   120→\\t// Validate the session ref path\\n   121→\\tif _, err := os.Stat(sessionRef); err != nil && !os.IsNotExist(err) {\\n   122→\\t\\t// Permission denied, broken symlink, or other non-recoverable errors\\n   123→\\t\\treturn fmt.Errorf(\\\"failed to stat OpenCode transcript path %s: %w\\\", sessionRef, err)\\n   124→\\t}\\n   125→\\n   126→\\t// Extract session ID from path: basename without .json extension\\n   127→\\tbase := filepath.Base(sessionRef)\\n   128→\\tif !strings.HasSuffix(base, \\\".json\\\") {\\n   129→\\t\\treturn fmt.Errorf(\\\"invalid OpenCode transcript path (expected .json): %s\\\", sessionRef)\\n   130→\\t}\\n   131→\\tsessionID := strings.TrimSuffix(base, \\\".json\\\")\\n   132→\\tif sessi