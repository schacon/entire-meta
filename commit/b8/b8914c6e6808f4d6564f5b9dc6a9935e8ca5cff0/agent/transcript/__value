sionID,\\n   147→\\t\\tSessionRef: raw.TranscriptPath,\\n   148→\\t\\tTimestamp:  time.Now(),\\n   149→\\t}, nil\\n   150→}\\n   151→\\n   152→func (g *GeminiCLIAgent) parseTurnStart(stdin io.Reader) (*agent.Event, error) {\\n   153→\\traw, err := agent.ReadAndParseHookInput[agentHookInputRaw](stdin)\\n   154→\\tif err != nil {\\n   155→\\t\\treturn nil, err\\n   156→\\t}\\n   157→\\treturn &agent.Event{\\n   158→\\t\\tType:       agent.TurnStart,\\n   159→\\t\\tSessionID:  raw.SessionID,\\n   160→\\t\\tSessionRef: raw.TranscriptPath,\\n   161→\\t\\tPrompt:     raw.Prompt,\\n   162→\\t\\tTimestamp:  time.Now(),\\n   163→\\t}, nil\\n   164→}\\n   165→\\n   166→func (g *GeminiCLIAgent) parseTurnEnd(stdin io.Reader) (*agent.Event, error) {\\n   167→\\traw, err := agent.ReadAndParseHookInput[agentHookInputRaw](stdin)\\n   168→\\tif err != nil {\\n   169→\\t\\treturn nil, err\\n   170→\\t}\\n   171→\\treturn &agent.Event{\\n   172→\\t\\tType:       agent.TurnEnd,\\n   173→\\t\\tSessionID:  raw.SessionID,\\n   174→\\t\\tSessionRef: raw.TranscriptPath,\\n   175→\\t\\tTimestamp:  time.Now(),\\n   176→\\t}, nil\\n   177→}\\n   178→\\n   179→func (g *GeminiCLIAgent) parseSessionEnd(stdin io.Reader) (*agent.Event, error) {\\n   180→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   181→\\tif err != nil {\\n   182→\\t\\treturn nil, err\\n   183→\\t}\\n   184→\\treturn &agent.Event{\\n   185→\\t\\tType:       agent.SessionEnd,\\n   186→\\t\\tSessionID:  raw.SessionID,\\n   187→\\t\\tSessionRef: raw.TranscriptPath,\\n   188→\\t\\tTimestamp:  time.Now(),\\n   189→\\t}, nil\\n   190→}\\n   191→\\n   192→func (g *GeminiCLIAgent) parseCompaction(stdin io.Reader) (*agent.Event, error) {\\n   193→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   194→\\tif err != nil {\\n   195→\\t\\treturn nil, err\\n   196→\\t}\\n   197→\\treturn &agent.Event{\\n   198→\\t\\tType:       agent.Compaction,\\n   199→\\t\\tSessionID:  raw.SessionID,\\n   200→\\t\\t