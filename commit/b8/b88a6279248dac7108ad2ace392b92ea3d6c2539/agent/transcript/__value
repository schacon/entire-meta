ire/checkpoints/v1.\\n    68→func (s *ManualCommitStrategy) getCheckpointLog(ctx context.Context, checkpointID id.CheckpointID) ([]byte, error) {\\n    69→\\tstore, err := s.getCheckpointStore()\\n    70→\\tif err != nil {\\n    71→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    72→\\t}\\n    73→\\n    74→\\tcontent, err := store.ReadLatestSessionContent(ctx, checkpointID)\\n    75→\\tif err != nil {\\n    76→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    77→\\t}\\n    78→\\tif content == nil {\\n    79→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n    80→\\t}\\n    81→\\tif len(content.Transcript) == 0 {\\n    82→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n    83→\\t}\\n    84→\\n    85→\\treturn content.Transcript, nil\\n    86→}\\n    87→\\n    88→// condenseOpts provides pre-resolved git objects to avoid redundant reads.\\n    89→type condenseOpts struct {\\n    90→\\tshadowRef      *plumbing.Reference // Pre-resolved shadow branch ref (nil = resolve from repo)\\n    91→\\theadTree       *object.Tree        // Pre-resolved HEAD tree (passed through to calculateSessionAttributions)\\n    92→\\trepoDir        string              // Repository worktree path for git CLI commands\\n    93→\\theadCommitHash string              // HEAD commit hash (passed through for attribution)\\n    94→}\\n    95→\\n    96→// CondenseSession condenses a session's shadow branch to permanent storage.\\n    97→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n    98→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n    99→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   100→//\\n   101→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   102→// In this case, data is extracted from the live transcript instead.\\n  