astInteraction:\\n   321→\\t\\t\\tnow := time.Now()\\n   322→\\t\\t\\tstate.LastInteractionTime = &now\\n   323→\\t\\tcase ActionClearEndedAt:\\n   324→\\t\\t\\tstate.EndedAt = nil\\n   325→\\t\\t\\tstate.FullyCondensed = false\\n   326→\\n   327→\\t\\t// Strategy-specific actions: skip remaining after the first handler error.\\n   328→\\t\\tcase ActionCondense:\\n   329→\\t\\t\\tif handlerErr == nil {\\n   330→\\t\\t\\t\\tif err := handler.HandleCondense(state); err != nil {\\n   331→\\t\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"%s: %w\\\", action, err)\\n   332→\\t\\t\\t\\t}\\n   333→\\t\\t\\t}\\n   334→\\t\\tcase ActionCondenseIfFilesTouched:\\n   335→\\t\\t\\tif handlerErr == nil {\\n   336→\\t\\t\\t\\tif err := handler.HandleCondenseIfFilesTouched(state); err != nil {\\n   337→\\t\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"%s: %w\\\", action, err)\\n   338→\\t\\t\\t\\t}\\n   339→\\t\\t\\t}\\n   340→\\t\\tcase ActionDiscardIfNoFiles:\\n   341→\\t\\t\\tif handlerErr == nil {\\n   342→\\t\\t\\t\\tif err := handler.HandleDiscardIfNoFiles(state); err != nil {\\n   343→\\t\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"%s: %w\\\", action, err)\\n   344→\\t\\t\\t\\t}\\n   345→\\t\\t\\t}\\n   346→\\t\\tcase ActionWarnStaleSession:\\n   347→\\t\\t\\tif handlerErr == nil {\\n   348→\\t\\t\\t\\tif err := handler.HandleWarnStaleSession(state); err != nil {\\n   349→\\t\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"%s: %w\\\", action, err)\\n   350→\\t\\t\\t\\t}\\n   351→\\t\\t\\t}\\n   352→\\t\\tdefault:\\n   353→\\t\\t\\tif handlerErr == nil {\\n   354→\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"unhandled action: %s\\\", action)\\n   355→\\t\\t\\t}\\n   356→\\t\\t}\\n   357→\\t}\\n   358→\\treturn handlerErr\\n   359→}\\n   360→\\n   361→// MermaidDiagram generates a Mermaid state diagram from the transition table.\\n   362→// The diagram is derived by calling Transition() for representative context\\n   363→// variants per phase/event, so it stays in sync with the implementation.\\n   364→func MermaidDiagram() string {\\n   365→\\tvar b strings.Builder\\n   366→\\tb.WriteString(\\\"stateDiagram-v2\\\\n\\\")\\n   367→\\n   368→\\t// State declarations with descriptions.\\n   369→\\tb.WriteString(\\\"    state \\\\\\\"IDLE\\\\\\\" as idle\\\\n\\\")\\n   370→\\tb.WriteString(\\\"    state \\\\\\\"ACTIVE\\\\\\\" as active\\\\n\\\")\\n   371→\\tb.WriteString(\\\"    state \\\\\\\"ENDED\\\\\\\" as ended\\\\n\\\")\\n   372→\\tb.WriteString(\\\"\\\\n\\\")\\n   373→\\n   374→\\t// Context variants for GitCommit: rebase, files/no-files.\\n   375→\\ttype contextVariant struct {\\n   376→\\t\\tlabel string\\n   377→\\t\\tctx   TransitionContext\\n   378→\\t}\\n   379→\\n   380→\\t// For each phase/event, generate edges.\\n   381→\\tfor _, phase := range allPhases {\\n   382→\\t\\tfor _, event := range allEvents {\\n   383→\\t\\t\\tvar variants []contextVariant\\n   384→\\t\\t\\tswitch {\\n   385→\\t\\t\\tcase event == EventGitCommit && phase == PhaseEnded:\\n   386→\\t\\t\\t\\t// HasFilesTouched only affects PhaseEnded transitions;\\n   387→\\t\\t\\t\\t// other phases produce identical edges for both values.\\n   388→\\t\\t\\t\\tvariants = []contextVariant{\\n   389→\\t\\t\\t\\t\\t{\\\"[files]\\\", TransitionContext{HasFilesTouched: true}},\\n   390→\\t\\t\\t\\t\\t{\\\"[no files]\\\", TransitionContext{HasFilesTouched: false}},\\n   391→\\t\\t\\t\\t\\t{\\\"[rebase]\\\", TransitionContext{IsRebaseInProgress: true}},\\n   392→\\t\\t\\t\\t}\\n   393→\\t\\t\\tcase event == EventGitCommit:\\n   394→\\t\\t\\t\\tvariants = []contextVariant{\\n   395→\\t\\t\\t\\t\\t{\\\"\\\", TransitionContext{}},\\n   396→\\t\\t\\t\\t\\t{\\\"[rebase]\\\", TransitionContext{IsRebaseInProgress: true}},\\n   397→\\t\\t\\t\\t}\\n   398→\\t\\t\\tdefault:\\n   399→\\t\\t\\t\\tvariants = []contextVariant{\\n   400→\\t\\t\\t\\t\\t{\\\"\\\", TransitionContext{}},\\n   401→\\t\\t\\t\\t}\\n   402→\\t\\t\\t}\\n   403→\\n   404→\\t\\t\\tfor _, v := range variants {\\n   405→\\t\\t\\t\\tresult := Transitio