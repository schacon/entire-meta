ilesTouched tracks files modified/created/deleted during this session\\n   111→\\tFilesTouched []string `json:\\\"files_touched,omitempty\\\"`\\n   112→\\n   113→\\t// LastCheckpointID is the checkpoint ID from the most recent condensation.\\n   114→\\t// Used to restore the Entire-Checkpoint trailer on amend and to identify\\n   115→\\t// sessions that have been condensed at least once. Cleared on new prompt.\\n   116→\\tLastCheckpointID id.CheckpointID `json:\\\"last_checkpoint_id,omitempty\\\"`\\n   117→\\n   118→\\t// FullyCondensed indicates this session has been condensed and has no remaining\\n   119→\\t// carry-forward files. PostCommit skips fully-condensed sessions entirely.\\n   120→\\t// Set after successful condensation when no files remain for carry-forward\\n   121→\\t// and the session phase is ENDED. Cleared on session reactivation (ENDED →\\n   122→\\t// ACTIVE via TurnStart, or ENDED → IDLE via SessionStart) by ActionClearEndedAt.\\n   123→\\tFullyCondensed bool `json:\\\"fully_condensed,omitempty\\\"`\\n   124→\\n   125→\\t// AgentType identifies the agent that created this session (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\", \\\"Cursor\\\")\\n   126→\\tAgentType types.AgentType `json:\\\"agent_type,omitempty\\\"`\\n   127→\\n   128→\\t// ModelName is the LLM model used in this session (e.g., \\\"claude-sonnet-4-20250514\\\", \\\"gpt-4o\\\").\\n   129→\\t// Set from hook data when the agent provides it.\\n   130→\\tModelName string `json:\\\"model_name,omitempty\\\"`\\n   131→\\n   132→\\t// Token usage tracking (accumulated across all checkpoints in this session)\\n   133→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   134→\\n   135→\\t// Deprecated: TranscriptLinesAtStart is replaced by CheckpointTranscriptStart.\\n   136→\\t// Kept for backward compatibility with existing state files.\\n   137→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   138→\\n   139→\\t// TranscriptIdentifierAtStart is the last transcript identifier when the session started.\\n   140→\\t// Used for identifier-based transcript scoping (UUID for Claude, message ID for Gemini).\\n   141→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"`\\n   142→\\n   143→\\t// TranscriptPath is the path to the live transcript file (for mid-session commit detection)\\n   144→\\tTranscriptPath string `json:\\\"transcript_path,omitempty\\\"`\\n   145→\\n   146→\\t// LastPrompt is the most recent user prompt for this session (truncated for display).\\n   147→\\t// Updated on every turn start (UserPromptSubmit). JSON tag kept as \\\"first_prompt\\\"\\n   148→\\t// for backward compatibility with existing state files.\\n   149→\\tLastPrompt string `json:\\\"last_prompt,omitempty\\\"`\\n   150→\\n   151→\\t// PromptAttributions tracks user and agent line changes at each prompt start.\\n   152→\\t// This enables accurate attribution by capturing user edits between checkpoints.\\n   153→\\tPromptAttributions []PromptAttribution `json:\\\"prompt_attributions,omitempty\\\"`\\n   154→\\n   155→\\t// PendingPromptAttribution holds attribution calculated at prompt start (before agent runs).\\n   156→\\t// This is moved to PromptAttributions when SaveStep is called.\\n   157→\\tPendingPromptAttribution *PromptAttribution `json:\\\"pending_prompt_attribution,omitempty\\\"`\\n   158→}\\n   159→\\n   160→// PromptAttribution captures line-level attribution data at the start of each prompt.\\n   161→// By recording what changed since the last checkpoint BEFORE the agent works,\\n   162→// we can accurately separate user edits from agent contributions.\\n   163→type PromptAttribution struct {\\n   164→\\t// CheckpointNumber is which checkpoint this was recorded before (1-indexed)\\n   165→\\tCheckpointNumber int `json:\\\"checkpoint_number\\\"`\\n   166→\\n   167→\\t// UserLinesAdded is lines added by user since the last checkpoint\\n   168→\\tUserLinesAdded int `json:\\\"user_lines_added\\\"`\\n   169→\\n   170→\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   171→\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   172→\\n   173→\\t// AgentLinesAdded is total agent lines added so far (base → last checkpoint).\\n   174→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   175→\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   176→\\n   177→\\t// AgentLinesRemoved is total agent lines removed so far (base → last checkpoint).\\n   178→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   179→\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   180→\\n   181→\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   182→\\t// This enables distinguishing user self-modifications from agent modifications.\\n   183→\\t// See docs/architecture/attribution.md for details.\\n   184→\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   185→}\\n   186→\\n   187→// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   188→// Call this after deserializing a State from JSON.\\n   189→func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   190→\\t// Normalize legacy phase values. \\\"active_committed\\\" was removed with the\\n   191→\\t// 1:1 checkpoint model in favor of the state machine handling commits\\n   192→\\t// during ACTIVE phase with immediate condensation.\\n   193→\\tif s.Phase == \\\"active_committed\\\" {\\n   194→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   195→\\t\\tlogging.Info(logCtx, \\\"migrating legacy active_committed phase to active\\\",\\n   196→\\t\\t\\tslog.String(\\\"session_id\\\", s.SessionID),\\n   197→\\t\\t)\\n   198→\\t\\ts.Phase = PhaseActive\\n   199→\\t}\\n   200→\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n   201→\\ts.Phase = PhaseFromString(string(s.Phase))\\n   202→\\n   203→\\t// Migrate transcript fields: CheckpointTranscriptStart replaces both\\n   204→\\t// CondensedTranscriptLines and TranscriptLinesAtStart from older state files.\\n   205→\\tif s.CheckpointTranscriptStart == 0 {\\n   206→\\t\\tif s.CondensedTranscriptLines > 0 {\\n   207→\\t\\t\\ts.CheckpointTranscriptStart = s.CondensedTranscriptLines\\n   208→\\t\\t} else if s.TranscriptLinesAtStart > 0 {\\n   209→\\t\\t\\ts.CheckpointTranscriptStart = s.TranscriptLinesAtStart\\n   210→\\t\\t}\\n   211→\\t}\\n   212→\\t// Clear deprecated fields so they aren't re-persisted.\\n   213→\\t// Note: this is a one-way migration. If the state is re-saved, older CLI versions\\n   214→\\t// will see 0 for these fields and fall back to scoping from the transcript start.\\n   215→\\t// This is acceptable since CLI upgrades are monotonic and the worst case is\\n   216→\\t// redundant transcript content in a condensation, not data loss.\\n   217→\\ts.CondensedTranscriptLines = 0\\n   218→\\ts.TranscriptLinesAtStart = 0\\n   219→\\n   220→\\t// Backfill AttributionBaseCommit for sessions created before this field existed.\\n   221→\\t// Without this, a mid-turn commit would migrate BaseCommit and the fallback in\\n   222→\\t// calculateSessionAttributions would use the migrated value, producing zero attribution.\\n   223→\\tif s.AttributionBaseCommit == \\\"\\\" && s.BaseCommit != \\\"\\\" {\\n   224→\\t\\ts.AttributionBaseCommit = s.BaseCommit\\n   225→\\t}\\n   226→}\\n   227→\\n   228→// IsStale returns true when a session hasn't seen interaction for longer than\\n   229→// StaleSessionThreshold. Falls back to StartedAt when LastInteractionTime is\\n   230→// nil (sessions created before interaction tracking was added).\\n   231→func (s *State) IsStale() bool {\\n   232→\\tvar since time.Duration\\n   233→\\tif s.LastInteractionTime != nil {\\n   234→\\t\\tsince = time.Since(*s.LastInteractionTime)\\n   235→\\t} else {\\n   236→\\t\\tsince = time.Since(s.StartedAt)\\n   237→\\t}\\n   238→\\treturn since > StaleSessionThreshold\\n   239→}\\n   240→\\n   241→// StateStore provides low-level operations for managing session state files.\\n   242→//\\n   243→// StateStore is a primitive for session state persistence. It is NOT the same as\\n   244→// the Sessions interface - it only handles state files in .git/entire-sessions/,\\n   245→// not the full session data which includes checkpoint content.\\n   246→//\\n   247→// Use StateStore directly in strategies for performance-critical state operations.\\n   248→// Use the Sessions interface (when implemented) for high-level session management.\\n   249→type StateStore struct {\\n   250→\\t// stateDir is the directory where session state files are stored\\n   251→\\tstateDir string\\n   252→}\\n   253→\\n   254→// NewStateStore creates a new state store.\\n   255→// Uses the git common dir to store session state (shared across worktrees).\\n   256→func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   257→\\tcommonDir, err := getGitCommonDir(ctx)\\n   258→\\tif err != nil {\\n   259→\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   260→\\t}\\n   261→\\treturn &StateStore{\\n   262→\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   263→\\t}, nil\\n   264→}\\n   265→\\n   266→// NewStateStoreWithDir creates a new state store with a custom directory.\\n   267→// This is useful for testing.\\n   268→func NewStateStoreWithDir(stateDir string) *StateStore {\\n   269→\\treturn &StateStore{stateDir: stateDir}\\n   270→}\\n   271→\\n   272→// Load loads the session state for the given session ID.\\n   273→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   274→// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   275→func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   276→\\t// Validate session ID to prevent path traversal\\n   277→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   278→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   279→\\t}\\n   280→\\n   281→\\tstateFile := s.stateFilePath(sessionID)\\n   282→\\n   283→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is derived from sessionID\\n   284→\\tif os.IsNotExist(err) {\\n   285→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   286→\\t}\\n   287→\\tif err != nil {\\n   288→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   289→\\t}\\n   290→\\n   291→\\tvar state State\\n   292→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   293→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal session state: %w\\\", err)\\n   294→\\t}\\n   295→\\tstate.NormalizeAfterLoad(ctx)\\n   296→\\n   297→\\tif state.IsStale() {\\n   298→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   299→\\t\\tlogging.Debug(logCtx, \\\"deleting stale session state\\\",\\n   300→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   301→\\t\\t)\\n   302→\\t\\t_ = s.Clear(ctx, sessionID) //nolint:errcheck // best-effort cleanup of stale session\\n   303→\\t\\treturn nil, nil             //nolint:nilnil // stale session treated as not found\\n   304→\\t}\\n   305→\\n   306→\\treturn &state, nil\\n   307→}\\n   308→\\n   309→// Save saves the session state atomically.\\n   310→func (s *StateStore) Save(ctx context.Context, state *State) error {\\n   311→\\t_ = ctx // Reserved for future use\\n   312→\\n   313→\\t// Validate session ID to prevent path traversal\\n   314→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n   315→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   316→\\t}\\n   317→\\n   318→\\tif err := os.MkdirAll(s.stateDir, 0o750); err != nil {\\n   319→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   320→\\t}\\n   321→\\n   322→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   323→\\tif err != nil {\\n   324→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   325→\\t}\\n   326→\\n   327→\\tstateFile := s.stateFilePath(state.SessionID)\\n   328→\\n   329→\\t// Atomic write: write to temp file, then rename\\n   330→\\ttmpFile := stateFile + \\\".tmp\\\"\\n   331→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n   332→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   333→\\t}\\n   334→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n   335→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n   336→\\t}\\n   337→\\treturn nil\\n   338→}\\n   339→\\n   340→// Clear removes the session state file for the given session ID.\\n   341→func (s *StateStore) Clear(ctx context.Context, sessionID string) error {\\n   342→\\t_ = ctx // Reserved for future use\\n   343→\\n   344→\\t// Validate session ID to prevent path traversal\\n   345→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   346→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   347→\\t}\\n   348→\\n   349→\\tstateFile := s.stateFilePath(sessionID)\\n   350→\\n   351→\\tif err := os.Remove(stateFile); err != nil {\\n   352→\\t\\tif os.IsNotExist(err) {\\n   353→\\t\\t\\treturn nil // Already gone, not an error\\n   354→\\t\\t}\\n   355→\\t\\treturn fmt.Errorf(\\\"failed to remove session state file: %w\\\", err)\\n   356→\\t}\\n   357→\\treturn nil\\n   358→}\\n   359→\\n   360→// RemoveAll removes the entire session state directory.\\n   361→// This is used during uninstall to completely remove all session state.\\n   362→func (s *StateStore) RemoveAll() error {\\n   363→\\tif err := os.RemoveAll(s.stateDir); err != nil {\\n   364→\\t\\treturn fmt.Errorf(\\\"failed to remove session state directory: %w\\\", err)\\n   365→\\t}\\n   366→\\treturn nil\\n   367→}\\n   368→\\n   369→// List returns all session states.\\n   370→func (s *StateStore) List(ctx context.Context) ([]*State, error) {\\n   371→\\tentries, err := os.ReadDir(s.stateDir)\\n   372→\\tif os.IsNotExist(err) {\\n   373→\\t\\treturn nil, nil\\n   374→\\t}\\n   375→\\tif err != nil {\\n   376→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state directory: %w\\\", err)\\n   377→\\t}\\n   378→\\n   379→\\tvar states []*State\\n   380→\\tfor _, entry := range entries {\\n   381→\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   382→\\t\\t\\tcontinue\\n   383→\\t\\t}\\n   384→\\t\\tif strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   385→\\t\\t\\tcontinue // Skip temp files\\n   386→\\t\\t}\\n   387→\\n   388→\\t\\tsessionID := strings.TrimSuffix(entry.Name(), \\\".json\\\")\\n   389→\\t\\tstate, err := s.Load(ctx, sessionID)\\n   390→\\t\\tif err != nil {\\n   391→\\t\\t\\tcontinue // Skip corrupted state files\\n   392→\\t\\t}\\n   393→\\t\\tif state == nil {\\n   394→\\t\\t\\tcontinue // Not found or stale (Load handles cleanup)\\n   395→\\t\\t}\\n   396→\\n   397→\\t\\tstates = append(states, state)\\n   398→\\t}\\n   399→\\treturn states, nil\\n   400→}\\n   401→\\n   402→// stateFilePath returns the path to a session state file.\\n   403→func (s *StateStore) stateFilePath(sessionID string) string {\\n   404→\\treturn filepath.Join(s.stateDir, sessionID+\\\".json\\\")\\n   405→}\\n   406→\\n   407→// gitCommonDirCache caches the git common dir to avoid repeated subprocess calls.\\n   408→// Keyed by working directory to handle directory changes (same pattern as paths.WorktreeRoot).\\n   409→var (\\n   410→\\tgitCommonDirMu       sync.RWMutex\\n   411→\\tgitCommonDirCache    string\\n   412→\\tgitCommonDirCacheDir string\\n   413→)\\n   414→\\n   415→// ClearGitCommonDirCache clears the cached git common dir.\\n   416→// U