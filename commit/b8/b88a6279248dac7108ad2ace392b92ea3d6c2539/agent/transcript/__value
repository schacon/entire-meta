ase PhaseActive:\\n   145→\\t\\treturn transitionFromActive(event, ctx)\\n   146→\\tcase PhaseEnded:\\n   147→\\t\\treturn transitionFromEnded(event, ctx)\\n   148→\\tdefault:\\n   149→\\t\\t// PhaseFromString guarantees we only get known phases, but the\\n   150→\\t\\t// exhaustive linter requires handling the default case.\\n   151→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   152→\\t}\\n   153→}\\n   154→\\n   155→func transitionFromIdle(event Event, ctx TransitionContext) TransitionResult {\\n   156→\\tswitch event {\\n   157→\\tcase EventTurnStart:\\n   158→\\t\\treturn TransitionResult{\\n   159→\\t\\t\\tNewPhase: PhaseActive,\\n   160→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   161→\\t\\t}\\n   162→\\tcase EventTurnEnd:\\n   163→\\t\\t// Turn end while idle is a no-op (no active turn to end).\\n   164→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   165→\\tcase EventGitCommit:\\n   166→\\t\\tif ctx.IsRebaseInProgress {\\n   167→\\t\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   168→\\t\\t}\\n   169→\\t\\treturn TransitionResult{\\n   170→\\t\\t\\tNewPhase: PhaseIdle,\\n   171→\\t\\t\\tActions:  []Action{ActionCondense},\\n   172→\\t\\t}\\n   173→\\tcase EventSessionStart:\\n   174→\\t\\t// Already condensable, no-op.\\n   175→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   176→\\tcase EventSessionStop:\\n   177→\\t\\treturn TransitionResult{\\n   178→\\t\\t\\tNewPhase: PhaseEnded,\\n   179→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   180→\\t\\t}\\n   181→\\tcase EventCompaction:\\n   182→\\t\\t// Compaction while idle shouldn't happen, but condense if there's work.\\n   183→\\t\\treturn TransitionResult{\\n   184→\\t\\t\\tNewPhase: PhaseIdle,\\n   185→\\t\\t\\tActions:  []Action{ActionCondenseIfFilesTouched, ActionUpdateLastInteraction},\\n   186→\\t\\t}\\n   187→\\tdefault:\\n   188→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   189→\\t}\\n   190→}\\n   191→\\n   192→func transitionFromActive(event Event, ctx TransitionContext) TransitionResult {\\n   193→\\tswitch event {\\n   194→\\tcase EventTurnStart:\\n   195→\\t\\t// Ctrl-C recovery: agent crashed or user interrupted mid-turn.\\n   196→\\t\\treturn TransitionResult{\\n   197→\\t\\t\\tNewPhase: PhaseActive,\\n   198→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   199→\\t\\t}\\n   200→\\tcase EventTurnEnd:\\n   201→\\t\\treturn TransitionResult{\\n   202→\\t\\t\\tNewPhase: PhaseIdle,\\n   203→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   204→\\t\\t}\\n   205→\\tcase EventGitCommit:\\n   206→\\t\\tif ctx.IsRebaseInProgress {\\n   207→\\t\\t\\treturn TransitionResult{NewPhase: PhaseActive}\\n   208→\\t\\t}\\n   209→\\t\\treturn TransitionResult{\\n   210→\\t\\t\\tNewPhase: PhaseActive,\\n   211→\\t\\t\\tActions:  []Action{ActionCondense},\\n   212→\\t\\t}\\n   213→\\tcase EventSessionStart:\\n   214→\\t\\treturn TransitionResult{\\n   215→\\t\\t\\tNewPhase: PhaseActive,\\n   216→\\t\\t\\tActions:  []Action{ActionWarnStaleSession},\\n   217→\\t\\t}\\n   218→\\tcase EventSessionStop:\\n   219→\\t\\treturn TransitionResult{\\n   220→\\t\\t\\tNewPhase: PhaseEnded,\\n   221→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   222→\\t\\t}\\n   223→\\tcase EventCompaction:\\n   224→\\t\\t// Compaction mid-turn: save current progress but stay active.\\n   225→\\t\\t// The transcript offset will be reset by the compaction handler.\\n   226→\\t\\treturn TransitionResult{\\n   227→\\t\\t\\tNewPhase: PhaseActive,\\n   228→\\t\\t\\tActions:  []Action{ActionCondenseIfFilesTouched, ActionUpdateLastInteraction},\\n   229→\\t\\t}\\n   230→\\tdefault:\\n   231→\\t\\treturn TransitionResult{NewPhase: PhaseActive}\\n   232→\\t}\\n   233→}\\n   234→\\n   235→func transitionFromEnded(event Event, ctx TransitionContext) TransitionResult {\\n   236→\\tswitch event {\\n   237→\\tcase EventTurnStart:\\n   238→\\t\\treturn TransitionResult{\\n   239→\\t\\t\\tNewPhase: PhaseActive,\\n   240→\\t\\t\\tActions:  []Action{ActionClearEndedAt, ActionUpdateLastInteraction},\\n   241→\\t\\t}\\n   242→\\tcase EventTurnEnd:\\n   243→\\t\\t// Turn end while ended is a no-op.\\n   244→\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   245→\\tcase EventGitCommit:\\n   246→\\t\\tif ctx.IsRebaseInProgress {\\n   247→\\t\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   248→\\t\\t}\\n   249→\\t\\tif ctx.HasFilesTouched {\\n   250→\\t\\t\\treturn TransitionResult{\\n   251→\\t\\t\\t\\tNewPhase: PhaseEnded,\\n   252→\\t\\t\\t\\tActions:  []Action{ActionCondenseIfFilesTouched},\\n   253→\\t\\t\\t}\\n   254→\\t\\t}\\n   255→\\t\\treturn TransitionResult{\\n   256→\\t\\t\\tNewPhase: PhaseEnded,\\n   257→\\t\\t\\tActions:  []Action{ActionDiscardIfNoFiles},\\n   258→\\t\\t}\\n   259→\\tcase EventSessionStart:\\n   260→\\t\\treturn TransitionResult{\\n   261→\\t\\t\\tNewPhase: PhaseIdle,\\n   262→\\t\\t\\tActions:  []Action{ActionClearEndedAt},\\n   263→\\t\\t}\\n   264→\\tcase EventSessionStop:\\n   265→\\t\\t// Already ended, no-op.\\n   266→\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   267→\\tcase EventCompaction:\\n   268→\\t\\t// Compaction while ended shouldn't happen, no-op.\\n   269→\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   270→\\tdefault:\\n   271→\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   272→\\t}\\n   273→}\\n   274→\\n   275→// ActionHandler defines strategy-specific side effects for state transitions.\\n   276→// The compiler enforces that every strategy-specific action has a handler.\\n   277→type ActionHandler interface {\\n   278→\\tHandleCondense(state *State) error\\n   279→\\tHandleCondenseIfFilesTouched(state *State) error\\n   280→\\tHandleDiscardIfNoFiles(state *State) error\\n   281→\\tHandleWarnStaleSession(state *State) error\\n   282→}\\n   283→\\n   284→// NoOpActionHandler is a default ActionHandler where all methods are no-ops.\\n   285→// Embed this in handler structs to only ove