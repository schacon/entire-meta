e := range details {\\n   113→\\t\\tfmt.Fprintf(tty, \\\"  %s\\\\n\\\", line)\\n   114→\\t}\\n   115→\\n   116→\\t// Show prompt with option descriptions\\n   117→\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", prompt)\\n   118→\\tif defaultYes {\\n   119→\\t\\tfmt.Fprint(tty, \\\"  [Y]es / [n]o / [a]lways (remember my choice): \\\")\\n   120→\\t} else {\\n   121→\\t\\tfmt.Fprint(tty, \\\"  [y]es / [N]o / [a]lways (remember my choice): \\\")\\n   122→\\t}\\n   123→\\n   124→\\t// Read response\\n   125→\\treader := bufio.NewReader(tty)\\n   126→\\tresponse, err := reader.ReadString('\\\\n')\\n   127→\\tif err != nil {\\n   128→\\t\\treturn defaultResult\\n   129→\\t}\\n   130→\\n   131→\\tresponse = strings.TrimSpace(strings.ToLower(response))\\n   132→\\tswitch response {\\n   133→\\tcase \\\"y\\\", \\\"yes\\\":\\n   134→\\t\\treturn ttyResultLink\\n   135→\\tcase \\\"n\\\", \\\"no\\\":\\n   136→\\t\\treturn ttyResultSkip\\n   137→\\tcase \\\"a\\\", \\\"always\\\":\\n   138→\\t\\treturn ttyResultLinkAlways\\n   139→\\tdefault:\\n   140→\\t\\t// Empty or invalid input - use default\\n   141→\\t\\treturn defaultResult\\n   142→\\t}\\n   143→}\\n   144→\\n   145→// saveCommitLinkingAlways persists commit_linking = \\\"always\\\" to settings.local.json.\\n   146→// Uses raw JSON merge to set only the commit_linking field without affecting other\\n   147→// fields. This avoids writing unintended defaults (e.g., enabled: true) when the\\n   148→// local settings file doesn't exist yet.\\n   149→func saveCommitLinkingAlways(ctx context.Context) error {\\n   150→\\tlocalPath, err := paths.AbsPath(ctx, settings.EntireSettingsLocalFile)\\n   151→\\tif err != nil {\\n   152→\\t\\treturn fmt.Errorf(\\\"resolving local settings path: %w\\\", err)\\n   153→\\t}\\n   154→\\n   155→\\t// Read existing file as raw JSON map to preserve all existing fields.\\n   156→\\t// If the file doesn't exist, start with an empty map so we only write commit_linking.\\n   157→\\tvar raw map[string]json