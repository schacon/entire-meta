entire/cli/logging\\\"\\n    13→)\\n    14→\\n    15→// Phase represents the lifecycle stage of a session.\\n    16→type Phase string\\n    17→\\n    18→const (\\n    19→\\tPhaseActive Phase = \\\"active\\\"\\n    20→\\tPhaseIdle   Phase = \\\"idle\\\"\\n    21→\\tPhaseEnded  Phase = \\\"ended\\\"\\n    22→)\\n    23→\\n    24→// allPhases is the canonical list of phases for enumeration (e.g., diagram generation).\\n    25→var allPhases = []Phase{PhaseIdle, PhaseActive, PhaseEnded}\\n    26→\\n    27→// PhaseFromString normalizes a phase string, treating empty or unknown values\\n    28→// as PhaseIdle for backward compatibility with pre-state-machine session files.\\n    29→func PhaseFromString(s string) Phase {\\n    30→\\tswitch Phase(s) {\\n    31→\\tcase PhaseActive, \\\"active_committed\\\":\\n    32→\\t\\t// \\\"active_committed\\\" was removed with the 1:1 checkpoint model.\\n    33→\\t\\t// It previously meant \\\"agent active + commit happened during turn\\\".\\n    34→\\t\\t// Normalize to ACTIVE so HandleTurnEnd can finalize any pending checkpoints.\\n    35→\\t\\treturn PhaseActive\\n    36→\\tcase PhaseIdle:\\n    37→\\t\\treturn PhaseIdle\\n    38→\\tcase PhaseEnded:\\n    39→\\t\\treturn PhaseEnded\\n    40→\\tdefault:\\n    41→\\t\\t// Backward compat: truly unknown phases normalize to idle.\\n    42→\\t\\treturn PhaseIdle\\n    43→\\t}\\n    44→}\\n    45→\\n    46→// IsActive reports whether the phase represents an active agent turn.\\n    47→func (p Phase) IsActive() bool {\\n    48→\\treturn p == PhaseActive\\n    49→}\\n    50→\\n    51→// Event represents something that happened to a session.\\n    52→type Event int\\n    53→\\n    54→const (\\n    55→\\tEventTurnStart    Event = iota // Agent begins working on a prompt\\n    56→\\tEventTurnEnd                   // Agent finishes its turn\\n    57→\\tEventGitCommit                 // A git commit was made (PostCommit hook)\\n    58→\\tEventSessionStart              // Session process started (