tif prompts, extractErr := extractor.ExtractPrompts(transcriptRef, transcriptOffset); extractErr == nil && len(prompts) > 0 {\\n   364→\\t\\t\\t\\tcontent := strings.Join(prompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   365→\\t\\t\\t\\tif writeErr := os.WriteFile(promptPath, []byte(content), 0o600); writeErr != nil {\\n   366→\\t\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to backfill prompt.txt from transcript\\\",\\n   367→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", writeErr.Error()))\\n   368→\\t\\t\\t\\t} else {\\n   369→\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"backfilled prompt.txt from transcript\\\",\\n   370→\\t\\t\\t\\t\\t\\tslog.Int(\\\"prompt_count\\\", len(prompts)))\\n   371→\\t\\t\\t\\t}\\n   372→\\t\\t\\t\\tbackfilledPrompt = prompts[len(prompts)-1]\\n   373→\\t\\t\\t}\\n   374→\\t\\t}\\n   375→\\t}\\n   376→\\n   377→\\t// Compute subagents directory for agents that support subagent extraction.\\n   378→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   379→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   380→\\n   381→\\t// Extract metadata via agent interface (modified files)\\n   382→\\tvar modifiedFiles []string\\n   383→\\n   384→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok {\\n   385→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   386→\\t\\tif subagentExtractor, subOk := agent.AsSubagentAwareExtractor(ag); subOk {\\n   387→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n   388→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n   389→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   390→\\t\\t\\t} else {\\n   391→\\t\\t\\t\\tmodifiedFiles = files\\n   392→\\t\\t\\t}\\n   393→\\t\\t} else {\\n   394→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   395→\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   396→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n   397→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   398→\\t\\t\\t} else {\\n   399→\\t\\t\\t\\tmodifiedFiles = files\\n   400→\\t\\t\\t}\\n   401→\\t\\t}\\n   402→\\t}\\n   403→\\textractSpan.End()\\n   404→\\n   405→\\t// Generate commit message from last prompt (read from session state, set at TurnStart)\\n   406→\\t_, commitMsgSpan := perf.Start(ctx, \\\"generate_commit_message\\\")\\n   407→\\tlastPrompt := \\\"\\\"\\n   408→\\tif sessionState, stateErr := strategy.LoadSessionState(ctx, sessionID); stateErr == nil && sessionState != nil {\\n   409→\\t\\tlastPrompt = sessionState.LastPrompt\\n   410→\\t}\\n   411→\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n   412→\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n   413→\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n   414→\\tcommitMsgSpan.End()\\n   415→\\n   416→\\t// Get worktree root for path normalization\\n   417→\\t_, detectSpan := perf.Start(ctx, \\\"detect_file_changes\\\")\\n   418→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   419→\\tif err != nil {\\n   420→\\t\\tdetectSpan.RecordError(err)\\n   421→\\t\\tdetectSpan.End()\\n   422→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   423→\\t}\\n   424→\\n   425→\\tvar preUntrackedFiles []string\\n   426→\\tif preState != nil {\\n   427→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n   428→\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n   429→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   430→\\t}\\n   431→\\n   432→\\t// Detect file changes via git status\\n   433→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   434→\\tif err != nil {\\n   435→\\t\\tlo