leanups = append(s.cleanups, fn)\\n    21→}\\n    22→\\n    23→// NewTmuxSession creates a new tmux session running the given command in dir.\\n    24→// unsetEnv lists environment variable names to strip from the session.\\n    25→func NewTmuxSession(name string, dir string, unsetEnv []string, command string, args ...string) (*TmuxSession, error) {\\n    26→\\ts := &TmuxSession{name: name}\\n    27→\\n    28→\\ttmuxArgs := []string{\\\"new-session\\\", \\\"-d\\\", \\\"-s\\\", name, \\\"-c\\\", dir}\\n    29→\\t// Build a shell command string, prefixed with env -u for each var to strip.\\n    30→\\t// All arguments are shell-quoted to prevent injection or splitting.\\n    31→\\tvar parts []string\\n    32→\\tfor _, v := range unsetEnv {\\n    33→\\t\\tparts = append(parts, \\\"env\\\", \\\"-u\\\", shellQuote(v))\\n    34→\\t}\\n    35→\\tparts = append(parts, shellQuote(command))\\n    36→\\tfor _, a := range args {\\n    37→\\t\\tparts = append(parts, shellQuote(a))\\n    38→\\t}\\n    39→\\ttmuxArgs = append(tmuxArgs, strings.Join(parts, \\\" \\\"))\\n    40→\\n    41→\\tcmd := exec.Command(\\\"tmux\\\", tmuxArgs...)\\n    42→\\tif out, err := cmd.CombinedOutput(); err != nil {\\n    43→\\t\\treturn nil, fmt.Errorf(\\\"tmux new-session: %w\\\\n%s\\\", err, out)\\n    44→\\t}\\n    45→\\t// Keep the pane around after the command exits so we can capture error output.\\n    46→\\tsetCmd := exec.Command(\\\"tmux\\\", \\\"set-option\\\", \\\"-t\\\", name, \\\"remain-on-exit\\\", \\\"on\\\")\\n    47→\\t_ = setCmd.Run()\\n    48→\\treturn s, nil\\n    49→}\\n    50→\\n    51→func (s *TmuxSession) Send(input string) error {\\n    52→\\tpreSend := stableContent(s.Capture())\\n    53→\\t// Send text and Enter separately — Claude's TUI can swallow Enter\\n    54→\\t// if it arrives before the input handler finishes processing the text.\\n    55→\\tif err := s.SendKeys(input); err != nil {\\n    56→\\t\\treturn err\\n    57→\\t}\\n    58→\\ttime.Sleep(200 * time.Millisecond)