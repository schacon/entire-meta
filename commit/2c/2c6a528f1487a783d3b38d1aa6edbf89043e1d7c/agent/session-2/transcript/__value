\\t}\\n    47→}\\n    48→\\n    49→// ParseHookEvent translates a Kiro hook into a normalized lifecycle Event.\\n    50→// Returns nil for hooks with no lifecycle significance (preToolUse, postToolUse).\\n    51→func (k *KiroAgent) ParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*agent.Event, error) {\\n    52→\\tswitch hookName {\\n    53→\\tcase HookNameAgentSpawn:\\n    54→\\t\\treturn k.parseAgentSpawn(ctx, stdin)\\n    55→\\tcase HookNameUserPromptSubmit:\\n    56→\\t\\treturn k.parseUserPromptSubmit(ctx, stdin)\\n    57→\\tcase HookNameStop:\\n    58→\\t\\treturn k.parseStop(ctx, stdin)\\n    59→\\tcase HookNamePreToolUse, HookNamePostToolUse:\\n    60→\\t\\t// Pass-through hooks with no lifecycle significance\\n    61→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    62→\\tdefault:\\n    63→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    64→\\t}\\n    65→}\\n    66→\\n    67→// readHookInputOrEmpty wraps ReadAndParseHookInput, returning a zero-value\\n    68→// hookInputRaw on empty stdin instead of erroring. This supports the Kiro IDE\\n    69→// which delivers data via environment variables rather than JSON on stdin.\\n    70→// Malformed JSON still returns an error.\\n    71→func readHookInputOrEmpty(stdin io.Reader) (*hookInputRaw, error) {\\n    72→\\traw, err := agent.ReadAndParseHookInput[hookInputRaw](stdin)\\n    73→\\tif err != nil {\\n    74→\\t\\tif errors.Is(err, agent.ErrEmptyHookInput) {\\n    75→\\t\\t\\treturn &hookInputRaw{}, nil\\n    76→\\t\\t}\\n    77→\\t\\treturn nil, err\\n    78→\\t}\\n    79→\\treturn raw, nil\\n    80→}\\n    81→\\n    82→func (k *KiroAgent) parseAgentSpawn(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n    83→\\t_, err := readHookInputOrEmpty(stdin)\\n    84→\\tif err != nil {\\n    85→\\t\\treturn nil, err\\n    86→\\t}\\n    87→\\n    88→\\t// Generate a new stable session ID and cache it for subsequent hook