t\":[{\"tool_use_id\":\"toolu_01UC5bYdEdvnXNLV8h4TzxAt\",\"type\":\"tool_result\",\"content\":\"     1→name: E2E Tests\\n     2→\\n     3→on:\\n     4→  workflow_dispatch:\\n     5→    inputs:\\n     6→      agent:\\n     7→        description: 'Run a single agent (leave empty for all)'\\n     8→        required: false\\n     9→        type: choice\\n    10→        options:\\n    11→          - ''\\n    12→          - claude-code\\n    13→          - opencode\\n    14→          - gemini-cli\\n    15→          - factoryai-droid\\n    16→          - cursor-cli\\n    17→          - kiro\\n    18→  push:\\n    19→    branches:\\n    20→      - main\\n    21→\\n    22→permissions:\\n    23→  id-token: write\\n    24→  actions: read\\n    25→  contents: read\\n    26→\\n    27→# Concurrency: only one E2E job runs at a time\\n    28→concurrency:\\n    29→  group: e2e-tests\\n    30→  cancel-in-progress: true\\n    31→\\n    32→jobs:\\n    33→  # Build the matrix dynamically so workflow_dispatch can select a single agent.\\n    34→  matrix-setup:\\n    35→    runs-on: ubuntu-latest\\n    36→    outputs:\\n    37→      agents: ${{ steps.set.outputs.agents }}\\n    38→    steps:\\n    39→      - id: set\\n    40→        run: |\\n    41→          input=\\\"${{ github.event.inputs.agent }}\\\"\\n    42→          if [ -n \\\"$input\\\" ]; then\\n    43→            echo \\\"agents=[\\\\\\\"$input\\\\\\\"]\\\" >> \\\"$GITHUB_OUTPUT\\\"\\n    44→          else\\n    45→            echo 'agents=[\\\"claude-code\\\",\\\"opencode\\\",\\\"gemini-cli\\\",\\\"factoryai-droid\\\",\\\"cursor-cli\\\", \\\"kiro\\\"]' >> \\\"$GITHUB_OUTPUT\\\"\\n    46→          fi\\n    47→\\n    48→  e2e-tests:\\n    49→    needs: matrix-setup\\n    50→    runs-on: ubuntu-latest\\n    51→    timeout-minutes: 40\\n    52→    strategy:\\n    53→      fail-fast: false\\n    54→      matrix:\\n    55→        agent: ${{ fromJson(needs.matrix-setup.outputs.agents) }}\\n    56→\\n    57→    steps:\\n    58→      - name: Checkout repository\\n    59→        uses: actions/checkout@v6\\n    60→\\n    61→      - name: Setup mise\\n    62→        uses: jdx/mise-action@v3\\n    63→\\n    64→      - name: Install system dependencies\\n    65→        run: sudo apt-get update && sudo apt-get install -y tmux\\n    66→\\n    67→      - name: Install agent CLI\\n    68→        run: |\\n    69→          case \\\"${{ matrix.agent }}\\\" in\\n    70→            claude-code) curl -fsSL https://claude.ai/install.sh | bash ;;\\n    71→            opencode)    curl -fsSL https://opencode.ai/install | bash ;;\\n    72→            gemini-cli)  npm install -g @google/gemini-cli ;;\\n    73→            kiro)        curl -fsSL https://cli.kiro.dev/install | bash ;;\\n    74→            cursor-cli)  curl https://cursor.com/install -fsS | bash ;;\\n    75→            factoryai-droid) curl -fsSL https://app.factory.ai/cli | sh ;;\\n    76→          esac\\n    77→          echo \\\"$HOME/.local/bin\\\" >> $GITHUB_PATH\\n    78→\\n    79→      - name: Configure AWS credentials (Kiro OIDC)\\n    80→        if: matrix.agent == 'kiro'\\n    81→        uses: aws-actions/configure-aws-credentials@v5\\n    82→        with:\\n    83→          role-to-assume: ${{ secrets.AWS_ROLE_ARN }}\\n    84→          aws-region: us-east-1\\n    85→\\n    86→      - name: Bootstrap agent\\n    87→        env:\\n    88→          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}\\n    89→          GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}\\n    90→          CURSOR_API_KEY: ${{ secrets.CURSOR_API_KEY }}\\n    91→          FACTORY_API_KEY: ${{ secrets.FACTORY_API_KEY }}\\n    92→          AMAZON_Q_SIGV4: ${{ matrix.agent == 'kiro' && '1' || '' }}\\n    93→          AWS_REGION: ${{ matrix.agent == 'kiro' && 'us-east-1' || '' }}\\n    94→        run: go run ./e2e/bootstrap\\n    95→\\n    96→      - name: Run E2E Tests\\n    97→        env:\\n    98→          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}\\n    99→          GEMINI_API_KEY: ${{ secrets.GEMINI_API_KEY }}\\n   100→          CURSOR_API_KEY: ${{ secrets.CURSOR_API_KEY }}\\n   101→          FACTORY_API_KEY: ${{ secrets.FACTORY_API_KEY }}\\n   102→          AMAZON_Q_SIGV4: ${{ matrix.agent == 'kiro' && '1' || '' }}\\n   103→          AWS_REGION: ${{ matrix.agent == 'kiro' && 'us-east-1' || '' }}\\n   104→          E2E_CONCURRENT_TEST_LIMIT: ${{ matrix.agent == 'gemini-cli' && '6' || matrix.agent == 'factoryai-droid' && '1' || '' }}\\n   105→        run: mise run test:e2e --agent ${{ matrix.agent }}\\n   106→\\n   107→      - name: Upload artifacts\\n   108→        if: always()\\n   109→        uses: actions/upload-artifact@v7\\n   110→        with:\\n   111→          name: e2e-artifacts-${{ matrix.agent }}\\n   112→          path: e2e/artifacts/\\n   113→          retention-days: 7\\n   114→\\n   115→  notify-slack:\\n   116→    runs-on: ubuntu-latest\\n   117→    needs: [e2e-tests]\\n   118→    if: ${{ always() && needs.e2e-tests.result == 'failure' && github.event_name == 'push' }}\\n   119→    steps:\\n   120→      - name: Get failed agents\\n   121→        id: failed\\n   122→        env:\\n   123→          GH_TOKEN: ${{ github.token }}\\n   124→        run: |\\n   125→          failed=$(gh api repos/${{ github.repository }}/actions/runs/${{ github.run_id }}/jobs \\\\\\n   126→            --jq '[.jobs[] | select(.conclusion == \\\"failure\\\") | .name | capture(\\\"\\\\\\\\((?<agent>[^)]+)\\\\\\\\)\\\") | .agent] | join(\\\", \\\")')\\n   127→          echo \\\"agents=$failed\\\" >> \\\"$GITHUB_OUTPUT\\\"\\n   128→\\n   129→      - name: Notify Slack of E2E failure\\n   130→        uses: slackapi/slack-github-action@91efab103c0de0a537f72a35f6b8cda0ee76bf0a # v2.1.1\\n   131→        with:\\n   132→          webhook: ${{ secrets.E2E_SLACK_WEBHOOK_URL }}\\n   133→          webhook-type: incoming-webhook\\n   134→          payload: |\\n   135→            {\\n   136→              \\\"blocks\\\": [\\n   137→                {\\n   138→                  \\\"type\\\": \\\"section\\\",\\n   139→                  \\\"text\\\": {\\n   140→                    \\\"type\\\": \\\"mrkdwn\\\",\\n   141→                    \\\"text\\\": \\\":red_circle: *E2E Tests Failed* on `main`\\\\n\\\\nFailed agents: *${{ steps.failed.outputs.agents }}*\\\\n<${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}|View run details>\\\"\\n   142→                  }\\n   143→                },\\n   144→                {\\n   145→                  \\\"type\\\": \\\"context\\\",\\n   146→                  \\\"elements\\\": [\\n   147→                    {\\n   148→                      \\\"type\\\": \\\"mrkdwn\\\",\\n   149→                      \\\"text\\\": \\\"Commit: <${{ github.server_url }}/${{ github.repository }}/commit/${{ github.sha }}|${{ github.sha }}> by ${{ github.actor }}\\\"\\n   150→                    }\\n   151→                  ]\\n   152→                }\\n   153→              ]\\n   154→            }\\n   155→\"}]},\"uuid\":\"7c972fd6-ddf4-4bc5-b78f-83f0073be565\",\"timestamp\":\"2026-03-05T18:34:54.566Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a2ca0c00c4ea8b5ae\"},\"toolUseID\":\"agent_msg_0165DCpkzNjP4y6EoucRSeWV\",\"parentToolUseID\":\"toolu_01AA6F5bVwMMoxGdqbJeqA7y\",\"uuid\":\"37d80c16-d48a-4202-96ad-dbd2b9d4d7b7\",\"timestamp\":\"2026-03-05T18:34:54.624Z\"}\n{\"parentUuid\":\"37d80c16-d48a-4202-96ad-dbd2b9d4d7b7\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"a6375286-82fb-48a9-90fd-f8e611e47d1b\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"snappy-yawning-swan\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-05T18:34:54.642Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_013Qwpzz8criSzmVNx3ZBPeX\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01Q9ZYMpJG5d9x5KCqESmF74\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/alisha/Projects/wt/kiro-oneshot/e2e/README.md\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":7,\"cache_creation_input_tokens\":10181,\"cache_read_input_tokens\":47388,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":10181},\"output_tokens\":3,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYkR2ofU2i1WeKew2h4WF\",\"uuid\":\"3588965a-6557-4a0e-8d86-79c7df8ae1ca\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a2ca0c00c4ea8b5ae\"},\"toolUseID\":\"agent_msg_0165DCpkzNjP4y6EoucRSeWV\",\"parentToolUseID\":\"toolu_01AA6F5bVwMMoxGdqbJeqA7y\",\"uuid\":\"f088a4a6-ba21-48fa-8dce-01a0ac272bb3\",\"timestamp\":\"2026-03-05T18:34:54.642Z\"}\n{\"parentUuid\":\"f088a4a6-ba21-48fa-8dce-01a0ac272bb3\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"a6375286-82fb-48a9-90fd-f8e611e47d1b\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"snappy-yawning-swan\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01Q9ZYMpJG5d9x5KCqESmF74\",\"type\":\"tool_result\",\"content\":\"     1→# E2E Tests\\n     2→\\n     3→End-to-end tests for the `entire` CLI against real agents (Claude Code, Gemini CLI, OpenCode, Factory Droid, Kiro).\\n     4→\\n     5→## Commands\\n     6→\\n     7→```bash\\n     8→mise run test:e2e [filter]                          # run filtered (or omit filter for all agents)\\n     9→mise run test:e2e --agent claude-code [filter]       # Claude Code only\\n    10→mise run test:e2e --agent gemini-cli [filter]        # Gemini CLI only\\n    11→mise run test:e2e --agent opencode [filter]          # OpenCode only\\n    12→go build ./...                                      # compile check (no agent CLI needed)\\n    13→```\\n    14→\\n    15→**Do NOT run E2E tests proactively.** They make real API calls that consume tokens and cost money. Only run when explicitly asked.\\n    16→\\n    17→## Structure\\n    18→\\n    19→```\\n    20→e2e/\\n    21→├── agents/       # Agent abstraction (Agent interface, tmux sessions, concurrency gates)\\n    22→├── bootstrap/    # CI pre-test setup (auth config, warmup)\\n    23→├── entire/       # `entire` CLI wrapper (enable, rewind, etc.)\\n    24→├── exploratory/  # Experimental tests, not run by CI\\n    25→├── tests/        # Blessed test files (run by CI)\\n    26→└── testutil/     # Repo setup, assertions, artifact capture\\n    27→```\\n    28→\\n    29→## Key Patterns\\n    30→\\n    31→- Every test uses `testutil.ForEachAgent` which runs it per registered agent with repo setup, concurrency gating, and timeout scaling.\\n    32→- All operations go through `RepoState` (`s.RunPrompt`, `s.Git`) so they're logged to `console.log`.\\n    33→- Use the `entire` package for CLI interactions, not raw `exec.Command`.\\n    34→- Skip tests pending CLI fixes with `t.Skip(\\\"ENT-XXX: reason\\\")`.\\n    35→\\n    36→## Adding a New Agent\\n    37→\\n    38→1. Create `agents/<name>.go` implementing the `Agent` interface.\\n    39→2. Register it in `init()` with `Register(&YourAgent{})`.\\n    40→3. Add a `Bootstrap()` method for any CI-specific setup (auth config, warmup).\\n    41→4. Add a `RegisterGate(\\\"<name>\\\", N)` call if concurrency needs limiting.\\n    42→5. Ensure the agent name is accepted by `mise run test:e2e --agent <name>`.\\n    43→6. Add the agent to `.github/workflows/e2e.yml` matrix and `e2e-isolated.yml` options.\\n    44→\\n    45→## Environment Variables\\n    46→\\n    47→| Variable | Description | Default |\\n    48→|----------|-------------|---------|\\n    49→| `E2E_AGENT` | Agent to test (`claude-code`, `gemini-cli`, `opencode`, `factoryai-droid`, `kiro`) | all registered |\\n    50→| `E2E_ENTIRE_BIN` | Path to a pre-built `entire` binary | builds from source |\\n    51→| `E2E_TIMEOUT` | Timeout per prompt | `2m` |\\n    52→| `E2E_KEEP_REPOS` | Set to `1` to preserve temp repos after test | unset |\\n    53→| `E2E_ARTIFACT_DIR` | Override artifact output directory | `e2e/artifacts/<timestamp>` |\\n    54→| `ANTHROPIC_API_KEY` | Required for Claude Code | — |\\n    55→| `GEMINI_API_KEY` | Required for Gemini CLI | — |\\n    56→| `AMAZON_Q_SIGV4` | Enable headless IAM/SIGV4 auth for Kiro | unset |\\n    57→| `AWS_REGION` | AWS region for Kiro SIGV4 auth | `us-east-1` in CI |\\n    58→\\n    59→## Debugging Failures\\n    60→\\n    61→Artifacts are captured to `e2e/artifacts/` on every run (git-log, git-tree, console.log, checkpoint metadata, entire logs). Set `E2E_KEEP_REPOS=1` to preserve the temp repo — a symlink appears in the artifact dir pointing to it.\\n    62→\\n    63→Use the `debug-e2e` skill (`.claude/skills/debug-e2e/`) for a structured workflow when investigating failures.\\n    64→\\n    65→### Reading artifacts\\n    66→\\n    67→- `console.log` — full operation transcript including agent stdout/stderr\\n    68→- `git-log.txt` — commit history at time of failure\\n    69→- `git-tree.txt` — working tree state\\n    70→- `entire-logs/` — internal CLI logs\\n    71→\\n    72→### Fixing flaky tests\\n    73→\\n    74→When a test passes on retry but failed once, the problem is usually agent non-determinism, not a CLI bug. Common patterns:\\n    75→\\n    76→- **Agent asked for confirmation instead of acting**: The model output contains \\\"Does this look right?\\\" or \\\"Should I proceed?\\\". Fix: append \\\"Do not ask for confirmation, just make the change.\\\" to the prompt.\\n    77→- **Agent wrote to wrong path or created extra files**: Fix: be more explicit about exact file paths and what _not_ to do.\\n    78→- **Agent committed when it shouldn't have**: Fix: add \\\"Do not commit\\\" to the prompt.\\n    79→- **Checkpoint wait timeout**: `WaitForCheckpoint` or `WaitForCheckpointAdvanceFrom` exceeded deadline. Fix: increase the timeout argument.\\n    80→\\n    81→To diagnose: read `console.log` in the failing test's artifact directory. Compare what the agent actually did vs what the test expected.\\n    82→\\n    83→## CI Workflows\\n    84→\\n    85→- **`.github/workflows/e2e.yml`** — Runs full suite on push to main. Matrix: `[claude-code, opencode, gemini-cli, factoryai-droid, kiro]`.\\n    86→- **`.github/workflows/e2e-isolated.yml`** — Manual dispatch for debugging a single test. Inputs: agent + test name filter.\\n    87→\\n    88→Both workflows run `go run ./e2e/bootstrap` before tests to handle agent-specific CI setup (auth config, warmup).\\n    89→\\n    90→## Kiro Authentication\\n    91→\\n    92→- **Local development**: use normal browser/device login (`kiro-cli login`) and the CLI will reuse your local auth state.\\n    93→- **GitHub-hosted CI**: Kiro jobs use AWS OIDC credentials plus SIGV4 (`AMAZON_Q_SIGV4=1`) instead of browser login.\\n    94→\\n    95→CI prerequisite: set `AWS_ROLE_ARN` repository secret so `aws-actions/configure-aws-credentials` can assume the role.\\n    96→\"}]},\"uuid\":\"54d832a7-478f-4157-927d-b97e8fd74eed\",\"timestamp\":\"2026-03-05T18:34:54.657Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a2ca0c00c4ea8b5ae\"},\"toolUseID\":\"agent_msg_0165DCpkzNjP4y6EoucRSeWV\",\"parentToolUseID\":\"toolu_01AA6F5bVwMMoxGdqbJeqA7y\",\"uuid\":\"44ca5b2a-07f8-45dd-a7e7-cef38d4eab1d\",\"timestamp\":\"2026-03-05T18:34:54.727Z\"}\n{\"parentUuid\":\"44ca5b2a-07f8-45dd-a7e7-cef38d4eab1d\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"a6375286-82fb-48a9-90fd-f8e611e47d1b\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"snappy-yawning-swan\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-05T18:34:56.842Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01BHuYtHL2TaymnjtDnhAZ6s\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01LmHrqXRPXVj5bc1ubWbz8v\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/alisha/Projects/wt/kiro-oneshot/cmd/entire/cli/agent/kiro/hooks.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":7,\"cache_creation_input_tokens\":4562,\"cache_read_input_tokens\":57569,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":4562},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYkR2wGrpxrR4F1T9Ninh\",\"uuid\":\"786ef68c-e8a3-4b7a-a155-dce64f4100f5\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a2ca0c00c4ea8b5ae\"},\"toolUseID\":\"agent_msg_0165DCpkzNjP4y6EoucRSeWV\",\"parentToolUseID\":\"toolu_01AA6F5bVwMMoxGdqbJeqA7y\",\"uuid\":\"c8d430c4-2b6d-4ee4-a3b6-6f60ff20e864\",\"timestamp\":\"2026-03-05T18:34:56.842Z\"}\n{\"parentUuid\":\"c8d430c4-2b6d-4ee4-a3b6-6f60ff20e864\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"a6375286-82fb-48a9-90fd-f8e611e47d1b\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"snappy-yawning-swan\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01LmHrqXRPXVj5bc1ubWbz8v\",\"type\":\"tool_result\",\"content\":\"     1→package kiro\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"encoding/json\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"os\\\"\\n     8→\\t\\\"path/filepath\\\"\\n     9→\\t\\\"strings\\\"\\n    10→\\n    11→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    14→)\\n    15→\\n    16→// Ensure KiroAgent implements HookSupport\\n    17→var _ agent.HookSupport = (*KiroAgent)(nil)\\n    18→\\n    19→// HooksFileName is the config file for Kiro hooks.\\n    20→const HooksFileName = \\\"entire.json\\\"\\n    21→\\n    22→// hooksDir is the directory within .kiro where agent hook configs live.\\n    23→const hooksDir = \\\"agents\\\"\\n    24→\\n    25→// ideHooksDir is the directory within .kiro where IDE hook files live.\\n    26→const ideHooksDir = \\\"hooks\\\"\\n    27→\\n    28→// ideHookFileSuffix is the file extension for IDE hook files.\\n    29→const ideHookFileSuffix = \\\".kiro.hook\\\"\\n    30→\\n    31→// ideHookVersion is the schema version for IDE hook files.\\n    32→const ideHookVersion = \\\"1\\\"\\n    33→\\n    34→// vscodeSettingsDir is the directory for VS Code settings.\\n    35→const vscodeSettingsDir = \\\".vscode\\\"\\n    36→\\n    37→// vscodeSettingsFile is the settings file within .vscode.\\n    38→const vscodeSettingsFile = \\\"settings.json\\\"\\n    39→\\n    40→// trustedCommandsKey is the VS Code settings key for Kiro trusted commands.\\n    41→const trustedCommandsKey = \\\"kiroAgent.trustedCommands\\\"\\n    42→\\n    43→// prodTrustedCommand is the trusted command pattern for production installs.\\n    44→const prodTrustedCommand = \\\"entire hooks *\\\"\\n    45→\\n    46→// localDevCmdPrefix is the command prefix used for local development builds.\\n    47→const localDevCmdPrefix = \\\"go run ${KIRO_PROJECT_DIR}/cmd/entire/main.go \\\"\\n    48→\\n    49→// prodHookCmdPrefix is the command prefix for production hook commands.\\n    50→const prodHookCmdPrefix = \\\"entire hooks kiro \\\"\\n    51→\\n    52→// entireHookPrefixes identify Entire hooks in the config file.\\n    53→var entireHookPrefixes = []string{\\n    54→\\t\\\"entire \\\",\\n    55→\\tlocalDevCmdPrefix,\\n    56→}\\n    57→\\n    58→// ideHookDef defines a single IDE hook file to install.\\n    59→type ideHookDef struct {\\n    60→\\tFilename    string // e.g. \\\"entire-prompt-submit\\\"\\n    61→\\tTriggerType string // e.g. \\\"promptSubmit\\\"\\n    62→\\tCLIVerb     string // e.g. \\\"user-prompt-submit\\\"\\n    63→}\\n    64→\\n    65→// ideHookDefs lists the 4 IDE hook files to install.\\n    66→// No agentSpawn IDE hook — the IDE has no such trigger.\\n    67→// The first promptSubmit serves as session start.\\n    68→var ideHookDefs = []ideHookDef{\\n    69→\\t{Filename: \\\"entire-prompt-submit\\\", TriggerType: \\\"promptSubmit\\\", CLIVerb: HookNameUserPromptSubmit},\\n    70→\\t{Filename: \\\"entire-stop\\\", TriggerType: \\\"agentStop\\\", CLIVerb: HookNameStop},\\n    71→\\t{Filename: \\\"entire-pre-tool-use\\\", TriggerType: \\\"preToolUse\\\", CLIVerb: HookNamePreToolUse},\\n    72→\\t{Filename: \\\"entire-post-tool-use\\\", TriggerType: \\\"postToolUse\\\", CLIVerb: HookNamePostToolUse},\\n    73→}\\n    74→\\n    75→// InstallHooks installs Entire hooks in .kiro/agents/entire.json (CLI hooks)\\n    76→// and .kiro/hooks/*.kiro.hook (IDE hooks).\\n    77→// Returns the total number of hooks installed (CLI + IDE).\\n    78→func (k *KiroAgent) InstallHooks(ctx context.Context, localDev bool, force bool) (int, error) {\\n    79→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    80→\\tif err != nil {\\n    81→\\t\\tworktreeRoot = \\\".\\\"\\n    82→\\t}\\n    83→\\n    84→\\thooksPath := filepath.Join(worktreeRoot, \\\".kiro\\\", hooksDir, HooksFileName)\\n    85→\\n    86→\\t// If hooks are already installed and not forcing, check if they're current\\n    87→\\tif !force {\\n    88→\\t\\tif existing, readErr := os.ReadFile(hooksPath); readErr == nil { //nolint:gosec // path constructed from repo root\\n    89→\\t\\t\\tvar file kiroAgentFile\\n    90→\\t\\t\\tif json.Unmarshal(existing, &file) ==