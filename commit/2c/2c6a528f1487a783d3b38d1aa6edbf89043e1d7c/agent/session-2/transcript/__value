cheDir, 0o750); err != nil {\\n   203→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to create transcript cache dir\\\", \\\"err\\\", err)\\n   204→\\t\\treturn \\\"\\\"\\n   205→\\t}\\n   206→\\tif err := os.WriteFile(cachePath, []byte(\\\"{}\\\"), 0o600); err != nil {\\n   207→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to write placeholder transcript\\\", \\\"err\\\", err)\\n   208→\\t\\treturn \\\"\\\"\\n   209→\\t}\\n   210→\\treturn cachePath\\n   211→}\\n   212→\\n   213→// generateAndCacheSessionID creates a new random session ID and writes it\\n   214→// to .entire/tmp/kiro-active-session for subsequent hooks to read.\\n   215→func (k *KiroAgent) generateAndCacheSessionID(ctx context.Context) string {\\n   216→\\tsid := generateSessionID()\\n   217→\\tcachePath := k.sessionIDCachePath(ctx)\\n   218→\\tif err := os.MkdirAll(filepath.Dir(cachePath), 0o750); err != nil {\\n   219→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to create session ID cache dir\\\", \\\"err\\\", err)\\n   220→\\t\\treturn sid\\n   221→\\t}\\n   222→\\tif err := os.WriteFile(cachePath, []byte(sid), 0o600); err != nil {\\n   223→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to write session ID cache\\\", \\\"err\\\", err)\\n   224→\\t}\\n   225→\\treturn sid\\n   226→}\\n   227→\\n   228→// clearCachedSessionID removes the session ID cache file so that a subsequent\\n   229→// session does not accidentally reuse a stale ID from a previous session.\\n   230→func (k *KiroAgent) clearCachedSessionID(ctx context.Context) {\\n   231→\\tcachePath := k.sessionIDCachePath(ctx)\\n   232→\\tif err := os.Remove(cachePath); err != nil && !os.IsNotExist(err) {\\n   233→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to clear session ID cache\\\", \\\"err\\\", err)\\n   234→\\t}\\n   235→}\\n   236→\\n   237→// readCachedSessionID reads the stable session ID from .entire/tmp/kiro-active-session.\\n   238→// Returns empty string if the cache file doesn't exist.\\n   239→func (k *KiroAgent) readCachedSessionID(ctx context.Con