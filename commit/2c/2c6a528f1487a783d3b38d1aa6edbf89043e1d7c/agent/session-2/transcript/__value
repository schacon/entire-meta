    24→// Kiro uses camelCase hook names natively, but CLI subcommands use kebab-case.\\n    25→const (\\n    26→\\tHookNameAgentSpawn       = \\\"agent-spawn\\\"\\n    27→\\tHookNameUserPromptSubmit = \\\"user-prompt-submit\\\"\\n    28→\\tHookNamePreToolUse       = \\\"pre-tool-use\\\"\\n    29→\\tHookNamePostToolUse      = \\\"post-tool-use\\\"\\n    30→\\tHookNameStop             = \\\"stop\\\"\\n    31→)\\n    32→\\n    33→// sessionIDFile is the filename for caching the generated session ID.\\n    34→// Stored in .entire/tmp/ to ensure a stable ID across all hooks in one session.\\n    35→const sessionIDFile = \\\"kiro-active-session\\\"\\n    36→\\n    37→// HookNames returns the hook verbs Kiro supports.\\n    38→// These become subcommands: entire hooks kiro <verb>\\n    39→func (k *KiroAgent) HookNames() []string {\\n    40→\\treturn []string{\\n    41→\\t\\tHookNameAgentSpawn,\\n    42→\\t\\tHookNameUserPromptSubmit,\\n    43→\\t\\tHookNamePreToolUse,\\n    44→\\t\\tHookNamePostToolUse,\\n    45→\\t\\tHookNameStop,\\n    46→\\t}\\n    47→}\\n    48→\\n    49→// ParseHookEvent translates a Kiro hook into a normalized lifecycle Event.\\n    50→// Returns nil for hooks with no lifecycle significance (preToolUse, postToolUse).\\n    51→func (k *KiroAgent) ParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*agent.Event, error) {\\n    52→\\tswitch hookName {\\n    53→\\tcase HookNameAgentSpawn:\\n    54→\\t\\treturn k.parseAgentSpawn(ctx, stdin)\\n    55→\\tcase HookNameUserPromptSubmit:\\n    56→\\t\\treturn k.parseUserPromptSubmit(ctx, stdin)\\n    57→\\tcase HookNameStop:\\n    58→\\t\\treturn k.parseStop(ctx, stdin)\\n    59→\\tcase HookNamePreToolUse, HookNamePostToolUse:\\n    60→\\t\\t// Pass-through hooks with no lifecycle significance\\n    61→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    62→\\tdefault:\\n    63→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    64→\\t}\\n    65→}\\n    66→\\n    67→// readHookInputOrEmpty wraps ReadAndParseHookInput, returning a zero-value\\n    68→// hookInputRaw on empty stdin instead of erroring. This supports the Kiro IDE\\n    69→// which delivers data via environment variables rather than JSON on stdin.\\n    70→// Malformed JSON still returns an error.\\n    71→func readHookInputOrEmpty(stdin io.Reader) (*hookInputRaw, error) {\\n    72→\\traw, err := agent.ReadAndParseHookInput[hookInputRaw](stdin)\\n    73→\\tif err != nil {\\n    74→\\t\\tif errors.Is(err, agent.ErrEmptyHookInput) {\\n    75→\\t\\t\\treturn &hookInputRaw{}, nil\\n    76→\\t\\t}\\n    77→\\t\\treturn nil, err\\n    78→\\t}\\n    79→\\treturn raw, nil\\n    80→}\\n    81→\\n    82→func (k *KiroAgent) parseAgentSpawn(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n    83→\\t_, err := readHookInputOrEmpty(stdin)\\n    84→\\tif err != nil {\\n    85→\\t\\treturn nil, err\\n    86→\\t}\\n    87→\\n    88→\\t// Generate a new stable session ID and cache it for subsequent hooks.\\n    89→\\t// Kiro's SQLite transcript isn't populated until the turn ends, so we can't\\n    90→\\t// use the native conversation_id as our session ID — it would be \\\"unknown\\\"\\n    91→\\t// at agentSpawn/userPromptSubmit and change to the real ID at stop.\\n    92→\\tsessionID := k.generateAndCacheSessionID(ctx)\\n    93→\\n    94→\\treturn &agent.Event{\\n    95→\\t\\tType:      agent.SessionStart,\\n    96→\\t\\tSessionID: sessionID,\\n    97→\\t\\tTimestamp: time.Now(),\\n    98→\\t}, nil\\n    99→}\\n   100→\\n   101→func (k *KiroAgent) parseUserPromptSubmit(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n   102→\\traw, err := readHookInputOrEmpty(stdin)\\n   103→\\tif err != nil {\\n   104→\\t\\treturn nil, err\\n   105→\\t}\\n   106→\\n   107→\\t// IDE mode: prompt comes from USER_PROMPT env var when stdin is empty.\\n   108→\\tprompt := raw.Prompt\\n   109→\\tif prompt == \\\"\\\" {\\n   110→\\t\\tprompt = os.Getenv(\\\"USER_PROMPT\\\")\\n   111→\\t}\\n   112→\\n   113→\\t// Read the stable session ID generated at agentSpawn.\\n   114→\\tsessionID := k.readCachedSessionID(ctx)\\n   115→\\tif sessionID == \\\"\\\" {\\n   116→\\t\\t// Fallback: generate new ID if cache file is missing (e.g., agentSpawn was skipped).\\n   117→\\t\\tsessionID = k.generateAndCacheSessionID(ctx)\\n   118→\\t}\\n   119→\\n   120→\\treturn &agent.Event{\\n   121→\\t\\tType:      agent.TurnStart,\\n   122→\\t\\tSessionID: sessionID,\\n   123→\\t\\tPrompt:    prompt,\\n   124→\\t\\tTimestamp: time.Now(),\\n   125→\\t}, nil\\n   126→}\\n   127→\\n   128→func (k *KiroAgent) parseStop(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n   129→\\traw, err := readHookInputOrEmpty(stdin)\\n   130→\\tif err != nil {\\n   131→\\t\\treturn nil, err\\n   132→\\t}\\n   133→\\n   134→\\t// IDE mode: CWD may not be in stdin. Fall back to repo root.\\n   135→\\tcwd := raw.CWD\\n   136→\\tif cwd == \\\"\\\" {\\n   137→\\t\\trepoRoot, rootErr := paths.WorktreeRoot(ctx)\\n   138→\\t\\tif rootErr == nil {\\n   139→\\t\\t\\tcwd = repoRoot\\n   140→\\t\\t}\\n   141→\\t}\\n   142→\\n   143→\\t// Read the stable session ID generated at agentSpawn.\\n   144→\\tsessionID := k.readCachedSessionID(ctx)\\n   145→\\tif sessionID == \\\"\\\" {\\n   146→\\t\\t// Fallback: try SQLite for the session ID.\\n   147→\\t\\tsid, queryErr := k.querySessionID(ctx, cwd)\\n   148→\\t\\tif queryErr != nil || sid == \\\"\\\" {\\n   149→\\t\\t\\tsessionID = \\\"unknown\\\"\\n   150→\\t\\t} else {\\n   151→\\t\\t\\tsessionID = sid\\n   152→\\t\\t}\\n   153→\\t}\\n   154→\\n   155→\\t// At stop, Kiro's SQLite transcript is available. Fetch and cache it\\n   156→\\t// under our stable session ID so lifecycle.go can read it.\\n   157→\\tvar sessionRef string\\n   158→\\tsessionRef, err = k.ensureCachedTranscript(ctx, cwd, sessionID)\\n   159→\\tif err != nil {\\n   160→\\t\\tlogging.Debug(ctx, \\\"kiro: ensureCachedTranscrip