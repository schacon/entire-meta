→    description: 'AWS region for Kiro CLI operations'\\n    20→    required: false\\n    21→    default: 'us-east-1'\\n    22→  enable-sigv4:\\n    23→    description: 'Enable SIGV4 authentication mode'\\n    24→    required: false\\n    25→    default: 'false'\\n    26→  verify-checksum:\\n    27→    description: 'Verify SHA256 checksum of downloaded binary'\\n    28→    required: false\\n    29→    default: 'false'\\n    30→\\n    31→outputs:\\n    32→  kiro-version:\\n    33→    description: 'Installed Kiro CLI version'\\n    34→    value: ${{ steps.install.outputs.version }}\\n    35→  kiro-path:\\n    36→    description: 'Path to Kiro CLI binary directory'\\n    37→    value: ${{ steps.setup-path.outputs.path }}\\n    38→\\n    39→runs:\\n    40→  using: 'composite'\\n    41→  steps:\\n    42→    - name: Check platform support\\n    43→      shell: bash\\n    44→      run: |\\n    45→        OS=\\\"${{ runner.os }}\\\"\\n    46→        if [ \\\"$OS\\\" != \\\"Linux\\\" ]; then\\n    47→          echo \\\"::error::Kiro CLI action only supports Linux runners. Use the official install script for macOS: curl -fsSL https://cli.kiro.dev/install | bash\\\"\\n    48→          exit 1\\n    49→        fi\\n    50→\\n    51→    - name: Cache Kiro CLI binaries\\n    52→      id: cache-kiro\\n    53→      uses: actions/cache@cdf6c1fa76f9f475f3d7449005a359c84ca0f306 # v5\\n    54→      with:\\n    55→        path: ~/.local/bin/kiro-cli-chat\\n    56→        key: kiro-${{ inputs.version }}-${{ runner.os }}-${{ runner.arch }}\\n    57→\\n    58→    - name: Install Kiro CLI\\n    59→      id: install\\n    60→      if: steps.cache-kiro.outputs.cache-hit != 'true'\\n    61→      shell: bash\\n    62→      run: |\\n    63→        echo \\\"::group::Installing Kiro CLI ${{ inputs.version }}\\\"\\n    64→        mkdir -p ~/.local/bin\\n    65→        \\n    66→        # Determine architecture\\n    67→        ARCH=\\\"${{ runner.arch }}\\\"\\n    68→        if [ \\\"$ARCH\\\" = \\\"X64\\\" ]; then\\n    69→          KIRO_ARCH=\\\"x86_64\\\"\\n    70→        elif [ \\\"$ARCH\\\" = \\\"ARM64\\\" ]; then\\n    71→          KIRO_ARCH=\\\"aarch64\\\"\\n    72→        else\\n    73→          echo \\\"::error::Unsupported architecture: $ARCH\\\"\\n    74→          exit 1\\n    75→        fi\\n    76→        \\n    77→        # Download URL (Linux only, versioned path)\\n    78→        DOWNLOAD_URL=\\\"https://desktop-release.q.us-east-1.amazonaws.com/${{ inputs.version }}/kirocli-${KIRO_ARCH}-linux.zip\\\"\\n    79→        echo \\\"Downloading from: $DOWNLOAD_URL\\\"\\n    80→        \\n    81→        # Download and extract\\n    82→        curl --proto '=https' --tlsv1.2 -sSfL \\\"$DOWNLOAD_URL\\\" -o kiro.zip\\n    83→        \\n    84→        # Verify checksum if requested\\n    85→        if [ \\\"${{ inputs.verify-checksum }}\\\" = \\\"true\\\" ]; then\\n    86→          echo \\\"Downloading SHA256 checksum...\\\"\\n    87→          curl --proto '=https' --tlsv1.2 -sSfL \\\"${DOWNLOAD_URL}.sha256\\\" -o kiro.zip.sha256\\n    88→          \\n    89→          EXPECTED_SHA=$(cat kiro.zip.sha256)\\n    90→          ACTUAL_SHA=$(shasum -a 256 kiro.zip | cut -d' ' -f1)\\n    91→          \\n    92→          if [ \\\"$EXPECTED_SHA\\\" != \\\"$ACTUAL_SHA\\\" ]; then\\n    93→            echo \\\"::error::SHA256 mismatch! Expected: $EXPECTED_SHA, Got: $ACTUAL_SHA\\\"\\n    94→            exit 1\\n    95→          fi\\n    96→          echo \\\"SHA256 verification passed\\\"\\n    97→        fi\\n    98→        \\n    99→        unzip -q kiro.zip\\n   100→        \\n   101→        # Get actual version from BUILD-INFO if available\\n   102→        if [ -f kirocli/BUILD-INFO ]; then\\n   103→          ACTUAL_VERSION=$(grep '^BUILD_VERSION=' kirocli/BUILD-INFO | cut -d= -f2)\\n   104→          echo \\\"version=${ACTUAL_VERSION}\\\" >> $GITHUB_OUTPUT\\n   105→        else\\n   106→          echo \\\"version=${{ inputs.version }}\\\" >> $GITHUB_OUTPUT\\n   107→        fi\\n   108→        \\n   109→        # Copy only kiro-cli-chat binary (sufficient for CI/CD)\\n   110→        cp kirocli/bin/kiro-cli-chat ~/.local/bin/\\n   111→        chmod +x ~/.local/bin/kiro-cli-chat\\n   112→        \\n   113→        # Cleanup\\n   114→        rm -rf kirocli kiro.zip\\n   115→        \\n   116→        echo \\\"::endgroup::\\\"\\n   117→\\n   118→    - name: Setup PATH\\n   119→      id: setup-path\\n   120→      shell: bash\\n   121→      run: |\\n   122→        echo \\\"$HOME/.local/bin\\\" >> $GITHUB_PATH\\n   123→        echo \\\"path=$HOME/.local/bin\\\" >> $GITHUB_OUTPUT\\n   124→\\n   125→    - name: Configure SIGV4 authentication\\n   126→      if: inputs.enable-sigv4 == 'true'\\n   127→      shell: bash\\n   128→      run: |\\n   129→        echo \\\"AMAZON_Q_SIGV4=true\\\" >> $GITHUB_ENV\\n   130→        echo \\\"AWS_REGION=${{ inputs.aws-region }}\\\" >> $GITHUB_ENV\\n   131→\\n   132→    - name: Verify installation\\n   133→      shell: bash\\n   134→      run: |\\n   135→        echo \\\"::group::Verifying Kiro CLI installation\\\"\\n   136→        kiro-cli-chat --version\\n   137→        echo \\\"Installed binary:\\\"\\n   138→        ls -lh ~/.local/bin/kiro-cli-chat\\n   139→        echo \\\"::endgroup::\\\"\\n   140→\\n   141→branding:\\n   142→  icon: 'terminal'\\n   143→  color: 'purple'\\n   144→\"}]},\"uuid\":\"7071a656-ccfb-4c57-a201-8bae82782d1d\",\"timestamp\":\"2026-03-05T18:57:25.637Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"adf0421f7910ffeda\"},\"toolUseID\":\"agent_msg_01Tp6cLdVhpG8c9zLByn7E21\",\"parentToolUseID\":\"toolu_01LEsxwfZ9MWJrbKeVbRzCa7\",\"uuid\":\"5d4dfe35-412d-4321-8469-6735e96f8db3\",\"timestamp\":\"2026-03-05T18:57:25.640Z\"}\n{\"parentUuid\":\"5d4dfe35-412d-4321-8469-6735e96f8db3\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"a6375286-82fb-48a9-90fd-f8e611e47d1b\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"snappy-yawning-swan\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01XSYFpXA63CrAau3wUwqZHN\",\"type\":\"tool_result\",\"content\":\"     1→# Setup Kiro CLI Action\\n     2→\\n     3→[![Test Action](https://github.com/clouatre-labs/setup-kiro-action/actions/workflows/test.yml/badge.svg)](https://github.com/clouatre-labs/setup-kiro-action/actions/workflows/test.yml)\\n     4→[![GitHub Marketplace](https://img.shields.io/badge/Marketplace-Setup%20Kiro%20CLI-blue?logo=github)](https://github.com/marketplace/actions/setup-kiro-cli)\\n     5→[![Composite Action](https://img.shields.io/badge/Composite-Action-green?logo=github)](https://docs.github.com/en/actions/creating-actions/about-custom-actions#composite-actions)\\n     6→[![License: MIT](https://img.shields.io/badge/License-MIT-blue.svg)](LICENSE)\\n     7→[![Latest Release](https://img.shields.io/github/v/release/clouatre-labs/setup-kiro-action)](https://github.com/clouatre-labs/setup-kiro-action/releases/latest)\\n     8→\\n     9→GitHub Action to install and cache [Kiro CLI](https://kiro.dev/docs/cli/) on GitHub-hosted runners. Provides automatic binary caching and headless IAM authentication via SIGV4 for AI-augmented CI/CD pipelines on AWS.\\n    10→\\n    11→**Unofficial community action.** Not affiliated with or endorsed by Amazon Web Services (AWS). \\\"Kiro\\\" and \\\"Amazon Web Services\\\" are trademarks of AWS.\\n    12→\\n    13→## Quick Start - Tier 1 (Maximum Security)\\n    14→\\n    15→> [!IMPORTANT]\\n    16→> **Prompt Injection Risk:** When AI analyzes user-controlled input (git diffs, code comments, commit messages), malicious actors can embed instructions to manipulate output. This applies to ANY AI tool, not just Kiro CLI or this action.\\n    17→> \\n    18→> For production use, see [Security Patterns](#security-patterns) below for three defensive tiers (tool output analysis, manual approval, trusted-only execution).\\n    19→\\n    20→```yaml\\n    21→name: Linter Analysis with Kiro CLI\\n    22→on: [push]\\n    23→\\n    24→permissions:\\n    25→  id-token: write\\n    26→  contents: read\\n    27→\\n    28→jobs:\\n    29→  analyze:\\n    30→    runs-on: ubuntu-latest\\n    31→    steps:\\n    32→      - name: Checkout\\n    33→        uses: actions/checkout@v6\\n    34→\\n    35→      - name: Run Linter\\n    36→        run: pipx run ruff check --output-format=json . > lint.json || true\\n    37→\\n    38→      - name: Configure AWS Credentials via OIDC\\n    39→        uses: aws-actions/configure-aws-credentials@v5\\n    40→        with:\\n    41→          role-to-assume: ${{ secrets.AWS_ROLE_ARN }}\\n    42→          aws-region: us-east-1\\n    43→\\n    44→      - name: Setup Kiro CLI\\n    45→        uses: clouatre-labs/setup-kiro-action@v1\\n    46→        with:\\n    47→          enable-sigv4: true\\n    48→          aws-region: us-east-1\\n    49→\\n    50→      - name: AI Analysis of Linter Output\\n    51→        run: |\\n    52→          echo \\\"Summarize these linting issues and suggest fixes:\\\" > prompt.txt\\n    53→          cat lint.json >> prompt.txt\\n    54→          kiro-cli-chat chat --no-interactive \\\"$(cat prompt.txt)\\\" > analysis.md\\n    55→\\n    56→      - name: Upload Analysis Artifact\\n    57→        uses: actions/upload-artifact@v5\\n    58→        with:\\n    59→          name: ai-analysis\\n    60→          path: analysis.md\\n    61→```\\n    62→\\n    63→## Features\\n    64→\\n    65→- **Automatic caching** - Caches Kiro CLI binaries for faster subsequent runs\\n    66→- **SIGV4 authentication** - IAM-based headless authentication for CI/CD\\n    67→- **GitHub-hosted runners** - Supports x64 Ubuntu runners (simple, fast, manageable)\\n    68→- **Lightweight** - Composite action with no external dependencies\\n    69→\\n    70→## Security\\n    71→\\n    72→**Safe Pattern:** AI analyzes tool output (ruff, trivy, semgrep), not raw code.\\n    73→\\n    74→**Unsafe Pattern:** AI analyzes git diffs directly → vulnerable to prompt injection.\\n    75→\\n    76→See [SECURITY.md](SECURITY.md) for reporting vulnerabilities.\\n    77→\\n    78→## Security Patterns\\n    79→\\n    80→This action supports three security tiers for AI-augmented CI/CD:\\n    81→\\n    82→- **Tier 1 (Maximum Security)**: AI analyzes only tool output (JSON), never raw code. [See workflow](examples/tier1-maximum-security.yml)\\n    83→- **Tier 2**: AI sees file stats, requires manual approval. [See workflow](examples/tier2-balanced-security.yml)\\n    84→- **Tier 3**: Full diff analysis, trusted teams only. [See workflow](examples/tier3-advanced-patterns.yml)\\n    85→\\n    86→Read the full explanation: [AI-Augmented CI/CD blog post](https://clouatre.ca/posts/ai-augmented-cicd)\\n    87→\\n    88→## Inputs\\n    89→\\n    90→| Input | Description | Required | Default |\\n    91→|-------|-------------|----------|---------|\\n    92→| `version` | Kiro CLI version to install | No | See [`action.yml`](action.yml#L15) |\\n    93→| `aws-region` | AWS region for Kiro CLI operations | No | `us-east-1` |\\n    94→| `enable-sigv4` | Enable SIGV4 authentication mode | No | `false` |\\n    95→| `verify-checksum` | Verify SHA256 checksum of downloaded binary | No | `false` |\\n    96→\\n    97→## Outputs\\n    98→\\n    99→| Output | Description |\\n   100→|--------|-------------|\\n   101→| `kiro-version` | Installed Kiro CLI version |\\n   102→| `kiro-path` | Path to Kiro CLI binary directory |\\n   103→\\n   104→## Supported Platforms\\n   105→\\n   106→**GitHub-hosted runners only** - Designed for simple, fast, manageable CI/CD.\\n   107→\\n   108→| OS | Architecture | Runner Label |\\n   109→|----|--------------|--------------|\\n   110→| Ubuntu | x64 | `ubuntu-latest`, `ubuntu-24.04`, `ubuntu-22.04` |\\n   111→\\n   112→**Not supported:** macOS, Windows. For macOS, use the official install script: `curl -fsSL https://cli.kiro.dev/install | bash`\\n   113→\\n   114→Self-hosted ARM64 runners may work but are untested.\\n   115→\\n   116→## Authentication Methods\\n   117→\\n   118→### Method 1: OIDC (Recommended for GitHub Actions)\\n   119→\\n   120→Uses GitHub's OIDC provider for secure, credential-free authentication.\\n   121→\\n   122→1. Create OIDC provider:\\n   123→```bash\\n   124→aws iam create-open-id-connect-provider \\\\\\n   125→  --url https://token.actions.githubusercontent.com \\\\\\n   126→  --client-id-list sts.amazonaws.com \\\\\\n   127→  --thumbprint-list 6938fd4d98bab03faadb97b34396831e3780aea1\\n   128→```\\n   129→\\n   130→2. Create IAM role with trust policy:\\n   131→```json\\n   132→{\\n   133→  \\\"Version\\\": \\\"2012-10-17\\\",\\n   134→  \\\"Statement\\\": [{\\n   135→    \\\"Effect\\\": \\\"Allow\\\",\\n   136→    \\\"Principal\\\": {\\n   137→      \\\"Federated\\\": \\\"arn:aws:iam::<ACCOUNT_ID>:oidc-provider/token.actions.githubusercontent.com\\\"\\n   138→    },\\n   139→    \\\"Action\\\": \\\"sts:AssumeRoleWithWebIdentity\\\",\\n   140→    \\\"Condition\\\": {\\n   141→      \\\"StringEquals\\\": {\\n   142→        \\\"token.actions.githubusercontent.com:aud\\\": \\\"sts.amazonaws.com\\\"\\n   143→      },\\n   144→      \\\"StringLike\\\": {\\n   145→        \\\"token.actions.githubusercontent.com:sub\\\": \\\"repo:<ORG>/*:*\\\"\\n   146→      }\\n   147→    }\\n   148→  }]\\n   149→}\\n   150→```\\n   151→\\n   152→3. Attach Kiro/Q Developer policy:\\n   153→```json\\n   154→{\\n   155→  \\\"Version\\\": \\\"2012-10-17\\\",\\n   156→  \\\"Statement\\\": [{\\n   157→    \\\"Effect\\\": \\\"Allow\\\",\\n   158→    \\\"Action\\\": [\\n   159→      \\\"q:StartConversation\\\",\\n   160→      \\\"q:SendMessage\\\",\\n   161→      \\\"q:GetConversation\\\"\\n   162→    ],\\n   163→    \\\"Resource\\\": \\\"*\\\"\\n   164→  }]\\n   165→}\\n   166→```\\n   167→\\n   168→4. In your workflow:\\n   169→```yaml\\n   170→permissions:\\n   171→  id-token: write  # Required for OIDC\\n   172→\\n   173→- uses: aws-actions/configure-aws-credentials@v5\\n   174→  with:\\n   175→    role-to-assume: ${{ secrets.AWS_ROLE_ARN }}\\n   176→    aws-region: us-east-1\\n   177→\\n   178→- uses: clouatre-labs/setup-kiro-action@v1\\n   179→  with:\\n   180→    enable-sigv4: true  # Required with OIDC\\n   181→```\\n   182→\\n   183→### Method 2: IAM User Credentials (Local Development)\\n   184→\\n   185→```yaml\\n   186→- uses: clouatre-labs/setup-kiro-action@v1\\n   187→  # Do NOT set enable-sigv4 with long-lived credentials\\n   188→\\n   189→- name: Use Kiro CLI\\n   190→  env:\\n   191→    AWS_ACCESS_KEY_ID: ${{ secrets.AWS_ACCESS_KEY_ID }}\\n   192→    AWS_SECRET_ACCESS_KEY: ${{ secrets.AWS_SECRET_ACCESS_KEY }}\\n   193→    AWS_REGION: us-east-1\\n   194→  run: kiro-cli-chat chat --no-interactive \\\"What is 2+2?\\\"\\n   195→```\\n   196→\\n   197→**Important:** Do not use `enable-sigv4: true` with long-lived IAM credentials (AKIA* keys).\\n   198→\\n   199→## Version Management\\n   200→\\n   201→This action defaults to a tested version that is automatically updated weekly.\\n   202→To pin a specific version:\\n   203→\\n   204→```yaml\\n   205→- uses: clouatre-labs/setup-kiro-action@v1\\n   206→  with:\\n   207→    version: '1.20.2'\\n   208→    verify-checksum: true\\n   209→```\\n   210→\\n   211→## How It Works\\n   212→\\n   213→On first run, the action downloads the Kiro CLI binary from AWS CDN and caches it at `~/.local/bin/`. Subsequent runs restore from cache. When `enable-sigv4` is set, the action exports `AMAZON_Q_SIGV4=true` for headless IAM authentication.\\n   214→\\n   215→## Troubleshooting\\n   216→\\n   217→### Binary not found after installation\\n   218→\\n   219→Ensure you're using the action before attempting to run `kiro-cli-chat`:\\n   220→\\n   221→```yaml\\n   222→- uses: clouatre-labs/setup-kiro-action@v1\\n   223→- run: kiro-cli-chat --version  # This will work\\n   224→```\\n   225→\\n   226→### SIGV4 authentication not working\\n   227→\\n   228→Verify:\\n   229→1. `enable-sigv4: true` is set in action inputs\\n   230→2. AWS credentials are available as environment variables\\n   231→3. IAM permissions include Amazon Q/Kiro access\\n   232→4. Correct AWS region is configured\\n   233→\\n   234→### Unsupported platform error\\n   235→\\n   236→Kiro CLI binaries are only available for Linux via this action. Use `ubuntu-latest`, `ubuntu-24.04`, or `ubuntu-22.04` runners:\\n   237→\\n   238→```yaml\\n   239→jobs:\\n   240→  build:\\n   241→    runs-on: ubuntu-latest  # Recommended\\n   242→```\\n   243→\\n   244→For macOS, use the official install script directly in your workflow:\\n   245→```yaml\\n   246→- run: curl -fsSL https://cli.kiro.dev/install | bash\\n   247→```\\n   248→\\n   249→### Cache not working\\n   250→\\n   251→The cache key includes OS and architecture. If you change runners or platforms, a new cache entry will be created. This is expected behavior.\\n   252→\\n   253→## Development\\n   254→\\n   255→This is a composite action (YAML-based) with no compilation required. See [`.github/workflows/test.yml`](.github/workflows/test.yml) for the test workflow. OIDC provider setup is required for SIGV4 tests (see Authentication Methods above).\\n   256→\\n   257→## Migration from Q CLI\\n   258→\\n   259→If you're migrating from `setup-q-cli-action`:\\n   260→\\n   261→| Q CLI | Kiro CLI |\\n   262→|-------|----------|\\n   263→| `clouatre-labs/setup-q-cli-action@v1` | `clouatre-labs/setup-kiro-action@v1` |\\n   264→| `qchat chat --no-interactive \\\"prompt\\\"` | `kiro-cli-chat chat --no-interactive \\\"prompt\\\"` |\\n   265→| `${{ steps.q.outputs.q-version }}` | `${{ steps.kiro.outputs.kiro-version }}` |\\n   266→| `${{ steps.q.outputs.q-path }}` | `${{ steps.kiro.outputs.kiro-path }}` |\\n   267→\\n   268→## Contributing\\n   269→\\n   270→Contributions are welcome! Please open an issue or PR.\\n   271→\\n   272→## License\\n   273→\\n   274→MIT - See [LICENSE](LICENSE)\\n   275→\\n   276→## Related\\n   277→\\n   278→- [AI-Augmented CI/CD](https://clouatre.ca/posts/ai-augmented-cicd/) - Blog post on the 3-tier security model for AI code review in CI/CD pipelines\\n   279→- [Kiro CLI Documentation](https://kiro.dev/docs/cli/) - Official Kiro CLI documentation\\n   280→- [Amazon Q Developer CLI](https://github.com/aws/amazon-q-developer-cli) - Upstream repository (Apache 2.0)\\n   281→- [Setup Q CLI Action](https://github.com/clouatre-labs/setup-q-cli-action) - Previous action for Q CLI (deprecated)\\n   282→- [Setup Goose Action](https://github.com/clouatre-labs/setup-goose-action) - Similar action for Goose AI agent\\n   283→\\n   284→## Acknowledgments\\n   285→\\n   286→Built by [clouatre-labs](https://github.com/clouatre-labs) for the developer community.\\n   287→\\n   288→**Trademark Notice:** \\\"Kiro\\\" and \\\"Amazon Web Services\\\" are trademarks of Amazon.com, Inc. or its affiliates. This project is not affiliated with, endorsed by, or sponsored by Amazon Web Services.\\n   289→\\n   290→**SIGV4 Discovery:** The `AMAZON_Q_SIGV4` authentication mechanism was discovered through source code analysis of the [amazon-q-developer-cli](https://github.com/aws/amazon-q-developer-cli) repository. It is an undocumented feature that enables headless IAM authentication for CI/CD environments.\\n   291→\"}]},\"uuid\":\"dd995253-d934-4893-8ccf-1ac00fd0c0ba\",\"timestamp\":\"2026-03-05T18:57:26.818Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"adf0421f7910ffeda\"},\"toolUseID\":\"agent_msg_01Tp6cLdVhpG8c9zLByn7E21\",\"parentToolUseID\":\"toolu_01LEsxwfZ9MWJrbKeVbRzCa7\",\"uuid\":\"14038a3a-afe3-4388-a50e-1260402b45b6\",\"timestamp\":\"2026-03-05T18:57:26.819Z\"}\n{\"parentUuid\":\"14038a3a-afe3-4388-a50e-1260402b45b6\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-