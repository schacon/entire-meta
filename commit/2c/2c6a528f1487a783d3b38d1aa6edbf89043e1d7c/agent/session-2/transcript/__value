riteFile(cachePath, []byte(sid), 0o600); err != nil {\\n   223→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to write session ID cache\\\", \\\"err\\\", err)\\n   224→\\t}\\n   225→\\treturn sid\\n   226→}\\n   227→\\n   228→// clearCachedSessionID removes the session ID cache file so that a subsequent\\n   229→// session does not accidentally reuse a stale ID from a previous session.\\n   230→func (k *KiroAgent) clearCachedSessionID(ctx context.Context) {\\n   231→\\tcachePath := k.sessionIDCachePath(ctx)\\n   232→\\tif err := os.Remove(cachePath); err != nil && !os.IsNotExist(err) {\\n   233→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to clear session ID cache\\\", \\\"err\\\", err)\\n   234→\\t}\\n   235→}\\n   236→\\n   237→// readCachedSessionID reads the stable session ID from .entire/tmp/kiro-active-session.\\n   238→// Returns empty string if the cache file doesn't exist.\\n   239→func (k *KiroAgent) readCachedSessionID(ctx context.Context) string {\\n   240→\\tcachePath := k.sessionIDCachePath(ctx)\\n   241→\\tdata, err := os.ReadFile(cachePath) //nolint:gosec // cachePath is constructed from WorktreeRoot + constant suffix\\n   242→\\tif err != nil {\\n   243→\\t\\treturn \\\"\\\"\\n   244→\\t}\\n   245→\\treturn strings.TrimSpace(string(data))\\n   246→}\\n   247→\\n   248→// sessionIDCachePath returns the path to the session ID cache file.\\n   249→func (k *KiroAgent) sessionIDCachePath(ctx context.Context) string {\\n   250→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   251→\\tif err != nil {\\n   252→\\t\\trepoRoot = \\\".\\\"\\n   253→\\t}\\n   254→\\treturn filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\", sessionIDFile)\\n   255→}\\n   256→\\n   257→// generateSessionID creates a random 32-character hex string for use as a session ID.\\n   258→func generateSessionID() string {\\n   259→\\tb := make([]byte, 16)\\n   260→\\tif _, err := rand.Read(b); err != nil {\\n   261→\\t\\t// crypto/rand.Read never fails on supported platforms, but use timestamp fal