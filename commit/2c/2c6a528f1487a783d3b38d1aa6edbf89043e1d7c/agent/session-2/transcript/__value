ntFile represents the .kiro/agents/entire.json structure.\\n    17→// This is a Kiro agent definition file — hooks are nested under the \\\"hooks\\\" field.\\n    18→// Entire owns this file entirely — no round-trip preservation needed.\\n    19→type kiroAgentFile struct {\\n    20→\\tName  string    `json:\\\"name\\\"`\\n    21→\\tTools []string  `json:\\\"tools\\\"`\\n    22→\\tHooks kiroHooks `json:\\\"hooks\\\"`\\n    23→}\\n    24→\\n    25→// kiroHooks contains all hook configurations using camelCase keys.\\n    26→type kiroHooks struct {\\n    27→\\tAgentSpawn       []kiroHookEntry `json:\\\"agentSpawn,omitempty\\\"`\\n    28→\\tUserPromptSubmit []kiroHookEntry `json:\\\"userPromptSubmit,omitempty\\\"`\\n    29→\\tPreToolUse       []kiroHookEntry `json:\\\"preToolUse,omitempty\\\"`\\n    30→\\tPostToolUse      []kiroHookEntry `json:\\\"postToolUse,omitempty\\\"`\\n    31→\\tStop             []kiroHookEntry `json:\\\"stop,omitempty\\\"`\\n    32→}\\n    33→\\n    34→// kiroHookEntry represents a single hook command in the config file.\\n    35→type kiroHookEntry struct {\\n    36→\\tCommand string `json:\\\"command\\\"`\\n    37→}\\n    38→\\n    39→// kiroIDEHookFile represents a .kiro/hooks/*.kiro.hook file for the Kiro IDE.\\n    40→// Unlike CLI agent hooks (nested in entire.json), IDE hooks are standalone files\\n    41→// with a when/then structure. The IDE delivers data via environment variables\\n    42→// (e.g., USER_PROMPT) rather than JSON on stdin.\\n    43→type kiroIDEHookFile struct {\\n    44→\\tEnabled     bool            `json:\\\"enabled\\\"`\\n    45→\\tName        string          `json:\\\"name\\\"`\\n    46→\\tDescription string          `json:\\\"description\\\"`\\n    47→\\tVersion     string          `json:\\\"version\\\"`\\n    48→\\tWhen        kiroIDEHookWhen `json:\\\"when\\\"`\\n    49→\\tThen        kiroIDEHookThen `json:\\\"then\\\"`\\n    50→}\\n    51→\\n    52→// kiroIDEHookWhen defines the trigger condition for an IDE hook.\\n    53→type kiroIDEHookWhen struct {\\n    54→\\tType string `json:\\\"type\\\"`\\n    55→}\\n    56→\\n    57→// kiroIDEHookThen defines the action for an IDE hook.\\n    58→type kiroIDEHookThen struct {\\n    59→\\tType    string `json:\\\"type\\\"`\\n    60→\\tCommand string `json:\\\"command\\\"`\\n    61→}\\n    62→\\n    63→// --- Transcript types ---\\n    64→// These types model the Kiro SQLite-cached conversation JSON.\\n    65→// The format uses paired user+assistant history entries with tagged unions\\n    66→// for content variants (Prompt vs ToolUseResults, Response vs ToolUse).\\n    67→\\n    68→// kiroTranscript is the top-level transcript structure cached from SQLite.\\n    69→type kiroTranscript struct {\\n    70→\\tConversationID string             `json:\\\"conversation_id\\\"`\\n    71→\\tHistory        []kiroHistoryEntry `json:\\\"history\\\"`\\n    72→}\\n    73→\\n    74→// kiroHistoryEntry is a single user+assistant exchange in the conversation.\\n    75→type kiroHistoryEntry struct {\\n    76→\\tUser      kiroUserMessage `json:\\\"user\\\"`\\n    77→\\tAssistant json.RawMessage `json:\\\"assistant\\\"`\\n    78→}\\n    79→\\n    80→// kiroUserMessage wraps the user's contribution in a history entry.\\n    81→type kiroUserMessage struct {\\n    82→\\tContent   json.RawMessage `json:\\\"content\\\"`\\n    83→\\tTimestamp string          `json:\\\"timestamp,omitempty\\\"`\\n    84→}\\n    85→\\n    86→// kiroPromptContent represents the {\\\"Prompt\\\": {\\\"prompt\\\": \\\"...\\\"}} user content variant.\\n    87→type kiroPromptContent struct {\\n    88→\\tPrompt struct {\\n    89→\\t\\tPrompt string `json:\\\"prompt\\\"`\\n    90→\\t} `json:\\\"Prompt\\\"`\\n    91→}\\n    92→\\n    93→// kiroToolUseContent represents the {\\\"ToolUse\\\": {...}} assistant content variant.\\n    94→type kiroToolUseContent struct {\\n    95→\\tToolUse kiroToolUsePayload `json:\\\"ToolUse\\\"`\\n    96→}\\n    97→\\n    98→// kiroToolUsePayload carries tool call details within a ToolUse assistant message.\\n    99→type kiroToolUsePayload struct {\\n   100→\\tMessageID string         `json:\\\"message_id\\\"`\\n   101→\\tToolUses  []kiroToolCall `json:\\\"tool_uses\\\"`\\n   102→}\\n   103→\\n   104→// kiroResponseContent represents the {\\\"Response\\\": {...}} assistant content variant.\\n   105→type kiroResponseContent struct {\\n   106→\\tResponse kiroResponsePayload `json:\\\"Response\\\"`\\n   107→}\\n   108→\\n   109→// kiroResponsePayload carries text content within a Response assistant message.\\n   110→type kiroResponsePayload struct {\\n   111→\\tMessageID string `json:\\\"message_id\\\"`\\n   112→\\tContent   string `json:\\\"content\\\"`\\n   113→}\\n   114→\\n   115→// kiroToolCall represents a single tool invocation within a ToolUse message.\\n   116→type kiroToolCall struct {\\n   117→\\tID   string          `json:\\\"id\\\"`\\n   118→\\tName string          `json:\\\"name\\\"`\\n   119→\\tArgs json.RawMessage `json:\\\"args\\\"`\\n   120→}\\n   121→\\n   122→// --- Kiro IDE transcript types ---\\n   123→// The Kiro IDE stores conversations as JSON files with sequential {role, content}\\n   124→// messages (Anthropic API format), unlike the CLI's paired user+assistant entries.\\n   125→\\n   126→// kiroIDETranscript is the top-level structure of a Kiro IDE session JSON file.\\n   127→type kiroIDETranscript struct {\\n   128→\\tHistory []kiroIDEHistoryEntry `json:\\\"history\\\"`\\n   129→}\\n   130→\\n   131→// kiroIDEHistoryEntry is a single message in an IDE conversation.\\n   132→type kiroIDEHistoryEntry struct {\\n   133→\\tMessage kiroIDEMessage `json:\\\"message\\\"`\\n   134→}\\n   135→\\n   136→// kiroIDEMessage holds the role and content of an IDE message.\\n   137→// Content is json.RawMessage because it can be either a plain string (assistant)\\n   138→// or an array of content blocks (user).\\n   139→type kiroIDEMessage struct {\\n   140→\\tRole    string          `json:\\\"role\\\"`\\n   141→\\tContent json.RawMessage `json:\\\"content\\\"`\\n   142→}\\n   143→\\n   144→// kiroIDEContentBlock represents a content block in IDE user messages\\n   145→// (e.g., [{\\\"type\\\": \\\"text\\\", \\\"text\\\": \\\"...\\\"}]).\\n   146→type kiroIDEContentBlock struct {\\n   147→\\tType string `json:\\\"type\\\"`\\n   148→\\tText string `json:\\\"text\\\"`\\n   149→}\\n   150→\\n   151→// --- Kiro IDE session index types ---\\n   152→// The IDE stores a sessions.json index alongside session files.\\n   153→\\n   154→// kiroIDESessionEntry represents one session in the IDE's sessions.json index.\\n   155→type kiroIDESessionEntry struct {\\n   156→\\tSessionID          string `json:\\\"sessionId\\\"`\\n   157→\\tTitle              string `json:\\\"title\\\"`\\n   158→\\tDateCreated        string `json:\\\"dateCreated\\\"`\\n   159→\\tWorkspaceDirectory string `json:\\\"workspaceDirectory\\\"`\\n   160→}\\n   161→\"}]},\"uuid\":\"a5920629-9454-4dcf-9e25-d220ffdfa34e\",\"timestamp\":\"2026-03-05T18:34:52.506Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"ae4a0d0f3dd182426\"},\"toolUseID\":\"agent_msg_0165DCpkzNjP4y6EoucRSeWV\",\"parentToolUseID\":\"toolu_011r1FaYdMgQ3waybF4yi9Zo\",\"uuid\":\"1352405c-5c18-49e8-b287-f8ae3ff1f681\",\"timestamp\":\"2026-03-05T18:34:52.506Z\"}\n{\"parentUuid\":\"1352405c-5c18-49e8-b287-f8ae3ff1f681\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"a6375286-82fb-48a9-90fd-f8e611e47d1b\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"snappy-yawning-swan\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-05T18:34:52.631Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01B2pH7kWBXBGEfAUe6vVyja\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_018W1VCS7gMvotg2d4HtzMY9\",\"name\":\"Grep\",\"input\":{\"patt