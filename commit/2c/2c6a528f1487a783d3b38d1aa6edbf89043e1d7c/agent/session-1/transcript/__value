   { return \\\"Kiro - Amazon AI coding CLI\\\" }\\n    44→func (k *KiroAgent) IsPreview() bool         { return true }\\n    45→func (k *KiroAgent) ProtectedDirs() []string { return []string{\\\".kiro\\\"} }\\n    46→\\n    47→// UsesTerminal reports that Kiro runs inside a terminal emulator (tmux).\\n    48→// This means hasTTY() returns true even when the agent is committing.\\n    49→func (k *KiroAgent) UsesTerminal() bool { return true }\\n    50→\\n    51→// DetectPresence checks if Kiro is configured in the repository.\\n    52→func (k *KiroAgent) DetectPresence(ctx context.Context) (bool, error) {\\n    53→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    54→\\tif err != nil {\\n    55→\\t\\tworktreeRoot = \\\".\\\"\\n    56→\\t}\\n    57→\\tif _, err := os.Stat(filepath.Join(worktreeRoot, \\\".kiro\\\")); err == nil {\\n    58→\\t\\treturn true, nil\\n    59→\\t}\\n    60→\\treturn false, nil\\n    61→}\\n    62→\\n    63→// --- Transcript Storage ---\\n    64→\\n    65→// ReadTranscript reads the cached transcript JSON for a session.\\n    66→func (k *KiroAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    67→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    68→\\tif err != nil {\\n    69→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    70→\\t}\\n    71→\\treturn data, nil\\n    72→}\\n    73→\\n    74→// ChunkTranscript splits a JSON transcript into chunks.\\n    75→// Kiro transcripts are single JSON objects; we use the JSONL chunker since the\\n    76→// cached format is a JSON blob that fits in a single chunk in most cases.\\n    77→func (k *KiroAgent) ChunkTranscript(_ context.Context, content []byte, maxSize int) ([][]byte, error) {\\n    78→\\tif len(content) <= maxSize {\\n    79→\\t\\treturn [][]byte{content}, nil\\n    80→\\t}\\n    81→\\t// For large transcripts, split at line boundaries\\n    82→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    83→\\tif err != nil {\\n    84→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n    85→\\t}\\n    86→\\treturn chunks, nil\\n    87→}\\n    88→\\n    89→// ReassembleTranscript combines transcript chunks back into a single blob.\\n    90→func (k *KiroAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    91→\\tif len(chunks) == 1 {\\n    92→\\t\\treturn chunks[0], nil\\n    93→\\t}\\n    94→\\treturn agent.ReassembleJSONL(chunks), nil\\n    95→}\\n    96→\\n    97→// --- Session Management ---\\n    98→\\n    99→// GetSessionID extracts the session ID from hook input.\\n   100→func (k *KiroAgent) GetSessionID(input *agent.HookInput) string {\\n   101→\\treturn input.SessionID\\n   102→}\\n   103→\\n   104→// GetSessionDir returns the directory where Kiro stores session data.\\n   105→// For Kiro, sessions are in SQLite, but we cache transcripts to .entire/tmp/.\\n   106→func (k *KiroAgent) GetSessionDir(repoPath string) (string, error) {\\n   107→\\treturn filepath.Join(repoPath, \\\".entire\\\", \\\"tmp\\\"), nil\\n   108→}\\n   109→\\n   110→// ResolveSessionFile returns the path to the cached transcript file.\\n   111→func (k *KiroAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   112→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".json\\\")\\n   113→}\\n   114→\\n   115→// ReadSession reads session data from the cached transcript.\\n   116→func (k *KiroAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   117→\\tif input.SessionRef == \\\"\\\" {\\n   118→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   119→\\t}\\n   120→\\n   121→\\tdata, err := os.ReadFile(input.SessionRef)\\n   122→\\tif err != nil {\\n   123→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   124→\\t}\\n   125→\\n   126→\\treturn &agent.AgentSession{\\n   127→\\t\\tSessionID:  input.SessionID,\\n   128→\\t\\tAgentName:  k.Name(),\\n   129→\\t\\tSessionRef: input.SessionRef,\\n   130→\\t\\tStartTime:  time.Now(),\\n   131→\\t\\tNativeData: data,\\n   132→\\t}, nil\\n   133→}\\n   134→\\n   135→// WriteSession writes session data for resumption.\\n   136→func (k *KiroAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   137→\\tif session == nil {\\n   138→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   139→\\t}\\n   140→\\tif session.AgentName != \\\"\\\" && session.AgentName != k.Name() {\\n   141→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, k.Name())\\n   142→\\t}\\n   143→\\tif session.SessionRef == \\\"\\\" {\\n   144→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   145→\\t}\\n   146→\\tif len(session.NativeData) == 0 {\\n   147→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   148→\\t}\\n   149→\\n   150→\\tif err := os.MkdirAll(filepath.Dir(session.SessionRef), 0o750); err != nil {\\n   151→\\t\\treturn fmt.Errorf(\\\"failed to create session dir: %w\\\", err)\\n   152→\\t}\\n   153→\\n   154→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   155→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   156→\\t}\\n   157→\\treturn nil\\n   158→}\\n   159→\\n   160→// FormatResumeCommand returns the command to resume a Kiro session.\\n   161→func (k *KiroAgent) FormatResumeCommand(_ string) string {\\n   162→\\treturn \\\"kiro-cli chat --resume\\\"\\n   163→}\\n   164→\\n   165→// GetHookConfigPath returns the path to the hook config file relative to repo root.\\n   166→func (k *KiroAgent) GetHookConfigPath() string {\\n   167→\\treturn filepath.Join(\\\".kiro\\\", hooksDir, HooksFileName)\\n   168→}\\n   169→\\n   170→// --- TranscriptAnalyzer interface implementation ---\\n   171→\\n   172→// errTranscriptEmpty is returned when the transcript file is missing or empty.\\n   173→var errTranscriptEmpty = errors.New(\\\"transcript is empty or missing\\\")\\n   174→\\n   175→// readAndParseTranscript reads and parses a Kiro transcript file.\\n   176→// Returns errTranscriptEmpty if the file doesn't exist or is empty.\\n   177→func readAndParseTranscript(path string) (*kiroTranscript, error) {\\n   178→\\tdata, err := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   179→\\tif err != nil {\\n   180→\\t\\tif os.IsNotExist(err) {\\n   181→\\t\\t\\treturn nil, errTranscriptEmpty\\n   182→\\t\\t}\\n   183→\\t\\treturn nil, fmt.Errorf(\\\"reading transcript: %w\\\", err)\\n   184→\\t}\\n   185→\\tif len(data) == 0 {\\n   186→\\t\\treturn nil, errTranscriptEmpty\\n   187→\\t}\\n   188→\\tt, err := parseTranscript(data)\\n   189→\\tif err != nil {\\n   190→\\t\\treturn nil, fmt.Errorf(\\\"parsing transcript: %w\\\", err)\\n   191→\\t}\\n   192→\\treturn t, nil\\n   193→}\\n   194→\\n   195→// GetTranscriptPosition returns the number of history entries in a Kiro transcript.\\n   196→// Kiro uses JSON format with paired user+assistant history entries, so position\\n   197→// is the entry count. Returns 0 if the file doesn't exist, is empty, or is a\\n   198→// placeholder \\\"{}\\\".\\n   199→func (k *KiroAgent) GetTranscriptPosition(path string) (int, error) {\\n   200→\\tif path == \\\"\\\" {\\n   201→\\t\\treturn 0, nil\\n   202→\\t}\\n   203→\\tt, err := readAndParseTranscript(path)\\n   204→\\tif errors.Is(err, errTranscriptEmpty) {\\n   205→\\t\\treturn 0, nil\\n   206→\\t}\\n   207→\\tif err != nil {\\n   208→\\t\\treturn 0, err\\n   209→\\t}\\n   210→\\treturn len(t.History), nil\\n   211→}\\n   212→\\n   213→// ExtractModifiedFilesFromOffset extracts files modified since a given history index.\\n   214→// For Kiro (JSON format), offset is the starting history entry index.\\n   215→func (k *KiroAgent) ExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error) {\\n   216→\\tif path == \\\"\\\" {\\n   217→\\t\\treturn nil, 0, nil\\n   218→\\t}\\n   219→\\tt, parseErr := readAndParseTranscript(path)\\n   220→\\tif errors.Is(parseErr, errTranscriptEmpty) {\\n   221→\\t\\treturn nil, 0, nil\\n   222→\\t}\\n   223→\\tif parseErr != nil {\\n   224→\\t\\treturn nil, 0, parseErr\\n   225→\\t}\\n   226→\\n   227→\\ttotalEntries := len(t.History)\\n   228→\\tif startOffset >= totalEntries {\\n   229→\\t\\treturn nil, totalEntries, nil\\n   230→\\t}\\n   231→\\n   232→\\tmodifiedFiles := extractModifiedFilesFromHistory(t.History[startOffset:])\\n   233→\\treturn modifiedFiles, totalEntries, nil\\n   234→}\\n   235→\\n   236→// ExtractPrompts extracts user prompts from the transcript starting at the given offset.\\n   237→// Only Prompt-type user messages are returned; ToolUseResults entries are skipped.\\n   238→func (k *KiroAgent) ExtractPrompts(sessionRef string, fromOffset int) ([]string, error) {\\n   239→\\tt, err := readAndParseTranscript(sessionRef)\\n   240→\\tif err != nil {\\n   241→\\t\\treturn nil, err\\n   242→\\t}\\n   243→\\n   244→\\tvar prompts []string\\n   245→\\tfor i := fromOffset; i < len(t.History); i++ {\\n   246→\\t\\tif prompt := extractUserPrompt(t.History[i].User.Content); prompt != \\\"\\\" {\\n   247→\\t\\t\\tprompts = append(prompts, prompt)\\n   248→\\t\\t}\\n   249→\\t}\\n   250→\\treturn prompts, nil\\n   251→}\\n   252→\\n   253→// ExtractSummary extracts the last assistant response as a session summary.\\n   254→func (k *KiroAgent) ExtractSummary(sessionRef string) (string, error) {\\n   255→\\tt, err := readAndParseTranscript(sessionRef)\\n   256→\\tif err != nil {\\n   257→\\t\\treturn \\\"\\\", err\\n   258→\\t}\\n   259→\\treturn extractLastAssistantResponse(t.History), nil\\n   260→}\\n   261→\\n   262→// --- SQLite helpers ---\\n   263→\\n   264→// escapeSQLString escapes single quotes for use in SQLite string literals.\\n   265→func escapeSQLString(s string) string {\\n   266→\\treturn strings.ReplaceAll(s, \\\"'\\\", \\\"''\\\")\\n   267→}\\n   268→\\n   269→// --- SQLite session resolution ---\\n   270→\\n   271→// dbPath returns the path to Kiro's SQLite database.\\n   272→func dbPath() (string, error) {\\n   273→\\thome, err := os.UserHomeDir()\\n   274→\\tif err != nil {\\n   275→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   276→\\t}\\n   277→\\tswitch runtime.GOOS {\\n   278→\\tcase \\\"darwin\\\":\\n   279→\\t\\treturn filepath.Join(home, \\\"Library\\\", \\\"Application Support\\\", \\\"kiro-cli\\\", \\\"data.sqlite3\\\"), nil\\n   280→\\tdefault: // linux\\n   281→\\t\\treturn filepath.Join(home, \\\".local\\\", \\\"share\\\", \\\"kiro-cli\\\", \\\"data.sqlite3\\\"), nil\\n   282→\\t}\\n   283→}\\n   284→\\n   285→// querySessionID queries the SQLite database for the most recent conversation ID\\n   286→// associated with the given CWD.\\n   287→func (k *KiroAgent) querySessionID(ctx context.Context, cwd string) (string, error) {\\n   288→\\tif os.Getenv(\\\"ENTIRE_TEST_KIRO_MOCK_DB\\\") == \\\"1\\\" {\\n   289→\\t\\treturn \\\"mock-session-id\\\", nil\\n   290→\\t}\\n   291→\\n   292→\\tdb, err := dbPath()\\n   293→\\tif err != nil {\\n   294→\\t\\treturn \\\"\\\", err\\n   295→\\t}\\n   296→\\tif _, err := os.Stat(db); err != nil {\\n   297→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"kiro database not found at %s: %w\\\", db, err)\\n   298→\\t}\\n   299→\\n   300→\\tquery := fmt.Sprintf(\\n   301→\\t\\t\\\"SELECT json_extract(value, '$.conversation_id') FROM conversations_v2 WHERE key = '%s' ORDER BY updated_at DESC LIMIT 1\\\",\\n   302→\\t\\tescapeSQLString(cwd),\\n   303→\\t)\\n   304→\\n   305→\\tcmd := exec.CommandContext(ctx, \\\"sqlite3\\\", \\\"-json\\\", db, query)\\n   306→\\tout, err := cmd.Output()\\n   307→\\tif err != nil {\\n   308→\\t\\tlogging.Warn(ctx, \\\"kiro: sqlite3 query failed\\\", \\\"err\\\", err, \\\"cwd\\\", cwd)\\n   309→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"sqlite3 query failed: %w\\\", err)\\n   310→\\t}\\n   311→\\n   312→\\tresult := strings.TrimSpace(string(out))\\n   313→\\tif result == \\\"\\\" || result == \\\"[]\\\" {\\n   314→\\t\\treturn \\\"\\\", nil\\n   315→\\t}\\n   316→\\n   317→\\t// sqlite3 -json returns an array of objects\\n   318→\\tvar rows []map[string]string\\n   319→\\tif err := json.Unmarshal([]byte(result), &rows); err != nil {\\n   320→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse sqlite3 output: %w\\\", err)\\n   321→\\t}\\n   322→\\tif len(rows) == 0 {\\n   323→\\t\\treturn \\\"\\\", nil\\n   324→\\t}\\n   325→\\n   326→\\t// The column name from json_extract\\n   327→\\tfor _, v := range rows[0] {\\n   328→\\t\\treturn v, nil\\n   329→\\t}\\n   330→\\treturn \\\"\\\", nil\\n   331→}\\n   332→\\n   333→// ensureCachedTranscript fetches the conversation from SQLite and caches it\\n   334→// to .entire/tmp/<sessionID>.json. Returns the cache file path.\\n   335→func (k *KiroAgent) ensureCachedTranscript(ctx context.Context, cwd, sessionID string) (string, error) {\\n   336→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   337→\\tif err != nil {\\n   338→\\t\\trepoRoot = cwd\\n   339→\\t}\\n   340→\\n   341→\\tcacheDir := filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\")\\n   342→\\tcachePath := filepath.Join(cacheDir, sessionID+\\\".json\\\")\\n   343→\\n   344→\\t// Fetch fresh transcript from SQLite on every call (transcript grows during session)\\n   345→\\tif os.Getenv(\\\"ENTIRE_TEST_KIRO_MOCK_DB\\\") == \\\"1\\\" {\\n   346→\\t\\t// In test mode, return the expected cache path without hitting SQLite.\\n   347→\\t\\treturn cachePath, nil\\n   348→\\t}\\n   349→\\n   350→\\tdb, err := dbPath()\\n   351→\\tif err != nil {\\n   352→\\t\\treturn \\\"\\\", err\\n   353→\\t}\\n   354→\\n   355→\\tquery := fmt.Sprintf(\\n   356→\\t\\t\\\"SELECT value FROM conversations_v2 WHERE key = '%s' ORDER BY updated_at DESC LIMIT 1\\\",\\n   357→\\t\\tescapeSQLString(cwd),\\n   358→\\t)\\n   359→\\n   360→\\tcmd := exec.CommandContext(ctx, \\\"sql