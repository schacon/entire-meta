sParentTree bool         // True if parentTree was explicitly resolved (distinguishes nil-not-resolved from nil-initial-commit)\\n    41→}\\n    42→\\n    43→// filesOverlapWithContent checks if any file in filesTouched overlaps with the committed\\n    44→// content, using content-aware comparison to detect the \\\"reverted and replaced\\\" scenario.\\n    45→//\\n    46→// This is used in PostCommit to determine if a session has work in the commit.\\n    47→func filesOverlapWithContent(ctx context.Context, repo *git.Repository, shadowBranchName string, headCommit *object.Commit, filesTouched []string, opts ...overlapOpts) bool {\\n    48→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n    49→\\n    50→\\t// Use pre-resolved trees if provided, otherwise resolve from repo.\\n    51→\\tvar o overlapOpts\\n    52→\\tif len(opts) > 0 {\\n    53→\\t\\to = opts[0]\\n    54→\\t}\\n    55→\\n    56→\\theadTree := o.headTree\\n    57→\\tif headTree == nil {\\n    58→\\t\\tvar err error\\n    59→\\t\\theadTree, err = headCommit.Tree()\\n    60→\\t\\tif err != nil {\\n    61→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: failed to get HEAD tree, falling back to filename check\\\",\\n    62→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    63→\\t\\t\\t)\\n    64→\\t\\t\\treturn len(filesTouched) > 0\\n    65→\\t\\t}\\n    66→\\t}\\n    67→\\n    68→\\tshadowTree := o.shadowTree\\n    69→\\tif shadowTree == nil {\\n    70→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n    71→\\t\\tshadowRef, err := repo.Reference(refName, true)\\n    72→\\t\\tif err != nil {\\n    73→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: shadow branch not found, falling back to filename check\\\",\\n    74→\\t\\t\\t\\tslog.String(\\\"branch\\\", shadowBranchName),\\n    75→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    76→\\t\\t\\t)\\n    77→\\t\\t\\treturn len(filesTouched) > 0\\n    78→\\t\\t}\\n    79→\\n    80→\\t\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n    81→\\t\\tif err != nil {\\n    82→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: failed to get shadow commit, falling back to filename check\\\",\\n    83→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    84→\\t\\t\\t)\\n    85→\\t\\t\\treturn len(filesTouched) > 0\\n    86→\\t\\t}\\n    87→\\n    88→\\t\\tshadowTree, err = shadowCommit.Tree()\\n    89→\\t\\tif err != nil {\\n    90→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: failed to get shadow tree, falling back to filename check\\\",\\n    91→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    92→\\t\\t\\t)\\n    93→\\t\\t\\treturn len(filesTouched) > 0\\n    94→\\t\\t}\\n    95→\\t}\\n    96→\\n    97→\\tparentTree := o.parentTree\\n    98→\\tif parentTree == nil && !o.hasParentTree {\\n    99→\\t\\tif headCommit.NumParents() > 0 {\\n   100→\\t\\t\\tif parent, err := headCommit.Parent(0); err == nil {\\n   101→\\t\\t\\t\\tif pTree, err := parent.Tree(); err == nil {\\n   102→\\t\\t\\t\\t\\tparentTree = pTree\\n   103→\\t\\t\\t\\t}\\n   104→\\t\\t\\t}\\n   105→\\t\\t}\\n   106→\\t}\\n   107→\\n   108→\\t// Check each file in filesTouched\\n   109→\\tfor _, filePath := range filesTouched {\\n   110→\\t\\t// Get file from HEAD tree (the committed content)\\n   111→\\t\\theadFile, err := headTree.File(filePath)\\n   112→\\t\\tif err != nil {\\n   113→\\t\\t\\t// File not in HEAD commit. Check if this is a deletion (existed in parent).\\n   114→\\t\\t\\t// Deletions count as overlap because the agent's action (deleting the file)\\n   115→\\t\\t\\t// is being committed - we want the session context linked to this commit.\\n   116→\\t\\t\\tif parentTree != nil {\\n   117→\\t\\t\\t\\tif _, parentErr := parentTree.File(filePath); parentErr == nil {\\n   118→\\t\\t\\t\\t\\t// File existed in parent but not in HEAD - this is a deletion\\n   119→\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: deleted file counts as overlap\\\",\\n   120→\\t\\t\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   121→\\t\\t\\t\\t\\t)\\n   122→\\t\\t\\t\\t\\treturn true\\n   123→\\t\\t\\t\\t}\\n   124→\\t\\t\\t}\\n   125→\\t\\t\\t// File didn't exist in parent either - not a deletion, skip\\n   126→\\t\\t\\tcontinue\\n   127→\\t\\t}\\n   128→\\n   129→\\t\\t// Check if this is a modified file (exists in parent) or new file\\n   130→\\t\\tisModified := false\\n   131→\\t\\tif parentTree != nil {\\n   132→\\t\\t\\tif _, err := parentTree.File(filePath); err == nil {\\n   133→\\t\\t\\t\\tisModified = true\\n   134→\\t\\t\\t}\\n   135→\\t\\t}\\n   136→\\n   137→\\t\\t// Modified files always count as overlap (user edited session's work)\\n   138→\\t\\tif isModified {\\n   139→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: modified file counts as overlap\\\",\\n   140→\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   141→\\t\\t\\t)\\n   142→\\t\\t\\treturn true\\n   143→\\t\\t}\\n   144→\\n   145→\\t\\t// For new files, check content against shadow branch\\n   146→\\t\\tshadowFile, err := shadowTree.File(filePath)\\n   147→\\t\\tif err != nil {\\n   148→\\t\\t\\t// File not in shadow branch - this shouldn't happen but skip it\\n   149→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: file in filesTouched but not in shadow branch\\\",\\n   150→\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   151→\\t\\t\\t)\\n   152→\\t\\t\\tcontinue\\n   153→\\t\\t}\\n   154→\\n   155→\\t\\t// Compare by hash (blob hash) - exact content match required for new files\\n   156→\\t\\tif headFile.Hash == shadowFile.Hash {\\n   157→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: new file content match found\\\",\\n   158→\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   159→\\t\\t\\t\\tslog.String(\\\"hash\\\", headFile.Hash.String()),\\n   160→\\t\\t\\t)\\n   161→\\t\\t\\treturn true\\n   162→\\t\\t}\\n   163→\\n   164→\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: new file content mismatch (may be reverted & replaced)\\\",\\n   165→\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   166→\\t\\t\\tslog.String(\\\"head_hash\\\", headFile.Hash.String()),\\n   167→\\t\\t\\tslog.String(\\\"shadow_hash\\\", shadowFile.Hash.String()),\\n   168→\\t\\t)\\n   169→\\t}\\n   170→\\n   171→\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: no overlapping files found\\\",\\n   172→\\t\\tslog.Int(\\\"files_checked\\\", len(filesTouched)),\\n   173→\\t)\\n   174→\\treturn false\\n   175→}\\n   176→\\n   177→// stagedFilesOverlapWithContent checks if any staged file overlaps with filesTouched,\\n   178→// distinguishing between modified files (always overlap) and new files (check content).\\n   179→//\\n   180→// For modified files (already exist in HEAD), we count as overlap because the user\\n   181→// is editing the session's work. For new files (don't exist in HEAD), we require\\n   182→// content match to detect the \\\"reverted and replaced\\\" scenario.\\n   183→//\\n   184→// This is used in PrepareCommitMsg for carry-forward scenarios.\\n   185→func stagedFilesOverlapWithContent(ctx context.Context, repo *git.Repository, shadowTree *object.Tree, stagedFiles, filesTouched []string) bool {\\n   186→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   187→\\n   188→\\t// Build set of filesTouched for quick lookup\\n   189→\\ttouchedSet := make(map[string]bool)\\n   190→\\tfor _, f := range filesTouched {\\n   191→\\t\\ttouchedSet[f] = true\\n   192→\\t}\\n   193→\\n   194→\\t// Get HEAD tree to determine if files are being modified or newly created\\n   195→\\thead, err := repo.Head()\\n   196→\\tif err != nil {\\n   197→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get HEAD, falling back to filename check\\\",\\n   198→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   199→\\t\\t)\\n   200→\\t\\treturn hasOverlappingFiles(stagedFiles, filesTouched)\\n   201→\\t}\\n   202→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   203→\\tif err != nil {\\n   204→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get HEAD commit, falling back to filename check\\\",\\n   205→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   206→\\t\\t)\\n   207→\\t\\treturn hasOverlappingFiles(stagedFiles, filesTouched)\\n   208→\\t}\\n   209→\\theadTree, err := headCommit.Tree()\\n   210→\\tif err != nil {\\n   211→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get HEAD tree, falling back to filename check\\\",\\n   212→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   213→\\t\\t)\\n   214→\\t\\treturn hasOverlappingFiles(stagedFiles, filesTouched)\\n   215→\\t}\\n   216→\\n   217→\\t// Get the git index to access staged file hashes\\n   218→\\tidx, err := repo.Storer.Index()\\n   219→\\tif err != nil {\\n   220→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get index, falling back to filename check\\\",\\n   221→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   222→\\t\\t)\\n   223→\\t\\treturn hasOverlappingFiles(stagedFiles, filesTouched)\\n   224→\\t}\\n   225→\\n   226→\\t// Build a map of index entries for O(1) lookup (avoid O(n*m) nested loop)\\n   227→\\tindexEntries := make(map[string]plumbing.Hash, len(idx.Entries))\\n   228→\\tfor _, entry := range idx.Entries {\\n   229→\\t\\tindexEntries[entry.Name] = entry.Hash\\n   230→\\t}\\n   231→\\n   232→\\t// Check each staged file\\n   233→\\tfor _, stagedPath := range stagedFiles {\\n   234→\\t\\tif !touchedSet[stagedPath] {\\n   235→\\t\\t\\tcontinue // Not in filesTouched, skip\\n   236→\\t\\t}\\n   237→\\n   238→\\t\\t// Check if this is a modified file (exists in HEAD) or new file\\n   239→\\t\\t_, headErr := headTree.File(stagedPath)\\n   240→\\t\\tisModified := headErr == nil\\n   241→\\n   242→\\t\\t// Modified files always count as overlap (user edited session's work)\\n   243→\\t\\t// This includes deletions - if file exists in HEAD and is being deleted,\\n   244→\\t\\t// that's the agent's work being committed.\\n   245→\\t\\tif isModified {\\n   246→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: modified file counts as overlap\\\",\\n   247→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   248→\\t\\t\\t)\\n   249→\\t\\t\\treturn true\\n   250→\\t\\t}\\n   251→\\n   252→\\t\\t// For new files, check content against shadow branch\\n   253→\\t\\tstagedHash, found := indexEntries[stagedPath]\\n   254→\\t\\tif !found {\\n   255→\\t\\t\\tcontinue // Not in index (shouldn't happen but be safe)\\n   256→\\t\\t}\\n   257→\\n   258→\\t\\t// Get file from shadow branch tree\\n   259→\\t\\tshadowFile, err := shadowTree.File(stagedPath)\\n   260→\\t\\tif err != nil {\\n   261→\\t\\t\\t// File not in shadow branch - can't verify content overlap.\\n   262→\\t\\t\\t// Don't assume overlap just because it's in filesTouched.\\n   263→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: file not in shadow tree, skipping\\\",\\n   264→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   265→\\t\\t\\t)\\n   266→\\t\\t\\tcontinue\\n   267→\\t\\t}\\n   268→\\n   269→\\t\\t// Compare hashes - exact match means file is unchanged\\n   270→\\t\\tif stagedHash == shadowFile.Hash {\\n   271→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: new file content match found\\\",\\n   272→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   273→\\t\\t\\t\\tslog.String(\\\"hash\\\", stagedHash.String()),\\n   274→\\t\\t\\t)\\n   275→\\t\\t\\treturn true\\n   276→\\t\\t}\\n   277→\\n   278→\\t\\t// Hashes differ - check if there's significant content overlap.\\n   279→\\t\\t// This distinguishes partial staging (user kept some agent content) from\\n   280→\\t\\t// \\\"reverted and replaced\\\" (user wrote completely different content).\\n   281→\\t\\tshadowContent, shadowErr := shadowFile.Contents()\\n   282→\\t\\tif shadowErr != nil {\\n   283→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to read shadow content\\\",\\n   284→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   285→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   286→\\t\\t\\t)\\n   287→\\t\\t\\tcontinue\\n   288→\\t\\t}\\n   289→\\n   290→\\t\\t// Read staged content from object store\\n   291→\\t\\tstagedBlob, blobErr := repo.BlobObject(stagedHash)\\n   292→\\t\\tif blobErr != nil {\\n   293→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to read staged blob\\\",\\n   294→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   295→\\t\\t\\t\\tslog.String(\\\"error\\\", blobErr.Error()),\\n   296→\\t\\t\\t)\\n   297→\\t\\t\\tcontinue\\n   298→\\t\\t}\\n   299→\\t\\tstagedReader, readerErr := stagedBlob.Reader()\\n   300→\\t\\tif readerErr != nil {\\n   301→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get staged reader\\\",\\n   302→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   303→\\t\\t\\t\\tslog.String(\\\"error\\\", readerErr.Error()),\\n   304→\\t\\t\\t)\\n   305→\\t\\t\\tcontinue\\n   306→\\t\\t}\\n   307→\\t\\tstagedBytes, readErr := io.ReadAll(stagedReader)\\n   308→\\t\\t_ = stagedReader.Close() // Best effort close\\n   309→\\t\\tif readErr != nil {\\n   310→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to read staged content\\\",\\n   311→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   312→\\t\\t\\t\\tslog.String(\\\"error\\\", readErr.Error()),\\n   313→\\t\\t\\t)\\n   314→\\t\\t\\tcontinue\\n   315→\\t\\t}\\n   316→\\t\\tstagedContent := string(stagedBytes)\\n   317→\\n   318→\\t\\t// Check for significant content overlap\\n   319→\\t\\tif hasSignificantContentOverlap(stagedContent, shadowContent) {\\n   320→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: new file has partial overlap (partial staging)\\\",\\n   321→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   322→\\t\\t\\t)\\n   323→\\t\\t\\treturn true\\n   324→\\t\\t}\\n   325→\\n   326→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: new file has no significant overlap (reverted & replaced)\\\",\\n   327→\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   328→\\t\\t\\tslog.String(\\\"staged_hash\\\", stagedHash.String()),\\n   329→\\t\\t\\tslog.String(\\\"shadow_hash\\\", shadowFile.Hash.String()),\\n   330→\\t\\t)\\n   331→\\t}\\n   332→\\n   333→\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: no overlapping files found\\\",\\n   334→\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n   335→\\t\\tslog.Int(\\\"files_touched\\\", len(filesTouched)),\\n   336→\\t)\\n   337→\\treturn false\\n   338→}\\n   339→\\n   340→// hasOverlappingFiles checks if any file in stagedFiles appears in filesTouched.\\n   341→// This is a fallback when content-aware comparison isn't possible.\\n   342→func hasOverlappingFiles(stagedFiles, filesTouched []string) bool {\\n   343→\\ttouchedSet := make(map[string]bool)\\n   344→\\tfor _, f := range filesTouched {\\n   345→\\t\\ttouchedSet[f] = true\\n   346→\\t}\\n   347→\\n   348→\\tfor _, staged := range stagedFiles {\\n   349→\\t\\tif touchedSet[staged] {\\n   350→\\t\\t\\treturn true\\n   351→\\t\\t}\\n   352→\\t}\\n   353→\\treturn false\\n   354→}\\n   355→\\n   356→// filesWithRemainingAgentChanges returns files from filesTouched that still have\\n   357→// uncommitted agent changes. This is used for carry-forward after partial commits.\\n   358→//\\n   359→// A file has remaining agent changes if:\\n   360→//   - It wasn't committed at all (not in committedFiles), OR\\n   361→//   - It was committed but the committed content doesn't match the shadow branch\\n   362→//     AND the working tree still has changes (e.g., user did git add -p)\\n   363→//\\n   364→// When committed content differs from the shadow but the working tree is clean\\n   365→// (matches the commit), the user intentionally wrote different content — there\\n   366→// is nothing left to carry forward.\\n   367→//\\n   368→// Falls back to file-level subtraction if shadow branch is unavailable.\\n   369→func filesWithRemainingAgentChanges(\\n   370→\\tctx context.Context,\\n   371→\\trepo *git.Repository,\\n   372→\\tshadowBranchName string,\\n   373→\\theadCommit *object.Commit,\\n   374→\\tfilesTouched []string,\\n   375→\\tcommittedFiles map[string]struct{},\\n   376→\\topts ...overlapOpts,\\n   377→) []string {\\n   378→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   379→\\n   380→\\t// Use pre-resolved trees if provided, otherwise resolve from repo.\\n   381→\\tvar o overlapOpts\\n   382→\\tif len(opts) > 0 {\\n   383→\\t\\to = opts[0]\\n   384→\\t}\\n   385→\\n   386→\\tcommitTree := o.headTree\\n   387→\\tif commitTree == nil {\\n   388→\\t\\tvar err error\\n   389→\\t\\tcommitTree, err = headCommit.Tree()\\n   390→\\t\\tif err != nil {\\n   391→\\t\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: failed to get commit tree, falling back to file subtraction\\\",\\n   392→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   393→\\t\\t\\t)\\n   394→\\t\\t\\treturn subtractFilesByName(ctx, filesTouched, committedFiles)\\n   395→\\t\\t}\\n   396→\\t}\\n   397→\\n   398→\\tshadowTree := o.shadowTree\\n   399→\\tif shadowTree == nil {\\n   400→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   401→\\t\\tshadowRef, err := repo.Reference(refName, true)\\n   402→\\t\\tif err != nil {\\n   403→\\t\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: shadow branch not found, falling back to file subtraction\\\",\\n   404→\\t\\t\\t\\tslog.String(\\\"branch\\\", shadowBranchName),\\n   405→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   406→\\t\\t\\t)\\n   407→\\t\\t\\treturn subtractFilesByName(ctx, filesTouched, committedFiles)\\n   408→\\t\\t}\\n   409→\\n   410→\\t\\tshadowCommit, err := repo.CommitObject(shadowRef