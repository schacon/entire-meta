.go\\\")\\n    73→\\t\\ts.Git(t, \\\"commit\\\", \\\"-m\\\", \\\"Update main.go\\\")\\n    74→\\n    75→\\t\\ttestutil.WaitForCheckpoint(t, s, 15*time.Second)\\n    76→\\t\\tcpID1 := testutil.AssertHasCheckpointTrailer(t, s.Dir, \\\"HEAD\\\")\\n    77→\\t\\tcpBranch1 := testutil.GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n    78→\\n    79→\\t\\t// Commit new files.\\n    80→\\t\\ts.Git(t, \\\"add\\\", \\\"src/utils.go\\\", \\\"src/types.go\\\")\\n    81→\\t\\ts.Git(t, \\\"commit\\\", \\\"-m\\\", \\\"Add utils.go and types.go\\\")\\n    82→\\n    83→\\t\\ttestutil.WaitForCheckpointAdvanceFrom(t, s.Dir, cpBranch1, 15*time.Second)\\n    84→\\t\\tcpID2 := testutil.AssertHasCheckpointTrailer(t, s.Dir, \\\"HEAD\\\")\\n    85→\\n    86→\\t\\tassert.NotEqual(t, cpID1, cpID2, \\\"checkpoint IDs should be distinct\\\")\\n    87→\\t\\ttestutil.AssertCheckpointExists(t, s.Dir, cpID1)\\n    88→\\t\\ttestutil.AssertCheckpointExists(t, s.Dir, cpID2)\\n    89→\\t\\ttestutil.AssertNoShadowBranches(t, s.Dir)\\n    90→\\t})\\n    91→}\\n    92→\\n    93→// TestInteractiveContentOverlapRevertNewFile: agent creates a file, user replaces its\\n    94→// content entirely with different text and commits while the session is still\\n    95→// idle (not ended). The content-aware overlap detection should prevent a\\n    96→// checkpoint trailer (content mismatch on new file). The shadow branch\\n    97→// correctly persists because the session is still active and no condensation\\n    98→// occurred.\\n    99→func TestInteractiveContentOverlapRevertNewFile(t *testing.T) {\\n   100→\\ttestutil.ForEachAgent(t, 2*time.Minute, func(t *testing.T, s *testutil.RepoState, ctx context.Context) {\\n   101→\\t\\tprompt := s.Agent.PromptPattern()\\n   102→\\n   103→\\t\\tsession := s.StartSession(t, ctx)\\n   104→\\t\\tif session == nil {\\n   105→\\t\\t\\tt.Skipf(\\\"agent %s does not support interactive mode\\\", s.Agent.Name())\\n   106→\\t\\t}\\n   107→\\n   108→\\t\\ts.WaitFor(t, session, prompt, 30*time.Second)\\n   109→\\n   110→\\t\\ts.Send(t, session, \\\"create a markdown file at docs/red.md with a paragraph about the colour red. Do not ask for confirmation, just make the change.\\\")\\n   111→\\t\\ts.WaitFor(t, session, prompt, 60*time.Second)\\n   112→\\t\\ttestutil.WaitForFileExists(t, s.Dir, \\\"docs/red.md\\\", 30*time.Second)\\n   113→\\n   114→\\t\\t// Session is now idle (turn ended, waiting for next prompt).\\n   115→\\t\\t// User replaces the content entirely.\\n   116→\\t\\tif err := os.WriteFile(filepath.Join(s.Dir, \\\"docs\\\", \\\"red.md\\\"), []byte(\\\"# Completely different content\\\\n\\\\nNothing about red here.\\\\n\\\"), 0o644); err != nil {\\n   117→\\t\\t\\tt.Fatalf(\\\"overwrite file: %v\\\", err)\\n   118→\\t\\t}\\n   119→\\n   120→\\t\\ts.Git(t, \\\"add\\\", \\\"docs/red.md\\\")\\n   121→\\t\\ts.Git(t, \\\"commit\\\", \\\"-m\\\", \\\"Replace red.md content\\\")\\n   122→\\n   123→\\t\\t// Give post-commit hook time to fire.\\n   124→\\t\\ttime.Sleep(5 * time.Second)\\n   125→\\n   126→\\t\\ttestutil.AssertNoCheckpointTrailer(t, s.Dir, \\\"HEAD\\\")\\n   127→\\t\\ttestutil.AssertCheckpointNotAdvanced(t, s)\\n   128→\\t\\t// Shadow branch correctly persists: session is idle and no\\n   129→\\t\\t// condensation occurred (content mismatch on new file).\\n   130→\\t\\ttestutil.AssertHasShadowBranches(t, s.Dir)\\n   131→\\t})\\n   132→}\\n   133→\\n   134→// TestModifiedFileAlwaysGetsCheckpoint: agent modifies an existing tracked\\n   135→// file, user writes completely different content and commits. A checkpoint\\n   136→// should STILL be created because content-aware overlap detection only\\n   137→// applies to new files, not modifications to existing tracked files.\\n   138→func TestModifiedFileAlwaysGetsCheckpoint(t *testing.T) {\\n   139→\\ttestutil.ForEachAgent(t, 2*time.Minute, func(t *testing.T, s *testutil.RepoState, ctx context.Context) {\\n   140→\\t\\t// Create a tracked file.\\n   141→\\t\\t