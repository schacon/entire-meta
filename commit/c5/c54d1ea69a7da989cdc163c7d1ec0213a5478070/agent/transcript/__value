\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   230→//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   231→//\\n   232→\\n   233→func (s *ManualCommitStrategy) PrepareCommitMsg(ctx context.Context, commitMsgFile string, source string) error {\\n   234→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   235→\\n   236→\\t// Skip during rebase, cherry-pick, or revert operations\\n   237→\\t// These are replaying existing commits and should not be linked to agent sessions\\n   238→\\tif isGitSequenceOperation(ctx) {\\n   239→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n   240→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   241→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   242→\\t\\t)\\n   243→\\t\\treturn nil\\n   244→\\t}\\n   245→\\n   246→\\t// Skip for merge and squash sources\\n   247→\\t// These are auto-generated messages - not from Claude sessions\\n   248→\\tswitch source {\\n   249→\\tcase \\\"merge\\\", \\\"squash\\\":\\n   250→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n   251→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   252→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   253→\\t\\t)\\n   254→\\t\\treturn nil\\n   255→\\t}\\n   256→\\n   257→\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   258→\\tif source == \\\"commit\\\" {\\n   259→\\t\\treturn s.handleAmendCommitMsg(ctx, commitMsgFile)\\n   260→\\t}\\n   261→\\n   262→\\trepo, err := OpenRepository(ctx)\\n   263→\\tif err != nil {\\n   264→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   265→\\t}\\n   266→\\n   267→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   268→\\tif err != nil {\\n   269→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   270→\\t}\\n   271→\\n   272→\\t// Find 