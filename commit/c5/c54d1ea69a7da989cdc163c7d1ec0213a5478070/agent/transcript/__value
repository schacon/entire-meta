n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    18→)\\n    19→\\n    20→//nolint:gochecknoinits // Agent self-registration is the intended pattern\\n    21→func init() {\\n    22→\\tagent.Register(agent.AgentNameOpenCode, NewOpenCodeAgent)\\n    23→}\\n    24→\\n    25→//nolint:revive // OpenCodeAgent is clearer than Agent in this context\\n    26→type OpenCodeAgent struct{}\\n    27→\\n    28→// NewOpenCodeAgent creates a new OpenCode agent instance.\\n    29→func NewOpenCodeAgent() agent.Agent {\\n    30→\\treturn &OpenCodeAgent{}\\n    31→}\\n    32→\\n    33→// --- Identity ---\\n    34→\\n    35→func (a *OpenCodeAgent) Name() agent.AgentName   { return agent.AgentNameOpenCode }\\n    36→func (a *OpenCodeAgent) Type() agent.AgentType   { return agent.AgentTypeOpenCode }\\n    37→func (a *OpenCodeAgent) Description() string     { return \\\"OpenCode - AI-powered terminal coding agent\\\" }\\n    38→func (a *OpenCodeAgent) IsPreview() bool         { return true }\\n    39→func (a *OpenCodeAgent) ProtectedDirs() []string { return []string{\\\".opencode\\\"} }\\n    40→\\n    41→func (a *OpenCodeAgent) DetectPresence(ctx context.Context) (bool, error) {\\n    42→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n    43→\\tif err != nil {\\n    44→\\t\\trepoRoot = \\\".\\\"\\n    45→\\t}\\n    46→\\t// Check for .opencode directory or opencode.json config\\n    47→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\".opencode\\\")); err == nil {\\n    48→\\t\\treturn true, nil\\n    49→\\t}\\n    50→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\"opencode.json\\\")); err == nil {\\n    51→\\t\\treturn true, nil\\n    52→\\t}\\n    53→\\treturn false, nil\\n    54→}\\n    55→\\n    56→// --- Transcript Storage ---\\n    57→\\n    58→// ReadTranscript reads the transcript for a session.\\n    59→// The sessionRef is expected to be a path to the export JSON file.\\n    60→func (a *OpenCodeAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    61→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    62→\\tif err != nil {\\n    63→\\t\\treturn nil, fmt.Errorf(\\\"failed to read opencode transcript: %w\\\", err)\\n    64→\\t}\\n    65→\\treturn data, nil\\n    66→}\\n    67→\\n    68→// ChunkTranscript splits an OpenCode export JSON transcript by distributing messages across chunks.\\n    69→// OpenCode uses JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]} structure.\\n    70→func (a *OpenCodeAgent) ChunkTranscript(_ context.Context, content []byte, maxSize int) ([][]byte, error) {\\n    71→\\tvar session ExportSession\\n    72→\\tif err := json.Unmarshal(content, &session); err != nil {\\n    73→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse export session for chunking: %w\\\", err)\\n    74→\\t}\\n    75→\\n    76→\\tif len(session.Messages) == 0 {\\n    77→\\t\\treturn [][]byte{content}, nil\\n    78→\\t}\\n    79→\\n    80→\\t// Marshal info to calculate accurate base size\\n    81→\\tinfoBytes, err := json.Marshal(session.Info)\\n    82→\\tif err != nil {\\n    83→\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal session info for chunking: %w\\\", err)\\n    84→\\t}\\n    85→\\t// Base JSON structure size: {\\\"info\\\":<info>,\\\"messages\\\":[ ... ]}\\n    86→\\tbaseSize := len(`{\\\"info\\\":`) + len(infoBytes) + len(`,\\\"messages\\\":[]}`)\\n    87→\\n    88→\\tvar chunks [][]byte\\n    89→\\tvar currentMessages []ExportMessage\\n    90→\\tcurrentSize := baseSize\\n    91→\\n    92→\\tfor _, msg := range session.Messages {\\n    93→\\t\\t// Marshal message to get its size\\n    94→\\t\\tmsgBytes, err := json.Marshal(msg)\\n    95→\\t\\tif err != nil {\\n    96→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal message for chunking: %w\\\", err)\\n    97→\\t\\t}\\n    98→\\t\\tmsgSize := len(msgBytes) + 1 // +1 for comma separator\\n    99→\\n   100→\\t\\tif currentSize+msgSize > maxSize && len(currentMessages) > 0 {\\n   101→\\t\\t\\t// Save current chunk\\n   102→\\t\\t\\tchunkData, err := json.Marshal(ExportSession{Info: session.Info, Messages: currentMessages})\\n   103→\\t\\t\\tif err != nil {\\n   104→\\t\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal chunk: %w\\\", err)\\n   105→\\t\\t\\t}\\n   106→\\t\\t\\tchunks = append(chunks, chunkData)\\n   107→\\n   108→\\t\\t\\t// Start new chunk\\n   109→\\t\\t\\tcurrentMessages = nil\\n   110→\\t\\t\\tcurrentSize = baseSize\\n   111→\\t\\t}\\n   112→\\n   113→\\t\\tcurrentMessages = append(currentMessages, msg)\\n   114→\\t\\tcurrentSize += msgSize\\n   115→\\t}\\n   116→\\n   117→\\t// Add the last chunk\\n   118→\\tif len(currentMessages) > 0 {\\n   119→\\t\\tchunkData, err := json.Marshal(ExportSession{Info: session.Info, Messages: currentMessages})\\n   120→\\t\\tif err != nil {\\n   121→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal final chunk: %w\\\", err)\\n   122→\\t\\t}\\n   123→\\t\\tchunks = append(chunks, chunkData)\\n   124→\\t}\\n   125→\\n   126→\\tif len(chunks) == 0 {\\n   127→\\t\\treturn nil, errors.New(\\\"failed to create any chunks\\\")\\n   128→\\t}\\n   129→\\n   130→\\treturn chunks, nil\\n   131→}\\n   132→\\n   133→// ReassembleTranscript merges OpenCode export JSON chunks by combining their message arrays.\\n   134→func (a *OpenCodeAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n   135→\\tif len(chunks) == 0 {\\n   136→\\t\\treturn nil, errors.New(\\\"no chunks to reassemble\\\")\\n   137→\\t}\\n   138→\\n   139→\\tvar allMessages []ExportMessage\\n   140→\\tvar sessionInfo SessionInfo\\n   141→\\n   142→\\tfor i, chunk := range chunks {\\n   143→\\t\\tvar session ExportSession\\n   144→\\t\\tif err := json.Unmarshal(chunk, &session); err != nil {\\n   145→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal chunk %d: %w\\\", i, err)\\n   146→\\t\\t}\\n   147→\\t\\tif i == 0 {\\n   148→\\t\\t\\tsessionInfo = session.Info // Preserve session info from first chunk\\n   149→\\t\\t}\\n   150→\\t\\tallMessages = append(allMessages, session.Messages...)\\n   151→\\t}\\n   152→\\n   153→\\tresult, err := json.Marshal(ExportSession{Info: sessionInfo, Messages: allMessages})\\n   154→\\tif err != nil {\\n   155→\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal reassembled transcript: %w\\\", err)\\n   156→\\t}\\n   157→\\treturn result, nil\\n   158→}\\n   159→\\n   160→// --- Legacy methods ---\\n   161→\\n   162→func (a *OpenCodeAgent) GetSessionID(input *agent.HookInput) string {\\n   163→\\treturn input.SessionID\\n   164→}\\n   165→\\n   166→// GetSessionDir returns the directory where Entire stores OpenCode session transcripts.\\n   167→// Transcripts are ephemeral handoff files between the TS plugin and the Go hook handler.\\n   168→// Once checkpointed, the data lives on git refs and the file is disposable.\\n   169→// Stored in os.TempDir()/entire-opencode/<sanitized-path>/ to avoid squatting on\\n   170→// OpenCode's own directories (~/.opencode/ is project-level, not home-level).\\n   171→func (a *OpenCodeAgent) GetSessionDir(repoPath string) (string, error) {\\n   172→\\t// Check for test environment override\\n   173→\\tif override := os.Getenv(\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR\\\"); override != \\\"\\\" {\\n   174→\\t\\treturn override, nil\\n   175→\\t}\\n   176→\\n   177→\\tprojectDir := SanitizePathForOpenCode(repoPath)\\n   178→\\treturn filepath.Join(os.TempDir(), \\\"entire-opencode\\\", projectDir), nil\\n   179→}\\n   180→\\n   181→func (a *OpenCodeAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   182→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".json\\\")\\n   183→}\\n   184→\\n   185→func (a *OpenCodeAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   186→\\tif input.SessionRef == \\\"\\\" {\\n   187→\\t\\treturn nil, errors.New(\\\"no session ref provided\\\")\\n   188→\\t}\\n   189→\\tdata, err := os.ReadFile(input.SessionRef)\\n   190→\\tif err != nil {\\n   191→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session: %w\\\", err)\\n   192→\\t}\\n   193→\\n   194→\\t// Parse to extract computed fields\\n   195→\\tmodifiedFiles, err := ExtractModifiedFiles(data)\\n   196→\\tif err != nil {\\n   197→\\t\\t// Non-fatal: we can still return the session without modified files\\n   198→\\t\\tlogging.Warn(context.Background(), \\\"failed to extract modified files from opencode session\\\",\\n   199→\\t\\t\\tslog.String(\\\"session_ref\\\", input.SessionRef),\\n   200→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   201→\\t\\t)\\n   202→\\t\\tmodifiedFiles = nil\\n   203→\\t}\\n   204→\\n   205→\\treturn &agent.AgentSession{\\n   206→\\t\\tAgentName:     a.Name(),\\n   207→\\t\\tSessionID:     input.SessionID,\\n   208→\\t\\tSessionRef:    input.SessionRef,\\n   209→\\t\\tNativeData:    data,\\n   210→\\t\\tModifiedFiles: modifiedFiles,\\n   211→\\t}, nil\\n   212→}\\n   213→\\n   214→func (a *OpenCodeAgent) WriteSession(ctx context.Context, session *agent.AgentSession) error {\\n   215→\\tif session == nil {\\n   216→\\t\\treturn errors.New(\\\"nil session\\\")\\n   217→\\t}\\n   218→\\tif len(session.NativeData) == 0 {\\n   219→\\t\\treturn errors.New(\\\"no session data to write\\\")\\n   220→\\t}\\n   221→\\n   222→\\t// Import the session into OpenCode's database.\\n   223→\\t// This enables `opencode -s <id>` for both resume and rewind.\\n   224→\\treturn a.importSessionIntoOpenCode(ctx, session.SessionID, session.NativeData)\\n   225→}\\n   226→\\n   227→// importSessionIntoOpenCode writes the export JSON to a temp file and runs\\n   228→// `opencode import` to restore the session into OpenCode's database.\\n   229→// For rewind (session already exists), the session is deleted first so the\\n   230→// reimport replaces it with the checkpoint-state messages.\\n   231→func (a *OpenCodeAgent) importSessionIntoOpenCode(ctx context.Context, sessionID string, exportData []byte) error {\\n   232→\\t// Delete existing session first so reimport replaces it cleanly.\\n   233→\\t// opencode import uses ON CONFLICT DO NOTHING, so existing messages\\n   234→\\t// would be skipped without this step (breaking rewind).\\n   235→\\tif err := runOpenCodeSessionDelete(ctx, sessionID); err != nil {\\n   236→\\t\\t// Non-fatal: session might not exist yet (first session).\\n   237→\\t\\t// Import will still work for new sessions; only rewind of existing sessions\\n   238→\\t\\t// would have stale messages.\\n   239→\\t\\tlogging.Warn(ctx, \\\"could not delete existing opencode session\\\",\\n   240→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   241→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   242→\\t\\t)\\n   243→\\t}\\n   244→\\n   245→\\t// Write export JSON to a temp file for opencode import\\n   246→\\ttmpFile, err := os.CreateTemp(\\\"\\\", \\\"entire-opencode-export-*.json\\\")\\n   247→\\tif err != nil {\\n   248→\\t\\treturn fmt.Errorf(\\\"failed to create temp file: %w\\\", err)\\n   249→\\t}\\n   250→\\tdefer os.Remove(tmpFile.Name())\\n   251→\\n   252→\\tif _, err := tmpFile.Write(exportData); err != nil {\\n   253→\\t\\t_ = tmpFile.Close()\\n   254→\\t\\treturn fmt.Errorf(\\\"failed to write export data: %w\\\", err)\\n   255→\\t}\\n   256→\\tif err := tmpFile.Close(); err != nil {\\n   257→\\t\\treturn fmt.Errorf(\\\"failed to close temp file: %w\\\", err)\\n   258→\\t}\\n   259→\\n   260→\\treturn runOpenCodeImport(ctx, tmpFile.Name())\\n   261→}\\n   262→\\n   263→func (a *OpenCodeAgent) FormatResumeCommand(sessionID string) string {\\n   264→\\tif strings.TrimSpace(sessionID) == \\\"\\\" {\\n   265→\\t\\treturn \\\"opencode\\\"\\n   266→\\t}\\n   267→\\treturn \\\"opencode -s \\\" + sessionID\\n   268→}\\n   269→\\n   270→// nonAlphanumericRegex matches any non-alphanumeric character.\\n   271→var nonAlphanumericRegex = regexp.MustCompile(`[^a