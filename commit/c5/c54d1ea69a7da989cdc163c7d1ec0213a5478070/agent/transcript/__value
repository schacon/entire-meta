tcreateShadowBranchWithContent(t, repo, \\\"del1234\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   207→\\t\\t\\\"other.txt\\\": []byte(\\\"other content\\\"),\\n   208→\\t})\\n   209→\\n   210→\\t// Delete the file and commit the deletion\\n   211→\\t_, err = wt.Remove(\\\"to_delete.txt\\\")\\n   212→\\trequire.NoError(t, err)\\n   213→\\tdeleteCommit, err := wt.Commit(\\\"Delete file\\\", &git.CommitOptions{\\n   214→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   215→\\t})\\n   216→\\trequire.NoError(t, err)\\n   217→\\n   218→\\tcommit, err := repo.CommitObject(deleteCommit)\\n   219→\\trequire.NoError(t, err)\\n   220→\\n   221→\\t// Test: deleted file in filesTouched should count as overlap\\n   222→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"del1234\\\", \\\"e3b0c4\\\")\\n   223→\\tresult := filesOverlapWithContent(context.Background(), repo, shadowBranch, commit, []string{\\\"to_delete.txt\\\"})\\n   224→\\tassert.True(t, result, \\\"Deleted file should count as overlap (agent's deletion being committed)\\\")\\n   225→}\\n   226→\\n   227→// TestFilesOverlapWithContent_NoShadowBranch tests fallback when shadow branch doesn't exist.\\n   228→func TestFilesOverlapWithContent_NoShadowBranch(t *testing.T) {\\n   229→\\tt.Parallel()\\n   230→\\tdir := setupGitRepo(t)\\n   231→\\n   232→\\trepo, err := git.PlainOpen(dir)\\n   233→\\trequire.NoError(t, err)\\n   234→\\n   235→\\t// Create a commit without any shadow branch\\n   236→\\ttestFile := filepath.Join(dir, \\\"test.txt\\\")\\n   237→\\trequire.NoError(t, os.WriteFile(testFile, []byte(\\\"content\\\"), 0o644))\\n   238→\\twt, err := repo.Worktree()\\n   239→\\trequire.NoError(t, err)\\n   240→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   241→\\trequire.NoError(t, err)\\n   242→\\theadCommit, err := wt.Commit(\\\"Test commit\\\", &git.CommitOptions{\\n   243→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   244→\\t})\\n   245→\\trequire.NoError(t, err)\\n   246→\\n   247→\\tcommit, err := repo.CommitObject(headCommit)\\n   248→\\trequire.NoError(t, err)\\n   249→\\n   250→\\t// Test: Non-existent shadow branch should fall back to assuming overlap\\n   251→\\tresult := filesOverlapWithContent(context.Background(), repo, \\\"entire/nonexistent-e3b0c4\\\", commit, []string{\\\"test.txt\\\"})\\n   252→\\tassert.True(t, result, \\\"Missing shadow branch should fall back to assuming overlap\\\")\\n   253→}\\n   254→\\n   255→// TestFilesWithRemainingAgentChanges_FileNotCommitted tests that files not in the commit\\n   256→// are kept in the remaining list.\\n   257→func TestFilesWithRemainingAgentChanges_FileNotCommitted(t *testing.T) {\\n   258→\\tt.Parallel()\\n   259→\\tdir := setupGitRepo(t)\\n   260→\\n   261→\\trepo, err := git.PlainOpen(dir)\\n   262→\\trequire.NoError(t, err)\\n   263→\\n   264→\\t// Create shadow branch with two files\\n   265→\\tcreateShadowBranchWithContent(t, repo, \\\"abc1234\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   266→\\t\\t\\\"fileA.txt\\\": []byte(\\\"content A\\\"),\\n   267→\\t\\t\\\"fileB.txt\\\": []byte(\\\"content B\\\"),\\n   268→\\t})\\n   269→\\n   270→\\t// Only commit fileA\\n   271→\\tfileA := filepath.Join(dir, \\\"fileA.txt\\\")\\n   272→\\trequire.NoError(t, os.WriteFile(fileA, []byte(\\\"content A\\\"), 0o644))\\n   273→\\twt, err := repo.Worktree()\\n   274→\\trequire.NoError(t, err)\\n   275→\\t_, err = wt.Add(\\\"fileA.txt\\\")\\n   276→\\trequire.NoError(t, err)\\n   277→\\theadCommit, err := wt.Commit(\\\"Add file A only\\\", &git.CommitOptions{\\n   278→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   279→\\t})\\n   280→\\trequire.NoError(t, err)\\n   281→\\n   282→\\tcommit, err := repo.CommitObject(headCommit)\\n   283→\\trequire.NoError(t, err)\\n   284→\\n   285→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"abc1234\\\", \\\"e3b0c4\\\")\\n   286→\\tcommittedFiles := map[string]struct{}{\\\"fileA.txt\\\": {}}\\n   287→\\n   288→\\t// fileB was not committed - should be in remaining\\n   289→\\tremaining := filesWithRemainingAgentChanges(context.Background(), repo, shadowBranch, commit, []string{\\\"fileA.txt\\\", \\\"fileB.txt\\\"}, committedFiles)\\n   290→\\tassert.Equal(t, []string{\\\"fileB.txt\\\"}, remaining, \\\"Uncommitted file should be in remaining\\\")\\n   291→}\\n   292→\\n   293→// TestFilesWithRemainingAgentChanges_FullyCommitted tests that files committed with\\n   294→// matching content are NOT in the remaining list.\\n   295→func TestFilesWithRemainingAgentChanges_FullyCommitted(t *testing.T) {\\n   296→\\tt.Parallel()\\n   297→\\tdir := setupGitRepo(t)\\n   298→\\n   299→\\trepo, err := git.PlainOpen(dir)\\n   300→\\trequire.NoError(t, err)\\n   301→\\n   302→\\tcontent := []byte(\\\"exact same content\\\")\\n   303→\\n   304→\\t// Create shadow branch with file\\n   305→\\tcreateShadowBranchWithContent(t, repo, \\\"def5678\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   306→\\t\\t\\\"test.txt\\\": content,\\n   307→\\t})\\n   308→\\n   309→\\t// Commit the file with SAME content\\n   310→\\ttestFile := filepath.Join(dir, \\\"test.txt\\\")\\n   311→\\trequire.NoError(t, os.WriteFile(testFile, content, 0o644))\\n   312→\\twt, err := repo.Worktree()\\n   313→\\trequire.NoError(t, err)\\n   314→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   315→\\trequire.NoError(t, err)\\n   316→\\theadCommit, err := wt.Commit(\\\"Add file with same content\\\", &git.CommitOptions{\\n   317→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   318→\\t})\\n   319→\\trequire.NoError(t, err)\\n   320→\\n   321→\\tcommit, err := repo.CommitObject(headCommit)\\n   322→\\trequire.NoError(t, err)\\n   323→\\n   324→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"def5678\\\", \\\"e3b0c4\\\")\\n   325→\\tcommittedFiles := map[string]struct{}{\\\"test.txt\\\": {}}\\n   326→\\n   327→\\t// File was fully committed - should NOT be in remaining\\n   328→\\tremaining := filesWithRemainingAgentChanges(context.Background(), repo, shadowBranch, commit, []string{\\\"test.txt\\\"}, committedFiles)\\n   329→\\tassert.Empty(t, remaining, \\\"Fully committed file should not be in remaining\\\")\\n   330→}\\n   331→\\n   332→// TestFilesWithRemainingAgentChanges_PartialCommit tests that files committed with\\n   333→// different content (partial commit via git add -p) ARE in the remaining list\\n   334→// when the working tree still has the full agent content.\\n   335→func TestFilesWithRemainingAgentChanges_PartialCommit(t *testing.T) {\\n   336→\\tt.Parallel()\\n   337→\\tdir := setupGitRepo(t)\\n   338→\\n   339→\\trepo, err := git.PlainOpen(dir)\\n   340→\\trequire.NoError(t, err)\\n   341→\\n   342→\\t// Shadow branch has the full agent content\\n   343→\\tfullContent := []byte(\\\"line 1\\\\nline 2\\\\nline 3\\\\nline 4\\\\n\\\")\\n   344→\\tcreateShadowBranchWithContent(t, repo, \\\"ghi9012\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   345→\\t\\t\\\"test.txt\\\": fullContent,\\n   346→\\t})\\n   347→\\n   348→\\t// User commits only partial content (simulating git add -p)\\n   349→\\tpartialContent := []byte(\\\"line 1\\\\nline 2\\\\n\\\")\\n   350→\\ttestFile := filepath.Join(dir, \\\"test.txt\\\")\\n   351→\\trequire.NoError(t, os.WriteFile(testFile, partialContent, 0o644))\\n   352→\\twt, err := repo.Worktree()\\n   353→\\trequire.NoError(t, err)\\n   354→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   355→\\trequire.NoError(t, err)\\n   356→\\theadCommit, err := wt.Commit(\\\"Partial commit\\\", &git.CommitOptions{\\n   357→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   358→\\t})\\n   359→\\trequire.NoError(t, err)\\n   360→\\n   361→\\t// After a real git add -p, the working tree still has the full content.\\n   362→\\t// Simulate this by writing the full content back to disk after the commit.\\n   363→\\trequire.NoError(t, os.WriteFile(testFile, fullContent, 0o644))\\n   364→\\n   365→\\tcommit, err := repo.CommitObject(headCommit)\\n   366→\\trequire.NoError(t, err)\\n   367→\\n   368→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"ghi9012\\\", \\\"e3b0c4\\\")\\n   369→\\tcommittedFiles := map[string]struct{}{\\\"test.txt\\\": {}}\\n   370→\\n   371→\\t// Content doesn't match and working tree is dirty - file should be in remaining\\n   372→\\tremaining := filesWithRemainingAgentChanges(context.Background(), repo, shadowBranch, commit, []string{\\\"test.txt\\\"}, committedFiles)\\n   373→\\tassert.Equal(t, []string{\\\"test.txt\\\"}, remaining, \\\"Partially committed file with dirty working tree should be in remaining\\\")\\n   374→}\\n   375→\\n   376→// TestFilesWithRemainingAgentChanges_ReplacedContent tests that files committed with\\n   377→// different content but a CLEAN working tree are NOT in the remaining list.\\n   378→// This is the scenario where the user intentionally replaced the agent's content.\\n   379→func TestFilesWithRemainingAgentChanges_ReplacedContent(t *testing.T) {\\n   380→\\tt.Parallel()\\n   381→\\tdir := setupGitRepo(t)\\n   382→\\n   383→\\trepo, err := git.PlainOpen(dir)\\n   384→\\trequire.NoError(t, err)\\n   385→\\n   386→\\t// Shadow branch has the agent's content\\n   387→\\tagentContent := []byte(\\\"func GetPort() int { return 8080 }\\\\n\\\")\\n   388→\\tcreateShadowBranchWithContent(t, repo, \\\"rep1234\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   389→\\t\\t\\\"config.go\\\": agentContent,\\n   390→\\t})\\n   391→\\n   392→\\t// User writes completely different content and commits\\n   393→\\tuserContent := []byte(\\\"func GetHost() string { return \\\\\\\"localhost\\\\\\\" }\\\\n\\\")\\n   394→\\ttestFile := filepath.Join(dir, \\\"config.go\\\")\\n   395→\\trequire.NoError(t, os.WriteFile(testFile, userContent, 0o644))\\n   396→\\twt, err := repo.Worktree()\\n   397→\\trequire.NoError(t, err)\\n   398→\\t_, err = wt.Add(\\\"config.go\\\")\\n   399→\\trequire.NoError(t, err)\\n   400→\\theadCommit, err := wt.Commit(\\\"Replace config\\\", &git.CommitOptions{\\n   401→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   402→\\t})\\n   403→\\trequire.NoError(t, err)\\n   404→\\n   405→\\t// Working tree is clean — matches the commit (user committed everything)\\n   406→\\n   407→\\tcommit, err := repo.CommitObject(headCommit)\\n   408→\\trequire.NoError(t, err)\\n   409→\\n   410→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"rep1234\\\", \\\"e3b0c4\\\")\\n   411→\\tcommittedFiles := map[string]struct{}{\\\"config.go\\\": {}}\\n   412→\\n   413→\\t// Content differs from shadow but working tree is clean — no carry-forward\\n   414→\\tremaining := filesWithRemainingAgentChanges(context.Background(), repo, shadowBranch, commit, []string{\\\"config.go\\\"}, committedFiles)\\n   415→\\tassert.Empty(t, remaining, \\\"Replaced content with clean working tree should not be in remaining\\\")\\n   416→}\\n   417→\\n   418→// TestFilesWithRemainingAgentChanges_NoShadowBranch tests fallback to file-level subtraction.\\n   419→func TestFilesWithRemainingAgentChanges_NoShadowBranch(t *testing.T) {\\n   420→\\tt.Parallel()\\n   421→\\tdir := setupGitRepo(t)\\n   422→\\n   423→\\trepo, err := git.PlainOpen(dir)\\n   424→\\trequire.NoError(t, err)\\n   425→\\n   426→\\t// Create a commit without any shadow branch\\n   427→\\ttestFile := filepath.Join(dir, \\\"test.txt\\\")\\n   428→\\trequire.NoError(t, os.WriteFile(testFile, []byte(\\\"content\\\"), 0o644))\\n   429→\\twt, err := repo.Worktree()\\n   430→\\trequire.NoError(t, err)\\n   431→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   432→\\trequire.NoError(t, err)\\n   433→\\theadCommit, err := wt.Commit(\\\"Test commit\\\", &git.CommitOptions{\\n   434→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   435→\\t})\\n   436→\\trequire.NoError(t, err)\\n   437→\\n   438→\\tcommit, err := repo.CommitObject(headCommit)\\n   439→\\trequire.NoError(t, err)\\n   440→\\n   441→\\t// Non-existent shadow branch should fall back to file-level subtraction\\n   442→\\tcommittedFiles := map[string]struct{}{\\\"test.txt\\\": {}}\\n   443→\\tremaining := filesWithRemainingAgentChanges(context.Background(), repo, \\\"entire/nonexistent-e3b0c4\\\", commit, []string{\\\"test.txt\\\", \\\"other.txt\\\"}, committedFiles)\\n   444→\\n   445→\\t// With file-level subtraction: test.txt is in committedFiles, other.txt is not\\n   446→\\tassert.Equal(t, []string{\\\"other.txt\\\"}, remaining, \\\"Fallback should use file-level subtraction\\\")\\n   447→}\\n   448→\\n   449→// resolveCommitTrees is a test helper that resolves HEAD tree, parent tree, and\\n   450→// shadow tree from a commit and shadow branch. Used to test cache equivalence.\\n   451→func resolveCommitTrees(t *testing.T, repo *git.Repository, commit *object.Commit, shadowBranchName string) (headTree, parentTree, shadowTree *object.Tree) {\\n   452→\\tt.Helper()\\n   453→\\n   454→\\tvar err error\\n   455→\\theadTree, err = commit.Tree()\\n   456→\\trequire.NoError(t, err)\\n   457→\\n   458→\\tif commit.NumParents() > 0 {\\n   459→\\t\\tparent, err := commit.Parent(0)\\n   460→\\t\\trequire.NoError(t, err)\\n   461→\\t\\tparentTree, err = parent.Tree()\\n   462→\\t\\trequire.NoError(t, err)\\n   463→\\t}\\n   464→\\n   465→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   466→\\tshadowRef, err := repo.Reference(refName, true)\\n   467→\\tif err == nil {\\n   468→\\t\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   469→\\t\\trequire.NoError(t, err)\\n   470→\\t\\tshadowTree, err = shadowCommit.Tree()\\n   471→\\t\\trequire.NoError(t, err)\\n   472→\\t}\\n   473→\\n   474→\\treturn headTree, parentTree, shadowTree\\n   475→}\\n   476→\\n   477→// TestFilesOverlapWithContent_CacheEquivalence verifies that calling\\n   478→// filesOverlapWithContent with pre-resolved trees (cache hit) produces\\n   479→// the same result as calling without opts (cache miss / fallback).\\n   480→func TestFilesOverlapWithContent_CacheEquivalence(t *testing.T) {\\n   481→\\tt.Parallel()\\n   482→\\tdir := setupGitRepo(t)\\n   483→\\n   484→\\trepo, err := git.PlainOpen(dir)\\n   485→\\trequire.NoError(t, err)\\n   486→\\n   487→\\t// Create initial file and commit\\n   488→\\ttestFile := filepath.Join(dir, \\\"test.txt\\\")\\n   489→\\trequire.NoError(t, os.WriteFile(testFile, []byte(\\\"original content\\\"), 0o644))\\n   490→\\twt, err := repo.Worktree()\\n   491→\\trequire.NoError(t, err)\\n   492→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   493→\\trequire.NoError(t, err)\\n   494→\\t_, err = wt.Commit(\\\"parent commit\\\", &git.CommitOptions{\\n   495→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   496→\\t})\\n   497→\\trequire.NoError(t, err)\\n   498→\\n   499→\\t// Create shadow branch\\n   500→\\tcreateShadowBranchWithContent(t, repo, \\\"abc1234\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   501→\\t\\t\\\"test.txt\\\": []byte(\\\"session modified\\\"),\\n   502→\\t})\\n   503→\\n   504→\\t// Modify file and commit\\n   505→\\trequire.NoError(t, os.WriteFile(testFile, []byte(\\\"user modified\\\"), 0o644))\\n   506→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   507→\\trequire.NoError(t, err)\\n   508→\\theadHash, err := wt.Commit(\\\"user commit\\\", &git.CommitOptions{\\n   509→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   510→\\t})\\n   511→\\trequire.NoError(t, err)\\n   512→\\n   513→\\tcommit, err := repo.CommitObject(headHash)\\n   514→\\trequire.NoError(t, err)\\n   515→\\n   516→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"abc1234\\\", \\\"e3b0c4\\\")\\n   517→\\theadTree, parentTree, shadowTree := resolveCommitTrees(t, repo, commit, shadowBranch)\\n   518→\\n   519→\\t// Cache miss (no opts)\\n   520→\\tresultWithout := filesOverlapWithContent(context.Background(), repo, shadowBranch, commit, []string{\\\"test.txt\\\"})\\n   521→\\n   522→\\t// Cache hit (all trees pre-resolved)\\n   523→\\tresultWith := filesOverlapWithContent(context.Background(), repo, shadowBranch, commit, []string{\\\"test.txt\\\"}, overlapOpts{\\n   524→\\t\\theadTree:      headTree,\\n   525→\\t\\tshadowTree:    shadowTree,\\n   526→\\t\\tparentTree:    parentTree,\\n   527→\\t\\thasParentTree: true,\\n   528→\\t})\\n   529→\\n   530→\\tassert.Equal(t, resultWithout, resultWith, \\\"Cache hit and cache miss should produce the same result\\\")\\n   531→\\tassert.True(t, resultWith, \\\"Modified file should count as overlap\\\")\\n   532→}\\n   533→\\n   534→// TestFilesOverlapWithContent_PartialCache verifies correct behavior when only\\n   535→// some trees are pre-resolved (e.g., headTree cached but shadowTree nil).\\n   536→func TestFilesOverlapWithContent_PartialCache(t *testing.T) {\\n   537→\\tt.Parallel()\\n   538→\\tdir := setupGitRepo(t)\\n   539→\\n   540→\\trepo, err := git.PlainOpen(dir)\\n   541→\\trequire.NoError(t, err)\\n   542→\\n   543→\\t// Create shadow branch with new file\\n   544→\\tcontent := []byte(\\\"session content\\\")\\n   545→\\tcreateShadowBranchWithContent(t, repo, \\\"part1234\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   546→\\t\\t\\\"newfile.txt\\\": content,\\n   547→\\t})\\n   548→\\n   549→\\t// Commit same file with same content\\n   550→\\ttestFile := filepath.Join(dir, \\\"newfile.txt\\\")\\n   551→\\trequire.NoError(t, os.WriteFile(testFile, content, 0o644))\\n   552→\\twt, err := repo.Worktree()\\n   553→\\trequire.NoError(t, err)\\n   554→\\t_, err = wt.Add(\\\"newfile.txt\\\")\\n   555→\\trequire.NoError(t, err)\\n   556→\\theadHash, err := wt.Commit(\\\"add new file\\\", &git.CommitOptions{\\n   557→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   558→\\t})\\n   559→\\trequire.NoError(t, err)\\n   560→\\n   561→\\tcommit, err := repo.CommitObject(headHash)\\n   562→\\trequire.NoError(t, err)\\n   563→\\n   564→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"part1234\\\", \\\"e3b0c4\\\")\\n   565→\\theadTree, parentTree, _ := resolveCommitTrees(t, repo, commit, shadowBranch)\\n   566→\\n   567→\\t// Partial cache: headTree and parentTree provided, shadowTree nil (will be resolved from repo)\\n   568→\\tresult := filesOverlapWithContent(context.Background(), repo, shadowBranch, commit, []string{\\\"newfile.txt\\\"}, overlapOpts{\\n   569→\\t\\theadTree:      headTree,\\n   570→\\t\\tparentTree:    parentTree,\\n   571→\\t\\thasParentTree: true,\\n   572→\\t\\t// shadowTree intentionally nil — triggers fallback resolution\\n   573→\\t})\\n   574→\\n   575→\\tassert.True(t, result, \\\"Partial cache (headTree only) should still detect overlap\\\")\\n   576→}\\n   577→\\n   578→// TestFilesOverlapWithContent_CacheWithInitialCommit verifies cache behavior\\n   579→// when parentTree is nil (initial commit / no parent).\\n   580→func TestFilesOverlapWithContent_CacheWithInitialCommit(t *testing.T) {\\n   581→\\tt.Parallel()\\n   582→\\t// setupGitRepo creates one initial commit (no parent), so HEAD has NumParents() == 0\\n   583→\\tdir := setupGitRepo(t)\\n   584→\\trepo, err := git.PlainOpen(dir)\\n   585→\\trequire.NoError(t, err)\\n   586→\\n   587→\\thead, err := repo.Head()\\n   588→\\trequire.NoError(t, err)\\n   589→\\tcommit, err := repo.CommitObject(head.Hash())\\n   590→\\trequire.NoError(t, err)\\n   591→\\trequire.Equal(t, 0, commit.NumParents(), \\\"setupGitRepo should create an initial commit\\\")\\n   592→\\n   593→\\t// Create shadow branch with content matching the initial commit's file\\n   594→\\tcreateShadowBranchWithContent(t, repo, \\\"init123\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   595→\\t\\t\\\"test.txt\\\": []byte(\\\"initial content\\\"),\\n   596→\\t})\\n   597→\\n   598→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"init123\\\", \\\"e3b0c4\\\")\\n   599→\\theadTree, err := commit.Tree()\\n   600→\\trequire.NoError(t, err)\\n   601→\\n   602→\\t// Cache with hasParentTree=true and parentTree=nil (initial commit has no parent)\\n   603→\\tresult := filesOverlapWithContent(context.Background(), repo, shadowBranch, commit, []string{\\\"test.txt\\\"}, overlapOpts{\\n   604→\\t\\theadTree:      headTree,\\n   605→\\t\\tparentTree:    nil,\\n   606→\\t\\thasParentTree: true, // Explicitly resolved as nil (initial commit)\\n   607→\\t})\\n   608→\\n   609→\\tassert.True(t, result, \\\"Initial commit with matching content should count as overlap\\\")\\n   610→}\\n   611→\\n   612→// TestFilesWithRemainingAgentChanges_CacheEquivalence verifies that calling\\n   613→// with pre-resolved trees produces the same result as without.\\n   614→func TestFilesWithRemainingAgentChanges_CacheEquivalence(t *testing.T) {\\n   615→\\tt.Parallel()\\n   616→\\tdir := setupGitRepo(t)\\n   617→\\n   618→\\trepo, err := git.PlainOpen(dir)\\n   619→\\trequire.NoError(t, err)\\n   620→\\n   621→\\t// Create shadow branch with two files\\n   622→\\tcreateShadowBranchWithContent(t, repo, \\\"rem1234\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   623→\\t\\t\\\"fileA.txt\\\": []byte(\\\"agent content A\\\"),\\n   624→\\t\\t\\\"fileB.txt\\\": []byte(\\\"agent content B\\\"),\\n   625→\\t})\\n   626→\\n   627→\\t// Commit only fileA with matching content\\n   628→\\twt, err := repo.Worktree()\\n   629→\\trequire.NoError(t, err)\\n   630→\\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \\\"fileA.txt\\\"), []byte(\\\"agent content A\\\"), 0o644))\\n   631→\\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \\\"fileB.txt\\\"), []byte(\\\"agent content B\\\"), 0o644))\\n   632→\\t_, err = wt.Add(\\\"fileA.txt\\\")\\n   633→\\trequire.NoError(t, err)\\n   634→\\t_, err = wt.Add(\\\"fileB.txt\\\")\\n   635→\\trequire.NoError(t, err)\\n   636→\\theadHash, err := wt.Commit(\\\"commit both files\\\", &git.CommitOptions{\\n   637→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   638→\\t})\\n   639→\\trequire.NoError(t, err)\\n   640→\\n   641→\\tcommit, err := repo.CommitObject(headHash)\\n   642→\\trequire.NoError(t, err)\\n   643→\\n   644→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"rem1234\\\", \\\"e3b0c4\\\")\\n   645→\\theadTree, _, shadowTree := resolveCommitTrees(t, repo, commit, shadowBranch)\\n   646→\\n   647→\\tcommittedFiles := map[string]struct{}{\\\"fileA.txt\\\": {}}\\n   648→\\tfilesTouched := []string{\\\"fileA.txt\\\", \\\"fileB.txt\\\"}\\n   649→\\n   650→\\t// Cache miss\\n   651→\\tresultWithout := filesWithRemainingAgentChanges(context.Background(), repo, shadowBranch, commit, filesTouched, committedFiles)\\n   652→\\n   653→\\t// Cache hit\\n   654→\\tresultWith := filesWithRemainingAgentChanges(context.Background(), repo, shadowBranch, commit, filesTouched, committedFiles, overlapOpts{\\n   655→\\t\\theadTree:   headTree,\\n   656→\\t\\tshadowTree: shadowTree,\\n   657→\\t})\\n   658→\\n   659→\\tassert.Equal(t, resultWithout, resultWith, \\\"Cache hit and cache miss should produce the same result\\\")\\n   660→\\t// fileB.txt was not committed, so it should be in remaining\\n   661→\\tassert.Contains(t, resultWith, \\\"fileB.txt\\\")\\n   662→\\t// fileA.txt was committed with matching content, so it should NOT be in remaining\\n   663→\\tassert.NotContains(t, resultWith, \\\"fileA.txt\\\")\\n   664→}\\n   665→\\n   666→// TestStagedFilesOverlapWithContent_ModifiedFile tests that a modified file\\n   667→// (exists in HEAD) always counts as overlap.\\n   668→func TestStagedFilesOverlapWithContent_ModifiedFile(t *testing.T) {\\n   669→\\tt.Parallel()\\n   670→\\tdir := setupGitRepo(t)\\n   671→\\n   672→\\trepo, err := git.PlainOpen(dir)\\n   673→\\trequire.NoError(t, err)\\n   674→\\n   675→\\t// Initial file is created by setupGitRepo\\n   676→\\t// Modify it and stage\\n   677→\\ttestFile := filepath.Join(dir, \\\"test.txt\\\")\\n   678→\\trequire.NoError(t, os.WriteFile(testFile, []byte(\\\"modified content\\\"), 0o644))\\n   679→\\twt, err := repo.Worktree()\\n   680→\\trequire.NoError(t, err)\\n   681→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   682→\\trequire.NoError(t, err)\\n   683→\\n   684→\\t// Create shadow branch (content doesn't matter for modified files)\\n   685→\\tcreateShadowBranchWithContent(t, repo, \\\"abc1234\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   686→\\t\\t\\\"test.txt\\\": []byte(\\\"shadow content\\\"),\\n   687→\\t})\\n   688→\\n   689→\\t// Get shadow tree\\n   690→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"abc1234\\\", \\\"e3b0c4\\\")\\n   691→\\tshadowRef, err := repo.Reference(plumbing.NewBranchReferenceName(shadowBranch), true)\\n   692→\\trequire.NoError(t, err)\\n   693→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   694→\\trequire.NoError(t, err)\\n   695→\\tshadowTree, err := shadowCommit.Tree()\\n   696→\\trequire.NoError(t, err)\\n   697→\\n   698→\\t// Modified file should count as overlap regardless of content\\n   699→\\tresult := stagedFilesOverlapWithContent(context.Background(), repo, shadowTree, []string{\\\"test.txt\\\"}, []string{\\\"test.txt\\\"})\\n   700→\\tassert.True(t, result, \\\"Modified file should always count as overlap\\\")\\n   701→}\\n   702→\\n   703→// TestStagedFilesOverlapWithContent_NewFile_ContentMatch tests that a new file\\n   704→// with matching content counts as overlap.\\n   705→func TestStagedFilesOverlapWithContent_NewFile_ContentMatch(t *testing.T) {\\n   706→\\tt.Parallel()\\n   707→\\tdir := setupGitRepo(t)\\n   708→\\n   709→\\trepo, err := git.PlainOpen(dir)\\n   710→\\trequire.NoError(t, err)\\n   711→\\n   712→\\t// Create a NEW file (doesn't exist in HEAD)\\n   713→\\tcontent := []byte(\\\"new file content\\\")\\n   714→\\tnewFile := filepath.Join(dir, \\\"newfile.txt\\\")\\n   715→\\trequire.NoError(t, os.WriteFile(newFile, content, 0o644))\\n   716→\\twt, err := repo.Worktree()\\n   717→\\trequire.NoError(t, err)\\n   718→\\t_, err = wt.Add(\\\"newfile.txt\\\")\\n   719→\\trequire.NoError(t, err)\\n   720→\\n   721→\\t// Create shadow branch with SAME content\\n   722→\\tcreateShadowBranchWithContent(t, repo, \\\"def5678\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   723→\\t\\t\\\"newfile.txt\\\": content,\\n   724→\\t})\\n   725→\\n   726→\\t// Get shadow tree\\n   727→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"def5678\\\", \\\"e3b0c4\\\")\\n   728→\\tshadowRef, err := repo.Reference(plumbing.NewBranchReferenceName(shadowBranch), true)\\n   729→\\trequire.NoError(t, err)\\n   730→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   731→\\trequire.NoError(t, err)\\n   732→\\tshadowTree, err := shadowCommit.Tree()\\n   733→\\trequire.NoError(t, err)\\n   734→\\n   735→\\t// New file with matching content should count as overlap\\n   736→\\tresult := stagedFilesOverlapWithContent(context.Background(), repo, shadowTree, []string{\\\"newfile.txt\\\"}, []string{\\\"newfile.txt\\\"})\\n   737→\\tassert.True(t, result, \\\"New file with matching content should count as overlap\\\")\\n   738→}\\n   739→\\n   740→// TestStagedFilesOverlapWithContent_NewFile_ContentMismatch tests that a new file\\n   741→// with different content does NOT count as overlap (reverted & replaced scenario).\\n   742→func TestStagedFilesOverlapWithContent_NewFile_ContentMismatch(t *testing.T) {\\n   743→\\tt.Parallel()\\n   744→\\tdir := setupGitRepo(t)\\n   745→\\n   746→\\trepo, err := git.PlainOpen(dir)\\n   747→\\trequire.NoError(t, err)\\n   748→\\n   749→\\t// Create a NEW file with different content than shadow branch\\n   750→\\tnewFile := filepath.Join(dir, \\\"newfile.txt\\\")\\n   751→\\trequire.NoError(t, os.WriteFile(newFile, []byte(\\\"user replaced content\\\"), 0o644))\\n   752→\\twt, err := repo.Worktree()\\n   753→\\trequire.NoError(t, err)\\n   754→\\t_, err = wt.Add(\\\"newfile.txt\\\")\\n   755→\\trequire.NoError(t, err)\\n   756→\\n   757→\\t// Create shadow branch with DIFFERENT content (agent's original)\\n   758→\\tcreateShadowBranchWithContent(t, repo, \\\"ghi9012\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   759→\\t\\t\\\"newfile.txt\\\": []byte(\\\"agent original content\\\"),\\n   760→\\t})\\n   761→\\n   762→\\t// Get shadow tree\\n   763→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"ghi9012\\\", \\\"e3b0c4\\\")\\n   764→\\tshadowRef, err := repo.Reference(plumbing.NewBranchReferenceName(shadowBranch), true)\\n   765→\\trequire.NoError(t, err)\\n   766→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   767→\\trequire.NoError(t, err)\\n   768→\\tshadowTree, err := shadowCommit.Tree()\\n   769→\\trequire.NoError(t, err)\\n   770→\\n   771→\\t// New file with different content should NOT count as overlap\\n   772→\\tresult := stagedFilesOverlapWithContent(context.Background(), repo, shadowTree, []string{\\\"newfile.txt\\\"}, []string{\\\"newfile.txt\\\"})\\n   773→\\tassert.False(t, result, \\\"New file with mismatched content should not count as overlap\\\")\\n   774→}\\n   775→\\n   776→// TestStagedFilesOverlapWithContent_NoOverlap tests that non-overlapping files\\n   777→// return false.\\n   778→func TestStagedFilesOverlapWithContent_NoOverlap(t *testing.T) {\\n   779→\\tt.Parallel()\\n   780→\\tdir := setupGitRepo(t)\\n   781→\\n   782→\\trepo, err := git.PlainOpen(dir)\\n   783→\\trequire.NoError(t, err)\\n   784→\\n   785→\\t// Stage a file NOT in filesTouched\\n   786→\\totherFile := filepath.Join(dir, \\\"other.txt\\\")\\n   787→\\trequire.NoError(t, os.WriteFile(otherFile, []byte(\\\"other content\\\"), 0o644))\\n   788→\\twt, err := repo.Worktree()\\n   789→\\trequire.NoError(t, err)\\n   790→\\t_, err = wt.Add(\\\"other.txt\\\")\\n   791→\\trequire.NoError(t, err)\\n   792→\\n   793→\\t// Create shadow branch\\n   794→\\tcreateShadowBranchWithContent(t, repo, \\\"jkl3456\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   795→\\t\\t\\\"session.txt\\\": []byte(\\\"session content\\\"),\\n   796→\\t})\\n   797→\\n   798→\\t// Get shadow tree\\n   799→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"jkl3456\\\", \\\"e3b0c4\\\")\\n   800→\\tshadowRef, err := repo.Reference(plumbing.NewBranchReferenceName(shadowBranch), true)\\n   801→\\trequire.NoError(t, err)\\n   802→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   803→\\trequire.NoError(t, err)\\n   804→\\tshadowTree, err := shadowCommit.Tree()\\n   805→\\trequire.NoError(t, err)\\n   806→\\n   807→\\t// Staged file \\\"other.txt\\\" is not in filesTouched \\\"session.txt\\\"\\n   808→\\tresult := stagedFilesOverlapWithContent(context.Background(), repo, shadowTree, []string{\\\"other.txt\\\"}, []string{\\\"session.txt\\\"})\\n   809→\\tassert.False(t, result, \\\"Non-overlapping files should return false\\\")\\n   810→}\\n   811→\\n   812→// TestStagedFilesOverlapWithContent_DeletedFile tests that a deleted file\\n   813→// (exists in HEAD but staged for deletion) DOES count as overlap.\\n   814→// The agent's action of deleting the file is being committed, so the session\\n   815→// context should be linked to this commit.\\n   816→func TestStagedFilesOverlapWithContent_DeletedFile(t *testing.T) {\\n   817→\\tt.Parallel()\\n   818→\\n   819→\\tdir := t.TempDir()\\n   820→\\trepo, err := git.PlainInit(dir, false)\\n   821→\\trequire.NoError(t, err)\\n   822→\\n   823→\\tworktree, err := repo.Worktree()\\n   824→\\trequire.NoError(t, err)\\n   825→\\n   826→\\t// Create and commit a file that will be deleted\\n   827→\\tfilePath := filepath.Join(dir, \\\"to_delete.txt\\\")\\n   828→\\terr = os.WriteFile(filePath, []byte(\\\"original content\\\"), 0644)\\n   829→\\trequire.NoError(t, err)\\n   830→\\t_, err = worktree.Add(\\\"to_delete.txt\\\")\\n   831→\\trequir