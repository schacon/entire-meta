sage metadata (role, tokens, etc.)\\n    14→  const messageStore = new Map<string, any>()\\n    15→\\n    16→  /**\\n    17→   * Pipe JSON payload to an entire hooks command (async).\\n    18→   * Errors are logged but never thrown — plugin failures must not crash OpenCode.\\n    19→   */\\n    20→  async function callHook(hookName: string, payload: Record<string, unknown>) {\\n    21→    try {\\n    22→      const json = JSON.stringify(payload)\\n    23→      await $`echo ${json} | ${ENTIRE_CMD} hooks opencode ${hookName}`.quiet().nothrow()\\n    24→    } catch {\\n    25→      // Silently ignore — plugin failures must not crash OpenCode\\n    26→    }\\n    27→  }\\n    28→\\n    29→  /**\\n    30→   * Synchronous variant for hooks that fire near process exit (turn-end, session-end).\\n    31→   * `opencode run` breaks its event loop on the same session.status idle event that\\n    32→   * triggers turn-end. The async callHook would be killed before completing.\\n    33→   * Bun.spawnSync blocks the event loop, preventing exit until the hook finishes.\\n    34→   */\\n    35→  function callHookSync(hookName: string, payload: Record<string, unknown>) {\\n    36→    try {\\n    37→      const json = JSON.stringify(payload)\\n    38→      Bun.spawnSync([\\\"sh\\\", \\\"-c\\\", `${ENTIRE_CMD} hooks opencode ${hookName}`], {\\n    39→        cwd: directory,\\n    40→        stdin: new TextEncoder().encode(json + \\\"\\\\n\\\"),\\n    41→        stdout: \\\"ignore\\\",\\n    42→        stderr: \\\"ignore\\\",\\n    43→      })\\n    44→    } catch {\\n    45→      // Silently ignore — plugin failures must not crash OpenCode\\n    46→    }\\n    47→  }\\n    48→\\n    49→  return {\\n    50→    event: async ({ event }) => {\\n    51→      switch (event.type) {\\n    52→        case \\\"session.created\\\": {\\n    53→          const session = (event as any).properties?.info\\n    54→          if (!session?.id) break\\n    55→          // Reset per-session tracking state when switching sessions.\\n    56→          if (currentSessionID !== session.id) {\\n    57→            seenUserMessages.clear()\\n    58→            messageStore.clear()\\n    59→          }\\n    60→          currentSessionID = session.id\\n    61→          await callHook(\\\"session-start\\\", {\\n    62→            session_id: session.id,\\n    63→          })\\n    64→          break\\n    65→        }\\n    66→\\n    67→        case \\\"message.updated\\\": {\\n    68→          const msg = (event as any).properties?.info\\n    69→          if (!msg) break\\n    70→          // Store message metadata (role, time, tokens, etc.)\\n    71→          messageStore.set(msg.id, msg)\\n    72→          break\\n    73→        }\\n    74→\\n    75→        case \\\"message.part.updated\\\": {\\n    76→          const part = (event as any).properties?.part\\n    77→          if (!part?.messageID) break\\n    78→\\n    79→          // Fire turn-start on the first text part of a new user message\\n    80→          const msg = messageStore.get(part.messageID)\\n    81→          if (msg?.role === \\\"user\\\" && part.type === \\\"text\\\" && !seenUserMessages.has(msg.id)) {\\n    82→            seenUserMessages.add(msg.id)\\n    83→            const sessionID = msg.sessionID ?? currentSessionID\\n    84→            if (sessionID) {\\n    85→              await callHook(\\\"turn-start\\\", {\\n    86→                session_id: sessionID,\\n    87→                prompt: part.text ?? \\\"\\\",\\n    88→              })\\n    89→            }\\n    90→          }\\n    91→          break\\n    92→        }\\n    93→\\n    94→        case \\\"session.status\\\": {\\n    95→          // session.status fires in both TUI and non-interactive (run) mode.\\n    96→          // session.idle is deprecated and not reliably emitted in run mode.\\n    97→          const props = (event as any).properties\\n    98→          if (props?.status?.type !== \\\"idle\\\") break\\n    99→          con