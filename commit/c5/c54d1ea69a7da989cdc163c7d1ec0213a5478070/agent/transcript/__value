.g., git commit -m).\\n    60→// Returns true for yes, false for no. If TTY is unavailable, returns the default.\\n    61→// If context is non-empty, it is displayed on a separate line before the prompt.\\n    62→func askConfirmTTY(prompt string, context string, defaultYes bool) bool {\\n    63→\\t// In test mode, don't try to interact with the real TTY — just use the default.\\n    64→\\t// ENTIRE_TEST_TTY=1 simulates \\\"a human is present\\\" for the hasTTY() check\\n    65→\\t// but we can't actually read from the TTY in tests.\\n    66→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n    67→\\t\\treturn defaultYes\\n    68→\\t}\\n    69→\\n    70→\\t// Gemini CLI sets GEMINI_CLI=1 when running shell commands (including git commit).\\n    71→\\t// The agent can't respond to TTY prompts, so use the default to avoid hanging.\\n    72→\\t// See: https://geminicli.com/docs/tools/shell/\\n    73→\\tif os.Getenv(\\\"GEMINI_CLI\\\") != \\\"\\\" {\\n    74→\\t\\treturn defaultYes\\n    75→\\t}\\n    76→\\n    77→\\t// Open /dev/tty for both reading and writing\\n    78→\\t// This is the controlling terminal, which works even when stdin/stderr are redirected\\n    79→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n    80→\\tif err != nil {\\n    81→\\t\\t// Can't open TTY (e.g., running in CI), use default\\n    82→\\t\\treturn defaultYes\\n    83→\\t}\\n    84→\\tdefer tty.Close()\\n    85→\\n    86→\\t// Show context if provided\\n    87→\\tif context != \\\"\\\" {\\n    88→\\t\\tfmt.Fprintf(tty, \\\"%s\\\\n\\\", context)\\n    89→\\t}\\n    90→\\n    91→\\t// Show prompt with default indicator\\n    92→\\t// Write to tty directly, not stderr, since git hooks may redirect stderr to /dev/null\\n    93→\\tvar hint string\\n    94→\\tif defaultYes {\\n    95→\\t\\thint = \\\"[Y/n]\\\"\\n    96→\\t} else {\\n    97→\\t\\thint = \\\"[y/N]\\\"\\n    98→\\t}\\n    99→\\tfmt.Fprintf(tty, \\\"%s %s \\\", prompt, hint)\\n   100→\\n   101→\\t// Read response\\n   102→\\treader := bufio.NewReader(tty)\\n   103→\\tresponse, err := reader.ReadString('\\\\n')\\n   104→\\tif err != nil {\\n   105→\\t\\treturn defaultYes\\n   106→\\t}\\n   107→\\n   108→\\tresponse = strings.TrimSpace(strings.ToLower(response))\\n   109→\\tswitch response {\\n   110→\\tcase \\\"y\\\", \\\"yes\\\":\\n   111→\\t\\treturn true\\n   112→\\tcase \\\"n\\\", \\\"no\\\":\\n   113→\\t\\treturn false\\n   114→\\tdefault:\\n   115→\\t\\t// Empty or invalid input - use default\\n   116→\\t\\treturn defaultYes\\n   117→\\t}\\n   118→}\\n   119→\\n   120→// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   121→// If the message contains only our trailer (no actual user content), strip it\\n   122→// so git will abort the commit due to empty message.\\n   123→\\n   124→func (s *ManualCommitStrategy) CommitMsg(_ context.Context, commitMsgFile string) error {\\n   125→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n   126→\\tif err != nil {\\n   127→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   128→\\t}\\n   129→\\n   130→\\tmessage := string(content)\\n   131→\\n   132→\\t// Check if our trailer is present (ParseCheckpoint validates format, so found==true means valid)\\n   133→\\tif _, found := trailers.ParseCheckpoint(message); !found {\\n   134→\\t\\t// No trailer, nothing to do\\n   135→\\t\\treturn nil\\n   136→\\t}\\n   137→\\n   138→\\t// Check if there's any user content (non-comment, non-trailer lines)\\n   139→\\tif !hasUserContent(message) {\\n   140→\\t\\t// No user content - strip the trailer so git aborts\\n   141→\\t\\tmessage = stripCheckpointTrailer(message)\\n   142→\\t\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   143→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   144→\\t\\t}\\n   145→\\t}\\n   146→\\n   147→\\treturn nil\\n   148→}\\n   149→\\n   150→// hasUserContent checks if the message has any content besides comments and our trailer.\\n   151→func hasUserContent(message string) bool {\\n   152→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   153→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   154→\\t\\ttrimmed := strings.TrimSpace(line)\\n   155→\\t\\t// Skip empty lines\\n   156→\\t\\tif trimmed == \\\"\\\" {\\n   157→\\t\\t\\tcontinue\\n   158→\\t\\t}\\n   159→\\t\\t// Skip comment lines\\n   160→\\t\\tif strings.HasPrefix(trimmed, \\\"#\\\") {\\n   161→\\t\\t\\tcontinue\\n   162→\\t\\t}\\n   163→\\t\\t// Skip our trailer line\\n   164→\\t\\tif strings.HasPrefix(trimmed, trailerPrefix) {\\n   165→\\t\\t\\tcontinue\\n   166→\\t\\t}\\n   167→\\t\\t// Found user content\\n   168→\\t\\treturn true\\n   169→\\t}\\n   170→\\treturn false\\n   171→}\\n   172→\\n   173→// stripCheckpointTrailer removes the Entire-Checkpoint trailer line from the message.\\n   174→func stripCheckpointTrailer(message string) string {\\n   175→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   176→\\tvar result []string\\n   177→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   178→\\t\\tif !strings.HasPrefix(strings.TrimSpace(line), trailerPrefix) {\\n   179→\\t\\t\\tresult = append(result, line)\\n   180→\\t\\t}\\n   181→\\t}\\n   182→\\treturn strings.Join(result, \\\"\\\\n\\\")\\n   183→}\\n   184→\\n   185→// isGitSequenceOperation checks if git is currently in the middle of a rebase,\\n   186→// cherry-pick, or revert operation. During these operations, commits are being\\n   187→// replayed and should not be linked to agent sessions.\\n   188→//\\n   189→// Detects:\\n   190→//   - rebase: .git/rebase-merge/ or .git/rebase-apply/ directories\\n   191→//   - cherry-pick: .git/CHERRY_PICK_HEAD file\\n   192→//   - revert: .git/REVERT_HEAD file\\n   193→func isGitSequenceOperation(ctx context.Context) bool {\\n   194→\\t// Get git directory (handles worktrees and relative paths correctly)\\n   195→\\tgitDir, err := GetGitDir(ctx)\\n   196→\\tif err != nil {\\n   197→\\t\\treturn false // Can't determine, assume not in sequence operation\\n   198→\\t}\\n   199→\\n   200→\\t// Check for rebase state directories\\n   201→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-merge\\\")); err == nil {\\n   202→\\t\\treturn true\\n   203→\\t}\\n   204→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-apply\\\")); err == nil {\\n   205→\\t\\treturn true\\n   206→\\t}\\n   207→\\n   208→\\t// Check for cherry-pick and revert state files\\n   209→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"CHERRY_PICK_HEAD\\\")); err == nil {\\n   210→\\t\\treturn true\\n   211→\\t}\\n   212→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"REVERT_HEAD\\\")); err == nil {\\n   213→\\t\\treturn true\\n   214→\\t}\\n   215→\\n   216→\\treturn false\\n   217→}\\n   218→\\n   219→// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   220→// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   221→// Only adds a trailer if there's actually new session content to condense.\\n   222→// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   223→// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   224→// For amended commits, preserves the existing checkpoint ID.\\n   225→//\\n   226→// The source parameter indicates how the commit was initiated:\\n   227→//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   228→//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   229→//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   230→//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   231→//\\n   232→\\n   233→func (s *ManualCommitStrategy) PrepareCommitMsg(ctx context.Context, commitMsgFile string, source string) error {\\n   234→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   235→\\n   236→\\t// Skip during rebase, cherry-pick, or revert operations\\n   237→\\t// These are replaying existing commits and should not be linked to agent sessions\\n   238→\\tif isGitSequenceOperation(ctx) {\\n   239→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n   240→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   241→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   242→\\t\\t)\\n   243→\\t\\treturn nil\\n   244→\\t}\\n   245→\\n   246→\\t// Skip for merge and squash sources\\n   247→\\t// These are auto-generated messages - not from Claude sessions\\n   248→\\tswitch source {\\n   249→\\tcase \\\"merge\\\", \\\"squash\\\":\\n   250→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n   251→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   252→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   253→\\t\\t)\\n   254→\\t\\treturn nil\\n   255→\\t}\\n   256→\\n   257→\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   258→\\tif source == \\\"commit\\\" {\\n   259→\\t\\treturn s.handleAmendCommitMsg(ctx, commitMsgFile)\\n   260→\\t}\\n   261→\\n   262→\\trepo, err := OpenRepository(ctx)\\n   263→\\tif err != nil {\\n   264→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   265→\\t}\\n   266→\\n   267→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   268→\\tif err != nil {\\n   269→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   270→\\t}\\n   271→\\n   272→\\t// Find all active sessions for this worktree\\n   273→\\t// We match by worktree (not BaseCommit) because the user may have made\\n   274→\\t// intermediate commits without entering new prompts, causing HEAD to diverge\\n   275→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   276→\\tif err != nil || len(sessions) == 0 {\\n   277→\\t\\t// No active sessions or error listing - silently skip (hooks must be resilient)\\n   278→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no active sessions\\\",\\n   279→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   280→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   281→\\t\\t)\\n   282→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   283→\\t}\\n   284→\\n   285→\\t// Fast path: when an agent is committing (ACTIVE session + no TTY), skip\\n   286→\\t// content detection and interactive prompts. The agent can't respond to TTY\\n   287→\\t// prompts and the content detection can miss mid-session work (no shadow\\n   288→\\t// branch yet, transcript analysis may fail). Generate a checkpoint ID and\\n   289→\\t// add the trailer directly.\\n   290→\\tif !hasTTY() {\\n   291→\\t\\tfor _, state := range sessions {\\n   292→\\t\\t\\tif state.Phase.IsActive() {\\n   293→\\t\\t\\t\\treturn s.addTrailerForAgentCommit(logCtx, commitMsgFile, state, source)\\n   294→\\t\\t\\t}\\n   295→\\t\\t}\\n   296→\\t}\\n   297→\\n   298→\\t// Check if any session has new content to condense\\n   299→\\tsessionsWithContent := s.filterSessionsWithNewContent(ctx, repo, sessions)\\n   300→\\n   301→\\tif len(sessionsWithContent) == 0 {\\n   302→\\t\\t// No new content — no trailer needed\\n   303→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no content to link\\\",\\n   304→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   305→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   306→\\t\\t\\tslog.Int(\\\"sessions_found\\\", len(sessions)),\\n   307→\\t\\t)\\n   308→\\t\\treturn nil\\n   309→\\t}\\n   310→\\n   311→\\t// Read current commit message\\n   312→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   313→\\tif err != nil {\\n   314→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   315→\\t}\\n   316→\\n   317→\\tmessage := string(content)\\n   318→\\n   319→\\t// Check if trailer already exists (ParseCheckpoint validates format, so found==true means valid)\\n   320→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   321→\\t\\t// Trailer already exists (e.g., amend) - keep it\\n   322→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: trailer already exists\\\",\\n   323→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   324→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   325→\\t\\t\\tslog.String(\\\"existing_checkpoint_id\\\", existingCpID.String()),\\n   326→\\t\\t)\\n   327→\\t\\treturn nil\\n   328→\\t}\\n   329→\\n   330→\\t// Generate a fresh checkpoint ID\\n   331→\\tcheckpointID, err := id.Generate()\\n   332→\\tif err != nil {\\n   333→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   334→\\t}\\n   335→\\n   336→\\t// Determine agent type and last prompt from session\\n   337→\\tvar agentType agent.AgentType\\n   338→\\tvar lastPrompt string\\n   339→\\tif len(sessionsWithContent) > 0 {\\n   340→\\t\\tfirstSession := sessionsWithContent[0]\\n   341→\\t\\tif firstSession.AgentType != \\\"\\\" {\\n   342→\\t\\t\\tagentType = firstSession.AgentType\\n   343→\\t\\t}\\n   344→\\t\\tlastPrompt = s.getLastPrompt(ctx, repo, firstSession)\\n   345→\\t}\\n   346→\\n   347→\\t// Prepare prompt for display: collapse newlines/whitespace, then truncate (rune-safe)\\n   348→\\tdisplayPrompt := stringutil.TruncateRunes(stringutil.CollapseWhitespace(lastPrompt), 80, \\\"...\\\")\\n   349→\\n   350→\\t// Add trailer differently based on commit source\\n   351→\\tswitch source {\\n   352→\\tcase \\\"message\\\":\\n   353→\\t\\t// Using -m or -F: ask user interactively whether to add trailer\\n   354→\\t\\t// (comments won't be stripped by git in this mode)\\n   355→\\n   356→\\t\\t// Build context string for interactive prompt\\n   357→\\t\\tvar promptContext string\\n   358→\\t\\tif displayPrompt != \\\"\\\" {\\n   359→\\t\\t\\tpromptContext = \\\"You have an active \\\" + string(agentType) + \\\" session.\\\\nLast Prompt: \\\" + displayPrompt\\n   360→\\t\\t}\\n   361→\\n   362→\\t\\tif !askConfirmTTY(\\\"Link this commit to \\\"+string(agentType)+\\\" session context?\\\", promptContext, true) {\\n   363→\\t\\t\\t// User declined - don't add trailer\\n   364→\\t\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: user declined trailer\\\",\\n   365→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   366→\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n   367→\\t\\t\\t)\\n   368→\\t\\t\\treturn nil\\n   369→\\t\\t}\\n   370→\\t\\tmessage = addCheckpointTrailer(message, checkpointID)\\n   371→\\tdefault:\\n   372→\\t\\t// Normal editor flow: add trailer with explanatory comment (will be stripped by git)\\n   373→\\t\\tmessage = addCheckpointTrailerWithComment(message, checkpointID, string(agentType), displayPrompt)\\n   374→\\t}\\n   375→\\n   376→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: trailer added\\\",\\n   377→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   378→\\t\\tslog.String(\\\"source\\\", source),\\n   379→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   380→\\t)\\n   381→\\n   382→\\t// Write updated message back\\n   383→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   384→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   385→\\t}\\n   386→\\n   387→\\treturn nil\\n   388→}\\n   389→\\n   390→// handleAmendCommitMsg handles the prepare-commit-msg hook for amend operations\\n   391→// (source=\\\"commit\\\"). It preserves existing trailers or restores from LastCheckpointID.\\n   392→func (s *ManualCommitStrategy) handleAmendCommitMsg(ctx context.Context, commitMsgFile string) error {\\n   393→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   394→\\t// Read current commit message\\n   395→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   396→\\tif err != nil {\\n   397→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   398→\\t}\\n   399→\\n   400→\\tmessage := string(content)\\n   401→\\n   402→\\t// If message already has a trailer, keep it unchanged\\n   403→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   404→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend preserves existing trailer\\\",\\n   405→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   406→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", existingCpID.String()),\\n   407→\\t\\t)\\n   408→\\t\\treturn nil\\n   409→\\t}\\n   410→\\n   411→\\t// No trailer in message — check if any session has LastCheckpointID to restore\\n   412→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   413→\\tif err != nil {\\n   414→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   415→\\t}\\n   416→\\n   417→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   418→\\tif err != nil || len(sessions) == 0 {\\n   419→\\t\\treturn nil //nolint:nilerr // No sessions - nothing to restore\\n   420→\\t}\\n   421→\\n   422→\\t// For amend, HEAD^ is the commit being amended, and HEAD is where we are now.\\n   423→\\t// We need to match sessions whose BaseCommit equals HEAD (the commit being amended\\n   424→\\t// was created from this base). This prevents stale sessions from injecting\\n   425→\\t// unrelated checkpoint IDs.\\n   426→\\trepo, repoErr := OpenRepository(ctx)\\n   427→\\tif repoErr != nil {\\n   428→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   429→\\t}\\n   430→\\thead, headErr := repo.Head()\\n   431→\\tif headErr != nil {\\n   432→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   433→\\t}\\n   434→\\tcurrentHead := head.Hash().String()\\n   435→\\n   436→\\t// Find first matching session with LastCheckpointID to restore.\\n   437→\\t// LastCheckpointID is set after condensation completes.\\n   438→\\tfor _, state := range sessions {\\n   439→\\t\\tif state.BaseCommit != currentHead {\\n   440→\\t\\t\\tcontinue\\n   441→\\t\\t}\\n   442→\\t\\tif state.LastCheckpointID.IsEmpty() {\\n   443→\\t\\t\\tcontinue\\n   444→\\t\\t}\\n   445→\\t\\tcpID := state.LastCheckpointID\\n   446→\\t\\tsource := \\\"LastCheckpointID\\\"\\n   447→\\n   448→\\t\\t// Restore the trailer\\n   449→\\t\\tmessage = addCheckpointTrailer(message, cpID)\\n   450→\\t\\tif writeErr := os.WriteFile(commitMsgFile, []byte(message), 0o600); writeErr != nil {\\n   451→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   452→\\t\\t}\\n   453→\\n   454→\\t\\tlogging.Info(logCtx, \\\"prepare-commit-msg: restored trailer on amend\\\",\\n   455→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   456→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   457→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   458→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   459→\\t\\t)\\n   460→\\t\\treturn nil\\n   461→\\t}\\n   462→\\n   463→\\t// No checkpoint ID found - leave message unchanged\\n   464→\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend with no checkpoint to restore\\\",\\n   465→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   466→\\t)\\n   467→\\treturn nil\\n   468→}\\n   469→\\n   470→// PostCommit is called by the git post-commit hook after a commit is created.\\n   471→// Uses the session state machine to determine what action to take per session:\\n   472→//   - ACTIVE → condense immediately (each commit gets its own checkpoint)\\n   473→//   - IDLE → condense immediately\\n   474→//   - ENDED → condense if files touched, discard if empty\\n   475→//\\n   476→// After condensation for ACTIVE sessions, remaining uncommitted files are\\n   477→// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n   478→//\\n   479→// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n   480→// and were condensed during this PostCommit.\\n   481→\\n   482→// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n   483→// Each session in the loop gets its own handler with per-session context.\\n   484→// Handler methods use the *State parameter from ApplyTransition (same pointer\\n   485→// as the state being transitioned) rather than capturing state separately.\\n   486→type postCommitActionHandler struct {\\n   487→\\ts                      *ManualCommitStrategy\\n   488→\\tctx                    context.Context\\n   489→\\trepo                   *git.Repository\\n   490→\\tcheckpointID           id.CheckpointID\\n   491→\\thead                   *plumbing.Reference\\n   492→\\tcommit                 *object.Commit\\n   493→\\tnewHead                string\\n   494→\\tshadowBranchName       string\\n   495→\\tshadowBranchesToDelete map[string]struct{}\\n   496→\\tcommittedFileSet       map[string]struct{}\\n   497→\\thasNew                 bool\\n   498→\\tfilesTouchedBefore     []string\\n   499→\\n   500→\\t// Cached git objects — resolved once per PostCommit invocation to avoid\\n   501→\\t// redundant reads across filesOverlapWithContent, filesWithRemainingAgentChanges,\\n   502→\\t// CondenseSession, and calculateSessionAttributions.\\n   503→\\theadTree   *object.Tree        // HEAD commit tree (shared across all sessions)\\n   504→\\tparentTree *object.Tree        // HEAD's first parent tree (shared, nil for initial commits)\\n   505→\\tshadowRef  *plumbing.Reference // Per-session shadow branch ref (nil if branch doesn't exist)\\n   506→\\tshadowTree *object.Tree        // Per-session shadow commit tree (nil if branch doesn't exist)\\n   507→\\n   508→\\t// Output: set by handler methods, read by caller after TransitionAndLog.\\n   509→\\tcondensed bool\\n   510→}\\n   511→\\n   512→func (h *postCommitActionHandler) HandleCondense(state *session.State) error {\\n   513→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   514→\\tshouldCondense := h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   515→\\n   516→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondense decision\\\",\\n   517→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   518→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   519→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   520→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   521→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   522→\\t)\\n   523→\\n   524→\\tif shouldCondense {\\n   525→\\t\\th.condensed = h.s.condenseAndUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   526→\\t\\t\\tshadowRef: h.shadowRef,\\n   527→\\t\\t\\theadTree:  h.headTree,\\n   528→\\t\\t})\\n   529→\\t} else {\\n   530→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   531→\\t}\\n   532→\\treturn nil\\n   533→}\\n   534→\\n   535→func (h *postCommitActionHandler) HandleCondenseIfFilesTouched(state *session.State) error {\\n   536→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   537→\\tshouldCondense := len(state.FilesTouched) > 0 && h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   538→\\n   539→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondenseIfFilesTouched decision\\\",\\n   540→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   541→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   542→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   543→\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n   544→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   545→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   546→\\t)\\n   547→\\n   548→\\tif shouldCondense {\\n   549→\\t\\th.condensed = h.s.condenseAndUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   550→\\t\\t\\tshadowRef: h.shadowRef,\\n   551→\\t\\t\\theadTree:  h.headTree,\\n   552→\\t\\t})\\n   553→\\t} else {\\n   554→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   555→\\t}\\n   556→\\treturn nil\\n   557→}\\n   558→\\n   559→// shouldCondenseWithOverlapCheck returns true if the session should be condensed\\n   560→// into this commit. Requires both that hasNew is true AND that the session's files\\n   561→// overlap with the committed files with matching content.\\n   562→//\\n   563→// This prevents stale sessions (ACTIVE sessions where the agent was killed, or\\n   564→// ENDED/IDLE sessions with carry-forward files) from being condensed into every\\n   565→// unrelated commit.\\n   566→//\\n   567→// filesTouchedBefore is populated from:\\n   568→//   - state.FilesTouched for IDLE/ENDED sessions (set via SaveStep/SaveTaskStep -> mergeFilesTouched)\\n   569→//   - transcript extraction for ACTIVE sessions when FilesTouched is empty\\n   570→//\\n   571→// When filesTouchedBefore is empty:\\n   572→//   - For ACTIVE sessions: fail-open (trust hasNew) because the agent may be\\n   573→//     mid-turn before any files are saved to state.\\n   574→//   - For IDLE/ENDED sessions: return false because there are no files to\\n   575→//     overlap with the commit.\\n   576→func (h *postCommitActionHandler) shouldCondenseWithOverlapCheck(isActive bool) bool {\\n   577→\\tif !h.hasNew {\\n   578→\\t\\treturn false\\n   579→\\t}\\n   580→\\tif len(h.filesTouchedBefore) == 0 {\\n   581→\\t\\treturn isActive // ACTIVE: fail-open; IDLE/ENDED: no files = no overlap\\n   582→\\t}\\n   583→\\t// Only check files that were actually changed in this commit.\\n   584→\\t// Without this, files that exist in the tree but weren't changed\\n   585→\\t// would pass the \\\"modified file\\\" check in filesOverlapWithContent\\n   586→\\t// (because the file exists in the parent tree), causing stale\\n   587→\\t// sessions to be incorrectly condensed.\\n   588→\\tvar committedTouchedFiles []string\\n   589→\\tfor _, f := range h.filesTouchedBefore {\\n   590→\\t\\tif _, ok := h.committedFileSet[f]; ok {\\n   591→\\t\\t\\tcommittedTouchedFiles = append(committedTouchedFiles, f)\\n   592→\\t\\t}\\n   593→\\t}\\n   594→\\tif len(committedTouchedFiles) == 0 {\\n   595→\\t\\treturn false\\n   596→\\t}\\n   597→\\treturn filesOverlapWithContent(h.ctx, h.repo, h.shadowBranchName, h.commit, committedTouchedFiles, overlapOpts{\\n   598→\\t\\theadTree:      h.headTree,\\n   599→\\t\\tshadowTree:    h.shadowTree,\\n   600→\\t\\tparentTree:    h.parentTree,\\n   601→\\t\\thasParentTree: true,\\n   602→\\t})\\n   603→}\\n   604→\\n   605→func (h *postCommitActionHandler) HandleDiscardIfNoFiles(state *session.State) error {\\n   606→\\tif len(state.FilesTouched) == 0 {\\n   607→\\t\\tlogging.Debug(logging.WithComponent(h.ctx, \\\"checkpoint\\\"), \\\"post-commit: skipping empty ended session (no files to condense)\\\",\\n   608→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   609→\\t\\t)\\n   610→\\t}\\n   611→\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   612→\\treturn nil\\n   613→}\\n   614→\\n   615→func (h *postCommitActionHandler) HandleWarnStaleSession(_ *session.State) error {\\n   616→\\t// Not produced by EventGitCommit; no-op for exhaustiveness.\\n   617→\\treturn nil\\n   618→}\\n   619→\\n   620→// During rebase/cherry-pick/revert operations, phase transitions are skipped entirely.\\n   621→//\\n   622→\\n   623→func (s *ManualCommitStrategy) PostCommit(ctx context.Context) error {\\n   624→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   625→\\n   626→\\trepo, err := OpenRepository(ctx)\\n   627→\\tif err != nil {\\n   628→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   629→\\t}\\n   630→\\n   631→\\t// Get HEAD commit to check for trailer\\n   632→\\thead, err := repo.Head()\\n   633→\\tif err != nil {\\n   634→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   635→\\t}\\n   636→\\n   637→\\tcommit, err := repo.CommitObject(head.Hash())\\n   638→\\tif err != nil {\\n   639→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   640→\\t}\\n   641→\\n   642→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   643→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   644→\\tif !found {\\n   645→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   646→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   647→\\t\\ts.postCommitUpdateBaseCommitOnly(ctx, head)\\n   648→\\t\\treturn nil\\n   649→\\t}\\n   650→\\n   651→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   652→\\tif err != nil {\\n   653→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   654→\\t}\\n   655→\\n   656→\\t// Find all active sessions for this worktree\\n   657→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   658→\\tif err != nil || len(sessions) == 0 {\\n   659→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   660→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   661→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   662→\\t\\t)\\n   663→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   664→\\t}\\n   665→\\n   666→\\t// Build transition context\\n   667→\\tisRebase := isGitSequenceOperation(ctx)\\n   668→\\ttransitionCtx := session.TransitionContext{\\n   669→\\t\\tIsRebaseInProgress: isRebase,\\n   670→\\t}\\n   671→\\n   672→\\tif isRebase {\\n   673→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   674→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   675→\\t\\t)\\n   676→\\t}\\n   677→\\n   678→\\t// Track shadow branch names and whether they can be deleted\\n   679→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   680→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   681→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   682→\\n   683→\\tnewHead := head.Hash().String()\\n   684→\\n   685→\\t// Pre-resolve HEAD tree and parent tree once for the entire PostCommit.\\n   686→\\t// These are immutable within this hook invocation and used by multiple\\n   687→\\t// per-session functions (filesChangedInCommit, filesOverlapWithContent,\\n   688→\\t// filesWithRemainingAgentChanges, calculateSessionAttributions).\\n   689→\\tvar headTree *object.Tree\\n   690→\\tif t, err := commit.Tree(); err == nil {\\n   691→\\t\\theadTree = t\\n   692→\\t}\\n   693→\\tvar parentTree *object.Tree\\n   694→\\tif commit.NumParents() > 0 {\\n   695→\\t\\tif parent, err := commit.Parent(0); err == nil {\\n   696→\\t\\t\\tif t, err := parent.Tree(); err == nil {\\n   697→\\t\\t\\t\\tparentTree = t\\n   698→\\t\\t\\t}\\n   699→\\t\\t}\\n   700→\\t}\\n   701→\\n   702→\\tcommittedFileSet := filesChangedInCommit(commit, headTree, parentTree)\\n   703→\\n   704→\\tfor _, state := range sessions {\\n   705→\\t\\ts.postCommitProcessSession(ctx, repo, state, &transitionCtx, checkpointID,\\n   706→\\t\\t\\thead, commit, newHead, headTree, parentTree, committedFileSet,\\n   707→\\t\\t\\tshadowBranchesToDelete, uncondensedActiveOnBranch)\\n   708→\\t}\\n   709→\\n   710→\\t// Clean up shadow branches — only delete when ALL sessions on the branch are non-active\\n   711→\\t// or were condensed during this PostCommit.\\n   712→\\tfor shadowBranchName := range shadowBranchesToDelete {\\n   713→\\t\\tif uncondensedActiveOnBranch[shadowBranchName] {\\n   714→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: preserving