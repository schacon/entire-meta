across sessionHasNewContent, filesOverlapWithContent,\\n   755→\\t// CondenseSession, filesWithRemainingAgentChanges, and calculateSessionAttributions.\\n   756→\\tvar shadowRef *plumbing.Reference\\n   757→\\tvar shadowTree *object.Tree\\n   758→\\tif ref, refErr := repo.Reference(plumbing.NewBranchReferenceName(shadowBranchName), true); refErr == nil {\\n   759→\\t\\tshadowRef = ref\\n   760→\\t\\tif sc, scErr := repo.CommitObject(ref.Hash()); scErr == nil {\\n   761→\\t\\t\\tif st, stErr := sc.Tree(); stErr == nil {\\n   762→\\t\\t\\t\\tshadowTree = st\\n   763→\\t\\t\\t}\\n   764→\\t\\t}\\n   765→\\t}\\n   766→\\n   767→\\t// Check for new content (needed for TransitionContext and condensation).\\n   768→\\t// Fail-open: if content check errors, assume new content exists so we\\n   769→\\t// don't silently skip data that should have been condensed.\\n   770→\\t//\\n   771→\\t// For ACTIVE sessions: the commit has a checkpoint trailer (verified above),\\n   772→\\t// meaning PrepareCommitMsg already determined this commit is session-related.\\n   773→\\t// The trailer is only added when either:\\n   774→\\t//   - No TTY (agent/subagent committing) — added unconditionally\\n   775→\\t//   - TTY (human committing) — added after content detection confirmed agent work\\n   776→\\t// In both cases, PrepareCommitMsg already validated this commit. We trust\\n   777→\\t// that decision here. Transcript-based re-validation is unreliable because\\n   778→\\t// subagent transcripts may not be available yet (subagent still running).\\n   779→\\tvar hasNew bool\\n   780→\\tif state.Phase.IsActive() {\\n   781→\\t\\thasNew = true\\n   782→\\t} else {\\n   783→\\t\\tvar contentErr error\\n   784→\\t\\thasNew, contentErr = s.sessionHasNewContent(ctx, repo, state, shadowTree)\\n   785→\\t\\tif contentErr != nil {\\n   786→\\t\\t\\thasNew = true\\n   787→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: error checking session content, assuming new content\\\",\\n   788→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   789→\\t\\t\\t\\tslog.String(\\\"error\\\", contentErr.Error()),\\n   790→\\t\\t\\t)\\n   791→\\t\\t}\\n   792→\\t}\\n   793→\\ttransitionCtx.HasFilesTouched = len(state.FilesTouched) > 0\\n   794→\\n   795→\\t// Save FilesTouched BEFORE TransitionAndLog — the handler's condensation\\n   796→\\t// clears it, but we need the original list for carry-forward computation.\\n   797→\\t// For mid-session commits (ACTIVE, no shadow branch), state.FilesTouched may be empty\\n   798→\\t// because no SaveStep/Stop has been called yet. Extract files from transcript.\\n   799→\\tfilesTouchedBefore := make([]string, len(state.FilesTouched))\\n   800→\\tcopy(filesTouchedBefore, state.FilesTouched)\\n   801→\\tif len(filesTouchedBefore) == 0 && state.Phase.IsActive() && state.TranscriptPath != \\\"\\\" {\\n   802→\\t\\tfilesTouchedBefore = s.extractFilesFromLiveTranscript(ctx, state)\\n   803→\\t}\\n   804→\\n   805→\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward prep\\\",\\n   806→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   807→\\t\\tslog.Bool(\\\"is_active\\\", state.Phase.IsActive()),\\n   808→\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n   809→\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   810→\\t\\tslog.Any(\\\"files\\\", filesTouchedBefore),\\n   811→\\t)\\n   812→\\n   813→\\t// Run the state machine transition with handler for strategy-specific actions.\\n   814→\\thandler := &postCommitActionHandler{\\n   815→\\t\\ts:                      s,\\n   816→\\t\\tctx:                    ctx,\\n   817→\\t\\trepo:                   repo,\\n   818→\\t\\tcheckpointID:           checkpointID,\\n   819→\\t\\thead:                   head,\\n   820→\\t\\tcommit:                 commit,\\n   821→\\t\\tnewHead:                newHead,\\n   822→\\t\\tshadowBranchName:       shadowBranchName,\\n   823→\\t\\tshadowBranchesToDelete: shadowBranchesToDelete,\\n   824→\\t\\tcommittedFileSet:       committedFileSet,\\n   825→\\t\\thasNew:                 hasNew,\\n   826→\\t\\tfilesTouchedBefore:     filesTouchedBefore,\\n   827→\\t\\theadTree:               headTree,\\n   828→\\t\\tparentTree:             parentTree,\\n   829→\\t\\tshadowRef:              shadowRef,\\n   830→\\t\\tshadowTree:             shadowTree,\\n   831→\\t}\\n   832→\\n   833→\\tif err := TransitionAndLog(ctx, state, session.EventGitCommit, *transitionCtx, handler); err != nil {\\n   834→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: post-commit action handler error: %v\\\\n\\\", err)\\n   835→\\t}\\n   836→\\n   837→\\t// Record checkpoint ID for ACTIVE sessions so HandleTurnEnd can finalize\\n   838→\\t// with full transcript. IDLE/ENDED sessions already have complete transcripts.\\n   839→\\t// NOTE: This check runs AFTER TransitionAndLog updated the phase. It relies on\\n   840→\\t// ACTIVE + GitCommit → ACTIVE (phase stays ACTIVE). If that state machine\\n   841→\\t// transition ever changed, this guard would silently stop recording IDs.\\n   842→\\tif handler.condensed && state.Phase.IsActive() {\\n   843→\\t\\tstate.TurnCheckpointIDs = append(state.TurnCheckpointIDs, checkpointID.String())\\n   844→\\t}\\n   845→\\n   846→\\t// Carry forward remaining uncommitted files so the next commit gets its\\n   847→\\t// own checkpoint ID. This applies to ALL phases — if a user splits their\\n   848→\\t// commit across two `git commit` invocations, each gets a 1:1 checkpoint.\\n   849→\\t// Uses content-aware comparison: if user did `git add -p` and committed\\n   850→\\t// partial changes, the file still has remaining agent changes to carry forward.\\n   851→\\tif handler.condensed {\\n   852→\\t\\tremainingFiles := filesWithRemainingAgentChanges(ctx, repo, shadowBranchName, commit, filesTouchedBefore, committedFileSet, overlapOpts{\\n   853→\\t\\t\\theadTree:   headTree,\\n   854→\\t\\t\\tshadowTree: shadowTree,\\n   855→\\t\\t})\\n   856→\\t\\tstate.FilesTouched = remainingFiles\\n   857→\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward decision (content-aware)\\\",\\n   858→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   859→\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   860→\\t\\t\\tslog.Int(\\\"committed_files\\\", len(committedFileSet)),\\n   861→\\t\\t\\tslog.Int(\\\"remaining_files\\\", len(remainingFiles)),\\n   862→\\t\\t\\tslog.Any(\\\"remaining\\\", remainingFiles),\\n   863→\\t\\t\\tslog.Any(\\\"committed_files\\\", committedFileSet),\\n   864→\\t\\t)\\n   865→\\t\\tif len(remainingFiles) > 0 {\\n   866→\\t\\t\\ts.carryForwardToNewShadowBranch(ctx, repo, state, remainingFiles)\\n   867→\\t\\t}\\n   868→\\t}\\n   869→\\n   870→\\t// Save the updated state\\n   871→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   872→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to update session state: %v\\\\n\\\", err)\\n   873→\\t}\\n   874→\\n   875→\\t// Only preserve shadow branch for active sessions that were NOT condensed.\\n   876→\\t// Condensed sessions already have their data on entire/checkpoints/v1.\\n   877→\\tif state.Phase.IsActive() && !handler.condensed {\\n   878→\\t\\tuncondensedActiveOnBranch[shadowBranchName] = true\\n   879→\\t}\\n   880→}\\n   881→\\n   882→// condenseAndUpdateState runs condensation for a session and updates state afterward.\\n   883→// Returns true if condensation succeeded.\\n   884→func (s *ManualCommitStrategy) condenseAndUpdateState(\\n   885→\\tctx context.Context,\\n   886→\\trepo *git.Repository,\\n   887→\\tcheckpointID id.CheckpointID,\\n   888→\\tstate *SessionState,\\n   889→\\thead *plumbing.Reference,\\n   890→\\tshadowBranchName string,\\n   891→\\tshadowBranchesToDelete map[string]struct{},\\n   892→\\tcommittedFiles map[string]struct{},\\n   893→\\topts ...condenseOpts,\\n   894→) bool {\\n   895→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   896→\\tresult, err := s.CondenseSession(ctx, repo, checkpointID, state, committedFiles, opts...)\\n   897→\\tif err != nil {\\n   898→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: condensation failed for session %s: %v\\\\n\\\",\\n   899→\\t\\t\\tstate.SessionID, err)\\n   900→\\t\\tlogging.Warn(logCtx, \\\"post-commit: condensation failed\\\",\\n   901→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   902→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   903→\\t\\t)\\n   904→\\t\\treturn false\\n   905→\\t}\\n   906→\\n   907→\\t// Track this shadow branch for cleanup\\n   908→\\tshadowBranchesToDelete[shadowBranchName] = struct{}{}\\n   909→\\n   910→\\t// Update session state for the new base commit\\n   911→\\tnewHead := head.Hash().String()\\n   912→\\tstate.BaseCommit = newHead\\n   913→\\tstate.AttributionBaseCommit = newHead\\n   914→\\tstate.StepCount = 0\\n   915→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   916→\\n   917→\\t// Clear attribution tracking — condensation already used these values\\n   918→\\tstate.PromptAttributions = nil\\n   919→\\tstate.PendingPromptAttribution = nil\\n   920→\\tstate.FilesTouched = nil\\n   921→\\n   922→\\t// Save checkpoint ID so subsequent commits can reuse it (e.g., amend restores trailer)\\n   923→\\tstate.LastCheckpointID = checkpointID\\n   924→\\n   925→\\tshortID := state.SessionID\\n   926→\\tif len(shortID) > 8 {\\n   927→\\t\\tshortID = shortID[:8]\\n   928→\\t}\\n   929→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Condensed session %s: %s (%d checkpoints)\\\\n\\\",\\n   930→\\t\\tshortID, result.CheckpointID, result.CheckpointsCount)\\n   931→\\n   932→\\tlogging.Info(logCtx, \\\"session condensed\\\",\\n   933→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   934→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   935→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   936→\\t\\tslog.Int(\\\"transcript_lines\\\", result.TotalTranscriptLines),\\n   937→\\t)\\n   938→\\n   939→\\treturn true\\n   940→}\\n   941→\\n   942→// updateBaseCommitIfChanged updates BaseCommit to newHead if it changed.\\n   943→// Only updates ACTIVE sessions. IDLE/ENDED sessions should NOT have their\\n   944→// BaseCommit updated, as this would cause them to be incorrectly associated\\n   945→// with a new shadow branch and potentially condensed on future commits.\\n   946→func (s *ManualCommitStrategy) updateBaseCommitIfChanged(ctx context.Context, state *SessionState, newHead string) {\\n   947→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   948→\\t// Only update ACTIVE sessions. IDLE/ENDED sessions are kept around for\\n   949→\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n   950→\\tif !state.Phase.IsActive() {\\n   951→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updateBaseCommitIfChanged skipped non-active session\\\",\\n   952→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   953→\\t\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   954→\\t\\t)\\n   955→\\t\\treturn\\n   956→\\t}\\n   957→\\tif state.BaseCommit != newHead {\\n   958→\\t\\tstate.BaseCommit = newHead\\n   959→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updated BaseCommit\\\",\\n   960→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   961→\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n   962→\\t\\t)\\n   963→\\t}\\n   964→}\\n   965→\\n   966→// postCommitUpdateBaseCommitOnly updates BaseCommit for all sessions on the current\\n   967→// worktree when a commit has no Entire-Checkpoint trailer. This prevents BaseCommit\\n   968→// from going stale, which would cause future PrepareCommitMsg calls to skip the\\n   969→// session (BaseCommit != currentHeadHash filter).\\n   970→//\\n   971→// Unlike the full PostCommit flow, this does NOT fire EventGitCommit or trigger\\n   972→// condensation — it only keeps BaseCommit in sync with HEAD.\\n   973→func (s *ManualCommitStrategy) postCommitUpdateBaseCommitOnly(ctx context.Context, head *plumbing.Reference) {\\n   974→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   975→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   976→\\tif err != nil {\\n   977→\\t\\treturn // Silent failure — hooks must be resilient\\n   978→\\t}\\n   979→\\n   980→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   981→\\tif err != nil || len(sessions) == 0 {\\n   982→\\t\\treturn\\n   983→\\t}\\n   984→\\n   985→\\tnewHead := head.Hash().String()\\n   986→\\tfor _, state := range sessions {\\n   987→\\t\\t// Only update active sessions. Idle/ended sessions are kept around for\\n   988→\\t\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n   989→\\t\\tif !state.Phase.IsActive() {\\n   990→\\t\\t\\tcontinue\\n   991→\\t\\t}\\n   992→\\t\\tif state.BaseCommit != newHead {\\n   993→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit (no trailer): updating BaseCommit\\\",\\n   994→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   995→\\t\\t\\t\\tslog.String(\\\"old_base\\\", truncateHash(state.BaseCommit)),\\n   996→\\t\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n   997→\\t\\t\\t)\\n   998→\\t\\t\\tstate.BaseCommit = newHead\\n   999→\\t\\t\\tif err := s.saveSessionState(ctx, state); err != nil {\\n  1000→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to update session state: %v\\\\n\\\", err)\\n  1001→\\t\\t\\t}\\n  1002→\\t\\t}\\n  1003→\\t}\\n  1004→}\\n  1005→\\n  1006→// truncateHash safely truncates a git hash to 7 chars for logging.\\n  1007→func truncateHash(h string) string {\\n  1008→\\tif len(h) > 7 {\\n  1009→\\t\\treturn h[:7]\\n  1010→\\t}\\n  1011→\\treturn h\\n  1012→}\\n  1013→\\n  1014→// filterSessionsWithNewContent returns sessions that have new transcript content\\n  1015→// beyond what was already condensed.\\n  1016→func (s *ManualCommitStrategy) filterSessionsWithNewContent(ctx context.Context, repo *git.Repository, sessions []*SessionState) []*SessionState {\\n  1017→\\tvar result []*SessionState\\n  1018→\\n  1019→\\tfor _, state := range sessions {\\n  1020→\\t\\thasNew, err := s.sessionHasNewContent(ctx, repo, state)\\n  1021→\\t\\tif err != nil {\\n  1022→\\t\\t\\t// On error, include the session (fail open for hooks)\\n  1023→\\t\\t\\tresult = append(result, state)\\n  1024→\\t\\t\\tcontinue\\n  1025→\\t\\t}\\n  1026→\\t\\tif hasNew {\\n  1027→\\t\\t\\tresult = append(result, state)\\n  1028→\\t\\t}\\n  1029→\\t}\\n  1030→\\n  1031→\\treturn result\\n  1032→}\\n  1033→\\n  1034→// sessionHasNewContent checks if a session has new transcript content\\n  1035→// beyond what was already condensed.\\n  1036→// When cachedShadowTree is non-nil, it is used directly to avoid redundant\\n  1037→// shadow branch resolution (the shadow ref/commit/tree were already resolved by the caller).\\n  1038→func (s *ManualCommitStrategy) sessionHasNewContent(ctx context.Context, repo *git.Repository, state *SessionState, cachedShadowTree ...*object.Tree) (bool, error) {\\n  1039→\\tlogCtx := logging.WithComponent(ctx, \\\"manual-commit\\\")\\n  1040→\\n  1041→\\t// Use cached shadow tree if provided\\n  1042→\\tvar tree *object.Tree\\n  1043→\\tif len(cachedShadowTree) > 0 && cachedShadowTree[0] != nil {\\n  1044→\\t\\ttree = cachedShadowTree[0]\\n  1045→\\t} else {\\n  1046→\\t\\t// Resolve shadow branch from repo\\n  1047→\\t\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n  1048→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1049→\\t\\tref, err := repo.Reference(refName, true)\\n  1050→\\t\\tif err != nil {\\n  1051→\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no shadow branch, checking live transcript\\\",\\n  1052→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1053→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n  1054→\\t\\t\\t)\\n  1055→\\t\\t\\treturn s.sessionHasNewContentFromLiveTranscript(ctx, repo, state)\\n  1056→\\t\\t}\\n  1057→\\n  1058→\\t\\tcommit, err := repo.CommitObject(ref.Hash())\\n  1059→\\t\\tif err != nil {\\n  1060→\\t\\t\\treturn false, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n  1061→\\t\\t}\\n  1062→\\n  1063→\\t\\ttree, err = commit.Tree()\\n  1064→\\t\\tif err != nil {\\n  1065→\\t\\t\\treturn false, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n  1066→\\t\\t}\\n  1067→\\t}\\n  1068→\\n  1069→\\t// Look for transcript file\\n  1070→\\tmetadataDir := paths.EntireMetadataDir + \\\"/\\\" + state.SessionID\\n  1071→\\tvar transcriptLines int\\n  1072→\\tvar hasTranscriptFile bool\\n  1073→\\n  1074→\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n  1075→\\t\\thasTranscriptFile = true\\n  1076→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n  1077→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n  1078→\\t\\t}\\n  1079→\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n  1080→\\t\\thasTranscriptFile = true\\n  1081→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n  1082→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n  1083→\\t\\t}\\n  1084→\\t}\\n  1085→\\n  1086→\\t// If shadow branch exists but has no transcript (e.g., carry-forward from mid-session commit),\\n  1087→\\t// check if the session has FilesTouched. Carry-forward sets FilesTouched with remaining files.\\n  1088→\\tif !hasTranscriptFile {\\n  1089→\\t\\tif len(state.FilesTouched) > 0 {\\n  1090→\\t\\t\\t// Shadow branch has files from carry-forward - check if staged files overlap\\n  1091→\\t\\t\\t// AND have matching content (content-aware check).\\n  1092→\\t\\t\\tstagedFiles := getStagedFiles(repo)\\n  1093→\\t\\t\\tif len(stagedFiles) > 0 {\\n  1094→\\t\\t\\t\\t// PrepareCommitMsg context: check staged files overlap with content\\n  1095→\\t\\t\\t\\tresult := stagedFilesOverlapWithContent(ctx, repo, tree, stagedFiles, state.FilesTouched)\\n  1096→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript, carry-forward with staged files\\\",\\n  1097→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1098→\\t\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n  1099→\\t\\t\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1100→\\t\\t\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n  1101→\\t\\t\\t\\t)\\n  1102→\\t\\t\\t\\treturn result, nil\\n  1103→\\t\\t\\t}\\n  1104→\\t\\t\\t// PostCommit context: no staged files, but we have carry-forward files.\\n  1105→\\t\\t\\t// Return true and let the caller do the overlap check with committed files.\\n  1106→\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript, carry-forward without staged files (post-commit context)\\\",\\n  1107→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1108→\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n  1109→\\t\\t\\t)\\n  1110→\\t\\t\\treturn true, nil\\n  1111→\\t\\t}\\n  1112→\\t\\t// No transcript and no FilesTouched - fall back to live transcript check\\n  1113→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript and no files touched, checking live transcript\\\",\\n  1114→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1115→\\t\\t)\\n  1116→\\t\\treturn s.sessionHasNewContentFromLiveTranscript(ctx, repo, state)\\n  1117→\\t}\\n  1118→\\n  1119→\\t// Check if there's new content to condense. Two cases:\\n  1120→\\t// 1. Transcript has grown since last condensation (new prompts/responses)\\n  1121→\\t// 2. FilesTouched has files not yet committed (carry-forward scenario)\\n  1122→\\t//\\n  1123→\\t// For PrepareCommitMsg context, we verify staged files overlap with session's files\\n  1124→\\t// using content-aware matching to detect reverted files.\\n  1125→\\t// For PostCommit context, getStagedFiles() is empty (files already committed),\\n  1126→\\t// so we return true and let the caller do the overlap check via filesOverlapWithContent.\\n  1127→\\n  1128→\\thasTranscriptGrowth := transcriptLines > state.CheckpointTranscriptStart\\n  1129→\\thasUncommittedFiles := len(state.FilesTouched) > 0\\n  1130→\\n  1131→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: transcript check\\\",\\n  1132→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1133→\\t\\tslog.Int(\\\"transcript_lines\\\", transcriptLines),\\n  1134→\\t\\tslog.Int(\\\"checkpoint_transcript_start\\\", state.CheckpointTranscriptStart),\\n  1135→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1136→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1137→\\t)\\n  1138→\\n  1139→\\tif !hasTranscriptGrowth && !hasUncommittedFiles {\\n  1140→\\t\\treturn false, nil // No new content and no carry-forward files\\n  1141→\\t}\\n  1142→\\n  1143→\\t// Check if staged files overlap with session's files with content-aware matching.\\n  1144→\\t// This is primarily for PrepareCommitMsg; in PostCommit, stagedFiles is empty.\\n  1145→\\tstagedFiles := getStagedFiles(repo)\\n  1146→\\tif len(stagedFiles) > 0 {\\n  1147→\\t\\tresult := stagedFilesOverlapWithContent(ctx, repo, tree, stagedFiles, state.FilesTouched)\\n  1148→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: staged files overlap check\\\",\\n  1149→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1150→\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1151→\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n  1152→\\t\\t)\\n  1153→\\t\\treturn result, nil\\n  1154→\\t}\\n  1155→\\n  1156→\\t// No staged files - either PostCommit context or edge case.\\n  1157→\\t// Return transcript growth status. For PostCommit with hasTranscriptFile=true,\\n  1158→\\t// if there's no transcript growth, the session hasn't done new work since last checkpoint.\\n  1159→\\t// (Carry-forward creates a shadow branch WITHOUT transcript, handled in the block above.)\\n  1160→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no staged files, returning transcript growth\\\",\\n  1161→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1162→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1163→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1164→\\t)\\n  1165→\\treturn hasTranscriptGrowth, nil\\n  1166→}\\n  1167→\\n  1168→// sessionHasNewContentFromLiveTranscript checks if a session has new content\\n  1169→// by examining the live transcript file. This is used when no shadow branch exists\\n  1170→// (i.e., no Stop has happened yet) but the agent may have done work.\\n  1171→//\\n  1172→// Returns true if:\\n  1173→//  1. The transcript has grown since the last condensation, AND\\n  1174→//  2. The new transcript portion contains file modifications, AND\\n  1175→//  3. At least one modified file overlaps with the currently staged files\\n  1176→//\\n  1177→// The overlap check ensures we don't add checkpoint trailers to commits that are\\n  1178→// unrelated to the agent's recent changes.\\n  1179→//\\n  1180→// This handles the scenario where the agent commits mid-session before Stop.\\n  1181→func (s *ManualCommitStrategy) sessionHasNewContentFromLiveTranscript(ctx context.Context, repo *git.Repository, state *SessionState) (bool, error) {\\n  1182→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n  1183→\\n  1184→\\tmodifiedFiles, ok := s.extractNewModifiedFilesFromLiveTranscript(ctx, state)\\n  1185→\\tif !ok || len(modifiedFiles) == 0 {\\n  1186→\\t\\treturn false, nil\\n  1187→\\t}\\n  1188→\\n  1189→\\tlogging.Debug(logCtx, \\\"live transcript check: found file modifications\\\",\\n  1190→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1191→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1192→\\t)\\n  1193→\\n  1194→\\t// Check if any modified files overlap with currently staged files\\n  1195→\\t// This ensures we only add checkpoint trailers to commits that include\\n  1196→\\t// files the agent actually modified\\n  1197→\\tstagedFiles := getStagedFiles(repo)\\n  1198→\\n  1199→\\tlogging.Debug(logCtx, \\\"live transcript check: comparing staged vs modified\\\",\\n  1200→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1201→\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1202→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1203→\\t)\\n  1204→\\n  1205→\\tif !hasOverlappingFiles(stagedFiles, modifiedFiles) {\\n  1206→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no overlap between staged and modified files\\\",\\n  1207→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1208→\\t\\t)\\n  1209→\\t\\treturn false, nil // No overlap - staged files are unrelated to agent's work\\n  1210→\\t}\\n  1211→\\n  1212→\\treturn true, nil\\n  1213→}\\n  1214→\\n  1215→// extractFilesFromLiveTranscript extracts modified file paths from the live transcript.\\n  1216→// Returns empty slice if extraction fails (fail-open behavior for hooks).\\n  1217→// Extracts files from the transcript starting at CheckpointTranscriptStart, which gives\\n  1218→// files touched since the last condensation — used for carry-forward computation.\\n  1219→func (s *ManualCommitStrategy) extractFilesFromLiveTranscript(ctx context.Context, state *SessionState) []string {\\n  1220→\\treturn s.extractModifiedFilesFromLiveTranscript(ctx, state, state.CheckpointTranscriptStart)\\n  1221→}\\n  1222→\\n  1223→// extractNewModifiedFilesFromLiveTranscript extracts modified files from the live\\n  1224→// transcript that are NEW since the last condensation. Returns the normalized file list\\n  1225→// and whether the extraction succeeded. Used by sessionHasNewContentFromLiveTranscript\\n  1226→// to detect agent work.\\n  1227→func (s *ManualCommitStrategy) extractNewModifiedFilesFromLiveTranscript(ctx context.Context, state *SessionState) ([]string, bool) {\\n  1228→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n  1229→\\n  1230→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1231→\\t\\treturn nil, false\\n  1232→\\t}\\n  1233→\\n  1234→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1235→\\tif err != nil {\\n  1236→\\t\\treturn nil, false\\n  1237→\\t}\\n  1238→\\n  1239→\\t// Ensure transcript file is up-to-date (OpenCode creates/refreshes it via `opencode export`).\\n  1240→\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n  1241→\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n  1242→\\t// Skipping the wait avoids a 3s timeout per session in prepare-commit-msg/post-commit hooks.\\n  1243→\\tif state.Phase.IsActive() {\\n  1244→\\t\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n  1245→\\t\\t\\tif prepErr := preparer.PrepareTranscript(ctx, state.TranscriptPath); prepErr != nil {\\n  1246→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prepare transcript failed\\\",\\n  1247→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1248→\\t\\t\\t\\t\\tslog.String(\\\"agent_type\\\", string(state.AgentType)),\\n  1249→\\t\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1250→\\t\\t\\t\\t\\tslog.Any(\\\"error\\\", prepErr),\\n  1251→\\t\\t\\t\\t)\\n  1252→\\t\\t\\t}\\n  1253→\\t\\t}\\n  1254→\\t}\\n  1255→\\n  1256→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1257→\\tif !ok {\\n  1258→\\t\\treturn nil, false\\n  1259→\\t}\\n  1260→\\n  1261→\\t// Check if transcript has grown since last condensation\\n  1262→\\tcurrentPos, err := analyzer.GetTranscriptPosition(state.TranscriptPath)\\n  1263→\\tif err != nil {\\n  1264→\\t\\treturn nil, false\\n  1265→\\t}\\n  1266→\\tif currentPos <= state.CheckpointTranscriptStart {\\n  1267→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no new content\\\",\\n  1268→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1269→\\t\\t\\tslog.Int(\\\"current_pos\\\", currentPos),\\n  1270→\\t\\t\\tslog.Int(\\\"start_offset\\\", state.CheckpointTranscriptStart),\\n  1271→\\t\\t)\\n  1272→\\t\\treturn nil, true // No new content, but extraction succeeded\\n  1273→\\t}\\n  1274→\\n  1275→\\treturn s.extractModifiedFilesFromLiveTranscript(ctx, state, state.CheckpointTranscriptStart), true\\n  1276→}\\n  1277→\\n  1278→// extractModifiedFilesFromLiveTranscript extracts modified files from the live transcript\\n  1279→// (including subagent transcripts) starting from the given offset, and normalizes them\\n  1280→// to repo-relative paths. Returns the normalized file list.\\n  1281→func (s *ManualCommitStrategy) extractModifiedFilesFromLiveTranscript(ctx context.Context, state *SessionState, offset int) []string {\\n  1282→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n  1283→\\n  1284→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1285→\\t\\treturn nil\\n  1286→\\t}\\n  1287→\\n  1288→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1289→\\tif err != nil {\\n  1290→\\t\\treturn nil\\n  1291→\\t}\\n  1292→\\n  1293→\\t// Ensure transcript file is up-to-date (OpenCode creates/refreshes it via `opencode export`).\\n  1294→\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n  1295→\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n  1296→\\tif state.Phase.IsActive() {\\n  1297→\\t\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n  1298→\\t\\t\\tif prepErr := preparer.PrepareTranscript(ctx, state.TranscriptPath); prepErr != nil {\\n  1299→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prepare transcript failed\\\",\\n  1300→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1301→\\t\\t\\t\\t\\tslog.String(\\\"agent_type\\\", string(state.AgentType)),\\n  1302→\\t\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1303→\\t\\t\\t\\t\\tslog.Any(\\\"error\\\", prepErr),\\n  1304→\\t\\t\\t\\t)\\n  1305→\\t\\t\\t}\\n  1306→\\t\\t}\\n  1307→\\t}\\n  1308→\\n  1309→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1310→\\tif !ok {\\n  1311→\\t\\treturn nil\\n  1312→\\t}\\n  1313→\\n  1314→\\tvar modifiedFiles []string\\n  1315→\\n  1316→\\t// For Claude Code, use ExtractAllModifiedFiles which parses the main transcript\\n  1317→\\t// AND subagent transcripts in a single pass, avoiding redundant parsing.\\n  1318→\\tif state.AgentType == agent.AgentTypeClaudeCode {\\n  1319→\\t\\tsubagentsDir := filepath.Join(filepath.Dir(state.TranscriptPath), state.SessionID, \\\"subagents\\\")\\n  1320→\\t\\ttranscriptData, readErr := os.ReadFile(state.TranscriptPath)\\n  1321→\\t\\tif readErr != nil {\\n  1322→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: failed to read transcript\\\",\\n  1323→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1324→\\t\\t\\t\\tslog.String(\\\"error\\\", readErr.Error()),\\n  1325→\\t\\t\\t)\\n  1326→\\t\\t} else {\\n  1327→\\t\\t\\t// TODO: fix when we refactor this area.\\n  1328→\\t\\t\\t// rather than instantiating claude specifically, we should iterate agents.\\n  1329→\\t\\t\\tc := &claudecode.ClaudeCodeAgent{}\\n  1330→\\t\\t\\tallFiles, extractErr := c.ExtractAllModifiedFiles(transcriptData, offset, subagentsDir)\\n  1331→\\t\\t\\tif extractErr != nil {\\n  1332→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: extraction failed\\\",\\n  1333→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1334→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", extractErr.Error()),\\n  1335→\\t\\t\\t\\t)\\n  1336→\\t\\t\\t} else {\\n  1337→\\t\\t\\t\\tmodifiedFiles = allFiles\\n  1338→\\t\\t\\t}\\n  1339→\\t\\t}\\n  1340→\\t} else {\\n  1341→\\t\\tfiles, _, err := analyzer.ExtractModifiedFilesFromOffset(state.TranscriptPath, offset)\\n  1342→\\t\\tif err != nil {\\n  1343→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: main transcript extraction failed\\\",\\n  1344→\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1345→\\t\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1346→\\t\\t\\t)\\n  1347→\\t\\t} else {\\n  1348→\\t\\t\\tmodifiedFiles = files\\n  1349→\\t\\t}\\n  1350→\\t}\\n  1351→\\n  1352→\\tif len(modifiedFiles) == 0 {\\n  1353→\\t\\treturn nil\\n  1354→\\t}\\n  1355→\\n  1356→\\t// Normalize to repo-relative paths.\\n  1357→\\t// Transcript tool_use entries contain absolute paths (e.g., /Users/alex/project/src/main.go)\\n  1358→\\t// but getStagedFiles/committedFiles use repo-relative paths (e.g., src/main.go).\\n  1359→\\tbasePath := state.WorktreePath\\n  1360→\\tif basePath == \\\"\\\" {\\n  1361→\\t\\tif wp, wpErr := paths.WorktreeRoot(ctx); wpErr == nil {\\n  1362→\\t\\t\\tbasePath = wp\\n  1363→\\t\\t}\\n  1364→\\t}\\n  1365→\\tif basePath != \\\"\\\" {\\n  1366→\\t\\tnormalized := make([]string, 0, len(modifiedFiles))\\n  1367→\\t\\tfor _, f := range modifiedFiles {\\n  1368→\\t\\t\\tif rel := paths.ToRelativePath(f, basePath); rel != \\\"\\\" {\\n  1369→\\t\\t\\t\\tnormalized = append(normalized, rel)\\n  1370→\\t\\t\\t} else {\\n  1371→\\t\\t\\t\\tnormalized = append(normalized, f)\\n  1372→\\t\\t\\t}\\n  1373→\\t\\t}\\n  1374→\\t\\tmodifiedFiles = normalized\\n  1375→\\t}\\n  1376→\\n  1377→\\treturn modifiedFiles\\n  1378→}\\n  1379→\\n  1380→// addTrailerForAgentCommit handles the fast path when an agent is committing\\n  1381→// (ACTIVE session + no TTY). Generates a checkpoint ID and adds the trailer\\n  1382→// directly, bypassing content detection and interactive prompts.\\n  1383→func (s *ManualCommitStrategy) addTrailerForAgentCommit(logCtx context.Context, commitMsgFile string, state *SessionState, source string) error {\\n  1384→\\tcpID, err := id.Generate()\\n  1385→\\tif err != nil {\\n  1386→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1387→\\t}\\n  1388→\\n  1389→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n  1390→\\tif err != nil {\\n  1391→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1392→\\t}\\n  1393→\\n  1394→\\tmessage := string(content)\\n  1395→\\n  1396→\\t// Don't add if trailer already exists\\n  1397→\\tif _, found := trailers.ParseCheckpoint(message); found {\\n  1398→\\t\\treturn nil\\n  1399→\\t}\\n  1400→\\n  1401→\\tmessage = addCheckpointTrailer(message, cpID)\\n  1402→\\n  1403→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: agent commit trailer added\\\",\\n  1404→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n  1405→\\t\\tslog.String(\\\"source\\\", source),\\n  1406→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n  1407→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1408→\\t)\\n  1409→\\n  1410→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n  1411→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1412→\\t}\\n  1413→\\treturn nil\\n  1414→}\\n  1415→\\n  1416→// addCheckpointTrailer adds the Entire-Checkpoint trailer to a commit message.\\n  1417→// Handles proper trailer formatting (blank line before trailers if needed).\\n  1418→func addCheckpointTrailer(message string, checkpointID id.CheckpointID) string {\\n  1419→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1420→\\n  1421→\\t// If message already ends with trailers (lines starting with key:), just append\\n  1422→\\t// Otherwise, add a blank line first\\n  1423→\\tlines := strings.Split(strings.TrimRight(message, \\\"\\\\n\\\"), \\\"\\\\n\\\")\\n  1424→\\n  1425→\\t// Check if the message already ends with a trailer paragraph.\\n  1426→\\t// Git trailers must be in a separate paragraph (preceded by a blank line).\\n  1427→\\t// A single-paragraph message (e.g., just a subject line) cannot have trailers,\\n  1428→\\t// even if the subject contains \\\": \\\" (like conventional commits: \\\"docs: Add foo\\\").\\n  1429→\\t//\\n  1430→\\t// Scan from the bottom: find the last paragraph of non-comment content,\\n  1431→\\t// then check if it looks like trailers AND has a blank line above it.\\n  1432→\\thasTrailers := false\\n  1433→\\ti := len(lines) - 1\\n  1434→\\n  1435→\\t// Skip trailing comment lines\\n  1436→\\tfor i >= 0 && strings.HasPrefix(strings.TrimSpace(lines[i]), \\\"#\\\") {\\n  1437→\\t\\ti--\\n  1438→\\t}\\n  1439→\\n  1440→\\t// Check if the last non-comment line looks like a trailer\\n  1441→\\tif i >= 0 {\\n  1442→\\t\\tline := strings.TrimSpace(lines[i])\\n  1443→\\t\\tif line != \\\"\\\" && strings.Contains(line, \\\": \\\") {\\n  1444→\\t\\t\\t// Found a trailer-like line. Now scan upward past the trailer block\\n  1445→\\t\\t\\t// to verify there's a blank line (paragraph separator) above it.\\n  1446→\\t\\t\\tfor i > 0 {\\n  1447→\\t\\t\\t\\ti--\\n  1448→\\t\\t\\t\\tabove := strings.TrimSpace(lines[i])\\n  1449→\\t\\t\\t\\tif strings.HasPrefix(above, \\\"#\\\") {\\n  1450→\\t\\t\\t\\t\\tcontinue\\n  1451→\\t\\t\\t\\t}\\n  1452→\\t\\t\\t\\tif above == \\\"\\\" {\\n  1453→\\t\\t\\t\\t\\t// Blank line found above trailer block — real trailers\\n  1454→\\t\\t\\t\\t\\thasTrailers = true\\n  1455→\\t\\t\\t\\t\\tbreak\\n  1456→\\t\\t\\t\\t}\\n  1457→\\t\\t\\t\\tif !strings.Contains(above, \\\": \\\") {\\n  1458→\\t\\t\\t\\t\\t// Non-trailer, non-blank line — this is message body, not trailers\\n  1459→\\t\\t\\t\\t\\tbreak\\n  1460→\\t\\t\\t\\t}\\n  1461→\\t\\t\\t\\t// Another trailer-like line, keep scanning upward\\n  1462→\\t\\t\\t}\\n  1463→\\t\\t}\\n  1464→\\t}\\n  1465→\\n  1466→\\tif hasTrailers {\\n  1467→\\t\\t// Append trailer directly\\n  1468→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1469→\\t}\\n  1470→\\n  1471→\\t// Add blank line before trailer\\n  1472→\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1473→}\\n  1474→\\n  1475→// addCheckpointTrailerWithComment adds the Entire-Checkpoint trailer with an explanatory comment.\\n  1476→// The trailer is placed above the git comment block but below the user's message area,\\n  1477→// with a comment explaining that the user can remove it if they don't want to link the commit\\n  1478→// to the agent session. If prompt is non-empty, it's shown as context.\\n  1479→func addCheckpointTrailerWithComment(message string, checkpointID id.CheckpointID, agentName, prompt string) string {\\n  1480→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1481→\\tcommentLines := []string{\\n  1482→\\t\\t\\\"# Remove the Entire-Checkpoint trailer above if you don't want to link this commit to \\\" + agentName + \\\" session context.\\\",\\n  1483→\\t}\\n  1484→\\tif prompt != \\\"\\\" {\\n  1485→\\t\\tcommentLines = append(commentLines, \\\"# Last Prompt: \\\"+prompt)\\n  1486→\\t}\\n  1487→\\tcommentLines = append(commentLines, \\\"# The trailer will be added to your next commit based on this branch.\\\")\\n  1488→\\tcomment := strings.Join(commentLines, \\\"\\\\n\\\")\\n  1489→\\n  1490→\\tlines := strings.Split(message, \\\"\\\\n\\\")\\n  1491→\\n  1492→\\t// Find where the git comment block starts (first # line)\\n  1493→\\tcommentStart := -1\\n  1494→\\tfor i, line := range lines {\\n  1495→\\t\\tif strings.HasPrefix(line, \\\"#\\\") {\\n  1496→\\t\\t\\tcommentStart = i\\n  1497→\\t\\t\\tbreak\\n  1498→\\t\\t}\\n  1499→\\t}\\n  1500→\\n  1501→\\tif commentStart == -1 {\\n  1502→\\t\\t// No git comments, append trailer at the end\\n  1503→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\"\\n  1504→\\t}\\n  1505→\\n  1506→\\t// Split into user content and git comments\\n  1507→\\tuserContent := strings.Join(lines[:commentStart], \\\"\\\\n\\\")\\n  1508→\\tgitComments := strings.Join(lines[commentStart:], \\\"\\\\n\\\")\\n  1509→\\n  1510→\\t// Build result: user content, blank line, trailer, comment, blank line, git comments\\n  1511→\\tuserContent = strings.TrimRight(userContent, \\\"\\\\n\\\")\\n  1512→\\tif userContent == \\\"\\\" {\\n  1513→\\t\\t// No user content yet - leave space for them to type, then trailer\\n  1514→\\t\\t// Two newlines: first for user's message line, second for blank separator\\n  1515→\\t\\treturn \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1516→\\t}\\n  1517→\\treturn userContent + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1518→}\\n  1519→\\n  1520→// InitializeSession creates session state for a new session or updates an existing one.\\n  1521→// This implements the optional SessionInitializer interface.\\n  1522→// Called during UserPromptSubmit to allow git hooks to detect active sessions.\\n  1523→//\\n  1524→// If the session already exists and HEAD has moved (e.g., user committed), updates\\n  1525→// BaseCommit to the new HEAD so future checkpoints go to the correct shadow branch.\\n  1526→//\\n  1527→// If there's an existing shadow branch with commits from a different session ID,\\n  1528→// returns a SessionIDConflictError to prevent orphaning existing session work.\\n  1529→//\\n  1530→// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n  1531→// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n  1532→// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\n  1533→func (s *ManualCommitStrategy) InitializeSession(ctx context.Context, sessionID string, agentType agent.AgentType, transcriptPath string, userPrompt string) error {\\n  1534→\\trepo, err := OpenRepository(ctx)\\n  1535→\\tif err != nil {\\n  1536→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n  1537→\\t}\\n  1538→\\n  1539→\\t// Check if session already exists\\n  1540→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n  1541→\\tif err != nil {\\n  1542→\\t\\treturn fmt.Errorf(\\\"failed to check session state: %w\\\", err)\\n  1543→\\t}\\n  1544→\\n  1545→\\tif state != nil && state.BaseCommit != \\\"\\\" {\\n  1546→\\t\\t// Session is fully initialized — apply phase transition for TurnStart.\\n  1547→\\t\\tif transErr := TransitionAndLog(ctx, state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1548→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1549→\\t\\t}\\n  1550→\\n  1551→\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n  1552→\\t\\tturnID, err := id.Generate()\\n  1553→\\t\\tif err != nil {\\n  1554→\\t\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n  1555→\\t\\t}\\n  1556→\\t\\tstate.TurnID = turnID.String()\\n  1557→\\n  1558→\\t\\t// Set AgentType from hook context if not yet set\\n  1559→\\t\\tif state.AgentType == \\\"\\\" && agentType != \\\"\\\" {\\n  1560→\\t\\t\\tstate.AgentType = agentType\\n  1561→\\t\\t}\\n  1562→\\n  1563→\\t\\t// Backfill FirstPrompt if empty (for sessions created before the first_prompt field was added)\\n  1564→\\t\\tif state.FirstPrompt == \\\"\\\" && userPrompt != \\\"\\\" {\\n  1565→\\t\\t\\tstate.FirstPrompt = truncatePromptForStorage(userPrompt)\\n  1566→\\t\\t}\\n  1567→\\n  1568→\\t\\t// Update transcript path if provided (may change on session resume)\\n  1569→\\t\\tif transcriptPath != \\\"\\\" && state.TranscriptPath != transcriptPath {\\n  1570→\\t\\t\\tstate.TranscriptPath = transcriptPath\\n  1571→\\t\\t}\\n  1572→\\n  1573→\\t\\t// Clear checkpoint IDs on every new prompt.\\n  1574→\\t\\t// LastCheckpointID is set during PostCommit, cleared at new prompt.\\n  1575→\\t\\t// TurnCheckpointIDs tracks mid-turn checkpoints for stop-time finalization.\\n  1576→\\t\\tstate.LastCheckpointID = \\\"\\\"\\n  1577→\\t\\tstate.TurnCheckpointIDs = nil\\n  1578→\\n  1579→\\t\\t// Calculate attribution at prompt start (BEFORE agent makes any changes)\\n  1580→\\t\\t// This captures user edits since the last checkpoint (or base commit for first prompt).\\n  1581→\\t\\t// IMPORTANT: Always calculate attribution, even for the first checkpoint, to capture\\n  1582→\\t\\t// user edits made before the first prompt. The inner CalculatePromptAttribution handles\\n  1583→\\t\\t// nil lastCheckpointTree by falling back to baseTree.\\n  1584→\\t\\tpromptAttr := s.calculatePromptAttributionAtStart(ctx, repo, state)\\n  1585→\\t\\tstate.PendingPromptAttribution = &promptAttr\\n  1586→\\n  1587→\\t\\t// Check if HEAD has moved (user pulled/rebased or committed)\\n  1588→\\t\\t// migrateShadowBranchIfNeeded handles renaming the shadow branch and updating state.BaseCommit\\n  1589→\\t\\tif _, err := s.migrateShadowBranchIfNeeded(ctx, repo, state); err != nil {\\n  1590→\\t\\t\\treturn fmt.Errorf(\\\"failed to check/migrate shadow branch: %w\\\", err)\\n  1591→\\t\\t}\\n  1592→\\n  1593→\\t\\tif err := s.saveSessionState(ctx, state); err != nil {\\n  1594→\\t\\t\\treturn fmt.Errorf(\\\"failed to update session state: %w\\\", err)\\n  1595→\\t\\t}\\n  1596→\\t\\treturn nil\\n  1597→\\t}\\n  1598→\\t// If state exists but BaseCommit is empty, it's a partial state from concurrent warning\\n  1599→\\t// Continue below to properly initialize it\\n  1600→\\n  1601→\\t// Initialize new session\\n  1602→\\tstate, err = s.initializeSession(ctx, repo, sessionID, agentType, transcriptPath, userPrompt)\\n  1603→\\tif err != nil {\\n  1604→\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n  1605→\\t}\\n  1606→\\n  1607→\\t// Apply phase transition: new session starts as ACTIVE.\\n  1608→\\tif transErr := TransitionAndLog(ctx, state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1609→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1610→\\t}\\n  1611→\\n  1612→\\t// Calculate attribution for pre-prompt edits\\n  1613→\\t// This captures any user edits made before the first prompt\\n  1614→\\tpromptAttr := s.calculatePromptAttributionAtStart(ctx, repo, state)\\n  1615→\\tstate.PendingPromptAttribution = &promptAttr\\n  1616→\\tif err = s.saveSessionState(ctx, state); err != nil {\\n  1617→\\t\\treturn fmt.Errorf(\\\"failed to save attribution: %w\\\", err)\\n  1618→\\t}\\n  1619→\\n  1620→\\tfmt.Fprintf(os.Stderr, \\\"Initialized shadow session: %s\\\\n\\\", sessionID)\\n  1621→\\treturn nil\\n  1622→}\\n  1623→\\n  1624→// calculatePromptAttributionAtStart calculates attribution at prompt start (before agent runs).\\n  1625→// This captures user changes since the last checkpoint - no filtering needed since\\n  1626→// the agent hasn't made any changes yet.\\n  1627→//\\n  1628→// IMPORTANT: This reads from the worktree (not staging area) to match what WriteTemporary\\n  1629→// captures in checkpoints. If we read staged content but checkpoints capture worktree content,\\n  1630→// unstaged changes would be in the checkpoint but not counted in PromptAttribution, causing\\n  1631→// them to be incorrectly attributed to the agent later.\\n  1632→func (s *ManualCommitStrategy) calculatePromptAttributionAtStart(\\n  1633→\\tctx context.Context,\\n  1634→\\trepo *git.Repository,\\n  1635→\\tstate *SessionState,\\n  1636→) PromptAttribution {\\n  1637→\\tlogCtx := logging.WithComponent(ctx, \\\"attribution\\\")\\n  1638→\\tnextCheckpointNum := state.StepCount + 1\\n  1639→\\tresult := PromptAttribution{CheckpointNumber: nextCheckpointNum}\\n  1640→\\n  1641→\\t// Get last checkpoint tree from shadow branch (if it exists)\\n  1642→\\t// For the first checkpoint, no shadow branch exists yet - this is fine,\\n  1643→\\t// CalculatePromptAttribution will use baseTree as the reference instead.\\n  1644→\\tvar lastCheckpointTree *object.Tree\\n  1645→\\tshadowBranchName := checkpoint.ShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n  1646→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1647→\\tref, err := repo.Reference(refName, true)\\n  1648→\\tif err != nil {\\n  1649→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: no shadow branch yet (first checkpoint)\\\",\\n  1650→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName))\\n  1651→\\t\\t// Continue with lastCheckpointTree = nil\\n  1652→\\t} else {\\n  1653→\\t\\tshadowCommit, err := repo.CommitObject(ref.Hash())\\n  1654→\\t\\tif err != nil {\\n  1655→\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: failed to get shadow commit\\\",\\n  1656→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", ref.Hash().String()),\\n  1657→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1658→\\t\\t\\t// Continue with lastCheckpointTree = nil\\n  1659→\\t\\t} else {\\n  1660→\\t\\t\\tlastCheckpointTree, err = shadowCommit.Tree()\\n  1661→\\t\\t\\tif err != nil {\\n  1662→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: failed to get shadow tree\\\",\\n  1663→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1664→\\t\\t\\t\\t// Continue with lastCheckpointTree = nil\\n  1665→\\t\\t\\t}\\n  1666→\\t\\t}\\n  1667→\\t}\\n  1668→\\n  1669→\\t// Get base tree for agent lines calculation\\n  1670→\\tvar baseTree *object.Tree\\n  1671→\\tif baseCommit, err := repo.CommitObject(plumbing.NewHash(state.BaseCommit)); err == nil {\\n  1672→\\t\\tif tree, treeErr := baseCommit.Tree(); treeErr == nil {\\n  1673→\\t\\t\\tbaseTree = tree\\n  1674→\\t\\t} else {\\n  1675→\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: base tree unavailable\\\",\\n  1676→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n  1677→\\t\\t}\\n  1678→\\t} else {\\n  1679→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: base commit unavailable\\\",\\n  1680→\\t\\t\\tslog.String(\\\"base_commit\\\", state.BaseCommit),\\n  1681→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1682→\\t}\\n  1683→\\n  1684→\\tworktree, err := repo.Worktree()\\n  1685→\\tif err != nil {\\n  1686→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution skipped: failed to get worktree\\\",\\n  1687→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1688→\\t\\treturn result\\n  1689→\\t}\\n  1690→\\n  1691→\\t// Get worktree status to find ALL changed files\\n  1692→\\tstatus, err := worktree.Status()\\n  1693→\\tif err != nil {\\n  1694→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution skipped: failed to get worktree status\\\",\\n  1695→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1696→\\t\\treturn result\\n  1697→\\t}\\n  1698→\\n  1699→\\tworktreeRoot := worktree.Filesystem.Root()\\n  1700→\\n  1701→\\t// Build map of changed files with their worktree content\\n  1702→\\t// IMPORTANT: We read from worktree (not staging area) to match what WriteTemporary\\n  1703→\\t// captures in checkpoints. This ensures attribution is consistent.\\n  1704→\\tchangedFiles := make(map[string]string)\\n  1705→\\tfor filePath, fileStatus := range status {\\n  1706→\\t\\t// Skip unmodified files\\n  1707→\\t\\tif fileStatus.Worktree == git.Unmodified && fileStatus.Staging == git.Unmodified {\\n  1708→\\t\\t\\tcontinue\\n  1709→\\t\\t}\\n  1710→\\t\\t// Skip .entire metadata directory (session data, not user code)\\n  1711→\\t\\tif strings.HasPrefix(filePath, paths.EntireMetadataDir+\\\"/\\\") || strings.HasPrefix(filePath, \\\".entire/\\\") {\\n  1712→\\t\\t\\tcontinue\\n  1713→\\t\\t}\\n  1714→\\n  1715→\\t\\t// Always read from worktree to match checkpoint behavior\\n  1716→\\t\\tfullPath := filepath.Join(worktreeRoot, filePath)\\n  1717→\\t\\tvar content string\\n  1718→\\t\\tif data, err := os.ReadFile(fullPath); err == nil { //nolint:gosec // filePath is from git worktree status\\n  1719→\\t\\t\\t// Use git's binary detection algorithm (matches getFileContent behavior).\\n  1720→\\t\\t\\t// Binary files are excluded from line-based attribution calculations.\\n  1721→\\t\\t\\tisBinary, binErr := binary.IsBinary(bytes.NewReader(data))\\n  1722→\\t\\t\\tif binErr == nil && !isBinary {\\n  1723→\\t\\t\\t\\tcontent = string(data)\\n  1724→\\t\\t\\t}\\n  1725→\\t\\t}\\n  1726→\\t\\t// else: file deleted, unreadable, or binary - content remains empty string\\n  1727→\\n  1728→\\t\\tchangedFiles[filePath] = content\\n  1729→\\t}\\n  1730→\\n  1731→\\t// Use CalculatePromptAttribution from manual_commit_attribution.go\\n  1732→\\tresult = CalculatePromptAttribution(baseTree, lastCheckpointTree, changedFiles, nextCheckpointNum)\\n  1733→\\n  1734→\\treturn result\\n  1735→}\\n  1736→\\n  1737→// getStagedFiles returns a list of files staged for commit.\\n  1738→func getStagedFiles(repo *git.Repository) []string {\\n  1739→\\tworktree, err := repo.Worktree()\\n  1740→\\tif err != nil {\\n  1741→\\t\\treturn nil\\n  1742→\\t}\\n  1743→\\n  1744→\\tstatus, err := worktree.Status()\\n  1745→\\tif err != nil {\\n  1746→\\t\\treturn nil\\n  1747→\\t}\\n  1748→\\n  1749→\\tvar staged []string\\n  1750→\\tfor path, fileStatus := range status {\\n  1751→\\t\\t// Check if file is staged (in index)\\n  1752→\\t\\tif fileStatus.Staging != git.Unmodified && fileStatus.Staging != git.Untracked {\\n  1753→\\t\\t\\tstaged = append(staged, path)\\n  1754→\\t\\t}\\n  1755→\\t}\\n  1756→\\treturn staged\\n  1757→}\\n  1758→\\n  1759→// getLastPrompt retrieves the most recent user prompt from a session's shadow branch.\\n  1760→// Returns empty string if no prompt can be retrieved.\\n  1761→func (s *ManualCommitStrategy) getLastPrompt(ctx context.Context, repo *git.Repository, state *SessionState) string {\\n  1762→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n  1763→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1764→\\tref, err := repo.Reference(refName, true)\\n  1765→\\tif err != nil {\\n  1766→\\t\\treturn \\\"\\\"\\n  1767→\\t}\\n  1768→\\n  1769→\\t// Extract session data to get prompts for commit message generation\\n  1770→\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini)\\n  1771→\\t// Pass 0 for checkpointTranscriptStart since we're extracting all prompts, not calculating token usage\\n  1772→\\tsessionData, err := s.extractSessionData(ctx, repo, ref.Hash(), state.SessionID, nil, state.AgentType, \\\"\\\", 0, state.Phase.IsActive())\\n  1773→\\tif err != nil || len(sessionData.Prompts) == 0 {\\n  1774→\\t\\treturn \\\"\\\"\\n  1775→\\t}\\n  1776→\\n  1777→\\t// Return the last prompt (most recent work before commit)\\n  1778→\\treturn sessionData.Prompts[len(sessionData.Prompts)-1]\\n  1779→}\\n  1780→\\n  1781→// HandleTurnEnd dispatches strategy-specific actions emitted when an agent turn ends.\\n  1782→// The primary job is to finalize all checkpoints from this turn with the full transcript.\\n  1783→//\\n  1784→// During a turn, PostCommit writes provisional transcript data (whatever was available\\n  1785→// at commit time). HandleTurnEnd replaces that with the complete session transcript\\n  1786→// (from prompt to stop event), ensuring every checkpoint has the full context.\\n  1787→//\\n  1788→\\n  1789→func (s *ManualCommitStrategy) HandleTurnEnd(ctx context.Context, state *SessionState) error {\\n  1790→\\t// Finalize all checkpoints from this turn with the full transcript.\\n  1791→\\t//\\n  1792→\\t// IMPORTANT: This is best-effort - errors are logged but don't fail the hook.\\n  1793→\\t// Failing here would prevent session cleanup and could leave state inconsistent.\\n  1794→\\t// The provisional transcript from PostCommit is already persisted, so the\\n  1795→\\t// checkpoint isn't lost - it just won't have the complete transcript.\\n  1796→\\terrCount := s.finalizeAllTurnCheckpoints(ctx, state)\\n  1797→\\tif errCount > 0 {\\n  1798→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n  1799→\\t\\tlogging.Warn(logCtx, \\\"HandleTurnEnd completed with errors (best-effort)\\\",\\n  1800→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1801→\\t\\t\\tslog.Int(\\\"error_count\\\", errCount),\\n  1802→\\t\\t)\\n  1803→\\t}\\n  1804→\\treturn nil\\n  1805→}\\n  1806→\\n  1807→// finalizeAllTurnCheckpoints replaces the provisional transcript in each checkpoint\\n  1808→// created during this turn with the full session transcript.\\n  1809→//\\n  1810→// This is called at turn end (stop hook). During the turn, PostCommit wrote whatever\\n  1811→// transcript was available at commit time. Now we have the complete transcript and\\n  1812→// replace it so every checkpoint has the full prompt-to-stop context.\\n  1813→//\\n  1814→// Returns the number of errors encountered (best-effort: continues processing on error).\\n  1815→func (s *ManualCommitStrategy) finalizeAllTurnCheckpoints(ctx context.Context, state *SessionState) int {\\n  1816→\\tif len(state.TurnCheckpointIDs) == 0 {\\n  1817→\\t\\treturn 0 // No mid-turn commits to finalize\\n  1818→\\t}\\n  1819→\\n  1820→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n  1821→\\n  1822→\\tlogging.Info(logCtx, \\\"finalizing turn checkpoints with full transcript\\\",\\n  1823→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1824→\\t\\tslog.Int(\\\"checkpoint_count\\\", len(state.TurnCheckpointIDs)),\\n  1825→\\t)\\n  1826→\\n  1827→\\terrCount := 0\\n  1828→\\n  1829→\\t// Read full transcript from live transcript file\\n  1830→\\tif state.TranscriptPath == \\\"\\\" {\\n  1831→\\t\\tlogging.Warn(logCtx, \\\"finalize: no transcript path, skipping\\\",\\n  1832→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1833→\\t\\t)\\n  1834→\\t\\tstate.TurnCheckpointIDs = nil\\n  1835→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1836→\\t}\\n  1837→\\n  1838→\\tfullTranscript, err := os.ReadFile(state.TranscriptPath)\\n  1839→\\tif err != nil || len(fullTranscript) == 0 {\\n  1840→\\t\\tmsg := \\\"finalize: empty transcript, skipping\\\"\\n  1841→\\t\\tif err != nil {\\n  1842→\\t\\t\\tmsg = \\\"finalize: failed to read transcript, skipping\\\"\\n  1843→\\t\\t}\\n  1844→\\t\\tlogging.Warn(logCtx, msg,\\n  1845→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1846→\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1847→\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1848→\\t\\t)\\n  1849→\\t\\tstate.TurnCheckpointIDs = nil\\n  1850→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1851→\\t}\\n  1852→\\n  1853→\\t// Extract prompts and context from the full transcript\\n  1854→\\tprompts := extractUserPrompts(state.AgentType, string(fullTranscript))\\n  1855→\\tcontextBytes := generateContextFromPrompts(prompts)\\n  1856→\\n  1857→\\t// Redact secrets before writing — matches WriteCommitted behavior.\\n  1858→\\t// The live transcript on disk contains raw content; redaction must happen\\n  1859→\\t// before anything is persisted to the metadata branch.\\n  1860→\\tfullTranscript, err = redact.JSONLBytes(fullTranscript)\\n  1861→\\tif err != nil {\\n  1862→\\t\\tlogging.Warn(logCtx, \\\"finalize: transcript redaction failed, skipping\\\",\\n  1863→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1864→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1865→\\t\\t)\\n  1866→\\t\\tstate.TurnCheckpointIDs = nil\\n  1867→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1868→\\t}\\n  1869→\\tfor i, p := range prompts {\\n  1870→\\t\\tprompts[i] = redact.String(p)\\n  1871→\\t}\\n  1872→\\tcontextBytes = redact.Bytes(contextBytes)\\n  1873→\\n  1874→\\t// Open repository and create checkpoint store\\n  1875→\\trepo, err := OpenRepository(ctx)\\n  1876→\\tif err != nil {\\n  1877→\\t\\tlogging.Warn(logCtx, \\\"finalize: failed to open repository\\\",\\n  1878→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1879→\\t\\t)\\n  1880→\\t\\tstate.TurnCheckpointIDs = nil\\n  1881→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1882→\\t}\\n  1883→\\tstore := checkpoint.NewGitStore(repo)\\n  1884→\\n  1885→\\t// Update each checkpoint with the full transcript\\n  1886→\\tfor _, cpIDStr := range state.TurnCheckpointIDs {\\n  1887→\\t\\tcpID, parseErr := id.NewCheckpointID(cpIDStr)\\n  1888→\\t\\tif parseErr != nil {\\n  1889→\\t\\t\\tlogging.Warn(logCtx, \\\"finalize: invalid checkpoint ID, skipping\\\",\\n  1890→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1891→\\t\\t\\t\\tslog.String(\\\"error\\\", parseErr.Error()),\\n  1892→\\t\\t\\t)\\n  1893→\\t\\t\\terrCount++\\n  1894→\\t\\t\\tcontinue\\n  1895→\\t\\t}\\n  1896→\\n  1897→\\t\\tupdateErr := store.UpdateCommitted(ctx, checkpoint.UpdateCommittedOptions{\\n  1898→\\t\\t\\tCheckpointID: cpID,\\n  1899→\\t\\t\\tSessionID:    state.SessionID,\\n  1900→\\t\\t\\tTranscript:   fullTranscript,\\n  1901→\\t\\t\\tPrompts:      prompts,\\n  1902→\\t\\t\\tContext:      contextBytes,\\n  1903→\\t\\t\\tAgent:        state.AgentType,\\n  1904→\\t\\t})\\n  1905→\\t\\tif updateErr != nil {\\n  1906→\\t\\t\\tlogging.Warn(logCtx, \\\"finalize: failed to update checkpoint\\\",\\n  1907→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1908→\\t\\t\\t\\tslog.String(\\\"error\\\", updateErr.Error()),\\n  1909→\\t\\t\\t)\\n  1910→\\t\\t\\terrCount++\\n  1911→\\t\\t\\tcontinue\\n  1912→\\t\\t}\\n  1913→\\n  1914→\\t\\tlogging.Info(logCtx, \\\"finalize: checkpoint updated with full transcript\\\",\\n  1915→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1916→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1917→\\t\\t)\\n  1918→\\t}\\n  1919→\\n  1920→\\t// Clear turn checkpoint IDs. Do NOT update CheckpointTranscriptStart here — it was\\n  1921→\\t// already set correctly by PostCommit: condenseAndUpdateState sets it to the total\\n  1922→\\t// transcript lines when condensing, and carryForwardToNewShadowBranch resets it to 0\\n  1923→\\t// when carry-forward is active. Overwriting here would break carry-forward by making\\n  1924→\\t// sessionHasNewContent think the transcript is fully consumed (no growth).\\n  1925→\\tstate.TurnCheckpointIDs = nil\\n  1926→\\n  1927→\\treturn errCount\\n  1928→}\\n  1929→\\n  1930→// filesChangedInCommit returns the set of files changed in a commit by diffing against its parent.\\n  1931→// When headTree and parentTree are provided, they are used directly to avoid redundant reads.\\n  1932→func filesChangedInCommit(commit *object.Commit, headTree, parentTree *object.Tree) map[string]struct{} {\\n  1933→\\tresult := make(map[string]struct{})\\n  1934→\\n  1935→\\tcommitTree := headTree\\n  1936→\\tif commitTree == nil {\\n  1937→\\t\\tvar err error\\n  1938→\\t\\tcommitTree, err = commit.Tree()\\n  1939→\\t\\tif err != nil {\\n  1940→\\t\\t\\treturn result\\n  1941→\\t\\t}\\n  1942→\\t}\\n  1943→\\n  1944→\\tif parentTree == nil && commit.NumParents() > 0 {\\n  1945→\\t\\tparent, err := commit.Parent(0)\\n  1946→\\t\\tif err != nil {\\n  1947→\\t\\t\\treturn result\\n  1948→\\t\\t}\\n  1949→\\t\\tparentTree, err = parent.Tree()\\n  1950→\\t\\tif err != nil {\\n  1951→\\t\\t\\treturn result\\n  1952→\\t\\t}\\n  1953→\\t}\\n  1954→\\n  1955→\\tif parentTree == nil {\\n  1956→\\t\\t// Initial commit — all files are new\\n  1957→\\t\\tif iterErr := commitTree.Files().ForEach(func(f *object.File) error {\\n  1958→\\t\\t\\tresult[f.Name] = struct{}{}\\n  1959→\\t\\t\\treturn nil\\n  1960→\\t\\t}); iterErr != nil {\\n  1961→\\t\\t\\treturn result\\n  1962→\\t\\t}\\n  1963→\\t\\treturn result\\n  1964→\\t}\\n  1965→\\n  1966→\\tchanges, err := parentTree.Diff(commitTree)\\n  1967→\\tif err != nil {\\n  1968→\\t\\treturn result\\n  1969→\\t}\\n  1970→\\tfor _, change := range changes {\\n  1971→\\t\\tname := change.To.Name\\n  1972→\\t\\tif name == \\\"\\\" {\\n  1973→\\t\\t\\tname = change.From.Name\\n  1974→\\t\\t}\\n  1975→\\t\\tresult[name] = struct{}{}\\n  1976→\\t}\\n  1977→\\treturn result\\n  1978→}\\n  1979→\\n  1980→// subtractFiles returns files that are NOT in the exclude set.\\n  1981→func subtractFiles(files []string, exclude map[string]struct{}) []string {\\n  1982→\\tvar remaining []string\\n  1983→\\tfor _, f := range files {\\n  1984→\\t\\tif _, excluded := exclude[f]; !excluded {\\n  1985→\\t\\t\\tremaining = append(remaining, f)\\n  1986→\\t\\t}\\n  1987→\\t}\\n  1988→\\treturn remaining\\n  1989→}\\n  1990→\\n  1991→// carryForwardToNewShadowBranch creates a new shadow branch at the current HEAD\\n  1992→// containing the remaining uncommitted files and all session metadata.\\n  1993→// This enables the next commit to get its own unique checkpoint.\\n  1994→func (s *ManualCommitStrategy) carryForwardToNewShadowBranch(\\n  1995→\\tctx context.Context,\\n  1996→\\trepo *git.Repository,\\n  1997→\\tstate *SessionState,\\n  1998→\\tremainingFiles []string,\\n  1999→) {\\n  2000→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n  2001→\\tstore := checkpoint.NewGitStore(repo)\\n  2002→\\n  2003→\\t// Don't include metadata directory in carry-forward. The carry-forward branch\\n  2004→\\t// only needs to preserve file content for comparison - not the transcript.\\n  2005→\\t// Including the transcript would cause sessionHasNewContent to always return true\\n  2006→\\t// because CheckpointTranscriptStart is reset to 0 for carry-forward.\\n  2007→\\tresult, err := store.WriteTemporary(ctx, checkpoint.WriteTemporaryOptions{\\n  2008→\\t\\tSessionID:         state.SessionID,\\n  2009→\\t\\tBaseCommit:        state.BaseCommit,\\n  2010→\\t\\tWorktreeID:        state.WorktreeID,\\n  2011→\\t\\tModifiedFiles:     remainingFiles,\\n  2012→\\t\\tMetadataDir:       \\\"\\\",\\n  2013→\\t\\tMetadataDirAbs:    \\\"\\\",\\n  2014→\\t\\tCommitMessage:     \\\"carry forward: uncommitted session files\\\",\\n  2015→\\t\\tIsFirstCheckpoint: false,\\n  2016→\\t})\\n  2017→\\tif err != nil {\\n  2018→\\t\\tlogging.Warn(logCtx, \\\"post-commit: carry-forward failed\\\",\\n  2019→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  2020→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  2021→\\t\\t)\\n  2022→\\t\\treturn\\n  2023→\\t}\\n  2024→\\tif result.Skipped {\\n  2025→\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward skipped (no changes)\\\",\\n  2026→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  2027→\\t\\t)\\n  2028→\\t\\treturn\\n  2029→\\t}\\n  2030→\\n  2031→\\t// Update state for the carry-forward checkpoint.\\n  2032→\\t// CheckpointTranscriptStart = 0 is intentional: each checkpoint is self-contained with\\n  2033→\\t// the full transcript. This trades storage efficiency for simplicity:\\n  2034→\\t// - Pro: Each checkpoint is independently readable without needing to stitch together\\n  2035→\\t//   multiple checkpoints to understand the session history\\n  2036→\\t// - Con: For long sessions with multiple partial commits, each checkpoint includes\\n  2037→\\t//   the full transcript, which could be large\\n  2038→\\t// An alternative would be incremental checkpoints (only new content since last condensation),\\n  2039→\\t// but this would complicate checkpoint retrieval and require careful tracking of dependencies.\\n  2040→\\tstate.StepCount = 1\\n  2041→\\tstate.CheckpointTranscriptStart = 0\\n  2042→\\tstate.LastCheckpointID = \\\"\\\"\\n  2043→\\t// NOTE: TurnCheckpointIDs is intentionally NOT cleared here. Those checkpoint\\n  2044→\\t// IDs from earlier in the turn still need finalization with the full transcript\\n  2045→\\t// when HandleTurnEnd runs at stop time.\\n  2046→\\n  2047→\\tlogging.Info(logCtx, \\\"post-commit: carried forward remaining files\\\",\\n  2048→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  2049→\\t\\tslog.Int(\\\"remaining_files\\\", len(remainingFiles)),\\n  2050→\\t)\\n  2051→}\\n  2052→\"}]},\"uuid\":\"d616856b-4fc9-4ac8-bf49-7fd4436f21c0\",\"timestamp\":\"2026-02-26T10:02:58.142Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand the content-aware overlap detection logic for the manual-commit strategy in this CLI codebase. The test `TestInteractiveContentOverlapRevertNewFile` in `e2e/tests/existing_files_test.go` expects that when an agent creates a new file, the user replaces its content entirely, and commits - no checkpoint trailer should be added (condensation should be skipped due to content mismatch on a new file).\\n\\nThe test is failing for OpenCode - condensation IS happening when it shouldn't.\\n\\nSearch for:\\n1. The content overlap detection logic (likely in `cmd/entire/cli/strategy/`)\\n2. How `prepare-commit-msg` decides whether to add the trailer\\n3. How `post-commit` decides whether to condense\\n4. Any OpenCode-specific differences in hook handling\\n5. The \\\"files touched\\\" or \\\"content overlap\\\" logic that determines if committed files match what the agent produced\\n\\nFocus on the manual-commit strategy files, especially hooks, condensation, and any content comparison logic. Report back all relevant code with file paths and line numbers.\",\"agentId\":\"a5aaf91\"},\"toolUseID\":\"agent_msg_01J2LTpq9JHZHAMkeGSjiQKf\",\"parentToolUseID\":\"toolu_01GuUWnvuJxbZFfEy6dCD5Br\",\"uuid\":\"633a8632-9efc-4be3-92da-4ca3c0d0f2b2\",\"timestamp\":\"2026-02-26T10:02:58.143Z\"}\n{\"parentUuid\":\"633a8632-9efc-4be3-92da-4ca3c0d0f2b2\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/robin/Developer/cli\",\"sessionId\":\"b017613f-5e57-4224-b298-1d0e425dcd51\",\"version\":\"2.1.49\",\"gitBranch\":\"rwr/fix-opencode-e2e\",\"slug\":\"vivid-orbiting-liskov\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01LEay84KyFEdnt1wh4qY8v4\",\"type\":\"tool_result\",\"content\":\"     1→package strategy\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"encoding/json\\\"\\n     6→\\t\\\"errors\\\"\\n     7→\\t\\\"fmt\\\"\\n     8→\\t\\\"log/slog\\\"\\n     9→\\t\\\"os\\\"\\n    10→\\t\\\"strings\\\"\\n    11→\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/opencode\\\"\\n    15→\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/stringutil\\\"\\n    22→\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n    23→\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    25→\\n    26→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    27→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    28→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    29→)\\n    30→\\n    31→// listCheckpoints returns all checkpoints from the metadata branch.\\n    32→// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\n    33→func (s *ManualCommitStrategy) listCheckpoints(ctx context.Context) ([]CheckpointInfo, error) {\\n    34→\\tstore, err := s.getCheckpointStore()\\n    35→\\tif err != nil {\\n    36→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    37→\\t}\\n    38→\\n    39→\\tcommitted, err := store.ListCommitted(ctx)\\n    40→\\tif err != nil {\\n    41→\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n    42→\\t}\\n    43→\\n    44→\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n    45→\\tresult := make([]CheckpointInfo, 0, len(committed))\\n    46→\\tfor _, c := range committed {\\n    47→\\t\\tresult = append(result, CheckpointInfo{\\n    48→\\t\\t\\tCheckpointID:     c.CheckpointID,\\n    49→\\t\\t\\tSessionID:        c.SessionID,\\n    50→\\t\\t\\tCreatedAt:        c.CreatedAt,\\n    51→\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n    52→\\t\\t\\tFilesTouched:     c.FilesTouched,\\n    53→\\t\\t\\tAgent:            c.Agent,\\n    54→\\t\\t\\tIsTask:           c.IsTask,\\n    55→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    56→\\t\\t\\tSessionCount:     c.SessionCount,\\n    57→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    58→\\t\\t})\\n    59→\\t}\\n    60→\\n    61→\\treturn result, nil\\n    62→}\\n    63→\\n    64→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    65→func (s *ManualCommitStrategy) getCheckpointsForSession(ctx context.Context, sessionID string) ([]CheckpointInfo, error) {\\n    66→\\tall, err := s.listCheckpoints(ctx)\\n    67→\\tif err != nil {\\n    68→\\t\\treturn nil, err\\n    69→\\t}\\n    70→\\n    71→\\tvar result []CheckpointInfo\\n    72→\\tfor _, cp := range all {\\n    73→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    74→\\t\\t\\tresult = append(result, cp)\\n    75→\\t\\t}\\n    76→\\t}\\n    77→\\n    78→\\tif len(result) == 0 {\\n    79→\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n    80→\\t}\\n    81→\\n    82→\\treturn result, nil\\n    83→}\\n    84→\\n    85→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    86→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    87→func (s *ManualCommitStrategy) getCheckpointLog(ctx context.Context, checkpointID id.CheckpointID) ([]byte, error) {\\n    88→\\tstore, err := s.getCheckpointStore()\\n    89→\\tif err != nil {\\n    90→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    91→\\t}\\n    92→\\n    93→\\tcontent, err := store.ReadLatestSessionContent(ctx, checkpointID)\\n    94→\\tif err != nil {\\n    95→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    96→\\t}\\n    97→\\tif content == nil {\\n    98→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n    99→\\t}\\n   100→\\tif len(content.Transcript) == 0 {\\n   101→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   102→\\t}\\n   103→\\n   104→\\treturn content.Transcript, nil\\n   105→}\\n   106→\\n   107→// condenseOpts provides pre-resolved git objects to avoid redundant reads.\\n   108→type condenseOpts struct {\\n   109→\\tshadowRef *plumbing.Reference // Pre-resolved shadow branch ref (nil = resolve from repo)\\n   110→\\theadTree  *object.Tree        // Pre-resolved HEAD tree (passed through to calculateSessionAttributions)\\n   111→}\\n   112→\\n   113→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   114→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   115→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   116→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   117→//\\n   118→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   119→// In this case, data is extracted from the live transcript instead.\\n   120→func (s *ManualCommitStrategy) CondenseSession(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}, opts ...condenseOpts) (*CondenseResult, error) {\\n   121→\\tag, _