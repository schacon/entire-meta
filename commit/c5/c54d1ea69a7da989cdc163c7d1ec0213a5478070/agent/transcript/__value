sion, err := parseExportSessionFromFile(path)\\n    95→\\tif err != nil {\\n    96→\\t\\tif os.IsNotExist(err) {\\n    97→\\t\\t\\treturn nil, 0, nil\\n    98→\\t\\t}\\n    99→\\t\\treturn nil, 0, err\\n   100→\\t}\\n   101→\\tif session == nil {\\n   102→\\t\\treturn nil, 0, nil\\n   103→\\t}\\n   104→\\n   105→\\tseen := make(map[string]bool)\\n   106→\\tvar files []string\\n   107→\\n   108→\\tfor i := startOffset; i < len(session.Messages); i++ {\\n   109→\\t\\tmsg := session.Messages[i]\\n   110→\\t\\tif msg.Info.Role != roleAssistant {\\n   111→\\t\\t\\tcontinue\\n   112→\\t\\t}\\n   113→\\t\\tfor _, part := range msg.Parts {\\n   114→\\t\\t\\tif part.Type != \\\"tool\\\" || part.State == nil {\\n   115→\\t\\t\\t\\tcontinue\\n   116→\\t\\t\\t}\\n   117→\\t\\t\\tif !slices.Contains(FileModificationTools, part.Tool) {\\n   118→\\t\\t\\t\\tcontinue\\n   119→\\t\\t\\t}\\n   120→\\t\\t\\tfilePath := extractFilePathFromInput(part.State.Input)\\n   121→\\t\\t\\tif filePath != \\\"\\\" && !seen[filePath] {\\n   122→\\t\\t\\t\\tseen[filePath] = true\\n   123→\\t\\t\\t\\tfiles = append(files, filePath)\\n   124→\\t\\t\\t}\\n   125→\\t\\t}\\n   126→\\t}\\n   127→\\n   128→\\treturn files, len(session.Messages), nil\\n   129→}\\n   130→\\n   131→// ExtractModifiedFiles extracts modified file paths from raw export JSON transcript bytes.\\n   132→// This is the bytes-based equivalent of ExtractModifiedFilesFromOffset, used by ReadSession.\\n   133→func ExtractModifiedFiles(data []byte) ([]string, error) {\\n   134→\\tsession, err := ParseExportSession(data)\\n   135→\\tif err != nil {\\n   136→\\t\\treturn nil, err\\n   137→\\t}\\n   138→\\tif session == nil {\\n   139→\\t\\treturn nil, nil\\n   140→\\t}\\n   141→\\n   142→\\tseen := make(map[string]bool)\\n   143→\\tvar files []string\\n   144→\\n   145→\\tfor _, msg := range session.Messages {\\n   146→\\t\\tif msg.Info.Role != roleAssistant {\\n   147→\\t\\t\\tcontinue\\n   148→\\t\\t}\\n   149→\\t\\tfor _, part := range msg.Parts {\\n   150→\\t\\t\\tif part.Type != \\\"tool\\\" || part.State == nil {\\n   151→\\t\\t\\t\\tcontinue\\n   152→\\t\\t\\t}\\n   153→\\t\\t\\tif !slices.Contains(FileModificationTools, part.Tool) {\\n   154→\\t\\t\\t\\tcontinue\\n   155→\\t\\t\\t}\\n   156→\\t\\t\\tfilePath := extractFilePathFromInput(part.State.Input)\\n   157→\\t\\t\\tif filePath != \\\"\\\" && !seen[filePath] {\\n   158→\\t\\t\\t\\tseen[filePath] = true\\n   159→\\t\\t\\t\\tfiles = append(files, filePath)\\n   160→\\t\\t\\t}\\n   161→\\t\\t}\\n   162→\\t}\\n   163→\\n   164→\\treturn files, nil\\n   165→}\\n   166→\\n   167→// extractFilePathFromInput extracts the file path from an OpenCode tool's input map.\\n   168→// OpenCode uses camelCase keys (e.g., \\\"filePath\\\"), with \\\"path\\\" as a fallback.\\n   169→func extractFilePathFromInput(input map[string]any) string {\\n   170→\\tfor _, key := range []string{\\\"filePath\\\", \\\"path\\\"} {\\n   171→\\t\\tif v, ok := input[key]; ok {\\n   172→\\t\\t\\tif s, ok := v.(string); ok && s != \\\"\\\" {\\n   173→\\t\\t\\t\\treturn s\\n   174→\\t\\t\\t}\\n   175→\\t\\t}\\n   176→\\t}\\n   177→\\treturn \\\"\\\"\\n   178→}\\n   179→\\n   180→// ExtractPrompts extracts user prompt strings from the transcript starting at the given offset.\\n   181→func (a *OpenCodeAgent) ExtractPrompts(sessionRef string, fromOffset int) ([]string, error) {\\n   182→\\tsession, err := parseExportSessionFromFile(sessionRef)\\n   183→\\tif err != nil {\\n   184→\\t\\tif os.IsNotExist(err) {\\n   185→\\t\\t\\treturn nil, nil\\n   186→\\t\\t}\\n   187→\\t\\treturn nil, err\\n   188→\\t}\\n   189→\\tif session == nil {\\n   190→\\t\\treturn nil, nil\\n   191→\\t}\\n   192→\\n   193→\\tvar prompts []string\\n   194→\\tfor i := fromOffset; i < len(session.Messages); i++ {\\n   195→\\t\\tmsg := session.Messages[i]\\n   196→\\t\\tif msg.Info.Role != roleUser {\\n   197→\\t\\t\\tcontinue\\n   198→\\t\\t}\\n   199→\\t\\t// Extract text from parts\\n   200→\\t\\tcontent := ExtractTextFromParts(msg.Parts)\\n   201→\\t\\tif content != \\\"\\\" {\\n   202→\\t\\t\\tprompts = append(prompts, content)\\n   203→\\t\\t}\\n   204→\\t}\\n   205→\\n   206→\\treturn prompts, nil\\n   207→}\\n   208→\\n   209→// ExtractSummary extracts the last assistant message content as a summary.\\n   210→func (a *OpenCodeAgent) ExtractSummary(sessionRef string) (string, error) {\\n   211→\\tsession, err := parseExportSessionFromFile(sessionRef)\\n   212→\\tif err != nil {\\n   213→\\t\\tif os.IsNotExist(err) {\\n   214→\\t\\t\\treturn \\\"\\\", nil\\n   215→\\t\\t}\\n   216→\\t\\treturn \\\"\\\", err\\n   217→\\t}\\n   218→\\tif session == nil {\\n   219→\\t\\treturn \\\"\\\", nil\\n   220→\\t}\\n   221→\\n   222→\\tfor i := len(session.Messages) - 1; i >= 0; i-- {\\n   223→\\t\\tmsg := session.Messages[i]\\n   224→\\t\\tif msg.Info.Role == roleAssistant {\\n   225→\\t\\t\\tcontent := ExtractTextFromParts(msg.Parts)\\n   226→\\t\\t\\tif content != \\\"\\\" {\\n   227→\\t\\t\\t\\treturn content, nil\\n   228→\\t\\t\\t}\\n   229→\\t\\t}\\n   230→\\t}\\n   231→\\n   232→\\treturn \\\"\\\", nil\\n   233→}\\n   234→\\n   235→// ExtractTextFromParts extracts text content from message parts.\\n   236→func ExtractTextFromParts(parts []Part) string {\\n   237→\\tvar texts []string\\n   238→\\tfor _, part := range parts {\\n   239→\\t\\tif part.Type == \\\"text\\\" && part.Text != \\\"\\\" {\\n   240→\\t\\t\\ttexts = append(texts, part.Text)\\n   241→\\t\\t}\\n   242→\\t}\\n   243→\\treturn strings.Join(texts, \\\"\\\\n\\\")\\n   244→}\\n   245→\\n   246→// ExtractAllUserPrompts extracts all user prompts from raw export JSON transcript bytes.\\n   247→// This is a package-level function used by the condensation path.\\n   248→func ExtractAllUserPrompts(data []byte) ([]string, error) {\\n   249→\\tsession, err := ParseExportSession(data)\\n   250→\\tif err != nil {\\n   251→\\t\\treturn nil, err\\n   252→\\t}\\n   253→\\tif session == nil {\\n   254→\\t\\treturn nil, nil\\n   255→\\t}\\n   256→\\n   257→\\tvar prompts []string\\n   258→\\tfor _, msg := range session.Messages {\\n   259→\\t\\tif msg.Info.Role != roleUser {\\n   260→\\t\\t\\tcontinue\\n   261→\\t\\t}\\n   262→\\t\\tcontent := ExtractTextFromParts(msg.Parts)\\n   263→\\t\\tif content != \\\"\\\" {\\n   264→\\t\\t\\tprompts = append(prompts, content)\\n   265→\\t\\t}\\n   266→\\t}\\n   267→\\treturn prompts, nil\\n   268→}\\n   269→\\n   270→// CalculateTokenUsage computes token usage from assistant messages starting at the given offset.\\n   271→func (a *OpenCodeAgent) CalculateTokenUsage(transcriptData []byte, fromOffset int) (*agent.TokenUsage, error) {\\n   272→\\tsession, err := ParseExportSession(transcriptData)\\n   273→\\tif err != nil {\\n   274→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript for token usage: %w\\\", err)\\n   275→\\t}\\n   276→\\tif session == nil {\\n   277→\\t\\treturn nil, nil //nolint:nilnil // nil usage for empty data is expected\\n   278→\\t}\\n   279→\\n   280→\\tusage := &agent.TokenUsage{}\\n   281→\\tfor i := fromOffset; i < len(session.Messages); i++ {\\n   282→\\t\\tmsg := session.Messages[i]\\n   283→\\t\\tif msg.Info.Role != roleAssistant || msg.Info.Tokens == nil {\\n   284→\\t\\t\\tcontinue\\n   285→\\t\\t}\\n   286→\\t\\tusage.InputTokens += msg.Info.Tokens.Input\\n   287→\\t\\tusage.OutputTokens += msg.Info.Tokens.Output\\n   288→\\t\\tusage.CacheReadTokens += msg.Info.Tokens.Cache.Read\\n   289→\\t\\tusage.CacheCreationTokens += msg.Info.Tokens.Cache.Write\\n   290→\\t\\tusage.APICallCount++\\n   291→\\t}\\n   292→\\n   293→\\treturn usage, nil\\n   294→}\\n   295→\"}]},\"uuid\":\"8aae81ae-78c2-42b6-9b89-45378006a312\",\"timestamp\":\"2026-02-26T10:03:09.477Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand the content-aware overlap detection logic for the manual-commit strategy in this CLI codebase. The test `TestInteractiveContentOverlapRevertNewFile` in `e2e/test