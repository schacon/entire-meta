cts agent-specific behavior (hooks, log parsing, session storage) so that\\n     3→// the same Strategy implementations can work with any coding agent.\\n     4→package agent\\n     5→\\n     6→import (\\n     7→\\t\\\"context\\\"\\n     8→\\t\\\"io\\\"\\n     9→)\\n    10→\\n    11→// Agent defines the interface for interacting with a coding agent.\\n    12→// Each agent implementation (Claude Code, Cursor, Aider, etc.) converts its\\n    13→// native format to the normalized types defined in this package.\\n    14→//\\n    15→// The interface is organized into three groups:\\n    16→//   - Identity (5 methods): Name, Type, Description, DetectPresence, ProtectedDirs\\n    17→//   - Transcript Storage (3 methods): ReadTranscript, ChunkTranscript, ReassembleTranscript\\n    18→//   - Legacy (6 methods): Will be moved to optional interfaces or removed in a future phase\\n    19→type Agent interface {\\n    20→\\t// --- Identity ---\\n    21→\\n    22→\\t// Name returns the agent registry key (e.g., \\\"claude-code\\\", \\\"gemini\\\")\\n    23→\\tName() AgentName\\n    24→\\n    25→\\t// Type returns the agent type identifier (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\")\\n    26→\\t// This is stored in metadata and trailers.\\n    27→\\tType() AgentType\\n    28→\\n    29→\\t// Description returns a human-readable description for UI\\n    30→\\tDescription() string\\n    31→\\n    32→\\t// IsPreview returns whether the agent integration is in preview or stable\\n    33→\\tIsPreview() bool\\n    34→\\n    35→\\t// DetectPresence checks if this agent is configured in the repository\\n    36→\\tDetectPresence(ctx context.Context) (bool, error)\\n    37→\\n    38→\\t// ProtectedDirs returns repo-root-relative directories that should never be\\n    39→\\t// modified or deleted during rewind or other destructive operations.\\n    40→\\t// Examples: [\\\".claude\\\"] for Claude, [\\\".gemini\\\"] for Gemini.\\n    41→\\tProtectedDirs() []string\\n    42→\\n    43→\\t// --- Transcript Storage ---\\n    44→\\n    45→\\t// ReadTranscript reads the raw transcript bytes for a session.\\n    46→\\tReadTranscript(sessionRef string) ([]byte, error)\\n    47→\\n    48→\\t// ChunkTranscript splits a transcript into chunks if it exceeds maxSize.\\n    49→\\t// Returns a slice of chunks. If the transcript fits in one chunk, returns single-element slice.\\n    50→\\t// The chunking is format-aware: JSONL splits at line boundaries, JSON splits message arrays.\\n    51→\\tChunkTranscript(ctx context.Context, content []byte, maxSize int) ([][]byte, error)\\n    52→\\n    53→\\t// ReassembleTranscript combines chunks back into a single transcript.\\n    54→\\t// Handles format-specific reassembly (JSONL concatenation, JSON message merging).\\n    55→\\tReassembleTranscript(chunks [][]byte) ([]byte, error)\\n    56→\\n    57→\\t// --- Legacy methods (will move to optional interfaces in Phase 4) ---\\n    58→\\n    59→\\t// GetSessionID extracts session ID from hook input.\\n    60→\\tGetSessionID(input *HookInput) string\\n    61→\\n    62→\\t// GetSessionDir returns where agent stores session data for this repo.\\n    63→\\tGetSessionDir(repoPath string) (string, error)\\n    64→\\n    65→\\t// ResolveSessionFile returns the path to the session transcript file.\\n    66→\\tResolveSessionFile(sessionDir, agentSessionID string) string\\n    67→\\n    68→\\t// ReadSession reads session data from agent's storage.\\n    69→\\tReadSession(input *HookInput) (*AgentSession, error)\\n    70→\\n    71→\\t// WriteSession writes session data for resumption.\\n    72→\\tWriteSession(ctx context.Context, session *AgentSession) error\\n    73→\\n    74→\\t// FormatResumeCommand returns command to resume a session.\\n    75→\\tFormatResumeCommand(sessionID string) string\\n    76→}\\n    77→\\n    78→// HookSupport is implemented by agents with lifecycle hooks.\\n    79→// This optional interface allows agents like Claude Code and Cursor to\\n    80→// install and manage hooks that notify Entire of agent events.\\n    81→//\\n    82→// The interface is organized into two groups:\\n    83→//   - Hook Mapping (2 methods): HookNames, ParseHookEvent\\n    84→//   - Hook Management (3 methods): InstallHooks, UninstallHooks, AreHooksInstalled\\n    85→type HookSupport interface {\\n    86→\\tAgent\\n    87→\\n    88→\\t// HookNames returns the hook verbs this agent supports.\\n    89→\\t// These become subcommands under `entire hooks <agent>`.\\n    90→\\t// e.g., [\\\"stop\\\", \\\"user-prompt-submit\\\", \\\"session-start\\\", \\\"session-end\\\"]\\n    91→\\tHookNames() []string\\n    92→\\n    93→\\t// ParseHookEvent translates an agent-native hook into a normalized lifecycle Event.\\n    94→\\t// Returns nil if the hook has no lifecycle significance (e.g., pass-through hooks).\\n    95→\\t// This is the core contribution surface for new agent implementations.\\n    96→\\tParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*Event, error)\\n    97→\\n    98→\\t// InstallHooks installs agent-specific hooks.\\n    99→\\t// If localDev is true, hooks point to local development build.\\n   100→\\t// If force is true, removes existing Entire hooks before installing.\\n   101→\\t// Returns the number of hooks installed.\\n   102→\\tInstallHooks(ctx context.Context, localDev bool, force bool) (int, error)\\n   103→\\n   104→\\t// UninstallHooks removes installed hooks\\n   105→\\tUninstallHooks(ctx context.Context) error\\n   106→\\n   107→\\t// AreHooksInstalled checks if hooks are currently installed\\n   108→\\tAreHooksInstalled(ctx context.Context) bool\\n   109→}\\n   110→\\n   111→// FileWatcher is implemented by agents that use file-based detection.\\n   112→// Agents like Aider that don't support hooks can use file watching\\n   113→// to detect session activity.\\n   114→type FileWatcher interface {\\n   115→\\tAgent\\n   116→\\n   117→\\t// GetWatchPaths returns paths to watch for session changes\\n   118→\\tGetWatchPaths() ([]string, error)\\n   119→\\n   120→\\t// OnFileChange handles a detected file change and returns session info\\n   121→\\tOnFileChange(path string) (*SessionChange, error)\\n   122→}\\n   123→\\n   124→// TranscriptAnalyzer provides format-specific transcript parsing.\\n   125→// Agents that implement this get richer checkpoints (transcript-derived file lists,\\n   126→// prompts, summaries). Agents that don't still participate in the checkpoint lifecycle\\n   127→// via git-status-based file detection and raw transcript storage.\\n   128→type TranscriptAnalyzer interface {\\n   129→\\tAgent\\n   130→\\n   131→\\t// GetTranscriptPosition returns the current position (length) of a transcript.\\n   132→\\t// For JSONL formats (Claude Code), this is the line count.\\n   133→\\t// For JSON formats (Gemini CLI), this is the message count.\\n   134→\\t// Returns 0 if the file doesn't exist or is empty.\\n   135→\\tGetTranscriptPosition(path string) (int, error)\\n   136→\\n   137→\\t// ExtractModifiedFilesFromOffset extracts files modified since a given offset.\\n   138→\\t// For JSONL formats (Claude Code), offset is the starting line number.\\n   139→\\t// For JSON formats (Gemini CLI), offset is the starting message index.\\n   140→\\t// Returns:\\n   141→\\t//   - files: list of file paths modified by the agent (from Write/Edit tools)\\n   142→\\t//   - currentPosition: the current position (line count or message count)\\n   143→\\t//   - error: any error encountered during reading\\n   144→\\tExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error)\\n   145→\\n   146→\\t// ExtractPrompts extracts user prompts from the transcript starting at the given offset.\\n   147→\\tExtractPrompts(sessionRef string, fromOffset int) ([]string, error)\\n   148→\\n   149→\\t// ExtractSummary extracts a summary of the session from the transcript.\\n   150→\\tExtractSummary(sessionRef string) (string, error)\"}]}