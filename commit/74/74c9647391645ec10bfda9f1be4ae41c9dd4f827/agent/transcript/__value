ion is deleted first so the\\n   226→// reimport replaces it with the checkpoint-state messages.\\n   227→func (a *OpenCodeAgent) importSessionIntoOpenCode(sessionID string, exportData []byte) error {\\n   228→\\t// Delete existing session first so reimport replaces it cleanly.\\n   229→\\t// opencode import uses ON CONFLICT DO NOTHING, so existing messages\\n   230→\\t// would be skipped without this step (breaking rewind).\\n   231→\\tif err := runOpenCodeSessionDelete(sessionID); err != nil {\\n   232→\\t\\t// Non-fatal: session might not exist yet (first session).\\n   233→\\t\\t// Import will still work for new sessions; only rewind of existing sessions\\n   234→\\t\\t// would have stale messages.\\n   235→\\t\\tlogging.Warn(context.Background(), \\\"could not delete existing opencode session\\\",\\n   236→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   237→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   238→\\t\\t)\\n   239→\\t}\\n   240→\\n   241→\\t// Write export JSON to a temp file for opencode import\\n   242→\\ttmpFile, err := os.CreateTemp(\\\"\\\", \\\"entire-opencode-export-*.json\\\")\\n   243→\\tif err != nil {\\n   244→\\t\\treturn fmt.Errorf(\\\"failed to create temp file: %w\\\", err)\\n   245→\\t}\\n   246→\\tdefer os.Remove(tmpFile.Name())\\n   247→\\n   248→\\tif _, err := tmpFile.Write(exportData); err != nil {\\n   249→\\t\\t_ = tmpFile.Close()\\n   250→\\t\\treturn fmt.Errorf(\\\"failed to write export data: %w\\\", err)\\n   251→\\t}\\n   252→\\tif err := tmpFile.Close(); err != nil {\\n   253→\\t\\treturn fmt.Errorf(\\\"failed to close temp file: %w\\\", err)\\n   254→\\t}\\n   255→\\n   256→\\treturn runOpenCodeImport(tmpFile.Name())\\n   257→}\\n   258→\\n   259→func (a *OpenCodeAgent) FormatResumeCommand(sessionID string) string {\\n   260→\\tif strings.TrimSpace(sessionID) == \\\"\\\" {\\n   261→\\t\\treturn \\\"opencode\\\"\\n   262→\\t}\\n   263→\\treturn \\\"opencode -s \\\" + sessionID\\n   264→}\\n   265→\\n   26