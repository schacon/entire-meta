x // test code, args are from trusted test setup, no context needed\\n   445→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile)\\n   446→\\tprepCmd.Dir = env.RepoDir\\n   447→\\tprepCmd.Env = append(os.Environ(),\\n   448→\\t\\t\\\"ENTIRE_TEST_TTY=1\\\",\\n   449→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".claude\\\"),\\n   450→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".gemini\\\"),\\n   451→\\t)\\n   452→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n   453→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n   454→\\t}\\n   455→\\n   456→\\t// Read the modified message (with trailer added by hook)\\n   457→\\t//nolint:gosec // test code, path is from test setup\\n   458→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n   459→\\tif err != nil {\\n   460→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n   461→\\t}\\n   462→\\n   463→\\t// REMOVE the Entire-Checkpoint trailer (simulating user editing the message)\\n   464→\\tlines := strings.Split(string(modifiedMsg), \\\"\\\\n\\\")\\n   465→\\tvar cleanedLines []string\\n   466→\\tfor _, line := range lines {\\n   467→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   468→\\t\\t\\tcontinue\\n   469→\\t\\t}\\n   470→\\t\\tif strings.Contains(line, \\\"Remove the Entire-Checkpoint trailer\\\") {\\n   471→\\t\\t\\tcontinue\\n   472→\\t\\t}\\n   473→\\t\\tif strings.Contains(line, \\\"trailer will be added to your next commit\\\") {\\n   474→\\t\\t\\tcontinue\\n   475→\\t\\t}\\n   476→\\t\\tcleanedLines = append(cleanedLines, line)\\n   477→\\t}\\n   478→\\tcleanedMsg := strings.TrimRight(strings.Join(cleanedLines, \\\"\\\\n\\\"), \\\"\\\\n\\\") + \\\"\\\\n\\\"\\n   479→\\n   480→\\t// Create the commit using go-git with the cleaned message (no trailer)\\n   481→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   482→\\tif err !