g `json:\\\"metadata_dir\\\"`\\n   574→\\t\\tDate             string `json:\\\"date\\\"`\\n   575→\\t\\tIsTaskCheckpoint bool   `json:\\\"is_task_checkpoint\\\"`\\n   576→\\t\\tToolUseID        string `json:\\\"tool_use_id\\\"`\\n   577→\\t\\tIsLogsOnly       bool   `json:\\\"is_logs_only\\\"`\\n   578→\\t\\tCondensationID   string `json:\\\"condensation_id\\\"`\\n   579→\\t}\\n   580→\\n   581→\\tif err := json.Unmarshal(output, &jsonPoints); err != nil {\\n   582→\\t\\tenv.T.Fatalf(\\\"failed to parse rewind points: %v\\\\nOutput: %s\\\", err, output)\\n   583→\\t}\\n   584→\\n   585→\\tpoints := make([]RewindPoint, len(jsonPoints))\\n   586→\\tfor i, jp := range jsonPoints {\\n   587→\\t\\t//nolint:errcheck // date parsing failure is acceptable, defaults to zero time\\n   588→\\t\\tdate, _ := time.Parse(time.RFC3339, jp.Date)\\n   589→\\t\\tpoints[i] = RewindPoint{\\n   590→\\t\\t\\tID:               jp.ID,\\n   591→\\t\\t\\tMessage:          jp.Message,\\n   592→\\t\\t\\tMetadataDir:      jp.MetadataDir,\\n   593→\\t\\t\\tDate:             date,\\n   594→\\t\\t\\tIsTaskCheckpoint: jp.IsTaskCheckpoint,\\n   595→\\t\\t\\tToolUseID:        jp.ToolUseID,\\n   596→\\t\\t\\tIsLogsOnly:       jp.IsLogsOnly,\\n   597→\\t\\t\\tCondensationID:   jp.CondensationID,\\n   598→\\t\\t}\\n   599→\\t}\\n   600→\\n   601→\\treturn points\\n   602→}\\n   603→\\n   604→// Rewind performs a rewind to the specified commit ID using the CLI.\\n   605→func (env *TestEnv) Rewind(commitID string) error {\\n   606→\\tenv.T.Helper()\\n   607→\\n   608→\\t//nolint:gosec,noctx // test code, commitID is from test setup, no context needed\\n   609→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID)\\n   610→\\tcmd.Dir = env.RepoDir\\n   611→\\n   612→\\toutput, err := cmd.CombinedOutput()\\n   613→\\tif err != nil {\\n   614→\\t\\treturn errors.New(\\\"rewind failed: \\\" + string(output))\\n   615→\\t}\\n   616→\\n   617→\\tenv.T.Logf(\\\"Rewind output: %s\\\", output)\\n   618→\\treturn nil\\n   619→}\\n   620→\\n   621→// BranchExists checks if a branch exists in the repository.\\n   622→func (env *TestEnv) BranchExists(branchName string) bool {\\n   623→\\tenv.T.Helper()\\n   624→\\n   625→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   626→\\tif err != nil {\\n   627→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   628→\\t}\\n   629→\\n   630→\\trefs, err := repo.References()\\n   631→\\tif err != nil {\\n   632→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   633→\\t}\\n   634→\\n   635→\\tfound := false\\n   636→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   637→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   638→\\t\\tif ref.Name().Short() == branchName {\\n   639→\\t\\t\\tfound = true\\n   640→\\t\\t}\\n   641→\\t\\treturn nil\\n   642→\\t})\\n   643→\\n   644→\\treturn found\\n   645→}\\n   646→\\n   647→// ListBranchesWithPrefix returns all branches that start with the given prefix.\\n   648→func (env *TestEnv) ListBranchesWithPrefix(prefix string) []string {\\n   649→\\tenv.T.Helper()\\n   650→\\n   651→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   652→\\tif err != nil {\\n   653→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   654→\\t}\\n   655→\\n   656→\\trefs, err := repo.References()\\n   657→\\tif err != nil {\\n   658→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   659→\\t}\\n   660→\\n   661→\\tvar branches []string\\n   662→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   663→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   664→\\t\\tname := ref.Name().Short()\\n   665→\\t\\tif strings.HasPrefix(name, prefix) {\\n   666→\\t\\t\\tbranches = append(branches, name)\\n   667→\\t\\t}\\n   668→\\t\\treturn nil\\n   669→\\t})\\n   670→\\n   671→\\treturn branches\\n   672→}\\n   673→\\n   674→// GetCommitMessage returns the commit message for the given commit hash.\\n   675→func (env *TestEnv) GetCommitMessage(hash string) string {\\n   676→\\tenv.T.Helper()\\n   677→\\n   678→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   679→\\tif err != nil {\\n   680→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   681→\\t}\\n   682→\\n   683→\\tcommitHash := plumbing.NewHash(hash)\\n   684→\\tcommit, err := repo.CommitObject(commitHash)\\n   685→\\tif err != nil {\\n   686→\\t\\tenv.T.Fatalf(\\\"failed to get commit %s: %v\\\", hash, err)\\n   687→\\t}\\n   688→\\n   689→\\treturn commit.Message\\n   690→}\\n   691→\\n   692→// GetLatestCheckpointIDFromHistory walks backwards from HEAD and returns\\n   693→// the checkpoint ID from the first commit with an Entire-Checkpoint trailer.\\n   694→// Returns an error if no checkpoint trailer is found in any commit.\\n   695→func (env *TestEnv) GetLatestCheckpointIDFromHistory() (string, error) {\\n   696→\\tenv.T.Helper()\\n   697→\\n   698→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   699→\\tif err != nil {\\n   700→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   701→\\t}\\n   702→\\n   703→\\thead, err := repo.Head()\\n   704→\\tif err != nil {\\n   705→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   706→\\t}\\n   707→\\n   708→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   709→\\tif err != nil {\\n   710→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   711→\\t}\\n   712→\\n   713→\\tvar checkpointID string\\n   714→\\t//nolint:errcheck,gosec // ForEach callback returns error to stop iteration, not a real error\\n   715→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   716→\\t\\t// Look for Entire-Checkpoint trailer\\n   717→\\t\\tfor _, line := range strings.Split(c.Message, \\\"\\\\n\\\") {\\n   718→\\t\\t\\tline = strings.TrimSpace(line)\\n   719→\\t\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   720→\\t\\t\\t\\tcheckpointID = strings.Tri