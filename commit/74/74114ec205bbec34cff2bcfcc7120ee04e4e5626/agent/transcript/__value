tCompile(`(?s)<system-reminder[^>]*>.*?</system-reminder>`),\\n    17→\\tregexp.MustCompile(`(?s)<command-name[^>]*>.*?</command-name>`),\\n    18→\\tregexp.MustCompile(`(?s)<command-message[^>]*>.*?</command-message>`),\\n    19→\\tregexp.MustCompile(`(?s)<command-args[^>]*>.*?</command-args>`),\\n    20→\\tregexp.MustCompile(`(?s)<local-command-stdout[^>]*>.*?</local-command-stdout>`),\\n    21→\\tregexp.MustCompile(`</?user_query>`), // Cursor wraps user text in <user_query> tags; strip tags but keep content\\n    22→}\\n    23→\\n    24→// StripIDEContextTags removes IDE-injected context tags from prompt text.\\n    25→// The VSCode extension injects tags like:\\n    26→//   - <ide_opened_file>...</ide_opened_file> - currently open file\\n    27→//   - <ide_selection>...</ide_selection> - selected code in editor\\n    28→//\\n    29→// Also removes system-injected tags like:\\n    30→//   - <local-command-caveat>...</local-command-caveat>\\n    31→//   - <system-reminder>...</system-reminder>\\n    32→//   - <command-name>...</command-name>\\n    33→//\\n    34→// These shouldn't appear in commit messages or session descriptions.\\n    35→func StripIDEContextTags(text string) string {\\n    36→\\tresult := ideContextTagRegex.ReplaceAllString(text, \\\"\\\")\\n    37→\\tfor _, re := range systemTagRegexes {\\n    38→\\t\\tresult = re.ReplaceAllString(result, \\\"\\\")\\n    39→\\t}\\n    40→\\treturn strings.TrimSpace(result)\\n    41→}\\n    42→\"}]},\"uuid\":\"c4f06001-4603-429e-89a1-763329f721d4\",\"timestamp\":\"2026-03-04T10:28:12.731Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a35bd3c00cf09e0b4\"},\"toolUseID\":\"agent_msg_01JZ5bXZt2y5ASgkttYikuLv\",\"parentToolUseID\":\"toolu_01Lzc2W1oFRCWg3KwENpXCkd\",\"uuid\":\"dc99e23d-56ad-4e22-980b-ccf1465e4a98\",\"timestamp\":\"2026-03-04T10:28:12.732Z\"}\n{\"parentUuid\":\"dc99e23d-56ad-4e22-980b-ccf1465e4a98\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Use