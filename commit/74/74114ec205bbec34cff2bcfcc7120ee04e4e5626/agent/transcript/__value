line.Role\\n   107→\\t}\\n   108→}\\n   109→\\n   110→// SliceFromLine returns the content starting from line number `startLine` (0-indexed).\\n   111→// This is used to extract only the checkpoint-specific portion of a cumulative transcript.\\n   112→// For example, if startLine is 2, lines 0 and 1 are skipped and the result starts at line 2.\\n   113→// Returns empty slice if startLine exceeds the number of lines.\\n   114→func SliceFromLine(content []byte, startLine int) []byte {\\n   115→\\tif len(content) == 0 || startLine <= 0 {\\n   116→\\t\\treturn content\\n   117→\\t}\\n   118→\\n   119→\\t// Find the byte offset where startLine begins\\n   120→\\tlineCount := 0\\n   121→\\toffset := 0\\n   122→\\tfor i, b := range content {\\n   123→\\t\\tif b == '\\\\n' {\\n   124→\\t\\t\\tlineCount++\\n   125→\\t\\t\\tif lineCount == startLine {\\n   126→\\t\\t\\t\\toffset = i + 1\\n   127→\\t\\t\\t\\tbreak\\n   128→\\t\\t\\t}\\n   129→\\t\\t}\\n   130→\\t}\\n   131→\\n   132→\\t// If we didn't find enough lines, return empty\\n   133→\\tif lineCount < startLine {\\n   134→\\t\\treturn nil\\n   135→\\t}\\n   136→\\n   137→\\t// If offset is beyond content, return empty\\n   138→\\tif offset >= len(content) {\\n   139→\\t\\treturn nil\\n   140→\\t}\\n   141→\\n   142→\\treturn content[offset:]\\n   143→}\\n   144→\\n   145→// ExtractUserContent extracts user content from a raw message.\\n   146→// Handles both string and array content formats.\\n   147→// IDE-injected context tags (like <ide_opened_file>) are stripped from the result.\\n   148→// Returns empty string if the message cannot be parsed or contains no text.\\n   149→func ExtractUserContent(message json.RawMessage) string {\\n   150→\\tvar msg UserMessage\\n   151→\\tif err := json.Unmarshal(message, &msg); err != nil {\\n   152→\\t\\treturn \\\"\\\"\\n   153→\\t}\\n   154→\\n   155→\\t// Handle string content\\n   156→\\tif str, ok := msg.Content.(string); ok {\\n   157→\\t\\treturn textutil.StripIDEContextTags(str)\\n   158→\\t}\\n   159→\\n   160→\\t// Handle array content (only if it contains text blocks)\\n   161→\\tif arr, ok := msg.Content.([]interface{}); ok {\\n   162→\\t\\tvar texts []string\\n   163→\\t\\tfor _, item := range arr {\\n   164→\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   165→\\t\\t\\t\\tif m[\\\"type\\\"] == ContentTypeText {\\n   166→\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   167→\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   168→\\t\\t\\t\\t\\t}\\n   169→\\t\\t\\t\\t}\\n   170→\\t\\t\\t}\\n   171→\\t\\t}\\n   172→\\t\\tif len(texts) > 0 {\\n   173→\\t\\t\\treturn textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   174→\\t\\t}\\n   175→\\t}\\n   176→\\n   177→\\treturn \\\"\\\"\\n   178→}\\n   179→\"}]},\"uuid\":\"90c3ce70-9c07-450f-a297-313c116dfe79\",\"timestamp\":\"2026-03-04T10:28:12.313Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a35bd3c00cf09e0b4\"},\"toolUseID\":\"agent_msg_01JZ5bXZt2y5ASgkttYikuLv\",\"parentToolUseID\":\"toolu_01Lzc2W1oFRCWg3KwENpXCkd\",\"uuid\":\"12247643-9af3-4825-8833-c6cf711932e3\",\"timestamp\":\"2026-03-04T10:28:12.688Z\"}\n{\"parentUuid\":\"12247643-9af3-4825-8833-c6cf711932e3\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"76ae3dc3-df0d-4d4e-9de7-f79828444ed4\",\"version\":\"2.1.66\",\"gitBranch\":\"nodo/external-plugins\",\"slug\":\"elegant-singing-yao\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-04T10:28:12.698Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_012BdAq9WQWNVAK8X9zmsmD9\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01T18jS98sWpBRK2X265c9Lb\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/nodo/work/cli/cmd/entire/cli/textutil/ide_tags.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":nul