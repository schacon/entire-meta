port (\\n     5→\\t\\\"bytes\\\"\\n     6→\\t\\\"encoding/json\\\"\\n     7→\\t\\\"fmt\\\"\\n     8→)\\n     9→\\n    10→// MarshalIndentWithNewline is like json.MarshalIndent but adds a trailing newline.\\n    11→// This ensures JSON files have proper POSIX line endings.\\n    12→func MarshalIndentWithNewline(v any, prefix, indent string) ([]byte, error) {\\n    13→\\tvar buf bytes.Buffer\\n    14→\\tenc := json.NewEncoder(&buf)\\n    15→\\tenc.SetIndent(prefix, indent)\\n    16→\\tif err := enc.Encode(v); err != nil {\\n    17→\\t\\treturn nil, fmt.Errorf(\\\"encoding JSON: %w\\\", err)\\n    18→\\t}\\n    19→\\treturn buf.Bytes(), nil\\n    20→}\\n    21→\"}]},\"uuid\":\"d54de4ff-2851-46ba-a8e3-cebd380e6223\",\"timestamp\":\"2026-03-04T10:28:12.753Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a35bd3c00cf09e0b4\"},\"toolUseID\":\"agent_msg_01JZ5bXZt2y5ASgkttYikuLv\",\"parentToolUseID\":\"toolu_01Lzc2W1oFRCWg3KwENpXCkd\",\"uuid\":\"168b4a7e-9601-4463-bcfe-4546065b5b57\",\"timestamp\":\"2026-03-04T10:28:12.754Z\"}\n{\"parentUuid\":\"168b4a7e-9601-4463-bcfe-4546065b5b57\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"76ae3dc3-df0d-4d4e-9de7-f79828444ed4\",\"version\":\"2.1.66\",\"gitBranch\":\"nodo/external-plugins\",\"slug\":\"elegant-singing-yao\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-04T10:28:14.639Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01XW3FQ4jvv288SdUYrCwk5r\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01Mys4GkPpZPA7UBdbmjHF6J\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/nodo/work/cli/docs/architecture/external-agent-protocol.md\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":3,\"cache_creation_input_tokens\":4239,\"cache_read_input_tokens\":47578,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":4239},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYht7Ri8vcSPfNLifgPJ1\",\"uuid\":\"bdfb4fce-0589-49ae-8f2b-28d647646bb9\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a35bd3c00cf09e0b4\"},\"toolUseID\":\"agent_msg_01JZ5bXZt2y5ASgkttYikuLv\",\"parentToolUseID\":\"toolu_01Lzc2W1oFRCWg3KwENpXCkd\",\"uuid\":\"5ea89f67-8f55-4c9f-96a0-3f73c0a81f2a\",\"timestamp\":\"2026-03-04T10:28:14.639Z\"}\n{\"parentUuid\":\"5ea89f67-8f55-4c9f-96a0-3f73c0a81f2a\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"76ae3dc3-df0d-4d4e-9de7-f79828444ed4\",\"version\":\"2.1.66\",\"gitBranch\":\"nodo/external-plugins\",\"slug\":\"elegant-singing-yao\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01Mys4GkPpZPA7UBdbmjHF6J\",\"type\":\"tool_result\",\"content\":\"     1→# External Agent Plugin Protocol\\n     2→\\n     3→## Overview\\n     4→\\n     5→The Entire CLI supports external agent plugins — standalone binaries that implement the Agent interface via a subcommand-based protocol over stdin/stdout. This allows third-party agents to integrate with the CLI without modifying the main repository.\\n     6→\\n     7→## Discovery\\n     8→\\n     9→The CLI discovers external agents by scanning `$PATH` for executables matching the pattern `entire-agent-<name>`. For example, `entire-agent-cursor` would register as the \\\"cursor\\\" agent.\\n    10→\\n    11→- Binaries whose `<name>` conflicts with an already-registered built-in agent are skipped.\\n    12→- Discovery runs once during CLI initialization (before building the hooks command tree).\\n    13→- The binary must be executable and respond to the `info` subcommand.\\n    14→\\n    15→## Environment\\n    16→\\n    17→Every subcommand invocation sets:\\n    18→\\n    19→| Variable | Description |\\n    20→|---|---|\\n    21→| `ENTIRE_REPO_ROOT` | Absolute path to the git repository root |\\n    22→| `ENTIRE_PROTOCOL_VERSION` | Protocol version (`1`) |\\n    23→\\n    24→The working directory is set to the repository root.\\n    25→\\n    26→## Communication Model\\n    27→\\n    28→- **Subcommand-based:** Each Agent interface method maps to a CLI subcommand.\\n    29→- **JSON over stdin/stdout:** Structured data uses JSON. Transcripts use raw bytes.\\n    30→- **Stateless:** Each invocation is independent — no persistent connection.\\n    31→- **Exit codes:** `0` = success, non-zero = error. Error messages go to stderr.\\n    32→\\n    33→## Subcommands\\n    34→\\n    35→### Always Required\\n    36→\\n    37→#### `info`\\n    38→\\n    39→Returns agent metadata and declared capabilities.\\n    40→\\n    41→**Arguments:** None\\n    42→\\n    43→**Output (stdout):** JSON\\n    44→\\n    45→```json\\n    46→{\\n    47→  \\\"protocol_version\\\": 1,\\n    48→  \\\"name\\\": \\\"cursor\\\",\\n    49→  \\\"type\\\": \\\"Cursor\\\",\\n    50→  \\\"description\\\": \\\"Cursor - AI-powered code editor\\\",\\n    51→  \\\"is_preview\\\": true,\\n    52→  \\\"protected_dirs\\\": [\\\".cursor\\\"],\\n    53→  \\\"hook_names\\\": [\\\"session-start\\\", \\\"session-end\\\", \\\"stop\\\"],\\n    54→  \\\"capabilities\\\": {\\n    55→    \\\"hooks\\\": true,\\n    56→    \\\"transcript_analyzer\\\": true,\\n    57→    \\\"transcript_preparer\\\": false,\\n    58→    \\\"token_calculator\\\": false,\\n    59→    \\\"text_generator\\\": false,\\n    60→    \\\"hook_response_writer\\\": false,\\n    61→    \\\"subagent_aware_extractor\\\": false\\n    62→  }\\n    63→}\\n    64→```\\n    65→\\n    66→The `capabilities` object determines which optional subcommands the CLI will call. If a capability is `false` or missing, the CLI will never invoke the corresponding subcommands.\\n    67→\\n    68→#### `detect`\\n    69→\\n    70→Checks whether the agent is present/usable in the current environment.\\n    71→\\n    72→**Arguments:** None\\n    73→\\n    74→**Output (stdout):** JSON\\n    75→\\n    76→```json\\n    77→{\\\"present\\\": true}\\n    78→```\\n    79→\\n    80→#### `get-session-id`\\n    81→\\n    82→Extracts the session ID from a hook input event.\\n    83→\\n    84→**Input (stdin):** JSON — the HookInput object\\n    85→\\n    86→**Output (stdout):** JSON\\n    87→\\n    88→```json\\n    89→{\\\"session_id\\\": \\\"abc123\\\"}\\n    90→```\\n    91→\\n    92→#### `get-session-dir --repo-path <path>`\\n    93→\\n    94→Returns the directory where agent sessions are stored.\\n    95→\\n    96→**Arguments:**\\n    97→- `--repo-path` — Absolute path to the repository\\n    98→\\n    99→**Output (stdout):** JSON\\n   100→\\n   101→```json\\n   102→{\\\"session_dir\\\": \\\"/path/to/sessions\\\"}\\n   103→```\\n   104→\\n   105→#### `resolve-session-file --session-dir <dir> --session-id <id>`\\n   106→\\n   107→Resolves the session file path from a session directory and ID.\\n   108→\\n   109→**Arguments:**\\n   110→- `--session-dir` — Session directory path\\n   111→- `--session-id` — Session identifier\\n   112→\\n   113→**Output (stdout):** JSON\\n   114→\\n   115→```json\\n   116→{\\\"session_file\\\": \\\"/path/to/session/file.jsonl\\\"}\\n   117→```\\n   118→\\n   119→#### `read-session`\\n   120→\\n   121→Reads session data from a hook input event.\\n   122→\\n   123→**Input (stdin):** JSON — the HookInput object\\n   124→\\n   125→**Output (stdout):** JSON — AgentSession object\\n   126→\\n   127→```json\\n   128→{\\n   129→  \\\"session_id\\\": \\\"abc123\\\",\\n   130→  \\\"session_file\\\": \\\"/path/to/file.jsonl\\\"\\n   131→}\\n   132→```\\n   133→\\n   134→#### `write-session`\\n   135→\\n   136→Writes/updates session data.\\n   137→\\n   138→**Input (stdin):** JSON — the AgentSession object\\n   139→\\n   140→**Output:** Exit 0 on success.\\n   141→\\n   142→#### `read-transcript --session-ref <path>`\\n   143→\\n   144→Reads a transcript file and returns its raw bytes.\\n   145→\\n   146→**Arguments:**\\n   147→- `--session-ref` — Path to the transcript file\\n   148→\\n   149→**Output (stdout):** Raw transcript bytes.\\n   150→\\n   151→#### `chunk-transcript --max-size <n>`\\n   152→\\n   153→Splits a transcript into chunks for storage.\\n   154→\\n   155→**Input (stdin):** Raw transcript bytes.\\n   156→\\n   157→**Arguments:**\\n   158→- `--max-size` — Maximum chunk size in bytes\\n   159→\\n   160→**Output (stdout):** JSON\\n   161→\\n   162→```json\\n   163→{\\\"chunks\\\": [\\\"<base64-encoded-chunk>\\\", \\\"...\\\"]}\\n   164→```\\n   165→\\n   166→#### `reassemble-transcript`\\n   167→\\n   168→Reassembles transcript chunks back into a full transcript.\\n   169→\\n   170→**Input (stdin):** JSON\\n   171→\\n   172→```json\\n   173→{\\\"chunks\\\": [\\\"<base64-encoded-chunk>\\\", \\\"...\\\"]}\\n   174→```\\n   175→\\n   176→**Output (stdout):** Raw transcript bytes.\\n   177→\\n   178→#### `format-resume-command --session-id <id>`\\n   179→\\n   180→Returns the command a user can run to resume a session.\\n   181→\\n   182→**Arguments:**\\n   183→- `--session-id` — Session identifier\\n   184→\\n   185→**Output (stdout):** JSON\\n   186→\\n   187→```json\\n   188→{\\\"command\\\": \\\"cursor --resume abc123\\\"}\\n   189→```\\n   190→\\n   191→### Capability: `hooks`\\n   192→\\n   193→These subcommands are required when `capabilities.hooks` is `true`.\\n   194→\\n   195→#### `parse-hook --hook <name>`\\n   196→\\n   197→Parses a raw agent hook payload into a structured event.\\n   198→\\n   199→**Arguments:**\\n   200→- `--hook` — Hook name (e.g., \\\"stop\\\", \\\"session-start\\\")\\n   201→\\n   202→**Input (stdin):** Raw agent hook payload bytes.\\n   203→\\n   204→**Output (stdout):** JSON — the parsed event, or `null` if the payload is not relevant.\\n   205→\\n   206→###