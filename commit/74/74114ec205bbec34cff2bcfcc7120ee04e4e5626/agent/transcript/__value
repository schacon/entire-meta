ntations can work with any coding agent.\\n     4→package agent\\n     5→\\n     6→import (\\n     7→\\t\\\"context\\\"\\n     8→\\t\\\"io\\\"\\n     9→\\n    10→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    11→)\\n    12→\\n    13→// Agent defines the interface for interacting with a coding agent.\\n    14→// Each agent implementation (Claude Code, Cursor, Aider, etc.) converts its\\n    15→// native format to the normalized types defined in this package.\\n    16→//\\n    17→// The interface is organized into three groups:\\n    18→//   - Identity (5 methods): Name, Type, Description, DetectPresence, ProtectedDirs\\n    19→//   - Transcript Storage (3 methods): ReadTranscript, ChunkTranscript, ReassembleTranscript\\n    20→//   - Legacy (6 methods): Will be moved to optional interfaces or removed in a future phase\\n    21→type Agent interface {\\n    22→\\t// --- Identity ---\\n    23→\\n    24→\\t// Name returns the agent registry key (e.g., \\\"claude-code\\\", \\\"gemini\\\")\\n    25→\\tName() types.AgentName\\n    26→\\n    27→\\t// Type returns the agent type identifier (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\")\\n    28→\\t// This is stored in metadata and trailers.\\n    29→\\tType() types.AgentType\\n    30→\\n    31→\\t// Description returns a human-readable description for UI\\n    32→\\tDescription() string\\n    33→\\n    34→\\t// IsPreview returns whether the agent integration is in preview or stable\\n    35→\\tIsPreview() bool\\n    36→\\n    37→\\t// DetectPresence checks if this agent is configured in the repository\\n    38→\\tDetectPresence(ctx context.Context) (bool, error)\\n    39→\\n    40→\\t// ProtectedDirs returns repo-root-relative directories that should never be\\n    41→\\t// modified or deleted during rewind or other destructive operations.\\n    42→\\t// Examples: [\\\".claude\\\"] for Claude, [\\\".gemini\\\"] for Gemini.\\n    43→\\tProtectedDirs() []string\\n    44→\\n    45→\\t// --- Transcript Storage ---\\n    46→\\n    47→\\t// ReadTranscript reads the raw transcript bytes for a session.\\n    48→\\tReadTranscript(sessionRef string) ([]byte, error)\\n    49→\\n    50→\\t// ChunkTranscript splits a transcript into chunks if it exceeds maxSize.\\n    51→\\t// Returns a slice of chunks. If the transcript fits in one chunk, returns single-element slice.\\n    52→\\t// The chunking is format-aware: JSONL splits at line boundaries, JSON splits message arrays.\\n    53→\\tChunkTranscript(ctx context.Context, content []byte, maxSize int) ([][]byte, error)\\n    54→\\n    55→\\t// ReassembleTranscript combines chunks back into a single transcript.\\n    56→\\t// Handles format-specific reassembly (JSONL concatenation, JSON message merging).\\n    57→\\tReassembleTranscript(chunks [][]byte) ([]byte, error)\\n    58→\\n    59→\\t// --- Legacy methods (will move to optional interfaces in Phase 4) ---\\n    60→\\n    61→\\t// GetSessionID extracts session ID from hook input.\\n    62→\\tGetSessionID(input *HookInput) string\\n    63→\\n    64→\\t// GetSessionDir returns where agent stores session data for this repo.\\n    65→\\tGetSessionDir(repoPath string) (string, error)\\n    66→\\n    67→\\t// ResolveSessionFile returns the path to the session transcript file.\\n    68→\\tResolveSessionFile(sessionDir, agentSessionID string) string\\n    69→\\n    70→\\t// ReadSession reads session data from agent's storage.\\n    71→\\tReadSession(input *HookInput) (*AgentSession, error)\\n    72→\\n    73→\\t// WriteSession writes session data for resumption.\\n    74→\\tWriteSession(ctx context.Context, session *AgentSession) error\\n    75→\\n    76→\\t// FormatResumeCommand returns command to resume a session.\\n    77→\\tFormatResumeCommand(sessionID string) string\\n    78→}\\n    79→\\n    80→// HookSupport is implemented by agents with lifecycle hooks.\\n    81→// This optional interface allows agents like Claude Code and Cursor to\\n    82→// install and manage hooks that notify Entire of agent events.\\n    83→//\\n    84→// The interface is organized into two groups:\\n    85→//   - Hook Mapping (2 methods): HookNames, ParseHookEvent\\n    86→//   - Hook Management (3 methods): InstallHooks, UninstallHooks, AreHooksInstalled\\n    87→type HookSupport interface {\\n    88→\\tAgent\\n    89→\\n    90→\\t// HookNames returns the hook verbs this agent supports.\\n    91→\\t// These become subcommands under `entire hooks <agent>`.\\n    92→\\t// e.g., [\\\"stop\\\", \\\"user-prompt-submit\\\", \\\"session-start\\\", \\\"session-end\\\"]\\n    93→\\tHookNames() []string\\n    94→\\n    95→\\t// ParseHookEvent translates an agent-native hook into a normalized lifecycle Event.\\n    96→\\t// Returns nil if the hook has no lifecycle significance (e.g., pass-through hooks).\\n    97→\\t// This is the core contribution surface for new agent implementations.\\n    98→\\tParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*Event, error)\\n    99→\\n   100→\\t// InstallHooks installs agent-specific hooks.\\n   101→\\t// If localDev is true, hooks point to local development build.\\n   102→\\t// If force is true, removes existing Entire hooks before installing.\\n   103→\\t// Returns the number of hooks installed.\\n   104→\\tInstallHooks(ctx context.Context, localDev bool, force bool) (int, error)\\n   105→\\n   106→\\t// UninstallHooks removes installed hooks\\n   107→\\tUninstallHooks(ctx context.Context) error\\n   108→\\n   109→\\t// AreHooksInstalled checks if hooks are currently installed\\n   110→\\tAreHooksInstalled(ctx context.Context) bool\\n   111→}\\n   112→\\n   113→// FileWatcher is implemented by agents that use file-based detection.\\n   114→// Agents like Aider that don't support hooks can use file watching\\n   115→// to detect session activity.\\n   116→type FileWatcher interface {\\n   117→\\tAgent\\n   118→\\n   119→\\t// GetWatchPaths returns paths to watch for session changes\\n   120→\\tGetWatchPaths() ([]string, error)\\n   121→\\n   122→\\t// OnFileChange handles a detected file change and returns session info\\n   123→\\tOnFileChange(path string) (*SessionChange, error)\\n   124→}\\n   125→\\n   126→// TranscriptAnalyzer provides format-specific transcript parsing.\\n   127→// Agents that implement this get richer checkpoints (transcript-derived file lists,\\n   128→// prompts, summaries). Agents that don't still participate in the checkpoint lifecycle\\n   129→// via git-status-based file detection and raw transcript storage.\\n   130→type TranscriptAnalyzer interface {\\n   131→\\tAgent\\n   132→\\n   133→\\t// GetTranscriptPosition returns the current position (length) of a transcript.\\n   134→\\t// For JSONL formats (Claude Code), this is the line count.\\n   135→\\t// For JSON formats (Gemini CLI), this is the message count.\\n   136→\\t// Returns 0 if the file doesn't exist or is empty.\\n   137→\\tGetTranscriptPosition(path string) (int, error)\\n   138→\\n   139→\\t// ExtractModifiedFilesFromOffset extracts files modified since a given offset.\\n   140→\\t// For JSONL formats (Claude Code), offset is the starting line number.\\n   141→\\t// For JSON formats (Gemini CLI), offset is the starting message index.\\n   142→\\t// Returns:\\n   143→\\t//   - files: list of file paths modified by the agent (from Write/Edit tools)\\n   144→\\t//   - currentPosition: the current position (line count or message count)\\n   145→\\t//   - error: any error encountered during reading\\n   146→\\tExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error)\\n   147→\\n   148→\\t// ExtractPrompts extracts user prompts from the transcript starting at the given offset.\\n   149→\\tExtractPrompts(sessionRef string, fromOffset int) ([]string, error)\\n   150→\\n   151→\\t// ExtractSummary extracts a summary of the session from the transcript.\\n   152→\\tExtractSummary(sessionRef string) (string, error)\\n   153→}\\n   154→\\n   155→// TranscriptPreparer is called before ReadTranscript to handle agent-specific\\n   156→// flush/sync requirements (e.g., Claude Code's async transcript writing).\\n   157→// The framework calls PrepareTranscript before ReadTranscript if implemented.\\n   158→type TranscriptPreparer interface {\\n   159→\\tAgent\\n   160→\\n   161→\\t// PrepareTranscript ensures the transcript is ready to read.\\n   162→\\t// For Claude Code, this waits for the async transcript flush to complete.\\n   163→\\tPrepareTranscript(ctx context.Context, sessionRef string) error\\n   164→}\\n   165→\\n   166→// TokenCalculator provides token usage calculation for a session.\\n   167→// The framework calls this during step save and checkpoint if implemented.\\n   168→type TokenCalculator interface {\\n   169→\\tAgent\\n   170→\\n   171→\\t// CalculateTokenUsage computes token usage from the transcript starting at the given offset.\\n   172→\\tCalculateTokenUsage(transcriptData []byte, fromOffset int) (*TokenUsage, error)\\n   173→}\\n   174→\\n   175→// TextGenerator is an optional interface for agents whose CLI supports\\n   176→// non-interactive text generation (e.g., claude --print).\\n   177→// Used for AI-powered metadata generation (trail titles, summaries).\\n   178→type TextGenerator interface {\\n   179→\\tAgent\\n   180→\\n   181→\\t// GenerateText sends a prompt to the agent's CLI and returns the raw text response.\\n   182→\\t// model is a hint (e.g., \\\"haiku\\\", \\\"sonnet\\\"). Implementations may ignore if not applicable.\\n   183→\\tGenerateText(ctx context.Context, prompt string, model string) (string, error)\\n   184→}\\n   185→\\n   186→// HookResponseWriter is implemented by agents that support structured hook responses.\\n   187→// Agents that implement this can output messages (e.g., banners) to the user via\\n   188→// the agent's response protocol. For example, Claude Code outputs JSON with a\\n   189→// systemMessage field to stdout. Agents that don't implement this will silently\\n   190→// skip hook response output.\\n   191→type HookResponseWriter interface {\\n   192→\\tAgent\\n   193→\\n   194→\\t// WriteHookResponse outputs a message to the user via the agent's hook response protocol.\\n   195→\\tWriteHookResponse(message string) error\\n   196→}\\n   197→\\n   198→// SubagentAwareExtractor provides methods for extracting files and tokens including subagents.\\n   199→// Agents that support spawning subagents (like Claude Code's Task tool) should implement this\\n   200→// to ensure subagent contributions are included in checkpoints.\\n   201→type SubagentAwareExtractor interface {\\n   202→\\tAgent\\n   203→\\n   204→\\t// ExtractAllModifiedFiles extracts files modified by both the main agent and any spawned subagents.\\n   205→\\t// The subagentsDir parameter specifies where subagent transcripts are stored.\\n   206→\\t// Returns a deduplicated list of all modified file paths.\\n   207→\\tExtractAllModifiedFiles(transcriptData []byte, fromOffset int, subagentsDir string) ([]string, error)\\n   208→\\n   209→\\t// CalculateTotalTokenUsage computes token usage including all spawned subagents.\\n   210→\\t// The subagentsDir parameter specifies where subagent transcripts are stored.\\n   211→\\tCalculateTotalTokenUsage(transcriptData []byte, fromOffset int, subagentsDir string) (*TokenUsage, error)\\n   212→}\\n   213→\"}]},\"uuid\":\"055e3c13-73c5-4977-91e3-8ecb30ada05d\",\"timestamp\":\"2026-03-04T10:28:17.700Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a35bd3c00cf09e0b4\"},\"toolUseID\":\"agent_msg_01JZ5bXZt2y5ASgkttYikuLv\",\"parentToolUseID\":\"toolu_01Lzc2W1oFRCWg3KwENpXCkd\",\"uuid\":\"95e93b05-0ca8-4f81-8112-3358f5dffc3d\",\"timestamp\":\"2026-03-04T10:28:17.863Z\"}\n{\"parentUuid\":\"95e93b05-0ca8-4f81-8112-3358f5dffc3d\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"76ae3dc3-df0d-4d4e-9de7-f79828444ed4\",\"version\":\"2.1.66\",\"gitBranch\":\"nodo/external-plugins\",\"slug\":\"elegant-singing-yao\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-04T10:28:17.913Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_0166rKh5v2htKFAuSLHcTPHh\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01Wbeqn5brEVrAp3EWsRxMzU\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/nodo/work/cli/cmd/entire/cli/agent/registry.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":666,\"cache_read_input_tokens\":56244,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":666},\"output_tokens\":25,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYht7iBaoeFUL3RvTqG1g\",\"uuid\":\"0047a08f-45fd-424a-9dad-cdc201772971\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a35bd3c00cf09e0b4\"},\"toolUseID\":\"agent_msg_01JZ5bXZt2y5ASgkttYikuLv\",\"parentToolUseID\":\"toolu_01Lzc2W1oFRCWg3KwENpXCkd\",\"uuid\":\"3178fae4-0b68-4aba-87b8-5002d3dbcd2c\",\"timestamp\":\"2026-03-04T10:28:17.913Z\"}\n{\"parentUuid\":\"3178fae4-0b68-4aba-87b8-5002d3dbcd2c\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"76ae3dc3-df0d-4d4e-9de7-f79828444ed4\",\"version\":\"2.1.66\",\"gitBranch\":\"nodo/external-plugins\",\"slug\":\"elegant-singing-yao\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01Wbeqn5brEVrAp3EWsRxMzU\",\"type\":\"tool_result\",\"content\":\"     1→package agent\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"fmt\\\"\\n     6→\\t\\\"slices\\\"\\n     7→\\t\\\"sync\\\"\\n     8→\\n     9→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    10→)\\n    11→\\n    12→var (\\n    13→\\tregistryMu sync.RWMutex\\n    14→\\tregistry   = make(map[types.AgentName]Factory)\\n    15→)\\n    16→\\n    17→// Factory creates a new agent instance\\n    18→type Factory func() Agent\\n    19→\\n    20→// Register adds an agent factory to the registry.\\n    21→// Called from init() in each agent implementation.\\n    22→func Register(name types.AgentName, factory Factory) {\\n    23→\\tregistryMu.Lock()\\n    24→\\tdefer registryMu.Unlock()\\n    25→\\tregistry[name] = factory\\n    26→}\\n    27→\\n    28→// Get retrieves an agent by name.\\n    29→//\\n    30→\\n    31→func Get(name types.AgentName) (Agent, error) {\\n    32→\\tregistryMu.RLock()\\n    33→\\tdefer registryMu.RUnlock()\\n    34→\\n    35→\\tfactory, ok := registry[name]\\n    36→\\tif !ok {\\n    37→\\t\\treturn nil, fmt.Errorf(\\\"unknown agent: %s (available: %v)\\\", name, List())\\n    38→\\t}\\n    39→\\treturn factory(), nil\\n    40→}\\n    41→\\n    42→// List returns all registered agent names in sorted order.\\n    43→func List() []types.AgentName {\\n    44→\\tregistryMu.RLock()\\n    45→\\tdefer registryMu.RUnlock()\\n    46→\\n    47→\\tnames := make([]types.AgentName, 0, len(registry))\\n    48→\\tfor name := range registry {\\n    49→\\t\\tnames = append(names, name)\\n    50→\\t}\\n    51→\\tslices.Sort(names)\\n    52→\\treturn names\\n    53→}\\n    54→\\n    55→func StringList() []string {\\n    56→\\tregistryMu.RLock()\\n    57→\\tdefer registryMu.RUnlock()\\n    58→\\n    59→\\tnames := make([]string, 0, len(registry))\\n    60→\\tfor name := range registry {\\n    61→\\t\\tnames = append(names, string(name))\\n    62→\\t}\\n    63→\\tslices.Sort(names)\\n    64→\\treturn names\\n    65→}\\n    66→\\n    67→// DetectAll returns all agents whose DetectPresence reports true.\\n    68→// Agents are checked in sorted name order (via List()) for deterministic results.\\n    69→// Returns an empty slice when no agent is detected.\\n    70→func DetectAll(ctx context.Context) []Agent {\\n    71→\\tnames := List() // sorted, lock-safe\\n    72→\\n    73→\\tvar detected []Agent\\n    74→\\tfor _, name := range names {\\n    75→\\t\\tag, err := Get(name)\\n    76→\\t\\tif err != nil {\\n    77→\\t\\t\\tcontinue\\n    78→\\t\\t}\\n    79→\\t\\tif present, err := ag.DetectPresence(ctx); err == nil && present {\\n    80→\\t\\t\\tdetected = append(detected, ag)\\n    81→\\t\\t}\\n    82→\\t}\\n    83→\\treturn detected\\n    84→}\\n    85→\\n    86→// Detect attempts to auto-detect which agent is being used.\\n    87→// Iterates registered agents in sorted name order for deterministic results.\\n    88→// Returns the first agent whose DetectPresence reports true.\\n    89→func Detect(ctx context.Context) (Agent, error) {\\n    90→\\tdetected := DetectAll(ctx)\\n    91→\\tif len(detected) == 0 {\\n    92→\\t\\treturn nil, fmt.Errorf(\\\"no agent detected (available: %v)\\\", List())\\n    93→\\t}\\n    94→\\treturn detected[0], nil\\n    95→}\\n    96→\\n    97→// Agent name constants (registry keys)\\n    98→const (\\n    99→\\tAgentNameClaudeCode     types.AgentName = \\\"claude-code\\\"\\n   100→\\tAgentNameCursor         types.AgentName = \\\"cursor\\\"\\n   101→\\tAgentNameGemini         types.AgentName = \\\"gemini\\\"\\n   102→\\tAgentNameOpenCode       types.AgentName = \\\"opencode\\\"\\n   103→\\tAgentNameFactoryAIDroid types.AgentName = \\\"factoryai-droid\\\"\\n   104→)\\n   105→\\n   106→// Agent type constants (type identifiers stored in metadata/trailers)\\n   107→const (\\n   108→\\tAgentTypeClaudeCode     types.AgentType = \\\"Claude Code\\\"\\n   109→\\tAgentTypeCursor         types.AgentType = \\\"Cursor\\\"\\n   110→\\tAgentTypeGemini         types.AgentType = \\\"Gemini CLI\\\"\\n   111→\\tAgentTypeOpenCode       types.AgentType = \\\"OpenCode\\\"\\n   112→\\tAgentTypeFactoryAIDroid types.AgentType = \\\"Factory AI Droid\\\"\\n   113→\\tAgentTypeUnknown        types.AgentType = \\\"Agent\\\" // Fallback for backwards compatibility\\n   114→)\\n   115→\\n   116→// DefaultAgentName is the registry key for the default agent.\\n   117→const DefaultAgentName types.AgentName = AgentNameClaudeCode\\n   118→\\n   119→// GetByAgentType retrieves an agent by its type identifier.\\n   120→//\\n   121→// Note: This uses a linear search that instantiates agents until a match is found.\\n   122→// This is acceptable because:\\n   123→//   - Agent count is small (~2-20 agents)\\n   124→//   - Agent factories are lightweight (empty struct allocation)\\n   125→//   - Called infrequently (commit hooks, rewind, debug commands - not hot paths)\\n   126→//   - Cost is ~400ns worst case vs milliseconds for I/O operations\\n   127→//\\n   128→// Only optimize if agent count exceeds 100 or profiling shows this as a bottleneck.\\n   129→func GetByAgentType(agentType types.AgentType) (Agent, error) {\\n   130→\\tregistryMu.RLock()\\n   131→\\tdefer registryMu.RUnlock()\\n   132→\\n   133→\\tfor _, factory := range registry {\\n   134→\\t\\tag := factory()\\n   135→\\t\\tif ag.Type() == agentType {\\n   136→\\t\\t\\treturn ag, nil\\n   137→\\t\\t}\\n   138→\\t}\\n   139→\\n   140→\\treturn nil, fmt.Errorf(\\\"unknown agent type: %s\\\", agentType)\\n   141→}\\n   142→\\n   143→// AllProtectedDirs returns the union of ProtectedDirs from all registered agents.\\n   144→func AllProtectedDirs() []string {\\n   145→\\t// Copy factories under the lock, then release before calling external code.\\n   146→\\tregistryMu.RLock()\\n   147→\\tfactories := make([]Factory, 0, len(registry))\\n   148→\\tfor _, f := range registry {\\n   149→\\t\\tfactories = append(factories, f)\\n   150→\\t}\\n   151→\\tregistryMu.RUnlock()\\n   152→\\n   153→\\tseen := make(map[string]struct{})\\n   154→\\tvar dirs []string\\n   155→\\tfor _, factory := range factories {\\n   156→\\t\\tfor _, d := range factory().ProtectedDirs() {\\n   157→\\t\\t\\tif _, ok := seen[d