ontent\":\"     1→package transcript\\n     2→\\n     3→import (\\n     4→\\t\\\"bufio\\\"\\n     5→\\t\\\"bytes\\\"\\n     6→\\t\\\"encoding/json\\\"\\n     7→\\t\\\"fmt\\\"\\n     8→\\t\\\"io\\\"\\n     9→\\t\\\"os\\\"\\n    10→\\t\\\"strings\\\"\\n    11→\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n    13→)\\n    14→\\n    15→// ParseFromBytes parses transcript content from a byte slice.\\n    16→// Uses bufio.Reader to handle arbitrarily long lines.\\n    17→func ParseFromBytes(content []byte) ([]Line, error) {\\n    18→\\tvar lines []Line\\n    19→\\treader := bufio.NewReader(bytes.NewReader(content))\\n    20→\\n    21→\\tfor {\\n    22→\\t\\tlineBytes, err := reader.ReadBytes('\\\\n')\\n    23→\\t\\tif err != nil && err != io.EOF {\\n    24→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    25→\\t\\t}\\n    26→\\n    27→\\t\\t// Handle empty line or EOF without content\\n    28→\\t\\tif len(lineBytes) == 0 {\\n    29→\\t\\t\\tif err == io.EOF {\\n    30→\\t\\t\\t\\tbreak\\n    31→\\t\\t\\t}\\n    32→\\t\\t\\tcontinue\\n    33→\\t\\t}\\n    34→\\n    35→\\t\\tvar line Line\\n    36→\\t\\tif err := json.Unmarshal(lineBytes, &line); err == nil {\\n    37→\\t\\t\\tnormalizeLineType(&line)\\n    38→\\t\\t\\tlines = append(lines, line)\\n    39→\\t\\t}\\n    40→\\n    41→\\t\\tif err == io.EOF {\\n    42→\\t\\t\\tbreak\\n    43→\\t\\t}\\n    44→\\t}\\n    45→\\n    46→\\treturn lines, nil\\n    47→}\\n    48→\\n    49→// ParseFromFileAtLine reads and parses a transcript file starting from a specific line.\\n    50→// Uses bufio.Reader to handle arbitrarily long lines (no size limit).\\n    51→// Returns:\\n    52→//   - lines: parsed transcript lines from startLine onwards (malformed lines skipped)\\n    53→//   - error: any error encountered during reading\\n    54→//\\n    55→// The startLine parameter is 0-indexed (startLine=0 reads from the beginning).\\n    56→// This is useful for incremental parsing wh