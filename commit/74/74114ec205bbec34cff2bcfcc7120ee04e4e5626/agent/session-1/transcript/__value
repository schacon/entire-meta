  488→\\t}, nil\\n   489→}\\n   490→\\n   491→func convertTokenUsage(r *TokenUsageResponse) *agent.TokenUsage {\\n   492→\\tif r == nil {\\n   493→\\t\\treturn nil\\n   494→\\t}\\n   495→\\tusage := &agent.TokenUsage{\\n   496→\\t\\tInputTokens:         r.InputTokens,\\n   497→\\t\\tCacheCreationTokens: r.CacheCreationTokens,\\n   498→\\t\\tCacheReadTokens:     r.CacheReadTokens,\\n   499→\\t\\tOutputTokens:        r.OutputTokens,\\n   500→\\t\\tAPICallCount:        r.APICallCount,\\n   501→\\t}\\n   502→\\tif r.SubagentTokens != nil {\\n   503→\\t\\tusage.SubagentTokens = convertTokenUsage(r.SubagentTokens)\\n   504→\\t}\\n   505→\\treturn usage\\n   506→}\\n   507→\"}]},\"uuid\":\"d674110c-6117-4c17-b930-6fcd0bc66c22\",\"timestamp\":\"2026-03-04T10:23:45.440Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a9aa8cb8e81494745\"},\"toolUseID\":\"agent_msg_01SMAg2K5fFV7BW8oRidQxGX\",\"parentToolUseID\":\"toolu_01TZHaKSeZmoXXvAr3egLqV7\",\"uuid\":\"28ba4099-36c6-4308-b4ff-520aae626783\",\"timestamp\":\"2026-03-04T10:23:45.441Z\"}\n{\"parentUuid\":\"28ba4099-36c6-4308-b4ff-520aae626783\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"b12319af-9a0a-4691-b084-e5fc5ae7e446\",\"version\":\"2.1.66\",\"gitBranch\":\"nodo/external-plugins\",\"slug\":\"elegant-singing-yao\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-04T10:23:49.857Z\",\"message\":{\"model\":\"claude-sonnet-4-6\",\"id\":\"msg_01LLGABVKJxUFdSSGaUEQEf5\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01T6vdpNCWPtyEKcXTMWhDEG\",\"name\":\"Bash\",\"input\":{\"command\":\"ls /Users/nodo/work/cli/cmd/ 2>&1\",\"description\":\"List cmd directory structure\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":7978,\"cache_creation_input_tokens\":7936,\"cache_read_input_tokens\":3485