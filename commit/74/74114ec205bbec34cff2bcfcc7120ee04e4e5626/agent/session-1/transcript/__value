sort\\\"\\n     8→\\t\\\"strings\\\"\\n     9→\\n    10→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    11→)\\n    12→\\n    13→const (\\n    14→\\t// MaxChunkSize is the maximum size for a single transcript chunk.\\n    15→\\t// GitHub has a 100MB limit per blob, so we use 50MB to be safe.\\n    16→\\tMaxChunkSize = 50 * 1024 * 1024 // 50MB\\n    17→\\n    18→\\t// ChunkSuffix is the format for chunk file suffixes (e.g., \\\".001\\\", \\\".002\\\")\\n    19→\\tChunkSuffix = \\\".%03d\\\"\\n    20→)\\n    21→\\n    22→// ChunkTranscript splits a transcript into chunks using the appropriate agent.\\n    23→// If agentType is empty or the agent is not found, falls back to JSONL (line-based) chunking.\\n    24→func ChunkTranscript(ctx context.Context, content []byte, agentType types.AgentType) ([][]byte, error) {\\n    25→\\tif len(content) <= MaxChunkSize {\\n    26→\\t\\treturn [][]byte{content}, nil\\n    27→\\t}\\n    28→\\n    29→\\t// Try to get the agent by type and use its format-aware chunking\\n    30→\\tif agentType != \\\"\\\" {\\n    31→\\t\\tag, err := GetByAgentType(agentType)\\n    32→\\t\\tif err == nil {\\n    33→\\t\\t\\tchunks, chunkErr := ag.ChunkTranscript(ctx, content, MaxChunkSize)\\n    34→\\t\\t\\tif chunkErr != nil {\\n    35→\\t\\t\\t\\treturn nil, fmt.Errorf(\\\"agent chunking failed: %w\\\", chunkErr)\\n    36→\\t\\t\\t}\\n    37→\\t\\t\\treturn chunks, nil\\n    38→\\t\\t}\\n    39→\\t}\\n    40→\\n    41→\\t// Fall back to JSONL chunking (default)\\n    42→\\treturn ChunkJSONL(content, MaxChunkSize)\\n    43→}\\n    44→\\n    45→// ReassembleTranscript combines chunks back into a single transcript.\\n    46→// If agentType is empty or the agent is not found, falls back to JSONL (line-based) reassembly.\\n    47→func ReassembleTranscript(chunks [][]byte, agentType types.AgentType) ([]byte, error) {\\n    48→\\tif len(chunks) == 0 {\\n    49→\\t\\treturn nil, nil\\n    50→\\t}\\n    51→\\tif len(chunks) == 1 {\\n    52→