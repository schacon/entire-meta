idAgent{}\\n    39→}\\n    40→\\n    41→// Name returns the agent registry key.\\n    42→func (f *FactoryAIDroidAgent) Name() types.AgentName { return agent.AgentNameFactoryAIDroid }\\n    43→\\n    44→// Type returns the agent type identifier.\\n    45→func (f *FactoryAIDroidAgent) Type() types.AgentType { return agent.AgentTypeFactoryAIDroid }\\n    46→\\n    47→// Description returns a human-readable description.\\n    48→func (f *FactoryAIDroidAgent) Description() string {\\n    49→\\treturn \\\"Factory AI Droid - agent-native development platform\\\"\\n    50→}\\n    51→\\n    52→// IsPreview returns true as Factory AI Droid integration is in preview.\\n    53→func (f *FactoryAIDroidAgent) IsPreview() bool { return true }\\n    54→\\n    55→// ProtectedDirs returns directories that Factory AI Droid uses for config/state.\\n    56→func (f *FactoryAIDroidAgent) ProtectedDirs() []string { return []string{\\\".factory\\\"} }\\n    57→\\n    58→// DetectPresence checks if Factory AI Droid is configured in the repository.\\n    59→func (f *FactoryAIDroidAgent) DetectPresence(ctx context.Context) (bool, error) {\\n    60→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n    61→\\tif err != nil {\\n    62→\\t\\trepoRoot = \\\".\\\"\\n    63→\\t}\\n    64→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\".factory\\\")); err == nil {\\n    65→\\t\\treturn true, nil\\n    66→\\t}\\n    67→\\treturn false, nil\\n    68→}\\n    69→\\n    70→// ReadTranscript reads the raw JSONL transcript bytes for a session.\\n    71→func (f *FactoryAIDroidAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    72→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n    73→\\tif err != nil {\\n    74→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    75→\\t}\\n    76→\\treturn data, nil\\n    77→}\\n    78→\\n    79→// ChunkTranscript splits a JSONL transcript at line boundaries.\\n    80→func (f *FactoryAIDroidAgent) ChunkTranscript(_ context.Context, content []byte, maxSize int) ([][]byte, error) {\\n    81→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    82→\\tif err != nil {\\n    83→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n    84→\\t}\\n    85→\\treturn chunks, nil\\n    86→}\\n    87→\\n    88→// ReassembleTranscript concatenates JSONL chunks with newlines.\\n    89→func (f *FactoryAIDroidAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    90→\\treturn agent.ReassembleJSONL(chunks), nil\\n    91→}\\n    92→\\n    93→// GetSessionID extracts the session ID from hook input.\\n    94→func (f *FactoryAIDroidAgent) GetSessionID(input *agent.HookInput) string { return input.SessionID }\\n    95→\\n    96→// GetSessionDir returns the directory where Factory AI Droid stores session transcripts.\\n    97→// Path: ~/.factory/sessions/<sanitized-repo-path>/\\n    98→func (f *FactoryAIDroidAgent) GetSessionDir(repoPath string) (string, error) {\\n    99→\\tif override := os.Getenv(\\\"ENTIRE_TEST_DROID_PROJECT_DIR\\\"); override != \\\"\\\" {\\n   100→\\t\\treturn override, nil\\n   101→\\t}\\n   102→\\thomeDir, err := os.UserHomeDir()\\n   103→\\tif err != nil {\\n   104→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   105→\\t}\\n   106→\\tprojectDir := sanitizeRepoPath(repoPath)\\n   107→\\treturn filepath.Join(homeDir, \\\".factory\\\", \\\"sessions\\\", projectDir), nil\\n   108→}\\n   109→\\n   110→// ResolveSessionFile returns the path to a Factory AI Droid session file.\\n   111→func (f *FactoryAIDroidAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   112→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".jsonl\\\")\\n   113→}\\n   114→\\n   115→// ReadSession reads a session from Factory AI Droid's storage (JSONL transcript file).\\n   116→// The session data is stored in NativeData as raw JSONL bytes.\\n   117→// ModifiedFiles is computed by parsing the transcript.\\n   118→func (f *FactoryAIDroidAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   119→\\tif input.SessionRef == \\\"\\\" {\\n   120→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   121→\\t}\\n   122→\\n   123→\\tdata, err := os.ReadFile(input.SessionRef)\\n   124→\\tif err != nil {\\n   125→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   126→\\t}\\n   127→\\n   128→\\tlines, _, err := ParseDroidTranscriptFromBytes(data, 0)\\n   129→\\tif err != nil {\\n   130→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   131→\\t}\\n   132→\\n   133→\\treturn &agent.AgentSession{\\n   134→\\t\\tSessionID:     input.SessionID,\\n   135→\\t\\tAgentName:     f.Name(),\\n   136→\\t\\tSessionRef:    input.SessionRef,\\n   137→\\t\\tStartTime:     time.Now(),\\n   138→\\t\\tNativeData:    data,\\n   139→\\t\\tModifiedFiles: ExtractModifiedFiles(lines),\\n   140→\\t}, nil\\n   141→}\\n   142→\\n   143→// WriteSession writes a session to Factory AI Droid's storage (JSONL transcript file).\\n   144→// Uses the NativeData field which contains raw JSONL bytes.\\n   145→func (f *FactoryAIDroidAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   146→\\tif session == nil {\\n   147→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   148→\\t}\\n   149→\\n   150→\\tif session.AgentName != \\\"\\\" && session.AgentName != f.Name() {\\n   151→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, f.Name())\\n   152→\\t}\\n   153→\\n   154→\\tif session.SessionRef == \\\"\\\" {\\n   155→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   156→\\t}\\n   157→\\n   158→\\tif len(session.NativeData) == 0 {\\n   159→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   160→\\t}\\n   161→\\n   162→\\tif err := os.MkdirAll(filepath.Dir(session.SessionRef), 0o750); err != nil {\\n   163→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   164→\\t}\\n   165→\\n   166→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   167→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   168→\\t}\\n   169→\\n   170→\\treturn nil\\n   171→}\\n   172→\\n   173→// FormatResumeCommand returns the command to resume a Factory AI Droid session.\\n   174→func (f *FactoryAIDroidAgent) FormatResumeCommand(sessionID string) string {\\n   175→\\treturn \\\"droid --session-id \\\" + sessionID\\n   176→}\\n   177→\"}]},\"uuid\":\"ca33a2f0-6de5-43b2-bdfd-b9ba139e99bf\",\"timestamp\":\"2026-03-04T10:24:06.893Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a9aa8cb8e81494745\"},\"toolUseID\":\"agent_msg_01SMAg2K5fFV7BW8oRidQxGX\",\"parentToolUseID\":\"toolu_01TZHaKSeZmoXXvAr3egLqV7\",\"uuid\":\"0dee6c0f-21b9-4394-b1e4-f514edd1a871\",\"timestamp\":\"2026-03-04T10:24:07.671Z\"}\n{\"parentUuid\":\"0dee6c0f-21b9-4394-b1e4-f514edd1a871\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"b12319af-9a0a-4691-b084-e5fc5ae7e446\",\"version\":\"2.1.66\",\"gitBranch\":\"nodo/external-plugins\",\"slug\":\"elegant-singing-yao\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-04T10:24:07.684Z\",\"message\":{\"model\":\"claude-sonnet-4-6\",\"id\":\"msg_015puRWzfNRntrnn8eucshRb\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01L4PmVTzkPwn6y1WCMaNqP3\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/nodo/work/cli/docs/architecture/external-agent-protocol.md\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":1879,\"cache_read_input_tokens\":61391,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":1879},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYhso1VMKKsfkzPhu6cFn\",\"uuid\":\"33c06389-ce1a-4c7e-ad39-280ec94a55d5\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a9aa8cb8e81494745\"},\"toolUseID\":\"agent_msg_01SMAg2K5fFV7BW8oRidQxGX\",\"parentToolUseID\":\"toolu_01TZHaKSeZmoXXvAr3egLqV7\",\"uuid\":\"dbf31210-d332-48c5-afdf-6345499f222f\",\"timestamp\":\"2026-03-04T10:24:07.684Z\"}\n{\"parentUuid\":\"dbf31210-d332-48c5-afdf-6345499f222f\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"b12319af-9a0a-4691-b084-e5fc5ae7e446\",\"version\":\"2.1.66\",\"gitBranch\":\"nodo/external-plugins\",\"slug\":\"elegant-singing-yao\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01L4PmVTzkPwn6y1WCMaNqP3\",\"type\":\"tool_result\",\"content\":\"     1→# External Agent Plugin Protocol\\n     2→\\n     3→## Overview\\n     4→\\n     5→The Entire CLI supports external agent plugins — standalone binaries that implement the Agent interface via a subcommand-based protocol over stdin/stdout. This allows third-party agents to integrate with the CLI without modifying the main repository.\\n     6→\\n     7→## Discovery\\n     8→\\n     9→The CLI discovers external agents by scanning `$PATH` for executables matching the pattern `entire-agent-<name>`. For example, `entire-agent-cursor` would register as the \\\"cursor\\\" agent.\\n    10→\\n    11→- Binaries whose `<name>` conflicts with an already-registered built-in agent are skipped.\\n    12→- Discovery runs once during CLI initialization (before building the hooks command tree).\\n    13→- The binary must be executable and respond to the `info` subcommand.\\n    14→\\n    15→## Environment\\n    16→\\n    17→Every subcommand invocation sets:\\n    18→\\n    19→| Variable | Description |\\n    20→|---|---|\\n    21→| `ENTIRE_REPO_ROOT` | Absolute path to the git repository root |\\n    22→| `ENTIRE_PROTOCOL_VERSION` | Protocol version (`1`) |\\n    23→\\n    24→The working directory is set to the repository root.\\n    25→\\n    26→## Communication Model\\n    27→\\n    28→- **Subcommand-based:** Each Agent interface method maps to a CLI subcommand.\\n    29→- **JSON over stdin/stdout:** Structured data uses JSON. Transcripts use raw bytes.\\n    30→- **Stateless:** Each invocation is independent — no persistent connection.\\n    31→- **Exit codes:** `0` = success, non-zero = error. Error messages go to stderr.\\n    32→\\n    33→## Subcommands\\n    34→\\n    35→### Always Required\\n    36→\\n    37→#### `info`\\n    38→\\n    39→Returns agent metadata and declared capabilities.\\n    40→\\n    41→**Arguments:** None\\n    42→\\n    43→**Output (stdout):** JSON\\n    44→\\n    45→```json\\n    46→{\\n    47→  \\\"protocol_version\\\": 1,\\n    48→  \\\"name\\\": \\\"cursor\\\",\\n    49→  \\\"type\\\": \\\"Cursor\\\",\\n    50→  \\\"description\\\": \\\"Cursor - AI-powered code editor\\\",\\n    51→  \\\"is_preview\\\": true,\\n    52→  \\\"protected_dirs\\\": [\\\".cursor\\\"],\\n    53→  \\\"hook_names\\\": [\\\"session-start\\\", \\\"session-end\\\", \\\"stop\\\"],\\n    54→  \\\"capabilities\\\": {\\n    55→    \\\"hooks\\\": true,\\n    56→    \\\"transcript_analyzer\\\": true,\\n    57→    \\\"transcript_preparer\\\": false,\\n    58→    \\\"token_calculator\\\": false,\\n    59→    \\\"text_generator\\\": false,\\n    60→    \\\"hook_response_writer\\\": false,\\n    61→    \\\"subagent_aware_extractor\\\": false\\n    62→  }\\n    63→}\\n    64→```\\n    65→\\n    66→The `capabilities` object determines which optional subcommands the CLI will call. If a capability is `false` or missing, the CLI will never invoke the corresponding subcommands.\\n    67→\\n    68→#### `detect`\\n    69→\\n    70→Checks whether the agent is present/usable in the current environment.\\n    71→\\n    72→**Arguments:** None\\n    73→\\n    74→**Output (stdout):** JSON\\n    75→\\n    76→```json\\n    77→{\\\"present\\\": true}\\n    78→```\\n    79→\\n    80→#### `get-session-id`\\n    81→\\n    82→Extracts the session ID from a hook input event.\\n    83→\\n    84→**Input (stdin):** JSON — the HookInput object\\n    85→\\n    86→**Output (stdout):** JSON\\n    87→\\n    88→```json\\n    89→{\\\"session_id\\\": \\\"abc123\\\"}\\n    90→```\\n    91→\\n    92→#### `get-session-dir --repo-path <path>`\\n    93→\\n    94→Returns the directory where agent sessions are stored.\\n    95→\\n    96→**Arguments:**\\n    97→- `--repo-path` — Absolute path to the repository\\n    98→\\n    99→**Output (stdout):** JSON\\n   100→\\n   101→```json\\n   102→{\\\"session_dir\\\": \\\"/path/to/sessions\\\"}\\n   103→```\\n   104→\\n   105→#### `resolve-session-file --session-dir <dir> --session-id <id>`\\n   106→\\n   107→Resolves the session file path from a session directory and ID.\\n   108→\\n   109→**Arguments:**\\n   110→- `--session-dir` — Session directory path\\n   111→- `--session-id` — Session identifier\\n   112→\\n   113→**Output (stdout):** JSON\\n   114→\\n   115→```json\\n   116→{\\\"session_file\\\": \\\"/path/to/session/file.jsonl\\\"}\\n   117→```\\n   118→\\n   119→#### `read-session`\\n   120→\\n   121→Reads session data from a hook input event.\\n   122→\\n   123→**Input (stdin):** JSON — the HookInput object\\n   124→\\n   125→**Output (stdout):** JSON — AgentSession object\\n   126→\\n   127→```json\\n   128→{\\n   129→  \\\"session_id\\\": \\\"abc123\\\",\\n   130→  \\\"session_file\\\": \\\"/path/to/file.jsonl\\\"\\n   131→}\\n   132→```\\n   133→\\n   134→#### `write-session`\\n   135→\\n   136→Writes/updates session data.\\n   137→\\n   138→**Input (stdin):** JSON — the AgentSession object\\n   139→\\n   140→**Output:** Exit 0 on success.\\n   141→\\n   142→#### `read-transcript --session-ref <path>`\\n   143→\\n   144→Reads a transcript file and returns its raw bytes.\\n   145→\\n   146→**Arguments:**\\n   147→- `--session-ref` — Path to the transcript file\\n   148→\\n   149→**Output (stdout):** Raw transcript bytes.\\n   150→\\n   151→#### `chunk-transcript --max-size <n>`\\n   152→\\n   153→Splits a transcript into chunks for storage.\\n   154→\\n   155→**Input (stdin):** Raw transcript bytes.\\n   156→\\n   157→**Arguments:**\\n   158→- `--max-size` — Maximum chunk size in bytes\\n   159→\\n   160→**Output (stdout):** JSON\\n   161→\\n   162→```json\\n   163→{\\\"chunks\\\": [\\\"<base64-encoded-chunk>\\\", \\\"...\\\"]}\\n   164→```\\n   165→\\n   166→#### `reassemble-transcript`\\n   167→\\n   168→Reassembles transcript chunks back into a full transcript.\\n   169→\\n   170→**Input (stdin):** JSON\\n   171→\\n   172→```json\\n   173→{\\\"chunks\\\": [\\\"<base64-encoded-chunk>\\\", \\\"...\\\"]}\\n   174→```\\n   175→\\n   176→**Output (stdout):** Raw transcript bytes.\\n   177→\\n   178→#### `format-resume-command --session-id <id>`\\n   179→\\n   180→Returns the command a user can run to resume a session.\\n   181→\\n   182→**Arguments:**\\n   183→- `--session-id` — Session identifier\\n   184→\\n   185→**Output (stdout):** JSON\\n   186→\\n   187→```json\\n   188→{\\\"command\\\": \\\"cursor --resume abc123\\\"}\\n   189→```\\n   190→\\n   191→### Capability: `hooks`\\n   192→\\n   193→These subcommands are required when `capabilities.hooks` is `true`.\\n   194→\\n   195→#### `parse-hook --hook <name>`\\n   196→\\n   197→Parses a raw agent hook payload into a structured event.\\n   198→\\n   199→**Arguments:**\\n   200→- `--hook` — Hook name (e.g., \\\"stop\\\", \\\"session-start\\\")\\n   201→\\n   202→**Input (stdin):** Raw agent hook payload bytes.\\n   203→\\n   204→**Output (stdout):** JSON — the parsed event, or `null` if the payload is not relevant.\\n   205→\\n   206→#### `install-hooks [--local-dev] [--force]`\\n   207→\\n   208→Installs agent hooks for Entire integration.\\n   209→\\n   210→**Arguments:**\\n   211→- `--local-dev` — Use local development binary path (optional)\\n   212→- `--force` — Overwrite existing hooks (optional)\\n   213→\\n   214→**Output (stdout):** JSON\\n   215→\\n   216→```json\\n   217→{\\\"hooks_installed\\\": 3}\\n   218→```\\n   219→\\n   220→#### `uninstall-hooks`\\n   221→\\n   222→Removes installed agent hooks.\\n   223→\\n   224→**Arguments:** None\\n   225→\\n   226→**Output:** Exit 0 on success.\\n   227→\\n   228→#### `are-hooks-installed`\\n   229→\\n   230→Checks whether hooks are currently installed.\\n   231→\\n   232→**Arguments:** None\\n   233→\\n   234→**Output (stdout):** JSON\\n   235→\\n   236→```json\\n   237→{\\\"installed\\\": true}\\n   238→```\\n   239→\\n   240→### Capability: `transcript_analyzer`\\n   241→\\n   242→Required when `capabilities.transcript_analyzer` is `true`.\\n   243→\\n   244→#### `get-transcript-position --path <path>`\\n   245→\\n   246→Returns the current byte position/size of a transcript file.\\n   247→\\n   248→**Arguments:**\\n   249→- `--path` — Path to the transcript file\\n   250→\\n   251→**Output (stdout):** JSON\\n   252→\\n   253→```json\\n   254→{\\\"position\\\": 12345}\\n   255→```\\n   256→\\n   257→#### `extract-modified-files --path <path> --offset <n>`\\n   258→\\n   259→Extracts the list of files modified by the agent from a transcript.\\n   260→\\n   261→**Arguments:**\\n   262→- `--path` — Path to the transcript file\\n   263→- `--offset` — Byte offset to start reading from\\n   264→\\n   265→**Output (stdout):** JSON\\n   266→\\n   267→```json\\n   268→{\\\"files\\\": [\\\"path/to/file1.go\\\", \\\"path/to/file2.go\\\"]}\\n   269→```\\n   270→\\n   271→#### `extract-prompts --session-ref <path> --offset <n>`\\n   272→\\n   273→Extracts user prompts from a transcript.\\n   274→\\n   275→**Arguments:**\\n   276→- `--session-ref` — Path to the transcript file\\n   277→- `--offset` — Byte offset to start reading from\\n   278→\\n   279→**Output (stdout):** JSON\\n   280→\\n   281→```json\\n   282→{\\\"prompts\\\": [\\\"first prompt text\\\", \\\"second prompt text\\\"]}\\n   283→```\\n   284→\\n   285→#### `extract-summary --session-ref <path>`\\n   286→\\n   287→Extracts an AI-generated summary from a transcript.\\n   288→\\n   289→**Arguments:**\\n   290→- `--session-ref` — Path to the transcript file\\n   291→\\n   292→**Output (stdout):** JSON\\n   293→\\n   294→```json\\n   295→{\\\"summary\\\": \\\"Summary text here\\\", \\\"has_summary\\\": true}\\n   296→```\\n   297→\\n   298→### Capability: `transcript_preparer`\\n   299→\\n   300→Required when `capabilities.transcript_preparer` is `true`.\\n   301→\\n   302→#### `prepare-transcript --session-ref <path>`\\n   303→\\n   304→Prepares/processes a transcript file (e.g., converting from raw format).\\n   305→\\n   306→**Arguments:**\\n   307→- `--session-ref` — Path to the transcript file\\n   308→\\n   309→**Output:** Exit 0 on success.\\n   310→\\n   311→### Capability: `token_calculator`\\n   312→\\n   313→Required when `capabilities.token_calculator` is `true`.\\n   314→\\n   315→#### `calculate-tokens --offset <n>`\\n   316→\\n   317→Calculates token usage from a transcript.\\n   318→\\n   319→**Input (stdin):** Raw transcript bytes.\\n   320→\\n   321→**Arguments:**\\n   322→- `--offset` — Byte offset to start calculating from\\n   323→\\n   324→**Output (stdout):** JSON\\n   325→\\n   326→```json\\n   327→{\\\"input_tokens\\\": 1500, \\\"output_tokens\\\": 500}\\n   328→```\\n   329→\\n   330→### Capability: `text_generator`\\n   331→\\n   332→Required when `capabilities.text_generator` is `true`.\\n   333→\\n   334→#### `generate-text --model <model>`\\n   335→\\n   336→Generates text using the agent's underlying LLM.\\n   337→\\n   338→**Input (stdin):** Prompt text.\\n   339→\\n   340→**Arguments:**\\n   341→- `--model` — Model to use for generation\\n   342→\\n   343→**Output (stdout):** JSON\\n   344→\\n   345→```json\\n   346→{\\\"text\\\": \\\"Generated response text\\\"}\\n   347→```\\n   348→\\n   349→### Capability: `hook_response_writer`\\n   350→\\n   351→Required when `capabilities.hook_response_writer` is `true`.\\n   352→\\n   353→#### `write-hook-response --message <message>`\\n   354→\\n   355→Writes a message in the agent's native hook response format.\\n   356→\\n   357→**Arguments:**\\n   358→- `--message` — Message to write\\n   359→\\n   360→**Output (stdout):** Agent-native format bytes (e.g., JSONL for Claude Code).\\n   361→\\n   362→### Capability: `subagent_aware_extractor`\\n   363→\\n   364→Required when `capabilities.subagent_aware_extractor` is `true`.\\n   365→\\n   366→#### `extract-all-modified-files --offset <n> --subagents-dir <dir>`\\n   367→\\n   368→Extracts modified files from both the main transcript and any subagent transcripts.\\n   369→\\n   370→**Input (stdin):** Raw main transcript bytes.\\n   371→\\n   372→**Arguments:**\\n   373→- `--offset` — Byte offset for the main transcript\\n   374→- `--subagents-dir` — Directory containing subagent transcripts\\n   375→\\n   376→**Output (stdout):** JSON\\n   377→\\n   378→```json\\n   379→{\\\"files\\\": [\\\"file1.go\\\", \\\"file2.go\\\"]}\\n   380→```\\n   381→\\n   382→#### `calculate-total-tokens --offset <n> --subagents-dir <dir>`\\n   383→\\n   384→Calculates total token usage across main transcript and subagent transcripts.\\n   385→\\n   386→**Input (stdin):** Raw main transcript bytes.\\n   387→\\n   388→**Arguments:**\\n   389→- `--offset` — Byte offset for the main transcript\\n   390→- `--subagents-dir` — Directory containing subagent transcripts\\n   391→\\n   392→**Output (stdout):** JSON\\n   393→\\n   394→```json\\n   395→{\\\"input_tokens\\\": 5000, \\\"output_tokens\\\": 2000}\\n   396→```\\n   397→\\n   398→## Error Handling\\n   399→\\n   400→- Exit code `0` indicates success.\\n   401→- Any non-zero exit code indicates an