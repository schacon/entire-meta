n    82→\\t}\\n    83→\\tif result.APICallCount != 1 {\\n    84→\\t\\tt.Errorf(\\\"APICallCount = %d, want 1\\\", result.APICallCount)\\n    85→\\t}\\n    86→}\\n    87→\\n    88→func TestCalculateTokenUsage_ClaudeCodeWithOffset(t *testing.T) {\\n    89→\\tt.Parallel()\\n    90→\\n    91→\\t// 4-line transcript; start at offset 2 to only count the second pair\\n    92→\\tlines := []string{\\n    93→\\t\\t`{\\\"type\\\":\\\"human\\\",\\\"uuid\\\":\\\"u1\\\",\\\"message\\\":{\\\"content\\\":\\\"first\\\"}}`,\\n    94→\\t\\t`{\\\"type\\\":\\\"assistant\\\",\\\"uuid\\\":\\\"u2\\\",\\\"message\\\":{\\\"id\\\":\\\"msg_001\\\",\\\"usage\\\":{\\\"input_tokens\\\":10,\\\"output_tokens\\\":5}}}`,\\n    95→\\t\\t`{\\\"type\\\":\\\"human\\\",\\\"uuid\\\":\\\"u3\\\",\\\"message\\\":{\\\"content\\\":\\\"second\\\"}}`,\\n    96→\\t\\t`{\\\"type\\\":\\\"assistant\\\",\\\"uuid\\\":\\\"u4\\\",\\\"message\\\":{\\\"id\\\":\\\"msg_002\\\",\\\"usage\\\":{\\\"input_tokens\\\":20,\\\"output_tokens\\\":15}}}`,\\n    97→\\t}\\n    98→\\tdata := []byte(strings.Join(lines, \\\"\\\\n\\\") + \\\"\\\\n\\\")\\n    99→\\n   100→\\tag, err := agent.GetByAgentType(agent.AgentTypeClaudeCode)\\n   101→\\tif err != nil {\\n   102→\\t\\tt.Fatalf(\\\"GetByAgentType(ClaudeCode) error: %v\\\", err)\\n   103→\\t}\\n   104→\\tfull := agent.CalculateTokenUsage(context.Background(), ag, data, 0, \\\"\\\")\\n   105→\\tsliced := agent.CalculateTokenUsage(context.Background(), ag, data, 2, \\\"\\\")\\n   106→\\n   107→\\tif full == nil || sliced == nil {\\n   108→\\t\\tt.Fatal(\\\"expected non-nil results\\\")\\n   109→\\t}\\n   110→\\tif full.OutputTokens != 20 {\\n   111→\\t\\tt.Errorf(\\\"full OutputTokens = %d, want 20\\\", full.OutputTokens)\\n   112→\\t}\\n   113→\\tif sliced.OutputTokens != 15 {\\n   114→\\t\\tt.Errorf(\\\"sliced OutputTokens = %d, want 15\\\", sliced.OutputTokens)\\n   115→\\t}\\n   116→}\\n   117→\\n   118→// cursorSampleTranscript is a subset of a real Cursor session transcript.\\n   119→// Cursor uses \\\"role\\\" (not \\\"type\\\") and wraps user text in <user_query> tags.\\n   120→var cursorSampleTranscript = strings.Join([]string{\\n   121→\\t`{\\\"role\\\":\\\"user\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"<user_query>\\\\ncreate a file with contents 'a' and commit, then create another file with contents 'b' and commit\\\\n</user_query>\\\"}]}}`,\\n   122→\\t`{\\\"role\\\":\\\"assistant\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"Creating two files (contents 'a' and 'b') and committing each.\\\"}]}}`,\\n   123→\\t`{\\\"role\\\":\\\"assistant\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"Both files are tracked and the working tree is clean.\\\"}]}}`,\\n   124→\\t`{\\\"role\\\":\\\"user\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"<user_query>\\\\ncreate a file with contents 'c' and commit\\\\n</user_query>\\\"}]}}`,\\n   125→\\t`{\\\"role\\\":\\\"assistant\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"Created c.txt with contents c and committed it.\\\"}]}}`,\\n   126→\\t`{\\\"role\\\":\\\"user\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"<user_query>\\\\nadd a file called bingo and commit\\\\n</user_query>\\\"}]}}`,\\n   127→\\t`{\\\"role\\\":\\\"assistant\\\",\\\"message\\\":{\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"Created bingo and committed it.\\\"}]}}`,\\n   128→}, \\\"\\\\n\\\") + \\\"\\\\n\\\"\\n   129→\\n   130→func TestCountTranscriptItems_Cursor(t *testing.T) {\\n   131→\\tt.Parallel()\\n   132→\\n   133→\\tcount := countTranscriptItems(agent.AgentTypeCursor, cursorSampleTranscript)\\n   134→\\tif count != 7 {\\n   135→\\t\\tt.Errorf(\\\"countTranscriptItems(Cursor) = %d, want 7\\\", count)\\n   136→\\t}\\n   137→}\\n   138→\\n   139→func TestCountTranscriptItems_CursorEmpty(t *testing.T) {\\n   140→\\tt.Parallel()\\n   141→\\n   142→\\tcount := countTranscriptItems(agent.AgentTypeCursor, \\\"\\\")\\n   143→\\tif count != 0 {\\n   144→\\t\\tt.Errorf(\\\"countTranscriptItems(Cursor, empty) = %d, want 0\\\", count)\\n   145→\\t}\\n   146→}\\n   147→\\n   148→func TestExtractUserPrompts_Cursor(t *testing.T) {\\n   149→\\tt.Parallel()\\n   150→\\n   151→\\t// Cursor uses \\\"role\\\":\\\"user\\\" instead of \\\"type\\\":\\\"human\\\". extractUserPromptsFromLines\\n   152→\\t// handles both via the \\\"role\\\" fallback.\\n   153→\\tprompts := extractUserPrompts(agent.AgentTypeCursor, cursorSampleTranscript)\\n   154→\\tif len(prompts) != 3 {\\n   155→\\t\\tt.Fatalf(\\\"extractUserPrompts(Cursor) returned %d prompts, want 3\\\", len(prompts))\\n   156→\\t}\\n   157→\\n   158→\\tif !strings.Contains(prompts[0], \\\"create a file with contents 'a'\\\") {\\n   159→\\t\\tt.Errorf(\\\"prompt[0] = %q, expected to contain file creation request\\\", prompts[0])\\n   160→\\t}\\n   161→\\tif !strings.Contains(prompts[2], \\\"bingo\\\") {\\n   162→\\t\\tt.Errorf(\\\"prompt[2] = %q, expected to contain 'bingo'\\\", prompts[2])\\n   163→\\t}\\n   164→\\n   165→\\t// Verify <user_query> tags are stripped\\n   166→\\tfor i, p := range prompts {\\n   167→\\t\\tif strings.Contains(p, \\\"<user_query>\\\") || strings.Contains(p, \\\"</user_query>\\\") {\\n   168→\\t\\t\\tt.Errorf(\\\"prompt[%d] still contains <user_query> tags: %q\\\", i, p)\\n   169→\\t\\t}\\n   170→\\t}\\n   171→}\\n   172→\\n   173→func TestExtractUserPrompts_CursorEmpty(t *testing.T) {\\n   174→\\tt.Parallel()\\n   175→\\n   176→\\tprompts := extractUserPrompts(agent.AgentTypeCursor, \\\"\\\")\\n   177→\\tif len(prompts) != 0 {\\n   178→\\t\\tt.Errorf(\\\"extractUserPrompts(Cursor, empty) = %v, want empty\\\", prompts)\\n   179→\\t}\\n   180→}\\n   181→\\n   182→func TestCalculateTokenUsage_CursorRealTranscript(t *testing.T) {\\n   183→\\tt.Parallel()\\n   184→\\n   185→\\t// Even with a multi-line real transcript, Cursor should return nil\\n   186→\\tag, err := agent.GetByAgentType(agent.AgentTypeCursor)\\n   187→\\tif err != nil {\\n   188→\\t\\tt.Fatalf(\\\"GetByAgentType(Cursor) error: %v\\\", err)\\n   189→\\t}\\n   190→\\tresult := agent.CalculateTokenUsage(context.Background(), ag, []byte(cursorSampleTranscript), 0, \\\"\\\")\\n   191→\\tif result != nil {\\n   192→\\t\\tt.Errorf(\\\"CalculateTokenUsage(Cursor, real transcript) = %+v, want nil\\\", result)\\n   193→\\t}\\n   194→}\\n   195→\\n   196→func TestCalculateTokenUsage_CursorWithOffset(t *testing.T) {\\n   197→\\tt.Parallel()\\n   198→\\n   199→\\t// Offset should not matter — Cursor always returns nil\\n   200→\\tag, err := agent.GetByAgentType(agent.AgentTypeCursor)\\n   201→\\tif err != nil {\\n   202→\\t\\tt.Fatalf(\\\"GetByAgentType(Cursor) error: %v\\\", err)\\n   203→\\t}\\n   204→\\tresult := agent.CalculateTokenUsage(context.Background(), ag, []byte(cursorSampleTranscript), 3, \\\"\\\")\\n   205→\\tif result != nil {\\n   206→\\t\\tt.Errorf(\\\"CalculateTokenUsage(Cursor, offset=3) = %+v, want nil\\\", result)\\n   207→\\t}\\n   208→}\\n   209→\\n   210→func TestGenerateContextFromPrompts_CJKTruncation(t *testing.T) {\\n   211→\\tt.Parallel()\\n   212→\\n   213→\\t// 600 CJK characters exceeds the 500-rune truncation limit.\\n   214→\\tprompt := strings.Repeat(\\\"あ\\\", 600)\\n   215→\\n   216→\\tresult := generateContextFromPrompts([]string{prompt})\\n   217→\\n   218→\\tif !utf8.Valid(result) {\\n   219→\\t\\tt.Error(\\\"generateContextFromPrompts produced invalid UTF-8 when truncating a CJK prompt\\\")\\n   220→\\t}\\n   221→\\n   222→\\tresultStr := string(result)\\n   223→\\tif !strings.Contains(resultStr, \\\"...\\\") {\\n   224→\\t\\tt.Error(\\\"expected truncated CJK prompt to contain '...' suffix\\\")\\n   225→\\t}\\n   226→\\t// Should not contain more than 500 CJK characters\\n   227→\\tif strings.Contains(resultStr, strings.Repeat(\\\"あ\\\", 501)) {\\n   228→\\t\\tt.Error(\\\"CJK prompt was not truncated\\\")\\n   229→\\t}\\n   230→}\\n   231→\\n   232→func TestGenerateContextFromPrompts_EmojiTruncation(t *testing.T) {\\n   233→\\tt.Parallel()\\n   234→\\n   235→\\t// 600 emoji exceeds the 500-rune truncation limit.\\n   236→\\tprompt := strings.Repeat(\\\"🎉\\\", 600)\\n   237→\\n   238→\\tresult := generateContextFromPrompts([]string{prompt})\\n   239→\\n   240→\\tif !utf8.Valid(result) {\\n   241→\\t\\tt.Error(\\\"generateContextFromPrompts produced invalid UTF-8 when truncating an emoji prompt\\\")\\n   242→\\t}\\n   243→\\n   244→\\tresultStr := string(result)\\n   245→\\tif !strings.Contains(resultStr, \\\"...\\\") {\\n   246→\\t\\tt.Error(\\\"expected truncated emoji prompt to contain '...' suffix\\\")\\n   247→\\t}\\n   248→}\\n   249→\\n   250→func TestGenerateContextFromPrompts_ASCIITruncation(t *testing.T) {\\n   251→\\tt.Parallel()\\n   252→\\n   253→\\t// Pure ASCII: should truncate at 500 runes with \\\"...\\\" suffix.\\n   254→\\tprompt := strings.Repeat(\\\"a\\\", 600)\\n   255→\\n   256→\\tresult := generateContextFromPrompts([]string{prompt})\\n   257→\\n   258→\\tif !utf8.Valid(result) {\\n   259→\\t\\tt.Error(\\\"generateContextFromPrompts produced invalid UTF-8 when truncating an ASCII prompt\\\")\\n   260→\\t}\\n   261→\\n   262→\\tresultStr := string(result)\\n   263→\\tif !strings.Contains(resultStr, \\\"...\\\") {\\n   264→\\t\\tt.Error(\\\"expected truncated prompt to contain '...' suffix\\\")\\n   265→\\t}\\n   266→\\n   267→\\tif strings.Contains(resultStr, strings.Repeat(\\\"a\\\", 501)) {\\n   268→\\t\\tt.Error(\\\"prompt was not truncated\\\")\\n   269→\\t}\\n   270→}\\n   271→\\n   272→func TestGenerateContextFromPrompts_ShortCJKNotTruncated(t *testing.T) {\\n   273→\\tt.Parallel()\\n   274→\\n   275→\\t// 200 CJK characters is under the 500-rune limit, should not be truncated.\\n   276→\\tprompt := strings.Repeat(\\\"あ\\\", 200)\\n   277→\\n   278→\\tresult := generateContextFromPrompts([]string{prompt})\\n   279→\\n   280→\\tif !utf8.Valid(result) {\\n   281→\\t\\tt.Error(\\\"generateContextFromPrompts produced invalid UTF-8\\\")\\n   282→\\t}\\n   283→\\n   284→\\tresultStr := string(result)\\n   285→\\tif strings.Contains(resultStr, \\\"...\\\") {\\n   286→\\t\\tt.Error(\\\"short CJK prompt should not be truncated\\\")\\n   287→\\t}\\n   288→}\\n   289→\\n   290→// droidSampleTranscript is a Droid JSONL transcript with user and assistant messages\\n   291→// in Droid's envelope format: {\\\"type\\\":\\\"message\\\",\\\"message\\\":{\\\"role\\\":\\\"...\\\",\\\"content\\\":[...]}}.\\n   292→var droidSampleTranscript = strings.Join([]string{\\n   293→\\t`{\\\"type\\\":\\\"session_start\\\",\\\"session\\\":{\\\"session_id\\\":\\\"s1\\\"}}`,\\n   294→\\t`{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"m1\\\",\\\"message\\\":{\\\"role\\\":\\\"user\\\",\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"create a file called hello.go\\\"}]}}`,\\n   295→\\t`{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"m2\\\",\\\"message\\\":{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"I'll create that file.\\\"}]}}`,\\n   296→\\t`{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"m3\\\",\\\"message\\\":{\\\"role\\\":\\\"user\\\",\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"<ide_opened_file>some content</ide_opened_file>now add a main function\\\"}]}}`,\\n   297→\\t`{\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"m4\\\",\\\"message\\\":{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":[{\\\"type\\\":\\\"text\\\",\\\"text\\\":\\\"Added the main function.\\\"}]}}`,\\n   298→}, \\\"\\\\n\\\") + \\\"\\\\n\\\"\\n   299→\\n   300→func TestExtractUserPrompts_Droid(t *testing.T) {\\n   301→\\tt.Parallel()\\n   302→\\n   303→\\tprompts := extractUserPrompts(agent.AgentTypeFactoryAIDroid, droidSampleTranscript)\\n   304→\\tif len(prompts) != 2 {\\n   305→\\t\\tt.Fatalf(\\\"extractUserPrompts(Droid) returned %d prompts, want 2\\\", len(prompts))\\n   306→\\t}\\n   307→\\n   308→\\tif prompts[0] != \\\"create a file called hello.go\\\" {\\n   309→\\t\\tt.Errorf(\\\"prompt[0] = %q, want %q\\\", prompts[0], \\\"create a file called hello.go\\\")\\n   310→\\t}\\n   311→\\n   312→\\t// Verify IDE tags are stripped\\n   313→\\tif strings.Contains(prompts[1], \\\"<ide_opened_file>\\\") {\\n   314→\\t\\tt.Errorf(\\\"prompt[1] still contains IDE tags: %q\\\", prompts[1])\\n   315→\\t}\\n   316→\\tif prompts[1] != \\\"now add a main function\\\" {\\n   317→\\t\\tt.Errorf(\\\"prompt[1] = %q, want %q\\\", prompts[1], \\\"now add a main function\\\")\\n   318→\\t}\\n   319→}\\n   320→\\n   321→func TestExtractUserPrompts_DroidEmpty(t *testing.T) {\\n   322→\\tt.Parallel()\\n   323→\\n   324→\\tprompts := extractUserPrompts(agent.AgentTypeFactoryAIDroid, \\\"\\\")\\n   325→\\tif len(prompts) != 0 {\\n   326→\\t\\tt.Errorf(\\\"extractUserPrompts(Droid, empty) = %v, want empty\\\", prompts)\\n   327→\\t}\\n   328→}\\n   329→\\n   330→// droidMessage builds a Droid JSONL \\\"message\\\" line with the given id, role, and optional usage.\\n   331→func droidMessage(t *testing.T, id, role string, usage map[string]int) string {\\n   332→\\tt.Helper()\\n   333→\\tinner := map[string]interface{}{\\n   334→\\t\\t\\\"role\\\":    role,\\n   335→\\t\\t\\\"content\\\": []interface{}{},\\n   336→\\t}\\n   337→\\tif usage != nil {\\n   338→\\t\\tinner[\\\"id\\\"] = id\\n   339→\\t\\tinner[\\\"usage\\\"] = usage\\n   340→\\t}\\n   341→\\tmsg, err := json.Marshal(inner)\\n   342→\\tif err != nil {\\n   343→\\t\\tt.Fatalf(\\\"failed to marshal inner message: %v\\\", err)\\n   344→\\t}\\n   345→\\tline := map[string]interface{}{\\n   346→\\t\\t\\\"type\\\":    \\\"message\\\",\\n   347→\\t\\t\\\"id\\\":      id,\\n   348→\\t\\t\\\"message\\\": json.RawMessage(msg),\\n   349→\\t}\\n   350→\\tb, err := json.Marshal(line)\\n   351→\\tif err != nil {\\n   352→\\t\\tt.Fatalf(\\\"failed to marshal droid line: %v\\\", err)\\n   353→\\t}\\n   354→\\treturn string(b)\\n   355→}\\n   356→\\n   357→func TestCalculateTokenUsage_DroidStartOffsetSkipsNonMessageLines(t *testing.T) {\\n   358→\\tt.Parallel()\\n   359→\\n   360→\\t// Build a Droid transcript with non-message entries interspersed:\\n   361→\\t// Line 0: session_start (non-message)\\n   362→\\t// Line 1: user message (no tokens)\\n   363→\\t// Line 2: assistant message with 10 input, 20 output tokens\\n   364→\\t// Line 3: session_event (non-message)\\n   365→\\t// Line 4: assistant message with 5 input, 30 output tokens\\n   366→\\ttranscript := \\\"\\\" +\\n   367→\\t\\t`{\\\"type\\\":\\\"session_start\\\",\\\"id\\\":\\\"s1\\\"}` + \\\"\\\\n\\\" +\\n   368→\\t\\tdroidMessage(t, \\\"m1\\\", \\\"user\\\", nil) + \\\"\\\\n\\\" +\\n   369→\\t\\tdroidMessage(t, \\\"m2\\\", \\\"assistant\\\", map[string]int{\\n   370→\\t\\t\\t\\\"input_tokens\\\": 10, \\\"output_tokens\\\": 20,\\n   371→\\t\\t}) + \\\"\\\\n\\\" +\\n   372→\\t\\t`{\\\"type\\\":\\\"session_event\\\",\\\"data\\\":\\\"heartbeat\\\"}` + \\\"\\\\n\\\" +\\n   373→\\t\\tdroidMessage(t, \\\"m3\\\", \\\"assistant\\\", map[string]int{\\n   374→\\t\\t\\t\\\"input_tokens\\\": 5, \\\"output_tokens\\\": 30,\\n   375→\\t\\t}) + \\\"\\\\n\\\"\\n   376→\\n   377→\\tdata := []byte(transcript)\\n   378→\\n   379→\\t// With startOffset=0: should count all messages (m2 + m3)\\n   380→\\tusageAll := calculateTokenUsage(agent.AgentTypeFactoryAIDroid, data, 0)\\n   381→\\tif usageAll.InputTokens != 15 {\\n   382→\\t\\tt.Errorf(\\\"startOffset=0: InputTokens = %d, want 15\\\", usageAll.InputTokens)\\n   383→\\t}\\n   384→\\tif usageAll.OutputTokens != 50 {\\n   385→\\t\\tt.Errorf(\\\"startOffset=0: OutputTokens = %d, want 50\\\", usageAll.OutputTokens)\\n   386→\\t}\\n   387→\\tif usageAll.APICallCount != 2 {\\n   388→\\t\\tt.Errorf(\\\"startOffset=0: APICallCount = %d, want 2\\\", usageAll.APICallCount)\\n   389→\\t}\\n   390→\\n   391→\\t// With startOffset=3: skip lines 0-2 (session_start, m1, m2).\\n   392→\\t// Only line 3 (session_event, filtered) and line 4 (m3) remain.\\n   393→\\t// Should count only m3's tokens.\\n   394→\\tusageFrom3 := calculateTokenUsage(agent.AgentTypeFactoryAIDroid, data, 3)\\n   395→\\tif usageFrom3.InputTokens != 5 {\\n   396→\\t\\tt.Errorf(\\\"startOffset=3: InputTokens = %d, want 5\\\", usageFrom3.InputTokens)\\n   397→\\t}\\n   398→\\tif usageFrom3.OutputTokens != 30 {\\n   399→\\t\\tt.Errorf(\\\"startOffset=3: OutputTokens = %d, want 30\\\", usageFrom3.OutputTokens)\\n   400→\\t}\\n   401→\\tif usageFrom3.APICallCount != 1 {\\n   402→\\t\\tt.Errorf(\\\"startOffset=3: APICallCount = %d, want 1\\\", usageFrom3.APICallCount)\\n   403→\\t}\\n   404→\\n   405→\\t// Regression: using the OLD buggy code would have parsed all messages (ignoring\\n   406→\\t// non-message entries), producing [m1, m2, m3], then sliced at index 3 which\\n   407→\\t// is out of bounds — returning all tokens instead of just m3's.\\n   408→\\t// With startOffset=1: skip only line 0 (session_start).\\n   409→\\t// Lines 1 (m1), 2 (m2), 3 (session_event, filtered), 4 (m3) remain.\\n   410→\\tusageFrom1 := calculateTokenUsage(agent.AgentTypeFactoryAIDroid, data, 1)\\n   411→\\tif usageFrom1.InputTokens != 15 {\\n   412→\\t\\tt.Errorf(\\\"startOffset=1: InputTokens = %d, want 15\\\", usageFrom1.InputTokens)\\n   413→\\t}\\n   414→\\tif usageFrom1.APICallCount != 2 {\\n   415→\\t\\tt.Errorf(\\\"startOffset=1: APICallCount = %d, want 2\\\", usageFrom1.APICallCount)\\n   416→\\t}\\n   417→}\\n   418→\\n   419→// Verify that startOffset beyond transcript length returns empty usage.\\n   420→func TestCalculateTokenUsage_DroidStartOffsetBeyondEnd(t *testing.T) {\\n   421→\\tt.Parallel()\\n   422→\\n   423→\\tdata := []byte(\\n   424→\\t\\t`{\\\"type\\\":\\\"session_start\\\",\\\"id\\\":\\\"s1\\\"}` + \\\"\\\\n\\\" +\\n   425→\\t\\t\\tdroidMessage(t, \\\"m1\\\", \\\"assistant\\\", map[string]int{\\n   426→\\t\\t\\t\\t\\\"input_tokens\\\": 10, \\\"output_tokens\\\": 20,\\n   427→\\t