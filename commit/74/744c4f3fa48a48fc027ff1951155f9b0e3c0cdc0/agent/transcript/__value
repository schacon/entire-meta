eservesShadowBranch(t *testing.T) {\\n   262→\\tdir := setupGitRepo(t)\\n   263→\\tt.Chdir(dir)\\n   264→\\n   265→\\trepo, err := git.PlainOpen(dir)\\n   266→\\trequire.NoError(t, err)\\n   267→\\n   268→\\ts := &ManualCommitStrategy{}\\n   269→\\tsessionID := \\\"test-postcommit-condense-fail-idle\\\"\\n   270→\\n   271→\\t// Initialize session and save a checkpoint\\n   272→\\tsetupSessionWithCheckpoint(t, s, repo, dir, sessionID)\\n   273→\\n   274→\\t// Set phase to IDLE\\n   275→\\tstate, err := s.loadSessionState(sessionID)\\n   276→\\trequire.NoError(t, err)\\n   277→\\tstate.Phase = session.PhaseIdle\\n   278→\\tstate.LastInteractionTime = nil\\n   279→\\tstate.FilesTouched = []string{\\\"test.txt\\\"}\\n   280→\\trequire.NoError(t, s.saveSessionState(state))\\n   281→\\n   282→\\t// Record original BaseCommit and StepCount before corruption\\n   283→\\toriginalBaseCommit := state.BaseCommit\\n   284→\\toriginalStepCount := state.StepCount\\n   285→\\n   286→\\t// Corrupt shadow branch by pointing it at ZeroHash\\n   287→\\tshadowBranch := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   288→\\tcorruptRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(shadowBranch), plumbing.ZeroHash)\\n   289→\\trequire.NoError(t, repo.Storer.SetReference(corruptRef))\\n   290→\\n   291→\\t// Create a commit with the checkpoint trailer\\n   292→\\tcommitWithCheckpointTrailer(t, repo, dir, \\\"e5f6a1b2c3d4\\\")\\n   293→\\n   294→\\t// Run PostCommit\\n   295→\\terr = s.PostCommit()\\n   296→\\trequire.NoError(t, err, \\\"PostCommit should not return error even when condensation fails\\\")\\n   297→\\n   298→\\t// Verify BaseCommit was NOT updated (condensation failed)\\n   299→\\tstate, err = s.loadSessionState(sessionID)\\n   300→\\trequire.NoError(t, err)\\n   301→\\tassert.Equal(t, originalBaseCommit, state.BaseCommit,\\n   302→\\t\\t\\\"BaseCommit should NOT be updated when condensation fails\\\")\\n   303→\\tassert.Equal(t, originalStepCount, state.StepCount,\\n   304→\\t\\t\\\"StepCount should NOT be reset when condensation fails\\\")\\n   305→\\n   306→\\t// Verify entire/checkpoints/v1 branch does NOT exist (condensation failed)\\n   307→\\t_, err = repo.Reference(plumbing.NewBranchReferenceName(paths.MetadataBranchName), true)\\n   308→\\trequire.Error(t, err,\\n   309→\\t\\t\\\"entire/checkpoints/v1 branch should NOT exist when condensation fails\\\")\\n   310→\\n   311→\\t// Phase transition still applies even when condensation fails\\n   312→\\tassert.Equal(t, session.PhaseIdle, state.Phase,\\n   313→\\t\\t\\\"phase should remain IDLE when condensation fails\\\")\\n   314→}\\n   315→\\n   316→// TestPostCommit_IdleSession_NoNewContent_PreservesBaseCommit verifies that when\\n   317→// an IDLE session has no new transcript content since last condensation,\\n   318→// PostCommit skips condensation and does NOT update BaseCommit.\\n   319→//\\n   320→// This prevents the bug where old IDLE sessions would have their BaseCommit\\n   321→// incorrectly updated, causing them to be condensed on future commits.\\n   322→func TestPostCommit_IdleSession_NoNewContent_PreservesBaseCommit(t *testing.T) {\\n   323→\\tdir := setupGitRepo(t)\\n   324→\\tt.Chdir(dir)\\n   325→\\n   326→\\trepo, err := git.PlainOpen(dir)\\n   327→\\trequire.NoError(t, err)\\n   328→\\n   329→\\ts := &ManualCommitStrategy{}\\n   330→\\tsessionID := \\\"test-postcommit-idle-no-content\\\"\\n   331→\\n   332→\\t// Initialize session and save a checkpoint\\n   333→\\tsetupSessionWithCheckpoint(t, s, repo, dir, sessionID)\\n   334→\\n   335→\\t// Set phase to IDLE with CheckpointTranscriptStart matching transcript length (2 lines)\\n   336→\\tstate, err := s.loadSessionState(sessionID)\\n   337→\\trequire.NoError(t, err)\\n   338→\\tstate.Phase = session.PhaseIdle\\n   339→\\tstate.LastInteractionTime = nil\\n   340→\\tstate.CheckpointTranscriptStart = 2 // Transcript has exactly 2 lines\\n   341→\\trequire.NoError(t, s.saveSessionState(state))\\n   342→\\n   343→\\t// Record shadow branch name and original BaseCommit\\n   344→\\tshadowBranch := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   345→\\toriginalBaseCommit := state.BaseCommit\\n   346→\\toriginalStepCount := state.StepCount\\n   347→\\n   348→\\t// Create a commit with the checkpoint trailer\\n   349→\\tcommitWithCheckpointTrailer(t, repo, dir, \\\"f6a1b2c3d4e5\\\")\\n   350→\\n   351→\\t// Run PostCommit\\n   352→\\terr = s.PostCommit()\\n   353→\\trequire.NoError(t, err)\\n   354→\\n   355→\\t// Verify BaseCommit was NOT updated (IDLE sessions don't get BaseCommit updated)\\n   356→\\tstate, err = s.loadSessionState(sessionID)\\n   357→\\trequire.NoError(t, err)\\n   358→\\tassert.Equal(t, originalBaseCommit, state.BaseCommit,\\n   359→\\t\\t\\\"BaseCommit should NOT be updated for IDLE session with no new content\\\")\\n   360→\\n   361→\\t// Shadow branch should still exist (not deleted, no condensation)\\n   362→\\trefName := plumbing.NewBranchReferenceName(shadowBranch)\\n   363→\\t_, err = repo.Reference(refName, true)\\n   364→\\trequire.NoError(t, err,\\n   365→\\t\\t\\\"shadow branch should still exist when no condensation happened\\\")\\n   366→\\n   367→\\t// entire/checkpoints/v1 branch should NOT exist (no condensation)\\n   368→\\t_, err = repo.Reference(plumbing.NewBranchReferenceName(paths.MetadataBranchName), true)\\n   369→\\trequire.Error(t, err,\\n   370→\\t\\t\\\"entire/checkpoints/v1 branch should NOT exist when no condensation happened\\\")\\n   371→\\n   372→\\t// StepCount should be unchanged\\n   373→\\tassert.Equal(t, originalStepCount, state.StepCount,\\n   374→\\t\\t\\\"StepCount should be unchanged when no condensation happened\\\")\\n   375→}\\n   376→\\n   377→// TestPostCommit_EndedSession_FilesTouched_Condenses verifies that an ENDED\\n   378→// session with files touched and new content condenses on commit.\\n   379→func TestPostCommit_EndedSession_FilesTouched_Condense