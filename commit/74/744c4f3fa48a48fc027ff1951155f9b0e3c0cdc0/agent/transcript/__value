72→\\n   273→\\t// Create the commit\\n   274→\\tcommitHash, err := s.createCommit(newTreeHash, parentHash, opts.CommitMessage, opts.AuthorName, opts.AuthorEmail)\\n   275→\\tif err != nil {\\n   276→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   277→\\t}\\n   278→\\n   279→\\t// Update shadow branch reference\\n   280→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   281→\\tref := plumbing.NewHashReference(refName, commitHash)\\n   282→\\tif err := s.repo.Storer.SetReference(ref); err != nil {\\n   283→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to update shadow branch reference: %w\\\", err)\\n   284→\\t}\\n   285→\\n   286→\\treturn commitHash, nil\\n   287→}\\n   288→\\n   289→// addTaskMetadataToTree adds task checkpoint metadata to a git tree.\\n   290→// When IsIncremental is true, only adds the incremental checkpoint file.\\n   291→func (s *GitStore) addTaskMetadataToTree(baseTreeHash plumbing.Hash, opts WriteTemporaryTaskOptions) (plumbing.Hash, error) {\\n   292→\\t// Get base tree and flatten it\\n   293→\\tbaseTree, err := s.repo.TreeObject(baseTreeHash)\\n   294→\\tif err != nil {\\n   295→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get base tree: %w\\\", err)\\n   296→\\t}\\n   297→\\n   298→\\tentries := make(map[string]object.TreeEntry)\\n   299→\\tif err := FlattenTree(s.repo, baseTree, \\\"\\\", entries); err != nil {\\n   300→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten tree: %w\\\", err)\\n   301→\\t}\\n   302→\\n   303→\\t// Compute metadata paths\\n   304→\\tsessionMetadataDir := paths.EntireMetadataDir + \\\"/\\\" + opts.SessionID\\n   305→\\ttaskMetadataDir := sessionMetadataDir + \\\"/tasks/\\\" + opts.ToolUseID\\n   306→\\n   307→\\tif opts.IsIncremental {\\n   308→\\t\\t// Incremental checkpoint: only add the checkpoint file\\n   309→\\t\\t// Use proper JSON marshaling to handle nil/empty IncrementalData correctly\\n   310→\\t\\tvar incData []byte\\n   311→\\t\\tif opts.IncrementalData != nil {\\n   312→\\t\\t\\tincData, err = redact.JSONLBytes(opts.IncrementalData)\\n   313→\\t\\t\\tif err != nil {\\n   314→\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to redact incremental checkpoint: %w\\\", err)\\n   315→\\t\\t\\t}\\n   316→\\t\\t}\\n   317→\\t\\tincrementalCheckpoint := struct {\\n   318→\\t\\t\\tType      string          `json:\\\"type\\\"`\\n   319→\\t\\t\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   320→\\t\\t\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n   321→\\t\\t\\tData      json.RawMessage `json:\\\"data\\\"`\\n   322→\\t\\t}{\\n   323→\\t\\t\\tType:      opts.IncrementalType,\\n   324→\\t\\t\\tToolUseID: opts.ToolUseID,\\n   325→\\t\\t\\tTimestamp: time.Now().UTC(),\\n   326→\\t\\t\\tData:      incData,\\n   327→\\t\\t}\\n   328→\\t\\tcpData, err := jsonutil.MarshalIndentWithNewline(incrementalCheckpoint, \\\"\\\", \\\"  \\\")\\n   329→\\t\\tif err != nil {\\n   330→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to marshal incremental checkpoint: %w\\\", err)\\n   331→\\t\\t}\\n   332→\\n   333→\\t\\tcpBlobHash, err := CreateBlobFromContent(s.repo, cpData)\\n   334→\\t\\tif err != nil {\\n   335→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create incremental checkpoint blob: %w\\\", err)\\n   336→\\t\\t}\\n   337→\\t\\tcpFilename := fmt.Sprintf(\\\"%03d-%s.json\\\", opts.IncrementalSequence, opts.ToolUseID)\\n   338→\\t\\tcpPath := taskMetadataDir + \\\"/checkpoints/\\\" + cpFilename\\n   339→\\t\\tentries[cpPath] = object.TreeEntry{\\n   340→\\t\\t\\tName: cpPath,\\n   341→\\t\\t\\tMode: filemode.Regular,\\n   342→\\t\\t\\tHash: cpBlobHash,\\n   343→\\t\\t}\\n   344→\\t} else {\\n   345→\\t\\t// Final checkpoint: add transcripts and checkpoint.json\\n   346→\\n   347→\\t\\t// Add session transcript (with chunking support for large transcripts)\\n   348→\\t\\tif opts.TranscriptPath != \\\"\\\" {\\n   349→\\t\\t\\tif transcriptContent, readErr := os.ReadFile(opts.TranscriptPath); readErr == nil {\\n   350→\\t\\t\\t\\t// Detect agent type from content for proper chunking\\n   351→\\t\\t\\t\\tagentType := agent.DetectAgentTypeFromContent(transcriptContent)\\n   352→\\n   353→\\t\\t\\t\\t// Chunk if necessary\\n   354→\\t\\t\\t\\tchunks, chunkErr := agent.ChunkTranscript(transcriptContent, agentType)\\n   355→\\t\\t\\t\\tif chunkErr != nil {\\n   356→\\t\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to chunk transcript, checkpoint will be saved without transcript\\\",\\n   357→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", chunkErr.Error()),\\n   358→\\t\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n   359→\\t\\t\\t\\t\\t)\\n   360→\\t\\t\\t\\t} else {\\n   361→\\t\\t\\t\\t\\tfor i, chunk := range chunks {\\n   362→\\t\\t\\t\\t\\t\\tchunkPath := sessionMetadataDir + \\\"/\\\" + agent.ChunkFileName(paths.TranscriptFileName, i)\\n   363→\\t\\t\\t\\t\\t\\tblobHash, blobErr := CreateBlobFromContent(s.repo, chunk)\\n   364→\\t\\t\\t\\t\\t\\tif blobErr != nil {\\n   365→\\t\\t\\t\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to create blob for transcript chunk\\\",\\n   366→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", blobErr.Error()),\\n   367→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n   368→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"chunk_index\\\", i),\\n   369→\\t\\t\\t\\t\\t\\t\\t)\\n   370→\\t\\t\\t\\t\\t\\t\\tcontinue\\n   371→\\t\\t\\t\\t\\t\\t}\\n   372→\\t\\t\\t\\t\\t\\tentries[chunkPath] = object.TreeEntry{\\n   373→\\t\\t\\t\\t\\t\\t\\tName: chunkPath,\\n   374→\\t\\t\\t\\t\\t\\t\\tMode: filemode.Regular,\\n   375→\\t\\t\\t\\t\\t\\t\\tHash: blobHash,\\n   376→\\t\\t\\t\\t\\t\\t}\\n   377→\\t\\t\\t\\t\\t}\\n   378→\\t\\t\\t\\t}\\n   379→\\t\\t\\t}\\n   380→\\t\\t}\\n   381→\\n   382→\\t\\t// Add subagent transcript if available\\n   383→\\t\\tif opts.SubagentTranscriptPath != \\\"\\\" && opts.AgentID != \\\"\\\" {\\n   384→\\t\\t\\tif agentContent, readErr := os.ReadFile(opts.SubagentTranscriptPath); readErr == nil {\\n   385→\\t\\t\\t\\tif blobHash, blobErr := CreateBlobFromContent(s.repo, agentContent); blobErr == nil {\\n   386→\\t\\t\\t\\t\\tagentPath := taskMetadataDir + \\\"/agent-\\\" + opts.AgentID + \\\".jsonl\\\"\\n   387→\\t\\t\\t\\t\\tentries[agentPath] = object.TreeEntry{\\n   388→\\t\\t\\t\\t\\t\\tName: agentPath,\\n   389→\\t\\t\\t\\t\\t\\tMode: filemode.Regular,\\n   390→\\t\\t\\t\\t\\t\\tHash: blobHash,\\n   391→\\t\\t\\t\\t\\t}\\n   392→\\t\\t\\t\\t}\\n   393→\\t\\t\\t}\\n   394→\\t\\t}\\n   395→\\n   396→\\t\\t// Add checkpoint.json\\n   397→\\t\\tcheckpointJSON := fmt.Sprintf(`{\\n   398→  \\\"session_id\\\": %q,\\n   399→  \\\"tool_use_id\\\": %q,\\n   400→  \\\"checkpoint_uuid\\\": %q,\\n   401→  \\\"agent_id\\\": %q\\n   402→}`, opts.SessionID, opts.ToolUseID, opts.CheckpointUUID, opts.AgentID)\\n   403→\\n   404→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(checkpointJSON))\\n   405→\\t\\tif err != nil {\\n   406→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create checkpoint blob: %w\\\", err)\\n   407→\\t\\t}\\n   408→\\t\\tcheckpointPath := taskMetadataDir + \\\"/checkpoint.json\\\"\\n   409→\\t\\tentries[checkpointPath] = object.TreeEntry{\\n   410→\\t\\t\\tName: checkpointPath,\\n   411→\\t\\t\\tMode: filemode.Regular,\\n   412→\\t\\t\\tHash: blobHash,\\n   413→\\t\\t}\\n   414→\\t}\\n   415→\\n   416→\\t// Build new tree from entries\\n   417→\\treturn BuildTreeFromEntries(s.repo, entries)\\n   418→}\\n   419→\\n   420→// ListTemporaryCheckpoints lists all checkpoint commits on a shadow branch.\\n   421→// This returns individual commits (rewind points), not just branch info.\\n   422→// The sessionID filter, if provided, limits results to commits from that session.\\n   423→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   424→func (s *GitStore) ListTemporaryCheckpoints(ctx context.Context, baseCommit, worktreeID, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   425→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   426→\\treturn s.listCheckpointsForBranch(ctx, shadowBranchName, sessionID, limit)\\n   427→}\\n   428→\\n   429→// ListCheckpointsForBranch lists checkpoint commits for a shadow branch by name.\\n   430→// Use this when you already have the full branch name (e.g., from ListTemporary).\\n   431→// The sessionID filter, if provided, limits results to commits from that session.\\n   432→func (s *GitStore) ListCheckpointsForBranch(ctx context.Context, branchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   433→\\treturn s.listCheckpointsForBranch(ctx, branchName, sessionID, limit)\\n   434→}\\n   435→\\n   436→// listCheckpointsForBranch lists checkpoint commits for a specific shadow branch name.\\n   437→// This is an internal helper used by ListTemporaryCheckpoints, ListCheckpointsForBranch, and ListAllTemporaryCheckpoints.\\n   438→func (s *GitStore) listCheckpointsForBranch(ctx context.Context, shadowBranchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   439→\\t_ = ctx // Reserved for future use\\n   440→\\n   441→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   442→\\n   443→\\tref, err := s.repo.Reference(refName, true)\\n   444→\\tif err != nil {\\n   445→\\t\\treturn nil, nil //nolint:nilerr // No shadow branch is expected case\\n   446→\\t}\\n   447→\\n   448→\\titer, err := s.repo.Log(&git.LogOptions{From: ref.Hash()})\\n   449→\\tif err != nil {\\n   450→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   451→\\t}\\n   452→\\n   453→\\tvar results []TemporaryCheckpointInfo\\n   454→\\tcount := 0\\n   455→\\n   456→\\terr = iter.ForEach(func(c *object.Commit) error {\\n   457→\\t\\tif count >= limit*5 { // Scan more to allow for session filtering\\n   458→\\t\\t\\treturn errStop\\n   459→\\t\\t}\\n   460→\\t\\tcount++\\n   461→\\n   462→\\t\\t// Verify commit belongs to target session via Entire-Session trailer\\n   463→\\t\\tcommitSessionID, hasTrailer := trailers.ParseSession(c.Message)\\n   464→\\t\\tif !hasTrailer {\\n   465→\\t\\t\\treturn nil // Skip commits without session trailer\\n   466→\\t\\t}\\n   467→\\t\\tif sessionID != \\\"\\\" && commitSessionID != sessionID {\\n   468→\\t\\t\\treturn nil // Skip commits from other sessions\\n   469→\\t\\t}\\n   470→\\n   471→\\t\\t// Get first line of message\\n   472→\\t\\tmessage := c.Message\\n   473→\\t\\tif idx := strings.Index(message, \\\"\\\\n\\\"); idx > 0 {\\n   474→\\t\\t\\tmessage = message[:idx]\\n   475→\\t\\t}\\n   476→\\n   477→\\t\\tinfo := TemporaryCheckpointInfo{\\n   478→\\t\\t\\tCommitHash: c.Hash,\\n   479→\\t\\t\\tMessage:    message,\\n   480→\\t\\t\\tSessionID:  commitSessionID,\\n   481→\\t\\t\\tTimestamp:  c.Author.When,\\n   482→\\t\\t}\\n   483→\\n   484→\\t\\t// Check for task checkpoint first\\n   485→\\t\\ttaskMetadataDir, foundTask := trailers.ParseTaskMetadata(c.Message)\\n   486→\\t\\tif foundTask {\\n   487→\\t\\t\\tinfo.IsTaskCheckpoint = true\\n   488→\\t\\t\\tinfo.MetadataDir = taskMetadataDir\\n   489→\\t\\t\\tinfo.ToolUseID = extractToolUseIDFromPath(taskMetadataDir)\\n   490→\\t\\t} else {\\n   491→\\t\\t\\tmetadataDir, found := trailers.ParseMetadata(c.Message)\\n   492→\\t\\t\\tif found {\\n   493→\\t\\t\\t\\tinfo.MetadataDir = metadataDir\\n   494→\\t\\t\\t}\\n   495→\\t\\t}\\n   496→\\n   497→\\t\\tresults = append(results, info)\\n   498→\\n   499→\\t\\tif len(results) >= limit {\\n   500→\\t\\t\\treturn errStop\\n   501→\\t\\t}\\n   502→\\t\\treturn nil\\n   503→\\t})\\n   504→\\n   505→\\tif err != nil && !errors.Is(err, errStop) {\\n   506→\\t\\treturn nil, fmt.Errorf(\\\"error iterating commits: %w\\\", err)\\n   507→\\t}\\n   508→\\n   509→\\treturn results, nil\\n   510→}\\n   511→\\n   512→// ListAllTemporaryCheckpoints lists checkpoint commits from ALL shadow branches.\\n   513→// This is used for checkpoint lookup when the base commit is unknown (e.g., HEAD advanced since session start).\\n   514→// The sessionID filter, if provided, limits results to commits from that session.\\n   515→func (s *GitStore) ListAllTemporaryCheckpoints(ctx context.Context, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   516→\\t_ = ctx // Reserved for future use\\n   517→\\n   518→\\t// List all shadow branches\\n   519→\\tbranches, err := s.ListTemporary(ctx)\\n   520→\\tif err != nil {\\n   521→\\t\\treturn nil, fmt.Errorf(\\\"failed to list shadow branches: %w\\\", err)\\n   522→\\t}\\n   523→\\n   524→\\tvar results []TemporaryCheckpointInfo\\n   525→\\n   526→\\t// Iterate through each shadow branch and collect checkpoints\\n   527→\\tfor _, branch := range branches {\\n   528→\\t\\t// Use the branch name directly to get checkpoints\\n   529→\\t\\tbranchCheckpoints, branchErr := s.listCheckpointsForBranch(ctx, branch.BranchName, sessionID, limit)\\n   530→\\t\\tif branchErr != nil {\\n   531→\\t\\t\\tcontinue // Skip branches we can't read\\n   532→\\t\\t}\\n   533→\\t\\tresults = append(results, branchCheckpoints...)\\n   534→\\t\\tif len(results) >= limit {\\n   535→\\t\\t\\tresults = results[:limit]\\n   536→\\t\\t\\tbreak\\n   537→\\t\\t}\\n   538→\\t}\\n   539→\\n   540→\\treturn results, nil\\n   541→}\\n   542→\\n   543→// extractToolUseIDFromPath extracts the ToolUseID from a task metadata directory path.\\n   544→// Task metadata dirs have format: .entire/metadata/<session>/tasks/<toolUseID>\\n   545→func extractToolUseIDFromPath(metadataDir string) string {\\n   546→\\tparts := strings.Split(metadataDir, \\\"/\\\")\\n   547→\\tif len(parts) >= 2 && parts[len(parts)-2] == \\\"tasks\\\" {\\n   548→\\t\\treturn parts[len(parts)-1]\\n   549→\\t}\\n   550→\\treturn \\\"\\\"\\n   551→}\\n   552→\\n   553→// errStop is a sentinel error used to break out of git log iteration.\\n   554→var errStop = errors.New(\\\"stop iteration\\\")\\n   555→\\n   556→// GetTranscriptFromCommit retrieves the transcript from a specific commit's tree.\\n   557→// This is used for shadow branch checkpoints where the transcript is stored in the commit tree\\n   558→// rather than on the entire/checkpoints/v1 branch.\\n   559→// commitHash is the commit to read from, metadataDir is the path within the tree.\\n   560→// agentType is used for reassembling chunked transcripts in the correct format.\\n   561→// Handles both chunked and non-chunked transcripts.\\n   562→func (s *GitStore) GetTranscriptFromCommit(commitHash plumbing.Hash, metadataDir string, agentType agent.AgentType) ([]byte, error) {\\n   563→\\tcommit, err := s.repo.CommitObject(commitHash)\\n   564→\\tif err != nil {\\n   565→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   566→\\t}\\n   567→\\n   568→\\ttree, err := commit.Tree()\\n   569→\\tif err != nil {\\n   570→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   571→\\t}\\n   572→\\n   573→\\t// Try to get the metadata subtree for chunk detection\\n   574→\\tsubTree, subTreeErr := tree.Tree(metadataDir)\\n   575→\\tif subTreeErr == nil {\\n   576→\\t\\t// Use the helper function that handles chunking\\n   577→\\t\\ttranscript, err := readTranscriptFromTree(subTree, agentType)\\n   578→\\t\\tif err == nil && transcript != nil {\\n   579→\\t\\t\\treturn transcript, nil\\n   580→\\t\\t}\\n   581→\\t}\\n   582→\\n   583→\\t// Fall back to direct file access (for backwards compatibility)\\n   584→\\ttranscriptPath := metadataDir + \\\"/\\\" + paths.TranscriptFileName\\n   585→\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n   586→\\t\\tcontent, contentErr := file.Contents()\\n   587→\\t\\tif contentErr == nil {\\n   588→\\t\\t\\treturn []byte(content), nil\\n   589→\\t\\t}\\n   590→\\t}\\n   591→\\n   592→\\ttranscriptPath = metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n   593→\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n   594→\\t\\tcontent, contentErr := file.Contents()\\n   595→\\t\\tif contentErr == nil {\\n   596→\\t\\t\\treturn []byte(content), nil\\n   597→\\t\\t}\\n   598→\\t}\\n   599→\\n   600→\\treturn nil, ErrNoTranscript\\n   601→}\\n   602→\\n   603→// ShadowBranchExists checks if a shadow branch exists for the given base commit and worktree.\\n   604→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   605→func (s *GitStore) ShadowBranchExists(baseCommit, worktreeID string) bool {\\n   606→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   607→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   608→\\t_, err := s.repo.Reference(refName, true)\\n   609→\\treturn err == nil\\n   610→}\\n   611→\\n   612→// DeleteShadowBranch deletes the shadow branch for the given base commit and worktree.\\n   613→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   614→// Uses git CLI instead of go-git's RemoveReference because go-git v5 doesn't properly\\n   615→// persist deletions with packed refs or worktrees.\\n   616→func (s *GitStore) DeleteShadowBranch(baseCommit, worktreeID string) error {\\n   617→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   618→\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", shadowBranchName) //nolint:gosec // shadowBranchName is constructed from commit hash, not user input\\n   619→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   620→\\t\\treturn fmt.Errorf(\\\"failed to delete shadow branch %s: %s: %w\\\", shadowBranchName, strings.TrimSpace(string(output)), err)\\n   621→\\t}\\n   622→\\treturn nil\\n   623→}\\n   624→\\n   625→// ShadowBranchNameForCommit returns the shadow branch name for a base commit hash\\n   626→// and worktree identifier. The worktree ID should be empty for the main worktree\\n   627→// or the internal git worktree name for linked worktrees.\\n   628→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   629→func ShadowBranchNameForCommit(baseCommit, worktreeID string) string {\\n   630→\\tcommitPart := baseCommit\\n   631→\\tif len(baseCommit) >= ShadowBranchHashLength {\\n   632→\\t\\tcommitPart = baseCommit[:ShadowBranchHashLength]\\n   633→\\t}\\n   634→\\tworktreeHash := HashWorktreeID(worktreeID)\\n   635→\\treturn ShadowBranchPrefix + commitPart + \\\"-\\\" + worktreeHash\\n   636→}\\n   637→\\n   638→// ParseShadowBranchName extracts the commit prefix and worktree hash from a shadow branch name.\\n   639→// Input format: \\\"entire/<commit[:7]>-<worktreeHash[:6]>\\\"\\n   640→// Returns (commitPrefix, worktreeHash, ok). Returns (\\\"\\\", \\\"\\\", false) if not a valid shadow branch.\\n   641→func ParseShadowBranchName(branchName string) (commitPrefix, worktreeHash string, ok bool) {\\n   642→\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n   643→\\t\\treturn \\\"\\\", \\\"\\\", false\\n   644→\\t}\\n   645→\\tsuffix := strings.TrimPrefix(branchName, ShadowBranchPrefix)\\n   646→\\n   647→\\t// Find the last dash - everything before is commit prefix, after is worktree hash\\n   648→\\tlastDash := strings.LastIndex(suffix, \\\"-\\\")\\n   649→\\tif lastDash == -1 || lastDash == 0 || lastDash == len(suffix)-1 {\\n   650→\\t\\t// No dash, or dash at start/end - invalid format\\n   651→\\t\\t// Could be old format \\\"entire/<commit[:7]>\\\" without worktree hash\\n   652→\\t\\treturn suffix, \\\"\\\", true // Return as commit prefix with empty worktree hash\\n   653→\\t}\\n   654→\\n   655→\\treturn suffix[:lastDash], suffix[lastDash+1:], true\\n   656→}\\n   657→\\n   658→// getOrCreateShadowBranch gets or creates the shadow branch for checkpoints.\\n   659→// Returns (parentHash, baseTreeHash, error).\\n   660→func (s *GitStore) getOrCreateShadowBranch(branchName string) (plumbing.Hash, plumbing.Hash, error) {\\n   661→\\trefName := plumbing.NewBranchReferenceName(branchName)\\n   662→\\tref, err := s.repo.Reference(refName, true)\\n   663→\\n   664→\\tif err == nil {\\n   665→\\t\\t// Branch exists\\n   666→\\t\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n   667→\\t\\tif err != nil {\\n   668→\\t\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   669→\\t\\t}\\n   670→\\t\\treturn ref.Hash(), commit.TreeHash, nil\\n   671→\\t}\\n   672→\\n   673→\\t// Branch doesn't exist, use current HEAD's tree as base\\n   674→\\thead, err := s.repo.Head()\\n   675→\\tif err != nil {\\n   676→\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   677→\\t}\\n   678→\\n   679→\\theadCommit, err := s.repo.CommitObject(head.Hash())\\n   680→\\tif err != nil {\\n   681→\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   682→\\t}\\n   683→\\n   684→\\treturn plumbing.ZeroHash, headCommit.TreeHash, nil\\n   685→}\\n   686→\\n   687→// buildTreeWithChanges builds a git tree with the given changes.\\n   688→// metadataDir is the relative path for git tree entries, metadataDirAbs is the absolute path\\n   689→// for filesystem operations (needed when CLI is run from a subdirectory).\\n   690→func (s *GitStore) buildTreeWithChanges(\\n   691→\\tbaseTreeHash plumbing.Hash,\\n   692→\\tmodifiedFiles, deletedFiles []string,\\n   693→\\tmetadataDir, metadataDirAbs string,\\n   694→) (plumbing.Hash, error) {\\n   695→\\t// Get repo root for resolving file paths\\n   696→\\t// This is critical because fileExists() and createBlobFromFile() use os.Stat()\\n   697→\\t// which resolves relative to CWD. The modifiedFiles are repo-relative paths,\\n   698→\\t// so we must resolve them against repo root, not CWD.\\n   699→\\trepoRoot, err := paths.RepoRoot()\\n   700→\\tif err != nil {\\n   701→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   702→\\t}\\n   703→\\n   704→\\t// Get the base tree\\n   705→\\tbaseTree, err := s.repo.TreeObject(baseTreeHash)\\n   706→\\tif err != nil {\\n   707→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get base tree: %w\\\", err)\\n   708→\\t}\\n   709→\\n   710→\\t// Flatten existing tree\\n   711→\\tentries := make(map[string]object.TreeEntry)\\n   712→\\tif err := FlattenTree(s.repo, baseTree, \\\"\\\", entries); err != nil {\\n   713→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten base tree: %w\\\", err)\\n   714→\\t}\\n   715→\\n   716→\\t// Remove deleted files\\n   717→\\tfor _, file := range deletedFiles {\\n   718→\\t\\tdelete(entries, file)\\n   719→\\t}\\n   720→\\n   721→\\t// Add/update modified files\\n   722→\\tfor _, file := range modifiedFiles {\\n   723→\\t\\t// Resolve path relative to repo root for filesystem operations\\n   724→\\t\\tabsPath := filepath.Join(repoRoot, file)\\n   725→\\t\\tif !fileExists(absPath) {\\n   726→\\t\\t\\tdelete(entries, file)\\n   727→\\t\\t\\tcontinue\\n   728→\\t\\t}\\n   729→\\n   730→\\t\\tblobHash, mode, err := createBlobFromFile(s.repo, absPath)\\n   731→\\t\\tif err != nil {\\n   732→\\t\\t\\t// Skip files that can't be staged (may have been deleted since detection)\\n   733→\\t\\t\\tcontinue\\n   734→\\t\\t}\\n   735→\\n   736→\\t\\tentries[file] = object.TreeEntry{\\n   737→\\t\\t\\tName: file,\\n   738→\\t\\t\\tMode: mode,\\n   739→\\t\\t\\tHash: blobHash,\\n   740→\\t\\t}\\n   741→\\t}\\n   742→\\n   743→\\t// Add metadata directory files\\n   744→\\tif metadataDir != \\\"\\\" && metadataDirAbs != \\\"\\\" {\\n   745→\\t\\tif err := addDirectoryToEntriesWithAbsPath(s.repo, metadataDirAbs, metadataDir, entries); err != nil {\\n   746→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to add metadata directory: %w\\\", err)\\n   747→\\t\\t}\\n   748→\\t}\\n   749→\\n   750→\\t// Build tree\\n   751→\\treturn BuildTreeFromEntries(s.repo, entries)\\n   752→}\\n   753→\\n   754→// createCommit creates a commit object.\\n   755→func (s *GitStore) createCommit(treeHash, parentHash plumbing.Hash, message, authorName, authorEmail string) (plumbing.Hash, error) {\\n   756→\\tnow := time.Now()\\n   757→\\tsig := object.Signature{\\n   758→\\t\\tName:  authorName,\\n   759→\\t\\tEmail: authorEmail,\\n   760→\\t\\tWhen:  now,\\n   761→\\t}\\n   762→\\n   763→\\tcommit := &object.Commit{\\n   764→\\t\\tTreeHash:  treeHash,\\n   765→\\t\\tAuthor:    sig,\\n   766→\\t\\tCommitter: sig,\\n   767→\\t\\tMessage:   message,\\n   768→\\t}\\n   769→\\n   770→\\t// Add parent if not a new branch\\n   771→\\tif parentHash != plumbing.ZeroHash {\\n   772→\\t\\tcommit.ParentHashes = []plumbing.Hash{parentHash}\\n   773→\\t}\\n   774→\\n   775→\\tobj := s.repo.Storer.NewEncodedObject()\\n   776→\\tif err := commit.Encode(obj); err != nil {\\n   777→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n   778→\\t}\\n   779→\\n   780→\\thash, err := s.repo.Storer.SetEncodedObject(obj)\\n   781→\\tif err != nil {\\n   782→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store commit: %w\\\", err)\\n   783→\\t}\\n   784→\\n   785→\\treturn hash, nil\\n   786→}\\n   787→\\n   788→// Helper functions extracted from strategy/common.go\\n   789→// These are exported for use by strategy package (push_common.go, session_test.go)\\n   790→\\n   791→// FlattenTree recursively flattens a tree into a map of full paths to entries.\\n   792→func FlattenTree(repo *git.Repository, tree *object.Tree, prefix string, entries map[string]object.TreeEntry) error {\\n   793→\\tfor _, entry := range tree.Entries {\\n   794→\\t\\tfullPath := entry.Name\\n   795→\\t\\tif prefix != \\\"\\\" {\\n   796→\\t\\t\\tfullPath = prefix + \\\"/\\\" + entry.Name\\n   797→\\t\\t}\\n   798→\\n   799→\\t\\tif entry.Mode == filemode.Dir {\\n   800→\\t\\t\\t// Recurse into subtree\\n   801→\\t\\t\\tsubtree, err := repo.TreeObject(entry.Hash)\\n   802→\\t\\t\\tif err != nil {\\n   803→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to get subtree %s: %w\\\", fullPath, err)\\n   804→\\t\\t\\t}\\n   805→\\t\\t\\tif err := FlattenTree(repo, subtree, fullPath, entries); err != nil {\\n   806→\\t\\t\\t\\treturn err\\n   807→\\t\\t\\t}\\n   808→\\t\\t} else {\\n   809→\\t\\t\\tentries[fullPath] = object.TreeEntry{\\n   810→\\t\\t\\t\\tName: fullPath,\\n   811→\\t\\t\\t\\tMode: entry.Mode,\\n   812→\\t\\t\\t\\tHash: entry.Hash,\\n   813→\\t\\t\\t}\\n   814→\\t\\t}\\n   815→\\t}\\n   816→\\treturn nil\\n   817→}\\n   818→\\n   819→// fileExists checks if a file exists at the given path.\\n   820→func fileExists(path string) bool {\\n   821→\\t_, err := os.Stat(path)\\n   822→\\treturn err == nil\\n   823→}\\n   824→\\n   825→// createBlobFromFile creates a blob object from a file in the working directory.\\n   826→func createBlobFromFile(repo *git.Repository, filePath string) (plumbing.Hash, filemode.FileMode, error) {\\n   827→\\tinfo, err := os.Stat(filePath)\\n   828→\\tif err != nil {\\n   829→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to stat file: %w\\\", err)\\n   830→\\t}\\n   831→\\n   832→\\t// Determine file mode\\n   833→\\tmode := filemode.Regular\\n   834→\\tif info.Mode()&0o111 != 0 {\\n   835→\\t\\tmode = filemode.Executable\\n   836→\\t}\\n   837→\\tif info.Mode()&os.ModeSymlink != 0 {\\n   838→\\t\\tmode = filemode.Symlink\\n   839→\\t}\\n   840→\\n   841→\\t// Read file contents\\n   842→\\tcontent, err := os.ReadFile(filePath) //nolint:gosec // filePath comes from walking the repository\\n   843→\\tif err != nil {\\n   844→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to read file: %w\\\", err)\\n   845→\\t}\\n   846→\\n   847→\\t// Create blob object\\n   848→\\tobj := repo.Storer.NewEncodedObject()\\n   849→\\tobj.SetType(plumbing.BlobObject)\\n   850→\\tobj.SetSize(int64(len(content)))\\n   851→\\n   852→\\twriter, err := obj.Writer()\\n   853→\\tif err != nil {\\n   854→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to get object writer: %w\\\", err)\\n   855→\\t}\\n   856→\\n   857→\\t_, err = writer.Write(content)\\n   858→\\tif err != nil {\\n   859→\\t\\t_ = writer.Close()\\n   860→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to write blob content: %w\\\", err)\\n   861→\\t}\\n   862→\\tif err := writer.Close(); err != nil {\\n   863→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to close blob writer: %w\\\", err)\\n   864→\\t}\\n   865→\\n   866→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n   867→\\tif err != nil {\\n   868→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to store blob object: %w\\\", err)\\n   869→\\t}\\n   870→\\n   871→\\treturn hash, mode, nil\\n   872→}\\n   873→\\n   874→// addDirectoryToEntriesWithAbsPath recursively adds all files in a directory to the entries map.\\n   875→func addDirectoryToEntriesWithAbsPath(repo *git.Repository, dirPathAbs, dirPathRel string, entries map[string]object.TreeEntry) error {\\n   876→\\terr := filepath.Walk(dirPathAbs, func(path string, info os.FileInfo, err error) error {\\n   877→\\t\\tif err != nil {\\n   878→\\t\\t\\treturn err\\n   879→\\t\\t}\\n   880→\\t\\tif info.IsDir() {\\n   881→\\t\\t\\treturn nil\\n   882→\\t\\t}\\n   883→\\n   884→\\t\\t// Calculate relative path within the directory, then join with dirPathRel for tree entry\\n   885→\\t\\trelWithinDir, err := filepath.Rel(dirPathAbs, path)\\n   886→\\t\\tif err != nil {\\n   887→\\t\\t\\treturn fmt.Errorf(\\\"failed to get relative path for %s: %w\\\", path, err)\\n   888→\\t\\t}\\n   889→\\n   890→\\t\\tblobHash, mode, err := createBlobFromFile(repo, path)\\n   891→\\t\\tif err != nil {\\n   892→\\t\\t\\treturn fmt.Errorf(\\\"failed to create blob for %s: %w\\\", path, err)\\n   893→\\t\\t}\\n   894→\\n   895→\\t\\ttreePath := filepath.Join(dirPathRel, relWithinDir)\\n   896→\\t\\tentries[treePath] = object.TreeEntry{\\n   897→\\t\\t\\tName: treePath,\\n   898→\\t\\t\\tMode: mode,\\n   899→\\t\\t\\tHash: blobHash,\\n   900→\\t\\t}\\n   901→\\t\\treturn nil\\n   902→\\t})\\n   903→\\tif err != nil {\\n   904→\\t\\treturn fmt.Errorf(\\\"failed to walk directory %s: %w\\\", dirPathAbs, err)\\n   905→\\t}\\n   906→\\treturn nil\\n   907→}\\n   908→\\n   909→// treeNode represents a node in our tree structure.\\n   910→type treeNode struct {\\n   911→\\tentries map[string]*treeNode // subdirectories\\n   912→\\tfiles   []object.TreeEntry   // files in this directory\\n   913→}\\n   914→\\n   915→// BuildTreeFromEntries builds a proper git tree structure from flattened file entries.\\n   916→// Exported for use by strategy package (push_common.go, session_test.go)\\n   917→func BuildTreeFromEntries(repo *git.Repository, entries map[string]object.TreeEntry) (plumbing.Hash, error) {\\n   918→\\t// Build a tree structure\\n   919→\\troot := &treeNode{\\n   920→\\t\\tentries: make(map[string]*treeNode),\\n   921→\\t\\tfiles:   []object.TreeEntry{},\\n   922→\\t}\\n   923→\\n   924→\\t// Insert all entries into the tree structure\\n   925→\\tfor fullPath, entry := range entries {\\n   926→\\t\\tparts := strings.Split(fullPath, \\\"/\\\")\\n   927→\\t\\tinsertIntoTree(root, parts, entry)\\n   928→\\t}\\n   929→\\n   930→\\t// Recursively build tree objects from bottom up\\n   931→\\treturn buildTreeObject(repo, root)\\n   932→}\\n   933→\\n   934→// insertIntoTree inserts a file entry into the tree structure.\\n   935→func insertIntoTree(node *treeNode, pathParts []string, entry object.TreeEntry) {\\n   936→\\tif len(pathParts) == 1 {\\n   937→\\t\\t// This is a file in the current directory\\n   938→\\t\\tnode.files = append(node.files, object.TreeEntry{\\n   939→\\t\\t\\tName: pathParts[0],\\n   940→\\t\\t\\tMode: entry.Mode,\\n   941→\\t\\t\\tHash: entry.Hash,\\n   942→\\t\\t})\\n   943→\\t\\treturn\\n   944→\\t}\\n   945→\\n   946→\\t// This is in a subdirectory\\n   947→\\tdirName := pathParts[0]\\n   948→\\tif node.entries[dirName] == nil {\\n   949→\\t\\tnode.entries[dirName] = &treeNode{\\n   950→\\t\\t\\tentries: make(map[string]*treeNode),\\n   951→\\t\\t\\tfiles:   []object.TreeEntry{},\\n   952→\\t\\t}\\n   953→\\t}\\n   954→\\tinsertIntoTree(node.entries[dirName], pathParts[1:], entry)\\n   955→}\\n   956→\\n   957→// buildTreeObject recursively builds tree objects from a treeNode.\\n   958→func buildTreeObject(repo *git.Repository, node *treeNode) (plumbing.Hash, error) {\\n   959→\\tvar treeEntries []object.TreeEntry\\n   960→\\n   961→\\t// Add files\\n   962→\\ttreeEntries = append(treeEntries, node.files...)\\n   963→\\n   964→\\t// Recursively build subtrees\\n   965→\\tfor name, subnode := range node.entries {\\n   966→\\t\\tsubHash, err := buildTreeObject(repo, subnode)\\n   967→\\t\\tif err != nil {\\n   968→\\t\\t\\treturn plumbing.ZeroHash, err\\n   969→\\t\\t}\\n   970→\\t\\ttreeEntries = append(treeEntries, object.TreeEntry{\\n   971→\\t\\t\\tName: name,\\n   972→\\t\\t\\tMode: filemode.Dir,\\n   973→\\t\\t\\tHash: subHash,\\n   974→\\t\\t})\\n   975→\\t}\\n   976→\\n   977→\\t// Sort entries (git requires sorted entries)\\n   978→\\tsortTreeEntries(treeEntries)\\n   979→\\n   980→\\t// Create tree object\\n   981→\\ttree := &object.Tree{Entries: treeEntries}\\n   982→\\n   983→\\tobj := repo.Storer.NewEncodedObject()\\n   984→\\tif err := tree.Encode(obj); err != nil {\\n   985→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode tree: %w\\\", err)\\n   986→\\t}\\n   987→\\n   988→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n   989→\\tif err != nil {\\n   990→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store tree: %w\\\", err)\\n   991→\\t}\\n   992→\\n   993→\\treturn hash, nil\\n   994→}\\n   995→\\n   996→// sortTreeEntries sorts tree entries in git's required order.\\n   997→// Git sorts tree entries by name, with directories having a trailing /\\n   998→func sortTreeEntries(entries []object.TreeEntry) {\\n   999→\\tsort.Slice(entries, func(i, j int) bool {\\n  1000→\\t\\tnameI := entries[i].Name\\n  1001→\\t\\tnameJ := entries[j].Name\\n  1002→\\t\\tif entries[i].Mode == filemode.Dir {\\n  1003→\\t\\t\\tnameI += \\\"/\\\"\\n  1004→\\t\\t}\\n  1005→\\t\\tif entries[j].Mode == filemode.Dir {\\n  1006→\\t\\t\\tnameJ += \\\"/\\\"\\n  1007→\\t\\t}\\n  1008→\\t\\treturn nameI < nameJ\\n  1009→\\t})\\n  1010→}\\n  1011→\\n  1012→// collectChangedFiles collects all changed files (modified tracked + untracked non-ignored)\\n  1013→// using git CLI. This is much faster than filesystem walk and respects all gitignore sources\\n  1014→// including global gitignore (core.excludesfile).\\n  1015→//\\n  1016→// Uses git CLI instead of go-git because go-git's worktree.Status() does not respect\\n  1017→// global gitignore, which can cause globally ignored files to appear as untracked.\\n  1018→// See: https://github.com/entireio/cli/pull/129\\n  1019→//\\n  1020→// changedFilesResult contains both changed and deleted files from git status.\\n  1021→type changedFilesResult struct {\\n  1022→\\tChanged []string // Files to include (modified, added, untracked, renamed, etc.)\\n  1023→\\tDeleted []string // Files that were deleted (need to be excluded from checkpoint tree)\\n  1024→}\\n  1025→\\n  1026→// collectChangedFiles returns all changed files from git status for the first checkpoint.\\n  1027→//\\n  1028→// For the first checkpoint, we need to capture:\\n  1029→// - Modified tracked files (user's uncommitted changes)\\n  1030→// - Untracked non-ignored files (new files not yet added to git)\\n  1031→// - Renamed/copied files (both source removal and destination)\\n  1032→// - Deleted files (to exclude from checkpoint tree)\\n  1033→//\\n  1034→// The base tree from HEAD already contains all unchanged tracked files.\\n  1035→//\\n  1036→// Uses `git status --porcelain -z` for reliable parsing of filenames with special characters.\\n  1037→func collectChangedFiles(ctx context.Context, repo *git.Repository) (changedFilesResult, error) {\\n  1038→\\t// Get repo root directory for running git command\\n  1039→\\twt, err := repo.Worktree()\\n  1040→\\tif err != nil {\\n  1041→\\t\\treturn changedFilesResult{}, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n  1042→\\t}\\n  1043→\\trepoRoot := wt.Filesystem.Root()\\n  1044→\\n  1045→\\t// Use -z for NUL-separated output (handles quoted filenames with spaces/special chars)\\n  1046→\\t// Use -uall to list individual untracked files instead of collapsed directories.\\n  1047→\\t// Note: CLAUDE.md warns against -uall for user-facing display, but we need the full list\\n  1048→\\t// for checkpointing.\\n  1049→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"status\\\", \\\"--porcelain\\\", \\\"-z\\\", \\\"-uall\\\")\\n  1050→\\tcmd.Dir = repoRoot\\n  1051→\\toutput, err := cmd.Output()\\n  1052→\\tif err != nil {\\n  1053→\\t\\treturn changedFilesResult{}, fmt.Errorf(\\\"failed to get git status in %s: %w\\\", repoRoot, err)\\n  1054→\\t}\\n  1055→\\n  1056→\\tchangedSeen := make(map[string]struct{})\\n  1057→\\tdeletedSeen := make(map[string]struct{})\\n  1058→\\n  1059→\\t// Parse NUL-separated output\\n  1060→\\t// Format: XY filename\\\\0 (for most entries)\\n  1061→\\t// For renames/copies: XY newname\\\\0oldname\\\\0\\n  1062→\\tentries := strings.Split(string(output), \\\"\\\\x00\\\")\\n  1063→\\n  1064→\\tfor i := 0; i < len(entries); i++ {\\n  1065→\\t\\tentry := entries[i]\\n  1066→\\t\\tif len(entry) < 3 {\\n  1067→\\t\\t\\tcontinue\\n  1068→\\t\\t}\\n  1069→\\n  1070→\\t\\t// git status --porcelain format: XY filename\\n  1071→\\t\\t// X = staging status, Y = worktree status\\n  1072→\\t\\tstaging := entry[0]\\n  1073→\\t\\twtStatus := entry[1]\\n  1074→\\t\\tfilename := entry[3:] // No TrimSpace needed with -z format\\n  1075→\\n  1076→\\t\\t// Handle R/C (rename/copy) first - they have a second entry we must skip\\n  1077→\\t\\t// even if the new filename is an infrastructure path\\n  1078→\\t\\tif staging == 'R' || staging == 'C' {\\n  1079→\\t\\t\\t// Renamed or copied: current entry is new name, next entry is old name\\n  1080→\\t\\t\\tif !paths.IsInfrastructurePath(filename) {\\n  1081→\\t\\t\\t\\tchangedSeen[filename] = struct{}{}\\n  1082→\\t\\t\\t}\\n  1083→\\t\\t\\t// The old name follows as the next NUL-separated entry - must always skip it\\n  1084→\\t\\t\\tif i+1 < len(entries) && entries[i+1] != \\\"\\\" {\\n  1085→\\t\\t\\t\\toldName := entries[i+1]\\n  1086→\\t\\t\\t\\tif staging == 'R' && !paths.IsInfrastructurePath(oldName) {\\n  1087→\\t\\t\\t\\t\\t// For renames, old file is effectively deleted\\n  1088→\\t\\t\\t\\t\\tdeletedSeen[oldName] = struct{}{}\\n  1089→\\t\\t\\t\\t}\\n  1090→\\t\\t\\t\\ti++ // Skip the old name entry\\n  1091→\\t\\t\\t}\\n  1092→\\t\\t\\tcontinue\\n  1093→\\t\\t}\\n  1094→\\n  1095→\\t\\t// Skip .entire directory for non-R/C entries\\n  1096→\\t\\tif paths.IsInfrastructurePath(filename) {\\n  1097→\\t\\t\\tcontinue\\n  1098→\\t\\t}\\n  1099→\\n  1100→\\t\\t// Handle different status codes\\n  1101→\\t\\tswitch {\\n  1102→\\t\\tcase staging == 'D' || wtStatus == 'D':\\n  1103→\\t\\t\\t// Deleted file - track separately\\n  1104→\\t\\t\\tdeletedSeen[filename] = struct{}{}\\n  1105→\\n  1106→\\t\\tcase wtStatus == 'M' || wtStatus == 'A':\\n  1107→\\t\\t\\t// Modified or added in worktree\\n  1108→\\t\\t\\tchangedSeen[filename] = struct{}{}\\n  1109→\\n  1110→\\t\\tcase staging == '?' && wtStatus == '?':\\n  1111→\\t\\t\\t// Untracked file\\n  1112→\\t\\t\\tchangedSeen[filename] = struct{}{}\\n  1113→\\n  1114→\\t\\tcase staging == 'A' || staging == 'M':\\n  1115→\\t\\t\\t// Staged add or modify\\n  1116→\\t\\t\\tchangedSeen[filename] = struct{}{}\\n  1117→\\n  1118→\\t\\tcase staging == 'T' || wtStatus == 'T':\\n  1119→\\t\\t\\t// Type change (e.g., file to symlink)\\n  1120→\\t\\t\\tchangedSeen[filename] = struct{}{}\\n  1121→\\n  1122→\\t\\tcase staging == 'U' || wtStatus == 'U':\\n  1123→\\t\\t\\t// Unmerged (conflict) - include current file state\\n  1124→\\t\\t\\tchangedSeen[filename] = struct{}{}\\n  1125→\\t\\t}\\n  1126→\\t}\\n  1127→\\n  1128→\\tchanged := make([]string, 0, len(changedSeen))\\n  1129→\\tfor file := range changedSeen {\\n  1130→\\t\\tchanged = append(changed, file)\\n  1131→\\t}\\n  1132→\\n  1133→\\tdeleted := make([]string, 0, len(deletedSeen))\\n  1134→\\tfor file := range deletedSeen {\\n  1135→\\t\\tdeleted = append(deleted, file)\\n  1136→\\t}\\n  1137→\\n  1138→\\treturn changedFilesResult{Changed: changed, Deleted: deleted}, nil\\n  1139→}\\n  1140→\"}]},\"uuid\":\"05e98be7-e05b-403a-8412-0a8383fa11f8\",\"timestamp\":\"2026-02-19T03:32:12.453Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alex/workspace/cli/.worktrees/2/cmd/entire/cli/checkpoint/temporary.go\",\"content\":\"package checkpoint\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"crypto/sha256\\\"\\n\\t\\\"encoding/hex\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"os/exec\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"sort\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n\\t\\\"github.com/entireio/cli/redact\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/filemode\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\nconst (\\n\\t// ShadowBranchPrefix is the prefix for shadow branches.\\n\\tShadowBranchPrefix = \\\"entire/\\\"\\n\\n\\t// ShadowBranchHashLength is the number of hex characters used in shadow branch names.\\n\\t// Shadow branches are named \\\"entire/<hash>\\\" using the first 7 characters of the commit hash.\\n\\tShadowBranchHashLength = 7\\n\\n\\t// WorktreeIDHashLength is the number of hex characters used for worktree ID hash.\\n\\tWorktreeIDHashLength = 6\\n)\\n\\n// HashWorktreeID returns a short hash of the worktree identifier.\\n// Used to create unique shadow branch names per worktree.\\nfunc HashWorktreeID(worktreeID string) string {\\n\\th := sha256.Sum256([]byte(worktreeID))\\n\\treturn hex.EncodeToString(h[:])[:WorktreeIDHashLength]\\n}\\n\\n// WriteTemporary writes a temporary checkpoint to a shadow branch.\\n// Shadow branches are named entire/<base-commit-short-hash>.\\n// Returns the result containing commit hash and whether it was skipped.\\n// If the new tree hash matches the last checkpoint's tree hash, the checkpoint\\n// is skipped to avoid duplicate commits (deduplication).\\nfunc (s *GitStore) WriteTemporary(ctx context.Context, opts WriteTemporaryOptions) (WriteTemporaryResult, error) {\\n\\t// Validate base commit - required for shadow branch naming\\n\\tif opts.BaseCommit == \\\"\\\" {\\n\\t\\treturn WriteTemporaryResult{}, errors.New(\\\"BaseCommit is required for temporary checkpoint\\\")\\n\\t}\\n\\n\\t// Validate session ID to prevent path traversal\\n\\tif err := validation.ValidateSessionID(opts.SessionID); err != nil {\\n\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"invalid temporary checkpoint options: %w\\\", err)\\n\\t}\\n\\n\\t// Get shadow branch name\\n\\tshadowBranchName := ShadowBranchNameForCommit(opts.BaseCommit, opts.WorktreeID)\\n\\n\\t// Get or create shadow branch\\n\\tparentHash, baseTreeHash, err := s.getOrCreateShadowBranch(shadowBranchName)\\n\\tif err != nil {\\n\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to get shadow branch: %w\\\", err)\\n\\t}\\n\\n\\t// Get the last checkpoint's tree hash for deduplication\\n\\tvar lastTreeHash plumbing.Hash\\n\\tif parentHash != plumbing.ZeroHash {\\n\\t\\tif lastCommit, err := s.repo.CommitObject(parentHash); err == nil {\\n\\t\\t\\tlastTreeHash = lastCommit.TreeHash\\n\\t\\t}\\n\\t}\\n\\n\\t// Collect all files to include\\n\\tvar allFiles []string\\n\\tvar allDeletedFiles []string\\n\\tif opts.IsFirstCheckpoint {\\n\\t\\t// For the first checkpoint, capture all changed files (modified tracked + untracked)\\n\\t\\t// using `git status --porcelain -z` which respects both repo and global .gitignore.\\n\\t\\t// This is much faster than filesystem walk. The base tree from HEAD already contains\\n\\t\\t// all unchanged tracked files. We also capture user's pre-existing deletions.\\n\\t\\tresult, err := collectChangedFiles(ctx, s.repo)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to collect changed files: %w\\\", err)\\n\\t\\t}\\n\\t\\tallFiles = result.Changed\\n\\t\\t// Merge user's pre-existing deletions with agent's deletions\\n\\t\\tallDeletedFiles = result.Deleted\\n\\t\\tallDeletedFiles = append(allDeletedFiles, opts.DeletedFiles...)\\n\\t} else {\\n\\t\\t// For subsequent checkpoints, only include modified/new files\\n\\t\\tallFiles = make([]string, 0, len(opts.ModifiedFiles)+len(opts.NewFiles))\\n\\t\\tallFiles = append(allFiles, opts.ModifiedFiles...)\\n\\t\\tallFiles = append(allFiles, opts.NewFiles...)\\n\\t\\tallDeletedFiles = opts.DeletedFiles\\n\\t}\\n\\n\\t// Build tree with changes\\n\\ttreeHash, err := s.buildTreeWithChanges(baseTreeHash, allFiles, allDeletedFiles, opts.MetadataDir, opts.MetadataDirAbs)\\n\\tif err != nil {\\n\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n\\t}\\n\\n\\t// Deduplication: skip if tree hash matches the last checkpoint\\n\\tif lastTreeHash != plumbing.ZeroHash && treeHash == lastTreeHash {\\n\\t\\treturn WriteTemporaryResult{\\n\\t\\t\\tCommitHash: parentHash,\\n\\t\\t\\tSkipped:    true,\\n\\t\\t}, nil\\n\\t}\\n\\n\\t// Create checkpoint commit with trailers\\n\\tcommitMsg := trailers.FormatShadowCommit(opts.CommitMessage, opts.MetadataDir, opts.SessionID)\\n\\n\\tcommitHash, err := s.createCommit(treeHash, parentHash, commitMsg, opts.AuthorName, opts.AuthorEmail)\\n\\tif err != nil {\\n\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n\\t}\\n\\n\\t// Update branch reference\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to update branch reference: %w\\\", err)\\n\\t}\\n\\n\\treturn WriteTemporaryResult{\\n\\t\\tCommitHash: commitHash,\\n\\t\\tSkipped:    false,\\n\\t}, nil\\n}\\n\\n// ReadTemporary reads the latest checkpoint from a shadow branch.\\n// Returns nil if the shadow branch doesn't exist.\\n// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\nfunc (s *GitStore) ReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error) {\\n\\t_ = ctx // Reserved for future use\\n\\n\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\n\\tref, err := s.repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\treturn nil, nil //nolint:nilnil,nilerr // Branch not found is an expected case\\n\\t}\\n\\n\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\t// Extract session ID and metadata dir from commit trailers\\n\\tsessionID, _ := trailers.ParseSession(commit.Message)\\n\\tmetadataDir, _ := trailers.ParseMetadata(commit.Message)\\n\\n\\treturn &ReadTemporaryResult{\\n\\t\\tCommitHash:  ref.Hash(),\\n\\t\\tTreeHash:    commit.TreeHash,\\n\\t\\tSessionID:   sessionID,\\n\\t\\tMetadataDir: metadataDir,\\n\\t\\tTimestamp:   commit.Author.When,\\n\\t}, nil\\n}\\n\\n// ListTemporary lists all shadow branches with their checkpoint info.\\nfunc (s *GitStore) ListTemporary(ctx context.Context) ([]TemporaryInfo, error) {\\n\\t_ = ctx // Reserved for future use\\n\\n\\titer, err := s.repo.Branches()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list branches: %w\\\", err)\\n\\t}\\n\\n\\tvar results []TemporaryInfo\\n\\terr = iter.ForEach(func(ref *plumbing.Reference) error {\\n\\t\\tbranchName := ref.Name().Short()\\n\\t\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\t// Skip the sessions branch\\n\\t\\tif branchName == paths.MetadataBranchName {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\tcommit, commitErr := s.repo.CommitObject(ref.Hash())\\n\\t\\tif commitErr != nil {\\n\\t\\t\\t//nolint:nilerr // Skip branches we can't read (non-fatal)\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\tsessionID, _ := trailers.ParseSession(commit.Message)\\n\\n\\t\\t// Extract base commit from branch name (handles new \\\"entire/<commit>-<worktreeHash>\\\" format)\\n\\t\\tbaseCommit, _, _ := ParseShadowBranchName(branchName)\\n\\n\\t\\tresults = append(results, TemporaryInfo{\\n\\t\\t\\tBranchName:   branchName,\\n\\t\\t\\tBaseCommit:   baseCommit,\\n\\t\\t\\tLatestCommit: ref.Hash(),\\n\\t\\t\\tSessionID:    sessionID,\\n\\t\\t\\tTimestamp:    commit.Author.When,\\n\\t\\t})\\n\\n\\t\\treturn nil\\n\\t})\\n\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to iterate branches: %w\\\", err)\\n\\t}\\n\\n\\treturn results, nil\\n}\\n\\n// WriteTemporaryTask writes a task checkpoint to a shadow branch.\\n// Task checkpoints include both code changes and task-specific metadata.\\n// Returns the commit hash of the created checkpoint.\\nfunc (s *GitStore) WriteTemporaryTask(ctx context.Context, opts WriteTemporaryTaskOptions) (plumbing.Hash, error) {\\n\\t_ = ctx // Reserved for future use\\n\\n\\t// Validate base commit - required for shadow branch naming\\n\\tif opts.BaseCommit == \\\"\\\" {\\n\\t\\treturn plumbing.ZeroHash, errors.New(\\\"BaseCommit is required for task checkpoint\\\")\\n\\t}\\n\\n\\t// Validate identifiers to prevent path traversal and malformed data\\n\\tif err := validation.ValidateSessionID(opts.SessionID); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n\\t}\\n\\tif err := validation.ValidateToolUseID(opts.ToolUseID); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n\\t}\\n\\tif err := validation.ValidateAgentID(opts.AgentID); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n\\t}\\n\\n\\t// Get shadow branch name\\n\\tshadowBranchName := ShadowBranchNameForCommit(opts.BaseCommit, opts.WorktreeID)\\n\\n\\t// Get or create shadow branch\\n\\tparentHash, baseTreeHash, err := s.getOrCreateShadowBranch(shadowBranchName)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get shadow branch: %w\\\", err)\\n\\t}\\n\\n\\t// Collect all files to include in the commit\\n\\tallFiles := make([]string, 0, len(opts.ModifiedFiles)+len(opts.NewFiles))\\n\\tallFiles = append(allFiles, opts.ModifiedFiles...)\\n\\tallFiles = append(allFiles, opts.NewFiles...)\\n\\n\\t// Build new tree with code changes (no metadata dir yet)\\n\\tnewTreeHash, err := s.buildTreeWithChanges(baseTreeHash, allFiles, opts.DeletedFiles, \\\"\\\", \\\"\\\")\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n\\t}\\n\\n\\t// Add task metadata to tree\\n\\tnewTreeHash, err = s.addTaskMetadataToTree(newTreeHash, opts)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to add task metadata: %w\\\", err)\\n\\t}\\n\\n\\t// Create the commit\\n\\tcommitHash, err := s.createCommit(newTreeHash, parentHash, opts.CommitMessage, opts.AuthorName, opts.AuthorEmail)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n\\t}\\n\\n\\t// Update shadow branch reference\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tref := plumbing.NewHashReference(refName, commitHash)\\n\\tif err := s.repo.Storer.SetReference(ref); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to update shadow branch reference: %w\\\", err)\\n\\t}\\n\\n\\treturn commitHash, nil\\n}\\n\\n// addTaskMetadataToTree adds task checkpoint metadata to a git tree.\\n// When IsIncremental is true, only adds the incremental checkpoint file.\\nfunc (s *GitStore) addTaskMetadataToTree(baseTreeHash plumbing.Hash, opts WriteTemporaryTaskOptions) (plumbing.Hash, error) {\\n\\t// Get base tree and flatten it\\n\\tbaseTree, err := s.repo.TreeObject(baseTreeHash)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get base tree: %w\\\", err)\\n\\t}\\n\\n\\tentries := make(map[string]object.TreeEntry)\\n\\tif err := FlattenTree(s.repo, baseTree, \\\"\\\", entries); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten tree: %w\\\", err)\\n\\t}\\n\\n\\t// Compute metadata paths\\n\\tsessionMetadataDir := paths.EntireMetadataDir + \\\"/\\\" + opts.SessionID\\n\\ttaskMetadataDir := sessionMetadataDir + \\\"/tasks/\\\" + opts.ToolUseID\\n\\n\\tif opts.IsIncremental {\\n\\t\\t// Incremental checkpoint: only add the checkpoint file\\n\\t\\t// Use proper JSON marshaling to handle nil/empty IncrementalData correctly\\n\\t\\tvar incData []byte\\n\\t\\tif opts.IncrementalData != nil {\\n\\t\\t\\tincData, err = redact.JSONLBytes(opts.IncrementalData)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to redact incremental checkpoint: %w\\\", err)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t\\tincrementalCheckpoint := struct {\\n\\t\\t\\tType      string          `json:\\\"type\\\"`\\n\\t\\t\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n\\t\\t\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n\\t\\t\\tData      json.RawMessage `json:\\\"data\\\"`\\n\\t\\t}{\\n\\t\\t\\tType:      opts.IncrementalType,\\n\\t\\t\\tToolUseID: opts.ToolUseID,\\n\\t\\t\\tTimestamp: time.Now().UTC(),\\n\\t\\t\\tData:      incData,\\n\\t\\t}\\n\\t\\tcpData, err := jsonutil.MarshalIndentWithNewline(incrementalCheckpoint, \\\"\\\", \\\"  \\\")\\n\\t\\tif err != nil {\\n\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to marshal incremental checkpoint: %w\\\", err)\\n\\t\\t}\\n\\n\\t\\tcpBlobHash, err := CreateBlobFromContent(s.repo, cpData)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create incremental checkpoint blob: %w\\\", err)\\n\\t\\t}\\n\\t\\tcpFilename := fmt.Sprintf(\\\"%03d-%s.json\\\", opts.IncrementalSequence, opts.ToolUseID)\\n\\t\\tcpPath := taskMetadataDir + \\\"/checkpoints/\\\" + cpFilename\\n\\t\\tentries[cpPath] = object.TreeEntry{\\n\\t\\t\\tName: cpPath,\\n\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\tHash: cpBlobHash,\\n\\t\\t}\\n\\t} else {\\n\\t\\t// Final checkpoint: add transcripts and checkpoint.json\\n\\n\\t\\t// Add session transcript (with chunking support for large transcripts)\\n\\t\\tif opts.TranscriptPath != \\\"\\\" {\\n\\t\\t\\tif transcriptContent, readErr := os.ReadFile(opts.TranscriptPath); readErr == nil {\\n\\t\\t\\t\\t// Detect agent type from content for proper chunking\\n\\t\\t\\t\\tagentType := agent.DetectAgentTypeFromContent(transcriptContent)\\n\\n\\t\\t\\t\\t// Chunk if necessary\\n\\t\\t\\t\\tchunks, chunkErr := agent.ChunkTranscript(transcriptContent, agentType)\\n\\t\\t\\t\\tif chunkErr != nil {\\n\\t\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to chunk transcript, checkpoint will be saved without transcript\\\",\\n\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", chunkErr.Error()),\\n\\t\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n\\t\\t\\t\\t\\t)\\n\\t\\t\\t\\t} else {\\n\\t\\t\\t\\t\\tfor i, chunk := range chunks {\\n\\t\\t\\t\\t\\t\\tchunkPath := sessionMetadataDir + \\\"/\\\" + agent.ChunkFileName(paths.TranscriptFileName, i)\\n\\t\\t\\t\\t\\t\\tblobHash, blobErr := CreateBlobFromContent(s.repo, chunk)\\n\\t\\t\\t\\t\\t\\tif blobErr != nil {\\n\\t\\t\\t\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to create blob for transcript chunk\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", blobErr.Error()),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"chunk_index\\\", i),\\n\\t\\t\\t\\t\\t\\t\\t)\\n\\t\\t\\t\\t\\t\\t\\tcontinue\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\tentries[chunkPath] = object.TreeEntry{\\n\\t\\t\\t\\t\\t\\t\\tName: chunkPath,\\n\\t\\t\\t\\t\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\t\\t\\t\\t\\tHash: blobHash,\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\n\\t\\t// Add subagent transcript if available\\n\\t\\tif opts.SubagentTranscriptPath != \\\"\\\" && opts.AgentID != \\\"\\\" {\\n\\t\\t\\tif agentContent, readErr := os.ReadFile(opts.SubagentTranscriptPath); readErr == nil {\\n\\t\\t\\t\\tif blobHash, blobErr := CreateBlobFromContent(s.repo, agentContent); blobErr == nil {\\n\\t\\t\\t\\t\\tagentPath := taskMetadataDir + \\\"/agent-\\\" + opts.AgentID + \\\".jsonl\\\"\\n\\t\\t\\t\\t\\tentries[agentPath] = object.TreeEntry{\\n\\t\\t\\t\\t\\t\\tName: agentPath,\\n\\t\\t\\t\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\t\\t\\t\\tHash: blobHash,\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\n\\t\\t// Add checkpoint.json\\n\\t\\tcheckpointJSON := fmt.Sprintf(`{\\n  \\\"session_id\\\": %q,\\n  \\\"tool_use_id\\\": %q,\\n  \\\"checkpoint_uuid\\\": %q,\\n  \\\"agent_id\\\": %q\\n}`, opts.SessionID, opts.ToolUseID, opts.CheckpointUUID, opts.AgentID)\\n\\n\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(checkpointJSON))\\n\\t\\tif err != nil {\\n\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create checkpoint blob: %w\\\", err)\\n\\t\\t}\\n\\t\\tcheckpointPath := taskMetadataDir + \\\"/checkpoint.json\\\"\\n\\t\\tentries[checkpointPath] = object.TreeEntry{\\n\\t\\t\\tName: checkpointPath,\\n\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\tHash: blobHash,\\n\\t\\t}\\n\\t}\\n\\n\\t// Build new tree from entries\\n\\treturn BuildTreeFromEntries(s.repo, entries)\\n}\\n\\n// ListTemporaryCheckpoints lists all checkpoint commits on a shadow branch.\\n// This returns individual commits (rewind points), not just branch info.\\n// The sessionID filter, if provided, limits results to commits from that session.\\n// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\nfunc (s *GitStore) ListTemporaryCheckpoints(ctx context.Context, baseCommit, worktreeID, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n\\treturn s.listCheckpointsForBranch(ctx, shadowBranchName, sessionID, limit)\\n}\\n\\n// ListCheckpointsForBranch lists checkpoint commits for a shadow branch by name.\\n// Use this when you already have the full branch name (e.g., from ListTemporary).\\n// The sessionID filter, if provided, limits results to commits from that session.\\nfunc (s *GitStore) ListCheckpointsForBranch(ctx context.Context, branchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n\\treturn s.listCheckpointsForBranch(ctx, branchName, sessionID, limit)\\n}\\n\\n// listCheckpointsForBranch lists checkpoint commits for a specific shadow branch name.\\n// This is an internal helper used by ListTemporaryCheckpoints, ListCheckpointsForBranch, and ListAllTemporaryCheckpoints.\\nfunc (s *GitStore) listCheckpointsForBranch(ctx context.Context, shadowBranchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n\\t_ = ctx // Reserved for future use\\n\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\n\\tref, err := s.repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\treturn nil, nil //nolint:nilerr // No shadow branch is expected case\\n\\t}\\n\\n\\titer, err := s.repo.Log(&git.LogOptions{From: ref.Hash()})\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n\\t}\\n\\n\\tvar results []TemporaryCheckpointInfo\\n\\tcount := 0\\n\\n\\terr = iter.ForEach(func(c *object.Commit) error {\\n\\t\\tif count >= limit*5 { // Scan more to allow for session filtering\\n\\t\\t\\treturn errStop\\n\\t\\t}\\n\\t\\tcount++\\n\\n\\t\\t// Verify commit belongs to target session via Entire-Session trailer\\n\\t\\tcommitSessionID, hasTrailer := trailers.ParseSession(c.Message)\\n\\t\\tif !hasTrailer {\\n\\t\\t\\treturn nil // Skip commits without session trailer\\n\\t\\t}\\n\\t\\tif sessionID != \\\"\\\" && commitSessionID != sessionID {\\n\\t\\t\\treturn nil // Skip commits from other sessions\\n\\t\\t}\\n\\n\\t\\t// Get first line of message\\n\\t\\tmessage := c.Message\\n\\t\\tif idx := strings.Index(message, \\\"\\\\n\\\"); idx > 0 {\\n\\t\\t\\tmessage = message[:idx]\\n\\t\\t}\\n\\n\\t\\tinfo := TemporaryCheckpointInfo{\\n\\t\\t\\tCommitHash: c.Hash,\\n\\t\\t\\tMessage:    message,\\n\\t\\t\\tSessionID:  commitSessionID,\\n\\t\\t\\tTimestamp:  c.Author.When,\\n\\t\\t}\\n\\n\\t\\t// Check for task checkpoint first\\n\\t\\ttaskMetadataDir, foundTask := trailers.ParseTaskMetadata(c.Message)\\n\\t\\tif foundTask {\\n\\t\\t\\tinfo.IsTaskCheckpoint = true\\n\\t\\t\\tinfo.MetadataDir = taskMetadataDir\\n\\t\\t\\tinfo.ToolUseID = extractToolUseIDFromPath(taskMetadataDir)\\n\\t\\t} else {\\n\\t\\t\\tmetadataDir, found := trailers.ParseMetadata(c.Message)\\n\\t\\t\\tif found {\\n\\t\\t\\t\\tinfo.MetadataDir = metadataDir\\n\\t\\t\\t}\\n\\t\\t}\\n\\n\\t\\tresults = append(results, info)\\n\\n\\t\\tif len(results) >= limit {\\n\\t\\t\\treturn errStop\\n\\t\\t}\\n\\t\\treturn nil\\n\\t})\\n\\n\\tif err != nil && !errors.Is(err, errStop) {\\n\\t\\treturn nil, fmt.Errorf(\\\"error iterating commits: %w\\\", err)\\n\\t}\\n\\n\\treturn results, nil\\n}\\n\\n// ListAllTemporaryCheckpoints lists checkpoint commits from ALL shadow branches.\\n// This is used for checkpoint lookup when the base commit is unknown (e.g., HEAD advanced since session start).\\n// The sessionID filter, if provided, limits results to commits from that session.\\nfunc (s *GitStore) ListAllTemporaryCheckpoints(ctx context.Context, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n\\t_ = ctx // Reserved for future use\\n\\n\\t// List all shadow branches\\n\\tbranches, err := s.ListTemporary(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list shadow branches: %w\\\", err)\\n\\t}\\n\\n\\tvar results []TemporaryCheckpointInfo\\n\\n\\t// Iterate through each shadow branch and collect checkpoints\\n\\tfor _, branch := range branches {\\n\\t\\t// Use the branch name directly to get checkpoints\\n\\t\\tbranchCheckpoints, branchErr := s.listCheckpointsForBranch(ctx, branch.BranchName, sessionID, limit)\\n\\t\\tif branchErr != nil {\\n\\t\\t\\tcontinue // Skip branches we can't read\\n\\t\\t}\\n\\t\\tresults = append(results, branchCheckpoints...)\\n\\t\\tif len(results) >= limit {\\n\\t\\t\\tresults = results[:limit]\\n\\t\\t\\tbreak\\n\\t\\t}\\n\\t}\\n\\n\\treturn results, nil\\n}\\n\\n// extractToolUseIDFromPath extracts the ToolUseID from a task metadata directory path.\\n// Task metadata dirs have format: .entire/metadata/<session>/tasks/<toolUseID>\\nfunc extractToolUseIDFromPath(metadataDir string) string {\\n\\tparts := strings.Split(metadataDir, \\\"/\\\")\\n\\tif len(parts) >= 2 && parts[len(parts)-2] == \\\"tasks\\\" {\\n\\t\\treturn parts[len(parts)-1]\\n\\t}\\n\\treturn \\\"\\\"\\n}\\n\\n// errStop is a sentinel error used to break out of git log iteration.\\nvar errStop = errors.New(\\\"stop iteration\\\")\\n\\n// GetTranscriptFromCommit retrieves the transcript from a specific commit's tree.\\n// This is used for shadow branch checkpoints where the transcript is stored in the commit tree\\n// rather than on the entire/checkpoints/v1 branch.\\n// commitHash is the commit to read from, metadataDir is the path within the tree.\\n// agentType is used for reassembling chunked transcripts in the correct format.\\n// Handles both chunked and non-chunked transcripts.\\nfunc (s *GitStore) GetTranscriptFromCommit(commitHash plumbing.Hash, metadataDir string, agentType agent.AgentType) ([]byte, error) {\\n\\tcommit, err := s.repo.CommitObject(commitHash)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\t// Try to get the metadata subtree for chunk detection\\n\\tsubTree, subTreeErr := tree.Tree(metadataDir)\\n\\tif subTreeErr == nil {\\n\\t\\t// Use the helper function that handles chunking\\n\\t\\ttranscript, err := readTranscriptFromTree(subTree, agentType)\\n\\t\\tif err == nil && transcript != nil {\\n\\t\\t\\treturn transcript, nil\\n\\t\\t}\\n\\t}\\n\\n\\t// Fall back to direct file access (for backwards compatibility)\\n\\ttranscriptPath := metadataDir + \\\"/\\\" + paths.TranscriptFileName\\n\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n\\t\\tcontent, contentErr := file.Contents()\\n\\t\\tif contentErr == nil {\\n\\t\\t\\treturn []byte(content), nil\\n\\t\\t}\\n\\t}\\n\\n\\ttranscriptPath = metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n\\t\\tcontent, contentErr := file.Contents()\\n\\t\\tif contentErr == nil {\\n\\t\\t\\treturn []byte(content), nil\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil, ErrNoTranscript\\n}\\n\\n// ShadowBranchExists checks if a shadow branch exists for the given base commit and worktree.\\n// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\nfunc (s *GitStore) ShadowBranchExists(baseCommit, worktreeID string) bool {\\n\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\t_, err := s.repo.Reference(refName, true)\\n\\treturn err == nil\\n}\\n\\n// DeleteShadowBranch deletes the shadow branch for the given base commit and worktree.\\n// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n// Uses git CLI instead of go-git's RemoveReference because go-git v5 doesn't properly\\n// persist deletions with packed refs or worktrees.\\nfunc (s *GitStore) DeleteShadowBranch(baseCommit, worktreeID string) error {\\n\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", shadowBranchName) //nolint:gosec // shadowBranchName is constructed from commit hash, not user input\\n\\tif output, err := cmd.CombinedOutput(); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to delete shadow branch %s: %s: %w\\\", shadowBranchName, strings.TrimSpace(string(output)), err)\\n\\t}\\n\\treturn nil\\n}\\n\\n// ShadowBranchNameForCommit returns the shadow branch name for a base commit hash\\n// and worktree identifier. The worktree ID should be empty for the main worktree\\n// or the internal git worktree name for linked worktrees.\\n// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\nfunc ShadowBranchNameForCommit(baseCommit, worktreeID string) string {\\n\\tcommitPart := baseCommit\\n\\tif len(baseCommit) >= ShadowBranchHashLength {\\n\\t\\tcommitPart = baseCommit[:ShadowBranchHashLength]\\n\\t}\\n\\tworktreeHash := HashWorktreeID(worktreeID)\\n\\treturn ShadowBranchPrefix + commitPart + \\\"-\\\" + worktreeHash\\n}\\n\\n// ParseShadowBranchName extracts the commit prefix and worktree hash from a shadow branch name.\\n// Input format: \\\"entire/<commit[:7]>-<worktreeHash[:6]>\\\"\\n// Returns (commitPrefix, worktreeHash, ok). Returns (\\\"\\\", \\\"\\\", false) if not a valid shadow branch.\\nfunc ParseShadowBranchName(branchName string) (commitPrefix, worktreeHash string, ok bool) {\\n\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n\\t\\treturn \\\"\\\", \\\"\\\", false\\n\\t}\\n\\tsuffix := strings.TrimPrefix(branchName, ShadowBranchPrefix)\\n\\n\\t// Find the last dash - everything before is commit prefix, after is worktree hash\\n\\tlastDash := strings.LastIndex(suffix, \\\"-\\\")\\n\\tif lastDash == -1 || lastDash == 0 || lastDash == len(suffix)-1 {\\n\\t\\t// No dash, or dash at start/end - invalid format\\n\\t\\t// Could be old format \\\"entire/<commit[:7]>\\\" without worktree hash\\n\\t\\treturn suffix, \\\"\\\", true // Return as commit prefix with empty worktree hash\\n\\t}\\n\\n\\treturn suffix[:lastDash], suffix[lastDash+1:], true\\n}\\n\\n// getOrCreateShadowBranch gets or creates the shadow branch for checkpoints.\\n// Returns (parentHash, baseTreeHash, error).\\nfunc (s *GitStore) getOrCreateShadowBranch(branchName string) (plumbing.Hash, plumbing.Hash, error) {\\n\\trefName := plumbing.NewBranchReferenceName(branchName)\\n\\tref, err := s.repo.Reference(refName, true)\\n\\n\\tif err == nil {\\n\\t\\t// Branch exists\\n\\t\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n\\t\\tif err != nil {\\n\\t\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t\\t}\\n\\t\\treturn ref.Hash(), commit.TreeHash, nil\\n\\t}\\n\\n\\t// Branch doesn't exist, use current HEAD's tree as base\\n\\thead, err := s.repo.Head()\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n\\t}\\n\\n\\theadCommit, err := s.repo.CommitObject(head.Hash())\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n\\t}\\n\\n\\treturn plumbing.ZeroHash, headCommit.TreeHash, nil\\n}\\n\\n// buildTreeWithChanges builds a git tree with the given changes.\\n// metadataDir is the relative path for git tree entries, metadataDirAbs is the absolute path\\n// for filesystem operations (needed when CLI is run from a subdirectory).\\nfunc (s *GitStore) buildTreeWithChanges(\\n\\tbaseTreeHash plumbing.Hash,\\n\\tmodifiedFiles, deletedFiles []string,\\n\\tmetadataDir, metadataDirAbs string,\\n) (plumbing.Hash, error) {\\n\\t// Get repo root for resolving file paths\\n\\t// This is critical because fileExists() and createBlobFromFile() use os.Stat()\\n\\t// which resolves relative to CWD. The modifiedFiles are repo-relative paths,\\n\\t// so we must resolve them against repo root, not CWD.\\n\\trepoRoot, err := paths.RepoRoot()\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n\\t}\\n\\n\\t// Get the base tree\\n\\tbaseTree, err := s.repo.TreeObject(baseTreeHash)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get base tree: %w\\\", err)\\n\\t}\\n\\n\\t// Flatten existing tree\\n\\tentries := make(map[string]object.TreeEntry)\\n\\tif err := FlattenTree(s.repo, baseTree, \\\"\\\", entries); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten base tree: %w\\\", err)\\n\\t}\\n\\n\\t// Remove deleted files\\n\\tfor _, file := range deletedFiles {\\n\\t\\tdelete(entries, file)\\n\\t}\\n\\n\\t// Add/update modified files\\n\\tfor _, file := range modifiedFiles {\\n\\t\\t// Resolve path relative to repo root for filesystem operations\\n\\t\\tabsPath := filepath.Join(repoRoot, file)\\n\\t\\tif !fileExists(absPath) {\\n\\t\\t\\tdelete(entries, file)\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tblobHash, mode, err := createBlobFromFile(s.repo, absPath)\\n\\t\\tif err != nil {\\n\\t\\t\\t// Skip files that can't be staged (may have been deleted since detection)\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tentries[file] = object.TreeEntry{\\n\\t\\t\\tName: file,\\n\\t\\t\\tMode: mode,\\n\\t\\t\\tHash: blobHash,\\n\\t\\t}\\n\\t}\\n\\n\\t// Add metadata directory files\\n\\tif metadataDir != \\\"\\\" && metadataDirAbs != \\\"\\\" {\\n\\t\\tif err := addDirectoryToEntriesWithAbsPath(s.repo, metadataDirAbs, metadataDir, entries); err != nil {\\n\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to add metadata directory: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// Build tree\\n\\treturn BuildTreeFromEntries(s.repo, entries)\\n}\\n\\n// createCommit creates a commit object.\\nfunc (s *GitStore) createCommit(treeHash, parentHash plumbing.Hash, message, authorName, authorEmail string) (plumbing.Hash, error) {\\n\\tnow := time.Now()\\n\\tsig := object.Signature{\\n\\t\\tName:  authorName,\\n\\t\\tEmail: authorEmail,\\n\\t\\tWhen:  now,\\n\\t}\\n\\n\\tcommit := &object.Commit{\\n\\t\\tTreeHash:  treeHash,\\n\\t\\tAuthor:    sig,\\n\\t\\tCommitter: sig,\\n\\t\\tMessage:   message,\\n\\t}\\n\\n\\t// Add parent if not a new branch\\n\\tif parentHash != plumbing.ZeroHash {\\n\\t\\tcommit.ParentHashes = []plumbing.Hash{parentHash}\\n\\t}\\n\\n\\tobj := s.repo.Storer.NewEncodedObject()\\n\\tif err := commit.Encode(obj); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n\\t}\\n\\n\\thash, err := s.repo.Storer.SetEncodedObject(obj)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store commit: %w\\\", err)\\n\\t}\\n\\n\\treturn hash, nil\\n}\\n\\n// Helper functions extracted from strategy/common.go\\n// These are exported for use by strategy package (push_common.go, session_test.go)\\n\\n// FlattenTree recursively flattens a tree into a map of full paths to entries.\\nfunc FlattenTree(repo *git.Repository, tree *o