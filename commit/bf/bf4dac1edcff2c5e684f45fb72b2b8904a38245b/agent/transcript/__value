xt\\\"\\n     6→\\t\\\"encoding/json\\\"\\n     7→\\t\\\"errors\\\"\\n     8→\\t\\\"fmt\\\"\\n     9→\\t\\\"os\\\"\\n    10→\\t\\\"os/exec\\\"\\n    11→\\t\\\"path/filepath\\\"\\n    12→\\t\\\"runtime\\\"\\n    13→\\t\\\"strings\\\"\\n    14→\\t\\\"time\\\"\\n    15→\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    20→)\\n    21→\\n    22→//nolint:gochecknoinits // Agent self-registration is the intended pattern\\n    23→func init() {\\n    24→\\tagent.Register(agent.AgentNameKiro, NewKiroAgent)\\n    25→}\\n    26→\\n    27→// KiroAgent implements the Agent interface for Amazon's Kiro CLI.\\n    28→//\\n    29→//nolint:revive // KiroAgent is clearer than Agent in this context\\n    30→type KiroAgent struct{}\\n    31→\\n    32→// NewKiroAgent creates a new Kiro agent instance.\\n    33→func NewKiroAgent() agent.Agent {\\n    34→\\treturn &KiroAgent{}\\n    35→}\\n    36→\\n    37→// --- Identity ---\\n    38→\\n    39→func (k *KiroAgent) Name() types.AgentName   { return agent.AgentNameKiro }\\n    40→func (k *KiroAgent) Type() types.AgentType   { return agent.AgentTypeKiro }\\n    41→func (k *KiroAgent) Description() string     { return \\\"Kiro - Amazon AI coding CLI\\\" }\\n    42→func (k *KiroAgent) IsPreview() bool         { return true }\\n    43→func (k *KiroAgent) ProtectedDirs() []string { return []string{\\\".kiro\\\"} }\\n    44→\\n    45→// DetectPresence checks if Kiro is configured in the repository.\\n    46→func (k *KiroAgent) DetectPresence(ctx context.Context) (bool, error) {\\n    47→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    48→\\tif err != nil {\\n    49→\\t\\tworktreeRoot = \\\".\\\"\\n    50→\\t}\\n    51→\\tif _, err := os.Stat(filepath.Join(worktreeRoot, \\\".kiro\\\")); err == nil {\\n    52→\\t\\treturn true, nil\\n    53→\\t}\\n    54→\\treturn false, nil\\n    55→}\\n    56→\\n    57→// --- Transcript Storage ---\\n    58→\\n    59→// ReadTranscript reads the cached transcript JSON for a session.\\n    60→func (k *KiroAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    61→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    62→\\tif err != nil {\\n    63→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    64→\\t}\\n    65→\\treturn data, nil\\n    66→}\\n    67→\\n    68→// ChunkTranscript splits a JSON transcript into chunks.\\n    69→// Kiro transcripts are single JSON objects; we use the JSONL chunker since the\\n    70→// cached format is a JSON blob that fits in a single chunk in most cases.\\n    71→func (k *KiroAgent) ChunkTranscript(_ context.Context, content []byte, maxSize int) ([][]byte, error) {\\n    72→\\tif len(content) <= maxSize {\\n    73→\\t\\treturn [][]byte{content}, nil\\n    74→\\t}\\n    75→\\t// For large transcripts, split at line boundaries\\n    76→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n    79→\\t}\\n    80→\\treturn chunks, nil\\n    81→}\\n    82→\\n    83→// ReassembleTranscript combines transcript chunks back into a single blob.\\n    84→func (k *KiroAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    85→\\tif len(chunks) == 1 {\\n    86→\\t\\treturn chunks[0], nil\\n    87→\\t}\\n    88→\\treturn agent.ReassembleJSONL(chunks), nil\\n    89→}\\n    90→\\n    91→// --- Session Management ---\\n    92→\\n    93→// GetSessionID extracts the session ID from hook input.\\n    94→func (k *KiroAgent) GetSessionID(input *agent.HookInput) string {\\n    95→\\treturn input.SessionID\\n    96→}\\n    97→\\n    98→// GetSessionDir returns the directory where Kiro stores session data.\\n    99→// For Kiro, sessions are in SQLite, but w