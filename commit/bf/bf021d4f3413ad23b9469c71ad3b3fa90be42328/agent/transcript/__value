rf(\\\"failed to create discussion blob: %w\\\", err)\\n   658→+\\t}\\n   659→+\\tentries[basePath+discussionFile] = object.TreeEntry{\\n   660→+\\t\\tName: basePath + discussionFile,\\n   661→+\\t\\tMode: filemode.Regular,\\n   662→+\\t\\tHash: discussionBlob,\\n   663→+\\t}\\n   664→+\\n   665→+\\t// Create checkpoints blob\\n   666→+\\tif checkpoints == nil {\\n   667→+\\t\\tcheckpoints = &Checkpoints{Checkpoints: []CheckpointRef{}}\\n   668→+\\t}\\n   669→+\\tcheckpointsJSON, err := json.MarshalIndent(checkpoints, \\\"\\\", \\\"  \\\")\\n   670→+\\tif err != nil {\\n   671→+\\t\\treturn fmt.Errorf(\\\"failed to marshal checkpoints: %w\\\", err)\\n   672→+\\t}\\n   673→+\\tcheckpointsBlob, err := checkpoint.CreateBlobFromContent(s.repo, checkpointsJSON)\\n   674→+\\tif err != nil {\\n   675→+\\t\\treturn fmt.Errorf(\\\"failed to create checkpoints blob: %w\\\", err)\\n   676→+\\t}\\n   677→+\\tentries[basePath+checkpointsFile] = object.TreeEntry{\\n   678→+\\t\\tName: basePath + checkpointsFile,\\n   679→+\\t\\tMode: filemode.Regular,\\n   680→+\\t\\tHash: checkpointsBlob,\\n   681→+\\t}\\n   682→+\\n   683→+\\t// Build tree and commit\\n   684→+\\tnewTreeHash, err := checkpoint.BuildTreeFromEntries(s.repo, entries)\\n   685→+\\tif err != nil {\\n   686→+\\t\\treturn fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n   687→+\\t}\\n   688→+\\n   689→+\\tauthorName, authorEmail := checkpoint.GetGitAuthorFromRepo(s.repo)\\n   690→+\\tcommitMsg := fmt.Sprintf(\\\"Trail: %s (%s)\\\", metadata.Title, metadata.TrailID)\\n   691→+\\tcommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, authorName, authorEmail)\\n   692→+\\tif err != nil {\\n   693→+\\t\\treturn fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   694→+\\t}\\n   695→+\\n   696→+\\t// Update branch ref\\n   697→+\\tnewRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(paths.TrailsBranchName), commitHash)\\n   698→+\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n   699→+\\t\\treturn fmt.Errorf(\\\"failed to update branch reference: %w\\\", err)\\n   700→+\\t}\\n   701→+\\n   702→+\\treturn nil\\n   703→+}\\n   704→+\\n   705→+// Read reads a trail by its ID from the entire/trails branch.\\n   706→+func (s *Store) Read(trailID ID) (*Metadata, *Discussion, *Checkpoints, error) {\\n   707→+\\ttree, err := s.getBranchTree()\\n   708→+\\tif err != nil {\\n   709→+\\t\\treturn nil, nil, nil, err\\n   710→+\\t}\\n   711→+\\n   712→+\\tbasePath := trailID.Path() + \\\"/\\\"\\n   713→+\\n   714→+\\t// Read metadata\\n   715→+\\tmetadataEntry, err := tree.FindEntry(basePath + metadataFile)\\n   716→+\\tif err != nil {\\n   717→+\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"trail %s not found: %w\\\", trailID, err)\\n   718→+\\t}\\n   719→+\\tmetadataBlob, err := s.repo.BlobObject(metadataEntry.Hash)\\n   720→+\\tif err != nil {\\n   721→+\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"failed to read metadata blob: %w\\\", err)\\n   722→+\\t}\\n   723→+\\tmetadataReader, err := metadataBlob.Reader()\\n   724→+\\tif err != nil {\\n   725→+\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"failed to open metadata reader: %w\\\", err)\\n   726→+\\t}\\n   727→+\\tdefer metadataReader.Close()\\n   728→+\\n   729→+\\tvar metadata Metadata\\n   730→+\\tif err := json.NewDecoder(metadataReader).Decode(&metadata); err != nil {\\n   731→+\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"failed to decode metadata: %w\\\", err)\\n   732→+\\t}\\n   733→+\\n   734→+\\t// Read discussion (optional, may not exist yet)\\n   735→+\\tvar discussion Discussion\\n   736→+\\tdiscussionEntry, err := tree.FindEntry(basePath + discussionFile)\\n   737→+\\tif err == nil {\\n   738→+\\t\\tdiscussionBlob, blobErr := s.repo.BlobObject(discussionEntry.Hash)\\n   739→+\\t\\tif blobErr == nil {\\n   740→+\\t\\t\\tdiscussionReader, readerErr := discussionBlob.Reader()\\n   741→+\\t\\t\\tif readerErr == nil {\\n   742→+\\t\\t\\t\\t//nolint:errcheck,gosec // best-effort decode of optional discussion\\n   743→+\\t\\t\\t\\tjson.NewDecoder(discussionReader).Decode(&discussion)\\n   744→+\\t\\t\\t\\t_ = discussionReader.Close()\\n   745→+\\t\\t\\t}\\n   746→+\\t\\t}\\n   747→+\\t}\\n   748→+\\n   749→+\\t// Read checkpoints (optional, may not exist yet)\\n   750→+\\tvar checkpoints Checkpoints\\n   751→+\\tcheckpointsEntry, err := tree.FindEntry(basePath + checkpointsFile)\\n   752→+\\tif err == nil {\\n   753→+\\t\\tcheckpointsBlob, blobErr := s.repo.BlobObject(checkpointsEntry.Hash)\\n   754→+\\t\\tif blobErr == nil {\\n   755→+\\t\\t\\tcheckpointsReader, readerErr := checkpointsBlob.Reader()\\n   756→+\\t\\t\\tif readerErr == nil {\\n   757→+\\t\\t\\t\\t//nolint:errcheck,gosec // best-effort decode of optional checkpoints\\n   758→+\\t\\t\\t\\tjson.NewDecoder(checkpointsReader).Decode(&checkpoints)\\n   759→+\\t\\t\\t\\t_ = checkpointsReader.Close()\\n   760→+\\t\\t\\t}\\n   761→+\\t\\t}\\n   762→+\\t}\\n   763→+\\n   764→+\\treturn &metadata, &discussion, &checkpoints, nil\\n   765→+}\\n   766→+\\n   767→+// FindByBranch finds a trail for the given branch name.\\n   768→+// Returns (nil, nil) if no trail exists for the branch.\\n   769→+func (s *Store) FindByBranch(branchName string) (*Metadata, error) {\\n   770→+\\ttrails, err := s.List()\\n   771→+\\tif err != nil {\\n   772→+\\t\\treturn nil, err\\n   773→+\\t}\\n   774→+\\n   775→+\\tfor _, t := range trails {\\n   776→+\\t\\tif t.Branch == branchName {\\n   777→+\\t\\t\\treturn t, nil\\n   778→+\\t\\t}\\n   779→+\\t}\\n   780→+\\treturn nil, nil //nolint:nilnil // nil, nil means \\\"not found\\\" — callers check both\\n   781→+}\\n   782→+\\n   783→+// List returns all trail metadata from the entire/trails branch.\\n   784→+func (s *Store) List() ([]*Metadata, error) {\\n   785→+\\ttree, err := s.getBranchTree()\\n   786→+\\tif err != nil {\\n   787→+\\t\\t// Branch doesn't exist yet — no trails\\n   788→+\\t\\treturn nil, nil //nolint:nilerr // Expected when no trails exist yet\\n   789→+\\t}\\n   790→+\\n   791→+\\tvar trails []*Metadata\\n   792→+\\tentries := make(map[string]object.TreeEntry)\\n   793→+\\tif err := checkpoint.FlattenTree(s.repo, tree, \\\"\\\", entries); err != nil {\\n   794→+\\t\\treturn nil, fmt.Errorf(\\\"failed to flatten tree: %w\\\", err)\\n   795→+\\t}\\n   796→+\\n   797→+\\t// Find all metadata.json files\\n   798→+\\tfor path, entry := range entries {\\n   799→+\\t\\tif !strings.HasSuffix(path, \\\"/\\\"+metadataFile) {\\n   800→+\\t\\t\\tcontinue\\n   801→+\\t\\t}\\n   802→+\\n   803→+\\t\\tblob, err := s.repo.BlobObject(entry.Hash)\\n   804→+\\t\\tif err != nil {\\n   805→+\\t\\t\\tcontinue\\n   806→+\\t\\t}\\n   807→+\\t\\treader, err := blob.Reader()\\n   808→+\\t\\tif err != nil {\\n   809→+\\t\\t\\tcontinue\\n   810→+\\t\\t}\\n   811→+\\n   812→+\\t\\tvar metadata Metadata\\n   813→+\\t\\tdecodeErr := json.NewDecoder(reader).Decode(&metadata)\\n   814→+\\t\\t_ = reader.Close()\\n   815→+\\t\\tif decodeErr != nil {\\n   816→+\\t\\t\\tcontinue\\n   817→+\\t\\t}\\n   818→+\\n   819→+\\t\\ttrails = append(trails, &metadata)\\n   820→+\\t}\\n   821→+\\n   822→+\\treturn trails, nil\\n   823→+}\\n   824→+\\n   825→+// Update updates an existing trail's metadata. It reads the current metadata,\\n   826→+// applies the provided update function, and writes it back.\\n   827→+func (s *Store) Update(trailID ID, updateFn func(*Metadata)) error {\\n   828→+\\tmetadata, discussion, checkpoints, err := s.Read(trailID)\\n   829→+\\tif err != nil {\\n   830→+\\t\\treturn fmt.Errorf(\\\"failed to read trail for update: %w\\\", err)\\n   831→+\\t}\\n   832→+\\n   833→+\\tupdateFn(metadata)\\n   834→+\\tmetadata.UpdatedAt = time.Now()\\n   835→+\\n   836→+\\treturn s.Write(metadata, discussion, checkpoints)\\n   837→+}\\n   838→+\\n   839→+// AddCheckpoint prepends a checkpoint reference to a trail's checkpoints list (newest first).\\n   840→+func (s *Store) AddCheckpoint(trailID ID, ref CheckpointRef) error {\\n   841→+\\tmetadata