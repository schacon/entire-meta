s *Store) Delete(trailID ID) error {\\n   412→\\tif err := ValidateID(string(trailID)); err != nil {\\n   413→\\t\\treturn err\\n   414→\\t}\\n   415→\\n   416→\\tif err := s.EnsureBranch(); err != nil {\\n   417→\\t\\treturn fmt.Errorf(\\\"failed to ensure trails branch: %w\\\", err)\\n   418→\\t}\\n   419→\\n   420→\\tcommitHash, rootTreeHash, err := s.getBranchRef()\\n   421→\\tif err != nil {\\n   422→\\t\\treturn fmt.Errorf(\\\"failed to get branch ref: %w\\\", err)\\n   423→\\t}\\n   424→\\n   425→\\t// Verify the trail exists by navigating the tree at O(depth)\\n   426→\\tshard, suffix := trailID.ShardParts()\\n   427→\\tif err := s.verifyTrailExists(rootTreeHash, shard, suffix); err != nil {\\n   428→\\t\\treturn err\\n   429→\\t}\\n   430→\\n   431→\\t// Delete the trail's subtree by removing it from the shard directory\\n   432→\\tnewTreeHash, err := checkpoint.UpdateSubtree(\\n   433→\\t\\ts.repo, rootTreeHash,\\n   434→\\t\\t[]string{shard},\\n   435→\\t\\tnil,\\n   436→\\t\\tcheckpoint.UpdateSubtreeOptions{\\n   437→\\t\\t\\tMergeMode:   checkpoint.MergeKeepExisting,\\n   438→\\t\\t\\tDeleteNames: []string{suffix},\\n   439→\\t\\t},\\n   440→\\t)\\n   441→\\tif err != nil {\\n   442→\\t\\treturn fmt.Errorf(\\\"failed to update subtree: %w\\\", err)\\n   443→\\t}\\n   444→\\n   445→\\tauthorName, authorEmail := checkpoint.GetGitAuthorFromRepo(s.repo)\\n   446→\\tcommitMsg := fmt.Sprintf(\\\"Delete trail: %s\\\", trailID)\\n   447→\\tnewCommitHash, err := checkpoint.CreateCommit(s.repo, newTreeHash, commitHash, commitMsg, authorName, authorEmail)\\n   448→\\tif err != nil {\\n   449→\\t\\treturn fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   450→\\t}\\n   451→\\n   452→\\tnewRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(paths.TrailsBranchName), newCommitHash)\\n   453→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n   454→\\t\\treturn fmt.Errorf(\\\"failed to update branch reference: %w\\\", err)\\n   455→\\t}