   276→\\tmetadata, discussion, checkpoints, err := s.Read(trailID)\\n   277→\\tif err != nil {\\n   278→\\t\\treturn fmt.Errorf(\\\"failed to read trail for update: %w\\\", err)\\n   279→\\t}\\n   280→\\n   281→\\tupdateFn(metadata)\\n   282→\\tmetadata.UpdatedAt = time.Now()\\n   283→\\n   284→\\treturn s.Write(metadata, discussion, checkpoints)\\n   285→}\\n   286→\\n   287→// AddCheckpoint prepends a checkpoint reference to a trail's checkpoints list (newest first).\\n   288→func (s *Store) AddCheckpoint(trailID ID, ref CheckpointRef) error {\\n   289→\\tmetadata, discussion, checkpoints, err := s.Read(trailID)\\n   290→\\tif err != nil {\\n   291→\\t\\treturn fmt.Errorf(\\\"failed to read trail for checkpoint update: %w\\\", err)\\n   292→\\t}\\n   293→\\n   294→\\tif checkpoints == nil {\\n   295→\\t\\tcheckpoints = &Checkpoints{Checkpoints: []CheckpointRef{}}\\n   296→\\t}\\n   297→\\n   298→\\t// Prepend new ref (newest first) without always allocating a new slice.\\n   299→\\t// Grow the slice by one, shift existing elements right, and insert at index 0.\\n   300→\\tcheckpoints.Checkpoints = append(checkpoints.Checkpoints, CheckpointRef{})\\n   301→\\tcopy(checkpoints.Checkpoints[1:], checkpoints.Checkpoints[:len(checkpoints.Checkpoints)-1])\\n   302→\\tcheckpoints.Checkpoints[0] = ref\\n   303→\\n   304→\\treturn s.Write(metadata, discussion, checkpoints)\\n   305→}\\n   306→\\n   307→// Delete removes a trail from the entire/trails branch.\\n   308→func (s *Store) Delete(trailID ID) error {\\n   309→\\tif err := s.EnsureBranch(); err != nil {\\n   310→\\t\\treturn fmt.Errorf(\\\"failed to ensure trails branch: %w\\\", err)\\n   311→\\t}\\n   312→\\n   313→\\tcommitHash, rootTreeHash, err := s.getBranchRef()\\n   314→\\tif err != nil {\\n   315→\\t\\treturn fmt.Errorf(\\\"failed to get branch ref: %w\\\", err)\\n   316→\\t}\\n   317→\\n   318→\\t// Verify the trail exists by navigating the tree at O(depth)\\n   319→\\tshard, suffix := trailID.ShardParts()\