nFile, discussion},\\n   130→\\t\\t{checkpointsFile, checkpoints},\\n   131→\\t}\\n   132→\\n   133→\\tentries := make([]object.TreeEntry, 0, len(files))\\n   134→\\tfor _, f := range files {\\n   135→\\t\\tjsonBytes, err := json.MarshalIndent(f.data, \\\"\\\", \\\"  \\\")\\n   136→\\t\\tif err != nil {\\n   137→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal %s: %w\\\", f.name, err)\\n   138→\\t\\t}\\n   139→\\t\\tblobHash, err := checkpoint.CreateBlobFromContent(s.repo, jsonBytes)\\n   140→\\t\\tif err != nil {\\n   141→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to create %s blob: %w\\\", f.name, err)\\n   142→\\t\\t}\\n   143→\\t\\tentries = append(entries, object.TreeEntry{\\n   144→\\t\\t\\tName: f.name,\\n   145→\\t\\t\\tMode: filemode.Regular,\\n   146→\\t\\t\\tHash: blobHash,\\n   147→\\t\\t})\\n   148→\\t}\\n   149→\\n   150→\\treturn entries, nil\\n   151→}\\n   152→\\n   153→// Read reads a trail by its ID from the entire/trails branch.\\n   154→func (s *Store) Read(trailID ID) (*Metadata, *Discussion, *Checkpoints, error) {\\n   155→\\tif err := ValidateID(string(trailID)); err != nil {\\n   156→\\t\\treturn nil, nil, nil, err\\n   157→\\t}\\n   158→\\n   159→\\ttree, err := s.getBranchTree()\\n   160→\\tif err != nil {\\n   161→\\t\\treturn nil, nil, nil, err\\n   162→\\t}\\n   163→\\n   164→\\tbasePath := trailID.Path() + \\\"/\\\"\\n   165→\\n   166→\\t// Read metadata\\n   167→\\tmetadataEntry, err := tree.FindEntry(basePath + metadataFile)\\n   168→\\tif err != nil {\\n   169→\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"trail %s not found: %w\\\", trailID, err)\\n   170→\\t}\\n   171→\\tmetadataBlob, err := s.repo.BlobObject(metadataEntry.Hash)\\n   172→\\tif err != nil {\\n   173→\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"failed to read metadata blob: %w\\\", err)\\n   174→\\t}\\n   175→\\tmetadataReader, err := metadataBlob.Reader()\\n   176→\\tif err != nil {\\n   177→\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"failed to open metadata reader: %w\\\", err)\\n   178→\\t}\\n   179→\\tdefer metadataReader.Close()\\n   180→\\n   181→\\tvar metadata Metadata\\n   182→\\tif err := json.NewDecoder(metadataReader).Decode(&metadata); err != nil {\\n   183→\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"failed to decode metadata: %w\\\", err)\\n   184→\\t}\\n   185→\\n   186→\\t// Read discussion (optional, may not exist yet)\\n   187→\\tvar discussion Discussion\\n   188→\\tdiscussionEntry, err := tree.FindEntry(basePath + discussionFile)\\n   189→\\tif err == nil {\\n   190→\\t\\tdiscussionBlob, blobErr := s.repo.BlobObject(discussionEntry.Hash)\\n   191→\\t\\tif blobErr == nil {\\n   192→\\t\\t\\tdiscussionReader, readerErr := discussionBlob.Reader()\\n   193→\\t\\t\\tif readerErr == nil {\\n   194→\\t\\t\\t\\t//nolint:errcheck,gosec // best-effort decode of optional discussion\\n   195→\\t\\t\\t\\tjson.NewDecoder(discussionReader).Decode(&discussion)\\n   196→\\t\\t\\t\\t_ = discussionReader.Close()\\n   197→\\t\\t\\t}\\n   198→\\t\\t}\\n   199→\\t}\\n   200→\\n   201→\\t// Read checkpoints (optional, may not exist yet)\\n   202→\\tvar checkpoints Checkpoints\\n   203→\\tcheckpointsEntry, err := tree.FindEntry(basePath + checkpointsFile)\\n   204→\\tif err == nil {\\n   205→\\t\\tcheckpointsBlob, blobErr := s.repo.BlobObject(checkpointsEntry.Hash)\\n   206→\\t\\tif blobErr == nil {\\n   207→\\t\\t\\tcheckpointsReader, readerErr := checkpointsBlob.Reader()\\n   208→\\t\\t\\tif readerErr == nil {\\n   209→\\t\\t\\t\\t//nolint:errcheck,gosec // best-effort decode of optional checkpoints\\n   210→\\t\\t\\t\\tjson.NewDecoder(checkpointsReader).Decode(&checkpoints)\\n   211→\\t\\t\\t\\t_ = checkpointsReader.Close()\\n   212→\\t\\t\\t}\\n   213→\\t\\t}\\n   214→\\t}\\n   215→\\n   216→\\treturn &metadata, &discussion, &checkpoints, nil\\n   217→}\\n   218→\\n   219→// FindByBranch finds a trail for the given branch name.\\n   220→// Returns (nil, nil) if no trail exists for the branch.\\n   221→func (s *Store) FindByBranch