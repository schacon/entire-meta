  222→\\ttrails, err := s.List()\\n   223→\\tif err != nil {\\n   224→\\t\\treturn nil, err\\n   225→\\t}\\n   226→\\n   227→\\tfor _, t := range trails {\\n   228→\\t\\tif t.Branch == branchName {\\n   229→\\t\\t\\treturn t, nil\\n   230→\\t\\t}\\n   231→\\t}\\n   232→\\treturn nil, nil //nolint:nilnil // nil, nil means \\\"not found\\\" — callers check both\\n   233→}\\n   234→\\n   235→// List returns all trail metadata from the entire/trails branch.\\n   236→func (s *Store) List() ([]*Metadata, error) {\\n   237→\\ttree, err := s.getBranchTree()\\n   238→\\tif err != nil {\\n   239→\\t\\t// Branch doesn't exist yet — no trails\\n   240→\\t\\treturn nil, nil //nolint:nilerr // Expected when no trails exist yet\\n   241→\\t}\\n   242→\\n   243→\\tvar trails []*Metadata\\n   244→\\tentries := make(map[string]object.TreeEntry)\\n   245→\\tif err := checkpoint.FlattenTree(s.repo, tree, \\\"\\\", entries); err != nil {\\n   246→\\t\\treturn nil, fmt.Errorf(\\\"failed to flatten tree: %w\\\", err)\\n   247→\\t}\\n   248→\\n   249→\\t// Find all metadata.json files\\n   250→\\tfor path, entry := range entries {\\n   251→\\t\\tif !strings.HasSuffix(path, \\\"/\\\"+metadataFile) {\\n   252→\\t\\t\\tcontinue\\n   253→\\t\\t}\\n   254→\\n   255→\\t\\tblob, err := s.repo.BlobObject(entry.Hash)\\n   256→\\t\\tif err != nil {\\n   257→\\t\\t\\tcontinue\\n   258→\\t\\t}\\n   259→\\t\\treader, err := blob.Reader()\\n   260→\\t\\tif err != nil {\\n   261→\\t\\t\\tcontinue\\n   262→\\t\\t}\\n   263→\\n   264→\\t\\tvar metadata Metadata\\n   265→\\t\\tdecodeErr := json.NewDecoder(reader).Decode(&metadata)\\n   266→\\t\\t_ = reader.Close()\\n   267→\\t\\tif decodeErr != nil {\\n   268→\\t\\t\\tcontinue\\n   269→\\t\\t}\\n   270→\\n   271→\\t\\ttrails = append(trails, &metadata)\\n   272→\\t}\\n   273→\\n   274→\\treturn trails, nil\\n   275→}\\n   276→\\n   277→// Update updates an existing trail's metadata. It reads the current metadata,\\n   278→// applies the provided update function, and writes it back.\\n   279→func (s *Store) Update(trailID ID, updateFn func(*Metadata)) error {\\n   280→\\tif err := ValidateID(string(trailID)); err != nil {\\n   281→\\t\\treturn err\\n   282→\\t}\\n   283→\\n   284→\\tmetadata, discussion, checkpoints, err := s.Read(trailID)\\n   285→\\tif err != nil {\\n   286→\\t\\treturn fmt.Errorf(\\\"failed to read trail for update: %w\\\", err)\\n   287→\\t}\\n   288→\\n   289→\\tupdateFn(metadata)\\n   290→\\tmetadata.UpdatedAt = time.Now()\\n   291→\\n   292→\\treturn s.Write(metadata, discussion, checkpoints)\\n   293→}\\n   294→\\n   295→// AddCheckpoint prepends a checkpoint reference to a trail's checkpoints list (newest first).\\n   296→// Only reads and writes the checkpoints.json file — metadata and discussion are untouched.\\n   297→func (s *Store) AddCheckpoint(trailID ID, ref CheckpointRef) error {\\n   298→\\tif err := ValidateID(string(trailID)); err != nil {\\n   299→\\t\\treturn err\\n   300→\\t}\\n   301→\\n   302→\\tif err := s.EnsureBranch(); err != nil {\\n   303→\\t\\treturn fmt.Errorf(\\\"failed to ensure trails branch: %w\\\", err)\\n   304→\\t}\\n   305→\\n   306→\\tcommitHash, rootTreeHash, err := s.getBranchRef()\\n   307→\\tif err != nil {\\n   308→\\t\\treturn fmt.Errorf(\\\"failed to get branch ref: %w\\\", err)\\n   309→\\t}\\n   310→\\n   311→\\t// Navigate to the trail's subtree and read only checkpoints.json\\n   312→\\tshard, suffix := trailID.ShardParts()\\n   313→\\tcheckpoints, err := s.readCheckpointsFromTree(rootTreeHash, shard, suffix)\\n   314→\\tif err != nil {\\n   315→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoints for trail %s: %w\\\", trailID, err)\\n   316→\\t}\\n   317→\\n   318→\\t// Prepend new ref (newest first)\\n   319→\\tcheckpoints.Checkpoints = append(checkpoints.Checkpoints, CheckpointRef{})\\n   320→\\tcopy(checkpoints.Checkpoints[1:], checkpoints.Checkpoints[:len(checkpoints.Checkpoints)-1])\\n   321→\\tcheckpoints.Checkpoints[0] = ref\\n   322→\\n   323→\\t// Create new blob and splice back — MergeKeepExisting preserves metadata.json and discussion.json\\n   324→\\tcheckpointsJSON, err := json.MarshalIndent(checkpoints, \\\"\\\", \\\"  \\\")\\n   325→\\tif err != nil {\\n   326→\\t\\treturn fmt.Errorf(\\\"failed to marshal checkpoints: %w\\\", err)\\n   327→\\t}\\n   328→\\tblobHash, err := checkpoint.CreateBlobFromContent(s.repo, checkpointsJSON)\\n   329→\\tif err != nil {\\n   330→\\t\\treturn fmt.Errorf(\\\"failed to create checkpoints blob: %w\\\", err)\\n   331→\\t}\\n   332→\\n   333→\\tnewTreeHash, err := checkpoint.UpdateSubtree(\\n   334→\\t\\ts.repo, rootTreeHash,\\n   335→\\t\\t[]string{shard, suffix},\\n   336→\\t\\t[]object.TreeEntry{{Name: checkpointsFile, Mode: filemode.Regular, Hash: blobHash}},\\n   337→\\t\\tcheckpoint.UpdateSubtreeOptions{MergeMode: checkpoint.MergeKeepExisting},\\n   338→\\t)\\n   339→\\tif err != nil {\\n   340→\\t\\treturn fmt.Errorf(\\\"failed to update subtree: %w\\\", err)\\n   341→\\t}\\n   342→\\n   343→\\tauthorName, authorEmail := checkpoint.GetGitAuthorFromRepo(s.repo)\\n   344→\\tcommitMsg := fmt.Sprintf(\\\"Add checkpoint to trail: %s\\\", trailID)\\n   345→\\tnewCommitHash, err := checkpoint.CreateCommit(s.repo, newTreeHash, commitHash, commitMsg, authorName, authorEmail)\\n   346→\\tif err != nil {\\n   347→\\t\\treturn fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   348→\\t}\\n   349→\\n   350→\\tnewRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(paths.TrailsBranchName), newCommitHash)\\n   351→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n   352→\\t\\treturn fmt.Errorf(\\\"failed to update branch reference: %w\\\", err)\\n   353→\\t}\\n   354→\\n   355→\\treturn nil\\n   356→}\\n   357→\\n   358→// readCheckpointsFromTree navigates to a trail's subtree and reads only checkpoints.json.\\n   359→func (s *Store) readCheckpointsFromTree(rootTreeHash plumbing.Hash, shard, suffix string) (*Checkpoints, error) {\\n   360→\\trootTree, err := s.repo.TreeObject(rootTreeHash)\\n   361→\\tif err != nil {\\n   362→\\t\\treturn nil, fmt.Errorf(\\\"trail %s%s not found\\\", shard, suffix)\\n   363→\\t}\\n   364→\\n   365→\\tshardEntry, err := rootTree.FindEntry(shard)\\n   366→\\tif err != nil {\\n   367→\\t\\treturn nil, fmt.Errorf(\\\"trail %s%s not found\\\", shard, suffix)\\n   368→\\t}\\n   369→\\n   370→\\tshardTree, err := s.repo.TreeObject(shardEntry.Hash)\\n   371→\\tif err != nil {\\n   372→\\t\\treturn nil, fmt.Errorf(\\\"trail %s%s not found\\\", shard, suffix)\\n   373→\\t}\\n   374→\\n   375→\\ttrailEntry, err := shardTree.FindEntry(suffix)\\n   376→\\tif err != nil {\\n   377→\\t\\treturn nil, fmt.Errorf(\\\"trail %s%s not found\\\", shard, suffix)\\n   378→\\t}\\n   379→\\n   380→\\ttrailTree, err := s.repo.TreeObject(trailEntry.Hash)\\n   381→\\tif err != nil {\\n   382→\\t\\treturn nil, fmt.Errorf(\\\"trail %s%s not found\\\", shard, suffix)\\n   383→\\t}\\n   384→\\n   385→\\tvar checkpoints Checkpoints\\n   386→\\tcpEntry, err := trailTree.FindEntry(checkpointsFile)\\n   387→\\tif err != nil {\\n   388→\\t\\t// No checkpoints file yet — return empty\\n   389→\\t\\treturn &Checkpoints{Checkpoints: []CheckpointRef{}}, nil\\n   390→\\t}\\n   391→\\n   392→\\tblob, err := s.repo.BlobObject(cpEntry.Hash)\\n   393→\\tif err != nil {\\n   394→\\t\\treturn &Checkpoints{Checkpoints: []CheckpointRef{}}, nil\\n   395→\\t}\\n   396→\\n   397→\\treader, err := blob.Reader()\\n   398→\\tif err != nil {\\n   399→\\t\\treturn &Checkpoints{Checkpoints: []CheckpointRef{}}, nil\\n   400→\\t}\\n   401→\\tdefer reader.Close()\\n   402→\\n   403→\\tif err := json.NewDecoder(reader).Decode(&checkpoints); err != nil {\\n   404→\\t\\treturn &Checkpoints{Checkpoints: []CheckpointRef{}}, nil\\n   405→\\t}\\n   406→\\n   407→\\treturn &checkpoints, nil\\n   408→}\\n   409→\\n   410→// Delete removes a trail from the entire/trails branch.\\n   411→func (s *Store) Delete(trailID ID) error {\\n   41