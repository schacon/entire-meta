anch, err := GetCurrentBranch(context.Background())\\n  1745→+\\tif err != nil {\\n  1746→+\\t\\treturn runTrailListAll(w, \\\"\\\", false)\\n  1747→+\\t}\\n  1748→+\\n  1749→+\\trepo, err := strategy.OpenRepository(context.Background())\\n  1750→+\\tif err != nil {\\n  1751→+\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n  1752→+\\t}\\n  1753→+\\n  1754→+\\tstore := trail.NewStore(repo)\\n  1755→+\\tmetadata, err := store.FindByBranch(branch)\\n  1756→+\\tif err != nil || metadata == nil {\\n  1757→+\\t\\treturn runTrailListAll(w, \\\"\\\", false)\\n  1758→+\\t}\\n  1759→+\\n  1760→+\\tprintTrailDetails(w, metadata)\\n  1761→+\\treturn nil\\n  1762→+}\\n  1763→+\\n  1764→+func printTrailDetails(w io.Writer, m *trail.Metadata) {\\n  1765→+\\tfmt.Fprintf(w, \\\"Trail: %s\\\\n\\\", m.Title)\\n  1766→+\\tfmt.Fprintf(w, \\\"  ID:      %s\\\\n\\\", m.TrailID)\\n  1767→+\\tfmt.Fprintf(w, \\\"  Branch:  %s\\\\n\\\", m.Branch)\\n  1768→+\\tfmt.Fprintf(w, \\\"  Base:    %s\\\\n\\\", m.Base)\\n  1769→+\\tfmt.Fprintf(w, \\\"  Status:  %s\\\\n\\\", m.Status)\\n  1770→+\\tfmt.Fprintf(w, \\\"  Author:  %s\\\\n\\\", m.Author)\\n  1771→+\\tif m.Body != \\\"\\\" {\\n  1772→+\\t\\tfmt.Fprintf(w, \\\"  Body:    %s\\\\n\\\", m.Body)\\n  1773→+\\t}\\n  1774→+\\tif len(m.Labels) > 0 {\\n  1775→+\\t\\tfmt.Fprintf(w, \\\"  Labels:  %s\\\\n\\\", strings.Join(m.Labels, \\\", \\\"))\\n  1776→+\\t}\\n  1777→+\\tif len(m.Assignees) > 0 {\\n  1778→+\\t\\tfmt.Fprintf(w, \\\"  Assignees: %s\\\\n\\\", strings.Join(m.Assignees, \\\", \\\"))\\n  1779→+\\t}\\n  1780→+\\tfmt.Fprintf(w, \\\"  Created: %s\\\\n\\\", m.CreatedAt.Format(time.RFC3339))\\n  1781→+\\tfmt.Fprintf(w, \\\"  Updated: %s\\\\n\\\", m.UpdatedAt.Format(time.RFC3339))\\n  1782→+}\\n  1783→+\\n  1784→+func newTrailListCmd() *cobra.Command {\\n  1785→+\\tvar statusFilter string\\n  1786→+\\tvar jsonOutput bool\\n  1787→+\\n  1788→+\\tcmd := &cobra.Command{\\n  1789→+\\t\\tUse:   \\\"list\\\",\\n  1790→+\\t\\tShort: