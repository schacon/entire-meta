ch already exists\\n    44→\\t}\\n    45→\\n    46→\\t// Create orphan branch with empty tree\\n    47→\\temptyTreeHash, err := checkpoint.BuildTreeFromEntries(s.repo, make(map[string]object.TreeEntry))\\n    48→\\tif err != nil {\\n    49→\\t\\treturn fmt.Errorf(\\\"failed to build empty tree: %w\\\", err)\\n    50→\\t}\\n    51→\\n    52→\\tauthorName, authorEmail := checkpoint.GetGitAuthorFromRepo(s.repo)\\n    53→\\tcommitHash, err := s.createCommit(emptyTreeHash, plumbing.ZeroHash, \\\"Initialize trails branch\\\", authorName, authorEmail)\\n    54→\\tif err != nil {\\n    55→\\t\\treturn fmt.Errorf(\\\"failed to create initial commit: %w\\\", err)\\n    56→\\t}\\n    57→\\n    58→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n    59→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n    60→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n    61→\\t}\\n    62→\\treturn nil\\n    63→}\\n    64→\\n    65→// Write writes trail metadata, discussion, and checkpoints to the entire/trails branch.\\n    66→// If checkpoints is nil, an empty checkpoints list is written.\\n    67→func (s *Store) Write(metadata *Metadata, discussion *Discussion, checkpoints *Checkpoints) error {\\n    68→\\tif metadata.TrailID.IsEmpty() {\\n    69→\\t\\treturn errors.New(\\\"trail ID is required\\\")\\n    70→\\t}\\n    71→\\n    72→\\tif err := s.EnsureBranch(); err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\\"failed to ensure trails branch: %w\\\", err)\\n    74→\\t}\\n    75→\\n    76→\\tcommitHash, rootTreeHash, err := s.getBranchRef()\\n    77→\\tif err != nil {\\n    78→\\t\\treturn fmt.Errorf(\\\"failed to get branch ref: %w\\\", err)\\n    79→\\t}\\n    80→\\n    81→\\t// Build blob entries for the trail's 3 files\\n    82→\\ttrailEntries, err := s.buildTrailEntries(metadata, discussion, checkpoints)\\n    83→\\tif err != nil {\\n    84→\\t\\treturn err\\n    85→\\t}\\n    86→\\n    87→\\t// Splice into tree at [shard, suffix] — preserves sibling trails automatically\\n    88→\\tshard, suffix := metadata.TrailID.ShardParts()\\n    89→\\tnewTreeHash, err := checkpoint.UpdateSubtree(\\n    90→\\t\\ts.repo, rootTreeHash,\\n    91→\\t\\t[]string{shard, suffix},\\n    92→\\t\\ttrailEntries,\\n    93→\\t\\tcheckpoint.UpdateSubtreeOptions{MergeMode: checkpoint.ReplaceAll},\\n    94→\\t)\\n    95→\\tif err != nil {\\n    96→\\t\\treturn fmt.Errorf(\\\"failed to update subtree: %w\\\", err)\\n    97→\\t}\\n    98→\\n    99→\\tauthorName, authorEmail := checkpoint.GetGitAuthorFromRepo(s.repo)\\n   100→\\tcommitMsg := fmt.Sprintf(\\\"Trail: %s (%s)\\\", metadata.Title, metadata.TrailID)\\n   101→\\tnewCommitHash, err := checkpoint.CreateCommit(s.repo, newTreeHash, commitHash, commitMsg, authorName, authorEmail)\\n   102→\\tif err != nil {\\n   103→\\t\\treturn fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   104→\\t}\\n   105→\\n   106→\\tnewRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(paths.TrailsBranchName), newCommitHash)\\n   107→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n   108→\\t\\treturn fmt.Errorf(\\\"failed to update branch reference: %w\\\", err)\\n   109→\\t}\\n   110→\\n   111→\\treturn nil\\n   112→}\\n   113→\\n   114→// buildTrailEntries creates blob objects for a trail's 3 files and returns them as tree entries.\\n   115→func (s *Store) buildTrailEntries(metadata *Metadata, discussion *Discussion, checkpoints *Checkpoints) ([]object.TreeEntry, error) {\\n   116→\\tif discussion == nil {\\n   117→\\t\\tdiscussion = &Discussion{Comments: []Comment{}}\\n   118→\\t}\\n   119→\\tif checkpoints == nil {\\n   120→\\t\\tcheckpoints = &Checkpoints{Checkpoints: []CheckpointRef{}}\\n   121→\\t}\\n   122→\\n   123→\\ttype fileSpec struct {\\n   124→\\t\\tname string\\n   125→\\t\\tdata any\\n   126→\\t}\\n   127→\\tfiles := []fileSpec{\\n   128→\\t\\t{metadataFile, metadata},\\n   129→\\t\\t{discussionFile, discussion},\\n   130→\\t\\t{checkpointsFile, checkpoints},\\n   131→\\t}\\n   132→\\n   133→\\tentries := make([]object.TreeEntry, 0, len(files))\\n   134→\\tfor _, f := range files {\\n   135→\\t\\tjsonBytes, err := json.MarshalIndent(f.data, \\\"\\\", \\\"  \\\")\\n   136→\\t\\tif err != nil {\\n   137→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal %s: %w\\\", f.name, err)\\n   138→\\t\\t}\\n   139→\\t\\tblobHash, err := checkpoint.CreateBlobFromContent(s.repo, jsonBytes)\\n   140→\\t\\tif err != nil {\\n   141→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to create %s blob: %w\\\", f.name, err)\\n   142→\\t\\t}\\n   143→\\t\\tentries = append(entries, object.TreeEntry{\\n   144→\\t\\t\\tName: f.name,\\n   145→\\t\\t\\tMode: filemode.Regular,\\n   146→\\t\\t\\tHash: blobHash,\\n   147→\\t\\t})\\n   148→\\t}\\n   149→\\n   150→\\treturn entries, nil\\n   151→}\\n   152→\\n   153→// Read reads a trail by its ID from the entire/trails branch.\\n   154→func (s *Store) Read(trailID ID) (*Metadata, *Discussion, *Checkpoints, error) {\\n   155→\\tif err := ValidateID(string(trailID)); err != nil {\\n   156→\\t\\treturn nil, nil, nil, err\\n   157→\\t}\\n   158→\\n   159→\\ttree, err := s.getBranchTree()\\n   160→\\tif err != nil {\\n   161→\\t\\treturn nil, nil, nil, err\\n   162→\\t}\\n   163→\\n   164→\\tbasePath := trailID.Path() + \\\"/\\\"\\n   165→\\n   166→\\t// Read metadata\\n   167→\\tmetadataEntry, err := tree.FindEntry(basePath + metadataFile)\\n   168→\\tif err != nil {\\n   169→\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"trail %s not found: %w\\\", trailID, err)\\n   170→\\t}\\n   171→\\tmetadataBlob, err := s.repo.BlobObject(metadataEntry.Hash)\\n   172→\\tif err != nil {\\n   173→\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"failed to read metadata blob: %w\\\", err)\\n   174→\\t}\\n   175→\\tmetadataReader, err := metadataBlob.Reader()\\n   176→\\tif err != nil {\\n   177→\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"failed to open metadata reader: %w\\\", err)\\n   178→\\t}\\n   179→\\tdefer