"transcript has no content\\\")\\n   521→+\\t}\\n   522→+\\n   523→+\\tinput := Input{Transcript: condensed, FilesTouched: filesTouched}\\n   524→+\\ttranscriptText := FormatCondensedTranscript(input)\\n   525→+\\n   526→+\\t// Build prompt and call agent's TextGenerator\\n   527→+\\tprompt := fmt.Sprintf(trailTitlePromptTemplate, transcriptText)\\n   528→+\\trawResult, err := gen.GenerateText(ctx, prompt, trailTitleModel)\\n   529→+\\tif err != nil {\\n   530→+\\t\\treturn nil, fmt.Errorf(\\\"text generation failed: %w\\\", err)\\n   531→+\\t}\\n   532→+\\n   533→+\\t// Parse JSON response (handle markdown code blocks)\\n   534→+\\tcleaned := extractJSONFromMarkdown(rawResult)\\n   535→+\\tvar result TrailTitleResult\\n   536→+\\tif err := json.Unmarshal([]byte(cleaned), &result); err != nil {\\n   537→+\\t\\treturn nil, fmt.Errorf(\\\"failed to parse trail title JSON: %w\\\", err)\\n   538→+\\t}\\n   539→+\\n   540→+\\treturn &result, nil\\n   541→+}\\n   542→diff --git a/cmd/entire/cli/trail/store.go b/cmd/entire/cli/trail/store.go\\n   543→new file mode 100644\\n   544→index 00000000..f5e93bc1\\n   545→--- /dev/null\\n   546→+++ b/cmd/entire/cli/trail/store.go\\n   547→@@ -0,0 +1,437 @@\\n   548→+package trail\\n   549→+\\n   550→+import (\\n   551→+\\t\\\"encoding/json\\\"\\n   552→+\\t\\\"errors\\\"\\n   553→+\\t\\\"fmt\\\"\\n   554→+\\t\\\"strings\\\"\\n   555→+\\t\\\"time\\\"\\n   556→+\\n   557→+\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n   558→+\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n   559→+\\n   560→+\\t\\\"github.com/go-git/go-git/v5\\\"\\n   561→+\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n   562→+\\t\\\"github.com/go-git/go-git/v5/plumbing/filemode\\\"\\n   563→+\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n   564→+)\\n   565→+\\n   566→+const (\\n   567→+\\tmetadataFile    = \\\"metadata.json\\\"\\n   568→+\\tdiscussionFile  = \\\"discussion.json\\\"\\n   569→+\\tcheckpointsFile = \\\"checkpoints.json\\\"\\n   570→+)\\n   571→+\\n   572→+// ErrTrailNotFound is returned when a trail cannot be found.\\n   573→+var ErrTrailNotFound = errors.New(\\\"trail not found\\\")\\n   574→+\\n   575→+// Store provides CRUD operations for trail metadata on the entire/trails branch.\\n   576→+type Store struct {\\n   577→+\\trepo *git.Repository\\n   578→+}\\n   579→+\\n   580→+// NewStore creates a new trail store backed by the given git repository.\\n   581→+func NewStore(repo *git.Repository) *Store {\\n   582→+\\treturn &Store{repo: repo}\\n   583→+}\\n   584→+\\n   585→+// EnsureBranch creates the entire/trails orphan branch if it doesn't exist.\\n   586→+func (s *Store) EnsureBranch() error {\\n   587→+\\trefName := plumbing.NewBranchReferenceName(paths.TrailsBranchName)\\n   588→+\\t_, err := s.repo.Reference(refName, true)\\n   589→+\\tif err == nil {\\n   590→+\\t\\treturn nil // Branch already exists\\n   591→+\\t}\\n   592→+\\n   593→+\\t// Create orphan branch with empty tree\\n   594→+\\temptyTreeHash, err := checkpoint.BuildTreeFromEntries(s.repo, make(map[string]object.TreeEntry))\\n   595→+\\tif err != nil {\\n   596→+\\t\\treturn fmt.Errorf(\\\"failed to build empty tree: %w\\\", err)\\n   597→+\\t}\\n   598→+\\n   599→+\\tauthorName, authorEmail := checkpoint.GetGitAuthorFromRepo(s.repo)\\n   600→+\\tcommitHash, err := s.createCommit(emptyTreeHash, plumbing.ZeroHash, \\\"Initialize trails branch\\\", authorName, authorEmail)\\n   601→+\\tif err != nil {\\n   602→+\\t\\treturn fmt.Errorf(\\\"failed to create initial commit: %w\\\", err)\\n   603→+\\t}\\n   604→+\\n   605→+\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n   606→+\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n   607→+\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n   608→+\\t}\\n   609→+\\treturn nil\\n   610→+}\\n   611→+\\n   612→+// Write writes trail metadata, discussion, and checkpoints to the entire/trails branch.\\n   613→+// If