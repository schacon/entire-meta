\"cached session ID %q does not match event session ID %q\\\", cachedID, event.SessionID)\\n   394→\\t}\\n   395→}\\n   396→\\n   397→func TestSessionIDCaching_UserPromptSubmitReadsCache(t *testing.T) {\\n   398→\\ttempDir := t.TempDir()\\n   399→\\tt.Chdir(tempDir)\\n   400→\\n   401→\\tag := &KiroAgent{}\\n   402→\\n   403→\\t// First call agent-spawn to generate and cache a session ID.\\n   404→\\tspawnInput := `{\\\"hook_event_name\\\":\\\"agentSpawn\\\",\\\"cwd\\\":\\\"` + tempDir + `\\\"}`\\n   405→\\tspawnEvent, err := ag.ParseHookEvent(context.Background(), HookNameAgentSpawn, strings.NewReader(spawnInput))\\n   406→\\tif err != nil {\\n   407→\\t\\tt.Fatalf(\\\"agent-spawn error: %v\\\", err)\\n   408→\\t}\\n   409→\\n   410→\\t// Then call user-prompt-submit which should read the cached session ID.\\n   411→\\tpromptInput := `{\\\"hook_event_name\\\":\\\"userPromptSubmit\\\",\\\"cwd\\\":\\\"` + tempDir + `\\\",\\\"prompt\\\":\\\"test\\\"}`\\n   412→\\tpromptEvent, err := ag.ParseHookEvent(context.Background(), HookNameUserPromptSubmit, strings.NewReader(promptInput))\\n   413→\\tif err != nil {\\n   414→\\t\\tt.Fatalf(\\\"user-prompt-submit error: %v\\\", err)\\n   415→\\t}\\n   416→\\n   417→\\tif promptEvent.SessionID != spawnEvent.SessionID {\\n   418→\\t\\tt.Errorf(\\\"user-prompt-submit session ID %q does not match agent-spawn session ID %q\\\",\\n   419→\\t\\t\\tpromptEvent.SessionID, spawnEvent.SessionID)\\n   420→\\t}\\n   421→}\\n   422→\\n   423→func TestSessionIDCaching_StopReadsCache(t *testing.T) {\\n   424→\\ttempDir := t.TempDir()\\n   425→\\tt.Chdir(tempDir)\\n   426→\\tt.Setenv(\\\"ENTIRE_TEST_KIRO_MOCK_DB\\\", \\\"1\\\")\\n   427→\\n   428→\\tag := &KiroAgent{}\\n   429→\\n   430→\\t// First call agent-spawn to generate and cache a session ID.\\n   431→\\tspawnInput := `{\\\"hook_event_name\\\":\\\"agentSpawn\\\",\\\"cwd\\\":\\\"` + tempDir + `\\\"}`\\n   432→\\tspawnEvent, err := ag.ParseHookEvent(context.Background(), HookNameAgentSpawn