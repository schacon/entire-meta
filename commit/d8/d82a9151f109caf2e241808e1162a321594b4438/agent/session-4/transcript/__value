e {\\n    49→\\tcase HookNameAgentSpawn:\\n    50→\\t\\treturn k.parseAgentSpawn(ctx, stdin)\\n    51→\\tcase HookNameUserPromptSubmit:\\n    52→\\t\\treturn k.parseUserPromptSubmit(ctx, stdin)\\n    53→\\tcase HookNameStop:\\n    54→\\t\\treturn k.parseStop(ctx, stdin)\\n    55→\\tcase HookNamePreToolUse, HookNamePostToolUse:\\n    56→\\t\\t// Pass-through hooks with no lifecycle significance\\n    57→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    58→\\tdefault:\\n    59→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    60→\\t}\\n    61→}\\n    62→\\n    63→// readHookInputOrEmpty wraps ReadAndParseHookInput, returning a zero-value\\n    64→// hookInputRaw on empty stdin instead of erroring. This supports the Kiro IDE\\n    65→// which delivers data via environment variables rather than JSON on stdin.\\n    66→// Malformed JSON still returns an error.\\n    67→func readHookInputOrEmpty(stdin io.Reader) (*hookInputRaw, error) {\\n    68→\\traw, err := agent.ReadAndParseHookInput[hookInputRaw](stdin)\\n    69→\\tif err != nil {\\n    70→\\t\\tif errors.Is(err, agent.ErrEmptyHookInput) {\\n    71→\\t\\t\\treturn &hookInputRaw{}, nil\\n    72→\\t\\t}\\n    73→\\t\\treturn nil, err\\n    74→\\t}\\n    75→\\treturn raw, nil\\n    76→}\\n    77→\\n    78→func (k *KiroAgent) parseAgentSpawn(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n    79→\\t_, err := readHookInputOrEmpty(stdin)\\n    80→\\tif err != nil {\\n    81→\\t\\treturn nil, err\\n    82→\\t}\\n    83→\\n    84→\\t// Generate a new stable session ID and cache it for subsequent hooks.\\n    85→\\t// Kiro's SQLite transcript isn't populated until the turn ends, so we can't\\n    86→\\t// use the native conversation_id as our session ID — it would be \\\"unknown\\\"\\n    87→\\t// at agentSpawn/userPromptSubmit and change to the real ID at stop.\\n    88→\\tsessionID := k.generateAndCacheSessionID(ctx)\\n    89→\\n    90→\\treturn &agent.Event{\\n    91→\\t\\tType:      agent.SessionStart,\\n    92→\\t\\tSessionID: sessionID,\\n    93→\\t\\tTimestamp: time.Now(),\\n    94→\\t}, nil\\n    95→}\\n    96→\\n    97→func (k *KiroAgent) parseUserPromptSubmit(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n    98→\\traw, err := readHookInputOrEmpty(stdin)\\n    99→\\tif err != nil {\\n   100→\\t\\treturn nil, err\\n   101→\\t}\\n   102→\\n   103→\\t// IDE mode: prompt comes from USER_PROMPT env var when stdin is empty.\\n   104→\\tprompt := raw.Prompt\\n   105→\\tif prompt == \\\"\\\" {\\n   106→\\t\\tprompt = os.Getenv(\\\"USER_PROMPT\\\")\\n   107→\\t}\\n   108→\\n   109→\\t// Read the stable session ID generated at agentSpawn.\\n   110→\\tsessionID := k.readCachedSessionID(ctx)\\n   111→\\tif sessionID == \\\"\\\" {\\n   112→\\t\\t// Fallback: generate new ID if cache file is missing (e.g., agentSpawn was skipped).\\n   113→\\t\\tsessionID = k.generateAndCacheSessionID(ctx)\\n   114→\\t}\\n   115→\\n   116→\\treturn &agent.Event{\\n   117→\\t\\tType:      agent.TurnStart,\\n   118→\\t\\tSessionID: sessionID,\\n   119→\\t\\tPrompt:    prompt,\\n   120→\\t\\tTimestamp: time.Now(),\\n   121→\\t}, nil\\n   122→}\\n   123→\\n   124→func (k *KiroAgent) parseStop(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n   125→\\traw, err := readHookInputOrEmpty(stdin)\\n   126→\\tif err != nil {\\n   127→\\t\\treturn nil, err\\n   128→\\t}\\n   129→\\n   130→\\t// IDE mode: CWD may not be in stdin. Fall back to repo root.\\n   131→\\tcwd := raw.CWD\\n   132→\\tif cwd == \\\"\\\" {\\n   133→\\t\\trepoRoot, rootErr := paths.WorktreeRoot(ctx)\\n   134→\\t\\tif rootErr == nil {\\n   135→\\t\\t\\tcwd = repoRoot\\n   136→\\t\\t}\\n   137→\\t}\\n   138→\\n   139→\\t// Read the stable session ID generated at agentSpawn.\\n   140→\\tsessionID := k.readCachedSessionID(ctx)\\n   141→\\tif sessionID == \\\"\\\" {\\n   142→\\t\\t// Fallback: try SQLite for the session ID.\\n   143→\\t\\tsid,