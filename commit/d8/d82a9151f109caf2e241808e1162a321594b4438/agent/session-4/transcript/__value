ntent) <= maxSize {\\n    73→\\t\\treturn [][]byte{content}, nil\\n    74→\\t}\\n    75→\\t// For large transcripts, split at line boundaries\\n    76→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n    79→\\t}\\n    80→\\treturn chunks, nil\\n    81→}\\n    82→\\n    83→// ReassembleTranscript combines transcript chunks back into a single blob.\\n    84→func (k *KiroAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    85→\\tif len(chunks) == 1 {\\n    86→\\t\\treturn chunks[0], nil\\n    87→\\t}\\n    88→\\treturn agent.ReassembleJSONL(chunks), nil\\n    89→}\\n    90→\\n    91→// --- Session Management ---\\n    92→\\n    93→// GetSessionID extracts the session ID from hook input.\\n    94→func (k *KiroAgent) GetSessionID(input *agent.HookInput) string {\\n    95→\\treturn input.SessionID\\n    96→}\\n    97→\\n    98→// GetSessionDir returns the directory where Kiro stores session data.\\n    99→// For Kiro, sessions are in SQLite, but we cache transcripts to .entire/tmp/.\\n   100→func (k *KiroAgent) GetSessionDir(repoPath string) (string, error) {\\n   101→\\treturn filepath.Join(repoPath, \\\".entire\\\", \\\"tmp\\\"), nil\\n   102→}\\n   103→\\n   104→// ResolveSessionFile returns the path to the cached transcript file.\\n   105→func (k *KiroAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   106→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".json\\\")\\n   107→}\\n   108→\\n   109→// ReadSession reads session data from the cached transcript.\\n   110→func (k *KiroAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   111→\\tif input.SessionRef == \\\"\\\" {\\n   112→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   113→\\t}\\n   114→\\n   115→\\tdata, err := os.ReadFile(input.SessionRef)\\n   116→\\tif err != nil {\\n   117→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   118→\\t}\\n   119→\\n   120→\\treturn &agent.AgentSession{\\n   121→\\t\\tSessionID:  input.SessionID,\\n   122→\\t\\tAgentName:  k.Name(),\\n   123→\\t\\tSessionRef: input.SessionRef,\\n   124→\\t\\tStartTime:  time.Now(),\\n   125→\\t\\tNativeData: data,\\n   126→\\t}, nil\\n   127→}\\n   128→\\n   129→// WriteSession writes session data for resumption.\\n   130→func (k *KiroAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   131→\\tif session == nil {\\n   132→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   133→\\t}\\n   134→\\tif session.AgentName != \\\"\\\" && session.AgentName != k.Name() {\\n   135→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, k.Name())\\n   136→\\t}\\n   137→\\tif session.SessionRef == \\\"\\\" {\\n   138→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   139→\\t}\\n   140→\\tif len(session.NativeData) == 0 {\\n   141→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   142→\\t}\\n   143→\\n   144→\\tif err := os.MkdirAll(filepath.Dir(session.SessionRef), 0o750); err != nil {\\n   145→\\t\\treturn fmt.Errorf(\\\"failed to create session dir: %w\\\", err)\\n   146→\\t}\\n   147→\\n   148→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   149→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   150→\\t}\\n   151→\\treturn nil\\n   152→}\\n   153→\\n   154→// FormatResumeCommand returns the command to resume a Kiro session.\\n   155→func (k *KiroAgent) FormatResumeCommand(_ string) string {\\n   156→\\treturn \\\"kiro-cli chat --resume\\\"\\n   157→}\\n   158→\\n   159→// GetHookConfigPath returns the path to the hook config file relative to repo root.\\n   160→func (k *KiroAgent) GetHookConfigPath() string {\\n   161→\\treturn filepath.Join(\\\".kiro\\\", hooksDir, HooksFileName)\\n   162→}\\n   163→\\n   164→// --- SQLite helpers ---\\n   165→\\n   166→// escapeSQLString escapes single quotes for use in SQLite string literals.\\n   167→func escapeSQLString(s string) string {\\n   168→\\treturn strings.ReplaceAll(s, \\\"'\\\", \\\"''\\\")\\n   169→}\\n   170→\\n   171→// --- SQLite session resolution ---\\n   172→\\n   173→// dbPath returns the path to Kiro's SQLite database.\\n   174→func dbPath() (string, error) {\\n   175→\\thome, err := os.UserHomeDir()\\n   176→\\tif err != nil {\\n   177→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   178→\\t}\\n   179→\\tswitch runtime.GOOS {\\n   180→\\tcase \\\"darwin\\\":\\n   181→\\t\\treturn filepath.Join(home, \\\"Library\\\", \\\"Application Support\\\", \\\"kiro-cli\\\", \\\"data.sqlite3\\\"), nil\\n   182→\\tdefault: // linux\\n   183→\\t\\treturn filepath.Join(home, \\\".local\\\", \\\"share\\\", \\\"kiro-cli\\\", \\\"data.sqlite3\\\"), nil\\n   184→\\t}\\n   185→}\\n   186→\\n   187→// querySessionID queries the SQLite database for the most recent conversation ID\\n   188→// associated with the given CWD.\\n   189→func (k *KiroAgent) querySessionID(ctx context.Context, cwd string) (string, error) {\\n   190→\\tif os.Getenv(\\\"ENTIRE_TEST_KIRO_MOCK_DB\\\") == \\\"1\\\" {\\n   191→\\t\\treturn \\\"mock-session-id\\\", nil\\n   192→\\t}\\n   193→\\n   194→\\tdb, err := dbPath()\\n   195→\\tif err != nil {\\n   196→\\t\\treturn \\\"\\\", err\\n   197→\\t}\\n   198→\\tif _, err := os.Stat(db); err != nil {\\n   199→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"kiro database not found at %s: %w\\\", db, err)\\n   200→\\t}\\n   201→\\n   202→\\tquery := fmt.Sprintf(\\n   203→\\t\\t\\\"SELECT json_extract(value, '$.conversation_id') FROM conversations_v2 WHERE key = '%s' ORDER BY updated_at DESC LIMIT 1\\\",\\n   204→\\t\\tescapeSQLString(cwd),\\n   205→\\t)\\n   206→\\n   207→\\tcmd := exec.CommandContext(ctx, \\\"sqlite3\\\", \\\"-json\\\", db, query)\\n   208→\\tout, err := cmd.Output()\\n   209→\\tif err != nil {\\n   210→\\t\\tlogging.Warn(ctx, \\\"kiro: sqlite3 query failed\\\", \\\"err\\\", err, \\\"cwd\\\", cwd)\\n   211→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"sqlite3 query failed: %w\\\", err)\\n   212→\\t}\\n   213→\\n   214→\\tresult := strings.TrimSpace(string(out))\\n   215→\\tif result == \\\"\\\" || result == \\\"[]\\\" {\\n   216→\\t\\treturn \\\"\\\", nil\\n   217→\\t}\\n   218→\\n   219→\\t// sqlite3 -json returns an array of objects\\n   220→\\tvar rows []map[string]string\\n   221→\\tif err := json.Unmarshal([]byte(result), &rows); err != nil {\\n   222→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse sqlite3 output: %w\\\", err)\\n   223→\\t}\\n   224→\\tif len(rows) == 0 {\\n   225→\\t\\treturn \\\"\\\", nil\\n   226→\\t}\\n   227→\\n   228→\\t// The column name from json_extract\\n   229→\\tfor _, v := range rows[0] {\\n   230→\\t\\treturn v, nil\\n   231→\\t}\\n   232→\\treturn \\\"\\\", nil\\n   233→}\\n   234→\\n   235→// ensureCachedTranscript fetches the conversation from SQLite and caches it\\n   236→// to .entire/tmp/<sessionID>.json. Returns the cache file path.\\n   237→func (k *KiroAgent) ensureCachedTranscript(ctx context.Context, cwd, sessionID string) (string, error) {\\n   238→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   239→\\tif err != nil {\\n   240→\\t\\trepoRoot = cwd\\n   241→\\t}\\n   242→\\n   243→\\tcacheDir := filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\")\\n   244→\\tcachePath := filepath.Join(cacheDir, sessionID+\\\".json\\\")\\n   245→\\n   246→\\t// Fetch fresh transcript from SQLite on every call (transcript grows during session)\\n   247→\\tif os.Getenv(\\\"ENTIRE_TEST_KIRO_MOCK_DB\\\") == \\\"1\\\" {\\n   248→\\t\\t// In test mode, return the expected cache path without hitting SQLite.\\n   249→\\t\\treturn cachePath, nil\\n   250→\\t}\\n   251→\\n   252→\\tdb, err := dbPath()\\n   253→\\tif err != nil {\\n   254→\\t\\treturn \\\"\\\", err\\n   255→\\t}\\n   256→\