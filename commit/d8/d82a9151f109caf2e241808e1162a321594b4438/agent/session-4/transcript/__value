vent{\\n   117→\\t\\tType:      agent.TurnStart,\\n   118→\\t\\tSessionID: sessionID,\\n   119→\\t\\tPrompt:    prompt,\\n   120→\\t\\tTimestamp: time.Now(),\\n   121→\\t}, nil\\n   122→}\\n   123→\\n   124→func (k *KiroAgent) parseStop(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n   125→\\traw, err := readHookInputOrEmpty(stdin)\\n   126→\\tif err != nil {\\n   127→\\t\\treturn nil, err\\n   128→\\t}\\n   129→\\n   130→\\t// IDE mode: CWD may not be in stdin. Fall back to repo root.\\n   131→\\tcwd := raw.CWD\\n   132→\\tif cwd == \\\"\\\" {\\n   133→\\t\\trepoRoot, rootErr := paths.WorktreeRoot(ctx)\\n   134→\\t\\tif rootErr == nil {\\n   135→\\t\\t\\tcwd = repoRoot\\n   136→\\t\\t}\\n   137→\\t}\\n   138→\\n   139→\\t// Read the stable session ID generated at agentSpawn.\\n   140→\\tsessionID := k.readCachedSessionID(ctx)\\n   141→\\tif sessionID == \\\"\\\" {\\n   142→\\t\\t// Fallback: try SQLite for the session ID.\\n   143→\\t\\tsid, queryErr := k.querySessionID(ctx, cwd)\\n   144→\\t\\tif queryErr != nil || sid == \\\"\\\" {\\n   145→\\t\\t\\tsessionID = \\\"unknown\\\"\\n   146→\\t\\t} else {\\n   147→\\t\\t\\tsessionID = sid\\n   148→\\t\\t}\\n   149→\\t}\\n   150→\\n   151→\\t// At stop, Kiro's SQLite transcript is available. Fetch and cache it\\n   152→\\t// under our stable session ID so lifecycle.go can read it.\\n   153→\\tsessionRef, _ := k.ensureCachedTranscript(ctx, cwd, sessionID) //nolint:errcheck // best-effort: sessionRef=\\\"\\\" is a valid fallback\\n   154→\\n   155→\\treturn &agent.Event{\\n   156→\\t\\tType:       agent.TurnEnd,\\n   157→\\t\\tSessionID:  sessionID,\\n   158→\\t\\tSessionRef: sessionRef,\\n   159→\\t\\tTimestamp:  time.Now(),\\n   160→\\t}, nil\\n   161→}\\n   162→\\n   163→// generateAndCacheSessionID creates a new random session ID and writes it\\n   164→// to .entire/tmp/kiro-active-session for subsequent hooks to read.\\n   165→func (k *KiroAgent) generateAndCacheSessionID(ctx context.Context) string {\\n   166→\\tsid := generateSessionID()\\n   167→\\tcachePath := k.sessionIDCachePath(ctx)\\n   168→\\tif err := os.MkdirAll(filepath.Dir(cachePath), 0o750); err != nil {\\n   169→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to create session ID cache dir\\\", \\\"err\\\", err)\\n   170→\\t\\treturn sid\\n   171→\\t}\\n   172→\\tif err := os.WriteFile(cachePath, []byte(sid), 0o600); err != nil {\\n   173→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to write session ID cache\\\", \\\"err\\\", err)\\n   174→\\t}\\n   175→\\treturn sid\\n   176→}\\n   177→\\n   178→// readCachedSessionID reads the stable session ID from .entire/tmp/kiro-active-session.\\n   179→// Returns empty string if the cache file doesn't exist.\\n   180→func (k *KiroAgent) readCachedSessionID(ctx context.Context) string {\\n   181→\\tcachePath := k.sessionIDCachePath(ctx)\\n   182→\\tdata, err := os.ReadFile(cachePath) //nolint:gosec // cachePath is constructed from WorktreeRoot + constant suffix\\n   183→\\tif err != nil {\\n   184→\\t\\treturn \\\"\\\"\\n   185→\\t}\\n   186→\\treturn strings.TrimSpace(string(data))\\n   187→}\\n   188→\\n   189→// sessionIDCachePath returns the path to the session ID cache file.\\n   190→func (k *KiroAgent) sessionIDCachePath(ctx context.Context) string {\\n   191→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   192→\\tif err != nil {\\n   193→\\t\\trepoRoot = \\\".\\\"\\n   194→\\t}\\n   195→\\treturn filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\", sessionIDFile)\\n   196→}\\n   197→\\n   198→// generateSessionID creates a random 32-character hex string for use as a session ID.\\n   199→func generateSessionID() string {\\n   200→\\tb := make([]byte, 16)\\n   201→\\tif _, err := rand.Read(b); err != nil {\\n   202→\\t\\t// crypto/rand.Read never fails on supported platforms, but use timestamp fallback.\\n   203→\\t\\treturn \\\"kiro-\\\" + time.Now().Format(\\\"20060102-150405\\\")\\n   204→\\t}\\n   205→\\treturn hex.EncodeToString(b)\\n   206→}\\n   207→\"}]