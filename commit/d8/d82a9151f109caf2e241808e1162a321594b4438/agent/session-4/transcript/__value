\"\\\", fmt.Errorf(\\\"kiro database not found at %s: %w\\\", db, err)\\n   200→\\t}\\n   201→\\n   202→\\tquery := fmt.Sprintf(\\n   203→\\t\\t\\\"SELECT json_extract(value, '$.conversation_id') FROM conversations_v2 WHERE key = '%s' ORDER BY updated_at DESC LIMIT 1\\\",\\n   204→\\t\\tescapeSQLString(cwd),\\n   205→\\t)\\n   206→\\n   207→\\tcmd := exec.CommandContext(ctx, \\\"sqlite3\\\", \\\"-json\\\", db, query)\\n   208→\\tout, err := cmd.Output()\\n   209→\\tif err != nil {\\n   210→\\t\\tlogging.Warn(ctx, \\\"kiro: sqlite3 query failed\\\", \\\"err\\\", err, \\\"cwd\\\", cwd)\\n   211→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"sqlite3 query failed: %w\\\", err)\\n   212→\\t}\\n   213→\\n   214→\\tresult := strings.TrimSpace(string(out))\\n   215→\\tif result == \\\"\\\" || result == \\\"[]\\\" {\\n   216→\\t\\treturn \\\"\\\", nil\\n   217→\\t}\\n   218→\\n   219→\\t// sqlite3 -json returns an array of objects\\n   220→\\tvar rows []map[string]string\\n   221→\\tif err := json.Unmarshal([]byte(result), &rows); err != nil {\\n   222→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse sqlite3 output: %w\\\", err)\\n   223→\\t}\\n   224→\\tif len(rows) == 0 {\\n   225→\\t\\treturn \\\"\\\", nil\\n   226→\\t}\\n   227→\\n   228→\\t// The column name from json_extract\\n   229→\\tfor _, v := range rows[0] {\\n   230→\\t\\treturn v, nil\\n   231→\\t}\\n   232→\\treturn \\\"\\\", nil\\n   233→}\\n   234→\\n   235→// ensureCachedTranscript fetches the conversation from SQLite and caches it\\n   236→// to .entire/tmp/<sessionID>.json. Returns the cache file path.\\n   237→func (k *KiroAgent) ensureCachedTranscript(ctx context.Context, cwd, sessionID string) (string, error) {\\n   238→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   239→\\tif err != nil {\\n   240→\\t\\trepoRoot = cwd\\n   241→\\t}\\n   242→\\n   243→\\tcacheDir := filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\")\\n   244→\\tcachePath := filepath.Join(cacheDir, sessionID+\\\".json\\\")\\n   245→\\n 