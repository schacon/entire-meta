9→// sessionIDFile is the filename for caching the generated session ID.\\n    30→// Stored in .entire/tmp/ to ensure a stable ID across all hooks in one session.\\n    31→const sessionIDFile = \\\"kiro-active-session\\\"\\n    32→\\n    33→// HookNames returns the hook verbs Kiro supports.\\n    34→// These become subcommands: entire hooks kiro <verb>\\n    35→func (k *KiroAgent) HookNames() []string {\\n    36→\\treturn []string{\\n    37→\\t\\tHookNameAgentSpawn,\\n    38→\\t\\tHookNameUserPromptSubmit,\\n    39→\\t\\tHookNamePreToolUse,\\n    40→\\t\\tHookNamePostToolUse,\\n    41→\\t\\tHookNameStop,\\n    42→\\t}\\n    43→}\\n    44→\\n    45→// ParseHookEvent translates a Kiro hook into a normalized lifecycle Event.\\n    46→// Returns nil for hooks with no lifecycle significance (preToolUse, postToolUse).\\n    47→func (k *KiroAgent) ParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*agent.Event, error) {\\n    48→\\tswitch hookName {\\n    49→\\tcase HookNameAgentSpawn:\\n    50→\\t\\treturn k.parseAgentSpawn(ctx, stdin)\\n    51→\\tcase HookNameUserPromptSubmit:\\n    52→\\t\\treturn k.parseUserPromptSubmit(ctx, stdin)\\n    53→\\tcase HookNameStop:\\n    54→\\t\\treturn k.parseStop(ctx, stdin)\\n    55→\\tcase HookNamePreToolUse, HookNamePostToolUse:\\n    56→\\t\\t// Pass-through hooks with no lifecycle significance\\n    57→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    58→\\tdefault:\\n    59→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    60→\\t}\\n    61→}\\n    62→\\n    63→// readHookInputOrEmpty wraps ReadAndParseHookInput, returning a zero-value\\n    64→// hookInputRaw on empty stdin instead of erroring. This supports the Kiro IDE\\n    65→// which delivers data via environment variables rather than JSON on stdin.\\n    66→// Malformed JSON still returns an error.\\n    67→func readHookInputOrEmpty(stdin io.Reader) (*hookInputRaw, error) {\\n    68→\\traw, 