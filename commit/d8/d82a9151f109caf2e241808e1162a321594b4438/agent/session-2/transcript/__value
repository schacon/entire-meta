ub.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    19→\\n    20→\\t\\\"github.com/spf13/cobra\\\"\\n    21→)\\n    22→\\n    23→// agentHookLogCleanup stores the cleanup function for agent hook logging.\\n    24→// Set by PersistentPreRunE, called by PersistentPostRunE.\\n    25→var agentHookLogCleanup func()\\n    26→\\n    27→// currentHookAgentName stores the agent name for the currently executing hook.\\n    28→// Set by newAgentHookVerbCmdWithLogging before calling the handler.\\n    29→// This allows handlers to know which agent invoked the hook without guessing.\\n    30→var currentHookAgentName types.AgentName\\n    31→\\n    32→// GetCurrentHookAgent returns the agent for the currently executing hook.\\n    33→// Returns the agent based on the hook command structure (e.g., \\\"entire hooks claude-code ...\\\")\\n    34→// rather than guessing from directory presence.\\n    35→// Falls back to GetAgent() if not in a hook context.\\n    36→func GetCurrentHookAgent() (agent.Agent, error) {\\n    37→\\tif currentHookAgentName == \\\"\\\" {\\n    38→\\t\\treturn nil, errors.New(\\\"not in a hook context: agent name not set\\\")\\n    39→\\t}\\n    40→\\n    41→\\tag, err := agent.Get(currentHookAgentName)\\n    42→\\tif err != nil {\\n    43→\\t\\treturn nil, fmt.Errorf(\\\"getting hook agent %q: %w\\\", currentHookAgentName, err)\\n    44→\\t}\\n    45→\\treturn ag, nil\\n    46→}\\n    47→\\n    48→// newAgentHooksCmd creates a hooks subcommand for an agent that implements HookSupport.\\n    49→// It dynamically creates subcommands for each hook the agent supports.\\n    50→func newAgentHooksCmd(agentName types.AgentName, handler agent.HookSupport) *cobra.Command {\\n    51→\\tcmd := &cobra.Command{\\n    52→\\t\\tUse:    string(agentName),\\n    53→\\t\\tShort:  handler.Description() + \\\" hook handlers\\\",\\n    54→\\t\\tHidden: true,\\n    55→\\t\\tPersistentPreRunE: func(cmd *cobra.Command, _ []string) error {\\n    56→\\t\\t\\tagentHookLogCleanup = initHookLogging(cmd.Context())\\n    57→\\t\\t\\treturn nil\\n    58→\\t\\t},\\n    59→\\t\\tPersistentPostRunE: func(_ *cobra.Command, _ []string) error {\\n    60→\\t\\t\\tif agentHookLogCleanup != nil {\\n    61→\\t\\t\\t\\tagentHookLogCleanup()\\n    62→\\t\\t\\t}\\n    63→\\t\\t\\treturn nil\\n    64→\\t\\t},\\n    65→\\t}\\n    66→\\n    67→\\tfor _, hookName := range handler.HookNames() {\\n    68→\\t\\tcmd.AddCommand(newAgentHookVerbCmdWithLogging(agentName, hookName))\\n    69→\\t}\\n    70→\\n    71→\\treturn cmd\\n    72→}\\n    73→\\n    74→// getHookType returns the hook type based on the hook name.\\n    75→// Returns \\\"subagent\\\" for task-related hooks (pre-task, post-task, post-todo),\\n    76→// \\\"tool\\\" for tool-related hooks (before-tool, after-tool),\\n    77→// \\\"agent\\\" for all other agent hooks.\\n    78→func getHookType(hookName string) string {\\n    79→\\tswitch hookName {\\n    80→\\tcase claudecode.HookNamePreTask, claudecode.HookNamePostTask, claudecode.HookNamePostTodo:\\n    81→\\t\\treturn \\\"subagent\\\"\\n    82→\\tcase geminicli.HookNameBeforeTool, geminicli.HookNameAfterTool:\\n    83→\\t\\treturn \\\"tool\\\"\\n    84→\\tdefault:\\n    85→\\t\\treturn \\\"agent\\\"\\n    86→\\t}\\n    87→}\\n    88→\\n    89→// newAgentHookVerbCmdWithLogging creates a command for a specific hook verb with structured logging.\\n    90→// It uses the lifecycle dispatcher (ParseHookEvent → DispatchLifecycleEvent) as the primary path.\\n    91→// PostTodo is handled directly as it's Claude-specific and not part of the lifecycle dispatcher.\\n    92→func newAgentHookVerbCmdWithLogging(agentName types.AgentName, hookName string) *cobra.Command {\\n    93→\\treturn &cobra.Command{\\n    94→\\t\\tUse:    hookName,\\n    95→\\t\\tHidden: true,\\n    96→\\t\\tShort:  \\\"Called on \\\" + hookName,\\n    97→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    98→\\t\\t\\t// Skip silently if not in a git repository - hooks shouldn't prevent the agent from working\\n    99→\\t\\t\\tif _, err := paths.WorktreeRoot(cmd.Context()); err != nil {\\n   100→\\t\\t\\t\\treturn nil\\n   101→\\t\\t\\t}\\n   102→\\n   103→\\t\\t\\t// Skip if Entire is not enabled\\n   104→\\t\\t\\tenabled, err := IsEnabled(cmd.Context())\\n   105→\\t\\t\\tif err == nil && !enabled {\\n   106→\\t\\t\\t\\treturn nil\\n   107→\\t\\t\\t}\\n   108→\\n   109→\\t\\t\\tstart := time.Now()\\n   110→\\n   111→\\t\\t\\t// Initialize logging context with agent name\\n   112→\\t\\t\\tctx := logging.WithAgent(logging.WithComponent(cmd.Context(), \\\"hooks\\\"), agentName)\\n   113→\\n   114→\\t\\t\\t// Strategy name for logging\\n   115→\\t\\t\\tstrategyName := strategy.StrategyNameManualCommit\\n   116→\\n   117→\\t\\t\\thookType := getHookType(hookName)\\n   118→\\n   119→\\t\\t\\tlogging.Debug(ctx, \\\"hook invoked\\\",\\n   120→\\t\\t\\t\\tslog.String(\\\"hook\\\", hookName),\\n   121→\\t\\t\\t\\tslog.String(\\\"hook_type\\\", hookType),\\n   122→\\t\\t\\t\\tslog.String(\\\"strategy\\\", strategyName),\\n   123→\\t\\t\\t)\\n   124→\\n   125→\\t\\t\\t// Set the current hook agent so handlers can retrieve it\\n   126→\\t\\t\\tcurrentHookAgentName = agentName\\n   127→\\t\\t\\tdefer func() { currentHookAgentName = \\\"\\\" }()\\n   128→\\n   129→\\t\\t\\t// Use the lifecycle dispatcher for all hooks\\n   130→\\t\\t\\tvar hookErr error\\n   131→\\t\\t\\tag, agentErr := agent.Get(agentName)\\n   132→\\t\\t\\tif agentErr != nil {\\n   133→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to get agent %q: %w\\\", agentName, agentErr)\\n   134→\\t\\t\\t}\\n   135→\\n   136→\\t\\t\\thandler, ok := ag.(agent.HookSupport)\\n   137→\\t\\t\\tif !ok {\\n   138→\\t\\t\\t\\treturn fmt.Errorf(\\\"agent %q does not support hooks\\\", agentName)\\n   139→\\t\\t\\t}\\n   140→\\n   141→\\t\\t\\t// Use cmd.InOrStdin() to support testing with cmd.SetIn()\\n   142→\\t\\t\\tevent, parseErr := handler.ParseHookEvent(ctx, hookName, cmd.InOrStdin())\\n   143→\\t\\t\\tif parseErr != nil {\\n   144→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to parse hook event: %w\\\", parseErr)\\n   145→\\t\\t\\t}\\n   146→\\n   147→\\t\\t\\tif event != nil {\\n   148→\\t\\t\\t\\t// Lifecycle event — use the generic dispatcher\\n   149→\\t\\t\\t\\thookErr = DispatchLifecycleEvent(ctx, ag, event)\\n   150→\\t\\t\\t} else if agentName == agent.AgentNameClaudeCode && hookName == claudecode.HookNamePostTodo {\\n   151→\\t\\t\\t\\t// PostTodo is Claude-specific: creates incremental checkpoints during subagent execution\\n   152→\\t\\t\\t\\thookErr = handleClaudeCodePostTodo(ctx)\\n   153→\\t\\t\\t}\\n   154→\\t\\t\\t// Other pass-through hooks (nil event, no special handling) are no-ops\\n   155→\\n   156→\\t\\t\\tlogging.LogDuration(ctx, slog.LevelDebug, \\\"hook completed\\\", start,\\n   157→\\t\\t\\t\\tslog.String(\\\"hook\\\", hookName),\\n   158→\\t\\t\\t\\tslog.String(\\\"hook_type\\\", hookType),\\n   159→\\t\\t\\t\\tslog.String(\\\"strategy\\\", strategyName),\\n   160→\\t\\t\\t\\tslog.Bool(\\\"success\\\", hookErr == nil),\\n   161→\\t\\t\\t)\\n   162→\\n   163→\\t\\t\\treturn hookErr\\n   164→\\t\\t},\\n   165→\\t}\\n   166→}\\n   167→\"}]},\"uuid\":\"e83fa992-5dba-48b2-90a7-715dcbccb907\",\"timestamp\":\"2026-03-03T19:08:00.533Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a4b3c6bfcd0e05118\"},\"toolUseID\":\"agent_msg_01RZLEMWM4zTLa9f6GfFcU1k\",\"parentToolUseID\":\"toolu_01D2YiCdoEr9G1SEs4krFgm5\",\"uuid\":\"d069d859-42ec-40bd-a996-42dfb048fd9d\",\"timestamp\":\"2026-03-03T19:08:00.534Z\"}\n{\"parentUuid\":\"d069d859-42ec-40bd-a996-42dfb048fd9d\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"8a949619-8aae-4f1a-a46c-6bbf236c34b3\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"glittery-waddling-parrot\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-03T19:08:02.095Z\",\"message\":{\"model\":\"claude-sonnet-4-6\",\"id\":\"msg_01L7ztLL8f2KTwfoNSWU6mDN\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01K3uGoarEDPgvuVviwn13Sm\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/alisha/Projects/wt/kiro-oneshot/cmd/entire/cli/agent/agent.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":3742,\"cache_read_input_tokens\":104857,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":3742},\"output_tokens\":24,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYgfwQhw6SUnyD1cVqfJ8\",\"uuid\":\"78626c4e-19c7-4f18-8267-21c4175a6cb7\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a0f69859fc1a7e8ed\"},\"toolUseID\":\"agent_msg_01RZLEMWM4zTLa9f6GfFcU1k\",\"parentToolUseID\":\"toolu_01EZQovuCTvbmbYQviSz5UyX\",\"uuid\":\"cf9b13d4-5bc3-4851-889a-6d94548cf871\",\"timestamp\":\"2026-03-03T19:08:02.095Z\"}\n{\"parentUuid\":\"cf9b13d4-5bc3-4851-889a-6d94548cf871\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"8a949619-8aae-4f1a-a46c-6bbf236c34b3\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"glittery-waddling-parrot\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01K3uGoarEDPgvuVviwn13Sm\",\"type\":\"tool_result\",\"content\":\"     1→// Package agent provides interfaces and types for integrating with coding agents.\\n     2→// It abstracts agent-specific behavior (hooks, log parsing, session storage) so that\\n     3→// the same Strategy implementations can work with any coding agent.\\n     4→package agent\\n     5→\\n     6→import (\\n     7→\\t\\\"context\\\"\\n     8→\\t\\\"io\\\"\\n     9→\\n    10→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    11→)\\n    12→\\n    13→// Agent defines the interface for interacting with a coding agent.\\n    14→// Each agent implementation (Claude Code, Cursor, Aider, etc.) converts its\\n    15→// native format to the normalized types defined in this package.\\n    16→//\\n    17→// The interface is organized into three groups:\\n    18→//   - Identity (5 methods): Name, Type, Description, DetectPresence, ProtectedDirs\\n    19→//   - Transcript Storage (3 methods): ReadTranscript, ChunkTranscript, ReassembleTranscript\\n    20→//   - Legacy (6 methods): Will be moved to optional interfaces or removed in a future phase\\n    21→type Agent interface {\\n    22→\\t// --- Identity ---\\n    23→\\n    24→\\t// Name returns the agent registry key (e.g., \\\"claude-code\\\", \\\"gemini\\\")\\n    25→\\tName() types.AgentName\\n    26→\\n    27→\\t// Type returns the agent type identifier (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\")\\n    28→\\t// This is stored in metadata and trailers.\\n    29→\\tType() types.AgentType\\n    30→\\n    31→\\t// Description returns a human-readable description for UI\\n    32→\\tDescription() string\\n    33→\\n    34→\\t// IsPreview returns whether the agent integration is in preview or stable\\n    35→\\tIsPreview() bool\\n    36→\\n    37→\\t// DetectPresence checks if this agent is configured in the repository\\n    38→\\tDetectPresence(ctx context.Context) (bool, error)\\n    39→\\n    40→\\t// ProtectedDirs returns repo-root-relative directories that should never be\\n    41→\\t// modified or deleted during rewind or other destructive operations.\\n    42→\\t// Examples: [\\\".claude\\\"] for Claude, [\\\".gemini\\\"] for Gemini.\\n    43→\\tProtectedDirs() []string\\n    44→\\n    45→\\t// --- Transcript Storage ---\\n    46→\\n    47→\\t// ReadTranscript reads the raw transcript bytes for a session.\\n    48→\\tReadTranscript(sessionRef string) ([]byte, error)\\n    49→\\n    50→\\t// ChunkTranscript splits a transcript into chunks if it exceeds maxSize.\\n    51→\\t// Returns a slice of chunks. If the transcript fits in one chunk, returns single-element slice.\\n    52→\\t// The chunking is format-aware: JSONL splits at line boundaries, JSON splits message arrays.\\n    53→\\tChunkTranscript(ctx context.Context, content []byte, maxSize int) ([][]byte, error)\\n    54→\\n    55→\\t// ReassembleTranscript combines chunks back into a single transcript.\\n    56→\\t// Handles format-specific reassembly (JSONL concatenation, JSON message merging).\\n    57→\\tReassembleTranscript(chunks [][]byte) ([]byte, error)\\n    58→\\n    59→\\t// --- Legacy methods (will move to optional interfaces in Phase 4) ---\\n    60→\\n    61→\\t// GetSessionID extracts session ID from hook input.\\n    62→\\tGetSessionID(input *HookInput) string\\n    63→\\n    64→\\t// GetSessionDir returns where agent stores session data for this repo.\\n    65→\\tGetSessionDir(repoPath string) (string, error)\\n    66→\\n    67→\\t// ResolveSessionFile returns the path to the session transcript file.\\n    68→\\tResolveSessionFile(sessionDir, agentSessionID string) string\\n    69→\\n    70→\\t// ReadSession reads session data from agent's storage.\\n    71→\\tReadSession(input *HookInput) (*AgentSession, error)\\n    72→\\n    73→\\t// WriteSession writes session data for resumption.\\n    74→\\tWriteSession(ctx context.Context, session *AgentSession) error\\n    75→\\n    76→\\t// FormatResumeCommand returns command to resume a session.\\n    77→\\tFormatResumeCommand(sessionID string) string\\n    78→}\\n    79→\\n    80→// HookSupport is implemented by agents with lifecycle hooks.\\n    81→// This optional interface allows agents like Claude Code and Cursor to\\n    82→// install and manage hooks that notify Entire of agent events.\\n    83→//\\n    84→// The interface is organized into two groups:\\n    85→//   - Hook Mapping (2 methods): HookNames, ParseHookEvent\\n    86→//   - Hook Management (3 methods): InstallHooks, UninstallHooks, AreHooksInstalled\\n    87→type HookSupport interface {\\n    88→\\tAgent\\n    89→\\n    90→\\t// HookNames returns the hook verbs this agent supports.\\n    91→\\t// These become subcommands under `entire hooks <agent>`.\\n    92→\\t// e.g., [\\\"stop\\\", \\\"user-prompt-submit\\\", \\\"session-start\\\", \\\"session-end\\\"]\\n    93→\\tHookNames() []string\\n    94→\\n    95→\\t// ParseHookEvent translates an agent-native hook into a normalized lifecycle Event.\\n    96→\\t// Returns nil if the hook has no lifecycle significance (e.g., pass-through hooks).\\n    97→\\t// This is the core contribution surface for new agent implementations.\\n    98→\\tParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*Event, error)\\n    99→\\n   100→\\t// InstallHooks installs agent-specific hooks.\\n   101→\\t// If localDev is true, hooks point to local development build.\\n   102→\\t// If force is true, removes existing Entire hooks before installing.\\n   103→\\t// Returns the number of hooks installed.\\n   104→\\tInstallHooks(ctx context.Context, localDev bool, force bool) (int, error)\\n   105→\\n   106→\\t// UninstallHooks removes installed hooks\\n   107→\\tUninstallHooks(ctx context.Context) error\\n   108→\\n   109→\\t// AreHooksInstalled checks if hooks are currently installed\\n   110→\\tAreHooksInstalled(ctx context.Context) bool\\n   111→}\\n   112→\\n   113→// FileWatcher is implemented by agents that use file-based detection.\\n   114→// Agents like Aider that don't support hooks can use file watching\\n   115→// to detect session activity.\\n   116→type FileWatcher interface {\\n   117→\\tAgent\\n   118→\\n   119→\\t// GetWatchPaths returns paths to watch for session changes\\n   120→\\tGetWatchPaths() ([]string, error)\\n   121→\\n   122→\\t// OnFileChange handles a detected file change and returns session info\\n   123→\\tOnFileChange(path string) (*SessionChange, error)\\n   124→}\\n   125→\\n   126→// TranscriptAnalyzer provides format-specific transcript parsing.\\n   127→// Agents that implement this get richer checkpoints (transcript-derived file lists,\\n   128→// prompts, summaries). Agents that don't still participate in the checkpoint lifecycle\\n   129→// via git-status-based file detection and raw transcript storage.\\n   130→type TranscriptAnalyzer interface {\\n   131→\\tAgent\\n   132→\\n   133→\\t// GetTranscriptPosition returns the current position (length) of a transcript.\\n   134→\\t// For JSONL formats (Claude Code), this is the line count.\\n   135→\\t// For JSON formats (Gemini CLI), this is the message count.\\n   136→\\t// Returns 0 if the file doesn't exist or is empty.\\n   137→\\tGetTranscriptPosition(path string) (int, error)\\n   138→\\n   139→\\t// ExtractModifiedFilesFromOffset extracts files modified since a given offset.\\n   140→\\t// For JSONL formats (Claude Code), offset is the starting line number.\\n   141→\\t// For JSON formats (Gemini CLI), offset is the starting message index.\\n   142→\\t// Returns:\\n   143→\\t//   - files: list of file paths modified by the agent (from Write/Edit tools)\\n   144→\\t//   - currentPosition: the current position (line count or message count)\\n   145→\\t//   - error: any error encountered during reading\\n   146→\\tExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error)\\n   147→\\n   148→\\t// ExtractPrompts extracts user prompts from the transcript starting at the given offset.\\n   149→\\tExtractPrompts(sessionRef string, fromOffset int) ([]string, error)\\n   150→\\n   151→\\t// ExtractSummary extracts a summary of the session from the transcript.\\n   152→\\tExtractSummary(sessionRef string) (string, error)\\n   153→}\\n   154→\\n   155→// TranscriptPreparer is called before ReadTranscript to handle agent-specific\\n   156→// flush/sync requirements (e.g., Claude Code's async transcript writing).\\n   157→// The framework calls PrepareTranscript before ReadTranscript if implemented.\\n   158→type TranscriptPreparer interface {\\n   159→\\tAgent\\n   160→\\n   161→\\t// PrepareTranscript ensures the transcript is ready to read.\\n   162→\\t// For Claude Code, this waits for the async transcript flush to complete.\\n   163→\\tPrepareTranscript(ctx context.Context, sessionRef string) error\\n   164→}\\n   165→\\n   166→// TokenCalculator provides token usage calculation for a session.\\n   167→// The framework calls this during step save and checkpoint if implemented.\\n   168→type TokenCalculator interface {\\n   169→\\tAgent\\n   170→\\n   171→\\t// CalculateTokenUsage computes token usage from the transcript starting at the given offset.\\n   172→\\tCalculateTokenUsage(transcriptData []byte, fromOffset int) (*TokenUsage, error)\\n   173→}\\n   174→\\n   175→// HookResponseWriter is implemented by agents that support structured hook responses.\\n   176→// Agents that implement this can output messages (e.g., banners) to the user via\\n   177→// the agent's response protocol. For example, Claude Code outputs JSON with a\\n   178→// systemMessage field to stdout. Agents that don't implement this will silently\\n   179→// skip hook response output.\\n   180→type HookResponseWriter interface {\\n   181→\\tAgent\\n   182→\\n   183→\\t// WriteHookResponse outputs a message to the user via the agent's hook response protocol.\\n   184→\\tWriteHookResponse(message string) error\\n   185→}\\n   186→\\n   187→// SubagentAwareExtractor provides methods for extracting files and tokens including subagents.\