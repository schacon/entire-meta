a session.\\n    60→func (k *KiroAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    61→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    62→\\tif err != nil {\\n    63→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    64→\\t}\\n    65→\\treturn data, nil\\n    66→}\\n    67→\\n    68→// ChunkTranscript splits a JSON transcript into chunks.\\n    69→// Kiro transcripts are single JSON objects; we use the JSONL chunker since the\\n    70→// cached format is a JSON blob that fits in a single chunk in most cases.\\n    71→func (k *KiroAgent) ChunkTranscript(_ context.Context, content []byte, maxSize int) ([][]byte, error) {\\n    72→\\tif len(content) <= maxSize {\\n    73→\\t\\treturn [][]byte{content}, nil\\n    74→\\t}\\n    75→\\t// For large transcripts, split at line boundaries\\n    76→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n    79→\\t}\\n    80→\\treturn chunks, nil\\n    81→}\\n    82→\\n    83→// ReassembleTranscript combines transcript chunks back into a single blob.\\n    84→func (k *KiroAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    85→\\tif len(chunks) == 1 {\\n    86→\\t\\treturn chunks[0], nil\\n    87→\\t}\\n    88→\\treturn agent.ReassembleJSONL(chunks), nil\\n    89→}\\n    90→\\n    91→// --- Session Management ---\\n    92→\\n    93→// GetSessionID extracts the session ID from hook input.\\n    94→func (k *KiroAgent) GetSessionID(input *agent.HookInput) string {\\n    95→\\treturn input.SessionID\\n    96→}\\n    97→\\n    98→// GetSessionDir returns the directory where Kiro stores session data.\\n    99→// For Kiro, sessions are in SQLite, but we cache transcripts to .entire/tmp/.\\n   100→func (k *KiroAgent) GetSessionDir(repoPath string) (string, error) {\\n   101→\\treturn filepath.Join(repoPath, \\\".entire\\\", \\\"tmp\\\"), nil\\n   102→}\\n   103→\\n   104→// ResolveSessionFile returns the path to the cached transcript file.\\n   105→func (k *KiroAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   106→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".json\\\")\\n   107→}\\n   108→\\n   109→// ReadSession reads session data from the cached transcript.\\n   110→func (k *KiroAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   111→\\tif input.SessionRef == \\\"\\\" {\\n   112→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   113→\\t}\\n   114→\\n   115→\\tdata, err := os.ReadFile(input.SessionRef)\\n   116→\\tif err != nil {\\n   117→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   118→\\t}\\n   119→\\n   120→\\treturn &agent.AgentSession{\\n   121→\\t\\tSessionID:  input.SessionID,\\n   122→\\t\\tAgentName:  k.Name(),\\n   123→\\t\\tSessionRef: input.SessionRef,\\n   124→\\t\\tStartTime:  time.Now(),\\n   125→\\t\\tNativeData: data,\\n   126→\\t}, nil\\n   127→}\\n   128→\\n   129→// WriteSession writes session data for resumption.\\n   130→func (k *KiroAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   131→\\tif session == nil {\\n   132→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   133→\\t}\\n   134→\\tif session.AgentName != \\\"\\\" && session.AgentName != k.Name() {\\n   135→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, k.Name())\\n   136→\\t}\\n   137→\\tif session.SessionRef == \\\"\\\" {\\n   138→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   139→\\t}\\n   140→\\tif len(session.NativeData) == 0 {\\n   141→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   142→\\t}\\n   143→\\n   144→\\tif err := os.MkdirAll(filepath.Dir(session.SessionRef), 0o750); err != nil {\\n   145→\\t\\treturn fmt.Errorf(\\\"failed to create