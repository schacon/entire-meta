 37→)\\n    38→\\n    39→// String returns a human-readable name for the event type.\\n    40→func (e EventType) String() string {\\n    41→\\tswitch e {\\n    42→\\tcase SessionStart:\\n    43→\\t\\treturn \\\"SessionStart\\\"\\n    44→\\tcase TurnStart:\\n    45→\\t\\treturn \\\"TurnStart\\\"\\n    46→\\tcase TurnEnd:\\n    47→\\t\\treturn \\\"TurnEnd\\\"\\n    48→\\tcase Compaction:\\n    49→\\t\\treturn \\\"Compaction\\\"\\n    50→\\tcase SessionEnd:\\n    51→\\t\\treturn \\\"SessionEnd\\\"\\n    52→\\tcase SubagentStart:\\n    53→\\t\\treturn \\\"SubagentStart\\\"\\n    54→\\tcase SubagentEnd:\\n    55→\\t\\treturn \\\"SubagentEnd\\\"\\n    56→\\tdefault:\\n    57→\\t\\treturn \\\"Unknown\\\"\\n    58→\\t}\\n    59→}\\n    60→\\n    61→// Event is a normalized lifecycle event produced by an agent's ParseHookEvent method.\\n    62→// The framework dispatcher uses these events to drive checkpoint/session lifecycle actions.\\n    63→type Event struct {\\n    64→\\t// Type is the kind of lifecycle event.\\n    65→\\tType EventType\\n    66→\\n    67→\\t// SessionID identifies the agent session.\\n    68→\\tSessionID string\\n    69→\\n    70→\\t// PreviousSessionID is non-empty when this event represents a session continuation\\n    71→\\t// or handoff (e.g., Claude starting a new session ID after exiting plan mode).\\n    72→\\tPreviousSessionID string\\n    73→\\n    74→\\t// SessionRef is an agent-specific reference to the transcript (typically a file path).\\n    75→\\tSessionRef string\\n    76→\\n    77→\\t// Prompt is the user's prompt text (populated on TurnStart events).\\n    78→\\tPrompt string\\n    79→\\n    80→\\t// Timestamp is when the event occurred.\\n    81→\\tTimestamp time.Time\\n    82→\\n    83→\\t// ToolUseID identifies the tool invocation (for SubagentStart/SubagentEnd events).\\n    84→\\tToolUseID string\\n    85→\\n    86→\\t// SubagentID identifies the subagent instance (for SubagentEnd events).\\n    87→\\tSubagentID string\\n    88→\\n    89→\\t// ToolInput is the raw tool input JSON (for subagent type/description extraction).\\n    90→\\t// Used when both SubagentType and TaskDescription are empty (agents that don't provide\\n    91→\\t// these fields directly parse them from ToolInput).\\n    92→\\tToolInput json.RawMessage\\n    93→\\n    94→\\t// SubagentType is the kind of subagent (for SubagentStart/SubagentEnd events).\\n    95→\\t// Used with TaskDescription instead of ToolInput\\n    96→\\tSubagentType    string\\n    97→\\tTaskDescription string\\n    98→\\n    99→\\t// ResponseMessage is an optional message to display to the user via the agent.\\n   100→\\tResponseMessage string\\n   101→\\n   102→\\t// Metadata holds agent-specific state that the framework stores and makes available\\n   103→\\t// on subsequent events. Examples: Pi's activeLeafId, Cursor's is_background_agent.\\n   104→\\tMetadata map[string]string\\n   105→}\\n   106→\\n   107→// ReadAndParseHookInput reads all bytes from stdin and unmarshals JSON into the given type.\\n   108→// This is a shared helper for agent ParseHookEvent implementations.\\n   109→func ReadAndParseHookInput[T any](stdin io.Reader) (*T, error) {\\n   110→\\tdata, err := io.ReadAll(stdin)\\n   111→\\tif err != nil {\\n   112→\\t\\treturn nil, fmt.Errorf(\\\"failed to read hook input: %w\\\", err)\\n   113→\\t}\\n   114→\\tif len(data) == 0 {\\n   115→\\t\\treturn nil, errors.New(\\\"empty hook input\\\")\\n   116→\\t}\\n   117→\\tvar result T\\n   118→\\tif err := json.Unmarshal(data, &result); err != nil {\\n   119→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse hook input: %w\\\", err)\\n   120→\\t}\\n   121→\\treturn &result, nil\\n   122→}\\n   123→\"}]},\"uuid\":\"a5f4c8a0-2b6b-450a-910a-303d43ee8766\",\"timestamp\":\"2026-03-03T19:07:56.008Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a4b3c6bfcd0e05118\"},\"toolUseID\":\"agent_msg_01RZLEMWM4zTLa9f6GfFcU1k\",\"parentToolUseID\":\"toolu_01D2YiCdoEr