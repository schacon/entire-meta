nally ignoring parse errors - leave target as nil/empty\\n   322→\\t\\tjson.Unmarshal(data, target)\\n   323→\\t}\\n   324→}\\n   325→\\n   326→// marshalCursorHookType marshals a hook type back into rawHooks.\\n   327→// If the slice is empty, removes the key from rawHooks.\\n   328→func marshalCursorHookType(rawHooks map[string]json.RawMessage, hookType string, entries []CursorHookEntry) {\\n   329→\\tif len(entries) == 0 {\\n   330→\\t\\tdelete(rawHooks, hookType)\\n   331→\\t\\treturn\\n   332→\\t}\\n   333→\\tdata, err := json.Marshal(entries)\\n   334→\\tif err != nil {\\n   335→\\t\\treturn // Silently ignore marshal errors (shouldn't happen)\\n   336→\\t}\\n   337→\\trawHooks[hookType] = data\\n   338→}\\n   339→\\n   340→// Helper functions for hook management\\n   341→\\n   342→func hookCommandExists(entries []CursorHookEntry, command string) bool {\\n   343→\\tfor _, entry := range entries {\\n   344→\\t\\tif entry.Command == command {\\n   345→\\t\\t\\treturn true\\n   346→\\t\\t}\\n   347→\\t}\\n   348→\\treturn false\\n   349→}\\n   350→\\n   351→func isEntireHook(command string) bool {\\n   352→\\tfor _, prefix := range entireHookPrefixes {\\n   353→\\t\\tif strings.HasPrefix(command, prefix) {\\n   354→\\t\\t\\treturn true\\n   355→\\t\\t}\\n   356→\\t}\\n   357→\\treturn false\\n   358→}\\n   359→\\n   360→func hasEntireHook(entries []CursorHookEntry) bool {\\n   361→\\tfor _, entry := range entries {\\n   362→\\t\\tif isEntireHook(entry.Command) {\\n   363→\\t\\t\\treturn true\\n   364→\\t\\t}\\n   365→\\t}\\n   366→\\treturn false\\n   367→}\\n   368→\\n   369→func removeEntireHooks(entries []CursorHookEntry) []CursorHookEntry {\\n   370→\\tresult := make([]CursorHookEntry, 0, len(entries))\\n   371→\\tfor _, entry := range entries {\\n   372→\\t\\tif !isEntireHook(entry.Command) {\\n   373→\\t\\t\\tresult = append(result, entry)\\n   374→\\t\\t}\\n   375→\\t}\\n   376→\\treturn result\\n   377→}\\n   378→\"}]},\"uuid\":\"bbd61fab-e762-4763-aee1-550eda8f5710\",\"timestamp\":\"2026-03-03T19:31:23.424Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"afad69267adabc97f\"},\"toolUseID\":\"agent_msg_01GxgNbse4nZZdHFUrepgkw1\",\"parentToolUseID\":\"toolu_01LFyfbTQCeCoPvavUc4fFVP\",\"uuid\":\"d4826dd9-0702-4476-ac01-aa877dce5ad6\",\"timestamp\":\"2026-03-03T19:31:23.431Z\"}\n{\"parentUuid\":\"d4826dd9-0702-4476-ac01-aa877dce5ad6\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"8a949619-8aae-4f1a-a46c-6bbf236c34b3\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"glittery-waddling-parrot\",\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"PostToolUse\",\"hookName\":\"PostToolUse:Agent\",\"command\":\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code post-task\"},\"parentToolUseID\":\"toolu_01LFyfbTQCeCoPvavUc4fFVP\",\"toolUseID\":\"toolu_01LFyfbTQCeCoPvavUc4fFVP\",\"timestamp\":\"2026-03-03T19:34:08.333Z\",\"uuid\":\"cdea29a6-3eaa-4aeb-96f1-8be9a3364bd4\"}\n{\"parentUuid\":\"d1fcd8e2-2981-4e31-944a-d3736e4de335\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"8a949619-8aae-4f1a-a46c-6bbf236c34b3\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"glittery-waddling-parrot\",\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01LFyfbTQCeCoPvavUc4fFVP\",\"type\":\"tool_result\",\"content\":[{\"type\":\"text\",\"text\":\"Now I have a thorough understanding of the codebase. Let me design the complete implementation plan.\\n\\n---\\n\\n## Implementation Plan: Kiro IDE Hooks (.kiro/hooks/*.kiro.hook)\\n\\n### Overview\\n\\nThe implementation spans 6 files across the `kiro` package. The core work is:\\n1. Adding new IDE hook file types to `types.go`\\n2. Extending `hooks.go` to install/uninstall/check 4 IDE hook files in `.kiro/hooks/`\\n3. Modifying `lifecycle.go` to gracefully handle empty stdin by falling back to env vars\\n4. Adding tests for both new behaviors\\n\\n---\\n\\n### File 1: `cmd/entire/cli/agent/kiro/types.go`\\n\\nAdd three new structs for the IDE hook file format. These go directly below the existing `kiroHookEntry` struct.\\n\\n```go\\n// kiroIDEHookFile represents a single .kiro.hook file installed for the Kiro IDE extension.\\n// Each file configures one hook trigger for the VS Code extension.\\n// Entire owns these files entirely — no round-trip preservation needed.\\ntype kiroIDEHookFile struct {\\n    Enabled     bool            `json:\\\"enabled\\\"`\\n    Name        string          `json:\\\"name\\\"`\\n    Description string          `json:\\\"description\\\"`\\n    Version     string          `json:\\\"version\\\"`\\n    When        kiroIDEHookWhen `json:\\\"when\\\"`\\n    Then        kiroIDEHookThen `json:\\\"then\\\"`\\n}\\n\\n// kiroIDEHookWhen describes when an IDE hook fires.\\ntype kiroIDEHookWhen struct {\\n    Type     string `json:\\\"type\\\"`\\n    ToolName string `json:\\\"toolName,omitempty\\\"`\\n}\\n\\n// kiroIDEHookThen describes the action to take when an IDE hook fires.\\ntype kiroIDEHookThen struct {\\n    Type    string `json:\\\"type\\\"`\\n    Command string `json:\\\"command\\\"`\\n}\\n```\\n\\nKey decisions:\\n- `Version` is `string` (not `int`) because the sample JSON shows `\\\"1\\\"` — but wait, the sample shows `\\\"version\\\": \\\"1\\\"` as a string. Looking at the format spec more carefully: the user provided `\\\"version\\\": \\\"1\\\"` as a string literal in the format. Use `string`.\\n- `ToolName` is `omitempty` to handle hooks that don't filter by tool name.\\n- These are unexported (lowercase) since they are package-internal.\\n\\n---\\n\\n### File 2: `cmd/entire/cli/agent/kiro/hooks.go`\\n\\nThis is the most substantial change. Here is the complete design:\\n\\n#### New constants\\n\\n```go\\n// ideHooksDir is the directory within .kiro where IDE hook files live.\\nconst ideHooksDir = \\\"hooks\\\"\\n\\n// ideHookFileSuffix is the file extension for Kiro IDE hook files.\\nconst ideHookFileSuffix = \\\".kiro.hook\\\"\\n\\n// ideHookVersion is the version field value for IDE hook files.\\nconst ideHookVersion = \\\"1\\\"\\n```\\n\\n#### New IDE hook filename mapping\\n\\nDefine the 4 IDE hook filenames and their metadata as a slice of structs. This avoids repetitive code:\\n\\n```go\\n// ideHookDef describes a single IDE hook file to install.\\ntype ideHookDef struct {\\n    filename    string\\n    name        string\\n    description string\\n    whenType    string\\n    hookVerb    string // appended to cmdPrefix\\n}\\n\\n// ideHookDefs defines the 4 IDE hook files Entire installs.\\nvar ideHookDefs = []ideHookDef{\\n    {\\n        filename:    \\\"entire-prompt-submit\\\" + ideHookFileSuffix,\\n        name:        \\\"Entire - Prompt Submit\\\",\\n        description: \\\"Tracks user prompts for Entire session checkpoints\\\",\\n        whenType:    \\\"promptSubmit\\\",\\n        hookVerb:    HookNameUserPromptSubmit,\\n    },\\n    {\\n        filename:    \\\"entire-stop\\\" + ideHookFileSuffix,\\n        name:        \\\"Entire - Stop\\\",\\n        description: \\\"Triggers Entire checkpoint on agent stop\\\",\\n        whenType:    \\\"agentStop\\\",\\n        hookVerb:    HookNameStop,\\n    },\\n    {\\n        filename:    \\\"entire-pre-tool-use\\\" + ideHookFileSuffix,\\n        name:        \\\"Entire - Pre Tool Use\\\",\\n        description: \\\"Notifies Entire before tool execution\\\",\\n        whenType:    \\\"preToolUse\\\",\\n        hookVerb:    HookNamePreToolUse,\\n    },\\n    {\\n        filename:    \\\"entire-post-tool-use\\\" + ideHookFileSuffix,\\n        name:        \\\"Entire - Post Tool Use\\\",\\n        description: \\\"Notifies Entire after tool execution\\\",\\n        whenType:    \\\"postToolUse\\\",\\n        hookVerb:    HookNamePostToolUse,\\n    },\\n}\\n```\\n\\n#### Modified `InstallHooks`\\n\\nThe function becomes a two-phase install: CLI agent file + IDE hook files. The count return reflects both. The early-exit idempotency check must now validate BOTH sets.\\n\\n```go\\nfunc (k *KiroAgent) InstallHooks(ctx context.Context, localDev bool, force bool) (int, error) {\\n    worktreeRoot, err := paths.WorktreeRoot(ctx)\\n    if err != nil {\\n        worktreeRoot = \\\".\\\"\\n    }\\n\\n    hooksPath := filepath.Join(worktreeRoot, \\\".kiro\\\", hooksDir, HooksFileName)\\n\\n    // If not forcing, check if both CLI and IDE hooks are already current\\n    if !force {\\n        if existing, readErr := os.ReadFile(hooksPath); readErr == nil { //nolint:gosec // path constructed from repo root\\n            var file kiroAgentFile\\n            if json.Unmarshal(existing, &file) == nil && allHooksPresent(file.Hooks, localDev) {\\n                // CLI agent hooks are current; also check IDE hooks\\n                if allIDEHooksPresent(worktreeRoot, localDev) {\\n                    return 0, nil\\n                }\\n            }\\n        }\\n    }\\n\\n    var cmdPrefix string\\n    if localDev {\\n        cmdPrefix = localDevCmdPrefix + \\\"hooks kiro \\\"\\n    } else {\\n        cmdPrefix = \\\"entire hooks kiro \\\"\\n    }\\n\\n    // --- Phase 1: Install CLI agent file ---\\n    file := kiroAgentFile{ /* ... same as before ... */ }\\n\\n    if err := os.MkdirAll(filepath.Dir(hooksPath), 0o750); err != nil {\\n        return 0, fmt.Errorf(\\\"failed to create .kiro/agents directory: %w\\\", err)\\n    }\\n    output, err := jsonutil.MarshalIndentWithNewline(file, \\\"\\\", \\\"  \\\")\\n    if err != nil {\\n        return 0, fmt.Errorf(\\\"failed to marshal hooks config: %w\\\", err)\\n    }\\n    if err := os.WriteFile(hooksPath, output, 0o600); err != nil {\\n        return 0, fmt.Errorf(\\\"failed to write hooks config: %w\\\", err)\\n    }\\n\\n    count := len(k.HookNames()) // 5 CLI hooks\\n\\n    // --- Phase 2: Install IDE hook files ---\\n    ideCount, err := installIDEHooks(worktreeRoot, cmdPrefix)\\n    if err != nil {\\n        return count, err\\n    }\\n    count += ideCount\\n\\n    return count, nil\\n}\\n```\\n\\nWait — there's a subtlety with the idempotency logic. The existing pattern for the CLI agent file writes unconditionally (no partial-write), and returns 0 only when nothing has changed. We should maintain consistency: if CLI hooks are already current AND IDE hooks are all present, return 0. If any are missing (or force is true), reinstall everything and return the total count.\\n\\nActually, re-reading the existing code more carefully: the existing `InstallHooks` only checks idempotency for the CLI agent file. It returns `len(k.HookNames())` (currently 5) when it actually writes. The requirement says \\\"Hook count: should reflect total hooks installed (CLI + IDE = 5 + 4 = 9 on fresh install)\\\" and \\\"Idempotency: skip re-install if IDE hooks already present and current\\\".\\n\\nThe cleanest approach: check both in the idempotency gate, and when writing return `len(k.HookNames()) + len(ideHookDefs)` = 9, rather than tracking individual counts.\\n\\nActually, looking at it more carefully, the cursor agent tracks individual `count++` and only counts newly-added hooks. But for Kiro, the agent file is always fully rewritten (no partial ownership). The simplest consistent approach: if idempotency check passes (all current), return 0. Otherwise, write everything and return 9 (5 CLI + 4 IDE).\\n\\nBut wait — the test `TestInstallHooks_CountMatchesHookNames` does `expectedCount := len(ag.HookNames())` and expects it to match. This test will break if we change the return count to 9 when `HookNames()` still returns 5. \\n\\nThe correct fix: we need to update `HookNames()` OR change the count semantics. The requirement says total count = 9, and tests need updating. Looking at the test, it says the count should match `len(HookNames())`. That test will need updating to expect 9, and `HookNames()` should NOT be changed (it lists CLI hook verbs, not IDE file hooks).\\n\\nThe simplest approach: `InstallHooks` returns `len(k.HookNames()) + len(ideHookDefs)` = 9 when writing. The existing test `TestInstallHooks_CountMatchesHookNames` needs to be updated in `hooks_test.go` to expect 9 directly (or removed, since the count is now CLI+IDE total).\\n\\n#### New helper: `installIDEHooks`\\n\\n```go\\n// installIDEHooks creates .kiro/hooks/*.kiro.hook files for the IDE extension.\\n// Returns the number of files created.\\nfunc installIDEHooks(worktreeRoot, cmdPrefix string) (int, error) {\\n    ideDir := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir)\\n    if err := os.MkdirAll(ideDir, 0o750); err != nil {\\n        return 0, fmt.Errorf(\\\"failed to create .kiro/hooks directory: %w\\\", err)\\n    }\\n\\n    count := 0\\n    for _, def := range ideHookDefs {\\n        hookFile := kiroIDEHookFile{\\n            Enabled:     true,\\n            Name:        def.name,\\n            Description: def.description,\\n            Version:     ideHookVersion,\\n            When:        kiroIDEHookWhen{Type: def.whenType},\\n            Then:        kiroIDEHookThen{Type: \\\"runCommand\\\", Command: cmdPrefix + def.hookVerb},\\n        }\\n        data, err := jsonutil.MarshalIndentWithNewline(hookFile, \\\"\\\", \\\"  \\\")\\n        if err != nil {\\n            return count, fmt.Errorf(\\\"failed to marshal IDE hook %s: %w\\\", def.filename, err)\\n        }\\n        path := filepath.Join(ideDir, def.filename)\\n        if err := os.WriteFile(path, data, 0o600); err != nil { //nolint:gosec // path constructed from repo root + constant\\n            return count, fmt.Errorf(\\\"failed to write IDE hook %s: %w\\\", def.filename, err)\\n        }\\n        count++\\n    }\\n    return count, nil\\n}\\n```\\n\\n#### New helper: `allIDEHooksPresent`\\n\\n```go\\n// allIDEHooksPresent checks whether all 4 IDE hook files are installed and current.\\nfunc allIDEHooksPresent(worktreeRoot string, localDev bool) bool {\\n    var cmdPrefix string\\n    if localDev {\\n        cmdPrefix = localDevCmdPrefix + \\\"hooks kiro \\\"\\n    } else {\\n        cmdPrefix = \\\"entire hooks kiro \\\"\\n    }\\n\\n    ideDir := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir)\\n    for _, def := range ideHookDefs {\\n        path := filepath.Join(ideDir, def.filename)\\n        data, err := os.ReadFile(path) //nolint:gosec // path constructed from repo root + constant\\n        if err != nil {\\n            return false\\n        }\\n        var hook kiroIDEHookFile\\n        if err := json.Unmarshal(data, &hook); err != nil {\\n            return false\\n        }\\n        expectedCmd := cmdPrefix + def.hookVerb\\n        if !hook.Enabled || hook.Then.Command != expectedCmd || hook.Then.Type != \\\"runCommand\\\" {\\n            return false\\n        }\\n    }\\n    return true\\n}\\n```\\n\\n#### Modified `UninstallHooks`\\n\\nRemove IDE hook files in addition to the CLI agent file:\\n\\n```go\\nfunc (k *KiroAgent) UninstallHooks(ctx context.Context) error {\\n    worktreeRoot, err := paths.WorktreeRoot(ctx)\\n    if err != nil {\\n        worktreeRoot = \\\".\\\"\\n    }\\n\\n    // Remove CLI agent file\\n    hooksPath := filepath.Join(worktreeRoot, \\\".kiro\\\", hooksDir, HooksFileName)\\n    if err := os.Remove(hooksPath); err != nil && !os.IsNotExist(err) {\\n        return fmt.Errorf(\\\"failed to remove hooks config: %w\\\", err)\\n    }\\n\\n    // Remove IDE hook files\\n    ideDir := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir)\\n    for _, def := range ideHookDefs {\\n        path := filepath.Join(ideDir, def.filename)\\n        if err := os.Remove(path); err != nil && !os.IsNotExist(err) {\\n            return fmt.Errorf(\\\"failed to remove IDE hook %s: %w\\\", def.filename, err)\\n        }\\n    }\\n    return nil\\n}\\n```\\n\\n#### Modified `AreHooksInstalled`\\n\\nReturn true if EITHER CLI or IDE hooks are present (per requirement):\\n\\n```go\\nfunc (k *KiroAgent) AreHooksInstalled(ctx context.Context) bool {\\n    worktreeRoot, err := paths.WorktreeRoot(ctx)\\n    if err != nil {\\n        worktreeRoot = \\\".\\\"\\n    }\\n\\n    // Check CLI agent file\\n    hooksPath := filepath.Join(worktreeRoot, \\\".kiro\\\", hooksDir, HooksFileName)\\n    data, err := os.ReadFile(hooksPath) //nolint:gosec // path constructed from repo root\\n    if err == nil {\\n        var file kiroAgentFile\\n        if json.Unmarshal(data, &file) == nil {\\n            if hasEntireHook(file.Hooks.AgentSpawn) ||\\n                hasEntireHook(file.Hooks.UserPromptSubmit) ||\\n                hasEntireHook(file.Hooks.Stop) {\\n                return true\\n            }\\n        }\\n    }\\n\\n    // Check IDE hook files — return true if any are present\\n    ideDir := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir)\\n    for _, def := range ideHookDefs {\\n        path := filepath.Join(ideDir, def.filename)\\n        if _, statErr := os.Stat(path); statErr == nil {\\n            // File exists; verify it's an Entire hook\\n            if fileData, readErr := os.ReadFile(path); readErr == nil { //nolint:gosec // path constructed from repo root + constant\\n                var hook kiroIDEHookFile\\n                if json.Unmarshal(fileData, &hook) == nil && isEntireIDEHook(hook) {\\n                    return true\\n                }\\n            }\\n        }\\n    }\\n    return false\\n}\\n\\n// isEntireIDEHook returns true if the IDE hook file belongs to Entire.\\nfunc isEntireIDEHook(hook kiroIDEHookFile) bool {\\n    for _, prefix := range entireHookPrefixes {\\n        if strings.HasPrefix(hook.Then.Command, prefix) {\\n            return true\\n        }\\n    }\\n    return false\\n}\\n```\\n\\n---\\n\\n### File 3: `cmd/entire/cli/agent/kiro/lifecycle.go`\\n\\nThe IDE hooks pass data via environment variables, not stdin. Currently `ReadAndParseHookInput` returns an error on empty stdin, which breaks IDE hooks.\\n\\nThe design: each parse function attempts stdin first; on empty stdin error, falls back to constructing `hookInputRaw` from env vars.\\n\\n#### Modified `parseAgentSpawn`\\n\\n```go\\nfunc (k *KiroAgent) parseAgentSpawn(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n    _, err := agent.ReadAndParseHookInput[hookInputRaw](stdin)\\n    if err != nil {\\n        // IDE hooks don't send stdin — fall through gracefully.\\n        // agentSpawn has no IDE equivalent, so this path handles unknown callers.\\n        if !isEmptyStdinError(err) {\\n            return nil, err\\n        }\\n        // Empty stdin is acceptable: continue with session ID generation.\\n    }\\n\\n    sessionID := k.generateAndCacheSessionID(ctx)\\n    return &agent.Event{\\n        Type:      agent.SessionStart,\\n        SessionID: sessionID,\\n        Timestamp: time.Now(),\\n    }, nil\\n}\\n```\\n\\n#### Helper `isEmptyStdinError`\\n\\n```go\\n// isEmptyStdinError returns true when ReadAndParseHookInput fails because stdin was empty.\\n// IDE hooks pass data via environment variables rather than stdin.\\nfunc isEmptyStdinError(err error) bool {\\n    return err != nil && err.Error() == \\\"empty hook input\\\"\\n}\\n```\\n\\nWait — using `err.Error()` for comparison is fragile and violates Go style. Better: define a sentinel error. But `ReadAndParseHookInput` uses `errors.New(\\\"empty hook input\\\")` directly, not an exported sentinel. We should use `strings.Contains` or, cleaner, update `agent/event.go` to export a sentinel. However, the instruction says we should not modify `agent/event.go` and the requirement is to handle it gracefully.\\n\\nLooking at this more carefully — the cleanest approach without modifying the agent package is to use `errors.Is` idiom. But since `errors.New(\\\"empty hook input\\\")` in `event.go` is not exported, we can't use `errors.Is`. The next best option: define a local constant string, or simply check `err != nil && strings.Contains(err.Error(), \\\"empty hook input\\\")`. Since the string \\\"empty hook input\\\" is stable and defined in the same codebase, this is acceptable and clear. Add a comment explaining why.\\n\\nActually, the cleanest approach that avoids string comparison: add a wrapper that returns a zero-value `hookInputRaw` when stdin is empty, rather than an error. But that changes the shared helper behavior.\\n\\nThe best approach: write a local wrapper for the lifecycle file:\\n\\n```go\\n// readHookInputOrEmpty attempts to parse JSON from stdin.\\n// If stdin is empty (IDE hooks don't send stdin), it returns a zero-value hookInputRaw and ok=true.\\n// If stdin contains malformed JSON, it returns an error.\\nfunc readHookInputOrEmpty(stdin io.Reader) (*hookInputRaw, error) {\\n    raw, err := agent.ReadAndParseHookInput[hookInputRaw](stdin)\\n    if err != nil {\\n        if strings.Contains(err.Error(), \\\"empty hook input\\\") { //nolint:goerr113 // comparing against stable internal error string\\n            return &hookInputRaw{}, nil\\n        }\\n        return nil, err\\n    }\\n    return raw, nil\\n}\\n```\\n\\nThen the individual parse functions use this wrapper and fill in missing fields from env vars.\\n\\n#### Modified `parseUserPromptSubmit`\\n\\n```go\\nfunc (k *KiroAgent) parseUserPromptSubmit(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n    raw, err := readHookInputOrEmpty(stdin)\\n    if err != nil {\\n        return nil, err\\n    }\\n\\n    // IDE hook: CWD and prompt come from environment variables, not stdin.\\n    if raw.CWD == \\\"\\\" {\\n        raw.CWD, _ = os.Getwd() //nolint:forbidigo // Intentional: IDE hooks don't provide CWD in stdin; fallback to process CWD\\n    }\\n    if raw.Prompt == \\\"\\\" {\\n        raw.Prompt = os.Getenv(\\\"USER_PROMPT\\\")\\n    }\\n\\n    sessionID := k.readCachedSessionID(ctx)\\n    if sessionID == \\\"\\\" {\\n        sessionID = k.generateAndCacheSessionID(ctx)\\n    }\\n\\n    return &agent.Event{\\n        Type:      agent.TurnStart,\\n        SessionID: sessionID,\\n        Prompt:    raw.Prompt,\\n        Timestamp: time.Now(),\\n    }, nil\\n}\\n```\\n\\nNote on `os.Getwd()`: the `.golangci.yaml` forbids `os.Getwd` in non-test files via forbidigo. However the linter rule says \\\"breaks when running from subdirectories - use paths.RepoRoot()\\\". For IDE hooks, the CWD is the fallback and it IS the correct value (the IDE sets the process CWD to the project root). The nolint comment is required. Looking at the forbidigo rule: it only triggers on `^os\\\\.Getwd$` in the `^os$` package. We need the nolint.\\n\\nActually — re-reading the requirement: \\\"IDE hooks pass data via environment variables (`USER_PROMPT` for promptSubmit) - NO JSON on stdin\\\". The CWD may not be needed for session lookup in the IDE path (Kiro IDE doesn't use SQLite CWD lookup the same way). Let's check what `raw.CWD` is used for in `parseUserPromptSubmit` — it's not used at all! Only `raw.Prompt` is used. So we only need to populate `Prompt` from env var. No CWD fallback needed for `parseUserPromptSubmit`.\\n\\nFor `parseStop`: `raw.CWD` IS used for the SQLite lookup (`k.querySessionID(ctx, raw.CWD)` and `k.ensureCachedTranscript`). In the IDE path, the session ID should already be cached from `parseUserPromptSubmit` (which acts as session start for IDE), so the SQLite fallback might not be needed. But for safety, we should populate CWD.\\n\\n#### Modified `parseStop`\\n\\n```go\\nfunc (k *KiroAgent) parseStop(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n    raw, err := readHookInputOrEmpty(stdin)\\n    if err != nil {\\n        return nil, err\\n    }\\n\\n    // IDE hook: CWD comes from the process working directory, not stdin.\\n    if raw.CWD == \\\"\\\" {\\n        raw.CWD, _ = os.Getwd() //nolint:forbidigo // Intentional: IDE hooks don't provide CWD; fallback to process CWD\\n    }\\n\\n    sessionID := k.readCachedSessionID(ctx)\\n    if sessionID == \\\"\\\" {\\n        sid, queryErr := k.querySessionID(ctx, raw.CWD)\\n        if queryErr != nil || sid == \\\"\\\" {\\n            sessionID = \\\"unknown\\\"\\n        } else {\\n            sessionID = sid\\n        }\\n    }\\n\\n    sessionRef, _ := k.ensureCachedTranscript(ctx, raw.CWD, sessionID) //nolint:errcheck // best-effort\\n\\n    return &agent.Event{\\n        Type:       agent.TurnEnd,\\n        SessionID:  sessionID,\\n        SessionRef: sessionRef,\\n        Timestamp:  time.Now(),\\n    }, nil\\n}\\n```\\n\\n#### Modified `parseAgentSpawn` (simplified)\\n\\nSince `agentSpawn` has no IDE equivalent and the raw input is not used beyond parsing (only the side effect of generating a session ID matters):\\n\\n```go\\nfunc (k *KiroAgent) parseAgentSpawn(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n    _, err := readHookInputOrEmpty(stdin)\\n    if err != nil {\\n        return nil, err\\n    }\\n\\n    sessionID := k.generateAndCacheSessionID(ctx)\\n    return &agent.Event{\\n        Type:      agent.SessionStart,\\n        SessionID: sessionID,\\n        Timestamp: time.Now(),\\n    }, nil\\n}\\n```\\n\\nThis is clean and handles empty stdin gracefully.\\n\\n---\\n\\n### File 4: `cmd/entire/cli/agent/kiro/hooks_test.go`\\n\\nAdd tests after the existing ones. Key areas:\\n\\n#### Updated count tests\\n\\nThe existing tests that check `count == 5` need updating to `count == 9`. Specifically:\\n- `TestInstallHooks_FreshInstall`: change `want 5` to `want 9`\\n- `TestInstallHooks_LocalDevMode`: change `want 5` to `want 9`\\n- `TestInstallHooks_Idempotent`: count1 changes to `want 9`\\n- `TestInstallHooks_ForceReinstall`: changes to `want 9`\\n- `TestInstallHooks_CountMatchesHookNames`: this test is now incorrect (count != len(HookNames())), so either update it to assert `count == len(ag.HookNames()) + 4` or replace it with a direct assertion of 9.\\n\\n#### New IDE hook tests\\n\\n```go\\n// --- IDE Hook Files ---\\n\\nfunc TestInstallHooks_CreatesIDEHookFiles(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    ag := &KiroAgent{}\\n    count, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"InstallHooks() error = %v\\\", err)\\n    }\\n    if count != 9 {\\n        t.Errorf(\\\"InstallHooks() returned count %d, want 9\\\", count)\\n    }\\n\\n    ideHookFiles := []string{\\n        \\\"entire-prompt-submit.kiro.hook\\\",\\n        \\\"entire-stop.kiro.hook\\\",\\n        \\\"entire-pre-tool-use.kiro.hook\\\",\\n        \\\"entire-post-tool-use.kiro.hook\\\",\\n    }\\n    for _, filename := range ideHookFiles {\\n        path := filepath.Join(tempDir, \\\".kiro\\\", \\\"hooks\\\", filename)\\n        if _, err := os.Stat(path); err != nil {\\n            t.Errorf(\\\"IDE hook file not found: %s\\\", path)\\n        }\\n    }\\n}\\n\\nfunc TestInstallHooks_IDEHooksValidJSON(t *testing.T) {\\n    tempDir := t.TempDir()\\n    t.Chdir(tempDir)\\n\\n    ag := &KiroAgent{}\\n    _, err := ag.InstallHooks(context.Background(), false, false)\\n    if err != nil {\\n        t.Fatalf(\\\"InstallHooks() error = %v\\\", err)\\n    }\\n\\n    path := filepath.Join(tempDir, \\\".kiro\\\", \\\"hooks\\\", \\\"entire-prompt-submit.kiro.hook\\\")\\n    hook := readKiroIDEHookFile(t, path)\\n\\n    if !hook.Enabled {\\n        t.Error(\\\"IDE hook should be enabled\\\")\\n    }\\n    if hook.Version != \\\"1\\\" {\\n        t.Errorf(\\\"IDE hook version = %q, want %q\\\", hook.Version, \\\"1\\\")\\n    }\\n    if hook.When.Type != \\\"promptSubmit\\\" {\\n        t.Errorf(\\\"IDE hook when.type = %q, want %q\\\", hook.When.Type, \\\"promptSubmit\\\")\\n    }\\n    if hook.Then.Type != \\\"runCommand\\\" {\\n        t.Errorf(\\\"IDE hook then.type = %q, want %q\\\", hook.Then.Type, \\\"runCommand\\\")\\n    }\\n    if hook.Then.Command != \\\"