s)\\n                    ├── uninstallDeselectedAgentHooks()\\n                    ├── for each agent: setupAgentHooks() → hookAgent.InstallHooks()\\n                    ├── setupEntireDirectory()\\n                    ├── strategy.InstallGitHook()\\n                    └── strategy.EnsureSetup()\\n```\\n\\nThe `setupAgentHooks` function does the type assertion:\\n```go\\nfunc setupAgentHooks(ctx context.Context, ag agent.Agent, localDev, forceHooks bool) (int, error) {\\n    hookAgent, ok := ag.(agent.HookSupport)\\n    if !ok {\\n        return 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n    }\\n    count, err := hookAgent.InstallHooks(ctx, localDev, forceHooks)\\n    ...\\n}\\n```\\n\\n---\\n\\n### 8. Hook Dispatch Flow (`hooks_cmd.go`, `hook_registry.go`)\\n\\n**Registration** (`hooks_cmd.go`):\\n```go\\nfunc newHooksCmd() *cobra.Command {\\n    // imports _ \\\"github.com/entireio/cli/cmd/entire/cli/agent/kiro\\\" (triggers init())\\n    for _, agentName := range agent.List() {\\n        ag, _ := agent.Get(agentName)\\n        if handler, ok := ag.(agent.HookSupport); ok {\\n            cmd.AddCommand(newAgentHooksCmd(agentName, handler))\\n        }\\n    }\\n}\\n```\\n\\n**Self-registration** via `init()` in `kiro/kiro.go`:\\n```go\\nfunc init() {\\n    agent.Register(agent.AgentNameKiro, NewKiroAgent)\\n}\\n```\\n\\n**Command tree built** (`hook_registry.go`):\\n```\\nentire hooks kiro\\n  ├── agent-spawn       → RunE calls KiroAgent.ParseHookEvent(ctx, \\\"agent-spawn\\\", stdin)\\n  ├── user-prompt-submit → RunE calls KiroAgent.ParseHookEvent(ctx, \\\"user-prompt-submit\\\", stdin)\\n  ├── pre-tool-use      → RunE calls KiroAgent.ParseHookEvent(ctx, \\\"pre-tool-use\\\", stdin)\\n  ├── post-tool-use     → RunE calls KiroAgent.ParseHookEvent(ctx, \\\"post-tool-use\\\", stdin)\\n  └── stop              → RunE calls KiroAgent.ParseHookEvent(ctx, \\\"stop\\\", stdin)\\n```\\n\\n**Dispatch path** for each hook invocation:\\n```\\nKiro invokes: entire hooks kiro stop\\n  └── newAgentHookVerbCmdWithLogging(\\\"kiro\\\", \\\"stop\\\").RunE\\n        ├── paths.WorktreeRoot() check\\n        ├── IsEnabled() check\\n        ├── currentHookAgentName = \\\"kiro\\\"\\n        ├── handler.ParseHookEvent(ctx, \\\"stop\\\", cmd.InOrStdin())\\n        │     └── KiroAgent.parseStop() → reads session ID cache → queries SQLite → returns TurnEnd event\\n        └── if event != nil: DispatchLifecycleEvent(ctx, ag, event)\\n              └── strategy.SaveStep() or other lifecycle actions\\n```\\n\\n---\\n\\n### 9. Strategy-Level Git Hooks (`strategy/hooks.go`)\\n\\nThese are separate from agent hooks. The `strategy/hooks.go` installs shell scripts into `.git/hooks/`:\\n\\n- `prepare-commit-msg` → `entire hooks git prepare-commit-msg \\\"$1\\\" \\\"$2\\\"`\\n- `commit-msg` → `entire hooks git commit-msg \\\"$1\\\"`\\n- `post-commit` → `entire hooks git post-commit`\\n- `pre-push` → `entire hooks git pre-push \\\"$1\\\"`\\n\\nThese fire on git operations and are agent-agnostic. They handle checkpoint condensation, trailer injection (`Entire-Checkpoint: <id>`), and log pushing.\\n\\nKey function: `InstallGitHook(ctx, silent, localDev, absolutePath bool) (int, error)` — backs up pre-existing hooks to `.pre-entire`, chains them.\\n\\n---\\n\\n### 10. Registry Wiring (`registry.go`)\\n\\nConstants added for Kiro:\\n```go\\nAgentNameKiro types.AgentName = \\\"kiro\\\"\\nAgentTypeKiro types.AgentType = \\\"Kiro\\\"\\n```\\n\\n`GetAgentsWithHooksInstalled(ctx)` (in `config.go`) iterates all registered agents, type-asserts each to `HookSupport`, and calls `AreHooksInstalled()`.\\n\\n---\\n\\n### Summary of the Kiro-Specific Design Decisions\\n\\n1. **File ownership**: Kiro owns `.kiro/agents/entire.json` entirely — written from scratch each time, not merged. Simpler than Claude Code and Cursor which do careful round-trip JSON preservation.\\n\\n2. **Session ID generation**: Kiro does not provide a session ID in hook stdin. The