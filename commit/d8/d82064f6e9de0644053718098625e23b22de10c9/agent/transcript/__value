econd)\\n    29→\\t\\tcpID1 := testutil.AssertHasCheckpointTrailer(t, s.Dir, \\\"HEAD\\\")\\n    30→\\t\\tcpBranchAfterFirst := testutil.GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n    31→\\n    32→\\t\\t// Second prompt — agent creates another file, user commits.\\n    33→\\t\\t_, err = s.RunPrompt(t, ctx,\\n    34→\\t\\t\\t\\\"create a markdown file at docs/blue.md with a paragraph about the colour blue. Do not commit it, only create the file. Do not ask for confirmation, just make the change.\\\")\\n    35→\\t\\tif err != nil {\\n    36→\\t\\t\\tt.Fatalf(\\\"agent prompt 2 failed: %v\\\", err)\\n    37→\\t\\t}\\n    38→\\n    39→\\t\\ts.Git(t, \\\"add\\\", \\\"docs/\\\")\\n    40→\\t\\ts.Git(t, \\\"commit\\\", \\\"-m\\\", \\\"Add blue.md\\\")\\n    41→\\n    42→\\t\\t// Wait for checkpoint branch to advance past the first checkpoint.\\n    43→\\t\\tdeadline := time.Now().Add(15 * time.Second)\\n    44→\\t\\tfor time.Now().Before(deadline) {\\n    45→\\t\\t\\tafter := testutil.GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n    46→\\t\\t\\tif after != cpBranchAfterFirst {\\n    47→\\t\\t\\t\\tbreak\\n    48→\\t\\t\\t}\\n    49→\\t\\t\\ttime.Sleep(200 * time.Millisecond)\\n    50→\\t\\t}\\n    51→\\n    52→\\t\\tcpID2 := testutil.AssertHasCheckpointTrailer(t, s.Dir, \\\"HEAD\\\")\\n    53→\\t\\tassert.NotEqual(t, cpID1, cpID2, \\\"checkpoint IDs should be distinct\\\")\\n    54→\\t\\ttestutil.AssertCheckpointExists(t, s.Dir, cpID1)\\n    55→\\t\\ttestutil.AssertCheckpointExists(t, s.Dir, cpID2)\\n    56→\\t})\\n    57→}\\n    58→\\n    59→// TestAgentAmendsCommit: agent creates and commits, then amends the commit\\n    60→// with additional changes. The amended commit should still have a valid\\n    61→// checkpoint trailer.\\n    62→func TestAgentAmendsCommit(t *testing.T) {\\n    63→\\ttestutil.ForEachAgent(t, 3*time.Minute, func(t *testing.T, s *testutil.RepoState, ctx context.Context) {\\n    64→\\t\\t_, err :