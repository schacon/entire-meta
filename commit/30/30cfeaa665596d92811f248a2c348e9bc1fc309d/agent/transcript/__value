\n    25→func SetRunDir(dir string) {\\n    26→\\trunDirOverride = dir\\n    27→}\\n    28→\\n    29→// ArtifactRunDir returns the directory for the current test run.\\n    30→func ArtifactRunDir() string {\\n    31→\\tif runDirOverride != \\\"\\\" {\\n    32→\\t\\treturn runDirOverride\\n    33→\\t}\\n    34→\\treturn filepath.Join(ArtifactRoot, ArtifactTimestamp)\\n    35→}\\n    36→\\n    37→func artifactDir(t *testing.T) string {\\n    38→\\tt.Helper()\\n    39→\\tname := strings.ReplaceAll(t.Name(), \\\"/\\\", \\\"-\\\")\\n    40→\\tdir := filepath.Join(ArtifactRunDir(), name)\\n    41→\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n    42→\\t\\tt.Logf(\\\"warning: failed to create artifact dir: %v\\\", err)\\n    43→\\t}\\n    44→\\treturn dir\\n    45→}\\n    46→\\n    47→// CaptureArtifacts captures git state, checkpoint metadata, entire logs,\\n    48→// and console output to the artifact directory.\\n    49→func CaptureArtifacts(t *testing.T, s *RepoState) {\\n    50→\\tt.Helper()\\n    51→\\tdir := s.ArtifactDir\\n    52→\\n    53→\\twriteArtifact(t, dir, \\\"git-log.txt\\\",\\n    54→\\t\\tgitOutputSafe(s.Dir, \\\"log\\\", \\\"--decorate\\\", \\\"--graph\\\", \\\"--all\\\"))\\n    55→\\n    56→\\twriteArtifact(t, dir, \\\"git-tree.txt\\\",\\n    57→\\t\\tgitOutputSafe(s.Dir, \\\"ls-tree\\\", \\\"-r\\\", \\\"HEAD\\\")+\\n    58→\\t\\t\\t\\\"\\\\n--- entire/checkpoints/v1 ---\\\\n\\\"+\\n    59→\\t\\t\\tgitOutputSafe(s.Dir, \\\"ls-tree\\\", \\\"-r\\\", \\\"entire/checkpoints/v1\\\"))\\n    60→\\n    61→\\t// console.log is written incrementally to disk via s.ConsoleLog (*os.File),\\n    62→\\t// so it already exists in the artifact dir and survives global timeouts.\\n    63→\\n    64→\\t// Capture final pane content from interactive sessions, then close.\\n    65→\\t// Must happen here (not in a separate t.Cleanup) because cleanup\\n    66→\\t// functions run LIFO — closing first would kill the tmux session\\n    67→\\t// before we can capture.\\n    68→\\tif s.session != nil {\\n    69→\\t\\tpane := s.session.Capture()\\n    70→\\t\\twriteArtifact(t, dir, \\\"pane.txt\\\", pane)\\n    71→\\t\\t_ = s.session.Close()\\n    72→\\t}\\n    73→\\n    74→\\tif t.Failed() {\\n    75→\\t\\twriteArtifact(t, dir, \\\"FAIL\\\", \\\"\\\")\\n    76→\\t} else {\\n    77→\\t\\twriteArtifact(t, dir, \\\"PASS\\\", \\\"\\\")\\n    78→\\t}\\n    79→\\n    80→\\tcaptureCheckpointMetadata(t, s, dir)\\n    81→\\tcaptureEntireLogs(t, s.Dir, dir)\\n    82→\\n    83→\\tif os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\" {\\n    84→\\t\\tlink := filepath.Join(dir, \\\"repo\\\")\\n    85→\\t\\tif err := os.Symlink(s.Dir, link); err != nil {\\n    86→\\t\\t\\tt.Logf(\\\"warning: failed to symlink repo: %v\\\", err)\\n    87→\\t\\t}\\n    88→\\t}\\n    89→}\\n    90→\\n    91→func captureCheckpointMetadata(t *testing.T, s *RepoState, outDir string) {\\n    92→\\tt.Helper()\\n    93→\\tcommits := NewCheckpointCommits(t, s)\\n    94→\\tmetaDir := filepath.Join(outDir, \\\"checkpoint-metadata\\\")\\n    95→\\n    96→\\tcpIDRe := regexp.MustCompile(`(?m)^Checkpoint:\\\\s+(\\\\S+)`)\\n    97→\\tfor _, sha := range commits {\\n    98→\\t\\tmsg := gitOutputSafe(s.Dir, \\\"log\\\", \\\"-1\\\", \\\"--format=%B\\\", sha)\\n    99→\\t\\tm := cpIDRe.FindStringSubmatch(msg)\\n   100→\\t\\tif m == nil || len(m[1]) < 3 {\\n   101→\\t\\t\\tcontinue\\n   102→\\t\\t}\\n   103→\\t\\tid := m[1]\\n   104→\\t\\tcpPath := CheckpointPath(id)\\n   105→\\n   106→\\t\\tcpDir := filepath.Join(metaDir, cpPath)\\n   107→\\t\\t_ = os.MkdirAll(cpDir, 0o755)\\n   108→\\t\\traw := gitOutputSafe(s.Dir, \\\"show\\\", sha+\\\":\\\"+cpPath+\\\"/metadata.json\\\")\\n   109→\\t\\twriteArtifact(t, cpDir, \\\"metadata.json\\\", raw)\\n   110→\\n   111→\\t\\tfor i := 0; ; i++ {\\n   112→\\t\\t\\tsessPath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", cpPath, i)\\n   113→\\t\\t\\traw := gitOutputSafe(s.Dir, \\\"show\\\", sha+\\\":\\\"+sessPath)\\n   114→\\t\\t\\tif raw == \\\"\\\" {\\n   115→\\t\\t\\t\\tbreak\\n   116→\\t\\t\\t}\\n   117→\\t\\t\\tsessDir := filepath.Join(cpDir, strconv.Itoa(i))\\n   118→\\t\\t\\t_ = os.MkdirAll(sessDir, 0o755)\\n   119→\\t\\t\\twriteArtifact(t, sessDir, \\\"metadata.json\\\", raw)\\n   120→\\t\\t}\\n   121→\\t}\\n   122→}\\n   123→\\n   124→func captureEntireLogs(t *testing.T, repoDir, outDir string) {\\n   125→\\tt.Helper()\\n   126→\\tlogDir := filepath.Join(repoDir, \\\".entire\\\", \\\"logs\\\")\\n   127→\\tentries, err := os.ReadDir(logDir)\\n   128→\\tif err != nil {\\n   129→\\t\\treturn\\n   130→\\t}\\n   131→\\tdst := filepath.Join(outDir, \\\"entire-logs\\\")\\n   132→\\t_ = os.MkdirAll(dst, 0o755)\\n   133→\\tfor _, e := range entries {\\n   134→\\t\\tdata, err := os.ReadFile(filepath.Join(logDir, e.Name()))\\n   135→\\t\\tif err != nil {\\n   136→\\t\\t\\tcontinue\\n   137→\\t\\t}\\n   138→\\t\\twriteArtifact(t, dst, e.Name(), string(data))\\n   139→\\t}\\n   140→}\\n   141→\\n   142→func writeArtifact(t *testing.T, dir, name, content string) {\\n   143→\\tt.Helper()\\n   144→\\tpath := filepath.Join(dir, name)\\n   145→\\tif err := os.WriteFile(path, []byte(content), 0o644); err != nil {\\n   146→\\t\\tt.Logf(\\\"warning: failed to write artifact %s: %v\\\", path, err)\\n   147→\\t}\\n   148→}\\n   149→\\n   150→func gitOutputSafe(dir string, args ...string) string {\\n   151→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   152→\\tcmd.Dir = dir\\n   153→\\tout, err := cmd.Output()\\n   154→\\tif err != nil {\\n   155→\\t\\treturn \\\"\\\"\\n   156→\\t}\\n   157→\\treturn string(out)\\n   158→}\\n   159→\"}]},\"uuid\":\"37bc4a77-f947-434d-9788-5e8122a86573\",\"timestamp\":\"2026-02-26T01:06:44.962Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Search the e2e/ directory and mise tasks configuration to understand how the E2E tests build and use the `entire` CLI binary. I need to know:\\n1. Is it built from the current branch's source code for each test run?\\n2. Where is the build s