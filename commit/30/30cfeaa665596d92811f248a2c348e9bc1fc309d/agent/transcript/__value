tchers[i].Hooks = append(matchers[i].Hooks, entry)\\n   434→\\t\\t\\t\\treturn matchers\\n   435→\\t\\t\\t}\\n   436→\\t\\t}\\n   437→\\t\\treturn append(matchers, ClaudeHookMatcher{\\n   438→\\t\\t\\tMatcher: \\\"\\\",\\n   439→\\t\\t\\tHooks:   []ClaudeHookEntry{entry},\\n   440→\\t\\t})\\n   441→\\t}\\n   442→\\n   443→\\t// Find or create matcher with the given name\\n   444→\\tfor i, matcher := range matchers {\\n   445→\\t\\tif matcher.Matcher == matcherName {\\n   446→\\t\\t\\tmatchers[i].Hooks = append(matchers[i].Hooks, entry)\\n   447→\\t\\t\\treturn matchers\\n   448→\\t\\t}\\n   449→\\t}\\n   450→\\n   451→\\treturn append(matchers, ClaudeHookMatcher{\\n   452→\\t\\tMatcher: matcherName,\\n   453→\\t\\tHooks:   []ClaudeHookEntry{entry},\\n   454→\\t})\\n   455→}\\n   456→\\n   457→// isEntireHook checks if a command is an Entire hook (old or new format)\\n   458→func isEntireHook(command string) bool {\\n   459→\\tfor _, prefix := range entireHookPrefixes {\\n   460→\\t\\tif strings.HasPrefix(command, prefix) {\\n   461→\\t\\t\\treturn true\\n   462→\\t\\t}\\n   463→\\t}\\n   464→\\treturn false\\n   465→}\\n   466→\\n   467→// removeEntireHooks removes all Entire hooks from a list of matchers (for simple hooks like Stop)\\n   468→func removeEntireHooks(matchers []ClaudeHookMatcher) []ClaudeHookMatcher {\\n   469→\\tresult := make([]ClaudeHookMatcher, 0, len(matchers))\\n   470→\\tfor _, matcher := range matchers {\\n   471→\\t\\tfilteredHooks := make([]ClaudeHookEntry, 0, len(matcher.Hooks))\\n   472→\\t\\tfor _, hook := range matcher.Hooks {\\n   473→\\t\\t\\tif !isEntireHook(hook.Command) {\\n   474→\\t\\t\\t\\tfilteredHooks = append(filteredHooks, hook)\\n   475→\\t\\t\\t}\\n   476→\\t\\t}\\n   477→\\t\\t// Only keep the matcher if it has hooks remaining\\n   478→\\t\\tif len(filteredHooks) > 0 {\\n   479→\\t\\t\\tmatcher.Hooks = filteredHooks\\n   480→\\t\\t\\tresult = append(result, matcher)\\n   481→\\t\\t}\\n   482→\\t}\\n   483→\\treturn result\