\\n    62→\\thooksDirMu.RLock()\\n    63→\\tif hooksDirCache != \\\"\\\" && hooksDirCacheDir == cwd {\\n    64→\\t\\tcached := hooksDirCache\\n    65→\\t\\thooksDirMu.RUnlock()\\n    66→\\t\\treturn cached, nil\\n    67→\\t}\\n    68→\\thooksDirMu.RUnlock()\\n    69→\\n    70→\\tresult, err := getHooksDirInPath(\\\".\\\")\\n    71→\\tif err != nil {\\n    72→\\t\\treturn \\\"\\\", err\\n    73→\\t}\\n    74→\\n    75→\\thooksDirMu.Lock()\\n    76→\\thooksDirCache = result\\n    77→\\thooksDirCacheDir = cwd\\n    78→\\thooksDirMu.Unlock()\\n    79→\\n    80→\\treturn result, nil\\n    81→}\\n    82→\\n    83→// ClearHooksDirCache clears the cached hooks directory.\\n    84→// This is primarily useful for testing when changing directories.\\n    85→func ClearHooksDirCache() {\\n    86→\\thooksDirMu.Lock()\\n    87→\\thooksDirCache = \\\"\\\"\\n    88→\\thooksDirCacheDir = \\\"\\\"\\n    89→\\thooksDirMu.Unlock()\\n    90→}\\n    91→\\n    92→// getGitDirInPath returns the git directory for a repository at the given path.\\n    93→// It delegates to `git rev-parse --git-dir` to leverage git's own validation.\\n    94→func getGitDirInPath(dir string) (string, error) {\\n    95→\\tctx := context.Background()\\n    96→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-dir\\\")\\n    97→\\tcmd.Dir = dir\\n    98→\\toutput, err := cmd.Output()\\n    99→\\tif err != nil {\\n   100→\\t\\treturn \\\"\\\", errors.New(\\\"not a git repository\\\")\\n   101→\\t}\\n   102→\\n   103→\\tgitDir := strings.TrimSpace(string(output))\\n   104→\\n   105→\\t// git rev-parse --git-dir returns relative paths from the working directory,\\n   106→\\t// so we need to make it absolute if it isn't already\\n   107→\\tif !filepath.IsAbs(gitDir) {\\n   108→\\t\\tgitDir = filepath.Join(dir, gitDir)\\n   109→\\t}\\n   110→\\n   111→\\treturn filepath.Clean(gitDir), nil\\n   112→}\\n   113→\\n   114→// getHooksDirInPath returns the active hooks directory for a repository at 