cli/cmd/entire/cli/transcript\\\"\\n    17→)\\n    18→\\n    19→// Compile-time interface assertions for new interfaces.\\n    20→var (\\n    21→\\t_ agent.TranscriptAnalyzer     = (*ClaudeCodeAgent)(nil)\\n    22→\\t_ agent.TranscriptPreparer     = (*ClaudeCodeAgent)(nil)\\n    23→\\t_ agent.TokenCalculator        = (*ClaudeCodeAgent)(nil)\\n    24→\\t_ agent.SubagentAwareExtractor = (*ClaudeCodeAgent)(nil)\\n    25→)\\n    26→\\n    27→// HookNames returns the hook verbs Claude Code supports.\\n    28→// These become subcommands: entire hooks claude-code <verb>\\n    29→func (c *ClaudeCodeAgent) HookNames() []string {\\n    30→\\treturn []string{\\n    31→\\t\\tHookNameSessionStart,\\n    32→\\t\\tHookNameSessionEnd,\\n    33→\\t\\tHookNameStop,\\n    34→\\t\\tHookNameUserPromptSubmit,\\n    35→\\t\\tHookNamePreTask,\\n    36→\\t\\tHookNamePostTask,\\n    37→\\t\\tHookNamePostTodo,\\n    38→\\t}\\n    39→}\\n    40→\\n    41→// ParseHookEvent translates a Claude Code hook into a normalized lifecycle Event.\\n    42→// Returns nil if the hook has no lifecycle significance.\\n    43→func (c *ClaudeCodeAgent) ParseHookEvent(hookName string, stdin io.Reader) (*agent.Event, error) {\\n    44→\\tswitch hookName {\\n    45→\\tcase HookNameSessionStart:\\n    46→\\t\\treturn c.parseSessionStart(stdin)\\n    47→\\tcase HookNameUserPromptSubmit:\\n    48→\\t\\treturn c.parseTurnStart(stdin)\\n    49→\\tcase HookNameStop:\\n    50→\\t\\treturn c.parseTurnEnd(stdin)\\n    51→\\tcase HookNameSessionEnd:\\n    52→\\t\\treturn c.parseSessionEnd(stdin)\\n    53→\\tcase HookNamePreTask:\\n    54→\\t\\treturn c.parseSubagentStart(stdin)\\n    55→\\tcase HookNamePostTask:\\n    56→\\t\\treturn c.parseSubagentEnd(stdin)\\n    57→\\tcase HookNamePostTodo:\\n    58→\\t\\t// PostTodo is Claude-specific; handled outside the generic dispatcher.\\n    59→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    60→\\tdefault:\\n    61→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    62→\\t}\\n    63→}\\n    64→\\n    65→// ReadTranscript reads the raw JSONL transcript bytes for a session.\\n    66→func (c *ClaudeCodeAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    67→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n    68→\\tif err != nil {\\n    69→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    70→\\t}\\n    71→\\treturn data, nil\\n    72→}\\n    73→\\n    74→// ExtractPrompts extracts user prompts from the transcript starting at the given line offset.\\n    75→func (c *ClaudeCodeAgent) ExtractPrompts(sessionRef string, fromOffset int) ([]string, error) {\\n    76→\\tlines, _, err := transcript.ParseFromFileAtLine(sessionRef, fromOffset)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    79→\\t}\\n    80→\\n    81→\\tvar prompts []string\\n    82→\\tfor i := range lines {\\n    83→\\t\\tif lines[i].Type != transcript.TypeUser {\\n    84→\\t\\t\\tcontinue\\n    85→\\t\\t}\\n    86→\\t\\tcontent := transcript.ExtractUserContent(lines[i].Message)\\n    87→\\t\\tif content != \\\"\\\" {\\n    88→\\t\\t\\tprompts = append(prompts, textutil.StripIDEContextTags(content))\\n    89→\\t\\t}\\n    90→\\t}\\n    91→\\treturn prompts, nil\\n    92→}\\n    93→\\n    94→// ExtractSummary extracts the last assistant message as a session summary.\\n    95→func (c *ClaudeCodeAgent) ExtractSummary(sessionRef string) (string, error) {\\n    96→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n    97→\\tif err != nil {\\n    98→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    99→\\t}\\n   100→\\n   101→\\tlines, parseErr := transcript.ParseFromBytes(data)\\n   102→\\tif parseErr != nil {\\n   103→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse transcript: %w\\\", parseErr)\\n   104→\\t}\\n   105→\\n   106→\\t// Walk backward to find last assistant text block\\n   107→\\tfor i := len(lines) - 1; i >= 0; i-- {\\n   108→\\t\\tif lines[i].Type != transcript.TypeAssistant {\\n   109→\\t\\t\\tcontinue\\n   110→\\t\\t}\\n   111→\\t\\tvar msg transcript.AssistantMessage\\n   112→\\t\\tif err := json.Unmarshal(lines[i].Message, &msg); err != nil {\\n   113→\\t\\t\\tcontinue\\n   114→\\t\\t}\\n   115→\\t\\tfor _, block := range msg.Content {\\n   116→\\t\\t\\tif block.Type == transcript.ContentTypeText && block.Text != \\\"\\\" {\\n   117→\\t\\t\\t\\treturn block.Text, nil\\n   118→\\t\\t\\t}\\n   119→\\t\\t}\\n   120→\\t}\\n   121→\\treturn \\\"\\\", nil\\n   122→}\\n   123→\\n   124→// PrepareTranscript waits for Claude Code's async transcript flush to complete.\\n   125→// Claude writes a hook_progress sentinel entry after flushing all pending writes.\\n   126→func (c *ClaudeCodeAgent) PrepareTranscript(sessionRef string) error {\\n   127→\\twaitForTranscriptFlush(sessionRef, time.Now())\\n   128→\\treturn nil\\n   129→}\\n   130→\\n   131→// CalculateTokenUsage computes token usage from the transcript starting at the given line offset.\\n   132→func (c *ClaudeCodeAgent) CalculateTokenUsage(sessionRef string, fromOffset int) (*agent.TokenUsage, error) {\\n   133→\\t// Subagent transcripts live in <transcriptDir>/<sessionID>/subagents/\\n   134→\\t// but we don't have the sessionID here. The caller should pass the transcript path\\n   135→\\t// which may contain the session ID in its directory structure.\\n   136→\\t// For now, compute subagentsDir from the transcript path structure.\\n   137→\\treturn CalculateTotalTokenUsage(sessionRef, fromOffset, \\\"\\\")\\n   138→}\\n   139→\\n   140→// --- Internal hook parsing functions ---\\n   141→\\n   142→func (c *ClaudeCodeAgent) parseSessionStart(stdin io.Reader) (*agent.Event, error) {\\n   143→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   144→\\tif err != nil {\\n   145