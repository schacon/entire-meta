jsonl transcript.\\n    89→type Event struct {\\n    90→\\tType      string          `json:\\\"type\\\"`\\n    91→\\tData      json.RawMessage `json:\\\"data\\\"`\\n    92→\\tID        string          `json:\\\"id\\\"`\\n    93→\\tTimestamp string          `json:\\\"timestamp\\\"`\\n    94→\\tParentID  *string         `json:\\\"parentId\\\"`\\n    95→}\\n    96→\\n    97→// Event type constants for events.jsonl\\n    98→//\\n    99→// Known types not listed here (unused but documented):\\n   100→//\\n   101→//\\tsession.end, session.mode_changed, session.model_change,\\n   102→//\\tassistant.turn_start, assistant.turn_end, tool.execution_complete\\n   103→const (\\n   104→\\tEventUserMessage      = \\\"user.message\\\"\\n   105→\\tEventAssistantMessage = \\\"assistant.message\\\"\\n   106→\\tEventToolExecStart    = \\\"tool.execution_start\\\"\\n   107→)\\n   108→\\n   109→// userMessageData is the data field for user.message events.\\n   110→type userMessageData struct {\\n   111→\\tContent            string `json:\\\"content\\\"`\\n   112→\\tTransformedContent string `json:\\\"transformedContent\\\"`\\n   113→}\\n   114→\\n   115→// assistantMessageData is the data field for assistant.message events.\\n   116→type assistantMessageData struct {\\n   117→\\tMessageID    string        `json:\\\"messageId\\\"`\\n   118→\\tContent      string        `json:\\\"content\\\"`\\n   119→\\tToolRequests []toolRequest `json:\\\"toolRequests\\\"`\\n   120→}\\n   121→\\n   122→// toolRequest represents a tool call request within an assistant.message event.\\n   123→type toolRequest struct {\\n   124→\\tToolCallID string         `json:\\\"toolCallId\\\"`\\n   125→\\tName       string         `json:\\\"name\\\"`\\n   126→\\tArguments  map[string]any `json:\\\"arguments\\\"`\\n   127→\\tType       string         `json:\\\"type\\\"`\\n   128→}\\n   129→\\n   130→// toolExecStartData is the data field for tool.execution_start events.\\n   131→type toolExecStartData struct {\\n   132→