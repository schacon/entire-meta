&ignoreUntracked, \\\"ignore-untracked\\\", false, \\\"Commit all new files without tracking pre-existing untracked files\\\")\\n   133→\\tcmd.Flags().MarkHidden(\\\"ignore-untracked\\\") //nolint:errcheck,gosec // flag is defined above\\n   134→\\tcmd.Flags().BoolVar(&useLocalSettings, \\\"local\\\", false, \\\"Write settings to .entire/settings.local.json instead of .entire/settings.json\\\")\\n   135→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Write settings to .entire/settings.json even if it already exists\\\")\\n   136→\\tcmd.Flags().StringVar(&agentName, \\\"agent\\\", \\\"\\\", \\\"Agent to setup hooks for (e.g., claude-code). Enables non-interactive mode.\\\")\\n   137→\\tcmd.Flags().StringVar(&strategyFlag, \\\"strategy\\\", \\\"\\\", \\\"Strategy to use (manual-commit or auto-commit)\\\")\\n   138→\\tcmd.Flags().BoolVarP(&forceHooks, \\\"force\\\", \\\"f\\\", false, \\\"Force reinstall hooks (removes existing Entire hooks first)\\\")\\n   139→\\tcmd.Flags().BoolVar(&skipPushSessions, \\\"skip-push-sessions\\\", false, \\\"Disable automatic pushing of session logs on git push\\\")\\n   140→\\tcmd.Flags().BoolVar(&telemetry, \\\"telemetry\\\", true, \\\"Enable anonymous usage analytics\\\")\\n   141→\\t//nolint:errcheck,gosec // completion is optional, flag is defined above\\n   142→\\tcmd.RegisterFlagCompletionFunc(\\\"strategy\\\", func(_ *cobra.Command, _ []string, _ string) ([]string, cobra.ShellCompDirective) {\\n   143→\\t\\treturn []string{strategyDisplayManualCommit, strategyDisplayAutoCommit}, cobra.ShellCompDirectiveNoFileComp\\n   144→\\t})\\n   145→\\n   146→\\t// Provide a helpful error when --agent is used without a value\\n   147→\\tdefaultFlagErr := cmd.FlagErrorFunc()\\n   148→\\tcmd.SetFlagErrorFunc(func(c *cobra.Command, err error) error {\\n   149→\\t\\tvar valErr *pflag.ValueRequiredError\\n   150→\\t\\tif errors.As(err, &valErr) && valErr.GetSpecifiedName() == \\\"agent\\\" {\\n   151→\\t\\t\\tprintMissingAg