le\\n   914→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   915→\\t\\tfor _, line := range strings.Split(c.Message, \\\"\\\\n\\\") {\\n   916→\\t\\t\\tline = strings.TrimSpace(line)\\n   917→\\t\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   918→\\t\\t\\t\\tid := strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   919→\\t\\t\\t\\tcheckpointIDs = append(checkpointIDs, id)\\n   920→\\t\\t\\t}\\n   921→\\t\\t}\\n   922→\\t\\treturn nil\\n   923→\\t})\\n   924→\\n   925→\\treturn checkpointIDs\\n   926→}\\n   927→\\n   928→// ReadFileFromBranch reads a file's content from a specific branch's tree.\\n   929→// Returns the content and true if found, empty string and false if not found.\\n   930→func (env *TestEnv) ReadFileFromBranch(branchName, filePath string) (string, bool) {\\n   931→\\tenv.T.Helper()\\n   932→\\n   933→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   934→\\tif err != nil {\\n   935→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   936→\\t}\\n   937→\\n   938→\\t// Get the branch reference\\n   939→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   940→\\tif err != nil {\\n   941→\\t\\t// Try as a remote-style ref\\n   942→\\t\\tref, err = repo.Reference(plumbing.ReferenceName(\\\"refs/heads/\\\"+branchName), true)\\n   943→\\t\\tif err != nil {\\n   944→\\t\\t\\treturn \\\"\\\", false\\n   945→\\t\\t}\\n   946→\\t}\\n   947→\\n   948→\\t// Get the commit\\n   949→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   950→\\tif err != nil {\\n   951→\\t\\treturn \\\"\\\", false\\n   952→\\t}\\n   953→\\n   954→\\t// Get the tree\\n   955→\\ttree, err := commit.Tree()\\n   956→\\tif err != nil {\\n   957→\\t\\treturn \\\"\\\", false\\n   958→\\t}\\n   959→\\n   960→\\t// Get the file\\n   961→\\tfile, err := tree.File(filePath)\\n   962→\\tif err != nil {\\n   963→\\t\\treturn \\\"\\\", false\\n   964→\\t}\\n   965→\\n   966→\\t// Get the content\\n   