ToolUse:         \\\"postToolUse\\\",\\n    44→\\tHookNameErrorOccurred:       \\\"errorOccurred\\\",\\n    45→}\\n    46→\\n    47→// entireHookPrefixes are command prefixes that identify Entire hooks\\n    48→var entireHookPrefixes = []string{\\n    49→\\t\\\"entire \\\",\\n    50→\\t\\\"go run ${COPILOT_PROJECT_DIR}/cmd/entire/main.go \\\",\\n    51→}\\n    52→\\n    53→// GetHookNames implements agent.HookHandler by delegating to HookNames.\\n    54→func (c *CopilotAgent) GetHookNames() []string {\\n    55→\\treturn c.HookNames()\\n    56→}\\n    57→\\n    58→// InstallHooks installs Copilot hooks in .github/hooks/copilot-setup.json.\\n    59→// If force is true, removes existing Entire hooks before installing.\\n    60→// Returns the number of hooks installed.\\n    61→func (c *CopilotAgent) InstallHooks(localDev bool, force bool) (int, error) {\\n    62→\\trepoRoot, err := paths.RepoRoot()\\n    63→\\tif err != nil {\\n    64→\\t\\trepoRoot, err = os.Getwd() //nolint:forbidigo // Intentional fallback when RepoRoot() fails (tests run outside git repos)\\n    65→\\t\\tif err != nil {\\n    66→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to get current directory: %w\\\", err)\\n    67→\\t\\t}\\n    68→\\t}\\n    69→\\n    70→\\tconfigPath := filepath.Join(repoRoot, \\\".github\\\", \\\"hooks\\\", CopilotConfigFileName)\\n    71→\\n    72→\\t// Read existing config if it exists\\n    73→\\tvar config hookConfig\\n    74→\\texistingData, readErr := os.ReadFile(configPath) //nolint:gosec // path is constructed from repo root + fixed path\\n    75→\\tif readErr == nil {\\n    76→\\t\\tif err := json.Unmarshal(existingData, &config); err != nil {\\n    77→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse existing %s: %w\\\", CopilotConfigFileName, err)\\n    78→\\t\\t}\\n    79→\\t} else {\\n    80→\\t\\tconfig.Version = 1\\n    81→\\t}\\n    82→\\n    83→\\tif config.Hooks == nil {\\n    84→\\t\\tconfig.Hooks = make(map[string][]hookEntry)\\n    85→\\t}\\n    86→\\n    87→\\t// Define hook command based on localDev mode\\n    88→\\tvar cmdPrefix string\\n    89→\\tif localDev {\\n    90→\\t\\tcmdPrefix = \\\"go run ${COPILOT_PROJECT_DIR}/cmd/entire/main.go hooks github-copilot \\\"\\n    91→\\t} else {\\n    92→\\t\\tcmdPrefix = \\\"entire hooks github-copilot \\\"\\n    93→\\t}\\n    94→\\n    95→\\t// Check for idempotency BEFORE removing hooks\\n    96→\\tif !force {\\n    97→\\t\\tconfigKey := hookNameToConfigKey[HookNameSessionStart]\\n    98→\\t\\texpectedCmd := cmdPrefix + HookNameSessionStart\\n    99→\\t\\tif entries, ok := config.Hooks[configKey]; ok {\\n   100→\\t\\t\\tfor _, entry := range entries {\\n   101→\\t\\t\\t\\tif entry.Bash == expectedCmd {\\n   102→\\t\\t\\t\\t\\treturn 0, nil // Already installed with same mode\\n   103→\\t\\t\\t\\t}\\n   104→\\t\\t\\t}\\n   105→\\t\\t}\\n   106→\\t}\\n   107→\\n   108→\\t// Remove existing Entire hooks first\\n   109→\\tfor configKey, entries := range config.Hooks {\\n   110→\\t\\tconfig.Hooks[configKey] = removeEntireHookEntries(entries)\\n   111→\\t\\tif len(config.Hooks[configKey]) == 0 {\\n   112→\\t\\t\\tdelete(config.Hooks, configKey)\\n   113→\\t\\t}\\n   114→\\t}\\n   115→\\n   116→\\t// Install all 8 hooks\\n   117→\\thookNames := c.HookNames()\\n   118→\\tfor _, hookName := range hookNames {\\n   119→\\t\\tconfigKey, ok := hookNameToConfigKey[hookName]\\n   120→\\t\\tif !ok {\\n   121→\\t\\t\\tcontinue\\n   122→\\t\\t}\\n   123→\\n   124→\\t\\tentry := hookEntry{\\n   125→\\t\\t\\tType:       \\\"command\\\",\\n   126→\\t\\t\\tBash:       cmdPrefix + hookName,\\n   127→\\t\\t\\tTimeoutSec: 10,\\n   128→\\t\\t}\\n   129→\\n   130→\\t\\tconfig.Hooks[configKey] = append(config.Hooks[configKey], entry)\\n   131→\\t}\\n   132→\\n   133→\\tcount := len(hookNames)\\n   134→\\n   135→\\t// Write config file\\n   136→\\tif err := os.MkdirAll(filepath.Dir(configPath), 0o750); err != nil {\\n   137→\\t\\treturn 0, fmt.Errorf(\\\"failed to create .github/hooks directory: %w\\\", err)\\n   138→\\t}\\n   139→\\n   140→\\toutput, err := json.MarshalIndent(config, \\\"\\\", \\\"  \\\")\\n   141→\\tif err != nil {\\n   142→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal config: %w\\\", err)\\n   143→\\t}\\n   144→\\n   145→\\tif err := os.WriteFile(configPath, output, 0o600); err != nil {\\n   146→\\t\\treturn 0, fmt.Errorf(\\\"failed to write %s: %w\\\", CopilotConfigFileName, err)\\n   147→\\t}\\n   148→\\n   149→\\treturn count, nil\\n   150→}\\n   151→\\n   152→// UninstallHooks removes Entire hooks from Copilot config.\\n   153→func (c *CopilotAgent) UninstallHooks() error {\\n   154→\\trepoRoot, err := paths.RepoRoot()\\n   155→\\tif err != nil {\\n   156→\\t\\trepoRoot = \\\".\\\"\\n   157→\\t}\\n   158→\\n   159→\\tconfigPath := filepath.Join(repoRoot, \\\".github\\\", \\\"hooks\\\", CopilotConfigFileName)\\n   160→\\tdata, err := os.ReadFile(configPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   161→\\tif err != nil {\\n   162→\\t\\treturn nil //nolint:nilerr // No config file means nothing to uninstall\\n   163→\\t}\\n   164→\\n   165→\\tvar config hookConfig\\n   166→\\tif err := json.Unmarshal(data, &config); err != nil {\\n   167→\\t\\treturn fmt.Errorf(\\\"failed to parse %s: %w\\\", CopilotConfigFileName, err)\\n   168→\\t}\\n   169→\\n   170→\\tif config.Hooks == nil {\\n   171→\\t\\treturn nil\\n   172→\\t}\\n   173→\\n   174→\\t// Remove Entire hooks from all hook types\\n   175→\\tfor configKey, entries := range config.Hooks {\\n   176→\\t\\tconfig.Hooks[configKey] = removeEntireHookEntries(entries)\\n   177→\\t\\tif len(config.Hooks[configKey]) == 0 {\\n   178→\\t\\t\\tdelete(config.Hooks, configKey)\\n   179→\\t\\t}\\n   180→\\t}\\n   181→\\n   182→\\t// Write back\\n   183→\\toutput, err := json.MarshalIndent(config, \\\"\\\", \\\"  \\\")\\n   184→\\tif err != nil {\\n   185→\\t\\treturn fmt.Errorf(\\\"failed to marshal config: %w\\\", err)\\n   186→\\t}\\n   187→\\n   188→\\tif err := os.WriteFile(configPath, output, 0o600); err != nil {\\n   189→\\t\\treturn fmt.Errorf(\\\"failed to write %s: %w\\\", CopilotConfigFileName, err)\\n   190→\\t}\\n   191→\\n   192→\\treturn nil\\n   193→}\\n   194→\\n   195→// AreHooksInstalled checks if Entire hooks are installed in Copilot config.\\n   196→func (c *CopilotAgent) AreHooksInstalled() bool {\\n   197→\\trepoRoot, err := paths.RepoRoot()\\n   198→\\tif err != nil {\\n   199→\\t\\trepoRoot = \\\".\\\"\\n   200→\\t}\\n   201→\\n   202→\\tconfigPath := filepath.Join(repoRoot, \\\".github\\\", \\\"hooks\\\", CopilotConfigFileName)\\n   203→\\tdata, err := os.ReadFile(configPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   204→\\tif err != nil {\\n   205→\\t\\treturn false\\n   206→\\t}\\n   207→\\n   208→\\tvar config hookConfig\\n   209→\\tif err := json.Unmarshal(data, &config); err != nil {\\n   210→\\t\\treturn false\\n   211→\\t}\\n   212→\\n   213→\\tfor _, entries := range config.Hooks {\\n   214→\\t\\tfor _, entry := range entries {\\n   215→\\t\\t\\tif isEntireHook(entry.Bash) {\\n   216→\\t\\t\\t\\treturn true\\n   217→\\t\\t\\t}\\n   218→\\t\\t}\\n   219→\\t}\\n   220→\\n   221→\\treturn false\\n   222→}\\n   223→\\n   224→// GetSupportedHooks returns the hook types Copilot supports.\\n   225→func (c *CopilotAgent) GetSupportedHooks() []agent.HookType {\\n   226→\\treturn []agent.HookType{\\n   227→\\t\\tagent.HookSessionStart,\\n   228→\\t\\tagent.HookSessionEnd,\\n   229→\\t\\tagent.HookStop,\\n   230→\\t\\tagent.HookUserPromptSubmit,\\n   231→\\t\\tagent.HookPreToolUse,\\n   232→\\t\\tagent.HookPostToolUse,\\n   233→\\t}\\n   234→}\\n   235→\\n   236→// Helper functions\\n   237→\\n   238→// isEntireHook checks if a command is an Entire hook\\n   239→func isEntireHook(command string) bool {\\n   240→\\tfor _, prefix := range entireHookPrefixes {\\n   241→\\t\\tif strings.HasPrefix(command, prefix) {\\n   242→\\t\\t\\treturn true\\n   243→\\t\\t}\\n   244→\\t}\\n   245→\