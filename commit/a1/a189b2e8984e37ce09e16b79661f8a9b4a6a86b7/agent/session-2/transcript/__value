licts.\\n    87→\\t// Using \\\"git add .\\\" is safe in test repos since we control all content.\\n    88→\\tenv.GitAddAll()\\n    89→\\tenv.GitCommit(\\\"Add entire and agent config\\\")\\n    90→\\n    91→\\treturn env\\n    92→}\\n    93→\\n    94→// RunEntireEnable runs `entire enable` to set up the project with hooks.\\n    95→// Uses the configured defaultAgent (from E2E_AGENT env var or \\\"claude-code\\\").\\n    96→func (env *TestEnv) RunEntireEnable(strategyName string) {\\n    97→\\tenv.T.Helper()\\n    98→\\n    99→\\targs := []string{\\n   100→\\t\\t\\\"enable\\\",\\n   101→\\t\\t\\\"--agent\\\", defaultAgent,\\n   102→\\t\\t\\\"--strategy\\\", strategyName,\\n   103→\\t\\t\\\"--telemetry=false\\\",\\n   104→\\t\\t\\\"--force\\\", // Force reinstall hooks in case they exist\\n   105→\\t}\\n   106→\\n   107→\\t//nolint:gosec,noctx // test code, args are static\\n   108→\\tcmd := exec.Command(getTestBinary(), args...)\\n   109→\\tcmd.Dir = env.RepoDir\\n   110→\\n   111→\\toutput, err := cmd.CombinedOutput()\\n   112→\\tif err != nil {\\n   113→\\t\\tenv.T.Fatalf(\\\"entire enable failed: %v\\\\nOutput: %s\\\", err, output)\\n   114→\\t}\\n   115→\\tenv.T.Logf(\\\"entire enable output: %s\\\", output)\\n   116→}\\n   117→\\n   118→// InitRepo initializes a git repository in the test environment.\\n   119→func (env *TestEnv) InitRepo() {\\n   120→\\tenv.T.Helper()\\n   121→\\n   122→\\trepo, err := git.PlainInit(env.RepoDir, false)\\n   123→\\tif err != nil {\\n   124→\\t\\tenv.T.Fatalf(\\\"failed to init git repo: %v\\\", err)\\n   125→\\t}\\n   126→\\n   127→\\t// Configure git user for commits\\n   128→\\tcfg, err := repo.Config()\\n   129→\\tif err != nil {\\n   130→\\t\\tenv.T.Fatalf(\\\"failed to get repo config: %v\\\", err)\\n   131→\\t}\\n   132→\\tcfg.User.Name = \\\"E2E Test User\\\"\\n   133→\\tcfg.User.Email = \\\"e2e-test@example.com\\\"\\n   134→\\n   135→\\t// Disable GPG signing for test commits\\n   136→\\tif cfg.Raw == nil {\\n   137→\\