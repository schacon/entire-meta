ion.\\n    43→func (c *CopilotAgent) Description() string {\\n    44→\\treturn \\\"GitHub Copilot - GitHub's AI coding assistant\\\"\\n    45→}\\n    46→\\n    47→// IsPreview returns true as the Copilot integration is in preview.\\n    48→func (c *CopilotAgent) IsPreview() bool { return true }\\n    49→\\n    50→// DetectPresence checks if GitHub Copilot is configured in the repository.\\n    51→func (c *CopilotAgent) DetectPresence() (bool, error) {\\n    52→\\trepoRoot, err := paths.RepoRoot()\\n    53→\\tif err != nil {\\n    54→\\t\\trepoRoot = \\\".\\\"\\n    55→\\t}\\n    56→\\n    57→\\t// Check if our hooks are installed\\n    58→\\tif c.AreHooksInstalled() {\\n    59→\\t\\treturn true, nil\\n    60→\\t}\\n    61→\\n    62→\\t// Check for .github/hooks directory with copilot config\\n    63→\\tconfigPath := filepath.Join(repoRoot, \\\".github\\\", \\\"hooks\\\", CopilotConfigFileName)\\n    64→\\tif _, err := os.Stat(configPath); err == nil {\\n    65→\\t\\treturn true, nil\\n    66→\\t}\\n    67→\\n    68→\\treturn false, nil\\n    69→}\\n    70→\\n    71→// GetHookConfigPath returns the path to Copilot's hook config file.\\n    72→func (c *CopilotAgent) GetHookConfigPath() string {\\n    73→\\treturn filepath.Join(\\\".github\\\", \\\"hooks\\\", CopilotConfigFileName)\\n    74→}\\n    75→\\n    76→// SupportsHooks returns true as GitHub Copilot supports lifecycle hooks.\\n    77→func (c *CopilotAgent) SupportsHooks() bool {\\n    78→\\treturn true\\n    79→}\\n    80→\\n    81→// ParseHookInput parses Copilot hook input from stdin.\\n    82→func (c *CopilotAgent) ParseHookInput(hookType agent.HookType, reader io.Reader) (*agent.HookInput, error) {\\n    83→\\tdata, err := io.ReadAll(reader)\\n    84→\\tif err != nil {\\n    85→\\t\\treturn nil, fmt.Errorf(\\\"failed to read input: %w\\\", err)\\n    86→\\t}\\n    87→\\n    88→\\tif len(data) == 0 {\\n    89→\\t\\treturn nil, errors.New(\\\"empty input\\\")\\n    90→\\t}\\n    91→\\n    92→\\tinput := &agent.HookInput{\\n    93→\\t\\tHookType:  hookType,\\n    94→\\t\\tTimestamp: time.Now(),\\n    95→\\t\\tRawData:   make(map[string]any),\\n    96→\\t}\\n    97→\\n    98→\\tswitch hookType {\\n    99→\\tcase agent.HookSessionStart:\\n   100→\\t\\tvar raw sessionStartRaw\\n   101→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   102→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse hook input: %w\\\", err)\\n   103→\\t\\t}\\n   104→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   105→\\t\\tinput.RawData[\\\"source\\\"] = raw.Source\\n   106→\\n   107→\\tcase agent.HookSessionEnd:\\n   108→\\t\\tvar raw sessionEndRaw\\n   109→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   110→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse hook input: %w\\\", err)\\n   111→\\t\\t}\\n   112→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   113→\\t\\tinput.RawData[\\\"reason\\\"] = raw.Reason\\n   114→\\n   115→\\tcase agent.HookStop:\\n   116→\\t\\t// agentStop is the only hook with sessionId and transcriptPath\\n   117→\\t\\tvar raw agentStopRaw\\n   118→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   119→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse hook input: %w\\\", err)\\n   120→\\t\\t}\\n   121→\\t\\tinput.SessionID = raw.SessionID\\n   122→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   123→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   124→\\t\\tinput.RawData[\\\"stopReason\\\"] = raw.StopReason\\n   125→\\n   126→\\tcase agent.HookUserPromptSubmit:\\n   127→\\t\\tvar raw userPromptRaw\\n   128→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   129→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse hook input: %w\\\", err)\\n   130→\\t\\t}\\n   131→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   132→\\t\\tif raw.Prompt != \\\"\\\" {\\n   133→\\t\\t\\tinput.UserPrompt = raw.Prompt\\n   134→\\t\\t\\tinput.RawData[\\\"prompt\\\"] = raw.Prompt\\n   135→\\t\\t}\\n   136→\\n   137→\\tcase agent.HookPreToolUse, agent.HookPostToolUse:\\n   138→\\t\\tvar raw toolUseRaw\\n   139→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   140→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse tool hook input: %w\\\", err)\\n   141→\\t\\t}\\n   142→\\t\\tinput.ToolName = raw.ToolName\\n   143→\\t\\tinput.ToolInput = raw.ToolArgs\\n   144→\\t\\tif hookType == agent.HookPostToolUse {\\n   145→\\t\\t\\tinput.ToolResponse = raw.ToolResult\\n   146→\\t\\t}\\n   147→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   148→\\t}\\n   149→\\n   150→\\treturn input, nil\\n   151→}\\n   152→\\n   153→// GetSessionID extracts the session ID from hook input.\\n   154→func (c *CopilotAgent) GetSessionID(input *agent.HookInput) string {\\n   155→\\treturn input.SessionID\\n   156→}\\n   157→\\n   158→// ProtectedDirs returns directories that Copilot uses.\\n   159→// .github is a shared directory (not solely ours), so we don't protect it.\\n   160→func (c *CopilotAgent) ProtectedDirs() []string { return []string{} }\\n   161→\\n   162→// GetSessionDir returns the directory where Copilot stores session transcripts.\\n   163→func (c *CopilotAgent) GetSessionDir(_ string) (string, error) {\\n   164→\\tif override := os.Getenv(\\\"ENTIRE_TEST_COPILOT_SESSION_DIR\\\"); override != \\\"\\\" {\\n   165→\\t\\treturn override, nil\\n   166→\\t}\\n   167→\\n   168→\\thomeDir, err := os.UserHomeDir()\\n   169→\\tif err != nil {\\n   170→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   171→\\t}\\n   172→\\n   173→\\treturn filepath.Join(homeDir, \\\".copilot\\\", \\\"session-state\\\"), nil\\n   174→}\\n   175→\\n   176→// ResolveSessionFile returns the path to a Copilot session file.\\n   177→func (c *CopilotAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   178→\\treturn filepath.Join(sessionDir, agentSessionID, \\\"events.jsonl\\\")\\n   179→}\\n   180→\\n   181→// ReadSession reads a session from Copilot's storage.\\n   182→func (c *CopilotAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   183→\\tif input.SessionRef == \\\"\\\" {\\n   184→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   185→\\t}\\n   186→\\n   187→\\tdata, err := os.ReadFile(input.SessionRef)\\n   188→\\tif err != nil {\\n   189→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   190→\\t}\\n   191→\\n   192→\\treturn &agent.AgentSession{\\n   193→\\t\\tSessionID:  input.SessionID,\\n   194→\\t\\tAgentName:  c.Name(),\\n   195→\\t\\tSessionRef: input.SessionRef,\\n   196→\\t\\tStartTime:  time.Now(),\\n   197→\\t\\tNativeData: data,\\n   198→\\t}, nil\\n   199→}\\n   200→\\n   201→// WriteSession writes a session to Copilot's storage.\\n   202→func (c *CopilotAgent) WriteSession(session *agent.AgentSession) error {\\n   203→\\tif session == nil {\\n   204→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   205→\\t}\\n   206→\\n   207→\\tif session.AgentName != \\\"\\\" && session.AgentName != c.Name() {\\n   208→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, c.Name())\\n   209→\\t}\\n   210→\\n   211→\\tif session.SessionRef == \\\"\\\" {\\n   212→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   213→\\t}\\n   214→\\n   215→\\tif len(session.NativeData) == 0 {\\n   216→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   217→\\t}\\n   218→\\n   219→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   220→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   221→\\t}\\n   222→\\n   223→\\treturn nil\\n   224→}\\n   225→\\n   226→// FormatResumeCommand returns the command to resume a Copilot session.\\n   227→func (c *CopilotAgent) FormatResumeCommand(_ string) string {\\n   228→\\treturn \\\"copilot --resume\\\"\\n   229→}\\n   230→\"}]},\"uuid\":\"6e269085-a735-4996-96ab-06e28b70d562\",\"timestamp\