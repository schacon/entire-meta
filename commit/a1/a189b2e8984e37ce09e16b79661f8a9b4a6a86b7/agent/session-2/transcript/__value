pilot CLI stores session transcripts as JSONL files at:\\n    13→//   ~/.copilot/session-state/<sessionID>/events.jsonl\\n    14→//\\n    15→// Each line is a JSON object with the schema:\\n    16→//   {\\\"type\\\":\\\"<event-type>\\\", \\\"data\\\":{...}, \\\"id\\\":\\\"uuid\\\", \\\"timestamp\\\":\\\"iso8601\\\", \\\"parentId\\\":\\\"uuid|null\\\"}\\n    17→//\\n    18→// Known event types:\\n    19→//   session.start, session.end, session.mode_changed, session.model_change\\n    20→//   user.message, assistant.message, assistant.turn_start, assistant.turn_end\\n    21→//   tool.execution_start, tool.execution_complete\\n    22→\\n    23→// CountLines counts the number of non-empty lines in JSONL content.\\n    24→func CountLines(data []byte) int {\\n    25→\\tif len(data) == 0 {\\n    26→\\t\\treturn 0\\n    27→\\t}\\n    28→\\n    29→\\tcount := 0\\n    30→\\tlines := bytes.Split(data, []byte(\\\"\\\\n\\\"))\\n    31→\\tfor _, line := range lines {\\n    32→\\t\\tif len(bytes.TrimSpace(line)) > 0 {\\n    33→\\t\\t\\tcount++\\n    34→\\t\\t}\\n    35→\\t}\\n    36→\\treturn count\\n    37→}\\n    38→\\n    39→// ExtractModifiedFilesFromLines extracts file paths modified by tool calls\\n    40→// from events.jsonl lines starting at the given offset.\\n    41→// Looks for tool.execution_start events where the tool name is a file modification tool.\\n    42→func ExtractModifiedFilesFromLines(data []byte, startOffset int) []string {\\n    43→\\tlines := bytes.Split(data, []byte(\\\"\\\\n\\\"))\\n    44→\\tfileSet := make(map[string]bool)\\n    45→\\tvar files []string\\n    46→\\n    47→\\tlineIndex := 0\\n    48→\\tfor _, line := range lines {\\n    49→\\t\\ttrimmed := bytes.TrimSpace(line)\\n    50→\\t\\tif len(trimmed) == 0 {\\n    51→\\t\\t\\tcontinue\\n    52→\\t\\t}\\n    53→\\n    54→\\t\\tif lineIndex < startOffset {\\n    55→\\t\\t\\tlineIndex++\\n    56→\\t\\t\\tcontinue\\n    57→\\t\\t}\\n    58→\\t\\tlineIndex++\\n    59→\\n    60→\\t\\tvar event Event\\