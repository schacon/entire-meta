NameSessionStart,\\n    19→\\t\\tHookNameSessionEnd,\\n    20→\\t\\tHookNameUserPromptSubmitted,\\n    21→\\t\\tHookNameAgentStop,\\n    22→\\t\\tHookNameSubagentStop,\\n    23→\\t\\tHookNamePreToolUse,\\n    24→\\t\\tHookNamePostToolUse,\\n    25→\\t\\tHookNameErrorOccurred,\\n    26→\\t}\\n    27→}\\n    28→\\n    29→// ParseHookEvent translates a Copilot hook into a normalized lifecycle Event.\\n    30→// Returns nil if the hook has no lifecycle significance (e.g., pass-through hooks).\\n    31→//\\n    32→// Note: In Copilot CLI, only agentStop provides sessionId and transcriptPath.\\n    33→// Other hooks (sessionStart, userPromptSubmitted, sessionEnd) do not include\\n    34→// these fields, so the resulting Event will have empty SessionID/SessionRef.\\n    35→func (c *CopilotAgent) ParseHookEvent(hookName string, stdin io.Reader) (*agent.Event, error) {\\n    36→\\tswitch hookName {\\n    37→\\tcase HookNameSessionStart:\\n    38→\\t\\treturn c.parseSessionStart(stdin)\\n    39→\\tcase HookNameUserPromptSubmitted:\\n    40→\\t\\treturn c.parseTurnStart(stdin)\\n    41→\\tcase HookNameAgentStop:\\n    42→\\t\\treturn c.parseTurnEnd(stdin)\\n    43→\\tcase HookNameSessionEnd:\\n    44→\\t\\treturn c.parseSessionEnd(stdin)\\n    45→\\tcase HookNameSubagentStop:\\n    46→\\t\\treturn c.parseSubagentEnd(stdin)\\n    47→\\tcase HookNamePreToolUse, HookNamePostToolUse, HookNameErrorOccurred:\\n    48→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    49→\\tdefault:\\n    50→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    51→\\t}\\n    52→}\\n    53→\\n    54→// ReadTranscript reads the raw JSONL transcript bytes for a session.\\n    55→func (c *CopilotAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    56→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n    57→\\tif err != nil {\\n    58→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript