\\tcase AgentNameGemini:\\n    60→\\t\\treturn NewGeminiCLIRunner(config)\\n    61→\\tdefault:\\n    62→\\t\\t// Return a runner that reports as unavailable\\n    63→\\t\\treturn &unavailableRunner{name: name}\\n    64→\\t}\\n    65→}\\n    66→\\n    67→// unavailableRunner is returned for unknown agent names.\\n    68→type unavailableRunner struct {\\n    69→\\tname string\\n    70→}\\n    71→\\n    72→func (r *unavailableRunner) Name() string { return r.name }\\n    73→\\n    74→func (r *unavailableRunner) IsAvailable() (bool, error) {\\n    75→\\treturn false, fmt.Errorf(\\\"unknown agent: %s\\\", r.name)\\n    76→}\\n    77→\\n    78→func (r *unavailableRunner) RunPrompt(_ context.Context, _ string, _ string) (*AgentResult, error) {\\n    79→\\treturn nil, fmt.Errorf(\\\"agent %s is not available\\\", r.name)\\n    80→}\\n    81→\\n    82→func (r *unavailableRunner) RunPromptWithTools(_ context.Context, _ string, _ string, _ []string) (*AgentResult, error) {\\n    83→\\treturn nil, fmt.Errorf(\\\"agent %s is not available\\\", r.name)\\n    84→}\\n    85→\\n    86→// ClaudeCodeRunner implements AgentRunner for Claude Code CLI.\\n    87→type ClaudeCodeRunner struct {\\n    88→\\tModel        string\\n    89→\\tTimeout      time.Duration\\n    90→\\tAllowedTools []string\\n    91→}\\n    92→\\n    93→// NewClaudeCodeRunner creates a new Claude Code runner with the given config.\\n    94→func NewClaudeCodeRunner(config AgentRunnerConfig) *ClaudeCodeRunner {\\n    95→\\tmodel := config.Model\\n    96→\\tif model == \\\"\\\" {\\n    97→\\t\\tmodel = os.Getenv(\\\"E2E_CLAUDE_MODEL\\\")\\n    98→\\t\\tif model == \\\"\\\" {\\n    99→\\t\\t\\tmodel = \\\"haiku\\\"\\n   100→\\t\\t}\\n   101→\\t}\\n   102→\\n   103→\\ttimeout := config.Timeout\\n   104→\\tif timeout == 0 {\\n   105→\\t\\tif envTimeout := os.Getenv(\\\"E2E_TIMEOUT\\\"); envTimeout != \\\"\\\" {\\n   106→\\t\\t\\tif parsed, err := time.ParseDuration(envTimeout); err == nil {\\n   107→\\t\\t\\t\\ttimeout = parsed\\n   108→\\t\\t\\t}\\n   109→\\t\\t}\\n   110→\\t\\tif timeout == 0 {\\n   111→\\t\\t\\ttimeout = 2 * time.Minute\\n   112→\\t\\t}\\n   113→\\t}\\n   114→\\n   115→\\treturn &ClaudeCodeRunner{\\n   116→\\t\\tModel:        model,\\n   117→\\t\\tTimeout:      timeout,\\n   118→\\t\\tAllowedTools: []string{\\\"Edit\\\", \\\"Read\\\", \\\"Write\\\", \\\"Bash\\\", \\\"Glob\\\", \\\"Grep\\\"},\\n   119→\\t}\\n   120→}\\n   121→\\n   122→func (r *ClaudeCodeRunner) Name() string {\\n   123→\\treturn AgentNameClaudeCode\\n   124→}\\n   125→\\n   126→// IsAvailable checks if Claude CLI is installed and responds to --version.\\n   127→// Note: This does NOT verify authentication status. Claude Code uses OAuth\\n   128→// authentication (via `claude login`), not ANTHROPIC_API_KEY. If the CLI is\\n   129→// installed but not logged in, tests will fail at RunPrompt time.\\n   130→func (r *ClaudeCodeRunner) IsAvailable() (bool, error) {\\n   131→\\t// Check if claude CLI is in PATH\\n   132→\\tif _, err := exec.LookPath(\\\"claude\\\"); err != nil {\\n   133→\\t\\treturn false, fmt.Errorf(\\\"claude CLI not found in PATH: %w\\\", err)\\n   134→\\t}\\n   135→\\n   136→\\t// Check if claude is working (--version doesn't require auth)\\n   137→\\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\\n   138→\\tdefer cancel()\\n   139→\\n   140→\\tcmd := exec.CommandContext(ctx, \\\"claude\\\", \\\"--version\\\")\\n   141→\\tif err := cmd.Run(); err != nil {\\n   142→\\t\\treturn false, fmt.Errorf(\\\"claude CLI not working: %w\\\", err)\\n   143→\\t}\\n   144→\\n   145→\\treturn true, nil\\n   146→}\\n   147→\\n   148→func (r *ClaudeCodeRunner) RunPrompt(ctx context.Context, workDir string, prompt string) (*AgentResult, error) {\\n   149→\\treturn r.RunPromptWithTools(ctx, workDir, prompt, r.AllowedTools)\\n   150→}\\n   151→\\n   152→func (r *ClaudeCodeRunner) RunPromptWithTools(ctx context.Context, workDir string, prompt string, tools []string) (*AgentResult, error) {\\n   153→\\t// Build command: claude --model <model> -p \\\"<prompt>\\\" --allowedTools <tools>\\n   154→\\targs := []string{\\n   155→\\t\\t\\\"--model\\\", r.Model,\\n   156→\\t\\t\\\"-p\\\", prompt,\\n   157→\\t}\\n   158→\\n   159→\\tif len(tools) > 0 {\\n   160→\\t\\t// Claude CLI expects each tool as a separate argument after --allowedTools\\n   161→\\t\\t// e.g., --allowedTools Edit Read Bash (not --allowedTools \\\"Edit,Read,Bash\\\")\\n   162→\\t\\targs = append(args, \\\"--allowedTools\\\")\\n   163→\\t\\targs = append(args, tools...)\\n   164→\\t}\\n   165→\\n   166→\\t// Create context with timeout\\n   167→\\tctx, cancel := context.WithTimeout(ctx, r.Timeout)\\n   168→\\tdefer cancel()\\n   169→\\n   170→\\t//nolint:gosec // args are constructed from trusted config, not user input\\n   171→\\tcmd := exec.CommandContext(ctx, \\\"claude\\\", args...)\\n   172→\\tcmd.Dir = workDir\\n   173→\\n   174→\\tvar stdout, stderr bytes.Buffer\\n   175→\\tcmd.Stdout = &stdout\\n   176→\\tcmd.Stderr = &stderr\\n   177→\\n   178→\\tstart := time.Now()\\n   179→\\terr := cmd.Run()\\n   180→\\tduration := time.Since(start)\\n   181→\\n   182→\\tresult := &AgentResult{\\n   183→\\t\\tStdout:   stdout.String(),\\n   184→\\t\\tStderr:   stderr.String(),\\n   185→\\t\\tDuration: duration,\\n   186→\\t}\\n   187→\\n   188→\\tif err != nil {\\n   189→\\t\\texitErr := &exec.ExitError{}\\n   190→\\t\\tif errors.As(err, &exitErr) {\\n   191→\\t\\t\\tresult.ExitCode = exitErr.ExitCode()\\n   192→\\t\\t} else {\\n   193→\\t\\t\\tresult.ExitCode = -1\\n   194→\\t\\t}\\n   195→\\t\\t//nolint:wrapcheck // error is from exec.Run, caller can check ExitCode in result\\n   196→\\t\\treturn result, err\\n   197→\\t}\\n   198→\\n   199→\\tresult.ExitCode = 0\\n   200→\\treturn result, nil\\n   201→}\\n   202→\\n   203→// GeminiCLIRunner implements AgentRunner for Gemini CLI.\\n   204→// See: https://github.com/google-gemini/gemini-cli\\n   205→type GeminiCLIRunner struct {\\n 