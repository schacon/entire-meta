the user is prompted to confirm.\\n   519→// If no agent is detected and no TTY is available, falls back to the default agent.\\n   520→//\\n   521→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   522→// It receives available agent names and returns the selected names.\\n   523→func detectOrSelectAgent(w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   524→\\t// Try auto-detection first\\n   525→\\tdetected := agent.DetectAll()\\n   526→\\n   527→\\tswitch {\\n   528→\\tcase len(detected) == 1:\\n   529→\\t\\t// Single agent detected — use it directly\\n   530→\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   531→\\t\\treturn detected, nil\\n   532→\\n   533→\\tcase len(detected) > 1:\\n   534→\\t\\t// Multiple agents detected — prompt the user to confirm which to enable\\n   535→\\t\\tagentTypes := make([]string, 0, len(detected))\\n   536→\\t\\tfor _, ag := range detected {\\n   537→\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   538→\\t\\t}\\n   539→\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   540→\\t\\tfmt.Fprintln(w)\\n   541→\\t\\t// Fall through to the interactive multi-select below\\n   542→\\t}\\n   543→\\n   544→\\t// No agent detected (or multiple detected) — check if we can prompt interactively\\n   545→\\tif !canPromptInteractively() {\\n   546→\\t\\tif len(detected) > 0 {\\n   547→\\t\\t\\t// Multiple agents detected but no TTY — use all of them\\n   548→\\t\\t\\treturn detected, nil\\n   549→\\t\\t}\\n   550→\\t\\t// No TTY available (e.g., running in CI or tests) - fall back to default agent\\n   551→\\t\\tdefaultAgent := agent.Default()\\n   552→\\t\\tif defaultAgent == nil {\\n   553→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   554→\\t\\t}\\n   555→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\"