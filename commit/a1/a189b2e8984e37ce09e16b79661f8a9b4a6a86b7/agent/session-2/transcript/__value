 err := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   103→\\tif err != nil {\\n   104→\\t\\tif os.IsNotExist(err) {\\n   105→\\t\\t\\treturn 0, nil\\n   106→\\t\\t}\\n   107→\\t\\treturn 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   108→\\t}\\n   109→\\n   110→\\treturn countLines(data), nil\\n   111→}\\n   112→\\n   113→// ExtractModifiedFilesFromOffset extracts files modified since a given line offset.\\n   114→func (c *CopilotAgent) ExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error) {\\n   115→\\tif path == \\\"\\\" {\\n   116→\\t\\treturn nil, 0, nil\\n   117→\\t}\\n   118→\\n   119→\\tdata, readErr := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   120→\\tif readErr != nil {\\n   121→\\t\\tif os.IsNotExist(readErr) {\\n   122→\\t\\t\\treturn nil, 0, nil\\n   123→\\t\\t}\\n   124→\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", readErr)\\n   125→\\t}\\n   126→\\n   127→\\tif len(data) == 0 {\\n   128→\\t\\treturn nil, 0, nil\\n   129→\\t}\\n   130→\\n   131→\\ttotalLines := countLines(data)\\n   132→\\textractedFiles := extractModifiedFilesFromLines(data, startOffset)\\n   133→\\n   134→\\treturn extractedFiles, totalLines, nil\\n   135→}\\n   136→\\n   137→// --- Internal hook parsing functions ---\\n   138→\\n   139→// parseSessionStart handles the sessionStart hook.\\n   140→// Note: Copilot's sessionStart stdin does NOT include sessionId or transcriptPath.\\n   141→func (c *CopilotAgent) parseSessionStart(stdin io.Reader) (*agent.Event, error) {\\n   142→\\t_, err := agent.ReadAndParseHookInput[sessionStartRaw](stdin)\\n   143→\\tif err != nil {\\n   144→\\t\\treturn nil, err\\n   145→\\t}\\n   146→\\treturn &agent.Event{\\n   147→\\t\\tType:      agent.SessionStart,\\n   148→\\t\\tTimestamp: time.Now(),\\n   149→\\t}, nil\\n   150→}\\n   151→\\n   152→// parseTurnStart handles the userPromptSub