} else {\\n   140→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   141→\\t\\tvar err error\\n   142→\\t\\tref, err = repo.Reference(refName, true)\\n   143→\\t\\thasShadowBranch = err == nil\\n   144→\\t}\\n   145→\\n   146→\\tt0 := time.Now()\\n   147→\\tvar sessionData *ExtractedSessionData\\n   148→\\tif hasShadowBranch {\\n   149→\\t\\tvar extractErr error\\n   150→\\t\\tsessionData, extractErr = s.extractSessionData(ctx, repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n   151→\\t\\tif extractErr != nil {\\n   152→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", extractErr)\\n   153→\\t\\t}\\n   154→\\t} else {\\n   155→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   156→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   157→\\t\\t}\\n   158→\\t\\tif state.Phase.IsActive() {\\n   159→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, state.TranscriptPath)\\n   160→\\t\\t}\\n   161→\\t\\tvar extractErr error\\n   162→\\t\\tsessionData, extractErr = s.extractSessionDataFromLiveTranscript(ctx, state)\\n   163→\\t\\tif extractErr != nil {\\n   164→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", extractErr)\\n   165→\\t\\t}\\n   166→\\t}\\n   167→\\tlogging.Info(logCtx, \\\"CondenseSession: timing\\\",\\n   168→\\t\\tslog.String(\\\"phase\\\", \\\"extractSessionData\\\"),\\n   169→\\t\\tslog.Duration(\\\"elapsed\\\", time.Since(t0)),\\n   170→\\t\\tslog.Bool(\\\"has_shadow_branch\\\", hasShadowBranch),\\n   171→\\t\\tslog.Int(\\\"transcript_bytes\\\", len(sessionData.Transcript)),\\n   172→\\t)\\n   173→\\n   174→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   175→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   176→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   177→\\tif len(committedFiles) > 0 {\\n   178→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   179→\\n   180→\\t\\tif hadFilesBeforeFiltering {\\n   181→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   182→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   183→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   184→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   185→\\t\\t\\t\\t}\\n   186→\\t\\t\\t}\\n   187→\\t\\t\\tsessionData.FilesTouched = filtered\\n   188→\\t\\t}\\n   189→\\n   190→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   191→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   192→\\t\\t\\tfor f := range committedFiles {\\n   193→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   194→\\t\\t\\t}\\n   195→\\t\\t}\\n   196→\\t}\\n   197→\\n   198→\\t// Get checkpoint store\\n   199→\\tstore, err := s.getCheckpointStore()\\n   200→\\tif err != nil {\\n   201→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   202→\\t}\\n   203→\\n   204→\\t// Get author info\\n   205→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   206→\\n   207→\\t// Determine attribution base commit\\n   208→\\tattrBase := state.AttributionBaseCommit\\n   209→\\tif attrBase == \\\"\\\" {\\n   210→\\t\\tattrBase = state.BaseCommit\\n   211→\\t}\\n   212→\\n   213→\\tattribution := calculateSessionAttributions(ctx, repo, ref, sessionData, state, attributionOpts{\\n   214→\\t\\theadTree:              o.headTree,\\n   215→\\t\\tattributionBaseCommit: attrBase,\\n   216→\\t\\theadCommitHash:        o.headCommitHash,\\n   217→\\t})\\n   218→\\n   219→\\t// Get current branch name\\n   220→\\tbranchName := GetCurrentBranchName(repo)\\n   221→\\n   222→\\t// Generate summary if enabled\\n   223→\\tvar summary *cpkg.Summary\\n   224→\\tif settings.IsSummarizeEnabled(ctx) && len(sessionData.Transcript) > 0 {\\n   225→\\t\\tt2 := time.Now()\\n   226→\\t\\tsummarizeCtx := logging.WithComponent(ctx, \\\"summarize\\\")\\n   227→\\n   228→\\t\\tvar scopedTranscript []byte\\n   229→\\t\\tswitch state.AgentType {\\n   230→\\t\\tcase agent.AgentTypeGemini:\\n   231→\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   232→\\t\\t\\tif sliceErr != nil {\\n   233→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n   234→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   235→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   236→\\t\\t\\t}\\n   237→\\t\\t\\tscopedTranscript = scoped\\n   238→\\t\\tcase agent.AgentTypeOpenCode:\\n   239→\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   240→\\t\\t\\tif sliceErr != nil {\\n   241→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n   242→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   243→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   244→\\t\\t\\t}\\n   245→\\t\\t\\tscopedTranscript = scoped\\n   246→\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeFactoryAIDroid, agent.AgentTypeUnknown:\\n   247→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   248→\\t\\t}\\n   249→\\t\\tif len(scopedTranscript) > 0 {\\n   250→\\t\\t\\tvar err error\\n   251→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   252→\\t\\t\\tif err != nil {\\n   253→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   254→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   255→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   256→\\t\\t\\t} else {\\n   257→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   258→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   259→\\t\\t\\t}\\n   260→\\t\\t}\\n   261→\\t\\tlogging.Info(logCtx, \\\"CondenseSession: timing\\\",\\n   262→\\t\\t\\tslog.String(\\\"phase\\\", \\\"summarize\\\"),\\n   263→\\t\\t\\tslog.Duration(\\\"elapsed\\\", time.Since(t2)),\\n   264→\\t\\t)\\n   265→\\t}\\n   266→\\n   267→\\t// Write checkpoint metadata using the checkpoint store\\n   268→\\tt3 := time.Now()\\n   269→\\tif err := store.WriteCommitted(ctx, cpkg.WriteCommittedOptions{\\n   270→\\t\\tCheckpointID:                checkpointID,\\n   271→\\t\\tSessionID:                   state.SessionID,\\n   272→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   273→\\t\\tBranch:                      branchName,\\n   274→\\t\\tTranscript:                  sessionData.Transcript,\\n   275→\\t\\tPrompts:                     sessionData.Prompts,\\n   276→\\t\\tContext:                     sessionData.Context,\\n   277→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   278→\\t\\tCheckpointsCount:            state.StepCount,\\n   279→\\t\\tEphemeralBranch:             shadowBranchName,\\n   280→\\t\\tAuthorName:                  authorName,\\n   281→\\t\\tAuthorEmail:                 authorEmail,\\n   282→\\t\\tAgent:                       state.AgentType,\\n   283→\\t\\tTurnID:                      state.TurnID,\\n   284→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   285→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   286→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   287→\\t\\tInitialAttribution:          attribution,\\n   288→\\t\\tSummary:                     summary,\\n   289→\\t}); err != nil {\\n   290→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   291→\\t}\\n   292→\\tlogging.Info(logCtx, \\\"CondenseSession: timing\\\",\\n   293→\\t\\tslog.String(\\\"phase\\\", \\\"WriteCommitted\\\"),\\n   294→\\t\\tslog.Duration(\\\"elapsed\\\", time.Since(t3)),\\n   295→\\t)\\n   296→\\n   297→\\tlogging.Info(logCtx, \\\"CondenseSession: timing\\\",\\n   298→\\t\\tslog.String(\\\"phase\\\", \\\"total\\\"),\\n   299→\\t\\tslog.Duration(\\\"elapsed\\\", time.Since(condenseStart)),\\n   300→\\t)\\n   301→\\n   302→\\treturn &CondenseResult{\\n   303→\\t\\tCheckpointID:         checkpointID,\\n   304→\\t\\tSessionID:            state.SessionID,\\n   305→\\t\\tCheckpointsCount:     state.StepCount,\\n   306→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   307→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   308→\\t}, nil\\n   309→}\\n   310→\\n   311→// attributionOpts provides pre-resolved git objects to avoid redundant reads.\\n   312→type attributionOpts struct {\\n   313→\\theadTree              *object.Tree // HEAD commit tree (already resolved by PostCommit)\\n   314→\\tshadowTree            *object.Tree // Shadow branch tree (already resolved by PostCommit)\\n   315→\\tattributionBaseCommit string       // Base commit hash for non-agent file detection (empty = fall back to go-git tree walk)\\n   316→\\theadCommitHash        string       // HEAD commit hash for non-agent file detection (empty = fall back to go-git tree walk)\\n   317→}\\n   318→\\n   319→func calculateSessionAttributions(ctx context.Context, repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState, opts ...attributionOpts) *cpkg.InitialAttribution {\\n   320→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   321→\\t// This uses user edits captured at each prompt start (before agent works),\\n   322→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   323→\\t//\\n   324→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   325→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   326→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   327→\\tlogCtx := logging.WithComponent(ctx, \\\"attribution\\\")\\n   328→\\n   329→\\tvar o attributionOpts\\n   330→\\tif len(opts) > 0 {\\n   331→\\t\\to = opts[0]\\n   332→\\t}\\n   333→\\n   334→\\theadTree := o.headTree\\n   335→\\tif headTree == nil {\\n   336→\\t\\theadRef, headErr := repo.Head()\\n   337→\\t\\tif headErr != nil {\\n   338→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   339→\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   340→\\t\\t\\treturn nil\\n   341→\\t\\t}\\n   342→\\n   343→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   344→\\t\\tif commitErr != nil {\\n   345→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   346→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   347→\\t\\t\\treturn nil\\n   348→\\t\\t}\\n   349→\\n   350→\\t\\tvar treeErr error\\n   351→\\t\\theadTree, treeErr = headCommit.Tree()\\n   352→\\t\\tif treeErr != nil {\\n   353→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   354→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   355→\\t\\t\\treturn nil\\n   356→\\t\\t}\\n   357→\\t}\\n   358→\\n   359→\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n   360→\\tshadowTree := o.shadowTree\\n   361→\\tif shadowTree == nil {\\n   362→\\t\\tif shadowRef != nil {\\n   363→\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   364→\\t\\t\\tif shadowErr != nil {\\n   365→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   366→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   367→\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().