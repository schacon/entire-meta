st-commit: carried forward remaining files\\\",\\n\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\tslog.Int(\\\"remaining_files\\\", len(remainingFiles)),\\n\\t)\\n}\\n\",\"structuredPatch\":[{\"oldStart\":327,\"oldLines\":15,\"newStart\":327,\"newLines\":10,\"lines\":[\"     return s.handleAmendCommitMsg(ctx, commitMsgFile)\",\"   }\",\" \",\"-  t0 := time.Now()\",\"   repo, err := OpenRepository(ctx)\",\"   if err != nil {\",\"     return nil //nolint:nilerr // Hook must be silent on failure\",\"   }\",\"-  logging.Info(logCtx, \\\"prepare-commit-msg: timing\\\",\",\"-    slog.String(\\\"phase\\\", \\\"OpenRepository\\\"),\",\"-    slog.Duration(\\\"elapsed\\\", time.Since(t0)),\",\"-  )\",\" \",\"   worktreePath, err := paths.WorktreeRoot(ctx)\",\"   if err != nil {\"]},{\"oldStart\":345,\"oldLines\":7,\"newStart\":340,\"newLines\":6,\"lines\":[\"   // Find all active sessions for this worktree\",\"   // We match by worktree (not BaseCommit) because the user may have made\",\"   // intermediate commits without entering new prompts, causing HEAD to diverge\",\"-  t1 := time.Now()\",\"   sessions, err := s.findSessionsForWorktree(ctx, worktreePath)\",\"   if err != nil || len(sessions) == 0 {\",\"     // No active sessions or error listing - silently skip (hooks must be resilient)\"]},{\"oldStart\":355,\"oldLines\":11,\"newStart\":349,\"newLines\":6,\"lines\":[\"     )\",\"     return nil //nolint:nilerr // Intentional: hooks must be silent on failure\",\"   }\",\"-  logging.Info(logCtx, \\\"prepare-commit-msg: timing\\\",\",\"-    slog.String(\\\"phase\\\", \\\"findSessionsForWorktree\\\"),\",\"-    slog.Duration(\\\"elapsed\\\", time.Since(t1)),\",\"-    slog.Int(\\\"sessions\\\", len(sessions)),\",\"-  )\",\" \",\"   // Fast path: when an agent is committing (ACTIVE session + no TTY), skip\",\"   // content detection and interactive prompts. The agent can't respond to TTY\"]}],\"userModified\":false,\"replaceAll\":false},\"sourceToolAssistantUUID\