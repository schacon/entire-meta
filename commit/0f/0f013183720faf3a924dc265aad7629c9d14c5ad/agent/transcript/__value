thorFromRepo(repo)\\n   205→\\n   206→\\tt1 := time.Now()\\n   207→\\tattribution := calculateSessionAttributions(ctx, repo, ref, sessionData, state, attributionOpts{\\n   208→\\t\\theadTree: o.headTree,\\n   209→\\t})\\n   210→\\tlogging.Info(logCtx, \\\"CondenseSession: timing\\\",\\n   211→\\t\\tslog.String(\\\"phase\\\", \\\"calculateAttribution\\\"),\\n   212→\\t\\tslog.Duration(\\\"elapsed\\\", time.Since(t1)),\\n   213→\\t)\\n   214→\\n   215→\\t// Get current branch name\\n   216→\\tbranchName := GetCurrentBranchName(repo)\\n   217→\\n   218→\\t// Generate summary if enabled\\n   219→\\tvar summary *cpkg.Summary\\n   220→\\tif settings.IsSummarizeEnabled(ctx) && len(sessionData.Transcript) > 0 {\\n   221→\\t\\tt2 := time.Now()\\n   222→\\t\\tsummarizeCtx := logging.WithComponent(ctx, \\\"summarize\\\")\\n   223→\\n   224→\\t\\tvar scopedTranscript []byte\\n   225→\\t\\tswitch state.AgentType {\\n   226→\\t\\tcase agent.AgentTypeGemini:\\n   227→\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   228→\\t\\t\\tif sliceErr != nil {\\n   229→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n   230→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   231→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   232→\\t\\t\\t}\\n   233→\\t\\t\\tscopedTranscript = scoped\\n   234→\\t\\tcase agent.AgentTypeOpenCode:\\n   235→\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   236→\\t\\t\\tif sliceErr != nil {\\n   237→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n   238→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   239→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   240→\\t\\t\\t}\\n   241→\\t\\t\\tscopedTranscript = scoped\\n   242→\\t\\tcase agent.AgentTypeClaudeCode, agent