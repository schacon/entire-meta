mitStrategy) postCommitProcessSession(\\n   901→\\tctx context.Context,\\n   902→\\trepo *git.Repository,\\n   903→\\tstate *SessionState,\\n   904→\\ttransitionCtx *session.TransitionContext,\\n   905→\\tcheckpointID id.CheckpointID,\\n   906→\\thead *plumbing.Reference,\\n   907→\\tcommit *object.Commit,\\n   908→\\tnewHead string,\\n   909→\\theadTree, parentTree *object.Tree,\\n   910→\\tcommittedFileSet map[string]struct{},\\n   911→\\tshadowBranchesToDelete map[string]struct{},\\n   912→\\tuncondensedActiveOnBranch map[string]bool,\\n   913→) {\\n   914→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   915→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   916→\\n   917→\\t// Pre-resolve shadow branch ref and tree for this session.\\n   918→\\t// These are read 4+ times across sessionHasNewContent, filesOverlapWithContent,\\n   919→\\t// CondenseSession, filesWithRemainingAgentChanges, and calculateSessionAttributions.\\n   920→\\tvar shadowRef *plumbing.Reference\\n   921→\\tvar shadowTree *object.Tree\\n   922→\\tif ref, refErr := repo.Reference(plumbing.NewBranchReferenceName(shadowBranchName), true); refErr == nil {\\n   923→\\t\\tshadowRef = ref\\n   924→\\t\\tif sc, scErr := repo.CommitObject(ref.Hash()); scErr == nil {\\n   925→\\t\\t\\tif st, stErr := sc.Tree(); stErr == nil {\\n   926→\\t\\t\\t\\tshadowTree = st\\n   927→\\t\\t\\t}\\n   928→\\t\\t}\\n   929→\\t}\\n   930→\\n   931→\\t// Check for new content (needed for TransitionContext and condensation).\\n   932→\\t// Fail-open: if content check errors, assume new content exists so we\\n   933→\\t// don't silently skip data that should have been condensed.\\n   934→\\t//\\n   935→\\t// For ACTIVE sessions: the commit has a checkpoint trailer (verified above),\\n   936→\\t// meaning PrepareCommitMsg already determined this commit is session-related.\\n   937→\\t// The trailer is only added when either:\\n   938→\\t//   - No TTY (agent/subagent