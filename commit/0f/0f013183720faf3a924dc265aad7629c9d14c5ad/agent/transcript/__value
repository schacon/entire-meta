rr // Hook must be silent on failure\\n   737→\\t}\\n   738→\\n   739→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   740→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   741→\\tif !found {\\n   742→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   743→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   744→\\t\\ts.postCommitUpdateBaseCommitOnly(ctx, head)\\n   745→\\t\\treturn nil\\n   746→\\t}\\n   747→\\n   748→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   749→\\tif err != nil {\\n   750→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   751→\\t}\\n   752→\\n   753→\\t// Find all active sessions for this worktree\\n   754→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   755→\\tif err != nil || len(sessions) == 0 {\\n   756→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   757→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   758→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   759→\\t\\t)\\n   760→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   761→\\t}\\n   762→\\n   763→\\t// Build transition context\\n   764→\\tisRebase := isGitSequenceOperation(ctx)\\n   765→\\ttransitionCtx := session.TransitionContext{\\n   766→\\t\\tIsRebaseInProgress: isRebase,\\n   767→\\t}\\n   768→\\n   769→\\tif isRebase {\\n   770→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   771→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   772→\\t\\t)\\n   773→\\t}\\n   774→\\n   775→\\t// Track shadow branch names and whether they can be deleted\\n   776→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   777→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   778→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   779→\\n   780→\\tnewHead := head.Hash().String()\\n   781→\\n   782→\\t// Pre-resolve HEAD tree and parent tree once for the entire PostCommit.\\n   783→\\t// These are immutable within this hook invocation and used by multiple\\n   784→\\t// per-session functions (filesChangedInCommit, filesOverlapWithContent,\\n   785→\\t// filesWithRemainingAgentChanges, calculateSessionAttributions).\\n   786→\\tvar headTree *object.Tree\\n   787→\\tif t, err := commit.Tree(); err == nil {\\n   788→\\t\\theadTree = t\\n   789→\\t}\\n   790→\\tvar parentTree *object.Tree\\n   791→\\tif commit.NumParents() > 0 {\\n   792→\\t\\tif parent, err := commit.Parent(0); err == nil {\\n   793→\\t\\t\\tif t, err := parent.Tree(); err == nil {\\n   794→\\t\\t\\t\\tparentTree = t\\n   795→\\t\\t\\t}\\n   796→\\t\\t}\\n   797→\\t}\\n   798→\\n   799→\\tcommittedFileSet := filesChangedInCommit(commit, headTree, parentTree)\\n   800→\\n   801→\\tfor _, state := range sessions {\\n   802→\\t\\t// Skip fully-condensed ended sessions — no work remains.\\n   803→\\t\\t// These sessions only persist for LastCheckpointID (amend trailer reuse).\\n   804→\\t\\tif state.FullyCondensed && state.Phase == session.PhaseEnded {\\n   805→\\t\\t\\tcontinue\\n   806→\\t\\t}\\n   807→\\t\\ts.postCommitProcessSession(ctx, repo, state, &transitionCtx, checkpointID,\\n   808→\\t\\t\\thead, commit, newHead, headTree, parentTree, committedFileSet,\\n   809→\\t\\t\\tshadowBranchesToDelete, uncondensedActiveOnBranch)\\n   810→\\t}\\n   811→\\n   812→\\t// Clean up shadow branches — only delete when ALL sessions on the branch are non-active\\n   813→\\t// or were condensed during this PostCommit.\\n   814→\\tfor shadowBranchName := range shadowBranchesToDelete {\\n   815→\\t\\tif uncondensedActiveOnBranch[shadowBranchName] {\\n   816→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: preserving shadow branch (active session exists)\\\",\\n   817→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   818→\\t\\t\\t)\\n   819→\\t\\t\\tcontinue\\n   820→\\t\\t}\\n   821→\\t\\tif err := deleteShadowBranch(ctx, repo, shadowBranchName); err != nil {\\n   822→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to clean up shadow branch\\\",\\n   823→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   824→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   825→\\t\\t} else {\\n   826→\\t\\t\\tlogging.Info(logCtx, \\\"shadow branch deleted\\\",\\n   827→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   828→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   829→\\t\\t\\t)\\n   830→\\t\\t}\\n   831→\\t}\\n   832→\\n   833→\\treturn nil\\n   834→}\\n   835→\\n   836→// postCommitProcessSession handles a single session within the PostCommit loop.\\n   837→// Pre-resolved git objects (headTree, parentTree) are shared across all sessions;\\n   838→// per-session shadow ref/tree are resolved once here and threaded through sub-calls.\\n   839→func (s *ManualCommitStrategy) postCommitProcessSession(\\n   840→\\tctx context.Context,\\n   841→\\trepo *git.Repository,\\n   842→\\tstate *SessionState,\\n   843→\\ttransitionCtx *session.TransitionContext,\\n   844→\\tcheckpointID id.CheckpointID,\\n   845→\\thead *plumbing.Reference,\\n   846→\\tcommit *object.Commit,\\n   847→\\tnewHead string,\\n   848→\\theadTree, parentTree *object.Tree,\\n   849→\\tcommittedFileSet map[string]struct{},\\n   850→\\tshadowBranchesToDelete map[string]struct{},\\n   851→\\tuncondensedActiveOnBranch map[string]bool,\\n   852→) {\\n   853→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   854→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   855→\\n   856→\\t// Pre-resolve shadow branch ref and tree for this session.\\n   857→\\t// These are read 4+ times across sessionHasNewContent, filesOverlapWithContent,\\n   858→\\t// CondenseSession, file