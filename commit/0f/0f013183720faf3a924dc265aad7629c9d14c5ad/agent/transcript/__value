y.Close()\\n   107→\\n   108→\\t// Write to tty directly, not stderr, since git hooks may redirect stderr to /dev/null\\n   109→\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", header)\\n   110→\\tfor _, line := range details {\\n   111→\\t\\tfmt.Fprintf(tty, \\\"  %s\\\\n\\\", line)\\n   112→\\t}\\n   113→\\n   114→\\t// Show prompt with option descriptions\\n   115→\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", prompt)\\n   116→\\tif defaultYes {\\n   117→\\t\\tfmt.Fprint(tty, \\\"  [Y]es / [n]o / [a]lways (remember my choice): \\\")\\n   118→\\t} else {\\n   119→\\t\\tfmt.Fprint(tty, \\\"  [y]es / [N]o / [a]lways (remember my choice): \\\")\\n   120→\\t}\\n   121→\\n   122→\\t// Read response\\n   123→\\treader := bufio.NewReader(tty)\\n   124→\\tresponse, err := reader.ReadString('\\\\n')\\n   125→\\tif err != nil {\\n   126→\\t\\treturn defaultResult\\n   127→\\t}\\n   128→\\n   129→\\tresponse = strings.TrimSpace(strings.ToLower(response))\\n   130→\\tswitch response {\\n   131→\\tcase \\\"y\\\", \\\"yes\\\":\\n   132→\\t\\treturn ttyResultLink\\n   133→\\tcase \\\"n\\\", \\\"no\\\":\\n   134→\\t\\treturn ttyResultSkip\\n   135→\\tcase \\\"a\\\", \\\"always\\\":\\n   136→\\t\\treturn ttyResultLinkAlways\\n   137→\\tdefault:\\n   138→\\t\\t// Empty or invalid input - use default\\n   139→\\t\\treturn defaultResult\\n   140→\\t}\\n   141→}\\n   142→\\n   143→// saveCommitLinkingAlways persists commit_linking = \\\"always\\\" to settings.local.json.\\n   144→// Uses raw JSON merge to set only the commit_linking field without affecting other\\n   145→// fields. This avoids writing unintended defaults (e.g., enabled: true) when the\\n   146→// local settings file doesn't exist yet.\\n   147→func saveCommitLinkingAlways(ctx context.Context) error {\\n   148→\\tlocalPath, err := paths.AbsPath(ctx, settings.EntireSettingsLocalFile)\\n   149→\\tif err != nil {\\n   150→\\t\\treturn fmt.Errorf(\\\"resolving local settings path: %w\\\", err)\\n   151→\\t}\\n   152→\\n   153→\\t// Read existing file as raw JSON map to preserve all existing fields.\\n   154→\\t// If the file doesn't exist, start with an empty map so we only write commit_linking.\\n   155→\\tvar raw map[string]json.RawMessage\\n   156→\\tdata, readErr := os.ReadFile(localPath) //nolint:gosec // path is from AbsPath\\n   157→\\tif readErr == nil {\\n   158→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   159→\\t\\t\\treturn fmt.Errorf(\\\"parsing local settings: %w\\\", err)\\n   160→\\t\\t}\\n   161→\\t} else if !os.IsNotExist(readErr) {\\n   162→\\t\\treturn fmt.Errorf(\\\"reading local settings: %w\\\", readErr)\\n   163→\\t}\\n   164→\\tif raw == nil {\\n   165→\\t\\traw = make(map[string]json.RawMessage)\\n   166→\\t}\\n   167→\\n   168→\\traw[\\\"commit_linking\\\"] = json.RawMessage(`\\\"` + settings.CommitLinkingAlways + `\\\"`)\\n   169→\\n   170→\\tout, err := json.MarshalIndent(raw, \\\"\\\", \\\"  \\\")\\n   171→\\tif err != nil {\\n   172→\\t\\treturn fmt.Errorf(\\\"marshaling local settings: %w\\\", err)\\n   173→\\t}\\n   174→\\tout = append(out, '\\\\n')\\n   175→\\n   176→\\tif err := os.MkdirAll(filepath.Dir(localPath), 0o750); err != nil {\\n   177→\\t\\treturn fmt.Errorf(\\\"creating settings directory: %w\\\", err)\\n   178→\\t}\\n   179→\\t//nolint:gosec // G306: settings file is config, not secrets; 0o644 is appropriate\\n   180→\\tif err := os.WriteFile(localPath, out, 0o644); err != nil {\\n   181→\\t\\treturn fmt.Errorf(\\\"writing local settings: %w\\\", err)\\n   182→\\t}\\n   183→\\treturn nil\\n   184→}\\n   185→\\n   186→// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   187→// If the message contains only our trailer (no actual user content), strip it\\n   188→// so git will abort the commit due to empty message.\\n   189→\\n   190→func (s *ManualCommitStrategy) CommitMsg(_ context.Context, commitMsgFile string) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   191→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n   192→\\tif err != nil {\\n   193→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   194→\\t}\\n   195→\\n   196→\\tmessage := string(content)\\n   197→\\n   198→\\t// Check if our trailer is present (ParseCheckpoint validates format, so found==true means valid)\\n   199→\\tif _, found := trailers.ParseCheckpoint(message); !found {\\n   200→\\t\\t// No trailer, nothing to do\\n   201→\\t\\treturn nil\\n   202→\\t}\\n   203→\\n   204→\\t// Check if there's any user content (non-comment, non-trailer lines)\\n   205→\\tif !hasUserContent(message) {\\n   206→\\t\\t// No user content - strip the trailer so git aborts\\n   207→\\t\\tmessage = stripCheckpointTrailer(message)\\n   208→\\t\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   209→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   210→\\t\\t}\\n   211→\\t}\\n   212→\\n   213→\\treturn nil\\n   214→}\\n   215→\\n   216→// hasUserContent checks if the message has any content besides comments and our trailer.\\n   217→func hasUserContent(message string) bool {\\n   218→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   219→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   220→\\t\\ttrimmed := strings.TrimSpace(line)\\n   221→\\t\\t// Skip empty lines\\n   222→\\t\\tif trimmed == \\\"\\\" {\\n   223→\\t\\t\\tcontinue\\n   224→\\t\\t}\\n   225→\\t\\t// Skip comment lines\\n   226→\\t\\tif strings.HasPrefix(trimmed, \\\"#\\\") {\\n   227→\\t\\t\\tcontinue\\n   228→\\t\\t}\\n   229→\\t\\t// Skip our trailer line\\n   230→\\t\\tif strings.HasPrefix(trimmed, trailerPrefix) {\\n   231→\\t\\t\\tcontinue\\n   232→\\t\\t}\\n   233→\\t\\t// Found user content\\n   234→\\t\\treturn true\\n   235→\\t}\\n   236→\\treturn false\\n   237→}\\n   238→\\n   239→// stripCheckpointTrailer removes the Entire-Checkpoint trailer line from the message.\\n   240→func stripCheckpointTrailer(message string) string {\\n   241→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   242→\\tvar result []string\\n   243→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   244→\\t\\tif !strings.HasPrefix(strings.TrimSpace(line), trailerPrefix) {\\n   245→\\t\\t\\tresult = append(result, line)\\n   246→\\t\\t}\\n   247→\\t}\\n   248→\\treturn strings.Join(result, \\\"\\\\n\\\")\\n   249→}\\n   250→\\n   251→// isGitSequenceOperation checks if git is currently in the middle of a rebase,\\n   252→// cherry-pick, or revert operation. During these operations, commits are being\\n   253→// replayed and should not be linked to agent sessions.\\n   254→//\\n   255→// Detects:\\n   256→//   - rebase: .git/rebase-merge/ or .git/rebase-apply/ directories\\n   257→//   - cherry-pick: .git/CHERRY_PICK_HEAD file\\n   258→//   - revert: .git/REVERT_HEAD file\\n   259→func isGitSequenceOperation(ctx context.Context) bool {\\n   260→\\t// Get git directory (handles worktrees and relative paths correctly)\\n   261→\\tgitDir, err := GetGitDir(ctx)\\n   262→\\tif err != nil {\\n   263→\\t\\treturn false // Can't determine, assume not in sequence operation\\n   264→\\t}\\n   265→\\n   266→\\t// Check for rebase state directories\\n   267→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-merge\\\")); err == nil {\\n   268→\\t\\treturn true\\n   269→\\t}\\n   270→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-apply\\\")); err == nil {\\n   271→\\t\\treturn true\\n   272→\\t}\\n   273→\\n   274→\\t// Check for cherry-pick and revert state files\\n   275→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"CHERRY_PICK_HEAD\\\")); err == nil {\\n   276→\\t\\treturn true\\n   277→\\t}\\n   278→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"REVERT_HEAD\\\")); err == nil {\\n   279→\\t\\treturn true\\n   280→\\t}\\n   281→\\n   282→\\treturn false\\n   283→}\\n   284→\\n   285→// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   286→// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   287→// Only adds a trailer if there's actually new session content to condense.\\n   288→// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   289→// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   290→// For amended commits, preserves the existing checkpoint ID.\\n   291→//\\n   292→// The source parameter indicates how the commit was initiated:\\n   293→//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   294→//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   295→//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   296→//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   297→//\\n   298→\\n   299→func (s *ManualCommitStrategy) PrepareCommitMsg(ctx context.Context, commitMsgFile string, source string) error {\\n   300→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   301→\\n   302→\\t// Skip during rebase, cherry-pick, or revert operations\\n   303→\\t// These are replaying existing commits and should not be linked to agent sessions\\n   304→\\tif isGitSequenceOperation(ctx) {\\n   305→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n   306→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   307→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   308→\\t\\t)\\n   309→\\t\\treturn nil\\n   310→\\t}\\n   311→\\n   312→\\t// Skip for merge and squash sources\\n   313→\\t// These are auto-generated messages - not from Claude sessions\\n   314→\\tswitch source {\\n   315→\\tcase \\\"merge\\\", \\\"squash\\\":\\n   316→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n   317→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   318→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   319→\\t\\t)\\n   320→\\t\\treturn nil\\n   321→\\t}\\n   322→\\n   323→\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   324→\\tif source == \\\"commit\\\" {\\n   325→\\t\\treturn s.handleAmendCommitMsg(ctx, commitMsgFile)\\n   326→\\t}\\n   327→\\n   328→\\trepo, err := OpenRepository(ctx)\\n   329→\\tif err != nil {\\n   330→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   331→\\t}\\n   332→\\n   333→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   334→\\tif err != nil {\\n   335→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   336→\\t}\\n   337→\\n   338→\\t// Find all active sessions for this worktree\\n   339→\\t// We match by worktree (not BaseCommit) because the user may have made\\n   340→\\t// intermediate commits without entering new prompts, causing HEAD to diverge\\n   341→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   342→\\tif err != nil || len(sessions) == 0 {\\n   343→\\t\\t// No active sessions or error listing - silently skip (hooks must be resilient)\\n   344→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no active sessions\\\",\\n   345→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   346→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   347→\\t\\t)\\n   348→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   349→\\t}\\n   350→\\n   351→\\t// Fast path: when an agent is committing (ACTIVE session + no TTY), skip\\n   352→\\t// content detection and interactive prompts. The agent can't respond to TTY\\n   353→\\t// prompts and the content detection can miss mid-session work (no shadow\\n   354→\\t// branch yet, transcript analysis may fail). Generate a checkpoint ID and\\n   355→\\t// add the trailer directly.\\n   356→\\tif !hasTTY() {\\n   357→\\t\\tfor _, state := range sessions {\\n   358→\\t\\t\\tif state.Phase.IsActive() {\\n   359→\\t\\t\\t\\treturn s.addTrailerForAgentCommit(logCtx, commitMsgFile, state, source)\\n   360→\\t\\t\\t}\\n   361→\\t\\t}\\n   362→\\t}\\n   363→\\n   364→\\t// Check if any session has new content to condense\\n   365→\\tsessionsWithContent := s.filterSessionsWithNewContent(ctx, repo, sessions)\\n   366→\\n   367→\\tif len(sessionsWithContent) == 0 {\\n   368→\\t\\t// No new content — no trailer needed\\n   369→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no content to link\\\",\\n   370→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   371→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   372→\\t\\t\\tslog.Int(\\\"sessions_found\\\", len(sessions)),\\n   373→\\t\\t)\\n   374→\\t\\treturn nil\\n   375→\\t}\\n   376→\\n   377→\\t// Read current commit message\\n   378→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   379→\\tif err != nil {\\n   380→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   381→\\t}\\n   382→\\n   383→\\tmessage := string(content)\\n   384→\\n   385→\\t// Check if trailer already exists (ParseCheckpoint validates format, so found==true means valid)\\n   386→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   387→\\t\\t// Trailer already exists (e.g., amend) - keep it\\n   388→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: trailer already exists\\\",\\n   389→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   390→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   391→\\t\\t\\tslog.String(\\\"existing_checkpoint_id\\\", existingCpID.String()),\\n   392→\\t\\t)\\n   393→\\t\\treturn nil\\n   394→\\t}\\n   395→\\n   396→\\t// Generate a fresh checkpoint ID\\n   397→\\tcheckpointID, err := id.Generate()\\n   398→\\tif err != nil {\\n   399→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\"}]},\"uuid\":\"bbfe63e7-5ca2-4bd6-bf3b-2bce7f166e94\",\"timestamp\":\"2026-03-03T05:44:22.145Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a3a72ac5f0d16847c\"},\"toolUseID\":\"agent_msg_01JnHxEWvZU2pmkKR253GEHq\",\"parentToolUseID\":\"toolu_01PAaCxtBqfR3QLf5e3bbkZj\",\"uuid\":\"7d55b111-83b8-4cfc-9cff-16dfb64f338f\",\"timestamp\":\"2026-03-03T05:44:22.155Z\"}\n{\"parentUuid\":\"7d55b111-83b8-4cfc-9cff-16dfb64f338f\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/3\",\"sessionId\":\"86a4c45c-4c6f-441c-9e41-80eb453d2c7d\",\"version\":\"2.1.63\",\"gitBranch\":\"alex/investigate-commit-slowness\",\"slug\":\"optimized-bubbling-widget\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-03T05:44:24.194Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01WyGykTKN2c6ZxPSQTdasDS\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01FL8hoAxKNqu5ScJN39yMZX\",\"name\":\"Bash\",\"input\":{\"command\":\"grep -n \\\"^func.*PostCommit\\\" /Users/alex/workspace/cli/.worktrees/3/cmd/entire/cli/strategy/manual_commit_hooks.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":2,\"cache_creation_input_tokens\":4771,\"cache_read_input_tokens\":61791,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":4771},\"output_tokens\":3,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYfcf7WmsQuLMRDDTHCbj\",\"uuid\":\"03983db6-7dce-4d95-9f92-599c9b2aa8c7\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a3a72ac5f0d16847c\"},\"toolUseID\":\"agent_msg_01JnHxEWvZU2pmkKR253GEHq\",\"parentToolUseID\":\"toolu_01PAaCxtBqfR3QLf5e3bbkZj\",\"uuid\":\"af62fb86-210c-4cc5-ab07-1a042b2f5e2f\",\"timestamp\":\"2026-03-