→\\t\\tfmt.Fprintf(tty, \\\"  %s\\\\n\\\", line)\\n   112→\\t}\\n   113→\\n   114→\\t// Show prompt with option descriptions\\n   115→\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", prompt)\\n   116→\\tif defaultYes {\\n   117→\\t\\tfmt.Fprint(tty, \\\"  [Y]es / [n]o / [a]lways (remember my choice): \\\")\\n   118→\\t} else {\\n   119→\\t\\tfmt.Fprint(tty, \\\"  [y]es / [N]o / [a]lways (remember my choice): \\\")\\n   120→\\t}\\n   121→\\n   122→\\t// Read response\\n   123→\\treader := bufio.NewReader(tty)\\n   124→\\tresponse, err := reader.ReadString('\\\\n')\\n   125→\\tif err != nil {\\n   126→\\t\\treturn defaultResult\\n   127→\\t}\\n   128→\\n   129→\\tresponse = strings.TrimSpace(strings.ToLower(response))\\n   130→\\tswitch response {\\n   131→\\tcase \\\"y\\\", \\\"yes\\\":\\n   132→\\t\\treturn ttyResultLink\\n   133→\\tcase \\\"n\\\", \\\"no\\\":\\n   134→\\t\\treturn ttyResultSkip\\n   135→\\tcase \\\"a\\\", \\\"always\\\":\\n   136→\\t\\treturn ttyResultLinkAlways\\n   137→\\tdefault:\\n   138→\\t\\t// Empty or invalid input - use default\\n   139→\\t\\treturn defaultResult\\n   140→\\t}\\n   141→}\\n   142→\\n   143→// saveCommitLinkingAlways persists commit_linking = \\\"always\\\" to settings.local.json.\\n   144→// Uses raw JSON merge to set only the commit_linking field without affecting other\\n   145→// fields. This avoids writing unintended defaults (e.g., enabled: true) when the\\n   146→// local settings file doesn't exist yet.\\n   147→func saveCommitLinkingAlways(ctx context.Context) error {\\n   148→\\tlocalPath, err := paths.AbsPath(ctx, settings.EntireSettingsLocalFile)\\n   149→\\tif err != nil {\\n   150→\\t\\treturn fmt.Errorf(\\\"resolving local settings path: %w\\\", err)\\n   151→\\t}\\n   152→\\n   153→\\t// Read existing file as raw JSON map to preserve all existing fields.\\n   154→\\t// If the file doesn't exist, start with an empty map so we only write commit_linking.\\n   155→\\tvar raw map[string]json.RawMessage\\n   156→\\tdata, readErr := os.ReadFile(localPath) //nolint:gosec // path is from AbsPath\\n   157→\\tif readErr == nil {\\n   158→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   159→\\t\\t\\treturn fmt.Errorf(\\\"parsing local settings: %w\\\", err)\\n   160→\\t\\t}\\n   161→\\t} else if !os.IsNotExist(readErr) {\\n   162→\\t\\treturn fmt.Errorf(\\\"reading local settings: %w\\\", readErr)\\n   163→\\t}\\n   164→\\tif raw == nil {\\n   165→\\t\\traw = make(map[string]json.RawMessage)\\n   166→\\t}\\n   167→\\n   168→\\traw[\\\"commit_linking\\\"] = json.RawMessage(`\\\"` + settings.CommitLinkingAlways + `\\\"`)\\n   169→\\n   170→\\tout, err := json.MarshalIndent(raw, \\\"\\\", \\\"  \\\")\\n   171→\\tif err != nil {\\n   172→\\t\\treturn fmt.Errorf(\\\"marshaling local settings: %w\\\", err)\\n   173→\\t}\\n   174→\\tout = append(out, '\\\\n')\\n   175→\\n   176→\\tif err := os.MkdirAll(filepath.Dir(localPath), 0o750); err != nil {\\n   177→\\t\\treturn fmt.Errorf(\\\"creating settings directory: %w\\\", err)\\n   178→\\t}\\n   179→\\t//nolint:gosec // G306: settings file is config, not secrets; 0o644 is appropriate\\n   180→\\tif err := os.WriteFile(localPath, out, 0o644); err != nil {\\n   181→\\t\\treturn fmt.Errorf(\\\"writing local settings: %w\\\", err)\\n   182→\\t}\\n   183→\\treturn nil\\n   184→}\\n   185→\\n   186→// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   187→// If the message contains only our trailer (no actual user content), strip it\\n   188→// so git will abort the commit due to empty message.\\n   189→\\n   190→func (s *ManualCommitStrategy) CommitMsg(_ context.Context, commitMsgFile string) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   191→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n   192→\\tif err != nil {\\n   193→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   194→\\t}\\n   195→\\n   196→\\tmessage := string(content)\\n   197→\\n   198→\\t// Check if our trailer is present (ParseCheckpoint validates format, so found==true means valid)\\n   199→\\tif _, found := trailers.ParseCheckpoint(message); !found {\\n   200→\\t\\t// No trailer, nothing to do\\n   201→\\t\\treturn nil\\n   202→\\t}\\n   203→\\n   204→\\t// Check if there's any user content (non-comment, non-trailer lines)\\n   205→\\tif !hasUserContent(message) {\\n   206→\\t\\t// No user content - strip the trailer so git aborts\\n   207→\\t\\tmessage = stripCheckpointTrailer(message)\\n   208→\\t\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   209→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   210→\\t\\t}\\n   211→\\t}\\n   212→\\n   213→\\treturn nil\\n   214→}\\n   215→\\n   216→// hasUserContent checks if the message has any content besides comments and our trailer.\\n   217→func hasUserContent(message string) bool {\\n   218→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   219→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   220→\\t\\ttrimmed := strings.TrimSpace(line)\\n   221→\\t\\t// Skip empty lines\\n   222→\\t\\tif trimmed == \\\"\\\" {\\n   223→\\t\\t\\tcontinue\\n   224→\\t\\t}\\n   225→\\t\\t// Skip comment lines\\n   226→\\t\\tif strings.HasPrefix(trimmed, \\\"#\\\") {\\n   227→\\t\\t\\tcontinue\\n   228→\\t\\t}\\n   229→\\t\\t// Skip our trailer line\\n   230→\\t\\tif strings.HasPrefix(trimmed, trailerPrefix) {\\n   231→\\t\\t\\tcontinue\\n   232→\\t\\t}\\n   233→\\t\\t// Found user content\\n   234→\\t\\treturn true\\n   235→\\t}\\n   236→\\treturn false\\n   237→}\\n   238→\\n   239→// stripCheckpointTrailer removes the Entire-Checkpoint trailer line from the message.\\n   240→func stripCheckpointTrailer(message string) string {\\n   241→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   242→\\tvar result []string\\n   243→\\tfor _, line := range strings.