tslog.String(\\\"error\\\", err.Error()),\\n  1014→\\t\\t)\\n  1015→\\t\\treturn false\\n  1016→\\t}\\n  1017→\\n  1018→\\t// Track this shadow branch for cleanup\\n  1019→\\tshadowBranchesToDelete[shadowBranchName] = struct{}{}\\n  1020→\\n  1021→\\t// Update session state for the new base commit\\n  1022→\\tnewHead := head.Hash().String()\\n  1023→\\tstate.BaseCommit = newHead\\n  1024→\\tstate.AttributionBaseCommit = newHead\\n  1025→\\tstate.StepCount = 0\\n  1026→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n  1027→\\n  1028→\\t// Clear attribution tracking — condensation already used these values\\n  1029→\\tstate.PromptAttributions = nil\\n  1030→\\tstate.PendingPromptAttribution = nil\\n  1031→\\tstate.FilesTouched = nil\\n  1032→\\n  1033→\\t// Save checkpoint ID so subsequent commits can reuse it (e.g., amend restores trailer)\\n  1034→\\tstate.LastCheckpointID = checkpointID\\n  1035→\\n  1036→\\tlogging.Info(logCtx, \\\"session condensed\\\",\\n  1037→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n  1038→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1039→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n  1040→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n  1041→\\t\\tslog.Int(\\\"transcript_lines\\\", result.TotalTranscriptLines),\\n  1042→\\t)\\n  1043→\\n  1044→\\treturn true\\n  1045→}\\n  1046→\\n  1047→// updateBaseCommitIfChanged updates BaseCommit to newHead if it changed.\\n  1048→// Only updates ACTIVE sessions. IDLE/ENDED sessions should NOT have their\\n  1049→// BaseCommit updated, as this would cause them to be incorrectly associated\\n  1050→// with a new shadow branch and potentially condensed on future commits.\\n  1051→func (s *ManualCommitStrategy) updateBaseCommitIfChanged(ctx context.Context, state *SessionState, newHead string) {\\n  1052→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n  1053→\\t// Only update ACTIVE sessions. IDLE/ENDED sessions are kept around for\\n  1054→\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n  1055→\\tif !state.Phase.IsActive() {\\n  1056→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updateBaseCommitIfChanged skipped non-active session\\\",\\n  1057→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1058→\\t\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n  1059→\\t\\t)\\n  1060→\\t\\treturn\\n  1061→\\t}\\n  1062→\\tif state.BaseCommit != newHead {\\n  1063→\\t\\tstate.BaseCommit = newHead\\n  1064→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updated BaseCommit\\\",\\n  1065→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1066→\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n  1067→\\t\\t)\\n  1068→\\t}\\n  1069→}\\n  1070→\\n  1071→// postCommitUpdateBaseCommitOnly updates BaseCommit for all sessions on the current\\n  1072→// worktree when a commit has no Entire-Checkpoint trailer. This prevents BaseCommit\\n  1073→// from going stale, which would cause future PrepareCommitMsg calls to skip the\\n  1074→// session (BaseCommit != currentHeadHash filter).\\n  1075→//\\n  1076→// Unlike the full PostCommit flow, this does NOT fire EventGitCommit or trigger\\n  1077→// condensation — it only keeps BaseCommit in sync with HEAD.\\n  1078→func (s *ManualCommitStrategy) postCommitUpdateBaseCommitOnly(ctx context.Context, head *plumbing.Reference) {\\n  1079→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n  1080→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n  1081→\\tif err != nil {\\n  1082→\\t\\treturn // Silent failure — hooks must be resilient\\n  1083→\\t}\\n  1084→\\n  1085→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n  1086→\\tif err != nil || len(sessions) == 0 {\\n  1087→\\t\\treturn\\n  1088→\\t}\\n  1089→\\n  1090→\\tnewHead := head.Hash().String()\\n  1091→\\tfor _, state := range sessions {\\n  1092→\\t\\t// Only update active sessions