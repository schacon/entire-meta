dedPerFile[filePath]\\n   349→\\t\\t// User can only self-modify up to what they previously added\\n   350→\\t\\tselfModified += min(removed, userAddedToFile)\\n   351→\\t}\\n   352→\\treturn selfModified\\n   353→}\\n   354→\\n   355→// CalculatePromptAttribution computes line-level attribution at the start of a prompt.\\n   356→// This captures user edits since the last checkpoint BEFORE the agent makes changes.\\n   357→//\\n   358→// Parameters:\\n   359→//   - baseTree: the tree at session start (the base commit)\\n   360→//   - lastCheckpointTree: the tree from the previous checkpoint (nil if first checkpoint)\\n   361→//   - worktreeFiles: map of file path → current worktree content for files that changed\\n   362→//   - checkpointNumber: which checkpoint we're about to create (1-indexed)\\n   363→//\\n   364→// Returns the attribution data to store in session state. For checkpoint 1 (when\\n   365→// lastCheckpointTree is nil), AgentLinesAdded/Removed will be 0 since there's no\\n   366→// previous checkpoint to measure cumulative agent work against.\\n   367→//\\n   368→// Note: Binary files (detected by null bytes) in reference trees are silently excluded\\n   369→// from attribution calculations since line-based diffing only applies to text files.\\n   370→func CalculatePromptAttribution(\\n   371→\\tbaseTree *object.Tree,\\n   372→\\tlastCheckpointTree *object.Tree,\\n   373→\\tworktreeFiles map[string]string,\\n   374→\\tcheckpointNumber int,\\n   375→) PromptAttribution {\\n   376→\\tresult := PromptAttribution{\\n   377→\\t\\tCheckpointNumber: checkpointNumber,\\n   378→\\t\\tUserAddedPerFile: make(map[string]int),\\n   379→\\t}\\n   380→\\n   381→\\tif len(worktreeFiles) == 0 {\\n   382→\\t\\treturn result\\n   383→\\t}\\n   384→\\n   385→\\t// Determine reference tree for user changes (last checkpoint or base)\\n   386→\\treferenceTree := lastCheckpointTree\\n   387→\\tif referenceTree == nil {\\n   388→\\t\\treferenceTree = baseTree\\n   389→\\t}\\n   390→\\n   391→\\tfor filePath, worktreeContent := range worktreeFiles {\\n   392→\\t\\treferenceContent := getFileContent(referenceTree, filePath)\\n   393→\\t\\tbaseContent := getFileContent(baseTree, filePath)\\n   394→\\n   395→\\t\\t// User changes: diff(reference, worktree)\\n   396→\\t\\t// These are changes since the last checkpoint that the agent didn't make\\n   397→\\t\\t_, userAdded, userRemoved := diffLines(referenceContent, worktreeContent)\\n   398→\\t\\tresult.UserLinesAdded += userAdded\\n   399→\\t\\tresult.UserLinesRemoved += userRemoved\\n   400→\\n   401→\\t\\t// Track per-file user additions for accurate modification tracking.\\n   402→\\t\\t// This enables distinguishing user self-modifications from agent modifications.\\n   403→\\t\\tif userAdded > 0 {\\n   404→\\t\\t\\tresult.UserAddedPerFile[filePath] = userAdded\\n   405→\\t\\t}\\n   406→\\n   407→\\t\\t// Agent lines so far: diff(base, lastCheckpoint)\\n   408→\\t\\t// Only calculate if we have a previous checkpoint\\n   409→\\t\\tif lastCheckpointTree != nil {\\n   410→\\t\\t\\tcheckpointContent := getFileContent(lastCheckpointTree, filePath)\\n   411→\\t\\t\\t_, agentAdded, agentRemoved := diffLines(baseContent, checkpointContent)\\n   412→\\t\\t\\tresult.AgentLinesAdded += agentAdded\\n   413→\\t\\t\\tresult.AgentLinesRemoved += agentRemoved\\n   414→\\t\\t}\\n   415→\\t}\\n   416→\\n   417→\\treturn result\\n   418→}\\n   419→\"}]},\"uuid\":\"23170108-e094-4a21-af02-7250912c8a5c\",\"timestamp\":\"2026-03-03T08:49:36.602Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alex/workspace/cli/.worktrees/3/cmd/entire/cli/strategy/manual_commit_attribution.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"slices\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n\\t\\\"github.com/sergi/go-diff/diffmatchpatch\\\"\\n)\\n\\n// getAllChangedFilesBetweenTrees returns a list of all files that differ between two trees.\\n// This includes files that were added, modified, or deleted in either tree.\\n// Uses git blob hashes for efficient comparison without reading file contents.\\nfunc getAllChangedFilesBetweenTrees(ctx context.Context, tree1, tree2 *object.Tree) ([]string, error) {\\n\\tif tree1 == nil && tree2 == nil {\\n\\t\\treturn nil, nil\\n\\t}\\n\\n\\t// Build hash maps for each tree - O(n) iteration, no content reading\\n\\ttree1Hashes := make(map[string]string)\\n\\ttree2Hashes := make(map[string]string)\\n\\n\\tif tree1 != nil {\\n\\t\\tif err := tree1.Files().ForEach(func(f *object.File) error {\\n\\t\\t\\tif err := ctx.Err(); err != nil {\\n\\t\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n\\t\\t\\t}\\n\\t\\t\\ttree1Hashes[f.Name] = f.Hash.String()\\n\\t\\t\\treturn nil\\n\\t\\t}); err != nil {\\n\\t\\t\\treturn nil, err //nolint:wrapcheck // Propagating context/iteration error\\n\\t\\t}\\n\\t}\\n\\n\\tif tree2 != nil {\\n\\t\\tif err := tree2.Files().ForEach(func(f *object.File) error {\\n\\t\\t\\tif err := ctx.Err(); err != nil {\\n\\t\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n\\t\\t\\t}\\n\\t\\t\\ttree2Hashes[f.Name] = f.Hash.String()\\n\\t\\t\\treturn nil\\n\\t\\t}); err != nil {\\n\\t\\t\\treturn nil, err //nolint:wrapcheck // Propagating context/iteration error\\n\\t\\t}\\n\\t}\\n\\n\\t// Find changed files by comparing hashes (much faster than content comparison)\\n\\tvar changed []string\\n\\n\\t// Check files in tree1 - either modified or deleted in tree2\\n\\tfor path, hash1 := range tree1Hashes {\\n\\t\\tif hash2, exists := tree2Hashes[path]; !exists || hash1 != hash2 {\\n\\t\\t\\tchanged = append(changed, path)\\n\\t\\t}\\n\\t}\\n\\n\\t// Check files only in tree2 (added files)\\n\\tfor path := range tree2Hashes {\\n\\t\\tif _, exists := tree1Hashes[path]; !exists {\\n\\t\\t\\tchanged = append(changed, path)\\n\\t\\t}\\n\\t}\\n\\n\\treturn changed, nil\\n}\\n\\n// getFileContent retrieves the content of a file from a tree.\\n// Returns empty string if the file doesn't exist, can't be read, or is a binary file.\\n//\\n// Binary files are silently excluded from attribution calculations because line-based\\n// diffing doesn't apply to binary content. This means binary files (images, compiled\\n// binaries, etc.) won't appear in attribution metrics even if they were added or modified.\\n// This is intentional - attribution measures code contributions via line counting,\\n// which only makes sense for text files.\\n//\\n// Uses go-git's IsBinary() which implements git's binary detection algorithm.\\n//\\n// TODO: Consider tracking binary file counts separately (e.g., BinaryFilesChanged field)\\n// to provide visibility into non-text file modifications.\\nfunc getFileContent(tree *object.Tree, path string) string {\\n\\tif tree == nil {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\n\\tfile, err := tree.File(path)\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\n\\t// Use git's binary detection algorithm\\n\\tisBinary, err := file.IsBinary()\\n\\tif err != nil || isBinary {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\n\\tcontent, err := file.Contents()\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\n\\treturn content\\n}\\n\\n// diffLines compares two strings and returns line-level diff stats.\\n// Returns (unchanged, added, removed) line counts.\\nfunc diffLines(checkpointContent, committedContent string) (unchanged, added, removed int) {\\n\\t// Handle edge cases\\n\\tif checkpointContent == committedContent {\\n\\t\\treturn countLinesStr(committedContent), 0, 0\\n\\t}\\n\\tif checkpointContent == \\\"\\\" {\\n\\t\\treturn 0, countLinesStr(committedContent), 0\\n\\t}\\n\\tif committedContent == \\\"\\\" {\\n\\t\\treturn 0, 0, countLinesStr(checkpointContent)\\n\\t}\\n\\n\\tdmp := diffmatchpatch.New()\\n\\n\\t// Convert to line-based diff using DiffLinesToChars/DiffCharsToL