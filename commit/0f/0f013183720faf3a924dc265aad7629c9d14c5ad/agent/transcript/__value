all files that differ between two trees.\\n    15→// This includes files that were added, modified, or deleted in either tree.\\n    16→// Uses git blob hashes for efficient comparison without reading file contents.\\n    17→func getAllChangedFilesBetweenTrees(ctx context.Context, tree1, tree2 *object.Tree) ([]string, error) {\\n    18→\\tif tree1 == nil && tree2 == nil {\\n    19→\\t\\treturn nil, nil\\n    20→\\t}\\n    21→\\n    22→\\t// Build hash maps for each tree - O(n) iteration, no content reading\\n    23→\\ttree1Hashes := make(map[string]string)\\n    24→\\ttree2Hashes := make(map[string]string)\\n    25→\\n    26→\\tif tree1 != nil {\\n    27→\\t\\tif err := tree1.Files().ForEach(func(f *object.File) error {\\n    28→\\t\\t\\tif err := ctx.Err(); err != nil {\\n    29→\\t\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n    30→\\t\\t\\t}\\n    31→\\t\\t\\ttree1Hashes[f.Name] = f.Hash.String()\\n    32→\\t\\t\\treturn nil\\n    33→\\t\\t}); err != nil {\\n    34→\\t\\t\\treturn nil, err //nolint:wrapcheck // Propagating context/iteration error\\n    35→\\t\\t}\\n    36→\\t}\\n    37→\\n    38→\\tif tree2 != nil {\\n    39→\\t\\tif err := tree2.Files().ForEach(func(f *object.File) error {\\n    40→\\t\\t\\tif err := ctx.Err(); err != nil {\\n    41→\\t\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n    42→\\t\\t\\t}\\n    43→\\t\\t\\ttree2Hashes[f.Name] = f.Hash.String()\\n    44→\\t\\t\\treturn nil\\n    45→\\t\\t}); err != nil {\\n    46→\\t\\t\\treturn nil, err //nolint:wrapcheck // Propagating context/iteration error\\n    47→\\t\\t}\\n    48→\\t}\\n    49→\\n    50→\\t// Find changed files by comparing hashes (much faster than content comparison)\\n    51→\\tvar changed []string\\n    52→\\n    53→\\t// Check files in tree1 - either modified or deleted in tree2\\n    54→\\tfor path, hash1 := range tree1Hashes {\\n    55→\\t\\tif hash2, exists := tree2Hashes[path]; !exists || hash1 != hash2 {\\n    56→\\t\\t\\tchanged = append(changed, path)\\n    57→\\t\\t}\\n    58→\\t}\\n    59→\\n    60→\\t// Check files only in tree2 (added files)\\n    61→\\tfor path := range tree2Hashes {\\n    62→\\t\\tif _, exists := tree1Hashes[path]; !exists {\\n    63→\\t\\t\\tchanged = append(changed, path)\\n    64→\\t\\t}\\n    65→\\t}\\n    66→\\n    67→\\treturn changed, nil\\n    68→}\\n    69→\\n    70→// getFileContent retrieves the content of a file from a tree.\\n    71→// Returns empty string if the file doesn't exist, can't be read, or is a binary file.\\n    72→//\\n    73→// Binary files are silently excluded from attribution calculations because line-based\\n    74→// diffing doesn't apply to binary content. This means binary files (images, compiled\\n    75→// binaries, etc.) won't appear in attribution metrics even if they were added or modified.\\n    76→// This is intentional - attribution measures code contributions via line counting,\\n    77→// which only makes sense for text files.\\n    78→//\\n    79→// Uses go-git's IsBinary() which implements git's binary detection algorithm.\\n    80→//\\n    81→// TODO: Consider tracking binary file counts separately (e.g., BinaryFilesChanged field)\\n    82→// to provide visibility into non-text file modifications.\\n    83→func getFileContent(tree *object.Tree, path string) string {\\n    84→\\tif tree == nil {\\n    85→\\t\\treturn \\\"\\\"\\n    86→\\t}\\n    87→\\n    88→\\tfile, err := tree.File(path)\\n    89→\\tif err != nil {\\n    90→\\t\\treturn \\\"\\\"\\n    91→\\t}\\n    92→\\n    93→\\t// Use git's binary detection algorithm\\n    94→\\tisBinary, err := file.IsBinary()\\n    95→\\tif err != nil || isBinary {\\n    96→\\t\\treturn \\\"\\\"\\n    97→\\t}\\n    98→\\n    99→\\tcontent, err := file.Contents()\\n   100→\\tif err != nil {\\n   101→\\t\\treturn \\\"\\\"\\n   102→\\t}\\n   103→\\n   104→\\treturn content\\n   105→}\\n   106→\\n   107→// diffLines compares two strings and returns line-level diff