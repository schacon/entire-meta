orName,\\n   277→\\t\\tAuthorEmail:                 authorEmail,\\n   278→\\t\\tAgent:                       state.AgentType,\\n   279→\\t\\tTurnID:                      state.TurnID,\\n   280→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   281→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   282→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   283→\\t\\tInitialAttribution:          attribution,\\n   284→\\t\\tSummary:                     summary,\\n   285→\\t}); err != nil {\\n   286→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   287→\\t}\\n   288→\\tlogging.Info(logCtx, \\\"CondenseSession: timing\\\",\\n   289→\\t\\tslog.String(\\\"phase\\\", \\\"WriteCommitted\\\"),\\n   290→\\t\\tslog.Duration(\\\"elapsed\\\", time.Since(t3)),\\n   291→\\t)\\n   292→\\n   293→\\tlogging.Info(logCtx, \\\"CondenseSession: timing\\\",\\n   294→\\t\\tslog.String(\\\"phase\\\", \\\"total\\\"),\\n   295→\\t\\tslog.Duration(\\\"elapsed\\\", time.Since(condenseStart)),\\n   296→\\t)\\n   297→\\n   298→\\treturn &CondenseResult{\\n   299→\\t\\tCheckpointID:         checkpointID,\\n   300→\\t\\tSessionID:            state.SessionID,\\n   301→\\t\\tCheckpointsCount:     state.StepCount,\\n   302→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   303→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   304→\\t}, nil\\n   305→}\\n   306→\\n   307→// attributionOpts provides pre-resolved git objects to avoid redundant reads.\\n   308→type attributionOpts struct {\\n   309→\\theadTree   *object.Tree // HEAD commit tree (already resolved by PostCommit)\\n   310→\\tshadowTree *object.Tree // Shadow branch tree (already resolved by PostCommit)\\n   311→}\\n   312→\\n   313→func calculateSessionAttributions(ctx context.Context, repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState, opts ...attributionOpts) *cpkg.InitialAttribution {\\n   314→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   315→\\t// This uses user edits captured at each prompt start (before agent works),\\n   316→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   317→\\t//\\n   318→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   319→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   320→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   321→\\tlogCtx := logging.WithComponent(ctx, \\\"attribution\\\")\\n   322→\\n   323→\\tvar o attributionOpts\\n   324→\\tif len(opts) > 0 {\\n   325→\\t\\to = opts[0]\\n   326→\\t}\\n   327→\\n   328→\\theadTree := o.headTree\\n   329→\\tif headTree == nil {\\n   330→\\t\\theadRef, headErr := repo.Head()\\n   331→\\t\\tif headErr != nil {\\n   332→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   333→\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   334→\\t\\t\\treturn nil\\n   335→\\t\\t}\\n   336→\\n   337→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   338→\\t\\tif commitErr != nil {\\n   339→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   340→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   341→\\t\\t\\treturn nil\\n   342→\\t\\t}\\n   343→\\n   344→\\t\\tvar treeErr error\\n   345→\\t\\theadTree, treeErr = headCommit.Tree()\\n   346→\\t\\tif treeErr != nil {\\n   347→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   348→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   349→\\t\\t\\treturn nil\\n   350→\\t\\t}\\n   351→\\t}\\n   352→\\n   353→\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n   354→\\tshadowTree := o.shadowTree\\n   355→\\tif shadowTree == nil {\\n   356→\\t\\tif shadowRef != nil {\\n   357→\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   358→\\t\\t\\tif shadowErr != nil {\\n   359→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   360→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   361→\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   362→\\t\\t\\t\\treturn nil\\n   363→\\t\\t\\t}\\n   364→\\t\\t\\tvar shadowTreeErr error\\n   365→\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   366→\\t\\t\\tif shadowTreeErr != nil {\\n   367→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   368→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   369→\\t\\t\\t\\treturn nil\\n   370→\\t\\t\\t}\\n   371→\\t\\t} else {\\n   372→\\t\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   373→\\t\\t\\t// because the agent's work is the commit itself.\\n   374→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   375→\\t\\t\\tshadowTree = headTree\\n   376→\\t\\t}\\n   377→\\t}\\n   378→\\n   379→\\t// Get base tree (state before session started)\\n   380→\\tvar baseTree *object.Tree\\n   381→\\tattrBase := state.AttributionBaseCommit\\n   382→\\tif attrBase == \\\"\\\" {\\n   383→\\t\\tattrBase = state.BaseCommit // backward compat\\n   384→\\t}\\n   385→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   386→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   387→\\t\\t\\tbaseTree = tree\\n   388→\\t\\t} else {\\n   389→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   390→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   391→\\t\\t}\\n   392→\\t} else {\\n   393→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   394→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   395→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   396→\\t}\\n   397→\\n   398→\\t// Log accumulated prompt attributions for debugging\\n   399→\\tvar totalUserAdded, totalUserRemoved int\\n   400→\\tfor i, pa := range state.PromptAttributions {\\n   401→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   402→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   403→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   404→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   405→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   406→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   407→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   408→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   409→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   410→\\t}\\n   411→\\n   412→\\tattribution := CalculateAttributionWithAccumulated(\\n   413→\\t\\tctx,\\n   414→\\t\\tbaseTree,\\n   415→\\t\\tshadowTree,\\n   416→\\t\\theadTree,\\n   417→\\t\\tsessionData.FilesTouched,\\n   418→\\t\\tstate.PromptAttributions,\\n   419→\\t)\\n   420→\\n   421→\\tif attribution != nil {\\n   422→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   423→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   424→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   425→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   426→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   427→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   428→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   429→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   430→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   431→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   432→\\t}\\n   433→\\n   434→\\treturn attribution\\n   435→}\\n   436→\\n   437→// extractSessionData extracts session data from the shadow branch.\\n   438→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   439→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   440→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   441→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   442→// continued growing — the shadow branch copy would be stale.\\n   443→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   444→func (s *ManualCommitStrategy) extractSessionData(ctx context.Context, repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType types.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n   445→\\tag, _ := agent.GetByAgentType(agentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   446→\\tcommit, err := repo.CommitObject(shadowRef)\\n   447→\\tif err != nil {\\n   448→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   449→\\t}\\n   450→\\n   451→\\ttree, err := commit.Tree()\\n   452→\\tif err != nil {\\n   453→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   454→\\t}\\n   455→\\n   456→\\tdata := &ExtractedSessionData{}\\n   457→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   458→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   459→\\n   460→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   461→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   462→\\t// (SaveStep is only called when there are file modifications).\\n   463→\\tvar fullTranscript string\\n   464→\\tif liveTranscriptPath != \\\"\\\" {\\n   465→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   466→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   467→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   468→\\t\\tif isActive {\\n   469→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, liveTranscriptPath)\\n   470→\\t\\t}\\n   471→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   472→\\t\\t\\tfullTranscript = string(liveData)\\n   473→\\t\\t}\\n   474→\\t}\\n   475→\\tif fullTranscript == \\\"\\\" {\\n   476→\\t\\t// Fall back to shadow branch copy\\n   477→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   478→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   479→\\t\\t\\t\\tfullTranscript = content\\n   480→\\t\\t\\t}\\n   481→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   482→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   483→\\t\\t\\t\\tfullTranscript = content\\n   484→\\t\\t\\t}\\n   485→\\t\\t}\\n   486→\\t}\\n   487→\\n   488→\\t// Process transcript based on agent type\\n   489→\\tif fullTranscript != \\\"\\\" {\\n   490→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   491→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   492→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   493→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   494→\\t}\\n   495→\\n   496→\\t// Use tracked files from session state (not all files in tree)\\n   497→\\tdata.FilesTouched = filesTouched\\n   498→\\n   499→\\t// Calculate token usage from the extracted transcript portion\\n   500→\\tif len(data.Transcript) > 0 {\\n   501→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ctx, ag, data.Transcript, checkpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   502→\\t}\\n   503→\\n   504→\\treturn data, nil\\n   505→}\\n   506→\\n   507→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   508→// This is used for mid-session commits where no shadow branch exists yet.\\n   509→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(ctx context.Context, state *SessionState) (*ExtractedSessionData, error) {\\n   510→\\tdata := &ExtractedSessionData{}\\n   511→\\n   512→\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   513→\\n   514→\\t// Read the live transcript\\n   515→\\tif state.TranscriptPath == \\\"\\\" {\\n   516→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   517→\\t}\\n   518→\\n   519→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   520→\\tif err != nil {\\n   521→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   522→\\t}\\n   523→\\n   524→\\tif len(liveData) == 0 {\\n   525→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   526→\\t}\\n   527→\\n   528→\\tfullTranscript := string(liveData)\\n   529→\\tdata.Transcript = liveData\\n   530→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   531→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   532→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   533→\\n   534→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   535→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   536→\\tif len(state.FilesTouched) > 0 {\\n   537→\\t\\tdata.FilesTouched = state.FilesTouched\\n   538→\\t} else {\\n   539→\\t\\t// Use the shared helper which includes subagent transcripts\\n   540→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(ctx, state, state.CheckpointTranscriptStart)\\n   541→\\t}\\n   542→\\n   543→\\t// Calculate token usage from the extracted transcript portion\\n   544→\\tif len(data.Transcript) > 0 {\\n   545→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ctx, ag, data.Transcript, state.CheckpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   546→\\t}\\n   547→\\n   548→\\treturn data, nil\\n   549→}\\n   550→\\n   551→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   552→// For Claude Code and JSONL-based agents, this counts lines.\\n   553→// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n   554→// Returns 0 if the content is empty or malformed.\\n   555→func countTranscriptItems(agentType types.AgentType, content string) int {\\n   556→\\tif content == \\\"\\\" {\\n   557→\\t\\treturn 0\\n   558→\\t}\\n   559→\\n   560→\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n   561→\\tif agentType == agent.AgentTypeOpenCode {\\n   562→\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n   563→\\t\\tif err == nil && session != nil {\\n   564→\\t\\t\\treturn len(session.Messages)\\n   565→\\t\\t}\\n   566→\\t\\treturn 0\\n   567→\\t}\\n   568→\\n   569→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   570→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   571→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   572→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   573→\\t\\t\\treturn len(transcript.Messages)\\n   574→\\t\\t}\\n   575→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   576→\\t\\tif agentType == agent.AgentTypeGemini {\\n   577→\\t\\t\\treturn 0\\n   578→\\t\\t}\\n   579→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   580→\\t}\\n   581→\\n   582→\\t// Claude Code and other JSONL-based agents\\n   583→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   584→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   585→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   586→\\t\\tallLines = allLines[:len(allLines)-1]\\n   587→\\t}\\n   588→\\treturn len(allLines)\\n   589→}\\n   590→\\n   591→// extractUserPrompts extracts all user prompts from transcript content.\\n   592→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   593→func extractUserPrompts(agentType types.AgentType, content string) []string {\\n   594→\\tif content == \\\"\\\" {\\n   595→\\t\\treturn nil\\n   596→\\t}\\n   597→\\n   598→\\t// Droid has its own envelope format — use its parser to normalize first\\n   599→\\tif agentType == agent.AgentTypeFactoryAIDroid {\\n   600→\\t\\tlines, _, err := factoryaidroid.ParseDroidTranscriptFromBytes([]byte(content), 0)\\n   601→\\t\\tif err != nil {\\n   602→\\t\\t\\treturn nil\\n   603→\\t\\t}\\n   604→\\t\\tvar prompts []string\\n   605→\\t\\tfor _, line := range lines {\\n   606→\\t\\t\\tif line.Type != transcript.TypeUser {\\n   607→\\t\\t\\t\\tcontinue\\n   608→\\t\\t\\t}\\n   609→\\t\\t\\tif text := transcript.ExtractUserContent(line.Message); text != \\\"\\\" {\\n   610→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(text); stripped != \\\"\\\" {\\n   611→\\t\\t\\t\\t\\tprompts = append(prompts, stripped)\\n   612→\\t\\t\\t\\t}\\n   613→\\t\\t\\t}\\n   614→\\t\\t}\\n   615→\\t\\treturn prompts\\n   616→\\t}\\n   617→\\n   618→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   619→\\tif agentType == agent.AgentTypeOpenCode {\\n   620→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   621→\\t\\tif err == nil && len(prompts) > 0 {\\n   622→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   623→\\t\\t\\tfor _, prompt := range prompts {\\n   624→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   625→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   626→\\t\\t\\t\\t}\\n   627→\\t\\t\\t}\\n   628→\\t\\t\\treturn cleaned\\n   629→\\t\\t}\\n   630→\\t\\treturn nil\\n   631→\\t}\\n   632→\\n   633→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   634→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   635→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   636→\\t\\tif err == nil && len(prompts) > 0 {\\n   637→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   638→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   639→\\t\\t\\tfor _, prompt := range prompts {\\n   640→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   641→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   642→\\t\\t\\t\\t}\\n   643→\\t\\t\\t}\\n   644→\\t\\t\\treturn cleaned\\n   645→\\t\\t}\\n   646→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   647→\\t\\tif agentType == agent.AgentTypeGemini {\\n   648→\\t\\t\\treturn nil\\n   649→\\t\\t}\\n   650→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   651→\\t}\\n   652→\\n   653→\\t// Claude Code and other JSONL-based agents\\n   654→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   655→}\\n   656→\\n   657→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   658→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   659→func extractUserPromptsFromLines(lines []string) []string {\\n   660→\\tvar prompts []string\\n   661→\\tfor _, line := range lines {\\n   662→\\t\\tline = strings.TrimSpace(line)\\n   663→\\t\\tif line == \\\"\\\" {\\n   664→\\t\\t\\tcontinue\\n   665→\\t\\t}\\n   666→\\n   667→\\t\\tvar entry map[string]interface{}\\n   668→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   669→\\t\\t\\tcontinue\\n   670→\\t\\t}\\n   671→\\n   672→\\t\\t// Check for user message:\\n   673→\\t\\t// - Claude Code uses \\\"type\\\": \\\"human\\\" or \\\"type\\\": \\\"user\\\"\\n   674→\\t\\t// - Cursor uses \\\"role\\\": \\\"user\\\"\\n   675→\\t\\tmsgType, _ := entry[\\\"type\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   676→\\t\\tmsgRole, _ := entry[\\\"role\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   677→\\t\\tisUser := msgType == \\\"human\\\" || msgType == \\\"user\\\" || msgRole == \\\"user\\\"\\n   678→\\t\\tif !isUser {\\n   679→\\t\\t\\tcontinue\\n   680→\\t\\t}\\n   681→\\n   682→\\t\\t// Extract message content\\n   683→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   684→\\t\\tif !ok {\\n   685→\\t\\t\\tcontinue\\n   686→\\t\\t}\\n   687→\\n   688→\\t\\t// Handle string content\\n   689→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   690→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   691→\\t\\t\\tif cleaned != \\\"\\\" {\\n   692→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   693→\\t\\t\\t}\\n   694→\\t\\t\\tcontinue\\n   695→\\t\\t}\\n   696→\\n   697→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   698→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   699→\\t\\t\\tvar texts []string\\n   700→\\t\\t\\tfor _, item := range arr {\\n   701→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   702→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   703→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   704→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   705→\\t\\t\\t\\t\\t\\t}\\n   706→\\t\\t\\t\\t\\t}\\n   707→\\t\\t\\t\\t}\\n   708→\\t\\t\\t}\\n   709→\\t\\t\\tif len(texts) > 0 {\\n   710→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   711→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   712→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   713→\\t\\t\\t\\t}\\n   714→\\t\\t\\t}\\n   715→\\t\\t}\\n   716→\\t}\\n   717→\\treturn prompts\\n   718→}\\n   719→\\n   720→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   721→func generateContextFromPrompts(prompts []string) []byte {\\n   722→\\tif len(prompts) == 0 {\\n   723→\\t\\treturn nil\\n   724→\\t}\\n   725→\\n   726→\\tvar buf strings.Builder\\n   727→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   728→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   729→\\n   730→\\tfor i, prompt := range prompts {\\n   731→\\t\\t// Truncate very long prompts for readability.\\n   732→\\t\\t// Use rune-based truncation to avoid splitting multi-byte UTF-8 characters (e.g. CJK).\\n   733→\\t\\tconst maxDisplayPromptRunes = 500\\n   734→\\t\\tdisplayPrompt := stringutil.TruncateRunes(prompt, maxDisplayPromptRunes, \\\"...\\\")\\n   735→\\t\\tfmt.Fprintf(&buf, \\\"### Prompt %d\\\\n\\\\n\\\", i+1)\\n   736→\\t\\tbuf.WriteString(displayPrompt)\\n   737→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   738→\\t}\\n   739→\\n   740→\\treturn []byte(buf.String())\\n   741→}\\n   742→\\n   743→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   744→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   745→func (s *ManualCommitStrategy) CondenseSessionByID(ctx context.Context, sessionID string) error {\\n   746→\\tlogCtx := logging.WithComponent(ctx, \\\"condense-by-id\\\")\\n   747→\\n   748→\\t// Load session state\\n   749→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   750→\\tif err != nil {\\n   751→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   752→\\t}\\n   753→\\tif state == nil {\\n   754→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   755→\\t}\\n   756→\\n   757→\\t// Open repository\\n   758→\\trepo, err := OpenRepository(ctx)\\n   759→\\tif err != nil {\\n   760→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   761→\\t}\\n   762→\\n   763→\\t// Generate a checkpoint ID\\n   764→\\tcheckpointID, err := id.Generate()\\n   765→\\tif err != nil {\\n   766→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   767→\\t}\\n   768→\\n   769→\\t// Check if shadow branch exists (required for condensation)\\n   770→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   771→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   772→\\t_, refErr := repo.Reference(refName, true)\\n   773→\\thasShadowBranch := refErr == nil\\n   774→\\n   775→\\tif !hasShadowBranch {\\n   776→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   777→\\t\\t// Just clean up the state file.\\n   778→\\t\\tlogging.Info(logCtx, \\\"no shadow branch for session, clearing state only\\\",\\n   779→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   780→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   781→\\t\\t)\\n   782→\\t\\tif err := s.clearSessionState(ctx, sessionID); err != nil {\\n   783→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   784→\\t\\t}\\n   785→\\t\\treturn nil\\n   786→\\t}\\n   787→\\n   788→\\t// Condense the session\\n   789→\\tresult, err := s.CondenseSession(ctx, repo, checkpointID, state, nil)\\n   790→\\tif err != nil {\\n   791→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   792→\\t}\\n   793→\\n   794→\\tlogging.Info(logCtx, \\\"session condensed by ID\\\",\\n   795→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   796→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   797→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   798→\\t)\\n   799→\\n   800→\\t// Update session state: reset step count and transition to idle\\n   801→\\tstate.StepCount = 0\\n   802→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   803→\\tstate.Phase = session.PhaseIdle\\n   804→\\tstate.LastCheckpointID = checkpointID\\n   805→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   806→\\tstate.PromptAttributions = nil\\n   807→\\tstate.PendingPromptAttribution = nil\\n   808→\\n   809→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   810→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   811→\\t}\\n   812→\\n   813→\\t// Clean up shadow branch if no other sessions need it\\n   814→\\tif err := s.cleanupShadowBranchIfUnused(ctx, repo, shadowBranchName, sessionID); err != nil {\\n   815→\\t\\tlogging.Warn(logCtx, \\\"failed to clean up shadow branch\\\",\\n   816→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   817→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   818→\\t\\t)\\n   819→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   820→\\t}\\n   821→\\n   822→\\treturn nil\\n   823→}\\n   824→\\n   825→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   826→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(ctx context.Context, _ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   827→\\t// List all session states to check if any other session uses this shadow branch\\n   828→\\tallStates, err := s.listAllSessionStates(ctx)\\n   829→\\tif err != nil {\\n   830→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   831→\\t}\\n   832→\\n   833→\\tfor _, state := range allStates {\\n   834→\\t\\tif state.SessionID == excludeSessionID {\\n   835→\\t\\t\\tcontinue\\n   836→\\t\\t}\\n   837→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   838→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   839→\\t\\t\\t// Another session still needs this shadow branch\\n   840→\\t\\t\\treturn nil\\n   841→\\t\\t}\\n   842→\\t}\\n   843→\\n   844→\\t// No other sessions need it, delete the shadow branch via CLI\\n   845→\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n   846→\\tif err := DeleteBranchCLI(ctx, shadowBranchName); err != nil {\\n   847→\\t\\t// Branch already gone is not an error\\n   848→\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n   849→\\t\\t\\treturn nil\\n   850→\\t\\t}\\n   851→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n   852→\\t}\\n   853→\\treturn nil\\n   854→}\\n   855→\"}]},\"uuid\":\"7b2ed243-3872-40a5-b58c-70621f2579af\",\"timestamp\":\"2026-03-03T22:29:20.904Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alex/workspace/cli/.worktrees/3/cmd/entire/cli/strategy/manual_commit_condensation.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/factoryaidroid\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/opencode\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/stringutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// listCheckpoints returns all checkpoints from the metadata branch.\\n// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) listCheckpoints(ctx context.Context) ([]CheckpointInfo, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcommitted, err := store.ListCommitted(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n\\t}\\n\\n\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n\\tresult := make([]CheckpointInfo, 0, len(committed))\\n\\tfor _, c := range committed {\\n\\t\\tresult = append(result, CheckpointInfo{\\n\\t\\t\\tCheckpointID:     c.CheckpointID,\\n\\t\\t\\tSessionID:        c.SessionID,\\n\\t\\t\\tCreatedAt:        c.CreatedAt,\\n\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n\\t\\t\\tFilesTouched:     c.FilesTouched,\\n\\t\\t\\tAgent:            c.Agent,\\n\\t\\t\\tIsTask:           c.IsTask,\\n\\t\\t\\tToolUseID:        c.ToolUseID,\\n\\t\\t\\tSessionCount:     c.SessionCount,\\n\\t\\t\\tSessionIDs:       c.SessionIDs,\\n\\t\\t})\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointsForSession returns all checkpoints for a session ID.\\nfunc (s *ManualCommitStrategy) getCheckpointsForSession(ctx context.Context, sessionID string) ([]CheckpointInfo, error) {\\n\\tall, err := s.listCheckpoints(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tvar result []CheckpointInfo\\n\\tfor _, cp := range all {\\n\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n\\t\\t\\tresult = append(result, cp)\\n\\t\\t}\\n\\t}\\n\\n\\tif len(result) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) getCheckpointLog(ctx context.Context, checkpointID id.CheckpointID) ([]byte, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(ctx, checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// condenseOpts provides pre-resolved git objects to avoid redundant reads.\\ntype condenseOpts struct {\\n\\tshadowRef *plumbing.Reference // Pre-resolved shadow branch ref (nil = resolve from repo)\\n\\theadTree  *object.Tree        // Pre-resolved HEAD tree (passed through to calculateSessionAttributions)\\n}\\n\\n// CondenseSession condenses a session's shadow branch to permanent storage.\\n// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n//\\n// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n// In this case, data is extracted from the live transcript instead.\\nfunc (s *ManualCommitStrategy) CondenseSession(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}, opts ...condenseOpts) (*CondenseResult, error) {\\n\\tcondenseStart := time.Now()\\n\\tlogCtx := logging.WithComponent(ctx, \\\"condense-timing\\\")\\n\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n\\tvar o condenseOpts\\n\\tif len(opts) > 0 {\\n\\t\\to = opts[0]\\n\\t}\\n\\n\\t// Get shadow branch — use pre-resolved ref if available, otherwise resolve from repo.\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\tref := o.shadowRef\\n\\tvar hasShadowBranch bool\\n\\tif ref != nil {\\n\\t\\thasShadowBranch = true\\n\\t} else {\\n\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\t\\tvar err error\\n\\t\\tref, err = repo.Reference(refName, true)\\n\\t\\thasShadowBranch = err == nil\\n\\t}\\n\\n\\tt0 := time.Now()\\n\\tvar sessionData *ExtractedSessionData\\n\\tif hasShadowBranch {\\n\\t\\tvar extractErr error\\n\\t\\tsessionData, extractErr = s.extractSessionData(ctx, repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n\\t\\tif extractErr != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", extractErr)\\n\\t\\t}\\n\\t} else {\\n\\t\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n\\t\\t}\\n\\t\\tif state.Phase.IsActive() {\\n\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, state.TranscriptPath)\\n\\t\\t}\\n\\t\\tvar extractErr error\\n\\t\\tsessionData, extractErr = s.extractSessionDataFromLiveTranscript(ctx, state)\\n\\t\\tif extractErr != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", extractErr)\\n\\t\\t}\\n\\t}\\n\\tlogging.Info(logCtx, \\\"CondenseSession: timing\\\",\\n\\t\\tslog.String(\\\"phase\\\", \\\"extractSessionData\\\"),\\n\\t\\tslog.Duration(\\\"elapsed\\\", time.Since(t0)),\\n\\t\\tslog.Bool(\\\"has_shadow_branch\\\", hasShadowBranch),\\n\\t\\tslog.Int(\\\"transcript_bytes\\\", len(sessionData.Transcript)),\\n\\t)\\n\\n\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n\\t// committed in this specific commit. This ensures each checkpoint represents\\n\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n\\tif len(committedFiles) > 0 {\\n\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n\\n\\t\\tif hadFilesBeforeFiltering {\\n\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tsessionData.FilesTouched = filtered\\n\\t\\t}\\n\\n\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n\\t\\t\\tfor f := range committedFiles {\\n\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Get checkpoint store\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get author info\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n\\n\\tt1 := time.Now()\\n\\tattribution := calculateSessionAttributions(ctx, repo, ref, sessionData, state, attributionOpts{\\n\\t\\theadTree: o.headTree,\\n\\t})\\n\\tlogging.Info(logCtx, \\\"CondenseSession: timing\\\",\\n\\t\\tslog.String(\\\"phase\\\", \\\"calculateAttribution\\\"),\\n\\t\\tslog.Duration(\\\"elapsed\\\", time.Since(t1)),\\n\\t)\\n\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Generate summary if enabled\\n\\tvar summary *cpkg.Summary\\n\\tif settings.IsSummarizeEnabled(ctx) && len(sessionData.Transcript) > 0 {\\n\\t\\tt2 := time.Now()\\n\\t\\tsummarizeCtx := logging.WithComponent(ctx, \\\"summarize\\\")\\n\\n\\t\\tvar scopedTranscript []byte\\n\\t\\tswitch state.AgentType {\\n\\t\\tcase agent.AgentTypeGemini:\\n\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t\\tif sliceErr != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n\\t\\t\\t}\\n\\t\\t\\tscopedTranscript = scoped\\n\\t\\tcase agent.AgentTypeOpenCode:\\n\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t\\tif sliceErr != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n\\t\\t\\t}\\n\\t\\t\\tscopedTranscript = scoped\\n\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeFactoryAIDroid, agent.AgentTypeUnknown:\\n\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t}\\n\\t\\tif len(scopedTranscript) > 0 {\\n\\t\\t\\tvar err error\\n\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n\\t\\t\\t}\\n\\t\\t}\\n\\t\\tlogging.Info(logCtx, \\\"CondenseSession: timing\\\",\\n\\t\\t\\tslog.String(\\\"phase\\\", \\\"summarize\\\"),\\n\\t\\t\\tslog.Duration(\\\"elapsed\\\", time.Since(t2)),\\n\\t\\t)\\n\\t}\\n\\n\\t// Write checkpoint metadata using the checkpoint store\\n\\tt3 := time.Now()\\n\\tif err := store.WriteCommitted(ctx, cpkg.WriteCommittedOptions{\\n\\t\\tCheckpointID:                checkpointID,\\n\\t\\tSessionID:                   state.SessionID,\\n\\t\\tStrategy:                    StrategyNameManualCommit,\\n\\t\\tBranch:                      branchName,\\n\\t\\tTranscript:                  sessionData.Transcript,\\n\\t\\tPrompts:                     sessionData.Prompts,\\n\\t\\tContext:                     sessionData.Context,\\n\\t\\tFilesTouched:                sessionData.FilesTouched,\\n\\t\\tCheckpointsCount:            state.StepCount,\\n\\t\\tEphemeralBranch:             shadowBranchName,\\n\\t\\tAuthorName:                  authorName,\\n\\t\\tAuthorEmail:                 authorEmail,\\n\\t\\tAgent:                       state.AgentType,\\n\\t\\tTurnID:                      state.TurnID,\\n\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n\\t\\tInitialAttribution:          attribution,\\n\\t\\tSummary:                     summary,\\n\\t}); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n\\t}\\n\\tlogging.Info(logCtx, \\\"CondenseSession: timing\\\",\\n\\t\\tslog.String(\\\"phase\\\", \\\"WriteCommitted\\\"),\\n\\t\\tslog.Duration(\\\"elapsed\\\", time.Since(t3)),\\n\\t)\\n\\n\\tlogging.Info(logCtx, \\\"CondenseSession: timing\\\",\\n\\t\\tslog.String(\\\"phase\\\", \\\"total\\\"),\\n\\t\\tslog.Duration(\\\"elapsed\\\", time.Since(condenseStart)),\\n\\t)\\n\\n\\treturn &CondenseResult{\\n\\t\\tCheckpointID:         checkpointID,\\n\\t\\tSessionID:            state.SessionID,\\n\\t\\tCheckpointsCount:     state.StepCount,\\n\\t\\tFilesTouched:         sessionData.FilesTouched,\\n\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n\\t}, nil\\n}\\n\\n// attributionOpts provides pre-resolved git objects to avoid redundant reads.\\ntype attributionOpts struct {\\n\\theadTree   *object.Tree // HEAD commit tree (already resolved by PostCommit)\\n\\tshadowTree *object.Tree // Shadow branch tree (already resolved by PostCommit)\\n}\\n\\nfunc calculateSessionAttributions(ctx context.Context, repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState, opts ...attributionOpts) *cpkg.InitialAttribution {\\n\\t// Calculate initial attribution using accumulated prompt attribution data.\\n\\t// This uses user edits captured at each prompt start (before agent works),\\n\\t// plus any user edits after the final checkpoint (shadow → head).\\n\\t//\\n\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n\\tlogCtx := logging.WithComponent(ctx, \\\"attribution\\\")\\n\\n\\tvar o attributionOpts\\n\\tif len(opts) > 0 {\\n\\t\\to = opts[0]\\n\\t}\\n\\n\\theadTree := o.headTree\\n\\tif headTree == nil {\\n\\t\\theadRef, headErr := repo.Head()\\n\\t\\tif headErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n\\t\\tif commitErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\tvar treeErr error\\n\\t\\theadTree, treeErr = headCommit.Tree()\\n\\t\\tif treeErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t}\\n\\n\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n\\tshadowTree := o.shadowTree\\n\\tif shadowTree == nil {\\n\\t\\tif shadowRef != nil {\\n\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n\\t\\t\\tif shadowErr != nil {\\n\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n\\t\\t\\t\\treturn nil\\n\\t\\t\\t}\\n\\t\\t\\tvar shadowTreeErr error\\n\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n\\t\\t\\tif shadowTreeErr != nil {\\n\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n\\t\\t\\t\\treturn nil\\n\\t\\t\\t}\\n\\t\\t} else {\\n\\t\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n\\t\\t\\t// because the agent's work is the commit itself.\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n\\t\\t\\tshadowTree = headTree\\n\\t\\t}\\n\\t}\\n\\n\\t// Get base tree (state before session started)\\n\\tvar baseTree *object.Tree\\n\\tattrBase := state.AttributionBaseCommit\\n\\tif attrBase == \\\"\\\" {\\n\\t\\tattrBase = state.BaseCommit // backward compat\\n\\t}\\n\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n\\t\\t\\tbaseTree = tree\\n\\t\\t} else {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n\\t\\t}\\n\\t} else {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n\\t}\\n\\n\\t// Log accumulated prompt attributions for debugging\\n\\tvar totalUserAdded, totalUserRemoved int\\n\\tfor i, pa := range state.PromptAttributions {\\n\\t\\ttotalUserAdded += pa.UserLinesAdded\\n\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"index\\\", i))\\n\\t}\\n\\n\\tattribution := CalculateAttributionWithAccumulated(\\n\\t\\tctx,\\n\\t\\tbaseTree,\\n\\t\\tshadowTree,\\n\\t\\theadTree,\\n\\t\\tsessionData.FilesTouched,\\n\\t\\tstate.PromptAttributions,\\n\\t)\\n\\n\\tif attribution != nil {\\n\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n\\t}\\n\\n\\treturn attribution\\n}\\n\\n// extractSessionData extracts session data from the shadow branch.\\n// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n// continued growing — the shadow branch copy would be stale.\\n// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\nfunc (s *ManualCommitStrategy) extractSessionData(ctx context.Context, repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType types.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n\\tag, _ := agent.GetByAgentType(agentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n\\tcommit, err := repo.CommitObject(shadowRef)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\tdata := &ExtractedSessionData{}\\n\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\n\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n\\t// (SaveStep is only called when there are file modifications).\\n\\tvar fullTranscript string\\n\\tif liveTranscriptPath != \\\"\\\" {\\n\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n\\t\\tif isActive {\\n\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, liveTranscriptPath)\\n\\t\\t}\\n\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n\\t\\t\\tfullTranscript = string(liveData)\\n\\t\\t}\\n\\t}\\n\\tif fullTranscript == \\\"\\\" {\\n\\t\\t// Fall back to shadow branch copy\\n\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Process transcript based on agent type\\n\\tif fullTranscript != \\\"\\\" {\\n\\t\\tdata.Transcript = []byte(fullTranscript)\\n\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\t}\\n\\n\\t// Use tracked files from session state (not all files in tree)\\n\\tdata.FilesTouched = filesTouched\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ctx, ag, data.Transcript, checkpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n// This is used for mid-session commits where no shadow branch exists yet.\\nfunc (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(ctx context.Context, state *SessionState) (*ExtractedSessionData, error) {\\n\\tdata := &ExtractedSessionData{}\\n\\n\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n\\n\\t// Read the live transcript\\n\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n\\t}\\n\\n\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n\\t}\\n\\n\\tif len(liveData) == 0 {\\n\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n\\t}\\n\\n\\tfullTranscript := string(liveData)\\n\\tdata.Transcript = liveData\\n\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\n\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n\\t// (no SaveStep/Stop has been called yet to populate it)\\n\\tif len(state.FilesTouched) > 0 {\\n\\t\\tdata.FilesTouched = state.FilesTouched\\n\\t} else {\\n\\t\\t// Use the shared helper which includes subagent transcripts\\n\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(ctx, state, state.CheckpointTranscriptStart)\\n\\t}\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ctx, ag, data.Transcript, state.CheckpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// countTranscriptIte