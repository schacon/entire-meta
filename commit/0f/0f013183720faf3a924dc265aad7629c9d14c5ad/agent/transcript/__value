& state.Phase.IsActive() && state.TranscriptPath != \\\"\\\" {\\n   905→\\t\\tfilesTouchedBefore = s.extractFilesFromLiveTranscript(ctx, state)\\n   906→\\t}\\n   907→\\n   908→\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward prep\\\",\\n   909→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   910→\\t\\tslog.Bool(\\\"is_active\\\", state.Phase.IsActive()),\\n   911→\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n   912→\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   913→\\t\\tslog.Any(\\\"files\\\", filesTouchedBefore),\\n   914→\\t)\\n   915→\\n   916→\\t// Run the state machine transition with handler for strategy-specific actions.\\n   917→\\thandler := &postCommitActionHandler{\\n   918→\\t\\ts:                      s,\\n   919→\\t\\tctx:                    ctx,\\n   920→\\t\\trepo:                   repo,\\n   921→\\t\\tcheckpointID:           checkpointID,\\n   922→\\t\\thead:                   head,\\n   923→\\t\\tcommit:                 commit,\\n   924→\\t\\tnewHead:                newHead,\\n   925→\\t\\tshadowBranchName:       shadowBranchName,\\n   926→\\t\\tshadowBranchesToDelete: shadowBranchesToDelete,\\n   927→\\t\\tcommittedFileSet:       committedFileSet,\\n   928→\\t\\thasNew:                 hasNew,\\n   929→\\t\\tfilesTouchedBefore:     filesTouchedBefore,\\n   930→\\t\\theadTree:               headTree,\\n   931→\\t\\tparentTree:             parentTree,\\n   932→\\t\\tshadowRef:              shadowRef,\\n   933→\\t\\tshadowTree:             shadowTree,\\n   934→\\t}\\n   935→\\n   936→\\tif err := TransitionAndLog(ctx, state, session.EventGitCommit, *transitionCtx, handler); err != nil {\\n   937→\\t\\tlogging.Warn(logCtx, \\\"post-commit action handler error\\\",\\n   938→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   939→\\t}\\n   940→\\n   941→\\t// Record checkpoint ID for ACTIVE sessions so HandleTurnEnd can finalize\\n   942→\\t// with full transcript. IDLE/ENDED sessions already have complete transcripts.\\n   943→\\t// NOTE: This check runs AFTER TransitionAndLog updated the phase. It relies on\\n   944→\\t// ACTIVE + GitCommit → ACTIVE (phase stays ACTIVE). If that state machine\\n   945→\\t// transition ever changed, this guard would silently stop recording IDs.\\n   946→\\tif handler.condensed && state.Phase.IsActive() {\\n   947→\\t\\tstate.TurnCheckpointIDs = append(state.TurnCheckpointIDs, checkpointID.String())\\n   948→\\t}\\n   949→\\n   950→\\t// Carry forward remaining uncommitted files so the next commit gets its\\n   951→\\t// own checkpoint ID. This applies to ALL phases — if a user splits their\\n   952→\\t// commit across two `git commit` invocations, each gets a 1:1 checkpoint.\\n   953→\\t// Uses content-aware comparison: if user did `git add -p` and committed\\n   954→\\t// partial changes, the file still has remaining agent changes to carry forward.\\n   955→\\tif handler.condensed {\\n   956→\\t\\tremainingFiles := filesWithRemainingAgentChanges(ctx, repo, shadowBranchName, commit, filesTouchedBefore, committedFileSet, overlapOpts{\\n   957→\\t\\t\\theadTree:   headTree,\\n   958→\\t\\t\\tshadowTree: shadowTree,\\n   959→\\t\\t})\\n   960→\\t\\tstate.FilesTouched = remainingFiles\\n   961→\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward decision (content-aware)\\\",\\n   962→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   963→\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   964→\\t\\t\\tslog.Int(\\\"committed_files\\\", len(committedFileSet)),\\n   965→\\t\\t\\tslog.Int(\\\"remaining_files\\\", len(remainingFiles)),\\n   966→\\t\\t\\tslog.Any(\\\"remaining\\\", remainingFiles),\\n   967→\\t\\t\\tslog.Any(\\\"committed_files\\\", committedFileSet),\\n   968→\\t\\t)\\n   969→\\t\\tif len(remainingFiles) > 0 {\\n   970→\\t\\t\\ts.carryForwardToNewShadowBranch(ctx, repo, state, remainingFiles)\\n   971→\\t\\t}\\n   972→\\t}\\n   973→\\n   974→\\t// Mark