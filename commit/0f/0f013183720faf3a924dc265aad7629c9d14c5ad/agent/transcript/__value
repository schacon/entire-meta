\\n    17→\\n    18→// Shadow strategy session state methods.\\n    19→// Uses session.StateStore for persistence.\\n    20→\\n    21→// loadSessionState loads session state using the StateStore.\\n    22→func (s *ManualCommitStrategy) loadSessionState(ctx context.Context, sessionID string) (*SessionState, error) {\\n    23→\\tstore, err := s.getStateStore(ctx)\\n    24→\\tif err != nil {\\n    25→\\t\\treturn nil, err\\n    26→\\t}\\n    27→\\tstate, err := store.Load(ctx, sessionID)\\n    28→\\tif err != nil {\\n    29→\\t\\treturn nil, fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n    30→\\t}\\n    31→\\treturn state, nil\\n    32→}\\n    33→\\n    34→// saveSessionState saves session state using the StateStore.\\n    35→func (s *ManualCommitStrategy) saveSessionState(ctx context.Context, state *SessionState) error {\\n    36→\\tstore, err := s.getStateStore(ctx)\\n    37→\\tif err != nil {\\n    38→\\t\\treturn err\\n    39→\\t}\\n    40→\\tif err := store.Save(ctx, state); err != nil {\\n    41→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n    42→\\t}\\n    43→\\treturn nil\\n    44→}\\n    45→\\n    46→// clearSessionState clears session state using the StateStore.\\n    47→func (s *ManualCommitStrategy) clearSessionState(ctx context.Context, sessionID string) error {\\n    48→\\tstore, err := s.getStateStore(ctx)\\n    49→\\tif err != nil {\\n    50→\\t\\treturn err\\n    51→\\t}\\n    52→\\tif err := store.Clear(ctx, sessionID); err != nil {\\n    53→\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n    54→\\t}\\n    55→\\treturn nil\\n    56→}\\n    57→\\n    58→// listAllSessionStates returns all active session states.\\n    59→// It filters out orphaned sessions whose shadow branch no longer exists.\\n    60→func (s *ManualCommitStrategy) listAllSessionStates(ctx context.Context) ([]*SessionState, error) {\\n    61→\\tstore, err := s.getStateStore(ctx)\\n    62→\\tif err != nil {\\n    63→\\t\\treturn nil, fmt.Errorf(\\\"failed to get state store: %w\\\", err)\\n    64→\\t}\\n    65→\\n    66→\\tsessionStates, err := store.List(ctx)\\n    67→\\tif err != nil {\\n    68→\\t\\treturn nil, fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n    69→\\t}\\n    70→\\n    71→\\tif len(sessionStates) == 0 {\\n    72→\\t\\treturn nil, nil\\n    73→\\t}\\n    74→\\n    75→\\trepo, err := OpenRepository(ctx)\\n    76→\\tif err != nil {\\n    77→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n    78→\\t}\\n    79→\\n    80→\\tvar states []*SessionState\\n    81→\\tfor _, sessionState := range sessionStates {\\n    82→\\t\\tstate := sessionState\\n    83→\\n    84→\\t\\t// Skip and cleanup orphaned sessions whose shadow branch no longer exists.\\n    85→\\t\\t// Keep active sessions (shadow branch may not be created yet) and sessions\\n    86→\\t\\t// with LastCheckpointID (needed for checkpoint ID reuse on subsequent commits).\\n    87→\\t\\t// Clean up everything else: stale pre-state-machine sessions (empty phase),\\n    88→\\t\\t// IDLE/ENDED sessions that were never condensed, etc.\\n    89→\\t\\tshadowBranch := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n    90→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranch)\\n    91→\\t\\tif _, err := repo.Reference(refName, true); err != nil {\\n    92→\\t\\t\\tif !state.Phase.IsActive() && state.LastCheckpointID.IsEmpty() {\\n    93→\\t\\t\\t\\t//nolint:errcheck,gosec // G104: Cleanup is best-effort, shouldn't fail the list operation\\n    94→\\t\\t\\t\\tstore.Clear(ctx, state.SessionID)\\n    95→\\t\\t\\t\\tcontinue\\n    96→\\t\\t\\t}\\n    97→\\t\\t}\\n    98→\\n    99→\\t\\tstates = append(states, state)\\n   100→\\t}\\n   101→\\treturn states, nil\\n   102→}\\n   103→\\n   104→// findSessionsForWorktree finds all sessions for the given worktree path.\\n   105→func (s *ManualCommitStrategy) findSessionsForWorktree(ctx context.Context, worktreePath string) ([]*SessionState, error) {\\n   106→\\tallStates, err := s.listAllSessionStates(ctx)\\n   107→\\tif err != nil {\\n   108→\\t\\treturn nil, err\\n   109→\\t}\\n   110→\\n   111→\\tvar matching []*SessionState\\n   112→\\tfor _, state := range allStates {\\n   113→\\t\\tif state.WorktreePath == worktreePath {\\n   114→\\t\\t\\tmatching = append(matching, state)\\n   115→\\t\\t}\\n   116→\\t}\\n   117→\\treturn matching, nil\\n   118→}\\n   119→\\n   120→// findSessionsForCommit finds all sessions where base_commit matches the given SHA.\\n   121→func (s *ManualCommitStrategy) findSessionsForCommit(ctx context.Context, baseCommitSHA string) ([]*SessionState, error) {\\n   122→\\tallStates, err := s.listAllSessionStates(ctx)\\n   123→\\tif err != nil {\\n   124→\\t\\treturn nil, err\\n   125→\\t}\\n   126→\\n   127→\\tvar matching []*SessionState\\n   128→\\tfor _, state := range allStates {\\n   129→\\t\\tif state.BaseCommit == baseCommitSHA {\\n   130→\\t\\t\\tmatching = append(matching, state)\\n   131→\\t\\t}\\n   132→\\t}\\n   133→\\treturn matching, nil\\n   134→}\\n   135→\\n   136→// FindSessionsForCommit is the exported version of findSessionsForCommit.\\n   137→// Used by the rewind reset command to find sessions to clean up.\\n   138→func (s *ManualCommitStrategy) FindSessionsForCommit(ctx context.Context, baseCommitSHA string) ([]*SessionState, error) {\\n   139→\\treturn s.findSessionsForCommit(ctx, baseCommitSHA)\\n   140→}\\n   141→\\n   142→// ClearSessionState is the exported version of clearSessionState.\\n   143→// Used by the rewind reset command to clean up session state files.\\n   144→func (s *ManualCommitStrategy) ClearSessionState(ctx context.Context, sessionID string) error {\\n   145→\\treturn s.clearSessionState(ctx, sessionID)\\n   146→}\\n   147→\\n   148→// CountOtherActiveSessionsWithCheckpoints counts how many other active sessions\\n   149→// from the SAME worktree (different from currentSessionID) have created checkpoints\\n   150→// on the SAME base commit (current HEAD). This is used to show an informational message\\n   151→// about concurrent sessions that will be included in the next commit.\\n   152→// Returns 0, nil if no such sessions exist.\\n   153→func (s *ManualCommitStrategy) CountOtherActiveSessionsWithCheckpoints(ctx context.Context, currentSessionID string) (int, error) {\\n   154→\\tcurrentWorktree, err := paths.WorktreeRoot(ctx)\\n   155→\\tif err != nil {\\n   156→\\t\\treturn 0, fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   157→\\t}\\n   158→\\n   159→\\t// Get current HEAD to compare with session base commits\\n   160→\\trepo, err := OpenRepository(ctx)\\n   161→\\tif err != nil {\\n   162→\\t\\treturn 0, err\\n   163→\\t}\\n   164→\\thead, err := repo.Head()\\n   165→\\tif err != nil {\\n   166→\\t\\treturn 0, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   167→\\t}\\n   168→\\tcurrentHead := head.Hash().String()\\n   169→\\n   170→\\tallStates, err := s.listAllSessionStates(ctx)\\n   171→\\tif err != nil {\\n   172→\\t\\treturn 0, err\\n   173→\\t}\\n   174→\\n   175→\\tcount := 0\\n   176→\\tfor _, state := range allStates {\\n   177→\\t\\t// Only consider sessions from the same worktree with checkpoints\\n   178→\\t\\t// AND based on the same commit (current HEAD)\\n   179→\\t\\t// Sessions from different base commits are independent and shouldn't be counted\\n   180→\\t\\tif state.SessionID != currentSessionID &&\\n   181→\\t\\t\\tstate.WorktreePath == currentWorktree &&\\n   182→\\t\\t\\tstate.StepCount > 0 &&\\n   183→\\t\\t\\tstate.BaseCommit == currentHead {\\n   184→\\t\\t\\tcount++\\n   185→\\t\\t}\\n   186→\\t}\\n   187→\\treturn count, nil\\n   188→}\\n   189→\\n   190→// initializeSession creates a new session state or updates a partial one.\\n   191→// A partial state may exist if the concurrent session warning was shown.\\n   192→// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n   193→// tr