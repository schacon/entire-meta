\\tEvent      string         `json:\\\"event\\\"`\\n    28→\\tDistinctID string         `json:\\\"distinct_id\\\"`\\n    29→\\tProperties map[string]any `json:\\\"properties\\\"`\\n    30→\\tTimestamp  time.Time      `json:\\\"timestamp\\\"`\\n    31→}\\n    32→\\n    33→// silentLogger suppresses PostHog log output - expected for CLI best-effort telemetry\\n    34→type silentLogger struct{}\\n    35→\\n    36→func (silentLogger) Logf(_ string, _ ...interface{})   {}\\n    37→func (silentLogger) Debugf(_ string, _ ...interface{}) {}\\n    38→func (silentLogger) Warnf(_ string, _ ...interface{})  {}\\n    39→func (silentLogger) Errorf(_ string, _ ...interface{}) {}\\n    40→\\n    41→// BuildEventPayload constructs the event payload for tracking.\\n    42→// Exported for testing. Returns nil if the payload cannot be built.\\n    43→func BuildEventPayload(cmd *cobra.Command, agent string, isEntireEnabled bool, version string) *EventPayload {\\n    44→\\tif cmd == nil {\\n    45→\\t\\treturn nil\\n    46→\\t}\\n    47→\\n    48→\\t// Get machine ID for distinct_id\\n    49→\\tmachineID, err := machineid.ProtectedID(\\\"entire-cli\\\")\\n    50→\\tif err != nil {\\n    51→\\t\\treturn nil\\n    52→\\t}\\n    53→\\n    54→\\t// Collect flag names (not values) for privacy\\n    55→\\tvar flags []string\\n    56→\\tcmd.Flags().Visit(func(flag *pflag.Flag) {\\n    57→\\t\\tflags = append(flags, flag.Name)\\n    58→\\t})\\n    59→\\n    60→\\tselectedAgent := agent\\n    61→\\tif selectedAgent == \\\"\\\" {\\n    62→\\t\\tselectedAgent = \\\"auto\\\"\\n    63→\\t}\\n    64→\\n    65→\\tproperties := map[string]any{\\n    66→\\t\\t\\\"command\\\":         cmd.CommandPath(),\\n    67→\\t\\t\\\"agent\\\":           selectedAgent,\\n    68→\\t\\t\\\"isEntireEnabled\\\": isEntireEnabled,\\n    69→\\t\\t\\\"cli_version\\\":     version,\\n    70→\\t\\t\\\"os\\\":              runtime.GOOS,\\n    71→\\t\\t\\\"arch\\\":            runtime.GOARCH,\\n    72→\\t}\\n    73→\\n    74→\\tif len(flags) > 0 {\\n    75→\\t\\tproperties[\\\"flags\\\"] = strings.Join(flags, \\\",\\\")\\n    76→\\t}\\n    77→\\n    78→\\treturn &EventPayload{\\n    79→\\t\\tEvent:      \\\"cli_command_executed\\\",\\n    80→\\t\\tDistinctID: machineID,\\n    81→\\t\\tProperties: properties,\\n    82→\\t\\tTimestamp:  time.Now(),\\n    83→\\t}\\n    84→}\\n    85→\\n    86→// TrackCommandDetached tracks a command execution by spawning a detached subprocess.\\n    87→// This returns immediately without blocking the CLI.\\n    88→func TrackCommandDetached(cmd *cobra.Command, agent string, isEntireEnabled bool, version string) {\\n    89→\\t// Check opt-out environment variables\\n    90→\\tif os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n    91→\\t\\treturn\\n    92→\\t}\\n    93→\\n    94→\\tif cmd == nil {\\n    95→\\t\\treturn\\n    96→\\t}\\n    97→\\n    98→\\tif cmd.Hidden {\\n    99→\\t\\treturn\\n   100→\\t}\\n   101→\\n   102→\\tpayload := BuildEventPayload(cmd, agent, isEntireEnabled, version)\\n   103→\\tif payload == nil {\\n   104→\\t\\treturn\\n   105→\\t}\\n   106→\\n   107→\\tif payloadJSON, err := json.Marshal(payload); err == nil {\\n   108→\\t\\tspawnDetachedAnalytics(string(payloadJSON))\\n   109→\\t}\\n   110→}\\n   111→\\n   112→// SendEvent processes an event payload in the detached subprocess.\\n   113→// This is called by the hidden __send_analytics command.\\n   114→func SendEvent(payloadJSON string) {\\n   115→\\tvar payload EventPayload\\n   116→\\tif err := json.Unmarshal([]byte(payloadJSON), &payload); err != nil {\\n   117→\\t\\treturn\\n   118→\\t}\\n   119→\\n   120→\\t// Create PostHog client - no need for fast timeouts since we're detached\\n   121→\\t// Read API key and endpoint from package-level vars (not passed via argv for security)\\n   122→\\tclient, err := posthog.NewWithConfig(PostHogAPIKey, posthog.Config{\\n   123→\\t\\tEndpoint:     PostHogEndpoint,\\n   124→\\t\\tLogger:       silentLogger{},\\n   125→\\t\\tDisable