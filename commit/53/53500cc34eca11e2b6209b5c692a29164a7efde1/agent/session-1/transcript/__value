    36→\\t// Can be overridden by ENTIRE_LOG_LEVEL environment variable.\\n    37→\\t// Defaults to \\\"info\\\".\\n    38→\\tLogLevel string `json:\\\"log_level,omitempty\\\"`\\n    39→\\n    40→\\t// StrategyOptions contains strategy-specific configuration\\n    41→\\tStrategyOptions map[string]any `json:\\\"strategy_options,omitempty\\\"`\\n    42→\\n    43→\\t// Telemetry controls anonymous usage analytics.\\n    44→\\t// nil = not asked yet (show prompt), true = opted in, false = opted out\\n    45→\\tTelemetry *bool `json:\\\"telemetry,omitempty\\\"`\\n    46→}\\n    47→\\n    48→// Load loads the Entire settings from .entire/settings.json,\\n    49→// then applies any overrides from .entire/settings.local.json if it exists.\\n    50→// Returns default settings if neither file exists.\\n    51→// Works correctly from any subdirectory within the repository.\\n    52→func Load() (*EntireSettings, error) {\\n    53→\\t// Get absolute paths for settings files\\n    54→\\tsettingsFileAbs, err := paths.AbsPath(EntireSettingsFile)\\n    55→\\tif err != nil {\\n    56→\\t\\tsettingsFileAbs = EntireSettingsFile // Fallback to relative\\n    57→\\t}\\n    58→\\tlocalSettingsFileAbs, err := paths.AbsPath(EntireSettingsLocalFile)\\n    59→\\tif err != nil {\\n    60→\\t\\tlocalSettingsFileAbs = EntireSettingsLocalFile // Fallback to relative\\n    61→\\t}\\n    62→\\n    63→\\t// Load base settings\\n    64→\\tsettings, err := loadFromFile(settingsFileAbs)\\n    65→\\tif err != nil {\\n    66→\\t\\treturn nil, fmt.Errorf(\\\"reading settings file: %w\\\", err)\\n    67→\\t}\\n    68→\\n    69→\\t// Apply local overrides if they exist\\n    70→\\tlocalData, err := os.ReadFile(localSettingsFileAbs) //nolint:gosec // path is from AbsPath or constant\\n    71→\\tif err != nil {\\n    72→\\t\\tif !os.IsNotExist(err) {\\n    73→\\t\\t\\treturn nil, fmt.Errorf(\\\"reading local settings file: %w\\\", err)\\n    74→\\t\\t}\\n    75→\\t\\t// Local file doesn't exist, continue without overrides\\n    76→\\t} else {\\n    77→\\t\\tif err := mergeJSON(settings, localData); err != nil {\\n    78→\\t\\t\\treturn nil, fmt.Errorf(\\\"merging local settings: %w\\\", err)\\n    79→\\t\\t}\\n    80→\\t}\\n    81→\\n    82→\\treturn settings, nil\\n    83→}\\n    84→\\n    85→// LoadFromFile loads settings from a specific file path without merging local overrides.\\n    86→// Returns default settings if the file doesn't exist.\\n    87→// Use this when you need to display individual settings files separately.\\n    88→func LoadFromFile(filePath string) (*EntireSettings, error) {\\n    89→\\treturn loadFromFile(filePath)\\n    90→}\\n    91→\\n    92→// loadFromFile loads settings from a specific file path.\\n    93→// Returns default settings if the file doesn't exist.\\n    94→func loadFromFile(filePath string) (*EntireSettings, error) {\\n    95→\\tsettings := &EntireSettings{\\n    96→\\t\\tEnabled: true, // Default to enabled\\n    97→\\t}\\n    98→\\n    99→\\tdata, err := os.ReadFile(filePath) //nolint:gosec // path is from caller\\n   100→\\tif err != nil {\\n   101→\\t\\tif os.IsNotExist(err) {\\n   102→\\t\\t\\treturn settings, nil\\n   103→\\t\\t}\\n   104→\\t\\treturn nil, fmt.Errorf(\\\"%w\\\", err)\\n   105→\\t}\\n   106→\\n   107→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   108→\\tdec.DisallowUnknownFields()\\n   109→\\tif err := dec.Decode(settings); err != nil {\\n   110→\\t\\treturn nil, fmt.Errorf(\\\"parsing settings file: %w\\\", err)\\n   111→\\t}\\n   112→\\n   113→\\treturn settings, nil\\n   114→}\\n   115→\\n   116→// mergeJSON merges JSON data into existing settings.\\n   117→// Only non-zero values from the JSON override existing settings.\\n   118→func mergeJSON(settings *EntireSettings, data []byte) error {\\n   119→\\t// First, validate that there are no unknown keys using strict decoding\\n   120→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   121→\\tdec.DisallowUnknownFields()\\n   122→\\tvar temp EntireSettings\\n   123→\\tif err := dec.Decode(&temp); err != nil {\\n   124→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   125→\\t}\\n   126→\\n   127→\\t// Parse into a map to check which fields are present\\n   128→\\tvar raw map[string]json.RawMessage\\n   129→\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   130→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   131→\\t}\\n   132→\\n   133→\\t// Override enabled if present\\n   134→\\tif enabledRaw, ok := raw[\\\"enabled\\\"]; ok {\\n   135→\\t\\tvar e bool\\n   136→\\t\\tif err := json.Unmarshal(enabledRaw, &e); err != nil {\\n   137→\\t\\t\\treturn fmt.Errorf(\\\"parsing enabled field: %w\\\", err)\\n   138→\\t\\t}\\n   139→\\t\\tsettings.Enabled = e\\n   140→\\t}\\n   141→\\n   142→\\t// Override local_dev if present\\n   143→\\tif localDevRaw, ok := raw[\\\"local_dev\\\"]; ok {\\n   144→\\t\\tvar ld bool\\n   145→\\t\\tif err := json.Unmarshal(localDevRaw, &ld); err != nil {\\n   146→\\t\\t\\treturn fmt.Errorf(\\\"parsing local_dev field: %w\\\", err)\\n   147→\\t\\t}\\n   148→\\t\\tsettings.LocalDev = ld\\n   149→\\t}\\n   150→\\n   151→\\t// Override log_level if present and non-empty\\n   152→\\tif logLevelRaw, ok := raw[\\\"log_level\\\"]; ok {\\n   153→\\t\\tvar ll string\\n   154→\\t\\tif err := json.Unmarshal(logLevelRaw, &ll); err != nil {\\n   155→\\t\\t\\treturn fmt.Errorf(\\\"parsing log_level field: %w\\\", err)\\n   156→\\t\\t}\\n   157→\\t\\tif ll != \\\"\\\" {\\n   158→\\t\\t\\tsettings.LogLevel = ll\\n   159→\\t\\t}\\n   160→\\t}\\n   161→\\n   162→\\t// Merge strategy_options if present\\n   163→\\tif optionsRaw, ok := raw[\\\"strategy_options\\\"]; ok {\\n   164→\\t\\tvar opts map[string]any\\n   165→\\t\\tif err := json.Unmarshal(optionsRaw, &opts); err != nil {\\n   166→\\t\\t\\treturn fmt.Errorf(\\\"parsing strategy_options field: %w\\\", err)\\n   167→\\t\\t}\\n   168→\\t\\tif settings.StrategyOptions == nil {\\n   169→\\t\\t\\tsettings.StrategyOptions = opts\\n   170→\\t\\t} else {\\n   171→\\t\\t\\tfor k, v := range opts {\\n   172→\\t\\t\\t\\tsettings.StrategyOptions[k] = v\\n   173→\\t\\t\\t}\\n   174→\\t\\t}\\n   175→\\t}\\n   176→\\n   177→\\t// Override telemetry if present\\n   178→\\tif telemetryRaw, ok := raw[\\\"telemetry\\\"]; ok {\\n   179→\\t\\tvar t bool\\n   180→\\t\\tif err := json.Unmarshal(telemetryRaw, &t); err != nil {\\n   181→\\t\\t\\treturn fmt.Errorf(\\\"parsing telemetry field: %w\\\", err)\\n   182→\\t\\t}\\n   183→\\t\\tsettings.Telemetry = &t\\n   184→\\t}\\n   185→\\n   186→\\treturn nil\\n   187→}\\n   188→\\n   189→// IsSummarizeEnabled checks if auto-summarize is enabled in settings.\\n   190→// Returns false by default if settings cannot be loaded or the key is missing.\\n   191→func IsSummarizeEnabled() bool {\\n   192→\\tsettings, err := Load()\\n   193→\\tif err != nil {\\n   194→\\t\\treturn false\\n   195→\\t}\\n   196→\\treturn settings.IsSummarizeEnabled()\\n   197→}\\n   198→\\n   199→// IsSummarizeEnabled checks if auto-summarize is enabled in this settings instance.\\n   200→func (s *EntireSettings) IsSummarizeEnabled() bool {\\n   201→\\tif s.StrategyOptions == nil {\\n   202→\\t\\treturn false\\n   203→\\t}\\n   204→\\tsummarizeOpts, ok := s.StrategyOptions[\\\"summarize\\\"].(map[string]any)\\n   205→\\tif !ok {\\n   206→\\t\\treturn false\\n   207→\\t}\\n   208→\\tenabled, ok := summarizeOpts[\\\"enabled\\\"].(bool)\\n   209→\\tif !ok {\\n   210→\\t\\treturn false\\n   211→\\t}\\n   212→\\treturn enabled\\n   213→}\\n   214→\\n   215→// IsPushSessionsDisabled checks if push_sessions is disabled in settings.\\n   216→// Returns true if push_sessions is explicitly set to false.\\n   217→func (s *EntireSettings) IsPushSessionsDisabled() bool {\\n   218→\\tif s.StrategyOptions == nil {\\n   219→\\t\\treturn false\\n   220→\\t}\\n   221→\\tval, exists := s.StrategyOptions[\\\"push_sessions\\\"]\\n   222→\\tif !exists {\\n   223→\\t\\treturn false\\n   224→\\t}\\n   225→\\tif boolV