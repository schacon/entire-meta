\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"session checkpoints won't work until you create your first commit.\\\")\\n    62→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout())\\n    63→\\t\\t\\t}\\n    64→\\n    65→\\t\\t\\t// Non-interactive mode if --agent flag is provided\\n    66→\\t\\t\\tif cmd.Flags().Changed(\\\"agent\\\") && agentName == \\\"\\\" {\\n    67→\\t\\t\\t\\tprintMissingAgentError(cmd.ErrOrStderr())\\n    68→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n    69→\\t\\t\\t}\\n    70→\\n    71→\\t\\t\\tif agentName != \\\"\\\" {\\n    72→\\t\\t\\t\\tag, err := agent.Get(agent.AgentName(agentName))\\n    73→\\t\\t\\t\\tif err != nil {\\n    74→\\t\\t\\t\\t\\tprintWrongAgentError(cmd.ErrOrStderr(), agentName)\\n    75→\\t\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"wrong agent name\\\"))\\n    76→\\t\\t\\t\\t}\\n    77→\\t\\t\\t\\treturn setupAgentHooksNonInteractive(cmd.OutOrStdout(), ag, localDev, forceHooks, skipPushSessions, telemetry)\\n    78→\\t\\t\\t}\\n    79→\\t\\t\\thasConfigFlags := forceHooks || skipPushSessions || !telemetry || useLocalSettings || useProjectSettings || localDev\\n    80→\\t\\t\\tif !hasConfigFlags {\\n    81→\\t\\t\\t\\tif fullyEnabled, agentDesc, configPath := isFullyEnabled(); fullyEnabled {\\n    82→\\t\\t\\t\\t\\tw := cmd.OutOrStdout()\\n    83→\\t\\t\\t\\t\\tfmt.Fprintln(w, \\\"Already enabled. Everything looks good.\\\")\\n    84→\\t\\t\\t\\t\\tfmt.Fprintln(w)\\n    85→\\t\\t\\t\\t\\tfmt.Fprintf(w, \\\"  Agent: %s\\\\n\\\", agentDesc)\\n    86→\\t\\t\\t\\t\\tfmt.Fprintf(w, \\\"  Config: %s\\\\n\\\", configPath)\\n    87→\\t\\t\\t\\t\\treturn nil\\n    88→\\t\\t\\t\\t}\\n    89→\\t\\t\\t}\\n    90→\\n    91→\\t\\t\\t// Detect or prompt for agents\\n    92→\\t\\t\\tagents, err := detectOrSelectAgent(cmd.OutOrStdout(), nil)\\n    93→\\t\\t\\tif err != nil {\\n    94→\\t\\t\\t\\treturn fmt.Errorf(\\\"agent selection failed: %w\\\", err)\\n    95→\\t\\t\\t}\\n    96→\\n    97→\\t\\t\\treturn runEnableInteractive(cmd.OutOrStdout(), agents, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry)\\n    98→\\t\\t},\\n    99→\\t}\\n   100→\\n   101→\\tcmd.Flags().BoolVar(&localDev, \\\"local-dev\\\", false, \\\"Use go run instead of entire binary for hooks\\\")\\n   102→\\tcmd.Flags().MarkHidden(\\\"local-dev\\\") //nolint:errcheck,gosec // flag is defined above\\n   103→\\tcmd.Flags().BoolVar(&ignoreUntracked, \\\"ignore-untracked\\\", false, \\\"Commit all new files without tracking pre-existing untracked files\\\")\\n   104→\\tcmd.Flags().MarkHidden(\\\"ignore-untracked\\\") //nolint:errcheck,gosec // flag is defined above\\n   105→\\tcmd.Flags().BoolVar(&useLocalSettings, \\\"local\\\", false, \\\"Write settings to .entire/settings.local.json instead of .entire/settings.json\\\")\\n   106→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Write settings to .entire/settings.json even if it already exists\\\")\\n   107→\\tcmd.Flags().StringVar(&agentName, \\\"agent\\\", \\\"\\\", \\\"Agent to setup hooks for (e.g., claude-code). Enables non-interactive mode.\\\")\\n   108→\\tcmd.Flags().BoolVarP(&forceHooks, \\\"force\\\", \\\"f\\\", false, \\\"Force reinstall hooks (removes existing Entire hooks first)\\\")\\n   109→\\tcmd.Flags().BoolVar(&skipPushSessions, \\\"skip-push-sessions\\\", false, \\\"Disable automatic pushing of session logs on git push\\\")\\n   110→\\tcmd.Flags().BoolVar(&telemetry, \\\"telemetry\\\", true, \\\"Enable anonymous usage analytics\\\")\\n   111→\\n   112→\\t// Provide a helpful error when --agent is used without a value\\n   113→\\tdefaultFlagErr := cmd.FlagErrorFunc()\\n   114→\\tcmd.SetFlagErrorFunc(func(c *cobra.Command, err error) error {\\n   115→\\t\\tvar valErr *pflag.ValueRequiredError\\n   116→\\t\\tif errors.As(err, &valErr) && valErr.GetSpecifiedName() == \\\"agent\\\" {\\n   117→\\t\\t\\tprintMissingAgentError(c.ErrOrStderr())\\n   118→\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n   119→\\t\\t}\\n   120→\\t\\treturn defaultFlagErr(c, err)\\n   121→\\t})\\n   122→\\n   123→\\t// Add subcommands for automation/testing\\n   124→\\tcmd.AddCommand(newSetupGitHookCmd())\\n   125→\\n   126→\\treturn cmd\\n   127→}\\n   128→\\n   129→func newDisableCmd() *cobra.Command {\\n   130→\\tvar useProjectSettings bool\\n   131→\\tvar uninstall bool\\n   132→\\tvar force bool\\n   133→\\n   134→\\tcmd := &cobra.Command{\\n   135→\\t\\tUse:   \\\"disable\\\",\\n   136→\\t\\tShort: \\\"Disable Entire in current project\\\",\\n   137→\\t\\tLong: `Disable Entire integrations in the current project.\\n   138→\\n   139→By default, this command will disable Entire. Hooks will exit silently and commands will\\n   140→show a disabled message.\\n   141→\\n   142→To completely remove Entire integrations from this repository, use --uninstall:\\n   143→  - .entire/ directory (settings, logs, metadata)\\n   144→  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\n   145→  - Session state files (.git/entire-sessions/)\\n   146→  - Shadow branches (entire/<hash>)\\n   147→  - Agent hooks (Claude Code, Gemini CLI)`,\\n   148→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   149→\\t\\t\\tif uninstall {\\n   150→\\t\\t\\t\\treturn runUninstall(cmd.OutOrStdout(), cmd.ErrOrStderr(), force)\\n   151→\\t\\t\\t}\\n   152→\\t\\t\\treturn runDisable(cmd.OutOrStdout(), useProjectSettings)\\n   153→\\t\\t},\\n   154→\\t}\\n   155→\\n   156→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Update .entire/settings.json instead of .entire/settings.local.json\\\")\\n   157→\\tcmd.Flags().BoolVar(&uninstall, \\\"uninstall\\\", false, \\\"Completely remove Entire from this repository\\\")\\n   158→\\tcmd.Flags().BoolVar(&force, \\\"force\\\", false, \\\"Skip confirmation prompt (use with --uninstall)\\\")\\n   159→\\n   160→\\treturn cmd\\n   161→}\\n   162→\\n   163→// isFullyEnabled checks whether Entire is already fully set up.\\n   164→// Returns whether it's fully enabled, and if so, the agent type display name and config file path.\\n   165→func isFullyEnabled() (enabled bool, agentDesc string, configPath string) {\\n   166→\\t// Check settings exist and Enabled == true\\n   167→\\ts, err := LoadEntireSettings()\\n   168→\\tif err != nil || !s.Enabled {\\n   169→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   170→\\t}\\n   171→\\n   172→\\t// Check any agent hooks installed (not just Claude Code — works with Gemini too)\\n   173→\\tinstalledAgents := GetAgentsWithHooksInstalled()\\n   174→\\tif len(installedAgents) == 0 {\\n   175→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   176→\\t}\\n   177→\\n   178→\\t// Check git hooks installed\\n   179→\\tif !strategy.IsGitHookInstalled() {\\n   180→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   181→\\t}\\n   182→\\n   183→\\t// Check .entire directory exists\\n   184→\\tif !checkEntireDirExists() {\\n   185→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   186→\\t}\\n   187→\\n   188→\\t// Determine agent description from first installed agent\\n   189→\\tdesc := string(installedAgents[0]) // fallback to agent name\\n   190→\\tif ag, err := agent.Get(installedAgents[0]); err == nil {\\n   191→\\t\\tdesc = string(ag.Type())\\n   192→\\t}\\n   193→\\n   194→\\t// Determine config path - check if local settings exists, otherwise show project settings\\n   195→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   196→\\tif err != nil {\\n   197→\\t\\tentireDirAbs = paths.EntireDir\\n   198→\\t}\\n   199→\\tconfigDisplay := configDisplayProject\\n   200→\\tlocalSettingsPath := filepath.Join(entireDirAbs, \\\"settings.local.json\\\")\\n   201→\\tif _, err := os.Stat(localSettingsPath); err == nil {\\n   202→\\t\\tconfigDisplay = configDisplayLocal\\n   203→\\t}\\n   204→\\n   205→\\treturn true, desc, configDisplay\\n   206→}\\n   207→\\n   208→// runEnableInteractive runs the interactive enable flow.\\n   209→// agents must be provided by the caller (via detectOrSelectAgent).\\n   210→// The isFullyEnabled check is handled by the caller before agent detection.\\n   211→func runEnableInteractive(w io.Writer, agents []agent.Agent, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry bool) error {\\n   212→\\t// Setup agent hooks for all selected agents\\n   213→\\tfor _, ag := range agents {\\n   214→\\t\\tif _, err := setupAgentHooks(ag, localDev, forceHooks); err != nil {\\n   215→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   216→\\t\\t}\\n   217→\\t}\\n   218→\\n   219→\\t// Setup .entire directory\\n   220→\\tif _, err := setupEntireDirectory(); err != nil {\\n   221→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   222→\\t}\\n   223→\\n   224→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   225→\\tsettings, err := LoadEntireSettings()\\n   226→\\tif err != nil {\\n   227→\\t\\t// If we can't load, start with defaults\\n   228→\\t\\tsettings = &EntireSettings{}\\n   229→\\t}\\n   230→\\t// Update the specific fields\\n   231→\\tsettings.LocalDev = localDev\\n   232→\\tsettings.Enabled = true\\n   233→\\n   234→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   235→\\tif skipPushSessions {\\n   236→\\t\\tif settings.StrategyOptions == nil {\\n   237→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   238→\\t\\t}\\n   239→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   240→\\t}\\n   241→\\n   242→\\t// Determine which settings file to write to\\n   243→\\t// First run always creates settings.json (no prompt)\\n   244→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   245→\\tif err != nil {\\n   246→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   247→\\t}\\n   248→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   249→\\n   250→\\tif showNotification {\\n   251→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   252→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   253→\\t}\\n   254→\\n   255→\\t// Helper to save settings to the appropriate file\\n   256→\\tsaveSettings := func() error {\\n   257→\\t\\tif shouldUseLocal {\\n   258→\\t\\t\\treturn SaveEntireSettingsLocal(settings)\\n   259→\\t\\t}\\n   260→\\t\\treturn SaveEntireSettings(settings)\\n   261→\\t}\\n   262→\\n   263→\\t// Save settings before telemetry prompt so config is persisted even if the user cancels\\n   264→\\tif err := saveSettings(); err != nil {\\n   265→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   266→\\t}\\n   267→\\n   268→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   269→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   270→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   271→\\t}\\n   272→\\tstrategy.CheckAndWarnHookManagers(w)\\n   273→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   274→\\n   275→\\tconfigDisplay := configDisplayProject\\n   276→\\tif shouldUseLocal {\\n   277→\\t\\tconfigDisplay = configDisplayLocal\\n   278→\\t}\\n   279→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   280→\\n   281→\\t// Ask about telemetry consent (only if not already asked)\\n   282→\\tfmt.Fprintln(w)\\n   283→\\tif err := promptTelemetryConsent(settings, telemetry); err != nil {\\n   284→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   285→\\t}\\n   286→\\t// Save again to persist telemetry choice\\n   287→\\tif err := saveSettings(); err != nil {\\n   288→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   289→\\t}\\n   290→\\n   291→\\tif err := strategy.EnsureSetup(); err != nil {\\n   292→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   293→\\t}\\n   294→\\n   295→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   296→\\n   297→\\treturn nil\\n   298→}\\n   299→\\n   300→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   301→func runEnable(w io.Writer) error {\\n   302→\\tsettings, err := LoadEntireSettings()\\n   303→\\tif err != nil {\\n   304→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   305→\\t}\\n   306→\\n   307→\\tsettings.Enabled = true\\n   308→\\tif err := SaveEntireSettings(settings); err != nil {\\n   309→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   310→\\t}\\n   311→\\n   312→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   313→\\treturn nil\\n   314→}\\n   315→\\n   316→func runDisable(w io.Writer, useProjectSettings bool) error {\\n   317→\\tsettings, err := LoadEntireSettings()\\n   318→\\tif err != nil {\\n   319→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   320→\\t}\\n   321→\\n   322→\\tsettings.Enabled = false\\n   323→\\n   324→\\t// If --project flag is specified, always write to project settings\\n   325→\\tif useProjectSettings {\\n   326→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   327→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   328→\\t\\t}\\n   329→\\t} else {\\n   330→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   331→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   332→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   333→\\t\\t}\\n   334→\\t}\\n   335→\\n   336→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   337→\\treturn nil\\n   338→}\\n   339→\\n   340→// DisabledMessage is the message shown when Entire is disabled\\n   341→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   342→\\n   343→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   344→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   345→// On error reading settings, defaults to enabled (returns false).\\n   346→func checkDisabledGuard(w io.Writer) bool {\\n   347→\\tenabled, err := IsEnabled()\\n   348→\\tif err != nil {\\n   349→\\t\\t// Default to enabled on error\\n   350→\\t\\treturn false\\n   351→\\t}\\n   352→\\tif !enabled {\\n   353→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   354→\\t\\treturn true\\n   355→\\t}\\n   356→\\treturn false\\n   357→}\\n   358→\\n   359→// setupAgentHooks sets up hooks for a given agent.\\n   360→// Returns the number of hooks installed (0 if already installed).\\n   361→func setupAgentHooks(ag agent.Agent, localDev, forceHooks bool) (int, error) {\\n   362→\\thookAgent, ok := ag.(agent.HookSupport)\\n   363→\\tif !ok {\\n   364→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   365→\\t}\\n   366→\\n   367→\\tcount, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   368→\\tif err != nil {\\n   369→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   370→\\t}\\n   371→\\n   372→\\treturn count, nil\\n   373→}\\n   374→\\n   375→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   376→// Returns the detected/selected agents and any error.\\n   377→// When exactly one agent is detected, it is used automatically.\\n   378→// When multiple agents are detected, the user is prompted to confirm.\\n   379→// If no agent is detected and no TTY is available, falls back to the default agent.\\n   380→//\\n   381→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   382→// It receives available agent names and returns the selected names.\\n   383→func detectOrSelectAgent(w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   384→\\t// Try auto-detection first\\n   385→\\tdetected := agent.DetectAll()\\n   386→\\n   387→\\tswitch {\\n   388→\\tcase len(detected) == 1:\\n   389→\\t\\t// Single agent detected — use it directly\\n   390→\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   391→\\t\\treturn detected, nil\\n   392→\\n   393→\\tcase len(detected) > 1:\\n   394→\\t\\t// Multiple agents detected — prompt the user to confirm which to enable\\n   395→\\t\\tagentTypes := make([]string, 0, len(detected))\\n   396→\\t\\tfor _, ag := range detected {\\n   397→\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   398→\\t\\t}\\n   399→\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   400→\\t\\tfmt.Fprintln(w)\\n   401→\\t\\t// Fall through to the interactive multi-select below\\n   402→\\t}\\n   403→\\n   404→\\t// No agent detected (or multiple detected) — check if we can prompt interactively\\n   405→\\tif !canPromptInteractively() {\\n   406→\\t\\tif len(detected) > 0 {\\n   407→\\t\\t\\t// Multiple agents detected but no TTY — use all of them\\n   408→\\t\\t\\treturn detected, nil\\n   409→\\t\\t}\\n   410→\\t\\t// No TTY available (e.g., running in CI or tests) - fall back to default agent\\n   411→\\t\\tdefaultAgent := agent.Default()\\n   412→\\t\\tif defaultAgent == nil {\\n   413→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   414→\\t\\t}\\n   415→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   416→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   417→\\t}\\n   418→\\n   419→\\tif len(detected) == 0 {\\n   420→\\t\\t// Show message only when nothing was detected\\n   421→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., .claude or .gemini directory).\\\")\\n   422→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   423→\\t\\tfmt.Fprintln(w)\\n   424→\\t}\\n   425→\\n   426→\\t// Build a set of detected agent names for pre-selection\\n   427→\\tdetectedSet := make(map[agent.AgentName]struct{}, len(detected))\\n   428→\\tfor _, ag := range detected {\\n   429→\\t\\tdetectedSet[ag.Name()] = struct{}{}\\n   430→\\t}\\n   431→\\n   432→\\t// Build options from registered agents\\n   433→\\tagentNames := agent.List()\\n   434→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   435→\\tfor _, name := range agentNames {\\n   436→\\t\\tag, err := agent.Get(name)\\n   437→\\t\\tif err != nil {\\n   438→\\t\\t\\tcontinue\\n   439→\\t\\t}\\n   440→\\t\\t// Only show agents that support hooks\\n   441→\\t\\tif _, ok := ag.(agent.HookSupport); !ok {\\n   442→\\t\\t\\tcontinue\\n   443→\\t\\t}\\n   444→\\t\\tlabel := string(ag.Type())\\n   445→\\t\\tif name == agent.DefaultAgentName {\\n   446→\\t\\t\\tlabel += \\\" (default)\\\"\\n   447→\\t\\t}\\n   448→\\t\\topt := huh.NewOption(label, string(name))\\n   449→\\t\\tif _, isDetected := detectedSet[name]; isDetected {\\n   450→\\t\\t\\topt = opt.Selected(true)\\n   451→\\t\\t}\\n   452→\\t\\toptions = append(options, opt)\\n   453→\\t}\\n   454→\\n   455→\\tif len(options) == 0 {\\n   456→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   457→\\t}\\n   458→\\n   459→\\t// Collect available agent names for the selector\\n   460→\\tavailableNames := make([]string, 0, len(options))\\n   461→\\tfor _, opt := range options {\\n   462→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   463→\\t}\\n   464→\\n   465→\\tvar selectedAgentNames []string\\n   466→\\tif selectFn != nil {\\n   467→\\t\\tvar err error\\n   468→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   469→\\t\\tif err != nil {\\n   470→\\t\\t\\treturn nil, err\\n   471→\\t\\t}\\n   472→\\t} else {\\n   473→\\t\\tform := NewAccessibleForm(\\n   474→\\t\\t\\thuh.NewGroup(\\n   475→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   476→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   477→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   478→\\t\\t\\t\\t\\tOptions(options...).\\n   479→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   480→\\t\\t\\t),\\n   481→\\t\\t)\\n   482→\\t\\tif err := form.Run(); err != nil {\\n   483→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   484→\\t\\t}\\n   485→\\t}\\n   486→\\n   487→\\tif len(selectedAgentNames) == 0 {\\n   488→\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   489→\\t}\\n   490→\\n   491→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   492→\\tfor _, name := range selectedAgentNames {\\n   493→\\t\\tselectedAgent, err := agent.Get(agent.AgentName(name))\\n   494→\\t\\tif err != nil {\\n   495→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   496→\\t\\t}\\n   497→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   498→\\t}\\n   499→\\n   500→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   501→\\tfor _, ag := range selectedAgents {\\n   502→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   503→\\t}\\n   504→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   505→\\treturn selectedAgents, nil\\n   506→}\\n   507→\\n   508→// canPromptInteractively checks if we can show interactive prompts.\\n   509→// Returns false when running in CI, tests, or other non-interactive environments.\\n   510→func canPromptInteractively() bool {\\n   511→\\t// Check for test environment\\n   512→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   513→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   514→\\t}\\n   515→\\n   516→\\t// Check if /dev/tty is available\\n   517→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   518→\\tif err != nil {\\n   519→\\t\\treturn false\\n   520→\\t}\\n   521→\\t_ = tty.Close()\\n   522→\\treturn true\\n   523→}\\n   524→\\n   525→// printAgentError writes an error message followed by available agents and usage.\\n   526→func printAgentError(w io.Writer, message string) {\\n   527→\\tagents := agent.List()\\n   528→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   529→\\tfmt.Fprintln(w)\\n   530→\\tfor _, a := range agents {\\n   531→\\t\\tsuffix := \\\"\\\"\\n   532→\\t\\tif a == agent.DefaultAgentName {\\n   533→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   534→\\t\\t}\\n   535→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   536→\\t}\\n   537→\\tfmt.Fprintln(w)\\n   538→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   539→}\\n   540→\\n   541→// printMissingAgentError writes a helpful error listing available agents.\\n   542→func printMissingAgentError(w io.Writer) {\\n   543→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   544→}\\n   545→\\n   546→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   547→func printWrongAgentError(w io.Writer, name string) {\\n   548→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   549→}\\n   550→\\n   551→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   552→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   553→func setupAgentHooksNonInteractive(w io.Writer, ag agent.Agent, localDev, forceHooks, skipPushSessions, telemetry bool) error {\\n   554→\\tagentName := ag.Name()\\n   555→\\t// Check if agent supports hooks\\n   556→\\thookAgent, ok := ag.(agent.HookSupport)\\n   557→\\tif !ok {\\n   558→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   559→\\t}\\n   560→\\n   561→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   562→\\n   563→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   564→\\tinstalledHooks, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   565→\\tif err != nil {\\n   566→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   567→\\t}\\n   568→\\n   569→\\t// Setup .entire directory\\n   570→\\tif _, err := setupEntireDirectory(); err != nil {\\n   571→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   572→\\t}\\n   573→\\n   574→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   575→\\tsettings, err := LoadEntireSettings()\\n   576→\\tif err != nil {\\n   577→\\t\\t// If we can't load, start with defaults\\n   578→\\t\\tsettings = &EntireSettings{}\\n   579→\\t}\\n   580→\\tsettings.Enabled = true\\n   581→\\tif localDev {\\n   582→\\t\\tsettings.LocalDev = localDev\\n   583→\\t}\\n   584→\\n   585→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   586→\\tif skipPushSessions {\\n   587→\\t\\tif settings.StrategyOptions == nil {\\n   588→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   589→\\t\\t}\\n   590→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   591→\\t}\\n   592→\\n   593→\\t// Handle telemetry for non-interactive mode\\n   594→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   595→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   596→\\t\\tf := false\\n   597→\\t\\tsettings.Telemetry = &f\\n   598→\\t}\\n   599→\\n   600→\\tif err := SaveEntireSettings(settings); err != nil {\\n   601→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   602→\\t}\\n   603→\\n   604→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   605→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   606→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   607→\\t}\\n   608→\\tstrategy.CheckAndWarnHookManagers(w)\\n   609→\\n   610→\\tif installedHooks == 0 {\\n   611→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   612→\\t\\tif agentName == agent.AgentNameGemini {\\n   613→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   614→\\t\\t}\\n   615→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   616→\\t} else {\\n   617→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   618→\\t\\tif agentName == agent.AgentNameGemini {\\n   619→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   620→\\t\\t}\\n   621→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   622→\\t}\\n   623→\\n   624→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   625→\\n   626→\\tif err := strategy.EnsureSetup(); err != nil {\\n   627→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   628→\\t}\\n   629→\\n   630→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   631→\\n   632→\\treturn nil\\n   633→}\\n   634→\\n   635→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   636→func validateSetupFlags(useLocal, useProject bool) error {\\n   637→\\tif useLocal && useProject {\\n   638→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   639→\\t}\\n   640→\\treturn nil\\n   641→}\\n   642→\\n   643→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   644→// - Whether settings.json already exists\\n   645→// - The --local and --project flags\\n   646→// Returns (useLocal, showNotification).\\n   647→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   648→\\t// Explicit --local flag always uses local settings\\n   649→\\tif useLocal {\\n   650→\\t\\treturn true, false\\n   651→\\t}\\n   652→\\n   653→\\t// Explicit --project flag always uses project settings\\n   654→\\tif useProject {\\n   655→\\t\\treturn false, false\\n   656→\\t}\\n   657→\\n   658→\\t// No flags specified - check if settings file exists\\n   659→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   660→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   661→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   662→\\t\\treturn true, true\\n   663→\\t}\\n   664→\\n   665→\\t// Settings file doesn't exist - create it\\n   666→\\treturn false, false\\n   667→}\\n   668→\\n   669→// setupEntireDirectory creates the .entire directory and gitignore.\\n   670→// Returns true if the directory was created, false if it already existed.\\n   671→func setupEntireDirectory() (bool, error) { //nolint:unparam // already present in codebase\\n   672→\\t// Get absolute path for the .entire directory\\n   673→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   674→\\tif err != nil {\\n   675→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   676→\\t}\\n   677→\\n   678→\\t// Check if directory already exists\\n   679→\\tcreated := false\\n   680→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   681→\\t\\tcreated = true\\n   682→\\t}\\n   683→\\n   684→\\t// Create .entire directory\\n   685→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   686→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   687→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   688→\\t}\\n   689→\\n   690→\\t// Create/update .gitignore with all required entries\\n   691→\\tif err := strategy.EnsureEntireGitignore(); err != nil {\\n   692→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   693→\\t}\\n   694→\\n   695→\\treturn created, nil\\n   696→}\\n   697→\\n   698→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   699→func setupGitHook() error {\\n   700→\\t// Use shared implementation from strategy package\\n   701→\\t// The localDev setting is read from settings.json\\n   702→\\t_, err := strategy.InstallGitHook(false) // not silent - show output during setup\\n   703→\\tif err != nil {\\n   704→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   705→\\t}\\n   706→\\tstrategy.CheckAndWarnHookManagers(os.Stderr)\\n   707→\\treturn nil\\n   708→}\\n   709→\\n   710→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   711→func newSetupGitHookCmd() *cobra.Command {\\n   712→\\tcmd := &cobra.Command{\\n   713→\\t\\tUse:    \\\"git-hook\\\",\\n   714→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   715→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   716→\\t\\tRunE: func(_ *cobra.Command, _ []string) error {\\n   717→\\t\\t\\treturn setupGitHook()\\n   718→\\t\\t},\\n   719→\\t}\\n   720→\\n   721→\\treturn cmd\\n   722→}\\n   723→\\n   724→func newCurlBashPostInstallCmd() *cobra.Command {\\n   725→\\treturn &cobra.Command{\\n   726→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   727→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   728→\\t\\tHidden: true,\\n   729→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   730→\\t\\t\\tw := cmd.OutOrStdout()\\n   731→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   732→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   733→\\t\\t\\t}\\n   734→\\t\\t\\treturn nil\\n   735→\\t\\t},\\n   736→\\t}\\n   737→}\\n   738→\\n   739→// shellCompletionComment is the comment preceding the completion line\\n   740→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   741→\\n   742→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   743→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   744→\\n   745→// shellCompletionTarget returns the rc file path and completion lines for the\\n   746→// user's current shell.\\n   747→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   748→\\thome, err := os.UserHomeDir()\\n   749→\\tif err !