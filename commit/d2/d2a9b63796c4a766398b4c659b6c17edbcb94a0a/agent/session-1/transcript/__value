estHandleTurnEnd_PartialFailure(t *testing.T) {\\n  1231→\\tdir := setupGitRepo(t)\\n  1232→\\tt.Chdir(dir)\\n  1233→\\n  1234→\\trepo, err := git.PlainOpen(dir)\\n  1235→\\trequire.NoError(t, err)\\n  1236→\\n  1237→\\ts := &ManualCommitStrategy{}\\n  1238→\\tsessionID := \\\"test-partial-failure\\\"\\n  1239→\\n  1240→\\tsetupSessionWithCheckpoint(t, s, repo, dir, sessionID)\\n  1241→\\n  1242→\\t// Set phase to ACTIVE and create a transcript file with updated content\\n  1243→\\tstate, err := s.loadSessionState(context.Background(), sessionID)\\n  1244→\\trequire.NoError(t, err)\\n  1245→\\tstate.Phase = session.PhaseActive\\n  1246→\\tstate.TurnCheckpointIDs = nil\\n  1247→\\trequire.NoError(t, s.saveSessionState(context.Background(), state))\\n  1248→\\n  1249→\\t// First commit → creates real checkpoint on entire/checkpoints/v1\\n  1250→\\tcommitWithCheckpointTrailer(t, repo, dir, \\\"a1b2c3d4e5f6\\\")\\n  1251→\\trequire.NoError(t, s.PostCommit(context.Background()))\\n  1252→\\n  1253→\\t// Write new content and create a second checkpoint on the shadow branch.\\n  1254→\\t// Use SaveStep directly (instead of setupSessionWithCheckpoint) so that\\n  1255→\\t// second.txt is included in FilesTouched — the overlap check needs it.\\n  1256→\\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \\\"second.txt\\\"), []byte(\\\"second file\\\"), 0o644))\\n  1257→\\tmetadataDir := \\\".entire/metadata/\\\" + sessionID\\n  1258→\\tmetadataDirAbs := filepath.Join(dir, metadataDir)\\n  1259→\\terr = s.SaveStep(context.Background(), StepContext{\\n  1260→\\t\\tSessionID:      sessionID,\\n  1261→\\t\\tModifiedFiles:  []string{\\\"test.txt\\\"},\\n  1262→\\t\\tNewFiles:       []string{\\\"second.txt\\\"},\\n  1263→\\t\\tDeletedFiles:   []string{},\\n  1264→\\t\\tMetadataDir:    metadataDir,\\n  1265→\\t\\tMetadataDirAbs: metadataDirAbs,\\n  1266→\\t\\tCommitMessage:  \\\"Checkpoint 2\\\",\\n  1267→\\t\\tAuthorName:     \\\"Test\\\",\\n  1268→\\t\\tAuthorEmail:    \\\"test@