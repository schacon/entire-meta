  2278→\\t\\t)\\n  2279→\\t\\treturn filesChangedInCommitFallback(ctx, headTree, parentTree)\\n  2280→\\t}\\n  2281→\\treturn result\\n  2282→}\\n  2283→\\n  2284→// filesChangedInCommitFallback uses go-git tree walks to compute changed files.\\n  2285→// Slower than git diff-tree but doesn't depend on an external process.\\n  2286→func filesChangedInCommitFallback(ctx context.Context, headTree, parentTree *object.Tree) map[string]struct{} {\\n  2287→\\tfiles, err := getAllChangedFilesBetweenTreesSlow(ctx, parentTree, headTree)\\n  2288→\\tif err != nil {\\n  2289→\\t\\tlogging.Warn(ctx, \\\"post-commit: tree walk fallback also failed; condensation and carry-forward may be affected\\\",\\n  2290→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  2291→\\t\\t)\\n  2292→\\t\\treturn make(map[string]struct{})\\n  2293→\\t}\\n  2294→\\tresult := make(map[string]struct{}, len(files))\\n  2295→\\tfor _, f := range files {\\n  2296→\\t\\tresult[f] = struct{}{}\\n  2297→\\t}\\n  2298→\\treturn result\\n  2299→}\"}]},\"uuid\":\"f3990e35-03e1-4c91-a193-f8e4272211a1\",\"timestamp\":\"2026-03-09T06:13:05.681Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"add0b92b17413a687\"},\"toolUseID\":\"agent_msg_0156tieRSEvFmMeD8KSLTMZQ\",\"parentToolUseID\":\"toolu_018fKfwwtE8RbbLN7psVNeux\",\"uuid\":\"247bba13-2117-4925-a7bc-a848d74119f9\",\"timestamp\":\"2026-03-09T06:13:05.703Z\"}\n{\"parentUuid\":\"247bba13-2117-4925-a7bc-a848d74119f9\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/devenv/cli\",\"sessionId\":\"061fd814-f357-4c55-a9c5-5b97c5911bf5\",\"version\":\"2.1.71\",\"gitBranch\":\"alisha/e2e-triage-local-only\",\"slug\":\"inherited-exploring-treehouse\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-09T06:13:08.079Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_013WPCi4GEw9Q1CqBEQcnrx4\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_u