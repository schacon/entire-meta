err // Hook must be silent on failure\\n   615→\\t}\\n   616→\\n   617→\\tcommit, err := repo.CommitObject(head.Hash())\\n   618→\\tif err != nil {\\n   619→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   620→\\t}\\n   621→\\n   622→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   623→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   624→\\tif !found {\\n   625→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   626→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   627→\\t\\ts.postCommitUpdateBaseCommitOnly(ctx, logCtx, head)\\n   628→\\t\\treturn nil\\n   629→\\t}\\n   630→\\n   631→\\tworktreePath, err := GetWorktreePath(ctx)\\n   632→\\tif err != nil {\\n   633→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   634→\\t}\\n   635→\\n   636→\\t// Find all active sessions for this worktree\\n   637→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   638→\\tif err != nil || len(sessions) == 0 {\\n   639→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   640→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   641→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   642→\\t\\t)\\n   643→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   644→\\t}\\n   645→\\n   646→\\t// Build transition context\\n   647→\\tisRebase := isGitSequenceOperation(ctx)\\n   648→\\ttransitionCtx := session.TransitionContext{\\n   649→\\t\\tIsRebaseInProgress: isRebase,\\n   650→\\t}\\n   651→\\n   652→\\tif isRebase {\\n   653→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   654→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   655→\\t\\t)\\n   656→\\t}\\n   657→\\n   658→\\t// Track shadow branch names and whether they can be deleted\\n   659→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   660→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   661→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   662→\\n   663→\\tnewHead := head.Hash().String()\\n   664→\\tcommittedFileSet := filesChangedInCommit(commit)\\n   665→\\n   666→\\tfor _, state := range sessions {\\n   667→\\t\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   668→\\n   669→\\t\\t// Check for new content (needed for TransitionContext and condensation).\\n   670→\\t\\t// Fail-open: if content check errors, assume new content exists so we\\n   671→\\t\\t// don't silently skip data that should have been condensed.\\n   672→\\t\\t//\\n   673→\\t\\t// For ACTIVE sessions: the commit has a checkpoint trailer (verified above),\\n   674→\\t\\t// meaning PrepareCommitMsg already determined this commit is session-related.\\n   675→\\t\\t// The trailer is only added when either:\\n   676→\\t\\t//   - No TTY (agent/subagent committing) — added unconditionally\\n   677→\\t\\t//   - TTY (human committing) — added after content detection confirmed agent work\\n   678→\\t\\t// In both cases, PrepareCommitMsg already validated this commit. We trust\\n   679→\\t\\t// that decision here. Transcript-based re-validation is unreliable because\\n   680→\\t\\t// subagent transcripts may not be available yet (subagent still running).\\n   681→\\t\\tvar hasNew bool\\n   682→\\t\\tif state.Phase.IsActive() {\\n   683→\\t\\t\\thasNew = true\\n   684→\\t\\t} else {\\n   685→\\t\\t\\tvar contentErr error\\n   686→\\t\\t\\thasNew, contentErr = s.sessionHasNewContent(ctx, repo, state)\\n   687→\\t\\t\\tif contentErr != nil {\\n   688→\\t\\t\\t\\thasNew = true\\n   689→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: error checking session content, assuming new content\\\",\\n   690→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionI