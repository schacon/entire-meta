 !ok {\\n  3287→ \\t\\treturn false\\n  3288→ \\t}\\n  3289→@@ -1488,7 +1488,23 @@ func (s *ManualCommitStrategy) extractModifiedFilesFromLiveTranscript(ctx contex\\n  3290→ \\t\\treturn nil\\n  3291→ \\t}\\n  3292→ \\n  3293→-\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  3294→+\\t// Ensure transcript file is up-to-date (OpenCode creates/refreshes it via `opencode export`).\\n  3295→+\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n  3296→+\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n  3297→+\\tif state.Phase.IsActive() {\\n  3298→+\\t\\tif preparer, ok := agent.AsTranscriptPreparer(ag); ok {\\n  3299→+\\t\\t\\tif prepErr := preparer.PrepareTranscript(ctx, state.TranscriptPath); prepErr != nil {\\n  3300→+\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prepare transcript failed\\\",\\n  3301→+\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  3302→+\\t\\t\\t\\t\\tslog.String(\\\"agent_type\\\", string(state.AgentType)),\\n  3303→+\\t\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  3304→+\\t\\t\\t\\t\\tslog.Any(\\\"error\\\", prepErr),\\n  3305→+\\t\\t\\t\\t)\\n  3306→+\\t\\t\\t}\\n  3307→+\\t\\t}\\n  3308→+\\t}\\n  3309→+\\n  3310→+\\tanalyzer, ok := agent.AsTranscriptAnalyzer(ag)\\n  3311→ \\tif !ok {\\n  3312→ \\t\\treturn nil\\n  3313→ \\t}\\n  3314→diff --git a/docs/architecture/external-agent-protocol.md b/docs/architecture/external-agent-protocol.md\\n  3315→new file mode 100644\\n  3316→index 00000000..d084337f\\n  3317→--- /dev/null\\n  3318→+++ b/docs/architecture/external-agent-protocol.md\\n  3319→@@ -0,0 +1,547 @@\\n  3320→+# External Agent Plugin Protocol\\n  3321→+\\n  3322→+## Overview\\n  3323→+\\n  3324→+The Entire CLI supports external agent plugins — standalone binaries that implement the Agent interface via a subcommand-based protocol over stdin/stdout. This allows third-party agents to integrate with the CLI without modifying the main repository.\\n  3325→+\\n  3326→+## Discovery\\n  3327→+\\n  3328→+The CLI discovers external agents by scanning `$PATH` for executables matching the pattern `entire-agent-<name>`. For example, `entire-agent-cursor` would register as the \\\"cursor\\\" agent.\\n  3329→+\\n  3330→+- Binaries whose `<name>` conflicts with an already-registered built-in agent are skipped.\\n  3331→+- Discovery runs once during CLI initialization (before building the hooks command tree).\\n  3332→+- The binary must be executable and respond to the `info` subcommand.\\n  3333→+\\n  3334→+## Environment\\n  3335→+\\n  3336→+Every subcommand invocation sets:\\n  3337→+\\n  3338→+| Variable | Description |\\n  3339→+|---|---|\\n  3340→+| `ENTIRE_REPO_ROOT` | Absolute path to the git repository root |\\n  3341→+| `ENTIRE_PROTOCOL_VERSION` | Protocol version (`1`) |\\n  3342→+\\n  3343→+The working directory is set to the repository root.\\n  3344→+\\n  3345→+## Communication Model\\n  3346→+\\n  3347→+- **Subcommand-based:** Each Agent interface method maps to a CLI subcommand.\\n  3348→+- **JSON over stdin/stdout:** Structured data uses JSON. Transcripts use raw bytes.\\n  3349→+- **Stateless:** Each invocation is independent — no persistent connection.\\n  3350→+- **Exit codes:** `0` = success, non-zero = error. Error messages go to stderr.\\n  3351→+\\n  3352→+## Subcommands\\n  3353→+\\n  3354→+### Always Required\\n  3355→+\\n  3356→+#### `info`\\n  3357→+\\n  3358→+Returns agent metadata and declared capabilities.\\n  3359→+\\n  3360→+**Arguments:** None\\n  3361→+\\n  3362→+**Output (stdout):** JSON\\n  3363→+\\n  3364→+```json\\n  3365→+{\\n  3366→+  \\\"protocol_version\\\": 1,\\n  3367→+  \\\"name\\\": \\\"cursor\\\",\\n  3368→+  \\\"type\\\": \\\"Cursor\\\",\\n  3369→+  \\\"description\\\": \\\"Cursor - AI-powered code editor\\\",\\n  3370→+  \\\"is_preview\\\": true,\\n  3371→+  \\\"protected_dirs\\\": [\\\".cursor\\\"],\\n  3372→+  \\\"hook_names\\\": [\\\"session-start\\\", \\\"session-end\\\", \\\"stop\\\"],\\n  3373→+  \\\"capabilities\\\": {\\n  3374→+    \\\"hooks\\\": true,\\n  3375→+    \\\"transcript_analyzer\\\": true,\\n  3376→+    \\\"transcript_preparer\\\": false,\\n  3377→+    \\\"token_calculator\\\": false,\\n  3378→+    \\\"text_generator\\\": false,\\n  3379→+    \\\"hook_response_writer\\\": false,\\n  3380→+    \\\"subagent_aware_extractor\\\": false\\n  3381→+  }\\n  3382→+}\\n  3383→+```\\n  3384→+\\n  3385→+The `capabilities` object determines which optional subcommands the CLI will call. If a capability is `false` or missing, the CLI will never invoke the corresponding subcommands.\\n  3386→+\\n  3387→+#### `detect`\\n  3388→+\\n  3389→+Checks whether the agent is present/usable in the current environment.\\n  3390→+\\n  3391→+**Arguments:** None\\n  3392→+\\n  3393→+**Output (stdout):** JSON\\n  3394→+\\n  3395→+```json\\n  3396→+{\\\"present\\\": true}\\n  3397→+```\\n  3398→+\\n  3399→+#### `get-session-id`\\n  3400→+\\n  3401→+Extracts the session ID from a hook input event.\\n  3402→+\\n  3403→+**Input (stdin):** JSON — the [HookInput object](#hookinput-object)\\n  3404→+\\n  3405→+**Output (stdout):** JSON\\n  3406→+\\n  3407→+```json\\n  3408→+{\\\"session_id\\\": \\\"abc123\\\"}\\n  3409→+```\\n  3410→+\\n  3411→+#### `get-session-dir --repo-path <path>`\\n  3412→+\\n  3413→+Returns the directory where agent sessions are stored.\\n  3414→+\\n  3415→+**Arguments:**\\n  3416→+- `--repo-path` — Absolute path to the repository\\n  3417→+\\n  3418→+**Output (stdout):** JSON\\n  3419→+\\n  3420→+```json\\n  3421→+{\\\"session_dir\\\": \\\"/path/to/sessions\\\"}\\n  3422→+```\\n  3423→+\\n  3424→+#### `resolve-session-file --session-dir <dir> --session-id <id>`\\n  3425→+\\n  3426→+Resolves the session file path from a session directory and ID.\\n  3427→+\\n  3428→+**Arguments:**\\n  3429→+- `--session-dir` — Session directory path\\n  3430→+- `--session-id` — Session identifier\\n  3431→+\\n  3432→+**Output (stdout):** JSON\\n  3433→+\\n  3434→+```json\\n  3435→+{\\\"session_file\\\": \\\"/path/to/session/file.jsonl\\\"}\\n  3436→+```\\n  3437→+\\n  3438→+#### `read-session`\\n  3439→+\\n  3440→+Reads session data from a hook input event.\\n  3441→+\\n  3442→+**Input (stdin):** JSON — the [HookInput object](#hookinput-object)\\n  3443→+\\n  3444→+**Output (stdout):** JSON — [AgentSession object](#agentsession-object)\\n  3445→+\\n  3446→+```json\\n  3447→+{\\n  3448→+  \\\"session_id\\\": \\\"abc123\\\",\\n  3449→+  \\\"agent_name\\\": \\\"cursor\\\",\\n  3450→+  \\\"repo_path\\\": \\\"/path/to/repo\\\",\\n  3451→+  \\\"session_ref\\\": \\\"/path/to/file.jsonl\\\",\\n  3452→+  \\\"start_time\\\": \\\"2026-01-13T12:00:00Z\\\",\\n  3453→+  \\\"native_data\\\": null,\\n  3454→+  \\\"modified_files\\\": [\\\"src/main.go\\\"],\\n  3455→+  \\\"new_files\\\": [],\\n  3456→+  \\\"deleted_files\\\": []\\n  3457→+}\\n  3458→+```\\n  3459→+\\n  3460→+#### `write-session`\\n  3461→+\\n  3462→+Writes/updates session data.\\n  3463→+\\n  3464→+**Input (stdin):** JSON — the [AgentSession object](#agentsession-object)\\n  3465→+\\n  3466→+**Output:** Exit 0 on success.\\n  3467→+\\n  3468→+#### `read-transcript --session-ref <path>`\\n  3469→+\\n  3470→+Reads a transcript file and returns its raw bytes.\\n  3471→+\\n  3472→+**Arguments:**\\n  3473→+- `--session-ref` — Path to the transcript file\\n  3474→+\\n  3475→+**Output (stdout):** Raw transcript bytes.\\n  3476→+\\n  3477→+#### `chunk-transcript --max-size <n>`\\n  3478→+\\n  3479→+Splits a transcript into chunks for storage.\\n  3480→+\\n  3481→+**Input (stdin):** Raw transcript bytes.\\n  3482→+\\n  3483→+**Arguments:**\\n  3484→+- `--max-size` — Maximum chunk size in bytes\\n  3485→+\\n  3486→+**Output (stdout):** JSON\\n  3487→+\\n  3488→+```json\\n  3489→+{\\\"chunks\\\": [\\\"<base64-encoded-chunk>\\\", \\\"...\\\"]}\\n  3490→+```\\n  3491→+\\n  3492→+#### `reassemble-transcript`\\n  3493→+\\n  3494→+Reassembles transcript chunks back into a full transcript.\\n  3495→+\\n  3496→+**Input (stdin):** JSON\\n  3497→+\\n  3498→+```json\\n  3499→+{\\\"chunks\\\": [\\\"<base64-encoded-chunk>\\\", \\\"...\\\"]}\"}]},\"uuid\":\"1452708f-d199-4244-95ec-b4e8d3973658\",\"timestamp\":\"2026-03-05T09:13:56.919Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"acf8d786c4bdadd9e\"},\"toolUseID\":\"agent_msg_012DXLQTpm4TaVJmo93oGb44\",\"parentToolUseID\":\"toolu_01Y7S6hEkU5EgFjKc8gd89uT\",\"uuid\":\"a9333bde-9ab8-4cfb-bead-bd0bfe669466\",\"timestamp\":\"2026-03-05T09:13:56.922Z\"}\n{\"parentUuid\":\"a9333bde-9ab8-4cfb-bead-bd0bfe669466\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"dccb059e-a37d-4287-9fa3-471a6aa16f44\",\"version\":\"2.1.69\",\"gitBranch\":\"nodo/external-plugins\",\"slug\":\"delegated-hugging-cherny\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-05T09:14:02.641Z\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01SdTyFN8S6Mothjdp9uceE7\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01GZNbqYkhita7wKaJqxU1Ke\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/nodo/.claude/projects/-Users-nodo-work-cli/dccb059e-a37d-4287-9fa3-471a6aa16f44/tool-results/bren5j1zl.txt\",\"offset\":3500,\"limit\":500},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":8446,\"cache_read_input_tokens\":64836,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":8446},\"output_tokens\":25,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYjgFt8wsBtJviZNyRww4\",\"uuid\":\"2caf53ac-e010-4a10-83a8-0ce25dfe7658\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"acf8d786c4bdadd9e\"},\"toolUseID\":\"agent_msg_012DXLQTpm4TaVJmo93oGb44\",\"parentToolUseID\":\