e {\\n    22→\\t// --- Identity ---\\n    23→\\n    24→\\t// Name returns the agent registry key (e.g., \\\"claude-code\\\", \\\"gemini\\\")\\n    25→\\tName() types.AgentName\\n    26→\\n    27→\\t// Type returns the agent type identifier (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\")\\n    28→\\t// This is stored in metadata and trailers.\\n    29→\\tType() types.AgentType\\n    30→\\n    31→\\t// Description returns a human-readable description for UI\\n    32→\\tDescription() string\\n    33→\\n    34→\\t// IsPreview returns whether the agent integration is in preview or stable\\n    35→\\tIsPreview() bool\\n    36→\\n    37→\\t// DetectPresence checks if this agent is configured in the repository\\n    38→\\tDetectPresence(ctx context.Context) (bool, error)\\n    39→\\n    40→\\t// ProtectedDirs returns repo-root-relative directories that should never be\\n    41→\\t// modified or deleted during rewind or other destructive operations.\\n    42→\\t// Examples: [\\\".claude\\\"] for Claude, [\\\".gemini\\\"] for Gemini.\\n    43→\\tProtectedDirs() []string\\n    44→\\n    45→\\t// --- Transcript Storage ---\\n    46→\\n    47→\\t// ReadTranscript reads the raw transcript bytes for a session.\\n    48→\\tReadTranscript(sessionRef string) ([]byte, error)\\n    49→\\n    50→\\t// ChunkTranscript splits a transcript into chunks if it exceeds maxSize.\\n    51→\\t// Returns a slice of chunks. If the transcript fits in one chunk, returns single-element slice.\\n    52→\\t// The chunking is format-aware: JSONL splits at line boundaries, JSON splits message arrays.\\n    53→\\tChunkTranscript(ctx context.Context, content []byte, maxSize int) ([][]byte, error)\\n    54→\\n    55→\\t// ReassembleTranscript combines chunks back into a single transcript.\\n    56→\\t// Handles format-specific reassembly (JSONL concatenation, JSON message merging).\\n    57→\\tReassembleTranscript(chunks [][]byte) ([]byte, error)\\n    58→\\n    59→\\t// --- Legacy methods (will move to optional interfaces in Phase 4) ---\\n    60→\\n    61→\\t// GetSessionID extracts session ID from hook input.\\n    62→\\tGetSessionID(input *HookInput) string\\n    63→\\n    64→\\t// GetSessionDir returns where agent stores session data for this repo.\\n    65→\\tGetSessionDir(repoPath string) (string, error)\\n    66→\\n    67→\\t// ResolveSessionFile returns the path to the session transcript file.\\n    68→\\tResolveSessionFile(sessionDir, agentSessionID string) string\\n    69→\\n    70→\\t// ReadSession reads session data from agent's storage.\\n    71→\\tReadSession(input *HookInput) (*AgentSession, error)\\n    72→\\n    73→\\t// WriteSession writes session data for resumption.\\n    74→\\tWriteSession(ctx context.Context, session *AgentSession) error\\n    75→\\n    76→\\t// FormatResumeCommand returns command to resume a session.\\n    77→\\tFormatResumeCommand(sessionID string) string\\n    78→}\\n    79→\\n    80→// HookSupport is implemented by agents with lifecycle hooks.\\n    81→// This optional interface allows agents like Claude Code and Cursor to\\n    82→// install and manage hooks that notify Entire of agent events.\\n    83→//\\n    84→// The interface is organized into two groups:\\n    85→//   - Hook Mapping (2 methods): HookNames, ParseHookEvent\\n    86→//   - Hook Management (3 methods): InstallHooks, UninstallHooks, AreHooksInstalled\\n    87→type HookSupport interface {\\n    88→\\tAgent\\n    89→\\n    90→\\t// HookNames returns the hook verbs this agent supports.\\n    91→\\t// These become subcommands under `entire hooks <agent>`.\\n    92→\\t// e.g., [\\\"stop\\\", \\\"user-prompt-submit\\\", \\\"session-start\\\", \\\"session-end\\\"]\\n    93→\\tHookNames() []string\\n    94→\\n    95→\\t// ParseHookEvent translates an agent-native hook into a normalized lifecycle Event.\\n    96→\\t// Returns nil if the hook has no lifecycle significance (e.g., pass-through hooks).\\n    97→\\t// This is the core contribution surface for new agent implementations.\\n    98→\\tParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*Event, error)\\n    99→\\n   100→\\t// InstallHooks installs agent-specific hooks.\\n   101→\\t// If localDev is true, hooks point to local development build.\\n   102→\\t// If force is true, removes existing Entire hooks before installing.\\n   103→\\t// Returns the number of hooks installed.\\n   104→\\tInstallHooks(ctx context.Context, localDev bool, force bool) (int, error)\\n   105→\\n   106→\\t// UninstallHooks removes installed hooks\\n   107→\\tUninstallHooks(ctx context.Context) error\\n   108→\\n   109→\\t// AreHooksInstalled checks if hooks are currently installed\\n   110→\\tAreHooksInstalled(ctx context.Context) bool\\n   111→}\\n   112→\\n   113→// FileWatcher is implemented by agents that use file-based detection.\\n   114→// Agents like Aider that don't support hooks can use file watching\\n   115→// to detect session activity.\\n   116→type FileWatcher interface {\\n   117→\\tAgent\\n   118→\\n   119→\\t// GetWatchPaths returns paths to watch for session changes\\n   120→\\tGetWatchPaths() ([]string, error)\\n   121→\\n   122→\\t// OnFileChange handles a detected file change and returns session info\\n   123→\\tOnFileChange(path string) (*SessionChange, error)\\n   124→}\\n   125→\\n   126→// TranscriptAnalyzer provides format-specific transcript parsing.\\n   127→// Agents that implement this get richer checkpoints (transcript-derived file lists,\\n   128→// prompts, summaries). Agents that don't still participate in the checkpoint lifecycle\\n   129→// via git-status-based file detection and raw transcript storage.\\n   130→type TranscriptAnalyzer interface {\\n   131→\\tAgent\\n   132→\\n   133→\\t// GetTranscriptPosition returns the current position (length) of a transcript.\\n   134→\\t// For JSONL formats (Claude Code), this is the line count.\\n   135→\\t// For JSON formats (Gemini CLI), this is the message count.\\n   136→\\t// Returns 0 if the file doesn't exist or is empty.\\n   137→\\tGetTranscriptPosition(path string) (int, error)\\n   138→\\n   139→\\t// ExtractModifiedFilesFromOffset extracts files modified since a given offset.\\n   140→\\t// For JSONL formats (Claude Code), offset is the starting line number.\\n   141→\\t// For JSON formats (Gemini CLI), offset is the starting message index.\\n   142→\\t// Returns:\\n   143→\\t//   - files: list of file paths modified by the agent (from Write/Edit tools)\\n   144→\\t//   - currentPosition: the current position (line count or message count)\\n   145→\\t//   - error: any error encountered during reading\\n   146→\\tExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error)\\n   147→\\n   148→\\t// ExtractPrompts extracts user prompts from the transcript starting at the given offset.\\n   149→\\tExtractPrompts(sessionRef string, fromOffset int) ([]string, error)\\n   150→\\n   151→\\t// ExtractSummary extracts a summary of the session from the transcript.\\n   152→\\tExtractSummary(sessionRef string) (string, error)\\n   153→}\\n   154→\\n   155→// TranscriptPreparer is called before ReadTranscript to handle agent-specific\\n   156→// flush/sync requirements (e.g., Claude Code's async transcript writing).\\n   157→// The framework calls PrepareTranscript before ReadTranscript if implemented.\\n   158→type TranscriptPreparer interface {\\n   159→\\tAgent\\n   160→\\n   161→\\t// PrepareTranscript ensures the transcript is ready to read.\\n   162→\\t// For Claude Code, this waits for the async transcript flush to complete.\\n   163→\\tPrepareTranscript(ctx context.Context, sessionRef string) error\\n   164→}\\n   165→\\n   166→// TokenCalculator provides token usage calculation for a session.\\n   167→// The framework calls this during step save and checkpoint if implemented.\\n   168→type TokenCalculator interface {\\n   169→\\tAgent\\n   170→\\n   171→\\t// CalculateTokenUsage computes token usage from the transcript starting at the given offset.\\n   172→\\tCalculateTokenUsage(transcriptData []byte, fromOffset int) (*TokenUsage, error)\\n   173→}\\n   174→\\n   175→// TextGenerator is an optional interface for agents whose CLI supports\\n   176→// non-interactive text generation (e.g., claude --print).\\n   177→// Used for AI-powered metadata generation (trail titles, summaries).\\n   178→type TextGenerator interface {\\n   179→\\tAgent\\n   180→\\n   181→\\t// GenerateText sends a prompt to the agent's CLI and returns the raw text response.\\n   182→\\t// model is a hint (e.g., \\\"haiku\\\", \\\"sonnet\\\"). Implementations may ignore if not applicable.\\n   183→\\tGenerateText(ctx context.Context, prompt string, model string) (string, error)\\n   184→}\\n   185→\\n   186→// HookResponseWriter is implemented by agents that support structured hook responses.\\n   187→// Agents that implement this can output messages (e.g., banners) to the user via\\n   188→// the agent's response protocol. For example, Claude Code outputs JSON with a\\n   189→// systemMessage field to stdout. Agents that don't implement this will silently\\n   190→// skip hook response output.\\n   191→type HookResponseWriter interface {\\n   192→\\tAgent\\n   193→\\n   194→\\t// WriteHookResponse outputs a message to the user via the agent's hook response protocol.\\n   195→\\tWriteHookResponse(message string) error\\n   196→}\\n   197→\\n   198→// SubagentAwareExtractor provides methods for extracting files and tokens including subagents.\\n   199→// Agents that support spawning subagents (like Claude Code's Task tool) should implement this\\n   200→// to ensure subagent contributions are included in checkpoints.\\n   201→type SubagentAwareExtractor interface {\\n   202→\\tAgent\\n   203→\\n   204→\\t// ExtractAllModifiedFiles extracts files modified by both the main agent and any spawned subagents.\\n   205→\\t// The subagentsDir parameter specifies where subagent transcripts are stored.\\n   206→\\t// Returns a deduplicated list of all modified file paths.\\n   207→\\tExtractAllModifiedFiles(transcriptData []byte, fromOffset int, subagentsDir string) ([]string, error)\\n   208→\\n   209→\\t// CalculateTotalTokenUsage computes token usage including all spawned subagents.\\n   210→\\t// The subagentsDir parameter specifies where subagent transcripts are stored.\\n   211→\\tCalculateTotalTokenUsage(transcriptData []byte, fromOffset int, subagentsDir string) (*TokenUsage, error)\\n   212→}\\n   213→\"}]},\"uuid\":\"284392bb-e804-4efa-a817-a6aaed6a43f9\",\"timestamp\":\"2026-03-04T20:12:38.461Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alisha/Projects/wt/kiro-oneshot/cmd/entire/cli/agent/agent.go\",\"content\":\"// Package agent provides interfaces and types for integrating with coding agents.\\n// It abstracts agent-specific behavior (hooks, log parsing, session storage) so that\\n// the same Strategy implementations can work with any coding agent.\\npackage agent\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"io\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n)\\n\\n// Agent defines the interface for interacting with a coding agent.\\n// Each agent implementation (Claude Code, Cursor, Aider, etc.) converts its\\n// native format to the normalized types defined in this package.\\n//\\n// The interface is organized into three groups:\\n//   - Identity (5 methods): Name, Type, Description, DetectPresence, ProtectedDirs\\n//   - Transcript Storage (3 methods): ReadTranscript, ChunkTranscript, ReassembleTranscript\\n//   - Legacy (6 methods): Will be moved to optional interfaces or removed in a future phase\\ntype Agent interface {\\n\\t// --- Identity ---\\n\\n\\t// Name returns the agent registry key (e.g., \\\"claude-code\\\", \\\"gemini\\\")\\n\\tName() types.AgentName\\n\\n\\t// Type returns the agent type identifier (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\")\\n\\t// This is stored in metadata and trailers.\\n\\tType() types.AgentType\\n\\n\\t// Description returns a human-readable description for UI\\n\\tDescription() string\\n\\n\\t// IsPreview returns whether the agent integration is in preview or stable\\n\\tIsPreview() bool\\n\\n\\t// DetectPresence checks if this agent is configured in the repository\\n\\tDetectPresence(ctx context.Context) (bool, error)\\n\\n\\t// ProtectedDirs returns repo-root-relative directories that should never be\\n\\t// modified or deleted during rewind or other destructive operations.\\n\\t// Examples: [\\\".claude\\\"] for Claude, [\\\".gemini\\\"] for Gemini.\\n\\tProtectedDirs() []string\\n\\n\\t// --- Transcript Storage ---\\n\\n\\t// ReadTranscript reads the raw transcript bytes for a session.\\n\\tReadTranscript(sessionRef string) ([]byte, error)\\n\\n\\t// ChunkTranscript splits a transcript into chunks if it exceeds maxSize.\\n\\t// Returns a slice of chunks. If the transcript fits in one chunk, returns single-element slice.\\n\\t// The chunking is format-aware: JSONL splits at line boundaries, JSON splits message arrays.\\n\\tChunkTranscript(ctx context.Context, content []byte, maxSize int) ([][]byte, error)\\n\\n\\t// ReassembleTranscript combines chunks back into a single transcript.\\n\\t// Handles format-specific reassembly (JSONL concatenation, JSON message merging).\\n\\tReassembleTranscript(chunks [][]byte) ([]byte, error)\\n\\n\\t// --- Legacy methods (will move to optional interfaces in Phase 4) ---\\n\\n\\t// GetSessionID extracts session ID from hook input.\\n\\tGetSessionID(input *HookInput) string\\n\\n\\t// GetSessionDir returns where agent stores session data for this repo.\\n\\tGetSessionDir(repoPath string) (string, error)\\n\\n\\t// ResolveSessionFile returns the path to the session transcript file.\\n\\tResolveSessionFile(sessionDir, agentSessionID string) string\\n\\n\\t// ReadSession reads session data from agent's storage.\\n\\tReadSession(input *HookInput) (*AgentSession, error)\\n\\n\\t// WriteSession writes session data for resumption.\\n\\tWriteSession(ctx context.Context, session *AgentSession) error\\n\\n\\t// FormatResumeCommand returns command to resume a session.\\n\\tFormatResumeCommand(sessionID string) string\\n}\\n\\n// HookSupport is implemented by agents with lifecycle hooks.\\n// This optional interface allows agents like Claude Code and Cursor to\\n// install and manage hooks that notify Entire of agent events.\\n//\\n// The interface is organized into two groups:\\n//   - Hook Mapping (2 methods): HookNames, ParseHookEvent\\n//   - Hook Management (3 methods): InstallHooks, UninstallHooks, AreHooksInstalled\\ntype HookSupport interface {\\n\\tAgent\\n\\n\\t// HookNames returns the hook verbs this agent supports.\\n\\t// These become subcommands under `entire hooks <agent>`.\\n\\t// e.g., [\\\"stop\\\", \\\"user-prompt-submit\\\", \\\"session-start\\\", \\\"session-end\\\"]\\n\\tHookNames() []string\\n\\n\\t// ParseHookEvent translates an agent-native hook into a normalized lifecycle Event.\\n\\t// Returns nil if the hook has no lifecycle significance (e.g., pass-through hooks).\\n\\t// This is the core contribution surface for new agent implementations.\\n\\tParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*Event, error)\\n\\n\\t// InstallHooks installs agent-specific hooks.\\n\\t// If localDev is true, hooks point to local development build.\\n\\t// If force is true, removes existing Entire hooks before installing.\\n\\t// Returns the number of hooks installed.\\n\\tInstallHooks(ctx context.Context, localDev bool, force bool) (int, error)\\n\\n\\t// UninstallHooks removes installed hooks\\n\\tUninstallHooks(ctx context.Context) error\\n\\n\\t// AreHooksInstalled checks if hooks are currently installed\\n\\tAreHooksInstalled(ctx context.Context) bool\\n}\\n\\n// FileWatcher is implemented by agents that use file-based detection.\\n// Agents like Aider that don't support hooks can use file watching\\n// to detect session activity.\\ntype FileWatcher interface {\\n\\tAgent\\n\\n\\t// GetWatchPaths returns paths to watch for session changes\\n\\tGetWatchPaths() ([]string, error)\\n\\n\\t// OnFileChange handles a detected file change and returns session info\\n\\tOnFileChange(path string) (*SessionChange, error)\\n}\\n\\n// TranscriptAnalyzer provides format-specific transcript parsing.\\n// Agents that implement this get richer checkpoints (transcript-derived file lists,\\n// prompts, summaries). Agents that don't still participate in the checkpoint lifecycle\\n// via git-status-based file detection and raw transcript storage.\\ntype TranscriptAnalyzer interface {\\n\\tAgent\\n\\n\\t// GetTranscriptPosition returns the current position (length) of a transcript.\\n\\t// For JSONL formats (Claude Code), this is the line count.\\n\\t// For JSON formats (Gemini CLI), this is the message count.\\n\\t// Returns 0 if the file doesn't exist or is empty.\\n\\tGetTranscriptPosition(path string) (int, error)\\n\\n\\t// ExtractModifiedFilesFromOffset extracts files modified since a given offset.\\n\\t// For JSONL formats (Claude Code), offset is the starting line number.\\n\\t// For JSON formats (Gemini CLI), offset is the starting message index.\\n\\t// Returns:\\n\\t//   - files: list of file paths modified by the agent (from Write/Edit tools)\\n\\t//   - currentPosition: the current position (line count or message count)\\n\\t//   - error: any error encountered during reading\\n\\tExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error)\\n\\n\\t// ExtractPrompts extracts user prompts from the transcript starting at the given offset.\\n\\tExtractPrompts(sessionRef string, fromOffset int) ([]string, error)\\n\\n\\t// ExtractSummary extracts a summary of the session from the transcript.\\n\\tExtractSummary(sessionRef string) (string, error)\\n}\\n\\n// TranscriptPreparer is called before ReadTranscript to handle agent-specific\\n// flush/s