 paths.WorktreeRoot(ctx)\\n    50→\\tif err != nil {\\n    51→\\t\\tworktreeRoot = \\\".\\\"\\n    52→\\t}\\n    53→\\tif _, err := os.Stat(filepath.Join(worktreeRoot, \\\".kiro\\\")); err == nil {\\n    54→\\t\\treturn true, nil\\n    55→\\t}\\n    56→\\treturn false, nil\\n    57→}\\n    58→\\n    59→// --- Transcript Storage ---\\n    60→\\n    61→// ReadTranscript reads the cached transcript JSON for a session.\\n    62→func (k *KiroAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    63→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    64→\\tif err != nil {\\n    65→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    66→\\t}\\n    67→\\treturn data, nil\\n    68→}\\n    69→\\n    70→// ChunkTranscript splits a JSON transcript into chunks.\\n    71→// Kiro transcripts are single JSON objects; we use the JSONL chunker since the\\n    72→// cached format is a JSON blob that fits in a single chunk in most cases.\\n    73→func (k *KiroAgent) ChunkTranscript(_ context.Context, content []byte, maxSize int) ([][]byte, error) {\\n    74→\\tif len(content) <= maxSize {\\n    75→\\t\\treturn [][]byte{content}, nil\\n    76→\\t}\\n    77→\\t// For large transcripts, split at line boundaries\\n    78→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    79→\\tif err != nil {\\n    80→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n    81→\\t}\\n    82→\\treturn chunks, nil\\n    83→}\\n    84→\\n    85→// ReassembleTranscript combines transcript chunks back into a single blob.\\n    86→func (k *KiroAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    87→\\tif len(chunks) == 1 {\\n    88→\\t\\treturn chunks[0], nil\\n    89→\\t}\\n    90→\\treturn agent.ReassembleJSONL(chunks), nil\\n    91→}\\n    92→\\n    93→// --- Session Management ---\\n    94→\\n    95→// GetSessionID extracts the session ID from hook input.\\n    96→func (k *KiroAgent) GetSessionID(input *agent.HookInput) string {\\n    97→\\treturn input.SessionID\\n    98→}\\n    99→\\n   100→// GetSessionDir returns the directory where Kiro stores session data.\\n   101→// For Kiro, sessions are in SQLite, but we cache transcripts to .entire/tmp/.\\n   102→func (k *KiroAgent) GetSessionDir(repoPath string) (string, error) {\\n   103→\\treturn filepath.Join(repoPath, \\\".entire\\\", \\\"tmp\\\"), nil\\n   104→}\\n   105→\\n   106→// ResolveSessionFile returns the path to the cached transcript file.\\n   107→func (k *KiroAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   108→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".json\\\")\\n   109→}\\n   110→\\n   111→// ReadSession reads session data from the cached transcript.\\n   112→func (k *KiroAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   113→\\tif input.SessionRef == \\\"\\\" {\\n   114→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   115→\\t}\\n   116→\\n   117→\\tdata, err := os.ReadFile(input.SessionRef)\\n   118→\\tif err != nil {\\n   119→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   120→\\t}\\n   121→\\n   122→\\treturn &agent.AgentSession{\\n   123→\\t\\tSessionID:  input.SessionID,\\n   124→\\t\\tAgentName:  k.Name(),\\n   125→\\t\\tSessionRef: input.SessionRef,\\n   126→\\t\\tStartTime:  time.Now(),\\n   127→\\t\\tNativeData: data,\\n   128→\\t}, nil\\n   129→}\\n   130→\\n   131→// WriteSession writes session data for resumption.\\n   132→func (k *KiroAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   133→\\tif session == nil {\\n   134→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   135→\\t}\\n   136→\\tif session.AgentName != \\\"\\\" && session.AgentName != k.Name() {\\n   137→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, k.Name())\\n   138→\\t}\\n   139→\\tif session.SessionRef == \\\"\\\" {\\n   140→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   141→\\t}\\n   142→\\tif len(session.NativeData) == 0 {\\n   143→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   144→\\t}\\n   145→\\n   146→\\tif err := os.MkdirAll(filepath.Dir(session.SessionRef), 0o750); err != nil {\\n   147→\\t\\treturn fmt.Errorf(\\\"failed to create session dir: %w\\\", err)\\n   148→\\t}\\n   149→\\n   150→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   151→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   152→\\t}\\n   153→\\treturn nil\\n   154→}\\n   155→\\n   156→// FormatResumeCommand returns the command to resume a Kiro session.\\n   157→func (k *KiroAgent) FormatResumeCommand(_ string) string {\\n   158→\\treturn \\\"kiro-cli chat --resume\\\"\\n   159→}\\n   160→\\n   161→// GetHookConfigPath returns the path to the hook config file relative to repo root.\\n   162→func (k *KiroAgent) GetHookConfigPath() string {\\n   163→\\treturn filepath.Join(\\\".kiro\\\", hooksDir, HooksFileName)\\n   164→}\\n   165→\\n   166→// --- TranscriptAnalyzer interface implementation ---\\n   167→\\n   168→// errTranscriptEmpty is returned when the transcript file is missing or empty.\\n   169→var errTranscriptEmpty = errors.New(\\\"transcript is empty or missing\\\")\\n   170→\\n   171→// readAndParseTranscript reads and parses a Kiro transcript file.\\n   172→// Returns errTranscriptEmpty if the file doesn't exist or is empty.\\n   173→func readAndParseTranscript(path string) (*kiroTranscript, error) {\\n   174→\\tdata, err := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   175→\\tif err != nil {\\n   176→\\t\\tif os.IsNotExist(err) {\\n   177→\\t\\t\\treturn nil, errTranscriptEmpty\\n   178→\\t\\t}\\n   179→\\t\\treturn nil, fmt.Errorf(\\\"reading transcript: %w\\\", err)\\n   180→\\t}\\n   181→\\tif len(data) == 0 {\\n   182→\\t\\treturn nil, errTranscriptEmpty\\n   183→\\t}\\n   184→\\tt, err := parseTranscript(data)\\n   185→\\tif err != nil {\\n   186→\\t\\treturn nil, fmt.Errorf(\\\"parsing transcript: %w\\\", err)\\n   187→\\t}\\n   188→\\treturn t, nil\\n   189→}\\n   190→\\n   191→// GetTranscriptPosition returns the number of history entries in a Kiro transcript.\\n   192→// Kiro uses JSON format with paired user+assistant history entries, so position\\n   193→// is the entry count. Returns 0 if the file doesn't exist, is empty, or is a\\n   194→// placeholder \\\"{}\\\".\\n   195→func (k *KiroAgent) GetTranscriptPosition(path string) (int, error) {\\n   196→\\tif path == \\\"\\\" {\\n   197→\\t\\treturn 0, nil\\n   198→\\t}\\n   199→\\tt, err := readAndParseTranscript(path)\\n   200→\\tif errors.Is(err, errTranscriptEmpty) {\\n   201→\\t\\treturn 0, nil\\n   202→\\t}\\n   203→\\tif err != nil {\\n   204→\\t\\treturn 0, err\\n   205→\\t}\\n   206→\\treturn len(t.History), nil\\n   207→}\\n   208→\\n   209→// ExtractModifiedFilesFromOffset extracts files modified since a given history index.\\n   210→// For Kiro (JSON format), offset is the starting history entry index.\\n   211→func (k *KiroAgent) ExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error) {\\n   212→\\tif path == \\\"\\\" {\\n   213→\\t\\treturn nil, 0, nil\\n   214→\\t}\\n   215→\\tt, parseErr := readAndParseTranscript(path)\\n   216→\\tif errors.Is(parseErr, errTranscriptEmpty) {\\n   217→\\t\\treturn nil, 0, nil\\n   218→\\t}\\n   219→\\tif parseErr != nil {\\n   220→\\t\\treturn nil, 0, parseErr\\n   221→\\t}\\n   222→\\n   223→\\ttotalEntries := len(t.History)\\n   224→\\tif startOffset >= totalEntries {\\n   225→\\t\\treturn nil, totalEntries, nil\\n   226→\\t}\\n   227→\\n   228→\\tmodifiedFiles := extractModifiedFilesFromHistory(t.History[startOffset:])\\n   229→\\treturn modifiedFiles, totalEntries, nil\\n   230→}\\n   231→\\n   232→// ExtractPrompts extracts user prompts from the transcript starting at the given offset.\\n   233→// Only Prompt-type user messages are returned; ToolUseResults entries are skipped.\\n   234→func (k *KiroAgent) ExtractPrompts(sessionRef string, fromOffset int) ([]string, error) {\\n   235→\\tt, err := readAndParseTranscript(sessionRef)\\n   236→\\tif err != nil {\\n   237→\\t\\treturn nil, err\\n   238→\\t}\\n   239→\\n   240→\\tvar prompts []string\\n   241→\\tfor i := fromOffset; i < len(t.History); i++ {\\n   242→\\t\\tif prompt := extractUserPrompt(t.History[i].User.Content); prompt != \\\"\\\" {\\n   243→\\t\\t\\tprompts = append(prompts, prompt)\\n   244→\\t\\t}\\n   245→\\t}\\n   246→\\treturn prompts, nil\\n   247→}\\n   248→\\n   249→// ExtractSummary extracts the last assistant response as a session summary.\\n   250→func (k *KiroAgent) ExtractSummary(sessionRef string) (string, error) {\\n   251→\\tt, err := readAndParseTranscript(sessionRef)\\n   252→\\tif err != nil {\\n   253→\\t\\treturn \\\"\\\", err\\n   254→\\t}\\n   255→\\treturn extractLastAssistantResponse(t.History), nil\\n   256→}\\n   257→\\n   258→// --- SQLite helpers ---\\n   259→\\n   260→// escapeSQLString escapes single quotes for use in SQLite string literals.\\n   261→func escapeSQLString(s string) string {\\n   262→\\treturn strings.ReplaceAll(s, \\\"'\\\", \\\"''\\\")\\n   263→}\\n   264→\\n   265→// --- SQLite session resolution ---\\n   266→\\n   267→// dbPath returns the path to Kiro's SQLite database.\\n   268→func dbPath() (string, error) {\\n   269→\\thome, err := os.UserHomeDir()\\n   270→\\tif err != nil {\\n   271→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   272→\\t}\\n   273→\\tswitch runtime.GOOS {\\n   274→\\tcase \\\"darwin\\\":\\n   275→\\t\\treturn filepath.Join(home, \\\"Library\\\", \\\"Application Support\\\", \\\"kiro-cli\\\", \\\"data.sqlite3\\\"), nil\\n   276→\\tdefault: // linux\\n   277→\\t\\treturn filepath.Join(home, \\\".local\\\", \\\"share\\\", \\\"kiro-cli\\\", \\\"data.sqlite3\\\"), nil\\n   278→\\t}\\n   279→}\\n   280→\\n   281→// querySessionID queries the SQLite database for the most recent conversation ID\\n   282→// associated with the given CWD.\\n   283→func (k *KiroAgent) querySessionID(ctx context.Context, cwd string) (string, error) {\\n   284→\\tif os.Getenv(\\\"ENTIRE_TEST_KIRO_MOCK_DB\\\") == \\\"1\\\" {\\n   285→\\t\\treturn \\\"mock-session-id\\\", nil\\n   286→\\t}\\n   287→\\n   288→\\tdb, err := dbPath()\\n   289→\\tif err != nil {\\n   290→\\t\\treturn \\\"\\\", err\\n   291→\\t}\\n   292→\\tif _, err := os.Stat(db); err != nil {\\n   293→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"kiro database not found at %s: %w\\\", db, err)\\n   294→\\t}\\n   295→\\n   296→\\tquery := fmt.Sprintf(\\n   297→\\t\\t\\\"SELECT json_extract(value, '$.conversation_id') FROM conversations_v2 WHERE key = '%s' ORDER BY updated_at DESC LIMIT 1\\\",\\n   298→\\t\\tescapeSQLString(cwd),\\n   299→\\t)\\n   300→\\n   301→\\tcmd := exec.CommandContext(ctx, \\\"sqlite3\\\", \\\"-json\\\", db, query)\\n   302→\\tout, err := cmd.Output()\\n   303→\\tif err != nil {\\n   304→\\t\\tlogging.Warn(ctx, \\\"kiro: sqlite3 query failed\\\", \\\"err\\\", err, \\\"cwd\\\", cwd)\\n   305→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"sqlite3 query failed: %w\\\", err)\\n   306→\\t}\\n   307→\\n   308→\\tresult := strings.TrimSpace(string(out))\\n   309→\\tif result == \\\"\\\" || result == \\\"[]\\\" {\\n   310→\\t\\treturn \\\"\\\", nil\\n   311→\\t}\\n   312→\\n   313→\\t// sqlite3 -json returns an array of objects\\n   314→\\tvar rows []map[string]string\\n   315→\\tif err := json.Unmarshal([]byte(result), &rows); err != nil {\\n   316→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse sqlite3 output: %w\\\", err)\\n   317→\\t}\\n   318→\\tif len(rows) == 0 {\\n   319→\\t\\treturn \\\"\\\", nil\\n   320→\\t}\\n   321→\\n   322→\\t// The column name from json_extract\\n   323→\\tfor _, v := range rows[0] {\\n   324→\\t\\treturn v, nil\\n   325→\\t}\\n   326→\\treturn \\\"\\\", nil\\n   327→}\\n   328→\\n   329→// ensureCachedTranscript fetches the conversation from SQLite and caches it\\n   330→// to .entire/tmp/<sessionID>.json. Returns the cache file path.\\n   331→func (k *KiroAgent) ensureCachedTranscript(ctx context.Context, cwd, sessionID string) (string, error) {\\n   332→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   333→\\tif err != nil {\\n   334→\\t\\trepoRoot = cwd\\n   335→\\t}\\n   336→\\n   337→\\tcacheDir := filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\")\\n   338→\\tcachePath := filepath.Join(cacheDir, sessionID+\\\".json\\\")\\n   339→\\n   340→\\t// Fetch fresh transcript from SQLite on every call (transcript grows during session)\\n   341→\\tif os.Getenv(\\\"ENTIRE_TEST_KIRO_MOCK_DB\\\") == \\\"1\\\" {\\n   342→\\t\\t// In test mode, return the expected cache path without hitting SQLite.\\n   343→\\t\\treturn cachePath, nil\\n   344→\\t}\\n   345→\\n   346→\\tdb, err := dbPath()\\n   347→\\tif err != nil {\\n   348→\\t\\treturn \\\"\\\", err\\n   349→\\t}\\n   350→\\n   351→\\tquery := fmt.Sprintf(\\n   352→\\t\\t\\\"SELECT value FROM conversations_v2 WHERE key = '%s' ORDER BY updated_at DESC LIMIT 1\\\",\\n   353→\\t\\tescapeSQLString(cwd),\\n   354→\\t)\\n   355→\\n   356→\\tcmd := exec.CommandContext(ctx, \\\"sqlite3\\\", db, query)\\n   357→\\tout, err := cmd.Output()\\n   358→\\tif err != nil {\\n   359→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"sqlite3 transcript query failed: %w\\\", err)\\n   360→\\t}\\n   361→\\n   362→\\ttranscript := strings.TrimSpace(string(out))\\n   363→\\tif transcript == \\\"\\\" {\\n   364→\\t\\treturn \\\"\\\", errors.New(\\\"no transcript found\\\")\\n   365→\\t}\\n   366→\\n   367→\\tif err := os.MkdirAll(cacheDir, 0o750); err != nil {\\n   368→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create cache dir: %w\\\", err)\\n   369→\\t}\\n   370→\\n   371→\\tif err := os.WriteFile(cachePath, []byte(transcript), 0o600); err != nil {\\n   372→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write cached transcript: %w\\\", err)\\n   373→\\t}\\n   374→\\n   375→\\treturn cachePath, nil\\n   376→}\\n   377→\\n   378→// --- IDE transcript discovery ---\\n   379→\\n   380→// ideWorkspaceSessionsDir returns the directory where the Kiro IDE stores\\n   381→// session files for the given working directory. The directory is derived from\\n   382→// the base64-encoded CWD.\\n   383→func ideWorkspaceSessionsDir(cwd string) (string, error) {\\n   384→\\thome, err := os.UserHomeDir()\\n   385→\\tif err != nil {\\n   386→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   387→\\t}\\n   388→\\n   389→\\tencoded := base64.StdEncoding.EncodeToString([]byte(cwd))\\n   390→\\n   391→\\tvar baseDir string\\n   392→\\tswitch runtime.GOOS {\\n   393→\\tcase \\\"darwin\\\":\\n   394→\\t\\tbaseDir = filepath.Join(home, \\\"Library\\\", \\\"Application Support\\\", \\\"Kiro\\\", \\\"User\\\", \\\"globalStorage\\\", \\\"kiro.kiroagent\\\", \\\"workspace-sessions\\\")\\n   395→\\tdefault: // linux\\n   396→\\t\\tbaseDir = filepath.Join(home, \\\".config\\\", \\\"Kiro\\\", \\\"User\\\", \\\"globalStorage\\\", \\\"kiro.kiroagent\\\", \\\"workspace-sessions\\\")\\n   397→\\t}\\n   398→\\n   399→\\treturn filepath.Join(baseDir, encoded), nil\\n   400→}\\n   401→\\n   402→// ensureIDETranscript looks for the most recent Kiro IDE session transcript\\n   403→// for the given CWD and copies it to .entire/tmp/<sessionID>.json.\\n   404→// Returns the cache path on success, or empty string if no transcript is found.\\n   405→func (k *KiroAgent) ensureIDETranscript(ctx context.Context, cwd, sessionID string) (string, error) {\\n   406→\\tsessDir, err := ideWorkspaceSessionsDir(cwd)\\n   407→\\tif err != nil {\\n   408→\\t\\treturn \\\"\\\", err\\n   409→\\t}\\n   410→\\n   411→\\t// Read the sessions.json index.\\n   412→\\tindexPath := filepath.Join(sessDir, \\\"sessions.json\\\")\\n   413→\\tindexData, err := os.ReadFile(indexPath) //nolint:gosec // Controlled path from IDE storage\\n   414→\\tif err != nil {\\n   415→\\t\\tlogging.Debug(ctx, \\\"kiro: IDE sessions.json not found\\\", \\\"path\\\", indexPath, \\\"err\\\", err)\\n   416→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"IDE sessions.json not found: %w\\\", err)\\n   417→\\t}\\n   418→\\n   419→\\tvar sessions []kiroIDESessionEntry\\n   420→\\tif err := json.Unmarshal(indexData, &sessions); err != nil {\\n   421→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse IDE sessions.json: %w\\\", err)\\n   422→\\t}\\n   423→\\n   424→\\tif len(sessions) == 0 {\\n   425→\\t\\treturn \\\"\\\", errors.New(\\\"no IDE sessions found\\\")\\n   426→\\t}\\n   427→\\n   428→\\t// Sort by dateCreated descending to find the most recent session.\\n   429→\\tsort.Slice(sessions, func(i, j int) bool {\\n   430→\\t\\treturn sessions[i].DateCreated > sessions[j].DateCreated\\n   431→\\t})\\n   432→\\n   433→\\t// Read the most recent session's transcript.\\n   434→\\tlatestSession := sessions[0]\\n   435→\\ttranscriptPath := filepath.Join(sessDir, latestSession.SessionID+\\\".json\\\")\\n   436→\\ttranscriptData, err := os.ReadFile(transcriptPath) //nolint:gosec // Controlled path from IDE storage\\n   437→\\tif err != nil {\\n   438→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read IDE transcript %s: %w\\\", transcriptPath, err)\\n   439→\\t}\\n   440→\\n   441→\\t// Cache the transcript under our session ID.\\n   442→\\trepoRoot, rootErr := paths.WorktreeRoot(ctx)\\n   443→\\tif rootErr != nil {\\n   444→\\t\\trepoRoot = cwd\\n   445→\\t}\\n   446→\\n   447→\\tcacheDir := filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\")\\n   448→\\tcachePath := filepath.Join(cacheDir, sessionID+\\\".json\\\")\\n   449→\\n   450→\\tif err := os.MkdirAll(cacheDir, 0o750); err != nil {\\n   451→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create cache dir: %w\\\", err)\\n   452→\\t}\\n   453→\\n   454→\\tif err := os.W