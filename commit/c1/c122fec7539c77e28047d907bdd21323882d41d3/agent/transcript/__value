dError marks the span as errored. Only the first non-nil error is stored;\\n   835â†’+// subsequent calls are no-ops. Call this before End() on error paths.\\n   836â†’+func (s *Span) RecordError(err error) {\\n   837â†’+\\tif err == nil || s.err != nil {\\n   838â†’+\\t\\treturn\\n   839â†’+\\t}\\n   840â†’+\\ts.err = err\\n   841â†’+}\\n   842â†’+\\n   843â†’+// End completes the span. For root spans, emits a single DEBUG log line\\n   844â†’+// with the full timing tree. For child spans, records the duration only.\\n   845â†’+// Safe to call multiple times -- subsequent calls are no-ops.\\n   846â†’+func (s *Span) End() {\\n   847â†’+\\tif s.ended {\\n   848â†’+\\t\\treturn\\n   849â†’+\\t}\\n   850â†’+\\ts.ended = true\\n   851â†’+\\ts.duration = time.Since(s.start)\\n   852â†’+\\n   853â†’+\\t// Only root spans emit log output\\n   854â†’+\\tif s.parent != nil {\\n   855â†’+\\t\\treturn\\n   856â†’+\\t}\\n   857â†’+\\n   858â†’+\\t// Build log attributes: component, op, duration_ms, error flag, then child step durations.\\n   859â†’+\\t// The \\\"component\\\" key is intentionally set to \\\"perf\\\" for easy filtering,\\n   860â†’+\\t// even if the context already has a component set via logging.WithComponent().\\n   861â†’+\\tattrs := make([]any, 0, 4+2*len(s.children)+len(s.attrs))\\n   862â†’+\\tattrs = append(attrs, slog.String(\\\"component\\\", \\\"perf\\\"))\\n   863â†’+\\tattrs = append(attrs, slog.String(\\\"op\\\", s.name))\\n   864â†’+\\tattrs = append(attrs, slog.Int64(\\\"duration_ms\\\", s.duration.Milliseconds()))\\n   865â†’+\\tif s.err != nil {\\n   866â†’+\\t\\tattrs = append(attrs, slog.Bool(\\\"error\\\", true))\\n   867â†’+\\t}\\n   868â†’+\\n   869â†’+\\t// Add child step durations (and error flags) as flat keys\\n   870â†’+\\tfor _, child := range s.children {\\n   871â†’+\\t\\t// Auto-end children that were not explicitly ended\\n   872â†’+\\t\\tif !child.ended {\\n   873â†’+\\t\\t\\tchild.ended = true\\n   874â†’+\\t\\t\\tchild.duratio