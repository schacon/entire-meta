\tspan.End()\\n  1018â†’+\\n  1019â†’+\\tif len(span.children) != 1 {\\n  1020â†’+\\t\\tt.Fatalf(\\\"expected 1 child from Measure, got %d\\\", len(span.children))\\n  1021â†’+\\t}\\n  1022â†’+\\tchild := span.children[0]\\n  1023â†’+\\tif child.name != \\\"substep\\\" {\\n  1024â†’+\\t\\tt.Errorf(\\\"child.name = %q, want %q\\\", child.name, \\\"substep\\\")\\n  1025â†’+\\t}\\n  1026â†’+\\tif child.duration < 10*time.Millisecond {\\n  1027â†’+\\t\\tt.Errorf(\\\"child.duration = %v, want >= 10ms\\\", child.duration)\\n  1028â†’+\\t}\\n  1029â†’+}\\n  1030â†’+\\n  1031â†’+func TestSpanFromContext_ReturnsNilWhenEmpty(t *testing.T) {\\n  1032â†’+\\tt.Parallel()\\n  1033â†’+\\tctx := context.Background()\\n  1034â†’+\\n  1035â†’+\\tif got := spanFromContext(ctx); got != nil {\\n  1036â†’+\\t\\tt.Errorf(\\\"spanFromContext on empty context = %v, want nil\\\", got)\\n  1037â†’+\\t}\\n  1038â†’+}\\n  1039â†’+\\n  1040â†’+func TestStart_MultipleChildren(t *testing.T) {\\n  1041â†’+\\tt.Parallel()\\n  1042â†’+\\tctx := context.Background()\\n  1043â†’+\\n  1044â†’+\\tctx, parent := Start(ctx, \\\"parent\\\")\\n  1045â†’+\\n  1046â†’+\\tctx2, child1 := Start(ctx, \\\"child1\\\")\\n  1047â†’+\\t_ = ctx2\\n  1048â†’+\\tchild1.End()\\n  1049â†’+\\n  1050â†’+\\tctx3, child2 := Start(ctx, \\\"child2\\\")\\n  1051â†’+\\t_ = ctx3\\n  1052â†’+\\tchild2.End()\\n  1053â†’+\\n  1054â†’+\\tparent.End()\\n  1055â†’+\\n  1056â†’+\\tif len(parent.children) != 2 {\\n  1057â†’+\\t\\tt.Fatalf(\\\"expected 2 children, got %d\\\", len(parent.children))\\n  1058â†’+\\t}\\n  1059â†’+\\tif parent.children[0].name != \\\"child1\\\" {\\n  1060â†’+\\t\\tt.Errorf(\\\"first child name = %q, want %q\\\", parent.children[0].name, \\\"child1\\\")\\n  1061â†’+\\t}\\n  1062â†’+\\tif parent.children[1].name != \\\"child2\\\" {\\n  1063â†’+\\t\\tt.Errorf(\\\"second child name = %q, want %q\\\", parent.children[1].name, \\\"child2\\\")\\n  1064â†’+\\t}\\n  1065â†’+}\\n  1066â†’+\\n  1067â†’+func TestRecordError