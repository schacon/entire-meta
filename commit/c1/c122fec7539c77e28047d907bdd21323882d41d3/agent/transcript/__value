bool\\n   814â†’+\\terr      error\\n   815â†’+}\\n   816â†’+\\n   817â†’+// Start begins a new span. If ctx already has a span, the new one becomes a child.\\n   818â†’+// Returns the updated context and the span. Call span.End() when the operation completes.\\n   819â†’+func Start(ctx context.Context, name string, attrs ...slog.Attr) (context.Context, *Span) {\\n   820â†’+\\tparent := spanFromContext(ctx)\\n   821â†’+\\ts := &Span{\\n   822â†’+\\t\\tname:   name,\\n   823â†’+\\t\\tstart:  time.Now(),\\n   824â†’+\\t\\tparent: parent,\\n   825â†’+\\t\\tattrs:  attrs,\\n   826â†’+\\t\\tctx:    ctx,\\n   827â†’+\\t}\\n   828â†’+\\tif parent != nil {\\n   829â†’+\\t\\tparent.children = append(parent.children, s)\\n   830â†’+\\t}\\n   831â†’+\\treturn contextWithSpan(ctx, s), s\\n   832â†’+}\\n   833â†’+\\n   834â†’+// RecordError marks the span as errored. Only the first non-nil error is stored;\\n   835â†’+// subsequent calls are no-ops. Call this before End() on error paths.\\n   836â†’+func (s *Span) RecordError(err error) {\\n   837â†’+\\tif err == nil || s.err != nil {\\n   838â†’+\\t\\treturn\\n   839â†’+\\t}\\n   840â†’+\\ts.err = err\\n   841â†’+}\\n   842â†’+\\n   843â†’+// End completes the span. For root spans, emits a single DEBUG log line\\n   844â†’+// with the full timing tree. For child spans, records the duration only.\\n   845â†’+// Safe to call multiple times -- subsequent calls are no-ops.\\n   846â†’+func (s *Span) End() {\\n   847â†’+\\tif s.ended {\\n   848â†’+\\t\\treturn\\n   849â†’+\\t}\\n   850â†’+\\ts.ended = true\\n   851â†’+\\ts.duration = time.Since(s.start)\\n   852â†’+\\n   853â†’+\\t// Only root spans emit log output\\n   854â†’+\\tif s.parent != nil {\\n   855â†’+\\t\\treturn\\n   856â†’+\\t}\\n   857â†’+\\n   858â†’+\\t// Build log attributes: component, op, duration_ms, error flag, then child step durations.\\n   859â†’+\\t// The \\\"component\\\" key is intentionally set to \\\"perf\\\" for easy filtering,\\n   860â†’+\\t// even if the context already has a component set via logging.WithComponent().\\n   861â†’+\\tattrs := make([]any, 0, 4+2*len(s.children)+len(s.attrs))\\n   862â†’+\\tattrs = append(attrs, slog.String(\\\"component\\\", \\\"perf\\\"))\\n   863â†’+\\tattrs = append(attrs, slog.String(\\\"op\\\", s.name))\\n   864â†’+\\tattrs = append(attrs, slog.Int64(\\\"duration_ms\\\", s.duration.Milliseconds()))\\n   865â†’+\\tif s.err != nil {\\n   866â†’+\\t\\tattrs = append(attrs, slog.Bool(\\\"error\\\", true))\\n   867â†’+\\t}\\n   868â†’+\\n   869â†’+\\t// Add child step durations (and error flags) as flat keys\\n   870â†’+\\tfor _, child := range s.children {\\n   871â†’+\\t\\t// Auto-end children that were not explicitly ended\\n   872â†’+\\t\\tif !child.ended {\\n   873â†’+\\t\\t\\tchild.ended = true\\n   874â†’+\\t\\t\\tchild.duration = time.Since(child.start)\\n   875â†’+\\t\\t}\\n   876â†’+\\t\\tkey := fmt.Sprintf(\\\"steps.%s_ms\\\", child.name)\\n   877â†’+\\t\\tattrs = append(attrs, slog.Int64(key, child.duration.Milliseconds()))\\n   878â†’+\\t\\tif child.err != nil {\\n   879â†’+\\t\\t\\terrKey := fmt.Sprintf(\\\"steps.%s_err\\\", child.name)\\n   880â†’+\\t\\t\\tattrs = append(attrs, slog.Bool(errKey, true))\\n   881â†’+\\t\\t}\\n   882â†’+\\t}\\n   883â†’+\\n   884â†’+\\t// Add any extra attributes from Start()\\n   885â†’+\\tfor _, a := range s.attrs {\\n   886â†’+\\t\\tattrs = append(attrs, a)\\n   887â†’+\\t}\\n   888â†’+\\n   889â†’+\\tlogging.Debug(s.ctx, \\\"perf\\\", attrs...)\\n   890â†’+}\\n   891â†’+\\n   892â†’+// Measure times a function as a child substep of this span.\\n   893â†’+func (s *Span) Measure(name string, fn func()) {\\n   894â†’+\\tctx := contextWithSpan(s.ctx, s)\\n   895â†’+\\t_, child := Start(ctx, name)\\n   896â†’+\\tdefer child.End()\\n   897â†’+\\tfn()\\n   898â†’+}\\n   899â†’diff --git a/perf/span_test.go b/perf/span_test.go\\n   900â†’new file mode 100644\\n   901â†’index 00000000..04bb4d98\\n   902â†’--- /dev/null\\n   903â†’+++ b/perf/span_test.go\\n   904â†’@@ -0,0 +1,248 @@\\n   905â†’+package perf\\n   906â†’+\\n   907â†’+import (\\n   908â†’+\\t\\\"context\\\"\\n   909â†’+\\t\\\"errors\\\"\\n   910â†’+\\t\\\"testing\\\"\\n   911â†’+\\t\\\"time\\\"\\n   912â†’+)\\n   913â†’+\\n   914â†’+func TestStart_CreatesRootSpan(t *testing.T) {\\n   915â†’+\\tt.Parallel()\\n   916â†’+\\tctx := context.Background()\\n   917â†’+\\n   918â†’+\\tctx, span := Start(ctx, \\\"test_op\\\")\\n   919â†’+\\tif span == nil {\\n   920â†’+\\t\\tt.Fatal(\\\"Start() returned nil span\\\")\\n   921â†’+\\t}\\n   922â†’+\\tif span.name != \\\"test_op\\\" {\\n   923â†’+\\t\\tt.Errorf(\\\"span.name = %q, want %q\\\", span.name, \\\"test_op\\\")\\n   924â†’+\\t}\\n   925â†’+\\tif span.parent != nil {\\n   926â†’+\\t\\tt.Error(\\\"root span should have nil parent\\\")\\n   927â†’+\\t}\\n   928â†’+\\n   929â†’+\\tgot := spanFromContext(ctx)\\n   930â†’+\\tif got != span {\\n   931â†’+\\t\\tt.Error(\\\"spanFromContext should return the span set by Start\\\")\\n   932â†’+\\t}\\n   933â†’+\\n   934â†’+\\tspan.End()\\n   935â†’+}\\n   936â†’+\\n   937â†’+func TestStart_NestsChildSpan(t *testing.T) {\\n   938â†’+\\tt.Parallel()\\n   939â†’+\\tctx := context.Background()\\n   940â†’+\\n   941â†’+\\tctx, parent := Start(ctx, \\\"parent\\\")\\n   942â†’+\\t_, child := Start(ctx, \\\"child\\\")\\n   943â†’+\\n   944â†’+\\tif child.parent != parent {\\n   945â†’+\\t\\tt.Error(\\\"child span should reference parent\\\")\\n   946â†’+\\t}\\n   947â†’+\\tif len(parent.children) != 1 {\\n   948â†’+\\t\\tt.Fatalf(\\\"parent should have 1 child, got %d\\\", len(parent.children))\\n   949â†’+\\t}\\n   950â†’+\\tif parent.children[0] != child {\\n   951â†’+\\t\\tt.Error(\\\"parent.children[0] should be the child span\\\")\\n   952â†’+\\t}\\n   953â†’+\\n   954â†’+\\tchild.End()\\n   955â†’+\\tparent.End()\\n   956â†’+}\\n   957â†’+\\n   958â†’+func TestEnd_RecordsDuration(t *testing.T) {\\n   959â†’+\\tt.Parallel()\\n   960â†’+\\tctx := context