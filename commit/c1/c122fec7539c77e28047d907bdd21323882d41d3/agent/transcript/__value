}\\n    29â†’\\n    30â†’\\tspan.End()\\n    31â†’}\\n    32â†’\\n    33â†’func TestStart_NestsChildSpan(t *testing.T) {\\n    34â†’\\tt.Parallel()\\n    35â†’\\tctx := context.Background()\\n    36â†’\\n    37â†’\\tctx, parent := Start(ctx, \\\"parent\\\")\\n    38â†’\\t_, child := Start(ctx, \\\"child\\\")\\n    39â†’\\n    40â†’\\tif child.parent != parent {\\n    41â†’\\t\\tt.Error(\\\"child span should reference parent\\\")\\n    42â†’\\t}\\n    43â†’\\tif len(parent.children) != 1 {\\n    44â†’\\t\\tt.Fatalf(\\\"parent should have 1 child, got %d\\\", len(parent.children))\\n    45â†’\\t}\\n    46â†’\\tif parent.children[0] != child {\\n    47â†’\\t\\tt.Error(\\\"parent.children[0] should be the child span\\\")\\n    48â†’\\t}\\n    49â†’\\n    50â†’\\tchild.End()\\n    51â†’\\tparent.End()\\n    52â†’}\\n    53â†’\\n    54â†’func TestEnd_RecordsDuration(t *testing.T) {\\n    55â†’\\tt.Parallel()\\n    56â†’\\tctx := context.Background()\\n    57â†’\\n    58â†’\\t_, span := Start(ctx, \\\"timed_op\\\")\\n    59â†’\\ttime.Sleep(10 * time.Millisecond)\\n    60â†’\\tspan.End()\\n    61â†’\\n    62â†’\\tif span.duration < 10*time.Millisecond {\\n    63â†’\\t\\tt.Errorf(\\\"span.duration = %v, want >= 10ms\\\", span.duration)\\n    64â†’\\t}\\n    65â†’}\\n    66â†’\\n    67â†’func TestEnd_Idempotent(t *testing.T) {\\n    68â†’\\tt.Parallel()\\n    69â†’\\tctx := context.Background()\\n    70â†’\\n    71â†’\\t_, span := Start(ctx, \\\"double_end\\\")\\n    72â†’\\ttime.Sleep(10 * time.Millisecond)\\n    73â†’\\tspan.End()\\n    74â†’\\n    75â†’\\tfirstDuration := span.duration\\n    76â†’\\n    77â†’\\ttime.Sleep(10 * time.Millisecond)\\n    78â†’\\tspan.End()\\n    79â†’\\n    80â†’\\tif span.duration != firstDuration {\\n    81â†’\\t\\tt.Errorf(\\\"second End() changed duration from %v to %v\\\", firstDuration, span.duration)\\n    82â†’\\t}\\n    83â†’}\\n    84â†’\\n    85â†’func TestEnd_AutoEndsChildren(t *testing.T) {\\n    86â†’\\tt.Parallel()\\n    87â†’\\tctx := context.Background()\\n    88â†’\\n    89â†’\\tctx, parent := Start(ctx, \\\"parent\\\")\\n    90â†’\\t_, child := Start(ctx, \\\"child\\\")\\n    91â†’\\n    92â†’\\ttime.Sleep(10 * time.Millisecond)\\n    93â†’\\tparent.End()\\n    94â†’\\n    95â†’\\tif !child.ended {\\n    96â†’\\t\\tt.Error(\\\"child should be auto-ended when parent ends\\\")\\n    97â†’\\t}\\n    98â†’\\tif child.duration == 0 {\\n    99â†’\\t\\tt.Error(\\\"child should have non-zero duration after auto-end\\\")\\n   100â†’\\t}\\n   101â†’}\\n   102â†’\\n   103â†’func TestMeasure_TimesFunction(t *testing.T) {\\n   104â†’\\tt.Parallel()\\n   105â†’\\tctx := context.Background()\\n   106â†’\\n   107â†’\\t_, span := Start(ctx, \\\"parent\\\")\\n   108â†’\\n   109â†’\\tspan.Measure(\\\"substep\\\", func() {\\n   110â†’\\t\\ttime.Sleep(10 * time.Millisecond)\\n   111â†’\\t})\\n   112â†’\\n   113â†’\\tspan.End()\\n   114â†’\\n   115â†’\\tif len(span.children) != 1 {\\n   116â†’\\t\\tt.Fatalf(\\\"expected 1 child from Measure, got %d\\\", len(span.children))\\n   117â†’\\t}\\n   118â†’\\tchild := span.children[0]\\n   119â†’\\tif child.name != \\\"substep\\\" {\\n   120â†’\\t\\tt.Errorf(\\\"child.name = %q, want %q\\\", child.name, \\\"substep\\\")\\n   121â†’\\t}\\n   122â†’\\tif child.duration < 10*time.Millisecond {\\n   123â†’\\t\\tt.Errorf(\\\"child.duration = %v, want >= 10ms\\\", child.duration)\\n   124â†’\\t}\\n   125â†’}\\n   126â†’\\n   127â†’func TestSpanFromContext_ReturnsNilWhenEmpty(t *testing.T) {\\n   128â†’\\tt.Parallel()\\n   129â†’\\tctx := context.Background()\\n   130â†’\\n   131â†’\\tif got := spanFromContext(ctx); got != nil {\\n   132â†’\\t\\tt.Errorf(\\\"spanFromContext on empty context = %v, want nil\\\", got)\\n   133â†’\\t}\\n   134â†’}\\n   135â†’\\n   136â†’func TestStart_MultipleChildren(t *testing.T) {\\n   137â†’\\tt.Parallel()\\n   138â†’\\tctx := context.Background()\\n   139â†’\\n   140â†’\\tctx, parent := Start(ctx, \\\"parent\\\")\\n   141â†’\\n   142â†’\\tctx2, child1 := Start(ctx, \\\"child1\\\")\\n   143â†’\\t_ = ctx2\\n   144â†’\\tchild1.End()\\n   145â†’\\n   146â†’\\tctx3, child2 := Start(ctx, \\\"child2\\\")\\n   147â†’\\t_ = ctx3\\n   148â†’\\tchild2.End()\\n   149â†’\\n   150â†’\\tparent.End()\\n   151â†’\\n   152â†’\\tif len(parent.children) != 2 {\\n   153â†’\\t\\tt.Fatalf(\\\"expected 2 children, got %d\\\", len(parent.children))\\n   154â†’\\t}\\n   155â†’\\tif parent.children[0].name != \\\"child1\\\" {\\n   156â†’\\t\\tt.Errorf(\\\"first child name = %q, want %q\\\", parent.children[0].name, \\\"child1\\\")\\n   157â†’\\t}\\n   158â†’\\tif parent.children[1].name != \\\"child2\\\" {\\n   159â†’\\t\\tt.Errorf(\\\"second child name = %q, want %q\\\", parent.children[1].name, \\\"child2\\\")\\n   160â†’\\t}\\n   161â†’}\\n   162â†’\\n   163â†’func TestRecordError_MarksSpanAsErrored(t *testing.T) {\\n   164â†’\\tt.Parallel()\\n   165â†’\\tctx := context.Background()\\n   166â†’\\n   167â†’\\t_, span := Start(ctx, \\\"op\\\")\\n   168â†’\\ttestErr := errors.New(\\\"something failed\\\")\\n   169â†’\\tspan.RecordError(testErr)\\n   170â†’\\n   171â†’\\tif !errors.Is(span.err, testErr) {\\n   172â†’\\t\\tt.Errorf(\\\"span.err = %v, want %v\\\", span.err, testErr)\\n   173â†’\\t}\\n   174â†’\\n   175â†’\\tspan.End()\\n   176â†’}\\n   177â†’\\n   178â†’func TestRecordError_NilIsNoOp(t *testing.T) {\\n   179â†’\\tt.Parallel()\\n   180â†’\\tctx := context.Background()\\n   181â†’\\n   182â†’\\t_, span := Start(ctx, \\\"op\\\")\\n   183â†’\\tspan.RecordError(nil)\\n   184â†’\\n   185â†’\\tif span.err != nil {\\n   186â†’\\t\\tt.Errorf(\\\"span.err = %v, want nil\\\", span.err)\\n   187â†’\\t}\\n   188â†’\\n   189â†’\\tspan.End()\\n   190â†’}\\n   191â†’\\n   192â†’func TestRecordError_FirstErrorWins(t *testing.T) {\\n   193â†’\\tt.Parallel()\\n   194â†’\\tctx := context.Background()\\n   195â†’\\n   196â†’\\t_, span := Start(ctx, \\\"op\\\")\\n   197â†’\\tfirstErr := errors.New(\\\"first\\\")\\n   198â†’\\tsecondErr := errors.New(\\\"second\\\")\\n   199â†’\\n   200â†’\\tspan.RecordError(firstErr)\\n   201â†’\\tspan.RecordError(secondErr)\\n   202â†’\\n   203â†’\\tif !errors.Is(span.err, firstErr) {\\n   204â†’\\t\\tt.Errorf(\\\"span.err = %v, want %v (first error)\\\", span.err, firstErr)\\n   205â†’\\t}\\n   206â†’\\n   207â†’\\tspan.End()\\n   208â†’}\\n   209â†’\\n   210â†’func TestRecordError_ChildErrorFlagInOutput(t *testing.T) {\\n   211â†’\\tt.Parallel()\\n   212â†’\\tctx := context.Background()\\n   213â†’\\n   214â†’\\tctx, parent := Start(ctx, \\\"parent\\\")\\n   215â†’\\t_, child := Start(ctx, \\\"failing_step\\\")\\n   216â†’\\n   217â†’\\tchild.RecordError(errors.New(\\\"step failed\\\"))\\n   218â†’\\tchild.End()\\n   219â†’\\tparent.End()\\n   220â†’\\n   221â†’\\t// Verify the child has the error recorded\\n   222â†’\\tif child.err == nil {\\n   223â†’\\t\\tt.Error(\\\"child span should have error recorded\\\")\\n   224â†’\\t}\\n   225â†’\\t// The error flag will appear as \\\"steps.failing_step_err: true\\\" in log output.\\n   226â†’\\t// We verify the span state directly since log output goes to slog.\\n   227â†’\\tif parent.children[0].err == nil {\\n   228â†’\\t\\tt.Error(\\\"parent's child should have error recorded\\\")\\n   229â†’\\t}\\n   230â†’}\\n   231â†’\\n   232â†’func TestEnd_NoErrorFlagByDefault(t *testing.T) {\\n   233â†’\\tt.Parallel()\\n   234â†’\\tctx := context.Background()\\n   235â†’\\n   236â†’\\tctx, parent := Start(ctx, \\\"parent\\\")\\n   237â†’\\t_, child := Start(ctx, \\\"ok_step\\\")\\n   238â†’\\n   239â†’\\tchild.End()\\n   240â†’\\tparent.End()\\n   241â†’\\n   242â†’\\tif child.err != nil {\\n   243â†’\\t\\tt.Errorf(\\\"child span should have nil error, got %v\\\", child.err)\\n   244â†’\\t}\\n   245â†’\\tif parent.err != nil {\\n   246â†’\\t\\tt.Errorf(\\\"parent span should have nil error, got %v\\\", parent.err)\\n   247â†’\\t}\\n   248â†’}\\n   249â†’\"}]},\"uuid\":\"98b8a725-c47c-483c-a4de-bc7a1c124707\",\"timestamp