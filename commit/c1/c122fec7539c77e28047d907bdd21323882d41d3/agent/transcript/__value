go implements the generic lifecycle event dispatcher.\\n     2â†’// It routes normalized events from any agent to the appropriate framework actions.\\n     3â†’//\\n     4â†’// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n     5â†’// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n     6â†’// the dispatcher handles all orchestration: state transitions, strategy calls,\\n     7â†’// file change detection, metadata generation.\\n     8â†’package cli\\n     9â†’\\n    10â†’import (\\n    11â†’\\t\\\"context\\\"\\n    12â†’\\t\\\"errors\\\"\\n    13â†’\\t\\\"fmt\\\"\\n    14â†’\\t\\\"log/slog\\\"\\n    15â†’\\t\\\"os\\\"\\n    16â†’\\t\\\"path/filepath\\\"\\n    17â†’\\t\\\"time\\\"\\n    18â†’\\n    19â†’\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    20â†’\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    21â†’\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    22â†’\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    23â†’\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    24â†’\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    25â†’\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    26â†’\\t\\\"github.com/entireio/cli/perf\\\"\\n    27â†’)\\n    28â†’\\n    29â†’// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n    30â†’// Returns nil if the event was handled successfully.\\n    31â†’func DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    32â†’\\tif ag == nil {\\n    33â†’\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    34â†’\\t}\\n    35â†’\\tif event == nil {\\n    36â†’\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    37â†’\\t}\\n    38â†’\\n    39â†’\\tswitch event.Type {\\n    40â†’\\tcase agent.SessionStart:\\n    41â†’\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n    42â†’\\tcase agent.TurnStart:\\n    43â†’\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n    44â†’\\tcase agent.TurnEnd:\\n    45â†’\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n    46â†’\\tcase agent.Compaction:\\n    47â†’\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n    48â†’\\tcase agent.SessionEnd:\\n    49â†’\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n    50â†’\\tcase agent.SubagentStart:\\n    51â†’\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n    52â†’\\tcase agent.SubagentEnd:\\n    53â†’\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n    54â†’\\tcase agent.ModelUpdate:\\n    55â†’\\t\\treturn handleLifecycleModelUpdate(ctx, ag, event)\\n    56â†’\\tdefault:\\n    57â†’\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    58â†’\\t}\\n    59â†’}\\n    60â†’\\n    61â†’// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    62â†’// fires state machine transition.\\n    63â†’func handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    64â†’\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n    65â†’\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    66â†’\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    67â†’\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    68â†’\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    69â†’\\t\\tslog.String(\\\"model\\\", event.Model),\\n    70â†’\\t)\\n    71â†’\\n    72â†’\\tif event.SessionID == \\\"\\\" {\\n    73â†’\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    74â†’\\t}\\n    75â†’\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    76â†’\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    77â†’\\t}\\n    78â†’\\n    79â†’\\t// Build informational message\\n    80â†’\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    81â†’\\n    82â†’\\t// Check for concurrent sessions and append count if any\\n    83â†’\\t_, countSessionsSpan := perf.Start(ctx, \\\"count_active_sessions\\\")\\n    84â†’\\tstrat := GetStrategy(ctx)\\n    85â†’\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n    86â†’\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    87â†’\\t}\\n    88â†’\\tcountSessionsSpan.End()\\n    89â†’\\n    90â†’\\t// Output informational message if the agent supports hook responses.\\n    91â†’\\t// Claude Code reads JSON from stdout; agents that don't implement\\n    92â†’\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n    93â†’\\t_, hookResponseSpan := perf.Start(ctx, \\\"write_hook_response\\\")\\n    94â†’\\tif event.ResponseMessage != \\\"\\\" {\\n    95â†’\\t\\tmessage = event.ResponseMessage\\n    96â†’\\t}\\n    97â†’\\tif writer, ok := agent.AsHookResponseWriter(ag); ok {\\n    98â†’\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n    99â†’\\t\\t\\thookResponseSpan.RecordError(err)\\n   100â†’\\t\\t\\thookResponseSpan.End()\\n   101â†’\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n   102â†’\\t\\t}\\n   103â†’\\t}\\n   104â†’\\thookResponseSpan.End()\\n   105â†’\\n   106â†’\\t// Store model hint if the agent provided model info on SessionStart\\n   107â†’\\tif event.Model != \\\"\\\" {\\n   108â†’\\t\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n   109â†’\\t\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint on session start\\\",\\n   110â†’\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   111â†’\\t\\t}\\n   112â†’\\t}\\n   113â†’\\n   114â†’\\t// Fire EventSessionStart for the current session (if state exists).\\n   115â†’\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n   116â†’\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n   117â†’\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   118â†’\\t} else if state != nil {\\n   119â†’\\t\\tpersistEventMetadataToState(event, state)\\n   120â†’\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   121â†’\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n   122â†’\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   123â†’\\t\\t}\\n   124â†’\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   125â†’\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n   126â†’\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   127â†’\\t\\t}\\n   128â†’\\t}\\n   129â†’\\n   130â†’\\treturn nil\\n   131â†’}\\n   132â†’\\n   133â†’// handleLifecycleModelUpdate persists the model name for the current session.\\n   134â†’//\\n   135â†’// If the session state file already exists (e.g., Gemini's BeforeModel fires\\n   136â†’// after TurnStart), the model is written directly to state.ModelName â€” no hint\\n   137â†’// file needed. Otherwise falls back to StoreModelHint for cross-process\\n   138â†’// persistence (see its doc comment for the full rationale).\\n   139â†’func handleLifecycleModelUpdate(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   140â†’\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   141â†’\\tlogging.Info(logCtx, \\\"model-update\\\",\\n   142â†’\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   143â†’\\t\\tslog.String(\\\"model\\\", event.Model),\\n   144â†’\\t)\\n   145â†’\\n   146â†’\\tif event.SessionID == \\\"\\\" || event.Model == \\\"\\\" {\\n   147â†’\\t\\treturn nil\\n   148â†’\\t}\\n   149â†’\\n   150â†’\\t// Prefer writing directly to session state when it exists\\n   151â†’\\tstate, loadErr := strategy.LoadSessionState(ctx, event.SessionID)\\n   152â†’\\tif loadErr != nil {\\n   153â†’\\t\\tlogging.Debug(logCtx, \\\"could not load session state for model update, using hint file\\\",\\n   154â†’\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   155â†’\\t}\\n   156â†’\\tif loadErr == nil && state != nil {\\n   157â†’\\t\\tstate.ModelName = event.Model\\n   158â†’\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   159â†’\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state with model\\\",\\n   160â†’\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   161â†’\\t\\t}\\n   162â†’\\t\\treturn nil\\n   163â†’\\t}\\n   164â†’\\n   165â†’\\t// State doesn't exist yet (or failed to load) â€” use hint file (see StoreModelHint doc)\\n   166â†’\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n   167â†’\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint\\\",\\n   168â†’\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   169â†’\\t}\\n   170â†’\\n   171â†’\\treturn nil\\n   172â†’}\\n   173â†’\\n   174â†’// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   175â†’// ensures strategy setup, initializes session.\\n   176â†’func handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   177â†’\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   178â†’\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   179â†’\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   180â†’\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   181â†’\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   182â†’\\t\\tslog.String(\\\"model\\\", event.Model),\\n   183â†’\\t)\\n   184â†’\\n   185â†’\\tsession