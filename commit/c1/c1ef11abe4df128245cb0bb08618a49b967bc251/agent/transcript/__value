testing\\\"\\n    11ŌåÆ)\\n    12ŌåÆ\\n    13ŌåÆ// TestAgentPackages_NoForbiddenImports verifies that agent implementation packages\\n    14ŌåÆ// (claudecode, geminicli, opencode, cursor, etc.) only import from allowed packages.\\n    15ŌåÆ//\\n    16ŌåÆ// This prevents agent implementations from coupling to framework internals\\n    17ŌåÆ// (strategy, checkpoint, session, commands, hook_registry, lifecycle) which\\n    18ŌåÆ// would create brittle dependencies that break when internals change.\\n    19ŌåÆ//\\n    20ŌåÆ// Agents should depend only on:\\n    21ŌåÆ//   - The agent contract package (agent, agent/types, agent/testutil)\\n    22ŌåÆ//   - Utility packages (logging, paths, jsonutil, textutil, transcript, etc.)\\n    23ŌåÆ//   - Standard library and external dependencies\\n    24ŌåÆfunc TestAgentPackages_NoForbiddenImports(t *testing.T) {\\n    25ŌåÆ\\tt.Parallel()\\n    26ŌåÆ\\n    27ŌåÆ\\tconst repoPrefix = \\\"github.com/entireio/cli/cmd/entire/cli/\\\"\\n    28ŌåÆ\\n    29ŌåÆ\\t// Packages that agent implementations must NOT import.\\n    30ŌåÆ\\t// These are framework internals that agents should be decoupled from.\\n    31ŌåÆ\\tforbiddenSuffixes := []string{\\n    32ŌåÆ\\t\\t\\\"strategy\\\",\\n    33ŌåÆ\\t\\t\\\"checkpoint\\\",\\n    34ŌåÆ\\t\\t\\\"session\\\",\\n    35ŌåÆ\\t\\t\\\"commands\\\",\\n    36ŌåÆ\\t}\\n    37ŌåÆ\\n    38ŌåÆ\\t// Individual files in the cli package that agents must not depend on.\\n    39ŌåÆ\\t// We check for the cli package import itself since these are all in\\n    40ŌåÆ\\t// the top-level cli package (not sub-packages).\\n    41ŌåÆ\\tforbiddenCLIPackage := repoPrefix[:len(repoPrefix)-1] // \\\"github.com/entireio/cli/cmd/entire/cli\\\"\\n    42ŌåÆ\\n    43ŌåÆ\\t// Packages within the repo that agents ARE allowed to import.\\n    44ŌåÆ\\tallowedPrefixes := []string{\\n    45ŌåÆ\\t\\trepoPrefix + \\\"agent\\\",      // agent contract + sub-packages\\n    46ŌåÆ\\t\\trepoPrefix + \\\"logging\\\",    // logging utilities\\n  