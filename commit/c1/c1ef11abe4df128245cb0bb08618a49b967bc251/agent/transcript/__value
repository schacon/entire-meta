ir native hooks into these event types via ParseHookEvent.\\n    13ŌåÆtype EventType int\\n    14ŌåÆ\\n    15ŌåÆconst (\\n    16ŌåÆ\\t// SessionStart indicates the agent session has begun.\\n    17ŌåÆ\\tSessionStart EventType = iota + 1\\n    18ŌåÆ\\n    19ŌåÆ\\t// TurnStart indicates the user submitted a prompt and the agent is about to work.\\n    20ŌåÆ\\tTurnStart\\n    21ŌåÆ\\n    22ŌåÆ\\t// TurnEnd indicates the agent finished responding to a prompt.\\n    23ŌåÆ\\tTurnEnd\\n    24ŌåÆ\\n    25ŌåÆ\\t// Compaction indicates the agent is about to compress its context window.\\n    26ŌåÆ\\t// This triggers the same save logic as TurnEnd but also resets the transcript offset.\\n    27ŌåÆ\\tCompaction\\n    28ŌåÆ\\n    29ŌåÆ\\t// SessionEnd indicates the session has been terminated.\\n    30ŌåÆ\\tSessionEnd\\n    31ŌåÆ\\n    32ŌåÆ\\t// SubagentStart indicates a subagent (task) has been spawned.\\n    33ŌåÆ\\tSubagentStart\\n    34ŌåÆ\\n    35ŌåÆ\\t// SubagentEnd indicates a subagent (task) has completed.\\n    36ŌåÆ\\tSubagentEnd\\n    37ŌåÆ)\\n    38ŌåÆ\\n    39ŌåÆ// String returns a human-readable name for the event type.\\n    40ŌåÆfunc (e EventType) String() string {\\n    41ŌåÆ\\tswitch e {\\n    42ŌåÆ\\tcase SessionStart:\\n    43ŌåÆ\\t\\treturn \\\"SessionStart\\\"\\n    44ŌåÆ\\tcase TurnStart:\\n    45ŌåÆ\\t\\treturn \\\"TurnStart\\\"\\n    46ŌåÆ\\tcase TurnEnd:\\n    47ŌåÆ\\t\\treturn \\\"TurnEnd\\\"\\n    48ŌåÆ\\tcase Compaction:\\n    49ŌåÆ\\t\\treturn \\\"Compaction\\\"\\n    50ŌåÆ\\tcase SessionEnd:\\n    51ŌåÆ\\t\\treturn \\\"SessionEnd\\\"\\n    52ŌåÆ\\tcase SubagentStart:\\n    53ŌåÆ\\t\\treturn \\\"SubagentStart\\\"\\n    54ŌåÆ\\tcase SubagentEnd:\\n    55ŌåÆ\\t\\treturn \\\"SubagentEnd\\\"\\n    56ŌåÆ\\tdefault:\\n    57ŌåÆ\\t\\treturn \\\"Unknown\\\"\\n    58ŌåÆ\\t}\\n    59ŌåÆ}\\n    60ŌåÆ\\n    61ŌåÆ// Event is a normalized lifecycle event produced by an agent's ParseHookEvent method.\\n    62ŌåÆ// The framework dispatcher uses these events to dri