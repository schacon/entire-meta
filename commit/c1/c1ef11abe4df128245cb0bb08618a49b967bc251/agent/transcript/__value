 31ŌåÆ\\t// Description returns a human-readable description for UI\\n    32ŌåÆ\\tDescription() string\\n    33ŌåÆ\\n    34ŌåÆ\\t// IsPreview returns whether the agent integration is in preview or stable\\n    35ŌåÆ\\tIsPreview() bool\\n    36ŌåÆ\\n    37ŌåÆ\\t// DetectPresence checks if this agent is configured in the repository\\n    38ŌåÆ\\tDetectPresence(ctx context.Context) (bool, error)\\n    39ŌåÆ\\n    40ŌåÆ\\t// ProtectedDirs returns repo-root-relative directories that should never be\\n    41ŌåÆ\\t// modified or deleted during rewind or other destructive operations.\\n    42ŌåÆ\\t// Examples: [\\\".claude\\\"] for Claude, [\\\".gemini\\\"] for Gemini.\\n    43ŌåÆ\\tProtectedDirs() []string\\n    44ŌåÆ\\n    45ŌåÆ\\t// --- Transcript Storage ---\\n    46ŌåÆ\\n    47ŌåÆ\\t// ReadTranscript reads the raw transcript bytes for a session.\\n    48ŌåÆ\\tReadTranscript(sessionRef string) ([]byte, error)\\n    49ŌåÆ\\n    50ŌåÆ\\t// ChunkTranscript splits a transcript into chunks if it exceeds maxSize.\\n    51ŌåÆ\\t// Returns a slice of chunks. If the transcript fits in one chunk, returns single-element slice.\\n    52ŌåÆ\\t// The chunking is format-aware: JSONL splits at line boundaries, JSON splits message arrays.\\n    53ŌåÆ\\tChunkTranscript(ctx context.Context, content []byte, maxSize int) ([][]byte, error)\\n    54ŌåÆ\\n    55ŌåÆ\\t// ReassembleTranscript combines chunks back into a single transcript.\\n    56ŌåÆ\\t// Handles format-specific reassembly (JSONL concatenation, JSON message merging).\\n    57ŌåÆ\\tReassembleTranscript(chunks [][]byte) ([]byte, error)\\n    58ŌåÆ\\n    59ŌåÆ\\t// --- Legacy methods (will move to optional interfaces in Phase 4) ---\\n    60ŌåÆ\\n    61ŌåÆ\\t// GetSessionID extracts session ID from hook input.\\n    62ŌåÆ\\tGetSessionID(input *HookInput) string\\n    63ŌåÆ\\n    64ŌåÆ\\t// GetSessionDir returns where agent stores session data for this repo.\\n    65ŌåÆ\\tGetSessionDir(repoPath string) (string, error)\\n    66ŌåÆ\\n    67ŌåÆ\\t// ResolveSessionFile returns the path to the session transcript file.\\n    68ŌåÆ\\tResolveSessionFile(sessionDir, agentSessionID string) string\\n    69ŌåÆ\\n    70ŌåÆ\\t// ReadSession reads session data from agent's storage.\\n    71ŌåÆ\\tReadSession(input *HookInput) (*AgentSession, error)\\n    72ŌåÆ\\n    73ŌåÆ\\t// WriteSession writes session data for resumption.\\n    74ŌåÆ\\tWriteSession(ctx context.Context, session *AgentSession) error\\n    75ŌåÆ\\n    76ŌåÆ\\t// FormatResumeCommand returns command to resume a session.\\n    77ŌåÆ\\tFormatResumeCommand(sessionID string) string\\n    78ŌåÆ}\\n    79ŌåÆ\\n    80ŌåÆ// HookSupport is implemented by agents with lifecycle hooks.\\n    81ŌåÆ// This optional interface allows agents like Claude Code and Cursor to\\n    82ŌåÆ// install and manage hooks that notify Entire of agent events.\\n    83ŌåÆ//\\n    84ŌåÆ// The interface is organized into two groups:\\n    85ŌåÆ//   - Hook Mapping (2 methods): HookNames, ParseHookEvent\\n    86ŌåÆ//   - Hook Management (3 methods): InstallHooks, UninstallHooks, AreHooksInstalled\\n    87ŌåÆtype HookSupport interface {\\n    88ŌåÆ\\tAgent\\n    89ŌåÆ\\n    90ŌåÆ\\t// HookNames returns the hook verbs this agent supports.\\n    91ŌåÆ\\t// These become subcommands under `entire hooks <agent>`.\\n    92ŌåÆ\\t// e.g., [\\\"stop\\\", \\\"user-prompt-submit\\\", \\\"session-start\\\", \\\"session-end\\\"]\\n    93ŌåÆ\\tHookNames() []string\\n    94ŌåÆ\\n    95ŌåÆ\\t// ParseHookEvent translates an agent-native hook into a normalized lifecycle Event.\\n    96ŌåÆ\\t// Returns nil if the hook has no lifecycle significance (e.g., pass-through hooks).\\n    97ŌåÆ\\t// This is the core contribution surface for new agent implementations.\\n    98ŌåÆ\\tParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*Event, error)\\n    99ŌåÆ\\n   100ŌåÆ\\t// InstallHooks installs agent-specific hooks.\\n   101ŌåÆ\\t// If localDev is true, hooks point to local development build.\\n   102ŌåÆ\\t// If force is true, removes existing Entire hooks before installing.\\n   103ŌåÆ\\t// Returns the number of hooks installed.\\n   104ŌåÆ\\tInstallHooks(ctx context.Context, localDev bool, force bool) (int, error)\\n   105ŌåÆ\\n   106ŌåÆ\\t// UninstallHooks removes installed hooks\\n   107ŌåÆ\\tUninstallHooks(ctx context.Context) error\\n   108ŌåÆ\\n   109ŌåÆ\\t// AreHooksInstalled checks if hooks are currently installed\\n   110ŌåÆ\\tAreHooksInstalled(ctx context.Context) bool\\n   111ŌåÆ}\\n   112ŌåÆ\\n   113ŌåÆ// FileWatcher is implemented by agents that use file-based detection.\\n   114ŌåÆ// Agents like Aider that don't support hooks can use file watching\\n   115ŌåÆ// to detect session activity.\\n   116ŌåÆtype FileWatcher interface {\\n   117ŌåÆ\\tAgent\\n   118ŌåÆ\\n   119ŌåÆ\\t// GetWatchPaths returns paths to watch for session changes\\n   120ŌåÆ\\tGetWatchPaths() ([]string, error)\\n   121ŌåÆ\\n   122ŌåÆ\\t// OnFileChange handles a detected file change and returns session info\\n   123ŌåÆ\\tOnFileChange(path string) (*SessionChange, error)\\n   124ŌåÆ}\\n   125ŌåÆ\\n   126ŌåÆ// TranscriptAnalyzer provides format-specific transcript parsing.\\n   127ŌåÆ// Agents that implement this get richer checkpoints (transcript-derived file lists,\\n   128ŌåÆ// prompts, summaries). Agents that don't still participate in the checkpoint lifecycle\\n   129ŌåÆ// via git-status-based file detection and raw transcript storage.\\n   130ŌåÆtype TranscriptAnalyzer interface {\\n   131ŌåÆ\\tAgent\\n   132ŌåÆ\\n   133ŌåÆ\\t// GetTranscriptPosition returns the current position (length) of a transcript.\\n   134ŌåÆ\\t// For JSONL formats (Claude Code), this is the line count.\\n   135ŌåÆ\\t// For JSON formats (Gemini CLI), this is the message count.\\n   136ŌåÆ\\t// Returns 0 if the file doesn't exist or is empty.\\n   137ŌåÆ\\tGetTranscriptPosition(path string) (int, error)\\n   138ŌåÆ\\n   139ŌåÆ\\t// ExtractModifiedFilesFromOffset extracts files modified since a given offset.\\n   140ŌåÆ\\t// For JSONL formats (Claude Code), offset is the starting line number.\\n   141ŌåÆ\\t// For JSON formats (Gemini CLI), offset is the starting message index.\\n   142ŌåÆ\\t// Returns:\\n   143ŌåÆ\\t//   - files: list of file paths modified by the agent (from Write/Edit tools)\\n   144ŌåÆ\\t//   - currentPosition: the current position (line count or message count)\\n   145ŌåÆ\\t//   - error: any error encountered during reading\\n   146ŌåÆ\\tExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error)\\n   147ŌåÆ\\n   148ŌåÆ\\t// ExtractPrompts extracts user prompts from the transcript starting at the given offset.\\n   149ŌåÆ\\tExtractPrompts(sessionRef string, fromOffset int) ([]string, error)\\n   150ŌåÆ\\n   151ŌåÆ\\t// ExtractSummary extracts a summary of the session from the transcript.\\n   152ŌåÆ\\tExtractSummary(sessionRef string) (string, error)\\n   153ŌåÆ}\\n   154ŌåÆ\\n   155ŌåÆ// TranscriptPreparer is called before ReadTranscript to handle agent-specific\\n   156ŌåÆ// flush/sync requirements (e.g., Claude Code's async transcript writing).\\n   157ŌåÆ// The framework calls PrepareTranscript before ReadTranscript if implemented.\\n   158ŌåÆtype TranscriptPreparer interface {\\n   159ŌåÆ\\tAgent\\n   160ŌåÆ\\n   161ŌåÆ\\t// PrepareTranscript ensures the transcript is ready to read.\\n   162ŌåÆ\\t// For Claude Code, this waits for the async transcript flush to complete.\\n   163ŌåÆ\\tPrepareTranscript(ctx context.Context, sessionRef string) error\\n   164ŌåÆ}\\n   165ŌåÆ\\n   166ŌåÆ// TokenCalculator provides token usage calculation for a session.\\n   167ŌåÆ// The framework calls this during step save and checkpoint if implemented.\\n   168ŌåÆtype TokenCalculator interface {\\n   169ŌåÆ\\tAgent\\n   170ŌåÆ\\n   171ŌåÆ\\t// CalculateTokenUsage computes token usage from the transcript starting at the given offset.\\n   172ŌåÆ\\tCalculateTokenUsage(transcriptData []byte, fromOffset int) (*TokenUsage, error)\\n   173ŌåÆ}\\n   174ŌåÆ\\n   175ŌåÆ// SubagentAwareExtractor provides methods for extracting files and tokens including subagents.\\n   176ŌåÆ// Agents that support spawning subagents (like Claude Code's Task tool) should implement this\\n   177ŌåÆ// to ensure subagent contributions are included in checkpoints.\\n   178ŌåÆtype SubagentAwareExtractor interface {\\n   179ŌåÆ\\tAgent\\n   180ŌåÆ\\n   181ŌåÆ\\t// ExtractAllModifiedFiles extracts files modified by both the main agent and any spawned subagents.\\n   182ŌåÆ\\t// The subagentsDir parameter specifies where subagent transcripts are stored.\\n   183ŌåÆ\\t// Returns a deduplicated list of all modified file paths.\\n   184ŌåÆ\\tExtractAllModifiedFiles(transcriptData []byte, fromOffset int, subagentsDir string) ([]string, error)\\n   185ŌåÆ\\n   186ŌåÆ\\t// CalculateTotalTokenUsage computes token usage including all spawned subagents.\\n   187ŌåÆ\\t// The subagentsDir parameter specifies where subagent transcripts are stored.\\n   188ŌåÆ\\tCalculateTotalTokenUsage(transcriptData []byte, fromOffset int, subagentsDir string) (*TokenUsage, error)\\n   189ŌåÆ}\\n   190ŌåÆ\"}]},\"uuid\":\"b4f768cd-32e8-4a3c-b148-c38d1c1b6123\",\"timestamp\":\"2026-03-01T22:53:15.753Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a68681856a1de802f\"},\"toolUseID\":\"agent_msg_0147CJcDBwVYQa3odUMs5wF2\",\"parentToolUseID\":\"toolu_01VUbsGAepJMqKDu63t5FTnk\",\"uuid\":\"dea416c4-37c5-4354-9fc1-b61efb306abb\",\"timestamp\":\"2026-03-01T22:53:15.977Z\"}\n{\"parentUuid\":\"dea416c4-37c5-4354-9fc1-b61efb306abb\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/1\",\"sessionId\":\"ee198057-0f22-496f-9674-0af8f6e0aa80\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/improve-agent-integration-skill\",\"slug\":\"snoopy-napping-lollipop\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-01