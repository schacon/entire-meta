ings.HasPrefix(rel, forbidden+\\\"/\\\") {\\n    85ŌåÆ\\t\\t\\t\\t\\t\\tt.Errorf(\\\"forbidden import %q ŌĆö agent packages must not import %s internals\\\", imp, forbidden)\\n    86ŌåÆ\\t\\t\\t\\t\\t}\\n    87ŌåÆ\\t\\t\\t\\t}\\n    88ŌåÆ\\n    89ŌåÆ\\t\\t\\t\\t// Check it's in the allowed list\\n    90ŌåÆ\\t\\t\\t\\tallowed := false\\n    91ŌåÆ\\t\\t\\t\\tfor _, prefix := range allowedPrefixes {\\n    92ŌåÆ\\t\\t\\t\\t\\tif imp == prefix || strings.HasPrefix(imp, prefix+\\\"/\\\") {\\n    93ŌåÆ\\t\\t\\t\\t\\t\\tallowed = true\\n    94ŌåÆ\\t\\t\\t\\t\\t\\tbreak\\n    95ŌåÆ\\t\\t\\t\\t\\t}\\n    96ŌåÆ\\t\\t\\t\\t}\\n    97ŌåÆ\\t\\t\\t\\tif !allowed {\\n    98ŌåÆ\\t\\t\\t\\t\\tt.Errorf(\\\"unexpected internal import %q ŌĆö if this is intentional, add it to allowedPrefixes in architecture_test.go\\\", imp)\\n    99ŌåÆ\\t\\t\\t\\t}\\n   100ŌåÆ\\t\\t\\t}\\n   101ŌåÆ\\t\\t})\\n   102ŌåÆ\\t}\\n   103ŌåÆ}\\n   104ŌåÆ\\n   105ŌåÆ// findAgentDir returns the absolute path to cmd/entire/cli/agent/.\\n   106ŌåÆfunc findAgentDir(t *testing.T) string {\\n   107ŌåÆ\\tt.Helper()\\n   108ŌåÆ\\t// Walk up from the test file location to find the repo root.\\n   109ŌåÆ\\twd, err := os.Getwd()\\n   110ŌåÆ\\tif err != nil {\\n   111ŌåÆ\\t\\tt.Fatalf(\\\"os.Getwd: %v\\\", err)\\n   112ŌåÆ\\t}\\n   113ŌåÆ\\t// We're in cmd/entire/cli/agent/ since the test is in that package.\\n   114ŌåÆ\\treturn wd\\n   115ŌåÆ}\\n   116ŌåÆ\\n   117ŌåÆ// discoverAgentPackages finds all subdirectories of the agent dir that contain\\n   118ŌåÆ// Go files, excluding \\\"types\\\" and \\\"testutil\\\" (those are contract/shared packages).\\n   119ŌåÆfunc discoverAgentPackages(t *testing.T, agentDir string) []string {\\n   120ŌåÆ\\tt.Helper()\\n   121ŌåÆ\\n   122ŌåÆ\\tskipDirs := map[string]bool{\\n   123ŌåÆ\\t\\t\\\"types\\\":    true, // contract types, not an agent implementation\\n   124ŌåÆ\\t\\t\\\"testutil\\\": true, // shared test utilities\\n   125ŌåÆ\\t}\\n   126ŌåÆ\\n   127ŌåÆ\\tentries, err := os.ReadDir(agentDir)\\n   128ŌåÆ\\tif err != nil {\\n   129ŌåÆ\\t\\tt.Fatalf(\\\"ReadDir(%s): %v\\\", agentDir, err)\\n   130ŌåÆ\\t}\\n   131ŌåÆ\\n   132ŌåÆ\\tvar pkgs []string\\n   133ŌåÆ\\tfor _, e := range entries {\\n   134ŌåÆ\\t\\tif !e.IsDir() || skipDirs[e.Name()] {\\n   135ŌåÆ\\t\\t\\tcontinue\\n   136ŌåÆ\\t\\t}\\n   137ŌåÆ\\t\\tdir := filepath.Join(agentDir, e.Name())\\n   138ŌåÆ\\t\\t// Only include if it has Go files\\n   139ŌåÆ\\t\\tgoFiles, err := filepath.Glob(filepath.Join(dir, \\\"*.go\\\"))\\n   140ŌåÆ\\t\\tif err != nil {\\n   141ŌåÆ\\t\\t\\tt.Fatalf(\\\"filepath.Glob(%s): %v\\\", dir, err)\\n   142ŌåÆ\\t\\t}\\n   143ŌåÆ\\t\\tif len(goFiles) > 0 {\\n   144ŌåÆ\\t\\t\\tpkgs = append(pkgs, dir)\\n   145ŌåÆ\\t\\t}\\n   146ŌåÆ\\t}\\n   147ŌåÆ\\treturn pkgs\\n   148ŌåÆ}\\n   149ŌåÆ\\n   150ŌåÆ// extractImports parses all Go files in a directory and returns unique import paths.\\n   151ŌåÆ// Includes both production and test files ŌĆö test-only imports should also respect boundaries.\\n   152ŌåÆfunc extractImports(t *testing.T, dir string) []string {\\n   153ŌåÆ\\tt.Helper()\\n   154ŌåÆ\\n   155ŌåÆ\\tfset := token.NewFileSet()\\n   156ŌåÆ\\t//nolint:staticcheck // ParseDir is deprecated in favor of go/packages, but we intentionally\\n   157ŌåÆ\\t// scan all files regardless of build tags to catch forbidden imports in test files too.\\n   158ŌåÆ\\tpkgs, err := parser.ParseDir(fset, dir, nil, parser.ImportsOnly)\\n   159ŌåÆ\\tif err != nil {\\n   160ŌåÆ\\t\\tt.Fatalf(\\\"parser.ParseDir(%s): %v\\\", dir, err)\\n   161ŌåÆ\\t}\\n   162ŌåÆ\\n   163ŌåÆ\\tseen := make(map[string]bool)\\n   164ŌåÆ\\tfor _, pkg := range pkgs {\\n   165ŌåÆ\\t\\tfor _, file := range pkg.Files {\\n   166ŌåÆ\\t\\t\\tfor _, imp := range file.Imports {\\n   167ŌåÆ\\t\\t\\t\\tpath := strings.Trim(imp.Path.Value, `\\\"`)\\n   168ŌåÆ\\t\\t\\t\\tseen[path] = true\\n   169ŌåÆ\\t\\t\\t}\\n   170ŌåÆ\\t\\t}\\n   171ŌåÆ\\t}\\n   172ŌåÆ\\n   173ŌåÆ\\timports := make([]string, 0, len(seen))\\n   174ŌåÆ\\t