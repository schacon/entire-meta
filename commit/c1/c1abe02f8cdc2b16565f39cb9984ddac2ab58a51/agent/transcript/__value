bug(ctx, \\\"logs-only rewind started\\\",\\n   545→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   546→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   547→\\t)\\n   548→\\n   549→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   550→\\tif !ok {\\n   551→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   552→\\t}\\n   553→\\n   554→\\tsessions, err := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   555→\\tif err != nil {\\n   556→\\t\\tlogging.Error(ctx, \\\"logs-only rewind failed\\\",\\n   557→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   558→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   559→\\t\\t)\\n   560→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   561→\\t}\\n   562→\\n   563→\\tlogging.Debug(ctx, \\\"logs-only rewind completed\\\",\\n   564→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   565→\\t)\\n   566→\\n   567→\\t// Show resume commands for all sessions\\n   568→\\tprintMultiSessionResumeCommands(sessions)\\n   569→\\n   570→\\tfmt.Println(\\\"Note: Working directory unchanged. Use interactive mode for full checkout.\\\")\\n   571→\\treturn nil\\n   572→}\\n   573→\\n   574→// handleLogsOnlyResetNonInteractive handles reset in non-interactive mode.\\n   575→// This performs a git reset --hard to the target commit.\\n   576→func handleLogsOnlyResetNonInteractive(start strategy.Strategy, point strategy.RewindPoint) error {\\n   577→\\t// Resolve agent once for use throughout\\n   578→\\tagent, err := getAgent(point.Agent)\\n   579→\\tif err != nil {\\n   580→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   581→\\t}\\n   582→\\n   583→\\t// Initialize logging context with agent from checkpoint\\n   584→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   585→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   586→\\n   587→\\tlogging.Debug(ctx, \\\"logs-only reset started\\\",\\n   588→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   589→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   590→\\t)\\n   591→\\n   592→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   593→\\tif !ok {\\n   594→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   595→\\t}\\n   596→\\n   597→\\t// Get current HEAD before reset (for recovery message)\\n   598→\\tcurrentHead, headErr := getCurrentHeadHash()\\n   599→\\tif headErr != nil {\\n   600→\\t\\tcurrentHead = \\\"\\\"\\n   601→\\t}\\n   602→\\n   603→\\t// Restore logs first\\n   604→\\tsessions, err := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   605→\\tif err != nil {\\n   606→\\t\\tlogging.Error(ctx, \\\"logs-only reset failed during log restoration\\\",\\n   607→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   608→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   609→\\t\\t)\\n   610→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   611→\\t}\\n   612→\\n   613→\\t// Perform git reset --hard\\n   614→\\tif err := performGitResetHard(point.ID); err != nil {\\n   615→\\t\\tlogging.Error(ctx, \\\"logs-only reset failed during git reset\\\",\\n   616→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   617→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   618→\\t\\t)\\n   619→\\t\\treturn fmt.Errorf(\\\"failed to reset branch: %w\\\", err)\\n   620→\\t}\\n   621→\\n   622→\\tlogging.Debug(ctx, \\\"logs-only reset completed\\\",\\n   623→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   624→\\t)\\n   625→\\n   626→\\tshortID := point.ID\\n   627→\\tif len(shortID) > 7 {\\n   628→\\t\\tshortID = shortID[:7]\\n   629→\\t}\\n   630→\\n   631→\\tfmt.Printf(\\\"Reset branch to %s.\\\\n\\\", shortID)\\n   632→\\n   633→\\t// Show resume commands for all sessions\\n   634→\\tprintMultiSessionResumeCommands(sessions)\\n   635→\\n   636→\\t// Show recovery instructions\\n   637→\\tif currentHead != \\\"\\\" && currentHead != point.ID {\\n   638→\\t\\tcurrentShort := currentHead\\n   639→\\t\\tif len(currentShort) > 7 {\\n   640→\\t\\t\\tcurrentShort = currentShort[:7]\\n   641→\\t\\t}\\n   642→\\t\\tfmt.Printf(\\\"\\\\nTo undo this reset: git reset --hard %s\\\\n\\\", currentShort)\\n   643→\\t}\\n   644→\\n   645→\\treturn nil\\n   646→}\\n   647→\\n   648→func restoreSessionTranscript(transcriptFile, sessionID string, agent agentpkg.Agent) error {\\n   649→\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   650→\\tif err != nil {\\n   651→\\t\\treturn err\\n   652→\\t}\\n   653→\\n   654→\\t// Ensure parent directory exists\\n   655→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   656→\\t\\treturn fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   657→\\t}\\n   658→\\n   659→\\tfmt.Fprintf(os.Stderr, \\\"Copying transcript:\\\\n  From: %s\\\\n  To: %s\\\\n\\\", transcriptFile, sessionFile)\\n   660→\\tif err := copyFile(transcriptFile, sessionFile); err != nil {\\n   661→\\t\\treturn fmt.Errorf(\\\"failed to copy transcript: %w\\\", err)\\n   662→\\t}\\n   663→\\n   664→\\treturn nil\\n   665→}\\n   666→\\n   667→// restoreSessionTranscriptFromStrategy restores a session transcript from checkpoint storage.\\n   668→// This is used for strategies that store transcripts in git branches rather than local files.\\n   669→// Returns the session ID that was actually used (may differ from input if checkpoint provides one).\\n   670→func restoreSessionTranscriptFromStrategy(cpID id.CheckpointID, sessionID string, agent agentpkg.Agent) (string, error) {\\n   671→\\t// Get transcript content from checkpoint storage\\n   672→\\tcontent, returnedSessionID, err := checkpoint.LookupSessionLog(cpID)\\n   673→\\tif err != nil {\\n   674→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get session log: %w\\\", err)\\n   675→\\t}\\n   676→\\n   677→\\t// Use session ID returned from checkpoint if available\\n   678→\\t// Otherwise fall back to the passed-in sessionID\\n   679→\\tif returnedSessionID != \\\"\\\" {\\n   680→\\t\\tsessionID = returnedSessionID\\n   681→\\t}\\n   682→\\n   683→\\treturn writeTranscriptToAgentSession(content, sessionID, agent)\\n   684→}\\n   685→\\n   686→// restoreSessionTranscriptFromShadow restores a session transcript from a shadow branch commit.\\n   687→// This is used for uncommitted checkpoints where the transcript is stored in the shadow branch tree.\\n   688→func restoreSessionTranscriptFromShadow(commitHash, metadataDir, sessionID string, agent agentpkg.Agent) (string, error) {\\n   689→\\t// Open repository\\n   690→\\trepo, err := git.PlainOpenWithOptions(\\\".\\\", &git.PlainOpenOptions{DetectDotGit: true})\\n   691→\\tif err != nil {\\n   692→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   693→\\t}\\n   694→\\n   695→\\t// Parse commit hash\\n   696→\\thash := plumbing.NewHash(commitHash)\\n   697→\\tif hash.IsZero() {\\n   698→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"invalid commit hash: %s\\\", commitHash)\\n   699→\\t}\\n   700→\\n   701→\\t// Get transcript from shadow branch commit tree\\n   702→\\tstore := checkpoint.NewGitStore(repo)\\n   703→\\tcontent, err := store.GetTranscriptFromCommit(hash, metadataDir, agent.Type())\\n   704→\\tif err != nil {\\n   705→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get transcript from shadow branch: %w\\\", err)\\n   706→\\t}\\n   707→\\n   708→\\treturn writeTranscriptToAgentSession(content, sessionID, agent)\\n   709→}\\n   710→\\n   711→// writeTranscriptToAgentSession writes transcript content to the agent's session storage.\\n   712→func writeTranscriptToAgentSession(content []byte, sessionID string, agent agentpkg.Agent) (string, error) {\\n   713→\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   714→\\tif err != nil {\\n   715→\\t\\treturn \\\"\\\", err\\n   716→\\t}\\n   717→\\n   718→\\t// Ensure parent directory exists\\n   719→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   720→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   721→\\t}\\n   722→\\n   723→\\tfmt.Fprintf(os.Stderr, \\\"Writing transcript to: %s\\\\n\\\", sessionFile)\\n   724→\\tif err := os.WriteFile(sessionFile, content, 0o600); err != nil {\\n   725→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   726→\\t}\\n   727→\\n   728→\\treturn sessionID, nil\\n   729→}\\n   730→\\n   731→// restoreTaskCheckpointTranscript restores a truncated transcript for a task checkpoint.\\n   732→// Uses GetTaskCheckpointTranscript to fetch the transcript from the strategy.\\n   733→//\\n   734→// NOTE: The transcript parsing/truncation/writing pipeline (transcript.ParseFromBytes,\\n   735→// TruncateTranscriptAtUUID, writeTranscript) assumes Claude's JSONL format.\\n   736→// This is acceptable because task checkpoints are currently only created by Claude Code's\\n   737→// PostToolUse hook. If other agents gain sub-agent support, this will need a\\n   738→// format-aware refactor (agent-specific parsing, truncation, and serialization).\\n   739→func restoreTaskCheckpointTranscript(strat strategy.Strategy, point strategy.RewindPoint, sessionID, checkpointUUID string, agent agentpkg.Agent) error {\\n   740→\\t// Get transcript content from strategy\\n   741→\\tcontent, err := strat.GetTaskCheckpointTranscript(point)\\n   742→\\tif err != nil {\\n   743→\\t\\treturn fmt.Errorf(\\\"failed to get task checkpoint transcript: %w\\\", err)\\n   744→\\t}\\n   745→\\n   746→\\t// Parse the transcript\\n   747→\\tparsed, err := transcript.ParseFromBytes(content)\\n   748→\\tif err != nil {\\n   749→\\t\\treturn fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   750→\\t}\\n   751→\\n   752→\\t// Truncate at checkpoint UUID\\n   753→\\ttruncated := TruncateTranscriptAtUUID(parsed, checkpointUUID)\\n   754→\\n   755→\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   756→\\tif err != nil {\\n   757→\\t\\treturn err\\n   758→\\t}\\n   759→\\n   760→\\t// Ensure parent directory exists\\n   761→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   762→\\t\\treturn fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   763→\\t}\\n   764→\\n   765→\\tfmt.Fprintf(os.Stderr, \\\"Writing truncated transcript to: %s\\\\n\\\", sessionFile)\\n   766→\\n   767→\\tif err := writeTranscript(sessionFile, truncated); err != nil {\\n   768→\\t\\treturn fmt.Errorf(\\\"failed to write truncated transcript: %w\\\", err)\\n   769→\\t}\\n   770→\\n   771→\\treturn nil\\n   772→}\\n   773→\\n   774→// handleLogsOnlyRewindInteractive handles rewind for logs-only points with a sub-choice menu.\\n   775→func handleLogsOnlyRewindInteractive(start strategy.Strategy, point strategy.RewindPoint, shortID string) error {\\n   776→\\tvar action string\\n   777→\\n   778→\\tform := NewAccessibleForm(\\n   779→\\t\\thuh.NewGroup(\\n   780→\\t\\t\\thuh.NewSelect[string]().\\n   781→\\t\\t\\t\\tTitle(\\\"Logs-only point: \\\"+shortID).\\n   782→\\t\\t\\t\\tDescription(\\\"This commit has session logs but no checkpoint state. Choose an action:\\\").\\n   783→\\t\\t\\t\\tOptions(\\n   784→\\t\\t\\t\\t\\thuh.NewOption(\\\"Restore logs only (keep current files)\\\", \\\"logs\\\"),\\n   785→\\t\\t\\t\\t\\thuh.NewOption(\\\"Checkout commit (detached HEAD, for viewing)\\\", \\\"checkout\\\"),\\n   786→\\t\\t\\t\\t\\thuh.NewOption(\\\"Reset branch to this commit (destructive!)\\\", \\\"reset\\\"),\\n   787→\\t\\t\\t\\t\\thuh.NewOption(\\\"Cancel\\\", \\\"cancel\\\"),\\n   788→\\t\\t\\t\\t).\\n   789→\\t\\t\\t\\tValue(&action),\\n   790→\\t\\t),\\n   791→\\t)\\n   792→\\n   793→\\tif err := form.Run(); err != nil {\\n   794→\\t\\treturn fmt.Errorf(\\\"action selection cancelled: %w\\\", err)\\n   795→\\t}\\n   796→\\n   797→\\tswitch action {\\n   798→\\tcase \\\"logs\\\":\\n   799→\\t\\treturn handleLogsOnlyRestore(start, point)\\n   800→\\tcase \\\"checkout\\\":\\n   801→\\t\\treturn handleLogsOnlyCheckout(start, point, shortID)\\n   802→\\tcase \\\"reset\\\":\\n   803→\\t\\treturn handleLogsOnlyReset(start, point, shortID)\\n   804→\\tcase \\\"cancel\\\":\\n   805→\\t\\tfmt.Println(\\\"Rewind cancelled.\\\")\\n   806→\\t\\treturn nil\\n   807→\\t}\\n   808→\\n   809→\\treturn nil\\n   810→}\\n   811→\\n   812→// handleLogsOnlyRestore restores only the session logs without changing files.\\n   813→func handleLogsOnlyRestore(start strategy.Strategy, point strategy.RewindPoint) error {\\n   814→\\t// Resolve agent once for use throughout\\n   815→\\tagent, err := getAgent(point.Agent)\\n   816→\\tif err != nil {\\n   817→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   818→\\t}\\n   819→\\n   820→\\t// Initialize logging context with agent from checkpoint\\n   821→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   822→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   823→\\n   824→\\tlogging.Debug(ctx, \\\"logs-only restore started\\\",\\n   825→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   826→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   827→\\t)\\n   828→\\n   829→\\t// Check if strategy supports logs-only restoration\\n   830→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   831→\\tif !ok {\\n   832→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   833→\\t}\\n   834→\\n   835→\\t// Restore logs\\n   836→\\tsessions, err := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   837→\\tif err != nil {\\n   838→\\t\\tlogging.Error(ctx, \\\"logs-only restore failed\\\",\\n   839→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   840→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   841→\\t\\t)\\n   842→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   843→\\t}\\n   844→\\n   845→\\tlogging.Debug(ctx, \\\"logs-only restore completed\\\",\\n   846→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   847→\\t)\\n   848→\\n   849→\\t// Show resume commands for all sessions\\n   850→\\tfmt.Println(\\\"Restored session logs.\\\")\\n   851→\\tprintMultiSessionResumeCommands(sessions)\\n   852→\\treturn nil\\n   853→}\\n   854→\\n   855→// handleLogsOnlyCheckout restores logs and checks out the commit (detached HEAD).\\n   856→func handleLogsOnlyCheckout(start strategy.Strategy, point strategy.RewindPoint, shortID string) error {\\n   857→\\t// Resolve agent once for use throughout\\n   858→\\tagent, err := getAgent(point.Agent)\\n   859→\\tif err != nil {\\n   860→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   861→\\t}\\n   862→\\n   863→\\t// Initialize logging context with agent from checkpoint\\n   864→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   865→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   866→\\n   867→\\tlogging.Debug(ctx, \\\"logs-only checkout started\\\",\\n   868→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   869→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   870→\\t)\\n   871→\\n   872→\\t// First, restore the logs\\n   873→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   874→\\tif !ok {\\n   875→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   876→\\t}\\n   877→\\n   878→\\tsessions, err := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   879→\\tif err != nil {\\n   880→\\t\\tlogging.Error(ctx, \\\"logs-only checkout failed during log restoration\\\",\\n   881→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   882→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   883→\\t\\t)\\n   884→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   885→\\t}\\n   886→\\n   887→\\t// Show warning about detached HEAD\\n   888→\\tvar confirm bool\\n   889→\\tconfirmForm := NewAccessibleForm(\\n   890→\\t\\thuh.NewGroup(\\n   891→\\t\\t\\thuh.NewConfirm().\\n   892→\\t\\t\\t\\tTitle(\\\"Create detached HEAD?\\\").\\n   893→\\t\\t\\t\\tDescription(\\\"This will checkout the commit directly. You'll be in 'detached HEAD' state.\\\\nAny uncommitted changes will be lost!\\\").\\n   894→\\t\\t\\t\\tValue(&confirm),\\n   895→\\t\\t),\\n   896→\\t)\\n   897→\\n   898→\\tif err := confirmForm.Run(); err != nil {\\n   899→\\t\\treturn fmt.Errorf(\\\"confirmation cancelled: %w\\\", err)\\n   900→\\t}\\n   901→\\n   902→\\tif !confirm {\\n   903→\\t\\tfmt.Println(\\\"Checkout cancelled. Session logs were still restored.\\\")\\n   904→\\t\\tprintMultiSessionResumeCommands(sessions)\\n   905→\\t\\treturn nil\\n   906→\\t}\\n   907→\\n   908→\\t// Perform git checkout\\n   909→\\tif err := CheckoutBranch(point.ID); err != nil {\\n   910→\\t\\tlogging.Error(ctx, \\\"logs-only checkout failed during git checkout\\\",\\n   911→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   912→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   913→\\t\\t)\\n   914→\\t\\treturn fmt.Errorf(\\\"failed to checkout commit: %w\\\", err)\\n   915→\\t}\\n   916→\\n   917→\\tlogging.Debug(ctx, \\\"logs-only checkout completed\\\",\\n   918→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   919→\\t)\\n   920→\\n   921→\\tfmt.Printf(\\\"Checked out %s (detached HEAD).\\\\n\\\", shortID)\\n   922→\\tprintMultiSessionResumeCommands(sessions)\\n   923→\\treturn nil\\n   924→}\\n   925→\\n   926→// handleLogsOnlyReset restores logs and resets the branch to the commit (destructive).\\n   927→func handleLogsOnlyReset(start strategy.Strategy, point strategy.RewindPoint, shortID string) error {\\n   928→\\t// Resolve agent once for use throughout\\n   929→\\tagent, agentErr := getAgent(point.Agent)\\n   930→\\tif agentErr != nil {\\n   931→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", agentErr)\\n   932→\\t}\\n   933→\\n   934→\\t// Initialize logging context with agent from checkpoint\\n   935→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   936→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   937→\\n   938→\\tlogging.Debug(ctx, \\\"logs-only reset (interactive) started\\\",\\n   939→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   940→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   941→\\t)\\n   942→\\n   943→\\t// First, restore the logs\\n   944→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   945→\\tif !ok {\\n   946→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   947→\\t}\\n   948→\\n   949→\\tsessions, restoreErr := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   950→\\tif restoreErr != nil {\\n   951→\\t\\tlogging.Error(ctx, \\\"logs-only reset failed during log restoration\\\",\\n   952→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   953→\\t\\t\\tslog.String(\\\"error\\\", restoreErr.Error()),\\n   954→\\t\\t)\\n   955→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", restoreErr)\\n   956→\\t}\\n   957→\\n   958→\\t// Get current HEAD before reset (for recovery message)\\n   959→\\tcurrentHead, err := getCurrentHeadHash()\\n   960→\\tif err != nil {\\n   961→\\t\\t// Non-fatal - just won't show recovery message\\n   962→\\t\\tcurrentHead = \\\"\\\"\\n   963→\\t}\\n   964→\\n   965→\\t// Get detailed uncommitted changes warning from strategy\\n   966→\\tvar uncommittedWarning string\\n   967→\\tif _, warn, err := start.CanRewind(); err == nil {\\n   968→\\t\\tuncommittedWarning = warn\\n   969→\\t}\\n   970→\\n   971→\\t// Check for safety issues\\n   972→\\twarnings, err := checkResetSafety(point.ID, uncommittedWarning)\\n   973→\\tif err != nil {\\n   974→\\t\\treturn fmt.Errorf(\\\"failed to check reset safety: %w\\\", err)\\n   975→\\t}\\n   976→\\n   977→\\t// Build confirmation message based on warnings\\n   978→\\tvar confirmTitle, confirmDesc string\\n   979→\\tif len(warnings) > 0 {\\n   980→\\t\\tconfirmTitle = \\\"⚠️  Reset branch with warnings?\\\"\\n   981→\\t\\tconfirmDesc = \\\"WARNING - the following issues were detected:\\\\n\\\" +\\n   982→\\t\\t\\tstrings.Join(warnings, \\\"\\\\n\\\") +\\n   983→\\t\\t\\t\\\"\\\\n\\\\nThis will move your branch to \\\" + shortID + \\\" and DISCARD commits after it!\\\"\\n   984→\\t} else {\\n   985→\\t\\tconfirmTitle = \\\"Reset branch to \\\" + shortID + \\\"?\\\"\\n   986→\\t\\tconfirmDesc = \\\"This will move your branch pointer to this commit.\\\\nCommits after this point will be orphaned (but recoverable via reflog).\\\"\\n   987→\\t}\\n   988→\\n   989→\\tvar confirm bool\\n   990→\\tconfirmForm := NewAccessibleForm(\\n   991→\\t\\thuh.NewGroup(\\n   992→\\t\\t\\thuh.NewConfirm().\\n   993→\\t\\t\\t\\tTitle(confirmTitle).\\n   994→\\t\\t\\t\\tDescription(confirmDesc).\\n   995→\\t\\t\\t\\tValue(&confirm),\\n   996→\\t\\t),\\n   997→\\t)\\n   998→\\n   999→\\tif err := confirmForm.Run(); err != nil {\\n  1000→\\t\\treturn fmt.Errorf(\\\"confirmation cancelled: %w\\\", err)\\n  1001→\\t}\\n  1002→\\n  1003→\\tif !confirm {\\n  1004→\\t\\tfmt.Println(\\\"Reset cancelled. Session logs were still restored.\\\")\\n  1005→\\t\\tprintMultiSessionResumeCommands(sessions)\\n  1006→\\t\\treturn nil\\n  1007→\\t}\\n  1008→\\n  1009→\\t// Perform git reset --hard\\n  1010→\\tif err := performGitResetHard(point.ID); err != nil {\\n  1011→\\t\\tlogging.Error(ctx, \\\"logs-only reset failed during git reset\\\",\\n  1012→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n  1013→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1014→\\t\\t)\\n  1015→\\t\\treturn fmt.Errorf(\\\"failed to reset branch: %w\\\", err)\\n  1016→\\t}\\n  1017→\\n  1018→\\tlogging.Debug(ctx, \\\"logs-only reset (interactive) completed\\\",\\n  1019→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n  1020→\\t)\\n  1021→\\n  1022→\\tfmt.Printf(\\\"Reset branch to %s.\\\\n\\\", shortID)\\n  1023→\\tprintMultiSessionResumeCommands(sessions)\\n  1024→\\n  1025→\\t// Show recovery instructions\\n  1026→\\tif currentHead != \\\"\\\" && currentHead != point.ID {\\n  1027→\\t\\tcurrentShort := currentHead\\n  1028→\\t\\tif len(currentShort) > 7 {\\n  1029→\\t\\t\\tcurrentShort = currentShort[:7]\\n  1030→\\t\\t}\\n  1031→\\t\\tfmt.Printf(\\\"\\\\nTo undo this reset: git reset --hard %s\\\\n\\\", currentShort)\\n  1032→\\t}\\n  1033→\\n  1034→\\treturn nil\\n  1035→}\\n  1036→\\n  1037→// getCurrentHeadHash returns the current HEAD commit hash.\\n  1038→func getCurrentHeadHash() (string, error) {\\n  1039→\\trepo, err := openRepository()\\n  1040→\\tif err != nil {\\n  1041→\\t\\treturn \\\"\\\", err\\n  1042→\\t}\\n  1043→\\n  1044→\\thead, err := repo.Head()\\n  1045→\\tif err != nil {\\n  1046→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n  1047→\\t}\\n  1048→\\n  1049→\\treturn head.Hash().String(), nil\\n  1050→}\\n  1051→\\n  1052→// checkResetSafety checks for potential issues before a git reset --hard.\\n  1053→// Returns a list of warning messages (empty if safe to proceed without warnings).\\n  1054→// If uncommittedChangesWarning is provided, it will be used instead of a generic warning.\\n  1055→func checkResetSafety(targetCommitHash string, uncommittedChangesWarning string) ([]string, error) {\\n  1056→\\tvar warnings []string\\n  1057→\\n  1058→\\trepo, err := openRepository()\\n  1059→\\tif err != nil {\\n  1060→\\t\\treturn nil, err\\n  1061→\\t}\\n  1062→\\n  1063→\\t// Check for uncommitted changes\\n  1064→\\tif uncommittedChangesWarning != \\\"\\\" {\\n  1065→\\t\\t// Use the detailed warning from strategy's CanRewind()\\n  1066→\\t\\twarnings = append(warnings, uncommittedChangesWarning)\\n  1067→\\t} else {\\n  1068→\\t\\t// Fall back to generic check\\n  1069→\\t\\tworktree, err := repo.Worktree()\\n  1070→\\t\\tif err != nil {\\n  1071→\\t\\t\\treturn nil, 