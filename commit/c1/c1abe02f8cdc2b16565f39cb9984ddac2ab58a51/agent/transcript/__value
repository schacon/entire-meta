mary(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry, sessions []SessionFilePaths) error {\\n   385→\\tcheckpointsCount, filesTouched, tokenUsage, err :=\\n   386→\\t\\ts.reaggregateFromEntries(basePath, len(sessions), entries)\\n   387→\\tif err != nil {\\n   388→\\t\\treturn fmt.Errorf(\\\"failed to aggregate session stats: %w\\\", err)\\n   389→\\t}\\n   390→\\n   391→\\tsummary := CheckpointSummary{\\n   392→\\t\\tCheckpointID:     opts.CheckpointID,\\n   393→\\t\\tCLIVersion:       buildinfo.Version,\\n   394→\\t\\tStrategy:         opts.Strategy,\\n   395→\\t\\tBranch:           opts.Branch,\\n   396→\\t\\tCheckpointsCount: checkpointsCount,\\n   397→\\t\\tFilesTouched:     filesTouched,\\n   398→\\t\\tSessions:         sessions,\\n   399→\\t\\tTokenUsage:       tokenUsage,\\n   400→\\t}\\n   401→\\n   402→\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(summary, \\\"\\\", \\\"  \\\")\\n   403→\\tif err != nil {\\n   404→\\t\\treturn fmt.Errorf(\\\"failed to marshal checkpoint summary: %w\\\", err)\\n   405→\\t}\\n   406→\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n   407→\\tif err != nil {\\n   408→\\t\\treturn err\\n   409→\\t}\\n   410→\\tentries[basePath+paths.MetadataFileName] = object.TreeEntry{\\n   411→\\t\\tName: basePath + paths.MetadataFileName,\\n   412→\\t\\tMode: filemode.Regular,\\n   413→\\t\\tHash: metadataHash,\\n   414→\\t}\\n   415→\\treturn nil\\n   416→}\\n   417→\\n   418→// findSessionIndex returns the index of an existing session with the given ID,\\n   419→// or the next available index if not found. This prevents duplicate session entries.\\n   420→func (s *GitStore) findSessionIndex(basePath string, existingSummary *CheckpointSummary, entries map[string]object.TreeEntry, sessionID string) int {\\n   421→\\tif existingSummary == nil {\\n   422→\\t\\treturn 0\\n   423→\\t}\\n   424→\\tfor i := range len(existingSummary.Sessions) {\\n   425→\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n   426→\\t\\tif entry, exists := entries[path]; exists {\\n   427→\\t\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n   428→\\t\\t\\tif err != nil {\\n   429→\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to read session metadata during dedup check\\\",\\n   430→\\t\\t\\t\\t\\tslog.Int(\\\"session_index\\\", i),\\n   431→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   432→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   433→\\t\\t\\t\\t)\\n   434→\\t\\t\\t\\tcontinue\\n   435→\\t\\t\\t}\\n   436→\\t\\t\\tif meta.SessionID == sessionID {\\n   437→\\t\\t\\t\\treturn i\\n   438→\\t\\t\\t}\\n   439→\\t\\t}\\n   440→\\t}\\n   441→\\treturn len(existingSummary.Sessions)\\n   442→}\\n   443→\\n   444→// reaggregateFromEntries reads all session metadata from the entries map and\\n   445→// reaggregates CheckpointsCount, FilesTouched, and TokenUsage.\\n   446→func (s *GitStore) reaggregateFromEntries(basePath string, sessionCount int, entries map[string]object.TreeEntry) (int, []string, *agent.TokenUsage, error) {\\n   447→\\tvar totalCount int\\n   448→\\tvar allFiles []string\\n   449→\\tvar totalTokens *agent.TokenUsage\\n   450→\\n   451→\\tfor i := range sessionCount {\\n   452→\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n   453→\\t\\tentry, exists := entries[path]\\n   454→\\t\\tif !exists {\\n   455→\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"session %d metadata not found at %s\\\", i, path)\\n   456→\\t\\t}\\n   457→\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n   458→\\t\\tif err != nil {\\n   459→\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"failed to read session %d metadata: %w\\\", i, err)\\n   460→\\t\\t}\\n   461→\\t\\ttotalCount += meta.CheckpointsCount\\n   462→\\t\\tallFiles = mergeFilesTouched(allFiles, meta.FilesTouched)\\n   463→\\t\\ttotalTokens = aggregateTokenUsage(totalTokens, meta.TokenUsage)\\n   464→\\t}\\n   465→\\n   466→\\treturn totalCount, allFiles, totalTokens, nil\\n   467→}\\n   468→\\n   469→// readJSONFromBlob reads JSON from a blob hash and decodes it to the given type.\\n   470→func readJSONFromBlob[T any](repo *git.Repository, hash plumbing.Hash) (*T, error) {\\n   471→\\tblob, err := repo.BlobObject(hash)\\n   472→\\tif err != nil {\\n   473→\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob: %w\\\", err)\\n   474→\\t}\\n   475→\\n   476→\\treader, err := blob.Reader()\\n   477→\\tif err != nil {\\n   478→\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob reader: %w\\\", err)\\n   479→\\t}\\n   480→\\tdefer reader.Close()\\n   481→\\n   482→\\tvar result T\\n   483→\\tif err := json.NewDecoder(reader).Decode(&result); err != nil {\\n   484→\\t\\treturn nil, fmt.Errorf(\\\"failed to decode: %w\\\", err)\\n   485→\\t}\\n   486→\\n   487→\\treturn &result, nil\\n   488→}\\n   489→\\n   490→// readSummaryFromBlob reads CheckpointSummary from a blob hash.\\n   491→func (s *GitStore) readSummaryFromBlob(hash plumbing.Hash) (*CheckpointSummary, error) {\\n   492→\\treturn readJSONFromBlob[CheckpointSummary](s.repo, hash)\\n   493→}\\n   494→\\n   495→// aggregateTokenUsage sums two TokenUsage structs.\\n   496→// Returns nil if both inputs are nil.\\n   497→func aggregateTokenUsage(a, b *agent.TokenUsage) *agent.TokenUsage {\\n   498→\\tif a == nil && b == nil {\\n   499→\\t\\treturn nil\\n   500→\\t}\\n   501→\\tresult := &agent.TokenUsage{}\\n   502→\\tif a != nil {\\n   503→\\t\\tresult.InputTokens = a.InputTokens\\n   504→\\t\\tresult.CacheCreationTokens = a.CacheCreationTokens\\n   505→\\t\\tresult.CacheReadTokens = a.CacheReadTokens\\n   506→\\t\\tresult.OutputTokens = a.OutputTokens\\n   507→\\t\\tresult.APICallCount = a.APICallCount\\n   508→\\t}\\n   509→\\tif b != nil {\\n   510→\\t\\tresult.InputTokens += b.InputTokens\\n   511→\\t\\tresult.CacheCreationTokens += b.CacheCreationTokens\\n   512→\\t\\tresult.CacheReadTokens += b.CacheReadTokens\\n   513→\\t\\tresult.OutputTokens += b.OutputTokens\\n   514→\\t\\tresult.APICallCount += b.APICallCount\\n   515→\\t}\\n   516→\\treturn result\\n   517→}\\n   518→\\n   519→// writeTranscript writes the transcript file from in-memory content or file path.\\n   520→// If the transcript exceeds MaxChunkSize, it's split into multiple chunk files.\\n   521→func (s *GitStore) writeTranscript(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry) error {\\n   522→\\ttranscript := opts.Transcript\\n   523→\\tif len(transcript) == 0 && opts.TranscriptPath != \\\"\\\" {\\n   524→\\t\\tvar readErr error\\n   525→\\t\\ttranscript, readErr = os.ReadFile(opts.TranscriptPath)\\n   526→\\t\\tif readErr != nil {\\n   527→\\t\\t\\t// Non-fatal: transcript may not exist yet\\n   528→\\t\\t\\ttranscript = nil\\n   529→\\t\\t}\\n   530→\\t}\\n   531→\\tif len(transcript) == 0 {\\n   532→\\t\\treturn nil\\n   533→\\t}\\n   534→\\n   535→\\t// Redact secrets before chunking so content hash reflects redacted content\\n   536→\\ttranscript, err := redact.JSONLBytes(transcript)\\n   537→\\tif err != nil {\\n   538→\\t\\treturn fmt.Errorf(\\\"failed to redact transcript secrets: %w\\\", err)\\n   539→\\t}\\n   540→\\n   541→\\t// Chunk the transcript if it's too large\\n   542→\\tchunks, err := agent.ChunkTranscript(transcript, opts.Agent)\\n   543→\\tif err != nil {\\n   544→\\t\\treturn fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n   545→\\t}\\n   546→\\n   547→\\t// Write chunk files\\n   548→\\tfor i, chunk := range chunks {\\n   549→\\t\\tchunkPath := basePath + agent.ChunkFileName(paths.TranscriptFileName, i)\\n   550→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, chunk)\\n   551→\\t\\tif err != nil {\\n   552→\\t\\t\\treturn err\\n   553→\\t\\t}\\n   554→\\t\\tentries[chunkPath] = object.TreeEntry{\\n   555→\\t\\t\\tName: chunkPath,\\n   556→\\t\\t\\tMode: filemode.Regular,\\n   557→\\t\\t\\tHash: blobHash,\\n   558→\\t\\t}\\n   559→\\t}\\n   560→\\n   561→\\t// Content hash for deduplication (hash of full transcript)\\n   562→\\tcontentHash := fmt.Sprintf(\\\"sha256:%x\\\", sha256.Sum256(transcript))\\n   563→\\thashBlob, err := CreateBlobFromContent(s.repo, []byte(contentHash))\\n   564→\\tif err != nil {\\n   565→\\t\\treturn err\\n   566→\\t}\\n   567→\\tentries[basePath+paths.ContentHashFileName] = object.TreeEntry{\\n   568→\\t\\tName: basePath + paths.ContentHashFileName,\\n   569→\\t\\tMode: filemode.Regular,\\n   570→\\t\\tHash: hashBlob,\\n   571→\\t}\\n   572→\\treturn nil\\n   573→}\\n   574→\\n   575→// mergeFilesTouched combines two file lists, removing duplicates.\\n   576→func mergeFilesTouched(existing, additional []string) []string {\\n   577→\\tseen := make(map[string]bool)\\n   578→\\tvar result []string\\n   579→\\n   580→\\tfor _, f := range existing {\\n   581→\\t\\tif !seen[f] {\\n   582→\\t\\t\\tseen[f] = true\\n   583→\\t\\t\\tresult = append(result, f)\\n   584→\\t\\t}\\n   585→\\t}\\n   586→\\tfor _, f := range additional {\\n   587→\\t\\tif !seen[f] {\\n   588→\\t\\t\\tseen[f] = true\\n   589→\\t\\t\\tresult = append(result, f)\\n   590→\\t\\t}\\n   591→\\t}\\n   592→\\n   593→\\tsort.Strings(result)\\n   594→\\treturn result\\n   595→}\\n   596→\\n   597→// redactSummary returns a copy of the summary with text fields redacted.\\n   598→// Structural fields (Path, Line, EndLine) are preserved.\\n   599→// NOTE: When adding new text fields to Summary, LearningsSummary, or CodeLearning,\\n   600→// update this function to include them in redaction.\\n   601→func redactSummary(s *Summary) *Summary {\\n   602→\\tif s == nil {\\n   603→\\t\\treturn nil\\n   604→\\t}\\n   605→\\treturn &Summary{\\n   606→\\t\\tIntent:    redact.String(s.Intent),\\n   607→\\t\\tOutcome:   redact.String(s.Outcome),\\n   608→\\t\\tFriction:  redactStringSlice(s.Friction),\\n   609→\\t\\tOpenItems: redactStringSlice(s.OpenItems),\\n   610→\\t\\tLearnings: LearningsSummary{\\n   611→\\t\\t\\tRepo:     redactStringSlice(s.Learnings.Repo),\\n   612→\\t\\t\\tWorkflow: redactStringSlice(s.Learnings.Workflow),\\n   613→\\t\\t\\tCode:     redactCodeLearnings(s.Learnings.Code),\\n   614→\\t\\t},\\n   615→\\t}\\n   616→}\\n   617→\\n   618→// redactStringSlice applies redact.String to each element.\\n   619→func redactStringSlice(ss []string) []string {\\n   620→\\tif ss == nil {\\n   621→\\t\\treturn nil\\n   622→\\t}\\n   623→\\tout := make([]string, len(ss))\\n   624→\\tfor i, s := range ss {\\n   625→\\t\\tout[i] = redact.String(s)\\n   626→\\t}\\n   627→\\treturn out\\n   628→}\\n   629→\\n   630→// redactCodeLearnings redacts only the Finding field, preserving Path/Line/EndLine.\\n   631→func redactCodeLearnings(cls []CodeLearning) []CodeLearning {\\n   632→\\tif cls == nil {\\n   633→\\t\\treturn nil\\n   634→\\t}\\n   635→\\tout := make([]CodeLearning, len(cls))\\n   636→\\tfor i, cl := range cls {\\n   637→\\t\\tout[i] = CodeLearning{\\n   638→\\t\\t\\tPath:    cl.Path,\\n   639→\\t\\t\\tLine:    cl.Line,\\n   640→\\t\\t\\tEndLine: cl.EndLine,\\n   641→\\t\\t\\tFinding: redact.String(cl.Finding),\\n   642→\\t\\t}\\n   643→\\t}\\n   644→\\treturn out\\n   645→}\\n   646→\\n   647→// readMetadataFromBlob reads CommittedMetadata from a blob hash.\\n   648→func (s *GitStore) readMetadataFromBlob(hash plumbing.Hash) (*CommittedMetadata, error) {\\n   649→\\treturn readJSONFromBlob[CommittedMetadata](s.repo, hash)\\n   650→}\\n   651→\\n   652→// buildCommitMessage constructs the commit message with proper trailers.\\n   653→// The commit subject is always \\\"Checkpoint: <id>\\\" for consistency.\\n   654→// If CommitSubject is provided (e.g., for task checkpoints), it's included in the body.\\n   655→func (s *GitStore) buildCommitMessage(opts WriteCommittedOptions, taskMetadataPath string) string {\\n   656→\\tvar commitMsg strings.Builder\\n   657→\\n   658→\\t// Subject line is always the checkpoint ID for consistent formatting\\n   659→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"Checkpoint: %s\\\\n\\\\n\\\", opts.CheckpointID))\\n   660→\\n   661→\\t// Include custom description in body if provided (e.g., task checkpoint details)\\n   662→\\tif opts.CommitSubject != \\\"\\\" {\\n   663→\\t\\tcommitMsg.WriteString(opts.CommitSubject + \\\"\\\\n\\\\n\\\")\\n   664→\\t}\\n   665→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.SessionTrailerKey, opts.SessionID))\\n   666→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.StrategyTrailerKey, opts.Strategy))\\n   667→\\tif opts.Agent != \\\"\\\" {\\n   668→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.AgentTrailerKey, opts.Agent))\\n   669→\\t}\\n   670→\\tif opts.EphemeralBranch != \\\"\\\" {\\n   671→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.EphemeralBranchTrailerKey, opts.EphemeralBranch))\\n   672→\\t}\\n   673→\\tif taskMetadataPath != \\\"\\\" {\\n   674→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.MetadataTaskTrailerKey, taskMetadataPath))\\n   675→\\t}\\n   676→\\n   677→\\treturn commitMsg.String()\\n   678→}\\n   679→\\n   680→// incrementalCheckpointData represents an incremental checkpoint during subagent execution.\\n   681→// This mirrors strategy.SubagentCheckpoint but avoids import cycles.\\n   682→type incrementalCheckpointData struct {\\n   683→\\tType      string          `json:\\\"type\\\"`\\n   684→\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   685→\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n   686→\\tData      json.RawMessage `json:\\\"data\\\"`\\n   687→}\\n   688→\\n   689→// taskCheckpointData represents a final task checkpoint.\\n   690→// This mirrors strategy.TaskCheckpoint but avoids import cycles.\\n   691→type taskCheckpointData struct {\\n   692→\\tSessionID      string `json:\\\"session_id\\\"`\\n   693→\\tToolUseID      string `json:\\\"tool_use_id\\\"`\\n   694→\\tCheckpointUUID string `json:\\\"checkpoint_uuid\\\"`\\n   695→\\tAgentID        string `json:\\\"agent_id,omitempty\\\"`\\n   696→}\\n   697→\\n   698→// ReadCommitted reads a committed checkpoint's summary by ID from the entire/checkpoints/v1 branch.\\n   699→// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n   700→// Use ReadSessionContent to read actual transcript/prompts/context.\\n   701→// Returns nil, nil if the checkpoint doesn't exist.\\n   702→//\\n   703→// The storage format uses numbered subdirectories for each session (0-based):\\n   704→//\\n   705→//\\t<checkpoint-id>/\\n   706→//\\t├── metadata.json      # CheckpointSummary with sessions map\\n   707→//\\t├── 0/                 # First session\\n   708→//\\t│   ├── metadata.json  # Session-specific metadata\\n   709→//\\t│   └── full.jsonl     # Transcript\\n   710→//\\t├── 1/                 # Second session\\n   711→//\\t└── ...\\n   712→func (s *GitStore) ReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error) {\\n   713→\\t_ = ctx // Reserved for future use\\n   714→\\n   715→\\ttree, err := s.getSessionsBranchTree()\\n   716→\\tif err != nil {\\n   717→\\t\\treturn nil, nil //nolint:nilnil,nilerr // No sessions branch means no checkpoint exists\\n   718→\\t}\\n   719→\\n   720→\\tcheckpointPath := checkpointID.Path()\\n   721→\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n   722→\\tif err != nil {\\n   723→\\t\\treturn nil, nil //nolint:nilnil,nilerr // Checkpoint directory not found\\n   724→\\t}\\n   725→\\n   726→\\t// Read root metadata.json as CheckpointSummary\\n   727→\\tmetadataFile, err := checkpointTree.File(paths.MetadataFileName)\\n   728→\\tif err != nil {\\n   729→\\t\\treturn nil, nil //nolint:nilnil,nilerr // metadata.json not found\\n   730→\\t}\\n   731→\\n   732→\\tcontent, err := metadataFile.Contents()\\n   733→\\tif err != nil {\\n   734→\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata.json: %w\\\", err)\\n   735→\\t}\\n   736→\\n   737→\\tvar summary CheckpointSummary\\n   738→\\tif err := json.Unmarshal([]byte(content), &summary); err != nil {\\n   739→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata.json: %w\\\", err)\\n   740→\\t}\\n   741→\\n   742→\\treturn &summary, nil\\n   743→}\\n   744→\\n   745→// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n   746→// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n   747→// Returns the session's metadata, transcript, prompts, and context.\\n   748→// Returns an error if the checkpoint or session doesn't exist.\\n   749→func (s *GitStore) ReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error) {\\n   750→\\t_ = ctx // Reserved for future use\\n   751→\\n   752→\\ttree, err := s.getSessionsBranchTree()\\n   753→\\tif err != nil {\\n   754→\\t\\treturn nil, ErrCheckpointNotFound\\n   755→\\t}\\n   756→\\n   757→\\tcheckpointPath := checkpointID.Path()\\n   758→\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n   759→\\tif err != nil {\\n   760→\\t\\treturn nil, ErrCheckpointNotFound\\n   761→\\t}\\n   762→\\n   763→\\t// Get the session subdirectory\\n   764→\\tsessionDir := strconv.Itoa(sessionIndex)\\n   765→\\tsessionTree, err := checkpointTree.Tree(sessionDir)\\n   766→\\tif err != nil {\\n   767→\\t\\treturn nil, fmt.Errorf(\\\"session %d not found: %w\\\", sessionIndex, err)\\n   768→\\t}\\n   769→\\n   770→\\tresult := &SessionContent{}\\n   771→\\n   772→\\t// Read session-specific metadata\\n   773→\\tvar agentType agent.AgentType\\n   774→\\tif metadataFile, fileErr := sessionTree.File(paths.MetadataFileName); fileErr == nil {\\n   775→\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n   776→\\t\\t\\tif jsonErr := json.Unmarshal([]byte(content), &result.Metadata); jsonErr == nil {\\n   777→\\t\\t\\t\\tagentType = result.Metadata.Agent\\n   778→\\t\\t\\t}\\n   779→\\t\\t}\\n  