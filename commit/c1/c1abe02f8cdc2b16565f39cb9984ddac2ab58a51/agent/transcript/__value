tCode() == 1 {\\n  1204→\\t\\t\\treturn fmt.Errorf(\\\"%w: %s\\\", ErrBranchNotFound, branchName)\\n  1205→\\t\\t}\\n  1206→\\t\\treturn fmt.Errorf(\\\"failed to check branch %s: %w\\\", branchName, err)\\n  1207→\\t}\\n  1208→\\n  1209→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", branchName)\\n  1210→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1211→\\t\\treturn fmt.Errorf(\\\"failed to delete branch %s: %s: %w\\\", branchName, strings.TrimSpace(string(output)), err)\\n  1212→\\t}\\n  1213→\\treturn nil\\n  1214→}\\n  1215→\\n  1216→// branchExistsCLI checks if a branch exists using git CLI.\\n  1217→// Returns nil if the branch exists, or an error if it does not.\\n  1218→func branchExistsCLI(branchName string) error {\\n  1219→\\tctx := context.Background()\\n  1220→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"show-ref\\\", \\\"--verify\\\", \\\"--quiet\\\", \\\"refs/heads/\\\"+branchName) //nolint:gosec // branchName comes from internal shadow branch naming\\n  1221→\\tif err := cmd.Run(); err != nil {\\n  1222→\\t\\treturn fmt.Errorf(\\\"branch %s not found: %w\\\", branchName, err)\\n  1223→\\t}\\n  1224→\\treturn nil\\n  1225→}\\n  1226→\\n  1227→// HardResetWithProtection performs a git reset --hard to the specified commit.\\n  1228→// Uses the git CLI instead of go-git because go-git's HardReset incorrectly\\n  1229→// deletes untracked directories (like .entire/) even when they're in .gitignore.\\n  1230→// Returns the short commit ID (7 chars) on success for display purposes.\\n  1231→func HardResetWithProtection(commitHash plumbing.Hash) (shortID string, err error) {\\n  1232→\\tctx := context.Background()\\n  1233→\\thashStr := commitHash.String()\\n  1234→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"reset\\\", \\\"--hard\\\", hashStr) //nolint:gosec // hashStr is a plumbing.Hash, not user input\\n  1235→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1236→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"reset failed: %s: %w\\\", strings.TrimSpace(string(output)), err)\\n  1237→\\t}\\n  1238→\\n  1239→\\t// Return short commit ID for display\\n  1240→\\tshortID = hashStr\\n  1241→\\tif len(shortID) > 7 {\\n  1242→\\t\\tshortID = shortID[:7]\\n  1243→\\t}\\n  1244→\\treturn shortID, nil\\n  1245→}\\n  1246→\\n  1247→// collectUntrackedFiles collects all untracked files in the working directory.\\n  1248→// This is used to capture the initial state when starting a session,\\n  1249→// ensuring untracked files present at session start are preserved during rewind.\\n  1250→// Excludes protected directories (.git/, .entire/, and agent config directories).\\n  1251→// Works correctly from any subdirectory within the repository.\\n  1252→func collectUntrackedFiles() ([]string, error) {\\n  1253→\\t// Get repository root to walk from there\\n  1254→\\trepoRoot, err := GetWorktreePath()\\n  1255→\\tif err != nil {\\n  1256→\\t\\trepoRoot = \\\".\\\" // Fallback to current directory\\n  1257→\\t}\\n  1258→\\n  1259→\\tvar untrackedFiles []string\\n  1260→\\terr = filepath.Walk(repoRoot, func(path string, info os.FileInfo, walkErr error) error {\\n  1261→\\t\\tif walkErr != nil {\\n  1262→\\t\\t\\treturn nil //nolint:nilerr // Skip filesystem errors during walk\\n  1263→\\t\\t}\\n  1264→\\n  1265→\\t\\t// Get path relative to repo root\\n  1266→\\t\\trelPath, err := filepath.Rel(repoRoot, path)\\n  1267→\\t\\tif err != nil {\\n  1268→\\t\\t\\treturn nil //nolint:nilerr // Skip paths we can't make relative\\n  1269→\\t\\t}\\n  1270→\\n  1271→\\t\\t// Skip directories\\n  1272→\\t\\tif info.IsDir() {\\n  1273→\\t\\t\\tif isProtectedPath(relPath) {\\n  1274→\\t\\t\\t\\treturn filepath.SkipDir\\n  1275→\\t\\t\\t}\\n  1276→\\t\\t\\treturn nil\\n  1277→\\t\\t}\\n  1278→\\n  1279→\\t\\t// Skip files in protected directories (shouldn't reach here due to SkipDir, but safety check)\\n  1280→\\t\\tif isProtectedPath(relPath) {\\n  1281→\\t\\t\\treturn nil\\n  1282