is called at stop time to finalize all checkpoints from the current turn\\n  1076→// with the complete session transcript (from prompt to stop event).\\n  1077→//\\n  1078→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n  1079→func (s *GitStore) UpdateCommitted(ctx context.Context, opts UpdateCommittedOptions) error {\\n  1080→\\tif opts.CheckpointID.IsEmpty() {\\n  1081→\\t\\treturn errors.New(\\\"invalid update options: checkpoint ID is required\\\")\\n  1082→\\t}\\n  1083→\\n  1084→\\t// Ensure sessions branch exists\\n  1085→\\tif err := s.ensureSessionsBranch(); err != nil {\\n  1086→\\t\\treturn fmt.Errorf(\\\"failed to ensure sessions branch: %w\\\", err)\\n  1087→\\t}\\n  1088→\\n  1089→\\t// Get current branch tip and flatten tree\\n  1090→\\tref, entries, err := s.getSessionsBranchEntries()\\n  1091→\\tif err != nil {\\n  1092→\\t\\treturn err\\n  1093→\\t}\\n  1094→\\n  1095→\\t// Read root CheckpointSummary to find the session slot\\n  1096→\\tbasePath := opts.CheckpointID.Path() + \\\"/\\\"\\n  1097→\\trootMetadataPath := basePath + paths.MetadataFileName\\n  1098→\\tentry, exists := entries[rootMetadataPath]\\n  1099→\\tif !exists {\\n  1100→\\t\\treturn ErrCheckpointNotFound\\n  1101→\\t}\\n  1102→\\n  1103→\\tcheckpointSummary, err := s.readSummaryFromBlob(entry.Hash)\\n  1104→\\tif err != nil {\\n  1105→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint summary: %w\\\", err)\\n  1106→\\t}\\n  1107→\\tif len(checkpointSummary.Sessions) == 0 {\\n  1108→\\t\\treturn ErrCheckpointNotFound\\n  1109→\\t}\\n  1110→\\n  1111→\\t// Find session index matching opts.SessionID\\n  1112→\\tsessionIndex := -1\\n  1113→\\tfor i := range len(checkpointSummary.Sessions) {\\n  1114→\\t\\tmetaPath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n  1115→\\t\\tif metaEntry, metaExists := entries[metaPath]; metaExists {\\n  1116→\\t\\t\\tmeta, metaErr := s.readMetadataFromBlob(metaEntry.Hash)\\n  1117→\\t\\t\\tif metaErr == nil && meta.SessionID == opts.SessionID {\\n  1118→\\t\\t\\t\\tsessionIndex = i\\n  1119→\\t\\t\\t\\tbreak\\n  1120→\\t\\t\\t}\\n  1121→\\t\\t}\\n  1122→\\t}\\n  1123→\\tif sessionIndex == -1 {\\n  1124→\\t\\t// Fall back to latest session; log so mismatches are diagnosable.\\n  1125→\\t\\tsessionIndex = len(checkpointSummary.Sessions) - 1\\n  1126→\\t\\tlogging.Debug(ctx, \\\"UpdateCommitted: session ID not found, falling back to latest\\\",\\n  1127→\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n  1128→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", string(opts.CheckpointID)),\\n  1129→\\t\\t\\tslog.Int(\\\"fallback_index\\\", sessionIndex),\\n  1130→\\t\\t)\\n  1131→\\t}\\n  1132→\\n  1133→\\tsessionPath := fmt.Sprintf(\\\"%s%d/\\\", basePath, sessionIndex)\\n  1134→\\n  1135→\\t// Replace transcript (full replace, not append)\\n  1136→\\t// Apply redaction as safety net (caller should redact, but we ensure it here)\\n  1137→\\tif len(opts.Transcript) > 0 {\\n  1138→\\t\\ttranscript, err := redact.JSONLBytes(opts.Transcript)\\n  1139→\\t\\tif err != nil {\\n  1140→\\t\\t\\treturn fmt.Errorf(\\\"failed to redact transcript secrets: %w\\\", err)\\n  1141→\\t\\t}\\n  1142→\\t\\tif err := s.replaceTranscript(transcript, opts.Agent, sessionPath, entries); err != nil {\\n  1143→\\t\\t\\treturn fmt.Errorf(\\\"failed to replace transcript: %w\\\", err)\\n  1144→\\t\\t}\\n  1145→\\t}\\n  1146→\\n  1147→\\t// Replace prompts (apply redaction as safety net)\\n  1148→\\tif len(opts.Prompts) > 0 {\\n  1149→\\t\\tpromptContent := redact.String(strings.Join(opts.Prompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\"))\\n  1150→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(promptContent))\\n  1151→\\t\\tif err != nil {\\n  1152→\\t\\t\\treturn fmt.Errorf(\\\"failed to create prompt blob: %w\\\", err)\\n  1153→\\t\\t}\\n  1154→\\t\\tentries[sessionPath+paths.PromptFileName] = object.TreeEntry{\\n  1155→\\t\\t\\tName: sessionPath + paths.PromptFileName,\\n  1156→\\t\\t\\tMode: filemode.Regular,\\n  1157→\\t\\t\\tHash: blobHash,\\n  1158→\\t\\t}\\n  1159→\\t}\\n  1160→\\n  1161→\\t// Replace context (apply redaction as safety net)\\n  1162→\\tif len(opts.Context) > 0 {\\n  1163→\\t\\tcontextBlob, err := CreateBlobFromContent(s.repo, redact.Bytes(opts.Context))\\n  1164→\\t\\tif err != nil {\\n  1165→\\t\\t\\treturn fmt.Errorf(\\\"failed to create context blob: %w\\\", err)\\n  1166→\\t\\t}\\n  1167→\\t\\tentries[sessionPath+paths.ContextFileName] = object.TreeEntry{\\n  1168→\\t\\t\\tName: sessionPath + paths.ContextFileName,\\n  1169→\\t\\t\\tMode: filemode.Regular,\\n  1170→\\t\\t\\tHash: contextBlob,\\n  1171→\\t\\t}\\n  1172→\\t}\\n  1173→\\n  1174→\\t// Build and commit\\n  1175→\\tnewTreeHash, err := BuildTreeFromEntries(s.repo, entries)\\n  1176→\\tif err != nil {\\n  1177→\\t\\treturn err\\n  1178→\\t}\\n  1179→\\n  1180→\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n  1181→\\tcommitMsg := fmt.Sprintf(\\\"Finalize transcript for Checkpoint: %s\\\", opts.CheckpointID)\\n  1182→\\tnewCommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, authorName, authorEmail)\\n  1183→\\tif err != nil {\\n  1184→\\t\\treturn err\\n  1185→\\t}\\n  1186→\\n  1187→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1188→\\tnewRef := plumbing.NewHashReference(refName, newCommitHash)\\n  1189→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1190→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1191→\\t}\\n  1192→\\n  1193→\\treturn nil\\n  1194→}\\n  1195→\\n  1196→// replaceTranscript writes the full transcript content, replacing any existing transcript.\\n  1197→// Also removes any chunk files from a previous write and updates the content hash.\\n  1198→func (s *GitStore) replaceTranscript(transcript []byte, agentType agent.AgentType, sessionPath string, entries map[string]object.TreeEntry) error {\\n  1199→\\t// Remove existing transcript files (base + any chunks)\\n  1200→\\ttranscriptBase := sessionPath + paths.TranscriptFileName\\n  1201→\\tfor key := range entries {\\n  1202→\\t\\tif key == transcriptBase || strings.HasPrefix(key, transcriptBase+\\\".\\\") {\\n  1203→\\t\\t\\tdelete(entries, key)\\n  1204→\\t\\t}\\n  1205→\\t}\\n  1206→\\n  1207→\\t// Chunk the transcript (matches writeTranscript behavior)\\n  1208→\\tchunks, err := agent.ChunkTranscript(transcript, agentType)\\n  1209→\\tif err != nil {\\n  1210→\\t\\treturn fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n  1211→\\t}\\n  1212→\\n  1213→\\t// Write chunk files\\n  1214→\\tfor i, chunk := range chunks {\\n  1215→\\t\\tchunkPath := sessionPath + agent.ChunkFileName(paths.TranscriptFileName, i)\\n  1216→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, chunk)\\n  1217→\\t\\tif err != nil {\\n  1218→\\t\\t\\treturn fmt.Errorf(\\\"failed to create transcript blob: %w\\\", err)\\n  1219→\\t\\t}\\n  1220→\\t\\tentries[chunkPath] = object.TreeEntry{\\n  1221→\\t\\t\\tName: chunkPath,\\n  1222→\\t\\t\\tMode: filemode.Regular,\\n  1223→\\t\\t\\tHash: blobHash,\\n  1224→\\t\\t}\\n  1225→\\t}\\n  1226→\\n  1227→\\t// Update content hash\\n  1228→\\tcontentHash := fmt.Sprintf(\\\"sha256:%x\\\", sha256.Sum256(transcript))\\n  1229→\\thashBlob, err := CreateBlobFromContent(s.repo, []byte(contentHash))\\n  1230→\\tif err != nil {\\n  1231→\\t\\treturn fmt.Errorf(\\\"failed to create content hash blob: %w\\\", err)\\n  1232→\\t}\\n  1233→\\thashPath := sessionPath + paths.ContentHashFileName\\n  1234→\\tentries[hashPath] = object.TreeEntry{\\n  1235→\\t\\tName: hashPath,\\n  1236→\\t\\tMode: filemode.Regular,\\n  1237→\\t\\tHash: hashBlob,\\n  1238→\\t}\\n  1239→\\n  1240→\\treturn nil\\n  1241→}\\n  1242→\\n  1243→// ensureSessionsBranch ensures the entire/checkpoints/v1 branch exists.\\n  1244→func (s *GitStore) ensureSessionsBranch() error {\\n  1245→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1246→\\t_, err := s.repo.Reference(refName, true)\\n  1247→\\tif err == nil {\\n  1248→\\t\\treturn nil // Branch exists\\n  1249→\\t}\\n  1250→\\n  1251→\\t// Create orphan branch with empty tree\\n  1252→\\temptyTreeHash, err := BuildTreeFromEntries(s.repo, make(map[string]object.TreeEntry))\\n  1253→\\tif err != nil {\\n  1254→\\t\\treturn err\\n  1255→\\t}\\n  1256→\\n  1257→\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n  1258→\\tcommitHash, err := s.createCommit(emptyTreeHash, plumbing.ZeroHash, \\\"Initialize sessions branch\\\", authorName, authorEmail)\\n  1259→\\tif err != nil {\\n  1260→\\t\\treturn err\\n  1261→\\t}\\n  1262→\\n  1263→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n  1264→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1265→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1266→\\t}\\n  1267→\\treturn nil\\n  1268→}\\n  1269→\\n  1270→// getSessionsBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\n  1271→// Falls back to origin/entire/checkpoints/v1 if the local branch doesn't exist.\\n  1272→func (s *GitStore) getSessionsBranchTree() (*object.Tree, error) {\\n  1273→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1274→\\tref, err := s.repo.Reference(refName, true)\\n  1275→\\tif err != nil {\\n  1276→\\t\\t// Local branch doesn't exist, try remote-tracking branch\\n  1277→\\t\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n  1278→\\t\\tref, err = s.repo.Reference(remoteRefName, true)\\n  1279→\\t\\tif err != nil {\\n  1280→\\t\\t\\treturn nil, fmt.Errorf(\\\"sessions branch not found: %w\\\", err)\\n  1281→\\t\\t}\\n  1282→\\t}\\n  1283→\\n  1284→\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n  1285→\\tif err != nil {\\n  1286→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n  1287→\\t}\\n  1288→\\n  1289→\\ttree, err := commit.Tree()\\n  1290→\\tif err != nil {\\n  1291→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n  1292→\\t}\\n  1293→\\n  1294→\\treturn tree, nil\\n  1295→}\\n  1296→\\n  1297→// CreateBlobFromContent creates a blob object from in-memory content.\\n  1298→// Exported for use by strategy package (session_test.go)\\n  1299→func CreateBlobFromContent(repo *git.Repository, content []byte) (plumbing.Hash, error) {\\n  1300→\\tobj := repo.Storer.NewEncodedObject()\\n  1301→\\tobj.SetType(plumbing.BlobObject)\\n  1302→\\tobj.SetSize(int64(len(content)))\\n  1303→\\n  1304→\\twriter, err := obj.Writer()\\n  1305→\\tif err != nil {\\n  1306→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get object writer: %w\\\", err)\\n  1307→\\t}\\n  1308→\\n  1309→\\t_, err = writer.Write(content)\\n  1310→\\tif err != nil {\\n  1311→\\t\\t_ = writer.Close()\\n  1312→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write blob content: %w\\\", err)\\n  1313→\\t}\\n  1314→\\tif err := writer.Close(); err != nil {\\n  1315→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to close blob writer: %w\\\", err)\\n  1316→\\t}\\n  1317→\\n  1318→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n  1319→\\tif err != nil {\\n  1320→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store blob object: %w\\\", err)\\n  1321→\\t}\\n  1322→\\treturn hash, nil\\n  1323→}\\n  1324→\\n  1325→// copyMetadataDir copies all files from a directory to the checkpoint path.\\n  1326→// Used to include additional metadata files like task checkpoints, subagent transcripts, etc.\\n  1327→func (s *GitStore) copyMetadataDir(metadataDir, basePath string, entries map[string]object.TreeEntry) error {\\n  1328→\\terr := filepath.Walk(metadataDir, func(path string, info os.FileInfo, err error) error {\\n  1329→\\t\\tif err != nil {\\n  1330→\\t\\t\\treturn err\\n  1331→\\t\\t}\\n  1332→\\n  1333→\\t\\t// Skip symlinks to prevent reading files outside the metadata directory.\\n  1334→\\t\\t// A symlink could point to sensitive files (e.g., /etc/passwd) which would\\n  1335→\\t\\t// then be captured in the checkpoint and stored in git history.\\n  1336→\\t\\t// NOTE: filepath.Walk uses os.Stat (follows symlinks), so info.Mode() never\\n  1337→\\t\\t// reports ModeSymlink. We use os.Lstat to check the entry itself.\\n  1338→\\t\\t// This check MUST come before IsDir() because Walk follows symlinked\\n  1339→\\t\\t// directories and would recurse into them otherwise.\\n  1340→\\t\\tlinfo, lstatErr := os.Lstat(path)\\n  1341→\\t\\tif lstatErr != nil {\\n  1342→\\t\\t\\treturn fmt.Errorf(\\\"failed to lstat %s: %w\\\", path, lstatErr)\\n  1343→\\t\\t}\\n  1344→\\t\\tif linfo.Mode()&os.ModeSymlink != 0 {\\n  1345→\\t\\t\\tif info.IsDir() {\\n  1346→\\t\\t\\t\\treturn filepath.SkipDir\\n  1347→\\t\\t\\t}\\n  1348→\\t\\t\\treturn nil\\n  1349→\\t\\t}\\n  1350→\\n  1351→\\t\\tif info.IsDir() {\\n  1352→\\t\\t\\treturn nil\\n  1353→\\t\\t}\\n  1354→\\n  1355→\\t\\t// Get relative path within metadata dir\\n  1356→\\t\\trelPath, err := filepath.Rel(metadataDir, path)\\n  1357→\\t\\tif err != nil {\\n  1358→\\t\\t\\treturn fmt.Errorf(\\\"failed to get relative path for %s: %w\\\", path, err)\\n  1359→\\t\\t}\\n  1360→\\n  1361→\\t\\t// Prevent path traversal via symlinks pointing outside the metadata dir\\n  1362→\\t\\tif strings.HasPrefix(relPath, \\\"..\\\") {\\n  1363→\\t\\t\\treturn fmt.Errorf(\\\"path traversal detected: %s\\\", relPath)\\n  1364→\\t\\t}\\n  1365→\\n  1366→\\t\\t// Create blob from file with secrets redaction\\n  1367→\\t\\tblobHash, mode, err := createRedactedBlobFromFile(s.repo, path, relPath)\\n  1368→\\t\\tif err != nil {\\n  1369→\\t\\t\\treturn fmt.Errorf(\\\"failed to create blob for %s: %w\\\", path, err)\\n  1370→\\t\\t}\\n  1371→\\n  1372→\\t\\t// Store at checkpoint path (use forward slashes for git tree compatibility on Windows)\\n  1373→\\t\\tfullPath := basePath + filepath.ToSlash(relPath)\\n  1374→\\t\\tentries[fullPath] = object.TreeEntry{\\n  1375→\\t\\t\\tName: fullPath,\\n  1376→\\t\\t\\tMode: mode,\\n  1377→\\t\\t\\tHash: blobHash,\\n  1378→\\t\\t}\\n  1379→\\n  1380→\\t\\treturn nil\\n  1381→\\t})\\n  1382→\\tif err != nil {\\n  1383→\\t\\treturn fmt.Errorf(\\\"failed to walk metadata directory: %w\\\", err)\\n  1384→\\t}\\n  1385→\\treturn nil\\n  1386→}\\n  1387→\\n  1388→// createRedactedBlobFromFile reads a file, applies secrets redaction, and creates a git blob.\\n  1389→// JSONL files get JSONL-aware redaction; all other files get plain string redaction.\\n  1390→func createRedactedBlobFromFile(repo *git.Repository, filePath, treePath string) (plumbing.Hash, filemode.FileMode, error) {\\n  1391→\\tinfo, err := os.Stat(filePath)\\n  1392→\\tif err != nil {\\n  1393→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to stat file: %w\\\", err)\\n  1394→\\t}\\n  1395→\\n  1396→\\tmode := filemode.Regular\\n  1397→\\tif info.Mode()&0o111 != 0 {\\n  1398→\\t\\tmode = filemode.Executable\\n  1399→\\t}\\n  1400→\\n  1401→\\tcontent, err := os.ReadFile(filePath) //nolint:gosec // filePath comes from walking the metadata directory\\n  1402→\\tif err != nil {\\n  1403→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to read file: %w\\\", err)\\n  1404→\\t}\\n  1405→\\n  1406→\\t// Skip redaction for binary files — they can't contain text secrets and\\n  1407→\\t// running string replacement on them would corrupt the data.\\n  1408→\\tisBin, binErr := binary.IsBinary(bytes.NewReader(content))\\n  1409→\\tif binErr != nil || isBin {\\n  1410→\\t\\thash, err := CreateBlobFromContent(repo, content)\\n  1411→\\t\\tif err != nil {\\n  1412→\\t\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to create blob: %w\\\", err)\\n  1413→\\t\\t}\\n  1414→\\t\\treturn hash, mode, nil\\n  1415→\\t}\\n  1416→\\n  1417→\\tif strings.HasSuffix(treePath, \\\".jsonl\\\") {\\n  1418→\\t\\tredacted, jsonlErr := redact.JSONLBytes(content)\\n  1419→\\t\\tif jsonlErr != nil {\\n  1420→\\t\\t\\tr