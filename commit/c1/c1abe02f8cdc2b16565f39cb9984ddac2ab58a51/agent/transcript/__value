agent.Register(agent.AgentNameGemini, NewGeminiCLIAgent)\\n    25→}\\n    26→\\n    27→// GeminiCLIAgent implements the Agent interface for Gemini CLI.\\n    28→//\\n    29→//nolint:revive // GeminiCLIAgent is clearer than Agent in this context\\n    30→type GeminiCLIAgent struct{}\\n    31→\\n    32→func NewGeminiCLIAgent() agent.Agent {\\n    33→\\treturn &GeminiCLIAgent{}\\n    34→}\\n    35→\\n    36→// Name returns the agent registry key.\\n    37→func (g *GeminiCLIAgent) Name() agent.AgentName {\\n    38→\\treturn agent.AgentNameGemini\\n    39→}\\n    40→\\n    41→// Type returns the agent type identifier.\\n    42→func (g *GeminiCLIAgent) Type() agent.AgentType {\\n    43→\\treturn agent.AgentTypeGemini\\n    44→}\\n    45→\\n    46→// Description returns a human-readable description.\\n    47→func (g *GeminiCLIAgent) Description() string {\\n    48→\\treturn \\\"Gemini CLI - Google's AI coding assistant\\\"\\n    49→}\\n    50→\\n    51→// DetectPresence checks if Gemini CLI is configured in the repository.\\n    52→func (g *GeminiCLIAgent) DetectPresence() (bool, error) {\\n    53→\\t// Get repo root to check for .gemini directory\\n    54→\\t// This is needed because the CLI may be run from a subdirectory\\n    55→\\trepoRoot, err := paths.RepoRoot()\\n    56→\\tif err != nil {\\n    57→\\t\\t// Not in a git repo, fall back to CWD-relative check\\n    58→\\t\\trepoRoot = \\\".\\\"\\n    59→\\t}\\n    60→\\n    61→\\t// Check for .gemini directory\\n    62→\\tgeminiDir := filepath.Join(repoRoot, \\\".gemini\\\")\\n    63→\\tif _, err := os.Stat(geminiDir); err == nil {\\n    64→\\t\\treturn true, nil\\n    65→\\t}\\n    66→\\t// Check for .gemini/settings.json\\n    67→\\tsettingsFile := filepath.Join(repoRoot, \\\".gemini\\\", \\\"settings.json\\\")\\n    68→\\tif _, err := os.Stat(settingsFile); err == nil {\\n    69→\\t\\treturn true, nil\\n    70→\\t}\\n    71→\\treturn false, nil\\n    72→}\\n    73→\\n    74→// GetHookConfigPath returns the path to Gemini's hook config file.\\n    75→func (g *GeminiCLIAgent) GetHookConfigPath() string {\\n    76→\\treturn \\\".gemini/settings.json\\\"\\n    77→}\\n    78→\\n    79→// SupportsHooks returns true as Gemini CLI supports lifecycle hooks.\\n    80→func (g *GeminiCLIAgent) SupportsHooks() bool {\\n    81→\\treturn true\\n    82→}\\n    83→\\n    84→// ParseHookInput parses Gemini CLI hook input from stdin.\\n    85→func (g *GeminiCLIAgent) ParseHookInput(hookType agent.HookType, reader io.Reader) (*agent.HookInput, error) {\\n    86→\\tdata, err := io.ReadAll(reader)\\n    87→\\tif err != nil {\\n    88→\\t\\treturn nil, fmt.Errorf(\\\"failed to read input: %w\\\", err)\\n    89→\\t}\\n    90→\\n    91→\\tif len(data) == 0 {\\n    92→\\t\\treturn nil, errors.New(\\\"empty input\\\")\\n    93→\\t}\\n    94→\\n    95→\\tinput := &agent.HookInput{\\n    96→\\t\\tHookType:  hookType,\\n    97→\\t\\tTimestamp: time.Now(),\\n    98→\\t\\tRawData:   make(map[string]interface{}),\\n    99→\\t}\\n   100→\\n   101→\\t// Parse based on hook type\\n   102→\\tswitch hookType {\\n   103→\\tcase agent.HookSessionStart, agent.HookSessionEnd, agent.HookStop:\\n   104→\\t\\tvar raw sessionInfoRaw\\n   105→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   106→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse session info: %w\\\", err)\\n   107→\\t\\t}\\n   108→\\t\\tinput.SessionID = raw.SessionID\\n   109→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   110→\\t\\t// Store Gemini-specific fields in RawData\\n   111→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   112→\\t\\tinput.RawData[\\\"hook_event_name\\\"] = raw.HookEventName\\n   113→\\t\\tif raw.Source != \\\"\\\" {\\n   114→\\t\\t\\tinput.RawData[\\\"source\\\"] = raw.Source\\n   115→\\t\\t}\\n   116→\\t\\tif raw.Reason != \\\"\\\" {\\n   117→\\t\\t\\tinput.RawData[\\\"reason\\\"] = raw.Reason\\n   118→\\t\\t}\\n   119→\\n   120→\\tcase agent.HookUserPromptSubmit:\\n   121→\\t\\t// BeforeAgent is Gemini's equivalent to Claude's UserPromptSubmit\\n   122→\\t\\t// It provides the user's prompt in the \\\"prompt\\\" field\\n   123→\\t\\tvar raw agentHookInputRaw\\n   124→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   125→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse agent hook input: %w\\\", err)\\n   126→\\t\\t}\\n   127→\\t\\tinput.SessionID = raw.SessionID\\n   128→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   129→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   130→\\t\\tinput.RawData[\\\"hook_event_name\\\"] = raw.HookEventName\\n   131→\\t\\tif raw.Prompt != \\\"\\\" {\\n   132→\\t\\t\\tinput.UserPrompt = raw.Prompt\\n   133→\\t\\t\\tinput.RawData[\\\"prompt\\\"] = raw.Prompt\\n   134→\\t\\t}\\n   135→\\n   136→\\tcase agent.HookPreToolUse, agent.HookPostToolUse:\\n   137→\\t\\tvar raw toolHookInputRaw\\n   138→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   139→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse tool hook input: %w\\\", err)\\n   140→\\t\\t}\\n   141→\\t\\tinput.SessionID = raw.SessionID\\n   142→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   143→\\t\\tinput.ToolName = raw.ToolName\\n   144→\\t\\tinput.ToolInput = raw.ToolInput\\n   145→\\t\\tif hookType == agent.HookPostToolUse {\\n   146→\\t\\t\\tinput.ToolResponse = raw.ToolResponse\\n   147→\\t\\t}\\n   148→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   149→\\t\\tinput.RawData[\\\"hook_event_name\\\"] = raw.HookEventName\\n   150→\\t}\\n   151→\\n   152→\\treturn input, nil\\n   153→}\\n   154→\\n   155→// GetSessionID extracts the session ID from hook input.\\n   156→func (g *GeminiCLIAgent) GetSessionID(input *agent.HookInput) string {\\n   157→\\treturn input.SessionID\\n   158→}\\n   159→\\n   160→// ProtectedDirs returns directories that Gemini uses for config/state.\\n   161→func (g *GeminiCLIAgent) ProtectedDirs() []string { return []string{\\\".gemini\\\"} }\\n   162→\\n   163→// ResolveSessionFile returns the path to a Gemini session file.\\n   164→// Gemini names files as session-<date>-<shortid>.json where shortid is the first 8 chars\\n   165→// of the session UUID. This searches for an existing file matching the pattern, falling\\n   166→// back to constructing a filename matching Gemini's convention if no match is found.\\n   167→func (g *GeminiCLIAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   168→\\t// Try to find existing file matching Gemini's naming convention:\\n   169→\\t// session-*-<first8chars>.json\\n   170→\\tshortID := agentSessionID\\n   171→\\tif len(shortID) > 8 {\\n   172→\\t\\tshortID = shortID[:8]\\n   173→\\t}\\n   174→\\n   175→\\tpattern := filepath.Join(sessionDir, \\\"session-*-\\\"+shortID+\\\".json\\\")\\n   176→\\tmatches, err := filepath.Glob(pattern)\\n   177→\\tif err == nil && len(matches) > 0 {\\n   178→\\t\\t// Return the most recent match (last alphabetically, since date is in the name)\\n   179→\\t\\treturn matches[len(matches)-1]\\n   180→\\t}\\n   181→\\n   182→\\t// Fallback: construct filename matching Gemini's convention: session-<timestamp>-<id[:8]>.json\\n   183→\\ttimestamp := time.Now().UTC().Format(\\\"2006-01-02T15-04\\\")\\n   184→\\treturn filepath.Join(sessionDir, \\\"session-\\\"+timestamp+\\\"-\\\"+shortID+\\\".json\\\")\\n   185→}\\n   186→\\n   187→// GetSessionDir returns the directory where Gemini stores session transcripts.\\n   188→// Gemini stores sessions in ~/.gemini/tmp/<project-hash>/chats/\\n   189→func (g *GeminiCLIAgent) GetSessionDir(repoPath string) (string, error) {\\n   190→\\t// Check for test environment override\\n   191→\\tif override := os.Getenv(\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR\\\"); override != \\\"\\\" {\\n   192→\\t\\treturn override, nil\\n   193→\\t}\\n   194→\\n   195→\\thomeDir, err := os.UserHomeDir()\\n   196→\\tif err != nil {\\n   197→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   198→\\t}\\n   199→\\n   200→\\t// Gemini uses a SHA256 hash of the project path for the directory name\\n   201→\\tprojectDir := GetProjectHash(repoPath)\\n   202→\\treturn filepath.Join(homeDir, \\\".gemini\\\", \\\"tmp\\\", projectDir, \\\"chats\\\"), nil\\n   203→}\\n   204→\\n   205→// ReadSession reads a session from Gemini's storage (JSON transcript file).\\n   206→// The session data is stored in NativeData as raw JSON bytes.\\n   207→func (g *GeminiCLIAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   208→\\tif input.SessionRef == \\\"\\\" {\\n   209→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   210→\\t}\\n   211→\\n   212→\\t// Read the raw JSON file\\n   213→\\tdata, err := os.ReadFile(input.SessionRef)\\n   214→\\tif err != nil {\\n   215→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   216→\\t}\\n   217→\\n   218→\\t// Parse to extract computed fields\\n   219→\\tmodifiedFiles, err := ExtractModifiedFiles(data)\\n   220→\\tif err != nil {\\n   221→\\t\\t// Non-fatal: we can still return the session without modified files\\n   222→\\t\\tmodifiedFiles = nil\\n   223→\\t}\\n   224→\\n   225→\\treturn &agent.AgentSession{\\n   226→\\t\\tSessionID:     input.SessionID,\\n   227→\\t\\tAgentName:     g.Name(),\\n   228→\\t\\tSessionRef:    input.SessionRef,\\n   229→\\t\\tStartTime:     time.Now(),\\n   230→\\t\\tNativeData:    data,\\n   231→\\t\\tModifiedFiles: modifiedFiles,\\n   232→\\t}, nil\\n   233→}\\n   234→\\n   235→// WriteSession writes a session to Gemini's storage (JSON transcript file).\\n   236→// Uses the NativeData field which contains raw JSON bytes.\\n   237→func (g *GeminiCLIAgent) WriteSession(session *agent.AgentSession) error {\\n   238→\\tif session == nil {\\n   239→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   240→\\t}\\n   241→\\n   242→\\t// Verify this session belongs to Gemini CLI\\n   243→\\tif session.AgentName != \\\"\\\" && session.AgentName != g.Name() {\\n   244→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, g.Name())\\n   245→\\t}\\n   246→\\n   247→\\tif session.SessionRef == \\\"\\\" {\\n   248→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   249→\\t}\\n   250→\\n   251→\\tif len(session.NativeData) == 0 {\\n   252→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   253→\\t}\\n   254→\\n   255→\\t// Write the raw JSON data\\n   256→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   257→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   258→\\t}\\n   259→\\n   260→\\treturn nil\\n   261→}\\n   262→\\n   263→// FormatResumeCommand returns the command to resume a Gemini CLI session.\\n   264→func (g *GeminiCLIAgent) FormatResumeCommand(sessionID string) string {\\n   265→\\treturn \\\"gemini --resume \\\" + sessionID\\n   266→}\\n   267→\\n   268→// GetProjectHash generates a unique hash for a project based on its root path.\\n   269→// This matches Gemini CLI's getProjectHash() which uses SHA256 of the project root.\\n   270→func GetProjectHash(projectRoot string) string {\\n   271→\\thash := sha256.Sum256([]byte(projectRoot))\\n   272→\\treturn hex.EncodeToString(hash[:])\\n   273→}\\n   274→\\n   275→// TranscriptAnalyzer interface implementation\\n   276→\\n   277→// GetTranscriptPosition returns the current message count of a Gemini transcript.\\n   278→// Gemini uses JSON format with a messages array, so position is the message count.\\n   279→// Returns 0 if the file doesn't exist or is empty.\\n   280→func (g *GeminiCLIAgent) GetTranscriptPosition(path string) (int, error) {\\n   281→\\tif path == \\\"\\\" {\\n   282→\\t\\treturn 0, nil\\n   283→\\t}\\n   284→\\n   285→\\tdata, err := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   286→\\tif err != nil {\\n   287→\\t\\tif os.IsNotExist(err) {\\n   288→\\t\\t\\treturn 0, nil\\n   289→\\t\\t}\\n   290→\\t\\