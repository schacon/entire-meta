lready present in codebase\\n   374→\\t}\\n   375→\\tfmt.Println(string(data))\\n   376→\\treturn nil\\n   377→}\\n   378→\\n   379→func runRewindToWithOptions(commitID string, logsOnly bool, reset bool) error {\\n   380→\\treturn runRewindToInternal(commitID, logsOnly, reset)\\n   381→}\\n   382→\\n   383→func runRewindToInternal(commitID string, logsOnly bool, reset bool) error {\\n   384→\\tstart := GetStrategy()\\n   385→\\n   386→\\t// Check for uncommitted changes (skip for reset which handles this itself)\\n   387→\\tif !reset {\\n   388→\\t\\tcanRewind, changeMsg, err := start.CanRewind()\\n   389→\\t\\tif err != nil {\\n   390→\\t\\t\\treturn fmt.Errorf(\\\"failed to check for uncommitted changes: %w\\\", err)\\n   391→\\t\\t}\\n   392→\\t\\tif !canRewind {\\n   393→\\t\\t\\treturn fmt.Errorf(\\\"%s\\\", changeMsg)\\n   394→\\t\\t}\\n   395→\\t}\\n   396→\\n   397→\\t// Get rewind points\\n   398→\\tpoints, err := start.GetRewindPoints(20)\\n   399→\\tif err != nil {\\n   400→\\t\\treturn fmt.Errorf(\\\"failed to find rewind points: %w\\\", err)\\n   401→\\t}\\n   402→\\n   403→\\t// Find the matching point (support both full and short commit IDs)\\n   404→\\tvar selectedPoint *strategy.RewindPoint\\n   405→\\tfor _, p := range points {\\n   406→\\t\\tif p.ID == commitID || (len(commitID) >= 7 && len(p.ID) >= 7 && strings.HasPrefix(p.ID, commitID)) {\\n   407→\\t\\t\\tpointCopy := p\\n   408→\\t\\t\\tselectedPoint = &pointCopy\\n   409→\\t\\t\\tbreak\\n   410→\\t\\t}\\n   411→\\t}\\n   412→\\n   413→\\tif selectedPoint == nil {\\n   414→\\t\\treturn fmt.Errorf(\\\"rewind point not found: %s\\\", commitID)\\n   415→\\t}\\n   416→\\n   417→\\t// Handle reset mode (for logs-only points)\\n   418→\\tif reset {\\n   419→\\t\\treturn handleLogsOnlyResetNonInteractive(start, *selectedPoint)\\n   420→\\t}\\n   421→\\n   422→\\t// Handle logs-only restoration:\\n   423→\\t// 1. For logs-only points, always use logs-only restoration\\n   424→\\t// 2. If --logs-only flag is set, use logs-only restoration even for checkpoint points\\n   425→\\tif selectedPoint.IsLogsOnly || logsOnly {\\n   426→\\t\\treturn handleLogsOnlyRewindNonInteractive(start, *selectedPoint)\\n   427→\\t}\\n   428→\\n   429→\\t// Preview rewind to show warnings about files that will be deleted\\n   430→\\tpreview, previewErr := start.PreviewRewind(*selectedPoint)\\n   431→\\tif previewErr == nil && preview != nil && len(preview.FilesToDelete) > 0 {\\n   432→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nWarning: The following untracked files will be DELETED:\\\\n\\\")\\n   433→\\t\\tfor _, f := range preview.FilesToDelete {\\n   434→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  - %s\\\\n\\\", f)\\n   435→\\t\\t}\\n   436→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\n\\\")\\n   437→\\t}\\n   438→\\n   439→\\t// Resolve agent once for use throughout\\n   440→\\tagent, err := getAgent(selectedPoint.Agent)\\n   441→\\tif err != nil {\\n   442→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   443→\\t}\\n   444→\\n   445→\\t// Initialize logging context with agent from checkpoint\\n   446→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   447→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   448→\\n   449→\\tlogging.Debug(ctx, \\\"rewind started\\\",\\n   450→\\t\\tslog.String(\\\"checkpoint_id\\\", selectedPoint.ID),\\n   451→\\t\\tslog.String(\\\"session_id\\\", selectedPoint.SessionID),\\n   452→\\t\\tslog.Bool(\\\"is_task_checkpoint\\\", selectedPoint.IsTaskCheckpoint),\\n   453→\\t)\\n   454→\\n   455→\\t// Perform the rewind\\n   456→\\tif err := start.Rewind(*selectedPoint); err != nil {\\n   457→\\t\\tlogging.Error(ctx, \\\"rewind failed\\\",\\n   458→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", selectedPoint.ID),\\n   459→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   460→\\t\\t)\\n   461→\\t\\treturn err //nolint:wrapcheck // already present in codebase\\n   462→\\t}\\n   463→\\n   464→\\tlogging.Debug(ctx, \\\"rewind completed\\\",\\n   465→\\t\\tslog.String(\\\"checkpoint_id\\\", selectedPoint.ID),\\n   466→\\t)\\n   467→\\n   468→\\t// Handle transcript restoration\\n   469→\\tvar sessionID string\\n   470→\\tvar transcriptFile string\\n   471→\\n   472→\\tif selectedPoint.IsTaskCheckpoint {\\n   473→\\t\\tcheckpoint, err := start.GetTaskCheckpoint(*selectedPoint)\\n   474→\\t\\tif err != nil {\\n   475→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to read task checkpoint: %v\\\\n\\\", err)\\n   476→\\t\\t\\treturn nil\\n   477→\\t\\t}\\n   478→\\n   479→\\t\\tsessionID = checkpoint.SessionID\\n   480→\\n   481→\\t\\tif checkpoint.CheckpointUUID != \\\"\\\" {\\n   482→\\t\\t\\t// Use strategy-based transcript restoration for task checkpoints\\n   483→\\t\\t\\tif err := restoreTaskCheckpointTranscript(start, *selectedPoint, sessionID, checkpoint.CheckpointUUID, agent); err != nil {\\n   484→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to restore truncated session transcript: %v\\\\n\\\", err)\\n   485→\\t\\t\\t} else {\\n   486→\\t\\t\\t\\tfmt.Printf(\\\"Rewound to task checkpoint. %s\\\\n\\\", agent.FormatResumeCommand(sessionID))\\n   487→\\t\\t\\t}\\n   488→\\t\\t\\treturn nil\\n   489→\\t\\t}\\n   490→\\t} else {\\n   491→\\t\\t// Prefer SessionID from trailer over path-based extraction\\n   492→\\t\\tsessionID = selectedPoint.SessionID\\n   493→\\t\\tif sessionID == \\\"\\\" {\\n   494→\\t\\t\\tsessionID = filepath.Base(selectedPoint.MetadataDir)\\n   495→\\t\\t}\\n   496→\\t\\ttranscriptFile = filepath.Join(selectedPoint.MetadataDir, paths.TranscriptFileNameLegacy)\\n   497→\\t}\\n   498→\\n   499→\\t// Try to restore transcript using the appropriate method:\\n   500→\\t// 1. Checkpoint storage (committed checkpoints with valid checkpoint ID)\\n   501→\\t// 2. Shadow branch (uncommitted checkpoints with commit hash)\\n   502→\\t// 3. Local file (active sessions)\\n   503→\\tvar restored bool\\n   504→\\tif !selectedPoint.CheckpointID.IsEmpty() {\\n   505→\\t\\t// Try 