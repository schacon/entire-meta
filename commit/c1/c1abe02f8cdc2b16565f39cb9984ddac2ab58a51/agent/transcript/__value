 0 && c.removed > 0:\\n   935→\\t\\t\\tstats = fmt.Sprintf(\\\"+%d/-%d\\\", c.added, c.removed)\\n   936→\\t\\tcase c.added > 0:\\n   937→\\t\\t\\tstats = fmt.Sprintf(\\\"+%d\\\", c.added)\\n   938→\\t\\tcase c.removed > 0:\\n   939→\\t\\t\\tstats = fmt.Sprintf(\\\"-%d\\\", c.removed)\\n   940→\\t\\t}\\n   941→\\n   942→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  %-10s %s\\\", c.status+\\\":\\\", c.filename))\\n   943→\\t\\tif stats != \\\"\\\" {\\n   944→\\t\\t\\tmsg.WriteString(fmt.Sprintf(\\\" (%s)\\\", stats))\\n   945→\\t\\t}\\n   946→\\t\\tmsg.WriteString(\\\"\\\\n\\\")\\n   947→\\t}\\n   948→\\n   949→\\tif totalAdded > 0 || totalRemoved > 0 {\\n   950→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"\\\\nTotal: +%d/-%d lines\\\\n\\\", totalAdded, totalRemoved))\\n   951→\\t}\\n   952→\\n   953→\\treturn true, msg.String(), nil\\n   954→}\\n   955→\\n   956→// countLines counts the number of lines in content.\\n   957→func countLines(content []byte) int {\\n   958→\\tif len(content) == 0 {\\n   959→\\t\\treturn 0\\n   960→\\t}\\n   961→\\tcount := 1\\n   962→\\tfor _, b := range content {\\n   963→\\t\\tif b == '\\\\n' {\\n   964→\\t\\t\\tcount++\\n   965→\\t\\t}\\n   966→\\t}\\n   967→\\t// Don't count trailing newline as extra line\\n   968→\\tif len(content) > 0 && content[len(content)-1] == '\\\\n' {\\n   969→\\t\\tcount--\\n   970→\\t}\\n   971→\\treturn count\\n   972→}\\n   973→\\n   974→// computeDiffStats computes added and removed line counts between old and new content.\\n   975→// Uses a simple line-based diff algorithm.\\n   976→func computeDiffStats(oldContent, newContent []byte) (added, removed int) {\\n   977→\\toldLines := splitLines(oldContent)\\n   978→\\tnewLines := splitLines(newContent)\\n   979→\\n   980→\\t// Build a set of old lines with counts\\n   981→\\toldSet := make(map[string]int)\\n   982→\\tfor _, line := range oldLines {\\n   983→\\t\\toldSet[line]++\\n   984→\\t}\\n   985→\\n   986→\\t// Check which new lines are truly new\\n   987→\\tfor _, line := range newLines {\\n   988→\\t\\tif oldSet[line] > 0 {\\n   989→\\t\\t\\toldSet[line]--\\n   990→\\t\\t} else {\\n   991→\\t\\t\\tadded++\\n   992→\\t\\t}\\n   993→\\t}\\n   994→\\n   995→\\t// Remaining old lines are removed\\n   996→\\tfor _, count := range oldSet {\\n   997→\\t\\tremoved += count\\n   998→\\t}\\n   999→\\n  1000→\\treturn added, removed\\n  1001→}\\n  1002→\\n  1003→// splitLines splits content into lines, preserving empty lines.\\n  1004→func splitLines(content []byte) []string {\\n  1005→\\tif len(content) == 0 {\\n  1006→\\t\\treturn nil\\n  1007→\\t}\\n  1008→\\ts := string(content)\\n  1009→\\t// Remove trailing newline to avoid empty last element\\n  1010→\\ts = strings.TrimSuffix(s, \\\"\\\\n\\\")\\n  1011→\\treturn strings.Split(s, \\\"\\\\n\\\")\\n  1012→}\\n  1013→\\n  1014→// fileExists checks if a file exists at the given path.\\n  1015→func fileExists(path string) bool {\\n  1016→\\t_, err := os.Stat(path)\\n  1017→\\treturn err == nil\\n  1018→}\\n  1019→\\n  1020→// StageFilesContext describes what type of staging operation this is (for messages).\\n  1021→type StageFilesContext string\\n  1022→\\n  1023→const (\\n  1024→\\t// StageForSession is used when staging files for a session checkpoint.\\n  1025→\\tStageForSession StageFilesContext = \\\"session\\\"\\n  1026→\\t// StageForTask is used when staging files for a task checkpoint.\\n  1027→\\tStageForTask StageFilesContext = \\\"task\\\"\\n  1028→)\\n  1029→\\n  1030→// StageFiles stages modified, new, and deleted files to the git worktree.\\n  1031→//\\n  1032→// This function handles three categories of file changes:\\n  1033→//  1. Modified files: existing files that have been changed\\n  1034→//  2. New files: files that were created during the session\\n  1035→//  3. Deleted files: files that were removed during the session\\n  1036→//\\n  1037→// Error Handling Strategy:\\n  1038→//   - Individual file staging errors are logged to stderr but don't fail the operation\\n  1039→//   - This ensures that partial staging succeeds even if some files have issues\\n  1040→//   - If a modified file no longer exists, it's treated as a deletion\\n  1041→//\\n  1042→// The stageCtx parameter is used for user-facing messages to indicate whether\\n  1043→// this is staging for a session checkpoint or a task checkpoint.\\n  1044→func StageFiles(worktree *git.Worktree, modified, newFiles, deleted []string, stageCtx StageFilesContext) {\\n  1045→\\t// Get repo root for resolving file paths\\n  1046→\\t// This is critical because fileExists() uses os.Stat() which resolves relative to CWD,\\n  1047→\\t// but worktree.Add/Remove resolve relative to repo root. If CWD != repo root,\\n  1048→\\t// fileExists() could return false for existing files, causing worktree.Remove()\\n  1049→\\t// to incorrectly delete them.\\n  1050→\\trepoRoot := worktree.Filesystem.Root()\\n  1051→\\n  1052→\\t// Stage modified files\\n  1053→\\tfor _, file := range modified {\\n  1054→\\t\\t// Resolve path relative to repo root for existence check\\n  1055→\\t\\tabsPath := filepath.Join(repoRoot, file)\\n  1056→\\t\\tif fileExists(absPath) {\\n  1057→\\t\\t\\tif _, err := worktree.Add(file); err != nil {\\n  1058→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage %s: %v\\\\n\\\", file, err)\\n  1059→\\t\\t\\t} else {\\n  1060→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged: %s\\\\n\\\", file)\\n  1061→\\t\\t\\t}\\n  1062→\\t\\t} else {\\n  1063→\\t\\t\\t// File was deleted - stage the deletion\\n  1064→\\t\\t\\tif _, err := worktree.Remove(file); err != nil {\\n  1065→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  File not found or deleted: %s\\\\n\\\", file)\\n  1066→\\t\\t\\t}\\n  1067→\\t\\t}\\n  1068→\\t}\\n  1069→\\n  1070→\\t// Stage new files\\n  1071→\\tif len(newFiles) > 0 {\\n  1072→\\t\\tfmt.Fprintf(os.Stderr, \\\"Staging %d new files created during %s:\\\\n\\\", len(newFiles), stageCtx)\\n  1073→\\t\\tfor _, file := range newFiles {\\n  1074→\\t\\t\\tif _, err := worktree.Add(file); err != nil {\\n  1075→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage %s: %v\\\\n\\\", file, err)\\n  1076→\\t\\t\\t} else {\\n  1077→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged new file: %s\\\\n\\\", file)\\n  1078→\\t\\t\\t}\\n  1079→\\t\\t}\\n  1080→\\t}\\n  1081→\\n  1082→\\t// Stage deleted files\\n  1083→\\tfor _, file := range deleted {\\n  1084→\\t\\tif _, err := worktree.Remove(file); err != nil {\\n  1085→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage deleted file %s: %v\\\\n\\\", file, err)\\n  1086→\\t\\t} else {\\n  1087→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged deleted file: %s\\\\n\\\", file)\\n  1088→\\t\\t}\\n  1089→\\t}\\n  1090→}\\n  1091→\\n  1092→// getTaskCheckpointFromTree retrieves a task checkpoint from a commit tree.\\n  1093→// Shared implementation for shadow and linear-shadow strategies.\\n  1094→func getTaskCheckpointFromTree(point RewindPoint) (*TaskCheckpoint, error) {\\n  1095→\\tif !point.IsTaskCheckpoint {\\n  1096→\\t\\treturn nil, ErrNotTaskCheckpoint\\n  1097→\\t}\\n  1098→\\n  1099→\\trepo, err := OpenRepository()\\n  1100→\\tif err != nil {\\n  1101→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n  1102→\\t}\\n  1103→\\n  1104→\\tcommitHash := plumbing.NewHash(point.ID)\\n  1105→\\tcommit, err := repo.CommitObject(commitHash)\\n  1106→\\tif err != nil {\\n  1107→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n  1108→\\t}\\n  1109→\\n  1110→\\ttree, err := commit.Tree()\\n  1111→\\tif err != nil {\\n  1112→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n  1113→\\t}\\n  1114→\\n  1115→\\t// Read checkpoint.json from the tree\\n  1116→\\tcheckpointPath := point.MetadataDir + \\\"/checkpoint.json\\\"\\n  1117→\\tfile, err := tree.File(checkpointPath)\\n  1118→\\tif err != nil {\\n  1119→\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", checkpointPath, err)\\n  1120→\\t}\\n  1121→\\n  1122→\\tcontent, err := file.Contents()\\n  1123→\\tif err != nil {\\n  1124→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n  1125→\\t}\\n  1126→\\n  1127→\\tvar checkpoint TaskCheckpoint\\n  1128→\\tif err := json.Unmarshal([]byte(content), &checkpoint); err != nil {\\n  1129→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse checkpoint: %w\\\", err)\\n  1130→\\t}\\n  1131→\\n  1132→\\treturn &checkpoint, nil\\n  1133→}\\n  1134→\\n  1135→// getTaskTranscriptFromTree retrieves a task transcript from a commit tree.\\n  1136→// Shared implementation for shadow and linear-shadow strategies.\\n  1137→func getTaskTranscriptFromTree(point RewindPoint) ([]byte, error) {\\n  1138→\\tif !point.IsTaskCheckpoint {\\n  1139→\\t\\treturn nil, ErrNotTaskCheckpoint\\n  1140→\\t}\\n  1141→\\n  1142→\\trepo, err := OpenRepository()\\n  1143→\\tif err != nil {\\n  1144→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n  1145→\\t}\\n  1146→\\n  1147→\\tcommitHash := plumbing.NewHash(point.ID)\\n  1148→\\tcommit, err := repo.CommitObject(commitHash)\\n  1149→\\tif err != nil {\\n  1150→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n  1151→\\t}\\n  1152→\\n  1153→\\ttree, err := commit.Tree()\\n  1154→\\tif err != nil {\\n  1155→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n  1156→\\t}\\n  1157→\\n  1158→\\t// MetadataDir format: .entire/metadata/<session>/tasks/<toolUseID>\\n  1159→\\t// Session transcript is at: .entire/metadata/<session>/<TranscriptFileName>\\n  1160→\\tsessionDir := filepath.Dir(filepath.Dir(point.MetadataDir))\\n  1161→\\n  1162→\\t// Try current format first, then legacy\\n  1163→\\ttranscriptPath := sessionDir + \\\"/\\\" + paths.TranscriptFileName\\n  1164→\\tfile, err := tree.File(transcriptPath)\\n  1165→\\tif err != nil {\\n  1166→\\t\\ttranscriptPath = sessionDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n  1167→\\t\\tfile, err = tree.File(transcriptPath)\\n  1168→