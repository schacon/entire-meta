745→// Returns (canRewind, reason, error). Shared by shadow and linear-shadow strategies.\\n   746→func checkCanRewind() (bool, string, error) {\\n   747→\\trepo, err := OpenRepository()\\n   748→\\tif err != nil {\\n   749→\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   750→\\t}\\n   751→\\n   752→\\tworktree, err := repo.Worktree()\\n   753→\\tif err != nil {\\n   754→\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   755→\\t}\\n   756→\\n   757→\\tstatus, err := worktree.Status()\\n   758→\\tif err != nil {\\n   759→\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n   760→\\t}\\n   761→\\n   762→\\tif status.IsClean() {\\n   763→\\t\\treturn true, \\\"\\\", nil\\n   764→\\t}\\n   765→\\n   766→\\tvar modified, added, deleted []string\\n   767→\\tfor file, st := range status {\\n   768→\\t\\t// Skip .entire directory\\n   769→\\t\\tif paths.IsInfrastructurePath(file) {\\n   770→\\t\\t\\tcontinue\\n   771→\\t\\t}\\n   772→\\n   773→\\t\\t// Skip untracked files\\n   774→\\t\\tif st.Worktree == git.Untracked {\\n   775→\\t\\t\\tcontinue\\n   776→\\t\\t}\\n   777→\\n   778→\\t\\tswitch {\\n   779→\\t\\tcase st.Staging == git.Added || st.Worktree == git.Added:\\n   780→\\t\\t\\tadded = append(added, file)\\n   781→\\t\\tcase st.Staging == git.Deleted || st.Worktree == git.Deleted:\\n   782→\\t\\t\\tdeleted = append(deleted, file)\\n   783→\\t\\tcase st.Staging == git.Modified || st.Worktree == git.Modified:\\n   784→\\t\\t\\tmodified = append(modified, file)\\n   785→\\t\\t}\\n   786→\\t}\\n   787→\\n   788→\\tif len(modified) == 0 && len(added) == 0 && len(deleted) == 0 {\\n   789→\\t\\treturn true, \\\"\\\", nil\\n   790→\\t}\\n   791→\\n   792→\\tvar msg strings.Builder\\n   793→\\tmsg.WriteString(\\\"You have uncommitted changes:\\\\n\\\")\\n   794→\\tfor _, f := range modified {\\n   795→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  modified:   %s\\\\n\\\", f))\\n   796→\\t}\\n   797→\\tfor _, f := range added {\\n   798→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  added:      %s\\\\n\\\", f))\\n   799→\\t}\\n   800→\\tfor _, f := range deleted {\\n   801→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  deleted:    %s\\\\n\\\", f))\\n   802→\\t}\\n   803→\\tmsg.WriteString(\\\"\\\\nPlease commit or stash your changes before rewinding.\\\")\\n   804→\\n   805→\\treturn false, msg.String(), nil\\n   806→}\\n   807→\\n   808→// checkCanRewindWithWarning checks working directory and returns a warning with diff stats.\\n   809→// Unlike checkCanRewind, this always returns canRewind=true but includes a warning message\\n   810→// with +/- line stats for uncommitted changes. Used by manual-commit strategy.\\n   811→func checkCanRewindWithWarning() (bool, string, error) {\\n   812→\\trepo, err := OpenRepository()\\n   813→\\tif err != nil {\\n   814→\\t\\t// Can't open repo - still allow rewind but without stats\\n   815→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if repo can't be opened\\n   816→\\t}\\n   817→\\n   818→\\tworktree, err := repo.Worktree()\\n   819→\\tif err != nil {\\n   820→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if worktree can't be accessed\\n   821→\\t}\\n   822→\\n   823→\\tstatus, err := worktree.Status()\\n   824→\\tif err != nil {\\n   825→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if status can't be retrieved\\n   826→\\t}\\n   827→\\n   828→\\tif status.IsClean() {\\n   829→\\t\\treturn true, \\\"\\\", nil\\n   830→\\t}\\n   831→\\n   832→\\t// Get HEAD commit tree for comparison - if we can't get it, just return without stats\\n   833→\\thead, err := repo.Head()\\n   834→\\tif err != nil {\\n   835→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even without HEAD (e.g., empty repo)\\n   836→\\t}\\n   837→\\n   838→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   839→\\tif err != nil {\\n   840→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if commit lookup fails\\n   841→\\t}\\n   842→\\n   843→\\theadTree, err := headCommit.Tree()\\n   844→\\tif err != nil {\\n   845→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if tree lookup fails\\n   846→\\t}\\n   847→\\n   848→\\ttype fileChange struct {\\n   849→\\t\\tstatus   string // \\\"modified\\\", \\\"added\\\", \\\"deleted\\\"\\n   850→\\t\\tadded    int\\n   851→\\t\\tremoved  int\\n   852→\\t\\tfilename string\\n   853→\\t}\\n   854→\\n   855→\\tvar changes []fileChange\\n   856→\\t// Use repo root, not cwd - git status returns paths relative to repo root\\n   857→\\trepoRoot, err := GetWorktreePath()\\n   858→\\tif err != nil {\\n   859→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if repo root lookup fails\\n   860→\\t}\\n   861→\\n   862→\\tfor file, st := range status {\\n   863→\\t\\t// Skip .entire directory\\n   864→\\t\\tif paths.IsInfrastructurePath(file) {\\n   865→\\t\\t\\tcontinue\\n   866→\\t\\t}\\n   867→\\n   868→\\t\\t// Skip untracked files\\n   869→\\t\\tif st.Worktree == git.Untracked {\\n   870→\\t\\t\\tcontinue\\n   871→\\t\\t}\\n   872→\\n   873→\\t\\tvar change fileChange\\n   874→\\t\\tchange.filename = file\\n   875→\\n   876→\\t\\tswitch {\\n   877→\\t\\tcase st.Staging == git.Added || st.Worktree == git.Added:\\n   878→\\t\\t\\tchange.status = \\\"added\\\"\\n   879→\\t\\t\\t// New file - count all lines as added\\n   880→\\t\\t\\tabsPath := filepath.Join(repoRoot, file)\\n   881→\\t\\t\\tif content, err := os.ReadFile(absPath); err == nil { //nolint:gosec // absPath is repo root + relative path from git status\\n   882→\\t\\t\\t\\tchange.added = countLines(content)\\n   883→\\t\\t\\t}\\n   884→\\t\\tcase st.Staging == git.Deleted || st.Worktree == git.Deleted:\\n   885→\\t\\t\\tchange.status = \\\"deleted\\\"\\n   886→\\t\\t\\t// Deleted file - count lines from HEAD as removed\\n   887→\\t\\t\\tif entry, 