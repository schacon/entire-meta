 Create an initial test environment at the original location\\n    31→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n    32→\\toriginalDir := env.RepoDir\\n    33→\\n    34→\\tt.Logf(\\\"Original repo location: %s\\\", originalDir)\\n    35→\\n    36→\\t// Step 1: Agent creates a file\\n    37→\\tt.Log(\\\"Step 1: Running agent to create checkpoint\\\")\\n    38→\\tresult, err := env.RunAgent(PromptCreateHelloGo.Prompt)\\n    39→\\trequire.NoError(t, err, \\\"Agent should succeed\\\")\\n    40→\\tAssertAgentSuccess(t, result, err)\\n    41→\\n    42→\\t// Step 2: Verify file was created\\n    43→\\tt.Log(\\\"Step 2: Verifying file was created\\\")\\n    44→\\trequire.True(t, env.FileExists(\\\"hello.go\\\"), \\\"hello.go should exist\\\")\\n    45→\\n    46→\\t// Step 3: User commits with hooks to create checkpoint\\n    47→\\tt.Log(\\\"Step 3: Committing with hooks to create checkpoint\\\")\\n    48→\\tenv.GitCommitWithShadowHooks(\\\"Add hello world program\\\", \\\"hello.go\\\")\\n    49→\\n    50→\\t// Step 4: Verify checkpoint exists\\n    51→\\tt.Log(\\\"Step 4: Verifying checkpoint was created\\\")\\n    52→\\tcheckpointID, err := env.GetLatestCheckpointIDFromHistory()\\n    53→\\trequire.NoError(t, err, \\\"Should find checkpoint in commit history\\\")\\n    54→\\trequire.NotEmpty(t, checkpointID, \\\"Commit should have Entire-Checkpoint trailer\\\")\\n    55→\\tt.Logf(\\\"Checkpoint ID: %s\\\", checkpointID)\\n    56→\\n    57→\\t// Compute the expected session directories for original and new locations.\\n    58→\\t// Claude stores transcripts at ~/.claude/projects/<sanitized-repo-path>/\\n    59→\\thome, err := os.UserHomeDir()\\n    60→\\trequire.NoError(t, err)\\n    61→\\n    62→\\toriginalProjectDir := claudecode.SanitizePathForClaude(originalDir)\\n    63→\\toriginalSessionDir := filepath.Join(home, \\\".claude\\\", \\\"projects\\\", originalProjectDir)\\n    64→\\n    65→\\t// Step 5: Move the repository to a new location\\n    66→\\tt.Log(\\\"Step 5: Moving repository to new location\\\")\\n    67→\\ttempBase := t.TempDir()\\n    68→\\t// Resolve symlinks (macOS: /var -> /private/var) to match what the CLI sees\\n    69→\\tif resolved, err := filepath.EvalSymlinks(tempBase); err == nil {\\n    70→\\t\\ttempBase = resolved\\n    71→\\t}\\n    72→\\tnewDir := filepath.Join(tempBase, \\\"relocated\\\", \\\"new-location\\\", \\\"test-repo\\\")\\n    73→\\trequire.NoError(t, os.MkdirAll(filepath.Dir(newDir), 0o755))\\n    74→\\trequire.NoError(t, os.Rename(originalDir, newDir), \\\"should be able to move repo\\\")\\n    75→\\n    76→\\t_, err = os.Stat(originalDir)\\n    77→\\trequire.True(t, os.IsNotExist(err), \\\"original location should not exist after move\\\")\\n    78→\\tt.Logf(\\\"Moved repo to: %s\\\", newDir)\\n    79→\\n    80→\\tnewProjectDir := claudecode.SanitizePathForClaude(newDir)\\n    81→\\tnewSessionDir := filepath.Join(home, \\\".claude\\\", \\\"projects\\\", newProjectDir)\\n    82→\\n    83→\\t// Sanity check: the two project dirs must be different\\n    84→\\trequire.NotEqual(t, originalProjectDir, newProjectDir,\\n    85→\\t\\t\\\"sanitized project dirs should differ for different repo paths\\\")\\n    86→\\tt.Logf(\\\"Original session dir: %s\\\", originalSessionDir)\\n    87→\\tt.Logf(\\\"New session dir:      %s\\\", newSessionDir)\\n    88→\\n    89→\\t// Clean up new session dir if it somehow already exists (idempotent test)\\n    90→\\t_ = os.RemoveAll(newSessionDir)\\n    91→\\n    92→\\t// Step 6: Create new environment pointing at the moved repo\\n    93→\\tt.Log(\\\"Step 6: Opening repo at new location\\\")\\n    94→\\tnewEnv := &TestEnv{\\n    95→\\t\\tT:       t,\\n    96→\\t\\tRepoDir: newDir,\\n    97→\\t\\tAgent:   env.Agent,\\n    98→\\t}\\n    99→\\n   100→\\t// Step 7: Run entire resume in the new location\\n   101→\\t// resume requires a branch name argument: entire resume <branch> [--force]\\n   102→\\tt.Log(\\\"Step 7: Running 'entire resume feature/e2e-test --force' in new location\\\")\\n   103→\\toutput := newEnv.RunCLI(\\\"resume\\\", \\\"feature/e2e-test\\\", \\\"--force\\\")\\n   104→\\tt.Logf(\\\"Resume output:\\\\n%s\\\", output)\\n   105→\\n   106→\\t// Step 8: Verify the transcript was written to the NEW session directory\\n   107→\\tt.Log(\\\"Step 8: Verifying session was created at new location\\\")\\n   108→\\n   109→\\t// The resume output should reference the new session dir, not the old one\\n   110→\\tassert.Contains(t, output, newProjectDir,\\n   111→\\t\\t\\\"resume output should reference the new project directory\\\")\\n   112→\\tassert.NotContains(t, output, originalProjectDir,\\n   113→\\t\\t\\\"resume output should NOT reference the old project directory\\\")\\n   114→\\n   115→\\t// Verify the new session dir was actually created with files\\n   116→\\tnewDirEntries, err := os.ReadDir(newSessionDir)\\n   117→\\trequire.NoError(t, err, \\\"new session directory should exist after resume\\\")\\n   118→\\trequire.NotEmpty(t, newDirEntries, \\\"new session directory should contain files\\\")\\n   119→\\tt.Logf(\\\"New session dir contains %d entries\\\", len(newDirEntries))\\n   120→\\n   121→\\t// Verify at least one JSONL transcript file exists\\n   122→\\thasTranscript := false\\n   123→\\tfor _, entry := range newDirEntries {\\n   124→\\t\\tif strings.HasSuffix(entry.Name(), \\\".jsonl\\\") {\\n   125→\\t\\t\\tinfo, statErr := entry.Info()\\n   126→\\t\\t\\tif statErr == nil && info.Size() > 0 {\\n   127→\\t\\t\\t\\thasTranscript = true\\n   128→\\t\\t\\t\\tt.Logf(\\\"Found transcript: %s (%d bytes)\\\", entry.Name(), info.Size())\\n   129→\\t\\t\\t}\\n   130→\\t\\t}\\n   131→\\t}\\n   132→\\tassert.True(t, hasTranscript, \\\"new session directory should contain a non-empty JSONL transcript\\\")\\n   133→\\n   134→\\t// Step 9: Verify the OLD session directory was NOT created by resume\\n   135→\\t// (It may exist from Step 1's agent run, so check that resume didn't write to it\\n   136→\\t// b