→\\tHookNameUserPromptSubmit = \\\"user-prompt-submit\\\"\\n    27→\\tHookNamePreToolUse       = \\\"pre-tool-use\\\"\\n    28→\\tHookNamePostToolUse      = \\\"post-tool-use\\\"\\n    29→\\tHookNameStop             = \\\"stop\\\"\\n    30→)\\n    31→\\n    32→// sessionIDFile is the filename for caching the generated session ID.\\n    33→// Stored in .entire/tmp/ to ensure a stable ID across all hooks in one session.\\n    34→const sessionIDFile = \\\"kiro-active-session\\\"\\n    35→\\n    36→// HookNames returns the hook verbs Kiro supports.\\n    37→// These become subcommands: entire hooks kiro <verb>\\n    38→func (k *KiroAgent) HookNames() []string {\\n    39→\\treturn []string{\\n    40→\\t\\tHookNameAgentSpawn,\\n    41→\\t\\tHookNameUserPromptSubmit,\\n    42→\\t\\tHookNamePreToolUse,\\n    43→\\t\\tHookNamePostToolUse,\\n    44→\\t\\tHookNameStop,\\n    45→\\t}\\n    46→}\\n    47→\\n    48→// ParseHookEvent translates a Kiro hook into a normalized lifecycle Event.\\n    49→// Returns nil for hooks with no lifecycle significance (preToolUse, postToolUse).\\n    50→func (k *KiroAgent) ParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*agent.Event, error) {\\n    51→\\tswitch hookName {\\n    52→\\tcase HookNameAgentSpawn:\\n    53→\\t\\treturn k.parseAgentSpawn(ctx, stdin)\\n    54→\\tcase HookNameUserPromptSubmit:\\n    55→\\t\\treturn k.parseUserPromptSubmit(ctx, stdin)\\n    56→\\tcase HookNameStop:\\n    57→\\t\\treturn k.parseStop(ctx, stdin)\\n    58→\\tcase HookNamePreToolUse, HookNamePostToolUse:\\n    59→\\t\\t// Pass-through hooks with no lifecycle significance\\n    60→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    61→\\tdefault:\\n    62→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    63→\\t}\\n    64→}\\n    65→\\n    66→// readHookInputOrEmpty wraps ReadAndParseHookInput, returning a zero-value\\n    67→// hookInputRaw on empty stdin instead of erroring