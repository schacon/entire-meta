\\t}\\n    80→\\n    81→\\t// 2. Pattern-based detection via gitleaks.\\n    82→\\tif d := getDetector(); d != nil {\\n    83→\\t\\tfor _, f := range d.DetectString(s) {\\n    84→\\t\\t\\tif f.Secret == \\\"\\\" {\\n    85→\\t\\t\\t\\tcontinue\\n    86→\\t\\t\\t}\\n    87→\\t\\t\\tsearchFrom := 0\\n    88→\\t\\t\\tfor {\\n    89→\\t\\t\\t\\tidx := strings.Index(s[searchFrom:], f.Secret)\\n    90→\\t\\t\\t\\tif idx < 0 {\\n    91→\\t\\t\\t\\t\\tbreak\\n    92→\\t\\t\\t\\t}\\n    93→\\t\\t\\t\\tabsIdx := searchFrom + idx\\n    94→\\t\\t\\t\\tregions = append(regions, region{absIdx, absIdx + len(f.Secret)})\\n    95→\\t\\t\\t\\tsearchFrom = absIdx + len(f.Secret)\\n    96→\\t\\t\\t}\\n    97→\\t\\t}\\n    98→\\t}\\n    99→\\n   100→\\tif len(regions) == 0 {\\n   101→\\t\\treturn s\\n   102→\\t}\\n   103→\\n   104→\\t// Merge overlapping regions and build result.\\n   105→\\tsort.Slice(regions, func(i, j int) bool {\\n   106→\\t\\treturn regions[i].start < regions[j].start\\n   107→\\t})\\n   108→\\tmerged := []region{regions[0]}\\n   109→\\tfor _, r := range regions[1:] {\\n   110→\\t\\tlast := &merged[len(merged)-1]\\n   111→\\t\\tif r.start <= last.end {\\n   112→\\t\\t\\tif r.end > last.end {\\n   113→\\t\\t\\t\\tlast.end = r.end\\n   114→\\t\\t\\t}\\n   115→\\t\\t} else {\\n   116→\\t\\t\\tmerged = append(merged, r)\\n   117→\\t\\t}\\n   118→\\t}\\n   119→\\n   120→\\tvar b strings.Builder\\n   121→\\tprev := 0\\n   122→\\tfor _, r := range merged {\\n   123→\\t\\tb.WriteString(s[prev:r.start])\\n   124→\\t\\tb.WriteString(RedactedPlaceholder)\\n   125→\\t\\tprev = r.end\\n   126→\\t}\\n   127→\\tb.WriteString(s[prev:])\\n   128→\\treturn b.String()\\n   129→}\\n   130→\\n   131→// Bytes is a convenience wrapper around String for []byte content.\\n   132→func Bytes(b []byte) []byte {\\n   133→\\ts := string(b)\\n   134→\\tredacted := String(s)\\n   135→\\tif redacted == s {\\n   136→\\t\\treturn b\\n   137→\\t}\\n   138→\\treturn []byte(redacted)\\n   139→}\\n   14