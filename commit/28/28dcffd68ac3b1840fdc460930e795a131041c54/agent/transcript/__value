.SessionID,\\n    49→\\t\\t\\tTimestamp: time.Now(),\\n    50→\\t\\t}, nil\\n    51→\\n    52→\\tcase HookNameTurnStart:\\n    53→\\t\\traw, err := agent.ReadAndParseHookInput[turnStartRaw](stdin)\\n    54→\\t\\tif err != nil {\\n    55→\\t\\t\\treturn nil, err\\n    56→\\t\\t}\\n    57→\\t\\ttranscriptPath, err := sessionTranscriptPath(ctx, raw.SessionID)\\n    58→\\t\\tif err != nil {\\n    59→\\t\\t\\treturn nil, err\\n    60→\\t\\t}\\n    61→\\t\\treturn &agent.Event{\\n    62→\\t\\t\\tType:       agent.TurnStart,\\n    63→\\t\\t\\tSessionID:  raw.SessionID,\\n    64→\\t\\t\\tSessionRef: transcriptPath,\\n    65→\\t\\t\\tPrompt:     raw.Prompt,\\n    66→\\t\\t\\tModel:      raw.Model,\\n    67→\\t\\t\\tTimestamp:  time.Now(),\\n    68→\\t\\t}, nil\\n    69→\\n    70→\\tcase HookNameTurnEnd:\\n    71→\\t\\traw, err := agent.ReadAndParseHookInput[turnEndRaw](stdin)\\n    72→\\t\\tif err != nil {\\n    73→\\t\\t\\treturn nil, err\\n    74→\\t\\t}\\n    75→\\t\\t// Export is deferred to PrepareTranscript; we just compute the path here.\\n    76→\\t\\ttranscriptPath, err := sessionTranscriptPath(ctx, raw.SessionID)\\n    77→\\t\\tif err != nil {\\n    78→\\t\\t\\treturn nil, err\\n    79→\\t\\t}\\n    80→\\t\\treturn &agent.Event{\\n    81→\\t\\t\\tType:       agent.TurnEnd,\\n    82→\\t\\t\\tSessionID:  raw.SessionID,\\n    83→\\t\\t\\tSessionRef: transcriptPath,\\n    84→\\t\\t\\tModel:      raw.Model,\\n    85→\\t\\t\\tTimestamp:  time.Now(),\\n    86→\\t\\t}, nil\\n    87→\\n    88→\\tcase HookNameCompaction:\\n    89→\\t\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n    90→\\t\\tif err != nil {\\n    91→\\t\\t\\treturn nil, err\\n    92→\\t\\t}\\n    93→\\t\\treturn &agent.Event{\\n    94→\\t\\t\\tType:      agent.Compaction,\\n    95→\\t\\t\\tSessionID: raw.SessionID,\\n    96→\\t\\t\\tTimestamp: time.Now(),\\n    97→\\t\\t}, nil\\n    98→\\n    99→\\tcase HookNameSessionEnd:\\n   100→\\t\\traw, err := agent.ReadAndParseHookInput[sessionInf