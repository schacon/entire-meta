56→\\n   857→// listCheckpointsInDir reads checkpoint IDs from the metadata branch tree.\\n   858→// This intentionally uses a separate implementation (git ls-tree) rather than\\n   859→// the production ListCheckpoints() to avoid testing the code with itself.\\n   860→// The sharded directory structure is documented in CLAUDE.md.\\n   861→func listCheckpointsInDir(t *testing.T, repoDir string) []string {\\n   862→\\tt.Helper()\\n   863→\\n   864→\\tcmd := exec.CommandContext(t.Context(), \\\"git\\\", \\\"ls-tree\\\", \\\"-r\\\", \\\"--name-only\\\", paths.MetadataBranchName)\\n   865→\\tcmd.Dir = repoDir\\n   866→\\tcmd.Env = testutil.GitIsolatedEnv()\\n   867→\\toutput, err := cmd.Output()\\n   868→\\tif err != nil {\\n   869→\\t\\tt.Logf(\\\"ls-tree failed (branch may not exist): %v\\\", err)\\n   870→\\t\\treturn nil\\n   871→\\t}\\n   872→\\n   873→\\t// Parse the sharded structure: <prefix>/<suffix>/metadata.json\\n   874→\\tseen := make(map[string]bool)\\n   875→\\tvar ids []string\\n   876→\\tfor _, line := range strings.Split(strings.TrimSpace(string(output)), \\\"\\\\n\\\") {\\n   877→\\t\\tline = strings.TrimSpace(line)\\n   878→\\t\\tif line == \\\"\\\" {\\n   879→\\t\\t\\tcontinue\\n   880→\\t\\t}\\n   881→\\t\\tparts := strings.Split(line, \\\"/\\\")\\n   882→\\t\\t// Match <prefix>/<suffix>/metadata.json (top-level, not session-level)\\n   883→\\t\\tif len(parts) == 3 && parts[2] == paths.MetadataFileName {\\n   884→\\t\\t\\tcpID := parts[0] + parts[1]\\n   885→\\t\\t\\tif !seen[cpID] {\\n   886→\\t\\t\\t\\tseen[cpID] = true\\n   887→\\t\\t\\t\\tids = append(ids, cpID)\\n   888→\\t\\t\\t}\\n   889→\\t\\t}\\n   890→\\t}\\n   891→\\n   892→\\treturn ids\\n   893→}\\n   894→\"}]},\"uuid\":\"087c8c39-57a1-4269-a3c0-441d560ee85e\",\"timestamp\":\"2026-03-16T11:47:23.254Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli_experiments/cmd/entire/cli/integration_test/remote_operations_test.go\",\"content\":\"//g