le\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01Gjmt9X7K8K8vPF1hJU4nAz\",\"type\":\"tool_result\",\"content\":\"     1→//go:build integration\\n     2→\\n     3→package integration\\n     4→\\n     5→import (\\n     6→\\t\\\"os/exec\\\"\\n     7→\\t\\\"strings\\\"\\n     8→\\t\\\"testing\\\"\\n     9→\\t\\\"time\\\"\\n    10→\\n    11→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/testutil\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/trail\\\"\\n    14→\\n    15→\\t\\\"github.com/go-git/go-git/v6\\\"\\n    16→\\t\\\"github.com/go-git/go-git/v6/plumbing\\\"\\n    17→\\t\\\"github.com/go-git/go-git/v6/plumbing/filemode\\\"\\n    18→\\t\\\"github.com/go-git/go-git/v6/plumbing/object\\\"\\n    19→)\\n    20→\\n    21→// =============================================================================\\n    22→// P0 -- PrePush Basic Flow\\n    23→// =============================================================================\\n    24→\\n    25→// TestPrePush_PushesCheckpointBranchToOrigin verifies that PrePush pushes\\n    26→// the entire/checkpoints/v1 branch to a bare remote after condensation.\\n    27→func TestPrePush_PushesCheckpointBranchToOrigin(t *testing.T) {\\n    28→\\tt.Parallel()\\n    29→\\tenv := NewFeatureBranchEnv(t)\\n    30→\\n    31→\\t// Set up bare remote\\n    32→\\tbareDir := env.SetupBareRemote()\\n    33→\\n    34→\\t// Create a session, make changes, checkpoint, and commit (triggers condensation)\\n    35→\\tsession := env.NewSession()\\n    36→\\ttranscriptPath := session.CreateTranscript(\\\"Add auth module\\\", []FileChange{\\n    37→\\t\\t{Path: \\\"auth.go\\\", Content: \\\"package auth\\\"},\\n    38→\\t})\\n    39→\\n    40→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Add auth module\\\", transcriptPath); err != nil {\\n    41→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n    42→\\t}\\n    43→\\n    44→\\tenv.WriteFile(\\\"auth.go\\\", \\\"package auth\\\")\\n    45→\\tenv.GitAdd(\\\"auth.go\\\")\\n    46→\\n    47→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n    48→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n    49→\\t}\\n    50→\\n    51→\\t// Commit with hooks (triggers prepare-commit-msg + post-commit = condensation)\\n    52→\\tenv.GitCommitWithShadowHooks(\\\"Add auth module\\\", \\\"auth.go\\\")\\n    53→\\n    54→\\t// Verify condensation happened locally\\n    55→\\tif !env.BranchExists(paths.MetadataBranchName) {\\n    56→\\t\\tt.Fatal(\\\"entire/checkpoints/v1 should exist locally after condensation\\\")\\n    57→\\t}\\n    58→\\n    59→\\t// Run PrePush (simulates what happens during git push)\\n    60→\\tenv.RunPrePush(\\\"origin\\\")\\n    61→\\n    62→\\t// Verify the branch arrived on the remote\\n    63→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n    64→\\t\\tt.Error(\\\"entire/checkpoints/v1 should exist on bare remote after PrePush\\\")\\n    65→\\t}\\n    66→\\n    67→\\t// Verify checkpoint metadata is in the remote tree\\n    68→\\tcheckpointID := env.GetLatestCheckpointID()\\n    69→\\tif checkpointID == \\\"\\\" {\\n    70→\\t\\tt.Fatal(\\\"should have a checkpoint ID after condensation\\\")\\n    71→\\t}\\n    72→\\tsummaryPath := CheckpointSummaryPath(checkpointID)\\n    73→\\tif !fileExistsOnRemoteBranch(t, bareDir, summaryPath) {\\n    74→\\t\\tt.Errorf(\\\"checkpoint metadata should exist on remote at %s\\\", summaryPath)\\n    75→\\t}\\n    76→}\\n    77→\\n    78→// TestPrePush_PushesTrailsBranchWhenPresent verifies that PrePush pushes\\n    79→// the entire/trails/v1 branch to the bare remote when it exists locally.\\n    80→//\\n    81→// Trails are only created when a trail is explicitly started (via \\\"trail start\\\")\\n    82→// and a checkpoint is linked to it. The basic session + commit flow does not\\n    83→// always create a trails branch. This test verifies the push mechanism works\\n    84→// when the branch IS present: we manually create the branch and then assert\\n    85→// it arrives on the remote.\\n    86→func TestPrePush_PushesTrailsBranchWhenPresent(t *testing.T) {\\n    87→\\tt.Parallel()\\n    88→\\tenv := NewFeatureBranchEnv(t)\\n    89→\\n    90→\\tbareDir := env.SetupBareRemote()\\n    91→\\n    92→\\t// Create a session, checkpoint, and commit\\n    93→\\t_ = createCheckpointedCommit(t, env, \\\"Add feature\\\", \\\"feature.go\\\", \\\"package feature\\\", \\\"Add feature\\\")\\n    94→\\n    95→\\t// If the trails branch exists locally (some configurations create it), verify it pushes.\\n    96→\\t// If not, create a minimal orphan trails branch to test the push mechanism.\\n    97→\\tensureTrailsBranchExists(t, env)\\n    98→\\n    99→\\t// Run PrePush\\n   100→\\tenv.RunPrePush(\\\"origin\\\")\\n   101→\\n   102→\\t// Checkpoint branch must be on remote\\n   103→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   104→\\t\\tt.Error(\\\"entire/checkpoints/v1 should exist on remote\\\")\\n   105→\\t}\\n   106→\\n   107→\\t// Trails branch must be on remote after PrePush\\n   108→\\tif !env.BranchExistsOnRemote(bareDir, paths.TrailsBranchName) {\\n   109→\\t\\tt.Error(\\\"entire/trails/v1 should exist on remote after PrePush when present locally\\\")\\n   110→\\t}\\n   111→}\\n   112→\\n   113→// TestPrePush_NoOpWhenNoCheckpoints verifies that PrePush is a no-op\\n   114→// when no sessions or checkpoints exist.\\n   115→func TestPrePush_NoOpWhenNoCheckpoints(t *testing.T) {\\n   116→\\tt.Parallel()\\n   117→\\tenv := NewFeatureBranchEnv(t)\\n   118→\\n   119→\\tbareDir := env.SetupBareRemote()\\n   120→\\n   121→\\t// Run PrePush without any session activity\\n   122→\\tenv.RunPrePush(\\\"origin\\\")\\n   123→\\n   124→\\t// No checkpoint branches should exist on remote\\n   125→\\tif env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   126→\\t\\tt.Error(\\\"entire/checkpoints/v1 should NOT exist on remote when no checkpoints were created\\\")\\n   127→\\t}\\n   128→}\\n   129→\\n   130→// TestPrePush_IdempotentWhenAlreadyPushed verifies that pushing twice\\n   131→// with no new checkpoints is a no-op (idempotent).\\n   132→func TestPrePush_IdempotentWhenAlreadyPushed(t *testing.T) {\\n   133→\\tt.Parallel()\\n   134→\\tenv := NewFeatureBranchEnv(t)\\n   135→\\n   136→\\tbareDir := env.SetupBareRemote()\\n   137→\\n   138→\\t// Create session, commit, push\\n   139→\\tsession := env.NewSession()\\n   140→\\ttranscriptPath := session.CreateTranscript(\\\"Initial work\\\", []FileChange{\\n   141→\\t\\t{Path: \\\"main.go\\\", Content: \\\"package main\\\"},\\n   142→\\t})\\n   143→\\n   144→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Initial work\\\", transcriptPath); err != nil {\\n   145→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   146→\\t}\\n   147→\\n   148→\\tenv.WriteFile(\\\"main.go\\\", \\\"package main\\\")\\n   149→\\tenv.GitAdd(\\\"main.go\\\")\\n   150→\\n   151→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   152→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   153→\\t}\\n   154→\\n   155→\\tenv.GitCommitWithShadowHooks(\\\"Initial work\\\", \\\"main.go\\\")\\n   156→\\n   157→\\t// First push\\n   158→\\tenv.RunPrePush(\\\"origin\\\")\\n   159→\\n   160→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   161→\\t\\tt.Fatal(\\\"checkpoint branch should exist after first push\\\")\\n   162→\\t}\\n   163→\\n   164→\\t// Get remote ref before second push\\n   165→\\trefBefore := getRemoteBranchHash(t, bareDir, paths.MetadataBranchName)\\n   166→\\n   167→\\t// Second push (no new checkpoints)\\n   168→\\tenv.RunPrePush(\\\"origin\\\")\\n   169→\\n   170→\\t// Remote ref should be unchanged\\n   171→\\trefAfter := getRemoteBranchHash(t, bareDir, paths.MetadataBranchName)\\n   172→\\tif refBefore != refAfter {\\n   173→\\t\\tt.Errorf(\\\"remote ref should be unchanged after idempotent push: before=%s, after=%s\\\", refBefore, refAfter)\\n   174→\\t}\\n   175→}\\n   176→\\n   177→// =============================================================================\\n   178→// P0 -- Checkpoint Remote Config\\n   179→// =============================================================================\\n   180→\\n   181→// TestPrePush_PushDisabledSkipsCheckpoints verifies that push_sessions: false\\n   182→// disables checkpoint push while trails are still pushed.\\n   183→func TestPrePush_PushDisabledSkipsCheckpoints(t *testing.T) {\\n   184→\\tt.Parallel()\\n   185→\\tenv := NewFeatureBranchEnv(t)\\n   186→\\n   187→\\tbareDir := env.SetupBareRemote()\\n   188→\\n   189→\\t// Configure push_sessions: false\\n   190→\\tenv.PatchSettings(map[string]any{\\n   191→\\t\\t\\\"strategy_options\\\": map[string]any{\\n   192→\\t\\t\\t\\\"push_sessions\\\": false,\\n   193→\\t\\t},\\n   194→\\t})\\n   195→\\n   196→\\t// Create session, checkpoint, and commit\\n   197→\\t_ = createCheckpointedCommit(t, env, \\\"Some work\\\", \\\"work.go\\\", \\\"package work\\\", \\\"Some work\\\")\\n   198→\\n   199→\\t// Verify checkpoint was created locally\\n   200→\\tif !env.BranchExists(paths.MetadataBranchName) {\\n   201→\\t\\tt.Fatal(\\\"should have local checkpoint branch after condensation\\\")\\n   202→\\t}\\n   203→\\n   204→\\t// Create a real trail so we can assert it pushes independently of checkpoints\\n   205→\\tcreateTrailForCurrentBranch(t, env)\\n   206→\\n   207→\\t// Single PrePush — should push trails but skip checkpoints\\n   208→\\tenv.RunPrePush(\\\"origin\\\")\\n   209→\\n   210→\\t// Checkpoints should NOT be on remote\\n   211→\\tif env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   212→\\t\\tt.Error(\\\"entire/checkpoints/v1 should NOT be on remote when push_sessions is false\\\")\\n   213→\\t}\\n   214→\\n   215→\\t// Trails SHOULD be on remote (trails are independent of push_sessions)\\n   216→\\tif !env.BranchExistsOnRemote(bareDir, paths.TrailsBranchName) {\\n   217→\\t\\tt.Error(\\\"entire/trails/v1 should be on remote even when push_sessions is false\\\")\\n   218→\\t}\\n   219→}\\n   220→\\n   221→// TestPrePush_CheckpointRemoteRoutesToSeparateRemote verifies that checkpoint data\\n   222→// can be selectively pushed to a separate remote while trails stay on origin.\\n   223→//\\n   224→// This is a data routing verification test. It validates that when the production\\n   225→// code's pushBranchIfNeeded is called with different targets for checkpoints vs\\n   226→// trails, the branches land on the correct remotes with correct data.\\n   227→//\\n   228→// Why not test through PrePush directly: resolvePushSettings derives the checkpoint\\n   229→// URL from origin's protocol (SSH/HTTPS). Since integration tests use local file\\n   230→// paths as remotes, parseGitRemoteURL fails and resolvePushSettings falls back to\\n   231→// origin. The URL derivation logic is unit-tested in checkpoint_remote_test.go\\n   232→// (TestDeriveCheckpointURL, TestResolvePushSettings_WithCheckpointRemote_*).\\n   233→//\\n   234→// The pushBranchIfNeeded function (which PrePush calls with the resolved target)\\n   235→// is exercised in push_common_test.go:TestPushBranchIfNeeded_LocalBareRepo_PushesSuccessfully,\\n   236→// verifying it works with local bare repo paths.\\n   237→func TestPrePush_CheckpointRemoteRoutesToSeparateRemote(t *testing.T) {\\n   238→\\tt.Parallel()\\n   239→\\tenv := NewFeatureBranchEnv(t)\\n   240→\\n   241→\\t// Set up two bare remotes: origin for user code + trails, checkpoint remote for checkpoints\\n   242→\\tbareOrigin := env.SetupBareRemote()\\n   243→\\tbareCheckpoint := env.SetupNamedBareRemote(\\\"checkpoint-store\\\")\\n   244→\\n   245→\\t// Create session, checkpoint, and commit\\n   246→\\tcheckpointID := createCheckpointedCommit(t, env, \\\"Add router\\\", \\\"router.go\\\", \\\"package router\\\", \\\"Add router\\\")\\n   247→\\n   248→\\t// Verify local checkpoint branch exists\\n   249→\\tif !env.BranchExists(paths.MetadataBranchName) {\\n   250→\\t\\tt.Fatal(\\\"should have local checkpoint branch after condensation\\\")\\n   251→\\t}\\n   252→\\n   253→\\t// Simulate checkpoint_remote routing: push checkpoints to the checkpoint bare repo\\n   254→\\t// and trails to origin. This mirrors what PrePush does when resolvePushSettings\\n   255→\\t// returns a checkpointURL: checkpoints go to ps.pushTarget(), trails go to ps.remote.\\n   256→\\tenv.GitPush(bareCheckpoint, paths.MetadataBranchName)\\n   257→\\n   258→\\t// Ensure trails branch exists for a definitive assertion.\\n   259→\\tensureTrailsBranchExists(t, env)\\n   260→\\tenv.GitPush(\\\"origin\\\", paths.TrailsBranchName)\\n   261→\\n   262→\\t// Checkpoints should be on checkpoint remote, NOT on origin\\n   263→\\tif !env.BranchExistsOnRemote(bareCheckpoint, paths.MetadataBranchName) {\\n   264→\\t\\tt.Error(\\\"entire/checkpoints/v1 should exist on checkpoint remote\\\")\\n   265→\\t}\\n   266→\\tif env.BranchExistsOnRemote(bareOrigin, paths.MetadataBranchName) {\\n   267→\\t\\tt.Error(\\\"entire/checkpoints/v1 should NOT be on origin when routed to checkpoint remote\\\")\\n   268→\\t}\\n   269→\\n   270→\\t// Trails should be on origin, NOT on checkpoint remote\\n   271→\\tif !env.BranchExistsOnRemote(bareOrigin, paths.TrailsBranchName) {\\n   272→\\t\\tt.Error(\\\"entire/trails/v1 should be on origin\\\")\\n   273→\\t}\\n   274→\\tif env.BranchExistsOnRemote(bareCheckpoint, paths.TrailsBranchName) {\\n   275→\\t\\tt.Error(\\\"entire/trails/v1 should NOT be on checkpoint remote\\\")\\n   276→\\t}\\n   277→\\n   278→\\t// Verify checkpoint data arrived on checkpoint remote\\n   279→\\tsummaryPath := CheckpointSummaryPath(checkpointID)\\n   280→\\tif !fileExistsOnRemoteBranch(t, bareCheckpoint, summaryPath) {\\n   281→\\t\\tt.Errorf(\\\"checkpoint metadata should exist on checkpoint remote at %s\\\", summaryPath)\\n   282→\\t}\\n   283→}\\n   284→\\n   285→// REDACTED verifies that when\\n   286→// origin is a local file path (not an SSH/HTTPS URL), resolvePushSettings cannot\\n   287→// derive a checkpoint URL and checkpoints fall back to origin.\\n   288→//\\n   289→// This exercises the integration behavior: when checkpoint_remote is configured but\\n   290→// the push remote URL cannot be parsed (local file path), checkpoints still land on\\n   291→// origin. The exact fork detection logic (owner mismatch) is unit-tested in\\n   292→// checkpoint_remote_test.go:TestResolvePushSettings_ForkDetection.\\n   293→func REDACTED(t *testing.T) {\\n   294→\\tt.Parallel()\\n   295→\\tenv := NewFeatureBranchEnv(t)\\n   296→\\n   297→\\tbareDir := env.SetupBareRemote()\\n   298→\\n   299→\\t// Configure checkpoint_remote with a different owner than origin.\\n   300→\\t// Since our bare remote is a local path (not a URL), resolvePushSettings cannot\\n   301→\\t// parse it via parseGitRemoteURL and falls back to origin. The unit test\\n   302→\\t// TestResolvePushSettings_ForkDetection in checkpoint_remote_test.go validates\\n   303→\\t// the exact fork detection logic with real URL parsing.\\n   304→\\tenv.PatchSettings(map[string]any{\\n   305→\\t\\t\\\"strategy_options\\\": map[string]any{\\n   306→\\t\\t\\t\\\"checkpoint_remote\\\": map[string]any{\\n   307→\\t\\t\\t\\t\\\"provider\\\": \\\"github\\\",\\n   308→\\t\\t\\t\\t\\\"repo\\\":     \\\"different-org/checkpoints\\\",\\n   309→\\t\\t\\t},\\n   310→\\t\\t},\\n   311→\\t})\\n   312→\\n   313→\\t// Create session, checkpoint, and commit\\n   314→\\tsession := env.NewSession()\\n   315→\\ttranscriptPath := session.CreateTranscript(\\\"Add middleware\\\", []FileChange{\\n   316→\\t\\t{Path: \\\"middleware.go\\\", Content: \\\"package middleware\\\"},\\n   317→\\t})\\n   318→\\n   319→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Add middleware\\\", transcriptPath); err != nil {\\n   320→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   321→\\t}\\n   322→\\n   323→\\tenv.WriteFile(\\\"middleware.go\\\", \\\"package middleware\\\")\\n   324→\\tenv.GitAdd(\\\"middleware.go\\\")\\n   325→\\n   326→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   327→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   328→\\t}\\n   329→\\n   330→\\tenv.GitCommitWithShadowHooks(\\\"Add middleware\\\", \\\"middleware.go\\\")\\n   331→\\n   332→\\t// Run PrePush -- with a local path remote, checkpoint URL derivation will fail\\n   333→\\t// (parseGitRemoteURL can't parse local paths), so checkpoints fall back to origin.\\n   334→\\tenv.RunPrePush(\\\"origin\\\")\\n   335→\\n   336→\\t// Checkpoints should be on origin (fallback behavior)\\n   337→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   338→\\t\\tt.Error(\\\"entire/checkpoints/v1 should be on origin when checkpoint_remote is unavailable (fork/fallback)\\\")\\n   339→\\t}\\n   340→}\\n   341→\\n   342→// =============================================================================\\n   343→// P0 -- Clone and Resume\\n   344→// =============================================================================\\n   345→\\n   346→// createCheckpointedCommit is a helper that creates a session with a single file change,\\n   347→// runs the full lifecycle (prompt submit -> write -> stop -> commit), and returns the\\n   348→// session and checkpoint ID. This reduces boilerplate in tests where the session setup\\n   349→// is not the focus.\\n   350→func createCheckpointedCommit(t *testing.T, env *TestEnv, prompt, fileName, fileContent, commitMsg string) string {\\n   351→\\tt.Helper()\\n   352→\\n   353→\\tsession := env.NewSession()\\n   354→\\ttranscriptPath := session.CreateTranscript(prompt, []FileChange{\\n   355→\\t\\t{Path: fileName, Content: fileContent},\\n   356→\\t})\\n   357→\\n   358→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, prompt, transcriptPath); err != nil {\\n   359→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   360→\\t}\\n   361→\\n   362→\\tenv.WriteFile(fileName, fileContent)\\n   363→\\tenv.GitAdd(fileName)\\n   364→\\n   365→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   366→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   367→\\t}\\n   368→\\n   369→\\tenv.GitCommitWithShadowHooks(commitMsg, fileName)\\n   370→\\n   371→\\treturn env.GetLatestCheckpointID()\\n   372→}\\n   373→\\n   374→// TestCloneAndResume_FetchesCheckpointMetadata verifies that after pushing\\n   375→// checkpoints to a remote, cloning the repo and fetching the metadata branch\\n   376→// brings the checkpoint data locally.\\n   377→//\\n   378→// Note: This test uses env.FetchMetadataBranch (raw git fetch) rather than\\n   379→// triggering fetchMetadataBranchIfMissing via the production code path, because\\n   380→// fetchMetadataBranchIfMissing uses OpenRepository which requires CWD to be\\n   381→// inside the repo (incompatible with t.Parallel). The production function is\\n   382→// tested directly in checkpoint_remote_test.go (TestFetchBranchIfMissing_*).\\n   383→// This test verifies the \\\"data arrives and is usable\\\" property.\\n   384→func TestCloneAndResume_FetchesCheckpointMetadata(t *testing.T) {\\n   385→\\tt.Parallel()\\n   386→\\tenv := NewFeatureBranchEnv(t)\\n   387→\\n   388→\\tbareDir := env.SetupBareRemote()\\n   389→\\n   390→\\t// Repo A: create session, checkpoint, commit, push\\n   391→\\tcheckpointID := createCheckpointedCommit(t, env, \\\"Build login page\\\", \\\"login.go\\\", \\\"package login\\\", \\\"Build login page\\\")\\n   392→\\tt.Logf(\\\"Original checkpoint ID: %s\\\", checkpointID)\\n   393→\\n   394→\\t// Push user branch + checkpoint branches to remote\\n   395→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   396→\\tenv.RunPrePush(\\\"origin\\\")\\n   397→\\n   398→\\t// Clone into repo B\\n   399→\\tcloneEnv := env.CloneFrom(bareDir)\\n   400→\\n   401→\\t// Fetch the metadata branch (simulates what fetchMetadataBranchIfMissing does)\\n   402→\\tcloneEnv.FetchMetadataBranch(bareDir)\\n   403→\\n   404→\\t// Now the metadata branch should exist locally in the clone\\n   405→\\tif !cloneEnv.BranchExists(paths.MetadataBranchName) {\\n   406→\\t\\tt.Fatal(\\\"entire/checkpoints/v1 should exist in clone after fetch\\\")\\n   407→\\t}\\n   408→\\n   409→\\t// Verify the checkpoint data is present\\n   410→\\tsummaryPath := CheckpointSummaryPath(checkpointID)\\n   411→\\tif !cloneEnv.FileExistsInBranch(paths.MetadataBranchName, summaryPath) {\\n   412→\\t\\tt.Errorf(\\\"checkpoint metadata should exist in clone at %s\\\", summaryPath)\\n   413→\\t}\\n   414→}\\n   415→\\n   416→// TestCloneAndResume_SessionListingWorksAfterClone verifies that checkpoint\\n   417→// metadata can be enumerated after cloning and fetching the metadata branch.\\n   418→func TestCloneAndResume_SessionListingWorksAfterClone(t *testing.T) {\\n   419→\\tt.Parallel()\\n   420→\\tenv := NewFeatureBranchEnv(t)\\n   421→\\n   422→\\tbareDir := env.SetupBareRemote()\\n   423→\\n   424→\\t// Repo A: create session, checkpoint, commit, push\\n   425→\\tcheckpointID := createCheckpointedCommit(t, env, \\\"Implement auth\\\", \\\"auth.go\\\", \\\"package auth\\\", \\\"Implement auth\\\")\\n   426→\\n   427→\\t// Push everything\\n   428→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   429→\\tenv.RunPrePush(\\\"origin\\\")\\n   430→\\n   431→\\t// Clone and fetch metadata\\n   432→\\tcloneEnv := env.CloneFrom(bareDir)\\n   433→\\tcloneEnv.FetchMetadataBranch(bareDir)\\n   434→\\n   435→\\t// List checkpoints from the clone by scanning the metadata branch tree\\n   436→\\tcheckpoints := listCheckpointsInDir(t, cloneEnv.RepoDir)\\n   437→\\n   438→\\tif len(checkpoints) == 0 {\\n   439→\\t\\tt.Fatal(\\\"should find checkpoints from original repo after clone\\\")\\n   440→\\t}\\n   441→\\n   442→\\t// Verify our checkpoint is in the list\\n   443→\\tfound := false\\n   444→\\tfor _, cp := range checkpoints {\\n   445→\\t\\tif cp == checkpointID {\\n   446→\\t\\t\\tfound = true\\n   447→\\t\\t\\tbreak\\n   448→\\t\\t}\\n   449→\\t}\\n   450→\\tif !found {\\n   451→\\t\\tt.Errorf(\\\"checkpoint %s from original repo should be in list, got: %v\\\", checkpointID, checkpoints)\\n   452→\\t}\\n   453→}\\n   454→\\n   455→// TestCloneAndResume_SessionLogRetrievalWorksAfterClone verifies that\\n   456→// checkpoint transcripts can be read after clone + fetch.\\n   457→func TestCloneAndResume_SessionLogRetrievalWorksAfterClone(t *testing.T) {\\n   458→\\tt.Parallel()\\n   459→\\tenv := NewFeatureBranchEnv(t)\\n   460→\\n   461→\\tbareDir := env.SetupBareRemote()\\n   462→\\n   463→\\t// Repo A: create session with a specific transcript content\\n   464→\\tcheckpointID := createCheckpointedCommit(t, env, \\\"Write tests for auth\\\", \\\"auth_test.go\\\", \\\"package auth_test\\\", \\\"Write auth tests\\\")\\n   465→\\n   466→\\t// Push\\n   467→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   468→\\tenv.RunPrePush(\\\"origin\\\")\\n   469→\\n   470→\\t// Clone and fetch metadata\\n   471→\\tcloneEnv := env.CloneFrom(bareDir)\\n   472→\\tcloneEnv.FetchMetadataBranch(bareDir)\\n   473→\\n   474→\\t// Read transcript from the clone\\n   475→\\ttranscriptFilePath := SessionFilePath(checkpointID, paths.TranscriptFileName)\\n   476→\\tcontent, found := cloneEnv.ReadFileFromBranch(paths.MetadataBranchName, transcriptFilePath)\\n   477→\\tif !found {\\n   478→\\t\\tt.Fatalf(\\\"transcript should be readable from clone at %s\\\", transcriptFilePath)\\n   479→\\t}\\n   480→\\n   481→\\tif content == \\\"\\\" {\\n   482→\\t\\tt.Error(\\\"transcript content should not be empty\\\")\\n   483→\\t}\\n   484→\\n   485→\\t// Verify it contains our expected content\\n   486→\\tif !strings.Contains(content, \\\"Write tests for auth\\\") {\\n   487→\\t\\tt.Error(\\\"transcript should contain the user prompt from the original session\\\")\\n   488→\\t}\\n   489→}\\n   490→\\n   491→// TestCloneAndResume_NewSessionPushAppends verifies that after cloning,\\n   492→// creating a new session, and pushing, the remote has BOTH original and\\n   493→// new checkpoint data.\\n   494→func TestCloneAndResume_NewSessionPushAppends(t *testing.T) {\\n   495→\\tt.Parallel()\\n   496→\\tenv := NewFeatureBranchEnv(t)\\n   497→\\n   498→\\tbareDir := env.SetupBareRemote()\\n   499→\\n   500→\\t// Repo A: session + commit + push\\n   501→\\toriginalCheckpointID := createCheckpointedCommit(t, env, \\\"Add models\\\", \\\"models.go\\\", \\\"package models\\\", \\\"Add models\\\")\\n   502→\\tt.Logf(\\\"Original checkpoint: %s\\\", originalCheckpointID)\\n   503→\\n   504→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   505→\\tenv.RunPrePush(\\\"origin\\\")\\n   506→\\n   507→\\t// Clone into repo B and fetch metadata\\n   508→\\tcloneEnv := env.CloneFrom(bareDir)\\n   509→\\tcloneEnv.FetchMetadataBranch(bareDir)\\n   510→\\n   511→\\t// Repo B: create NEW session on a new branch, commit, push\\n   512→\\tcloneEnv.GitCheckoutNewBranch(\\\"feature/clone-work\\\")\\n   513→\\n   514→\\tnewCheckpointID := createCheckpointedCommit(t, cloneEnv, \\\"Add handlers\\\", \\\"handlers.go\\\", \\\"package handlers\\\", \\\"Add handlers\\\")\\n   515→\\tt.Logf(\\\"New checkpoint: %s\\\", newCheckpointID)\\n   516→\\n   517→\\t// Push from clone\\n   518→\\tcloneEnv.RunPrePush(\\\"origin\\\")\\n   519→\\n   520→\\t// Verify remote has BOTH checkpoints\\n   521→\\toriginalSummaryPath := CheckpointSummaryPath(originalCheckpointID)\\n   522→\\tif !fileExistsOnRemoteBranch(t, bareDir, originalSummaryPath) {\\n   523→\\t\\tt.Errorf(\\\"original checkpoint %s should still exist on remote\\\", originalCheckpointID)\\n   524→\\t}\\n   525→\\n   526→\\tnewSummaryPath := CheckpointSummaryPath(newCheckpointID)\\n   527→\\tif !fileExistsOnRemoteBranch(t, bareDir, newSummaryPath) {\\n   528→\\t\\tt.Errorf(\\\"new checkpoint %s should exist on remote\\\", newCheckpointID)\\n   529→\\t}\\n   530→}\\n   531→\\n   532→// =============================================================================\\n   533→// P1 -- Non-Fast-Forward Recovery\\n   534→// =============================================================================\\n   535→\\n   536→// TestConcurrentPush_SecondPusherMergesAndRetries verifies that when two clones\\n   537→// push to the same remote, the second pusher fetches, merges, and retries.\\n   538→func TestConcurrentPush_SecondPusherMergesAndRetries(t *testing.T) {\\n   539→\\tt.Parallel()\\n   540→\\tenv := NewFeatureBranchEnv(t)\\n   541→\\n   542→\\tbareDir := env.SetupBareRemote()\\n   543→\\n   544→\\t// Clone A\\n   545→\\tcloneA := env.CloneFrom(bareDir)\\n   546→\\tcloneA.GitCheckoutNewBranch(\\\"feature/clone-a\\\")\\n   547→\\n   548→\\t// Clone B\\n   549→\\tcloneB := env.CloneFrom(bareDir)\\n   550→\\tcloneB.GitCheckoutNewBranch(\\\"feature/clone-b\\\")\\n   551→\\n   552→\\t// Clone A: session + commit\\n   553→\\tcheckpointA := createCheckpointedCommit(t, cloneA, \\\"Work in clone A\\\", \\\"a.go\\\", \\\"package a\\\", \\\"Work from A\\\")\\n   554→\\tt.Logf(\\\"Clone A checkpoint: %s\\\", checkpointA)\\n   555→\\n   556→\\t// Clone B: session + commit\\n   557→\\tcheckpointB := createCheckpointedCommit(t, cloneB, \\\"Work in clone B\\\", \\\"b.go\\\", \\\"package b\\\", \\\"Work from B\\\")\\n   558→\\tt.Logf(\\\"Clone B checkpoint: %s\\\", checkpointB)\\n   559→\\n   560→\\t// A pushes first (should succeed cleanly)\\n   561→\\tcloneA.RunPrePush(\\\"origin\\\")\\n   562→\\n   563→\\t// B pushes second (will get non-fast-forward, should fetch+merge+retry)\\n   564→\\tcloneB.RunPrePush(\\\"origin\\\")\\n   565→\\n   566→\\t// Remote should have BOTH checkpoints\\n   567→\\tsummaryA := CheckpointSummaryPath(checkpointA)\\n   568→\\tif !fileExistsOnRemoteBranch(t, bareDir, summaryA) {\\n   569→\\t\\tt.Errorf(\\\"remote should have checkpoint from clone A: %s\\\", checkpointA)\\n   570→\\t}\\n   571→\\n   572→\\tsummaryB := CheckpointSummaryPath(checkpointB)\\n   573→\\tif !fileExistsOnRemoteBranch(t, bareDir, summaryB) {\\n   574→\\t\\tt.Errorf(\\\"remote should have checkpoint from clone B: %s\\\", checkpointB)\\n   575→\\t}\\n   576→\\n   577→\\t// Verify B's local metadata branch has a merge commit with 2 parents.\\n   578→\\t// This confirms the fetch+merge+retry path was taken.\\n   579→\\tparentCount := cloneB.GetBranchTipParentCount(paths.MetadataBranchName)\\n   580→\\tif parentCount != 2 {\\n   581→\\t\\tt.Errorf(\\\"clone B's metadata branch tip should have 2 parents (merge commit), got %d\\\", parentCount)\\n   582→\\t}\\n   583→}\\n   584→\\n   585→// =============================================================================\\n   586→// P1 -- Graceful Degradation\\n   587→// =============================================================================\\n   588→\\n   589→// TestGracefulDegradation_UnreachableCheckpointRemotePushContinues verifies that\\n   590→// when checkpoint_remote is configured but cannot be resolved (because origin is a\\n   591→// local path, not an SSH/HTTPS URL), PrePush falls back to pushing checkpoints to\\n   592→// origin. Trails are always pushed to origin regardless of checkpoint_remote config.\\n   593→//\\n   594→// This test exercises the PrePush -> resolvePushSettings -> fallback code path.\\n   595→// The actual doPushBranch graceful degradation (push to unreachable URL returns nil,\\n   596→// not an error) is tested in push_common_test.go:\\n   597→//   - TestDoPushBranch_UnreachableTarget_ReturnsNil\\n   598→//   - TestPushBranchIfNeeded_UnreachableTarget_ReturnsNil\\n   599→func TestGracefulDegradation_UnreachableCheckpointRemotePushContinues(t *testing.T) {\\n   600→\\tt.Parallel()\\n   601→\\tenv := NewFeatureBranchEnv(t)\\n   602→\\n   603→\\tbareOrigin := env.SetupBareRemote()\\n   604→\\n   605→\\t// Configure checkpoint_remote with a nonexistent repo. Since origin is a local\\n   606→\\t// file path, resolvePushSettings cannot parse it as a URL and will silently fall\\n   607→\\t// back to pushing checkpoints to origin (the default behavior).\\n   608→\\tenv.PatchSettings(map[string]any{\\n   609→\\t\\t\\\"strategy_options\\\": map[string]any{\\n   610→\\t\\t\\t\\\"checkpoint_remote\\\": map[string]any{\\n   611→\\t\\t\\t\\t\\\"provider\\\": \\\"github\\\",\\n   612→\\t\\t\\t\\t\\\"repo\\\":     \\\"nonexistent-org/unreachable-repo\\\",\\n   613→\\t\\t\\t},\\n   614→\\t\\t},\\n   615→\\t})\\n   616→\\n   617→\\t// Create session, checkpoint, and commit\\n   618→\\t_ = createCheckpointedCommit(t, env, \\\"Some work\\\", \\\"work.go\\\", \\\"package work\\\", \\\"Some work\\\")\\n   619→\\n   620→\\t// Verify local checkpoint branch exists\\n   621→\\tif !env.BranchExists(paths.MetadataBranchName) {\\n   622→\\t\\tt.Fatal(\\\"should have local checkpoint branch after condensation\\\")\\n   623→\\t}\\n   624→\\n   625→\\t// Ensure trails branch exists so we can verify it pushes independently.\\n   626→\\tensureTrailsBranchExists(t, env)\\n   627→\\n   628→\\t// Run PrePush with checkpoint_remote configured. Since origin is a local path,\\n   629→\\t// resolvePushSettings will fail to derive a checkpoint URL and fall back to\\n   630→\\t// pushing both checkpoints and trails to origin.\\n   631→\\tenv.RunPrePush(\\\"origin\\\")\\n   632→\\n   633→\\t// Checkpoints should be on origin (fallback behavior when checkpoint URL derivation fails)\\n   634→\\tif !env.BranchExistsOnRemote(bareOrigin, paths.MetadataBranchName) {\\n   635→\\t\\tt.Error(\\\"entire/checkpoints/v1 should be on origin when checkpoint_remote URL derivation fails\\\")\\n   636→\\t}\\n   637→\\n   638→\\t// Trails should always be on origin regardless of checkpoint_remote config\\n   639→\\tif !env.BranchExistsOnRemote(bareOrigin, paths.TrailsBranchName) {\\n   640→\\t\\tt.Error(\\\"entire/trails/v1 should be on origin even when checkpoint_remote is configured\\\")\\n   641→\\t}\\n   642→}\\n   643→\\n   644→// TestGracefulDegradation_UnreachableCheckpointRemoteOnCloneIsSilent verifies that\\n   645→// when a clone configures checkpoint_remote pointing to an unreachable path, starting\\n   646→// a session does not error. fetchMetadataBranchIfMissing silently swallows fetch failures.\\n   647→func TestGracefulDegradation_UnreachableCheckpointRemoteOnCloneIsSilent(t *testing.T) {\\n   648→\\tt.Parallel()\\n   649→\\tenv := NewFeatureBranchEnv(t)\\n   650→\\n   651→\\tbareDir := env.SetupBareRemote()\\n   652→\\n   653→\\t// Create a session in repo A and push\\n   654→\\tcreateCheckpointedCommit(t, env, \\\"Initial work\\\", \\\"init.go\\\", \\\"package init\\\", \\\"Initial work\\\")\\n   655→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   656→\\tenv.RunPrePush(\\\"origin\\\")\\n   657→\\n   658→\\t// Clone from origin\\n   659→\\tcloneEnv := env.CloneFrom(bareDir)\\n   660→\\n   661→\\t// Configure checkpoint_remote to an unreachable path in the clone.\\n   662→\\t// When the checkpoint_remote URL can't be reached, fetch fails silently.\\n   663→\\tcloneEnv.PatchSettings(map[string]any{\\n   664→\\t\\t\\\"strategy_options\\\": map[string]any{\\n   665→\\t\\t\\t\\\"checkpoint_remote\\\": map[string]any{\\n   666→\\t\\t\\t\\t\\\"provider\\\": \\\"github\\\",\\n   667→\\t\\t\\t\\t\\\"repo\\\":     \\\"nonexistent-org/nonexistent-repo\\\",\\n   668→\\t\\t\\t},\\n   669→\\t\\t},\\n   670→\\t})\\n   671→\\n   672→\\t// Starting a new session should not error even though checkpoint_remote is unreachable.\\n   673→\\t// The session machinery itself doesn't trigger fetchMetadataBranchIfMissing (that happens\\n   674→\\t// in resolvePushSettings during PrePush), so this verifies the session starts cleanly.\\n   675→\\tsession := cloneEnv.NewSession()\\n   676→\\ttranscriptPath := session.CreateTranscript(\\\"Clone work\\\", []FileChange{\\n   677→\\t\\t{Path: \\\"clone.go\\\", Content: \\\"package clone\\\"},\\n   678→\\t})\\n   679→\\n   680→\\tif err := cloneEnv.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Clone work\\\", transcriptPath); err != nil {\\n   681→\\t\\tt.Fatalf(\\\"session start should not fail with unreachable checkpoint_remote: %v\\\", err)\\n   682→\\t}\\n   683→\\n   684→\\tif err := cloneEnv.SimulateStop(session.ID, transcriptPath); err != nil {\\n   685→\\t\\tt.Fatalf(\\\"session stop should not fail: %v\\\", err)\\n   686→\\t}\\n   687→\\n   688→\\t// PrePush should also not fail -- checkpoint_remote URL derivation will fail\\n   689→\\t// (origin is a local path, can't parse it), so it falls back to pushing to origin.\\n   690→\\tcloneEnv.WriteFile(\\\"clone.go\\\", \\\"package clone\\\")\\n   691→\\tcloneEnv.GitAdd(\\\"clone.go\\\")\\n   692→\\tcloneEnv.GitCommitWithShadowHooks(\\\"Clone work\\\", \\\"clone.go\\\")\\n   693→\\tcloneEnv.RunPrePush(\\\"origin\\\")\\n   694→\\n   695→\\t// Verify that the session actually created a local checkpoint despite the\\n   696→\\t// unreachable checkpoint_remote config.\\n   697→\\tif !cloneEnv.BranchExists(paths.MetadataBranchName) {\\n   698→\\t\\tt.Error(\\\"entire/checkpoints/v1 should exist locally after session + commit in clone\\\")\\n   699→\\t}\\n   700→}\\n   701→\\n   702→// =============================================================================\\n   703→// Helpers\\n   704→// =============================================================================\\n   705→\\n   706→// createTrailForCurrentBranch creates a real trail via the trail.Store for the\\n   707→// current branch. Unlike ensureTrailsBranchExists (which stubs a fake orphan\\n   708→// branch), this writes proper trail metadata through the production code path.\\n   709→func createTrailForCurrentBranch(t *testing.T, env *TestEnv) {\\n   710→\\tt.Helper()\\n   711→\\n   712→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   713→\\tif 