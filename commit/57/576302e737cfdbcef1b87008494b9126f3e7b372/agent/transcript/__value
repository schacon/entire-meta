entWithNewline(rawSettings, \\\"\\\", \\\"  \\\")\\n   387→\\tif err != nil {\\n   388→\\t\\treturn fmt.Errorf(\\\"failed to marshal settings: %w\\\", err)\\n   389→\\t}\\n   390→\\tif err := os.WriteFile(settingsPath, output, 0o600); err != nil {\\n   391→\\t\\treturn fmt.Errorf(\\\"failed to write settings.json: %w\\\", err)\\n   392→\\t}\\n   393→\\treturn nil\\n   394→}\\n   395→\\n   396→// AreHooksInstalled checks if Entire hooks are installed.\\n   397→func (f *FactoryAIDroidAgent) AreHooksInstalled() bool {\\n   398→\\t// Use repo root to find .factory directory when run from a subdirectory\\n   399→\\trepoRoot, err := paths.RepoRoot()\\n   400→\\tif err != nil {\\n   401→\\t\\trepoRoot = \\\".\\\" // Fallback to CWD if not in a git repo\\n   402→\\t}\\n   403→\\tsettingsPath := filepath.Join(repoRoot, \\\".factory\\\", FactorySettingsFileName)\\n   404→\\tdata, err := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   405→\\tif err != nil {\\n   406→\\t\\treturn false\\n   407→\\t}\\n   408→\\n   409→\\tvar settings FactorySettings\\n   410→\\tif err := json.Unmarshal(data, &settings); err != nil {\\n   411→\\t\\treturn false\\n   412→\\t}\\n   413→\\n   414→\\t// Check for at least one of our hooks (new or old format)\\n   415→\\treturn hookCommandExists(settings.Hooks.Stop, \\\"entire hooks factoryai-droid stop\\\") ||\\n   416→\\t\\thookCommandExists(settings.Hooks.Stop, \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid stop\\\")\\n   417→}\\n   418→\\n   419→// GetSupportedHooks returns the hook types Factory AI Droid supports.\\n   420→func (f *FactoryAIDroidAgent) GetSupportedHooks() []agent.HookType {\\n   421→\\treturn []agent.HookType{\\n   422→\\t\\tagent.HookSessionStart,\\n   423→\\t\\tagent.HookSessionEnd,\\n   424→\\t\\tagent.HookUserPromptSubmit,\\n   425→\\t\\tagent.HookStop,\\n   426→\\t\\tagent.HookPreToolUse,\\n   427→\\t\\tagent.HookPostToolUse,\\n   428→\\t}\\n   429→}\\n   430→\\n   431→// Helper functions for hook management\\n   432→\\n   433→func hookCommandExists(matchers []FactoryHookMatcher, command string) bool {\\n   434→\\tfor _, matcher := range matchers {\\n   435→\\t\\tfor _, hook := range matcher.Hooks {\\n   436→\\t\\t\\tif hook.Command == command {\\n   437→\\t\\t\\t\\treturn true\\n   438→\\t\\t\\t}\\n   439→\\t\\t}\\n   440→\\t}\\n   441→\\treturn false\\n   442→}\\n   443→\\n   444→func hookCommandExistsWithMatcher(matchers []FactoryHookMatcher, matcherName, command string) bool {\\n   445→\\tfor _, matcher := range matchers {\\n   446→\\t\\tif matcher.Matcher == matcherName {\\n   447→\\t\\t\\tfor _, hook := range matcher.Hooks {\\n   448→\\t\\t\\t\\tif hook.Command == command {\\n   449→\\t\\t\\t\\t\\treturn true\\n   450→\\t\\t\\t\\t}\\n   451→\\t\\t\\t}\\n   452→\\t\\t}\\n   453→\\t}\\n   454→\\treturn false\\n   455→}\\n   456→\\n   457→func addHookToMatcher(matchers []FactoryHookMatcher, matcherName, command string) []FactoryHookMatcher {\\n   458→\\tentry := FactoryHookEntry{\\n   459→\\t\\tType:    \\\"command\\\",\\n   460→\\t\\tCommand: command,\\n   461→\\t}\\n   462→\\n   463→\\t// If no matcher name, add to a matcher with empty string\\n   464→\\tif matcherName == \\\"\\\" {\\n   465→\\t\\tfor i, matcher := range matchers {\\n   466→\\t\\t\\tif matcher.Matcher == \\\"\\\" {\\n   467→\\t\\t\\t\\tmatchers[i].Hooks = append(matchers[i].Hooks, entry)\\n   468→\\t\\t\\t\\treturn matchers\\n   469→\\t\\t\\t}\\n   470→\\t\\t}\\n   471→\\t\\treturn append(matchers, FactoryHookMatcher{\\n   472→\\t\\t\\tMatcher: \\\"\\\",\\n   473→\\t\\t\\tHooks:   []FactoryHookEntry{entry},\\n   474→\\t\\t})\\n   475→\\t}\\n   476→\\n   477→\\t// Find or create matcher with the given name\\n   478→\\tfor i, matcher := range matchers {\\n   479→\\t\\tif matcher.Matcher == matcherName {\\n   480→\\t\\t\\tmatchers[i].Hooks = append(matchers[i].Hooks, entry)\\n   481→\\t\\t\\treturn matchers\\n   482→\\t\\t}\\n   483→\\t}\\n   484→\\n   485→\\treturn append(matchers, FactoryHookMatcher{\\n   486→\\t\\tMatcher: matcherName,\\n   487→\\t\\tHooks:   []FactoryHookEntry{entry},\\n   488→\\t})\\n   489→}\\n   490→\\n   491→// isEntireHook checks if a command is an Entire hook (old or new format)\\n   492→func isEntireHook(command string) bool {\\n   493→\\tfor _, prefix := range entireHookPrefixes {\\n   494→\\t\\tif strings.HasPrefix(command, prefix) {\\n   495→\\t\\t\\treturn true\\n   496→\\t\\t}\\n   497→\\t}\\n   498→\\treturn false\\n   499→}\\n   500→\\n   501→// removeEntireHooks removes all Entire hooks from a list of matchers (for simple hooks like Stop)\\n   502→func removeEntireHooks(matchers []FactoryHookMatcher) []FactoryHookMatcher {\\n   503→\\tresult := make([]FactoryHookMatcher, 0, len(matchers))\\n   504→\\tfor _, matcher := range matchers {\\n   505→\\t\\tfilteredHooks := make([]FactoryHookEntry, 0, len(matcher.Hooks))\\n   506→\\t\\tfor _, hook := range matcher.Hooks {\\n   507→\\t\\t\\tif !isEntireHook(hook.Command) {\\n   508→\\t\\t\\t\\tfilteredHooks = append(filteredHooks, hook)\\n   509→\\t\\t\\t}\\n   510→\\t\\t}\\n   511→\\t\\t// Only keep the matcher if it has hooks remaining\\n   512→\\t\\tif len(filteredHooks) > 0 {\\n   513→\\t\\t\\tmatcher.Hooks = filteredHooks\\n   514→\\t\\t\\tresult = append(result, matcher)\\n   515→\\t\\t}\\n   516→\\t}\\n   517→\\treturn result\\n   518→}\\n   519→\\n   520→// removeEntireHooksFromMatchers removes Entire hooks from tool-use matchers (PreToolUse, PostToolUse)\\n   521→// This handles the nested structure where hooks are grouped by tool matcher (e.g., \\\"Task\\\")\\n   522→func removeEntireHooksFromMatchers(matchers []FactoryHookMatcher) []FactoryHookMatcher {\\n   523→\\t// Same logic as removeEntireHooks - both work on the same structure\\n   524→\\treturn removeEntireHooks(matchers)\\n   525→}\\n   526→\"}]},\"uuid\":\"4bf3ac4e-0b47-475f-bdaa-fb87276cf4b1\",\"timestamp\":\"2026-02-20T22:15:14.653Z\",\"toolUseResult\":