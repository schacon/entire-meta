ake(map[string]json.RawMessage)\\n   111→\\t}\\n   112→\\tif rawPermissions == nil {\\n   113→\\t\\trawPermissions = make(map[string]json.RawMessage)\\n   114→\\t}\\n   115→\\n   116→\\t// Parse only the hook types we need to modify\\n   117→\\tvar sessionStart, sessionEnd, stop, userPromptSubmit, preToolUse, postToolUse, preCompact []FactoryHookMatcher\\n   118→\\tparseHookType(rawHooks, \\\"SessionStart\\\", &sessionStart)\\n   119→\\tparseHookType(rawHooks, \\\"SessionEnd\\\", &sessionEnd)\\n   120→\\tparseHookType(rawHooks, \\\"Stop\\\", &stop)\\n   121→\\tparseHookType(rawHooks, \\\"UserPromptSubmit\\\", &userPromptSubmit)\\n   122→\\tparseHookType(rawHooks, \\\"PreToolUse\\\", &preToolUse)\\n   123→\\tparseHookType(rawHooks, \\\"PostToolUse\\\", &postToolUse)\\n   124→\\tparseHookType(rawHooks, \\\"PreCompact\\\", &preCompact)\\n   125→\\n   126→\\t// If force is true, remove all existing Entire hooks first\\n   127→\\tif force {\\n   128→\\t\\tsessionStart = removeEntireHooks(sessionStart)\\n   129→\\t\\tsessionEnd = removeEntireHooks(sessionEnd)\\n   130→\\t\\tstop = removeEntireHooks(stop)\\n   131→\\t\\tuserPromptSubmit = removeEntireHooks(userPromptSubmit)\\n   132→\\t\\tpreToolUse = removeEntireHooksFromMatchers(preToolUse)\\n   133→\\t\\tpostToolUse = removeEntireHooksFromMatchers(postToolUse)\\n   134→\\t\\tpreCompact = removeEntireHooks(preCompact)\\n   135→\\t}\\n   136→\\n   137→\\t// Define hook commands\\n   138→\\tvar sessionStartCmd, sessionEndCmd, stopCmd, userPromptSubmitCmd, preTaskCmd, postTaskCmd, preCompactCmd string\\n   139→\\tif localDev {\\n   140→\\t\\tsessionStartCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid session-start\\\"\\n   141→\\t\\tsessionEndCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid session-end\\\"\\n   142→\\t\\tstopCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid stop\\\"\\n   143→\\t\\tuserPromptSubmitCmd = \\\"go run