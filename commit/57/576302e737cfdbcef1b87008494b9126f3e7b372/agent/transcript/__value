wHooks, \\\"PreCompact\\\", preCompact)\\n   219→\\n   220→\\t// Marshal hooks and update raw settings\\n   221→\\thooksJSON, err := json.Marshal(rawHooks)\\n   222→\\tif err != nil {\\n   223→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal hooks: %w\\\", err)\\n   224→\\t}\\n   225→\\trawSettings[\\\"hooks\\\"] = hooksJSON\\n   226→\\n   227→\\t// Marshal permissions and update raw settings\\n   228→\\tpermJSON, err := json.Marshal(rawPermissions)\\n   229→\\tif err != nil {\\n   230→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal permissions: %w\\\", err)\\n   231→\\t}\\n   232→\\trawSettings[\\\"permissions\\\"] = permJSON\\n   233→\\n   234→\\t// Write back to file\\n   235→\\tif err := os.MkdirAll(filepath.Dir(settingsPath), 0o750); err != nil {\\n   236→\\t\\treturn 0, fmt.Errorf(\\\"failed to create .factory directory: %w\\\", err)\\n   237→\\t}\\n   238→\\n   239→\\toutput, err := jsonutil.MarshalIndentWithNewline(rawSettings, \\\"\\\", \\\"  \\\")\\n   240→\\tif err != nil {\\n   241→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal settings: %w\\\", err)\\n   242→\\t}\\n   243→\\n   244→\\tif err := os.WriteFile(settingsPath, output, 0o600); err != nil {\\n   245→\\t\\treturn 0, fmt.Errorf(\\\"failed to write settings.json: %w\\\", err)\\n   246→\\t}\\n   247→\\n   248→\\treturn count, nil\\n   249→}\\n   250→\\n   251→// parseHookType parses a specific hook type from rawHooks into the target slice.\\n   252→// Silently ignores parse errors (leaves target unchanged).\\n   253→func parseHookType(rawHooks map[string]json.RawMessage, hookType string, target *[]FactoryHookMatcher) {\\n   254→\\tif data, ok := rawHooks[hookType]; ok {\\n   255→\\t\\t//nolint:errcheck,gosec // Intentionally ignoring parse errors - leave target as nil/empty\\n   256→\\t\\tjson.Unmarshal(data, target)\\n   257→\\t}\\n   258→}\\n   259→\\n   260→// marshalHookType marshals a hook type back to rawHooks.\\n   261→// If the slice is empty, removes the key from rawHooks.\\n   262→func marshalHookType(rawHooks map[string]json.RawMessage, hookType string, matchers []FactoryHookMatcher) {\\n   263→\\tif len(matchers) == 0 {\\n   264→\\t\\tdelete(rawHooks, hookType)\\n   265→\\t\\treturn\\n   266→\\t}\\n   267→\\tdata, err := json.Marshal(matchers)\\n   268→\\tif err != nil {\\n   269→\\t\\treturn // Silently ignore marshal errors (shouldn't happen)\\n   270→\\t}\\n   271→\\trawHooks[hookType] = data\\n   272→}\\n   273→\\n   274→// UninstallHooks removes Entire hooks from Factory AI Droid settings.\\n   275→func (f *FactoryAIDroidAgent) UninstallHooks() error {\\n   276→\\t// Use repo root to find .factory directory when run from a subdirectory\\n   277→\\trepoRoot, err := paths.RepoRoot()\\n   278→\\tif err != nil {\\n   279→\\t\\trepoRoot = \\\".\\\" // Fallback to CWD if not in a git repo\\n   280→\\t}\\n   281→\\tsettingsPath := filepath.Join(repoRoot, \\\".factory\\\", FactorySettingsFileName)\\n   282→\\tdata, err := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   283→\\tif err != nil {\\n   284→\\t\\treturn nil //nolint:nilerr // No settings file means nothing to uninstall\\n   285→\\t}\\n   286→\\n   287→\\tvar rawSettings map[string]json.RawMessage\\n   288→\\tif err := json.Unmarshal(data, &rawSettings); err != nil {\\n   289→\\t\\treturn fmt.Errorf(\\\"failed to parse settings.json: %w\\\", err)\\n   290→\\t}\\n   291→\\n   292→\\t// rawHooks preserves unknown hook types\\n   293→\\tvar rawHooks map[string]json.RawMessage\\n   294→\\tif hooksRaw, ok := rawSettings[\\\"hooks\\\"]; ok {\\n   295→\\t\\tif err := json.Unmarshal(hooksRaw, &rawHooks); err != nil {\\n   296→\\t\\t\\treturn fmt.Errorf(\\\"failed to parse hooks: %w\\\", err)\\n   297→\\t\\t}\\n   298→\\t}\\n   299→\\tif rawHooks == nil {\\n   300→\\t\\trawHooks = make(map[string]json.RawMessage)\\n   301→\\t}\\n   302→\\n   303→\\t// Parse only the hook types we need to modify\\n   304→\\tvar sessionStart, sessionEnd, stop, userPromptSubmit, preToolUse, postToolUse, preCompact []FactoryHookMatcher\\n   305→\\tparseHookType(rawHooks, \\\"SessionStart\\\", &sessionStart)\\n   306→\\tparseHookType(rawHooks, \\\"SessionEnd\\\", &sessionEnd)\\n   307→\\tparseHookType(rawHooks, \\\"Stop\\\", &stop)\\n   308→\\tparseHookType(rawHooks, \\\"UserPromptSubmit\\\", &userPromptSubmit)\\n   309→\\tparseHookType(rawHooks, \\\"PreToolUse\\\", &preToolUse)\\n   310→\\tparseHookType(rawHooks, \\\"PostToolUse\\\", &postToolUse)\\n   311→\\tparseHookType(rawHooks, \\\"PreCompact\\\", &preCompact)\\n   312→\\n   313→\\t// Remove Entire hooks from all hook types\\n   314→\\tsessionStart = removeEntireHooks(sessionStart)\\n   315→\\tsessionEnd = removeEntireHooks(sessionEnd)\\n   316→\\tstop = removeEntireHooks(stop)\\n   317→\\tuserPromptSubmit = removeEntireHooks(userPromptSubmit)\\n   318→\\tpreToolUse = removeEntireHooksFromMatchers(preToolUse)\\n   319→\\tpostToolUse = removeEntireHooksFromMatchers(postToolUse)\\n   320→\\tpreCompact = removeEntireHooks(preCompact)\\n   321→\\n   322→\\t// Marshal modified hook types back to rawHooks\\n   323→\\tmarshalHookType(rawHooks, \\\"SessionStart\\\", sessionStart)\\n   324→\\tmarshalHookType(rawHooks, \\\"SessionEnd\\\", sessionEnd)\\n   325→\\tmarshalHookType(rawHooks, \\\"Stop\\\", stop)\\n   326→\\tmarshalHookType(rawHooks, \\\"UserPromptSubmit\\\", userPromptSubmit)\\n   327→\\tmarshalHookType(rawHooks, \\\"PreToolUse\\\", preToolUse)\\n   328→\\tmarshalHookType(rawHooks, \\\"PostToolUse\\\", postToolUse)\\n   329→\\tmarshalHookType(rawHooks, \\\"PreCompact\\\", preCompact)\\n   330→\\n   331→\\t// Also remove the metadata deny rule from permissions\\n   332→\\tvar rawPermissions map[string]json.RawMessage\\n   333→\\tif permRaw, ok := rawSettings[\\\"permissions\\\"]; ok {\\n   334→\\t\\tif err := json.Unmarshal(permRaw, &rawPermissions); err != nil {\\n   335→\\t\\t\\t// If parsing fails, just skip permissions cleanup\\n   336→\\t\\t\\trawPermissions = nil\\n   