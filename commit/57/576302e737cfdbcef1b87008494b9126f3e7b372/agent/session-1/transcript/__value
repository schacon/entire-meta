actoryai-droid post-tool-use\\\"\\n   143→\\t\\tpreCompactCmd = \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid pre-compact\\\"\\n   144→\\t} else {\\n   145→\\t\\tsessionStartCmd = \\\"entire hooks factoryai-droid session-start\\\"\\n   146→\\t\\tsessionEndCmd = \\\"entire hooks factoryai-droid session-end\\\"\\n   147→\\t\\tstopCmd = \\\"entire hooks factoryai-droid stop\\\"\\n   148→\\t\\tuserPromptSubmitCmd = \\\"entire hooks factoryai-droid user-prompt-submit\\\"\\n   149→\\t\\tpreTaskCmd = \\\"entire hooks factoryai-droid pre-tool-use\\\"\\n   150→\\t\\tpostTaskCmd = \\\"entire hooks factoryai-droid post-tool-use\\\"\\n   151→\\t\\tpreCompactCmd = \\\"entire hooks factoryai-droid pre-compact\\\"\\n   152→\\t}\\n   153→\\n   154→\\tcount := 0\\n   155→\\n   156→\\t// Add hooks if they don't exist\\n   157→\\tif !hookCommandExists(sessionStart, sessionStartCmd) {\\n   158→\\t\\tsessionStart = addHookToMatcher(sessionStart, \\\"\\\", sessionStartCmd)\\n   159→\\t\\tcount++\\n   160→\\t}\\n   161→\\tif !hookCommandExists(sessionEnd, sessionEndCmd) {\\n   162→\\t\\tsessionEnd = addHookToMatcher(sessionEnd, \\\"\\\", sessionEndCmd)\\n   163→\\t\\tcount++\\n   164→\\t}\\n   165→\\tif !hookCommandExists(stop, stopCmd) {\\n   166→\\t\\tstop = addHookToMatcher(stop, \\\"\\\", stopCmd)\\n   167→\\t\\tcount++\\n   168→\\t}\\n   169→\\tif !hookCommandExists(userPromptSubmit, userPromptSubmitCmd) {\\n   170→\\t\\tuserPromptSubmit = addHookToMatcher(userPromptSubmit, \\\"\\\", userPromptSubmitCmd)\\n   171→\\t\\tcount++\\n   172→\\t}\\n   173→\\tif !hookCommandExistsWithMatcher(preToolUse, \\\"Task\\\", preTaskCmd) {\\n   174→\\t\\tpreToolUse = addHookToMatcher(preToolUse, \\\"Task\\\", preTaskCmd)\\n   175→\\t\\tcount++\\n   176→\\t}\\n   177→\\tif !hookCommandExistsWithMatcher(postToolUse, \\\"Task\\\", postTaskCmd) {\\n   178→\\t\\tpostToolUse = addHookToMatcher(postToolUse, \\\"Task\\\", postTaskCmd)\\n   179→\\t\\tcount++\\n   180→\\t}\\n   18