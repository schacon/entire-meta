he result for debugging.\\n    45→\\tif err != nil {\\n    46→\\t\\tt.Logf(\\\"Agent completed with error (may be expected): %v\\\", err)\\n    47→\\t\\tif result != nil {\\n    48→\\t\\t\\tt.Logf(\\\"Stdout: %s\\\", result.Stdout)\\n    49→\\t\\t\\tt.Logf(\\\"Stderr: %s\\\", result.Stderr)\\n    50→\\t\\t}\\n    51→\\t} else if result != nil {\\n    52→\\t\\tt.Logf(\\\"Agent completed successfully\\\")\\n    53→\\t\\tt.Logf(\\\"Output: %s\\\", result.Stdout)\\n    54→\\t}\\n    55→\\n    56→\\t// Check if the expected file was created (by subagent or main agent)\\n    57→\\tif env.FileExists(\\\"subagent_output.txt\\\") {\\n    58→\\t\\tcontent := env.ReadFile(\\\"subagent_output.txt\\\")\\n    59→\\t\\tt.Logf(\\\"subagent_output.txt content: %s\\\", content)\\n    60→\\t} else {\\n    61→\\t\\tt.Log(\\\"subagent_output.txt was not created - Task tool may not have been used\\\")\\n    62→\\t}\\n    63→\\n    64→\\t// Get rewind points after agent action\\n    65→\\tpointsAfter := env.GetRewindPoints()\\n    66→\\tt.Logf(\\\"Rewind points after: %d\\\", len(pointsAfter))\\n    67→\\n    68→\\t// Log all rewind points for debugging\\n    69→\\tfor i, p := range pointsAfter {\\n    70→\\t\\tt.Logf(\\\"  Point %d: ID=%s, IsTask=%v, ToolUseID=%s, Message=%s\\\",\\n    71→\\t\\t\\ti, safeIDPrefix(p.ID), p.IsTaskCheckpoint, p.ToolUseID, truncateMessage(p.Message, 50))\\n    72→\\t}\\n    73→\\n    74→\\t// Check for task checkpoints\\n    75→\\tvar taskCheckpoints []RewindPoint\\n    76→\\tfor _, p := range pointsAfter {\\n    77→\\t\\tif p.IsTaskCheckpoint {\\n    78→\\t\\t\\ttaskCheckpoints = append(taskCheckpoints, p)\\n    79→\\t\\t}\\n    80→\\t}\\n    81→\\n    82→\\tif len(taskCheckpoints) > 0 {\\n    83→\\t\\tt.Logf(\\\"Found %d task checkpoint(s)\\\", len(taskCheckpoints))\\n    84→\\n    85→\\t\\t// Validate the first task checkpoint\\n    86→\\t\\ttaskCP := taskCheckpoints[0]\\n    87→\\t\\tassert.True(t, taskCP.IsTaskCheckpoint, \\\"Should be marked as task checkpoint\\\")\\n    88→\\t\\tassert.NotEmpty(t, taskCP.ToolUseID, \\\"Task checkpoint should have ToolUseID\\\")\\n    89→\\t\\tassert.True(t, strings.HasPrefix(taskCP.ToolUseID, \\\"toolu_\\\"),\\n    90→\\t\\t\\t\\\"ToolUseID should have expected format: %s\\\", taskCP.ToolUseID)\\n    91→\\n    92→\\t\\tt.Logf(\\\"Task checkpoint validated: ToolUseID=%s\\\", taskCP.ToolUseID)\\n    93→\\t} else {\\n    94→\\t\\t// If no task checkpoints, Claude may have done the work itself without Task tool\\n    95→\\t\\t// This is acceptable behavior - log it for visibility\\n    96→\\t\\tt.Log(\\\"No task checkpoints found - Claude may not have used Task tool\\\")\\n    97→\\t\\tt.Log(\\\"This is acceptable as Claude decides when to use Task tool\\\")\\n    98→\\t}\\n    99→\\n   100→\\t// Verify we have at least one checkpoint (task or regular)\\n   101→\\tassert.GreaterOrEqual(t, len(pointsAfter), 1,\\n   102→\\t\\t\\\"Should have at least one checkpoint after agent action\\\")\\n   103→}\\n   104→\\n   105→// TestE2E_SubagentCheckpoint_CommitFlow tests that task checkpoints are properly\\n   106→// handled when the user commits changes that include subagent-created files.\\n   107→func TestE2E_SubagentCheckpoint_CommitFlow(t *testing.T) {\\n   108→\\tt.Parallel()\\n   109→\\n   110→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   111→\\n   112→\\t// 1. Run prompt that may trigger Task tool\\n   113→\\tt.Log(\\\"Step 1: Running prompt that may use Task tool\\\")\\n   114→\\tresult, err := env.RunAgentWithTools(PromptUseTaskTool.Prompt, []string{\\n   115→\\t\\t\\\"Edit\\\", \\\"Read\\\", \\\"Write\\\", \\\"Bash\\\", \\\"Glob\\\", \\\"Grep\\\", \\\"Task\\\",\\n   116→\\t})\\n   117→\\n   118→\\tif err != nil {\\n   119→\\t\\tt.Logf(\\\"Agent completed with error: %v\\\", err)\\n   120→\\t}\\n   121→\\tif result != nil {\\n   122→\\t\\tt.Logf(\\\"Agent output: %s\\\", truncateMessage(result.Stdout, 200))\\n   123→\\t}\\n   124→\\n   125→\\t// 2. Check what files were created\\n   126→\\tvar filesToCommit []string\\n   127→\\tif env.FileExists(\\\"subagent_output.txt\\\") {\\n   128→\\t\\tfilesToCommit = append(filesToCommit, \\\"subagent_output.txt\\\")\\n   129→\\t\\tt.Log(\\\"Found subagent_output.txt\\\")\\n   130→\\t}\\n   131→\\n   132→\\t// If no files created, the test can't continue meaningfully\\n   133→\\tif len(filesToCommit) == 0 {\\n   134→\\t\\tt.Log(\\\"No files created by agent - skipping commit flow test\\\")\\n   135→\\t\\tt.Log(\\\"This may happen if Task tool wasn't used or failed\\\")\\n   136→\\t\\treturn\\n   137→\\t}\\n   138→\\n   139→\\t// 3. Get rewind points before commit\\n   140→\\tpointsBefore := env.GetRewindPoints()\\n   141→\\ttaskCheckpointsBefore := countTaskCheckpoints(pointsBefore)\\n   142→\\tt.Logf(\\\"Task checkpoints before commit: %d\\\", taskCheckpointsBefore)\\n   143→\\n   144→\\t// 4. Commit the changes\\n   145→\\tt.Log(\\\"Step 2: Committing changes\\\")\\n   146→\\tenv.GitCommitWithShadowHooks(\\\"Add subagent output\\\", filesToCommit...)\\n   147→\\n   148→\\t// 5. Verify checkpoint was created\\n   149→\\tcheckpointID, err := env.GetLatestCheckpointIDFromHistory()\\n   150→\\trequire.NoError(t, err, \\\"Should find checkpoint in commit history\\\")\\n   151→\\tt.Logf(\\\"Checkpoint ID: %s\\\", checkpointID)\\n   152→\\n   153→\\t// 6. Validate checkpoint on metadata branch\\n   154→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   155→\\t\\tCheckpointID:              checkpointID,\\n   156→\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   157→\\t\\tFilesTouched:              filesToCommit,\\n   158→\\t\\tExpectedTranscriptContent: []string{\\\"subagent_output.txt\\\"},\\n   159→\\t})\\n   160→\\n   161→\\t// 7. Verify rewind points after commit\\n   162→\\tpointsAfter := env.GetRewindPoints()\\n   163→\\tt.Logf(\\\"Rewind points after commit: %d\\\", len(pointsAfter))\\n   164→\\n   165→\\t// Check for logs-only point from the commit\\n   166→\\tvar logsOnlyFound bool\\n   167→\\tfor _, p := range pointsAfter {\\n   168→\\t\\tif p.IsLogsOnly {\\n   169→\\t\\t\\tlogsOnlyFound = true\\n   170→\\t\\t\\tt.Logf(\\\"Found logs-only point: %s\\\", safeIDPrefix(p.ID))\\n   171→\\t\\t}\\n   172→\\t}\\n   173→\\tassert.True(t, logsOnlyFound, \\\"Should have logs-only point after commit\\\")\\n   174→}\\n   175→\\n   176→// countTaskCheckpoints counts how many task checkpoints are in the list.\\n   177→func countTaskCheckpoints(points []RewindPoint) int {\\n   178→\\tcount := 0\\n   179→\\tfor _, p := range points {\\n   180→\\t\\tif p.IsTaskCheckpoint {\\n   181→\\t\\t\\tcount++\\n   182→\\t\\t}\\n   183→\\t}\\n   184→\\treturn count\\n   185→}\\n   186→\\n   187→// truncateMessage truncates a message to maxLen characters, adding \\\"...\\\" if truncated.\\n   188→func truncateMessage(msg string, maxLen int) string {\\n   189→\\t// Remove newlines for cleaner logging\\n   190→\\tmsg = strings.ReplaceAll(msg, \\\"\\\\n\\\", \\\" \\\")\\n   191→\\tif len(msg) > maxLen {\\n   192→\\t\\treturn msg[:maxLen] + \\\"...\\\"\\n   193→\\t}\\n   194→\\treturn msg\\n   195→}\\n   196→\"}]},\"uuid\":\"c6097417-912d-4cdb-8895-da7aa18ce70f\",\"timestamp\":\"2026-02-20T11:36:33.776Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Search the entire codebase for patterns where a string is truncated by byte slicing that could split multi-byte UTF-8 characters. Look for patterns like:\\n\\n1. `someString[:N]` where N is a numeric literal and someString is a `string` type (not `[]byte`)\\n2. `someString[:someVar]` followed by or near a length check like `len(someString) > N`\\n\\nSpecifically, I'm looking for Go code that does byte-based truncation of strings that might contain multi-byte characters (like CJK or emoji). The pattern we just fixed was:\\n```go\\nif len(displayPrompt) > 500 {\\n    displayPrompt = displayPrompt[:500] + \\\"...\\\"\\n}\\n```\\n\\nSearch all `.go` files in the repo. Exclude `_test.go` files and `vendor/` directories. For each match found, show the surrounding context (5-10 lines) so I can evaluate if it's a real issue.\\n\\nDo NOT search for byte slice truncation `[]byte` - only string truncation.\",\"agentId\":\"aff647c\"},\"toolUseID\":\"agent_msg_011AUpH86dU5K4ueHuLRiRWR\",\"parentToolUseID\":\"toolu_01KLqyTC9YQNbZrJHAzuJQy7\",\"uuid\":\"428b3485-a533-49b8-a154-0db910d187e4\",\"timestamp\":\"2026-02-20T11:36:33.853Z\"}\n{\"parentUuid\":\"428b3485-a533-49b8-a154-0db910d187e4\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/georgf/src/entire-labs/cli\",\"sessionId\":\"85773b9f-c9f9-4153-ab5d-0e75abb9005a\",\"version\":\"2.1.49\",\"gitBranch\":\"main\",\"slug\":\"cosmic-spinning-glacier\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01WT6tKLjZboQ7x9xAtnKFDn\",\"type\":\"tool_result\",\"content\":\"     1→package strategy\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"encoding/json\\\"\\n     6→\\t\\\"errors\\\"\\n     7→\\t\\\"fmt\\\"\\n     8→\\t\\\"log/slog\\\"\\n     9→\\t\\\"os\\\"\\n    10→\\t\\\"path/filepath\\\"\\n    11→\\t\\\"strings\\\"\\n    12→\\t\\\"sync\\\"\\n    13→\\t\\\"time\\\"\\n    14→\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/buildinfo\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n    22→\\n    23→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    24→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    25→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    26→)\\n    27→\\n    28→// isNotFoundError checks if an error represents a \\\"not found\\\" condition in go-git.\\n    29→// This includes entry not found, file not found, directory not found, and object not found.\\n    30→func isNotFoundError(err error) bool {\\n    31→\\treturn errors.Is(err, object.ErrEntryNotFound) ||\\n    32→\\t\\terrors.Is(err, object.ErrFileNotFound) ||\\n    33→\\t\\terrors.Is(err, object.ErrDirectoryNotFound) ||\\n    34→\\t\\terrors.Is(err, plumbing.ErrObjectNotFound) ||\\n    35→\\t\\terrors.Is(err, plumbing.ErrReferenceNotFound)\\n    36→}\\n    37→\\n    38→// commitOrHead attempts to create a commit. If the commit would be empty (files already\\n    39→// committed), it returns HEAD hash instead. This handles the case where files were\\n    40→// modified during a session but already committed by the user before the hook runs.\\n    41→func commitOrHead(repo *git.Repository, worktree *git.Worktree, msg string, author *object.Signature) (plumbing.Hash, error) {\\n    42→\\tcommitHash, err := worktree.Commit(msg, &git.CommitOptions{Author: author})\\n    43→\\tif errors.Is(err, git.ErrEmptyCommit) {\\n    44→\\t\\tfmt.Fprintf(os.Stderr, \\\"No changes to commit (files already committed)\\\\n\\\")\\n    45→\\t\\thead, err := repo.Head()\\n    46→\\t\\tif err != nil {\\n    47→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n    48→\\t\\t}\\n    49→\\t\\treturn head.Hash(), nil\\n    50→\\t}\\n    51→\\tif err != nil {\\n    52→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to commit: %w\\\", err)\\n    53→\\t}\\n    54→\\treturn commitHash, nil\\n    55→}\\n    56→\\n    57→// AutoCommitStrategy implements the auto-commit strategy:\\n    58→// - Code changes are committed to the active branch (like commit strategy)\\n    59→// - Session logs are committed to a shadow branch (like manual-commit strategy)\\n    60→// - Code commits can reference the shadow branch via trailers\\n    61→type AutoCommitStrategy struct {\\n    62→\\t// checkpointStore manages checkpoint data on entire/checkpoints/v1 branch\\n    63→\\tcheckpointStore *checkpoint.GitStore\\n    64→\\t// checkpointStoreOnce ensures thread-safe lazy initialization\\n    65→\\tcheckpointStoreOnce sync.Once\\n    66→\\t// checkpointStoreErr captures any error during initialization\\n    67→\\tcheckpointStoreErr error\\n    68→}\\n    69→\\n    70→// getCheckpointStore returns the checkpoint store, initializing it lazily if needed.\\n    71→// Thread-safe via sync.Once.\\n    72→func (s *AutoCommitStrategy) getCheckpointStore() (*checkpoint.GitStore, error) {\\n    73→\\ts.checkpointStoreOnce.Do(func() {\\n    74→\\t\\trepo, err := OpenRepository()\\n    75→\\t\\tif err != nil {\\n    76→\\t\\t\\ts.checkpointStoreErr = fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n    77→\\t\\t\\treturn\\n    78→\\t\\t}\\n    79→\\t\\ts.checkpointStore = checkpoint.NewGitStore(repo)\\n    80→\\t})\\n    81→\\treturn s.checkpointStore, s.checkpointStoreErr\\n    82→}\\n    83→\\n    84→// NewAutoCommitStrategy creates a new AutoCommitStrategy instance.\\n    85→//\\n    86→\\n    87→func NewAutoCommitStrategy() Strategy {\\n    88→\\treturn &AutoCommitStrategy{}\\n    89→}\\n    90→\\n    91→func (s *AutoCommitStrategy) Name() string {\\n    92→\\treturn StrategyNameAutoCommit\\n    93→}\\n    94→\\n    95→func (s *AutoCommitStrategy) Description() string {\\n    96→\\treturn \\\"Auto-commits code to active branch with metadata on entire/checkpoints/v1\\\"\\n    97→}\\n    98→\\n    99→func (s *AutoCommitStrategy) ValidateRepository() error {\\n   100→\\trepo, err := OpenRepository()\\n   101→\\tif err != nil {\\n   102→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   103→\\t}\\n   104→\\n   105→\\t_, err = repo.Worktree()\\n   106→\\tif err != nil {\\n   107→\\t\\treturn fmt.Errorf(\\\"failed to access worktree: %w\\\", err)\\n   108→\\t}\\n   109→\\n   110→\\treturn nil\\n   111→}\\n   112→\\n   113→// PrePush is called by the git pre-push hook before pushing to a remote.\\n   114→// It pushes the entire/checkpoints/v1 branch alongside the user's push.\\n   115→// Configuration options (stored in .entire/settings.json under strategy_options.push_sessions):\\n   116→//   - \\\"auto\\\": always push automatically\\n   117→//   - \\\"prompt\\\" (default): ask user with option to enable auto\\n   118→//   - \\\"false\\\"/\\\"off\\\"/\\\"no\\\": never push\\n   119→func (s *AutoCommitStrategy) PrePush(remote string) error {\\n   120→\\treturn pushSessionsBranchCommon(remote, paths.MetadataBranchName)\\n   121→}\\n   122→\\n   123→func (s *AutoCommitStrategy) SaveStep(ctx StepContext) error {\\n   124→\\trepo, err := OpenRepository()\\n   125→\\tif err != nil {\\n   126→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   127→\\t}\\n   128→\\n   129→\\t// Generate checkpoint ID for this commit\\n   130→\\tcpID, err := id.Generate()\\n   131→\\tif err != nil {\\n   132→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   133→\\t}\\n   134→\\t// Step 1: Commit code changes to active branch with checkpoint ID trailer\\n   135→\\t// We do code first to avoid orphaned metadata if this step fails.\\n   136→\\t// If metadata commit fails after this, the code commit exists but GetRewindPoints\\n   137→\\t// already handles missing metadata gracefully (skips commits without metadata).\\n   138→\\tcodeResult, err := s.commitCodeToActive(repo, ctx, cpID)\\n   139→\\tif err != nil {\\n   140→\\t\\treturn fmt.Errorf(\\\"failed to commit code to active branch: %w\\\", err)\\n   141→\\t}\\n   142→\\n   143→\\t// If no code commit was created (no changes), skip metadata creation\\n   144→\\t// This prevents orphaned metadata commits that don't correspond to any code commit\\n   145→\\tif !codeResult.Created {\\n   146→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   147→\\t\\tlogging.Info(logCtx, \\\"checkpoint skipped (no changes)\\\",\\n   148→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n   149→\\t\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"session\\\"),\\n   150→\\t\\t)\\n   151→\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipped checkpoint (no changes since last commit)\\\\n\\\")\\n   152→\\t\\treturn nil\\n   153→\\t}\\n   154→\\n   155→\\t// Step 2: Commit metadata to entire/checkpoints/v1 branch using sharded path\\n   156→\\t// Path is <checkpointID[:2]>/<checkpointID[2:]>/ for direct lookup\\n   157→\\t_, err = s.commitMetadataToMetadataBranch(repo, ctx, cpID)\\n   158→\\tif err != nil {\\n   159→\\t\\treturn fmt.Errorf(\\\"failed to commit metadata to entire/checkpoints/v1 branch: %w\\\", err)\\n   160→\\t}\\n   161→\\n   162→\\t// Log checkpoint creation\\n   163→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   164→\\tlogging.Info(logCtx, \\\"checkpoint saved\\\",\\n   165→\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n   166→\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"session\\\"),\\n   167→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   168→\\t\\tslog.Int(\\\"modified_files\\\", len(ctx.ModifiedFiles)),\\n   169→\\t\\tslog.Int(\\\"new_files\\\", len(ctx.NewFiles)),\\n   170→\\t\\tslog.Int(\\\"deleted_files\\\", len(ctx.DeletedFiles)),\\n   171→\\t)\\n   172→\\n   173→\\treturn nil\\n   174→}\\n   175→\\n   176→// commitCodeResult contains the result of committing code to the active branch.\\n   177→type commitCodeResult struct {\\n   178→\\tCommitHash plumbing.Hash\\n   179→\\tCreated    bool // True if a new commit was created, false if skipped (no changes)\\n   180→}\\n   181→\\n   182→// commitCodeToActive commits code changes to the active branch.\\n   183→// Adds an Entire-Checkpoint trailer for metadata lookup that survives amend/rebase.\\n   184→// Returns the result containing commit hash and whether a commit was created.\\n   185→func (s *AutoCommitStrategy) commitCodeToActive(repo *git.Repository, ctx StepContext, checkpointID id.CheckpointID) (commitCodeResult, error) {\\n   186→\\t// Check if there are any code changes to commit\\n   187→\\tif len(ctx.ModifiedFiles) == 0 && len(ctx.NewFiles) == 0 && len(ctx.DeletedFiles) == 0 {\\n   188→\\t\\tfmt.Fprintf(os.Stderr, \\\"No code changes to commit to active branch\\\\n\\\")\\n   189→\\t\\t// Return current HEAD hash but mark as not created\\n   190→\\t\\thead, err := repo.Head()\\n   191→\\t\\tif err != nil {\\n   192→\\t\\t\\treturn commitCodeResult{}, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   193→\\t\\t}\\n   194→\\t\\treturn commitCodeResult{CommitHash: head.Hash(), Created: false}, nil\\n   195→\\t}\\n   196→\\n   197→\\tworktree, err := repo.Worktree()\\n   198→\\tif err != nil {\\n   199→\\t\\treturn commitCodeResult{}, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   200→\\t}\\n   201→\\n   202→\\t// Get HEAD hash before commit to detect if commitOrHead actually creates a new commit\\n   203→\\t// (commitOrHead returns HEAD hash without error when git.ErrEmptyCommit occurs)\\n   204→\\theadBefore, err := repo.Head()\\n   205→\\tif err != nil {\\n   206→\\t\\treturn commitCodeResult{}, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   207→\\t}\\n   208→\\n   209→\\t// Stage code changes\\n   210→\\tStageFiles(worktree, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles, StageForSession)\\n   211→\\n   212→\\t// Add checkpoint ID trailer to commit message\\n   213→\\tcommitMsg := ctx.CommitMessage + \\\"\\\\n\\\\n\\\" + trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n   214→\\n   215→\\tauthor := &object.Signature{\\n   216→\\t\\tName:  ctx.AuthorName,\\n   217→\\t\\tEmail: ctx.AuthorEmail,\\n   218→\\t\\tWhen:  time.Now(),\\n   219→\\t}\\n   220→\\tcommitHash, err := commitOrHead(repo, worktree, commitMsg, author)\\n   221→\\tif err != nil {\\n   222→\\t\\treturn commitCodeResult{}, err\\n   223→\\t}\\n   224→\\n   225→\\t// Check if a new commit was actually created by comparing with HEAD before\\n   226→\\tcreated := commitHash != headBefore.Hash()\\n   227→\\tif created {\\n   228→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed code changes to active branch (%s)\\\\n\\\", commitHash.String()[:7])\\n   229→\\t}\\n   230→\\treturn commitCodeResult{CommitHash: commitHash, Created: created}, nil\\n   231→}\\n   232→\\n   233→// commitMetadataToMetadataBranch commits session metadata to the entire/checkpoints/v1 branch.\\n   234→// Metadata is stored at sharded path: <checkpointID[:2]>/<checkpointID[2:]>/\\n   235→// This allows direct lookup from the checkpoint ID trailer on the code commit.\\n   236→// Uses checkpoint.WriteCommitted for git operations.\\n   237→func (s *AutoCommitStrategy) commitMetadataToMetadataBranch(repo *git.Repository, ctx StepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n   238→\\tstore, err := s.getCheckpointStore()\\n   239→\\tif err != nil {\\n   240→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   241→\\t}\\n   242→\\n   243→\\t// Extract session ID from metadata dir\\n   244→\\tsessionID := filepath.Base(ctx.MetadataDir)\\n   245→\\n   246→\\t// Get current branch name\\n   247→\\tbranchName := GetCurrentBranchName(repo)\\n   248→\\n   249→\\t// Combine all file changes into FilesTouched (same as manual-commit)\\n   250→\\tfilesTouched := mergeFilesTouched(nil, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles)\\n   251→\\n   252→\\t// Load TurnID from session state (correlates checkpoints from the same turn)\\n   253→\\tvar turnID string\\n   254→\\tif state, loadErr := LoadSessionState(sessionID); loadErr == nil && state != nil {\\n   255→\\t\\tturnID = state.TurnID\\n   256→\\t}\\n   257→\\n   258→\\t// Write committed checkpoint using the checkpoint store\\n   259→\\t// Pass TranscriptPath so writeTranscript generates content_hash.txt\\n   260→\\ttranscriptPath := filepath.Join(ctx.MetadataDirAbs, paths.TranscriptFileName)\\n   261→\\terr = store.WriteCommitted(context.Background(), checkpoint.WriteCommittedOptions{\\n   262→\\t\\tCheckpointID:                checkpointID,\\n   263→\\t\\tSessionID:                   sessionID,\\n   264→\\t\\tStrategy:                    StrategyNameAutoCommit, // Use new strategy name\\n   265→\\t\\tBranch:                      branchName,\\n   266→\\t\\tMetadataDir:                 ctx.MetadataDirAbs, // Copy all files from metadata dir\\n   267→\\t\\tTranscriptPath:              transcriptPath,     // For content hash generation\\n   268→\\t\\tAuthorName:                  ctx.AuthorName,\\n   269→\\t\\tAuthorEmail:                 ctx.AuthorEmail,\\n   270→\\t\\tAgent:                       ctx.AgentType,\\n   271→\\t\\tTurnID:                      turnID,\\n   272→\\t\\tTranscriptIdentifierAtStart: ctx.StepTranscriptIdentifier,\\n   273→\\t\\tCheckpointTranscriptStart:   ctx.StepTranscriptStart,\\n   274→\\t\\tTokenUsage:                  ctx.TokenUsage,\\n   275→\\t\\tCheckpointsCount:            1,            // Each auto-commit checkpoint = 1\\n   276→\\t\\tFilesTouched:                filesTouched, // Track modified files (same as manual-commit)\\n   277→\\t})\\n   278→\\tif err != nil {\\n   279→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write committed checkpoint: %w\\\", err)\\n   280→\\t}\\n   281→\\n   282→\\tfmt.Fprintf(os.Stderr, \\\"Committed session metadata to %s (%s)\\\\n\\\", paths.MetadataBranchName, checkpointID)\\n   283→\\treturn plumbing.ZeroHash, nil // Commit hash not needed by callers\\n   284→}\\n   285→\\n   286→func (s *AutoCommitStrategy) GetRewindPoints(limit int) ([]RewindPoint, error) {\\n   287→\\t// For auto-commit strategy, rewind points are found by looking for Entire-Checkpoint trailers\\n   288→\\t// in the current branch's commit history. The checkpoint ID provides direct lookup\\n   289→\\t// to metadata on entire/checkpoints/v1 branch.\\n   290→\\trepo, err := OpenRepository()\\n   291→\\tif err != nil {\\n   292→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   293→\\t}\\n   294→\\n   295→\\thead, err := repo.Head()\\n   296→\\tif err != nil {\\n   297→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   298→\\t}\\n   299→\\n   300→\\t// Get metadata branch tree for lookups\\n   301→\\tmetadataTree, err := GetMetadataBranchTree(repo)\\n   302→\\tif err != nil {\\n   303→\\t\\t// No metadata branch yet is fine\\n   304→\\t\\treturn []RewindPoint{}, nil //nolint:nilerr // Expected when no metadata exists\\n   305→\\t}\\n   306→\\n   307→\\t// Get the main branch commit hash to determine branch-only commits\\n   308→\\tmainBranchHash := GetMainBranchHash(repo)\\n   309→\\n   310→\\t// Walk current branch history looking for commits with checkpoint trailers\\n   311→\\titer, err := repo.Log(&git.LogOptions{\\n   312→\\t\\tFrom:  head.Hash(),\\n   313→\\t\\tOrder: git.LogOrderCommitterTime,\\n   314→\\t})\\n   315→\\tif err != nil {\\n   316→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   317→\\t}\\n   318→\\n   319→\\tvar points []RewindPoint\\n   320→\\tcount := 0\\n   321→\\n   322→\\terr = iter.ForEach(func(c *object.Commit) error {\\n   323→\\t\\tif count >= logsOnlyScanLimit || len(points) >= limit {\\n   324→\\t\\t\\treturn errStop\\n   325→\\t\\t}\\n   326→\\t\\tcount++\\n   327→\\n   328→\\t\\t// Check for Entire-Checkpoint trailer\\n   329→\\t\\tcpID, found := trailers.ParseCheckpoint(c.Message)\\n   330→\\t\\tif !found {\\n   331→\\t\\t\\treturn nil\\n   332→\\t\\t}\\n   333→\\n   334→\\t\\t// Look up metadata from sharded path\\n   335→\\t\\tcheckpointPath := cpID.Path()\\n   336→\\t\\tmetadata, err := ReadCheckpointMetadata(metadataTree, checkpointPath)\\n   337→\\t\\tif err != nil {\\n   338→\\t\\t\\t// Checkpoint exists in commit but no metadata found - skip this commit\\n   339→\\t\\t\\treturn nil //nolint:nilerr // Intentional: skip commits without metadata\\n   340→\\t\\t}\\n   341→\\n   342→\\t\\tmessage := strings.Split(c.Message, \\\"\\\\n\\\")[0]\\n   343→\\n   344→\\t\\t// Determine if this is a full rewind or logs-only\\n   345→\\t\\t// Full rewind is allowed if commit is only on this branch (not reachable from main)\\n   346→\\t\\tisLogsOnly := false\\n   347→\\t\\tif mainBranchHash != plumbing.ZeroHash {\\n   348→\\t\\t\\tif IsAncestorOf(repo, c.Hash, mainBranchHash) {\\n   349→\\t\\t\\t\\tisLogsOnly = true\\n   350→\\t\\t\\t}\\n   351→\\t\\t}\\n   352→\\n   353→\\t\\t// Build metadata path - for task checkpoints, include the task path\\n   354→\\t\\tmetadataDir := checkpointPath\\n   355→\\t\\tif metadata.IsTask && metadata.ToolUseID != \\\"\\\" {\\n   356→\\t\\t\\tmetadataDir = checkpointPath + \\\"/tasks/\\\" + metadata.ToolUseID\\n   357→\\t\\t}\\n   358→\\n   359→\\t\\t// Read session prompt from metadata tree\\n   360→\\t\\tsessionPrompt := ReadSessionPromptFromTree(metadataTree, checkpointPath)\\n   361→\\n   362→\\t\\tpoints = append(points, RewindPoint{\\n   363→\\t\\t\\tID:               c.Hash.String(),\\n   364→\\t\\t\\tMessage:          message,\\n   365→\\t\\t\\tMetadataDir:      metadataDir,\\n   366→\\t\\t\\tDate:             c.Author.When,\\n   367→\\t\\t\\tIsLogsOnly:       isLogsOnly,\\n   368→\\t\\t\\tCheckpointID:     cpID,\\n   369→\\t\\t\\tIsTaskCheckpoint: metadata.IsTask,\\n   370→\\t\\t\\tToolUseID:        metadata.ToolUseID,\\n   371→\\t\\t\\tAgent:            metadata.Agent,\\n   372→\\t\\t\\tSessionID:        metadata.SessionID,\\n   373→\\t\\t\\tSessionPrompt:    sessionPrompt,\\n   374→\\t\\t})\\n   375→\\n   376→\\t\\treturn nil\\n   377→\\t})\\n   378→\\n   379→\\tif err != nil && !errors.Is(err, errStop) {\\n   380→\\t\\treturn nil, fmt.Errorf(\\\"failed to iterate commits: %w\\\", err)\\n   381→\\t}\\n   382→\\n   383→\\treturn points, nil\\n   384→}\\n   385→\\n   386→// findTaskMetadataPathForCommit looks up the task metadata path for a task checkpoint commit\\n   387→// by searching the entire/checkpoints/v1 branch commit history for the checkpoint directory.\\n   388→// Returns (\\\"\\\", nil) if metadata is not found - this is expected for commits without metadata.\\n   389→func (s *AutoCommitStrategy) findTaskMetadataPathForCommit(repo *git.Repository, commitSHA, toolUseID string) (string, error) {\\n   390→\\t// Get the entire/checkpoints/v1 branch\\n   391→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   392→\\tref, err := repo.Reference(refName, true)\\n   393→\\tif err != nil {\\n   394→\\t\\tif isNotFoundError(err) {\\n   395→\\t\\t\\treturn \\\"\\\", nil // No metadata branch yet\\n   396→\\t\\t}\\n   397→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get metadata branch: %w\\\", err)\\n   398→\\t}\\n   399→\\n   400→\\t// Search commit history for a commit referencing this code commit SHA and tool use ID\\n   401→\\tshortSHA := commitSHA\\n   402→\\tif len(shortSHA) > 7 {\\n   403→\\t\\tshortSHA = shortSHA[:7]\\n   404→\\t}\\n   405→\\n   406→\\titer, err := repo.Log(&git.LogOptions{From: ref.Hash()})\\n   407→\\tif err != nil {\\n   408→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   409→\\t}\\n   410→\\n   411→\\tvar foundTaskPath string\\n   412→\\terr = iter.ForEach(func(commit *object.Commit) error {\\n   413→\\t\\t// Check if commit message contains \\\"Commit: <sha>\\\" and the tool use ID\\n   414→\\t\\tif strings.Contains(commit.Message, \\\"Commit: \\\"+shortSHA) &&\\n   415→\\t\\t\\tstrings.Contains(commit.Message, toolUseID) {\\n   416→\\t\\t\\t// Parse task metadata trailer\\n   417→\\t\\t\\tif taskPath, found := trailers.ParseTaskMetadata(commit.Message); found {\\n   418→\\t\\t\\t\\tfoundTaskPath = taskPath\\n   419→\\t\\t\\t\\treturn errStop // Found it\\n   420→\\t\\t\\t}\\n   421→\\t\\t}\\n   422→\\t\\treturn nil\\n   423→\\t})\\n   424→\\tif err != nil && !errors.Is(err, errStop) {\\n   425→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to iterate commits: %w\\\", err)\\n   426→\\t}\\n   427→\\n   428→\\treturn foundTaskPath, nil\\n   429→}\\n   430→\\n   431→func (s *AutoCommitStrategy) Rewind(point RewindPoint) error {\\n   432→\\tcommitHash := plumbing.NewHash(point.ID)\\n   433→\\tshortID, err := HardResetWithProtection(commitHash)\\n   434→\\tif err != nil {\\n   435→\\t\\treturn err\\n   436→\\t}\\n   437→\\n   438→\\tfmt.Println()\\n   439→\\tfmt.Printf(\\\"Reset to commit %s\\\\n\\\", shortID)\\n   440→\\tfmt.Println()\\n   441→\\n   442→\\treturn nil\\n   443→}\\n   444→\\n   445→func (s *AutoCommitStrategy) CanRewind() (bool, string, error) {\\n   446→\\treturn checkCanRewind()\\n   447→}\\n   448→\\n   449→// PreviewRewind returns what will happen if rewinding to the given point.\\n   450→// For auto-commit strategy, this returns nil since git reset doesn't delete untracked files.\\n   451→func (s *AutoCommitStrategy) PreviewRewind(_ RewindPoint) (*RewindPreview, error) {\\n   452→\\t// Auto-commit uses git reset --hard which doesn't affect untracked files\\n   453→\\t// Return empty preview to indicate no untracked files will be deleted\\n   454→\\treturn &RewindPreview{}, nil\\n   455→}\\n   456→\\n   457→// EnsureSetup ensures the strategy's required setup is in place.\\n   458→// For auto-commit strategy:\\n   459→// - Ensure .entire/.gitignore has all required entries\\n   460→// - Create orphan entire/checkpoints/v1 branch if it doesn't exist\\n   461→// - Install git hooks if missing (self-healing for third-party overwrites)\\n   462→func (s *AutoCommitStrategy) EnsureSetup() error {\\n   463→\\tif err := EnsureEntireGitignore(); err != nil {\\n   464→\\t\\treturn err\\n   465→\\t}\\n   466→\\n   467→\\trepo, err := OpenRepository()\\n   468→\\tif err != nil {\\n   469→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   470→\\t}\\n   471→\\n   472→\\t// Ensure the entire/checkpoints/v1 orphan branch exists\\n   473→\\tif err := EnsureMetadataBranch(repo); err != nil {\\n   474→\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n   475→\\t}\\n   476→\\n   477→\\t// Install generic hooks if missing (they delegate to strategy at runtime)\\n   478→\\tif !IsGitHookInstalled() {\\n   479→\\t\\tif _, err := InstallGitHook(true); err != nil {\\n   480→\\t\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   481→\\t\\t}\\n   482→\\t}\\n   483→\\n   484→\\treturn nil\\n   485→}\\n   486→\\n   487→// GetSessionInfo returns session information for linking commits.\\n   488→// For auto-commit strategy, we don't track active sessions - metadata is stored on\\n   489→// entire/checkpoints/v1 branch when SaveStep is called. Active branch commits\\n   490→// are kept clean (no trailers), so this returns ErrNoSession.\\n   491→// Use ListSessions() or GetSession() to retrieve session info from the metadata branch.\\n   492→func (s *AutoCommitStrategy) GetSessionInfo() (*SessionInfo, error) {\\n   493→\\t// Dual strategy doesn't track active sessions like shadow does.\\n   494→\\t// Session metadata is stored on entire/checkpoints/v1 branch and can be\\n   495→\\t// retrieved via ListSessions() or GetSession().\\n   496→\\treturn nil, ErrNoSession\\n   497→}\\n   498→\\n   499→// SaveTaskStep creates a checkpoint commit for a completed task.\\n   500→// For auto-commit strategy:\\n   501→// 1. Commit code changes to active branch (no trailers - clean history)\\n   502→// 2. Commit task metadata to entire/checkpoints/v1 branch with checkpoint format\\n   503→func (s *AutoCommitStrategy) SaveTaskStep(ctx TaskStepContext) error {\\n   504→\\trepo, err := OpenRepository()\\n   505→\\tif err != nil {\\n   506→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   507→\\t}\\n   508→\\n   509→\\t// Ensure entire/checkpoints/v1 branch exists\\n   510→\\tif err := EnsureMetadataBranch(repo); err != nil {\\n   511→\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n   512→\\t}\\n   513→\\n   514→\\t// Generate checkpoint ID for this task checkpoint\\n   515→\\tcpID, err := id.Generate()\\n   516→\\tif err != nil {\\n   517→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   518→\\t}\\n   519→\\n   520→\\t// Step 1: Commit code changes to active branch with checkpoint ID trailer\\n   521→\\t// We do code first to avoid orphaned metadata if this step fails.\\n   522→\\t_, err = s.commitTaskCodeToActive(repo, ctx, cpID)\\n   523→\\tif err != nil {\\n   524→\\t\\treturn fmt.Errorf(\\\"failed to commit task code to active branch: %w\\\", err)\\n   525→\\t}\\n   526→\\n   527→\\t// Step 2: Commit task metadata to entire/checkpoints/v1 branch at sharded path\\n   528→\\t_, err = s.commitTaskMetadataToMetadataBranch(repo, ctx, cpID)\\n   529→\\tif err != nil {\\n   530→\\t\\treturn fmt.Errorf(\\\"failed to commit task metadata to entire/checkpoints/v1 branch: %w\\\", err)\\n   531→\\t}\\n   532→\\n   533→\\t// Log task checkpoint creation\\n   534→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   535→\\tattrs := []any{\\n   536→\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n   537→\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"task\\\"),\\n   538→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   539→\\t\\tslog.String(\\\"checkpoint_uuid\\\", ctx.CheckpointUUID),\\n   540→\\t\\tslog.String(\\\"tool_use_id\\\", ctx.ToolUseID),\\n   541→\\t\\tslog.String(\\\"subagent_type\\\", ctx.SubagentType),\\n   542→\\t\\tslog.Int(\\\"modified_files\\\", len(ctx.ModifiedFiles)),\\n   543→\\t\\tslog.Int(\\\"new_files\\\", len(ctx.NewFiles)),\\n   544→\\t\\tslog.Int(\\\"deleted_files\\\", len(ctx.DeletedFiles)),\\n   545→\\t}\\n   546→\\tif ctx.IsIncremental {\\n   547→\\t\\tattrs = append(attrs,\\n   548→\\t\\t\\tslog.Bool(\\\"is_incremental\\\", true),\\n   549→\\t\\t\\tslog.String(\\\"incremental_type\\\", ctx.IncrementalType),\\n   550→\\t\\t\\tslog.Int(\\\"incremental_sequence\\\", ctx.IncrementalSequence),\\n   551→\\t\\t)\\n   552→\\t}\\n   553→\\tlogging.Info(logCtx, \\\"task checkpoint saved\\\", attrs...)\\n   554→\\n   555→\\treturn nil\\n   556→}\\n   557→\\n   558→// commitTaskCodeToActive commits task code changes to the active branch.\\n   559→// Adds an Entire-Checkpoint trailer for metadata lookup that survives amend/rebase.\\n   560→// Skips commit creation if there are no file changes.\\n   561→func (s *AutoCommitStrategy) commitTaskCodeToActive(repo *git.Repository, ctx TaskStepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n   562→\\thasFileChanges := len(ctx.ModifiedFiles) > 0 || len(ctx.NewFiles) > 0 || len(ctx.DeletedFiles) > 0\\n   563→\\n   564→\\t// If no file changes, skip code commit\\n   565→\\tif !hasFileChanges {\\n   566→\\t\\tfmt.Fprintf(os.Stderr, \\\"No code changes to commit for task checkpoint\\\\n\\\")\\n   567→\\t\\t// Return current HEAD hash so metadata can still be stored\\n   568→\\t\\thead, err := repo.Head()\\n   569→\\t\\tif err != nil {\\n   570→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   571→\\t\\t}\\n   572→\\t\\treturn head.Hash(), nil\\n   573→\\t}\\n   574→\\n   575→\\tworktree, err := repo.Worktree()\\n   576→\\tif err != nil {\\n   577→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   578→\\t}\\n   579→\\n   580→\\t// Stage code changes\\n   581→\\tStageFiles(worktree, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles, StageForTask)\\n   582→\\n   583→\\t// Build commit message with checkpoint trailer\\n   584→\\tshortToolUseID := ctx.ToolUseID\\n   585→\\tif len(shortToolUseID) > id.ShortIDLength {\\n   586→\\t\\tshortToolUseID = shortToolUseID[:id.ShortIDLength]\\n   587→\\t}\\n   588→\\n   589→\\tvar subject string\\n   590→\\tif ctx.IsIncremental {\\n   591→\\t\\tsubject = FormatIncrementalSubject(\\n   592→\\t\\t\\tctx.IncrementalType,\\n   593→\\t\\t\\tctx.SubagentType,\\n   594→\\t\\t\\tctx.TaskDescription,\\n   595→\\t\\t\\tctx.TodoContent,\\n   596→\\t\\t\\tctx.IncrementalSequence,\\n   597→\\t\\t\\tshortToolUseID,\\n   598→\\t\\t)\\n   599→\\t} else {\\n   600→\\t\\tsubject = FormatSubagentEndMessage(ctx.SubagentType, ctx.TaskDescription, shortToolUseID)\\n   601→\\t}\\n   602→\\n   603→\\t// Add checkpoint ID trailer to commit message\\n   604→\\tcommitMsg := subject + \\\"\\\\n\\\\n\\\" + trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n   605→\\n   606→\\tauthor := &object.Signature{\\n   607→\\t\\tName:  ctx.AuthorName,\\n   608→\\t\\tEmail: ctx.AuthorEmail,\\n   609→\\t\\tWhen:  time.Now(),\\n   610→\\t}\\n   611→\\n   612→\\tcommitHash, err := commitOrHead(repo, worktree, commitMsg, author)\\n   613→\\tif err != nil {\\n   614→\\t\\treturn plumbing.ZeroHash, err\\n   615→\\t}\\n   616→\\n   617→\\tif ctx.IsIncremental {\\n   618→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed incremental checkpoint #%d to active branch (%s)\\\\n\\\", ctx.IncrementalSequence, commitHash.String()[:7])\\n   619→\\t} else {\\n   620→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed task checkpoint to active branch (%s)\\\\n\\\", commitHash.String()[:7])\\n   621→\\t}\\n   622→\\treturn commitHash, nil\\n   623→}\\n   624→\\n   625→// commitTaskMetadataToMetadataBranch commits task metadata to the entire/checkpoints/v1 branch.\\n   626→// Uses sharded path: <checkpointID[:2]>/<checkpointID[2:]>/tasks/<tool-use-id>/\\n   627→// Returns the metadata commit hash.\\n   628→// When IsIncremental is true, only writes the incremental checkpoint file, skipping transcripts.\\n   629→// Uses checkpoint.WriteCommitted for git operations.\\n   630→func (s *AutoCommitStrategy) commitTaskMetadataToMetadataBranch(repo *git.Repository, ctx TaskStepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n   631→\\tstore, err := s.getCheckpointStore()\\n   632→\\tif err != nil {\\n   633→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   634→\\t}\\n   635→\\n   636→\\t// Format commit subject line for better git log readability\\n   637→\\tshortToolUseID := ctx.ToolUseID\\n   638→\\tif len(shortToolUseID) > id.ShortIDLength {\\n   639→\\t\\tshortToolUseID = shortToolUseID[:id.ShortIDLength]\\n   640→\\t}\\n   641→\\n   642→\\tvar messageSubject string\\n   643→\\tif ctx.IsIncremental {\\n   644→\\t\\tmessageSubject = FormatIncrementalSubject(\\n   645→\\t\\t\\tctx.IncrementalType,\\n   646→\\t\\t\\tctx.SubagentType,\\n   647→\\t\\t\\tctx.TaskDescription,\\n   648→\\t\\t\\tctx.TodoContent,\\n   649→\\t\\t\\tctx.IncrementalSequence,\\n   650→\\t\\t\\tshortToolUseID,\\n   651→\\t\\t)\\n   652→\\t} else {\\n   653→\\t\\tmessageSubject = FormatSubagentEndMessage(ctx.SubagentType, ctx.TaskDescription, shortToolUseID)\\n   654→\\t}\\n   655→\\n   656→\\t// Get current branch name\\n   657→\\tbranchName := GetCurrentBranchName(repo)\\n   658→\\n   659→\\t// Write committed checkpoint using the checkpoint store\\n   660→\\terr = store.WriteCommitted(context.Background(), checkpoint.WriteCommittedOptions{\\n   661→\\t\\tCheckpointID:           checkpointID,\\n   662→\\t\\tSessionID:              ctx.SessionID,\\n   663→\\t\\tStrategy:               StrategyNameAutoCommit,\\n   664→\\t\\tBranch:                 branchName,\\n   665→\\t\\tIsTask:                 true,\\n   666→\\t\\tToolUseID:              ctx.ToolUseID,\\n   667→\\t\\tAgentID:                ctx.AgentID,\\n   668→\\t\\tCheckpointUUID:         ctx.CheckpointUUID,\\n   669→\\t\\tTranscriptPath:         ctx.TranscriptPath,\\n   670→\\t\\tSubagentTranscriptPath: ctx.SubagentTranscriptPath,\\n   671→\\t\\tIsIncremental:          ctx.IsIncremental,\\n   672→\\t\\tIncrementalSequence:    ctx.IncrementalSequence,\\n   673→\\t\\tIncrementalType:        ctx.IncrementalType,\\n   674→\\t\\tIncrementalData:        ctx.IncrementalData,\\n   675→\\t\\tCommitSubject:          messageSubject,\\n   676→\\t\\tAuthorName:             ctx.AuthorName,\\n   677→\\