 718→\\tif err != nil {\\n   719→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata tree: %w\\\", err)\\n   720→\\t}\\n   721→\\n   722→\\t// Find checkpoint using the metadata path from rewind point\\n   723→\\t// MetadataDir for auto-commit task checkpoints is: cond-YYYYMMDD-HHMMSS-XXXXXXXX/tasks/<tool-use-id>\\n   724→\\tcheckpointPath := point.MetadataDir + \\\"/checkpoint.json\\\"\\n   725→\\tfile, err := tree.File(checkpointPath)\\n   726→\\tif err != nil {\\n   727→\\t\\t// Try finding via commit SHA lookup\\n   728→\\t\\ttaskCheckpointPath, findErr := s.findTaskCheckpointPath(repo, point.ID, point.ToolUseID)\\n   729→\\t\\tif findErr != nil {\\n   730→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", checkpointPath, err)\\n   731→\\t\\t}\\n   732→\\t\\tfile, err = tree.File(taskCheckpointPath)\\n   733→\\t\\tif err != nil {\\n   734→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", taskCheckpointPath, err)\\n   735→\\t\\t}\\n   736→\\t}\\n   737→\\n   738→\\tcontent, err := file.Contents()\\n   739→\\tif err != nil {\\n   740→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   741→\\t}\\n   742→\\n   743→\\tvar checkpoint TaskCheckpoint\\n   744→\\tif err := json.Unmarshal([]byte(content), &checkpoint); err != nil {\\n   745→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse checkpoint: %w\\\", err)\\n   746→\\t}\\n   747→\\n   748→\\treturn &checkpoint, nil\\n   749→}\\n   750→\\n   751→// GetTaskCheckpointTranscript returns the session transcript for a task checkpoint.\\n   752→// For auto-commit strategy, transcripts are stored on the entire/checkpoints/v1 branch in checkpoint directories.\\n   753→// Returns ErrNotTaskCheckpoint if the point is not a task checkpoint.\\n   754→func (s *AutoCommitStrategy) GetTaskCheckpointTranscript(point RewindPoint) ([]byte, error) {\\n   755→\\tif !point.IsTaskCheckpoint {\\n   756→\\t\\treturn nil, ErrNotTaskCheckpoint\\n   757→\\t}\\n 