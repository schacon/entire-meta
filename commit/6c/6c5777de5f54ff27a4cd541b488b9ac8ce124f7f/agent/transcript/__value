\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, err\\n\\t\\t}\\n\\t\\t// Export the transcript to ensure it exists for mid-turn commits.\\n\\t\\t// Without this, if the agent commits during its turn (before turn-end),\\n\\t\\t// the post-commit hook would fail to read the transcript for condensation.\\n\\t\\ttranscriptPath, exportErr := a.fetchAndCacheExport(raw.SessionID)\\n\\t\\tif exportErr != nil {\\n\\t\\t\\t// Non-fatal: fall back to computed path. The file may be created later\\n\\t\\t\\t// by turn-end, or condensation will fail gracefully.\\n\\t\\t\\trepoRoot, _ := paths.RepoRoot()\\n\\t\\t\\tif repoRoot == \\\"\\\" {\\n\\t\\t\\t\\trepoRoot = \\\".\\\"\\n\\t\\t\\t}\\n\\t\\t\\ttmpDir := filepath.Join(repoRoot, paths.EntireTmpDir)\\n\\t\\t\\ttranscriptPath = filepath.Join(tmpDir, raw.SessionID+\\\".json\\\")\\n\\t\\t}\\n\\t\\treturn &agent.Event{\\n\\t\\t\\tType:       agent.TurnStart,\\n\\t\\t\\tSessionID:  raw.SessionID,\\n\\t\\t\\tSessionRef: transcriptPath,\\n\\t\\t\\tPrompt:     raw.Prompt,\\n\\t\\t\\tTimestamp:  time.Now(),\\n\\t\\t}, nil\\n\\n\\tcase HookNameTurnEnd:\\n\\t\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, err\\n\\t\\t}\\n\\t\\t// Call `opencode export` to get the transcript and write to temp file\\n\\t\\ttranscriptPath, exportErr := a.fetchAndCacheExport(raw.SessionID)\\n\\t\\tif exportErr != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to export session: %w\\\", exportErr)\\n\\t\\t}\\n\\t\\treturn &agent.Event{\\n\\t\\t\\tType:       agent.TurnEnd,\\n\\t\\t\\tSessionID:  raw.SessionID,\\n\\t\\t\\tSessionRef: transcriptPath,\\n\\t\\t\\tTimestamp:  time.Now(),\\n\\t\\t}, nil\\n\\n\\tcase HookNameCompaction:\\n\\t\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, err\\n\\t\\t}\\n\\t\\treturn &agent.Event{\\n\\t\\t\\tType:      agent.Compaction,\\n\\t\\t\\tSessionID: raw.SessionID,\\n\\t\\t\\tTimestamp: time.Now