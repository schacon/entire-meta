\n   859→\\tcmd := exec.Command(\\\"git\\\", \\\"checkout\\\", \\\"--\\\", path)\\n   860→\\tcmd.Dir = env.RepoDir\\n   861→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   862→\\t\\tenv.T.Fatalf(\\\"git checkout -- %s failed: %v\\\\nOutput: %s\\\", path, err, output)\\n   863→\\t}\\n   864→}\\n   865→\\n   866→// DeleteFile removes a file from the test repo.\\n   867→func (env *TestEnv) DeleteFile(path string) {\\n   868→\\tenv.T.Helper()\\n   869→\\n   870→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   871→\\tif err := os.Remove(fullPath); err != nil {\\n   872→\\t\\tenv.T.Fatalf(\\\"failed to delete file %s: %v\\\", path, err)\\n   873→\\t}\\n   874→}\\n   875→\\n   876→// GetCommitCount returns the number of commits on the current branch.\\n   877→func (env *TestEnv) GetCommitCount() int {\\n   878→\\tenv.T.Helper()\\n   879→\\n   880→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   881→\\tif err != nil {\\n   882→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   883→\\t}\\n   884→\\n   885→\\thead, err := repo.Head()\\n   886→\\tif err != nil {\\n   887→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   888→\\t}\\n   889→\\n   890→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   891→\\tif err != nil {\\n   892→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   893→\\t}\\n   894→\\n   895→\\tcount := 0\\n   896→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   897→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   898→\\t\\tcount++\\n   899→\\t\\treturn nil\\n   900→\\t})\\n   901→\\n   902→\\treturn count\\n   903→}\\n   904→\\n   905→// GetAllCheckpointIDsFromHistory walks backwards from HEAD and returns\\n   906→// all checkpoint IDs from commits with Entire-Checkpoint trailers.\\n   907→func (env *TestEnv) GetAllCheckpointIDsFromHistory() []string {\\n   908→\\tenv.T.Helper()\\n   909→\\n   910→\\trepo, err := git.PlainOpen(env.