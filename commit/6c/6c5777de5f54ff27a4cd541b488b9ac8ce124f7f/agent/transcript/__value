ach commit should have its own unique checkpoint ID (1:1 model)\\n    75→\\tif len(checkpointIDs) >= 3 {\\n    76→\\t\\t// Verify checkpoint IDs are unique\\n    77→\\t\\tidSet := make(map[string]bool)\\n    78→\\t\\tfor _, id := range checkpointIDs {\\n    79→\\t\\t\\trequire.Falsef(t, idSet[id], \\\"Checkpoint IDs should be unique: %s is duplicated\\\", id)\\n    80→\\t\\t\\tidSet[id] = true\\n    81→\\t\\t}\\n    82→\\t}\\n    83→\\n    84→\\t// Verify metadata branch exists\\n    85→\\tassert.True(t, env.BranchExists(\\\"entire/checkpoints/v1\\\"),\\n    86→\\t\\t\\\"entire/checkpoints/v1 branch should exist\\\")\\n    87→\\n    88→\\t// Validate each checkpoint has proper metadata and content\\n    89→\\t// Note: checkpointIDs are in reverse chronological order (newest first)\\n    90→\\t// So checkpointIDs[0] = file3.go, [1] = file2.go, [2] = file1.go\\n    91→\\t//\\n    92→\\t// With deferred finalization, all checkpoints from the same turn get the\\n    93→\\t// FULL transcript at turn end, so all checkpoints should contain all file names.\\n    94→\\tallFiles := []string{\\\"file1.go\\\", \\\"file2.go\\\", \\\"file3.go\\\"}\\n    95→\\tfor i, cpID := range checkpointIDs {\\n    96→\\t\\tfileNum := len(checkpointIDs) - i // Reverse the index to match file numbers\\n    97→\\t\\tfileName := fmt.Sprintf(\\\"file%d.go\\\", fileNum)\\n    98→\\t\\tt.Logf(\\\"Validating checkpoint %d: %s (files_touched: %s)\\\", i, cpID, fileName)\\n    99→\\t\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   100→\\t\\t\\tCheckpointID:              cpID,\\n   101→\\t\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   102→\\t\\t\\tFilesTouched:              []string{fileName},\\n   103→\\t\\t\\tExpectedTranscriptContent: allFiles, // All checkpoints have full transcript\\n   104→\\t\\t})\\n   105→\\t}\\n   106→\\n   107→\\t// No shadow branches should remain after agent committed all files\\n   108→\\tentireBranches := env.ListBranchesWithPrefix(\\\"entire/\\\")\\n   109→\\tfor _, b := range entireBranches {\\n   110→\\t\\tassert.Equal(t, \\\"entire/checkpoints/v1\\\", b,\\n   111→\\t\\t\\t\\\"Unexpected shadow branch after all files committed: %s\\\", b)\\n   112→\\t}\\n   113→}\\n   114→\\n   115→// TestE2E_Scenario4_UserSplitsCommits tests user splitting agent changes into multiple commits.\\n   116→//\\n   117→// Scenario 4: User Splits Changes Into Multiple Commits\\n   118→// - Agent makes changes to multiple files\\n   119→// - User commits only some files first\\n   120→// - Uncommitted files are carried forward\\n   121→// - User commits remaining files later\\n   122→// - Each commit gets its own checkpoint ID\\n   123→func TestE2E_Scenario4_UserSplitsCommits(t *testing.T) {\\n   124→\\tt.Parallel()\\n   125→\\n   126→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   127→\\n   128→\\t// Agent creates multiple files in one prompt\\n   129→\\tmultiFilePrompt := `Create these files:\\n   130→1. fileA.go with content: package main; func A() string { return \\\"A\\\" }\\n   131→2. fileB.go with content: package main; func B() string { return \\\"B\\\" }\\n   132→3. fileC.go with content: package main; func C() string { return \\\"C\\\" }\\n   133→4. fileD.go with content: package main; func D() string { return \\\"D\\\" }\\n   134→\\n   135→Create all four files, no other files or actions.`\\n   136→\\n   137→\\tresult, err := env.RunAgent(multiFilePrompt)\\n   138→\\trequire.NoError(t, err)\\n   139→\\tAssertAgentSuccess(t, result, err)\\n   140→\\n   141→\\t// Verify all files were created\\n   142→\\tassert.True(t, env.FileExists(\\\"fileA.go\\\"), \\\"fileA.go should exist\\\")\\n   143→\\tassert.True(t, env.FileExists(\\\"fileB.go\\\"), \\\"fileB.go should exist\\\")\\n   144→\\tassert.True(t, env.FileExists(\\\"fileC.go\\\"), \\\"fileC.go should exist\\\")\\n   145→\\tassert.True(t, env.FileExists(\\\"fileD.go\\\"), \\\"fileD.go should exist\\\")\\n   146→\\n   147→\\t// Check rewind points before commit\\n   148→\\tpointsBefore := env.GetRewindPoints()\\n   149→\\tt.Logf(\\\"Rewind points before commit: %d\\\", len(pointsBefore))\\n   150→\\n   151→\\t// User commits only A, B first\\n   152→\\tt.Log(\\\"Committing fileA.go and fileB.go only\\\")\\n   153→\\tenv.GitCommitWithShadowHooks(\\\"Add files A and B\\\", \\\"fileA.go\\\", \\\"fileB.go\\\")\\n   154→\\n   155→\\t// Verify first checkpoint was created\\n   156→\\tcheckpointIDsAfterFirstCommit := env.GetAllCheckpointIDsFromHistory()\\n   157→\\trequire.GreaterOrEqual(t, len(checkpointIDsAfterFirstCommit), 1, \\\"Should have first checkpoint\\\")\\n   158→\\t// Note: GetAllCheckpointIDsFromHistory returns IDs in reverse chronological order (newest first)\\n   159→\\tcheckpointAB := checkpointIDsAfterFirstCommit[0]\\n   160→\\tt.Logf(\\\"Checkpoint for A,B commit: %s\\\", checkpointAB)\\n   161→\\n   162→\\t// Check rewind points - should still have points for uncommitted files\\n   163→\\tpointsAfterFirst := env.GetRewindPoints()\\n   164→\\tt.Logf(\\\"Rewind points after first commit: %d\\\", len(pointsAfterFirst))\\n   165→\\n   166→\\t// User commits C, D later\\n   167→\\tt.Log(\\\"Committing fileC.go and fileD.go\\\")\\n   168→\\tenv.GitCommitWithShadowHooks(\\\"Add files C and D\\\", \\\"fileC.go\\\", \\\"fileD.go\\\")\\n   169→\\n   170→\\t// Verify second checkpoint was created with different ID\\n   171→\\tcheckpointIDsAfterSecondCommit := env.GetAllCheckpointIDsFromHistory()\\n   172→\\trequire.GreaterOrEqual(t, len(checkpointIDsAfterSecondCommit), 2, \\\"Should have two checkpoints\\\")\\n   173→\\tcheckpointCD := checkpointIDsAfterSecondCommit[0] // Most recent (C,D commit) is first\\n   174→\\tt.Logf(\\\"Checkpoint for C,D commit: %s\\\", checkpointCD)\\n   175→\\n   176→\\t// Each commit should have its own unique checkpoint ID (1:1 model)\\n   177→\\tassert.NotEqual(t, checkpointAB, checkpointCD,\\n   178→\\t\\t\\\"Each commit should have its own unique checkpoint ID\\\")\\n   179→\\n   180→\\t// Verify metadata branch exists\\n   181→\\tassert.True(t, env.BranchExists(\\\"entire/checkpoints/v1\\\"),\\n   182→\\t\\t\\\"entire/checkpoints/v1 branch should exist\\\")\\n   183→\\n   184→\\t// Both checkpoints are from the same session where agent created all 4 files.\\n   185→\\t// The transcript should contain all file names since it's the same agent work.\\n   186→\\tallFiles := []string{\\\"fileA.go\\\", \\\"fileB.go\\\", \\\"fileC.go\\\", \\\"fileD.go\\\"}\\n   187→\\n   188→\\t// Validate first checkpoint (files A, B committed)\\n   189→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   190→\\t\\tCheckpointID:              checkpointAB,\\n   191→\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   192→\\t\\tFilesTouched:              []string{\\\"fileA.go\\\", \\\"fileB.go\\\"},\\n   193→\\t\\tExpectedTranscriptContent: allFiles, // Full session transcript\\n   194→\\t})\\n   195→\\n   196→\\t// Validate second checkpoint (files C, D committed)\\n   197→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   198→\\t\\tCheckpointID:              checkpointCD,\\n   199→\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   200→\\t\\tFilesTouched:              []string{\\\"fileC.go\\\", \\\"fileD.go\\\"},\\n   201→\\t\\tExpectedTranscriptContent: allFiles, // Full session transcript\\n   202→\\t})\\n   203→\\n   204→\\t// CRITICAL: After all carry-forward files are committed, no shadow branches\\n   205→\\t// should remain. Only entire/checkpoints/v1 should exist. Extra shadow\\n   206→\\t// branches (entire/<hash>-<hash>) indicate a regression in carry-forward cleanup.\\n   207→\\tentireBranches := env.ListBranchesWithPrefix(\\\"entire/\\\")\\n   208→\\tfor _, b := range entireBranches {\\n   209→\\t\\tassert.Equal(t, \\\"entire/checkpoints/v1\\\", b,\\n   210→\\t\\t\\t\\\"Unexpected shadow branch after all files committed: %s\\\", b)\\n   211→\\t}\\n   212→\\tt.Logf(\\\"Entire branches after all commits: %v\\\", entireBranches)\\n   213→}\\n   214→\\n   215→// TestE2E_Scenario5_PartialCommitStashNextPrompt tests partial commit, stash, then new prompt.\\n   216→//\\n   217→// Scenario 5: Partial Commit → Stash → Next Prompt\\n   218→// - Agent makes changes to A, B, C\\n   219→// - User commits A only\\n   220→// - User stashes B, C\\n   221→// - User runs another prompt (creates D, E)\\n   222→// - User commits D, E\\n   223→// - FilesTouched accumulates across prompts\\n   224→func TestE2E_Scenario5_PartialCommitStashNextPrompt(t *testing.T) {\\n   225→\\tt.Parallel()\\n   226→\\n   227→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   228→\\n   229→\\t// Prompt 1: Agent creates files A, B, C\\n   230→\\tt.Log(\\\"Prompt 1: Creating files A, B, C\\\")\\n   231→\\tprompt1 := `Create these files:\\n   232→1. stash_a.go with content: package main; func StashA() {}\\n   233→2. stash_b.go with content: package main; func StashB() {}\\n   234→3. stash_c.go with content: package main; func StashC() {}\\n   235→Create all three files, nothing else.`\\n   236→\\n   237→\\tresult, err := env.RunAgent(prompt1)\\n   238→\\trequire.NoError(t, err)\\n   239→\\tAssertAgentSuccess(t, result, err)\\n   240→\\n   241→\\trequire.True(t, env.FileExists(\\\"stash_a.go\\\"))\\n   242→\\trequire.True(t, env.FileExists(\\\"stash_b.go\\\"))\\n   243→\\trequire.True(t, env.FileExists(\\\"stash_c.go\\\"))\\n   244→\\n   245→\\t// User commits A only\\n   246→\\tt.Log(\\\"Committing stash_a.go only\\\")\\n   247→\\tenv.GitCommitWithShadowHooks(\\\"Add stash_a\\\", \\\"stash_a.go\\\")\\n   248→\\n   249→\\t// User stashes B, C\\n   250→\\tt.Log(\\\"Stashing remaining files\\\")\\n   251→\\tenv.GitStash()\\n   252→\\n   253→\\t// Verify B, C are no longer in working directory\\n   254→\\tassert.False(t, env.FileExists(\\\"stash_b.go\\\"), \\\"stash_b.go should be stashed\\\")\\n   255→\\tassert.False(t, env.FileExists(\\\"stash_c.go\\\"), \\\"stash_c.go should be stashed\\\")\\n   256→\\n   257→\\t// Prompt 2: Agent creates