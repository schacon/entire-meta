nces()\\n   633→\\tif err != nil {\\n   634→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   635→\\t}\\n   636→\\n   637→\\tfound := false\\n   638→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   639→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   640→\\t\\tif ref.Name().Short() == branchName {\\n   641→\\t\\t\\tfound = true\\n   642→\\t\\t}\\n   643→\\t\\treturn nil\\n   644→\\t})\\n   645→\\n   646→\\treturn found\\n   647→}\\n   648→\\n   649→// ListBranchesWithPrefix returns all branches that start with the given prefix.\\n   650→func (env *TestEnv) ListBranchesWithPrefix(prefix string) []string {\\n   651→\\tenv.T.Helper()\\n   652→\\n   653→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   654→\\tif err != nil {\\n   655→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   656→\\t}\\n   657→\\n   658→\\trefs, err := repo.References()\\n   659→\\tif err != nil {\\n   660→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   661→\\t}\\n   662→\\n   663→\\tvar branches []string\\n   664→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   665→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   666→\\t\\tname := ref.Name().Short()\\n   667→\\t\\tif strings.HasPrefix(name, prefix) {\\n   668→\\t\\t\\tbranches = append(branches, name)\\n   669→\\t\\t}\\n   670→\\t\\treturn nil\\n   671→\\t})\\n   672→\\n   673→\\treturn branches\\n   674→}\\n   675→\\n   676→// GetCommitMessage returns the commit message for the given commit hash.\\n   677→func (env *TestEnv) GetCommitMessage(hash string) string {\\n   678→\\tenv.T.Helper()\\n   679→\\n   680→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   681→\\tif err != nil {\\n   682→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   683→\\t}\\n   684→\\n   685→\\tcommitHash := plumbing.NewHash(hash)\\n   686→\\tcommit, err := repo.CommitObject(commitHash)\\n   687→\\tif err != nil {\\n   688→\\t\\tenv.T.Fatalf(\\\"failed to get commit %s: %v\\\", hash, err)\\n   689→\\t}\\n   690→\\n   691→\\treturn commit.Message\\n   692→}\\n   693→\\n   694→// GetLatestCheckpointIDFromHistory walks backwards from HEAD and returns\\n   695→// the checkpoint ID from the first commit with an Entire-Checkpoint trailer.\\n   696→// Returns an error if no checkpoint trailer is found in any commit.\\n   697→func (env *TestEnv) GetLatestCheckpointIDFromHistory() (string, error) {\\n   698→\\tenv.T.Helper()\\n   699→\\n   700→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   701→\\tif err != nil {\\n   702→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   703→\\t}\\n   704→\\n   705→\\thead, err := repo.Head()\\n   706→\\tif err != nil {\\n   707→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   708→\\t}\\n   709→\\n   710→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   711→\\tif err != nil {\\n   712→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   713→\\t}\\n   714→\\n   715→\\tvar checkpointID string\\n   716→\\t//nolint:errcheck,gosec // ForEach callback returns error to stop iteration, not a real error\\n   717→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   718→\\t\\t// Look for Entire-Checkpoint trailer\\n   719→\\t\\tfor _, line := range strings.Split(c.Message, \\\"\\\\n\\\") {\\n   720→\\t\\t\\tline = strings.TrimSpace(line)\\n   721→\\t\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   722→\\t\\t\\t\\tcheckpointID = strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   723→\\t\\t\\t\\treturn errors.New(\\\"stop iteration\\\")\\n   724→\\t\\t\\t}\\n   725→\\t\\t}\\n   726→\\t\\treturn nil\\n   727→\\t})\\n   728→\\n   729→\\tif checkpointID == \\\"\\\" {\\n   730→\\t\\treturn \\\"\\\", errors.New(\\\"no commit with Entire-Checkpoint trailer found in history\\\")\\n   731→\\t}\\n   732→\\n   733→\\treturn checkpointID, nil\\n   734→}\\n   735→\\n   736→// GetLatestCheckpointID returns the checkpoint ID from HEAD commit, or empty string if none.\\n   737→// This is a convenience wrapper that doesn't fail the test on missing checkpoint.\\n   738→func (env *TestEnv) GetLatestCheckpointID() string {\\n   739→\\tenv.T.Helper()\\n   740→\\n   741→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   742→\\tif err != nil {\\n   743→\\t\\treturn \\\"\\\"\\n   744→\\t}\\n   745→\\n   746→\\thead, err := repo.Head()\\n   747→\\tif err != nil {\\n   748→\\t\\treturn \\\"\\\"\\n   749→\\t}\\n   750→\\n   751→\\tcommit, err := repo.CommitObject(head.Hash())\\n   752→\\tif err != nil {\\n   753→\\t\\treturn \\\"\\\"\\n   754→\\t}\\n   755→\\n   756→\\t// Look for Entire-Checkpoint trailer in HEAD commit only\\n   757→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n   758→\\t\\tline = strings.TrimSpace(line)\\n   759→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   760→\\t\\t\\treturn strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   761→\\t\\t}\\n   762→\\t}\\n   763→\\treturn \\\"\\\"\\n   764→}\\n   765→\\n   766→// safeIDPrefix returns first 12 chars of ID or the full ID if shorter.\\n   767→// Use this when logging checkpoint IDs to avoid index out of bounds panic.\\n   768→func safeIDPrefix(id string) string {\\n   769→\\tif len(id) >= 12 {\\n   770→\\t\\treturn id[:12]\\n   771→\\t}\\n   772→\\treturn id\\n   773→}\\n   774→\\n   775→// RunCLI runs the entire CLI with the given arguments and returns stdout.\\n   776→func (env *TestEnv) RunCLI(args ...string) string {\\n   777→\\tenv.T.Helper()\\n   778→\\toutput, err := env.RunCLIWithError(args...)\\n   779→\\tif err != nil {\\n   780→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   781→\\t}\\n   782→\\treturn output\\n   783→}\\n   784→\\n   785→// RunCLIWithError runs the entire CLI and returns output and error.\\n   786→func (env *TestEnv) RunCLIWithError(args ...string) (string, error) {\\n   787→\\tenv.T.Helper()\\n   788→\\n   789→\\t//nolint:gosec,noctx // test code, args are from test setup, no context needed\\n   790→\\tcmd := exec.Command(getTestBinary(), args...)\\n   791→\\tcmd.Dir = env.RepoDir\\n   792→\\n   793→\\toutput, err := cmd.CombinedOutput()\\n   794→\\treturn string(output), err\\n   795→}\\n   796→\\n   797→// RunAgent runs the agent with the given prompt and returns the result.\\n   798→func (env *TestEnv) RunAgent(prompt string) (*AgentResult, error) {\\n   799→\\tenv.T.Helper()\\n   800→\\tresult, err := env.Agent.RunPrompt(context.Background(), env.RepoDir, prompt)\\n   801→\\tif err != nil && result != nil {\\n   802→\\t\\tenv.T.Logf(\\\"Agent failed with exit code %d\\\", result.ExitCode)\\n   803→\\t\\tif result.Stderr != \\\"\\\" {\\n   804→\\t\\t\\tenv.T.Logf(\\\"Agent stderr: %s\\\", result.Stderr)\\n   805→\\t\\t}\\n   806→\\t\\tif result.Stdout != \\\"\\\" {\\n   807→\\t\\t\\tenv.T.Logf(\\\"Agent stdout: %s\\\", result.Stdout)\\n   808→\\t\\t}\\n   809→\\t}\\n   810→\\t//nolint:wrapcheck // test helper, caller handles error\\n   811→\\treturn result, err\\n   812→}\\n   813→\\n   814→// RunAgentWithTools runs the agent with specific tools enabled.\\n   815→func (env *TestEnv) RunAgentWithTools(prompt string, tools []string) (*AgentResult, error) {\\n   816→\\tenv.T.Helper()\\n   817→\\tresult, err := env.Agent.RunPromptWithTools(context.Background(), env.RepoDir, prompt, tools)\\n   818→\\tif err != nil && result != nil {\\n   819→\\t\\tenv.T.Logf(\\\"Agent failed with exit code %d\\\", result.ExitCode)\\n   820→\\t\\tif result.Stderr != \\\"\\\" {\\n   821→\\t\\t\\tenv.T.Logf(\\\"Agent stderr: %s\\\", result.Stderr)\\n   822→\\t\\t}\\n   823→\\t\\tif result.Stdout != \\\"\\\" {\\n   824→\\t\\t\\tenv.T.Logf(\\\"Agent stdout: %s\\\", result.Stdout)\\n   825→\\t\\t}\\n   826→\\t}\\n   827→\\t//nolint:wrapcheck // test helper, caller handles error\\n   828→\\treturn result, err\\n   829→}\\n   830→\\n   831→// GitStash runs git stash to save uncommitted changes.\\n   832→// Uses -u flag to include untracked files (new files created by agent).\\n   833→func (env *TestEnv) GitStash() {\\n   834→\\tenv.T.Helper()\\n   835→\\n   836→\\t//nolint:noctx // test code, no context needed for git stash\\n   837→\\tcmd := exec.Command(\\\"git\\\", \\\"stash\\\", \\\"-u\\\")\\n   838→\\tcmd.Dir = env.RepoDir\\n   839→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   840→\\t\\tenv.T.Fatalf(\\\"git stash failed: %v\\\\nOutput: %s\\\", err, output)\\n   841→\\t}\\n   842→}\\n   843→\\n   844→// GitStashPop runs git stash pop to restore stashed changes.\\n   845→func (env *TestEnv) GitStashPop() {\\n   846→\\tenv.T.Helper()\\n   847→\\n   848→\\t//nolint:noctx // test code, no context needed for git stash pop\\n   849→\\tcmd := exec.Command(\\\"git\\\", \\\"stash\\\", \\\"pop\\\")\\n   850→\\tcmd.Dir = env.RepoDir\\n   851→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   852→\\t\\tenv.T.Fatalf(\\\"git stash pop failed: %v\\\\nOutput: %s\\\", err, output)\\n   853→\\t}\\n   854→}\\n   855→\\n   856→// GitCheckoutFile reverts a file to its committed state.\\n   857→func (env *TestEnv) GitCheckoutFile(path string) {\\n   858→\\tenv.T.Helper()\\n   859→\\n   860→\\t//nolint:gosec,noctx // test code, path is from test setup, no context needed\\n   861→\\tcmd := exec.Command(\\\"git\\\", \\\"checkout\\\", \\\"--\\\", path)\\n   862→\\tcmd.Dir = env.RepoDir\\n   863→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   864→\\t\\tenv.T.Fatalf(\\\"git checkout -- %s failed: %v\\\\nOutput: %s\\\", path, err, output)\\n   865→\\t}\\n   866→}\\n   867→\\n   868→// DeleteFile removes a file from the test repo.\\n   869→func (env *TestEnv) DeleteFile(path string) {\\n   870→\\tenv.T.Helper()\\n   871→\\n   872→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   873→\\tif err := os.Remove(fullPath); err != nil {\\n   874→\\t\\tenv.T.Fatalf(\\\"failed to delete file %s: %v\\\", path, err)\\n   875→\\t}\\n   876→}\\n   877→\\n   878→// GetCommitCount returns the number of commits on the current branch.\\n   879→func (env *TestEnv) GetCommitCount() int {\\n   880→\\tenv.T.Helper()\\n   881→\\n   882→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   883→\\tif err != nil {\\n   884→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   885→\\t}\\n   886→\\n   887→\\thead, err := repo.Head()\\n   888→\\tif err != nil {\\n   889→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   890→\\t}\\n   891→\\n   892→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   893→\\tif err != nil {\\n   894→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   895→\\t}\\n   896→\\n   897→\\tcount := 0\\n   898→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   899→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   900→\\t\\tcount++\\n   901→\\t\\treturn nil\\n   902→\\t})\\n   903→\\n   904→\\treturn count\\n   905→}\\n   906→\\n   907→// GetAllCheckpointIDsFromHistory walks backwards from HEAD and returns\\n   908→// all checkpoint IDs from commits with Entire-Checkpoint trailers.\\n   909→func (env *TestEnv) GetAllCheckpointIDsFromHistory() []string {\\n   910→\\tenv.T.Helper()\\n   911→\\n   912→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   913→\\tif err != nil {\\n   914→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   915→\\t}\\n   916→\\n   917→\\thead, err := repo.Head()\\n   918→\\tif err != nil {\\n   919→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   920→\\t}\\n   921→\\n   922→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   923→\\tif err != nil {\\n   924→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   925→\\t}\\n   926→\\n   927→\\tvar checkpointIDs []string\\n   928→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   929→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   930→\\t\\tfor _, line := range strings.Split(c.Message, \\\"\\\\n\\\") {\\n   931→\\t\\t\\tline = strings.TrimSpace(line)\\n   932→\\t\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   933→\\t\\t\\t\\tid := strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   934→\\t\\t\\t\\tcheckpointIDs = append(checkpointIDs, id)\\n   935→\\t\\t\\t}\\n   936→\\t\\t}\\n   937→\\t\\treturn nil\\n   938→\\t})\\n   939→\\n   940→\\treturn checkpointIDs\\n   941→}\\n   942→\\n   943→// ReadFileFromBranch reads a file's content from a specific branch's tree.\\n   944→// Returns the content and true if found, empty string and false if not found.\\n   945→func (env *TestEnv) ReadFileFromBranch(branchName, filePath string) (string, bool) {\\n   946→\\tenv.T.Helper()\\n   947→\\n   948→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   949→\\tif err != nil {\\n   950→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   951→\\t}\\n   952→\\n   953→\\t// Get the branch reference\\n   954→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   955→\\tif err != nil {\\n   956→\\t\\t// Try as a remote-style ref\\n   957→\\t\\tref, err = repo.Reference(plumbing.ReferenceName(\\\"refs/heads/\\\"+branchName), true)\\n   958→\\t\\tif err != nil {\\n   959→\\t\\t\\treturn \\\"\\\", false\\n   960→\\t\\t}\\n   961→\\t}\\n   962→\\n   963→\\t// Get the commit\\n   964→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   965→\\tif err != nil {\\n   966→\\t\\treturn \\\"\\\", false\\n   967→\\t}\\n   968→\\n   969→\\t// Get the tree\\n   970→\\ttree, err := commit.Tree()\\n   971→\\tif err != nil {\\n   972→\\t\\treturn \\\"\\\", false\\n   973→\\t}\\n   974→\\n   975→\\t// Get the file\\n   976→\\tfile, err := tree.File(filePath)\\n   977→\\tif err != nil {\\n   978→\\t\\treturn \\\"\\\", false\\n   979→\\t}\\n   980→\\n   981→\\t// Get the content\\n   982→\\tcontent, err := file.Contents()\\n   983→\\tif err != nil {\\n   984→\\t\\treturn \\\"\\\", false\\n   985→\\t}\\n   986→\\n   987→\\treturn content, true\\n   988→}\\n   989→\\n   990→// CheckpointValidation contains expected values for checkpoint validation.\\n   991→type CheckpointValidation struct {\\n   992→\\t// CheckpointID is the expected checkpoint ID\\n   993→\\tCheckpointID string\\n   994→\\n   995→\\t// Strategy is the expected strategy name (optional)\\n   996→\\tStrategy string\\n   997→\\n   998→\\t// FilesTouched are the expected files in files_touched (optional)\\n   999→\\tFilesTouched []string\\n  1000→\\n  1001→\\t// ExpectedPrompts are strings that should appear in prompt.txt (optional)\\n  1002→\\tExpectedPrompts []string\\n  1003→\\n  1004→\\t// ExpectedTranscriptContent are strings that should appear in full.jsonl (optional)\\n  1005→\\tExpectedTranscriptContent []string\\n  1006→}\\n  1007→\\n  1008→// ValidateCheckpoint performs comprehensive validation of a checkpoint on the metadata branch.\\n  1009→func (env *TestEnv) ValidateCheckpoint(v CheckpointValidation) {\\n  1010→\\tenv.T.Helper()\\n  1011→\\n  1012→\\tmetadataBranch := \\\"entire/checkpoints/v1\\\"\\n  1013→\\n  1014→\\t// Compute sharded path: <id[:2]>/<id[2:]>/\\n  1015→\\tif len(v.CheckpointID) < 3 {\\n  1016→\\t\\tenv.T.Fatalf(\\\"Checkpoint ID too short: %s\\\", v.CheckpointID)\\n  1017→\\t}\\n  1018→\\tshardedPath := v.CheckpointID[:2] + \\\"/\\\" + v.CheckpointID[2:]\\n  1019→\\n  1020→\\t// Validate root metadata.json exists and has expected fields\\n  1021→\\tsummaryPath := shardedPath + \\\"/metadata.json\\\"\\n  1022→\\tsummaryContent, found := env.ReadFileFromBranch(metadataBranch, summaryPath)\\n  1023→\\tif !found {\\n  1024→\\t\\tenv.T.Errorf(\\\"CheckpointSummary not found at %s\\\", summaryPath)\\n  1025→\\t} else {\\n  1026→\\t\\tvar summary map[string]any\\n  1027→\\t\\tif err := json.Unmarshal([]byte(summaryContent), &summa