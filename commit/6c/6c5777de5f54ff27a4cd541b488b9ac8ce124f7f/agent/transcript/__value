nvironment.\\n    48→func NewTestEnv(t *testing.T) *TestEnv {\\n    49→\\tt.Helper()\\n    50→\\n    51→\\t// Resolve symlinks on macOS where /var -> /private/var\\n    52→\\trepoDir := t.TempDir()\\n    53→\\tif resolved, err := filepath.EvalSymlinks(repoDir); err == nil {\\n    54→\\t\\trepoDir = resolved\\n    55→\\t}\\n    56→\\n    57→\\t// Create agent runner\\n    58→\\tagent := NewAgentRunner(defaultAgent, AgentRunnerConfig{})\\n    59→\\n    60→\\treturn &TestEnv{\\n    61→\\t\\tT:       t,\\n    62→\\t\\tRepoDir: repoDir,\\n    63→\\t\\tAgent:   agent,\\n    64→\\t}\\n    65→}\\n    66→\\n    67→// NewFeatureBranchEnv creates an E2E test environment ready for testing.\\n    68→// It initializes the repo, creates an initial commit on main,\\n    69→// checks out a feature branch, and sets up agent hooks.\\n    70→func NewFeatureBranchEnv(t *testing.T, strategyName string) *TestEnv {\\n    71→\\tt.Helper()\\n    72→\\n    73→\\tenv := NewTestEnv(t)\\n    74→\\tenv.InitRepo()\\n    75→\\tenv.WriteFile(\\\"README.md\\\", \\\"# Test Repository\\\\n\\\\nThis is a test repository for E2E testing.\\\\n\\\")\\n    76→\\tenv.GitAdd(\\\"README.md\\\")\\n    77→\\tenv.GitCommit(\\\"Initial commit\\\")\\n    78→\\tenv.GitCheckoutNewBranch(\\\"feature/e2e-test\\\")\\n    79→\\n    80→\\t// OpenCode's `run` (non-interactive) mode defaults external_directory permission\\n    81→\\t// to \\\"ask\\\", which auto-rejects since there's no user to prompt — even when the\\n    82→\\t// path is the project directory itself. Override to \\\"allow\\\" for the test repo.\\n    83→\\t// Note: specific path patterns don't work here because OpenCode evaluates the\\n    84→\\t// catch-all \\\"ask\\\" rule before specific \\\"allow\\\" rules (known issue).\\n    85→\\t// Include $schema to prevent OpenCode from modifying the file when it runs.\\n    86→\\tif defaultAgent == AgentNameOpenCode {\\n    87→\\t\\tenv.WriteFile(\\\"opencode.json\\\", `{\\n    88→  \\\"$schema\\\": \\\"https://opencode.ai/config.json\\\",\\n    89→  \\\"permission\\\": {\\n    90→    \\\"external_directory\\\": \\\"allow\\\"\\n    91→  }\\n    92→}\\n    93→`)\\n    94→\\t}\\n    95→\\n    96→\\t// Use `entire enable` to set up everything (hooks, settings, etc.)\\n    97→\\t// This sets up .entire/settings.json and .claude/settings.json with hooks\\n    98→\\tenv.RunEntireEnable(strategyName)\\n    99→\\n   100→\\t// Commit all files created by `entire enable` so they survive git stash -u operations.\\n   101→\\t// Without this, stash operations would stash away the hooks config and entire settings,\\n   102→\\t// causing hooks to not fire for subsequent prompts and stash pop conflicts.\\n   103→\\t// Using \\\"git add .\\\" is safe in test repos since we control all content.\\n   104→\\tenv.GitAddAll()\\n   105→\\tenv.GitCommit(\\\"Add entire and agent config\\\")\\n   106→\\n   107→\\treturn env\\n   108→}\\n   109→\\n   110→// RunEntireEnable runs `entire enable` to set up the project with hooks.\\n   111→// Uses the configured defaultAgent (from E2E_AGENT env var or \\\"claude-code\\\").\\n   112→func (env *TestEnv) RunEntireEnable(strategyName string) {\\n   113→\\tenv.T.Helper()\\n   114→\\n   115→\\targs := []string{\\n   116→\\t\\t\\\"enable\\\",\\n   117→\\t\\t\\\"--agent\\\", defaultAgent,\\n   118→\\t\\t\\\"--strategy\\\", strategyName,\\n   119→\\t\\t\\\"--telemetry=false\\\",\\n   120→\\t\\t\\\"--force\\\", // Force reinstall hooks in case they exist\\n   121→\\t}\\n   122→\\n   123→\\t//nolint:gosec,noctx // test code, args are static\\n   124→\\tcmd := exec.Command(getTestBinary(), args...)\\n   125→\\tcmd.Dir = env.RepoDir\\n   126→\\n   127→\\toutput, err := cmd.CombinedOutput()\\n   128→\\tif err != nil {\\n   129→\\t\\tenv.T.Fatalf(\\\"entire enable failed: %v\\\\nOutput: %s\\\", err, output)\\n   130→\\t}\\n   131→\\tenv.T.Logf(\\\"entire enable output: %s\\\", output)\\n   132→}\\n   133→\\n   134→// InitRepo initializes a git repository in the test environment.\\n   135→func (env *TestEnv) InitRepo() {\\n   136→\\tenv.T.Helper()\\n   137→\\n   138→\\trepo, err := git.PlainInit(env.RepoDir, false)\\n   139→\\tif err != nil {\\n   140→\\t\\tenv.T.Fatalf(\\\"failed to init git repo: %v\\\", err)\\n   141→\\t}\\n   142→\\n   143→\\t// Configure git user for commits\\n   144→\\tcfg, err := repo.Config()\\n   145→\\tif err != nil {\\n   146→\\t\\tenv.T.Fatalf(\\\"failed to get repo config: %v\\\", err)\\n   147→\\t}\\n   148→\\tcfg.User.Name = \\\"E2E Test User\\\"\\n   149→\\tcfg.User.Email = \\\"e2e-test@example.com\\\"\\n   150→\\n   151→\\t// Disable GPG signing for test commits\\n   152→\\tif cfg.Raw == nil {\\n   153→\\t\\tcfg.Raw = config.New()\\n   154→\\t}\\n   155→\\tcfg.Raw.Section(\\\"commit\\\").SetOption(\\\"gpgsign\\\", \\\"false\\\")\\n   156→\\n   157→\\tif err := repo.SetConfig(cfg); err != nil {\\n   158→\\t\\tenv.T.Fatalf(\\\"failed to set repo config: %v\\\", err)\\n   159→\\t}\\n   160→}\\n   161→\\n   162→// WriteFile creates a file with the given content in the test repo.\\n   163→func (env *TestEnv) WriteFile(path, content string) {\\n   164→\\tenv.T.Helper()\\n   165→\\n   166→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   167→\\n   168→\\t// Create parent directories\\n   169→\\tdir := filepath.Dir(fullPath)\\n   170→\\t//nolint:gosec // test code, permissions are intentionally standard\\n   171→\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   172→\\t\\tenv.T.Fatalf(\\\"failed to create directory %s: %v\\\", dir, err)\\n   173→\\t}\\n   174→\\n   175→\\t//nolint:gosec // test code, permissions are intentionally standard\\n   176→\\tif err := os.WriteFile(fullPath, []byte(content), 0o644); err != nil {\\n   177→\\t\\tenv.T.Fatalf(\\\"failed to write file %s: %v\\\", path, err)\\n   178→\\t}\\n   179→}\\n   180→\\n   181→// ReadFile reads a file from the test repo.\\n   182→func (env *TestEnv) ReadFile(path string) string {\\n   183→\\tenv.T.Helper()\\n   184→\\n   185→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   186→\\t//nolint:gosec // test code, path is from test setup\\n   187→\\tdata, err := os.ReadFile(fullPath)\\n   188→\\tif err != nil {\\n   189→\\t\\tenv.T.Fatalf(\\\"failed to read file %s: %v\\\", path, err)\\n   190→\\t}\\n   191→\\treturn string(data)\\n   192→}\\n   193→\\n   194→// TryReadFile reads a file from the test repo, returning empty string if not found.\\n   195→func (env *TestEnv) TryReadFile(path string) string {\\n   196→\\tenv.T.Helper()\\n   197→\\n   198→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   199→\\t//nolint:gosec // test code, path is from test setup\\n   200→\\tdata, err := os.ReadFile(fullPath)\\n   201→\\tif err != nil {\\n   202→\\t\\treturn \\\"\\\"\\n   203→\\t}\\n   204→\\treturn string(data)\\n   205→}\\n   206→\\n   207→// FileExists checks if a file exists in the test repo.\\n   208→func (env *TestEnv) FileExists(path string) bool {\\n   209→\\tenv.T.Helper()\\n   210→\\n   211→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   212→\\t_, err := os.Stat(fullPath)\\n   213→\\treturn err == nil\\n   214→}\\n   215→\\n   216→// GitAdd stages files for commit.\\n   217→func (env *TestEnv) GitAdd(paths ...string) {\\n   218→\\tenv.T.Helper()\\n   219→\\n   220→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   221→\\tif err != nil {\\n   222→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   223→\\t}\\n   224→\\n   225→\\tworktree, err := repo.Worktree()\\n   226→\\tif err != nil {\\n   227→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   228→\\t}\\n   229→\\n   230→\\tfor _, path := range paths {\\n   231→\\t\\tif _, err := worktree.Add(path); err != nil {\\n   232→\\t\\t\\tenv.T.Fatalf(\\\"failed to add file %s: %v\\\", path, err)\\n   233→\\t\\t}\\n   234→\\t}\\n   235→}\\n   236→\\n   237→// GitAddAll stages all files (git add .).\\n   238→func (env *TestEnv) GitAddAll() {\\n   239→\\tenv.T.Helper()\\n   240→\\n   241→\\tcmd := exec.Command(\\\"git\\\", \\\"add\\\", \\\".\\\")\\n   242→\\tcmd.Dir = env.RepoDir\\n   243→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   244→\\t\\tenv.T.Fatalf(\\\"git add . failed: %v\\\\nOutput: %s\\\", err, output)\\n   245→\\t}\\n   246→}\\n   247→\\n   248→// GitCommit creates a commit with all staged files.\\n   249→func (env *TestEnv) GitCommit(message string) {\\n   250→\\tenv.T.Helper()\\n   251→\\n   252→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   253→\\tif err != nil {\\n   254→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   255→\\t}\\n   256→\\n   257→\\tworktree, err := repo.Worktree()\\n   258→\\tif err != nil {\\n   259→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   260→\\t}\\n   261→\\n   262→\\t_, err = worktree.Commit(message, &git.CommitOptions{\\n   263→\\t\\tAuthor: &object.Signature{\\n   264→\\t\\t\\tName:  \\\"E2E Test User\\\",\\n   265→\\t\\t\\tEmail: \\\"e2e-test@example.com\\\",\\n   266→\\t\\t\\tWhen:  time.Now(),\\n   267→\\t\\t},\\n   268→\\t})\\n   269→\\tif err != nil {\\n   270→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   271→\\t}\\n   272→}\\n   273→\\n   274→// GitCommitWithShadowHooks stages and commits files, running the prepare-commit-msg\\n   275→// and post-commit hooks like a real workflow.\\n   276→func (env *TestEnv) GitCommitWithShadowHooks(message string, files ...string) {\\n   277→\\tenv.T.Helper()\\n   278→\\n   279→\\t// Stage files using go-git\\n   280→\\tfor _, file := range files {\\n   281→\\t\\tenv.GitAdd(file)\\n   282→\\t}\\n   283→\\n   284→\\t// Create a temp file for the commit message\\n   285→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n   286→\\t//nolint:gosec // test code, permissions are intentionally standard\\n   287→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n   288→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n   289→\\t}\\n   290→\\n   291→\\t// Run prep