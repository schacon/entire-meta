atalf(\\\"failed to get HEAD: %v\\\", err)\\n   541→\\t}\\n   542→\\n   543→\\treturn head.Hash().String()\\n   544→}\\n   545→\\n   546→// RewindPoint mirrors the rewind --list JSON output.\\n   547→type RewindPoint struct {\\n   548→\\tID               string    `json:\\\"id\\\"`\\n   549→\\tMessage          string    `json:\\\"message\\\"`\\n   550→\\tMetadataDir      string    `json:\\\"metadata_dir\\\"`\\n   551→\\tDate             time.Time `json:\\\"date\\\"`\\n   552→\\tIsTaskCheckpoint bool      `json:\\\"is_task_checkpoint\\\"`\\n   553→\\tToolUseID        string    `json:\\\"tool_use_id\\\"`\\n   554→\\tIsLogsOnly       bool      `json:\\\"is_logs_only\\\"`\\n   555→\\tCondensationID   string    `json:\\\"condensation_id\\\"`\\n   556→}\\n   557→\\n   558→// GetRewindPoints returns available rewind points using the CLI.\\n   559→func (env *TestEnv) GetRewindPoints() []RewindPoint {\\n   560→\\tenv.T.Helper()\\n   561→\\n   562→\\t//nolint:gosec,noctx // test code, args are static, no context needed\\n   563→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--list\\\")\\n   564→\\tcmd.Dir = env.RepoDir\\n   565→\\n   566→\\toutput, err := cmd.CombinedOutput()\\n   567→\\tif err != nil {\\n   568→\\t\\tenv.T.Fatalf(\\\"rewind --list failed: %v\\\\nOutput: %s\\\", err, output)\\n   569→\\t}\\n   570→\\n   571→\\t// Parse JSON output\\n   572→\\tvar jsonPoints []struct {\\n   573→\\t\\tID               string `json:\\\"id\\\"`\\n   574→\\t\\tMessage          string `json:\\\"message\\\"`\\n   575→\\t\\tMetadataDir      string `json:\\\"metadata_dir\\\"`\\n   576→\\t\\tDate             string `json:\\\"date\\\"`\\n   577→\\t\\tIsTaskCheckpoint bool   `json:\\\"is_task_checkpoint\\\"`\\n   578→\\t\\tToolUseID        string `json:\\\"tool_use_id\\\"`\\n   579→\\t\\tIsLogsOnly       bool   `json:\\\"is_logs_only\\\"`\\n   580→\\t\\tCondensationID   string `json:\\\"condensation_id\\\"`\\n   581→\\t}\\n   582→\\n   583→\\tif err := json.Unmarshal(output,