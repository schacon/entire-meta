25→   325→\\n   326→   326→\\t// Prompt 1: Agent creates files A, B, C\\n   327→   327→\\tt.Log(\\\"Prompt 1: Creating files A, B, C\\\")\\n   328→   328→\\tprompt1 := `Create these files:\\n   329→   329→1. combo_a.go with content: package main; func ComboA() {}\\n   330→   330→2. combo_b.go with content: package main; func ComboB() {}\\n   331→   331→3. combo_c.go with content: package main; func ComboC() {}\\n   332→   332→Create all three files, nothing else.`\\n   333→   333→\\n   334→   334→\\tresult, err := env.RunAgent(prompt1)\\n   335→   335→\\trequire.NoError(t, err)\\n   336→   336→\\tAssertAgentSuccess(t, result, err)\\n   337→   337→\\n   338→   338→\\trequire.True(t, env.FileExists(\\\"combo_a.go\\\"))\\n   339→   339→\\trequire.True(t, env.FileExists(\\\"combo_b.go\\\"))\\n   340→   340→\\trequire.True(t, env.FileExists(\\\"combo_c.go\\\"))\\n   341→   341→\\n   342→   342→\\t// User commits A only\\n   343→   343→\\tt.Log(\\\"Committing combo_a.go only\\\")\\n   344→   344→\\tenv.GitCommitWithShadowHooks(\\\"Add combo_a\\\", \\\"combo_a.go\\\")\\n   345→   345→\\n   346→   346→\\t// User stashes B, C\\n   347→   347→\\tt.Log(\\\"Stashing remaining files B, C\\\")\\n   348→   348→\\tenv.GitStash()\\n   349→   349→\\n   350→   350→\\t// Verify B, C are no longer in working directory\\n   351→   351→\\tassert.False(t, env.FileExists(\\\"combo_b.go\\\"), \\\"combo_b.go should be stashed\\\")\\n   352→   352→\\tassert.False(t, env.FileExists(\\\"combo_c.go\\\"), \\\"combo_c.go should be stashed\\\")\\n   353→   353→\\n   354→   354→\\t// Prompt 2: Agent creates files D, E\\n   355→   355→\\tt.Log(\\\"Prompt 2: Creating files D, E\\\")\\n   356→   356→\\tprompt2 := `Create these files:\\n   357→   357→1. combo_d.go with content: package main; func ComboD() {}\\n   358→   358→2. combo_e.go with content: package main; func ComboE() {}\\n   359→   359→Create both files, nothing else.`\\n   360→   360→\\n   361→   361→\\tresult, err = env.RunAgent(prompt2)\\n   362→   362→\\trequire.NoError(t, err)\\n   363→   363→\\tAssertAgentSuccess(t, result, err)\\n   364→   364→\\n   365→   365→\\trequire.True(t, env.FileExists(\\\"combo_d.go\\\"))\\n   366→   366→\\trequire.True(t, env.FileExists(\\\"combo_e.go\\\"))\\n   367→   367→\\n   368→   368→\\t// User unstashes B, C\\n   369→   369→\\tt.Log(\\\"Unstashing B, C\\\")\\n   370→   370→\\tenv.GitStashPop()\\n   371→   371→\\n   372→   372→\\t// Verify B, C are back\\n   373→   373→\\tassert.True(t, env.FileExists(\\\"combo_b.go\\\"), \\\"combo_b.go should be back after unstash\\\")\\n   374→   374→\\tassert.True(t, env.FileExists(\\\"combo_c.go\\\"), \\\"combo_c.go should be back after unstash\\\")\\n   375→   375→\\n   376→   376→\\t// User commits ALL files together (B, C, D, E)\\n   377→   377→\\tt.Log(\\\"Committing all remaining files together\\\")\\n   378→   378→\\tenv.GitCommitWithShadowHooks(\\\"Add combo_b, combo_c, combo_d, combo_e\\\",\\n   379→   379→\\t\\t\\\"combo_b.go\\\", \\\"combo_c.go\\\", \\\"combo_d.go\\\", \\\"combo_e.go\\\")\\n   380→   380→\\n   381→   381→\\t// Verify checkpoint was created\\n   382→   382→\\tcheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n   383→   383→\\trequire.GreaterOrEqual(t, len(checkpointIDs), 2, \\\"Should have checkpoints\\\")\\n   384→   384→\\tt.Logf(\\\"Checkpoint IDs: %v\\\", checkpointIDs)\\n   385→   385→\\n   386→   386→\\t// The second commit should have all 4 files linked to a single checkpoint\\n   387→   387→\\t// Verify metadata branch exists\\n   388→   388→\\tassert.True(t, env.BranchExists(\\\"entire/checkpoints/v1\\\"),\\n   389→   389→\\t\\t\\\"entire/checkpoints/v1 branch should exist\\\")\\n   390→   390→\\n   391→   391→\\t// Validate checkpoints have proper metadata\\n   392→   392→\\t// checkpointIDs[0] is the most recent (B, C, D, E combined commit)\\n   393→   393→\\t// checkpointIDs[1] is the earlier commit (A only)\\n   394→   394→\\t//\\n   395→   395→\\t// Prompt 1 created A, B, C. User committed A, then stashed B, C.\\n   396→   396→\\t// Prompt 2 created D, E. User unstashed B, C, then committed all 4 together.\\n   397→   397→\\t//\\n   398→   398→\\t// Note: We don't validate transcript content here because:\\n   399→   399→\\t// 1. Claude's response text varies and may not contain exact file names\\n   400→   400→\\t// 2. Multi-session checkpoints have multiple session folders, making validation complex\\n   401→   401→\\t// The key validation is that files_touched is correct for each checkpoint.\\n   402→   402→\\tif len(checkpointIDs) >= 2 {\\n   403→   403→\\t\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   404→   404→\\t\\t\\tCheckpointID: checkpointIDs[0],\\n   405→   405→\\t\\t\\tStrategy:     \\\"manual-commit\\\",\\n   406→   406→\\t\\t\\tFilesTouched: []string{\\\"combo_b.go\\\", \\\"combo_c.go\\\", \\\"combo_d.go\\\", \\\"combo_e.go\\\"},\\n   407→   407→\\t\\t})\\n   408→   408→\\t\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   409→   409→\\t\\t\\tCheckpointID: checkpointIDs[1],\\n   410→   410→\\t\\t\\tStrategy:     \\\"manual-commit\\\",\\n   411→   411→\\t\\t\\tFilesTouched: []string{\\\"combo_a.go\\\"},\\n   412→   412→\\t\\t})\\n   413→   413→\\t}\\n   414→   414→\\n   415→   415→\\t// No shadow branches should remain after all files committed\\n   416→   416→\\tentireBranches := env.ListBranchesWithPrefix(\\\"entire/\\\")\\n   417→   417→\\tfor _, b := range entireBranches {\\n   418→   418→\\t\\tassert.Equal(t, \\\"entire/checkpoints/v1\\\", b,\\n   419→   419→\\t\\t\\t\\\"Unexpected shadow branch after all files committed: %s\\\", b)\\n   420→   420→\\t}\\n   421→   421→}\\n   422→   422→\\n   423→   423→// TestE2E_Scenario7_PartialStagingWithGitAddP tests partial staging with git add -p.\\n   424→   424→//\\n   425→   425→// Scenario 7: Partial Staging with `git add -p`\\n   426→   426→// - Agent makes multiple changes to a single file\\n   427→   427→// - User stages only part of the changes (simulated with partial write)\\n   428→   428→// - Content-aware carry-forward detects partial commit\\n   429→   429→// - Remaining changes carried forward to next commit\\n   430→   430→func TestE2E_Scenario7_PartialStagingSimulated(t *testing.T) {\\n   431→   431→\\tt.Parallel()\\n   432→   432→\\n   433→   433→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   434→   434→\\n   435→   435→\\t// Create partial.go as an existing tracked file first.\\n   436→   436→\\t// For MODIFIED files (vs NEW files), content-aware detection always\\n   437→   437→\\t// creates checkpoints regardless of content changes. This allows us\\n   438→   438→\\t// to test the partial staging scenario.\\n   439→   439→\\tenv.WriteFile(\\\"partial.go\\\", \\\"package main\\\\n\\\\n// placeholder\\\\n\\\")\\n   440→   440→\\tenv.GitAdd(\\\"partial.go\\\")\\n   441→   441→\\tenv.GitCommit(\\\"Add placeholder partial.go\\\")\\n   442→   442→\\n   443→   443→\\t// Agent modifies the file with multiple functions\\n   444→   444→\\tt.Log(\\\"Agent modifying file with multiple functions\\\")\\n   445→   445→\\tmultiLinePrompt := `Replace the contents of partial.go with this exact content:\\n   446→   446→package main\\n   447→   447→\\n   448→   448→func First() int {\\n   449→   449→\\treturn 1\\n   450→   450→}\\n   451→   451→\\n   452→   452→func Second() int {\\n   453→   453→\\treturn 2\\n   454→   454→}\\n   455→   455→\\n   456→   456→func Third() int {\\n   457→   457→\\treturn 3\\n   458→   458→}\\n   459→   459→\\n   460→   460→func Fourth() int {\\n   461→   461→\\treturn 4\\n   462→   462→}\\n   463→   463→\\n   464→   464→Replace the file with exactly this content, nothing else.`\\n   465→   465→\\n   466→   466→\\tresult, err := env.RunAgent(multiLinePrompt)\\n   467→   467→\\trequire.NoError(t, err)\\n   468→   468→\\tAssertAgentSuccess(t, result, err)\\n   469→   469→\\n   470→   470→\\trequire.True(t, env.FileExists(\\\"partial.go\\\"))\\n   471→   471→\\n   472→   472→\\t// Check rewind points before commit\\n   473→   473→\\tpointsBefore := env.GetRewindPoints()\\n   474→   474→\\tt.Logf(\\\"Rewind points before commit: %d\\\", len(pointsBefore))\\n   475→   475→\\n   476→   476→\\t// Simulate partial staging by temporarily replacing file with partial content\\n   477→   477→\\t// Save the full content\\n   478→   478→\\tfullContent := env.ReadFile(\\\"partial.go\\\")\\n   479→   479→\\tt.Logf(\\\"Full content length: %d bytes\\\", len(fullContent))\\n   480→   480→\\n   481→   481→\\t// Write partial content (only first two functions)\\n   482→   482→\\tpartialContent := `package main\\n   483→   483→\\n   484→   484→func First() int {\\n   485→   485→\\treturn 1\\n   486→   486→}\\n   487→   487→\\n   488→   488→func Second() int {\\n   489→   489→\\treturn 2\\n   490→   490→}\\n   491→   491→`\\n   492→   492→\\tenv.WriteFile(\\\"partial.go\\\", partialContent)\\n   493→   493→\\n   494→   494→\\t// Commit the partial content\\n   495→   495→\\tt.Log(\\\"Committing partial content (First and Second functions)\\\")\\n   496→   496→\\tenv.GitCommitWithShadowHooks(\\\"Add first two functions\\\", \\\"partial.go\\\")\\n   497→   497→\\n   498→   498→\\t// Verify first checkpoint was created\\n   499→   499→\\tcheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n   500→   500→\\trequire.GreaterOrEqual(t, len(checkpointIDs), 1, \\\"Should have first checkpoint\\\")\\n   501→   501→\\tt.Logf(\\\"First checkpoint ID: %s\\\", checkpointIDs[0])\\n   502→   502→\\n   503→   503→\\t// Restore the full content (simulating remaining changes still in worktree)\\n   504→   504→\\tenv.WriteFile(\\\"partial.go\\\", fullContent)\\n   505→   505→\\n   506→   506→\\t// Commit the remaining content\\n   507→   507→\\tt.Log(\\\"Committing full content (all functions)\\\")\\n   508→   508→\\tenv.GitCommitWithShadowHooks(\\\"Add remaining functions\\\", \\\"partial.go\\\")\\n   509→   509→\\n   510→   510→\\t// Verify second checkpoint was created\\n   511→   511→\\tcheckpointIDsAfter := env.GetAllCheckpointIDsFromHistory()\\n   512→   512→\\trequire.GreaterOrEqual(t, len(checkpointIDsAfter), 2, \\\"Should have two checkpoints\\\")\\n   513→   513→\\tt.Logf(\\\"Checkpoint IDs: %v\\\", checkpointIDsAfter)\\n   514→   514→\\n   515→   515→\\t// Each commit should have its own unique checkpoint ID\\n   516→   516→\\tassert.NotEqual(t, checkpointIDsAfter[0], checkpointIDsAfter[1],\\n   517→   517→\\t\\t\\\"Each commit should have its own unique checkpoint ID\\\")\\n   518→   518→\\n   519→   519→\\t// Validate checkpoints have proper metadata and transcripts\\n   520→   520→\\t// checkpointIDsAfter[0] is the most recent (full content commit)\\n   521→   521→\\t// checkpointIDsAfter[1] is the earlier commit (partial content)\\n   522→   522→\\t//\\n   523→   523→\\t// Both commits are from the same session (single prompt), so both have\\n   524→   524→\\t// the same full transcript referencing partial.go and the function names.\\n   525→   525→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   526→   526→\\t\\tCheckpointID:              checkpointIDsAfter[0],\\n   527→   527→\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   528→   528→\\t\\tFilesTouched:              []string{\\\"partial.go\\\"},\\n   529→   529→\\t\\tExpectedTranscriptContent: []string{\\\"partial.go\\\", \\\"First\\\", \\\"Second\\\", \\\"Third\\\", \\\"Fourth\\\"},\\n   530→   530→\\t})\\n   531→   531→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   532→   532→\\t\\tCheckpointID:              checkpointIDsAfter[1],\\n   533→   533→\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   534→   534→\\t\\tFilesTouched:              []string{\\\"partial.go\\\"},\\n   535→   535→\\t\\tExpectedTranscriptContent: []string{\\\"partial.go\\\", \\\"First\\\", \\\"Second\\\", \\\"Third\\\", \\\"Fourth\\\"},\\n   536→   536→\\t})\\n   537→   537→}\\n   538→   538→\\n   539→   539→// TestE2E_ContentAwareOverlap_RevertAndReplace tests content-aware overlap detection\\n   540→   540→// when user reverts session changes and writes different content.\\n   541→   541→//\\n   542→   542→// Content-Aware Overlap Detection:\\n   543→   543→// - Agent creates file X with content \\\"hello\\\"\\n   544→   544→// - User reverts X (git checkout -- X)\\n   545→   545→// - User writes completely different content\\n   546→   546→// - User commits\\n   547→   547→// - Content mismatch → NO checkpoint trailer added\\n   548→   548→func TestE2E_ContentAwareOverlap_RevertAndReplace(t *testing.T) {\\n   549→   549→\\tt.Parallel()\\n   550→   550→\\n   551→   551→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   552→   552→\\n   553→   553→\\t// Agent creates a file\\n   554→   554→\\tt.Log(\\\"Agent creating file with specific content\\\")\\n   555→   555→\\tcreatePrompt := `Create a file called overlap_test.go with this exact content:\\n   556→   556→package main\\n   557→   557→\\n   558→   558→func OverlapOriginal() string {\\n   559→   559→\\treturn \\\"original content from agent\\\"\\n   560→   560→}\\n   561→   561→\\n   562→   562→Create only this file.`\\n   563→   563→\\n   564→   564→\\tresult, err := env.RunAgent(createPrompt)\\n   565→   565→\\trequire.NoError(t, err)\\n   566→   566→\\tAssertAgentSuccess(t, result, err)\\n   567→   567→\\n   568→   568→\\trequire.True(t, env.FileExists(\\\"overlap_test.go\\\"))\\n   569→   569→\\toriginalContent := env.ReadFile(\\\"overlap_test.go\\\")\\n   570→   570→\\tt.Logf(\\\"Original content: %s\\\", originalContent)\\n   571→   571→\\n   572→   572→\\t// Verify rewind points exist (session tracked the change)\\n   573→   573→\\tpoints := env.GetRewindPoints()\\n   574→   574→\\trequire.GreaterOrEqual(t, len(points), 1, \\\"Should have rewind points\\\")\\n   575→   575→\\n   576→   576→\\t// User reverts the file and writes completely different content\\n   577→   577→\\tt.Log(\\\"User reverting file and writing different content\\\")\\n   578→   578→\\tdifferentContent := `package main\\n   579→   579→\\n   580→   580→func CompletelyDifferent() string {\\n   581→   581→\\treturn \\\"user wrote this, not the agent\\\"\\n   582→   582→}\\n   583→   583→`\\n   584→   584→\\tenv.WriteFile(\\\"overlap_test.go\\\", differentContent)\\n   585→   585→\\n   586→   586→\\t// Verify content is different\\n   587→   587→\\tcurrentContent := env.ReadFile(\\\"overlap_test.go\\\")\\n   588→   588→\\tassert.NotEqual(t, originalContent, currentContent)\\n   589→   589→\\n   590→   590→\\t// Commits before this test\\n   591→   591→\\tcommitsBefore := env.GetCommitCount()\\n   592→   592→\\n   593→   593→\\t// User commits the different content\\n   594→   594→\\tt.Log(\\\"Committing user-written content\\\")\\n   595→   595→\\tenv.GitCommitWithShadowHooks(\\\"Add overlap test file\\\", \\\"overlap_test.go\\\")\\n   596→   596→\\n   597→   597→\\t// Verify commit was made\\n   598→   598→\\tcommitsAfter := env.GetCommitCount()\\n   599→   599→\\tassert.Equal(t, commitsBefore+1, commitsAfter, \\\"Should have one new commit\\\")\\n   600→   600→\\n   601→   601→\\t// Check for checkpoint trailer\\n   602→   602→\\t// With content-aware overlap detection, if the user completely replaced\\n   603→   603→\\t// the agent's content (new file with different hash), there should be\\n   604→   604→\\t// NO checkpoint trailer added. This is documented in checkpoint-scenarios.md\\n   605→   605→\\t// under \\\"Content-Aware Overlap Detection\\\".\\n   606→   606→\\tcheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n   607→   607→\\tt.Logf(\\\"Checkpoint IDs found: %v\\\", checkpointIDs)\\n   608→   608→\\n   609→   609→\\t// The first commit (Initial commit from NewFeatureBranchEnv) doesn't have a checkpoint.\\n   610→   610→\\t// Only agent-assisted commits should have checkpoint trailers.\\n   611→   611→\\t// When user completely replaces agent content, content-aware detection should\\n   612→   612→\\t// prevent the checkpoint trailer from being added.\\n   613→   613→\\t//\\n   614→   614→\\t// Per docs/architecture/checkpoint-scenarios.md:\\n   615→   615→\\t// - New file + content hash mismatch → No overlap → No checkpoint trailer\\n   616→   616→\\tassert.Empty(t, checkpointIDs,\\n   617→   617→\\t\\t\\\"Content-aware detection should prevent checkpoint trailer when user completely replaces agent content\\\")\\n   618→   618→}\\n   619→   619→\\n   620→   620→// TestE2E_Scenario1_BasicFlow verifies the simplest workflow matches the documented scenario.\\n   621→   621→//\\n   622→   622→// Scenario 1: Prompt → Changes → Prompt Finishes → User Commits\\n   623→   623→// This test explicitly verifies the documented flow.\\n   624→   624→func TestE2E_Scenario1_BasicFlow(t *testing.T) {\\n   625→   625→\\tt.Parallel()\\n   626→   626→\\n   627→   627→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   628→   628→\\n   629→   629→\\t// 1. User submits prompt (triggers UserPromptSubmit hook → InitializeSession)\\n   630→   630→\\tt.Log(\\\"Step 1: User submits prompt\\\")\\n   631→   631→\\n   632→   632→\\t// 2. Claude makes changes (creates files)\\n   633→   633→\\tprompt := `Create a file called scenario1.go with this content:\\n   634→   634→package main\\n   635→   635→func Scenario1() {}\\n   636→   636→Create only this file.`\\n   637→   637→\\n   638→   638→\\tresult, err := env.RunAgent(prompt)\\n   639→   639→\\trequire.NoError(t, err)\\n   640→   640→\\tAssertAgentSuccess(t, result, err)\\n   641→   641→\\n   642→   642→\\t// Verify file was created\\n   643→   643→\\trequire.True(t, env.FileExists(\\\"scenario1.go\\\"))\\n   644→   644→\\n   645→   645→\\t// 3. After stop hook: checkpoint is saved, FilesTouched is set\\n   646→   646→\\tt.Log(\\\"Step 3: Checking rewind points after stop\\\")\\n   647→   647→\\tpoints := env.GetRewindPoints()\\n   648→   648→\\trequire.GreaterOrEqual(t, len(points), 1, \\\"Should have rewind point after stop\\\")\\n   649→   649→\\tt.Logf(\\\"Rewind points: %d\\\", len(points))\\n   650→   650→\\n   651→   651→\\t// 4. User commits (triggers prepare-commit-msg and post-commit hooks)\\n   652→   652→\\tt.Log(\\\"Step 4: User commits\\\")\\n   653→   653→\\tenv.GitCommitWithShadowHooks(\\\"Add scenario1 file\\\", \\\"scenario1.go\\\")\\n   654→   654→\\n   655→   655→\\t// 5. Verify checkpoint was created with trailer\\n   656→   656→\\tcheckpointID, err := env.GetLatestCheckpointIDFromHistory()\\n   657→   657→\\trequire.NoError(t, err, \\\"Should find checkpoint in commit history\\\")\\n   658→   658→\\tassert.NotEmpty(t, checkpointID, \\\"Commit should have Entire-Checkpoint trailer\\\")\\n   659→   659→\\tt.Logf(\\\"Checkpoint ID: %s\\\", checkpointID)\\n   660→   660→\\n   661→   661→\\t// 6. Verify shadow branch was cleaned up and metadata branch exists\\n   662→   662→\\tassert.True(t, env.BranchExists(\\\"entire/checkpoints/v1\\\"),\\n   663→   663→\\t\\t\\\"entire/checkpoints/v1 branch should exist after condensation\\\")\\n   664→   664→\\n   665→   665→\\t// 7. Validate checkpoint has proper metadata and transcript\\n   666→   666→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   667→   667→\\t\\tCheckpointID:              checkpointID,\\n   668→   668→\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   669→   669→\\t\\tFilesTouched:              []string{\\\"scenario1.go\\\"},\\n   670→   670→\\t\\tExpectedTranscriptContent: []string{\\\"scenario1.go\\\"},\\n   671→   671→\\t})\\n   672→   672→}\\n   673→   673→\\n   674→   674→// TestE2E_Scenario2_AgentCommitsDuringTurn verifies the deferred finalization flow.\\n   675→   675→//\\n   676→   676→// Scenario 2: Prompt Commits Within Single Turn\\n   677→   677→// - Agent commits during ACTIVE phase\\n   678→   678→// - PostCommit saves provisional transcript\\n   679→   679→// - HandleTurnEnd (Stop hook) finalizes with full transcript\\n   680→   680→func TestE2E_Scenario2_AgentCommitsDuringTurn(t *testing.T) {\\n   681→   681→\\tt.Parallel()\\n   682→   682→\\n   683→   683→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   684→   684→\\n   685→   685→\\tcommitsBefore := env.GetCommitCount()\\n   686→   686→\\n   687→   687→\\t// Agent creates file and commits it\\n   688→   688→\\tt.Log(\\\"Agent creating file and committing\\\")\\n   689→   689→\\tcommitPrompt := `Create a file called agent_commit.go with this content:\\n   690→   690→package main\\n   691→   691→func AgentCommit() {}\\n   692→   692→\\n   693→   693→Then commit it with: git add agent_commit.go && git commit -m \\\"Agent adds file\\\"\\n   694→   694→\\n   695→   695→Create the file first, then run the git commands.`\\n   696→   696→\\n   697→   697→\\tresult, err := env.RunAgentWithTools(commitPrompt, []string{\\\"Write\\\", \\\"Bash\\\"})\\n   698→   698→\\trequire.NoError(t, err)\\n   699→   699→\\tAssertAgentSuccess(t, result, err)\\n   700→   700→\\n   701→   701→\\t// Verify file was created\\n   702→   702→\\trequire.True(t, env.FileExists(\\\"agent_commit.go\\\"))\\n   703→   703→\\n   704→   704→\\t// Verify commit was made\\n   705→   705→\\tcommitsAfter := env.GetCommitCount()\\n   706→   706→\\tassert.Greater(t, commitsAfter, commitsBefore, \\\"Agent should have made a commit\\\")\\n   707→   707→\\n   708→   708→\\t// Check commit message\\n   709→   709→\\theadMsg := env.GetCommitMessage(env.GetHeadHash())\\n   710→   710→\\tt.Logf(\\\"HEAD commit message: %s\\\", headMsg)\\n   711→   711→\\n   712→   712→\\t// Check for checkpoint trailer\\n   713→   713→\\tcheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n   714→   714→\\tt.Logf(\\\"Checkpoint IDs: %v\\\", checkpointIDs)\\n   715→   715→\\n   716→   716→\\t// Verify metadata branch exists (if checkpoint was created)\\n   717→   717→\\tif len(checkpointIDs) > 0 {\\n   718→   718→\\t\\tassert.True(t, env.BranchExists(\\\"entire/checkpoints/v1\\\"),\\n   719→   719→\\t\\t\\t\\\"entire/checkpoints/v1 branch should exist\\\")\\n   720→   720→\\n   721→   721→\\t\\t// Validate checkpoint has proper metadata and transcript\\n   722→   722→\\t\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   723→   723→\\t\\t\\tCheckpointID:              checkpointIDs[0],\\n   724→   724→\\t\\t\\tStrategy:                  \\\"manual-commit\\\",\\n   725→   725→\\t\\t\\tFilesTouched:              []string{\\\"agent_commit.go\\\"},\\n   726→   726→\\t\\t\\tExpectedTranscriptContent: []string{\\\"agent_commit.go\\\"},\\n   727→   727→\\t\\t})\\n   728→   728→\\t}\\n   729→   729→}\\n   730→   730→\\n   731→   731→// =============================================================================\\n   732→   732→// Tests for MODIFYING EXISTING FILES (not just creating new ones)\\n   733→   733→// =============================================================================\\n   734→   734→// These tests ensure checkpoints work correctly when the agent modifies\\n   735→   735→// tracked files that already exist in the repository, which behaves differently\\n   736→   736→// from creating new (untracked) files with respect to git stash, staging, etc.\\n   737→   737→\\n   738→   738→// TestE2E_ExistingFiles_ModifyAndCommit tests basic workflow where agent\\n   739→   739→// modifies an existing tracked file instead of creating a new one.\\n   740→   740→func TestE2E_ExistingFiles_ModifyAndCommit(t *testing.T) {\\n   741→   741→\\tt.Parallel()\\n   742→   742→\\n   743→   743→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   744→   744→\\n   745→   745→\\t// Create and commit an existing file first\\n   746→   746→\\tenv.WriteFile(\\\"config.go\\\", `package main\\n   747→   747→\\n   748→   748→var Config = map[string]string{\\n   749→   749→\\t\\\"version\\\": \\\"1.0\\\",\\n   750→   750→}\\n   751→   751→`)\\n   752→   752→\\tenv.GitCommitWithShadowHooks(\\\"Add initial config\\\", \\\"config.go\\\")\\n   753→   753→\\n   754→   754→\\t// Agent modifies the existing file\\n   755→   755→\\tt.Log(\\\"Agent modifying existing config.go\\\")\\n   756→   756→\\tprompt := `Modify the file config.go to add a new config key \\\"debug\\\" with value \\\"true\\\".\\n   757→   757→Keep the existing content and just add the new key. Only modify this one file.`\\n   758→   758→\\n   759→   759→\\tresult, err := env.RunAgent(prompt)\\n   760→   760→\\trequire.NoError(t, err)\\n   761→   761→\\tAssertAgentSuccess(t, result, err)\\n   762→   762→\\n   763→   763→\\t// Verify file was modified\\n   764→   764→\\tcontent := env.ReadFile(\\\"config.go\\\")\\n   765→   765→\\tassert.Contains(t, content, \\\"debug\\\", \\\"config.go should contain debug key\\\")\\n   766→   766→\\n   767→   767→\\t// User commits the modification\\n   768→   768→\\tt.Log(\\\"User committing modified config.go\\\")\\n   769→   769→\\tenv.GitCommitWithShadowHooks(\\\"Add debug config\\\", \\\"config.go\\\")\\n   770→   770→\\n   771→   771→\\t// Verify checkpoint was created\\n   772→   772→\\tcheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n   773→   773→\\t// First commit (initial config) may or may not have checkpoint depending on session state\\n   774→   774→\\t// The agent's modification commit should have a checkpoint\\n   775→   775→\\trequire.NotEmpty(t, checkpointIDs, \\\"Should have at least one checkpoint\\\")\\n   776→   776→\\tt.Logf(\\\"Checkpoint IDs: %v\\\", checkpointIDs)\\n   777→   777→}\\n   778→   778→\\n   779→   779→// TestE2E_ExistingFiles_StashModifications tests stashing modifications to\\n   780→   780→// tracked files (not new untracked files). This exercises the standard git stash\\n   781→   781→// behavior (without -u flag) since modifications to tracked files are stashable.\\n   782→   782→func TestE2E_ExistingFiles_StashModifications(t *testing.T) {\\n   783→   783→\\tt.Parallel()\\n   784→   784→\\n   785→   785→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   786→   786→\\n   787→   787→\\t// Create and commit two existing files\\n   788→   788→\\tenv.WriteFile(\\\"fileA.go\\\", \\\"package main\\\\n\\\\nfunc A() { /* original */ }\\\\n\\\")\\n   789→   789→\\tenv.WriteFile(\\\"fileB.go\\\", \\\"package main\\\\n\\\\nfunc B() { /* original */ }\\\\n\\\")\\n   790→   790→\\tenv.GitCommitWithShadowHooks(\\\"Add initial files\\\", \\\"fileA.go\\\", \\\"fileB.go\\\")\\n   791→   791→\\n   792→   792→\\t// Agent modifies both files\\n   793→   793→\\tt.Log(\\\"Agent modifying fileA.go and fileB.go\\\")\\n   794→   794→\\tprompt := `Modify these files:\\n   795→   795→1. In fileA.go, change the comment from \\\"original\\\" to \\\"modified by agent\\\"\\n   796→   796→2. In fileB.go, change the comment from \\\"original\\\" to \\\"modified by agent\\\"\\n   797→   797→Only modify these two files.`\\n   798→   798→\\n   799→   799→\\tresult, err := env.RunAgent(prompt)\\n   800→   800→\\trequire.NoError(t, err)\\n   801→   801→\\tAssertAgentSuccess(t, result, err)\\n   802→   802→\\n   803→   803→\\t// Verify both files were modified\\n   804→   804→\\tcontentA := env.ReadFile(\\\"fileA.go\\\")\\n   805→   805→\\tcontentB := env.ReadFile(\\\"fileB.go\\\")\\n   806→   806→\\tassert.Contains(t, contentA, \\\"modified by agent\\\", \\\"fileA.go should be modified\\\")\\n   807→   807→\\tassert.Contains(t, contentB, \\\"modified by agent\\\", \\\"fileB.go should be modified\\\")\\n   808→   808→\\n   809→   809→\\t// User commits only fileA.go\\n   810→   810→\\tt.Log(\\\"Committing only fileA.go\\\")\\n   811→   811→\\tenv.GitCommitWithShadowHooks(\\\"Update fileA\\\", \\\"fileA.go\\\")\\n   812→   812→\\tcheckpoint1 := env.GetLatestCheckpointID()\\n   813→   813→\\trequire.NotEmpty(t, checkpoint1, \\\"First commit should have checkpoint\\\")\\n   814→   814→\\n   815→   815→\\t// User stashes fileB.go modifications (tracked file, standard stash works)\\n   816→   816→\\tt.Log(\\\"Stashing fileB.go modifications\\\")\\n   817→   817→\\tenv.GitStash()\\n   818→   818→\\n   819→   819→\\t// Verify fileB.go is reverted to original\\n   820→   820→\\tcontentB = env.ReadFile(\\\"fileB.go\\\")\\n   821→   821→\\tassert.Contains(t, contentB, \\\"original\\\", \\\"fileB.go should be reverted after stash\\\")\\n   822→   822→\\tassert.NotContains(t, contentB, \\\"modified by agent\\\", \\\"fileB.go should not have agent changes\\\")\\n   823→   823→\\n   824→   824→\\t// User pops the stash and commits fileB.go\\n   825→   825→\\tt.Log(\\\"Popping stash and committing fileB.go\\\")\\n   826→   826→\\tenv.GitStashPop()\\n   827→   827→\\tcontentB = env.ReadFile(\\\"fileB.go\\\")\\n   828→   828→\\tassert.Contains(t, contentB, \\\"modified by agent\\\", \\\"fileB.go should have agent changes after stash pop\\\")\\n   829→   829→\\n   830→   830→\\tenv.GitCommitWithShadowHooks(\\\"Update fileB\\\", \\\"fileB.go\\\")\\n   831→   831→\\tcheckpoint2 := env.GetLatestCheckpointID()\\n   832→   832→\\n   833→   833→\\t// Both commits should have checkpoints\\n   834→   834→\\trequire.NotEmpty(t, checkpoint2, \\\"Second commit should have checkpoint\\\")\\n   835→   835→\\tassert.NotEqual(t, checkpoint1, checkpoint2, \\\"Checkpoints should be different\\\")\\n   836→   836→\\n   837→   837→\\tt.Logf(\\\"Checkpoint 1: %s, Checkpoint 2: %s\\\", checkpoint1, checkpoint2)\\n   838→   838→}\\n   839→   839→\\n   840→   840→// TestE2E_ExistingFiles_SplitCommits tests user splitting agent's modifications\\n   841→   841→// to multiple existing files into separate commits.\\n   842→   842→func TestE2E_ExistingFiles_SplitCommits(t *testing.T) {\\n   843→   843→\\tt.Parallel()\\n   844→   844→\\n   845→   845→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   846→   846→\\n   847→   847→\\t// Create and commit multiple existing files\\n   848→   848→\\tenv.WriteFile(\\\"model.go\\\", \\\"package main\\\\n\\\\ntype Model struct{}\\\\n\\\")\\n   849→   849→\\tenv.WriteFile(\\\"view.go\\\", \\\"package main\\\\n\\\\ntype View struct{}\\\\n\\\")\\n   850→   850→\\tenv.WriteFile(\\\"controller.go\\\", \\\"package main\\\\n\\\\ntype Controller struct{}\\\\n\\\")\\n   851→   851→\\tenv.GitCommitWithShadowHooks(\\\"Add MVC scaffolding\\\", \\\"model.go\\\", \\\"view.go\\\", \\\"controller.go\\\")\\n   852→   852→\\n   853→   853→\\t// Agent modifies all three files\\n   854→   854→\\tt.Log(\\\"Agent modifying model.go, view.go, controller.go\\\")\\n   855→   855→\\tprompt := `Add a Name field (string type) to each struct in these files:\\n   856→   856→1. model.go - add Name string to Model struct\\n   857→   857→2. view.go - add Name string to View struct\\n   858→   858→3. controller.go - add Name string to Controller struct\\n   859→   859→Only modify these three files.`\\n   860→   860→\\n   861→   861→\\tresult, err := env.RunAgent(prompt)\\n   862→   862→\\trequire.NoError(t, err)\\n   863→   863→\\tAssertAgentSuccess(t, result, err)\\n   864→   864→\\n   865→   865→\\t// User commits each file separately\\n   866→   866→\\tt.Log(\\\"Committing model.go\\\")\\n   867→   867→\\tenv.GitCommitWithShadowHooks(\\\"Add Name to Model\\\", \\\"model.go\\\")\\n   868→   868→\\tcheckpointModel := env.GetLatestCheckpointID()\\n   869→   869→\\trequire.NotEmpty(t, checkpointModel, \\\"Model commit should have checkpoint\\\")\\n   870→   870→\\n   871→   871→\\tt.Log(\\\"Committing view.go\\\")\\n   872→   872→\\tenv.GitCommitWithShadowHooks(\\\"Add Name to View\\\", \\\"view.go\\\")\\n   873→   873→\\tcheckpointView := env.GetLatestCheckpointID()\\n   874→   874→\\trequire.NotEmpty(t, checkpointView, \\\"View commit should have checkpoint\\\")\\n   875→   875→\\n   876→   876→\\tt.Log(\\\"Committing controller.go\\\")\\n   877→   877→\\tenv.GitCommitWithShadowHooks(\\\"Add Name to Controller\\\", \\\"controller.go\\\")\\n   878→   878→\\tcheckpointController := env.GetLatestCheckpointID()\\n   879→   879→\\trequire.NotEmpty(t, checkpointController, \\\"Controller commit should have checkpoint\\\")\\n   880→   880→\\n   881→   881→\\t// All three checkpoints should be different\\n   882→   882→\\tassert.NotEqual(t, checkpointModel, checkpointView)\\n   883→   883→\\tassert.NotEqual(t, checkpointView, checkpointController)\\n   884→   884→\\tassert.NotEqual(t, checkpointModel, checkpointController)\\n   885→   885→\\n   886→   886→\\tt.Logf(\\\"Checkpoints: model=%s, view=%s, controller=%s\\\",\\n   887→   887→\\t\\tcheckpointModel, checkpointView, checkpointController)\\n   888→   888→\\n   889→   889→\\t// Validate each checkpoint has the correct files_touched\\n   890→   890→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   891→   891→\\t\\tCheckpointID: checkpointModel,\\n   892→   892→\\t\\tStrategy:     \\\"manual-commit\\\",\\n   893→   893→\\t\\tFilesTouched: []string{\\\"model.go\\\"},\\n   894→   894→\\t})\\n   895→   895→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   896→   896→\\t\\tCheckpointID: checkpointView,\\n   897→   897→\\t\\tStrategy:     \\\"manual-commit\\\",\\n   898→   898→\\t\\tFilesTouched: []string{\\\"view.go\\\"},\\n   899→   899→\\t})\\n   900→   900→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   901→   901→\\t\\tCheckpointID: checkpointController,\\n   902→   902→\\t\\tStrategy:     \\\"manual-commit\\\",\\n   903→   903→\\t\\tFilesTouched: []string{\\\"controller.go\\\"},\\n   904→   904→\\t})\\n   905→   905→\\n   906→   906→\\t// No shadow branches should remain after all files committed\\n   907→   907→\\tentireBranches := env.ListBranchesWithPrefix(\\\"entire/\\\")\\n   908→   908→\\tfor _, b := range entireBranches {\\n   909→   909→\\t\\tassert.Equal(t, \\\"entire/checkpoints/v1\\\", b,\\n   910→   910→\\t\\t\\t\\\"Unexpected shadow branch after all files committed: %s\\\", b)\\n   911→   911→\\t}\\n   912→   912→}\\n   913→   913→\\n   914→   914→// TestE2E_ExistingFiles_RevertModification tests that modifying an existing file\\n   915→   915→// that was touched by the session ALWAYS gets a checkpoint, even if the user writes\\n   916→   916→// completely different content.\\n   917→   917→//\\n   918→   918→// This is intentional behavior: for files that already exist in HEAD (modified files),\\n   919→   919→// we always count as overlap because the user is editing a file the session worked on.\\n   920→   920→// Content-aware detection only applies to NEW files (don't exist in HEAD).\\n   921→   921→//\\n   922→   922→// See content_overlap.go for the rationale.\\n   923→   923→func TestE2E_ExistingFiles_RevertModification(t *testing.T) {\\n   924→   924→\\tt.Parallel()\\n   925→   925→\\n   926→   926→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   927→   927→\\n   928→   928→\\t// Create and commit an existing file\\n   929→   929→\\toriginalContent := `package main\\n   930→   930→\\n   931→   931→// placeholder\\n   932→   932→`\\n   933→   933→\\tenv.WriteFile(\\\"calc.go\\\", originalContent)\\n   934→   934→\\tenv.GitCommitWithShadowHooks(\\\"Add placeholder\\\", \\\"calc.go\\\")\\n   935→   935→\\n   936→   936→\\t// Agent modifies the existing file\\n   937→   937→\\tt.Log(\\\"Agent modifying calc.go\\\")\\n   938→   938→\\tprompt := `Replace the contents of calc.go with this exact code:\\n   939→   939→package main\\n   940→   940→\\n   941→   941→func AgentMultiply(a, b int) int {\\n   942→   942→\\treturn a * b\\n   943→   943→}\\n   944→   944→\\n   945→   945→Only modify calc.go, nothing else.`\\n   946→   946→\\n   947→   947→\\tresult, err := env.RunAgent(prompt)\\n   948→   948→\\trequire.NoError(t, err)\\n   949→   949→\\tAssertAgentSuccess(t, result, err)\\n   950→   950→\\n   951→   951→\\t// Verify agent modified the file\\n   952→   952→\\tmodifiedContent := env.ReadFile(\\\"calc.go\\\")\\n   953→   953→\\tassert.Contains(t, modifiedContent, \\\"AgentMultiply\\\", \\\"calc.go should have AgentMultiply function\\\")\\n   954→   954→\\n   955→   955→\\t// User reverts and writes completely different content\\n   956→   956→\\tt.Log(\\\"User reverting and writing completely different content\\\")\\n   957→   957→\\tuserContent := `package main\\n   958→   958→\\n   959→   959→func UserAdd(x, y int) int {\\n   960→   960→\\treturn x + y\\n   961→   961→}\\n   962→   962→`\\n   963→   963→\\tenv.WriteFile(\\\"calc.go\\\", userContent)\\n   964→   964→\\n   965→   965→\\t// User commits their changes\\n   966→   966→\\tt.Log(\\\"Committing user's changes\\\")\\n   967→   967→\\tenv.GitCommitWithShadowHooks(\\\"Add user functions\\\", \\\"calc.go\\\")\\n   968→   968→\\n   969→   969→\\t// For MODIFIED files (existing in HEAD), we always count as overlap.\\n   970→   970→\\t// The checkpoint SHOULD be created even though content is different.\\n   971→   971→\\t// This is because the session touched this file, so any commit to it\\n   972→   972→\\t// should be linked to preserve the editing history.\\n   973→   973→\\tcheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n   974→   974→\\tt.Logf(\\\"Checkpoint IDs: %v\\\", checkpointIDs)\\n   975→   975→\\n   976→   976→\\tlatestCheckpoint := env.GetLatestCheckpointID()\\n   977→   977→\\tassert.NotEmpty(t, latestCheckpoint,\\n   978→   978→\\t\\t\\\"Modified files should always get checkpoint (content-aware only applies to new files)\\\")\\n   979→   979→}\\n   980→   980→\\n   981→   981→// TestE2E_ExistingFiles_MixedNewAndModified tests a scenario where the agent\\n   982→   982→// both creates new files AND modifies existing files in the same session.\\n   983→   983→func TestE2E_ExistingFiles_MixedNewAndModified(t *testing.T) {\\n   984→   984→\\tt.Parallel()\\n   985→   985→\\n   986→   986→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   987→   987→\\n   988→   988→\\t// Create and commit an existing file\\n   989→   989→\\tenv.WriteFile(\\\"main.go\\\", `package main\\n   990→   990→\\n   991→   991→func main() {\\n   992→   992→\\t// TODO: add imports\\n   993→   993→}\\n   994→   994→`)\\n   995→   995→\\tenv.GitCommitWithShadowHooks(\\\"Add main.go\\\", \\\"main.go\\\")\\n   996→   996→\\n   997→   997→\\t// Agent modifies existing file AND creates new files\\n   998→   998→\\tt.Log(\\\"Agent modifying main.go and creating new files\\\")\\n   999→   999→\\tprompt := `Do these tasks:\\n  1000→  1000→1. Create a new file utils.go with: package main; func Helper() string { return \\\"helper\\\" }\\n  1001→  1001→2. Create a new file types.go with: package main; type Config struct { Name string }\\n  1002→  1002→3. Modify main.go to add a comment \\\"// imports utils and types\\\" at the top (after package main)\\n  1003→  1003→Complete all three tasks.`\\n  1004→  1004→\\n  1005→  1005→\\tresult, err := env.RunAgent(prompt)\\n  1006→  1006→\\trequire.NoError(t, err)\\n  1007→  1007→\\tAssertAgentSuccess(t, result, err)\\n  1008→  1008→\\n  1009→  1009→\\t// Verify all changes\\n  1010→  1010→\\trequire.True(t, env.FileExists(\\\"utils.go\\\"), \\\"utils.go should exist\\\")\\n  1011→  1011→\\trequire.True(t, env.FileExists(\\\"types.go\\\"), \\\"types.go should exist\\\")\\n  1012→  1012→\\tmainContent := env.ReadFile(\\\"main.go\\\")\\n  1013→  1013→\\tassert.Contains(t, mainContent, \\\"imports utils and types\\\", \\\"main.go should be modified\\\")\\n  1014→  1014→\\n  1015→  1015→\\t// User commits existing file modification first\\n  1016→  1016→\\tt.Log(\\\"Committing main.go modification\\\")\\n  1017→  1017→\\tenv.GitCommitWithShadowHooks(\\\"Update main.go imports comment\\\", \\\"main.go\\\")\\n  1018→  1018→\\tcheckpoint1 := env.GetLatestCheckpointID()\\n  1019→  1019→\\trequire.NotEmpty(t, checkpoint1, \\\"main.go commit should have checkpoint\\\")\\n  1020→  1020→\\n  1021→  1021→\\t// User commits new files together\\n  1022→  1022→\\tt.Log(\\\"Committing new files utils.go and types.go\\\")\\n  1023→  1023→\\tenv.GitCommitWithShadowHooks(\\\"Add utils and types\\\", \\\"utils.go\\\", \\\"types.go\\\")\\n  1024→  1024→\\tcheckpoint2 := env.GetLatestCheckpointID()\\n  1025→  1025→\\trequire.NotEmpty(t, checkpoint2, \\\"New files commit should have checkpoint\\\")\\n  1026→  1026→\\n  1027→  1027→\\tassert.NotEqual(t, checkpoint1, checkpoint2, \\\"Checkpoints should be different\\\")\\n  1028→  1028→\\tt.Logf(\\\"Checkpoint 1 (modified): %s, Checkpoint 2 (new): %s\\\", checkpoint1, checkpoint2)\\n  1029→  1029→}\\n  1030→  1030→\\n  1031→  1031→// TestE2E_EndedSession_UserCommitsAfterExit tests that after agent exits\\n  1032→  1032→// (session naturally ends), user commits still get checkpoint trailers.\\n  1033→  1033→// This exercises the ENDED + GitCommit → ActionCondenseIfFilesTouched path.\\n  1034→  1034→func TestE2E_EndedSession_UserCommitsAfterExit(t *testing.T) {\\n  1035→  1035→\\tt.Parallel()\\n  1036→  1036→\\n  1037→  1037→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n  1038→  1038→\\n  1039→  1039→\\t// Agent creates files A, B, C — session ends when agent exits\\n  1040→  1040→\\tprompt := `Create these files:\\n  1041→  1041→1. ended_a.go with content: package main; func EndedA() {}\\n  1042→  1042→2. ended_b.go with content: package main; func EndedB() {}\\n  1043→  1043→3. ended_c.go with content: package main; func EndedC() {}\\n  1044→  1044→Create all three files, nothing else.`\\n  1045→  1045→\\n  1046→  1046→\\tresult, err := env.RunAgent(prompt)\\n  1047→  1047→\\trequire.NoError(t, err)\\n  1048→  1048→\\tAssertAgentSuccess(t, result, err)\\n  1049→  1049→\\n  1050→  1050→\\trequire.True(t, env.FileExists(\\\"ended_a.go\\\"), \\\"ended_a.go should exist\\\")\\n  1051→  1051→\\trequire.True(t, env.FileExists(\\\"ended_b.go\\\"), \\\"ended_b.go should exist\\\")\\n  1052→  1052→\\trequire.True(t, env.FileExists(\\\"ended_c.go\\\"), \\\"ended_c.go should exist\\\")\\n  1053→  1053→\\n  1054→  1054→\\t// User commits A and B together\\n  1055→  1055→\\tt.Log(\\\"Committing ended_a.go and ended_b.go\\\")\\n  1056→  1056→\\tenv.GitCommitWithShadowHooks(\\\"Add ended files A and B\\\", \\\"ended_a.go\\\", \\\"ended_b.go\\\")\\n  1057→  1057→\\tcheckpointIDsAfterFirst := env.GetAllCheckpointIDsFromHistory()\\n  1058→  1058→\\trequire.GreaterOrEqual(t, len(checkpointIDsAfterFirst), 1, \\\"Should have first checkpoint\\\")\\n  1059→  1059→\\tcheckpointAB := checkpointIDsAfterFirst[0]\\n  1060→  1060→\\tt.Logf(\\\"Checkpoint for A,B: %s\\\", checkpointAB)\\n  1061→  1061→\\n  1062→  1062→\\t// User commits C\\n  1063→  1063→\\tt.Log(\\\"Committing ended_c.go\\\")\\n  1064→  1064→\\tenv.GitCommitWithShadowHooks(\\\"Add ended file C\\\", \\\"ended_c.go\\\")\\n  1065→  1065→\\tcheckpointIDsAfterSecond := env.GetAllCheckpointIDsFromHistory()\\n  1066→  1066→\\trequire.GreaterOrEqual(t, len(checkpointIDsAfterSecond), 2, \\\"Should have two checkpoints\\\")\\n  1067→  1067→\\tcheckpointC := checkpointIDsAfterSecond[0]\\n  1068→  1068→\\tt.Logf(\\\"Checkpoint for C: %s\\\", checkpointC)\\n  1069→  1069→\\n  1070→  1070→\\t// Checkpoint IDs must be unique\\n  1071→  1071→\\tassert.NotEqual(t, checkpointAB, checkpointC,\\n  1072→  1072→\\t\\t\\\"Each commit should have its own unique checkpoint ID\\\")\\n  1073→  1073→\\n  1074→  1074→\\t// Validate both checkpoints\\n  1075→  1075→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n  1076→  1076→\\t\\tCheckpointID: checkpointAB,\\n  1077→  1077→\\t\\tStrategy:     \\\"manual-commit\\\",\\n  1078→  1078→\\t\\tFilesTouched: []string{\\\"ended_a.go\\\", \\\"ended_b.go\\\"},\\n  1079→  1079→\\t})\\n  1080→  1080→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n  1081→  1081→\\t\\tCheckpointID: checkpointC,\\n  1082→  1082→\\t\\tStrategy:     \\\"manual-commit\\\",\\n  1083→  1083→\\t\\tFilesTouched: []string{\\\"ended_c.go\\\"},\\n  1084→  1084→\\t})\\n  1085→  1085→\\n  1086→  1086→\\t// No shadow branches should remain\\n  1087→  1087→\\tentireBranches := env.ListBranchesWithPrefix(\\\"entire/\\\")\\n  1088→  1088→\\tfor _, b := range entireBranches {\\n  1089→  1089→\\t\\tassert.Equal(t, \\\"entire/checkpoints/v1\\\", b,\\n  1090→  1090→\\t\\t\\t\\\"Unexpected shadow branch after all files committed: %s\\\", b)\\n  1091→  1091→\\t}\\n  1092→  1092→}\\n  1093→  1093→\\n  1094→  1094→// TestE2E_DeletedFiles_CommitDeletion tests that deleting a file that was tracked\\n  1095→  1095→// in the session gets handled properly when committed via git rm.\\n  1096→  1096→func TestE2E_DeletedFiles_CommitDeletion(t *testing.T) {\\n  1097→  1097→\\tt.Parallel()\\n  1098→  1098→\\n  1099→  1099→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n  1100→  1100→\\n  1101→  1101→\\t// Pre-commit a file that will be deleted\\n  1102→  1102→\\tenv.WriteFile(\\\"to_delete.go\\\", \\\"package main\\\\n\\\\nfunc ToDelete() {}\\\\n\\\")\\n  1103→  1103→\\tenv.GitCommitWithShadowHooks(\\\"Add to_delete.go\\\", \\\"to_delete.go\\\")\\n  1104→  1104→\\n  1105→  1105→\\t// Agent deletes it and creates a replacement\\n  1106→  1106→\\tprompt := `Do these two tasks:\\n  1107→  1107→1. Delete the file to_delete.go (use: rm to_delete.go)\\n  1108→  1108→2. Create a new file replacement.go with content: package main; func Replacement() {}\\n  1109→  1109→\\n  1110→  1110→Do both tasks.`\\n  1111→  1111→\\n  1112→  1112→\\tresult, err := env.RunAgentWithTools(prompt, []string{\\\"Write\\\", \\\"Bash\\\"})\\n  1113→  1113→\\trequire.NoError(t, err)\\n  1114→  1114→\\tAssertAgentSuccess(t, result, err)\\n  1115→  1115→\\n  1116→  1116→\\t// to_delete.go should be gone, replacement.go should exist\\n  1117→  1117→\\tassert.False(t, env.FileExists(\\\"to_delete.go\\\"), \\\"to_delete.go should be deleted\\\")\\n  1118→  1118→\\trequire.True(t, env.FileExists(\\\"replacement.go\\\"), \\\"replacement.go should exist\\\")\\n  1119→  1119→\\n  1120→  1120→\\t// Commit the replacement file first\\n  1121→  1121→\\tt.Log(\\\"Committing replacement.go\\\")\\n  1122→  1122→\\tenv.GitCommitWithShadowHooks(\\\"Add replacement\\\", \\\"replacement.go\\\")\\n  1123→  1123→\\tcheckpointIDsAfterFirst := env.GetAllCheckpointIDsFromHistory()\\n  1124→  1124→\\trequire.GreaterOrEqual(t, len(checkpointIDsAfterFirst), 1, \\\"Should have checkpoint for replacement\\\")\\n  1125→  1125→\\tcheckpointReplacement := checkpointIDsAfterFirst[0]\\n  1126→  1126→\\tt.Logf(\\\"Checkpoint for replacement: %s\\\", checkpointReplacement)\\n  1127→  1127→\\n  1128→  1128→\\t// Commit the deletion via git rm\\n  1129→  1129→\\tt.Log(\\\"Committing deletion of to_delete.go\\\")\\n  1130→  1130→\\tenv.GitRm(\\\"to_delete.go\\\")\\n  1131→  1131→\\tenv.GitCommitStagedWithShadowHooks(\\\"Remove to_delete.go\\\")\\n  1132→  1132→\\n  1133→  1133→\\t// Check if deletion got a checkpoint trailer\\n  1134→  1134→\\tcheckpointIDsAfterSecond := env.GetAllCheckpointIDsFromHistory()\\n  1135→  1135→\\tif len(checkpointIDsAfterSecond) > len(checkpointIDsAfterFirst) {\\n  1136→  1136→\\t\\tcheckpointDeletion := checkpointIDsAfterSecond[0]\\n  1137→  1137→\\t\\tt.Logf(\\\"Checkpoint for deletion: %s (carry-forward for deleted file)\\\", checkpointDeletion)\\n  1138→  1138→\\t\\tassert.NotEqual(t, checkpointReplacement, checkpointDeletion,\\n  1139→  1139→\\t\\t\\t\\\"Checkpoint IDs should be unique\\\")\\n  1140→  1140→\\t\\tenv.ValidateCheckpoint(CheckpointValidation{\\n  1141→  1141→\\t\\t\\tCheckpointID: checkpointDeletion,\\n  1142→  1142→\\t\\t\\tStrategy:     \\\"manual-commit\\\",\\n  1143→  1143→\\t\\t})\\n  1144→  1144→\\t} else {\\n  1145→  1145→\\t\\tt.Log(\\\"Deletion commit has no checkpoint trailer (deleted files may not carry forward)\\\")\\n  1146→  1146→\\t}\\n  1147→  1147→\\n  1148→  1148→\\t// Validate the replacement checkpoint\\n  1149→  1149→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n  1150→  1150→\\t\\tCheckpointID: checkpointReplacement,\\n  1151→  1151→\\t\\tStrategy:     \\\"manual-commit\\\",\\n  1152→  1152→\\t})\\n  1153→  1153→}\\n  1154→  1154→\\n  1155→  1155→// TestE2E_AgentCommitsMidTurn_UserCommitsRemainder tests that when the agent\\n  1156→  1156→// commits some files during its turn and the user commits the rest after,\\n  1157→  1157→// both get valid checkpoint trailers.\\n  1158→  1158→func TestE2E_AgentCommitsMidTurn_UserCommitsRemainder(t *testing.T) {\\n  1159→  1159→\\tt.Parallel()\\n  1160→  1160→\\n  1161→  1161→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n  1162→  1162→\\n  1163→  1163→\\tcommitsBefore := env.GetCommitCount()\\n  1164→  1164→\\n  1165→  1165→\\t// Agent creates 3 files and commits 2 mid-turn\\n  1166→  1166→\\tprompt := `Do these tasks in order:\\n  1167→  1167→1. Create file agent_mid1.go with content: package main; func AgentMid1() {}\\n  1168→  1168→2. Create file agent_mid2.go with content: package main; func AgentMid2() {}\\n  1169→  1169→3. Commit these two files: git add agent_mid1.go agent_mid2.go && git commit -m \\\"Agent adds mid1 and mid2\\\"\\n  1170→  1170→4. Create file user_remainder.go with content: package main; func UserRemainder() {}\\n  1171→  1171→\\n  1172→  1172→Do all tasks in order. Create each file, then commit the first two, then create the third.`\\n  1173→  1173→\\n  1174→  1174→\\tresult, err := env.RunAgentWithTools(prompt, []string{\\\"Write\\\", \\\"Bash\\\"})\\n  1175→  1175→\\trequire.NoError(t, err)\\n  1176→  1176→\\tAssertAgentSuccess(t, result, err)\\n  1177→  1177→\\n  1178→  1178→\\t// Verify all files were created\\n  1179→  1179→\\trequire.True(t, env.FileExists(\\\"agent_mid1.go\\\"), \\\"agent_mid1.go should exist\\\")\\n  1180→  1180→\\trequire.True(t, env.FileExists(\\\"agent_mid2.go\\\"), \\\"agent_mid2.go should exist\\\")\\n  1181→  1181→\\trequire.True(t, env.FileExists(\\\"user_remainder.go\\\"), \\\"user_remainder.go should exist\\\")\\n  1182→  1182→\\n  1183→  1183→\\t// Verify agent made a commit\\n  1184→  1184→\\tcommitsAfter := env.GetCommitCount()\\n  1185→  1185→\\tassert.Greater(t, commitsAfter, commitsBefore, \\\"Agent should have made a commit\\\")\\n  1186→  1186→\\n  1187→  1187→\\t// Get agent checkpoint IDs\\n  1188→  1188→\\tagentCheckpointIDs := env.GetAllCheckpointIDsFromHistory()\\n  1189→  1189→\\tt.Logf(\\\"Agent checkpoint IDs: %v\\\"