alf(\\\"failed to write commit message file: %v\\\", err)\\n   441→\\t}\\n   442→\\n   443→\\t// Run prepare-commit-msg hook\\n   444→\\t//nolint:gosec,noctx // test code, args are from trusted test setup, no context needed\\n   445→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile)\\n   446→\\tprepCmd.Dir = env.RepoDir\\n   447→\\tprepCmd.Env = append(os.Environ(),\\n   448→\\t\\t\\\"ENTIRE_TEST_TTY=1\\\",\\n   449→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".claude\\\"),\\n   450→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".gemini\\\"),\\n   451→\\t)\\n   452→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n   453→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n   454→\\t}\\n   455→\\n   456→\\t// Read the modified message (with trailer added by hook)\\n   457→\\t//nolint:gosec // test code, path is from test setup\\n   458→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n   459→\\tif err != nil {\\n   460→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n   461→\\t}\\n   462→\\n   463→\\t// REMOVE the Entire-Checkpoint trailer (simulating user editing the message)\\n   464→\\tlines := strings.Split(string(modifiedMsg), \\\"\\\\n\\\")\\n   465→\\tvar cleanedLines []string\\n   466→\\tfor _, line := range lines {\\n   467→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   468→\\t\\t\\tcontinue\\n   469→\\t\\t}\\n   470→\\t\\tif strings.Contains(line, \\\"Remove the Entire-Checkpoint trailer\\\") {\\n   471→\\t\\t\\tcontinue\\n   472→\\t\\t}\\n   473→\\t\\tif strings.Contains(line, \\\"trailer will be added to your next commit\\\") {\\n   474→\\t\\t\\tcontinue\\n   475→\\t\\t}\\n   476→\\t\\tcleanedLines = append(cleanedLines, line)\\n   477→\\t}\\n   478→\\tcleanedMsg := strings.TrimRight(strings.Join(cleanedLines, \\\"\\\\n\\\"), \\\"\\\\n\\\") + \\\"\\\\n\\\"\\n   479→\\n   480→\\t// Create the commit using go-git with the cleaned message (no trailer)\\n   481→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   482→\\tif err != nil {\\n   483→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   484→\\t}\\n   485→\\n   486→\\tworktree, err := repo.Worktree()\\n   487→\\tif err != nil {\\n   488→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   489→\\t}\\n   490→\\n   491→\\t_, err = worktree.Commit(cleanedMsg, &git.CommitOptions{\\n   492→\\t\\tAuthor: &object.Signature{\\n   493→\\t\\t\\tName:  \\\"E2E Test User\\\",\\n   494→\\t\\t\\tEmail: \\\"e2e-test@example.com\\\",\\n   495→\\t\\t\\tWhen:  time.Now(),\\n   496→\\t\\t},\\n   497→\\t})\\n   498→\\tif err != nil {\\n   499→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   500→\\t}\\n   501→\\n   502→\\t// Run post-commit hook - since trailer was removed, no condensation should happen\\n   503→\\t//nolint:gosec,noctx // test code, args are from trusted test setup, no context needed\\n   504→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n   505→\\tpostCmd.Dir = env.RepoDir\\n   506→\\tpostCmd.Env = append(os.Environ(),\\n   507→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".claude\\\"),\\n   508→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".gemini\\\"),\\n   509→\\t)\\n   510→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n   511→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n   512→\\t}\\n   513→}\\n   514→\\n   515→// GitCheckoutNewBranch creates and checks out a new branch.\\n   516→func (env *TestEnv) GitCheckoutNewBranch(branchName string) {\\n   517→\\tenv.T.Helper()\\n   518→\\n   519→\\t//nolint:noctx // test code, no context needed for git checkout\\n   520→\\tcmd := exec.Command(\\\"git\\\", \\\"checkout\\\", \\\"-b\\\", branchName)\\n   521→\\tcmd.Dir = env.RepoDir\\n   522→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   523→\\t\\tenv.T.Fatalf(\\\"failed to checkout new branch %s: %v\\\\nOutput: %s\\\", branchName, err, output)\\n   524→\\t}\\n   525→}\\n   526→\\n   527→// GetHeadHash returns the current HEAD commit hash.\\n   528→func (env *TestEnv) GetHeadHash() string {\\n   529→\\tenv.T.Helper()\\n   530→\\n   531→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   532→\\tif err != nil {\\n   533→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   534→\\t}\\n   535→\\n   536→\\thead, err := repo.Head()\\n   537→\\tif err != nil {\\n   538→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   539→\\t}\\n   540→\\n   541→\\treturn head.Hash().String()\\n   542→}\\n   543→\\n   544→// RewindPoint mirrors the rewind --list JSON output.\\n   545→type RewindPoint struct {\\n   546→\\tID               string    `json:\\\"id\\\"`\\n   547→\\tMessage          string    `json:\\\"message\\\"`\\n   548→\\tMetadataDir      string    `json:\\\"metadata_dir\\\"`\\n   549→\\tDate             time.Time `json:\\\"date\\\"`\\n   550→\\tIsTaskCheckpoint bool      `json:\\\"is_task_checkpoint\\\"`\\n   551→\\tToolUseID        string    `json:\\\"tool_use_id\\\"`\\n   552→\\tIsLogsOnly       bool      `json:\\\"is_logs_only\\\"`\\n   553→\\tCondensationID   string    `json:\\\"condensation_id\\\"`\\n   554→}\\n   555→\\n   556→// GetRewindPoints returns available rewind points using the CLI.\\n   557→func (env *TestEnv) GetRewindPoints() []RewindPoint {\\n   558→\\tenv.T.Helper()\\n   559→\\n   560→\\t//nolint:gosec,noctx // test code, args are static, no context needed\\n   561→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--list\\\")\\n   562→\\tcmd.Dir = env.RepoDir\\n   563→\\n   564→\\toutput, err := cmd.CombinedOutput()\\n   565→\\tif err != nil {\\n   566→\\t\\tenv.T.Fatalf(\\\"rewind --list failed: %v\\\\nOutput: %s\\\", err, output)\\n   567→\\t}\\n   568→\\n   569→\\t// Parse JSON output\\n   570→\\tvar jsonPoints []struct {\\n   571→\\t\\tID               string `json:\\\"id\\\"`\\n   572→\\t\\tMessage          string `json:\\\"message\\\"`\\n   573→\\t\\tMetadataDir      string `json:\\\"metadata_dir\\\"`\\n   574→\\t\\tDate             string `json:\\\"date\\\"`\\n   575→\\t\\tIsTaskCheckpoint bool   `json:\\\"is_task_checkpoint\\\"`\\n   576→\\t\\tToolUseID        string `json:\\\"tool_use_id\\\"`\\n   577→\\t\\tIsLogsOnly       bool   `json:\\\"is_logs_only\\\"`\\n   578→\\t\\tCondensationID   string `json:\\\"condensation_id\\\"`\\n   579→\\t}\\n   580→\\n   581→\\tif err := json.Unmarshal(output, &jsonPoints); err != nil {\\n   582→\\t\\tenv.T.Fatalf(\\\"failed to parse rewind points: %v\\\\nOutput: %s\\\", err, output)\\n   583→\\t}\\n   584→\\n   585→\\tpoints := make([]RewindPoint, len(jsonPoints))\\n   586→\\tfor i, jp := range jsonPoints {\\n   587→\\t\\t//nolint:errcheck // date parsing failure is acceptable, defaults to zero time\\n   588→\\t\\tdate, _ := time.Parse(time.RFC3339, jp.Date)\\n   589→\\t\\tpoints[i] = RewindPoint{\\n   590→\\t\\t\\tID:               jp.ID,\\n   591→\\t\\t\\tMessage:          jp.Message,\\n   592→\\t\\t\\tMetadataDir:      jp.MetadataDir,\\n   593→\\t\\t\\tDate:             date,\\n   594→\\t\\t\\tIsTaskCheckpoint: jp.IsTaskCheckpoint,\\n   595→\\t\\t\\tToolUseID:        jp.ToolUseID,\\n   596→\\t\\t\\tIsLogsOnly:       jp.IsLogsOnly,\\n   597→\\t\\t\\tCondensationID:   jp.CondensationID,\\n   598→\\t\\t}\\n   599→\\t}\\n   600→\\n   601→\\treturn points\\n   602→}\\n   603→\\n   604→// Rewind performs a rewind to the specified commit ID using the CLI.\\n   605→func (env *TestEnv) Rewind(commitID string) error {\\n   606→\\tenv.T.Helper()\\n   607→\\n   608→\\t//nolint:gosec,noctx // test code, commitID is from test setup, no context needed\\n   609→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID)\\n   610→\\tcmd.Dir = env.RepoDir\\n   611→\\n   612→\\toutput, err := cmd.CombinedOutput()\\n   613→\\tif err != nil {\\n   614→\\t\\treturn errors.New(\\\"rewind failed: \\\" + string(output))\\n   615→\\t}\\n   616→\\n   617→\\tenv.T.Logf(\\\"Rewind output: %s\\\", output)\\n   618→\\treturn nil\\n   619→}\\n   620→\\n   621→// BranchExists checks if a branch exists in the repository.\\n   622→func (env *TestEnv) BranchExists(branchName string) bool {\\n   623→\\tenv.T.Helper()\\n   624→\\n   625→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   626→\\tif err != nil {\\n   627→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   628→\\t}\\n   629→\\n   630→\\trefs, err := repo.References()\\n   631→\\tif err != nil {\\n   632→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   633→\\t}\\n   634→\\n   635→\\tfound := false\\n   636→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   637→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   638→\\t\\tif ref.Name().Short() == branchName {\\n   639→\\t\\t\\tfound = true\\n   640→\\t\\t}\\n   641→\\t\\treturn nil\\n   642→\\t})\\n   643→\\n   644→\\treturn found\\n   645→}\\n   646→\\n   647→// ListBranchesWithPrefix returns all branches that start with the given prefix.\\n   648→func (env *TestEnv) ListBranchesWithPrefix(prefix string) []string {\\n   649→\\tenv.T.Helper()\\n   650→\\n   651→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   652→\\tif err != nil {\\n   653→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   654→\\t}\\n   655→\\n   656→\\trefs, err := repo.References()\\n   657→\\tif err != nil {\\n   658→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   659→\\t}\\n   660→\\n   661→\\tvar branches []string\\n   662→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   663→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   664→\\t\\tname := ref.Name().Short()\\n   665→\\t\\tif strings.HasPrefix(name, prefix) {\\n   666→\\t\\t\\tbranches = append(branches, name)\\n   667→\\t\\t}\\n   668→\\t\\treturn nil\\n   669→\\t})\\n   670→\\n   671→\\treturn branches\\n   672→}\\n   673→\\n   674→// GetCommitMessage returns the commit message for the given commit hash.\\n   675→func (env *TestEnv) GetCommitMessage(hash string) string {\\n   676→\\tenv.T.Helper()\\n   677→\\n   678→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   679→\\tif err != nil {\\n   680→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   681→\\t}\\n   682→\\n   683→\\tcommitHash := plumbing.NewHash(hash)\\n   684→\\tcommit, err := repo.CommitObject(commitHash)\\n   685→\\tif err != nil {\\n   686→\\t\\tenv.T.Fatalf(\\\"failed to get commit %s: %v\\\", hash, err)\\n   687→\\t}\\n   688→\\n   689→\\treturn commit.Message\\n   690→}\\n   691→\\n   692→// GetLatestCheckpointIDFromHistory walks backwards from HEAD and returns\\n   693→// the checkpoint ID from the first commit with an Entire-Checkpoint trailer.\\n   694→// Returns an error if no checkpoint trailer is found in any commit.\\n   695→func (env *TestEnv) GetLatestCheckpointIDFromHistory() (string, error) {\\n   696→\\tenv.T.Helper()\\n   697→\\n   698→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   699→\\tif err != nil {\\n   700→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   701→\\t}\\n   702→\\n   703→\\thead, err := repo.Head()\\n   704→\\tif err != nil {\\n   705→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   706→\\t}\\n   707→\\n   708→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   709→\\tif err != nil {\\n   710→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   711→\\t}\\n   712→\\n   713→\\tvar checkpointID string\\n   714→\\t//nolint:errcheck,gosec // ForEach callback returns error to stop iteration, not a real error\\n   715→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   716→\\t\\t// Look for Entire-Checkpoint trailer\\n   717→\\t\\tfor _, line := range strings.Split(c.Message, \\\"\\\\n\\\") {\\n   718→\\t\\t\\tline = strings.TrimSpace(line)\\n   719→\\t\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   720→\\t\\t\\t\\tcheckpointID = strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   721→\\t\\t\\t\\treturn errors.New(\\\"stop iteration\\\")\\n   722→\\t\\t\\t}\\n   723→\\t\\t}\\n   724→\\t\\treturn nil\\n   725→\\t})\\n   726→\\n   727→\\tif checkpointID == \\\"\\\" {\\n   728→\\t\\treturn \\\"\\\", errors.New(\\\"no commit with Entire-Checkpoint trailer found in history\\\")\\n   729→\\t}\\n   730→\\n   731→\\treturn checkpointID, nil\\n   732→}\\n   733→\\n   734→// GetLatestCheckpointID returns the checkpoint ID from HEAD commit, or empty string if none.\\n   735→// This is a convenience wrapper that doesn't fail the test on missing checkpoint.\\n   736→func (env *TestEnv) GetLatestCheckpointID() string {\\n   737→\\tenv.T.Helper()\\n   738→\\n   739→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   740→\\tif err != nil {\\n   741→\\t\\treturn \\\"\\\"\\n   742→\\t}\\n   743→\\n   744→\\thead, err := repo.Head()\\n   745→\\tif err != nil {\\n   746→\\t\\treturn \\\"\\\"\\n   747→\\t}\\n   748→\\n   749→\\tcommit, err := repo.CommitObject(head.Hash())\\n   750→\\tif err != nil {\\n   751→\\t\\treturn \\\"\\\"\\n   752→\\t}\\n   753→\\n   754→\\t// Look for Entire-Checkpoint trailer in HEAD commit only\\n   755→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n   756→\\t\\tline = strings.TrimSpace(line)\\n   757→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   758→\\t\\t\\treturn strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   759→\\t\\t}\\n   760→\\t}\\n   761→\\treturn \\\"\\\"\\n   762→}\\n   763→\\n   764→// safeIDPrefix returns first 12 chars of ID or the full ID if shorter.\\n   765→// Use this when logging checkpoint IDs to avoid index out of bounds panic.\\n   766→func safeIDPrefix(id string) string {\\n   767→\\tif len(id) >= 12 {\\n   768→\\t\\treturn id[:12]\\n   769→\\t}\\n   770→\\treturn id\\n   771→}\\n   772→\\n   773→// RunCLI runs the entire CLI with the given arguments and returns stdout.\\n   774→func (env *TestEnv) RunCLI(args ...string) string {\\n   775→\\tenv.T.Helper()\\n   776→\\toutput, err := env.RunCLIWithError(args...)\\n   777→\\tif err != nil {\\n   778→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   779→\\t}\\n   780→\\treturn output\\n   781→}\\n   782→\\n   783→// RunCLIWithError runs the entire CLI and returns output and error.\\n   784→func (env *TestEnv) RunCLIWithError(args ...string) (string, error) {\\n   785→\\tenv.T.Helper()\\n   786→\\n   787→\\t//nolint:gosec,noctx // test code, args are from test setup, no context needed\\n   788→\\tcmd := exec.Command(getTestBinary(), args...)\\n   789→\\tcmd.Dir = env.RepoDir\\n   790→\\n   791→\\toutput, err := cmd.CombinedOutput()\\n   792→\\treturn string(output), err\\n   793→}\\n   794→\\n   795→// RunAgent runs the agent with the given prompt and returns the result.\\n   796→func (env *TestEnv) RunAgent(prompt string) (*AgentResult, error) {\\n   797→\\tenv.T.Helper()\\n   798→\\tresult, err := env.Agent.RunPrompt(context.Background(), env.RepoDir, prompt)\\n   799→\\tif err != nil && result != nil {\\n   800→\\t\\tenv.T.Logf(\\\"Agent failed with exit code %d\\\", result.ExitCode)\\n   801→\\t\\tif result.Stderr != \\\"\\\" {\\n   802→\\t\\t\\tenv.T.Logf(\\\"Agent stderr: %s\\\", result.Stderr)\\n   803→\\t\\t}\\n   804→\\t\\tif result.Stdout != \\\"\\\" {\\n   805→\\t\\t\\tenv.T.Logf(\\\"Agent stdout: %s\\\", result.Stdout)\\n   806→\\t\\t}\\n   807→\\t}\\n   808→\\t//nolint:wrapcheck // test helper, caller handles error\\n   809→\\treturn result, err\\n   810→}\\n   811→\\n   812→// RunAgentWithTools runs the agent with specific tools enabled.\\n   813→func (env *TestEnv) RunAgentWithTools(prompt string, tools []string) (*AgentResult, error) {\\n   814→\\tenv.T.Helper()\\n   8