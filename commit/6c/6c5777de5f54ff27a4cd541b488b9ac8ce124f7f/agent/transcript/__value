ommits(t *testing.T) {\\n    24→    24→\\tt.Parallel()\\n    25→    25→\\n    26→    26→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n    27→    27→\\n    28→    28→\\t// Count commits before\\n    29→    29→\\tcommitsBefore := env.GetCommitCount()\\n    30→    30→\\tt.Logf(\\\"Commits before: %d\\\", commitsBefore)\\n    31→    31→\\n    32→    32→\\t// Agent creates multiple files and commits them separately\\n    33→    33→\\tgranularCommitPrompt := `Please do the following tasks, committing after each one:\\n    34→    34→\\n    35→    35→1. Create a file called file1.go with this content:\\n    36→    36→   package main\\n    37→    37→   func One() int { return 1 }\\n    38→    38→   Then run: git add file1.go && git commit -m \\\"Add file1\\\"\\n    39→    39→\\n    40→    40→2. Create a file called file2.go with this content:\\n    41→    41→   package main\\n    42→    42→   func Two() int { return 2 }\\n    43→    43→   Then run: git add file2.go && git commit -m \\\"Add file2\\\"\\n    44→    44→\\n    45→    45→3. Create a file called file3.go with this content:\\n    46→    46→   package main\\n    47→    47→   func Three() int { return 3 }\\n    48→    48→   Then run: git add file3.go && git commit -m \\\"Add file3\\\"\\n    49→    49→\\n    50→    50→Do each task in order, making the commit after each file creation.`\\n    51→    51→\\n    52→    52→\\tresult, err := env.RunAgentWithTools(granularCommitPrompt, []string{\\\"Write\\\", \\\"Bash\\\"})\\n    53→    53→\\trequire.NoError(t, err)\\n    54→    54→\\tAssertAgentSuccess(t, result, err)\\n    55→    55→\\tt.Logf(\\\"Agent output: %s\\\", result.Stdout)\\n    56→    56→\\n    57→    57→\\t// Verify all files were created\\n    58→    58→\\tassert.True(t, env.FileExists(\\\"file1.go\\\"), \\\"file1.go should exist\\\")\\n    59→    59→\\tassert.True(t, env.FileExists(\\\"file2.go\\\"), \\\"file2.go should exist\\\")\\n    60→    60→\\tassert.True(t, env.FileExists(\\\"file3.go\\\"), \