→\\n   549→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   550→\\tif err != nil {\\n   551→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   552→\\t}\\n   553→\\n   554→\\thead, err := repo.Head()\\n   555→\\tif err != nil {\\n   556→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   557→\\t}\\n   558→\\n   559→\\treturn head.Hash().String()\\n   560→}\\n   561→\\n   562→// RewindPoint mirrors the rewind --list JSON output.\\n   563→type RewindPoint struct {\\n   564→\\tID               string    `json:\\\"id\\\"`\\n   565→\\tMessage          string    `json:\\\"message\\\"`\\n   566→\\tMetadataDir      string    `json:\\\"metadata_dir\\\"`\\n   567→\\tDate             time.Time `json:\\\"date\\\"`\\n   568→\\tIsTaskCheckpoint bool      `json:\\\"is_task_checkpoint\\\"`\\n   569→\\tToolUseID        string    `json:\\\"tool_use_id\\\"`\\n   570→\\tIsLogsOnly       bool      `json:\\\"is_logs_only\\\"`\\n   571→\\tCondensationID   string    `json:\\\"condensation_id\\\"`\\n   572→}\\n   573→\\n   574→// GetRewindPoints returns available rewind points using the CLI.\\n   575→func (env *TestEnv) GetRewindPoints() []RewindPoint {\\n   576→\\tenv.T.Helper()\\n   577→\\n   578→\\t//nolint:gosec,noctx // test code, args are static, no context needed\\n   579→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--list\\\")\\n   580→\\tcmd.Dir = env.RepoDir\\n   581→\\n   582→\\toutput, err := cmd.CombinedOutput()\\n   583→\\tif err != nil {\\n   584→\\t\\tenv.T.Fatalf(\\\"rewind --list failed: %v\\\\nOutput: %s\\\", err, output)\\n   585→\\t}\\n   586→\\n   587→\\t// Parse JSON output\\n   588→\\tvar jsonPoints []struct {\\n   589→\\t\\tID               string `json:\\\"id\\\"`\\n   590→\\t\\tMessage          string `json:\\\"message\\\"`\\n   591→\\t\\tMetadataDir      string `json:\\\"metadata_dir\\\"`\\n   592→\\t\\tDate             string `json:\\\"date\\\"`\\n   593→\\t\\tIsTaskCheckpoint bool   `json:\\\"is_task_checkpoint\\\"`\\n   594