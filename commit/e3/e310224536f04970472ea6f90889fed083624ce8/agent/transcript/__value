\"tool_result\",\"content\":\"     1→//go:build e2e\\n     2→\\n     3→package e2e\\n     4→\\n     5→import (\\n     6→\\t\\\"bytes\\\"\\n     7→\\t\\\"context\\\"\\n     8→\\t\\\"errors\\\"\\n     9→\\t\\\"fmt\\\"\\n    10→\\t\\\"os\\\"\\n    11→\\t\\\"os/exec\\\"\\n    12→\\t\\\"strings\\\"\\n    13→\\t\\\"time\\\"\\n    14→)\\n    15→\\n    16→// AgentNameClaudeCode is the name for Claude Code agent.\\n    17→const AgentNameClaudeCode = \\\"claude-code\\\"\\n    18→\\n    19→// AgentNameGemini is the name for Gemini CLI agent.\\n    20→const AgentNameGemini = \\\"gemini\\\"\\n    21→\\n    22→// AgentNameFactoryAIDroid is the name for Factory AI Droid agent.\\n    23→const AgentNameFactoryAIDroid = \\\"factoryai-droid\\\"\\n    24→\\n    25→// AgentNameOpenCode is the name for OpenCode agent.\\n    26→const AgentNameOpenCode = \\\"opencode\\\"\\n    27→\\n    28→// AgentRunner abstracts invoking a coding agent for e2e tests.\\n    29→// This follows the multi-agent pattern from cmd/entire/cli/agent/agent.go.\\n    30→type AgentRunner interface {\\n    31→\\t// Name returns the agent name (e.g., \\\"claude-code\\\", \\\"gemini-cli\\\")\\n    32→\\tName() string\\n    33→\\n    34→\\t// IsAvailable checks if the agent CLI is installed and authenticated\\n    35→\\tIsAvailable() (bool, error)\\n    36→\\n    37→\\t// RunPrompt executes a prompt and returns the result\\n    38→\\tRunPrompt(ctx context.Context, workDir string, prompt string) (*AgentResult, error)\\n    39→\\n    40→\\t// RunPromptWithTools executes with specific allowed tools\\n    41→\\tRunPromptWithTools(ctx context.Context, workDir string, prompt string, tools []string) (*AgentResult, error)\\n    42→}\\n    43→\\n    44→// AgentResult holds the result of an agent invocation.\\n    45→type AgentResult struct {\\n    46→\\tStdout   string\\n    47→\\tStderr   string\\n    48→\\tExitCode int\\n    49→\\tDuration time.Duration\\n    50→}\\n    51→\\n    52→// AgentRunnerConfig holds configuration for agent runners.\\n    53→type AgentRunnerConfig struct {\\n    54→\\tModel   string        // Model to use (e.g., \\\"haiku\\\" for Claude)\\n    55→\\tTimeout time.Duration // Timeout per prompt\\n    56→}\\n    57→\\n    58→// NewAgentRunner creates an agent runner based on the agent name.\\n    59→//\\n    60→//nolint:ireturn // factory pattern intentionally returns interface\\n    61→func NewAgentRunner(name string, config AgentRunnerConfig) AgentRunner {\\n    62→\\tswitch name {\\n    63→\\tcase AgentNameClaudeCode:\\n    64→\\t\\treturn NewClaudeCodeRunner(config)\\n    65→\\tcase AgentNameGemini:\\n    66→\\t\\treturn NewGeminiCLIRunner(config)\\n    67→\\tcase AgentNameFactoryAIDroid:\\n    68→\\t\\treturn NewFactoryAIDroidRunner(config)\\n    69→\\tcase AgentNameOpenCode:\\n    70→\\t\\treturn NewOpenCodeRunner(config)\\n    71→\\tdefault:\\n    72→\\t\\t// Return a runner that reports as unavailable\\n    73→\\t\\treturn &unavailableRunner{name: name}\\n    74→\\t}\\n    75→}\\n    76→\\n    77→// unavailableRunner is returned for unknown agent names.\\n    78→type unavailableRunner struct {\\n    79→\\tname string\\n    80→}\\n    81→\\n    82→func (r *unavailableRunner) Name() string { return r.name }\\n    83→\\n    84→func (r *unavailableRunner) IsAvailable() (bool, error) {\\n    85→\\treturn false, fmt.Errorf(\\\"unknown agent: %s\\\", r.name)\\n    86→}\\n    87→\\n    88→func (r *unavailableRunner) RunPrompt(_ context.Context, _ string, _ string) (*AgentResult, error) {\\n    89→\\treturn nil, fmt.Errorf(\\\"agent %s is not available\\\", r.name)\\n    90→}\\n    91→\\n    92→func (r *unavailableRunner) RunPromptWithTools(_ context.Context, _ string, _ string, _ []string) (*AgentResult, error) {\\n    93→\\treturn nil, fmt.Errorf(\\\"agent %s is not available\\\", r.name)\\n    94→}\\n    95→\\n    96→// ClaudeCodeRunner implements AgentRunner for Claude Code CLI.\\n    97→type ClaudeCodeRunner struct {\\n    98→\\tModel        string\\n    99→\\tTimeout      time.Duration\\n   100→\\tAllowedTools []string\\n   101→}\\n   102→\\n   103→// NewClaudeCodeRunner creates a new Claude Code runner with the given config.\\n   104→func NewClaudeCodeRunner(config AgentRunnerConfig) *ClaudeCodeRunner {\\n   105→\\tmodel := config.Model\\n   106→\\tif model == \\\"\\\" {\\n   107→\\t\\tmodel = os.Getenv(\\\"E2E_CLAUDE_MODEL\\\")\\n   108→\\t\\tif model == \\\"\\\" {\\n   109→\\t\\t\\tmodel = \\\"haiku\\\"\\n   110→\\t\\t}\\n   111→\\t}\\n   112→\\n   113→\\ttimeout := config.Timeout\\n   114→\\tif timeout == 0 {\\n   115→\\t\\tif envTimeout := os.Getenv(\\\"E2E_TIMEOUT\\\"); envTimeout != \\\"\\\" {\\n   116→\\t\\t\\tif parsed, err := time.ParseDuration(envTimeout); err == nil {\\n   117→\\t\\t\\t\\ttimeout = parsed\\n   118→\\t\\t\\t}\\n   119→\\t\\t}\\n   120→\\t\\tif timeout == 0 {\\n   121→\\t\\t\\ttimeout = 2 * time.Minute\\n   122→\\t\\t}\\n   123→\\t}\\n   124→\\n   125→\\treturn &ClaudeCodeRunner{\\n   126→\\t\\tModel:        model,\\n   127→\\t\\tTimeout:      timeout,\\n   128→\\t\\tAllowedTools: []string{\\\"Edit\\\", \\\"Read\\\", \\\"Write\\\", \\\"Bash\\\", \\\"Glob\\\", \\\"Grep\\\"},\\n   129→\\t}\\n   130→}\\n   131→\\n   132→func (r *ClaudeCodeRunner) Name() string {\\n   133→\\treturn AgentNameClaudeCode\\n   134→}\\n   135→\\n   136→// IsAvailable checks if Claude CLI is installed and responds to --version.\\n   137→// Note: This does NOT verify authentication status. Claude Code uses OAuth\\n   138→// authentication (via `claude login`), not ANTHROPIC_API_KEY. If the CLI is\\n   139→// installed but not logged in, tests will fail at RunPrompt time.\\n   140→func (r *ClaudeCodeRunner) IsAvailable() (bool, error) {\\n   141→\\t// Check if claude CLI is in PATH\\n   142→\\tif _, err := exec.LookPath(\\\"claude\\\"); err != nil {\\n   143→\\t\\treturn false, fmt.Errorf(\\\"claude CLI not found in PATH: %w\\\", err)\\n   144→\\t}\\n   145→\\n   146→\\t// Check if claude is working (--version doesn't requ