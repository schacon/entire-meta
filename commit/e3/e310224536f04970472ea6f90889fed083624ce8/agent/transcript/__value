→\\t\\t\\\"ShellTool(git diff)\\\",\\n   292→\\t\\t\\\"ShellTool(git log)\\\",\\n   293→\\t}\\n   294→\\n   295→\\t// Merge with any additional tools passed in\\n   296→\\tallTools := append(defaultAllowedTools, tools...)\\n   297→\\tif len(allTools) > 0 {\\n   298→\\t\\targs = append(args, \\\"--allowed-tools\\\", strings.Join(allTools, \\\",\\\"))\\n   299→\\t}\\n   300→\\n   301→\\t// Create context with timeout\\n   302→\\tctx, cancel := context.WithTimeout(ctx, r.Timeout)\\n   303→\\tdefer cancel()\\n   304→\\n   305→\\t//nolint:gosec // args are constructed from trusted config, not user input\\n   306→\\tcmd := exec.CommandContext(ctx, \\\"gemini\\\", args...)\\n   307→\\tcmd.Dir = workDir\\n   308→\\n   309→\\tvar stdout, stderr bytes.Buffer\\n   310→\\tcmd.Stdout = &stdout\\n   311→\\tcmd.Stderr = &stderr\\n   312→\\n   313→\\tstart := time.Now()\\n   314→\\terr := cmd.Run()\\n   315→\\tduration := time.Since(start)\\n   316→\\n   317→\\tresult := &AgentResult{\\n   318→\\t\\tStdout:   stdout.String(),\\n   319→\\t\\tStderr:   stderr.String(),\\n   320→\\t\\tDuration: duration,\\n   321→\\t}\\n   322→\\n   323→\\tif err != nil {\\n   324→\\t\\texitErr := &exec.ExitError{}\\n   325→\\t\\tif errors.As(err, &exitErr) {\\n   326→\\t\\t\\tresult.ExitCode = exitErr.ExitCode()\\n   327→\\t\\t} else {\\n   328→\\t\\t\\tresult.ExitCode = -1\\n   329→\\t\\t}\\n   330→\\t\\t//nolint:wrapcheck // error is from exec.Run, caller can check ExitCode in result\\n   331→\\t\\treturn result, err\\n   332→\\t}\\n   333→\\n   334→\\tresult.ExitCode = 0\\n   335→\\treturn result, nil\\n   336→}\\n   337→\\n   338→// FactoryAIDroidRunner implements AgentRunner for Factory AI Droid CLI.\\n   339→type FactoryAIDroidRunner struct {\\n   340→\\tModel     string\\n   341→\\tTimeout   time.Duration\\n   342→\\tAutoLevel string\\n   343→}\\n   344→\\n   345→// NewFactoryAIDroidRunner creates a new Factory AI Droid runner with the given config.\\n   346→func NewFactoryAIDroidRunner(config