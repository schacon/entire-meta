 string) bool {\\n   641→\\tenv.T.Helper()\\n   642→\\n   643→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   644→\\tif err != nil {\\n   645→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   646→\\t}\\n   647→\\n   648→\\trefs, err := repo.References()\\n   649→\\tif err != nil {\\n   650→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   651→\\t}\\n   652→\\n   653→\\tfound := false\\n   654→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   655→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   656→\\t\\tif ref.Name().Short() == branchName {\\n   657→\\t\\t\\tfound = true\\n   658→\\t\\t}\\n   659→\\t\\treturn nil\\n   660→\\t})\\n   661→\\n   662→\\treturn found\\n   663→}\\n   664→\\n   665→// ListBranchesWithPrefix returns all branches that start with the given prefix.\\n   666→func (env *TestEnv) ListBranchesWithPrefix(prefix string) []string {\\n   667→\\tenv.T.Helper()\\n   668→\\n   669→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   670→\\tif err != nil {\\n   671→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   672→\\t}\\n   673→\\n   674→\\trefs, err := repo.References()\\n   675→\\tif err != nil {\\n   676→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   677→\\t}\\n   678→\\n   679→\\tvar branches []string\\n   680→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   681→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   682→\\t\\tname := ref.Name().Short()\\n   683→\\t\\tif strings.HasPrefix(name, prefix) {\\n   684→\\t\\t\\tbranches = append(branches, name)\\n   685→\\t\\t}\\n   686→\\t\\treturn nil\\n   687→\\t})\\n   688→\\n   689→\\treturn branches\\n   690→}\\n   691→\\n   692→// GetCommitMessage returns the commit message for the given commit hash.\\n   693→func (env *TestEnv) GetCommitMessage(hash string) string {\\n   694→\\tenv.T.Helper()\\n   695→\\n   696→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   697→\\tif err != nil {\\n   698→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   699→\\t}\\n   700→\\n   701→\\tcommitHash := plumbing.NewHash(hash)\\n   702→\\tcommit, err := repo.CommitObject(commitHash)\\n   703→\\tif err != nil {\\n   704→\\t\\tenv.T.Fatalf(\\\"failed to get commit %s: %v\\\", hash, err)\\n   705→\\t}\\n   706→\\n   707→\\treturn commit.Message\\n   708→}\\n   709→\\n   710→// GetLatestCheckpointIDFromHistory walks backwards from HEAD and returns\\n   711→// the checkpoint ID from the first commit with an Entire-Checkpoint trailer.\\n   712→// Returns an error if no checkpoint trailer is found in any commit.\\n   713→func (env *TestEnv) GetLatestCheckpointIDFromHistory() (string, error) {\\n   714→\\tenv.T.Helper()\\n   715→\\n   716→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   717→\\tif err != nil {\\n   718→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   719→\\t}\\n   720→\\n   721→\\thead, err := repo.Head()\\n   722→\\tif err != nil {\\n   723→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   724→\\t}\\n   725→\\n   726→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   727→\\tif err != nil {\\n   728→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   729→\\t}\\n   730→\\n   731→\\tvar checkpointID string\\n   732→\\t//nolint:errcheck,gosec // ForEach callback returns error to stop iteration, not a real error\\n   733→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   734→\\t\\t// Look for Entire-Checkpoint trailer\\n   735→\\t\\tfor _, line := range strings.Split(c.Message, \\\"\\\\n\\\") {\\n   736→\\t\\t\\tline = strings.TrimSpace(line)\\n   737→\\t\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   738→\\t\\t\\t\\tcheckpointID = strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   739→\\t\\t\\t\\treturn errors.New(\\\"stop iteration\\\")\\n   740→\\t\\t\\t}\\n   741→\\t\\t}\\n   742→\\t\\treturn nil\\n   743→\\t})\\n   744→\\n   745→\\tif checkpointID == \\\"\\\" {\\n   746→\\t\\treturn \\\"\\\", errors.New(\\\"no commit with Entire-Checkpoint trailer found in history\\\")\\n   747→\\t}\\n   748→\\n   749→\\treturn checkpointID, nil\\n   750→}\\n   751→\\n   752→// GetLatestCheckpointID returns the checkpoint ID from HEAD commit, or empty string if none.\\n   753→// This is a convenience wrapper that doesn't fail the test on missing checkpoint.\\n   754→func (env *TestEnv) GetLatestCheckpointID() string {\\n   755→\\tenv.T.Helper()\\n   756→\\n   757→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   758→\\tif err != nil {\\n   759→\\t\\treturn \\\"\\\"\\n   760→\\t}\\n   761→\\n   762→\\thead, err := repo.Head()\\n   763→\\tif err != nil {\\n   764→\\t\\treturn \\\"\\\"\\n   765→\\t}\\n   766→\\n   767→\\tcommit, err := repo.CommitObject(head.Hash())\\n   768→\\tif err != nil {\\n   769→\\t\\treturn \\\"\\\"\\n   770→\\t}\\n   771→\\n   772→\\t// Look for Entire-Checkpoint trailer in HEAD commit only\\n   773→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n   774→\\t\\tline = strings.TrimSpace(line)\\n   775→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   776→\\t\\t\\treturn strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   777→\\t\\t}\\n   778→\\t}\\n   779→\\treturn \\\"\\\"\\n   780→}\\n   781→\\n   782→// safeIDPrefix returns first 12 chars of ID or the full ID if shorter.\\n   783→// Use this when logging checkpoint IDs to avoid index out of bounds panic.\\n   784→func safeIDPrefix(id string) string {\\n   785→\\tif len(id) >= 12 {\\n   786→\\t\\treturn id[:12]\\n   787→\\t}\\n   788→\\treturn id\\n   789→}\\n   790→\\n   791→// RunCLI runs the entire CLI with the given arguments and returns stdout.\\n   792→func (env *TestEnv) RunCLI(args ...string) string {\\n   793→\\tenv.T.Helper()\\n   794→\\toutput, err := env.RunCLIWithError(args...)\\n   795→\\tif err != nil {\\n   796→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   797→\\t}\\n   798→\\treturn output\\n   799→}\\n   800→\\n   801→// RunCLIWithError runs the entire CLI and returns output and error.\\n   802→func (env *TestEnv) RunCLIWithError(args ...string) (string, error) {\\n   803→\\tenv.T.Helper()\\n   804→\\n   805→\\t//nolint:gosec,noctx // test code, args are from test setup, no context needed\\n   806→\\tcmd := exec.Command(getTestBinary(), args...)\\n   807→\\tcmd.Dir = env.RepoDir\\n   808→\\n   809→\\toutput, err := cmd.CombinedOutput()\\n   810→\\treturn string(output), err\\n   811→}\\n   812→\\n   813→// RunAgent runs the agent with the given prompt and returns the result.\\n   814→func (env *TestEnv) RunAgent(prompt string) (*AgentResult, error) {\\n   815→\\tenv.T.Helper()\\n   816→\\tresult, err := env.Agent.RunPrompt(context.Background(), env.RepoDir, prompt)\\n   817→\\tif err != nil && result != nil {\\n   818→\\t\\tenv.T.Logf(\\\"Agent failed with exit code %d\\\", result.ExitCode)\\n   819→\\t\\tif result.Stderr != \\\"\\\" {\\n   820→\\t\\t\\tenv.T.Logf(\\\"Agent stderr: %s\\\", result.Stderr)\\n   821→\\t\\t}\\n   822→\\t\\tif result.Stdout != \\\"\\\" {\\n   823→\\t\\t\\tenv.T.Logf(\\\"Agent stdout: %s\\\", result.Stdout)\\n   824→\\t\\t}\\n   825→\\t}\\n   826→\\t//nolint:wrapcheck // test helper, caller handles error\\n   827→\\treturn result, err\\n   828→}\\n   829→\\n   830→// RunAgentWithTools runs the agent with specific tools enabled.\\n   831→func (env *TestEnv) RunAgentWithTools(prompt string, tools []string) (*AgentResult, error) {\\n   832→\\tenv.T.Helper()\\n   833→\\tresult, err := env.Agent.RunPromptWithTools(context.Background(), env.RepoDir, prompt, tools)\\n   834→\\tif err != nil && result != nil {\\n   835→\\t\\tenv.T.Logf(\\\"Agent failed with exit code %d\\\", result.ExitCode)\\n   836→\\t\\tif result.Stderr != \\\"\\\" {\\n   837→\\t\\t\\tenv.T.Logf(\\\"Agent stderr: %s\\\", result.Stderr)\\n   838→\\t\\t}\\n   839→\\t\\tif result.Stdout != \\\"\\\" {\\n   840→\\t\\t\\tenv.T.Logf(\\\"Agent stdout: %s\\\", result.Stdout)\\n   841→\\t\\t}\\n   842→\\t}\\n   843→\\t//nolint:wrapcheck // test helper, caller handles error\\n   844→\\treturn result, err\\n   845→}\\n   846→\\n   847→// GitStash runs git stash to save uncommitted changes.\\n   848→// Uses -u flag to include untracked files (new files created by agent).\\n   849→func (env *TestEnv) GitStash() {\\n   850→\\tenv.T.Helper()\\n   851→\\n   852→\\t//nolint:noctx // test code, no context needed for git stash\\n   853→\\tcmd := exec.Command(\\\"git\\\", \\\"stash\\\", \\\"-u\\\")\\n   854→\\tcmd.Dir = env.RepoDir\\n   855→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   856→\\t\\tenv.T.Fatalf(\\\"git stash failed: %v\\\\nOutput: %s\\\", err, output)\\n   857→\\t}\\n   858→}\\n   859→\\n   860→// GitStashPop runs git stash pop to restore stashed changes.\\n   861→func (env *TestEnv) GitStashPop() {\\n   862→\\tenv.T.Helper()\\n   863→\\n   864→\\t//nolint:noctx // test code, no context needed for git stash pop\\n   865→\\tcmd := exec.Command(\\\"git\\\", \\\"stash\\\", \\\"pop\\\")\\n   866→\\tcmd.Dir = env.RepoDir\\n   867→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   868→\\t\\tenv.T.Fatalf(\\\"git stash pop failed: %v\\\\nOutput: %s\\\", err, output)\\n   869→\\t}\\n   870→}\\n   871→\\n   872→// GitCheckoutFile reverts a file to its committed state.\\n   873→func (env *TestEnv) GitCheckoutFile(path string) {\\n   874→\\tenv.T.Helper()\\n   875→\\n   876→\\t//nolint:gosec,noctx // test code, path is from test setup, no context needed\\n   877→\\tcmd := exec.Command(\\\"git\\\", \\\"checkout\\\", \\\"--\\\", path)\\n   878→\\tcmd.Dir = env.RepoDir\\n   879→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   880→\\t\\tenv.T.Fatalf(\\\"git checkout -- %s failed: %v\\\\nOutput: %s\\\", path, err, output)\\n   881→\\t}\\n   882→}\\n   883→\\n   884→// DeleteFile removes a file from the test repo.\\n   885→func (env *TestEnv) DeleteFile(path string) {\\n   886→\\tenv.T.Helper()\\n   887→\\n   888→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   889→\\tif err := os.Remove(fullPath); err != nil {\\n   890→\\t\\tenv.T.Fatalf(\\\"failed to delete file %s: %v\\\", path, err)\\n   891→\\t}\\n   892→}\\n   893→\\n   894→// GetCommitCount returns the number of commits on the current branch.\\n   895→func (env *TestEnv) GetCommitCount() int {\\n   896→\\tenv.T.Helper()\\n   897→\\n   898→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   899→\\tif err != nil {\\n   900→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   901→\\t}\\n   902→\\n   903→\\thead, err := repo.Head()\\n   904→\\tif err != nil {\\n   905→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   906→\\t}\\n   907→\\n   908→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   909→\\tif err != nil {\\n   910→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   911→\\t}\\n   912→\\n   913→\\tcount := 0\\n   914→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   915→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   916→\\t\\tcount++\\n   917→\\t\\treturn nil\\n   918→\\t})\\n   919→\\n   920→\\treturn count\\n   921→}\\n   922→\\n   923→// GetAllCheckpointIDsFromHistory walks backwards from HEAD and returns\\n   924→// all checkpoint IDs from commits with Entire-Checkpoint trailers.\\n   925→func (env *TestEnv) GetAllCheckpointIDsFromHistory() []string {\\n   926→\\tenv.T.Helper()\\n   927→\\n   928→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   929→\\tif err != nil {\\n   930→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   931→\\t}\\n   932→\\n   933→\\thead, err := repo.Head()\\n   934→\\tif err != nil {\\n   935→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   936→\\t}\\n   937→\\n   938→\\tcommitIter, err := repo.Log(&