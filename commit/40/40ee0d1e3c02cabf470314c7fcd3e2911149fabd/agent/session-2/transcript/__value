 _ agent.TranscriptAnalyzer = (*KiroAgent)(nil)\\n    22→\\n    23→// Kiro hook names — these become CLI subcommands under `entire hooks kiro`.\\n    24→// Kiro uses camelCase hook names natively, but CLI subcommands use kebab-case.\\n    25→const (\\n    26→\\tHookNameAgentSpawn       = \\\"agent-spawn\\\"\\n    27→\\tHookNameUserPromptSubmit = \\\"user-prompt-submit\\\"\\n    28→\\tHookNamePreToolUse       = \\\"pre-tool-use\\\"\\n    29→\\tHookNamePostToolUse      = \\\"post-tool-use\\\"\\n    30→\\tHookNameStop             = \\\"stop\\\"\\n    31→)\\n    32→\\n    33→// sessionIDFile is the filename for caching the generated session ID.\\n    34→// Stored in .entire/tmp/ to ensure a stable ID across all hooks in one session.\\n    35→const sessionIDFile = \\\"kiro-active-session\\\"\\n    36→\\n    37→// HookNames returns the hook verbs Kiro supports.\\n    38→// These become subcommands: entire hooks kiro <verb>\\n    39→func (k *KiroAgent) HookNames() []string {\\n    40→\\treturn []string{\\n    41→\\t\\tHookNameAgentSpawn,\\n    42→\\t\\tHookNameUserPromptSubmit,\\n    43→\\t\\tHookNamePreToolUse,\\n    44→\\t\\tHookNamePostToolUse,\\n    45→\\t\\tHookNameStop,\\n    46→\\t}\\n    47→}\\n    48→\\n    49→// ParseHookEvent translates a Kiro hook into a normalized lifecycle Event.\\n    50→// Returns nil for hooks with no lifecycle significance (preToolUse, postToolUse).\\n    51→func (k *KiroAgent) ParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*agent.Event, error) {\\n    52→\\tswitch hookName {\\n    53→\\tcase HookNameAgentSpawn:\\n    54→\\t\\treturn k.parseAgentSpawn(ctx, stdin)\\n    55→\\tcase HookNameUserPromptSubmit:\\n    56→\\t\\treturn k.parseUserPromptSubmit(ctx, stdin)\\n    57→\\tcase HookNameStop:\\n    58→\\t\\treturn k.parseStop(ctx, stdin)\\n    59→\\tcase HookNamePreToolUse, HookNamePostToolUse:\\n    60→\\t\\t// Pass-through hooks with no lifecycle significance\\n    61→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    62→\\tdefault:\\n    63→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    64→\\t}\\n    65→}\\n    66→\\n    67→// readHookInputOrEmpty wraps ReadAndParseHookInput, returning a zero-value\\n    68→// hookInputRaw on empty stdin instead of erroring. This supports the Kiro IDE\\n    69→// which delivers data via environment variables rather than JSON on stdin.\\n    70→// Malformed JSON still returns an error.\\n    71→func readHookInputOrEmpty(stdin io.Reader) (*hookInputRaw, error) {\\n    72→\\traw, err := agent.ReadAndParseHookInput[hookInputRaw](stdin)\\n    73→\\tif err != nil {\\n    74→\\t\\tif errors.Is(err, agent.ErrEmptyHookInput) {\\n    75→\\t\\t\\treturn &hookInputRaw{}, nil\\n    76→\\t\\t}\\n    77→\\t\\treturn nil, err\\n    78→\\t}\\n    79→\\treturn raw, nil\\n    80→}\\n    81→\\n    82→func (k *KiroAgent) parseAgentSpawn(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n    83→\\t_, err := readHookInputOrEmpty(stdin)\\n    84→\\tif err != nil {\\n    85→\\t\\treturn nil, err\\n    86→\\t}\\n    87→\\n    88→\\t// Generate a new stable session ID and cache it for subsequent hooks.\\n    89→\\t// Kiro's SQLite transcript isn't populated until the turn ends, so we can't\\n    90→\\t// use the native conversation_id as our session ID — it would be \\\"unknown\\\"\\n    91→\\t// at agentSpawn/userPromptSubmit and change to the real ID at stop.\\n    92→\\tsessionID := k.generateAndCacheSessionID(ctx)\\n    93→\\n    94→\\treturn &agent.Event{\\n    95→\\t\\tType:      agent.SessionStart,\\n    96→\\t\\tSessionID: sessionID,\\n    97→\\t\\tTimestamp: time.Now(),\\n    98→\\t}, nil\\n    99→}\\n   100→\\n   101→func (k *KiroAgent) parseUserPromptSubmit(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n   102→\\traw, err := readHookInputOrEmpty(stdin)\\n   103→\\tif err != nil {\\n   104→\\t\\treturn nil, err\\n   105→\\t}\\n   106→\\n   107→\\t// IDE mode: prompt comes from USER_PROMPT env var when stdin is empty.\\n   108→\\tprompt := raw.Prompt\\n   109→\\tif prompt == \\\"\\\" {\\n   110→\\t\\tprompt = os.Getenv(\\\"USER_PROMPT\\\")\\n   111→\\t}\\n   112→\\n   113→\\t// Read the stable session ID generated at agentSpawn.\\n   114→\\tsessionID := k.readCachedSessionID(ctx)\\n   115→\\tif sessionID == \\\"\\\" {\\n   116→\\t\\t// Fallback: generate new ID if cache file is missing (e.g., agentSpawn was skipped).\\n   117→\\t\\tsessionID = k.generateAndCacheSessionID(ctx)\\n   118→\\t}\\n   119→\\n   120→\\treturn &agent.Event{\\n   121→\\t\\tType:      agent.TurnStart,\\n   122→\\t\\tSessionID: sessionID,\\n   123→\\t\\tPrompt:    prompt,\\n   124→\\t\\tTimestamp: time.Now(),\\n   125→\\t}, nil\\n   126→}\\n   127→\\n   128→func (k *KiroAgent) parseStop(ctx context.Context, stdin io.Reader) (*agent.Event, error) {\\n   129→\\traw, err := readHookInputOrEmpty(stdin)\\n   130→\\tif err != nil {\\n   131→\\t\\treturn nil, err\\n   132→\\t}\\n   133→\\n   134→\\t// IDE mode: CWD may not be in stdin. Fall back to repo root.\\n   135→\\tcwd := raw.CWD\\n   136→\\tif cwd == \\\"\\\" {\\n   137→\\t\\trepoRoot, rootErr := paths.WorktreeRoot(ctx)\\n   138→\\t\\tif rootErr == nil {\\n   139→\\t\\t\\tcwd = repoRoot\\n   140→\\t\\t}\\n   141→\\t}\\n   142→\\n   143→\\t// Read the stable session ID generated at agentSpawn.\\n   144→\\tsessionID := k.readCachedSessionID(ctx)\\n   145→\\tif sessionID == \\\"\\\" {\\n   146→\\t\\t// Fallback: try SQLite for the session ID.\\n   147→\\t\\tsid, queryErr := k.querySessionID(ctx, cwd)\\n   148→\\t\\tif queryErr != nil || sid == \\\"\\\" {\\n   149→\\t\\t\\tsessionID = \\\"unknown\\\"\\n   150→\\t\\t} else {\\n   151→\\t\\t\\tsessionID = sid\\n   152→\\t\\t}\\n   153→\\t}\\n   154→\\n   155→\\t// At stop, Kiro's SQLite transcript is available. Fetch and cache it\\n   156→\\t// under our stable session ID so lifecycle.go can read it.\\n   157→\\tvar sessionRef string\\n   158→\\tsessionRef, err = k.ensureCachedTranscript(ctx, cwd, sessionID)\\n   159→\\tif err != nil {\\n   160→\\t\\tlogging.Debug(ctx, \\\"kiro: ensureCachedTranscript failed (best-effort)\\\", slog.String(\\\"error\\\", err.Error()))\\n   161→\\t}\\n   162→\\n   163→\\t// IDE mode: SQLite may not exist. Try the IDE's workspace session files.\\n   164→\\tif sessionRef == \\\"\\\" {\\n   165→\\t\\tsessionRef, err = k.ensureIDETranscript(ctx, cwd, sessionID)\\n   166→\\t\\tif err != nil {\\n   167→\\t\\t\\tlogging.Debug(ctx, \\\"kiro: ensureIDETranscript failed (best-effort)\\\", slog.String(\\\"error\\\", err.Error()))\\n   168→\\t\\t}\\n   169→\\t}\\n   170→\\n   171→\\t// Last resort: create a minimal placeholder so the lifecycle handler can\\n   172→\\t// proceed (file-diff checkpoints still work without a real transcript).\\n   173→\\tif sessionRef == \\\"\\\" {\\n   174→\\t\\tsessionRef = k.createPlaceholderTranscript(ctx, cwd, sessionID)\\n   175→\\t}\\n   176→\\n   177→\\t// Clear the cache so a subsequent session doesn't reuse this stale ID\\n   178→\\t// (e.g., if Kiro resumes without firing agentSpawn).\\n   179→\\tk.clearCachedSessionID(ctx)\\n   180→\\n   181→\\treturn &agent.Event{\\n   182→\\t\\tType:       agent.TurnEnd,\\n   183→\\t\\tSessionID:  sessionID,\\n   184→\\t\\tSessionRef: sessionRef,\\n   185→\\t\\tTimestamp:  time.Now(),\\n   186→\\t}, nil\\n   187→}\\n   188→\\n   189→// createPlaceholderTranscript writes a minimal JSON transcript to .entire/tmp/\\n   190→// so the lifecycle handler can proceed when the real transcript is unavailable\\n   191→// (e.g., Kiro IDE mode where SQLite is at a different path).\\n   192→func (k *KiroAgent) createPlaceholderTranscript(ctx context.Context, cwd, sessionID string) string {\\n   193→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   194→\\tif err != nil {\\n   195→\\t\\trepoRoot = cwd\\n   196→\\t}\\n   197→\\tif repoRoot == \\\"\\\" {\\n   198→\\t\\treturn \\\"\\\"\\n   199→\\t}\\n   200→\\tcacheDir := filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\")\\n   201→\\tcachePath := filepath.Join(cacheDir, sessionID+\\\".json\\\")\\n   202→\\tif err := os.MkdirAll(cacheDir, 0o750); err != nil {\\n   203→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to create transcript cache dir\\\", \\\"err\\\", err)\\n   204→\\t\\treturn \\\"\\\"\\n   205→\\t}\\n   206→\\tif err := os.WriteFile(cachePath, []byte(\\\"{}\\\"), 0o600); err != nil {\\n   207→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to write placeholder transcript\\\", \\\"err\\\", err)\\n   208→\\t\\treturn \\\"\\\"\\n   209→\\t}\\n   210→\\treturn cachePath\\n   211→}\\n   212→\\n   213→// generateAndCacheSessionID creates a new random session ID and writes it\\n   214→// to .entire/tmp/kiro-active-session for subsequent hooks to read.\\n   215→func (k *KiroAgent) generateAndCacheSessionID(ctx context.Context) string {\\n   216→\\tsid := generateSessionID()\\n   217→\\tcachePath := k.sessionIDCachePath(ctx)\\n   218→\\tif err := os.MkdirAll(filepath.Dir(cachePath), 0o750); err != nil {\\n   219→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to create session ID cache dir\\\", \\\"err\\\", err)\\n   220→\\t\\treturn sid\\n   221→\\t}\\n   222→\\tif err := os.WriteFile(cachePath, []byte(sid), 0o600); err != nil {\\n   223→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to write session ID cache\\\", \\\"err\\\", err)\\n   224→\\t}\\n   225→\\treturn sid\\n   226→}\\n   227→\\n   228→// clearCachedSessionID removes the session ID cache file so that a subsequent\\n   229→// session does not accidentally reuse a stale ID from a previous session.\\n   230→func (k *KiroAgent) clearCachedSessionID(ctx context.Context) {\\n   231→\\tcachePath := k.sessionIDCachePath(ctx)\\n   232→\\tif err := os.Remove(cachePath); err != nil && !os.IsNotExist(err) {\\n   233→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to clear session ID cache\\\", \\\"err\\\", err)\\n   234→\\t}\\n   235→}\\n   236→\\n   237→// readCachedSessionID reads the stable session ID from .entire/tmp/kiro-active-session.\\n   238→// Returns empty string if the cache file doesn't exist.\\n   239→func (k *KiroAgent) readCachedSessionID(ctx context.Context) string {\\n   240→\\tcachePath := k.sessionIDCachePath(ctx)\\n   241→\\tdata, err := os.ReadFile(cachePath) //nolint:gosec // cachePath is constructed from WorktreeRoot + constant suffix\\n   242→\\tif err != nil {\\n   243→\\t\\treturn \\\"\\\"\\n   244→\\t}\\n   245→\\treturn strings.TrimSpace(string(data))\\n   246→}\\n   247→\\n   248→// sessionIDCachePath returns the path to the session ID cache file.\\n   249→func (k *KiroAgent) sessionIDCachePath(ctx context.Context) string {\\n   250→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   251→\\tif err != nil {\\n   252→\\t\\trepoRoot = \\\".\\\"\\n   253→\\t}\\n   254→\\treturn filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\", sessionIDFile)\\n   255→}\\n   256→\\n   257→// generateSessionID creates a random 32-character hex string for use as a session ID.\\n   258→func generateSessionID() string {\\n   259→\\tb := make([]byte, 16)\\n   260→\\tif _, err := rand.Read(b); err != nil {\\n   261→\\t\\t// crypto/rand.Read never fails on supported platforms, but use timestamp fallback.\\n   262→\\t\\treturn \\\"kiro-\\\" + time.Now().Format(\\\"20060102-150405\\\")\\n   263→\\t}\\n   264→\\treturn hex.EncodeToString(b)\\n   265→}\\n   266→\"}]},\"uuid\":\"5be538da-0140-4475-87ec-6fd5ce29f748\",\"timestamp\":\"2026-03-05T22:00:36.744Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a42501637d37c0a1a\"},\"toolUseID\":\"agent_msg_017R5GmJZJoV2EBd421aCSkM\",\"parentToolUseID\":\"toolu_01Xd3hNhb8NQo9MUoyCu3Ukx\",\"uuid\":\"efdd774d-5820-4b33-bac4-9d41c4263a16\",\"timestamp\":\"2026-03-05T22:00:36.782Z\"}\n{\"parentUuid\":\"efdd774d-5820-4b33-bac4-9d41c4263a16\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"7682603d-1d7b-49cc-900b-ee77433e7db4\",\"version\":\"2.1.69\",\"gitBranch\":\"alisha/k