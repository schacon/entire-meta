= nil {\\n   318→\\t\\t\\tcontinue\\n   319→\\t\\t}\\n   320→\\t\\tvar hook kiroIDEHookFile\\n   321→\\t\\tif json.Unmarshal(data, &hook) == nil && isEntireIDEHook(hook) {\\n   322→\\t\\t\\treturn true\\n   323→\\t\\t}\\n   324→\\t}\\n   325→\\treturn false\\n   326→}\\n   327→\\n   328→// isEntireIDEHook checks if an IDE hook file belongs to Entire.\\n   329→func isEntireIDEHook(hook kiroIDEHookFile) bool {\\n   330→\\treturn strings.HasPrefix(hook.Name, \\\"entire-\\\") && isEntireHook(hook.Then.Command)\\n   331→}\\n   332→\\n   333→// trustedCommand returns the trusted command pattern for the given mode.\\n   334→func trustedCommand(localDev bool) string {\\n   335→\\tif localDev {\\n   336→\\t\\treturn localDevCmdPrefix + \\\"hooks *\\\"\\n   337→\\t}\\n   338→\\treturn prodTrustedCommand\\n   339→}\\n   340→\\n   341→// isEntireTrustedCommand checks if a command string is an Entire trusted command.\\n   342→func isEntireTrustedCommand(cmd string) bool {\\n   343→\\treturn cmd == prodTrustedCommand || cmd == localDevCmdPrefix+\\\"hooks *\\\"\\n   344→}\\n   345→\\n   346→// trustedCommandsPresent checks if the appropriate trusted command is in .vscode/settings.json.\\n   347→func trustedCommandsPresent(worktreeRoot string, localDev bool) bool {\\n   348→\\tsettingsPath := filepath.Join(worktreeRoot, vscodeSettingsDir, vscodeSettingsFile)\\n   349→\\tdata, err := os.ReadFile(settingsPath) //nolint:gosec // path constructed from repo root\\n   350→\\tif err != nil {\\n   351→\\t\\treturn false\\n   352→\\t}\\n   353→\\n   354→\\tvar rawSettings map[string]json.RawMessage\\n   355→\\tif err := json.Unmarshal(data, &rawSettings); err != nil {\\n   356→\\t\\treturn false\\n   357→\\t}\\n   358→\\n   359→\\traw, ok := rawSettings[trustedCommandsKey]\\n   360→\\tif !ok {\\n   361→\\t\\treturn false\\n   362→\\t}\\n   363→\\n   364→\\tvar commands []string\\n   365→\\tif err := json.Unmarshal(raw, &commands); err != nil {\\n   366→\\t\\treturn false\\n   367→\\t}\\n   