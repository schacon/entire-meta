ntire hooks are installed.\\n   175→// Returns true if EITHER CLI agent hooks or IDE hooks are present.\\n   176→func (k *KiroAgent) AreHooksInstalled(ctx context.Context) bool {\\n   177→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n   178→\\tif err != nil {\\n   179→\\t\\tworktreeRoot = \\\".\\\"\\n   180→\\t}\\n   181→\\n   182→\\t// Check CLI agent hooks\\n   183→\\thooksPath := filepath.Join(worktreeRoot, \\\".kiro\\\", hooksDir, HooksFileName)\\n   184→\\tdata, err := os.ReadFile(hooksPath) //nolint:gosec // path constructed from repo root\\n   185→\\tif err == nil {\\n   186→\\t\\tvar file kiroAgentFile\\n   187→\\t\\tif json.Unmarshal(data, &file) == nil {\\n   188→\\t\\t\\tif hasEntireHook(file.Hooks.AgentSpawn) ||\\n   189→\\t\\t\\t\\thasEntireHook(file.Hooks.UserPromptSubmit) ||\\n   190→\\t\\t\\t\\thasEntireHook(file.Hooks.Stop) {\\n   191→\\t\\t\\t\\treturn true\\n   192→\\t\\t\\t}\\n   193→\\t\\t}\\n   194→\\t}\\n   195→\\n   196→\\t// Check IDE hooks — any Entire IDE hook file means hooks are installed\\n   197→\\treturn anyIDEHookPresent(worktreeRoot)\\n   198→}\\n   199→\\n   200→// GetSupportedHooks returns the hook types Kiro supports.\\n   201→func (k *KiroAgent) GetSupportedHooks() []agent.HookType {\\n   202→\\treturn []agent.HookType{\\n   203→\\t\\tagent.HookSessionStart,\\n   204→\\t\\tagent.HookUserPromptSubmit,\\n   205→\\t\\tagent.HookPreToolUse,\\n   206→\\t\\tagent.HookPostToolUse,\\n   207→\\t\\tagent.HookStop,\\n   208→\\t}\\n   209→}\\n   210→\\n   211→func allHooksPresent(hooks kiroHooks, localDev bool) bool {\\n   212→\\tcmdPrefix := hookCmdPrefix(localDev)\\n   213→\\n   214→\\treturn hookCommandExists(hooks.AgentSpawn, cmdPrefix+HookNameAgentSpawn) &&\\n   215→\\t\\thookCommandExists(hooks.UserPromptSubmit, cmdPrefix+HookNameUserPromptSubmit) &&\\n   216→\\t\\thookCommandExists(hooks.PreToolUse, cmdPrefix+HookNamePreToolUse) &&\\n   217→\\t\\thookCommandExists(hooks.PostToolUse, cmdPrefix+HookNamePostToolUse) &&\\n   218→\\t\\thookCommandExists(hooks.Stop, cmdPrefix+HookNameStop)\\n   219→}\\n   220→\\n   221→func hookCommandExists(entries []kiroHookEntry, command string) bool {\\n   222→\\tfor _, entry := range entries {\\n   223→\\t\\tif entry.Command == command {\\n   224→\\t\\t\\treturn true\\n   225→\\t\\t}\\n   226→\\t}\\n   227→\\treturn false\\n   228→}\\n   229→\\n   230→func isEntireHook(command string) bool {\\n   231→\\tfor _, prefix := range entireHookPrefixes {\\n   232→\\t\\tif strings.HasPrefix(command, prefix) {\\n   233→\\t\\t\\treturn true\\n   234→\\t\\t}\\n   235→\\t}\\n   236→\\treturn false\\n   237→}\\n   238→\\n   239→func hasEntireHook(entries []kiroHookEntry) bool {\\n   240→\\tfor _, entry := range entries {\\n   241→\\t\\tif isEntireHook(entry.Command) {\\n   242→\\t\\t\\treturn true\\n   243→\\t\\t}\\n   244→\\t}\\n   245→\\treturn false\\n   246→}\\n   247→\\n   248→func hookCmdPrefix(localDev bool) string {\\n   249→\\tif localDev {\\n   250→\\t\\treturn localDevCmdPrefix + \\\"hooks kiro \\\"\\n   251→\\t}\\n   252→\\treturn prodHookCmdPrefix\\n   253→}\\n   254→\\n   255→// installIDEHooks creates .kiro/hooks/*.kiro.hook files for the Kiro IDE.\\n   256→func installIDEHooks(worktreeRoot, cmdPrefix string) (int, error) {\\n   257→\\tdir := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir)\\n   258→\\tif err := os.MkdirAll(dir, 0o750); err != nil {\\n   259→\\t\\treturn 0, fmt.Errorf(\\\"failed to create .kiro/hooks directory: %w\\\", err)\\n   260→\\t}\\n   261→\\n   262→\\tfor _, def := range ideHookDefs {\\n   263→\\t\\thook := kiroIDEHookFile{\\n   264→\\t\\t\\tEnabled:     true,\\n   265→\\t\\t\\tName:        def.Filename,\\n   266→\\t\\t\\tDescription: \\\"Entire CLI \\\" + def.TriggerType + \\\" hook\\\",\\n   267→\\t\\t\\tVersion:     ideHookVersion,\\n   268→\\t\\t\\tWhen: kiroIDEHookWhen{\\n   269→\\t\\t\\t\\tType: def.TriggerType,\\n   270→\\t\\t\\t},\\n   271→\\t\\t\\tThen: kiroIDEHookThen{\\n   272→\\t\\t\\t\\tType:    \\\"runCommand\\\