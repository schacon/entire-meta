\t\\tif json.Unmarshal(existing, &file) == nil &&\\n    91→\\t\\t\\t\\tallHooksPresent(file.Hooks, localDev) &&\\n    92→\\t\\t\\t\\tallIDEHooksPresent(worktreeRoot, localDev) &&\\n    93→\\t\\t\\t\\ttrustedCommandsPresent(worktreeRoot, localDev) {\\n    94→\\t\\t\\t\\treturn 0, nil\\n    95→\\t\\t\\t}\\n    96→\\t\\t}\\n    97→\\t}\\n    98→\\n    99→\\tcmdPrefix := hookCmdPrefix(localDev)\\n   100→\\n   101→\\tfile := kiroAgentFile{\\n   102→\\t\\tName: \\\"entire\\\",\\n   103→\\t\\t// Include all default Kiro tools so the agent profile doesn't restrict them.\\n   104→\\t\\tTools: []string{\\n   105→\\t\\t\\t\\\"read\\\", \\\"write\\\", \\\"shell\\\", \\\"grep\\\", \\\"glob\\\",\\n   106→\\t\\t\\t\\\"aws\\\", \\\"report\\\", \\\"introspect\\\", \\\"knowledge\\\",\\n   107→\\t\\t\\t\\\"thinking\\\", \\\"todo\\\", \\\"delegate\\\",\\n   108→\\t\\t},\\n   109→\\t\\tHooks: kiroHooks{\\n   110→\\t\\t\\tAgentSpawn:       []kiroHookEntry{{Command: cmdPrefix + HookNameAgentSpawn}},\\n   111→\\t\\t\\tUserPromptSubmit: []kiroHookEntry{{Command: cmdPrefix + HookNameUserPromptSubmit}},\\n   112→\\t\\t\\tPreToolUse:       []kiroHookEntry{{Command: cmdPrefix + HookNamePreToolUse}},\\n   113→\\t\\t\\tPostToolUse:      []kiroHookEntry{{Command: cmdPrefix + HookNamePostToolUse}},\\n   114→\\t\\t\\tStop:             []kiroHookEntry{{Command: cmdPrefix + HookNameStop}},\\n   115→\\t\\t},\\n   116→\\t}\\n   117→\\n   118→\\tif err := os.MkdirAll(filepath.Dir(hooksPath), 0o750); err != nil {\\n   119→\\t\\treturn 0, fmt.Errorf(\\\"failed to create .kiro/agents directory: %w\\\", err)\\n   120→\\t}\\n   121→\\n   122→\\toutput, err := jsonutil.MarshalIndentWithNewline(file, \\\"\\\", \\\"  \\\")\\n   123→\\tif err != nil {\\n   124→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal hooks config: %w\\\", err)\\n   125→\\t}\\n   126→\\n   127→\\tif err := os.WriteFile(hooksPath, output, 0o600); err != nil {\\n   128→\\t\\treturn 0, fmt.Errorf(\\\"failed to write hooks config: %w\\\", err)