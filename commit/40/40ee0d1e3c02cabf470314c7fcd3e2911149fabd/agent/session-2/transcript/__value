turn 1.5 }\\n    37→\\n    38→func (k *Kiro) IsTransientError(out Output, _ error) bool {\\n    39→\\tcombined := out.Stdout + out.Stderr\\n    40→\\tfor _, p := range []string{\\\"overloaded\\\", \\\"rate limit\\\", \\\"503\\\", \\\"529\\\", \\\"throttl\\\"} {\\n    41→\\t\\tif strings.Contains(strings.ToLower(combined), p) {\\n    42→\\t\\t\\treturn true\\n    43→\\t\\t}\\n    44→\\t}\\n    45→\\treturn false\\n    46→}\\n    47→\\n    48→func (k *Kiro) Bootstrap() error {\\n    49→\\t// kiro-cli-chat is the standalone binary that supports headless SIGV4 auth.\\n    50→\\t// The desktop app wrapper (kiro-cli) ignores AMAZON_Q_SIGV4 and always\\n    51→\\t// forces browser OAuth, so E2E tests must use kiro-cli-chat.\\n    52→\\tif os.Getenv(\\\"CI\\\") == \\\"\\\" {\\n    53→\\t\\treturn nil\\n    54→\\t}\\n    55→\\n    56→\\tif isTruthyEnvValue(os.Getenv(\\\"AMAZON_Q_SIGV4\\\")) {\\n    57→\\t\\tif err := validateKiroSIGV4Inputs(\\n    58→\\t\\t\\tos.Getenv(\\\"AWS_REGION\\\"),\\n    59→\\t\\t\\tos.Getenv(\\\"AWS_ACCESS_KEY_ID\\\"),\\n    60→\\t\\t\\tos.Getenv(\\\"AWS_SECRET_ACCESS_KEY\\\"),\\n    61→\\t\\t); err != nil {\\n    62→\\t\\t\\treturn fmt.Errorf(\\\"kiro-cli-chat sigv4 auth check failed: %w\\\", err)\\n    63→\\t\\t}\\n    64→\\t\\treturn nil\\n    65→\\t}\\n    66→\\n    67→\\t// Verify login status — fail fast if not authenticated.\\n    68→\\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\\n    69→\\tdefer cancel()\\n    70→\\tcmd := exec.CommandContext(ctx, \\\"kiro-cli-chat\\\", \\\"whoami\\\", \\\"-f\\\", \\\"json\\\")\\n    71→\\tout, err := cmd.CombinedOutput()\\n    72→\\tif err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\n    74→\\t\\t\\t\\\"kiro-cli-chat auth check failed (run `kiro-cli-chat login --use-device-flow`): %s\\\",\\n    75→\\t\\t\\tstrings.TrimSpace(string(out)),\\n    76→\\t\\t)\\n    77→\\t}\\n    78→\\tif err := validateKiroWhoamiJSON(out); err != nil {\\n    79→\\t\\treturn fmt.Errorf(\\\"kiro-cli-chat auth check failed: %w\\\", err)\\n    80→\\t}\\n    81→\\treturn nil\\n    82→}\\n    83→\\n    84→func isTruthyEnvValue(v string) bool {\\n    85→\\tvalue := strings.TrimSpace(v)\\n    86→\\tif value == \\\"\\\" {\\n    87→\\t\\treturn false\\n    88→\\t}\\n    89→\\tlower := strings.ToLower(value)\\n    90→\\treturn lower != \\\"0\\\" && lower != \\\"false\\\"\\n    91→}\\n    92→\\n    93→func validateKiroSIGV4Inputs(region, accessKeyID, secretAccessKey string) error {\\n    94→\\tif strings.TrimSpace(region) == \\\"\\\" {\\n    95→\\t\\treturn errors.New(\\\"AWS_REGION is required when AMAZON_Q_SIGV4 is enabled\\\")\\n    96→\\t}\\n    97→\\tif strings.TrimSpace(accessKeyID) == \\\"\\\" {\\n    98→\\t\\treturn errors.New(\\\"AWS_ACCESS_KEY_ID is required when AMAZON_Q_SIGV4 is enabled\\\")\\n    99→\\t}\\n   100→\\tif strings.TrimSpace(secretAccessKey) == \\\"\\\" {\\n   101→\\t\\treturn errors.New(\\\"AWS_SECRET_ACCESS_KEY is required when AMAZON_Q_SIGV4 is enabled\\\")\\n   102→\\t}\\n   103→\\treturn nil\\n   104→}\\n   105→\\n   106→func validateKiroWhoamiJSON(out []byte) error {\\n   107→\\tvar response struct {\\n   108→\\t\\tAccount json.RawMessage `json:\\\"account\\\"`\\n   109→\\t}\\n   110→\\n   111→\\tif err := json.Unmarshal(out, &response); err != nil {\\n   112→\\t\\treturn fmt.Errorf(\\\"invalid whoami JSON: %w\\\", err)\\n   113→\\t}\\n   114→\\tif len(response.Account) == 0 {\\n   115→\\t\\treturn errors.New(\\\"account is missing\\\")\\n   116→\\t}\\n   117→\\tif strings.EqualFold(strings.TrimSpace(string(response.Account)), \\\"null\\\") {\\n   118→\\t\\treturn errors.New(\\\"account is null\\\")\\n   119→\\t}\\n   120→\\treturn nil\\n   121→}\\n   122→\\n   123→func (k *Kiro) RunPrompt(ctx context.Context, dir string, prompt string, opts ...Option) (Output, error) {\\n   124→\\tcfg := &runConfig{}\\n   125→\\tfor _, o := range opts {\\n   126→\\t\\to(cfg)\\n   127→\\t}\\n   128→\\n   129→\\ttimeout := 2 * time.Minute\\n   130→\\tif cfg.PromptTimeout > 0 {\\n   131→\\t\\ttimeout = cfg.PromptTimeout\\n   132→\\t}\\n   133→\\tcmdCtx, cancel := context.WithTimeout(ctx, timeout)\\n   134→\\tdefer cancel()\\n   135→\\n   136→\\t// --no-interactive: runs a single prompt and exits; SIGV4 env vars\\n   137→\\t// propagate naturally (no tmux env forwarding needed).\\n   138→\\t// --trust-all-tools: auto-approve tool use (equivalent to -a in interactive mode).\\n   139→\\t// --agent entire: activates the agent profile that contains our hooks.\\n   140→\\targs := []string{\\\"chat\\\", \\\"--no-interactive\\\", \\\"--trust-all-tools\\\", \\\"--agent\\\", \\\"entire\\\"}\\n   141→\\tif cfg.Model != \\\"\\\" {\\n   142→\\t\\targs = append(args, \\\"--model\\\", cfg.Model)\\n   143→\\t}\\n   144→\\targs = append(args, prompt)\\n   145→\\n   146→\\t// Build display args with quoted prompt for logging.\\n   147→\\tdisplayArgs := make([]string, len(args))\\n   148→\\tcopy(displayArgs, args)\\n   149→\\tdisplayArgs[len(displayArgs)-1] = fmt.Sprintf(\\\"%q\\\", prompt)\\n   150→\\n   151→\\tcmd := exec.CommandContext(cmdCtx, k.Binary(), args...)\\n   152→\\tcmd.Dir = dir\\n   153→\\tcmd.Stdin = nil\\n   154→\\tcmd.SysProcAttr = &syscall.SysProcAttr{Setpgid: true}\\n   155→\\tcmd.Cancel = func() error {\\n   156→\\t\\treturn syscall.Kill(-cmd.Process.Pid, syscall.SIGKILL)\\n   157→\\t}\\n   158→\\tcmd.WaitDelay = 5 * time.Second\\n   159→\\n   160→\\tvar stdout, stderr strings.Builder\\n   161→\\tcmd.Stdout = &stdout\\n   162→\\tcmd.Stderr = &stderr\\n   163→\\n   164→\\terr := cmd.Run()\\n   165→\\texitCode := 0\\n   166→\\tif err != nil {\\n   167→\\t\\texitErr := &exec.ExitError{}\\n   168→\\t\\tif errors.As(err, &exitErr) {\\n   169→\\t\\t\\texitCode = exitErr.ExitCode()\\n   170→\\t\\t} else {\\n   171→\\t\\t\\texitCode = -1\\n   172→\\t\\t}\\n   173→\\t}\\n   174→\\n   175→\\treturn Output{\\n   176→\\t\\tCommand:  k.Binary() + \\\" \\\" + strings.Join(displayArgs, \\\" \\\"),\\n   177→\\t\\tStdout:   stdout.String(),\\n   178→\\t\\tStderr:   stderr.String(),\\n   179→\\t\\tExitCode: exitCode,\\n   180→\\t}, err\\n   181→}\\n   182→\\n   183→func (k *Kiro) StartSession(ctx context.Context, dir string) (Session, error) {\\n   184→\\treturn &KiroSession{kiro: k, dir: dir, ctx: ctx}, nil\\n   185→}\\n   186→\\n   187→// KiroSession runs each Send as a separate --no-interactive command.\\n   188→// SIGV4 auth does not work with the interactive TUI, so this approach\\n   189→// runs one kiro-cli-chat process per prompt (same pattern as setup-kiro-action).\\n   190→type KiroSession struct {\\n   191→\\tkiro       *Kiro\\n   192→\\tdir        string\\n   193→\\tctx        context.Context\\n   194→\\tlastOutput string\\n   195→}\\n   196→\\n   197→func (s *KiroSession) Send(input string) error {\\n   198→\\tout, err := s.kiro.RunPrompt(s.ctx, s.dir, input)\\n   199→\\ts.lastOutput = out.Stdout + out.Stderr\\n   200→\\treturn err\\n   201→}\\n   202→\\n   203→func (s *KiroSession) WaitFor(_ string, _ time.Duration) (string, error) {\\n   204→\\treturn s.lastOutput, nil\\n   205→}\\n   206→\\n   207→func (s *KiroSession) Capture() string { return s.lastOutput }\\n   208→func (s *KiroSession) Close() error    { return nil }\\n   209→\"}]},\"uuid\":\"dcc13714-6c42-4f79-a752-55c340adce71\",\"timestamp\":\"2026-03-05T22:00:34.334Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a42501637d37c0a1a\"},\"toolUseID\":\"agent_msg_017R5GmJZJoV2EBd421aCSkM\",\"parentToolUseID\":\"toolu_01Xd3hNhb8NQo9MUoyCu3Ukx\",\"uuid\":\"61e7a652-58f0-4154-8bff-9c93813c4acf\",\"timestamp\":\"2026-03-05T22:00:34.335Z\"}\n{\"parentUuid\":\"61e7a652-58f0-4154-8bff-9c93813c4acf\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alisha/Projects/wt/kiro-oneshot\",\"sessionId\":\"7682603d-1d7b-49cc-900b-ee77433e7db4\",\"version\":\"2.1.69\",\"gitBranch\":\"alisha/kiro-oneshot\",\"slug\":\"toasty-stargazing-mountain\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message