T) {\\n   113→\\tt.Parallel()\\n   114→\\ttmpDir := t.TempDir()\\n   115→\\tfile := filepath.Join(tmpDir, \\\"transcript.jsonl\\\")\\n   116→\\tcontent := `{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"hello\\\"}\\n   117→{\\\"role\\\":\\\"assistant\\\",\\\"content\\\":\\\"hi\\\"}`\\n   118→\\tif err := os.WriteFile(file, []byte(content), 0o644); err != nil {\\n   119→\\t\\tt.Fatalf(\\\"failed to write test file: %v\\\", err)\\n   120→\\t}\\n   121→\\n   122→\\tag := &FactoryAIDroidAgent{}\\n   123→\\tdata, err := ag.ReadTranscript(file)\\n   124→\\tif err != nil {\\n   125→\\t\\tt.Fatalf(\\\"ReadTranscript() error = %v\\\", err)\\n   126→\\t}\\n   127→\\tif string(data) != content {\\n   128→\\t\\tt.Errorf(\\\"ReadTranscript() = %q, want %q\\\", string(data), content)\\n   129→\\t}\\n   130→}\\n   131→\\n   132→func TestReadTranscript_MissingFile(t *testing.T) {\\n   133→\\tt.Parallel()\\n   134→\\tag := &FactoryAIDroidAgent{}\\n   135→\\t_, err := ag.ReadTranscript(\\\"/nonexistent/path/transcript.jsonl\\\")\\n   136→\\tif err == nil {\\n   137→\\t\\tt.Error(\\\"ReadTranscript() should error on missing file\\\")\\n   138→\\t}\\n   139→}\\n   140→\\n   141→func TestChunkTranscript_SmallContent(t *testing.T) {\\n   142→\\tt.Parallel()\\n   143→\\tag := &FactoryAIDroidAgent{}\\n   144→\\tcontent := []byte(`{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"hello\\\"}`)\\n   145→\\n   146→\\tchunks, err := ag.ChunkTranscript(content, agent.MaxChunkSize)\\n   147→\\tif err != nil {\\n   148→\\t\\tt.Fatalf(\\\"ChunkTranscript() error = %v\\\", err)\\n   149→\\t}\\n   150→\\tif len(chunks) != 1 {\\n   151→\\t\\tt.Errorf(\\\"Expected 1 chunk, got %d\\\", len(chunks))\\n   152→\\t}\\n   153→}\\n   154→\\n   155→func TestChunkTranscript_LargeContent(t *testing.T) {\\n   156→\\tt.Parallel()\\n   157→\\tag := &FactoryAIDroidAgent{}\\n   158→\\n   159→\\t// Build multi-line JSONL that exceeds a small maxSize\\n   160→\\tvar lines []string\\n   161→\\tfor i := range 50 {\\n   162→