pe\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01JYFZce9nxTKx3eohmVD6cn\",\"type\":\"tool_result\",\"content\":\"     1→package cli\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"errors\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"io\\\"\\n     8→\\t\\\"time\\\"\\n     9→\\n    10→\\t\\\"github.com/charmbracelet/huh\\\"\\n    11→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    14→\\n    15→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    16→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    17→\\t\\\"github.com/spf13/cobra\\\"\\n    18→)\\n    19→\\n    20→// stalenessThreshold is the duration after which an active session is considered stuck.\\n    21→const stalenessThreshold = 1 * time.Hour\\n    22→\\n    23→func newDoctorCmd() *cobra.Command {\\n    24→\\tvar forceFlag bool\\n    25→\\n    26→\\tcmd := &cobra.Command{\\n    27→\\t\\tUse:   \\\"doctor\\\",\\n    28→\\t\\tShort: \\\"Fix stuck sessions\\\",\\n    29→\\t\\tLong: `Scan for stuck or problematic sessions and offer to fix them.\\n    30→\\n    31→A session is considered stuck if:\\n    32→  - It is in ACTIVE phase with no interaction for over 1 hour\\n    33→  - It is in ENDED phase with uncondensed checkpoint data on a shadow branch\\n    34→\\n    35→For each stuck session, you can choose to:\\n    36→  - Condense: Save session data to permanent storage (entire/checkpoints/v1 branch)\\n    37→  - Discard: Remove the session state and shadow branch data\\n    38→  - Skip: Leave the session as-is\\n    39→\\n    40→Use --force to condense all fixable sessions without prompting.  Sessions that can't\\n    41→be condensed will be discarded.`,\\n    42→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    43→\\t\\t\\treturn runSessionsFix(cmd, forceFlag)\\n    44→\\t\\t},\\n    45→\\t}\\n    46→\\n    47→\\tcmd.Flags().BoolVarP(&forceFlag, \\\"force\\\", \\\"f\\\", false, \\\"Fix all stuck sessions without prompting (condense if possible, otherwise discard)\\\")\\n    48→\\n    49→\\treturn cmd\\n    50→}\\n    51→\\n    52→// stuckSession holds a session state along with diagnostic info.\\n    53→type stuckSession struct {\\n    54→\\tState             *strategy.SessionState\\n    55→\\tReason            string\\n    56→\\tShadowBranch      string\\n    57→\\tHasShadowBranch   bool\\n    58→\\tCheckpointCount   int\\n    59→\\tFilesTouchedCount int\\n    60→}\\n    61→\\n    62→func runSessionsFix(cmd *cobra.Command, force bool) error {\\n    63→\\tctx := cmd.Context()\\n    64→\\t// Load all session states\\n    65→\\tstates, err := strategy.ListSessionStates(ctx)\\n    66→\\tif err != nil {\\n    67→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n    68→\\t}\\n    69→\\n    70→\\tif len(states) == 0 {\\n    71→\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"No stuck sessions found.\\\")\\n    72→\\t\\treturn nil\\n    73→\\t}\\n    74→\\n    75→\\t// Open repository to check shadow branches (uses worktree-aware helper)\\n    76→\\trepo, err := openRepository(ctx)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n    79→\\t}\\n    80→\\n    81→\\t// Identify stuck sessions\\n    82→\\tnow := time.Now()\\n    83→\\tvar stuck []stuckSession\\n    84→\\n    85→\\tfor _, state := range states {\\n    86→\\t\\tss := classifySession(state, repo, now)\\n    87→\\t\\tif ss != nil {\\n    88→\\t\\t\\tstuck = append(stuck, *ss)\\n    89→\\t\\t}\\n    90→\\t}\\n    91→\\n    92→\\tif len(stuck) == 0 {\\n    93→\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"No stuck sessions found.\\\")\\n    94→\\t\\treturn nil\\n    95→\\t}\\n    96→\\n    97→\\t// Get the current strategy for condense operations\\n    98→\\tstrat := GetStrategy(ctx)\\n    99→\\n   100→\\tfmt.Fprintf(cmd.OutOrStdout(), \\\"Found %d stuck session(s):\\\\n\\\\n\\\", len(stuck))\\n   101→\\n   102→\\tfor _, ss := range stuck {\\n   103→\\t\\tdisplayStuckSession(cmd, ss)\\n   104→\\n   105→\\t\\tif force {\\n   106→\\t\\t\\tif ss.HasShadowBranch && ss.CheckpointCount > 0 {\\n   107→\\t\\t\\t\\tif err := strat.CondenseSessionByID(ctx, ss.State.SessionID); err != nil {\\n   108→\\t\\t\\t\\t\\tfmt.Fprintf(cmd.ErrOrStderr(), \\\"Warning: failed to condense session %s: %v\\\\n\\\", ss.State.SessionID, err)\\n   109→\\t\\t\\t\\t} else {\\n   110→\\t\\t\\t\\t\\tfmt.Fprintf(cmd.OutOrStdout(), \\\"  -> Condensed session %s\\\\n\\\\n\\\", ss.State.SessionID)\\n   111→\\t\\t\\t\\t}\\n   112→\\t\\t\\t} else {\\n   113→\\t\\t\\t\\t// Discard if we can't condense\\n   114→\\t\\t\\t\\tif err := discardSession(ctx, ss, repo, cmd.ErrOrStderr()); err != nil {\\n   115→\\t\\t\\t\\t\\tfmt.Fprintf(cmd.ErrOrStderr(), \\\"Warning: failed to discard session %s: %v\\\\n\\\", ss.State.SessionID, err)\\n   116→\\t\\t\\t\\t} else {\\n   117→\\t\\t\\t\\t\\tfmt.Fprintf(cmd.OutOrStdout(), \\\"  -> Discarded session %s\\\\n\\\\n\\\", ss.State.SessionID)\\n   118→\\t\\t\\t\\t}\\n   119→\\t\\t\\t}\\n   120→\\t\\t\\tcontinue\\n   121→\\t\\t}\\n   122→\\n   123→\\t\\t// Interactive: prompt for action\\n   124→\\t\\taction, err := promptSessionAction(ss)\\n   125→\\t\\tif err != nil {\\n   126→\\t\\t\\tif errors.Is(err, huh.ErrUserAborted) {\\n   127→\\t\\t\\t\\treturn nil\\n   128→\\t\\t\\t}\\n   129→\\t\\t\\treturn fmt.Errorf(\\\"failed to get action: %w\\\", err)\\n   130→\\t\\t}\\n   131→\\n   132→\\t\\tswitch action {\\n   133→\\t\\tcase \\\"condense\\\":\\n   134→\\t\\t\\tif err := strat.CondenseSessionByID(ctx, ss.State.SessionID); err != nil {\\n   135→\\t\\t\\t\\tfmt.Fprintf(cmd.ErrOrStderr(), \\\"Warning: failed to condense session %s: %v\\\\n\\\", ss.State.SessionID, err)\\n   136→\\t\\t\\t} else {\\n   137→\\t\\t\\t\\tfmt.Fprintf(cmd.OutOrStdout(), \\\"  -> Condensed session %s\\\\n\\\\n\\\", ss.State.SessionID)\\n   138→\\t\\t\\t}\\n   139→\\t\\tcase \\\"discard\\\":\\n   140→\\t\\t\\tif err := discardSession(ctx, ss, repo, cmd.ErrOrStderr()); err != nil {\\n   141→\\t\\t\\t\\tfmt.Fprintf(cmd.ErrOrStderr(), \\\"Warning: failed to discard session %s: %v\\\\n\\\", ss.State.SessionID, err)\\n   142→\\t\\t\\t} else {\\n   143→\\t\\t\\t\\tfmt.Fprintf(cmd.OutOrStdout(), \\\"  -> Discarded session %s\\\\n\\\\n\\\", ss.State.SessionID)\\n   144→\\t\\t\\t}\\n   145→\\t\\tcase \\\"skip\\\":\\n   146→\\t\\t\\tfmt.Fprintf(cmd.OutOrStdout(), \\\"  -> Skipped\\\\n\\\\n\\\")\\n   147→\\t\\t}\\n   148→\\t}\\n   149→\\n   150→\\treturn nil\\n   151→}\\n   152→\\n   153→// classifySession determines if a session is stuck and returns diagnostic info.\\n   154→// Returns nil if the session is healthy.\\n   155→func classifySession(state *strategy.SessionState, repo *git.Repository, now time.Time) *stuckSession {\\n   156→\\t// Determine shadow branch info\\n   157→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   158→\\trefName := plumbing.NewBranchReferenceName(shadowBranch)\\n   159→\\t_, refErr := repo.Reference(refName, true)\\n   160→\\thasShadowBranch := refErr == nil\\n   161→\\n   162→\\tswitch {\\n   163→\\tcase state.Phase.IsActive():\\n   164→\\t\\t// Active sessions are stuck if no interaction for over the staleness threshold\\n   165→\\t\\tisStale := state.LastInteractionTime == nil || now.Sub(*state.LastInteractionTime) > stalenessThreshold\\n   166→\\t\\tif !isStale {\\n   167→\\t\\t\\treturn nil\\n   168→\\t\\t}\\n   169→\\n   170→\\t\\tvar reason string\\n   171→\\t\\tif state.LastInteractionTime != nil {\\n   172→\\t\\t\\treason = fmt.Sprintf(\\\"active, last interaction %s ago\\\", now.Sub(*state.LastInteractionTime).Truncate(time.Minute))\\n   173→\\t\\t} else {\\n   174→\\t\\t\\treason = \\\"active, no recorded interaction time\\\"\\n   175→\\t\\t}\\n   176→\\n   177→\\t\\treturn &stuckSession{\\n   178→\\t\\t\\tState:    