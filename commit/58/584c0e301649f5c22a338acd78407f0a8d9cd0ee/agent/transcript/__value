s checkout and reset --hard (see HardResetWithProtection).\\n/Users/dvydra/src/cli/cmd/entire/cli/strategy/common.go-1168-//\\n/Users/dvydra/src/cli/cmd/entire/cli/strategy/common.go-1169-// Returns ErrBranchNotFound if the branch does not exist, allowing callers\\n/Users/dvydra/src/cli/cmd/entire/cli/strategy/common.go-1170-// to use errors.Is for idempotent deletion patterns.\\ncmd/entire/cli/strategy/common.go:1171:func DeleteBranchCLI(ctx context.Context, branchName string) error {\\ncmd/entire/cli/strategy/common.go-1172-\\t/ Pre-check: verify the branch exists so callers get a structured error\\n/Users/dvydra/src/cli/cmd/entire/cli/strategy/common.go-1173-\\t// instead of parsing git's output string (which varies across locales).\\n/Users/dvydra/src/cli/cmd/entire/cli/strategy/common.go-1174-\\t// git show-ref exits 1 for \\\"not found\\\" and 128+ for fatal errors (corrupt\\n/Users/dvydra/src/cli/cmd/entire/cli/strategy/common.go-1175-\\t// repo, permissions, not a git directory). Only map exit code 1 to\\n/Users/dvydra/src/cli/cmd/entire/cli/strategy/common.go-1176-\\t// ErrBranchNotFound; propagate other failures as-is.\"}]},\"uuid\":\"9a779660-ffa5-4fd1-8991-15531889c085\",\"timestamp\":\"2026-03-03T04:00:06.811Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a615627ce8cb37747\"},\"toolUseID\":\"agent_msg_012BLcPcMvNXxWahhuPUTyXH\",\"parentToolUseID\":\"toolu_019Dhxr1H5tybcffB6rWJCnz\",\"uuid\":\"d0b54893-432b-4b96-9586-7e2462b9a77d\",\"timestamp\":\"2026-03-03T04:00:06.812Z\"}\n{\"parentUuid\":\"d0b54893-432b-4b96-9586-7e2462b9a77d\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/dvydra/src/cli\",\"sessionId\":\"ae3fd4eb-1bb7-4e7b-8986-8c5944422068\",\"version\":\"2.1.63\",\"gitBranch\":\"fix/reconcile-disconnected-metadata-branch\",\"slug\":\"tidy-bubbling-duckling\",\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"PostToolUse\",\"hookName\":\"PostToolUse:Agent\",\"command\":\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code post-task\"},\"parentToolUseID\":\"toolu_019Dhxr1H5tybcffB6rWJCnz\",\"toolUseID\":\"toolu_019Dhxr1H5tybcffB6rWJCnz\",\"timestamp\":\"2026-03-03T04:01:54.511Z\",\"uuid\":\"9f08b46f-540a-4726-aebc-f4635b7de42c\"}\n{\"parentUuid\":\"cd5beb67-977e-47eb-bc95-857794d3198a\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/dvydra/src/cli\",\"sessionId\":\"ae3fd4eb-1bb7-4e7b-8986-8c5944422068\",\"version\":\"2.1.63\",\"gitBranch\":\"fix/reconcile-disconnected-metadata-branch\",\"slug\":\"tidy-bubbling-duckling\",\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_019Dhxr1H5tybcffB6rWJCnz\",\"type\":\"tool_result\",\"content\":[{\"type\":\"text\",\"text\":\"I now have a thorough understanding of the full codebase. Let me present the detailed implementation plan.\\n\\n---\\n\\n## Implementation Plan: Refactoring Metadata Branch Reconciliation\\n\\n### Overview\\n\\nThe goal is to move reconciliation out of hot read paths (where it runs on every `ListCheckpoints`, `getCheckpointStore`, and `getBranchCheckpoints` call) and into exactly two explicit locations: the **pre-push hook** (automatic repair before push) and **`entire doctor`** (user-initiated repair). All other locations that previously reconciled will instead detect the problem and emit a one-time warning pointing the user to `entire doctor`.\\n\\n---\\n\\n### Part 1: Add exported `IsMetadataDisconnected()` function\\n\\n**File:** `/Users/dvydra/src/cli/cmd/entire/cli/strategy/metadata_reconcile.go`\\n\\nThe existing `isDisconnected(repoPath, hashA, hashB)` is unexported and takes low-level string arguments. A new exported function wraps the full check logic (look up local ref, look up remote ref, compare hashes, call `isDisconnected`).\\n\\n```go\\n// IsMetadataDisconnected checks whether the local and remote entire/checkpoints/v1\\n// branches exist but share no common ancestor (the \\\"empty-orphan bug\\\").\\n// Returns (false, nil) if:\\n//   - either branch is missing (nothing to reconcile)\\n//   - branches point to same hash\\n//   - branches share a common ancestor (normal divergence, handled by push merge)\\n// Returns (true, nil) only when both exist and are truly disconnected.\\nfunc IsMetadataDisconnected(repo *git.Repository) (bool, error) {\\n    refName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n    localRef, err := repo.Reference(refName, true)\\n    if errors.Is(err, plumbing.ErrReferenceNotFound) {\\n        return false, nil\\n    }\\n    if err != nil {\\n        return false, fmt.Errorf(\\\"failed to check local metadata branch: %w\\\", err)\\n    }\\n\\n    remoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n    remoteRef, err := repo.Reference(remoteRefName, true)\\n    if errors.Is(err, plumbing.ErrReferenceNotFound) {\\n        return false, nil\\n    }\\n    if err != nil {\\n        return false, fmt.Errorf(\\\"failed to check remote metadata branch: %w\\\", err)\\n    }\\n\\n    if localRef.Hash() == remoteRef.Hash() {\\n        return false, nil\\n    }\\n\\n    repoPath, err := getRepoPath(repo)\\n    if err != nil {\\n        return false, err\\n    }\\n\\n    return isDisconnected(repoPath, localRef.Hash().String(), remoteRef.Hash().String())\\n}\\n```\\n\\nThis is essentially the detection logic already inside `ReconcileDisconnectedMetadataBranch`, extracted into its own function. The existing `ReconcileDisconnectedMetadataBranch` can then be simplified to call `IsMetadataDisconnected` first (optional refactor; not strictly required since both share the same internal `isDisconnected`).\\n\\n**Note on refactoring `ReconcileDisconnectedMetadataBranch`:** Rather than having it duplicate the detection logic, consider having it call `IsMetadataDisconnected` at the top and return early if `(false, nil)`. This would eliminate code duplication. However, `ReconcileDisconnectedMetadataBranch` already has the local/remote refs it needs for the repair, so extracting them again via `IsMetadataDisconnected` is wasteful. The pragmatic choice: keep `ReconcileDisconnectedMetadataBranch` as-is (it already does detection + repair inline) and have `IsMetadataDisconnected` exist as a lightweight detection-only function. Both share `isDisconnected()` internally, so the real logic is not duplicated.\\n\\n---\\n\\n### Part 2: Add `WarnIfMetadataDisconnected()` function\\n\\n**File:** `/Users/dvydra/src/cli/cmd/entire/cli/strategy/metadata_reconcile.go`\\n\\nThis replaces the `EnsureMetadataReconciled` sync.Once wrapper. It uses its own `sync.Once` to check once per process and emit a warning.\\n\\n```go\\nvar (\\n    disconnectedOnce   sync.Once\\n    disconnectedResult bool\\n)\\n\\n// WarnIfMetadataDisconnected checks (once per process) whether the metadata\\n// branch is disconnected and prints a warning to stderr if so.\\n// It does NOT attempt to fix the problem. Users are directed to `entire doctor`.\\nfunc WarnIfMetadataDisconnected() {\\n    disconnectedOnce.Do(func() {\\n        repo, err := OpenRepository(context.Background())\\n        if err != nil {\\n            return // Can't check, don't warn\\n        }\\n        disconnected, err := IsMetadataDisconnected(repo)\\n        if err != nil {\\n            return // Can't check, don't warn\\n        }\\n        disconnectedResult = disconnected\\n        if disconnected {\\n            fmt.Fprintln(os.Stderr,\\n                \\\"[entire] Warning: Local and remote session metadata branches are disconnected.\\\")\\n            fmt.Fprintln(os.Stderr,\\n                \\\"[entire] Some checkpoints from remote may not be visible. Run 'entire doctor' to fix.\\\")\\n        }\\n    })\\n}\\n```\\n\\nKey design choices:\\n- Returns nothing (not an error). The warning is best-effort. If we cannot open the repo or detect disconnection, we silently skip. This ensures read paths never fail due to the detection check.\\n- Uses `sync.Once` to avoid spamming the same message across multiple call sites within a single process invocation.\\n- The message is terse but actionable: it tells the user what is wrong (\\\"disconnected\\\") and what to do about it (\\\"run `entire doctor`\\\").\\n\\n---\\n\\n### Part 3: Remove `EnsureMetadataReconciled()` and its global state\\n\\n**File:** `/Users/dvydra/src/cli/cmd/entire/cli/strategy/common.go`\\n\\nDelete lines 49-69:\\n- The `reconcileOnce` and `reconcileResult` globals (lines 51-54)\\n- The `EnsureMetadataReconciled()` function (lines 56-69)\\n\\nThese are fully replaced by `WarnIfMetadataDisconnected()` for read paths and direct `ReconcileDisconnectedMetadataBranch()` calls for fix paths.\\n\\n---\\n\\n### Part 4: Replace call sites with warning or direct reconciliation\\n\\n#### 4a. `ListCheckpoints()` in `common.go` (line 148)\\n\\n**File:** `/Users/dvydra/src/cli/cmd/entire/cli/strategy/common.go`\\n\\nReplace:\\n```go\\n// Ensure disconnected metadata branches are reconciled before reading\\nif reconcileErr := EnsureMetadataReconciled(); reconcileErr != nil {\\n    fmt.Fprintf(os.Stderr, \\\"[entire] Warning: %v\\\\n\\\", reconcileErr)\\n}\\n```\\n\\nWith:\\n```go\\n// Warn (once per process) if metadata branches are disconnected\\nWarnIfMetadataDisconnected()\\n```\\n\\nThis is a read path. It should not attempt to fix anything; just warn the user.\\n\\n#### 4b. `getCheckpointStore()` in `manual_commit.go` (line 55)\\n\\n**File:** `/Users/dvydra/src/cli/cmd/entire/cli/strategy/manual_commit.go`\\n\\nReplace:\\n```go\\nif err := EnsureMetadataReconciled(); err != nil {\\n    fmt.Fprintf(os.Stderr, \\\"[entire] Warning: %v\\\\n\\\", err)\\n}\\n```\\n\\nWith:\\n```go\\nWarnIfMetadataDisconnected()\\n```\\n\\nSame rationale: `getCheckpointStore()` is called from many write and read operations. Reconciliation is too heavy and surprising to run here. A one-time warning is appropriate.\\n\\n**Important consideration:** `getCheckpointStore()` is called from write paths too (e.g., `condense`). In the disconnected state, writes to the metadata branch still work correctly -- they add new checkpoint shards to the local branch. The problem is only that existing remote data is not visible. The next push will reconcile (Part 5), so this is fine.\\n\\n#### 4c. `getBranchCheckpoints()` in `explain.go` (line 897)\\n\\n**File:** `/Users/dvydra/src/cli/cmd/entire/cli/explain.go`\\n\\nReplace:\\n```go\\n// Ensure disconnected metadata branches are reconciled before reading\\nif err := strategy.EnsureMetadataReconciled(); err != nil {\\n    logging.Warn(ctx, \\\"metadata reconciliation failed\\\", \\\"error\\\", err)\\n}\\n```\\n\\nWith:\\n```go\\n// Warn (once per process) if metadata branches are disconnected\\nstrategy.WarnIfMetadataDisconnected()\\n```\\n\\n---\\n\\n### Part 5: Integrate reconciliation into pre-push flow\\n\\n**File:** `/Users/dvydra/src/cli/cmd/entire/cli/strategy/push_common.go`\\n\\nThe reconciliation must happen inside `fetchAndMergeSessionsCommon()`, after the fetch (so the remote-tracking ref `refs/remotes/origin/entire/checkpoints/v1` is updated) but before reading the local ref for tree operations.\\n\\nCurrent flow in `fetchAndMergeSessionsCommon()` (lines 125-202):\\n1. `git fetch remote branchName` (line 132) -- updates FETCH_HEAD and remote-tracking ref\\n2. `OpenRepository()` (line 138)\\n3. Read local ref (line 144)\\n4. Read local commit/tree (lines 148-155)\\n5. Read FETCH_HEAD ref (line 158)\\n6. Read remote commit/tree (lines 162-169)\\n7. Flatten + combine trees (lines 173-179)\\n8. Build merged tree + merge commit (lines 182-193)\\n9. Update local branch ref (lines 196-198)\\n\\nInsert reconciliation between step 2 (open repo) and step 3 (read local ref):\\n\\n```go\\nrepo, err := OpenRepository(ctx)\\nif err != nil {\\n    return fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n}\\n\\n// Reconcile disconnected metadata branches before merging.\\n// After fetch, the remote-tracking ref is fresh. If local and remote\\n// are disconnected (empty-orphan bug), cherry-pick local onto remote.\\n// This updates the local ref, so we must read it AFTER this call.\\nif reconcileErr := ReconcileDisconnectedMetadataBranch(repo); reconcileErr != nil {\\n    fmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to reconcile metadata branches: %v\\\\n\\\", reconcileErr)\\n    // Continue with normal merge — worst case, we create a merge commit\\n    // that duplicates some entries (which is harmless for append-only shards).\\n}\\n\\n// Get local branch (re-read after potential reconciliation)\\nlocalRef, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n```\\n\\nThe rest of the function remains unchanged. After reconciliation, the local branch ref now sits on top of the remote tip (linear history). When we read it and compare trees, we'll find either:\\n- **Identical trees** (if reconciliation made local = remote): the merge is a no-op, but the function will still create a merge commit. This is harmless.\\n- **Local has additional data** (cherry-picked on top of remote): the tree merge will combine both, creating a valid merge commit.\\n\\n**Edge case -- reconciliation already happened:** If `ReconcileDisconnectedMetadataBranch` finds no disconnection (shared ancestry or same hash), it returns nil immediately. The fetch-and-merge continues as before, handling normal divergence via its tree-merge logic.\\n\\n**Edge case -- reconciliation fails:** We log a warning and continue. The tree merge in `fetchAndMergeSessionsCommon` will still attempt to combine entries from both trees. Since both trees contain unique shard paths, this produces a valid merged tree even without reconciliation. The result will be a merge commit with two unrelated parents (the disconnected branches), which is technically valid git but not ideal. On the next push cycle, the same reconciliation attempt will occur.\\n\\n--