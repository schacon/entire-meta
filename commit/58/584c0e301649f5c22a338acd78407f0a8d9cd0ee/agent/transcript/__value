g bool\\n    25→\\n    26→\\tcmd := &cobra.Command{\\n    27→\\t\\tUse:   \\\"doctor\\\",\\n    28→\\t\\tShort: \\\"Fix stuck sessions\\\",\\n    29→\\t\\tLong: `Scan for stuck or problematic sessions and offer to fix them.\\n    30→\\n    31→A session is considered stuck if:\\n    32→  - It is in ACTIVE phase with no interaction for over 1 hour\\n    33→  - It is in ENDED phase with uncondensed checkpoint data on a shadow branch\\n    34→\\n    35→For each stuck session, you can choose to:\\n    36→  - Condense: Save session data to permanent storage (entire/checkpoints/v1 branch)\\n    37→  - Discard: Remove the session state and shadow branch data\\n    38→  - Skip: Leave the session as-is\\n    39→\\n    40→Use --force to condense all fixable sessions without prompting.  Sessions that can't\\n    41→be condensed will be discarded.`,\\n    42→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    43→\\t\\t\\treturn runSessionsFix(cmd, forceFlag)\\n    44→\\t\\t},\\n    45→\\t}\\n    46→\\n    47→\\tcmd.Flags().BoolVarP(&forceFlag, \\\"force\\\", \\\"f\\\", false, \\\"Fix all stuck sessions without prompting (condense if possible, otherwise discard)\\\")\\n    48→\\n    49→\\treturn cmd\\n    50→}\\n    51→\\n    52→// stuckSession holds a session state along with diagnostic info.\\n    53→type stuckSession struct {\\n    54→\\tState             *strategy.SessionState\\n    55→\\tReason            string\\n    56→\\tShadowBranch      string\\n    57→\\tHasShadowBranch   bool\\n    58→\\tCheckpointCount   int\\n    59→\\tFilesTouchedCount int\\n    60→}\\n    61→\\n    62→func runSessionsFix(cmd *cobra.Command, force bool) error {\\n    63→\\tctx := cmd.Context()\\n    64→\\t// Load all session states\\n    65→\\tstates, err := strategy.ListSessionStates(ctx)\\n    66→\\tif err != nil {\\n    67→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n    68→\\t}\\n    69→\\n    70→\\tif len(states) == 0 {\\n    71→\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"No stuck sessions found.\\\")\\n    72→\\t\\treturn nil\\n    73→\\t}\\n    74→\\n    75→\\t// Open repository to check shadow branches (uses worktree-aware helper)\\n    76→\\trepo, err := openRepository(ctx)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n    79→\\t}\\n    80→\\n    81→\\t// Identify stuck sessions\\n    82→\\tnow := time.Now()\\n    83→\\tvar stuck []stuckSession\\n    84→\\n    85→\\tfor _, state := range states {\\n    86→\\t\\tss := classifySession(state, repo, now)\\n    87→\\t\\tif ss != nil {\\n    88→\\t\\t\\tstuck = append(stuck, *ss)\\n    89→\\t\\t}\\n    90→\\t}\\n    91→\\n    92→\\tif len(stuck) == 0 {\\n    93→\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"No stuck sessions found.\\\")\\n    94→\\t\\treturn nil\\n    95→\\t}\\n    96→\\n    97→\\t// Get the current strategy for condense operations\\n    98→\\tstrat := GetStrategy(ctx)\\n    99→\\n   100→\\tfmt.Fprintf(cmd.OutOrStdout(), \\\"Found %d stuck session(s):\\\\n\\\\n\\\", len(stuck))\\n   101→\\n   102→\\tfor _, ss := range stuck {\\n   103→\\t\\tdisplayStuckSession(cmd, ss)\\n   104→\\n   105→\\t\\tif force {\\n   106→\\t\\t\\tif ss.HasShadowBranch && ss.CheckpointCount > 0 {\\n   107→\\t\\t\\t\\tif err := strat.CondenseSessionByID(ctx, ss.State.SessionID); err != nil {\\n   108→\\t\\t\\t\\t\\tfmt.Fprintf(cmd.ErrOrStderr(), \\\"Warning: failed to condense session %s: %v\\\\n\\\", ss.State.SessionID, err)\\n   109→\\t\\t\\t\\t} else {\\n   110→\\t\\t\\t\\t\\tfmt.Fprintf(cmd.OutOrStdout(), \\\"  -> Condensed session %s\\\\n\\\\n\\\", ss.State.SessionID)\\n   111→\\t\\t\\t\\t}\\n   112→\\t\\t\\t} else {\\n   113→\\t\\t\\t\\t// Discard if we can't condense\\n   114→\\t\\t\\t\\tif err := discardSession(ctx, ss, repo, cmd.ErrOrStderr()); err != nil {\\n   115→\\t\\t\\t\\t\\tfmt.Fprintf(cmd.ErrOrStderr(), \\\"Warning: failed to discard session %s: %v\\\\n\\\", ss.State.SessionID, err)\\n   116→\\t\\t\\t\\t} e