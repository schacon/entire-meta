nfiguration (stored in .entire/settings.json under strategy_options.push_sessions):\\n    23→//   - false: disable automatic pushing\\n    24→//   - true or not set: push automatically (default)\\n    25→func pushSessionsBranchCommon(ctx context.Context, remote, branchName string) error {\\n    26→\\t// Check if pushing is disabled\\n    27→\\tif isPushSessionsDisabled(ctx) {\\n    28→\\t\\treturn nil\\n    29→\\t}\\n    30→\\n    31→\\trepo, err := OpenRepository(ctx)\\n    32→\\tif err != nil {\\n    33→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n    34→\\t}\\n    35→\\n    36→\\t// Check if branch exists locally\\n    37→\\tbranchRef := plumbing.NewBranchReferenceName(branchName)\\n    38→\\tlocalRef, err := repo.Reference(branchRef, true)\\n    39→\\tif err != nil {\\n    40→\\t\\t// No branch, nothing to push\\n    41→\\t\\treturn nil //nolint:nilerr // Expected when no sessions exist yet\\n    42→\\t}\\n    43→\\n    44→\\t// Check if there's actually something to push (local differs from remote)\\n    45→\\tif !hasUnpushedSessionsCommon(repo, remote, localRef.Hash(), branchName) {\\n    46→\\t\\t// Nothing to push - skip silently\\n    47→\\t\\treturn nil\\n    48→\\t}\\n    49→\\n    50→\\treturn doPushSessionsBranch(ctx, remote, branchName)\\n    51→}\\n    52→\\n    53→// hasUnpushedSessionsCommon checks if the local branch differs from the remote.\\n    54→// Returns true if there's any difference that needs syncing (local ahead, remote ahead, or diverged).\\n    55→func hasUnpushedSessionsCommon(repo *git.Repository, remote string, localHash plumbing.Hash, branchName string) bool {\\n    56→\\t// Check for remote tracking ref: refs/remotes/<remote>/<branch>\\n    57→\\tremoteRefName := plumbing.NewRemoteReferenceName(remote, branchName)\\n    58→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n    59→\\tif err != nil {\\n    60→\\t\\t// Remote branch doesn't exist yet - we have content to push\\n    61→\\t\\treturn true