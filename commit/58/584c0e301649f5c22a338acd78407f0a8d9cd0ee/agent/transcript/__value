t int\\n    64→\\n    65→const (\\n    66→\\tttyResultLink       ttyResult = iota // Link: add the checkpoint trailer\\n    67→\\tttyResultSkip                        // Skip: don't add the trailer\\n    68→\\tttyResultLinkAlways                  // Link and remember: add trailer + save \\\"always\\\" preference\\n    69→)\\n    70→\\n    71→// askConfirmTTY prompts the user via /dev/tty whether to link a commit to session context.\\n    72→// This requires a controlling terminal — callers must check hasTTY() first and handle\\n    73→// the no-TTY case (agent subprocesses, CI) themselves.\\n    74→//\\n    75→// header is displayed as the first line (e.g., \\\"Entire: Active Claude Code session\\\").\\n    76→// detail lines are displayed indented below the header.\\n    77→func askConfirmTTY(header string, details []string, prompt string, defaultYes bool) ttyResult {\\n    78→\\tdefaultResult := ttyResultSkip\\n    79→\\tif defaultYes {\\n    80→\\t\\tdefaultResult = ttyResultLink\\n    81→\\t}\\n    82→\\n    83→\\t// In test mode, don't try to interact with the real TTY — just use the default.\\n    84→\\t// ENTIRE_TEST_TTY=1 simulates \\\"a human is present\\\" for the hasTTY() check\\n    85→\\t// but we can't actually read from the TTY in tests.\\n    86→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n    87→\\t\\treturn defaultResult\\n    88→\\t}\\n    89→\\n    90→\\t// Open /dev/tty for both reading and writing.\\n    91→\\t// This is the controlling terminal, which works even when stdin/stderr are redirected\\n    92→\\t// (e.g., human runs git commit -m where stdin is not a pipe).\\n    93→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n    94→\\tif err != nil {\\n    95→\\t\\treturn defaultResult\\n    96→\\t}\\n    97→\\tdefer tty.Close()\\n    98→\\n    99→\\t// Write to tty directly, not stderr, since git hooks may redirect stderr to /dev/null\\n   100→\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", header)\\n   101→\\tfor _, line :=