md/entire/cli/paths\\\"\\n    13→\\n    14→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    15→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    16→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    17→)\\n    18→\\n    19→// ReconcileDisconnectedMetadataBranch detects and repairs disconnected local/remote\\n    20→// entire/checkpoints/v1 branches. Disconnected means no common ancestor, which\\n    21→// only happens due to the empty-orphan bug. Diverged (shared ancestor) is normal\\n    22→// and handled by the push path's tree merge.\\n    23→//\\n    24→// Repair strategy: cherry-pick local commits onto remote tip, preserving all data.\\n    25→// Checkpoint shards use unique paths (<id[:2]>/<id[2:]>/), so cherry-picks always\\n    26→// apply cleanly.\\n    27→func ReconcileDisconnectedMetadataBranch(repo *git.Repository) error {\\n    28→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n    29→\\n    30→\\t// Check local branch\\n    31→\\tlocalRef, err := repo.Reference(refName, true)\\n    32→\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n    33→\\t\\treturn nil // No local branch — nothing to reconcile\\n    34→\\t}\\n    35→\\tif err != nil {\\n    36→\\t\\treturn fmt.Errorf(\\\"failed to check local metadata branch: %w\\\", err)\\n    37→\\t}\\n    38→\\n    39→\\t// Check remote-tracking branch\\n    40→\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n    41→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n    42→\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n    43→\\t\\treturn nil // No remote branch — nothing to reconcile\\n    44→\\t}\\n    45→\\tif err != nil {\\n    46→\\t\\treturn fmt.Errorf(\\\"failed to check remote metadata branch: %w\\\", err)\\n    47→\\t}\\n    48→\\n    49→\\tlocalHash := localRef.Hash()\\n    50→\\tremoteHash := remoteRef.Hash()\\n    51→\\n    52→\\t// Same hash — nothing to do\\n    53→\\tif localHash == remoteHash {\\n    54→\\t\\treturn nil\\n    55→\\t}\\n    56→\\n    57→\\t// Check if disconnected using git merge-base\\n    58→\\trepoPath, err := getRepoPath(repo)\\n    59→\\tif err != nil {\\n    60→\\t\\treturn err\\n    61→\\t}\\n    62→\\n    63→\\tdisconnected, err := isDisconnected(repoPath, localHash.String(), remoteHash.String())\\n    64→\\tif err != nil {\\n    65→\\t\\treturn fmt.Errorf(\\\"failed to check metadata branch ancestry: %w\\\", err)\\n    66→\\t}\\n    67→\\tif !disconnected {\\n    68→\\t\\t// Shared ancestry (diverged or ancestor) — not our problem\\n    69→\\t\\treturn nil\\n    70→\\t}\\n    71→\\n    72→\\t// Disconnected — cherry-pick local commits onto remote tip\\n    73→\\tfmt.Fprintln(os.Stderr, \\\"[entire] Detected disconnected session metadata (local and remote share no common ancestor)\\\")\\n    74→\\n    75→\\t// Collect local commits oldest-first\\n    76→\\tlocalCommits, err := collectCommitChain(repo, localHash)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn fmt.Errorf(\\\"failed to collect local commits: %w\\\", err)\\n    79→\\t}\\n    80→\\n    81→\\t// Filter out empty-tree commits (the orphan bug commit)\\n    82→\\tvar dataCommits []*object.Commit\\n    83→\\tfor _, c := range localCommits {\\n    84→\\t\\ttree, treeErr := c.Tree()\\n    85→\\t\\tif treeErr != nil {\\n    86→\\t\\t\\treturn fmt.Errorf(\\\"failed to read tree for commit %s: %w\\\", c.Hash.String()[:7], treeErr)\\n    87→\\t\\t}\\n    88→\\t\\tif len(tree.Entries) > 0 {\\n    89→\\t\\t\\tdataCommits = append(dataCommits, c)\\n    90→\\t\\t}\\n    91→\\t}\\n    92→\\n    93→\\tif len(dataCommits) == 0 {\\n    94→\\t\\t// Local only had empty orphan — just point to remote\\n    95→\\t\\tref := plumbing.NewHashReference(refName, remoteHash)\\n    96→\\t\\tif err := repo.Storer.SetReference(ref); err != nil {\\n    97→\\t\\t\\treturn fmt.Errorf(\\\"failed to reset metadata branch to remote: %w\\\", err)\\n    98→\\t\\t}\\n    99→\\t\\tfmt.Fprintln(os.Stderr, \\\"[entire] Done — local had no checkpoint data, reset to remote\\\")\\n   100→\\t\\treturn nil\\n   101→\\t}\\n   102→\\n   103→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Cherry-picking %d local checkpoint(s) onto remote...\\\\n\\\", len(dataCommits))\\n   104→\\n   105→\\tnewTip, err := cherryPickOnto(repo, remoteHash, dataCommits)\\n   106→\\tif err != nil {\\n   107→\\t\\treturn fmt.Errorf(\\\"failed to cherry-pick local commits onto remote: %w\\\", err)\\n   108→\\t}\\n   109→\\n   110→\\t// Update local branch ref\\n   111→\\tref := plumbing.NewHashReference(refName, newTip)\\n   112→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   113→\\t\\treturn fmt.Errorf(\\\"failed to update metadata branch: %w\\\", err)\\n   114→\\t}\\n   115→\\n   116→\\tfmt.Fprintln(os.Stderr, \\\"[entire] Done — all local and remote checkpoints preserved\\\")\\n   117→\\treturn nil\\n   118→}\\n   119→\\n   120→// isDisconnected checks if two commits have no common ancestor using git merge-base.\\n   121→// Returns (true, nil) if disconnected, (false, nil) if they share ancestry,\\n   122→// or (false, error) if git merge-base failed for another reason.\\n   123→//\\n   124→// git merge-base exit codes:\\n   125→//   - 0: common ancestor found (shared ancestry)\\n   126→//   - 1: no common ancestor (disconnected)\\n   127→//   - 128+: error (corrupt repo, invalid hash, etc.)\\n   128→func isDisconnected(repoPath, hashA, hashB string) (bool, error) {\\n   129→\\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\\n   130→\\tdefer cancel()\\n   131→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"merge-base\\\", hashA, hashB)\\n   132→\\tcmd.Dir = repoPath\\n   133→\\tif err := cmd.Run(); err != nil {\\n   134→\\t\\tvar exitErr *exec.ExitError\\n   135→\\t\\tif errors.As(err, &exitErr) && exitErr.ExitCode() == 1 {\\n   136→\\t\\t\\treturn true, nil // No common ancestor — disconnected\\n   137→\\t\\t}\\n   138→\\t\\treturn false, fmt.Errorf(\\\"git merge-base failed: %w\\\", err)\\n   139→\\t}\\n   140→\\treturn false, nil // Shared ancestry\\n   141→}\\n   142→\\n   143→// collectCommitChain walks from tip to root following first parent, returns oldest-first.\\n   144→func collectCommitChain(repo *git.Repository, tip plumbing.Hash) ([]*object.Commit, error) {\\n   145→\\tvar chain []*object.Commit\\n   146→\\tcurrent := tip\\n   147→\\n   148→\\treachedRoot := false\\n   149→\\tfor range MaxCommitTraversalDepth {\\n   150→\\t\\tcommit, err := repo.CommitObject(current)\\n   151→\\t\\tif err != nil {\\n   152→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit %s: %w\\\", current, err)\\n   153→\\t\\t}\\n   154→\\t\\tchain = append(chain, commit)\\n   155→\\n   156→\\t\\tif len(commit.ParentHashes) == 0 {\\n   157→\\t\\t\\treachedRoot = true\\n   158→\\t\\t\\tbreak\\n   159→\\t\\t}\\n   160→\\t\\tcurrent = commit.ParentHashes[0]\\n   161→\\t}\\n   162→\\n   163→\\tif !reachedRoot {\\n   164→\\t\\treturn nil, fmt.Errorf(\\\"commit chain exceeded %d commits without reaching root; aborting reconciliation\\\", MaxCommitTraversalDepth)\\n   165→\\t}\\n   166→\\n   167→\\t// Reverse to oldest-first\\n   168→\\tfor i, j := 0, len(chain)-1; i < j; i, j = i+1, j-1 {\\n   169→\\t\\tchain[i], chain[j] = chain[j], chain[i]\\n   170→\\t}\\n   171→\\n   172→\\treturn chain, nil\\n   173→}\\n   174→\\n   175→// cherryPickOnto applies each commit's delta onto base, building a linear chain.\\n   176→// For each commit, it computes the full diff from its parent (additions, modifications,\\n   177→// and deletions), then applies that delta onto the current tip's tree.\\n   178→func cherryPickOnto(repo *git.Repository, base plumbing.Hash, commits []*object.Commit) (plumbing.Hash, error) {\\n   179→\\tcurrentTip := base\\n   180→\\n   181→\\tfor _, commit := range commits {\\n   182→\\t\\t// Get the commit's tree entries\\n   183→\\t\\tcommitTree, err := commit.Tree()\\n   184→\\t\\tif err != nil {\\n   185→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get tree for commit %s: %w\\\", commit.Hash, err)\\n   186→\\t\\t}\\n   187→\\n   188→\\t\\tcommitEntries := make(map[string]object.TreeEntry)\\n   189→\\t\\tif err := checkpoint.FlattenTree(repo, commitTree, \\\"\\\", commitEntries); err != nil {\\n   190→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten commit tree: %w\\\", err)\\n   191→\\t\\t}\\n   192→\\n   193→\\t\\t// Get parent's tree entries (empty if root commit)\\n   194→\\t\\tparentEntries := make(map[string]object.TreeEntry)\\n   195→\\t\\tif len(commit.ParentHashes) > 0 {\\n   196→\\t\\t\\tparentCommit, pErr := repo.CommitObject(commit.ParentHashes[0])\\n   197→\\t\\t\\tif pErr != nil {\\n   198→\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get parent commit %s: %w\\\", commit.ParentHashes[0], pErr)\\n   199→\\t\\t\\t}\\n   200→\\t\\t\\tparentTree, ptErr := parentCommit.Tree()\\n   201→\\t\\t\\tif ptErr != nil {\\n   202→\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get parent tree for commit %s: %w\\\", commit.ParentHashes[0], ptErr)\\n   203→\\t\\t\\t}\\n   204→\\t\\t\\tif err := checkpoint.FlattenTree(repo, parentTree, \\\"\\\", parentEntries); err != nil {\\n   205→\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten parent tree for commit %s: %w\\\", commit.ParentHashes[0], err)\\n   206→\\t\\t\\t}\\n   207→\\t\\t}\\n   208→\\n   209→\\t\\t// Compute full delta: additions, modifications, and deletions\\n   210→\\t\\tadded := make(map[string]object.TreeEntry)\\n   211→\\t\\tfor path, entry := range commitEntries {\\n   212→\\t\\t\\tparentEntry, exists := parentEntries[path]\\n   213→\\t\\t\\tif !exists || parentEntry.Hash != entry.Hash {\\n   214→\\t\\t\\t\\tadded[path] = entry // New or modified\\n   215→\\t\\t\\t}\\n   216→\\t\\t}\\n   217→\\t\\tvar deleted []string\\n   218→\\t\\tfor path := range parentEntries {\\n   219→\\t\\t\\tif _, exists := commitEntries[path]; !exists {\\n   220→\\