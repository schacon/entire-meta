nil {\\n    40→\\t\\t// No branch, nothing to push\\n    41→\\t\\treturn nil //nolint:nilerr // Expected when no sessions exist yet\\n    42→\\t}\\n    43→\\n    44→\\t// Check if there's actually something to push (local differs from remote)\\n    45→\\tif !hasUnpushedSessionsCommon(repo, remote, localRef.Hash(), branchName) {\\n    46→\\t\\t// Nothing to push - skip silently\\n    47→\\t\\treturn nil\\n    48→\\t}\\n    49→\\n    50→\\treturn doPushSessionsBranch(ctx, remote, branchName)\\n    51→}\\n    52→\\n    53→// hasUnpushedSessionsCommon checks if the local branch differs from the remote.\\n    54→// Returns true if there's any difference that needs syncing (local ahead, remote ahead, or diverged).\\n    55→func hasUnpushedSessionsCommon(repo *git.Repository, remote string, localHash plumbing.Hash, branchName string) bool {\\n    56→\\t// Check for remote tracking ref: refs/remotes/<remote>/<branch>\\n    57→\\tremoteRefName := plumbing.NewRemoteReferenceName(remote, branchName)\\n    58→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n    59→\\tif err != nil {\\n    60→\\t\\t// Remote branch doesn't exist yet - we have content to push\\n    61→\\t\\treturn true\\n    62→\\t}\\n    63→\\n    64→\\t// If local and remote point to same commit, nothing to sync\\n    65→\\t// This is the only case where we skip - any difference needs handling\\n    66→\\treturn localHash != remoteRef.Hash()\\n    67→}\\n    68→\\n    69→// isPushSessionsDisabled checks if push_sessions is disabled in settings.\\n    70→// Returns true if push_sessions is explicitly set to false.\\n    71→func isPushSessionsDisabled(ctx context.Context) bool {\\n    72→\\ts, err := settings.Load(ctx)\\n    73→\\tif err != nil {\\n    74→\\t\\treturn false // Default: push is enabled\\n    75→\\t}\\n    76→\\treturn s.IsPushSessionsDisabled()\\n    77→}\\n    78→\\n    79→// doPushSessionsBranch pushes the sessions branch to the remote.\\n    80→func doPushSessionsBranch(ctx context.Context, remote, branchName string) error {\\n    81→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Pushing session logs to %s...\\\\n\\\", remote)\\n    82→\\n    83→\\t// Try pushing first\\n    84→\\tif err := tryPushSessionsCommon(ctx, remote, branchName); err == nil {\\n    85→\\t\\treturn nil\\n    86→\\t}\\n    87→\\n    88→\\t// Push failed - likely non-fast-forward. Try to fetch and merge.\\n    89→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Syncing with remote session logs...\\\\n\\\")\\n    90→\\n    91→\\tif err := fetchAndMergeSessionsCommon(ctx, remote, branchName); err != nil {\\n    92→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: couldn't sync sessions: %v\\\\n\\\", err)\\n    93→\\t\\treturn nil // Don't fail the main push\\n    94→\\t}\\n    95→\\n    96→\\t// Try pushing again after merge\\n    97→\\tif err := tryPushSessionsCommon(ctx, remote, branchName); err != nil {\\n    98→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to push sessions after sync: %v\\\\n\\\", err)\\n    99→\\t}\\n   100→\\n   101→\\treturn nil\\n   102→}\\n   103→\\n   104→// tryPushSessionsCommon attempts to push the sessions branch.\\n   105→func tryPushSessionsCommon(ctx context.Context, remote, branchName string) error {\\n   106→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   107→\\tdefer cancel()\\n   108→\\n   109→\\t// Use --no-verify to prevent recursive hook calls\\n   110→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"push\\\", \\\"--no-verify\\\", remote, branchName)\\n   111→\\tcmd.Stdin = nil // Disconnect stdin to prevent hanging in hook context\\n   112→\\n   113→\\toutput, err := cmd.CombinedOutput()\\n   114→\\tif err != nil {\\n   115→\\t\\t// Check if it's a non-fast-forward error (we can try to recover)\\n   116→\\t\\tif strings.Contains(string(output), \\\"non-fast-forward\\\") ||\\n   117→\\t\\t\\tstrings.Contains(string(output), \\\"rejected\\\") {\\n   118→\\t\\t\\treturn errors.New(\\\"non-fast-forward\\\")\\n   119→\\t\\t}\\n   120→\\t\\treturn fmt.Errorf(\\\"push failed: %s\\\", output)\\n   121→\\t}\\n   122→\\treturn nil\\n   123→}\\n   124→\\n   125→// fetchAndMergeSessionsCommon fetches remote sessions and merges into local using go-git.\\n   126→// Since session logs are append-only (unique cond-* directories), we just combine trees.\\n   127→func fetchAndMergeSessionsCommon(ctx context.Context, remote, branchName string) error {\\n   128→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   129→\\tdefer cancel()\\n   130→\\n   131→\\t// Use git CLI for fetch (go-git's fetch can be tricky with auth)\\n   132→\\tfetchCmd := exec.CommandContext(ctx, \\\"git\\\", \\\"fetch\\\", remote, branchName)\\n   133→\\tfetchCmd.Stdin = nil\\n   134→\\tif output, err := fetchCmd.CombinedOutput(); err != nil {\\n   135→\\t\\treturn fmt.Errorf(\\\"fetch failed: %s\\\", output)\\n   136→\\t}\\n   137→\\n   138→\\trepo, err := OpenRepository(ctx)\\n   139→\\tif err != nil {\\n   140→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   141→\\t}\\n   142→\\n   143→\\t// Get local branch\\n   144→\\tlocalRef, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   145→\\tif err != nil {\\n   146→\\t\\treturn fmt.Errorf(\\\"failed to get local ref: %w\\\", err)\\n   147→\\t}\\n   148→\\tlocalCommit, err := repo.CommitObject(localRef.Hash())\\n   149→\\tif err != nil {\\n   150→\\t\\treturn fmt.Errorf(\\\"failed to get local commit: %w\\\", err)\\n   151→\\t}\\n   152→\\tlocalTree, err := localCommit.Tree()\\n   153→\\tif err != nil {\\n   154→\\t\\treturn fmt.Errorf(\\\"failed to get local tree: %w\\\", err)\\n   155→\\t}\\n   156→\\n   157→\\t// Get remote (FETCH_HEAD)\\n   158→\\tfetchHeadRef, err := repo.Reference(plumbing.ReferenceName(\\\"FETCH_HEAD\\\"), true)\\n   159→\\tif err != nil {\\n   160→\\t\\treturn fmt.Errorf(\\\"failed to get FETCH_HEAD: %w\\\", err)\\n   161→\\t}\\n   162→\\tremoteCommit, err := repo.CommitObject(fetchHeadRef.Hash())\\n   163→\\tif err != nil {\\n   164→\\t\\treturn fmt.Errorf(\\\"failed to get remote commit: %w\\\", err)\\n   165→\\t}\\n   166→\\tremoteTree, err := remoteCommit.Tree()\\n   167→\\tif err != nil {\\n   168→\\t\\treturn fmt.Errorf(\\\"failed to get remote tree: %w\\\", err)\\n   169→\\t}\\n   170→\\n   171→\\t// Flatten both trees and combine entries\\n   172→\\t// Session logs have unique cond-* directories, so no conflicts expected\\n   173→\\tentries := make(map[string]object.TreeEntry)\\n   174→\\tif err := checkpoint.FlattenTree(repo, localTree, \\\"\\\", entries); err != nil {\\n   175→\\t\\treturn fmt.Errorf(\\\"failed to flatten local tree: %w\\\", err)\\n   176→\\t}\\n   177→\\tif err := checkpoint.FlattenTree(repo, remoteTree, \\\"\\\", entries); err != nil {\\n   178→\\t\\treturn fmt.Errorf(\\\"failed to flatten remote tree: %w\\\", err)\\n   179→\\t}\\n   180→\\n   181→\\t// Build merged tree\\n   182→\\tmergedTreeHash, err := checkpoint.BuildTreeFromEntries(repo, entries)\\n   183→\\tif err != nil {\\n   184→\\t\\treturn fmt.Errorf(\\\"failed to build merged tree: %w\\\", err)\\n   185→\\t}\\n   186→\\n   187→\\t// Create merge commit with both parents\\n   188→\\tmergeCommitHash, err := createMergeCommitCommon(repo, mergedTreeHash,\\n   189→\\t\\t[]plumbing.Hash{localRef.Hash(), fetchHeadRef.Hash()},\\n   190→\\t\\t\\\"Merge remote session logs\\\")\\n   191→\\tif err != nil {\\n   192→\\t\\treturn fmt.Errorf(\\\"failed to create merge commit: %w\\\", err)\\n   193→\\t}\\n   194→\\n   195→\\t// Update branch ref\\n   196→\\tnewRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(branchName), mergeCommitHash)\\n   197→\\tif err := repo.Storer.SetReference(newRef); err != nil {\\n   198→\\t\\treturn fmt.Errorf(\\\"failed to update branch ref: %w\\\", err)\\n   199→\\t}\\n   200→\\n   201→\\treturn nil\\n   202→}\\n   203→\\n   204→// createMergeCommitCommon creates a merge commit with multiple parents.\\n   205→func createMergeCommitCo