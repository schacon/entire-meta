t index, falling back to filename check\\\",\\n   201→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   202→\\t\\t)\\n   203→\\t\\treturn hasOverlappingFiles(stagedFiles, filesTouched)\\n   204→\\t}\\n   205→\\n   206→\\t// Build a map of index entries for O(1) lookup (avoid O(n*m) nested loop)\\n   207→\\tindexEntries := make(map[string]plumbing.Hash, len(idx.Entries))\\n   208→\\tfor _, entry := range idx.Entries {\\n   209→\\t\\tindexEntries[entry.Name] = entry.Hash\\n   210→\\t}\\n   211→\\n   212→\\t// Check each staged file\\n   213→\\tfor _, stagedPath := range stagedFiles {\\n   214→\\t\\tif !touchedSet[stagedPath] {\\n   215→\\t\\t\\tcontinue // Not in filesTouched, skip\\n   216→\\t\\t}\\n   217→\\n   218→\\t\\t// Check if this is a modified file (exists in HEAD) or new file\\n   219→\\t\\t_, headErr := headTree.File(stagedPath)\\n   220→\\t\\tisModified := headErr == nil\\n   221→\\n   222→\\t\\t// Modified files always count as overlap (user edited session's work)\\n   223→\\t\\tif isModified {\\n   224→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: modified file counts as overlap\\\",\\n   225→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   226→\\t\\t\\t)\\n   227→\\t\\t\\treturn true\\n   228→\\t\\t}\\n   229→\\n   230→\\t\\t// For new files, check content against shadow branch\\n   231→\\t\\tstagedHash, found := indexEntries[stagedPath]\\n   232→\\t\\tif !found {\\n   233→\\t\\t\\tcontinue // Not in index (shouldn't happen but be safe)\\n   234→\\t\\t}\\n   235→\\n   236→\\t\\t// Get file from shadow branch tree\\n   237→\\t\\tshadowFile, err := shadowTree.File(stagedPath)\\n   238→\\t\\tif err != nil {\\n   239→\\t\\t\\t// File not in shadow branch - can't verify content overlap.\\n   240→\\t\\t\\t// Don't assume overlap just because it's in filesTouched.\\n   241→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: file not in shadow tree, skipping\\\",\\n   242→\\t\\t\\t\\tslog.String(\\\"file\\\", stage