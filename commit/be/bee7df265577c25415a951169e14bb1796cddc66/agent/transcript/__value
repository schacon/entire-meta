97→\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n   798→\\t\\t)\\n   799→\\t}\\n   800→}\\n   801→\\n   802→// postCommitUpdateBaseCommitOnly updates BaseCommit for all sessions on the current\\n   803→// worktree when a commit has no Entire-Checkpoint trailer. This prevents BaseCommit\\n   804→// from going stale, which would cause future PrepareCommitMsg calls to skip the\\n   805→// session (BaseCommit != currentHeadHash filter).\\n   806→//\\n   807→// Unlike the full PostCommit flow, this does NOT fire EventGitCommit or trigger\\n   808→// condensation — it only keeps BaseCommit in sync with HEAD.\\n   809→func (s *ManualCommitStrategy) postCommitUpdateBaseCommitOnly(logCtx context.Context, head *plumbing.Reference) {\\n   810→\\tworktreePath, err := GetWorktreePath()\\n   811→\\tif err != nil {\\n   812→\\t\\treturn // Silent failure — hooks must be resilient\\n   813→\\t}\\n   814→\\n   815→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   816→\\tif err != nil || len(sessions) == 0 {\\n   817→\\t\\treturn\\n   818→\\t}\\n   819→\\n   820→\\tnewHead := head.Hash().String()\\n   821→\\tfor _, state := range sessions {\\n   822→\\t\\t// Only update active sessions. Idle/ended sessions are kept around for\\n   823→\\t\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n   824→\\t\\tif !state.Phase.IsActive() {\\n   825→\\t\\t\\tcontinue\\n   826→\\t\\t}\\n   827→\\t\\tif state.BaseCommit != newHead {\\n   828→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit (no trailer): updating BaseCommit\\\",\\n   829→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   830→\\t\\t\\t\\tslog.String(\\\"old_base\\\", truncateHash(state.BaseCommit)),\\n   831→\\t\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n   832→\\t\\t\\t)\\n   833→\\t\\t\\tstate.BaseCommit = newHead\\n   834→\\t\\t\\tif err := s.saveSessionState(state); err != nil {\\n   835→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to update session state: %v\\\\n\\\", err)\\n   836→\\t\\t\\t}\\n   837→\\t\\t}\\n   838→\\t}\\n   839→}\\n   840→\\n   841→// truncateHash safely truncates a git hash to 7 chars for logging.\\n   842→func truncateHash(h string) string {\\n   843→\\tif len(h) > 7 {\\n   844→\\t\\treturn h[:7]\\n   845→\\t}\\n   846→\\treturn h\\n   847→}\\n   848→\\n   849→// filterSessionsWithNewContent returns sessions that have new transcript content\\n   850→// beyond what was already condensed.\\n   851→func (s *ManualCommitStrategy) filterSessionsWithNewContent(repo *git.Repository, sessions []*SessionState) []*SessionState {\\n   852→\\tvar result []*SessionState\\n   853→\\n   854→\\tfor _, state := range sessions {\\n   855→\\t\\thasNew, err := s.sessionHasNewContent(repo, state)\\n   856→\\t\\tif err != nil {\\n   857→\\t\\t\\t// On error, include the session (fail open for hooks)\\n   858→\\t\\t\\tresult = append(result, state)\\n   859→\\t\\t\\tcontinue\\n   860→\\t\\t}\\n   861→\\t\\tif hasNew {\\n   862→\\t\\t\\tresult = append(result, state)\\n   863→\\t\\t}\\n   864→\\t}\\n   865→\\n   866→\\treturn result\\n   867→}\\n   868→\\n   869→// sessionHasNewContent checks if a session has new transcript content\\n   870→// beyond what was already condensed.\\n   871→func (s *ManualCommitStrategy) sessionHasNewContent(repo *git.Repository, state *SessionState) (bool, error) {\\n   872→\\t// Get shadow branch\\n   873→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   874→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   875→\\tref, err := repo.Reference(refName, true)\\n   876→\\tif err != nil {\\n   877→\\t\\t// No shadow branch means no Stop has happened since the last condensation.\\n   878→\\t\\t// However, the agent may have done work (including commits) without a Stop.\\n   879→\\t\\t// Check the live transcript to detect this scenario.\\n   880→\\t\\treturn s.sessionHasNewContentFromLiveTranscript(repo, state)\\n   881→\\t}\\n   882→\\n   883→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   884→\\tif err != nil {\\n   885→\\t\\treturn false, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   886→\\t}\\n   887→\\n   888→\\ttree, err := commit.Tree()\\n   889→\\tif err != nil {\\n   890→\\t\\treturn false, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   891→\\t}\\n   892→\\n   893→\\t// Look for transcript file\\n   894→\\tmetadataDir := paths.EntireMetadataDir + \\\"/\\\" + state.SessionID\\n   895→\\tvar transcriptLines int\\n   896→\\tvar hasTranscriptFile bool\\n   897→\\n   898→\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   899→\\t\\thasTranscriptFile = true\\n   900→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   901→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n   902→\\t\\t}\\n   903→\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   904→\\t\\thasTranscriptFile = true\\n   905→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   906→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n   907→\\t\\t}\\n   908→\\t}\\n   909→\\n   910→\\t// If shadow branch exists but has no transcript (e.g., carry-forward from mid-session commit),\\n   911→\\t// check if the session has FilesTouched. Carry-forward sets FilesTouched with remaining files.\\n   912→\\tif !hasTranscriptFile {\\n   913→\\t\\tif len(state.FilesTouched) > 0 {\\n   914→\\t\\t\\t// Shadow branch has files from carry-forward - check if staged files overlap\\n   915→\\t\\t\\t// AND have matching content (content-aware check).\\n   916→\\t\\t\\tstagedFiles := getStagedFiles(repo)\\n   917→\\t\\t\\tif len(stagedFiles) > 0 {\\n   918→\\t\\t\\t\\t// PrepareCommitMsg context: check staged files overlap with content\\n   919→\\t\\t\\t\\tresult := stagedFilesOverlapWithContent(repo, tree, stagedFiles, state.FilesTouched)\\n   920→\\t\\t\\t\\treturn result, nil\\n   921→\\t\\t\\t}\\n   922→\\t\\t\\t// PostCommit context: no staged files, but we have carry-forward files.\\n   923→\\t\\t\\t// Return true and let the caller do the overlap check with committed files.\\n   924→\\t\\t\\treturn true, nil\\n   925→\\t\\t}\\n   926→\\t\\t// No transcript and no FilesTouched - fall back to live transcript check\\n   927→\\t\\treturn s.sessionHasNewContentFromLiveTranscript(repo, state)\\n   928→\\t}\\n   929→\\n   930→\\t// Check if there's new content to condense. Two cases:\\n   931→\\t// 1. Transcript has grown since last condensation (new prompts/responses)\\n   932→\\t// 2. FilesTouched has files not yet committed (carry-forward scenario)\\n   933→\\t//\\n   934→\\t// For PrepareCommitMsg context, we verify staged files overlap with session's files\\n   935→\\t// using content-aware matching to detect reverted files.\\n   936→\\t// For PostCommit context, getStagedFiles() is empty (files already committed),\\n   937→\\t// so we return true and let the caller do the overlap check via filesOverlapWithContent.\\n   938→\\n   939→\\thasTranscriptGrowth := transcriptLines > state.CheckpointTranscriptStart\\n   940→\\thasUncommittedFiles := len(state.FilesTouched) > 0\\n   941→\\n   942→\\tif !hasTranscriptGrowth && !hasUncommittedFiles {\\n   943→\\t\\treturn false, nil // No new content and no carry-forward files\\n   944→\\t}\\n   945→\\n   946→\\t// Check if staged files overlap with session's files with content-aware matching.\\n   947→\\t// This is primarily for PrepareCommitMsg; in PostCommit, stagedFiles is empty.\\n   948→\\tstagedFiles := getStagedFiles(repo)\\n   949→\\tif len(stagedFiles) > 0 {\\n   950→\\t\\treturn stagedFilesOverlapWithContent(repo, tree, stagedFiles, state.FilesTouched), nil\\n   951→\\t}\\n   952→\\n   953→\\t// No staged files - either PostCommit context or edge case.\\n   954→\\t// Return transcript growth status. For PostCommit with hasTranscriptFile=true,\\n   955→\\t// if there's no transcript growth, the session hasn't done new work since last checkpoint.\\n   956→\\t// (Carry-forward creates a shadow branch WITHOUT transcript, handled in the block above.)\\n   957→\\treturn hasTranscriptGrowth, nil\\n   958→}\\n   959→\\n   960→// sessionHasNewContentFromLiveTranscript checks if a session has new content\\n   961→// by examining the live transcript file. This is used when no shadow branch exists\\n   962→// (i.e., no Stop has happened yet) but the agent may have done work.\\n   963→//\\n   964→// Returns true if:\\n   965→//  1. The transcript has grown since the last condensation, AND\\n   966→//  2. The new transcript portion contains file modifications, AND\\n   967→//  3. At least one modified file overlaps with the currently staged files\\n   968→//\\n   969→// The overlap check ensures we don't add checkpoint trailers to commits that are\\n   970→// unrelated to the agent's recent changes.\\n   971→//\\n   972→// This handles the scenario where the agent commits mid-session before Stop.\\n   973→func (s *ManualCommitStrategy) sessionHasNewContentFromLiveTranscript(repo *git.Repository, state *SessionState) (bool, error) {\\n   974→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   975→\\n   976→\\tmodifiedFiles, ok := s.extractNewModifiedFilesFromLiveTranscript(state)\\n   977→\\tif !ok || len(modifiedFiles) == 0 {\\n   978→\\t\\treturn false, nil\\n   979→\\t}\\n   980→\\n   981→\\tlogging.Debug(logCtx, \\\"live transcript check: found file modifications\\\",\\n   982→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   983→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n   984→\\t)\\n   985→\\n   986→\\t// Check if any modified files overlap with currently staged files\\n   987→\\t// This ensures we only add checkpoint trailers to commits that include\\n   988→\\t// files the agent actually