\\n   283→\\t\\t\\tcontinue\\n   284→\\t\\t}\\n   285→\\t\\tstagedBytes, readErr := io.ReadAll(stagedReader)\\n   286→\\t\\t_ = stagedReader.Close() // Best effort close\\n   287→\\t\\tif readErr != nil {\\n   288→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to read staged content\\\",\\n   289→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   290→\\t\\t\\t\\tslog.String(\\\"error\\\", readErr.Error()),\\n   291→\\t\\t\\t)\\n   292→\\t\\t\\tcontinue\\n   293→\\t\\t}\\n   294→\\t\\tstagedContent := string(stagedBytes)\\n   295→\\n   296→\\t\\t// Check for significant content overlap\\n   297→\\t\\tif hasSignificantContentOverlap(stagedContent, shadowContent) {\\n   298→\\t\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: new file has partial overlap (partial staging)\\\",\\n   299→\\t\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   300→\\t\\t\\t)\\n   301→\\t\\t\\treturn true\\n   302→\\t\\t}\\n   303→\\n   304→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: new file has no significant overlap (reverted & replaced)\\\",\\n   305→\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   306→\\t\\t\\tslog.String(\\\"staged_hash\\\", stagedHash.String()),\\n   307→\\t\\t\\tslog.String(\\\"shadow_hash\\\", shadowFile.Hash.String()),\\n   308→\\t\\t)\\n   309→\\t}\\n   310→\\n   311→\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: no overlapping files found\\\",\\n   312→\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n   313→\\t\\tslog.Int(\\\"files_touched\\\", len(filesTouched)),\\n   314→\\t)\\n   315→\\treturn false\\n   316→}\\n   317→\\n   318→// hasOverlappingFiles checks if any file in stagedFiles appears in filesTouched.\\n   319→// This is a fallback when content-aware comparison isn't possible.\\n   320→func hasOverlappingFiles(stagedFiles, filesTouched []string) bool {\\n   321→\\ttouchedSet := make(map[string]bool)\\n   322→\\tfor _, f := range filesTouched {\\n   323→\\t\\ttouchedSet[f] = true\\n   324→\\t}\\n   325→\\n   326→\\tfor _, staged := range stagedFiles {\\n   327→\\t\\tif touchedSet[staged] {\\n   328→\\t\\t\\treturn true\\n   329→\\t\\t}\\n   330→\\t}\\n   331→\\treturn false\\n   332→}\\n   333→\\n   334→// filesWithRemainingAgentChanges returns files from filesTouched that still have\\n   335→// uncommitted agent changes. This is used for carry-forward after partial commits.\\n   336→//\\n   337→// A file has remaining agent changes if:\\n   338→//   - It wasn't committed at all (not in committedFiles), OR\\n   339→//   - It was committed but the committed content doesn't match the shadow branch\\n   340→//     (user committed partial changes, e.g., via git add -p)\\n   341→//\\n   342→// Falls back to file-level subtraction if shadow branch is unavailable.\\n   343→func filesWithRemainingAgentChanges(\\n   344→\\trepo *git.Repository,\\n   345→\\tshadowBranchName string,\\n   346→\\theadCommit *object.Commit,\\n   347→\\tfilesTouched []string,\\n   348→\\tcommittedFiles map[string]struct{},\\n   349→) []string {\\n   350→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   351→\\n   352→\\t// Get HEAD commit tree (the committed content)\\n   353→\\tcommitTree, err := headCommit.Tree()\\n   354→\\tif err != nil {\\n   355→\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: failed to get commit tree, falling back to file subtraction\\\",\\n   356→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   357→\\t\\t)\\n   358→\\t\\treturn subtractFilesByName(filesTouched, committedFiles)\\n   359→\\t}\\n   360→\\n   361→\\t// Get shadow branch tree (the session's full content)\\n   362→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   363→\\tshadowRef, err := repo.Reference(refName, true)\\n   364→\\tif err != nil {\\n   365→\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: shadow branch not found, falling back to file subtraction\\\",\\n   366→\\t\\t\\tslog.String(\\\"branch\\\", shadowBranchName),\\n   367→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   368→\\t\\t)\\n   369→\\t\\treturn subtractFilesByName(filesTouched, committedFiles)\\n   370→\\t}\\n   371→\\n   372→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   373→\\tif err != nil {\\n   374→\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: failed to get shadow commit, falling back to file subtraction\\\",\\n   375→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   376→\\t\\t)\\n   377→\\t\\treturn subtractFilesByName(filesTouched, committedFiles)\\n   378→\\t}\\n   379→\\n   380→\\tshadowTree, err := shadowCommit.Tree()\\n   381→\\tif err != nil {\\n   382→\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: failed to get shadow tree, falling back to file subtraction\\\",\\n   383→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   384→\\t\\t)\\n   385→\\t\\treturn subtractFilesByName(filesTouched, committedFiles)\\n   386→\\t}\\n   387→\\n   388→\\tvar remaining []string\\n   389→\\n   390→\\tfor _, filePath := range filesTouched {\\n   391→\\t\\t// If file wasn't committed at all, it definitely has remaining changes\\n   392→\\t\\tif _, wasCommitted := committedFiles[filePath]; !wasCommitted {\\n   393→\\t\\t\\tremaining = append(remaining, filePath)\\n   394→\\t\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: file not committed, keeping\\\",\\n   395→\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   396→\\t\\t\\t)\\n   397→\\t\\t\\tcontinue\\n   398→\\t\\t}\\n   399→\\n   400→\\t\\t// File was committed - check if committed content matches shadow branch\\n   401→\\t\\tshadowFile, err := shadowTree.File(filePath)\\n   402→\\t\\tif err != nil {\\n   403→\\t\\t\\t// File not in shadow branch - nothing to carry forward for this file\\n   404→\\t\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: file not in shadow branch, skipping\\\",\\n   405→\\t\\t\\t\\tslog.String(\\\"file