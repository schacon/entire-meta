1023→\\t\\treturn nil, false\\n  1024→\\t}\\n  1025→\\n  1026→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1027→\\tif err != nil {\\n  1028→\\t\\treturn nil, false\\n  1029→\\t}\\n  1030→\\n  1031→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1032→\\tif !ok {\\n  1033→\\t\\treturn nil, false\\n  1034→\\t}\\n  1035→\\n  1036→\\t// Check if transcript has grown since last condensation\\n  1037→\\tcurrentPos, err := analyzer.GetTranscriptPosition(state.TranscriptPath)\\n  1038→\\tif err != nil {\\n  1039→\\t\\treturn nil, false\\n  1040→\\t}\\n  1041→\\tif currentPos <= state.CheckpointTranscriptStart {\\n  1042→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no new content\\\",\\n  1043→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1044→\\t\\t\\tslog.Int(\\\"current_pos\\\", currentPos),\\n  1045→\\t\\t\\tslog.Int(\\\"start_offset\\\", state.CheckpointTranscriptStart),\\n  1046→\\t\\t)\\n  1047→\\t\\treturn nil, true // No new content, but extraction succeeded\\n  1048→\\t}\\n  1049→\\n  1050→\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart), true\\n  1051→}\\n  1052→\\n  1053→// extractModifiedFilesFromLiveTranscript extracts modified files from the live transcript\\n  1054→// (including subagent transcripts) starting from the given offset, and normalizes them\\n  1055→// to repo-relative paths. Returns the normalized file list.\\n  1056→func (s *ManualCommitStrategy) extractModifiedFilesFromLiveTranscript(state *SessionState, offset int) []string {\\n  1057→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1058→\\n  1059→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1060→\\t\\treturn nil\\n  1061→\\t}\\n  1062→\\n  1063→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1064→\\tif err != nil {\\n  1065→\\t\\treturn nil\\n  1066→\\t}\\n  1067→\\n  1068→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1069→\\tif !ok {\\n  1070→\\t\\treturn nil\\n  1071→\\t}\\n  1072→\\n  1073→\\tvar modifiedFiles []string\\n  1074→\\n  1075→\\t// For Claude Code, use ExtractAllModifiedFiles which parses the main transcript\\n  1076→\\t// AND subagent transcripts in a single pass, avoiding redundant parsing.\\n  1077→\\tif state.AgentType == agent.AgentTypeClaudeCode {\\n  1078→\\t\\tsubagentsDir := filepath.Join(filepath.Dir(state.TranscriptPath), state.SessionID, \\\"subagents\\\")\\n  1079→\\t\\tallFiles, extractErr := claudecode.ExtractAllModifiedFiles(state.TranscriptPath, offset, subagentsDir)\\n  1080→\\t\\tif extractErr != nil {\\n  1081→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: extraction failed\\\",\\n  1082→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1083→\\t\\t\\t\\tslog.String(\\\"error\\\", extractErr.Error()),\\n  1084→\\t\\t\\t)\\n  1085→\\t\\t} else {\\n  1086→\\t\\t\\tmodifiedFiles = allFiles\\n  1087→\\t\\t}\\n  1088→\\t} else {\\n  1089→\\t\\tfiles, _, err := analyzer.ExtractModifiedFilesFromOffset(state.TranscriptPath, offset)\\n  1090→\\t\\tif err != nil {\\n  1091→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: main transcript extraction failed\\\",\\n  1092→\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1093→\\t\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1094→\\t\\t\\t)\\n  1095→\\t\\t} else {\\n  1096→\\t\\t\\tmodifiedFiles = files\\n  1097→\\t\\t}\\n  1098→\\t}\\n  1099→\\n  1100→\\tif len(modifiedFiles) == 0 {\\n  1101→\\t\\treturn nil\\n  1102→\\t}\\n  1103→\\n  1104→\\t// Normalize to repo-relative paths.\\n  1105→\\t// Transcript tool_use entries contain absolute paths (e.g., /Users/alex/project/src/main.go)\\n  1106→\\t// but getStagedFiles/committedFiles use repo-relative paths (e.g., src/main.go).\\n  1107→\\tbasePath := state.WorktreePath\\n  1108→\\tif basePath == \\\"\\\" {\\n  1109→\\t\\tif wp, wpErr := GetWorktreePath(); wpErr == nil {\\n  1110→\\t\\t\\tbasePath = wp\\n  1111→\\t\\t}\\n  1112→\\t}\\n  1113→\\tif basePath != \\\"\\\" {\\n  1114→\\t\\tnormalized := make([]string, 0, len(modifiedFiles))\\n  1115→\\t\\tfor _, f := range modifiedFiles {\\n  1116→\\t\\t\\tif rel := paths.ToRelativePath(f, basePath); rel != \\\"\\\" {\\n  1117→\\t\\t\\t\\tnormalized = append(normalized, rel)\\n  1118→\\t\\t\\t} else {\\n  1119→\\t\\t\\t\\tnormalized = append(normalized, f)\\n  1120→\\t\\t\\t}\\n  1121→\\t\\t}\\n  1122→\\t\\tmodifiedFiles = normalized\\n  1123→\\t}\\n  1124→\\n  1125→\\treturn modifiedFiles\\n  1126→}\\n  1127→\\n  1128→// addTrailerForAgentCommit handles the fast path when an agent is committing\\n  1129→// (ACTIVE session + no TTY). Generates a checkpoint ID and adds the trailer\\n  1130→// directly, bypassing content detection and interactive prompts.\\n  1131→func (s *ManualCommitStrategy) addTrailerForAgentCommit(logCtx context.Context, commitMsgFile string, state *SessionState, source string) error {\\n  1132→\\tcpID, err := id.Generate()\\n  1133→\\tif err != nil {\\n  1134→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1135→\\t}\\n  1136→\\n  1137→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n  1138→\\tif err != nil {\\n  1139→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1140→\\t}\\n  1141→\\n  1142→\\tmessage := string(content)\\n  1143→\\n  1144→\\t// Don't add if trailer already exists\\n  1145→\\tif _, found := trailers.ParseCheckpoint(message); found {\\n  1146→\\t\\treturn nil\\n  1147→\\t}\\n  1148→\\n  1149→\\tmessage = addCheckpointTrailer(message, cpID)\\n  1150→\\n  1151→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: agent commit trailer added\\\",\\n  1152→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n  1153→\\t\\tslog.String(\\\"source\\\", source),\\n  1154→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n  1155→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1156→\\t)\\n  1157→\\n  1158→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n  1159→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1160→\\t}\\n  1161→\\treturn nil\\n  1162→}\\n  1163→\\n  1164→// addCheckpointTrailer adds the Entire-Checkpoint trailer to a commit message.\\n  1165→// Handles proper trailer formatting (blank line before trailers if needed).\\n  1166→func addCheckpointTrailer(message string, checkpointID id.CheckpointID) string {\\n  1167→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1168→\\n  1169→\\t// If message already ends with trailers (lines starting with key:), just append\\n  1170→\\t// Otherwise, add a blank line first\\n  1171→\\tlines := strings.Split(strings.TrimRight(message, \\\"\\\\n\\\"), \\\"\\\\n\\\")\\n  1172→\\n  1173→\\t// Check if the message already ends with a trailer paragraph.\\n  1174→\\t// Git trailers must be in a separate paragraph (preceded by a blank line).\\n  1175→\\t// A single-paragraph message (e.g., just a subject line) cannot have trailers,\\n  1176→\\t// even if the subject contains \\\": \\\" (like conventional commits: \\\"docs: Add foo\\\").\\n  1177→\\t//\\n  1178→\\t// Scan from the bottom: find the last paragraph of non-comment content,\\n  1179→\\t// then check if it looks like trailers AND has a blank line above it.\\n  1180→\\thasTrailers := false\\n  1181→\\ti := len(lines) - 1\\n  1182→\\n  1183→\\t// Skip trailing comment lines\\n  1184→\\tfor i >= 0 && strings.HasPrefix(strings.TrimSpace(lines[i]), \\\"#\\\") {\\n  1185→\\t\\ti--\\n  1186→\\t}\\n  1187→\\n  1188→\\t// Check if the last non-comment line looks like a trailer\\n  1189→\\tif i >= 0 {\\n  1190→\\t\\tline := strings.TrimSpace(lines[i])\\n  1191→\\t\\tif line != \\\"\\\" && strings.Contains(line, \\\": \\\") {\\n  1192→\\t\\t\\t// Found a trailer-like line. Now scan upward past the trailer block\\n  1193→\\t\\t\\t// to verify there's a blank line (paragraph separator) above it.\\n  1194→\\t\\t\\tfor i > 0 {\\n  1195→\\t\\t\\t\\ti--\\n  1196→\\t\\t\\t\\tabove := strings.TrimSpace(lines[i])\\n  1197→\\t\\t\\t\\tif strings.HasPrefix(above, \\\"#\\\") {\\n  1198→\\t\\t\\t\\t\\tcontinue\\n  1199→\\t\\t\\t\\t}\\n  1200→\\t\\t\\t\\tif above == \\\"\\\" {\\n  1201→\\t\\t\\t\\t\\t// Blank line found above trailer block — real trailers\\n  1202→\\t\\t\\t\\t\\thasTrailers = true\\n  1203→\\t\\t\\t\\t\\tbreak\\n  1204→\\t\\t\\t\\t}\\n  1205→\\t\\t\\t\\tif !strings.Contains(above, \\\": \\\") {\\n  1206→\\t\\t\\t\\t\\t// Non-trailer, non-blank line — this is message body, not trailers\\n  1207→\\t\\t\\t\\t\\tbreak\\n  1208→\\t\\t\\t\\t}\\n  1209→\\t\\t\\t\\t// Another trailer-like line, keep scanning upward\\n  1210→\\t\\t\\t}\\n  1211→\\t\\t}\\n  1212→\\t}\\n  1213→\\n  1214→\\tif hasTrailers {\\n  1215→\\t\\t// Append trailer directly\\n  1216→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1217→\\t}\\n  1218→\\n  1219→\\t// Add blank line before trailer\\n  1220→\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1221→}\\n  1222→\\n  1223→// addCheckpointTrailerWithComment adds the Entire-Checkpoint trailer with an explanatory comment.\\n  1224→// The trailer is placed above the git comment block but below the user's message area,\\n  1225→// with a comment explaining that the user can remove it if they don't want to link the commit\\n  1226→// to the agent session. If prompt is non-empty, it's shown as context.\\n  1227→func addCheckpointTrailerWithComment(message string, checkpointID id.CheckpointID, agentName, prompt string) string {\\n  1228→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1229→\\tcommentLines := []string{\\n  1230→\\t\\t\\\"# Remove the Entire-Checkpoint trailer above if you don't want to link this commit to \\\" + agentName + \\\" session context.\\\",\\n  1231→\\t}\\n  1232→\\tif prompt != \\\"\\\" {\\n  1233→\\t\\tcommentLines = append(commentLines, \\\"# Last Prompt: \\\"+prompt)\\n  1234→\\t}\\n  1235→\\tcommentLines = append(commentLines, \\\"# The trailer will be added to your next commit based on this branch.\\\")\\n  1236→\\tcomment := strings.Join(commentLines, \\\"\\\\n\\\")\\n  1237→\\n  1238→\\tlines := strings.Split(message, \\\"\\\\n\\\")\\n  1239→\\n  1240→\\t// Find where the git comment block starts (first # line)\\n  1241→\\tcommentStart := -1\\n  1242→\\tfor i, line := range lines {\\n  1243→\\t\\tif strings.HasPrefix(line, \\\"#\\\") {\\n  1244→\\t\\t\\tcommentStart = i\\n  1245→\\t\\t\\tbreak\\n  1246→\\t\\t}\\n  1247→\\t}\\n  1248→\\n  1249→\\tif commentStart == -1 {\\n  1250→\\t\\t// No git comments, append trailer at the end\\n  1251→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\"\\n  1252→\\t}\\n  1253→\\n  1254→\\t// Split into user content and git comments\\n  1255→\\tuserContent := strings.Join(lines[:commentStart], \\\"\\\\n\\\")\\n  1256→\\tgitComments := strings.Join(lines[commentStart:], \\\"\\\\n\\\")\\n  1257→\\n  1258→\\t// Build result: user content, blank line, trailer, comment, blank line, git comments\\n  1259→\\tuserContent = strings.TrimRight(userContent, \\\"\\\\n\\\")\\n  1260→\\tif userContent == \\\"\\\" {\\n  1261→\\t\\t// No user content yet - leave space for them to type, then trailer\\n  1262→\\t\\t// Two newlines: first for user's message line, second for blank separator\\n  1263→\\t\\treturn \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1264→\\t}\\n  1265→\\treturn userContent + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1266→}\\n  1267→\\n  1268→// InitializeSession creates session state for a new session or updates an existing one.\\n  1269→// This implements the optional SessionInitializer interface.\\n  1270→// Called during UserPromptSubmit to allow git hooks to detect active sessions.\\n  1271→//\\n  1272→// If the session already exists and HEAD has moved (e.g., user committed), updates\\n  1273→// BaseCommit to the new HEAD so future checkpoints go to the correct shadow branch.\\n  1274→//\\n  1275→// If there's an existing shadow branch with commits from a different session ID,\\n  1276→// returns a SessionIDConflictError to prevent orphaning existing session work.\\n  1277→//\\n  1278→// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n  1279→// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n  1280→// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\n  1281→func (s *ManualCommitStrategy) InitializeSession(sessionID string, agentType agent.AgentType, transcriptPath string, userPrompt string) error {\\n  1282→\\trepo, err := OpenRepository()\\n  1283→\\tif err != nil {\\n  1284→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n  1285→\\t}\\n  1286→\\n  1287→\\t// Check if session already exists\\n  1288→\\tstate, err := s.loadSessionState(sessionID)\\n  1289→\\tif err != nil {\\n  1290→\\t\\treturn fmt.Errorf(\\\"failed to check session state: %w\\\", err)\\n  1291→\\t}\\n  1292→\\n  1293→\\tif state != nil && state.BaseCommit != \\\"\\\" {\\n  1294→\\t\\t// Session is fully initialized — apply phase transition for TurnStart.\\n  1295→\\t\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1296→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1297→\\t\\t}\\n  1298→\\n  1299→\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n  1300→\\t\\tturnID, err := id.Generate()\\n  1301→\\t\\tif err != nil {\\n  1302→\\t\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n  1303→\\t\\t}\\n  1304→\\t\\tstate.TurnID = turnID.String()\\n  1305→\\n  1306→\\t\\t// Backfill AgentType if empty or set to the generic default \\\"Agent\\\"\\n  1307→\\t\\tif !isSpecificAgentType(state.AgentType) && agentType != \\\"\\\" {\\n  1308→\\t\\t\\tstate.AgentType = agentType\\n  1309→\\t\\t}\\n  1310→\\n  1311→\\t\\t// Backfill FirstPrompt if empty (for sessions created before the first_prompt field was added)\\n  1312→\\t\\tif state.FirstPrompt == \\\"\\\" && userPrompt != \\\"\\\" {\\n  1313→\\t\\t\\tstate.FirstPrompt = truncatePromptForStorage(userPrompt)\\n  1314→\\t\\t}\\n  1315→\\n  1316→\\t\\t// Update transcript path if provided (may change on session resume)\\n  1317→\\t\\tif transcriptPath != \\\"\\\" && state.TranscriptPath != transcriptPath {\\n  1318→\\t\\t\\tstate.TranscriptPath = transcriptPath\\n  1319→\\t\\t}\\n  1320→\\n  1321→\\t\\t// Clear checkpoint IDs on every new prompt.\\n  1322→\\t\\t// LastCheckpointID is set during PostCommit, cleared at new prompt.\\n  1323→\\t\\t// TurnCheckpointIDs tracks mid-turn checkpoints for stop-time finalization.\\n  1324→\\t\\tstate.LastCheckpointID = \\\"\\\"\\n  1325→\\t\\tstate.TurnCheckpointIDs = nil\\n  1326→\\n  1327→\\t\\t// Calculate attribution at prompt start (BEFORE agent makes any changes)\\n  1328→\\t\\t// This captures user edits since the last checkpoint (or base commit for first prompt).\\n  1329→\\t\\t// IMPORTANT: Always calculate attribution, even for the first checkpoint, to capture\\n  1330→\\t\\t// user edits made before the first prompt. The inner CalculatePromptAttribution handles\\n  1331→\\t\\t// nil lastCheckpointTree by falling back to baseTree.\\n  1332→\\t\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n  1333→\\t\\tstate.PendingPromptAttribution = &promptAttr\\n  1334→\\n  1335→\\t\\t// Check if HEAD has moved (user pulled/rebased or committed)\\n  1336→\\t\\t// migrateShadowBranchIfNeeded handles renaming the shadow branch and updating state.BaseCommit\\n  1337→\\t\\tif _, err := s.migrateShadowBranchIfNeeded(repo, state); err != nil {\\n  1338→\\t\\t\\treturn fmt.Errorf(\\\"failed to check/migrate shadow branch: %w\\\", err)\\n  1339→\\t\\t}\\n  1340→\\n  1341→\\t\\tif err := s.saveSessionState(state); err != nil {\\n  1342→\\t\\t\\treturn fmt.Errorf(\\\"failed to update session state: %w\\\", err)\\n  1343→\\t\\t}\\n  1344→\\t\\treturn nil\\n  1345→\\t}\\n  1346→\\t// If state exists but BaseCommit is empty, it's a partial state from concurrent warning\\n  1347→\\t// Continue below to properly initialize it\\n  1348→\\n  1349→\\t// Initialize new session\\n  1350→\\tstate, err = s.initializeSession(repo, sessionID, agentType, transcriptPath, userPrompt)\\n  1351→\\tif err != nil {\\n  1352→\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n  1353→\\t}\\n  1354→\\n  1355→\\t// Apply phase transition: new session starts as ACTIVE.\\n  1356→\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1357→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1358→\\t}\\n  1359→\\n  1360→\\t// Calculate attribution for pre-prompt edits\\n  1361→\\t// This captures any user edits made before the first prompt\\n  1362→\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n  1363→\\tstate.PendingPromptAttribution = &promptAttr\\n  1364→\\tif err = s.saveSessionState(state); err != nil {\\n  1365→\\t\\treturn fmt.Errorf(\\\"failed to save attribution: %w\\\", err)\\n  1366→\\t}\\n  1367→\\n  1368→\\tfmt.Fprintf(os.Stderr, \\\"Initialized shadow session: %s\\\\n\\\", sessionID)\\n  1369→\\treturn nil\\n  1370→}\\n  1371→\\n  1372→// calculatePromptAttributionAtStart calculates attribution at prompt start (before agent runs).\\n  1373→// This captures user changes