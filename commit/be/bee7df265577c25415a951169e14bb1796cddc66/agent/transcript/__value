ged, \\\"file2.txt\\\")\\n   881→\\t// test.txt was in the initial commit, not this one\\n   882→\\tassert.NotContains(t, changed, \\\"test.txt\\\")\\n   883→}\\n   884→\\n   885→// TestFilesChangedInCommit_InitialCommit verifies that filesChangedInCommit\\n   886→// handles the initial commit (no parent) by listing all files.\\n   887→func TestFilesChangedInCommit_InitialCommit(t *testing.T) {\\n   888→\\tdir := t.TempDir()\\n   889→\\tt.Chdir(dir)\\n   890→\\n   891→\\trepo, err := git.PlainInit(dir, false)\\n   892→\\trequire.NoError(t, err)\\n   893→\\n   894→\\tcfg, err := repo.Config()\\n   895→\\trequire.NoError(t, err)\\n   896→\\tcfg.User.Name = \\\"Test\\\"\\n   897→\\tcfg.User.Email = \\\"test@test.com\\\"\\n   898→\\trequire.NoError(t, repo.SetConfig(cfg))\\n   899→\\n   900→\\twt, err := repo.Worktree()\\n   901→\\trequire.NoError(t, err)\\n   902→\\n   903→\\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \\\"init.txt\\\"), []byte(\\\"initial\\\"), 0o644))\\n   904→\\t_, err = wt.Add(\\\"init.txt\\\")\\n   905→\\trequire.NoError(t, err)\\n   906→\\n   907→\\tcommitHash, err := wt.Commit(\\\"initial\\\", &git.CommitOptions{\\n   908→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   909→\\t})\\n   910→\\trequire.NoError(t, err)\\n   911→\\n   912→\\tcommit, err := repo.CommitObject(commitHash)\\n   913→\\trequire.NoError(t, err)\\n   914→\\n   915→\\tchanged := filesChangedInCommit(commit)\\n   916→\\tassert.Contains(t, changed, \\\"init.txt\\\")\\n   917→\\tassert.Len(t, changed, 1)\\n   918→}\\n   919→\\n   920→// TestPostCommit_ActiveSession_CarryForward_PartialCommit verifies that when an\\n   921→// ACTIVE session has touched files A, B, C but only A and B are committed, the\\n   922→// remaining file C is carried forward to a new shadow branch.\\n   923→func TestPostCommit_ActiveSession_CarryForward_PartialCommit(t *testing.T) {\\n   924→\\tdir := setupGitRepo(t)\\n   925→\\tt.Chdir(dir)\\