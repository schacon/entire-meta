  session.ID,\\n    36→\\t\\t\\\"transcript_path\\\": session.TranscriptPath,\\n    37→\\t}\\n    38→\\tinputJSON, _ := json.Marshal(input)\\n    39→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"claude-code\\\", \\\"user-prompt-submit\\\")\\n    40→\\tcmd.Dir = env.RepoDir\\n    41→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n    42→\\tcmd.Env = append(os.Environ(),\\n    43→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+env.ClaudeProjectDir,\\n    44→\\t)\\n    45→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n    46→\\t\\tt.Fatalf(\\\"user-prompt-submit failed: %v\\\\nOutput: %s\\\", err, output)\\n    47→\\t}\\n    48→\\n    49→\\t// Verify session state has transcript path\\n    50→\\tstate, err := env.GetSessionState(session.ID)\\n    51→\\tif err != nil {\\n    52→\\t\\tt.Fatalf(\\\"Failed to get session state: %v\\\", err)\\n    53→\\t}\\n    54→\\tif state == nil {\\n    55→\\t\\tt.Fatal(\\\"Session state is nil\\\")\\n    56→\\t}\\n    57→\\tif state.TranscriptPath == \\\"\\\" {\\n    58→\\t\\tt.Error(\\\"Session state should have TranscriptPath after user-prompt-submit\\\")\\n    59→\\t}\\n    60→\\tt.Logf(\\\"Session state TranscriptPath: %s\\\", state.TranscriptPath)\\n    61→\\n    62→\\t// Create a file as if Claude wrote it\\n    63→\\tenv.WriteFile(\\\"claude_file.txt\\\", \\\"content from Claude\\\")\\n    64→\\n    65→\\t// Create transcript showing Claude created the file (NO Stop called)\\n    66→\\tsession.CreateTranscript(\\\"Create a file for me\\\", []FileChange{\\n    67→\\t\\t{Path: \\\"claude_file.txt\\\", Content: \\\"content from Claude\\\"},\\n    68→\\t})\\n    69→\\n    70→\\t// Verify NO shadow branch exists (Stop hasn't been called)\\n    71→\\tshadowBranches := env.ListBranchesWithPrefix(\\\"entire/\\\")\\n    72→\\thasShadowBranch := false\\n    73→\\tfor _, b := range shadowBranches {\\n    74→\\t\\tif b != paths.MetadataBranchName {\\n    75→\\t\\t\\thasShadowBranch = true\\n    76→\\t\\t\\tbreak\\n    77→\\t\\t}\\n    78→\\t}\\n    79→\\tif hasShadowBranch {\\n    80→\\t\\tt.Error(\\\"Shadow branch should not exist before Stop is called\\\")\\n    81→\\t}\\n    82→\\n    83→\\t// Get HEAD before commit\\n    84→\\theadBefore := env.GetHeadHash()\\n    85→\\n    86→\\t// Commit with shadow hooks - should add trailer because transcript shows file modifications\\n    87→\\tenv.GitCommitWithShadowHooks(\\\"Add file from Claude (mid-session)\\\", \\\"claude_file.txt\\\")\\n    88→\\n    89→\\t// Get the commit\\n    90→\\tcommitHash := env.GetHeadHash()\\n    91→\\tif commitHash == headBefore {\\n    92→\\t\\tt.Fatal(\\\"Commit was not created\\\")\\n    93→\\t}\\n    94→\\n    95→\\t// CRITICAL: Verify commit has a checkpoint trailer\\n    96→\\t// This is the fix for ENT-112 scenario 2: detect work from live transcript\\n    97→\\tcheckpointID := env.GetCheckpointIDFromCommitMessage(commitHash)\\n    98→\\tif checkpointID == \\\"\\\" {\\n    99→\\t\\tt.Error(\\\"Mid-session commit should have Entire-Checkpoint trailer when transcript shows file modifications\\\")\\n   100→\\t} else {\\n   101→\\t\\tt.Logf(\\\"Mid-session commit has checkpoint ID: %s\\\", checkpointID)\\n   102→\\t}\\n   103→}\\n   104→\\n   105→// TestShadowStrategy_MidSessionCommit_NoTrailerWithoutTranscriptPath tests that\\n   106→// when TranscriptPath is not set in session state, commits don't get erroneous\\n   107→// checkpoint trailers (graceful fallback).\\n   108→func TestShadowStrategy_MidSessionCommit_NoTrailerWithoutTranscriptPath(t *testing.T) {\\n   109→\\tt.Parallel()\\n   110→\\n   111→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   112→\\n   113→\\tsession := env.NewSession()\\n   114→\\n   115→\\t// Simulate user prompt WITHOUT transcript path (legacy behavior)\\n   116→\\tif err := env.SimulateUserPromptSubmit(session.ID); err != nil {\\n   117→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   118→\\t}\\n   119→\\n   120→\\t// Create a file