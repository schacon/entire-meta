s.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   103→\\t} else {\\n   104→\\t\\t// Branch exists locally, check for uncommitted changes before checkout\\n   105→\\t\\thasChanges, err := HasUncommittedChanges(ctx)\\n   106→\\t\\tif err != nil {\\n   107→\\t\\t\\treturn fmt.Errorf(\\\"failed to check for uncommitted changes: %w\\\", err)\\n   108→\\t\\t}\\n   109→\\t\\tif hasChanges {\\n   110→\\t\\t\\treturn errors.New(\\\"you have uncommitted changes. Please commit or stash them first\\\")\\n   111→\\t\\t}\\n   112→\\n   113→\\t\\t// Checkout the branch\\n   114→\\t\\tif err := CheckoutBranch(ctx, branchName); err != nil {\\n   115→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n   116→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   117→\\t\\t}\\n   118→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   119→\\t}\\n   120→\\n   121→\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n   122→}\\n   123→\\n   124→func resumeFromCurrentBranch(ctx context.Context, branchName string, force bool) error {\\n   125→\\trepo, err := openRepository(ctx)\\n   126→\\tif err != nil {\\n   127→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   128→\\t}\\n   129→\\n   130→\\t// Find a commit with an Entire-Checkpoint trailer, looking at branch-only commits\\n   131→\\tresult, err := findBranchCheckpoint(repo, branchName)\\n   132→\\tif err != nil {\\n   133→\\t\\treturn err\\n   134→\\t}\\n   135→\\tif len(result.checkpointIDs) == 0 {\\n   136→\\t\\tfmt.Fprintf(os.Stderr, \\\"No Entire checkpoint found on branch '%s'\\\\n\\\", branchName)\\n   137→\\t\\treturn nil\\n   138→\\t}\\n   139→\\n   140→\\t// If there are newer commits without checkpoints, ask for confirmation.\\n   141→\\t// Merge commits (e.g., from merging main) don't count as \\\"work\\\" and are skipped silently.\\n   142→\\tif result.newerCommitsExist && !force {\\n   143→\\t\\tfmt.Fprintf(os.Stderr, \\\"Found checkpoint in an older commit.\\\\n\\\")\\n   144→\\t\\tfmt.Fprintf(os.Stderr, \\\"There are %d newer commit(s) on this branch without checkpoints.\\\\n\\\", result.newerCommitCount)\\n   145→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint from: %s %s\\\\n\\\\n\\\", result.commitHash[:7], firstLine(result.commitMessage))\\n   146→\\n   147→\\t\\tshouldResume, err := promptResumeFromOlderCheckpoint()\\n   148→\\t\\tif err != nil {\\n   149→\\t\\t\\treturn err\\n   150→\\t\\t}\\n   151→\\t\\tif !shouldResume {\\n   152→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled.\\\\n\\\")\\n   153→\\t\\t\\treturn nil\\n   154→\\t\\t}\\n   155→\\t}\\n   156→\\n   157→\\t// Multiple checkpoints (squash merge): restore all sessions\\n   158→\\tif len(result.checkpointIDs) > 1 {\\n   159→\\t\\treturn resumeMultipleCheckpoints(ctx, repo, result.checkpointIDs, force)\\n   160→\\t}\\n   161→\\n   162→\\t// Single checkpoint: existing behavior (unchanged)\\n   163→\\tcheckpointID := result.checkpointIDs[0]\\n   164→\\n   165→\\t// Get metadata branch tree for lookups\\n   166→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   167→\\tif err != nil {\\n   168→\\t\\t// No local metadata branch, check if remote has it\\n   169→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   170→\\t}\\n   171→\\n   172→\\t// Look up metadata from sharded path\\n   173→\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n   174→\\tif err != nil {\\n   175→\\t\\t// Checkpoint exists in commit but no local metadata - check remote\\n   176→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   177→\\t}\\n   178→\\n   179→\\treturn resumeSession(ctx, metadata.SessionID, checkpointID, force)\\n   180→}\\n   181→\\n   182→// resumeMultipleCheckpoints restores sessions from multiple checkpoint IDs.\\n   183→// This handles squash merge commits where multiple Entire-Checkpoint trailers\\n   184→// are present in a single commit message. Each checkpoint is looked up independently\\n   185→// and missing metadata is skipped (best-effort).\\n   186→func resumeMultipleCheckpoints(ctx context.Context, repo *git.Repository, checkpointIDs []id.CheckpointID, force bool) error {\\n   187→\\tlogCtx := logging.WithComponent(ctx, \\\"resume\\\")\\n   188→\\n   189→\\t// Get metadata branch tree (try local first, then remote)\\n   190→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   191→\\tif err != nil {\\n   192→\\t\\t// Try fetching from remote\\n   193→\\t\\tlogging.Debug(logCtx, \\\"metadata branch not available locally, trying remote\\\")\\n   194→\\t\\tif fetchErr := FetchMetadataBranch(ctx); fetchErr != nil {\\n   195→\\t\\t\\t// If fetch also fails, try remote tree directly\\n   196→\\t\\t\\tremoteTree, remoteErr := strategy.GetRemoteMetadataBranchTree(repo)\\n   197→\\t\\t\\tif remoteErr != nil {\\n   198→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint metadata not available locally or on remote\\\\n\\\")\\n   199→\\t\\t\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   200→\\t\\t\\t}\\n   201→\\t\\t\\tmetadataTree = remoteTree\\n   202→\\t\\t} else {\\n   203→\\t\\t\\tmetadataTree, err = strategy.GetMetadataBranchTree(repo)\\n   204→\\t\\t\\tif err != nil {\\n   205→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint metadata not available after fetch\\\\n\\\")\\n   206→\\t\\t\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   207→\\t\\t\\t}\\n   208→\\t\\t}\\n   209→\\t}\\n   210→\\n   211→\\tstrat := GetStrategy(ctx)\\n   212→\\tvar allSessions []strategy.RestoredSession\\n   213→\\n   214→\\tfor _, cpID := range checkpointIDs {\\n   215→\\t\\tmetadata, metaErr := strategy.ReadCheckpointMetadata(metadataTree, cpID.Path())\\n   216→\\t\\tif metaErr != nil {\\n   217→\\t\\t\\tlogging.Debug(logCtx, \\\"skipping checkpoint without metadata\\\",\\n   218→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   219→\\t\\t\\t\\tslog.String(\\\"error\\\", metaErr.Error()),\\n   220→\\t\\t\\t)\\n   221→\\t\\t\\tcontinue\\n   222→\\t\\t}\\n   223→\\n   224→\\t\\tpoint := strategy.RewindPoint{\\n   225→\\t\\t\\tIsLogsOnly:   true,\\n   226→\\t\\t\\tCheckpointID: cpID,\\n   227→\\t\\t\\tAgent:        metadata.Agent,\\n   228→\\t\\t}\\n   229→\\n   230→\\t\\tsessions, restoreErr := strat.RestoreLogsOnly(ctx, point, force)\\n   231→\\t\\tif restoreErr != nil {\\n   232→\\t\\t\\tlogging.Debug(logCtx, \\\"skipping checkpoint: restore failed\\\",\\n   233→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   234→\\t\\t\\t\\tslog.String(\\\"error\\\", restoreErr.Error()),\\n   235→\\t\\t\\t)\\n   236→\\t\\t\\tcontinue\\n   237→\\t\\t}\\n   238→\\t\\tif len(sessions) == 0 {\\n   239→\\t\\t\\tlogging.Debug(logCtx, \\\"skipping checkpoint: no sessions restored\\\",\\n   240→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   241→\\t\\t\\t)\\n   242→\\t\\t\\tcontinue\\n   243→\\t\\t}\\n   244→\\n   245→\\t\\tallSessions = deduplicateSessions(allSessions, sessions)\\n   246→\\t}\\n   247→\\n   248→\\tif len(allSessions) == 0 {\\n   249→\\t\\tfmt.Fprintf(os.Stderr, \\\"No session metadata found for checkpoints in this commit\\\\n\\\")\\n   250→\\t\\treturn nil\\n   251→\\t}\\n   252→\\n   253→\\tlogging.Debug(logCtx, \\\"resume multiple checkpoints completed\\\",\\n   254→\\t\\tslog.Int(\\\"checkpoint_count\\\", len(checkpointIDs)),\\n   255→\\t\\tslog.Int(\\\"session_count\\\", len(allSessions)),\\n   256→\\t)\\n   257→\\n   258→\\treturn displayRestoredSessions(allSessions)\\n   259→}\\n   260→\\n   261→// deduplicateSessions merges new sessions into existing, keeping the one with the latest\\n   262→// CreatedAt when a SessionID appears more than once. This handles squash merges where the\\n   263→// same session may be referenced by multiple checkpoints.\\n   264→func deduplicateSessions(existing, incoming []strategy.RestoredSession) []strategy.RestoredSession {\\n   265→\\ttype entry struct {\\n   266→\\t\\tindex     int\\n   267→\\t\\tcreatedAt time.Time\\n   268→\\t}\\n   269→\\n   270→\\tseen := make(map[string]entry, len(existing))\\n   271→\\tfor i, s := range existing {\\n   272→\\t\\tseen[s.SessionID] = entry{index: i, createdAt: s.CreatedAt}\\n   273→\\t}\\n   274→\\n   275→\\tfor _, sess := range incoming {\\n   276→\\t\\tif prev, exists := seen[sess.SessionID]; exists {\\n   277→\\t\\t\\t// Keep the one with the later CreatedAt (more complete transcript)\\n   278→\\t\\t\\tif sess.CreatedAt.After(prev.createdAt) {\\n   279→\\t\\t\\t\\texisting[prev.index] = sess\\n   280→\\t\\t\\t\\tseen[sess.SessionID] = entry{index: prev.index, createdAt: sess.CreatedAt}\\n   281→\\t\\t\\t}\\n   282→\\t\\t} else {\\n   283→\\t\\t\\tseen[sess.SessionID] = entry{index: len(existing), createdAt: sess.CreatedAt}\\n   284→\\t\\t\\texisting = append(existing, sess)\\n   285→\\t\\t}\\n   286→\\t}\\n   287→\\n   288→\\treturn existing\\n   289→}\\n   290→\\n   291→// branchCheckpointResult contains the result of searching for a checkpoint on a branch.\\n   292→type branchCheckpointResult struct {\\n   293→\\tcheckpointIDs     []id.CheckpointID\\n   294→\\tcommitHash        string\\n   295→\\tcommitMessage     string\\n   296→\\tnewerCommitsExist bool // true if there are branch-only commits (not merge commits) without checkpoints\\n   297→\\tnewerCommitCount  int  // count of branch-only commits without checkpoints\\n   298→}\\n   299→\\n   300→// findBranchCheckpoint finds the most recent commit with an Entire-Checkpoint trailer\\n   301→// among commits that are unique to this branch (not reachable from the default branch).\\n   302→// This handles the case where main has been merged into the feature branch.\\n   303→func findBranchCheckpoint(repo *git.Repository, branchName string) (*branchCheckpointResult, error) {\\n   304→\\tresult := &branchCheckpointResult{}\\n   305→\\n   306→\\t// Get HEAD commit\\n   307→\\thead, err := repo.Head()\\n   308→\\tif err != nil {\\n   309→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   310→\\t}\\n   311→\\n   312→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   313→\\tif err != nil {\\n   314→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   315→\\t}\\n   316→\\n   317→\\t// First, check if HEAD itself has a checkpoint (most common case)\\n   318→\\tif cpIDs := trailers.ParseAllCheckpoints(headCommit.Message); len(cpIDs) > 0 {\\n   319→\\t\\tresult.checkpointIDs = cpIDs\\n   320→\\t\\tresult.commitHash = head.Hash().String()\\n   321→\\t\\tresult.commitMessage = headCommit.Message\\n   322→\\t\\tresult.newerCommitsExist = false\\n   323→\\t\\treturn result, nil\\n   324→\\t}\\n   325→\\n   326→\\t// HEAD doesn't have a checkpoint - find branch-only commits\\n   327→\\t// Get the default branch name\\n   328→\\tdefaultBranch := getDefaultBranchFromRemote(repo)\\n   329→\\tif defaultBranch == \\\"\\\" {\\n   330→\\t\\t// Fallback: try common names\\n   331→\\t\\tfor _, name := range []string{\\\"main\\\", \\\"master\\\"} {\\n   332→\\t\\t\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(name), true); err == nil {\\n   333→\\t\\t\\t\\tdefaultBranch = name\\n   334→\\t\\t\\t\\tbreak\\n   335→\\t\\t\\t}\\n   336→\\t\\t}\\n   337→\\t}\\n   338→\\n   339→\\t// If we can't find a default branch, or we're on it, just walk all commits\\n   340→\\tif defaultBranch == \\\"\\\" || defaultBranch == branchName {\\n   341→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil\\n   342→\\t}\\n   343→\\n   344→\\t// Get the default branch reference\\n   345→\\tdefaultRef, err := repo.Reference(plumbing.NewBranchReferenceName(defaultBranch), true)\\n   346→\\tif err != nil {\\n   347→\\t\\t// Default branch doesn't exist locally, fall back to walking all commits\\n   348→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   349→\\t}\\n   350→\\n   351→\\tdefaultCommit, err := repo.CommitObject(defaultRef.Hash())\\n   352→\\tif err != nil {\\n   353→\\t\\t// Can't get default commit, fall back to walking all commits\\n   354→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   355→\\t}\\n   356→\\n   357→\\t// Find merge base\\n   358→\\tmergeBase, err := headCommit.MergeBase(defaultCommit)\\n   359→\\tif err != nil || len(mergeBase) == 0 {\\n   360→\\t\\t// No common ancestor, fall back to walking all commits\\n   361→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   362→\\t}\\n   363→\\n   364→\\t// Walk from HEAD to merge base, looking for checkpoint\\n   365→\\treturn findCheckpointInHistory(headCommit, &mergeBase[0].Hash), nil\\n   366→}\\n   367→\\n   368→// findCheckpointInHistory walks commit history from start looking for a checkpoint trailer.\\n   369→// If stopAt is provided, stops when reaching that commit (exclusive).\\n   370→// Returns the first checkpoint found and info about commits between HEAD and the checkpoint.\\n   371→// It distinguishes between merge commits (bringing in other branches) and regular commits\\n   372→// (actual branch work) to avoid false warnings after merging main.\\n   373→func findCheckpointInHistory(start *object.Commit, stopAt *plumbing.Hash) *branchCheckpointResult {\\n   374→\\tresult := &branchCheckpointResult{}\\n   375→\\tbranchWorkCommits := 0 // Regular commits without checkpoints (actual work)\\n   376→\\tconst maxCommits = 100 // Limit search depth\\n   377→\\ttotalChecked := 0\\n   378→\\n   379→\\tcurrent := start\\n   380→\\tfor current != nil && totalChecked < maxCommits {\\n   381→\\t\\t// Stop if we've reached the boundary\\n   382→\\t\\tif stopAt != nil && current.Hash == *stopAt {\\n   383→\\t\\t\\tbreak\\n   384→\\t\\t}\\n   385→\\n   386→\\t\\t// Check for checkpoint trailer\\n   387→\\t\\tif cpIDs := trailers.ParseAllCheckpoints(current.Message); len(cpIDs) > 0 {\\n   388→\\t\\t\\tresult.checkpointIDs = cpIDs\\n   389→\\t\\t\\tresult.commitHash = current.Hash.String()\\n   390→\\t\\t\\tresult.commitMessage = current.Message\\n   391→\\t\\t\\t// Only warn about branch work commits, not merge commits\\n   392→\\t\\t\\tresult.newerCommitsExist = branchWorkCommits > 0\\n   393→\\t\\t\\tresult.newerCommitCount = branchWorkCommits\\n   394→\\t\\t\\treturn result\\n   395→\\t\\t}\\n   396→\\n   397→\\t\\t// Only count regular commits (not merge commits) as \\\"branch work\\\"\\n   398→\\t\\tif current.NumParents() <= 1 {\\n   399→\\t\\t\\tbranchWorkCommits++\\n   400→\\t\\t}\\n   401→\\n   402→\\t\\ttotalChecked++\\n   403→\\n   404→\\t\\t// Move to parent (first parent for merge commits - follows the main line)\\n   405→\\t\\tif current.NumParents() == 0 {\\n   406→\\t\\t\\tbreak\\n   407→\\t\\t}\\n   408→\\t\\tparent, err := current.Parent(0)\\n   409→\\t\\tif err != nil {\\n   410→\\t\\t\\t// Can't get parent, treat as end of history\\n   411→\\t\\t\\tbreak\\n   412→\\t\\t}\\n   413→\\t\\tcurrent = parent\\n   414→\\t}\\n   415→\\n   416→\\t// No checkpoint found\\n   417→\\treturn result\\n   418→}\\n   419→\\n   420→// promptResumeFromOlderCheckpoint asks the user if they want to resume from an older checkpoint.\\n   421→func promptResumeFromOlderCheckpoint() (bool, error) {\\n   422→\\tvar confirmed bool\\n   423→\\n   424→\\tform := NewAccessibleForm(\\n   425→\\t\\thuh.NewGroup(\\n   426→\\t\\t\\thuh.NewConfirm().\\n   427→\\t\\t\\t\\tTitle(\\\"Resume from this older checkpoint?\\\").\\n   428→\\t\\t\\t\\tValue(&confirmed),\\n   429→\\t\\t),\\n   430→\\t)\\n   431→\\n   432→\\tif err := form.Run(); err != nil {\\n   433→\\t\\tif errors.Is(err, huh.ErrUserAborted) {\\n   434→\\t\\t\\treturn false, nil\\n   435→\\t\\t}\\n   436→\\t\\treturn false, fmt.Errorf(\\\"failed to get confirmation: %w\\\", err)\\n   437→\\t}\\n   438→\\n   439→\\treturn confirmed, nil\\n   440→}\\n   441→\\n   442→// checkRemoteMetadata checks if checkpoint metadata exists on origin/entire/checkpoints/v1\\n   443→// and automatically fetches it if available.\\n   444→func checkRemoteMetadata(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID) error {\\n   445→\\t// Try to get remote metadata branch tree\\n   446→\\tremoteTree, err := strategy.GetRemoteMetadataBranchTree(repo)\\n   447→\\tif err != nil {\\n   448→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   449→\\t\\tfmt.Fprintf(os.Stderr, \\\"The entire/checkpoints/v1 branch may not exist locally or on the remote.\\\\n\\\")\\n   450→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   451→\\t}\\n   452→\\n   453→\\t// Check if the checkpoint exists on the remote\\n   454→\\tmetadata, err := strategy.ReadCheckpointMetadata(remoteTree, checkpointID.Path())\\n   455→\\tif err != nil {\\n   456→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   457→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   458→\\t}\\n   459→\\n   460→\\t// Metadata exists on remote but not locally - fetch it automatically\\n   461→\\tfmt.Fprintf(os.Stderr, \\\"Fetching session metadata from origin...\\\\n\\\")\\n   462→\\tif err := FetchMetadataBranch(ctx); err != nil {\\n   463→\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to fetch metadata: %v\\\\n\\\", err)\\n   464→\\t\\tfmt.Fprintf(os.Stderr, \\\"You can try manually: git fetch origin entire/checkpoints/v1:entire/checkpoints/v1\\\\n\\\")\\n   465→\\t\\treturn NewSilentError(errors.New(\\\"failed to fetch metadata\\\"))\\n   466→\\t}\\n   467→\\n   468→\\t// Now resume the session with the fetched metadata\\n   469→\\treturn resumeSession(ctx, metadata.SessionID, checkpointID, false)\\n   470→}\\n   471→\\n   472→// resumeSession restores and displays the resume command for a specific session.\\n   473→// For multi-session checkpoints, restores ALL sessions and shows commands for each.\\n   474→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   475→func resumeSession(ctx context.Context, sessionID string, checkpointID id.CheckpointID, force bool) error {\\n   476→\\t// Read checkpoint metadata first to get agent type (matching rewind pattern)\\n   477→\\trepo, err := openRepository(ctx)\\n   478→\\tif err != nil {\\n   479→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   480→\\t}\\n   481→\\n   482→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   483→\\tif err != nil {\\n   484→\\t\\treturn fmt.Errorf(\\\"failed to get metadata branch: %w\\\", err)\\n   485→\\t}\\n   486→\\n   487→\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n   488→\\tif err != nil {\\n   489→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint metadata: %w\\\", err)\\n   490→\\t}\\n   491→\\n   492→\\t// Resolve agent from checkpoint metadata (same as rewind)\\n   493→\\tag, err := strategy.ResolveAgentForRewind(metadata.Agent)\\n   494→\\tif err != nil {\\n   495→\\t\\treturn fmt.Errorf(\\\"failed to resolve agent: %w\\\", err)\\n   496→\\t}\\n   497→\\n   498→\\t// Initialize logging context with agent\\n   499→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"resume\\\"), ag.Name())\\n   500→\\n   501→\\tlogging.Debug(logCtx, \\\"resume session started\\\",\\n   502→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   503→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   504→\\t)\\n   505→\\n   506→\\t// Get worktree root for session directory lookup\\n   507→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   508→\\tif err != nil {\\n   509→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   510→\\t}\\n   511→\\n   512→\\tsessionDir, err := ag.GetSessionDir(repoRoot)\\n   513→\\tif err != nil {\\n   514→\\t\\treturn fmt.Errorf(\\\"failed to determine session directory: %w\\\", err)\\n   515→\\t}\\n   516→\\n   517→\\t// Create directory if it doesn't exist\\n   518→\\tif err := os.MkdirAll(sessionDir, 0o700); err != nil {\\n   519→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   520→\\t}\\n   521→\\n   522→\\t// Get strategy and restore sessions using full checkpoint data\\n   523→\\tstrat := GetStrategy(ctx)\\n   524→\\n   525→\\t// Use RestoreLogsOnly via LogsOnlyRestorer interface for multi-session support\\n   526→\\t// Create a logs-only rewind point with Agent populated (same as rewind)\\n   527→\\tpoint := strategy.RewindPoint{\\n   528→\\t\\tIsLogsOnly:   true,\\n   529→\\t\\tCheckpointID: checkpointID,\\n   530→\\t\\tAgent:        metadata.Agent,\\n   531→\\t}\\n   532→\\n   533→\\tsessions, restoreErr := strat.RestoreLogsOnly(ctx, point, force)\\n   534→\\tif restoreErr != nil || len(sessions) == 0 {\\n   535→\\t\\t// Fall back to single-session restore (e.g., old checkpoints without agent metadata)\\n   536→\\t\\treturn resumeSingleSession(ctx, ag, sessionID, checkpointID, repoRoot, force)\\n   537→\\t}\\n   538→\\n   539→\\tlogging.Debug(logCtx, \\\"resume session completed\\\",\\n   540→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   541→\\t\\tslog.Int(\\\"session_count\\\", len(sessions)),\\n   542→\\t)\\n   543→\\n   544→\\treturn displayRestoredSessions(sessions)\\n   545→}\\n   546→\\n   547→// displayRestoredSessions sorts sessions by CreatedAt and prints resume commands.\\n   548→// Used by both resumeSession (single checkpoint) and resumeMultipleCheckpoints (squash merge).\\n   549→func displayRestoredSessions(sessions []strategy.RestoredSession) error {\\n   550→\\tsort.Slice(sessions, func(i, j int) bool {\\n   551→\\t\\treturn sessions[i].CreatedAt.Before(sessions[j].CreatedAt)\\n   552→\\t})\\n   553→\\n   554→\\tif len(sessions) > 1 {\\n   555→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nRestored %d sessions. To continue, run:\\\\n\\\", len(sessions))\\n   556→\\t} else if len(sessions) == 1 {\\n   557→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session: %s\\\\n\\\", sessions[0].SessionID)\\n   558→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   559→\\t}\\n   560→\\n   561→\\tfor i, sess := range sessions {\\n   562→\\t\\tsessionAgent, err := strategy.ResolveAgentForRewind(sess.Agent)\\n   563→\\t\\tif err != nil {\\n   564→\\t\\t\\treturn fmt.Errorf(\\\"failed to resolve agent for session %s: %w\\\", sess.SessionID, err)\\n   565→\\t\\t}\\n   566→\\t\\tcmd := sessionAgent.FormatResumeCommand(sess.SessionID)\\n   567→\\n   568→\\t\\tisLast := i == len(sessions)-1\\n   569→\\t\\tswitch {\\n   570→\\t\\tcase len(sessions) > 1 && isLast && sess.Prompt != \\\"\\\":\\n   571→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # %s (most recent)\\\\n\\\", cmd, sess.Prompt)\\n   572→\\t\\tcase len(sessions) > 1 && isLast:\\n   573→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # (most recent)\\\\n\\\", cmd)\\n   574→\\t\\tcase sess.Prompt != \\\"\\\":\\n   575→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # %s\\\\n\\\", cmd, sess.Prompt)\\n   576→\\t\\tdefault:\\n   577→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", cmd)\\n   578→\\t\\t}\\n   579→\\t}\\n   580→\\n   581→\\treturn nil\\n   582→}\\n   583→\\n   584→// resumeSingleSession restores a single session (fallback when multi-session restore fails).\\n   585→// Always overwrites existing session logs to ensure consistency with checkpoint state.\\n   586→// If force is false, prompts for confirmation when local log has newer timestamps.\\n   587→func resumeSingleSession(ctx context.Context, ag agent.Agent, sessionID string, checkpointID id.CheckpointID, repoRoot string, force bool) error {\\n   588→\\tsessionLogPath, err := resolveTranscriptPath(ctx, sessionID, ag)\\n   589→\\tif err != nil {\\n   590→\\t\\treturn fmt.Errorf(\\\"failed to resolve transcript path: %w\\\", err)\\n   591→\\t}\\n   592→\\n   593→\\tif checkpointID.IsEmpty() {\\n   594→\\t\\tlogging.Debug(ctx, \\\"resume session: empty checkpoint ID\\\",\\n   595→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   596→\\t\\t)\\n   597→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session '%s' found in commit trailer but session log not available\\\\n\\\", sessionID)\\n   598→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   599→\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", ag.FormatResumeCommand(sessionID))\\n   600→\\t\\treturn nil\\n   601→\\t}\\n   602→\\n   603→\\tlogContent, _, err := checkpoint.LookupSessionLog(ctx, checkpointID)\\n   604→\\tif err != nil {\\n   605→\\t\\tif errors.Is(err, checkpoint.ErrCheckpointNotFound) || errors.Is(err, checkpoint.ErrNoTranscript) {\\n   606→\\t\\t\\tlogging.Debug(ctx, \\\"resume session completed (no metadata)\\\",\\n   607→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   608→\\t\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   609→\\t\\t\\t)\\n   610→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Session '%s' found in commit trailer but session log not available\\\\n\\\", sessionID)\\n   611→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   612→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", ag.FormatResumeCommand(sessionID))\\n   613→\\t\\t\\treturn nil\\n   614→\\t\\t}\\n   615→\\t\\tlogging.Error(ctx, \\\"resume session failed\\\",\\n   616→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   617→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   618→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   619→\\t\\t)\\n   620→\\t\\treturn fmt.Errorf(\\\"failed to get session log: %w\\\", err)\\n   621→\\t}\\n   622→\\n   623→\\t// Check if local file has newer timestamps than checkpoint\\n   624→\\tif !force {\\n   625→\\t\\tlocalTime := paths.GetLastTimestampFromFile(sessionLogPath)\\n   626→\\t\\tcheckpointTime := paths.GetLastTimestampFromBytes(logContent)\\n   627→\\t\\tstatus := strategy.ClassifyTimestamps(localTime, checkpointTime)\\n   628→\\n   629→\\t\\tif status == strategy.StatusLocalNewer {\\n   630→\\t\\t\\tsessions := []strategy.SessionRestoreInfo{{\\n   631→\\t\\t\\t\\tSessionID:      sessionID,\\n   632→\\t\\t\\t\\tStatus:         status,\\n   633→\\t\\t\\t\\tLocalTime:      localTime,\\n   634→\\t\\t\\t\\tCheckpointTime: checkpointTime,\\n   635→\\t\\t\\t}}\\n   636→\\t\\t\\tshouldOverwrite, promptErr := strategy.PromptOverwriteNewerLogs(sessions)\\n   637→\\t\\t\\tif promptErr != nil {\\n   638→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to get confirmation: %w\\\", promptErr)\\n   639→\\t\\t\\t}\\n   640→\\t\\t\\tif !shouldOverwrite {\\n   641→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled. Local session log preserved.\\\\n\\\")\\n   642→\\t\\t\\t\\treturn nil\\n   643→\\t\\t\\t}\\n   644→\\t\\t}\\n   645→\\t}\\n   646→\\n   647→\\t// Ensure parent directory exists\\n   648→\\tif err := os.MkdirAll(filepath.Dir(sessionLogPath), 0o750); err != nil {\\n   649→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   650→\\t}\\n   651→\\n   652→\\tagentSession := &agent.AgentSession{\\n   653→\\t\\tSessionID:  sessionID,\\n   654→\\t\\tAgentName:  ag.Name(),\\n   655→\\t\\tRepoPath:   repoRoot,\\n   656→\\t\\tSessionRef: sessionLogPath,\\n   657→\\t\\tNativeData: logContent,\\n   658→\\t}\\n   659→\\n   660→\\t// Write the session using the agent's WriteSession method\\n   661→\\tif err := ag.WriteSession(ctx, agentSession); err != nil {\\n   662→\\t\\tlogging.Error(ctx, \\\"resume session failed during write\\\",\\n   663→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   664→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   665→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   666→\\t\\t)\\n   667→\\t\\treturn fmt.Errorf(\\\"failed to write session: %w\\\", err)