"\\n    22→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    23→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    24→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    25→\\t\\\"github.com/spf13/cobra\\\"\\n    26→)\\n    27→\\n    28→func newResumeCmd() *cobra.Command {\\n    29→\\tvar force bool\\n    30→\\n    31→\\tcmd := &cobra.Command{\\n    32→\\t\\tUse:   \\\"resume <branch>\\\",\\n    33→\\t\\tShort: \\\"Switch to a branch and resume its session\\\",\\n    34→\\t\\tLong: `Switch to a local branch and resume the agent session from its last commit.\\n    35→\\n    36→This command:\\n    37→1. Checks out the specified branch\\n    38→2. Finds the session ID from commits unique to this branch (not on main)\\n    39→3. Restores the session log if it doesn't exist locally\\n    40→4. Shows the command to resume the session\\n    41→\\n    42→If the branch doesn't exist locally but exists on origin, you'll be prompted\\n    43→to fetch it.\\n    44→\\n    45→If newer commits without checkpoints exist on the branch (e.g., after merging main\\n    46→or cherry-picking from elsewhere), this operation will reset your Git status to the\\n    47→most recent commit with a checkpoint.  You'll be prompted to confirm resuming in this case.`,\\n    48→\\t\\tArgs: cobra.ExactArgs(1),\\n    49→\\t\\tRunE: func(cmd *cobra.Command, args []string) error {\\n    50→\\t\\t\\tif checkDisabledGuard(cmd.Context(), cmd.OutOrStdout()) {\\n    51→\\t\\t\\t\\treturn nil\\n    52→\\t\\t\\t}\\n    53→\\t\\t\\treturn runResume(cmd.Context(), args[0], force)\\n    54→\\t\\t},\\n    55→\\t}\\n    56→\\n    57→\\tcmd.Flags().BoolVarP(&force, \\\"force\\\", \\\"f\\\", false, \\\"Resume from older checkpoint without confirmation\\\")\\n    58→\\n    59→\\treturn cmd\\n    60→}\\n    61→\\n    62→func runResume(ctx context.Context, branchName string, force bool) error {\\n    63→\\t// Check if we're already on this branch\\n    64→\\tcurrentBranch, err := GetCurrentBranch(ctx)\\n    65→\\tif err == nil && currentBranch == branchName {\\n    66→\\t\\t// Already on the branch, skip checkout\\n    67→\\t\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n    68→\\t}\\n    69→\\n    70→\\t// Check if branch exists locally\\n    71→\\texists, err := BranchExistsLocally(ctx, branchName)\\n    72→\\tif err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\\"failed to check branch: %w\\\", err)\\n    74→\\t}\\n    75→\\n    76→\\tif !exists {\\n    77→\\t\\t// Branch doesn't exist locally, check if it exists on remote\\n    78→\\t\\tremoteExists, err := BranchExistsOnRemote(ctx, branchName)\\n    79→\\t\\tif err != nil {\\n    80→\\t\\t\\treturn fmt.Errorf(\\\"failed to check remote branch: %w\\\", err)\\n    81→\\t\\t}\\n    82→\\n    83→\\t\\tif !remoteExists {\\n    84→\\t\\t\\treturn fmt.Errorf(\\\"branch '%s' not found locally or on origin\\\", branchName)\\n    85→\\t\\t}\\n    86→\\n    87→\\t\\t// Ask user if they want to fetch from remote\\n    88→\\t\\tshouldFetch, err := promptFetchFromRemote(branchName)\\n    89→\\t\\tif err != nil {\\n    90→\\t\\t\\treturn err\\n    91→\\t\\t}\\n    92→\\t\\tif !shouldFetch {\\n    93→\\t\\t\\treturn nil\\n    94→\\t\\t}\\n    95→\\n    96→\\t\\t// Fetch and checkout the remote branch\\n    97→\\t\\tfmt.Fprintf(os.Stderr, \\\"Fetching branch '%s' from origin...\\\\n\\\", branchName)\\n    98→\\t\\tif err := FetchAndCheckoutRemoteBranch(ctx, branchName); err != nil {\\n    99→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n   100→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   101→\\t\\t}\\n   102→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   103→\\t} else {\\n   104→\\t\\t// Branch exists locally, check for uncommitted changes before checkout\\n   105→\\t\\thasChanges, err := HasUncommittedChanges(ctx)\\n   106→\\t\\tif err != nil {\\n   107→\\t\\t\\treturn fmt.Errorf(\\\"failed to check for uncommitted changes: %w\\\", err)\\n   108→\\t\\t}\\n   109→\\t\\tif hasChanges {\\n   110→\\t\\t\\treturn errors.New(\\\"you have uncommitted changes. Please commit or stash them first\\\")\\n   111→\\t\\t}\\n   112→\\n   113→\\t\\t// Checkout the branch\\n   114→\\t\\tif err := CheckoutBranch(ctx, branchName); err != nil {\\n   115→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n   116→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   117→\\t\\t}\\n   118→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   119→\\t}\\n   120→\\n   121→\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n   122→}\\n   123→\\n   124→func resumeFromCurrentBranch(ctx context.Context, branchName string, force bool) error {\\n   125→\\trepo, err := openRepository(ctx)\\n   126→\\tif err != nil {\\n   127→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   128→\\t}\\n   129→\\n   130→\\t// Find a commit with an Entire-Checkpoint trailer, looking at branch-only commits\\n   131→\\tresult, err := findBranchCheckpoint(repo, branchName)\\n   132→\\tif err != nil {\\n   133→\\t\\treturn err\\n   134→\\t}\\n   135→\\tif len(result.checkpointIDs) == 0 {\\n   136→\\t\\tfmt.Fprintf(os.Stderr, \\\"No Entire checkpoint found on branch '%s'\\\\n\\\", branchName)\\n   137→\\t\\treturn nil\\n   138→\\t}\\n   139→\\n   140→\\t// If there are newer commits without checkpoints, ask for confirmation.\\n   141→\\t// Merge commits (e.g., from merging main) don't count as \\\"work\\\" and are skipped silently.\\n   142→\\tif result.newerCommitsExist && !force {\\n   143→\\t\\tfmt.Fprintf(os.Stderr, \\\"Found checkpoint in an older commit.\\\\n\\\")\\n   144→\\t\\tfmt.Fprintf(os.Stderr, \\\"There are %d newer commit(s) on this branch without checkpoints.\\\\n\\\", result.newerCommitCount)\\n   145→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint from: %s %s\\\\n\\\\n\\\", result.commitHash[:7], firstLine(result.commitMessage))\\n   146→\\n   147→\\t\\tshouldResume, err := promptResumeFromOlderCheckpoint()\\n   148→\\t\\tif err != nil {\\n   149→\\t\\t\\treturn err\\n   150→\\t\\t}\\n   151→\\t\\tif !shouldResume {\\n   152→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled.\\\\n\\\")\\n   153→\\t\\t\\treturn nil\\n   154→\\t\\t}\\n   155→\\t}\\n   156→\\n   157→\\t// Multiple checkpoints (squash merge): restore all sessions\\n   158→\\tif len(result.checkpointIDs) > 1 {\\n   159→\\t\\treturn resumeMultipleCheckpoints(ctx, repo, result.checkpointIDs, force)\\n   160→\\t}\\n   161→\\n   162→\\t// Single checkpoint: existing behavior (unchanged)\\n   163→\\tcheckpointID := result.checkpointIDs[0]\\n   164→\\n   165→\\t// Get metadata branch tree for lookups\\n   166→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   167→\\tif err != nil {\\n   168→\\t\\t// No local metadata branch, check if remote has it\\n   169→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   170→\\t}\\n   171→\\n   172→\\t// Look up metadata from sharded path\\n   173→\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n   174→\\tif err != nil {\\n   175→\\t\\t// Checkpoint exists in commit but no local metadata - check remote\\n   176→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   177→\\t}\\n   178→\\n   179→\\treturn resumeSession(ctx, metadata.SessionID, checkpointID, force)\\n   180→}\\n   181→\\n   182→// resumeMultipleCheckpoints restores sessions from multiple checkpoint IDs.\\n   183→// This handles squash merge commits where multiple Entire-Checkpoint trailers\\n   184→// are present in a single commit message. Each checkpoint is looked up independently\\n   185→// and missing metadata is skipped (best-effort).\\n   186→func resumeMultipleCheckpoints(ctx context.Context, repo *git.Repository, checkpointIDs []id.CheckpointID, force bool) error {\\n   187→\\tlogCtx := logging.WithComponent(ctx, \\\"resume\\\")\\n   188→\\n   189→\\t// Get metadata branch tree (try local first, then remote)\\n   190→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   191→\\tif err != nil {\\n   192→\\t\\t// Try fetching from remote\\n   193→\\t\\tlogging.Debug(logCtx, \\\"metadata branch not available locally, trying remote\\\")\\n   194→\\t\\tif fetchErr := FetchMetadataBranch(ctx); fetchErr != nil {\\n   195→\\t\\t\\t// If fetch also fails, try remote tree directly\\n   196→\\t\\t\\tremoteTree, remoteErr := strategy.GetRemoteMetadataBranchTree(repo)\\n   197→\\t\\t\\tif remoteErr != nil {\\n   198→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint metadata not available locally or on remote\\\\n\\\")\\n   199→\\t\\t\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   200→\\t\\t\\t}\\n   201→\\t\\t\\tmetadataTree = remoteTree\\n   202→\\t\\t} else {\\n   203→\\t\\t\\tmetadataTree, err = strategy.GetMetadataBranchTree(repo)\\n   204→\\t\\t\\tif err != nil {\\n   205→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint metadata not available after fetch\\\\n\\\")\\n   206→\\t\\t\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   207→\\t\\t\\t}\\n   208→\\t\\t}\\n   209→\\t}\\n   210→\\n   211→\\t// Read metadata for all checkpoints and sort by CreatedAt ascending\\n   212→\\t// (oldest first → newest writes last and wins on disk)\\n   213→\\tcheckpoints := collectCheckpointsByAge(metadataTree, checkpointIDs)\\n   214→\\n   215→\\t// Iterate sorted checkpoints and restore\\n   216→\\tstrat := GetStrategy(ctx)\\n   217→\\tvar allSessions []strategy.RestoredSession\\n   218→\\n   219→\\tfor _, cp := range checkpoints {\\n   220→\\t\\tpoint := strategy.RewindPoint{\\n   221→\\t\\t\\tIsLogsOnly:   true,\\n   222→\\t\\t\\tCheckpointID: cp.CheckpointID,\\n   223→\\t\\t\\tAgent:        cp.Agent,\\n   224→\\t\\t}\\n   225→\\n   226→\\t\\tsessions, restoreErr := strat.RestoreLogsOnly(ctx, point, force)\\n   227→\\t\\tif restoreErr != nil {\\n   228→\\t\\t\\tlogging.Debug(logCtx, \\\"skipping checkpoint: restore failed\\\",\\n   229→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cp.CheckpointID.String()),\\n   230→\\t\\t\\t\\tslog.String(\\\"error\\\", restoreErr.Error()),\\n   231→\\t\\t\\t)\\n   232→\\t\\t\\tcontinue\\n   233→\\t\\t}\\n   234→\\t\\tif len(sessions) == 0 {\\n   235→\\t\\t\\tlogging.Debug(logCtx, \\\"skipping checkpoint: no sessions restored\\\",\\n   236→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cp.CheckpointID.String()),\\n   237→\\t\\t\\t)\\n   238→\\t\\t\\tcontinue\\n   239→\\t\\t}\\n   240→\\n   241→\\t\\tallSessions = deduplicateSessions(allSessions, sessions)\\n   242→\\t}\\n   243→\\n   244→\\tif len(allSessions) == 0 {\\n   245→\\t\\tfmt.Fprintf(os.Stderr, \\\"No session metadata found for checkpoints in this commit\\\\n\\\")\\n   246→\\t\\treturn nil\\n   247→\\t}\\n   248→\\n   249→\\tlogging.Debug(logCtx, \\\"resume multiple checkpoints completed\\\",\\n   250→\\t\\tslog.Int(\\\"checkpoint_count\\\", len(checkpointIDs)),\\n   251→\\t\\tslog.Int(\\\"session_count\\\", len(allSessions)),\\n   252→\\t)\\n   253→\\n   254→\\treturn displayRestoredSessions(allSessions)\\n   255→}\\n   256→\\n   257→// collectCheckpointsByAge reads metadata for each checkpoint ID from the tree,\\n   258→// skips any that can't be read, and returns them sorted by CreatedAt ascending.\\n   259→// Sorting ensures the newest checkpoint is restored last and wins on disk,\\n   260→// regardless of trailer order in the commit message.\\n   261→func collectCheckpointsByAge(tree *object.Tree, checkpointIDs []id.CheckpointID) []*strategy.CheckpointInfo {\\n   262→\\tvar checkpoints []*strategy.CheckpointInfo\\n   263→\\tfor _, cpID := range checkpointIDs {\\n   264→\\t\\tmetadata, err := strategy.ReadCheckpointMetadata(tree, cpID.Path())\\n   265→\\t\\tif err != nil {\\n   266→\\t\\t\\tcontinue\\n   267→\\t\\t}\\n   268→\\t\\tcheckpoints = append(checkpoints, metadata)\\n   269→\\t}\\n   270→\\tsort.Slice(checkpoints, func(i, j int) bool {\\n   271→\\t\\treturn checkpoints[i].CreatedAt.Before(checkpoints[j].CreatedAt)\\n   272→\\t})\\n   273→\\treturn checkpoints\\n   274→}\\n   275→\\n   276→// deduplicateSessions merges new sessions into existing, keeping the one with the latest\\n   277→// CreatedAt when a SessionID appears more than once. This handles squash merges where the\\n   278→// same session may be referenced by multiple checkpoints.\\n   279→func deduplicateSessions(existing, incoming []strategy.RestoredSession) []strategy.RestoredSession {\\n   280→\\ttype entry struct {\\n   281→\\t\\tindex     int\\n   282→\\t\\tcreatedAt time.Time\\n   283→\\t}\\n   284→\\n   285→\\tseen := make(map[string]entry, len(existing))\\n   286→\\tfor i, s := range existing {\\n   287→\\t\\tseen[s.SessionID] = entry{index: i, createdAt: s.CreatedAt}\\n   288→\\t}\\n   289→\\n   290→\\tfor _, sess := range incoming {\\n   291→\\t\\tif prev, exists := seen[sess.SessionID]; exists {\\n   292→\\t\\t\\t// Keep the one with the later CreatedAt (more complete transcript)\\n   293→\\t\\t\\tif sess.CreatedAt.After(prev.createdAt) {\\n   294→\\t\\t\\t\\texisting[prev.index] = sess\\n   295→\\t\\t\\t\\tseen[sess.SessionID] = entry{index: prev.index, createdAt: sess.CreatedAt}\\n   296→\\t\\t\\t}\\n   297→\\t\\t} else {\\n   298→\\t\\t\\tseen[sess.SessionID] = entry{index: len(existing), createdAt: sess.CreatedAt}\\n   299→\\t\\t\\texisting = append(existing, sess)\\n   300→\\t\\t}\\n   301→\\t}\\n   302→\\n   303→\\treturn existing\\n   304→}\\n   305→\\n   306→// branchCheckpointResult contains the result of searching for a checkpoint on a branch.\\n   307→type branchCheckpointResult struct {\\n   308→\\tcheckpointIDs     []id.CheckpointID\\n   309→\\tcommitHash        string\\n   310→\\tcommitMessage     string\\n   311→\\tnewerCommitsExist bool // true if there are branch-only commits (not merge commits) without checkpoints\\n   312→\\tnewerCommitCount  int  // count of branch-only commits without checkpoints\\n   313→}\\n   314→\\n   315→// findBranchCheckpoint finds the most recent commit with an Entire-Checkpoint trailer\\n   316→// among commits that are unique to this branch (not reachable from the default branch).\\n   317→// This handles the case where main has been merged into the feature branch.\\n   318→func findBranchCheckpoint(repo *git.Repository, branchName string) (*branchCheckpointResult, error) {\\n   319→\\tresult := &branchCheckpointResult{}\\n   320→\\n   321→\\t// Get HEAD commit\\n   322→\\thead, err := repo.Head()\\n   323→\\tif err != nil {\\n   324→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   325→\\t}\\n   326→\\n   327→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   328→\\tif err != nil {\\n   329→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   330→\\t}\\n   331→\\n   332→\\t// First, check if HEAD itself has a checkpoint (most common case)\\n   333→\\tif cpIDs := trailers.ParseAllCheckpoints(headCommit.Message); len(cpIDs) > 0 {\\n   334→\\t\\tresult.checkpointIDs = cpIDs\\n   335→\\t\\tresult.commitHash = head.Hash().String()\\n   336→\\t\\tresult.commitMessage = headCommit.Message\\n   337→\\t\\tresult.newerCommitsExist = false\\n   338→\\t\\treturn result, nil\\n   339→\\t}\\n   340→\\n   341→\\t// HEAD doesn't have a checkpoint - find branch-only commits\\n   342→\\t// Get the default branch name\\n   343→\\tdefaultBranch := getDefaultBranchFromRemote(repo)\\n   344→\\tif defaultBranch == \\\"\\\" {\\n   345→\\t\\t// Fallback: try common names\\n   346→\\t\\tfor _, name := range []string{\\\"main\\\", \\\"master\\\"} {\\n   347→\\t\\t\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(name), true); err == nil {\\n   348→\\t\\t\\t\\tdefaultBranch = name\\n   349→\\t\\t\\t\\tbreak\\n   350→\\t\\t\\t}\\n   351→\\t\\t}\\n   352→\\t}\\n   353→\\n   354→\\t// If we can't find a default branch, or we're on it, just walk all commits\\n   355→\\tif defaultBranch == \\\"\\\" || defaultBranch == branchName {\\n   356→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil\\n   357→\\t}\\n   358→\\n   359→\\t// Get the default branch reference\\n   360→\\tdefaultRef, err := repo.Reference(plumbing.NewBranchReferenceName(defaultBranch), true)\\n   361→\\tif err != nil {\\n   362→\\t\\t// Default branch doesn't exist locally, fall back to walking all commits\\n   363→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   364→\\t}\\n   365→\\n   366→\\tdefaultCommit, err := repo.CommitObject(defaultRef.Hash())\\n   367→\\tif err != nil {\\n   368→\\t\\t// Can't get default commit, fall back to walking all commits\\n   369→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   370→\\t}\\n   371→\\n   372→\\t// Find merge base\\n   373→\\tmergeBase, err := headCommit.MergeBase(defaultCommit)\\n   374→\\tif err != nil || len(mergeBase) == 0 {\\n   375→\\t\\t// No common ancestor, fall back to walking all commits\\n   376→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   377→\\t}\\n   378→\\n   379→\\t// Walk from HEAD to merge base, looking for checkpoint\\n   380→\\treturn findCheckpointInHistory(headCommit, &mergeBase[0].Hash), nil\\n   381→}\\n   382→\\n   383→// findCheckpointInHistory walks commit history from start looking for a checkpoint trailer.\\n   384→// If stopAt is provided, stops when reaching that commit (exclusive).\\n   385→// Returns the first checkpoint found and info about commits between HEAD and the checkpoint.\\n   386→// It distinguishes between merge commits (bringing in other branches) and regular commits\\n   387→// (actual branch work) to avoid false warnings after merging main.\\n   388→func findCheckpointInHistory(start *object.Commit, stopAt *plumbing.Hash) *branchCheckpointResult {\\n   389→\\tresult := &branchCheckpointResult{}\\n   390→\\tbranchWorkCommits := 0 // Regular commits without checkpoints (actual work)\\n   391→\\tconst maxCommits = 100 // Limit search depth\\n   392→\\ttotalChecked := 0\\n   393→\\n   394→\\tcurrent := start\\n   395→\\tfor current != nil && totalChecked < maxCommits {\\n   396→\\t\\t// Stop if we've reached the boundary\\n   397→\\t\\tif stopAt != nil && current.Hash == *stopAt {\\n   398→\\t\\t\\tbreak\\n   399→\\t\\t}\\n   400→\\n   401→\\t\\t// Check for checkpoint trailer\\n   402→\\t\\tif cpIDs := trailers.ParseAllCheckpoints(current.Message); len(cpIDs) > 0 {\\n   403→\\t\\t\\tresult.checkpointIDs = cpIDs\\n   404→\\t\\t\\tresult.commitHash = current.Hash.String()\\n   405→\\t\\t\\tresult.commitMessage = current.Message\\n   406→\\t\\t\\t// Only warn about branch work commits, not merge commits\\n   407→\\t\\t\\tresult.newerCommitsExist = branchWorkCommits > 0\\n   408→\\t\\t\\tresult.newerCommitCount = branchWorkCommits\\n   409→\\t\\t\\treturn result\\n   410→\\t\\t}\\n   411→\\n   412→\\t\\t// Only count regular commits (not merge commits) as \\\"branch work\\\"\\n   413→\\t\\tif current.NumParents() <= 1 {\\n   414→\\t\\t\\tbranchWorkCommits++\\n   415→\\t\\t}\\n   416→\\n   417→\\t\\ttotalChecked++\\n   418→\\n   419→\\t\\t// Move to parent (first parent for merge commits - follows the main line)\\n   420→\\t\\tif current.NumParents() == 0 {\\n   421→\\t\\t\\tbreak\\n   422→\\t\\t}\\n   423→\\t\\tparent, err := current.Parent(0)\\n   424→\\t\\tif err != nil {\\n   425→\\t\\t\\t// Can't get parent, treat as end of history\\n   426→\\t\\t\\tbreak\\n   427→\\t\\t}\\n   428→\\t\\tcurrent = parent\\n   429→\\t}\\n   430→\\n   431→\\t// No checkpoint found\\n   432→\\treturn result\\n   433→}\\n   434→\\n   435→// promptResumeFromOlderCheckpoint asks the user if they want to resume from an older checkpoint.\\n   436→func promptResumeFromOlderCheckpoint() (bool, error) {\\n   437→\\tvar confirmed bool\\n   438→\\n   439→\\tform := NewAccessibleForm(\\n   440→\\t\\thuh.NewGroup(\\n   441→\\t\\t\\thuh.NewConfirm().\\n   442→\\t\\t\\t\\tTitle(\\\"Resume from this older checkpoint?\\\").\\n   443→\\t\\t\\t\\tValue(&confirmed),\\n   444→\\t\\t),\\n   445→\\t)\\n   446→\\n   447→\\tif err := form.Run(); err != nil {\\n   448→\\t\\tif errors.Is(err, huh.ErrUserAborted) {\\n   449→\\t\\t\\treturn false, nil\\n   450→\\t\\t}\\n   451→\\t\\treturn false, fmt.Errorf(\\\"failed to get confirmation: %w\\\", err)\\n   452→\\t}\\n   453→\\n   454→\\treturn confirmed, nil\\n   455→}\\n   456→\\n   457→// checkRemoteMetadata checks if checkpoint metadata exists on origin/entire/checkpoints/v1\\n   458→// and automatically fetches it if available.\\n   459→func checkRemoteMetadata(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID) error {\\n   460→\\t// Try to get remote metadata branch tree\\n   461→\\tremoteTree, err := strategy.GetRemoteMetadataBranchTree(repo)\\n   462→\\tif err != nil {\\n   463→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   464→\\t\\tfmt.Fprintf(os.Stderr, \\\"The entire/checkpoints/v1 branch may not exist locally or on the remote.\\\\n\\\")\\n   465→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   466→\\t}\\n   467→\\n   468→\\t// Check if the checkpoint exists on the remote\\n   469→\\tmetadata, err := strategy.ReadCheckpointMetadata(remoteTree, checkpointID.Path())\\n   470→\\tif err != nil {\\n   471→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   472→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   473→\\t}\\n   474→\\n   475→\\t// Metadata exists on remote but not locally - fetch it automatically\\n   476→\\tfmt.Fprintf(os.Stderr, \\\"Fetching session metadata from origin...\\\\n\\\")\\n   477→\\tif err := FetchMetadataBranch(ctx); err != nil {\\n   478→\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to fetch metadata: %v\\\\n\\\", err)\\n   479→\\t\\tfmt.Fprintf(os.Stderr, \\\"You can try manually: git fetch origin entire/checkpoints/v1:entire/checkpoints/v1\\\\n\\\")\\n   480→\\t\\treturn NewSilentError(errors.New(\\\"failed to fetch metadata\\\"))\\n   481→\\t}\\n   482→\\n   483→\\t// Now resume the session with the fetched metadata\\n   484→\\treturn resumeSession(ctx, metadata.SessionID, checkpointID, false)\\n   485→}\\n   486→\\n   487→// resumeSession restores and displays the resume command for a specific session.\\n   488→// For multi-session checkpoints, restores ALL sessions and shows commands for each.\\n   489→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   490→func resumeSession(ctx context.Context, sessionID string, checkpointID id.CheckpointID, force bool) error {\\n   491→\\t// Read checkpoint metadata first to get agent type (matching rewind pattern)\\n   492→\\trepo, err := openRepository(ctx)\\n   493→\\tif err != nil {\\n   494→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   495→\\t}\\n   496→\\n   497→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   498→\\tif err != nil {\\n   499→\\t\\treturn fmt.Errorf(\\\"failed to get metadata branch: %w\\\", err)\\n   500→\\t}\\n   501→\\n   502→\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n   503→\\tif err != nil {\\n   504→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint metadata: %w\\\", err)\\n   505→\\t}\\n   506→\\n   507→\\t// Resolve agent from checkpoint metadata (same as rewind)\\n   508→\\tag, err := strategy.ResolveAgentForRewind(metadata.Agent)\\n   509→\\tif err != nil {\\n   510→\\t\\treturn fmt.Errorf(\\\"failed to resolve agent: %w\\\", err)\\n   511→\\t}\\n   512→\\n   513→\\t// Initialize logging context with agent\\n   514→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"resume\\\"), ag.Name())\\n   515→\\n   516→\\tlogging.Debug(logCtx, \\\"resume session started\\\",\\n   517→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   518→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   519→\\t)\\n   520→\\n   521→\\t// Get worktree root for session directory lookup\\n   522→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   523→\\tif err != nil {\\n   524→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   525→\\t}\\n   526→\\n   527→\\tsessionDir, err := ag.GetSessionDir(repoRoot)\\n   528→\\tif err != nil {\\n   529→\\t\\treturn fmt.Errorf(\\\"failed to determine session directory: %w\\\", err)\\n   530→\\t}\\n   531→\\n   532→\\t// Create directory if it doesn't exist\\n   533→\\tif err := os.MkdirAll(sessionDir, 0o700); err != nil {\\n   534→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   535→\\t}\\n   536→\\n   537→\\t// Get strategy and restore sessions using full checkpoint data\\n   538→\\tstrat := GetStrategy(ctx)\\n   539→\\n   540→\\t// Use RestoreLogsOnly via LogsOnlyRestorer interface for multi-session support\\n   541→\\t// Create a logs-only rewind point with Agent populated (same as rewind)\\n   542→\\tpoint := strategy.RewindPoint{\\n   543→\\t\\tIsLogsOnly:   true,\\n   544→\\t\\tCheckpointID: checkpointID,\\n   545→\\t\\tAgent:        metadata.Agent,\\n   546→\\t}\\n   547→\\n   548→\\tsessions, restoreErr := strat.RestoreLogsOnly(ctx, point, force)\\n   549→\\tif restoreErr != nil || len(sessions) == 0 {\\n   550→\\t\\t// Fall back to single-session restore (e.g., old checkpoints without agent metadata)\\n   551→\\t\\treturn resumeSingleSession(ctx, ag, sessionID, checkpointID, repoRoot, force)\\n   552→\\t}\\n   553→\\n   554→\\tlogging.Debug(logCtx, \\\"resume session completed\\\",\\n   555→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   556→\\t\\tslog.Int(\\\"session_count\\\", len(sessions)),\\n   557→\\t)\\n   558→\\n   559→\\treturn displayRestoredSessions(sessions)\\n   560→}\\n   561→\\n   562→// displayRestoredSessions sorts sessions by CreatedAt and prints resume commands.\\n   563→// Used by both resumeSession (single checkpoint) and resumeMultipleCheckpoints (squash merge).\\n   564→func displayRestoredSessions(sessions []strategy.RestoredSession) error {\\n   565→\\tsort.Slice(sessions, func(i, j int) bool {\\n   566→\\t\\treturn sessions[i].CreatedAt.Before(sessions[j].CreatedAt)\\n   567→\\t})\\n   568→\\n   569→\\tif len(sessions) > 1 {\\n   570→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nRestored %d sessions. To continue, run:\\\\n\\\", len(sessions))\\n   571→\\t} else if len(sessions) == 1 {\\n   572→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session: %s\\\\n\\\", sessions[0].SessionID)\\n   573→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   574→\\t}\\n   575→\\n   576→\\tfor i, sess := range sessions {\\n   577→\\t\\tsessionAgent, err := strategy.ResolveAgentForRewind(sess.Agent)\\n   578→\\t\\tif err != nil {\\n   579→\\t\\t\\treturn fmt.Errorf(\\\"failed to resolve agent for session %s: %w\\\", sess.SessionID, err)\\n   580→\\t\\t}\\n   581→\\t\\tcmd := sessionAgent.FormatResumeCommand(sess.SessionID)\\n   582→\\n   583→\\t\\tisLast := i == len(sessions)-1\\n   584→\\t\\tswitch {\\n   585→\\t\\tcase len(sessions) > 1 && isLast && sess.Prompt != \\\"\\\":\\n   586→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # %s (most recent)\\\\n\\\", cmd, sess.Prompt)\\n   587→\\t\\tcase len(sessions) > 1 && isLast:\\n   588→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # (most recent)\\\\n\\\", cmd)\\n   589→\\t\\tcase sess.Prompt != \\\"\\\":\\n   590→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # %s\\\\n\\\", cmd, sess.Prompt)\\n   591→\\t\\tdefault:\\n   592→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", cmd)\\n   593→\\t\\t}\\n   594→\\t}\\n   595→\\n   596→\\treturn nil\\n   597→}\\n   598→\\n   599→// resumeSingleSession restores a single session (fallback when multi-session restore fails).\\n   600→// Always overwrites existing session logs to ensure consistency with checkpoint state.\\n   601→// If force is false, prompts for confirmation when local log has newer timestamps.\\n   602→func resumeSingleSession(ctx context.Context, ag agent.Agent, sessionID string, checkpointID id.CheckpointID, repoRoot string, force bool) error {\\n   603→\\tsessionLogPath, err := resolveTranscriptPath(ctx, sessionID, ag)\\n   604→\\tif err != nil {\\n   605→\\t\\treturn fmt.Errorf(\\\"failed to resolve transcript path: %w\\\", err)\\n   606→\\t}\\n   607→\\n   608→\\tif checkpointID.IsEmpty() {\\n   609→\\t\\tlogging.Debug(ctx, \\\"resume session: empty checkpoint ID\\\",\\n   610→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   611→\\t\\t)\\n   612→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session '%s' found in commit trailer but session log not available\\\\n\\\", sessionID)\\n   613→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   614→\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", ag.FormatResumeCommand(sessionID))\\n   615→\\t\\treturn nil\\n   616→\\t}\\n   617→\\n   618→\\tlogContent, _, err := checkpoint.LookupSessionLog(ctx, checkpointID)\\n   619→\\tif err != nil {\\n   620→\\t\\tif errors.Is(err, checkpoint.ErrCheckpointNotFound) || errors.Is(err, checkpoint.ErrNoTranscript) {\\n   621→\\t\\t\\tlogging.Debug(ctx, \\\"resume session completed (no metadata)\\\",\\n   622→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   623→\\t\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   624→\\t\\t\\t)\\n   625→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Session '%s' found in commit trailer but session log not available\\\\n\\\", sessionID)\\n   626→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   627→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", ag.FormatResumeCommand(sessionID))\\n   628→\\t\\t\\treturn nil\\n   629→\\t\\t}\\n   6