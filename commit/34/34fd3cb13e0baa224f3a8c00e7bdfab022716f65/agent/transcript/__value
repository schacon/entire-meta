   119→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   120→// In this case, data is extracted from the live transcript instead.\\n   121→func (s *ManualCommitStrategy) CondenseSession(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}, opts ...condenseOpts) (*CondenseResult, error) {\\n   122→\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   123→\\tvar o condenseOpts\\n   124→\\tif len(opts) > 0 {\\n   125→\\t\\to = opts[0]\\n   126→\\t}\\n   127→\\n   128→\\t// Get shadow branch — use pre-resolved ref if available, otherwise resolve from repo.\\n   129→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   130→\\tref := o.shadowRef\\n   131→\\tvar hasShadowBranch bool\\n   132→\\tif ref != nil {\\n   133→\\t\\thasShadowBranch = true\\n   134→\\t} else {\\n   135→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   136→\\t\\tvar err error\\n   137→\\t\\tref, err = repo.Reference(refName, true)\\n   138→\\t\\thasShadowBranch = err == nil\\n   139→\\t}\\n   140→\\n   141→\\tvar sessionData *ExtractedSessionData\\n   142→\\tif hasShadowBranch {\\n   143→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   144→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   145→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   146→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   147→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   148→\\t\\t// last turn had no code changes).\\n   149→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   150→\\t\\tvar extractErr error\\n   151→\\t\\tsessionData, extractErr = s.extractSessionData(ctx, repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n   152→\\t\\tif extractErr != nil {\\n   153→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", extractErr)\\n   154→\\t\\t}\\n   155→\\t} else {\\n   156→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   157→\\t\\t// Extract data directly from live transcript.\\n   158→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   159→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   160→\\t\\t}\\n   161→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   162→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   163→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   164→\\t\\tif state.Phase.IsActive() {\\n   165→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, state.TranscriptPath)\\n   166→\\t\\t}\\n   167→\\t\\tvar extractErr error\\n   168→\\t\\tsessionData, extractErr = s.extractSessionDataFromLiveTranscript(ctx, state)\\n   169→\\t\\tif extractErr != nil {\\n   170→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", extractErr)\\n   171→\\t\\t}\\n   172→\\t}\\n   173→\\n   174→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   175→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   176→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   177→\\tif len(committedFiles) > 0 {\\n   178→\\t\\t// Track if we had files before filtering to distinguish between:\\n   179→\\t\\t// - Session had files but none were committed (don't fallback)\\n   180→\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n   181→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   182→\\n   183→\\t\\tif hadFilesBeforeFiltering {\\n   184→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   185→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   186→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   187→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   188→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   189→\\t\\t\\t\\t}\\n   190→\\t\\t\\t}\\n   191→\\t\\t\\tsessionData.FilesTouched = filtered\\n   192→\\t\\t}\\n   193→\\n   194→\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n   195→\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n   196→\\t\\t// the session had files that simply didn't overlap with the commit - that\\n   197→\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n   198→\\t\\t// overwritten with unrelated committed files.\\n   199→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   200→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   201→\\t\\t\\tfor f := range committedFiles {\\n   202→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   203→\\t\\t\\t}\\n   204→\\t\\t}\\n   205→\\t}\\n   206→\\n   207→\\t// Get checkpoint store\\n   208→\\tstore, err := s.getCheckpointStore()\\n   209→\\tif err != nil {\\n   210→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   211→\\t}\\n   212→\\n   213→\\t// Get author info\\n   214→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   215→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   216→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   217→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   218→\\tattribution := calculateSessionAttributions(ctx, repo, ref, sessionData, state, attributionOpts{\\n   219→\\t\\theadTree: o.headTree,\\n   220→\\t})\\n   221→\\t// Get current branch name\\n   222→\\tbranchName := GetCurrentBranchName(repo)\\n   223→\\n   224→\\t// Generate summary if enabled\\n   225→\\tvar summary *cpkg.Summary\\n   226→\\tif settings.IsSummarizeEnabled(ctx) && len(sessionData.Transcript) > 0 {\\n   227→\\t\\tsummarizeCtx := logging.WithComponent(ctx, \\\"summarize\\\")\\n   228→\\n   229→\\t\\t// Scope transcript to this checkpoint's portion.\\n   230→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   231→\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n   232→\\t\\tvar scopedTranscript []byte\\n   233→\\t\\tswitch state.AgentType {\\n   234→\\t\\tcase agent.AgentTypeGemini:\\n   235→\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   236→\\t\\t\\tif sliceErr != nil {\\n   237→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n   238→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   239→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   240→\\t\\t\\t}\\n   241→\\t\\t\\tscopedTranscript = scoped\\n   242→\\t\\tcase agent.AgentTypeOpenCode:\\n   243→\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   244→\\t\\t\\tif sliceErr != nil {\\n   245→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n   246→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   247→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   248→\\t\\t\\t}\\n   249→\\t\\t\\tscopedTranscript = scoped\\n   250→\\t\\tcase agent.AgentTypeClaudeCode, agent.Agen