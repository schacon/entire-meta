ithContent,\\n   771→\\t// filesWithRemainingAgentChanges, calculateSessionAttributions).\\n   772→\\tvar headTree *object.Tree\\n   773→\\tif t, err := commit.Tree(); err == nil {\\n   774→\\t\\theadTree = t\\n   775→\\t}\\n   776→\\tvar parentTree *object.Tree\\n   777→\\tif commit.NumParents() > 0 {\\n   778→\\t\\tif parent, err := commit.Parent(0); err == nil {\\n   779→\\t\\t\\tif t, err := parent.Tree(); err == nil {\\n   780→\\t\\t\\t\\tparentTree = t\\n   781→\\t\\t\\t}\\n   782→\\t\\t}\\n   783→\\t}\\n   784→\\n   785→\\tcommittedFileSet := filesChangedInCommit(commit, headTree, parentTree)\\n   786→\\n   787→\\tfor _, state := range sessions {\\n   788→\\t\\ts.postCommitProcessSession(ctx, repo, state, &transitionCtx, checkpointID,\\n   789→\\t\\t\\thead, commit, newHead, headTree, parentTree, committedFileSet,\\n   790→\\t\\t\\tshadowBranchesToDelete, uncondensedActiveOnBranch)\\n   791→\\t}\\n   792→\\n   793→\\t// Clean up shadow branches — only delete when ALL sessions on the branch are non-active\\n   794→\\t// or were condensed during this PostCommit.\\n   795→\\tfor shadowBranchName := range shadowBranchesToDelete {\\n   796→\\t\\tif uncondensedActiveOnBranch[shadowBranchName] {\\n   797→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: preserving shadow branch (active session exists)\\\",\\n   798→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   799→\\t\\t\\t)\\n   800→\\t\\t\\tcontinue\\n   801→\\t\\t}\\n   802→\\t\\tif err := deleteShadowBranch(ctx, repo, shadowBranchName); err != nil {\\n   803→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to clean up %s: %v\\\\n\\\", shadowBranchName, err)\\n   804→\\t\\t} else {\\n   805→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Cleaned up shadow branch: %s\\\\n\\\", shadowBranchName)\\n   806→\\t\\t\\tlogging.Info(logCtx, \\\"shadow branch deleted\\\",\\n   807→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   808→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   809→\\t\\t\\t)\\n   810→\\t\\t}\\n   811→\\t}\\n   812→\\n   813→\\treturn nil\\n   814→}\\n   815→\\n   816→// postCommitProcessSession handles a single session within the PostCommit loop.\\n   817→// Pre-resolved git objects (headTree, parentTree) are shared across all sessions;\\n   818→// per-session shadow ref/tree are resolved once here and threaded through sub-calls.\\n   819→func (s *ManualCommitStrategy) postCommitProcessSession(\\n   820→\\tctx context.Context,\\n   821→\\trepo *git.Repository,\\n   822→\\tstate *SessionState,\\n   823→\\ttransitionCtx *session.TransitionContext,\\n   824→\\tcheckpointID id.CheckpointID,\\n   825→\\thead *plumbing.Reference,\\n   826→\\tcommit *object.Commit,\\n   827→\\tnewHead string,\\n   828→\\theadTree, parentTree *object.Tree,\\n   829→\\tcommittedFileSet map[string]struct{},\\n   830→\\tshadowBranchesToDelete map[string]struct{},\\n   831→\\tuncondensedActiveOnBranch map[string]bool,\\n   832→) {\\n   833→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   834→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   835→\\n   836→\\t// Pre-resolve shadow branch ref and tree for this session.\\n   837→\\t// These are read 4+ times across sessionHasNewContent, filesOverlapWithContent,\\n   838→\\t// CondenseSession, filesWithRemainingAgentChanges, and calculateSessionAttributions.\\n   839→\\tvar shadowRef *plumbing.Reference\\n   840→\\tvar shadowTree *object.Tree\\n   841→\\tif ref, refErr := repo.Reference(plumbing.NewBranchReferenceName(shadowBranchName), true); refErr == nil {\\n   842→\\t\\tshadowRef = ref\\n   843→\\t\\tif sc, scErr := repo.CommitObject(ref.Hash()); scErr == nil {\\n   844→\\t\\t\\tif st, stErr := sc.Tree(); stErr == nil {\\n   845→\\t\\t\\t\\tshadowTree = st\\n   846→\\t\\t\\t}\\n   847→\\t\\t}\\n   848→\\t}\\n   849→\\n   850→\\t// Check for new content (needed for TransitionContext and condensation).\\n   851→\\t// Fail-open: if content check errors, assume new content exists so we\\n   852→\\t// don't silently skip data that should have been condensed.\\n   853→\\t//\\n   854→\\t// For ACTIVE sessions: the commit has a checkpoint trailer (verified above),\\n   855→\\t// meaning PrepareCommitMsg already determined this commit is session-related.\\n   856→\\t// The trailer is only added when either:\\n   857→\\t//   - No TTY (agent/subagent committing) — added unconditionally\\n   858→\\t//   - TTY (human committing) — added after content detection confirmed agent work\\n   859→\\t// In both cases, PrepareCommitMsg already validated this commit. We trust\\n   860→\\t// that decision here. Transcript-based re-validation is unreliable because\\n   861→\\t// subagent transcripts may not be available yet (subagent still running).\\n   862→\\tvar hasNew bool\\n   863→\\tif state.Phase.IsActive() {\\n   864→\\t\\thasNew = true\\n   865→\\t} else {\\n   866→\\t\\tvar contentErr error\\n   867→\\t\\thasNew, contentErr = s.sessionHasNewContent(ctx, repo, state, shadowTree)\\n   868→\\t\\tif contentErr != nil {\\n   869→\\t\\t\\thasNew = true\\n   870→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: error checking session content, assuming new content\\\",\\n   871→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   872→\\t\\t\\t\\tslog.String(\\\"error\\\", contentErr.Error()),\\n   873→\\t\\t\\t)\\n   874→\\t\\t}\\n   875→\\t}\\n   876→\\ttransitionCtx.HasFilesTouched = len(state.FilesTouched) > 0\\n   877→\\n   878→\\t// Save FilesTouched BEFORE TransitionAndLog — the handler's condensation\\n   879→\\t// clears it, but we need the original list for carry-forward computation.\\n   880→\\t// For mid-session commits (ACTIVE, no shadow branch), state.FilesTouched may be empty\\n   881→\\t// because no SaveStep/Stop has been called yet. Extract files from transcript.\\n   882→\\tfilesTouchedBefore := make([]string, len(state.FilesTouched))\\n   883→\\tcopy(filesTouchedBefore, state.FilesTouched)\\n   884→\\tif len(filesTouchedBefore) == 0 && state.Phase.IsActive() && state.TranscriptPath != \\\"\\\" {\\n   885→\\t\\tfilesTouchedBefore = s.extractFilesFromLiveTranscript(ctx, state)\\n   886→\\t}\\n   887→\\n   888→\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward prep\\\",\\n   889→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   890→\\t\\tslog.Bool(\\\"is_active\\\", state.Phase.IsActive()),\\n   891→\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n   892→\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   893→\\t\\tslog.Any(\\\"files\\\", filesTouchedBefore),\\n   894→\\t)\\n   895→\\n   896→\\t// Run the state machine transition with handler for strategy-specific actions.\\n   897→\\thandler := &postCommitActionHandler{\\n   898→\\t\\ts:                      s,\\n   899→\\t\\tctx:                    ctx,\\n   900→\\t\\trepo:                   repo,\\n   901→\\t\\tcheckpointID:           checkpointID,\\n   902→\\t\\thead:                   head,\\n   903→\\t\\tcommit:                 commit,\\n   904→\\t\\tnewHead:                newHead,\\n   905→\\t\\tshadowBranchName:       shadowBranchName,\\n   906→\\t\\tshadowBranchesToDelete: shadowBranchesToDelete,\\n   907→\\t\\tcommittedFileSet:       committedFileSet,\\n   908→\\t\\thasNew:                 hasNew,\\n   909→\\t\\tfilesTouchedBefore:     filesTouchedBefore,\\n   910→\\t\\theadTree:               headTree,\\n   911→\\t\\tparentTree:             parentTree,\\n   912→\\t\\tshadowRef:              shadowRef,\\n   913→\\t\\tshadowTree:             shadowTree,\\n   914→\\t}\\n   915→\\n   916→\\tif err := TransitionAndLog(ctx, state, session.EventGitCommit, *transitionCtx, handler); err != nil {\\n   917→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: post-commit action handler error: %v\\\\n\\\", err)\\n   918→\\t}\\n   919→\\n   920→\\t// Record checkpoint ID for ACTIVE sessions so HandleTurnEnd can finalize\\n   921→\\t// with full transcript. IDLE/ENDED sessions already have complete transcripts.\\n   922→\\t// NOTE: This check runs AFTER TransitionAndLog updated the phase. It relies on\\n   923→\\t// ACTIVE + GitCommit → ACTIVE (phase stays ACTIVE). If that state machine\\n   924→\\t// transition ever changed, this guard would silently stop recording IDs.\\n   925→\\tif handler.condensed && state.Phase.IsActive() {\\n   926→\\t\\tstate.TurnCheckpointIDs = append(state.TurnCheckpointIDs, checkpointID.String())\\n   927→\\t}\\n   928→\\n   929→\\t// Carry forward remaining uncommitted files so the next commit gets its\\n   930→\\t// own checkpoint ID. This applies to ALL phases — if a user splits their\\n   931→\\t// commit across two `git commit` invocations, each gets a 1:1 checkpoint.\\n   932→\\t// Uses content-aware comparison: if user did `git add -p` and committed\\n   933→\\t// partial changes, the file still has remaining agent changes to carry forward.\\n   934→\\tif handler.condensed {\\n   935→\\t\\tremainingFiles := filesWithRemainingAgentChanges(ctx, repo, shadowBranchName, commit, filesTouchedBefore, committedFileSet, overlapOpts{\\n   936→\\t\\t\\theadTree:   headTree,\\n   937→\\t\\t\\tshadowTree: shadowTree,\\n   938→\\t\\t})\\n   939→\\t\\tstate.FilesTouched = remainingFiles\\n   940→\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward decision (content-aware)\\\",\\n   941→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   942→\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   943→\\t\\t\\tslog.Int(\\\"committed_files\\\", len(committedFileSet)),\\n   944→\\t\\t\\tslog.Int(\\\"remaining_files\\\", len(remainingFiles)),\\n   945→\\t\\t\\tslog.Any(\\\"remaining\\\", remainingFiles),\\n   946→\\t\\t\\tslog.Any(\\\"committed_files\\\", committedFileSet),\\n   947→\\t\\t)\\n   948→\\t\\tif len(remainingFiles) > 0 {\\n   949→\\t\\t\\ts.carryForwardToNewShadowBranch(ctx, repo, state, remainingFiles)\\n   950→\\t\\t}\\n   951→\\t}\\n   952→\\n   953→\\t// Save the updated state\\n   954→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   955→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to update session state: %v\\\\n\\\", err)\\n   956→\\t}\\n   957→\\n   958→\\t// Only preserve shadow branch for active sessions that were NOT condensed.\\n   959→\\t// Condensed sessions already have their data on entire/checkpoints/v1.\\n   960→\\tif state.Phase.IsActive() && !handler.condensed {\\n   961→\\t\\tuncondensedActiveOnBranch[shadowBranchName] = true\\n   962→\\t}\\n   963→}\\n   964→\\n   965→// condenseAndUpdateState runs condensation for a session and updates state afterward.\\n   966→// Returns true if condensation succeeded.\\n   967→func (s *ManualCommitStrategy) condenseAndUpdateState(\\n   968→\\tctx context.Context,\\n   969→\\trepo *git.Repository,\\n   970→\\tcheckpointID id.CheckpointID,\\n   971→\\tstate *SessionState,\\n   972→\\thead *plumbing.Reference,\\n   973→\\tshadowBranchName string,\\n   974→\\tshadowBranchesToDelete map[string]struct{},\\n   975→\\tcommittedFiles map[string]struct{},\\n   976→\\topts ...condenseOpts,\\n   977→) bool {\\n   978→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   979→\\tresult, err := s.CondenseSession(ctx, repo, checkpointID, state, committedFiles, opts...)\\n   980→\\tif err != nil {\\n   981→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: condensation failed for session %s: %v\\\\n\\\",\\n   982→\\t\\t\\tstate.SessionID, err)\\n   983→\\t\\tlogging.Warn(logCtx, \\\"post-commit: condensation failed\\\",\\n   984→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   985→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   986→\\t\\t)\\n   987→\\t\\treturn false\\n   988→\\t}\\n   989→\\n   990→\\t// Track this shadow branch for cleanup\\n   991→\\tshadowBranchesToDelete[shadowBranchName] = struct{}{}\\n   992→\\n   993→\\t// Update session state for the new base commit\\n