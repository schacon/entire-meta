adata branch.\\n    33→// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\n    34→func (s *ManualCommitStrategy) listCheckpoints(ctx context.Context) ([]CheckpointInfo, error) {\\n    35→\\tstore, err := s.getCheckpointStore()\\n    36→\\tif err != nil {\\n    37→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    38→\\t}\\n    39→\\n    40→\\tcommitted, err := store.ListCommitted(ctx)\\n    41→\\tif err != nil {\\n    42→\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n    43→\\t}\\n    44→\\n    45→\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n    46→\\tresult := make([]CheckpointInfo, 0, len(committed))\\n    47→\\tfor _, c := range committed {\\n    48→\\t\\tresult = append(result, CheckpointInfo{\\n    49→\\t\\t\\tCheckpointID:     c.CheckpointID,\\n    50→\\t\\t\\tSessionID:        c.SessionID,\\n    51→\\t\\t\\tCreatedAt:        c.CreatedAt,\\n    52→\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n    53→\\t\\t\\tFilesTouched:     c.FilesTouched,\\n    54→\\t\\t\\tAgent:            c.Agent,\\n    55→\\t\\t\\tIsTask:           c.IsTask,\\n    56→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    57→\\t\\t\\tSessionCount:     c.SessionCount,\\n    58→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    59→\\t\\t})\\n    60→\\t}\\n    61→\\n    62→\\treturn result, nil\\n    63→}\\n    64→\\n    65→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    66→func (s *ManualCommitStrategy) getCheckpointsForSession(ctx context.Context, sessionID string) ([]CheckpointInfo, error) {\\n    67→\\tall, err := s.listCheckpoints(ctx)\\n    68→\\tif err != nil {\\n    69→\\t\\treturn nil, err\\n    70→\\t}\\n    71→\\n    72→\\tvar result []CheckpointInfo\\n    73→\\tfor _, cp := range all {\\n    74→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    75→\\t\\t\\tresult = append(result, cp)\\n    76→