s\\n   319→\\tif len(opts) > 0 {\\n   320→\\t\\to = opts[0]\\n   321→\\t}\\n   322→\\n   323→\\theadTree := o.headTree\\n   324→\\tif headTree == nil {\\n   325→\\t\\theadRef, headErr := repo.Head()\\n   326→\\t\\tif headErr != nil {\\n   327→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   328→\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   329→\\t\\t\\treturn nil\\n   330→\\t\\t}\\n   331→\\n   332→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   333→\\t\\tif commitErr != nil {\\n   334→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   335→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   336→\\t\\t\\treturn nil\\n   337→\\t\\t}\\n   338→\\n   339→\\t\\tvar treeErr error\\n   340→\\t\\theadTree, treeErr = headCommit.Tree()\\n   341→\\t\\tif treeErr != nil {\\n   342→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   343→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   344→\\t\\t\\treturn nil\\n   345→\\t\\t}\\n   346→\\t}\\n   347→\\n   348→\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n   349→\\tshadowTree := o.shadowTree\\n   350→\\tif shadowTree == nil {\\n   351→\\t\\tif shadowRef != nil {\\n   352→\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   353→\\t\\t\\tif shadowErr != nil {\\n   354→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   355→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   356→\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   357→\\t\\t\\t\\treturn nil\\n   358→\\t\\t\\t}\\n   359→\\t\\t\\tvar shadowTreeErr error\\n   360→\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   361→\\t\\t\\tif shadowTreeErr != nil {\\n   362→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: faile