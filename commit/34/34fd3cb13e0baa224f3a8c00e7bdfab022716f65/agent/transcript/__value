 29→func (c *ClaudeCodeAgent) HookNames() []string {\\n    30→\\treturn []string{\\n    31→\\t\\tHookNameSessionStart,\\n    32→\\t\\tHookNameSessionEnd,\\n    33→\\t\\tHookNameStop,\\n    34→\\t\\tHookNameUserPromptSubmit,\\n    35→\\t\\tHookNamePreTask,\\n    36→\\t\\tHookNamePostTask,\\n    37→\\t\\tHookNamePostTodo,\\n    38→\\t}\\n    39→}\\n    40→\\n    41→// ParseHookEvent translates a Claude Code hook into a normalized lifecycle Event.\\n    42→// Returns nil if the hook has no lifecycle significance.\\n    43→func (c *ClaudeCodeAgent) ParseHookEvent(_ context.Context, hookName string, stdin io.Reader) (*agent.Event, error) {\\n    44→\\tswitch hookName {\\n    45→\\tcase HookNameSessionStart:\\n    46→\\t\\treturn c.parseSessionStart(stdin)\\n    47→\\tcase HookNameUserPromptSubmit:\\n    48→\\t\\treturn c.parseTurnStart(stdin)\\n    49→\\tcase HookNameStop:\\n    50→\\t\\treturn c.parseTurnEnd(stdin)\\n    51→\\tcase HookNameSessionEnd:\\n    52→\\t\\treturn c.parseSessionEnd(stdin)\\n    53→\\tcase HookNamePreTask:\\n    54→\\t\\treturn c.parseSubagentStart(stdin)\\n    55→\\tcase HookNamePostTask:\\n    56→\\t\\treturn c.parseSubagentEnd(stdin)\\n    57→\\tcase HookNamePostTodo:\\n    58→\\t\\t// PostTodo is Claude-specific; handled outside the generic dispatcher.\\n    59→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    60→\\tdefault:\\n    61→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    62→\\t}\\n    63→}\\n    64→\\n    65→// ReadTranscript reads the raw JSONL transcript bytes for a session.\\n    66→func (c *ClaudeCodeAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    67→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n    68→\\tif err != nil {\\n    69→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    70→\\t}\\n    71→\\treturn data, nil\\n    72→}\\n    73→\\n    74→// ExtractPrompts extracts