02→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   403→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   404→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   405→\\t}\\n   406→\\n   407→\\tattribution := CalculateAttributionWithAccumulated(\\n   408→\\t\\tctx,\\n   409→\\t\\tbaseTree,\\n   410→\\t\\tshadowTree,\\n   411→\\t\\theadTree,\\n   412→\\t\\tsessionData.FilesTouched,\\n   413→\\t\\tstate.PromptAttributions,\\n   414→\\t)\\n   415→\\n   416→\\tif attribution != nil {\\n   417→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   418→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   419→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   420→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   421→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   422→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   423→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   424→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   425→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   426→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   427→\\t}\\n   428→\\n   429→\\treturn attribution\\n   430→}\\n   431→\\n   432→// extractSessionData extracts session data from the shadow branch.\\n   433→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   434→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   435→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   436→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   437→// continued growing — the shadow branch copy would be stale.\\n   438→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   439→func (s *ManualCommitStrategy) extractSessionData(ctx context.Context, repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType types.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n   440→\\tag, _ := agent.GetByAgentType(agentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   441→\\tcommit, err := repo.CommitObject(shadowRef)\\n   442→\\tif err != nil {\\n   443→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   444→\\t}\\n   445→\\n   446→\\ttree, err := commit.Tree()\\n   447→\\tif err != nil {\\n   448→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   449→\\t}\\n   450→\\n   451→\\tdata := &ExtractedSessionData{}\\n   452→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   453→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   454→\\n   455→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   456→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   457→\\t// (SaveStep is only called when there are file modifications).\\n   458→\\tvar fullTranscript string\\n   459→\\tif liveTranscriptPath != \\\"\\\" {\\n   460→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   461→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   462→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   463→\\t\\tif isActive {\\n   464→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, liveTranscriptPath)\\n   465→\\t\\t}\\n   466→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   467→\\t\\t\\tfullTranscript = string(liveData)\\n   468→\\t\\t}\\n   469→\\t}\\n   470→\\tif fullTranscript == \\\"\\\" {\\n   471→\\t\\t// Fall back to shadow branch copy\\n   472→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   473→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   474→\\t\\t\\t\\tfullTranscript = content\\n   475→\\t\\t\\t}\\n   476→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   477→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   478→\\t\\t\\t\\tfullTranscript = content\\n   479→\\t\\t\\t}\\n   480→\\t\\t}\\n   481→\\t}\\n   482→\\n   483→\\t// Process transcript based on agent type\\n   484→\\tif fullTranscript != \\\"\\\" {\\n   485→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   486→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   487→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   488→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   489→\\t}\\n   490→\\n   491→\\t// Use tracked files from session state (not all files in tree)\\n   492→\\tdata.FilesTouched = filesTouched\\n   493→\\n   494→\\t// Calculate token usage from the extracted transcript portion\\n   495→\\tif len(data.Transcript) > 0 {\\n   496→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, checkpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   497→\\t}\\n   498→\\n   499→\\treturn data, nil\\n   500→}\\n   501→\\n   502→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   503→// This is used for mid-session commits where no shadow branch exists yet.\\n   504→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(ctx context.Context, state *SessionState) (*ExtractedSessionData, error) {\\n   505→\\tdata := &ExtractedSessionData{}\\n   506→\\n   507→\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   508→\\n   509→\\t// Read the live transcript\\n   510→\\tif state.TranscriptPath == \\\"\\\" {\\n   511→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   512→\\t}\\n   513→\\n   514→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   515→\\tif err != nil {\\n   516→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   517→\\t}\\n   518→\\n   519→\\tif len(liveData) == 0 {\\n   520→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   521→\\t}\\n   522→\\n   523→\\tfullTranscript := string(liveData)\\n   524→\\tdata.Transcript = liveData\\n   525→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   526→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   527→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   528→\\n   529→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   530→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   531→\\tif len(state.FilesTouched) > 0 {\\n   532→\\t\\tdata.FilesTouched = state.FilesTouched\\n   533→\\t} else {\\n   534→\\t\\t// Use the shared helper which includes subagent transcripts\\n   535→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(ctx, state, state.CheckpointTranscriptStart)\\n   536→\\t}\\n   537→\\n   538→\\t// Calculate token usage from the extracted transcript portion\\n   539→\\tif len(data.Transcript) > 0 {\\n   540→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, state.CheckpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   541→\\t}\\n   542→\\n   543→\\treturn data, nil\\n   544→}\\n   545→\\n   546→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   547→// For Claude Code and JSONL-based agents, this counts lines.\\n   548→// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n   549→// Returns 0 if the content is empty or malformed.\\n   550→func countTranscriptItems(agentType types.AgentType, content string) int {\\n   551→\\tif content == \\\"\\\" {\\n   552→\\t\\treturn 0\\n   553→\\t}\\n   554→\\n   555→\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n   556→\\tif agentType == agent.AgentTypeOpenCode {\\n   557→\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n   558→\\t\\tif err == nil && session != nil {\\n   559→\\t\\t\\treturn len(session.Messages)\\n   560→\\t\\t}\\n   561→\\t\\treturn 0\\n   562→\\t}\\n   563→\\n   564→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   565→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   566→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   567→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   568→\\t\\t\\treturn len(transcript.Messages)\\n   569→\\t\\t}\\n   570→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   571→\\t\\tif agentType == agent.AgentTypeGemini {\\n   572→\\t\\t\\treturn 0\\n   573→\\t\\t}\\n   574→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   575→\\t}\\n   576→\\n   577→\\t// Claude Code and other JSONL-based agents\\n   578→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   579→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   580→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   581→\\t\\tallLines = allLines[:len(allLines)-1]\\n   582→\\t}\\n   583→\\treturn len(allLines)\\n   584→}\\n   585→\\n   586→// extractUserPrompts extracts all user prompts from transcript content.\\n   587→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   588→func extractUserPrompts(agentType types.AgentType, content string) []string {\\n   589→\\tif content == \\\"\\\" {\\n   590→\\t\\treturn nil\\n   591→\\t}\\n   592→\\n   593→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   594→\\tif agentType == agent.AgentTypeOpenCode {\\n   595→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   596→\\t\\tif err == nil && len(prompts) > 0 {\\n   597→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   598→\\t\\t\\tfor _, prompt := range prompts {\\n   599→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   600→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   601→\\t\\t\\t\\t}\\n   602→\\t\\t\\t}\\n   603→\\t\\t\\treturn cleaned\\n   604→\\t\\t}\\n   605→\\t\\treturn nil\\n   606→\\t}\\n   607→\\n   608→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   609→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   610→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   611→\\t\\tif err == nil && len(prompts) > 0 {\\n   612→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   613→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   614→\\t\\t\\tfor _, prompt := range prompts {\\n   615→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   616→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   617→\\t\\t\\t\\t}\\n   618→\\t\\t\\t}\\n   619→\\t\\t\\treturn cleaned\\n   620→\\t\\t}\\n   621→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   622→\\t\\tif agentType == agent.AgentTypeGemini {\\n   623→\\t\\t\\treturn nil\\n   624→\\t\\t}\\n   625→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   626→\\t}\\n   627→\\n   628→\\t// Claude Code and other JSONL-based agents\\n   629→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   630→}\\n   631→\\n   632→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   633→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   634→func extractUserPromptsFromLines(lines []string) []string {\\n   635→\\tvar prompts []string\\n   636→\\tfor _, line := range lines {\\n   637→\\t\\tline = strings.TrimSpace(line)\\n   638→\\t\\tif line == \\\"\\\" {\\n   639→\\t\\t\\tcontinue\\n   640→\\t\\t}\\n   641→\\n   642→\\t\\tvar entry map[string]interface{}\\n   643→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   644→\\t\\t\\tcontinue\\n   645→\\t\\t}\\n   646→\\n   647→\\t\\t// Check for user message:\\n   648→\\t\\t// - Claude Code uses \\\"type\\\": \\\"human\\\" or \\\"type\\\": \\\"user\\\"\\n   649→\\t\\t// - Cursor uses \\\"role\\\": \\\"user\\\"\\n   650→\\t\\tmsgType, _ := entry[\\\"type\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   651→\\t\\tmsgRole, _ := entry[\\\"role\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   652→\\t\\tisUser := msgType == \\\"human\\\" || msgType == \\\"user\\\" || msgRole == \\\"user\\\"\\n   653→\\t\\tif !isUser {\\n   654→\\t\\t\\tcontinue\\n   655→\\t\\t}\\n   656→\\n   657→\\t\\t// Extract message content\\n   658→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   659→\\t\\tif !ok {\\n   660→\\t\\t\\tcontinue\\n   661→\\t\\t}\\n   662→\\n   663→\\t\\t// Handle string content\\n   664→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   665→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   666→\\t\\t\\tif cleaned != \\\"\\\" {\\n   667→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   668→\\t\\t\\t}\\n   669→\\t\\t\\tcontinue\\n   670→\\t\\t}\\n   671→\\n   672→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   673→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   674→\\t\\t\\tvar texts []string\\n   675→\\t\\t\\tfor _, item := range arr {\\n   676→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   677→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   678→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   679→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   680→\\t\\t\\t\\t\\t\\t}\\n   681→\\t\\t\\t\\t\\t}\\n   682→\\t\\t\\t\\t}\\n   683→\\t\\t\\t}\\n   684→\\t\\t\\tif len(texts) > 0 {\\n   685→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   686→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   687→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   688→\\t\\t\\t\\t}\\n   689→\\t\\t\\t}\\n   690→\\t\\t}\\n   691→\\t}\\n   692→\\treturn prompts\\n   693→}\\n   694→\\n   695→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   696→func generateContextFromPrompts(prompts []string) []byte {\\n   697→\\tif len(prompts) == 0 {\\n   698→\\t\\treturn nil\\n   699→\\t}\\n   700→\\n   701→\\tvar buf strings.Builder\\n   702→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   703→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   704→\\n   705→\\tfor i, prompt := range prompts {\\n   706→\\t\\t// Truncate very long prompts for readability.\\n   707→\\t\\t// Use rune-based truncation to avoid splitting multi-byte UTF-8 characters (e.g. CJK).\\n   708→\\t\\tconst maxDisplayPromptRunes = 500\\n   709→\\t\\tdisplayPrompt := stringutil.TruncateRunes(prompt, maxDisplayPromptRunes, \\\"...\\\")\\n   710→\\t\\tfmt.Fprintf(&buf, \\\"### Prompt %d\\\\n\\\\n\\\", i+1)\\n   711→\\t\\tbuf.WriteString(displayPrompt)\\n   712→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   713→\\t}\\n   714→\\n   715→\\treturn []byte(buf.String())\\n   716→}\\n 