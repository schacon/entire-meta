hadow branch.\\n    32→//   If content differs completely, the session's work was likely reverted & replaced.\\n    33→\\n    34→// overlapOpts provides pre-resolved git objects to avoid redundant reads.\\n    35→// When fields are non-nil, they are used directly instead of reading from the repo.\\n    36→type overlapOpts struct {\\n    37→\\theadTree      *object.Tree // HEAD commit tree\\n    38→\\tshadowTree    *object.Tree // Shadow branch tree\\n    39→\\tparentTree    *object.Tree // HEAD's first parent tree (nil = initial commit or not provided)\\n    40→\\thasParentTree bool         // True if parentTree was explicitly resolved (distinguishes nil-not-resolved from nil-initial-commit)\\n    41→}\\n    42→\\n    43→// filesOverlapWithContent checks if any file in filesTouched overlaps with the committed\\n    44→// content, using content-aware comparison to detect the \\\"reverted and replaced\\\" scenario.\\n    45→//\\n    46→// This is used in PostCommit to determine if a session has work in the commit.\\n    47→func filesOverlapWithContent(ctx context.Context, repo *git.Repository, shadowBranchName string, headCommit *object.Commit, filesTouched []string, opts ...overlapOpts) bool {\\n    48→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n    49→\\n    50→\\t// Use pre-resolved trees if provided, otherwise resolve from repo.\\n    51→\\tvar o overlapOpts\\n    52→\\tif len(opts) > 0 {\\n    53→\\t\\to = opts[0]\\n    54→\\t}\\n    55→\\n    56→\\theadTree := o.headTree\\n    57→\\tif headTree == nil {\\n    58→\\t\\tvar err error\\n    59→\\t\\theadTree, err = headCommit.Tree()\\n    60→\\t\\tif err != nil {\\n    61→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: failed to get HEAD tree, falling back to filename check\\\",\\n    62→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    63→\\t\\t\\t)\\n    64→\\t\\t\\treturn len(filesTouched) > 0\\n    65→\\t\\t}\\n    66→\\t}\\n    67→\\n    68→\\tshadowTree := o.shadowTree\\n    69→\\tif shadowTree == nil {\\n    70→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n    71→\\t\\tshadowRef, err := repo.Reference(refName, true)\\n    72→\\t\\tif err != nil {\\n    73→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: shadow branch not found, falling back to filename check\\\",\\n    74→\\t\\t\\t\\tslog.String(\\\"branch\\\", shadowBranchName),\\n    75→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    76→\\t\\t\\t)\\n    77→\\t\\t\\treturn len(filesTouched) > 0\\n    78→\\t\\t}\\n    79→\\n    80→\\t\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n    81→\\t\\tif err != nil {\\n    82→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: failed to get shadow commit, falling back to filename check\\\",\\n    83→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    84→\\t\\t\\t)\\n    85→\\t\\t\\treturn len(filesTouched) > 0\\n    86→\\t\\t}\\n    87→\\n    88→\\t\\tshadowTree, err = shadowCommit.Tree()\\n    89→\\t\\tif err != nil {\\n    90→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: failed to get shadow tree, falling back to filename check\\\",\\n    91→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    92→\\t\\t\\t)\\n    93→\\t\\t\\treturn len(filesTouched) > 0\\n    94→\\t\\t}\\n    95→\\t}\\n    96→\\n    97→\\tparentTree := o.parentTree\\n    98→\\tif parentTree == nil && !o.hasParentTree {\\n    99→\\t\\tif headCommit.NumParents() > 0 {\\n   100→\\t\\t\\tif parent, err := headCommit.Parent(0); err == nil {\\n   101→\\t\\t\\t\\tif pTree, err := parent.Tree(); err == nil {\\n   102→\\t\\t\\t\\t\\tparentTree = pTree\\n   103→\\t\\t\\t\\t}\\n   104→\\t\\t\\t}\\n   105→\\t\\t}\\n   106→\\t}\\n   107→\\n   108→\\t// Check each file in filesTouched\\n   109→\\tfor _, filePath := range filesTouched {\\n   110→\\t\\t// Get file from HEAD tree (the committed content)\\n   111→\\t\\theadFile, err := headTree.File(filePath)\\n   112→\\t\\tif err != nil {\\n   