nscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1368→\\t\\treturn nil\\n  1369→\\t}\\n  1370→\\n  1371→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1372→\\tif err != nil {\\n  1373→\\t\\treturn nil\\n  1374→\\t}\\n  1375→\\n  1376→\\t// Ensure transcript file is up-to-date (OpenCode creates/refreshes it via `opencode export`).\\n  1377→\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n  1378→\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n  1379→\\tif state.Phase.IsActive() {\\n  1380→\\t\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n  1381→\\t\\t\\tif prepErr := preparer.PrepareTranscript(ctx, state.TranscriptPath); prepErr != nil {\\n  1382→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prepare transcript failed\\\",\\n  1383→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1384→\\t\\t\\t\\t\\tslog.String(\\\"agent_type\\\", string(state.AgentType)),\\n  1385→\\t\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1386→\\t\\t\\t\\t\\tslog.Any(\\\"error\\\", prepErr),\\n  1387→\\t\\t\\t\\t)\\n  1388→\\t\\t\\t}\\n  1389→\\t\\t}\\n  1390→\\t}\\n  1391→\\n  1392→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1393→\\tif !ok {\\n  1394→\\t\\treturn nil\\n  1395→\\t}\\n  1396→\\n  1397→\\tvar modifiedFiles []string\\n  1398→\\n  1399→\\t// For Claude Code, use ExtractAllModifiedFiles which parses the main transcript\\n  1400→\\t// AND subagent transcripts in a single pass, avoiding redundant parsing.\\n  1401→\\tif state.AgentType == agent.AgentTypeClaudeCode {\\n  1402→\\t\\tsubagentsDir := filepath.Join(filepath.Dir(state.TranscriptPath), state.SessionID, \\\"subagents\\\")\\n  1403→\\t\\ttranscriptData, readErr := os.ReadFile(state.TranscriptPath)\\n  1404→\\t\\tif readErr != nil {\\n  1405→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: failed to read transcript\\\",\\n  1406→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1407→\\t\\t\\t\\tslog.String(\\\"error\\\", readErr.Error()),\\n  1408→\\t\\t\\t)\\n  1409→\\t\\t} else {\\n  1410→\\t\\t\\t// TODO: fix when we refactor this area.\\n  1411→\\t\\t\\t// rather than instantiating claude specifically, we should iterate agents.\\n  1412→\\t\\t\\tc := &claudecode.ClaudeCodeAgent{}\\n  1413→\\t\\t\\tallFiles, extractErr := c.ExtractAllModifiedFiles(transcriptData, offset, subagentsDir)\\n  1414→\\t\\t\\tif extractErr != nil {\\n  1415→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: extraction failed\\\",\\n  1416→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1417→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", extractErr.Error()),\\n  1418→\\t\\t\\t\\t)\\n  1419→\\t\\t\\t} else {\\n  1420→\\t\\t\\t\\tmodifiedFiles = allFiles\\n  1421→\\t\\t\\t}\\n  1422→\\t\\t}\\n  1423→\\t} else {\\n  1424→\\t\\tfiles, _, err := analyzer.ExtractModifiedFilesFromOffset(state.TranscriptPath, offset)\\n  1425→\\t\\tif err != nil {\\n  1426→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: main transcript extraction failed\\\",\\n  1427→\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1428→\\t\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1429→\\t\\t\\t)\\n  1430→\\t\\t} else {\\n  1431→\\t\\t\\tmodifiedFiles = files\\n  1432→\\t\\t}\\n  1433→\\t}\\n  1434→\\n  1435→\\tif len(modifiedFiles) == 0 {\\n  1436→\\t\\treturn nil\\n  1437→\\t}\\n  1438→\\n  1439→\\t// Normalize to repo-relative paths.\\n  1440→\\t// Transcript tool_use entries contain absolute paths (e.g., /Users/alex/project/src/main.go)\\n  1441→\\t// but getStagedFiles/committedFiles use repo-relative paths (e.g., src/main.go).\\n  1442→\\tbasePath := state.WorktreePath\\n  1443→\\tif basePath == \\\"\\\" {\\n  1444→\\t\\tif wp, wpErr := paths.WorktreeRoot(ctx); wpErr == nil {\\n  1445→\\t\\t\\tbasePath = wp\\n  1446→\\t\\t}\\n  1447→\\t}\\n  1448→\\tif basePath != \\\"\\\" {\\n  1449→\\t\\tnormalized := make([]string, 0, len(modifiedFiles))\\n  1450→\\t\\tfor _, f := range modifiedFiles {\\n  1451→\\t\\t\\tif rel := paths.ToRelativePath(f, basePath); rel != \\\"\\\" {\\n  1452→\\t\\t\\t\\tnormalized = append(normalized, rel)\\n  1453→\\t\\t\\t} else {\\n  1454→\\t\\t\\t\\tnormalized = append(normalized, f)\\n  1455→\\t\\t\\t}\\n  1456→\\t\\t}\\n  1457→\\t\\tmodifiedFiles = normalized\\n  1458→\\t}\\n  1459→\\n  1460→\\treturn modifiedFiles\\n  1461→}\\n  1462→\\n  1463→// addTrailerForAgentCommit handles the fast path when an agent is committing\\n  1464→// (ACTIVE session + no TTY). Generates a checkpoint ID and adds the trailer\\n  1465→// directly, bypassing content detection and interactive prompts.\\n  1466→func (s *ManualCommitStrategy) addTrailerForAgentCommit(logCtx context.Context, commitMsgFile string, state *SessionState, source string) error {\\n  1467→\\tcpID, err := id.Generate()\\n  1468→\\tif err != nil {\\n  1469→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1470→\\t}\\n  1471→\\n  1472→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n  1473→\\tif err != nil {\\n  1474→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1475→\\t}\\n  1476→\\n  1477→\\tmessage := string(content)\\n  1478→\\n  1479→\\t// Don't add if trailer already exists\\n  1480→\\tif _, found := trailers.ParseCheckpoint(message); found {\\n  1481→\\t\\treturn nil\\n  1482→\\t}\\n  1483→\\n  1484→\\tmessage = addCheckpointTrailer(message, cpID)\\n  1485→\\n  1486→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: agent commit trailer added\\\",\\n  1487→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n  1488→\\t\\tslog.String(\\\"source\\\", source),\\n  1489→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n  1490→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1491→\\t)\\n  1492→\\n  1493→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n  1494→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1495→\\t}\\n  1496→\\treturn nil\\n  1497→}\\n  1498→\\n  1499→// addCheckpointTrailer adds the Entire-Checkpoint trailer to a commit message.\\n  1500→// Handles proper trailer formatting (blank line before trailers if needed).\\n  1501→func addCheckpointTrailer(message string, checkpointID id.CheckpointID) string {\\n  1502→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1503→\\n  1504→\\t// If message already ends with trailers (lines starting with key:), just append\\n  1505→\\t// Otherwise, add a blank line first\\n  1506→\\tlines := strings.Split(strings.TrimRight(message, \\\"\\\\n\\\"), \\\"\\\\n\\\")\\n  1507→\\n  1508→\\t// Check if the message already ends with a trailer paragraph.\\n  1509→\\t// Git trailers must be in a separate paragraph (preceded by a blank line).\\n  1510→\\t// A single-paragraph message (e.g., just a subject line) cannot have trailers,\\n  1511→\\t// even if the subject contains \\\": \\\" (like conventional commits: \\\"docs: Add foo\\\").\\n  1512→\\t//\\n  1513→\\t// Scan from the bottom: find the last paragraph of non-comment content,\\n  1514→\\t// then check if it looks like trailers AND has a blank line above it.\\n  1515→\\thasTrailers := false\\n  1516→\\ti := len(lines) - 1\\n  1517→\\n  1518→\\t// Skip trailing comment lines\\n  1519→\\tfor i >= 0 && strings.HasPrefix(strings.TrimSpace(lines[i]), \\\"#\\\") {\\n  1520→\\t\\ti--\\n  1521→\\t}\\n  1522→\\n  1523→\\t// Check if the last non-comment line looks like a trailer\\n  1524→\\tif i >= 0 {\\n  1525→\\t\\tline := strings.TrimSpace(lines[i])\\n  1526→\\t\\tif line != \\\"\\\" && strings.Contains(line, \\\": \\\") {\\n  1527→\\t\\t\\t// Found a trailer-like line. Now scan upward past the trailer block\\n  1528→\\t\\t\\t// to verify there's a blank line (paragraph separator) above it.\\n  1529→\\t\\t\\tfor i > 0 {\\n  1530→\\t\\t\\t\\ti--\\n  1531→\\t\\t\\t\\tabove := strings.TrimSpace(lines[i])\\n  1532→\\t\\t\\t\\tif strings.HasPrefix(above, \\\"#\\\") {\\n  1533→\\t\\t\\t\\t\\tcontinue\\n  1534→\\t\\t\\t\\t}\\n  1535→\\t\\t\\t\\tif above == \\\"\\\" {\\n  1536→\\t\\t\\t\\t\\t// Blank line found above trailer block — real trailers\\n  1537→\\t\\t\\t\\t\\thasTrailers = true\\n  1538→\\t\\t\\t\\t\\tbreak\\n  1539→\\t\\t\\t\\t}\\n  1540→\\t\\t\\t\\tif !strings.Contains(above, \\\": \\\") {\\n  1541→\\t\\t\\t\\t\\t// Non-trailer, non-blank line — this is message body, not trailers\\n  1542→\\t\\t\\t\\t\\tbreak\\n  1543→\\t\\t\\t\\t}\\n  1544→\\t\\t\\t\\t// Another trailer-like line, keep scanning upward\\n  1545→\\t\\t\\t}\\n  1546→\\t\\t}\\n  1547→\\t}\\n  1548→\\n  1549→\\tif hasTrailers {\\n  1550→\\t\\t// Append trailer directly\\n  1551→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1552→\\t}\\n  1553→\\n  1554→\\t// Add blank line before trailer\\n  1555→\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1556→}\\n  1557→\\n  1558→// addCheckpointTrailerWithComment adds the Entire-Checkpoint trailer with an explanatory comment.\\n  1559→// The trailer is placed above the git comment block but below the user's message area,\\n  1560→// with a comment explaining that the user can remove it if they don't want to link the commit\\n  1561→// to the agent session. If prompt is non-empty, it's shown as context.\\n  1562→func addCheckpointTrailerWithComment(message string, checkpointID id.CheckpointID, agentName, prompt string) string {\\n  1563→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1564→\\tcommentLines := []string{\\n  1565→\\t\\t\\\"# Remove the Entire-Checkpoint trailer above if you don't want to link this commit to \\\" + agentName + \\\" session context.\\\",\\n  1566→\\t}\\n  1567→\\tif prompt != \\\"\\\" {\\n  1568→\\t\\tcommentLines = append(commentLines, \\\"# Last Prompt: \\\"+prompt)\\n  1569→\\t}\\n  1570→\\tcommentLines = append(commentLines, \\\"# The trailer will be added to your next commit based on this branch.\\\")\\n  1571→\\tcomment := strings.Join(commentLines, \\\"\\\\n\\\")\\n  1572→\\n  1573→\\tlines := strings.Split(message, \\\"\\\\n\\\")\\n  1574→\\n  1575→\\t// Find where the git comment block starts (first # line)\\n  1576→\\tcommentStart := -1\\n  1577→\\tfor i, line := range lines {\\n  1578→\\t\\tif strings.HasPrefix(line, \\\"#\\\") {\\n  1579→\\t\\t\\tcommentStart = i\\n  1580→\\t\\t\\tbreak\\n  1581→\\t\\t}\\n  1582→\\t}\\n  1583→\\n  1584→\\tif commentStart == -1 {\\n  1585→\\t\\t// No git comments, append trailer at the end\\n  1586→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\"\\n  1587→\\t}\\n  1588→\\n  1589→\\t// Split into user content and git comments\\n  1590→\\tuserContent := strings.Join(lines[:commentStart], \\\"\\\\n\\\")\\n  1591→\\tgitComments := strings.Join(lines[commentStart:], \\\"\\\\n\\\")\\n  1592→\\n  1593→\\t// Build result: user content, blank line, trailer, comment, blank line, git comments\\n  1594→\\tuserContent = strings.TrimRight(userContent, \\\"\\\\n\\\")\\n  1595→\\tif userContent == \\\"\\\" {\\n  1596→\\t\\t// No user content yet - leave space for them to type, then trailer\\n  1597→\\t\\t// Two newlines: first for user's message line, second for blank separator\\n  1598→\\t\\treturn \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1599→\\t}\\n  1600→\\treturn userContent + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1601→}\\n  1602→\\n  1603→// InitializeSession creates session state for a new session or updates an existing one.\\n  1604→// This implements the optional SessionInitializer interface.\\n  1605→// Called during UserPromptSubmit to allow git hooks to detect active sessions.\\n  1606→//\\n  1607→// If the session already exists and HEAD has moved (e.g., user committed), updates\\n  1608→// BaseCommit to the new HEAD so future checkpoints go to the correct shadow branch.\\n  1609→//\\n  1610→// If there's an existing shadow branch with commits from a different session ID,\\n  1611→// returns a SessionIDConflictError to prevent orphaning existing session work.\\n  1612→//\\n  1613→// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n  1614→// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n  1615→// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\n  1616→func (s *ManualCommitStrategy) InitializeSession(ctx context.Context, sessionID string, agentType types.AgentType, transcriptPath string, userPrompt string) error {\\n  1617→\\trepo, err := OpenRepository(ctx)\\n  1618→\\tif err != nil {\\n  1619→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n  1620→\\t}\\n  1621→\\n  1622→\\t// Check if session already exists\\n  1623→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n  1624→\\tif err != nil {\\n  1625→\\t\\treturn fmt.Errorf(\\\"failed to check session state: %w\\\", err)\\n  1626→\\t}\\n  1627→\\n  1628→\\tif state != nil && state.BaseCommit != \\\"\\\" {\\n  1629→\\t\\t// Session is fully initialized — apply phase transition for TurnStart.\\n  1630→\\t\\tif transErr := TransitionAndLog(ctx, state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1631→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1632→\\t\\t}\\n  1633→\\n  1634→\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n  1635→\\t\\tturnID, err := id.Generate()\\n  1636→\\t\\tif err != nil {\\n  1637→\\t\\t\\treturn fmt.Error