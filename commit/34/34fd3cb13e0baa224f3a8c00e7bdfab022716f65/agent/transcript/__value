github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n     9→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    10→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    11→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/versioninfo\\\"\\n    13→\\n    14→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    15→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    16→)\\n    17→\\n    18→// Shadow strategy session state methods.\\n    19→// Uses session.StateStore for persistence.\\n    20→\\n    21→// loadSessionState loads session state using the StateStore.\\n    22→func (s *ManualCommitStrategy) loadSessionState(ctx context.Context, sessionID string) (*SessionState, error) {\\n    23→\\tstore, err := s.getStateStore(ctx)\\n    24→\\tif err != nil {\\n    25→\\t\\treturn nil, err\\n    26→\\t}\\n    27→\\tstate, err := store.Load(ctx, sessionID)\\n    28→\\tif err != nil {\\n    29→\\t\\treturn nil, fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n    30→\\t}\\n    31→\\treturn state, nil\\n    32→}\\n    33→\\n    34→// saveSessionState saves session state using the StateStore.\\n    35→func (s *ManualCommitStrategy) saveSessionState(ctx context.Context, state *SessionState) error {\\n    36→\\tstore, err := s.getStateStore(ctx)\\n    37→\\tif err != nil {\\n    38→\\t\\treturn err\\n    39→\\t}\\n    40→\\tif err := store.Save(ctx, state); err != nil {\\n    41→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n    42→\\t}\\n    43→\\treturn nil\\n    44→}\\n    45→\\n    46→// clearSessionState clears session state using the StateStore.\\n    47→func (s *ManualCommitStrategy) clearSessionState(ctx context.Context, sessionID string) error {\\n    48→\\tstore, err := s.getStateStore(ctx)\\n    49→\\tif err != nil {\\n    50→\\t\\treturn err\\n    51→\\t}\\n    52→\\tif err := store.Clear(ctx, sessionID); err != nil {\\n    53→\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n    54→\\t}\\n    55→\\treturn nil\\n    56→}\\n    57→\\n    58→// listAllSessionStates returns all active session states.\\n    59→// It filters out orphaned sessions whose shadow branch no longer exists.\\n    60→func (s *ManualCommitStrategy) listAllSessionStates(ctx context.Context) ([]*SessionState, error) {\\n    61→\\tstore, err := s.getStateStore(ctx)\\n    62→\\tif err != nil {\\n    63→\\t\\treturn nil, fmt.Errorf(\\\"failed to get state store: %w\\\", err)\\n    64→\\t}\\n    65→\\n    66→\\tsessionStates, err := store.List(ctx)\\n    67→\\tif err != nil {\\n    68→\\t\\treturn nil, fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n    69→\\t}\\n    70→\\n    71→\\tif len(sessionStates) == 0 {\\n    72→\\t\\treturn nil, nil\\n    73→\\t}\\n    74→\\n    75→\\trepo, err := OpenRepository(ctx)\\n    76→\\tif err != nil {\\n    77→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n    78→\\t}\\n    79→\\n    80→\\tvar states []*SessionState\\n    81→\\tfor _, sessionState := range sessionStates {\\n    82→\\t\\tstate := sessionState\\n    83→\\n    84→\\t\\t// Skip and cleanup orphaned sessions whose shadow branch no longer exists.\\n    85→\\t\\t// Keep active sessions (shadow branch may not be created yet) and sessions\\n    86→\\t\\t// with LastCheckpointID (needed for checkpoint ID reuse on subsequent commits).\\n    87→\\t\\t// Clean up everything else: stale pre-state-machine sessions (empty phase),\\n    88→\\t\\t// IDLE/ENDED sessions that were never condensed, etc.\\n    89→\\t\\tshadowBranch := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n    90→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranch)\\n    91→\\t\\tif _, err := repo.Reference(refName, true); err != nil {\\n    92→\\t\\t\\tif !state.Phase.IsActive() && state.LastCheckpointID.IsEmpty() {\\n    93→\\t\\t\\t\\t//nolint:errcheck,gosec // G104: Cleanup is best-eff