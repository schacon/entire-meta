 151→\\t\\t\\t)\\n   152→\\t\\t\\tcontinue\\n   153→\\t\\t}\\n   154→\\n   155→\\t\\t// Compare by hash (blob hash) - exact content match required for new files\\n   156→\\t\\tif headFile.Hash == shadowFile.Hash {\\n   157→\\t\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: new file content match found\\\",\\n   158→\\t\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   159→\\t\\t\\t\\tslog.String(\\\"hash\\\", headFile.Hash.String()),\\n   160→\\t\\t\\t)\\n   161→\\t\\t\\treturn true\\n   162→\\t\\t}\\n   163→\\n   164→\\t\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: new file content mismatch (may be reverted & replaced)\\\",\\n   165→\\t\\t\\tslog.String(\\\"file\\\", filePath),\\n   166→\\t\\t\\tslog.String(\\\"head_hash\\\", headFile.Hash.String()),\\n   167→\\t\\t\\tslog.String(\\\"shadow_hash\\\", shadowFile.Hash.String()),\\n   168→\\t\\t)\\n   169→\\t}\\n   170→\\n   171→\\tlogging.Debug(logCtx, \\\"filesOverlapWithContent: no overlapping files found\\\",\\n   172→\\t\\tslog.Int(\\\"files_checked\\\", len(filesTouched)),\\n   173→\\t)\\n   174→\\treturn false\\n   175→}\\n   176→\\n   177→// stagedFilesOverlapWithContent checks if any staged file overlaps with filesTouched,\\n   178→// distinguishing between modified files (always overlap) and new files (check content).\\n   179→//\\n   180→// For modified files (already exist in HEAD), we count as overlap because the user\\n   181→// is editing the session's work. For new files (don't exist in HEAD), we require\\n   182→// content match to detect the \\\"reverted and replaced\\\" scenario.\\n   183→//\\n   184→// This is used in PrepareCommitMsg for carry-forward scenarios.\\n   185→func stagedFilesOverlapWithContent(ctx context.Context, repo *git.Repository, shadowTree *object.Tree, stagedFiles, filesTouched []string) bool {\\n   186→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   187→\\n   188→\\t// Build set of filesTouched for quick lookup\\n   189→\\ttouchedSet := make(m