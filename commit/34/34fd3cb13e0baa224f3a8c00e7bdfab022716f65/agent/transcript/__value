0→  \\\"intent\\\": \\\"What the user was trying to accomplish (1-2 sentences)\\\",\\n    31→  \\\"outcome\\\": \\\"What was actually achieved (1-2 sentences)\\\",\\n    32→  \\\"learnings\\\": {\\n    33→    \\\"repo\\\": [\\\"Codebase-specific patterns, conventions, or gotchas discovered\\\"],\\n    34→    \\\"code\\\": [{\\\"path\\\": \\\"file/path.go\\\", \\\"line\\\": 42, \\\"end_line\\\": 56, \\\"finding\\\": \\\"What was learned\\\"}],\\n    35→    \\\"workflow\\\": [\\\"General development practices or tool usage insights\\\"]\\n    36→  },\\n    37→  \\\"friction\\\": [\\\"Problems, blockers, or annoyances encountered\\\"],\\n    38→  \\\"open_items\\\": [\\\"Tech debt, unfinished work, or things to revisit later\\\"]\\n    39→}\\n    40→\\n    41→Guidelines:\\n    42→- Be concise but specific\\n    43→- Include line numbers for code learnings when the transcript references specific lines\\n    44→- Friction should capture both blockers and minor annoyances\\n    45→- Open items are things intentionally deferred, not failures\\n    46→- Empty arrays are fine if a category doesn't apply\\n    47→- Return ONLY the JSON object, no markdown formatting or explanation`\\n    48→\\n    49→// DefaultModel is the default model used for summarization.\\n    50→// Sonnet provides a good balance of quality and cost, with 1M context window\\n    51→// to handle long transcripts without truncation.\\n    52→const DefaultModel = \\\"sonnet\\\"\\n    53→\\n    54→// ClaudeGenerator generates summaries using the Claude CLI.\\n    55→type ClaudeGenerator struct {\\n    56→\\t// ClaudePath is the path to the claude CLI executable.\\n    57→\\t// If empty, defaults to \\\"claude\\\" (expects it to be in PATH).\\n    58→\\tClaudePath string\\n    59→\\n    60→\\t// Model is the Claude model to use for summarization.\\n    61→\\t// If empty, defaults to DefaultModel (\\\"sonnet\\\").\\n    62→\\tModel string\\n    63→\\n    64→\\t// CommandRunner allows injection of the command execution for testing.\\n    65→\\t// If nil, uses exec.CommandContext directly.\\n    66→\\tCommandRunner func(ctx context.Context, name string, args ...string) *exec.Cmd\\n    67→}\\n    68→\\n    69→// claudeCLIResponse represents the JSON response from the Claude CLI.\\n    70→type claudeCLIResponse struct {\\n    71→\\tResult string `json:\\\"result\\\"`\\n    72→}\\n    73→\\n    74→// Generate creates a summary from checkpoint data by calling the Claude CLI.\\n    75→func (g *ClaudeGenerator) Generate(ctx context.Context, input Input) (*checkpoint.Summary, error) {\\n    76→\\t// Format the transcript for the prompt\\n    77→\\ttranscriptText := FormatCondensedTranscript(input)\\n    78→\\n    79→\\t// Build the prompt\\n    80→\\tprompt := buildSummarizationPrompt(transcriptText)\\n    81→\\n    82→\\t// Execute the Claude CLI\\n    83→\\trunner := g.CommandRunner\\n    84→\\tif runner == nil {\\n    85→\\t\\trunner = exec.CommandContext\\n    86→\\t}\\n    87→\\n    88→\\tclaudePath := g.ClaudePath\\n    89→\\tif claudePath == \\\"\\\" {\\n    90→\\t\\tclaudePath = \\\"claude\\\"\\n    91→\\t}\\n    92→\\n    93→\\tmodel := g.Model\\n    94→\\tif model == \\\"\\\" {\\n    95→\\t\\tmodel = DefaultModel\\n    96→\\t}\\n    97→\\n    98→\\t// Use empty --setting-sources to skip all settings (user, project, local).\\n    99→\\t// This avoids loading MCP servers, hooks, or other config that could interfere\\n   100→\\t// with a simple --print summarization call.\\n   101→\\tcmd := runner(ctx, claudePath, \\\"--print\\\", \\\"--output-format\\\", \\\"json\\\", \\\"--model\\\", model, \\\"--setting-sources\\\", \\\"\\\")\\n   102→\\n   103→\\t// Fully isolate the subprocess from the user's git repo (ENT-242).\\n   104→\\t// Claude Code performs internal git operations (plugin cache, context gathering)\\n   105→\\t// that pollute the worktree index with phantom entries from its plugin cache.\\n   106→\\t// We must both change the working directory AND strip GIT_* env vars, because\\n   107→\\t// git hooks set GIT_DIR which lets Claude Code find the repo regardless of cwd.\\n   108→\\t// This also prevents recursive triggering of Entire's own git hooks.\\n   109→\\tcmd.Dir = os.TempDir()\\n   110→\\tcmd.Env = stripGitEnv(os.Environ())\\n   111→\\n   112→\\t// Pass prompt via stdin\\n   113→\\tcmd.Stdin = strings.NewReader(prompt)\\n   114→\\n   115→\\tvar stdout, stderr bytes.Buffer\\n   116→\\tcmd.Stdout = &stdout\\n   117→\\tcmd.Stderr = &stderr\\n   118→\\n   119→\\terr := cmd.Run()\\n   120→\\tif err != nil {\\n   121→\\t\\t// Check if the command was not found\\n   122→\\t\\tvar execErr *exec.Error\\n   123→\\t\\tif errors.As(err, &execErr) {\\n   124→\\t\\t\\treturn nil, fmt.Errorf(\\\"claude CLI not found: %w\\\", err)\\n   125→\\t\\t}\\n   126→\\n   127→\\t\\t// Check for exit error\\n   128→\\t\\tvar exitErr *exec.ExitError\\n   129→\\t\\tif errors.As(err, &exitErr) {\\n   130→\\t\\t\\treturn nil, fmt.Errorf(\\\"claude CLI failed (exit %d): %s\\\", exitErr.ExitCode(), stderr.String())\\n   131→\\t\\t}\\n   132→\\n   133→\\t\\treturn nil, fmt.Errorf(\\\"failed to run claude CLI: %w\\\", err)\\n   134→\\t}\\n   135→\\n   136→\\t// Parse the CLI response\\n   137→\\tvar cliResponse claudeCLIResponse\\n   138→\\tif err := json.Unmarshal(stdout.Bytes(), &cliResponse); err != nil {\\n   139→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse claude CLI response: %w\\\", err)\\n   140→\\t}\\n   141→\\n   142→\\t// The result field contains the actual JSON summary\\n   143→\\tresultJSON := cliResponse.Result\\n   144→\\n   145→\\t// Try to extract JSON if it's wrapped in markdown code blocks\\n   146→\\tresultJSON = extractJSONFromMarkdown(resultJSON)\\n   147→\\n   148→\\t// Parse the summary from the result\\n   149→\\tvar summary checkpoint.Summary\\n   150→\\tif err := json.Unmarshal([]byte(resultJSON), &summary); err != nil {\"}]},\"uuid\":\"5b2afeb9-7456-4880-b856-198136e6016c\",\"timestamp\":\"2026-02-27T10:59:03.008Z\"},