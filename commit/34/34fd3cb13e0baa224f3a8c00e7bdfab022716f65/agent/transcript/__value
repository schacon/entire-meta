ng every checkpoint has the full context.\\n  1870→//\\n  1871→\\n  1872→func (s *ManualCommitStrategy) HandleTurnEnd(ctx context.Context, state *SessionState) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n  1873→\\t// Finalize all checkpoints from this turn with the full transcript.\\n  1874→\\t//\\n  1875→\\t// IMPORTANT: This is best-effort - errors are logged but don't fail the hook.\\n  1876→\\t// Failing here would prevent session cleanup and could leave state inconsistent.\\n  1877→\\t// The provisional transcript from PostCommit is already persisted, so the\\n  1878→\\t// checkpoint isn't lost - it just won't have the complete transcript.\\n  1879→\\terrCount := s.finalizeAllTurnCheckpoints(ctx, state)\\n  1880→\\tif errCount > 0 {\\n  1881→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n  1882→\\t\\tlogging.Warn(logCtx, \\\"HandleTurnEnd completed with errors (best-effort)\\\",\\n  1883→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1884→\\t\\t\\tslog.Int(\\\"error_count\\\", errCount),\\n  1885→\\t\\t)\\n  1886→\\t}\\n  1887→\\treturn nil\\n  1888→}\\n  1889→\\n  1890→// finalizeAllTurnCheckpoints replaces the provisional transcript in each checkpoint\\n  1891→// created during this turn with the full session transcript.\\n  1892→//\\n  1893→// This is called at turn end (stop hook). During the turn, PostCommit wrote whatever\\n  1894→// transcript was available at commit time. Now we have the complete transcript and\\n  1895→// replace it so every checkpoint has the full prompt-to-stop context.\\n  1896→//\\n  1897→// Returns the number of errors encountered (best-effort: continues processing on error).\\n  1898→func (s *ManualCommitStrategy) finalizeAllTurnCheckpoints(ctx context.Context, state *SessionState) int {\\n  1899→\\tif len(state.TurnCheckpointIDs) == 0 {\\n  1900→\\t\\treturn 0 // No mid-turn commits to finalize\\n  1901→\\t}\\n  1902→\\n  1903→\\tlogCtx := logging.Wi