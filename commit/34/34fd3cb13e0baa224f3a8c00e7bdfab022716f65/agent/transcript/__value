d\":\"toolu_01VNs9kgNJwV8WFRm8k1rEic\",\"type\":\"tool_result\",\"content\":\"     1→//go:build integration\\n     2→\\n     3→package integration\\n     4→\\n     5→import (\\n     6→\\t\\\"bytes\\\"\\n     7→\\t\\\"encoding/json\\\"\\n     8→\\t\\\"fmt\\\"\\n     9→\\t\\\"os/exec\\\"\\n    10→\\t\\\"testing\\\"\\n    11→\\t\\\"time\\\"\\n    12→\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/benchutil\\\"\\n    14→)\\n    15→\\n    16→// BenchmarkHookSessionStart measures the end-to-end latency of the\\n    17→// \\\"entire hooks claude-code session-start\\\" subprocess.\\n    18→//\\n    19→// Each sub-benchmark isolates a single scaling dimension that appears\\n    20→// in the session-start hot path (see hook_registry.go → lifecycle.go):\\n    21→//\\n    22→//   - Sessions:      store.List() called 2x, ReadDir + ReadFile + unmarshal + repo.Reference() per file\\n    23→//   - SessionsXRefs: sessions × refs interaction (repo.Reference scans packed-refs per session)\\n    24→//   - PackedRefs:    go-git PlainOpen + repo.Reference cost with many packed refs\\n    25→//   - GitObjects:    go-git PlainOpen cost with large .git/objects packfile\\n    26→//   - Subprocess:    isolates git rev-parse and binary spawn overhead\\n    27→//\\n    28→// Run all:\\n    29→//\\n    30→//\\tgo test -tags=integration -bench=BenchmarkHookSessionStart -benchtime=3x -run='^$' -timeout=10m ./cmd/entire/cli/integration_test/...\\n    31→//\\n    32→// Run one dimension:\\n    33→//\\n    34→//\\tgo test -tags=integration -bench=BenchmarkHookSessionStart/Subprocess -benchtime=5x -run='^$' ./cmd/entire/cli/integration_test/...\\n    35→func BenchmarkHookSessionStart(b *testing.B) {\\n    36→\\tb.Run(\\\"Sessions\\\", benchSessions)\\n    37→\\tb.Run(\\\"SessionsXRefs\\\", benchSessionsXRefs)\\n    38→\\tb.Run(\\\"PackedRefs\\\", benchPackedRefs)\\n    39→\\tb.Run(\\\"GitObjects\\\", benchGitObjects)\\n    40→\\tb.Run(\\\"Subprocess\\\", benchSubprocessOverhead)\\n    41→}\\n    42→\\n    43→// benchSessions scales session state files in .git/entire-sessions/.\\n    44→// listAllSessionStates() is called twice: once in FindMostRecentSession (logging init),\\n    45→// once in CountOtherActiveSessionsWithCheckpoints. Each call does\\n    46→// ReadDir + (ReadFile + JSON unmarshal + repo.Reference) per file.\\n    47→func benchSessions(b *testing.B) {\\n    48→\\tfor _, n := range []int{0, 1, 5, 10, 25, 50, 100, 200} {\\n    49→\\t\\tb.Run(fmt.Sprintf(\\\"%d\\\", n), func(b *testing.B) {\\n    50→\\t\\t\\trepo := benchutil.NewBenchRepo(b, benchutil.RepoOpts{\\n    51→\\t\\t\\t\\tFileCount:     10,\\n    52→\\t\\t\\t\\tFeatureBranch: \\\"feature/bench\\\",\\n    53→\\t\\t\\t})\\n    54→\\t\\t\\tfor range n {\\n    55→\\t\\t\\t\\trepo.CreateSessionState(b, benchutil.SessionOpts{\\n    56→\\t\\t\\t\\t\\tStepCount:    3,\\n    57→\\t\\t\\t\\t\\tFilesTouched: []string{\\\"src/file_000.go\\\", \\\"src/file_001.go\\\"},\\n    58→\\t\\t\\t\\t})\\n    59→\\t\\t\\t}\\n    60→\\t\\t\\trunSessionStartHook(b, repo)\\n    61→\\t\\t})\\n    62→\\t}\\n    63→}\\n    64→\\n    65→// benchSessionsXRefs tests the interaction between session count and ref count.\\n    66→// For each session, listAllSessionStates calls repo.Reference() which scans packed-refs.\\n    67→// Cost should be O(sessions × packed-refs-size).\\n    68→func benchSessionsXRefs(b *testing.B) {\\n    69→\\ttype scenario struct {\\n    70→\\t\\tsessions int\\n    71→\\t\\trefs     int\\n    72→\\t}\\n    73→\\tscenarios := []scenario{\\n    74→\\t\\t{5, 10},\\n    75→\\t\\t{5, 500},\\n    76→\\t\\t{50, 10},\\n    77→\\t\\t{50, 500},\\n    78→\\t\\t{100, 500},\\n    79→\\t}\\n    80→\\tfor _, sc := range scenarios {\\n    81→\\t\\tb.Run(fmt.Sprintf(\\\"s%d_r%d\\\", sc.sessions, sc.refs), func(b *testing.B) {\\n    82→\\t\\t\\trepo := benchutil.NewBenchRepo(b, benchutil.RepoOpts{\\n    83→\\t\\t\\t\\tFileCount:     10,\\n    84→\\t\\t\\t\\tFeatureBranch: \\\"feature/bench\\\",\\n    85→\\t\\t\\t})\\n    86→\\t\\t\\tfor range sc.sessions {\\n    87→\\t\\t\\t\\trepo.CreateSessionState(b, benchutil.SessionOpts{\\n    88→\\t\\t\\t\\t\\tStepCount:    3,\\n    89→\\t\\t\\t\\t\\tFilesTouched: []string{\\\"src/file_000.go\\\"},\\n    90→\\t\\t\\t\\t})\\n    91→\\t\\t\\t}\\n    92→\\t\\t\\trepo.SeedBranches(b, \\\"feature/team-\\\", sc.refs)\\n    93→\\t\\t\\trepo.PackRefs(b)\\n    94→\\t\\t\\trunSessionStartHook(b, repo)\\n    95→\\t\\t})\\n    96→\\t}\\n    97→}\\n    98→\\n    99→// benchPackedRefs scales the number of packed git refs (branches).\\n   100→// go-git PlainOpen reads packed-refs, and every repo.Reference() call\\n   101→// scans it. Session count held constant at 5.\\n   102→func benchPackedRefs(b *testing.B) {\\n   103→\\tfor _, n := range []int{0, 50, 200, 500, 1000, 2000} {\\n   104→\\t\\tb.Run(fmt.Sprintf(\\\"%d\\\", n), func(b *testing.B) {\\n   105→\\t\\t\\trepo := benchutil.NewBenchRepo(b, benchutil.RepoOpts{\\n   106→\\t\\t\\t\\tFileCount:     10,\\n   107→\\t\\t\\t\\tFeatureBranch: \\\"feature/bench\\\",\\n   108→\\t\\t\\t})\\n   109→\\t\\t\\tfor range 5 {\\n   110→\\t\\t\\t\\trepo.CreateSessionState(b, benchutil.SessionOpts{\\n   111→\\t\\t\\t\\t\\tStepCount:    3,\\n   112→\\t\\t\\t\\t\\tFilesTouched: []string{\\\"src/file_000.go\\\"},\\n   113→\\t\\t\\t\\t})\\n   114→\\t\\t\\t}\\n   115→\\t\\t\\tif n > 0 {\\n   116→\\t\\t\\t\\trepo.SeedBranches(b, \\\"feature/team-\\\", n)\\n   117→\\t\\t\\t\\trepo.PackRefs(b)\\n   118→\\t\\t\\t}\\n   119→\\t\\t\\trunSessionStartHook(b, repo)\\n   120→\\t\\t})\\n   121→\\t}\\n   122→}\\n   123→\\n   124→// benchGitObjects scales the .git/objects packfile size.\\n   125→// go-git PlainOpen parses pack indexes; large packs may slow it down.\\n   126→// This also affects repo.Head() and repo.Reference() indirectly.\\n   127→func benchGitObjects(b *testing.B) {\\n   128→\\tfor _, n := range []int{0, 1000, 5000, 10000} {\\n   129→\\t\\tb.Run(fmt.Sprintf(\\\"%d\\\", n), func(b *testing.B) {\\n   130→\\t\\t\\trepo := benchutil.NewBenchRepo(b, benchutil.RepoOpts{\\n   131→\\t\\t\\t\\tFileCount:     10,\\n   132→\\t\\t\\t\\tFeatureBranch: \\\"feature/bench\\\",\\n   133→\\t\\t\\t})\\n   134→\\t\\t\\tfor range 5 {\\n   135→\\t\\t\\t\\trepo.CreateSessionState(b, benchutil.SessionOpts{\\n   136→\\t\\t\\t\\t\\tStepCount:    3,\\n   137→\\t\\t\\t\\t\\tFilesTouched: []string{\\\"src/file_000.go\\\"},\\n   138→\\t\\t\\t\\t})\\n   139→\\t\\t\\t}\\n   140→\\t\\t\\tif n > 0 {\\n   141→\\t\\t\\t\\trepo.SeedGitObjects(b, n)\\n   142→\\t\\t\\t}\\n   143→\\t\\t\\trunSessionStartHook(b, repo)\\n   144→\\t\\t})\\n   145→\\t}\\n   146→}\\n   147→\\n   148→// benchSubprocessOverhead isolates the cost of subprocess spawns that happen\\n   149→// during session-start. The hook calls git rev-parse multiple times (some cached,\\n   150→// some not) plus spawns the entire binary itself. This benchmark measures each\\n   151→// component so we can see what fraction of the total is subprocess overhead.\\n   152→func benchSubprocessOverhead(b *testing.B) {\\n   153→\\trepo := benchutil.NewBenchRepo(b, benchutil.RepoOpts{\\n   154→\\t\\tFileCount:     10,\\n   155→\\t\\tFeatureBranch: \\\"feature/bench\\\",\\n   156→\\t})\\n   157→\\n   158→\\t// 1. Bare git rev-parse round-trip\\n   159→\\tb.Run(\\\"GitRevParse_1x\\\", func(b *testing.B) {\\n   160→\\t\\tb.ResetTimer()\\n   161→\\t\\tfor range b.N {\\n   162→\\t\\t\\tstart := time.Now()\\n   163→\\t\\t\\tcmd := exec.Command(\\\"git\\\", \\\"rev-parse\\\", \\\"--show-toplevel\\\")\\n   164→\\t\\t\\tcmd.Dir = repo.Dir\\n   165→\\t\\t\\tcmd.Env = gitIsolatedEnv()\\n   166→\\t\\t\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   167→\\t\\t\\t\\tb.Fatalf(\\\"git rev-parse failed: %v\\\\n%s\\\", err, output)\\n   168→\\t\\t\\t}\\n   169→\\t\\t\\tb.ReportMetric(float64(time.Since(start).Milliseconds()), \\\"ms/op\\\")\\n   170→\\t\\t}\\n   171→\\t})\\n   172→\\n   173→\\t// 2. Seven sequential git rev-parse calls (pre-optimization baseline)\\n   174→\\tb.Run(\\\"GitRevParse_7x\\\", func(b *testing.B) {\\n   175→\\t\\tb.ResetTimer()\\n   176→\\t\\tfor range b.N {\\n   177→\\t\\t\\tstart := time.Now()\\n   178→\\t\\t\\tfor range 7 {\\n   179→\\t\\t\\t\\tcmd := exec.Command(\\\"git\\\", \\\"rev-parse\\\", \\\"--show-toplevel\\\")\\n   180→\\t\\t\\t\\tcmd.Dir = repo.Dir\\n   181→\\t\\t\\t\\tcmd.Env = gitIsolatedEnv()\\n   182→\\t\\t\\t\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   183→\\t\\t\\t\\t\\tb.Fatalf(\\\"git rev-parse failed: %v\\\\n%s\\\", err, output)\\n   184→\\t\\t\\t\\t}\\n   185→\\t\\t\\t}\\n   186→\\t\\t\\tb.ReportMetric(float64(time.Since(start).Milliseconds()), \\\"ms/op\\\")\\n   187→\\t\\t}\\n   188→\\t})\\n   189→\\n   190→\\t// 3. Bare `entire` binary spawn (version command — minimal work, no git)\\n   191→\\tb.Run(\\\"EntireBinary_version\\\", func(b *testing.B) {\\n   192→\\t\\tbinary := getTestBinary()\\n   193→\\t\\tb.ResetTimer()\\n   194→\\t\\tfor range b.N {\\n   195→\\t\\t\\tstart := time.Now()\\n   196→\\t\\t\\tcmd := exec.Command(binary, \\\"version\\\")\\n   197→\\t\\t\\tcmd.Dir = repo.Dir\\n   198→\\t\\t\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   199→\\t\\t\\t\\tb.Fatalf(\\\"entire version failed: %v\\\\n%s\\\", err, output)\\n   200→\\t\\t\\t}\\n   201→\\t\\t\\tb.ReportMetric(float64(time.Since(start).Milliseconds()), \\\"ms/op\\\")\\n   202→\\t\\t}\\n   203→\\t})\\n   204→\\n   205→\\t// 4. Full session-start hook (for direct comparison)\\n   206→\\tb.Run(\\\"FullHook\\\", func(b *testing.B) {\\n   207→\\t\\tfor range 5 {\\n   208→\\t\\t\\trepo.CreateSessionState(b, benchutil.SessionOpts{\\n   209→\\t\\t\\t\\tStepCount:    3,\\n   210→\\t\\t\\t\\tFilesTouched: []string{\\\"src/file_000.go\\\"},\\n   211→\\t\\t\\t})\\n   212→\\t\\t}\\n   213→\\t\\trunSessionStartHook(b, repo)\\n   214→\\t})\\n   215→}\\n   216→\\n   217→// runSessionStartHook is the shared benchmark loop that invokes the session-start\\n   218→// hook as a subprocess and repo