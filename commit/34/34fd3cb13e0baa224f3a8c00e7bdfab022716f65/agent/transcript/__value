   117→\\t\\t\\t\\treturn block.Text, nil\\n   118→\\t\\t\\t}\\n   119→\\t\\t}\\n   120→\\t}\\n   121→\\treturn \\\"\\\", nil\\n   122→}\\n   123→\\n   124→// PrepareTranscript waits for Claude Code's async transcript flush to complete.\\n   125→// Claude writes a hook_progress sentinel entry after flushing all pending writes.\\n   126→func (c *ClaudeCodeAgent) PrepareTranscript(ctx context.Context, sessionRef string) error {\\n   127→\\twaitForTranscriptFlush(ctx, sessionRef, time.Now())\\n   128→\\treturn nil\\n   129→}\\n   130→\\n   131→// CalculateTokenUsage computes token usage from the transcript starting at the given line offset.\\n   132→func (c *ClaudeCodeAgent) CalculateTokenUsage(transcriptData []byte, fromOffset int) (*agent.TokenUsage, error) {\\n   133→\\treturn c.CalculateTotalTokenUsage(transcriptData, fromOffset, \\\"\\\")\\n   134→}\\n   135→\\n   136→// --- Internal hook parsing functions ---\\n   137→\\n   138→func (c *ClaudeCodeAgent) parseSessionStart(stdin io.Reader) (*agent.Event, error) {\\n   139→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   140→\\tif err != nil {\\n   141→\\t\\treturn nil, err\\n   142→\\t}\\n   143→\\treturn &agent.Event{\\n   144→\\t\\tType:       agent.SessionStart,\\n   145→\\t\\tSessionID:  raw.SessionID,\\n   146→\\t\\tSessionRef: raw.TranscriptPath,\\n   147→\\t\\tTimestamp:  time.Now(),\\n   148→\\t}, nil\\n   149→}\\n   150→\\n   151→func (c *ClaudeCodeAgent) parseTurnStart(stdin io.Reader) (*agent.Event, error) {\\n   152→\\traw, err := agent.ReadAndParseHookInput[userPromptSubmitRaw](stdin)\\n   153→\\tif err != nil {\\n   154→\\t\\treturn nil, err\\n   155→\\t}\\n   156→\\treturn &agent.Event{\\n   157→\\t\\tType:       agent.TurnStart,\\n   158→\\t\\tSessionID:  raw.SessionID,\\n   159→\\t\\tSessionRef: raw.TranscriptPath,\\n   160→\\t\\tPrompt:     raw.Prompt,\\n   161→\\t\\tTimestamp:  time.Now(),\\n   162→\\t}, nil\\n   163→}\\n   164→\\n   165→func (c *ClaudeCodeAgent) parseTurnEnd(stdin io.Reader) (*agent.Event, error) {\\n   166→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   167→\\tif err != nil {\\n   168→\\t\\treturn nil, err\\n   169→\\t}\\n   170→\\treturn &agent.Event{\\n   171→\\t\\tType:       agent.TurnEnd,\\n   172→\\t\\tSessionID:  raw.SessionID,\\n   173→\\t\\tSessionRef: raw.TranscriptPath,\\n   174→\\t\\tTimestamp:  time.Now(),\\n   175→\\t}, nil\\n   176→}\\n   177→\\n   178→func (c *ClaudeCodeAgent) parseSessionEnd(stdin io.Reader) (*agent.Event, error) {\\n   179→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   180→\\tif err != nil {\\n   181→\\t\\treturn nil, err\\n   182→\\t}\\n   183→\\treturn &agent.Event{\\n   184→\\t\\tType:       agent.SessionEnd,\\n   185→\\t\\tSessionID:  raw.SessionID,\\n   186→\\t\\tSessionRef: raw.TranscriptPath,\\n   187→\\t\\tTimestamp:  time.Now(),\\n   188→\\t}, nil\\n   189→}\\n   190→\\n   191→func (c *ClaudeCodeAgent) parseSubagentStart(stdin io.Reader) (*agent.Event, error) {\\n   192→\\traw, err := agent.ReadAndParseHookInput[taskHookInputRaw](stdin)\\n   193→\\tif err != nil {\\n   194→\\t\\treturn nil, err\\n   195→\\t}\\n   196→\\treturn &agent.Event{\\n   197→\\t\\tType:       agent.SubagentStart,\\n   198→\\t\\tSessionID:  raw.SessionID,\\n   199→\\t\\tSessionRef: raw.TranscriptPath,\\n   200→\\t\\tToolUseID:  raw.ToolUseID,\\n   201→\\t\\tToolInput:  raw.ToolInput,\\n   202→\\t\\tTimestamp:  time.Now(),\\n   203→\\t}, nil\\n   204→}\\n   205→\\n   206→func (c *ClaudeCodeAgent) parseSubagentEnd(stdin io.Reader) (*agent.Event, error) {\\n   207→\\traw, err := agent.ReadAndParseHookInput[postToolHookInputRaw](stdin)\\n   208→\\tif err != nil {\\n   209→\\t\\treturn nil, err\\n   210→\\t}\\n   211→\\tevent := &agent.Event{\\n   212→\\t\\tType:       agent.SubagentEnd,\\n   213→\\t\\tSessionID:  raw.SessionID,\\n   214→\\t\\tSessionRef: raw.TranscriptPath,\\n   215→\\t\\tToolUseID:  raw.ToolUseID,\\n   216→\\t\\tToolInput:  raw.ToolInput,\\n   217→\\t\\tTimestamp:  time.Now(),\\n   218→\\t}\\n   219→\\tif raw.ToolResponse.AgentID != \\\"\\\" {\\n   220→\\t\\tevent.SubagentID = raw.ToolResponse.AgentID\\n   221→\\t}\\n   222→\\treturn event, nil\\n   223→}\\n   224→\\n   225→// --- Transcript flush sentinel ---\\n   226→\\n   227→// stopHookSentinel is the string that appears in Claude Code's hook_progress\\n   228→// entry when the stop hook has been invoked, indicating the transcript is fully flushed.\\n   229→const stopHookSentinel = \\\"hooks claude-code stop\\\"\\n   230→\\n   231→// waitForTranscriptFlush polls the transcript file for the stop hook sentinel.\\n   232→// Falls back silently after a timeout.\\n   233→func waitForTranscriptFlush(ctx context.Context, transcriptPath string, hookStartTime time.Time) {\\n   234→\\tconst (\\n   235→\\t\\tmaxWait      = 3 * time.Second\\n   236→\\t\\tpollInterval = 50 * time.Millisecond\\n   237→\\t\\ttailBytes    = 4096\\n   238→\\t\\tmaxSkew      = 2 * time.Second\\n   239→\\t)\\n   240→\\n   241→\\tlogCtx := logging.WithComponent(ctx, \\\"agent.claudecode\\\")\\n   242→\\n   243→\\t// Fast path: skip the poll loop when the sentinel can't possibly appear.\\n   244→\\t// - File doesn't exist: nothing to poll.\\n   245→\\t// - File is stale (unmodified for 2+ min): agent isn't running anymore.\\n   246→\\t//   This avoids 3s timeouts per stale \\\"active\\\" session (e.g., agent crashed\\n   247→\\t//   without firing stop hook).\\n   248→\\tconst staleThreshold = 2 * time.Minute\\n   249→\\tinfo, err := os.Stat(transcriptPath)\\n   250→\\tif err != nil {\\n   251→\\t\\treturn // file doesn't exist, nothing to wait for\\n   252→\\t}\\n   253→\\tif time.Since(info.ModTime()) > staleThreshold {\\n   254→\\t\\tlogging.Debug(logCtx, \\\"transcript file is stale, skipping sentinel wait\\\",\\n   255→\\t\\t\\tslog.Duration(\\\"file_age\\\", time.Since(info.ModTime())),\\n   256→\\t\\t)\\n   257→\\t\\treturn\\n   258→\\t}\\n   259→\\n   260→\\tdeadline := time.Now().Add(maxWait)\\n   261→\\tfor time.Now().Before(deadline) {\\n   262→\\t\\tif checkStopSentinel(transcriptPath, tailBytes, hookStartTime, maxSkew) {\\n   263→\\t\\t\\tlogging.Debug(logCtx, \\\"transcript flush sentinel found\\\",\\n   264→\\t\\t\\t\\tslog.Duration(\\\"wait\\\", time.Since(hookStartTime)),\\n   265→\\t\\t\\t)\\n   266→\\t\\t\\treturn\\n   267→\\t\\t}\\n   268→\\t\\ttime.Sleep(pollInterval)\\n   269→\\t}\\n   270→\\tlogging.Warn(logCtx, \\\"transcript flush sentinel not found within timeout, proceeding\\\",\\n   271→\\t\\tslog.Duration(\\\"timeout\\\", maxWait),\\n   272→\\t)\\n   273→}\\n   274→\\n   275→// checkStopSentinel reads the tail of the transcript file and looks for the sentinel.\\n   276→func checkStopSentinel(path string, tailBytes int64, hookStartTime time.Time, maxSkew time.Duration) bool {\\n   277→\\tf, err := os.Open(path) //nolint:gosec // path comes from agent hook input\\n   278→\\tif err != nil {\\n   279→\\t\\treturn false\\n   280→\\t}\\n   281→\\tdefer f.Close()\\n   282→\\n   283→\\tinfo, err := f.Stat()\\n   284→\\tif err != nil {\\n   285→\\t\\treturn false\\n   286→\\t}\\n   287→\\toffset := info.Size() - tailBytes\\n   288→\\tif offset < 0 {\\n   289→\\t\\toffset = 0\\n   290→\\t}\\n   291→\\tbuf := make([]byte, info.Size()-offset)\\n   292→\\tif _, err := f.ReadAt(buf, offset); err != nil {\\n   293→\\t\\treturn false\\n   294→\\t}\\n   295→\\n   296→\\tlines := strings.Split(string(buf), \\\"\\\\n\\\")\\n   297→\\tfor _, line := range lines {\\n   298→\\t\\tline = strings.TrimSpace(line)\\n   299→\\t\\tif line == \\\"\\\" || !strings.Contains(line, stopHookSentinel) {\\n   300→\\t\\t\\tcontinue\\n   301→\\t\\t}\\n   302→\\n   303→\\t\\tvar entry struct {\\n   304→\\t\\t\\tTimestamp string `json:\\\"timestamp\\\"`\\n   305→\\t\\t}\\n   306→\\t\\tif json.Unmarshal([]byte(line), &entry) != nil || entry.Timestamp == \\\"\\\" {\\n   307→\\t\\t\\tcontinue\\n   308→\\t\\t}\\n   309→\\t\\tts, err := time.Parse(time.RFC3339N