n.MarshalIndent(raw, \\\"\\\", \\\"  \\\")\\n   168→\\tif err != nil {\\n   169→\\t\\treturn fmt.Errorf(\\\"marshaling local settings: %w\\\", err)\\n   170→\\t}\\n   171→\\tout = append(out, '\\\\n')\\n   172→\\n   173→\\tif err := os.MkdirAll(filepath.Dir(localPath), 0o750); err != nil {\\n   174→\\t\\treturn fmt.Errorf(\\\"creating settings directory: %w\\\", err)\\n   175→\\t}\\n   176→\\t//nolint:gosec // G306: settings file is config, not secrets; 0o644 is appropriate\\n   177→\\tif err := os.WriteFile(localPath, out, 0o644); err != nil {\\n   178→\\t\\treturn fmt.Errorf(\\\"writing local settings: %w\\\", err)\\n   179→\\t}\\n   180→\\treturn nil\\n   181→}\\n   182→\\n   183→// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   184→// If the message contains only our trailer (no actual user content), strip it\\n   185→// so git will abort the commit due to empty message.\\n   186→\\n   187→func (s *ManualCommitStrategy) CommitMsg(_ context.Context, commitMsgFile string) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   188→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n   189→\\tif err != nil {\\n   190→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   191→\\t}\\n   192→\\n   193→\\tmessage := string(content)\\n   194→\\n   195→\\t// Check if our trailer is present (ParseCheckpoint validates format, so found==true means valid)\\n   196→\\tif _, found := trailers.ParseCheckpoint(message); !found {\\n   197→\\t\\t// No trailer, nothing to do\\n   198→\\t\\treturn nil\\n   199→\\t}\\n   200→\\n   201→\\t// Check if there's any user content (non-comment, non-trailer lines)\\n   202→\\tif !hasUserContent(message) {\\n   203→\\t\\t// No user content - strip the trailer so git aborts\\n   204→\\t\\tmessage = stripCheckpointTrailer(message)\\n   205→\\t\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   206→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   207→\\t\\t}\\n   208→\\t}\\n   209→\\n   210→\\treturn nil\\n   211→}\\n   212→\\n   213→// hasUserContent checks if the message has any content besides comments and our trailer.\\n   214→func hasUserContent(message string) bool {\\n   215→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   216→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   217→\\t\\ttrimmed := strings.TrimSpace(line)\\n   218→\\t\\t// Skip empty lines\\n   219→\\t\\tif trimmed == \\\"\\\" {\\n   220→\\t\\t\\tcontinue\\n   221→\\t\\t}\\n   222→\\t\\t// Skip comment lines\\n   223→\\t\\tif strings.HasPrefix(trimmed, \\\"#\\\") {\\n   224→\\t\\t\\tcontinue\\n   225→\\t\\t}\\n   226→\\t\\t// Skip our trailer line\\n   227→\\t\\tif strings.HasPrefix(trimmed, trailerPrefix) {\\n   228→\\t\\t\\tcontinue\\n   229→\\t\\t}\\n   230→\\t\\t// Found user content\\n   231→\\t\\treturn true\\n   232→\\t}\\n   233→\\treturn false\\n   234→}\\n   235→\\n   236→// stripCheckpointTrailer removes the Entire-Checkpoint trailer line from the message.\\n   237→func stripCheckpointTrailer(message string) string {\\n   238→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   239→\\tvar result []string\\n   240→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   241→\\t\\tif !strings.HasPrefix(strings.TrimSpace(line), trailerPrefix) {\\n   242→\\t\\t\\tresult = append(result, line)\\n   243→\\t\\t}\\n   244→\\t}\\n   245→\\treturn strings.Join(result, \\\"\\\\n\\\")\\n   246→}\\n   247→\\n   248→// isGitSequenceOperation checks if git is currently in the middle of a rebase,\\n   249→// cherry-pick, or revert operation. During these operations, commits are being\\n   250→// replayed and should not be linked to agent sessions.\\n   251→//\\n   252→// Detects:\\n   253→//   - rebase: .git/rebase-merge/ or .git/rebase-apply/ directories\\n   254→//   - cherry-pick: .git/CHERRY_PICK_HEAD file\\n   255→//   - revert: .git/REVERT_HEAD file\\n   256→func isGitSequenceOperation(ctx context.Context) bool {\\n   257→\\t// Get git directory (handles worktrees and relative paths correctly)\\n   258→\\tgitDir, err := GetGitDir(ctx)\\n   259→\\tif err != nil {\\n   260→\\t\\treturn false // Can't determine, assume not in sequence operation\\n   261→\\t}\\n   262→\\n   263→\\t// Check for rebase state directories\\n   264→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-merge\\\")); err == nil {\\n   265→\\t\\treturn true\\n   266→\\t}\\n   267→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-apply\\\")); err == nil {\\n   268→\\t\\treturn true\\n   269→\\t}\\n   270→\\n   271→\\t// Check for cherry-pick and revert state files\\n   272→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"CHERRY_PICK_HEAD\\\")); err == nil {\\n   273→\\t\\treturn true\\n   274→\\t}\\n   275→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"REVERT_HEAD\\\")); err == nil {\\n   276→\\t\\treturn true\\n   277→\\t}\\n   278→\\n   279→\\treturn false\\n   280→}\\n   281→\\n   282→// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   283→// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   284→// Only adds a trailer if there's actually new session content to condense.\\n   285→// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   286→// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   287→// For amended commits, preserves the existing checkpoint ID.\\n   288→//\\n   289→// The source parameter indicates how the commit was initiated:\\n   290→//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   291→//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   292→//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   293→//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   294→//\\n   295→\\n   296→func (s *ManualCommitStrategy) PrepareCommitMsg(ctx context.Context, commitMsgFile string, source string) error {\\n   297→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   298→\\n   299→\\t// Skip during rebase, cherry-pick, or revert operations\\n   300→\\t// These are replaying existing commits and should not be linked to agent sessions\\n   301→\\tif isGitSequenceOperation(ctx) {\\n   302→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n   303→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   304→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   305→\\t\\t)\\n   306→\\t\\treturn nil\\n   307→\\t}\\n   308→\\n   309→\\t// Skip for merge and squash sources\\n   310→\\t// These are auto-generated messages - not from Claude sessions\\n   311→\\tswitch source {\\n   312→\\tcase \\\"merge\\\", \\\"squash\\\":\\n   313→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n   314→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   315→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   316→\\t\\t)\\n   317→\\t\\treturn nil\\n   318→\\t}\\n   319→\\n   320→\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   321→\\tif source == \\\"commit\\\" {\\n   322→\\t\\treturn s.handleAmendCommitMsg(ctx, commitMsgFile)\\n   323→\\t}\\n   324→\\n   325→\\trepo, err := OpenRepository(ctx)\\n   326→\\tif err != nil {\\n   327→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   328→\\t}\\n   329→\\n   330→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   331→\\tif err != nil {\\n   332→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   333→\\t}\\n   334→\\n   335→\\t// Find all active sessions for this worktree\\n   336→\\t// We match by worktree (not Base