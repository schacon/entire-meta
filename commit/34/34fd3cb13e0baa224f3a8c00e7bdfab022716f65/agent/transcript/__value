172→\\t}\\n   173→\\n   174→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   175→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   176→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   177→\\tif len(committedFiles) > 0 {\\n   178→\\t\\t// Track if we had files before filtering to distinguish between:\\n   179→\\t\\t// - Session had files but none were committed (don't fallback)\\n   180→\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n   181→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   182→\\n   183→\\t\\tif hadFilesBeforeFiltering {\\n   184→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   185→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   186→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   187→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   188→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   189→\\t\\t\\t\\t}\\n   190→\\t\\t\\t}\\n   191→\\t\\t\\tsessionData.FilesTouched = filtered\\n   192→\\t\\t}\\n   193→\\n   194→\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n   195→\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n   196→\\t\\t// the session had files that simply didn't overlap with the commit - that\\n   197→\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n   198→\\t\\t// overwritten with unrelated committed files.\\n   199→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   200→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   201→\\t\\t\\tfor f := range committedFiles {\\n   202→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   203→\\t\\t\\t}\\n   204→\\t\\t}\\n   205→\\t}\\n   206→\\n   207→\\t// Get checkpoint store\\n   208→\\tstore, err := s.getCheckpointStore()\\n   209→\\tif err != nil {\\n   210→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   211→\\t}\\n   212→\\n   213→\\t// Get author info\\n   214→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   215→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   216→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   217→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   218→\\tattribution := calculateSessionAttributions(ctx, repo, ref, sessionData, state, attributionOpts{\\n   219→\\t\\theadTree: o.headTree,\\n   220→\\t})\\n   221→\\t// Get current branch name\\n   222→\\tbranchName := GetCurrentBranchName(repo)\\n   223→\\n   224→\\t// Generate summary if enabled\\n   225→\\tvar summary *cpkg.Summary\\n   226→\\tif settings.IsSummarizeEnabled(ctx) && len(sessionData.Transcript) > 0 {\\n   227→\\t\\tsummarizeCtx := logging.WithComponent(ctx, \\\"summarize\\\")\\n   228→\\n   229→\\t\\t// Scope transcript to this checkpoint's portion.\\n   230→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   231→\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n   232→\\t\\tvar scopedTranscript []byte\\n   233→\\t\\tswitch state.AgentType {\\n   234→\\t\\tcase agent.AgentTypeGemini:\\n   235→\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   236→\\t\\t\\tif sliceErr != nil {\\n   237→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n   238→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   239→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   240→\\t\\t\\t}\\n   241→\\t\\t\\tscopedTranscript = scoped\\n   242→\\t\\tcase agent.AgentTypeOpenCode:\\n   243→\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   244→\\t\\t\\tif sliceErr != nil {\\n   245→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n   246→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   247→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   248→\\t\\t\\t}\\n   249→\\t\\t\\tscopedTranscript = scoped\\n   250→\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeUnknown:\\n   251→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   252→\\t\\t}\\n   253→\\t\\tif len(scopedTranscript) > 0 {\\n   254→\\t\\t\\tvar err error\\n   255→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   256→\\t\\t\\tif err != nil {\\n   257→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   258→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   259→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   260→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   261→\\t\\t\\t} else {\\n   262→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   263→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   264→\\t\\t\\t}\\n   265→\\t\\t}\\n   266→\\t}\\n   267→\\n   268→\\t// Write checkpoint metadata using the checkpoint store\\n   269→\\tif err := store.WriteCommitted(ctx, cpkg.WriteCommittedOptions{\\n   270→\\t\\tCheckpointID:                checkpointID,\\n   271→\\t\\tSessionID:                   state.SessionID,\\n   272→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   273→\\t\\tBranch:                      branchName,\\n   274→\\t\\tTranscript:                  sessionData.Transcript,\\n   275→\\t\\tPrompts:                     sessionData.Prompts,\\n   276→\\t\\tContext:                     sessionData.Context,\\n   277→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   278→\\t\\tCheckpointsCount:            state.StepCount,\\n   279→\\t\\tEphemeralBranch:             shadowBranchName,\\n   280→\\t\\tAuthorName:                  authorName,\\n   281→\\t\\tAuthorEmail:                 authorEmail,\\n   282→\\t\\tAgent:                       state.AgentType,\\n   283→\\t\\tTurnID:                      state.TurnID,\\n   284→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   285→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   286→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   287→\\t\\tInitialAttribution:          attribution,\\n   288→\\t\\tSummary:                     summary,\\n   289→\\t}); err != nil {\\n   290→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   291→\\t}\\n   292→\\n   293→\\treturn &CondenseResult{\\n   294→\\t\\tCheckpointID:         checkpointID,\\n   295→\\t\\tSessionID:            state.SessionID,\\n   296→\\t\\tCheckpointsCount:     state.StepCount,\\n   297→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   298→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   299→\\t}, nil\\n   300→}\\n   301→\\n   302→// attributionOpts provides pre-resolved git objects to avoid redundant reads.\\n   303→type attributionOpts struct {\\n   304→\\theadTree   *object.Tree // HEAD commit tree (already resolved by PostCommit)\\n   305→\\tshadowTree *object.Tree // Shadow branch tree (already resolved by PostCommit)\\n   306→}\\n   307→\\n   308→func calculateSessionAttributions(ctx context.Context, repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState, opts ...attributionOpts) *cpkg.InitialAttribution {\\n   309→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   310→\\t// This uses user edits captured at each prompt start (before agent works),\\n   311→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   312→\\t//\\n   313→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   314→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   315→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   316→\\tlogCtx := logging.WithComponent(ctx, \\\"attribution\\\")\\n   317→\\n   318→\\tvar o attributionOpts\\n   319→\\tif len(opts) > 0 {\\n   320→\\t\\to = opts[0]\\n   321→\\t}\\n   322→\\n   323→\\theadTree := o.headTree\\n   324→\\tif headTree == nil {\\n   325→\\t\\theadRef, headErr := repo.Head()\\n   326→\\t\\tif headErr != nil {\\n   327→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   328→\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   329→\\t\\t\\treturn nil\\n   330→\\t\\t}\\n   331→\\n   332→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   333→\\t\\tif commitErr != nil {\\n   334→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   335→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   336→\\t\\t\\treturn nil\\n   337→\\t\\t}\\n   338→\\n   339→\\t\\tvar treeErr error\\n   340→\\t\\theadTree, treeErr = headCommit.Tree()\\n   341→\\t\\tif treeErr != nil {\\n   342→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   343→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   344→\\t\\t\\treturn nil\\n   345→\\t\\t}\\n   346→\\t}\\n   347→\\n   348→\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n   349→\\tshadowTree := o.shadowTree\\n   350→\\tif shadowTree == nil {\\n   351→\\t\\tif shadowRef != nil {\\n   352→\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   353→\\t\\t\\tif shadowErr != nil {\\n   354→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   355→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   356→\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   357→\\t\\t\\t\\treturn nil\\n   358→\\t\\t\\t}\\n   359→\\t\\t\\tvar shadowTreeErr error\\n   360→\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   361→\\t\\t\\tif shadowTreeErr != nil {\\n   362→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   363→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   364→\\t\\t\\t\\treturn nil\\n   365→\\t\\t\\t}\\n   366→\\t\\t} else {\\n   367→\\t\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   368→\\t\\t\\t// because the agent's work is the commit itself.\\n   369→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   370→\\t\\t\\tshadowTree = headTree\\n   371→\\t\\t}\\n   372→\\t}\\n   373→\\n   374→\\t// Get base tree (state before session started)\\n   375→\\tvar baseTree *object.Tree\\n   376→\\tattrBase := state.AttributionBaseCommit\\n   377→\\tif attrBase == \\\"\\\" {\\n   378→\\t\\tattrBase = state.BaseCommit // backward compat\\n   379→\\t}\\n   380→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   381→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   382→\\t\\t\\tbaseTree = tree\\n   383→\\t\\t} else {\\n   384→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   385→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   386→\\t\\t}\\n   387→\\t} else {\\n   388→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   389→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   390→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   391→\\t}\\n   392→\\n   393→\\t// Log accumulated prompt attributions for debugging\\n   394→\\tvar totalUserAdded, totalUserRemoved int\\n   395→\\tfor i, pa := range state.PromptAttributions {\\n   396→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   397→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   398→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   399→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   400→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   401→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   402→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   403→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   404→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   405→\\t}\\n   406→\\n   407→\\tattribution := CalculateAttributionWithAccumulated(\\n   408→\\t\\tctx,\\n   409→\\t\\tbaseTree,\\n   410→\\t\\tshadowTree,\\n   411→\\t\\theadTree,\\n   412→\\t\\tsessionData.FilesTouched,\\n   413→\\t\\tstate.PromptAttributions,\\n   414→\\t)\\n   415→\\n   416→\\tif attribution != nil {\\n   417→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   418→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   419→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   420→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   421→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   422→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   423→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   424→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   425→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   426→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   427→\\t}\\n   428→\\n   429→\\treturn attribution\\n   430→}\\n   431→\\n   432→// extractSessionData extracts session data from the shadow branch.\\n   433→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   434→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   435→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   436→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   437→// continued growing — the shadow branch copy would be stale.\\n   438→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   439→func (s *ManualCommitStrategy) extractSessionData(ctx context.Context, repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType types.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n   440→\\tag, _ := agent.GetByAgentType(agentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   441→\\tcommit, err := repo.CommitObject(shadowRef)\\n   442→\\tif err != nil {\\n   443→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   444→\\t}\\n   445→\\n   446→\\ttree, err := commit.Tree()\\n   447→\\tif err != nil {\\n   448→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   449→\\t}\\n   450→\\n   451→\\tdata := &ExtractedSessionData{}\\n   452→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   453→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   454→\\n   455→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   456→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   457→\\t// (SaveStep is only called when there are file modifications).\\n   458→\\tvar fullTranscript string\\n   459→\\tif liveTranscriptPath != \\\"\\\" {\\n   460→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   461→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   462→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   463→\\t\\tif isActive {\\n   464→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, liveTranscriptPath)\\n   465→\\t\\t}\\n   466→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   467→\\t\\t\\tfullTranscript = string(liveData)\\n   468→\\t\\t}\\n   469→\\t}\\n   470→\\tif fullTranscript == \\\"\\\" {\\n   471→\\t\\t// Fall back to shadow branch copy\\n   472→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   473→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   474→\\t\\t\\t\\tfullTranscript = content\\n   475→\\t\\t\\t}\\n   476→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   477→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   478→\\t\\t\\t\\tfullTranscript = content\\n   479→\\t\\t\\t}\\n   480→\\t\\t}\\n   481→\\t}\\n   482→\\n   483→\\t// Process transcript based on agent type\\n   484→\\tif fullTranscript != \\\"\\\" {\\n   485→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   486→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   487→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   488→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   489→\\t}\\n   490→\\n   491→\\t// Use tracked files from session state (not all files in tree)\\n   492→\\tdata.FilesTouched = filesTouched\\n   493→\\n   494→\\t// Calculate token usage from the extracted transcript portion\\n   495→\\tif len(data.Transcript) > 0 {\\n   496→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, checkpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   497→\\t}\\n   498→\\n   499→\\treturn data, nil\\n   500→}\\n   501→\\n   502→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   503→// This is used for mid-session commits where no shadow branch exists yet.\\n   504→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(ctx context.Context, state *SessionState) (*ExtractedSessionData, error) {\\n   505→\\tdata := &ExtractedSessionData{}\\n   506→\\n   507→\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   508→\\n   509→\\t// Read the live transcript\\n   510→\\tif state.TranscriptPath == \\\"\\\" {\\n   511→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   512→\\t}\\n   513→\\n   514→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   515→\\tif err != nil {\\n   516→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   517→\\t}\\n   518→\\n   519→\\tif len(liveData) == 0 {\\n   520→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   521→\\t}\\n   522→\\n   523→\\tfullTranscript := string(liveData)\\n   524→\\tdata.Transcript = liveData\\n   525→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   526→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   527→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   528→\\n   529→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   530→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   531→\\tif len(state.FilesTouched) > 0 {\\n   532→\\t\\tdata.FilesTouched = state.FilesTouched\\n   533→\\t} else {\\n   534→\\t\\t// Use the shared helper which includes subagent transcripts\\n   535→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(ctx, state, state.CheckpointTranscriptStart)\\n   536→\\t}\\n   537→\\n   538→\\t// Calculate token usage from the extracted transcript portion\\n   539→\\tif len(data.Transcript) > 0 {\\n   540→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, state.CheckpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   541→\\t}\\n   542→\\n   543→\\treturn data, nil\\n   544→}\\n   545→\\n   546→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   547→// For Claude Code and JSONL-based agents, this counts lines.\\n   548→// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n   549→// Returns 0 if the content is empty or malformed.\\n   550→func countTranscriptItems(agentType types.AgentType, content string) int {\\n   551→\\tif content == \\\"\\\" {\\n   552→\\t\\treturn 0\\n   553→\\t}\\n   554→\\n   555→\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n   556→\\tif agentType == agent.AgentTypeOpenCode {\\n   557→\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n   558→\\t\\tif err == nil && session != nil {\\n   559→\\t\\t\\treturn len(session.Messages)\\n   560→\\t\\t}\\n   561→\\t\\treturn 0\\n   562→\\t}\\n   563→\\n   564→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   565→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   566→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   567→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   568→\\t\\t\\treturn len(transcript.Messages)\\n   569→\\t\\t}\\n   570→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   571→\\t\\tif agentType == agent.AgentTypeGemini {\\n   572→\\t\\t\\treturn 0\\n   573→\\t\\t}\\n   574→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   575→\\t}\\n   576→\\n   577→\\t// Claude Code and other JSONL-based agents\\n   578→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   579→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   580→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   581→\\t\\tallLines = allLines[:len(allLines)-1]\\n   582→\\t}\\n   583→\\treturn len(allLines)\\n   584→}\\n   585→\\n   586→// extractUserPrompts extracts all user prompts from transcript content.\\n   587→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   588→func extractUserPrompts(agentType types.AgentType, content string) []string {\\n   589→\\tif content == \\\"\\\" {\\n   590→\\t\\treturn nil\\n   591→\\t}\\n   592→\\n   593→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   594→\\tif agentType == agent.AgentTypeOpenCode {\\n   595→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   596→\\t\\tif err == nil && len(prompts) > 0 {\\n   597→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   598→\\t\\t\\tfor _, prompt := range prompts {\\n   599→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   600→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   601→\\t\\t\\t\\t}\\n   602→\\t\\t\\t}\\n   603→\\t\\t\\treturn cleaned\\n   604→\\t\\t}\\n   605→\\t\\treturn nil\\n   606→\\t}\\n   607→\\n   608→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   609→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   610→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   611→\\t\\tif err == nil && len(prompts) > 0 {\\n   612→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   613→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   614→\\t\\t\\tfor _, prompt := range prompts {\\n   615→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   616→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   617→\\t\\t\\t\\t}\\n   618→\\t\\t\\t}\\n   619→\\t\\t\\treturn cleaned\\n   620→\\t\\t}\\n   621→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   622→\\t\\tif agentType == agent.AgentTypeGemini {\\n   623→\\t\\t\\treturn nil\\n   624→\\t\\t}\\n   625→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   626→\\t}\\n   627→\\n   628→\\t// Claude Code and other JSONL-based agents\\n   629→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   630→}\\n   631→\\n   632→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   633→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   634→func extractUserPromptsFromLines(lines []string) []string {\\n   635→\\tvar prompts []string\\n   636→\\tfor _, line := range lines {\\n   637→\\t\\tline = strings.TrimSpace(line)\\n   638→\\t\\tif line == \\\"\\\" {\\n   639→\\t\\t\\tcontinue\\n   640→\\t\\t}\\n   641→\\n   642→\\t\\tvar entry map[string]interface{}\\n   643→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   644→\\t\\t\\tcontinue\\n   645→\\t\\t}\\n   646→\\n   647→\\t\\t// Check for user message:\\n   648→\\t\\t// - Claude Code uses \\\"type\\\": \\\"human\\\" or \\\"type\\\": \\\"user\\\"\\n   649→\\t\\t// - Cursor uses \\\"role\\\": \\\"user\\\"\\n   650→\\t\\tmsgType, _ := entry[\\\"type\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   651→\\t\\tmsgRole, _ := entry[\\\"role\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   652→\\t\\tisUser := msgType == \\\"human\\\" || msgType == \\\"user\\\" || msgRole == \\\"user\\\"\\n   653→\\t\\tif !isUser {\\n   654→\\t\\t\\tcontinue\\n   655→\\t\\t}\\n   656→\\n   657→\\t\\t// Extract message content\\n   658→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   659→\\t\\tif !ok {\\n   660→\\t\\t\\tcontinue\\n   661→\\t\\t}\\n   662→\\n   663→\\t\\t// Handle string content\\n   664→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   665→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   666→\\t\\t\\tif cleaned != \\\"\\\" {\\n   667→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   668→\\t\\t\\t}\\n   669→\\t\\t\\tcontinue\\n   670→\\t\\t}\\n   671→\\n   672→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   673→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   674→\\t\\t\\tvar texts []string\\n   675→\\t\\t\\tfor _, item := range arr {\\n   676→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   677→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   678→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   679→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   680→\\t\\t\\t\\t\\t\\t}\\n   681→\\t\\t\\t\\t\\t}\\n   682→\\t\\t\\t\\t}\\n   683→\\t\\t\\t}\\n   684→\\t\\t\\tif len(texts) > 0 {\\n   685→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   686→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   687→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   688→\\t\\t\\t\\t}\\n   689→\\t\\t\\t}\\n   690→\\t\\t}\\n   691→\\t}\\n   692→\\treturn prompts\\n   693→}\\n   694→\\n   695→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   696→func generateContextFromPrompts(prompts []string) []byte {\\n   697→\\tif len(prompts) == 0 {\\n   698→\\t\\treturn nil\\n   699→\\t}\\n   700→\\n   701→\\tvar buf strings.Builder\\n   702→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   703→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   704→\\n   705→\\tfor i, prompt := range prompts {\\n   706→\\t\\t// Truncate very long prompts for readability.\\n   707→\\t\\t// Use rune-based truncation to avoid splitting multi-byte UTF-8 characters (e.g. CJK).\\n   708→\\t\\tconst maxDisplayPromptRunes = 500\\n   709→\\t\\tdisplayPrompt := stringutil.TruncateRunes(prompt, maxDisplayPromptRunes, \\\"...\\\")\\n   710→\\t\\tfmt.Fprintf(&buf, \\\"### Prompt %d\\\\n\\\\n\\\", i+1)\\n   711→\\t\\tbuf.WriteString(displayPrompt)\\n   712→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   713→\\t}\\n   714→\\n   715→\\treturn []byte(buf.String())\\n   716→}\\n   717→\\n   718→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   719→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   720→func (s *ManualCommitStrategy) CondenseSessionByID(ctx context.Context, sessionID string) error {\\n   721→\\tlogCtx := logging.WithComponent(ctx, \\\"condense-by-id\\\")\\n   722→\\n   723→\\t// Load session state\\n   724→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   725→\\tif err != nil {\\n   726→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   727→\\t}\\n   728→\\tif state == nil {\\n   729→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   730→\\t}\\n   731→\\n   732→\\t// Open repository\\n   733→\\trepo, err := OpenRepository(ctx)\\n   734→\\tif err != nil {\\n   735→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   736→\\t}\\n   737→\\n   738→\\t// Generate a checkpoint ID\\n   739→\\tcheckpointID, err := id.Generate()\\n   740→\\tif err != nil {\\n   741→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   742→\\t}\\n   743→\\n   744→\\t// Check if shadow branch exists (required for condensation)\\n   745→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   746→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   747→\\t_, refErr := repo.Reference(refName, true)\\n   748→\\thasShadowBranch := refErr == nil\\n   749→\\n   750→\\tif !hasShadowBranch {\\n   751→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   752→\\t\\t// Just clean up the state file.\\n   753→\\t\\tlogging.Info(logCtx, \\\"no shadow branch for session, clearing state only\\\",\\n   754→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   755→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   756→\\t\\t)\\n   757→\\t\\tif err := s.clearSessionState(ctx, sessionID); err != nil {\\n   758→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   759→\\t\\t}\\n   760→\\t\\treturn nil\\n   761→\\t}\\n   762→\\n   763→\\t// Condense the session\\n   764→\\tresult, err := s.CondenseSession(ctx, repo, checkpointID, state, nil)\\n   765→\\tif err != nil {\\n   766→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   767→\\t}\\n   768→\\n   769→\\tlogging.Info(logCtx, \\\"session condensed by ID\\\",\\n   770→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   771→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   772→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   773→\\t)\\n   774→\\n   775→\\t// Update session state: reset step count and transition to idle\\n   776→\\tstate.StepCount = 0\\n   777→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   778→\\tstate.Phase = session.PhaseIdle\\n   779→\\tstate.LastCheckpointID = checkpointID\\n   780→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   781→\\tstate.PromptAttributions = nil\\n   782→\\tstate.PendingPromptAttribution = nil\\n   783→\\n   784→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   785→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   786→\\t}\\n   787→\\n   788→\\t// Clean up shadow branch if no other sessions need it\\n   789→\\tif err := s.cleanupShadowBranchIfUnused(ctx, repo, shadowBranchName, sessionID); err != nil {\\n   790→\\t\\tlogging.Warn(logCtx, \\\"failed to clean up shadow branch\\\",\\n   791→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   792→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   793→\\t\\t)\\n   794→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   795→\\t}\\n   796→\\n   797→\\treturn nil\\n   798→}\\n   799→\\n   800→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   801→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(ctx context.Context, _ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   802→\\t// List all session states to check if any other session uses this shadow branch\\n   803→\\tallStates, err := s.listAllSessionStates(ctx)\\n   804→\\tif err != nil {\\n   805→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   806→\\t}\\n   807→\\n   808→\\tfor _, state := range allStates {\\n   809→\\t\\tif state.SessionID == excludeSessionID {\\n   810→\\t\\t\\tcontinue\\n   811→\\t\\t}\\n   812→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   813→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   814→\\t\\t\\t// Another session still needs this shadow branch\\n   815→\\t\\t\\treturn nil\\n   816→\\t\\t}\\n   817→\\t}\\n   818→\\n   819→\\t// No other sessions need it, delete the shadow branch via CLI\\n   820→\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n   821→\\tif err := DeleteBranchCLI(ctx, shadowBranchName); err != nil {\\n   822→\\t\\t// Branch already gone is not an error\\n   823→\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n   824→\\t\\t\\treturn nil\\n   825→\\t\\t}\\n   826→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n   827→\\t}\\n   828→\\treturn nil\\n   829→}\\n   830→\"}]},\"uuid\":\"7b06059d-a3ef-4811-b5a7-738457bd4f41\",\"timestamp\":\"2026-02-27T12:28:39.367Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli_worktree1/cmd/entire/cli/strategy/manual_commit_condensation.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/opencode\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/stringutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// listCheckpoints returns all checkpoints from the metadata branch.\\n// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) listCheckpoints(ctx context.Context) ([]CheckpointInfo, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcommitted, err := store.ListCommitted(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n\\t}\\n\\n\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n\\tresult := make([]CheckpointInfo, 0, len(committed))\\n\\tfor _, c := range committed {\\n\\t\\tresult = append(result, CheckpointInfo{\\n\\t\\t\\tCheckpointID:     c.CheckpointID,\\n\\t\\t\\tSessionID:        c.SessionID,\\n\\t\\t\\tCreatedAt:        c.CreatedAt,\\n\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n\\t\\t\\tFilesTouched:     c.FilesTouched,\\n\\t\\t\\tAgent:            c.Agent,\\n\\t\\t\\tIsTask:           c.IsTask,\\n\\t\\t\\tToolUseID:        c.ToolUseID,\\n\\t\\t\\tSessionCount:     c.SessionCount,\\n\\t\\t\\tSessionIDs:       c.SessionIDs,\\n\\t\\t})\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointsForSession returns all checkpoints for a session ID.\\nfunc (s *ManualCommitStrategy) getCheckpointsForSession(ctx context.Context, sessionID string) ([]CheckpointInfo, error) {\\n\\tall, err := s.listCheckpoints(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tvar result []CheckpointInfo\\n\\tfor _, cp := range all {\\n\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n\\t\\t\\tresult = append(result, cp)\\n\\t\\t}\\n\\t}\\n\\n\\tif len(result) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) getCheckpointLog(ctx context.Context, checkpointID id.CheckpointID) ([]byte, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(ctx, checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// condenseOpts provides pre-resolved git objects to avoid redundant reads.\\ntype condenseOpts struct {\\n\\tshadowRef *plumbing.Reference // Pre-resolved shadow branch ref (nil = resolve from repo)\\n\\theadTree  *object.Tree        // Pre-resolved HEAD tree (passed through to calculateSessionAttributions)\\n}\\n\\n// CondenseSession condenses a session's shadow branch to permanent storage.\\n// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n//\\n// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n// In this case, data is extracted from the live transcript instead.\\nfunc (s *ManualCommitStrategy) CondenseSession(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}, opts ...condenseOpts) (*CondenseResult, error) {\\n\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n\\tvar o condenseOpts\\n\\tif len(opts) > 0 {\\n\\t\\to = opts[0]\\n\\t}\\n\\n\\t// Get shadow branch — use pre-resolved ref if available, otherwise resolve from repo.\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\tref := o.shadowRef\\n\\tvar hasShadowBranch bool\\n\\tif ref != nil {\\n\\t\\thasShadowBranch = true\\n\\t} else {\\n\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\t\\tvar err error\\n\\t\\tref, err = repo.Reference(refName, true)\\n\\t\\thasShadowBranch = err == nil\\n\\t}\\n\\n\\tvar sessionData *ExtractedSessionData\\n\\tif hasShadowBranch {\\n\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n\\t\\t// last turn had no code changes).\\n\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n\\t\\tvar extractErr error\\n\\t\\tsessionData, extractErr = s.extractSessionData(ctx, repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n\\t\\tif extractErr != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", extractErr)\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n\\t\\t// Extract data directly from live transcript.\\n\\t\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n\\t\\t}\\n\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n\\t\\tif state.Phase.IsActive() {\\n\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, state.TranscriptPath)\\n\\t\\t}\\n\\t\\tvar extractErr error\\n\\t\\tsessionData, extractErr = s.extractSessionDataFromLiveTranscript(ctx, state)\\n\\t\\tif extractErr != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", extractErr)\\n\\t\\t}\\n\\t}\\n\\n\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n\\t// committed in this specific commit. This ensures each checkpoint represents\\n\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n\\tif len(committedFiles) > 0 {\\n\\t\\t// Track if we had files before filtering to distinguish between:\\n\\t\\t// - Session had files but none were committed (don't fallback)\\n\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n\\n\\t\\tif hadFilesBeforeFiltering {\\n\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tsessionData.FilesTouched = filtered\\n\\t\\t}\\n\\n\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n\\t\\t// the session had files that simply didn't overlap with the commit - that\\n\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n\\t\\t// overwritten with unrelated committed files.\\n\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n\\t\\t\\tfor f := range committedFiles {\\n\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Get checkpoint store\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get author info\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n\\tattribution := calculateSessionAttributions(ctx, repo, ref, sessionData, state, attributionOpts{\\n\\t\\theadTree: o.headTree,\\n\\t})\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Generate summary if enabled\\n\\tvar summary *cpkg.Summary\\n\\tif settings.IsSummarizeEnabled(ctx) && len(sessionData.Transcript) > 0 {\\n\\t\\tsummarizeCtx := logging.WithComponent(ctx, \\\"summarize\\\")\\n\\n\\t\\t// Scope transcript to this checkpoint's portion.\\n\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n\\t\\tvar scopedTranscript []byte\\n\\t\\tswitch state.AgentType {\\n\\t\\tcase agent.AgentTypeGemini:\\n\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t\\tif sliceErr != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n\\t\\t\\t}\\n\\t\\t\\tscopedTranscript = scoped\\n\\t\\tcase agent.AgentTypeOpenCode:\\n\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t\\tif sliceErr != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n\\t\\t\\t}\\n\\t\\t\\tscopedTranscript = scoped\\n\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeUnknown:\\n\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t}\\n\\t\\tif len(scopedTranscript) > 0 {\\n\\t\\t\\tvar err error\\n\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t\\t// Continue without summary - non-blocking\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write checkpoint metadata using the checkpoint store\\n\\tif err := store.WriteCommitted(ctx, cpkg.WriteCommittedOptions{\\n\\t\\tCheckpointID:                checkpointID,\\n\\t\\tSessionID:                   state.SessionID,\\n\\t\\tStrategy:                    StrategyNameManualCommit,\\n\\t\\tBranch:                      branchName,\\n\\t\\tTranscript:                  sessionData.Transcript,\\n\\t\\tPrompts:                     sessionData.Prompts,\\n\\t\\tContext:                     sessionData.Context,\\n\\t\\tFilesTouched:                sessionData.FilesTouched,\\n\\t\\tCheckpointsCount:            state.StepCount,\\n\\t\\tEphemeralBranch:             shadowBranchName,\\n\\t\\tAuthorName:                  authorName,\\n\\t\\tAuthorEmail:                 authorEmail,\\n\\t\\tAgent:                       state.AgentType,\\n\\t\\tTurnID:                      state.TurnID,\\n\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n\\t\\tInitialAttribution:          attribution,\\n\\t\\tSummary:                     summary,\\n\\t}); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n\\t}\\n\\n\\treturn &CondenseResult{\\n\\t\\tCheckpointID:         checkpointID,\\n\\t\\tSessionID:            state.SessionID,\\n\\t\\tCheckpointsCount:     state.StepCount,\\n\\t\\tFilesTouched:         sessionData.FilesTouched,\\n\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n\\t}, nil\\n}\\n\\n// attributionOpts provides pre-resolved git objects to avoid redundant reads.\\ntype attributionOpts struct {\\n\\theadTree   *object.Tree // HEAD commit tree (already resolved by PostCommit)\\n\\tshadowTree *object.Tree // Shadow branch tree (already resolved by PostCommit)\\n}\\n\\nfunc calculateSessionAttributions(ctx context.Context, repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState, opts ...attributionOpts) *cpkg.InitialAttribution {\\n\\t// Calculate initial attribution using accumulated prompt attribution data.\\n\\t// This uses user edits captured at each prompt start (before agent works),\\n\\t// plus any user edits after the final checkpoint (shadow → head).\\n\\t//\\n\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n\\tlogCtx := logging.WithComponent(ctx, \\\"attribution\\\")\\n\\n\\tvar o attributionOpts\\n\\tif len(opts) > 0 {\\n\\t\\to = opts[0]\\n\\t}\\n\\n\\theadTree := o.headTree\\n\\tif headTree == nil {\\n\\t\\theadRef, headErr := repo.Head()\\n\\t\\tif headErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n\\t\\tif commitErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\tvar treeErr error\\n\\t\\theadTree, treeErr = headCommit.Tree()\\n\\t\\tif treeErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t}\\n\\n\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n\\tshadowTree := o.shadowTree\\n\\tif shadowTree == nil {\\n\\t\\tif shadowRef != nil {\\n\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n\\t\\t\\tif shadowErr != nil {\\n\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n\\t\\t\\t\\treturn nil\\n\\t\\t\\t}\\n\\t\\t\\tvar shadowTreeErr error\\n\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n\\t\\t\\tif shadowTreeErr != nil {\\n\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n\\t\\t\\t\\treturn nil\\n\\t\\t\\t}\\n\\t\\t} else {\\n\\t\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n\\t\\t\\t// because the agent's work is the commit itself.\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n\\t\\t\\tshadowTree = headTree\\n\\t\\t}\\n\\t}\\n\\n\\t// Get base tree (state before session started)\\n\\tvar baseTree *object.Tree\\n\\tattrBase := state.AttributionBaseCommit\\n\\tif attrBase == \\\"\\\" {\\n\\t\\tattrBase = state.BaseCommit // backward compat\\n\\t}\\n\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n\\t\\t\\tbaseTree = tree\\n\\t\\t} else {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n\\t\\t}\\n\\t} else {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n\\t}\\n\\n\\t// Log accumulated prompt attributions for debugging\\n\\tvar totalUserAdded, totalUserRemoved int\\n\\tfor i, pa := range state.PromptAttributions {\\n\\t\\ttotalUserAdded += pa.UserLinesAdded\\n\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"index\\\", i))\\n\\t}\\n\\n\\tattribution := CalculateAttributionWithAccumulated(\\n\\t\\tctx,\\n\\t\\tbaseTree,\\n\\t\\tshadowTree,\\n\\t\\theadTree,\\n\\t\\tsessionData.FilesTouched,\\n\\t\\tstate.PromptAttributions,\\n\\t)\\n\\n\\tif attribution != nil {\\n\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n\\t}\\n\\n\\treturn attribution\\n}\\n\\n// extractSessionData extracts session data from the shadow branch.\\n// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n// continued growing — the shadow branch copy would be stale.\\n// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\nfunc (s *ManualCommitStrategy) extractSessionData(ctx context.Context, repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType types.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n\\tag, _ := agent.GetByAgentType(agentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n\\tcommit, err := repo.CommitObject(shadowRef)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\tdata := &ExtractedSessionData{}\\n\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\n\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n\\t// (SaveStep is only called when there are file modifications).\\n\\tvar fullTranscript string\\n\\tif liveTranscriptPath != \\\"\\\" {\\n\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n\\t\\tif isActive {\\n\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, liveTranscriptPath)\\n\\t\\t}\\n\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n\\t\\t\\tfullTranscript = string(liveData)\\n\\t\\t}\\n\\t}\\n\\tif fullTranscript == \\\"\\\" {\\n\\t\\t// Fall back to shadow branch copy\\n\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Process transcript based on agent type\\n\\tif fullTranscript != \\\"\\\" {\\n\\t\\tdata.Transcript = []byte(fullTranscript)\\n\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\t}\\n\\n\\t// Use tracked files from session state (not all files in tree)\\n\\tdata.FilesTouched = filesTouched\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, checkpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n// This is used for mid-session commits where no shadow branch exists yet.\\nfunc (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(ctx context.Context, state *SessionState) (*ExtractedSessionData, error) {\\n\\tdata := &ExtractedSessionData{}\\n\\n\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n\\n\\t// Read the live transcript\\n\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n\\t}\\n\\n\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n\\t}\\n\\n\\tif len(liveData) == 0 {\\n\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n\\t}\\n\\n\\tfullTranscript := string(liveData)\\n\\tdata.Transcript = liveData\\n\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\n\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n\\t// (no SaveStep/Stop has been called yet to populate it)\\n\\tif len(state.FilesTouched) > 0 {\\n\\t\\tdata.FilesTouched = state.FilesTouched\\n\\t} else {\\n\\t\\t// Use the shared helper which includes subagent transcripts\\n\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(ctx, state, state.CheckpointTranscriptStart)\\n\\t}\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, state.CheckpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n// For Claude Code and JSONL-based agents, this counts lines.\\n// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n// Returns 0 if the content is empty or malformed.\\nfunc countTranscriptItems(agentType types.AgentType, content string) int {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn 0\\n\\t}\\n\\n\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n\\tif agentType == agent.AgentTypeOpenCode {\\n\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n\\t\\tif err == nil && session != nil {\\n\\t\\t\\treturn len(session.Messages)\\n\\t\\t}\\n\\t\\treturn 0\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n\\t\\t\\treturn len(transcript.Messages)\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn 0\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n\\t\\tallLines = allLines[:len(allLines)-1]\\n\\t}\\n\\treturn len(allLines)\\n}\\n\\n// extractUserPrompts extracts all user prompts from transcript content.\\n// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\nfunc extractUserPrompts(agentType types.AgentType, content string) []string {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n\\tif agentType == agent.AgentTypeOpenCode {\\n\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n\\t\\tif err == nil && len(prompts) > 0 {\\n\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n\\t\\t\\tfor _, prompt := range prompts {\\n\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\treturn cleaned\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n\\t\\tif err == nil && len(prompts) > 0 {\\n\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n\\t\\t\\tfor _, prompt := range prompts {\\n\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\treturn cleaned\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n}\\n\\n// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\nfunc extractUserPromptsFromLines(lines []string) []string {\\n\\tvar prompts []string\\n\\tfor _, line := range lines {\\n\\t\\tline = strings.TrimSpace(line)\\n\\t\\tif line == \\\"\\\" {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tvar entry map[string]interface{}\\n\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Check for user message:\\n\\t\\t// - Claude Cod