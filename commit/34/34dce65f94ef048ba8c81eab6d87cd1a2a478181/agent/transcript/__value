l\\\", false, \\\"Completely remove Entire from this repository\\\")\\n   179→\\tcmd.Flags().BoolVar(&force, \\\"force\\\", false, \\\"Skip confirmation prompt (use with --uninstall)\\\")\\n   180→\\n   181→\\treturn cmd\\n   182→}\\n   183→\\n   184→// runEnableWithStrategy enables Entire with a specified strategy (non-interactive).\\n   185→// The selectedStrategy can be either a display name (manual-commit, auto-commit)\\n   186→// or an internal name (manual-commit, auto-commit).\\n   187→// agents must be provided by the caller (via detectOrSelectAgent).\\n   188→func runEnableWithStrategy(w io.Writer, agents []agent.Agent, selectedStrategy string, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry bool) error {\\n   189→\\t// Map the strategy to internal name if it's a display name\\n   190→\\tinternalStrategy := selectedStrategy\\n   191→\\tif mapped, ok := strategyDisplayToInternal[selectedStrategy]; ok {\\n   192→\\t\\tinternalStrategy = mapped\\n   193→\\t}\\n   194→\\n   195→\\t// Validate the strategy exists\\n   196→\\tstrat, err := strategy.Get(internalStrategy)\\n   197→\\tif err != nil {\\n   198→\\t\\treturn fmt.Errorf(\\\"unknown strategy: %s (use manual-commit or auto-commit)\\\", selectedStrategy)\\n   199→\\t}\\n   200→\\n   201→\\t// Uninstall hooks for agents that were previously active but are no longer selected\\n   202→\\tif err := uninstallDeselectedAgentHooks(w, agents); err != nil {\\n   203→\\t\\treturn fmt.Errorf(\\\"failed to clean up deselected agents: %w\\\", err)\\n   204→\\t}\\n   205→\\n   206→\\t// Setup agent hooks for all selected agents\\n   207→\\tfor _, ag := range agents {\\n   208→\\t\\tif _, err := setupAgentHooks(ag, localDev, forceHooks); err != nil {\\n   209→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   210→\\t\\t}\\n   211→\\t}\\n   212→\\n   213→\\t// Setup .entire directory\\n   214→\\tif _, err := setupEntireDirectory(); err != nil {\\n   215→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   216→\\t}\\n   217→\\n   218→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   219→\\tsettings, err := LoadEntireSettings()\\n   220→\\tif err != nil {\\n   221→\\t\\t// If we can't load, start with defaults\\n   222→\\t\\tsettings = &EntireSettings{}\\n   223→\\t}\\n   224→\\t// Update the specific fields\\n   225→\\tsettings.Strategy = internalStrategy\\n   226→\\tsettings.LocalDev = localDev\\n   227→\\tsettings.Enabled = true\\n   228→\\n   229→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   230→\\tif skipPushSessions {\\n   231→\\t\\tif settings.StrategyOptions == nil {\\n   232→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   233→\\t\\t}\\n   234→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   235→\\t}\\n   236→\\n   237→\\t// Handle telemetry for non-interactive mode\\n   238→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   239→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   240→\\t\\tf := false\\n   241→\\t\\tsettings.Telemetry = &f\\n   242→\\t}\\n   243→\\n   244→\\t// Determine which settings file to write to\\n   245→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   246→\\tif err != nil {\\n   247→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   248→\\t}\\n   249→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   250→\\n   251→\\tif showNotification {\\n   252→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   253→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   254→\\t}\\n   255→\\n   256→\\tconfigDisplay := configDisplayProject\\n   257→\\tif shouldUseLocal {\\n   258→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   259→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   260→\\t\\t}\\n   261→\\t\\tconfigDisplay = configDisplayLocal\\n   262→\\t} else {\\n   263→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   264→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   265→\\t\\t}\\n   266→\\t}\\n   267→\\n   268→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   269→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   270→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   271→\\t}\\n   272→\\tstrategy.CheckAndWarnHookManagers(w)\\n   273→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   274→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   275→\\n   276→\\t// Let the strategy handle its own setup requirements\\n   277→\\tif err := strat.EnsureSetup(); err != nil {\\n   278→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   279→\\t}\\n   280→\\n   281→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   282→\\n   283→\\treturn nil\\n   284→}\\n   285→\\n   286→// runEnableInteractive runs the interactive enable flow.\\n   287→// agents must be provided by the caller (via detectOrSelectAgent).\\n   288→func runEnableInteractive(w io.Writer, agents []agent.Agent, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry bool) error {\\n   289→\\t// Uninstall hooks for agents that were previously active but are no longer selected\\n   290→\\tif err := uninstallDeselectedAgentHooks(w, agents); err != nil {\\n   291→\\t\\treturn fmt.Errorf(\\\"failed to clean up deselected agents: %w\\\", err)\\n   292→\\t}\\n   293→\\n   294→\\t// Setup agent hooks for all selected agents\\n   295→\\tfor _, ag := range agents {\\n   296→\\t\\tif _, err := setupAgentHooks(ag, localDev, forceHooks); err != nil {\\n   297→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   298→\\t\\t}\\n   299→\\t}\\n   300→\\n   301→\\t// Setup .entire directory\\n   302→\\tif _, err := setupEntireDirectory(); err != nil {\\n   303→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   304→\\t}\\n   305→\\n   306→\\t// Use the default strategy (manual-commit)\\n   307→\\tinternalStrategy := strategy.DefaultStrategyName\\n   308→\\n   309→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   310→\\tsettings, err := LoadEntireSettings()\\n   311→\\tif err != nil {\\n   312→\\t\\t// If we can't load, start with defaults\\n   313→\\t\\tsettings = &EntireSettings{}\\n   314→\\t}\\n   315→\\t// Update the specific fields\\n   316→\\tsettings.Strategy = internalStrategy\\n   317→\\tsettings.LocalDev = localDev\\n   318→\\tsettings.Enabled = true\\n   319→\\n   320→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   321→\\tif skipPushSessions {\\n   322→\\t\\tif settings.StrategyOptions == nil {\\n   323→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   324→\\t\\t}\\n   325→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   326→\\t}\\n   327→\\n   328→\\t// Determine which settings file to write to\\n   329→\\t// First run always creates settings.json (no prompt)\\n   330→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   331→\\tif err != nil {\\n   332→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   333→\\t}\\n   334→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   335→\\n   336→\\tif showNotification {\\n   337→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   338→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   339→\\t}\\n   340→\\n   341→\\t// Helper to save settings to the appropriate file\\n   342→\\tsaveSettings := func() error {\\n   343→\\t\\tif shouldUseLocal {\\n   344→\\t\\t\\treturn SaveEntireSettingsLocal(settings)\\n   345→\\t\\t}\\n   346→\\t\\treturn SaveEntireSettings(settings)\\n   347→\\t}\\n   348→\\n   349→\\t// Save settings before telemetry prompt so config is persisted even if the user cancels\\n   350→\\tif err := saveSettings(); err != nil {\\n   351→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   352→\\t}\\n   353→\\n   354→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   355→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   356→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   357→\\t}\\n   358→\\tstrategy.CheckAndWarnHookManagers(w)\\n   359→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   360→\\n   361→\\tconfigDisplay := configDisplayProject\\n   362→\\tif shouldUseLocal {\\n   363→\\t\\tconfigDisplay = configDisplayLocal\\n   364→\\t}\\n   365→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   366→\\n   367→\\t// Ask about telemetry consent (only if not already asked)\\n   368→\\tfmt.Fprintln(w)\\n   369→\\tif err := promptTelemetryConsent(settings, telemetry); err != nil {\\n   370→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   371→\\t}\\n   372→\\t// Save again to persist telemetry choice\\n   373→\\tif err := saveSettings(); err != nil {\\n   374→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   375→\\t}\\n   376→\\n   377→\\t// Let the strategy handle its own setup requirements\\n   378→\\tstrat, err := strategy.Get(internalStrategy)\\n   379→\\tif err != nil {\\n   380→\\t\\treturn fmt.Errorf(\\\"failed to get strategy: %w\\\", err)\\n   381→\\t}\\n   382→\\tif err := strat.EnsureSetup(); err != nil {\\n   383→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   384→\\t}\\n   385→\\n   386→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   387→\\n   388→\\treturn nil\\n   389→}\\n   390→\\n   391→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   392→func runEnable(w io.Writer) error {\\n   393→\\tsettings, err := LoadEntireSettings()\\n   394→\\tif err != nil {\\n   395→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   396→\\t}\\n   397→\\n   398→\\tsettings.Enabled = true\\n   399→\\tif err := SaveEntireSettings(settings); err != nil {\\n   400→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   401→\\t}\\n   402→\\n   403→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   404→\\treturn nil\\n   405→}\\n   406→\\n   407→func runDisable(w io.Writer, useProjectSettings bool) error {\\n   408→\\tsettings, err := LoadEntireSettings()\\n   409→\\tif err != nil {\\n   410→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   411→\\t}\\n   412→\\n   413→\\tsettings.Enabled = false\\n   414→\\n   415→\\t// If --project flag is specified, always write to project settings\\n   416→\\tif useProjectSettings {\\n   417→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   418→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   419→\\t\\t}\\n   420→\\t} else {\\n   421→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   422→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   423→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   424→\\t\\t}\\n   425→\\t}\\n   426→\\n   427→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   428→\\treturn nil\\n   429→}\\n   430→\\n   431→// DisabledMessage is the message shown when Entire is disabled\\n   432→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   433→\\n   434→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   435→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   436→// On error reading settings, defaults to enabled (returns false).\\n   437→func checkDisabledGuard(w io.Writer) bool {\\n   438→\\tenabled, err := IsEnabled()\\n   439→\\tif err != nil {\\n   440→\\t\\t// Default to enabled on error\\n   441→\\t\\treturn false\\n   442→\\t}\\n   443→\\tif !enabled {\\n   444→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   445→\\t\\treturn true\\n   446→\\t}\\n   447→\\treturn false\\n   448→}\\n   449→\\n   450→// uninstallDeselectedAgentHooks removes hooks for agents that were previously\\n   451→// installed but are not in the selected list. This handles the case where a user\\n   452→// re-runs `entire enable` and deselects an agent.\\n   453→func uninstallDeselectedAgentHooks(w io.Writer, selectedAgents []agent.Agent) error {\\n   454→\\tinstalledNames := GetAgentsWithHooksInstalled()\\n   455→\\tif len(installedNames) == 0 {\\n   456→\\t\\treturn nil\\n   457→\\t}\\n   458→\\n   459→\\tselectedSet := make(map[agent.AgentName]struct{}, len(selectedAgents))\\n   460→\\tfor _, ag := range selectedAgents {\\n   461→\\t\\tselectedSet[ag.Name()] = struct{}{}\\n   462→\\t}\\n   463→\\n   464→\\tvar errs []error\\n   465→\\tfor _, name := range installedNames {\\n   466→\\t\\tif _, selected := selectedSet[name]; selected {\\n   467→\\t\\t\\tcontinue\\n   468→\\t\\t}\\n   469→\\t\\tag, err := agent.Get(name)\\n   470→\\t\\tif err != nil {\\n   471→\\t\\t\\tcontinue\\n   472→\\t\\t}\\n   473→\\t\\thookAgent, ok := ag.(agent.HookSupport)\\n   474→\\t\\tif !ok {\\n   475→\\t\\t\\tcontinue\\n   476→\\t\\t}\\n   477→\\t\\tif err := hookAgent.UninstallHooks(); err != nil {\\n   478→\\t\\t\\terrs = append(errs, fmt.Errorf(\\\"failed to uninstall %s hooks: %w\\\", ag.Type(), err))\\n   479→\\t\\t} else {\\n   480→\\t\\t\\tfmt.Fprintf(w, \\\"Removed %s hooks\\\\n\\\", ag.Type())\\n   481→\\t\\t}\\n   482→\\t}\\n   483→\\treturn errors.Join(errs...)\\n   484→}\\n   485→\\n   486→// setupAgentHooks sets up hooks for a given agent.\\n   487→// Returns the number of hooks installed (0 if already installed).\\n   488→func setupAgentHooks(ag agent.Agent, localDev, forceHooks bool) (int, error) { //nolint:unparam // return value used by setupAgentHooksNonInteractive\\n   489→\\thookAgent, ok := ag.(agent.HookSupport)\\n   490→\\tif !ok {\\n   491→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   492→\\t}\\n   493→\\n   494→\\tcount, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   495→\\tif err != nil {\\n   496→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   497→\\t}\\n   498→\\n   499→\\treturn count, nil\\n   500→}\\n   501→\\n   502→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   503→// Returns the detected/selected agents and any error.\\n   504→//\\n   505→// On first run (no hooks installed):\\n   506→//   - Single detected agent: used automatically\\n   507→//   - Multiple/no detected agents: interactive multi-select prompt\\n   508→//\\n   509→// On re-run (hooks already installed):\\n   510→//   - Always shows the interactive multi-select\\n   511→//   - Pre-selects only agents that have hooks installed (respects prior deselection)\\n   512→//\\n   513→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   514→// It receives available agent names and returns the selected names.\\n   515→func detectOrSelectAgent(w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   516→\\t// Check for agents with hooks already installed (re-run detection)\\n   517→\\tinstalledAgentNames := GetAgentsWithHooksInstalled()\\n   518→\\thasInstalledHooks := len(installedAgentNames) > 0\\n   519→\\n   520→\\t// Try auto-detection\\n   521→\\tdetected := agent.DetectAll()\\n   522→\\n   523→\\t// First run: use existing auto-detect shortcuts\\n   524→\\tif !hasInstalledHooks {\\n   525→\\t\\tswitch {\\n   526→\\t\\tcase len(detected) == 1:\\n   527→\\t\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   528→\\t\\t\\treturn detected, nil\\n   529→\\n   530→\\t\\tcase len(detected) > 1:\\n   531→\\t\\t\\tagentTypes := make([]string, 0, len(detected))\\n   532→\\t\\t\\tfor _, ag := range detected {\\n   533→\\t\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   534→\\t\\t\\t}\\n   535→\\t\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   536→\\t\\t\\tfmt.Fprintln(w)\\n   537→\\t\\t}\\n   538→\\t}\\n   539→\\n   540→\\t// Check if we can prompt interactively\\n   541→\\tif !canPromptInteractively() {\\n   542→\\t\\tif hasInstalledHooks {\\n   543→\\t\\t\\t// Re-run without TTY — keep currently installed agents\\n   544→\\t\\t\\tagents := make([]agent.Agent, 0, len(installedAgentNames))\\n   545→\\t\\t\\tfor _, name := range installedAgentNames {\\n   546→\\t\\t\\t\\tag, err := agent.Get(name)\\n   547→\\t\\t\\t\\tif err != nil {\\n   548→\\t\\t\\t\\t\\tcontinue\\n   549→\\t\\t\\t\\t}\\n   550→\\t\\t\\t\\tagents = append(agents, ag)\\n   551→\\t\\t\\t}\\n   552→\\t\\t\\treturn agents, nil\\n   553→\\t\\t}\\n   554→\\t\\tif len(detected) > 0 {\\n   555→\\t\\t\\treturn detected, nil\\n   556→\\t\\t}\\n   557→\\t\\tdefaultAgent := agent.Default()\\n   558→\\t\\tif defaultAgent == nil {\\n   559→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   560→\\t\\t}\\n   561→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   562→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   563→\\t}\\n   564→\\n   565→\\tif !hasInstalledHooks && len(detected) == 0 {\\n   566→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., .claude or .gemini directory).\\\")\\n   567→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   568→\\t\\tfmt.Fprintln(w)\\n   569→\\t}\\n   570→\\n   571→\\t// Build pre-selection set.\\n   572→\\t// On re-run: only pre-select agents with hooks installed (respect prior deselection).\\n   573→\\t// On first run: pre-select all detected agents.\\n   574→\\tpreSelectedSet := make(map[agent.AgentName]struct{})\\n   575→\\tif hasInstalledHooks {\\n   576→\\t\\tfor _, name := range installedAgentNames {\\n   577→\\t\\t\\tpreSelectedSet[name] = struct{}{}\\n   578→\\t\\t}\\n   579→\\t} else {\\n   580→\\t\\tfor _, ag := range detected {\\n   581→\\t\\t\\tpreSelectedSet[ag.Name()] = struct{}{}\\n   582→\\t\\t}\\n   583→\\t}\\n   584→\\n   585→\\t// Build options from registered agents\\n   586→\\tagentNames := agent.List()\\n   587→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   588→\\tfor _, name := range agentNames {\\n   589→\\t\\tag, err := agent.Get(name)\\n   590→\\t\\tif err != nil {\\n   591→\\t\\t\\tcontinue\\n   592→\\t\\t}\\n   593→\\t\\t// Only show agents that support hooks\\n   594→\\t\\tif _, ok := ag.(agent.HookSupport); !ok {\\n   595→\\t\\t\\tcontinue\\n   596→\\t\\t}\\n   597→\\t\\topt := huh.NewOption(string(ag.Type()), string(name))\\n   598→\\t\\tif _, isPreSelected := preSelectedSet[name]; isPreSelected {\\n   599→\\t\\t\\topt = opt.Selected(true)\\n   600→\\t\\t}\\n   601→\\t\\toptions = append(options, opt)\\n   602→\\t}\\n   603→\\n   604→\\tif len(options) == 0 {\\n   605→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   606→\\t}\\n   607→\\n   608→\\t// Collect available agent names for the selector\\n   609→\\tavailableNames := make([]string, 0, len(options))\\n   610→\\tfor _, opt := range options {\\n   611→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   612→\\t}\\n   613→\\n   614→\\tvar selectedAgentNames []string\\n   615→\\tif selectFn != nil {\\n   616→\\t\\tvar err error\\n   617→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   618→\\t\\tif err != nil {\\n   619→\\t\\t\\treturn nil, err\\n   620→\\t\\t}\\n   621→\\t\\tif len(selectedAgentNames) == 0 {\\n   622→\\t\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   623→\\t\\t}\\n   624→\\t} else {\\n   625→\\t\\tform := NewAccessibleForm(\\n   626→\\t\\t\\thuh.NewGroup(\\n   627→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   628→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   629→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   630→\\t\\t\\t\\t\\tOptions(options...).\\n   631→\\t\\t\\t\\t\\tValidate(func(selected []string) error {\\n   632→\\t\\t\\t\\t\\t\\tif len(selected) == 0 {\\n   633→\\t\\t\\t\\t\\t\\t\\treturn errors.New(\\\"please select at least one agent\\\")\\n   634→\\t\\t\\t\\t\\t\\t}\\n   635→\\t\\t\\t\\t\\t\\treturn nil\\n   636→\\t\\t\\t\\t\\t}).\\n   637→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   638→\\t\\t\\t),\\n   639→\\t\\t)\\n   640→\\t\\tif err := form.Run(); err != nil {\\n   641→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   642→\\t\\t}\\n   643→\\t}\\n   644→\\n   645→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   646→\\tfor _, name := range selectedAgentNames {\\n   647→\\t\\tselectedAgent, err := agent.Get(agent.AgentName(name))\\n   648→\\t\\tif err != nil {\\n   649→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   650→\\t\\t}\\n   651→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   652→\\t}\\n   653→\\n   654→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   655→\\tfor _, ag := range selectedAgents {\\n   656→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   657→\\t}\\n   658→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   659→\\treturn selectedAgents, nil\\n   660→}\\n   661→\\n   662→// canPromptInteractively checks if we can show interactive prompts.\\n   663→// Returns false when running in CI, tests, or other non-interactive environments.\\n   664→func canPromptInteractively() bool {\\n   665→\\t// Check for test environment\\n   666→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   667→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   668→\\t}\\n   669→\\n   670→\\t// Check if /dev/tty is available\\n   671→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   672→\\tif err != nil {\\n   673→\\t\\treturn false\\n   674→\\t}\\n   675→\\t_ = tty.Close()\\n   676→\\treturn true\\n   677→}\\n   678→\\n   679→// printAgentError writes an error message followed by available agents and usage.\\n   680→func printAgentError(w io.Writer, message string) {\\n   681→\\tagents := agent.List()\\n   682→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   683→\\tfmt.Fprintln(w)\\n   684→\\tfor _, a := range agents {\\n   685→\\t\\tsuffix := \\\"\\\"\\n   686→\\t\\tif a == agent.DefaultAgentName {\\n   687→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   688→\\t\\t}\\n   689→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   690→\\t}\\n   691→\\tfmt.Fprintln(w)\\n   692→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   693→}\\n   694→\\n   695→// printMissingAgentError writes a helpful error listing available agents.\\n   696→func printMissingAgentError(w io.Writer) {\\n   697→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   698→}\\n   699→\\n   700→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   701→func printWrongAgentError(w io.Writer, name string) {\\n   702→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   703→}\\n   704→\\n   705→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   706→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   707→func setupAgentHooksNonInteractive(w io.Writer, ag agent.Agent, strategyName string, localDev, forceHooks, skipPushSessions, telemetry bool) error {\\n   708→\\tagentName := ag.Name()\\n   709→\\t// Check if agent supports hooks\\n   710→\\thookAgent, ok := ag.(agent.HookSupport)\\n   711→\\tif !ok {\\n   712→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   713→\\t}\\n   714→\\n   715→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   716→\\n   717→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   718→\\tinstalledHooks, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   719→\\tif err != nil {\\n   720→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   721→\\t}\\n   722→\\n   723→\\t// Setup .entire directory\\n   724→\\tif _, err := setupEntireDirectory(); err != nil {\\n   725→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   726→\\t}\\n   727→\\n   728→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   729→\\tsettings, err := LoadEntireSettings()\\n   730→\\tif err != nil {\\n   731→\\t\\t// If we can't load, start with defaults\\n   732→\\t\\tsettings = &EntireSettings{Strategy: strategy.DefaultStrategyName}\\n   733→\\t}\\n   734→\\tsettings.Enabled = true\\n   735→\\tif localDev {\\n   736→\\t\\tsettings.LocalDev = localDev\\n   737→\\t}\\n   738→\\n   739→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   740→\\tif skipPushSessions {\\n   741→\\t\\tif settings.StrategyOptions == nil {\\n   742→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   743→\\t\\t}\\n   744→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   745→\\t}\\n   746→\\n   747→\\t// Set strategy if provided\\n   748→\\tif strategyName != \\\"\\\" {\\n   749→\\t\\t// Map display name to internal name if needed\\n   750→\\t\\tinternalStrategy := strategyName\\n   751→\\t\\tif mapped, ok := strategyDisplayToInternal[strategyName]; ok {\\n   752→\\t\\t\\tinternalStrategy = mapped\\n   753→\\t\\t}\\n   754→\\t\\t// Validate the strategy exists\\n   755→\\t\\tif _, err := strategy.Get(internalStrategy); err != nil {\\n   756→\\t\\t\\treturn fmt.Errorf(\\\"unknown strategy: %s (use manual-commit or auto-commit)\\\", strategyName)\\n   757→\\t\\t}\\n   758→\\t\\tsettings.Strategy = internalStrategy\\n   759→\\t}\\n   760→\\n   761→\\t// Handle telemetry for non-interactive mode\\n   762→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   763→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   764→\\t\\tf := false\\n   765→\\t\\tsettings.Telemetry = &f\\n   766→\\t}\\n   767→\\n   768→\\tif err := SaveEntireSettings(settings); err != nil {\\n   769→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   770→\\t}\\n   771→\\n   772→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   773→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   774→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   775→\\t}\\n   776→\\tstrategy.CheckAndWarnHookManagers(w)\\n   777→\\n   778→\\tif installedHooks == 0 {\\n   779→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   780→\\t\\tif ag.IsPreview() {\\n   781→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   782→\\t\\t}\\n   783→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   784→\\t} else {\\n   785→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   786→\\t\\tif ag.IsPreview() {\\n   787→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   788→\\t\\t}\\n   789→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   790→\\t}\\n   791→\\n   792→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   793→\\n   794→\\t// Let the strategy handle its own setup requirements (creates entire/checkpoints/v1 branch, etc.)\\n   795→\\tstrat, err := strategy.Get(settings.Strategy)\\n   796→\\tif err != nil {\\n   797→\\t\\treturn fmt.Errorf(\\\"failed to get strategy: %w\\\", err)\\n   798→\\t}\\n   799→\\tif err := strat.EnsureSetup(); err != nil {\\n   800→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   801→\\t}\\n   802→\\n   803→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   804→\\n   805→\\treturn nil\\n   806→}\\n   807→\\n   808→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   809→func validateSetupFlags(useLocal, useProject bool) error {\\n   810→\\tif useLocal && useProject {\\n   811→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   812→\\t}\\n   813→\\treturn nil\\n   814→}\\n   815→\\n   816→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   817→// - Whether settings.json already exists\\n   818→// - The --local and --project flags\\n   819→// Returns (useLocal, showNotification).\\n   820→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   821→\\t// Explicit --local flag always uses local settings\\n   822→\\tif useLocal {\\n   823→\\t\\treturn true, false\\n   824→\\t}\\n   825→\\n   826→\\t// Explicit --project flag always uses project settings\\n   827→\\tif useProject {\\n   828→\\t\\treturn false, false\\n   829→\\t}\\n   830→\\n   831→\\t// No flags specified - check if settings file exists\\n   832→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   833→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   834→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   835→\\t\\treturn true, true\\n   836→\\t}\\n   837→\\n   838→\\t// Settings file doesn't exist - create it\\n   839→\\treturn false, false\\n   840→}\\n   841→\\n   842→// setupEntireDirectory creates the .entire directory and gitignore.\\n   843→// Returns true if the directory was created, false if it already existed.\\n   844→func setupEntireDirectory() (bool, error) { //nolint:unparam // already present in codebase\\n   845→\\t// Get absolute path for the .entire directory\\n   846→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   847→\\tif err != nil {\\n   848→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   849→\\t}\\n   850→\\n   851→\\t// Check if directory already exists\\n   852→\\tcreated := false\\n   853→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   854→\\t\\tcreated = true\\n   855→\\t}\\n   856→\\n   857→\\t// Create .entire directory\\n   858→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   859→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   860→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   861→\\t}\\n   862→\\n   863→\\t// Create/update .gitignore with all required entries\\n   864→\\tif err := strategy.EnsureEntireGitignore(); err != nil {\\n   865→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   866→\\t}\\n   867→\\n   868→\\treturn created, nil\\n   869→}\\n   870→\\n   871→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   872→func setupGitHook() error {\\n   873→\\t// Use shared implementation from strategy package\\n   874→\\t// The localDev setting is read from settings.json\\n   875→\\t_, err := strategy.InstallGitHook(false) // not silent - show output during setup\\n   876→\\tif err != nil {\\n   877→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   878→\\t}\\n   879→\\tstrategy.CheckAndWarnHookManagers(os.Stderr)\\n   880→\\treturn nil\\n   881→}\\n   882→\\n   883→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   884→func newSetupGitHookCmd() *cobra.Command {\\n   885→\\tcmd := &cobra.Command{\\n   886→\\t\\tUse:    \\\"git-hook\\\",\\n   887→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   888→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   889→\\t\\tRunE: func(_ *cobra.Command, _ []string) error {\\n   890→\\t\\t\\treturn setupGitHook()\\n   891→\\t\\t},\\n   892→\\t}\\n   893→\\n   894→\\treturn cmd\\n   895→}\\n   896→\\n   897→func newCurlBashPostInstallCmd() *cobra.Command {\\n   898→\\treturn &cobra.Command{\\n   899→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   900→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   901→\\t\\tHidden: true,\\n   902→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   903→\\t\\t\\tw := cmd.OutOrStdout()\\n   904→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   905→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   906→\\t\\t\\t}\\n   907→\\t\\t\\treturn nil\\n   908→\\t\\t},\\n   909→\\t}\\n   910→}\\n   911→\\n   912→// shellCompletionComment is the comment preceding the completion line\\n   913→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   914→\\n   915→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   916→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   917→\\n   918→// shellCompletionTarget returns the rc file path and completion lines for the\\n   919→// user's current shell.\\n   920→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   921→\\thome, err := os.UserHomeDir()\\n   922→\\tif err != nil {\\n   923→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   924→\\t}\\n   925→\\n   926→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   927→\\tswitch {\\n   928→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   929→\\t\\treturn \\\"Zsh\\\",\\n   930→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   931→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   932→\\t\\t\\tnil\\n   933→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   934→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   935→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   936→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   937→\\t\\t}\\n   938→\\t\\treturn \\\"Bash\\\",\\n   939→\\t\\t\\tbashRC,\\n   940→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   941→\\t\\t\\tnil\\n   942→\\tcase strings.Contains(shell, \\\"fish\\\"):\\n   943→\\t\\treturn \\\"Fish\\\",\\n   944→\\t\\t\\tfilepath.Join(home, \\\".config\\\", \\\"fish\\\", \\\"config.fish\\\"),\\n   945→\\t\\t\\t\\\"entire completion fish | source\\\",\\n   946→\\t\\t\\tnil\\n   947→\\tdefault:\\n   948→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   949→\\t}\\n   950→}\\n   951→\\n   952→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   953→// Only prompts if completion is not already configured.\\n   954→func promptShellCompletion(w io.Writer) error {\\n   955→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   956→\\tif err != nil {\\n   957→\\t\\tif errors.Is(err, errUnsupportedShell) {\\n   958→\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion not available for your shell. Supported: zsh, bash, fish.\\\\n\\\")\\n   959→\\t\\t\\treturn nil\\n   960→\\t\\t}\\n   961→\\t\\treturn fmt.Errorf(\\\"shell completion: %w\\\", err)\\n   962→\\t}\\n   963→\\n   964→\\tif isCompletionConfigured(rcFile) {\\n   965→\\t\\tfmt.Fprintf(w, \\\"✓ Shell completion already configured in %s\\\\n\\\", rcFile)\\n   966→\\t\\treturn nil\\n   967→\\t}\\n   968→\\n   969→\\tvar selected string\\n   970→\\tform := NewAccessibleForm(\\n   971→\\t\\thuh.NewGroup(\\n   972→\\t\\t\\thuh.NewSelect[string]().\\n   973→\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Enable shell completion? (detected: %s)\\\", shellName)).\\n   974→\\t\\t\\t\\tOptions(\\n   975→\\t\\t\\t\\t\\thuh.NewOption(\\\"Yes\\\", \\\"yes\\\"),\\n   976→\\t\\t\\t\\t\\thuh.NewOption(\\\"No\\\", \\\"no\\\"),\\n   977→\\t\\t\\