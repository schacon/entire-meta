d = 10 * time.Minute\\n    26→)\\n    27→\\n    28→// CleanupType identifies the type of orphaned item.\\n    29→type CleanupType string\\n    30→\\n    31→const (\\n    32→\\tCleanupTypeShadowBranch CleanupType = \\\"shadow-branch\\\"\\n    33→\\tCleanupTypeSessionState CleanupType = \\\"session-state\\\"\\n    34→\\tCleanupTypeCheckpoint   CleanupType = \\\"checkpoint\\\"\\n    35→)\\n    36→\\n    37→// CleanupItem represents an orphaned item that can be cleaned up.\\n    38→type CleanupItem struct {\\n    39→\\tType   CleanupType\\n    40→\\tID     string // Branch name, session ID, or checkpoint ID\\n    41→\\tReason string // Why this item is considered orphaned\\n    42→}\\n    43→\\n    44→// CleanupResult contains the results of a cleanup operation.\\n    45→type CleanupResult struct {\\n    46→\\tShadowBranches    []string // Deleted shadow branches\\n    47→\\tSessionStates     []string // Deleted session state files\\n    48→\\tCheckpoints       []string // Deleted checkpoint metadata\\n    49→\\tFailedBranches    []string // Shadow branches that failed to delete\\n    50→\\tFailedStates      []string // Session states that failed to delete\\n    51→\\tFailedCheckpoints []string // Checkpoints that failed to delete\\n    52→}\\n    53→\\n    54→// shadowBranchPattern matches shadow branch names in both old and new formats:\\n    55→//   - Old format: entire/<commit[:7+]>\\n    56→//   - New format: entire/<commit[:7+]>-<worktreeHash[:6]>\\n    57→//\\n    58→// The pattern requires at least 7 hex characters for the commit, optionally followed\\n    59→// by a dash and exactly 6 hex characters for the worktree hash.\\n    60→var shadowBranchPattern = regexp.MustCompile(`^entire/[0-9a-fA-F]{7,}(-[0-9a-fA-F]{6})?$`)\\n    61→\\n    62→// IsShadowBranch returns true if the branch name matches the shadow branch pattern.\\n    63→// Shadow branches have the format \\\"entire/<commit-hash>-<worktree-hash>\\\" where the\\n    64→// commit hash is at least 7 hex characters and worktree hash is 6 hex characters.\\n    65→// The \\\"entire/checkpoints/v1\\\" branch is NOT a shadow branch.\\n    66→func IsShadowBranch(branchName string) bool {\\n    67→\\t// Explicitly exclude entire/checkpoints/v1\\n    68→\\tif branchName == paths.MetadataBranchName {\\n    69→\\t\\treturn false\\n    70→\\t}\\n    71→\\treturn shadowBranchPattern.MatchString(branchName)\\n    72→}\\n    73→\\n    74→// ListShadowBranches returns all shadow branches in the repository.\\n    75→// Shadow branches match the pattern \\\"entire/<commit-hash>\\\" (7+ hex chars).\\n    76→// The \\\"entire/checkpoints/v1\\\" branch is excluded as it stores permanent metadata.\\n    77→// Returns an empty slice (not nil) if no shadow branches exist.\\n    78→func ListShadowBranches() ([]string, error) {\\n    79→\\trepo, err := OpenRepository()\\n    80→\\tif err != nil {\\n    81→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n    82→\\t}\\n    83→\\n    84→\\trefs, err := repo.References()\\n    85→\\tif err != nil {\\n    86→\\t\\treturn nil, fmt.Errorf(\\\"failed to get references: %w\\\", err)\\n    87→\\t}\\n    88→\\n    89→\\tvar shadowBranches []string\\n    90→\\n    91→\\terr = refs.ForEach(func(ref *plumbing.Reference) error {\\n    92→\\t\\t// Only look at branch references\\n    93→\\t\\tif !ref.Name().IsBranch() {\\n    94→\\t\\t\\treturn nil\\n    95→\\t\\t}\\n    96→\\n    97→\\t\\t// Extract branch name without refs/heads/ prefix\\n    98→\\t\\tbranchName := strings.TrimPrefix(ref.Name().String(), \\\"refs/heads/\\\")\\n    99→\\n   100→\\t\\tif IsShadowBranch(branchName) {\\n   101→\\t\\t\\tshadowBranches = append(shadowBranches, branchName)\\n   102→\\t\\t}\\n   103→\\t\\treturn nil\\n   104→\\t})\\n   105→\\tif err != nil {\\n   106→\\t\\treturn nil, fmt.Errorf(\\\"failed to iterate references: %w\\\", err)\\n   107→\\t}\\n   108→\\n   109→\\t// Ensure we return empty slice, not nil\\n   110→\\tif shadowBranches == nil {\\n   111→\\t\\tshadowBranches = []string{}\\n   112→\\t}\\n   113→\\n   114→\\treturn shadowBranches, nil\\n   115→}\\n   116→\\n   117→// DeleteShadowBranches deletes the specified branches from the repository.\\n   118→// Returns two slices: successfully deleted branches and branches that failed to delete.\\n   119→// Individual branch deletion failures do not stop the operation - all branches are attempted.\\n   120→func DeleteShadowBranches(branches []string) (deleted []string, failed []string, err error) { //nolint:unparam // already present in codebase\\n   121→\\tif len(branches) == 0 {\\n   122→\\t\\treturn []string{}, []string{}, nil\\n   123→\\t}\\n   124→\\n   125→\\tfor _, branch := range branches {\\n   126→\\t\\t// Use git CLI to delete branches because go-git v5's RemoveReference\\n   127→\\t\\t// doesn't properly persist deletions with packed refs or worktrees\\n   128→\\t\\tif err := DeleteBranchCLI(branch); err != nil {\\n   129→\\t\\t\\tfailed = append(failed, branch)\\n   130→\\t\\t\\tcontinue\\n   131→\\t\\t}\\n   132→\\n   133→\\t\\tdeleted = append(deleted, branch)\\n   134→\\t}\\n   135→\\n   136→\\treturn deleted, failed, nil\\n   137→}\\n   138→\\n   139→// ListOrphanedSessionStates returns session state files that are orphaned.\\n   140→// A session state is orphaned if:\\n   141→//   - No checkpoints on entire/checkpoints/v1 reference this session ID\\n   142→//   - No shadow branch exists for the session's base commit\\n   143→//\\n   144→// This is strategy-agnostic as session states are shared by all strategies.\\n   145→func ListOrphanedSessionStates() ([]CleanupItem, error) {\\n   146→\\trepo, err := OpenRepository()\\n   147→\\tif err != nil {\\n   148→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   149→\\t}\\n   150→\\n   151→\\t// Get all session states\\n   152→\\tstore, err := session.NewStateStore()\\n   153→\\tif err != nil {\\n   154→\\t\\treturn nil, fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n   155→\\t}\\n   156→\\n   157→\\tstates, err := store.List(context.Background())\\n   158→\\tif err != nil {\\n   159→\\t\\treturn nil, fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   160→\\t}\\n   161→\\n   162→\\tif len(states) == 0 {\\n   163→\\t\\treturn []CleanupItem{}, nil\\n   164→\\t}\\n   165→\\n   166→\\t// Get all checkpoints to find which sessions have checkpoints\\n   167→\\tcpStore := checkpoint.NewGitStore(repo)\\n   168→\\n   169→\\tsessionsWithCheckpoints := make(map[string]bool)\\n   170→\\tcheckpoints, listErr := cpStore.ListCommitted(context.Background())\\n   171→\\tif listErr == nil {\\n   172→\\t\\tfor _, cp := range checkpoints {\\n   173→\\t\\t\\tsessionsWithCheckpoints[cp.SessionID] = true\\n   174→\\t\\t}\\n   175→\\t}\\n   176→\\n   177→\\t// Get all shadow branches as a set for quick lookup\\n   178→\\tshadowBranches, _ := ListShadowBranches() //nolint:errcheck // Best effort\\n   179→\\tshadowBranchSet := make(map[string]bool)\\n   180→\\tfor _, branch := range shadowBranches {\\n   181→\\t\\tshadowBranchSet[branch] = true\\n   182→\\t}\\n   183→\\n   184→\\tvar orphaned []CleanupItem\\n   185→\\tnow := time.Now()\\n   186→\\n   187→\\tfor _, state := range states {\\n   188→\\t\\t// Skip sessions that started recently - they may be actively in use\\n   189→\\t\\t// but haven't created their first checkpoint yet\\n   190→\\t\\tif now.Sub(state.StartedAt) < sessionGracePeriod {\\n   191→\\t\\t\\tcontinue\\n   192→\\t\\t}\\n   193→\\n   194→\\t\\t// Check if session has checkpoints on entire/checkpoints/v1\\n   195→\\t\\thasCheckpoints := sessionsWithCheckpoints[state.SessionID]\\n   196→\\n   197→\\t\\t// Check if shadow branch exists for this session's base commit and worktree\\n   198→\\t\\t// Shadow branches are now worktree-specific: entire/<commit[:7]>-<worktreeHash[:6]>\\n   199→\\t\\texpectedBranch := checkpoint.ShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   200→\\t\\thasShadowBranch := shadowBranchSet[expectedBranch]\\n   201→\\n   202→\\t\\t// Session is orphaned if it has no checkpoints AND no shadow branch\\n   203→\\t\\tif !hasCheckpoints && !hasShadowBranch {\\n   204→\\t\\t\\treason := \\\"no checkpoints or shadow branch found\\\"\\n   205→\\t\\t\\torphaned = append(orphaned, CleanupItem{\\n   206→\\t\\t\\t\\tType:   CleanupTypeSessionState,\\n   207→\\t\\t\\t\\tID:     state.SessionID,\\n   208→\\t\\t\\t\\tReason: reason,\\n   209→\\t\\t\\t})\\n   210→\\t\\t}\\n   211→\\t}\\n   212→\\n   213→\\treturn orphaned, nil\\n   214→}\\n   215→\\n   216→// DeleteOrphanedSessionStates deletes the specified session state files.\\n   217→func DeleteOrphanedSessionStates(sessionIDs []string) (deleted []string, failed []string, err error) {\\n   218→\\tif len(sessionIDs) == 0 {\\n   219→\\t\\treturn []string{}, []string{}, nil\\n   220→\\t}\\n   221→\\n   222→\\tstore, err := session.NewStateStore()\\n   223→\\tif err != nil {\\n   224→\\t\\treturn nil, nil, fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n   225→\\t}\\n   226→\\n   227→\\tfor _, sessionID := range sessionIDs {\\n   228→\\t\\tif err := store.Clear(context.Background(), sessionID); err != nil {\\n   229→\\t\\t\\tfailed = append(failed, sessionID)\\n   230→\\t\\t} else {\\n   231→\\t\\t\\tdeleted = append(deleted, sessionID)\\n   232→\\t\\t}\\n   233→\\t}\\n   234→\\n   235→\\treturn deleted, failed, nil\\n   236→}\\n   237→\\n   238→// DeleteOrphanedCheckpoints removes checkpoint directories from the entire/checkpoints/v1 branch.\\n   239→func DeleteOrphanedCheckpoints(checkpointIDs []string) (deleted []string, failed []string, err error) {\\n   240→\\tif len(checkpointIDs) == 0 {\\n   241→\\t\\treturn []string{}, []string{}, nil\\n   242→\\t}\\n   243→\\n   244→\\trepo, err := OpenRepository()\\n   245→\\tif err != nil {\\n   246→\\t\\treturn nil, nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   247→\\t}\\n   248→\\n   249→\\t// Get sessions branch\\n   250→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   251→\\tref, err := repo.Reference(refName, true)\\n   252→\\tif err != nil {\\n   253→\\t\\treturn nil, nil, fmt.Errorf(\\\"sessions branch not found: %w\\\", err)\\n   254→\\t}\\n   255→\\n   256→\\tparentCommit, err := repo.CommitObject(ref.Hash())\\n   257→\\tif err != nil {\\n   258→\\t\\treturn nil, nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   259→\\t}\\n   260→\\n   261→\\tbaseTree, err := parentCommit.Tree()\\n   262→\\tif err != nil {\\n   263→\\t\\treturn nil, nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n   264→\\t}\\n   265→\\n   266→\\t// Flatten tree to entries\\n   267→\\tentries := make(map[string]object.TreeEntry)\\n   268→\\tif err := checkpoint.FlattenTree(repo, baseTree, \\\"\\\", entries); err != nil {\\n   269→\\t\\treturn nil, nil, fmt.Errorf(\\\"failed to flatten tree: %w\\\", err)\\n   270→\\t}\\n   271→\\n   272→\\t// Remove entries for each checkpoint\\n   273→\\tcheckpointSet := make(map[string]bool)\\n   274→\\tfor _, id := range checkpointIDs {\\n   275→\\t\\tcheckpointSet[id] = true\\n   276→\\t}\\n   277→\\n   278→\\t// Find and remove entries matching checkpoint paths\\n   279→\\tfor path := range entries {\\n   280→\\t\\tfor checkpointIDStr := range checkpointSet {\\n   281→\\t\\t\\tcpID, err := id.NewCheckpointID(checkpointIDStr)\\n   282→\\t\\t\\tif err != nil {\\n   283→\\t\\t\\t\\tcontinue // Skip invalid checkpoint IDs\\n   284→\\t\\t\\t}\\n   285→\\t\\t\\tcpPath := cpID.Path()\\n   286→\\t\\t\\tif strings.HasPrefix(path, cpPath+\\\"/\\\") {\\n   287→\\t\\t\\t\\tdelete(entries, path)\\n   288→\\t\\t\\t}\\n   289→\\t\\t}\\n   290→\\t}\\n   291→\\n   292→\\t// Build new tree\\n   293→\\tnewTreeHash, err := checkpoint.BuildTreeFromEntries(repo, entries)\\n   294→\\tif err != nil {\\n   295→\\t\\treturn nil, nil, fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n   296→\\t}\\n   297→\\n   298→\\t// Create commit\\n   299→\\tcommit := &object.Commit{\\n   300→\\t\\tAuthor: object.Signature{\\n   301→\\t\\t\\tName:  \\\"Entire CLI\\\",\\n   302→\\t\\t\\tEmail: \\\"cli@entire.io\\\",\\n   303→\\t\\t\\tWhen:  parentCommit.Author.When,\\n   304→\\t\\t},\\n   305→\\t\\tCommitter: object.Signature{\\n   306→\\t\\t\\tName:  \\\"Entire CLI\\\",\\n   307→\\t\\t\\tEmail: \\\"cli@entire.io\\\",\\n   308→\\t\\t\\tWhen:  parentCommit.Committer.When,\\n   309→\\t\\t},\\n   310→\\t\\tMessage:      fmt.Sprintf(\\\"Cleanup: removed %d orphaned checkpoints\\\", len(checkpointIDs)),\\n   311→\\t\\tTreeHash:     newTreeHash,\\n   312→\\t\\tParentHashes: []plumbing.Hash{ref.Hash()},\\n   313→\\t}\\n   314→\\n   315→\\tobj := repo.Storer.NewEncodedObject()\\n   316→\\tif err := commit.Encode(obj); err != nil {\\n   317→\\t\\treturn nil, nil, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n   318→\\t}\\n   319→\\n   320→\\tcommitHash, err := repo.Storer.SetEncodedObject(obj)\\n   321→\\tif err != nil {\\n   322→\\t\\treturn nil, nil, fmt.Errorf(\\\"failed to store commit: %w\\\", err)\\n   323→\\t}\\n   324→\\n   325→\\t// Update branch reference\\n   326→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n   327→\\tif err := repo.Storer.SetReference(newRef); err != nil {\\n   328→\\t\\treturn nil, nil, fmt.Errorf(\\\"failed to update branch: %w\\\", err)\\n   329→\\t}\\n   330→\\n   331→\\t// All checkpoints deleted successfully\\n   332→\\treturn checkpointIDs, []string{}, nil\\n   333→}\\n   334→\\n   335→// ListAllCleanupItems returns all orphaned items across all categories.\\n   336→// It iterates over all registered strategies and calls ListOrphanedItems on those\\n   337→// that implement OrphanedItemsLister.\\n   338→// Returns an error if the repository cannot be opened.\\n   339→func ListAllCleanupItems() ([]CleanupItem, error) {\\n   340→\\tvar items []CleanupItem\\n   341→\\tvar firstErr error\\n   342→\\n   343→\\t// Iterate over all registered strategies\\n   344→\\tfor _, name := range List() {\\n   345→\\t\\tstrat, err := Get(name)\\n   346→\\t\\tif err != nil {\\n   347→\\t\\t\\tif firstErr == nil {\\n   348→\\t\\t\\t\\tfirstErr = err\\n   349→\\t\\t\\t}\\n   350→\\t\\t\\tcontinue\\n   351→\\t\\t}\\n   352→\\n   353→\\t\\t// Check if strategy implements OrphanedItemsLister\\n   354→\\t\\tif lister, ok := strat.(OrphanedItemsLister); ok {\\n   355→\\t\\t\\tstratItems, err := lister.ListOrphanedItems()\\n   356→\\t\\t\\tif err != nil {\\n   357→\\t\\t\\t\\tif firstErr == nil {\\n   358→\\t\\t\\t\\t\\tfirstErr = err\\n   359→\\t\\t\\t\\t}\\n   360→\\t\\t\\t\\tcontinue\\n   361→\\t\\t\\t}\\n   362→\\t\\t\\titems = append(items, stratItems...)\\n   363→\\t\\t}\\n   364→\\t}\\n   365→\\n   366→\\t// Orphaned session states (strategy-agnostic)\\n   367→\\tstates, err := ListOrphanedSessionStates()\\n   368→\\tif err != nil {\\n   369→\\t\\tif firstErr == nil {\\n   370→\\t\\t\\tfirstErr = err\\n   371→\\t\\t}\\n   372→\\t} else {\\n   373→\\t\\titems = append(items, states...)\\n   374→\\t}\\n   375→\\n   376→\\treturn items, firstErr\\n   377→}\\n   378→\\n   379→// DeleteAllCleanupItems deletes all specified cleanup items.\\n   380→// Logs each deletion for audit purposes.\\n   381→func DeleteAllCleanupItems(items []CleanupItem) (*CleanupResult, error) {\\n   382→\\tresult := &CleanupResult{}\\n   383→\\tlogCtx := logging.WithComponent(context.Background(), \\\"cleanup\\\")\\n   384→\\n   385→\\t// Build ID-to-Reason map for logging after deletion\\n   386→\\treasonMap := make(map[string]string)\\n   387→\\tfor _, item := range items {\\n   388→\\t\\treasonMap[item.ID] = item.Reason\\n   389→\\t}\\n   390→\\n   391→\\t// Group items by type\\n   392→\\tvar branches, states, checkpoints []string\\n   393→\\tfor _, item := range items {\\n   394→\\t\\tswitch item.Type {\\n   395→\\t\\tcase CleanupTypeShadowBranch:\\n   396→\\t\\t\\tbranches = append(branches, item.ID)\\n   397→\\t\\tcase CleanupTypeSessionState:\\n   398→\\t\\t\\tstates = append(states, item.ID)\\n   399→\\t\\tcase CleanupTypeCheckpoint:\\n   400→\\t\\t\\tcheckpoints = append(checkpoints, item.ID)\\n   401→\\t\\t}\\n   402→\\t}\\n   403→\\n   404→\\t// Delete shadow branches\\n   405→\\tif len(branches) > 0 {\\n   406→\\t\\tdeleted, failed, err := DeleteShadowBranches(branches)\\n   407→\\t\\tif err != nil {\\n   408→\\t\\t\\treturn result, err\\n   409→\\t\\t}\\n   410→\\t\\tresult.ShadowBranches = deleted\\n   411→\\t\\tresult.FailedBranches = failed\\n   412→\\n   413→\\t\\t// Log deleted branches\\n   414→\\t\\tfor _, id := range deleted {\\n   415→\\t\\t\\tlogging.Info(logCtx, \\\"deleted orphaned shadow branch\\\",\\n   416→\\t\\t\\t\\tslog.String(\\\"type\\\", string(CleanupTypeShadowBranch)),\\n   417→\\t\\t\\t\\tslog.String(\\\"id\\\", id),\\n   418→\\t\\t\\t\\tslog.String(\\\"reason\\\", reasonMap[id]),\\n   419→\\t\\t\\t)\\n   420→\\t\\t}\\n   421→\\t\\t// Log failed branches\\n   422→\\t\\tfor _, id := range failed {\\n   423→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to delete orphaned shadow branch\\\",\\n   424→\\t\\t\\t\\tslog.String(\\\"type\\\", string(CleanupTypeShadowBranch)),\\n   425→\\t\\t\\t\\tslog.String(\\\"id\\\", id),\\n   426→\\t\\t\\t\\tslog.String(\\\"reason\\\", reasonMap[id]),\\n   427→\\t\\t\\t)\\n   428→\\t\\t}\\n   429→\\t}\\n   430→\\n   431→\\t// Delete session states\\n   432→\\tif len(states) > 0 {\\n   433→\\t\\tdeleted, failed, err := DeleteOrphanedSessionStates(states)\\n   434→\\t\\tif err != nil {\\n   435→\\t\\t\\treturn result, err\\n   436→\\t\\t}\\n   437→\\t\\tresult.SessionStates = deleted\\n   438→\\t\\tresult.FailedStates = failed\\n   439→\\n   440→\\t\\t// Log deleted session states\\n   441→\\t\\tfor _, id := range deleted {\\n   442→\\t\\t\\tlogging.Info(logCtx, \\\"deleted orphaned session state\\\",\\n   443→\\t\\t\\t\\tslog.String(\\\"type\\\", string(CleanupTypeSessionState)),\\n   444→\\t\\t\\t\\tslog.String(\\\"id\\\", id),\\n   445→\\t\\t\\t\\tslog.String(\\\"reason\\\", reasonMap[id]),\\n   446→\\t\\t\\t)\\n   447→\\t\\t}\\n   448→\\t\\t// Log failed session states\\n   449→\\t\\tfor _, id := range failed {\\n   450→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to delete orphaned session state\\\",\\n   451→\\t\\t\\t\\tslog.String(\\\"type\\\", string(CleanupTypeSessionState)),\\n   452→\\t\\t\\t\\tslog.String(\\\"id\\\", id),\\n   453→\\t\\t\\t\\tslog.String(\\\"reason\\\", reasonMap[id]),\\n   454→\\t\\t\\t)\\n   455→\\t\\t}\\n   456→\\t}\\n   457→\\n   458→\\t// Delete checkpoints\\n   459→\\tif len(checkpoints) > 0 {\\n   460→\\t\\tdeleted, failed, err := DeleteOrphanedCheckpoints(checkpoints)\\n   461→\\t\\tif err != nil {\\n   462→\\t\\t\\treturn result, err\\n   463→\\t\\t}\\n   464→\\t\\tresult.Checkpoints = deleted\\n   465→\\t\\tresult.FailedCheckpoints = failed\\n   466→\\n   467→\\t\\t// Log deleted checkpoints\\n   468→\\t\\tfor _, id := range deleted {\\n   469→\\t\\t\\tlogging.Info(logCtx, \\\"deleted orphaned checkpoint\\\",\\n   470→\\t\\t\\t\\tslog.String(\\\"type\\\", string(CleanupTypeCheckpoint)),\\n   471→\\t\\t\\t\\tslog.String(\\\"id\\\", id),\\n   472→\\t\\t\\t\\tslog.String(\\\"reason\\\", reasonMap[id]),\\n   473→\\t\\t\\t)\\n   474→\\t\\t}\\n   475→\\t\\t// Log failed checkpoints\\n   476→\\t\\tfor _, id := range failed {\\n   477→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to delete orphaned checkpoint\\\",\\n   478→\\t\\t\\t\\tslog.String(\\\"type\\\", string(CleanupTypeCheckpoint)),\\n   479→\\t\\t\\t\\tslog.String(\\\"id\\\", id),\\n   480→\\t\\t\\t\\tslog.String(\\\"reason\\\", reasonMap[id]),\\n   481→\\t\\t\\t)\\n   482→\\t\\t}\\n   483→\\t}\\n   484→\\n   485→\\t// Log summary\\n   486→\\ttotalDeleted := len(result.ShadowBranches) + len(result.SessionStates) + len(result.Checkpoints)\\n   487→\\ttotalFailed := len(result.FailedBranches) + len(result.FailedStates) + len(result.FailedCheckpoints)\\n   488→\\tif totalDeleted > 0 || totalFailed > 0 {\\n   489→\\t\\tlogging.Info(logCtx, \\\"cleanup 