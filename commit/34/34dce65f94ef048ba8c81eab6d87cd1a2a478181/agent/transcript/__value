tfmt.Fprintf(os.Stderr, \\\"[entire] Created trail for branch: %s\\\\n\\\", branchName)\\n   407→\\treturn nil\\n   408→}\\n   409→\\n   410→// hasFlag is a simple helper that checks os.Args for --flag presence.\\n   411→// Used to distinguish between \\\"flag not provided\\\" and \\\"flag provided with empty value\\\".\\n   412→func hasFlag(name string) bool {\\n   413→\\tfor _, arg := range os.Args {\\n   414→\\t\\tif arg == \\\"--\\\"+name || strings.HasPrefix(arg, \\\"--\\\"+name+\\\"=\\\") {\\n   415→\\t\\t\\treturn true\\n   416→\\t\\t}\\n   417→\\t}\\n   418→\\treturn false\\n   419→}\\n   420→\\n   421→func truncate(s string, maxLen int) string {\\n   422→\\tif len(s) <= maxLen {\\n   423→\\t\\treturn s\\n   424→\\t}\\n   425→\\tif maxLen <= 3 {\\n   426→\\t\\treturn s[:maxLen]\\n   427→\\t}\\n   428→\\treturn s[:maxLen-3] + \\\"...\\\"\\n   429→}\\n   430→\\n   431→func formatValidStatuses() string {\\n   432→\\tstatuses := trail.ValidStatuses()\\n   433→\\tnames := make([]string, len(statuses))\\n   434→\\tfor i, s := range statuses {\\n   435→\\t\\tnames[i] = string(s)\\n   436→\\t}\\n   437→\\treturn strings.Join(names, \\\", \\\")\\n   438→}\\n   439→\\n   440→func containsString(slice []string, s string) bool {\\n   441→\\tfor _, v := range slice {\\n   442→\\t\\tif v == s {\\n   443→\\t\\t\\treturn true\\n   444→\\t\\t}\\n   445→\\t}\\n   446→\\treturn false\\n   447→}\\n   448→\\n   449→func removeString(slice []string, s string) []string {\\n   450→\\tvar result []string\\n   451→\\tfor _, v := range slice {\\n   452→\\t\\tif v != s {\\n   453→\\t\\t\\tresult = append(result, v)\\n   454→\\t\\t}\\n   455→\\t}\\n   456→\\treturn result\\n   457→}\\n   458→\"}]},\"uuid\":\"d8cc1156-e2bc-4fa1-af30-b13e832ed5a5\",\"timestamp\":\"2026-02-20T15:08:46.062Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/dip/Repositories/cli/cmd/entire/cli/trail_cmd.go\",\"content\":\"package cli\\n\\nimport (\\n\\t\\\"encoding/json\\\"\\n\\t\\\"fmt\\