strings.TrimSpace(line), trailerPrefix) {\\n   182→\\t\\t\\tresult = append(result, line)\\n   183→\\t\\t}\\n   184→\\t}\\n   185→\\treturn strings.Join(result, \\\"\\\\n\\\")\\n   186→}\\n   187→\\n   188→// isGitSequenceOperation checks if git is currently in the middle of a rebase,\\n   189→// cherry-pick, or revert operation. During these operations, commits are being\\n   190→// replayed and should not be linked to agent sessions.\\n   191→//\\n   192→// Detects:\\n   193→//   - rebase: .git/rebase-merge/ or .git/rebase-apply/ directories\\n   194→//   - cherry-pick: .git/CHERRY_PICK_HEAD file\\n   195→//   - revert: .git/REVERT_HEAD file\\n   196→func isGitSequenceOperation() bool {\\n   197→\\t// Get git directory (handles worktrees and relative paths correctly)\\n   198→\\tgitDir, err := GetGitDir()\\n   199→\\tif err != nil {\\n   200→\\t\\treturn false // Can't determine, assume not in sequence operation\\n   201→\\t}\\n   202→\\n   203→\\t// Check for rebase state directories\\n   204→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-merge\\\")); err == nil {\\n   205→\\t\\treturn true\\n   206→\\t}\\n   207→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-apply\\\")); err == nil {\\n   208→\\t\\treturn true\\n   209→\\t}\\n   210→\\n   211→\\t// Check for cherry-pick and revert state files\\n   212→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"CHERRY_PICK_HEAD\\\")); err == nil {\\n   213→\\t\\treturn true\\n   214→\\t}\\n   215→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"REVERT_HEAD\\\")); err == nil {\\n   216→\\t\\treturn true\\n   217→\\t}\\n   218→\\n   219→\\treturn false\\n   220→}\\n   221→\\n   222→// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   223→// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   224→// Only adds a trailer if there's actually new session content to condense.\\n   225→// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   226→// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   227→// For amended commits, preserves the existing checkpoint ID.\\n   228→//\\n   229→// The source parameter indicates how the commit was initiated:\\n   230→//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   231→//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   232→//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   233→//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   234→//\\n   235→\\n   236→func (s *ManualCommitStrategy) PrepareCommitMsg(commitMsgFile string, source string) error {\\n   237→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   238→\\n   239→\\t// Skip during rebase, cherry-pick, or revert operations\\n   240→\\t// These are replaying existing commits and should not be linked to agent sessions\\n   241→\\tif isGitSequenceOperation() {\\n   242→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n   243→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   244→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   245→\\t\\t)\\n   246→\\t\\treturn nil\\n   247→\\t}\\n   248→\\n   249→\\t// Skip for merge and squash sources\\n   250→\\t// These are auto-generated messages - not from Claude sessions\\n   251→\\tswitch source {\\n   252→\\tcase \\\"merge\\\", \\\"squash\\\":\\n   253→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n   254→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   255→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   256→\\t\\t)\\n   257→\\t\\treturn nil\\n   258→\\t}\\n   259→\\n   260→\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   261→\\tif source == \\\"commit\\\" {\\n   262→\\t\\treturn s.handleAmendCommitMsg(logCtx, commitMsgFile)\\n   263→\\t}\\n   264→\\n   265→\\trepo, err := OpenRepository()\\n   266→\\tif err != nil {\\n   267→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   268→\\t}\\n   269→\\n   270→\\tworktreePath, err := GetWorktreePath()\\n   271→\\tif err != nil {\\n   272→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   273→\\t}\\n   274→\\n   275→\\t// Find all active sessions for this worktree\\n   276→\\t// We match by worktree (not BaseCommit) because the user may have made\\n   277→\\t// intermediate commits without entering new prompts, causing HEAD to diverge\\n   278→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   279→\\tif err != nil || len(sessions) == 0 {\\n   280→\\t\\t// No active sessions or error listing - silently skip (hooks must be resilient)\\n   281→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no active sessions\\\",\\n   282→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   283→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   284→\\t\\t)\\n   285→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   286→\\t}\\n   287→\\n   288→\\t// Fast path: when an agent is committing (ACTIVE session + no TTY), skip\\n   289→\\t// content detection and interactive prompts. The agent can't respond to TTY\\n   290→\\t// prompts and the content detection can miss mid-session work (no shadow\\n   291→\\t// branch yet, transcript analysis may fail). Generate a checkpoint ID and\\n   292→\\t// add the trailer directly.\\n   293→\\tif !hasTTY() {\\n   294→\\t\\tfor _, state := range sessions {\\n   295→\\t\\t\\tif state.Phase.IsActive() {\\n   296→\\t\\t\\t\\treturn s.addTrailerForAgentCommit(logCtx, commitMsgFile, state, source)\\n   297→\\t\\t\\t}\\n   298→\\t\\t}\\n   299→\\t}\\n   300→\\n   301→\\t// Check if any session has new content to condense\\n   302→\\tsessionsWithContent := s.filterSessionsWithNewContent(repo, sessions)\\n   303→\\n   304→\\tif len(sessionsWithContent) == 0 {\\n   305→\\t\\t// No new content — no trailer needed\\n   306→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no content to link\\\",\\n   307→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   308→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   309→\\t\\t\\tslog.Int(\\\"sessions_found\\\", len(sessions)),\\n   310→\\t\\t)\\n   311→\\t\\treturn nil\\n   312→\\t}\\n   313→\\n   314→\\t// Read current commit message\\n   315→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   316→\\tif err != nil {\\n   317→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   318→\\t}\\n   319→\\n   320→\\tmessage := string(content)\\n   321→\\n   322→\\t// Check if trailer already exists (ParseCheckpoint validates format, so found==true means valid)\\n   323→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   324→\\t\\t// Trailer already exists (e.g., amend) - keep it\\n   325→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: trailer already exists\\\",\\n   326→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   327→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   328→\\t\\t\\tslog.String(\\\"existing_checkpoint_id\\\", existingCpID.String()),\\n   329→\\t\\t)\\n   330→\\t\\treturn nil\\n   331→\\t}\\n   332→\\n   333→\\t// Generate a fresh checkpoint ID\\n   334→\\tcheckpointID, err := id.Generate()\\n   335→\\tif err != nil {\\n   336→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   337→\\t}\\n   338→\\n   339→\\t// Determine agent type and last prompt from session\\n   340→\\tagentType := DefaultAgentType // default for backward compatibility\\n   341→\\tvar lastPrompt string\\n   342→\\tif len(sessionsWithContent) > 0 {\\n   343→\\t\\tfirstSession := sessionsWithContent[0]\\n   344→\\t\\tif firstSession.AgentType != \\\"\\\" {\\n   345→\\t\\t\\tagentType = firstSession.AgentType\\n   346→\\t\\t}\\n   347→\\t\\tlastPrompt = s.getLastPrompt(repo, firstSession)\\n   348→\\t}\\n   349→\\n   350→\\t// Prepare prompt for display: collapse newlines/whitespace, then truncate (rune-safe)\\n   351→\\tdisplayPrompt := stringutil.TruncateRunes(stringutil.CollapseWhitespace(lastPrompt), 80, \\\"...\\\")\\n   352→\\n   353→\\t// Add trailer differently based on commit source\\n   354→\\tswitch source {\\n   355→\\tcase \\\"message\\\":\\n   356→\\t\\t// Using -m or -F: ask user interactively whether to add trailer\\n   357→\\t\\t// (comments won't be stripped by git in this mode)\\n   358→\\n   359→\\t\\t// Build context string for interactive prompt\\n   360→\\t\\tvar promptContext string\\n   361→\\t\\tif displayPrompt != \\\"\\\" {\\n   362→\\t\\t\\tpromptContext = \\\"You have an active \\\" + string(agentType) + \\\" session.\\\\nLast Prompt: \\\" + displayPrompt\\n   363→\\t\\t}\\n   364→\\n   365→\\t\\tif !askConfirmTTY(\\\"Link this commit to \\\"+string(agentType)+\\\" session context?\\\", promptContext, true) {\\n   366→\\t\\t\\t// User declined - don't add trailer\\n   367→\\t\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: user declined trailer\\\",\\n   368→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   369→\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n   370→\\t\\t\\t)\\n   371→\\t\\t\\treturn nil\\n   372→\\t\\t}\\n   373→\\t\\tmessage = addCheckpointTrailer(message, checkpointID)\\n   374→\\tdefault:\\n   375→\\t\\t// Normal editor flow: add trailer with explanatory comment (will be stripped by git)\\n   376→\\t\\tmessage = addCheckpointTrailerWithComment(message, checkpointID, string(agentType), displayPrompt)\\n   377→\\t}\\n   378→\\n   379→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: trailer added\\\",\\n   380→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   381→\\t\\tslog.String(\\\"source\\\", source),\\n   382→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   383→\\t)\\n   384→\\n   385→\\t// Write updated message back\\n   386→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   387→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   388→\\t}\\n   389→\\n   390→\\treturn nil\\n   391→}\\n   392→\\n   393→// handleAmendCommitMsg handles the prepare-commit-msg hook for amend operations\\n   394→// (source=\\\"commit\\\"). It preserves existing trailers or restores from LastCheckpointID.\\n   395→func (s *ManualCommitStrategy) handleAmendCommitMsg(logCtx context.Context, commitMsgFile string) error {\\n   396→\\t// Read current commit message\\n   397→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   398→\\tif err != nil {\\n   399→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   400→\\t}\\n   401→\\n   402→\\tmessage := string(content)\\n   403→\\n   404→\\t// If message already has a trailer, keep it unchanged\\n   405→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   406→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend preserves existing trailer\\\",\\n   407→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   408→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", existingCpID.String()),\\n   409→\\t\\t)\\n   410→\\t\\treturn nil\\n   411→\\t}\\n   412→\\n   413→\\t// No trailer in message — check if any session has LastCheckpointID to restore\\n   414→\\tworktreePath, err := GetWorktreePath()\\n   415→\\tif err != nil {\\n   416→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   417→\\t}\\n   418→\\n   419→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   420→\\tif err != nil || len(sessions) == 0 {\\n   421→\\t\\treturn nil //nolint:nilerr // No sessions - nothing to restore\\n   422→\\t}\\n   423→\\n   424→\\t// For amend, HEAD^ is the commit being amended, and HEAD is where we are now.\\n   425→\\t// We need to match sessions whose BaseCommit equals HEAD (the commit being amended\\n   426→\\t// was created from this base). This prevents stale sessions from injecting\\n   427→\\t// unrelated checkpoint IDs.\\n   428→\\trepo, repoErr := OpenRepository()\\n   429→\\tif repoErr != nil {\\n   430→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   431→\\t}\\n   432→\\thead, headErr := repo.Head()\\n   433→\\tif headErr != nil {\\n   434→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   435→\\t}\\n   436→\\tcurrentHead := head.Hash().String()\\n   437→\\n   438→\\t// Find first matching session with LastCheckpointID to restore.\\n   439→\\t// LastCheckpointID is set after condensation completes.\\n   440→\\tfor _, state := range sessions {\\n   441→\\t\\tif state.BaseCommit != currentHead {\\n   442→\\t\\t\\tcontinue\\n   443→\\t\\t}\\n   444→\\t\\tif state.LastCheckpointID.IsEmpty() {\\n   445→\\t\\t\\tcontinue\\n   446→\\t\\t}\\n   447→\\t\\tcpID := state.LastCheckpointID\\n   448→\\t\\tsource := \\\"LastCheckpointID\\\"\\n   449→\\n   450→\\t\\t// Restore the trailer\\n   451→\\t\\tmessage = addCheckpointTrailer(message, cpID)\\n   452→\\t\\tif writeErr := os.WriteFile(commitMsgFile, []byte(message), 0o600); writeErr != nil {\\n   453→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   454→\\t\\t}\\n   455→\\n   456→\\t\\tlogging.Info(logCtx, \\\"prepare-commit-msg: restored trailer on amend\\\",\\n   457→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   458→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   459→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   460→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   461→\\t\\t)\\n   462→\\t\\treturn nil\\n   463→\\t}\\n   464→\\n   465→\\t// No checkpoint ID found - leave message unchanged\\n   466→\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend with no checkpoint to restore\\\",\\n   467→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   468→\\t)\\n   469→\\treturn nil\\n   470→}\\n   471→\\n   472→// PostCommit is called by the git post-commit hook after a commit is created.\\n   473→// Uses the session state machine to determine what action to take per session:\\n   474→//   - ACTIVE → condense immediately (each commit gets its own checkpoint)\\n   475→//   - IDLE → condense immediately\\n   476→//   - ENDED → condense if files touched, discard if empty\\n   477→//\\n   478→// After condensation for ACTIVE sessions, remaining uncommitted files are\\n   479→// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n   480→//\\n   481→// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n   482→// and were condensed during this PostCommit.\\n   483→\\n   484→// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n   485→// Each session in the loop gets its own handler with per-session context.\\n   486→// Handler methods use the *State parameter from ApplyTransition (same pointer\\n   487→// as the state being transitioned) rather than capturing state separately.\\n   488→type postCommitActionHandler struct {\\n   489→\\ts                      *ManualCommitStrategy\\n   490→\\tlogCtx                 context.Context\\n   491→\\trepo                   *git.Repository\\n   492→\\tcheckpointID           id.CheckpointID\\n   493→\\thead                   *plumbing.Reference\\n   494→\\tcommit                 *object.Commit\\n   495→\\tnewHead                string\\n   496→\\tshadowBranchName       string\\n   497→\\tshadowBranchesToDelete map[string]struct{}\\n   498→\\tcommittedFileSet       map[string]struct{}\\n   499→\\thasNew                 bool\\n   500→\\tfilesTouchedBefore     []string\\n   501→\\n   502→\\t// Output: set by handler methods, read by caller after TransitionAndLog.\\n   503→\\tcondensed bool\\n   504→}\\n   505→\\n   506→func (h *postCommitActionHandler) HandleCondense(state *session.State) error {\\n   507→\\tshouldCondense := h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   508→\\n   509→\\tlogging.Debug(h.logCtx, \\\"post-commit: HandleCondense decision\\\",\\n   510→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   511→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   512→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   513→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   514→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   515→\\t)\\n   516→\\n   517→\\tif shouldCondense {\\n   518→\\t\\th.condensed = h.s.condenseAndUpdateState(h.logCtx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet)\\n   519→\\t} else {\\n   520→\\t\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n   521→\\t}\\n   522→\\treturn nil\\n   523→}\\n   524→\\n   525→func (h *postCommitActionHandler) HandleCondenseIfFilesTouched(state *session.State) error {\\n   526→\\tshouldCondense := len(state.FilesTouched) > 0 && h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   527→\\n   528→\\tlogging.Debug(h.logCtx, \\\"post-commit: HandleCondenseIfFilesTouched decision\\\",\\n   529→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   530→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   531→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   532→\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n   533→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   534→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   535→\\t)\\n   536→\\n   537→\\tif shouldCondense {\\n   538→\\t\\th.condensed = h.s.condenseAndUpdateState(h.logCtx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet)\\n   539→\\t} else {\\n   540→\\t\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n   541→\\t}\\n   542→\\treturn nil\\n   543→}\\n   544→\\n   545→// shouldCondenseWithOverlapCheck returns true if the session should be condensed\\n   546→// into this commit. Requires both that hasNew is true AND that the session's files\\n   547→// overlap with the committed files with matching content.\\n   548→//\\n   549→// This prevents stale sessions (ACTIVE sessions where the agent was killed, or\\n   550→// ENDED/IDLE sessions with carry-forward files) from being condensed into every\\n   551→// unrelated commit.\\n   552→//\\n   553→// filesTouchedBefore is populated from:\\n   554→//   - state.FilesTouched for IDLE/ENDED sessions (set via SaveStep/SaveTaskStep -> mergeFilesTouched)\\n   555→//   - transcript extraction for ACTIVE sessions when FilesTouched is empty\\n   556→//\\n   557→// When filesTouchedBefore is empty:\\n   558→//   - For ACTIVE sessions: fail-open (trust hasNew) because the agent may be\\n   559→//     mid-turn before any files are saved to state.\\n   560→//   - For IDLE/ENDED sessions: return false because there are no files to\\n   561→//     overlap with the commit.\\n   562→func (h *postCommitActionHandler) shouldCondenseWithOverlapCheck(isActive bool) bool {\\n   563→\\tif !h.hasNew {\\n   564→\\t\\treturn false\\n   565→\\t}\\n   566→\\tif len(h.filesTouchedBefore) == 0 {\\n   567→\\t\\treturn isActive // ACTIVE: fail-open; IDLE/ENDED: no files = no overlap\\n   568→\\t}\\n   569→\\t// Only check files that were actually changed in this commit.\\n   570→\\t// Without this, files that exist in the tree but weren't changed\\n   571→\\t// would pass the \\\"modified file\\\" check in filesOverlapWithContent\\n   572→\\t// (because the file exists in the parent tree), causing stale\\n   573→\\t// sessions to be incorrectly condensed.\\n   574→\\tvar committedTouchedFiles []string\\n   575→\\tfor _, f := range h.filesTouchedBefore {\\n   576→\\t\\tif _, ok := h.committedFileSet[f]; ok {\\n   577→\\t\\t\\tcommittedTouchedFiles = append(committedTouchedFiles, f)\\n   578→\\t\\t}\\n   579→\\t}\\n   580→\\tif len(committedTouchedFiles) == 0 {\\n   581→\\t\\treturn false\\n   582→\\t}\\n   583→\\treturn filesOverlapWithContent(h.repo, h.shadowBranchName, h.commit, committedTouchedFiles)\\n   584→}\\n   585→\\n   586→func (h *postCommitActionHandler) HandleDiscardIfNoFiles(state *session.State) error {\\n   587→\\tif len(state.FilesTouched) == 0 {\\n   588→\\t\\tlogging.Debug(h.logCtx, \\\"post-commit: skipping empty ended session (no files to condense)\\\",\\n   589→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   590→\\t\\t)\\n   591→\\t}\\n   592→\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n   593→\\treturn nil\\n   594→}\\n   595→\\n   596→func (h *postCommitActionHandler) HandleWarnStaleSession(_ *session.State) error {\\n   597→\\t// Not produced by EventGitCommit; no-op for exhaustiveness.\\n   598→\\treturn nil\\n   599→}\\n   600→\\n   601→// During rebase/cherry-pick/revert operations, phase transitions are skipped entirely.\\n   602→//\\n   603→//nolint:unparam // error return required by interface but hooks must return nil\\n   604→func (s *ManualCommitStrategy) PostCommit() error {\\n   605→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   606→\\n   607→\\trepo, err := OpenRepository()\\n   608→\\tif err != nil {\\n   609→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   610→\\t}\\n   611→\\n   612→\\t// Get HEAD commit to check for trailer\\n   613→\\thead, err := repo.Head()\\n   614→\\tif err != nil {\\n   615→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   616→\\t}\\n   617→\\n   618→\\tcommit, err := repo.CommitObject(head.Hash())\\n   619→\\tif err != nil {\\n   620→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   621→\\t}\\n   622→\\n   623→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   624→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   625→\\tif !found {\\n   626→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   627→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   628→\\t\\ts.postCommitUpdateBaseCommitOnly(logCtx, head)\\n   629→\\t\\treturn nil\\n   630→\\t}\\n   631→\\n   632→\\tworktreePath, err := GetWorktreePath()\\n   633→\\tif err != nil {\\n   634→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   635→\\t}\\n   636→\\n   637→\\t// Find all active sessions for this worktree\\n   638→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   639→\\tif err != nil || len(sessions) == 0 {\\n   640→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   641→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   642→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   643→\\t\\t)\\n   644→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   645→\\t}\\n   646→\\n   647→\\t// Build transition context\\n   648→\\tisRebase := isGitSequenceOperation()\\n   649→\\ttransitionCtx := session.TransitionContext{\\n   650→\\t\\tIsRebaseInProgress: isRebase,\\n   651→\\t}\\n   652→\\n   653→\\tif isRebase {\\n   654→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   655→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   656→\\t\\t)\\n   657→\\t}\\n   658→\\n   659→\\t// Track shadow branch names and whether they can be deleted\\n   660→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   661→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   662→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   663→\\n   664→\\tnewHead := head.Hash().String()\\n   665→\\tcommittedFileSet := filesChangedInCommit(commit)\\n   666→\\n   667→\\tfor _, state := range sessions {\\n   668→\\t\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   669→\\n   670→\\t\\t// Check for new content (needed for TransitionContext and condensation).\\n   671→\\t\\t// Fail-open: if content check errors, assume new content exists so we\\n   672→\\t\\t// don't silently skip data that should have been condensed.\\n   673→\\t\\t//\\n   674→\\t\\t// For ACTIVE sessions: the commit has a checkpoint trailer (verified above),\\n   675→\\t\\t// meaning PrepareCommitMsg already determined this commit is session-related.\\n   676→\\t\\t// The trailer is only added when either:\\n   677→\\t\\t//   - No TTY (agent/subagent committing) — added unconditionally\\n   678→\\t\\t//   - TTY (human committing) — added after content detection confirmed agent work\\n   679→\\t\\t// In both cases, PrepareCommitMsg already validated this commit. We trust\\n   680→\\t\\t// that decision here. Transcript-based re-validation is unreliable because\\n   681→\\t\\t// subagent transcripts may not be available yet (subagent still running).\\n   682→\\t\\tvar hasNew bool\\n   683→\\t\\tif state.Phase.IsActive() {\\n   684→\\t\\t\\thasNew = true\\n   685→\\t\\t} else {\\n   686→\\t\\t\\tvar contentErr error\\n   687→\\t\\t\\thasNew, contentErr = s.sessionHasNewContent(repo, state)\\n   688→\\t\\t\\tif contentErr != nil {\\n   689→\\t\\t\\t\\thasNew = true\\n   690→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: error checking session content, assuming new content\\\",\\n   691→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   692→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", contentErr.Error()),\\n   693→\\t\\t\\t\\t)\\n   694→\\t\\t\\t}\\n   695→\\t\\t}\\n   696→\\t\\ttransitionCtx.HasFilesTouched = len(state.FilesTouched) > 0\\n   697→\\n   698→\\t\\t// Save FilesTouched BEFORE TransitionAndLog — the handler's condensation\\n   699→\\t\\t// clears it,