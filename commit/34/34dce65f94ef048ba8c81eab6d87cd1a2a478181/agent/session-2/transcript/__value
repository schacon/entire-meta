\\\"failed to get checkpoint store: %w\\\", err)\\n    37→\\t}\\n    38→\\n    39→\\tcommitted, err := store.ListCommitted(context.Background())\\n    40→\\tif err != nil {\\n    41→\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n    42→\\t}\\n    43→\\n    44→\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n    45→\\tresult := make([]CheckpointInfo, 0, len(committed))\\n    46→\\tfor _, c := range committed {\\n    47→\\t\\tresult = append(result, CheckpointInfo{\\n    48→\\t\\t\\tCheckpointID:     c.CheckpointID,\\n    49→\\t\\t\\tSessionID:        c.SessionID,\\n    50→\\t\\t\\tCreatedAt:        c.CreatedAt,\\n    51→\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n    52→\\t\\t\\tFilesTouched:     c.FilesTouched,\\n    53→\\t\\t\\tAgent:            c.Agent,\\n    54→\\t\\t\\tIsTask:           c.IsTask,\\n    55→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    56→\\t\\t\\tSessionCount:     c.SessionCount,\\n    57→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    58→\\t\\t})\\n    59→\\t}\\n    60→\\n    61→\\treturn result, nil\\n    62→}\\n    63→\\n    64→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    65→func (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n    66→\\tall, err := s.listCheckpoints()\\n    67→\\tif err != nil {\\n    68→\\t\\treturn nil, err\\n    69→\\t}\\n    70→\\n    71→\\tvar result []CheckpointInfo\\n    72→\\tfor _, cp := range all {\\n    73→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    74→\\t\\t\\tresult = append(result, cp)\\n    75→\\t\\t}\\n    76→\\t}\\n    77→\\n    78→\\tif len(result) == 0 {\\n    79→\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n    80→\\t}\\n    81→\\n    82→\\treturn result, nil\\n    83→}\\n    84→\\n    85→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    86→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    87→func (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n    88→\\tstore, err := s.getCheckpointStore()\\n    89→\\tif err != nil {\\n    90→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    91→\\t}\\n    92→\\n    93→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n    94→\\tif err != nil {\\n    95→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    96→\\t}\\n    97→\\tif content == nil {\\n    98→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n    99→\\t}\\n   100→\\tif len(content.Transcript) == 0 {\\n   101→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   102→\\t}\\n   103→\\n   104→\\treturn content.Transcript, nil\\n   105→}\\n   106→\\n   107→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   108→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   109→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   110→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   111→//\\n   112→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   113→// In this case, data is extracted from the live transcript instead.\\n   114→func (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n   115→\\t// Get shadow branch (may not exist for mid-session commits)\\n   116→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   117→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   118→\\tref, err := repo.Reference(refName, true)\\n   119→\\thasShadowBranch := err == nil\\n   120→\\n   121→\\tvar sessionData *ExtractedSessionData\\n   122→\\tif hasShadowBranch {\\n   123→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   124→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   125→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   126→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   127→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   128→\\t\\t// last turn had no code changes).\\n   129→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   130→\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n   131→\\t\\tif err != nil {\\n   132→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n   133→\\t\\t}\\n   134→\\t} else {\\n   135→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   136→\\t\\t// Extract data directly from live transcript.\\n   137→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   138→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   139→\\t\\t}\\n   140→\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n   141→\\t\\tif err != nil {\\n   142→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n   143→\\t\\t}\\n   144→\\t}\\n   145→\\n   146→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   147→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   148→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   149→\\tif len(committedFiles) > 0 {\\n   150→\\t\\t// Track if we had files before filtering to distinguish between:\\n   151→\\t\\t// - Session had files but none were committed (don't fallback)\\n   152→\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n   153→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   154→\\n   155→\\t\\tif hadFilesBeforeFiltering {\\n   156→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   157→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   158→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   159→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   160→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   161→\\t\\t\\t\\t}\\n   162→\\t\\t\\t}\\n   163→\\t\\t\\tsessionData.FilesTouched = filtered\\n   164→\\t\\t}\\n   165→\\n   166→\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n   167→\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n   168→\\t\\t// the session had files that simply didn't overlap with the commit - that\\n   169→\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n   170→\\t\\t// overwritten with unrelated committed files.\\n   171→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   172→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   173→\\t\\t\\tfor f := range committedFiles {\\n   174→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   175→\\t\\t\\t}\\n   176→\\t\\t}\\n   177→\\t}\\n   178→\\n   179→\\t// Get checkpoint store\\n   180→\\tstore, err := s.getCheckpointStore()\\n   181→\\tif err != nil {\\n   182→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   183→\\t}\\n   184→\\n   185→\\t// Get author info\\n   186→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   187→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   188→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   189→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   190→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n   191→\\t// Get current branch name\\n   192→\\tbranchName := GetCurrentBranchName(repo)\\n   193→\\n   194→\\t// Generate summary if enabled\\n   195→\\tvar summary *cpkg.Summary\\n   196→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   197→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   198→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   199→\\n   200→\\t\\t// Scope transcript to this checkpoint's portion.\\n   201→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   202→\\t\\t// For Gemini (JSON), CheckpointTranscriptStart is a message index.\\n   203→\\t\\tvar scopedTranscript []byte\\n   204→\\t\\tif state.AgentType == agent.AgentTypeGemini {\\n   205→\\t\\t\\tscopedTranscript = geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   206→\\t\\t} else {\\n   207→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   208→\\t\\t}\\n   209→\\t\\tif len(scopedTranscript) > 0 {\\n   210→\\t\\t\\tvar err error\\n   211→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   212→\\t\\t\\tif err != nil {\\n   213→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   214→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   215→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   216→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   217→\\t\\t\\t} else {\\n   218→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   219→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   220→\\t\\t\\t}\\n   221→\\t\\t}\\n   222→\\t}\\n   223→\\n   224→\\t// Write checkpoint metadata using the checkpoint store\\n   225→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   226→\\t\\tCheckpointID:                checkpointID,\\n   227→\\t\\tSessionID:                   state.SessionID,\\n   228→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   229→\\t\\tBranch:                      branchName,\\n   230→\\t\\tTranscript:                  sessionData.Transcript,\\n   231→\\t\\tPrompts:                     sessionData.Prompts,\\n   232→\\t\\tContext:                     sessionData.Context,\\n   233→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   234→\\t\\tCheckpointsCount:            state.StepCount,\\n   235→\\t\\tEphemeralBranch:             shadowBranchName,\\n   236→\\t\\tAuthorName:                  authorName,\\n   237→\\t\\tAuthorEmail:                 authorEmail,\\n   238→\\t\\tAgent:                       state.AgentType,\\n   239→\\t\\tTurnID:                      state.TurnID,\\n   240→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   241→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   242→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   243→\\t\\tExportData:                  sessionData.ExportData,\\n   244→\\t\\tInitialAttribution:          attribution,\\n   245→\\t\\tSummary:                     summary,\\n   246→\\t}); err != nil {\\n   247→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   248→\\t}\\n   249→\\n   250→\\treturn &CondenseResult{\\n   251→\\t\\tCheckpointID:         checkpointID,\\n   252→\\t\\tSessionID:            state.SessionID,\\n   253→\\t\\tCheckpointsCount:     state.StepCount,\\n   254→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   255→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   256→\\t}, nil\\n   257→}\\n   258→\\n   259→func calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n   260→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   261→\\t// This uses user edits captured at each prompt start (before agent works),\\n   262→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   263→\\t//\\n   264→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   265→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   266→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   267→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   268→\\n   269→\\theadRef, headErr := repo.Head()\\n   270→\\tif headErr != nil {\\n   271→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   272→\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   273→\\t\\treturn nil\\n   274→\\t}\\n   275→\\n   276→\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   277→\\tif commitErr != nil {\\n   278→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   279→\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   280→\\t\\treturn nil\\n   281→\\t}\\n   282→\\n   283→\\theadTree, treeErr := headCommit.Tree()\\n   284→\\tif treeErr != nil {\\n   285→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   286→\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   287→\\t\\treturn nil\\n   288→\\t}\\n   289→\\n   290→\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n   291→\\tvar shadowTree *object.Tree\\n   292→\\tif shadowRef != nil {\\n   293→\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   294→\\t\\tif shadowErr != nil {\\n   295→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   296→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   297→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   298→\\t\\t\\treturn nil\\n   299→\\t\\t}\\n   300→\\t\\tvar shadowTreeErr error\\n   301→\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   302→\\t\\tif shadowTreeErr != nil {\\n   303→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   304→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   305→\\t\\t\\treturn nil\\n   306→\\t\\t}\\n   307→\\t} else {\\n   308→\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   309→\\t\\t// because the agent's work is the commit itself.\\n   310→\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   311→\\t\\tshadowTree = headTree\\n   312→\\t}\\n   313→\\n   314→\\t// Get base tree (state before session started)\\n   315→\\tvar baseTree *object.Tree\\n   316→\\tattrBase := state.AttributionBaseCommit\\n   317→\\tif attrBase == \\\"\\\" {\\n   318→\\t\\tattrBase = state.BaseCommit // backward compat\\n   319→\\t}\\n   320→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   321→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   322→\\t\\t\\tbaseTree = tree\\n   323→\\t\\t} else {\\n   324→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   325→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   326→\\t\\t}\\n   327→\\t} else {\\n   328→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   329→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   330→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   331→\\t}\\n   332→\\n   333→\\t// Log accumulated prompt attributions for debugging\\n   334→\\tvar totalUserAdded, totalUserRemoved int\\n   335→\\tfor i, pa := range state.PromptAttributions {\\n   336→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   337→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   338→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   339→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   340→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   341→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   342→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   343→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   344→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   345→\\t}\\n   346→\\n   347→\\tattribution := CalculateAttributionWithAccumulated(\\n   348→\\t\\tbaseTree,\\n   349→\\t\\tshadowTree,\\n   350→\\t\\theadTree,\\n   351→\\t\\tsessionData.FilesTouched,\\n   352→\\t\\tstate.PromptAttributions,\\n   353→\\t)\\n   354→\\n   355→\\tif attribution != nil {\\n   356→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   357→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   358→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   359→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   360→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   361→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   362→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   363→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   364→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   365→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   366→\\t}\\n   367→\\n   368→\\treturn attribution\\n   369→}\\n   370→\\n   371→// extractSessionData extracts session data from the shadow branch.\\n   372→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   373→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   374→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   375→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   376→// continued growing — the shadow branch copy would be stale.\\n   377→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   378→func (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n   379→\\tcommit, err := repo.CommitObject(shadowRef)\\n   380→\\tif err != nil {\\n   381→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   382→\\t}\\n   383→\\n   384→\\ttree, err := commit.Tree()\\n   385→\\tif err != nil {\\n   386→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   387→\\t}\\n   388→\\n   389→\\tdata := &ExtractedSessionData{}\\n   390→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   391→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   392→\\n   393→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   394→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   395→\\t// (SaveStep is only called when there are file modifications).\\n   396→\\tvar fullTranscript string\\n   397→\\tif liveTranscriptPath != \\\"\\\" {\\n   398→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   399→\\t\\t\\tfullTranscript = string(liveData)\\n   400→\\t\\t}\\n   401→\\t}\\n   402→\\tif fullTranscript == \\\"\\\" {\\n   403→\\t\\t// Fall back to shadow branch copy\\n   404→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   405→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   406→\\t\\t\\t\\tfullTranscript = content\\n   407→\\t\\t\\t}\\n   408→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   409→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   410→\\t\\t\\t\\tfullTranscript = content\\n   411→\\t\\t\\t}\\n   412→\\t\\t}\\n   413→\\t}\\n   414→\\n   415→\\t// Process transcript based on agent type\\n   416→\\tif fullTranscript != \\\"\\\" {\\n   417→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   418→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   419→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   420→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   421→\\t}\\n   422→\\n   423→\\t// Use tracked files from session state (not all files in tree)\\n   424→\\tdata.FilesTouched = filesTouched\\n   425→\\n   426→\\t// Read export data from local metadata directory (e.g., OpenCode SQLite export).\\n   427→\\t// This is written by lifecycle.go during TurnEnd and must be stored in the\\n   428→\\t// committed checkpoint so resume/rewind can re-import the session.\\n   429→\\texportRelPath := metadataDir + \\\"/\\\" + paths.ExportDataFileName\\n   430→\\tif exportAbsPath, absErr := paths.AbsPath(exportRelPath); absErr == nil {\\n   431→\\t\\tif exportBytes, readErr := os.ReadFile(exportAbsPath); readErr == nil && len(exportBytes) > 0 { //nolint:gosec // path from session metadata\\n   432→\\t\\t\\tdata.ExportData = exportBytes\\n   433→\\t\\t}\\n   434→\\t}\\n   435→\\n   436→\\t// Calculate token usage from the extracted transcript portion\\n   437→\\tif len(data.Transcript) > 0 {\\n   438→\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n   439→\\t}\\n   440→\\n   441→\\treturn data, nil\\n   442→}\\n   443→\\n   444→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   445→// This is used for mid-session commits where no shadow branch exists yet.\\n   446→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n   447→\\tdata := &ExtractedSessionData{}\\n   448→\\n   449→\\t// Read the live transcript\\n   450→\\tif state.TranscriptPath == \\\"\\\" {\\n   451→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   452→\\t}\\n   453→\\n   454→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   455→\\tif err != nil {\\n   456→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   457→\\t}\\n   458→\\n   459→\\tif len(liveData) == 0 {\\n   460→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   461→\\t}\\n   462→\\n   463→\\tfullTranscript := string(liveData)\\n   464→\\tdata.Transcript = liveData\\n   465→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   466→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   467→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   468→\\n   469→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   470→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   471→\\tif len(state.FilesTouched) > 0 {\\n   472→\\t\\tdata.FilesTouched = state.FilesTouched\\n   473→\\t} else {\\n   474→\\t\\t// Use the shared helper which includes subagent transcripts\\n   475→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n   476→\\t}\\n   477→\\n   478→\\t// Read export data from local metadata directory\\n   479→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(state.SessionID)\\n   480→\\texportRelPath := metadataDir + \\\"/\\\" + paths.ExportDataFileName\\n   481→\\tif exportAbsPath, absErr := paths.AbsPath(exportRelPath); absErr == nil {\\n   482→\\t\\tif exportBytes, readErr := os.ReadFile(exportAbsPath); readErr == nil && len(exportBytes) > 0 { //nolint:gosec // path from session metadata\\n   483→\\t\\t\\tdata.ExportData = exportBytes\\n   484→\\t\\t}\\n   485→\\t}\\n   486→\\n   487→\\t// Calculate token usage from the extracted transcript portion\\n   488→\\tif len(data.Transcript) > 0 {\\n   489→\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n   490→\\t}\\n   491→\\n   492→\\treturn data, nil\\n   493→}\\n   494→\\n   495→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   496→// For Claude Code and JSONL-based agents, this counts lines.\\n   497→// For Gemini CLI and JSON-based agents, this counts messages.\\n   498→// Returns 0 if the content is empty or malformed.\\n   499→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   500→\\tif content == \\\"\\\" {\\n   501→\\t\\treturn 0\\n   502→\\t}\\n   503→\\n   504→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   505→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   506→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   507→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   508→\\t\\t\\treturn len(transcript.Messages)\\n   509→\\t\\t}\\n   510→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   511→\\t\\tif agentType == agent.AgentTypeGemini {\\n   512→\\t\\t\\treturn 0\\n   513→\\t\\t}\\n   514→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   515→\\t}\\n   516→\\n   517→\\t// Claude Code and other JSONL-based agents\\n   518→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   519→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   520→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   521→\\t\\tallLines = allLines[:len(allLines)-1]\\n   522→\\t}\\n   523→\\treturn len(allLines)\\n   524→}\\n   525→\\n   526→// extractUserPrompts extracts all user prompts from transcript content.\\n   527→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   528→func extractUserPrompts(agentType agent.AgentType, content string) []string {\\n   529→\\tif content == \\\"\\\" {\\n   530→\\t\\treturn nil\\n   531→\\t}\\n   532→\\n   533→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   534→\\tif agentType == agent.AgentTypeOpenCode {\\n   535→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   536→\\t\\tif err == nil && len(prompts) > 0 {\\n   537→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   538→\\t\\t\\tfor _, prompt := range prompts {\\n   539→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   540→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   541→\\t\\t\\t\\t}\\n   542→\\t\\t\\t}\\n   543→\\t\\t\\treturn cleaned\\n   544→\\t\\t}\\n   545→\\t\\treturn nil\\n   546→\\t}\\n   547→\\n   548→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   549→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   550→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   551→\\t\\tif err == nil && len(prompts) > 0 {\\n   552→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   553→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   554→\\t\\t\\tfor _, prompt := range prompts {\\n   555→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   556→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   557→\\t\\t\\t\\t}\\n   558→\\t\\t\\t}\\n   559→\\t\\t\\treturn cleaned\\n   560→\\t\\t}\\n   561→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   562→\\t\\tif agentType == agent.AgentTypeGemini {\\n   563→\\t\\t\\treturn nil\\n   564→\\t\\t}\\n   565→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   566→\\t}\\n   567→\\n   568→\\t// Claude Code and other JSONL-based agents\\n   569→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   570→}\\n   571→\\n   572→// calculateTokenUsage calculates token usage from raw transcript data.\\n   573→// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n   574→// where the current checkpoint began, allowing calculation for only the portion\\n   575→// of the transcript since the last checkpoint.\\n   576→func calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n   577→\\tif len(data) == 0 {\\n   578→\\t\\treturn &agent.TokenUsage{}\\n   579→\\t}\\n   580→\\n   581→\\t// OpenCode uses JSONL with token info on assistant messages (different schema from Claude Code)\\n   582→\\tif agentType == agent.AgentTypeOpenCode {\\n   583→\\t\\treturn opencode.CalculateTokenUsageFromBytes(data, startOffset)\\n   584→\\t}\\n   585→\\n   586→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   587→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   588→\\t\\t// Attempt to parse as Gemini JSON\\n   589→\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n   590→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   591→\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n   592→\\t\\t}\\n   593→\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n   594→\\t\\tif agentType == agent.AgentTypeGemini {\\n   595→\\t\\t\\treturn &agent.TokenUsage{}\\n   596→\\t\\t}\\n   597→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   598→\\t}\\n   599→\\n   600→\\t// Claude Code and other JSONL-based agents\\n   601→\\tlines, err := transcript.ParseFromBytes(data)\\n   602→\\tif err != nil || len(lines) == 0 {\\n   603→\\t\\treturn &agent.TokenUsage{}\\n   604→\\t}\\n   605→\\t// Slice transcript lines to only include checkpoint portion\\n   606→\\tif startOffset > 0 && startOffset < len(lines) {\\n   607→\\t\\tlines = lines[startOffset:]\\n   608→\\t}\\n   609→\\treturn claudecode.CalculateTokenUsage(lines)\\n   610→}\\n   611→\\n   612→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   613→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   614→func extractUserPromptsFromLines(lines []string) []string {\\n   615→\\tvar prompts []string\\n   616→\\tfor _, line := range lines {\\n   617→\\t\\tline = strings.TrimSpace(line)\\n   618→\\t\\tif line == \\\"\\\" {\\n   619→\\t\\t\\tcontinue\\n   620→\\t\\t}\\n   621→\\n   622→\\t\\tvar entry map[string]interface{}\\n   623→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   624→\\t\\t\\tcontinue\\n   625→\\t\\t}\\n   626→\\n   627→\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n   628→\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n   629→\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n   630→\\t\\t\\tcontinue\\n   631→\\t\\t}\\n   632→\\n   633→\\t\\t// Extract message content\\n   634→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   635→\\t\\tif !ok {\\n   636→\\t\\t\\tcontinue\\n   637→\\t\\t}\\n   638→\\n   639→\\t\\t// Handle string content\\n   640→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   641→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   642→\\t\\t\\tif cleaned != \\\"\\\" {\\n   643→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   644→\\t\\t\\t}\\n   645→\\t\\t\\tcontinue\\n   646→\\t\\t}\\n   647→\\n   648→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   649→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   650→\\t\\t\\tvar texts []string\\n   651→\\t\\t\\tfor _, item := range arr {\\n   652→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   653→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   654→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   655→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   656→\\t\\t\\t\\t\\t\\t}\\n   657→\\t\\t\\t\\t\\t}\\n   658→\\t\\t\\t\\t}\\n   659→\\t\\t\\t}\\n   660→\\t\\t\\tif len(texts) > 0 {\\n   661→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   662→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   663→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   664→\\t\\t\\t\\t}\\n   665→\\t\\t\\t}\\n   666→\\t\\t}\\n   667→\\t}\\n   668→\\treturn prompts\\n   669→}\\n   670→\\n   671→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   672→func generateContextFromPrompts(prompts []string) []byte {\\n   673→\\tif len(prompts) == 0 {\\n   674→\\t\\treturn nil\\n   675→\\t}\\n   676→\\n   677→\\tvar buf strings.Builder\\n   678→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   679→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   680→\\n   681→\\tfor i, prompt := range prompts {\\n   682→\\t\\t// Truncate very long prompts for readability\\n   683→\\t\\tdisplayPrompt := prompt\\n   684→\\t\\tif len(displayPrompt) > 500 {\\n   685→\\t\\t\\tdisplayPrompt = displayPrompt[:500] + \\\"...\\\"\\n   686→\\t\\t}\\n   687→\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n   688→\\t\\tbuf.WriteString(displayPrompt)\\n   689→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   690→\\t}\\n   691→\\n   692→\\treturn []byte(buf.String())\\n   693→}\\n   694→\\n   695→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   696→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   697→func (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n   698→\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n   699→\\n   700→\\t// Load session state\\n   701→\\tstate, err := s.loadSessionState(sessionID)\\n   702→\\tif err != nil {\\n   703→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   704→\\t}\\n   705→\\tif state == nil {\\n   706→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   707→\\t}\\n   708→\\n   709→\\t// Open repository\\n   710→\\trepo, err := OpenRepository()\\n   711→\\tif err != nil {\\n   712→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   713→\\t}\\n   714→\\n   715→\\t// Generate a checkpoint ID\\n   716→\\tcheckpointID, err := id.Generate()\\n   717→\\tif err != nil {\\n   718→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   719→\\t}\\n   720→\\n   721→\\t// Check if shadow branch exists (required for condensation)\\n   722→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   723→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   724→\\t_, refErr := repo.Reference(refName, true)\\n   725→\\thasShadowBranch := refErr == nil\\n   726→\\n   727→\\tif !hasShadowBranch {\\n   728→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   729→\\t\\t// Just clean up the state file.\\n   730→\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n   731→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   732→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   733→\\t\\t)\\n   734→\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n   735→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   736→\\t\\t}\\n   737→\\t\\treturn nil\\n   738→\\t}\\n   739→\\n   740→\\t// Condense the session\\n   741→\\tresult, err := s.CondenseSession(repo, checkpointID, state, nil)\\n   742→\\tif err != nil {\\n   743→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   744→\\t}\\n   745→\\n   746→\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n   747→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   748→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   749→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   750→\\t)\\n   751→\\n   752→\\t// Update session state: reset step count and transition to idle\\n   753→\\tstate.StepCount = 0\\n   754→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   755→\\tstate.Phase = session.PhaseIdle\\n   756→\\tstate.LastCheckpointID = checkpointID\\n   757→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   758→\\tstate.PromptAttributions = nil\\n   759→\\tstate.PendingPromptAttribution = nil\\n   760→\\n   761→\\tif err := s.saveSessionState(state); err != nil {\\n   762→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   763→\\t}\\n   764→\\n   765→\\t// Clean up shadow branch if no other sessions need it\\n   766→\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n   767→\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n   768→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   769→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   770→\\t\\t)\\n   771→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   772→\\t}\\n   773→\\n   774→\\treturn nil\\n   775→}\\n   776→\\n   777→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   778→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(_ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   779→\\t// List all session states to check if any other session uses this shadow branch\\n   780→\\tallStates, err := s.listAllSessionStates()\\n   781→\\tif err != nil {\\n   782→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   783→\\t}\\n   784→\\n   785→\\tfor _, state := range allStates {\\n   786→\\t\\tif state.SessionID == excludeSessionID {\\n   787→\\t\\t\\tcontinue\\n   788→\\t\\t}\\n   789→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   790→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   791→\\t\\t\\t// Another session still needs this shadow branch\\n   792→\\t\\t\\treturn nil\\n   793→\\t\\t}\\n   794→\\t}\\n   795→\\n   796→\\t// No other sessions need it, delete the shadow branch via CLI\\n   797→\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n   798→\\tif err := DeleteBranchCLI(shadowBranchName); err != nil {\\n   799→\\t\\t// Branch already gone is not an error\\n   800→\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n   801→\\t\\t\\treturn nil\\n   802→\\t\\t}\\n   803→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n   804→\\t}\\n   805→\\treturn nil\\n   806→}\\n   807→\"}]},\"uuid\":\"93bcabe4-d20b-4608-b342-8293168221c4\",\"timestamp\":\"2026-02-20T17:54:02.830Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/dip/Repositories/cli/cmd/entire/cli/strategy/manual_commit_condensation.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/opencode\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// listCheckpoints returns all checkpoints from the metadata branch.\\n// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) listCheckpoints() ([]CheckpointInfo, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcommitted, err := store.ListCommitted(context.Background())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n\\t}\\n\\n\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n\\tresult := make([]CheckpointInfo, 0, len(committed))\\n\\tfor _, c := range committed {\\n\\t\\tresult = append(result, CheckpointInfo{\\n\\t\\t\\tCheckpointID:     c.CheckpointID,\\n\\t\\t\\tSessionID:        c.SessionID,\\n\\t\\t\\tCreatedAt:        c.CreatedAt,\\n\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n\\t\\t\\tFilesTouched:     c.FilesTouched,\\n\\t\\t\\tAgent:            c.Agent,\\n\\t\\t\\tIsTask:           c.IsTask,\\n\\t\\t\\tToolUseID:        c.ToolUseID,\\n\\t\\t\\tSessionCount:     c.SessionCount,\\n\\t\\t\\tSessionIDs:       c.SessionIDs,\\n\\t\\t})\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointsForSession returns all checkpoints for a session ID.\\nfunc (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n\\tall, err := s.listCheckpoints()\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tvar result []CheckpointInfo\\n\\tfor _, cp := range all {\\n\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n\\t\\t\\tresult = append(result, cp)\\n\\t\\t}\\n\\t}\\n\\n\\tif len(result) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// CondenseSession condenses a session's shadow branch to permanent storage.\\n// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n//\\n// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n// In this case, data is extracted from the live transcript instead.\\nfunc (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n\\t// Get shadow branch (may not exist for mid-session commits)\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\thasShadowBranch := err == nil\\n\\n\\tvar sessionData *ExtractedSessionData\\n\\tif hasShadowBranch {\\n\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n\\t\\t// last turn had no code changes).\\n\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n\\t\\t// Extract data directly from live transcript.\\n\\t\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n\\t\\t}\\n\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n\\t// committed in this specific commit. This ensures each checkpoint represents\\n\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n\\tif len(committedFiles) > 0 {\\n\\t\\t// Track if we had files before filtering to distinguish between:\\n\\t\\t// - Session had files but none were committed (don't fallback)\\n\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n\\n\\t\\tif hadFilesBeforeFiltering {\\n\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tsessionData.FilesTouched = filtered\\n\\t\\t}\\n\\n\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n\\t\\t// the session had files that simply didn't overlap with the commit - that\\n\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n\\t\\t// overwritten with unrelated committed files.\\n\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n\\t\\t\\tfor f := range committedFiles {\\n\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Get checkpoint store\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get author info\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Generate summary if enabled\\n\\tvar summary *cpkg.Summary\\n\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n\\n\\t\\t// Scope transcript to this checkpoint's portion.\\n\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n\\t\\t// For Gemini (JSON), CheckpointTranscriptStart is a message index.\\n\\t\\tvar scopedTranscript []byte\\n\\t\\tif state.AgentType == agent.AgentTypeGemini {\\n\\t\\t\\tscopedTranscript = geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t} else {\\n\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t}\\n\\t\\tif len(scopedTranscript) > 0 {\\n\\t\\t\\tvar err error\\n\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t\\t// Continue without summary - non-blocking\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write checkpoint metadata using the checkpoint store\\n\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n\\t\\tCheckpointID:                checkpointID,\\n\\t\\tSessionID:                   state.SessionID,\\n\\t\\tStrategy:                    StrategyNameManualCommit,\\n\\t\\tBranch:                      branchName,\\n\\t\\tTranscript:                  sessionData.Transcript,\\n\\t\\tPrompts:                     sessionData.Prompts,\\n\\t\\tContext:                     sessionData.Context,\\n\\t\\tFilesTouched:                sessionData.FilesTouched,\\n\\t\\tCheckpointsCount:            state.StepCount,\\n\\t\\tEphemeralBranch:             shadowBranchName,\\n\\t\\tAuthorName:                  authorName,\\n\\t\\tAuthorEmail:                 authorEmail,\\n\\t\\tAgent:                       state.AgentType,\\n\\t\\tTurnID:                      state.TurnID,\\n\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n\\t\\tExportData:                  sessionData.ExportData,\\n\\t\\tInitialAttribution:          attribution,\\n\\t\\tSummary:                     summary,\\n\\t}); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n\\t}\\n\\n\\treturn &CondenseResult{\\n\\t\\tCheckpointID:         checkpointID,\\n\\t\\tSessionID:            state.SessionID,\\n\\t\\tCheckpointsCount:     state.StepCount,\\n\\t\\tFilesTouched:         sessionData.FilesTouched,\\n\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n\\t}, nil\\n}\\n\\nfunc calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n\\t// Calculate initial attribution using accumulated prompt attribution data.\\n\\t// This uses user edits captured at each prompt start (before agent works),\\n\\t// plus any user edits after the final checkpoint (shadow → head).\\n\\t//\\n\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\n\\theadRef, headErr := repo.Head()\\n\\tif headErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n\\tif commitErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\theadTree, treeErr := headCommit.Tree()\\n\\tif treeErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n\\tvar shadowTree *object.Tree\\n\\tif shadowRef != nil {\\n\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n\\t\\tif shadowErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\tvar shadowTreeErr error\\n\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n\\t\\tif shadowTreeErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n\\t\\t// because the agent's work is the commit itself.\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n\\t\\tshadowTree = headTree\\n\\t}\\n\\n\\t// Get base tree (state before session started)\\n\\tvar baseTree *object.Tree\\n\\tattrBase := state.AttributionBaseCommit\\n\\tif attrBase == \\\"\\\" {\\n\\t\\tattrBase = state.BaseCommit // backward compat\\n\\t}\\n\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n\\t\\t\\tbaseTree = tree\\n\\t\\t} else {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n\\t\\t}\\n\\t} else {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n\\t}\\n\\n\\t// Log accumulated prompt attributions for debugging\\n\\tvar totalUserAdded, totalUserRemoved int\\n\\tfor i, pa := range state.PromptAttributions {\\n\\t\\ttotalUserAdded += pa.UserLinesAdded\\n\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n\\t\\t\\tslog.Int(\\\"index\\\", i))\\n\\t}\\n\\n\\tattribution := CalculateAttributionWithAccumulated(\\n\\t\\tbaseTree,\\n\\t\\tshadowTree,\\n\\t\\theadTree,\\n\\t\\tsessionData.FilesTouched,\\n\\t\\tstate.PromptAttributions,\\n\\t)\\n\\n\\tif attribution != nil {\\n\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n\\t}\\n\\n\\treturn attribution\\n}\\n\\n// extractSessionData extracts session data from the shadow branch.\\n// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n// continued growing — the shadow branch copy would be stale.\\n// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\nfunc (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n\\tcommit, err := repo.CommitObject(shadowRef)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\tdata := &ExtractedSessionData{}\\n\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\n\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n\\t// (SaveStep is only called when there are file modifications).\\n\\tvar fullTranscript string\\n\\tif liveTranscriptPath != \\\"\\\" {\\n\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n\\t\\t\\tfullTranscript = string(liveData)\\n\\t\\t}\\n\\t}\\n\\tif fullTranscript == \\\"\\\" {\\n\\t\\t// Fall back to shadow branch copy\\n\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Process transcript based on agent type\\n\\tif fullTranscript != \\\"\\\" {\\n\\t\\tdata.Transcript = []byte(fullTranscript)\\n\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\t}\\n\\n\\t// Use tracked files from session state (not all files in tree)\\n\\tdata.FilesTouched = filesTouched\\n\\n\\t// Read export data from local metadata directory (e.g., OpenCode SQLite export).\\n\\t// This is written by lifecycle.go during TurnEnd and must be stored in the\\n\\t// committed checkpoint so resume/rewind can re-import the session.\\n\\texportRelPath := metadataDir + \\\"/\\\" + paths.ExportDataFileName\\n\\tif exportAbsPath, absErr := paths.AbsPath(exportRelPath); absErr == nil {\\n\\t\\tif exportBytes, readErr := os.ReadFile(exportAbsPath); readErr == nil && len(exportBytes) > 0 { //nolint:gosec // path from session metadata\\n\\t\\t\\tdata.ExportData = exportBytes\\n\\t\\t}\\n\\t}\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n// This is used for mid-session commits where no shadow branch exists yet.\\nfunc (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n\\tdata := &ExtractedSessionData{}\\n\\n\\t// Read the live transcript\\n\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n\\t}\\n\\n\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n\\t}\\n\\n\\tif len(liveData) == 0 {\\n\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n\\t}\\n\\n\\tfullTranscript := string(liveData)\\n\\tdata.Transcript = liveData\\n\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\n\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n\\t// (no SaveStep/Stop has been called yet to populate it)\\n\\tif len(state.FilesTouched) > 0 {\\n\\t\\tdata.FilesTouched = state.FilesTouched\\n\\t} else {\\n\\t\\t// Use the shared helper which includes subagent transcripts\\n\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n\\t}\\n\\n\\t// Read export data from local metadata directory\\n\\tmetadataDir := paths.SessionMetadataDirFromSessionID(state.SessionID)\\n\\texportRelPath := metadataDir + \\\"/\\\" + paths.ExportDataFileName\\n\\tif exportAbsPath, absErr := paths.AbsPath(exportRelPath); absErr == nil {\\n\\t\\tif exportBytes, readErr := os.ReadFile(exportAbsPath); readErr == nil && len(exportBytes) > 0 { //nolint:gosec // path from session metadata\\n\\t\\t\\tdata.ExportData = exportBytes\\n\\t\\t}\\n\\t}\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n// For Claude Code and JSONL-based agents, this counts lines.\\n// For Gemini CLI and JSON-based agents, this counts messages.\\n// Returns 0 if the content is empty or malformed.\\nfunc countTranscriptItems(agentType agent.AgentType, content string) int {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn 0\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n\\t\\t\\treturn len(transcript.Messages)\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn 0\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n\\t\\tallLines = allLines[:len(allLines)-1]\\n\\t}\\n\\treturn len(allLines)\\n}\\n\\n// extractUserPrompts extracts all user prompts from transcript content.\\n// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\nfunc extractUserPrompts(agentType agent.AgentType, content string) []string {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n\\tif agentType == agent.AgentTypeOpenCode {\\n\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n\\t\\tif err == nil && len(prompts) > 0 {\\n\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n\\t\\t\\tfor _, prompt := range prompts {\\n\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\treturn cleaned\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n\\t\\tif err == nil && len(prompts) > 0 {\\n\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n\\t\\t\\tfor _, prompt := range prompts {\\n\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\treturn cleaned\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n}\\n\\n// calculateTokenUsage calculates token usage from raw transcript data.\\n// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n// where the current checkpoint began, allowing calculation for only the portion\\n// of the transcript since the last checkpoint.\\nfunc calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n\\tif len(data) == 0 {\\n\\t\\treturn &agent.TokenUsage{}\\n\\t}\\n\\n\\t// OpenCode uses JSONL with token info on assistant messages (different schema from Claude Code)\\n\\tif agentType == agent.AgentTypeOpenCode {\\n\\t\\treturn opencode.CalculateTokenUsageFromBytes(data, startOffset)\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\t// Attempt to parse as Gemini JSON\\n\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn &agent.TokenUsage{}\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\tlines, err := transcript.ParseFromBytes(data)\\n\\tif err != nil || len(lines) == 0 {\\n\\t\\treturn &agent.TokenUsage{}\\n\\t}\\n\\t// Slice transcript lines to only include checkpoint portion\\n\\tif startOffset > 0 && startOffset < len(lines) {\\n\\t\\tlines = lines[startOffset:]\\n\\t}\\n\\treturn claudecode.CalculateTokenUsage(lines)\\n}\\n\\n// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\nfunc extractUserPromptsFromLines(lines []string) []string {\\n\\tvar prompts []string\\n\\tfor _, line := range lines {\\n\\t\\tline = strings.TrimSpace(line)\\n\\t\\tif line == \\\"\\\" {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tvar entry map[string]interface{}\\n\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Extract message content\\n\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n\\t\\tif !ok {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Handle string content\\n\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n\\t\\t\\tif cleaned != \\\"\\\" {\\n\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n\\t\\t\\t}\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n\\t\\t\\tvar texts []string\\n\\t\\t\\tfor _, item := range arr {\\n\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tif len(texts) > 0 {\\n\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\treturn prompts\\n}\\n\\n// generateContextFromPrompts generates context.md content from a list of prompts.\\nfunc generateContextFromPrompts(prompts []string) []byte {\\n\\tif len(prompts) == 0 {\\n\\t\\treturn nil\\n\\t}\\n\\n\\tvar buf strings.Builder\\n\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n\\n\\tfor i, prompt := range prompts {\\n\\t\\t// Truncate very long prompts for readability\\n\\t\\tdisplayPrompt := prompt\\n\\t\\tif len(displayPrompt) > 500 {\\n\\t\\t\\tdisplayPrompt = displayPrompt[:500] + \\\"...\\\"\\n\\t\\t}\\n\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n\\t\\tbuf.WriteString(displayPrompt)\\n\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n\\t}\\n\\n\\treturn []byte(buf.String())\\n}\\n\\n// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\nfunc (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n\\n\\t// Load session state\\n\\tstate, err := s.loadSessionState(sessionID)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n\\t}\\n\\tif state == nil {\\n\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n\\t}\\n\\n\\t// Open repository\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\t// Generate a checkpoint ID\\n\\tcheckpointID, err := id.Generate()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n\\t}\\n\\n\\t// Check if shadow branch exists (required for condensation)\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\t_, refErr := repo.Reference(refName, true)\\n\\thasShadowBranch := refErr == nil\\n\\n\\tif !hasShadowBranch {\\n\\t\\t// No shadow branch means no checkpoint data to condense.\\n\\t\\t// Just clean up the state file.\\n\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n\\t\\t)\\n\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Condense the session\\n\\tresult, err := s.CondenseSession(repo, checkpointID, state, nil)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n\\t}\\n\\n\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n\\t)\\n\\n\\t// Update session state: reset step count and transition to idle\\n\\tstate.StepCount = 0\\n\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n\\tstate.Phase = session.PhaseIdle\\n\\tstate.LastCheckpointID = checkpointID\\n\\tstate.AttributionBaseCommit = state.BaseCommit\\n\\tstate.PromptAttributions = nil\\n\\tstate.PendingPromptAttribution = nil\\n\\n\\tif err := s.saveSessionState(state); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n\\t}\\n\\n\\t// Clean up shadow branch if no other sessions need it\\n\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n\\t\\t)\\n\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\nfunc (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(_ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n\\t// List all session states to check if any other session uses this shadow branch\\n\\tallStates, err := s.listAllSessionStates()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n\\t}\\n\\n\\tfor _, state := range allStates {\\n\\t\\tif state.SessionID == excludeSessionID {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n\\t\\t\\t// Another session still needs this shadow branch\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t}\\n\\n\\t// No other sessions need it, delete the shadow branch via CLI\\n\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n\\tif err := DeleteBranchCLI(shadowBranchName); err != nil {\\n\\t\\t// Branch already gone is not an error\\n\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n\\t}\\n\\treturn nil\\n}\\n\",\"numLines\":807,\"startLine\":1,\"totalLines\":807}},\"sourceToolAssistantUUID\":\"9a4368a4-a501-4536-bb12-e3fd3dff2abb\"}\n{\"parentUuid\":\"93bcabe4-d20b-4608-b342-8293168221c4\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/dip/Repositories/cli\",\"sessionId\":\"6edd18ba-782c-4019-88d9-018079feea08\",\"version\":\"2.1.49\",\"gitBranch\":\"main\",\"slug\":\"wondrous-finding-raven\",\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"PostToolUse\",\"hookName\":\"PostToolUse:Read\",\"command\":\"callback\"},\"parentToolUseID\":\"toolu_012X9QJXdbAvTyTxcgdQ19oa\",\"toolUseID\":\"toolu_012X9QJXdbAvTyTxcgdQ19oa\",\"timestamp\":\"2026-02-20T17:54:03.050Z\",\"uuid\":\"352f89ce-e55e-4699-aacc-745c4b6bcd88\"}\n{\"parentUuid\":\"34f51625-adad-4ffc-ab30-3bb045c31c92\",\"isSide