il ID\\n   272→\\ttrailID, err := trail.GenerateID()\\n   273→\\tif err != nil {\\n   274→\\t\\treturn fmt.Errorf(\\\"failed to generate trail ID: %w\\\", err)\\n   275→\\t}\\n   276→\\n   277→\\t// Get git author\\n   278→\\tauthorName, _ := checkpoint.GetGitAuthorFromRepo(repo)\\n   279→\\n   280→\\tnow := time.Now()\\n   281→\\tmetadata := &trail.Metadata{\\n   282→\\t\\tTrailID:     trailID,\\n   283→\\t\\tBranch:      branch,\\n   284→\\t\\tBase:        base,\\n   285→\\t\\tTitle:       title,\\n   286→\\t\\tDescription: description,\\n   287→\\t\\tStatus:      trailStatus,\\n   288→\\t\\tAuthor:      authorName,\\n   289→\\t\\tAssignees:   []string{},\\n   290→\\t\\tLabels:      []string{},\\n   291→\\t\\tCreatedAt:   now,\\n   292→\\t\\tUpdatedAt:   now,\\n   293→\\t}\\n   294→\\n   295→\\tif err := store.Write(metadata, nil, nil); err != nil {\\n   296→\\t\\treturn fmt.Errorf(\\\"failed to create trail: %w\\\", err)\\n   297→\\t}\\n   298→\\n   299→\\tfmt.Fprintf(w, \\\"Created trail %q for branch %s (ID: %s)\\\\n\\\", title, branch, trailID)\\n   300→\\treturn nil\\n   301→}\\n   302→\\n   303→func newTrailUpdateCmd() *cobra.Command {\\n   304→\\tvar statusStr, title, description, branch string\\n   305→\\tvar labelAdd, labelRemove []string\\n   306→\\n   307→\\tcmd := &cobra.Command{\\n   308→\\t\\tUse:   \\\"update\\\",\\n   309→\\t\\tShort: \\\"Update trail metadata\\\",\\n   310→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   311→\\t\\t\\treturn runTrailUpdate(cmd.OutOrStdout(), statusStr, title, description, branch, labelAdd, labelRemove)\\n   312→\\t\\t},\\n   313→\\t}\\n   314→\\n   315→\\tcmd.Flags().StringVar(&statusStr, \\\"status\\\", \\\"\\\", \\\"Update status\\\")\\n   316→\\tcmd.Flags().StringVar(&title, \\\"title\\\", \\\"\\\", \\\"Update title\\\")\\n   317→\\tcmd.Flags().StringVar(&description, \\\"description\\\", \\\"\\\", \\\"Update description\\\")\\n   318→\\tcmd.Flags().StringVar(&branch, \\\"branch\\\", \\\"\\\", \\\"Branch to update trail for (defaults to current)\\\")\\n   319→\\tcmd.Flags().StringSliceVar(&labelAdd, \\\"add-label\\\", nil, \\\"Add label(s)\\\")\\n   320→\\tcmd.Flags().StringSliceVar(&labelRemove, \\\"remove-label\\\", nil, \\\"Remove label(s)\\\")\\n   321→\\n   322→\\treturn cmd\\n   323→}\\n   324→\\n   325→func runTrailUpdate(w io.Writer, statusStr, title, description, branch string, labelAdd, labelRemove []string) error {\\n   326→\\trepo, err := strategy.OpenRepository()\\n   327→\\tif err != nil {\\n   328→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   329→\\t}\\n   330→\\n   331→\\t// Determine branch\\n   332→\\tif branch == \\\"\\\" {\\n   333→\\t\\tbranch, err = GetCurrentBranch()\\n   334→\\t\\tif err != nil {\\n   335→\\t\\t\\treturn fmt.Errorf(\\\"failed to determine current branch: %w\\\", err)\\n   336→\\t\\t}\\n   337→\\t}\\n   338→\\n   339→\\tstore := trail.NewStore(repo)\\n   340→\\tmetadata, err := store.FindByBranch(branch)\\n   341→\\tif err != nil {\\n   342→\\t\\treturn fmt.Errorf(\\\"failed to find trail: %w\\\", err)\\n   343→\\t}\\n   344→\\tif metadata == nil {\\n   345→\\t\\treturn fmt.Errorf(\\\"no trail found for branch %q\\\", branch)\\n   346→\\t}\\n   347→\\n   348→\\t// Validate status if provided\\n   349→\\tif statusStr != \\\"\\\" {\\n   350→\\t\\tstatus := trail.Status(statusStr)\\n   351→\\t\\tif !status.IsValid() {\\n   352→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusStr, formatValidStatuses())\\n   353→\\t\\t}\\n   354→\\t}\\n   355→\\n   356→\\terr = store.Update(metadata.TrailID, func(m *trail.Metadata) {\\n   357→\\t\\tif statusStr != \\\"\\\" {\\n   358→\\t\\t\\tm.Status = trail.Status(statusStr)\\n   359→\\t\\t}\\n   360→\\t\\tif title != \\\"\\\" {\\n   361→\\t\\t\\tm.Title = title\\n   362→\\t\\t}\\n   363→\\t\\tif description != \\\"\\\" {\\n   364→\\t\\t\\tm.Description = description\\n   365→\\t\\t}\\n   366→\\t\\tfor _, l := range labelAdd {\\n   367→\\t\\t\\tif !containsString(m.Labels, l) {\\n   368→\\t\\t\\t\\tm.Labels = append(m.Labels, l)\\n   369→\\t\\t\\t}\\n   370→\\t\\t}\\n   371→\\t\\tfor _, l := range labelRemove {\\n   372→\\t\\t\\tm.Labels = removeString(m.Labels, l)\\n   373→\\t\\t}\\n   374→\\t})\\n   375→\\tif err != nil {\\n   376→\\t\\treturn fmt.Errorf(\\\"failed to update trail: %w\\\", err)\\n   377→\\t}\\n   378→\\n   379→\\tfmt.Fprintf(w, \\\"Updated trail for branch %s\\\\n\\\", branch)\\n   380→\\treturn nil\\n   381→}\\n   382→\\n   383→func newTrailEnableCmd() *cobra.Command {\\n   384→\\tcmd := &cobra.Command{\\n   385→\\t\\tUse:   \\\"enable\\\",\\n   386→\\t\\tShort: \\\"Enable automatic trail creation and pushing\\\",\\n   387→\\t\\tLong: `Enable trail auto-creation on session start and pushing the trails branch\\n   388→on git push. Trails are enabled by default.`,\\n   389→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   390→\\t\\t\\treturn runTrailEnable(cmd.OutOrStdout())\\n   391→\\t\\t},\\n   392→\\t}\\n   393→\\treturn cmd\\n   394→}\\n   395→\\n   396→func runTrailEnable(w io.Writer) error {\\n   397→\\ts, err := LoadEntireSettings()\\n   398→\\tif err != nil {\\n   399→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   400→\\t}\\n   401→\\n   402→\\tif s.StrategyOptions != nil {\\n   403→\\t\\tdelete(s.StrategyOptions, \\\"trails\\\")\\n   404→\\t}\\n   405→\\n   406→\\tif err := SaveEntireSettings(s); err != nil {\\n   407→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   408→\\t}\\n   409→\\n   410→\\tfmt.Fprintln(w, \\\"Trails enabled.\\\")\\n   411→\\treturn nil\\n   412→}\\n   413→\\n   414→func newTrailDisableCmd() *cobra.Command {\\n   415→\\tvar useProjectSettings bool\\n   416→\\n   417→\\tcmd := &cobra.Command{\\n   418→\\t\\tUse:   \\\"disable\\\",\\n   419→\\t\\tShort: \\\"Disable automatic trail creation and pushing\\\",\\n   420→\\t\\tLong: `Disable trail auto-creation on session start and pushing the trails branch\\n   421→on git push. Existing trails are preserved.\\n   422→\\n   423→By default, writes to .entire/settings.local.json. Use --project to write to\\n   424→.entire/settings.json instead.`,\\n   425→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   426→\\t\\t\\treturn runTrailDisable(cmd.OutOrStdout(), useProjectSettings)\\n   427→\\t\\t},\\n   428→\\t}\\n   429→\\n   430→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Write to .entire/settings.json instead of .entire/settings.local.json\\\")\\n   431→\\treturn cmd\\n   432→}\\n   433→\\n   434→func runTrailDisable(w io.Writer, useProjectSettings bool) error {\\n   435→\\ts, err := LoadEntireSettings()\\n   436→\\tif err != nil {\\n   437→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   438→\\t}\\n   439→\\n   440→\\tif s.StrategyOptions == nil {\\n   441→\\t\\ts.StrategyOptions = make(map[string]any)\\n   442→\\t}\\n   443→\\ts.StrategyOptions[\\\"trails\\\"] = false\\n   444→\\n   445→\\tif useProjectSettings {\\n   446→\\t\\tif err := SaveEntireSettings(s); err != nil {\\n   447→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   448→\\t\\t}\\n   449→\\t} else {\\n   450→\\t\\tif err := SaveEntireSettingsLocal(s); err != nil {\\n   451→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   452→\\t\\t}\\n   453→\\t}\\n   454→\\n   455→\\tfmt.Fprintln(w, \\\"Trails disabled.\\\")\\n   456→\\treturn nil\\n   457→}\\n   458→\\n   459→// defaultBaseBranch is the fallback base branch name when it cannot be determined.\\n   460→const defaultBaseBranch = \\\"main\\\"\\n   461→\\n   462→// AutoCreateTrail creates a trail automatically for the current branch if one doesn't exist.\\n   463→// This is called during session start for non-main branches.\\n   464→// If prompt is non-empty, its first line is used as the trail title instead of the branch name.\\n   465→func AutoCreateTrail(repo *git.Repository, branchName, baseBranch, prompt string) error {\\n   466→\\tstore := trail.NewStore(repo)\\n   467→\\n   468→\\texisting, err := store.FindByBranch(branchName)\\n   469→\\tif err == nil && existing != nil {\\n   470→\\t\\treturn nil // Trail already exists\\n   471→\\t}\\n   472→\\n   473→\\ttrailID, err := trail.GenerateID()\\n   474→\\tif err != nil {\\n   475→\\t\\treturn fmt.Errorf(\\\"failed to generate trail ID: %w\\\", err)\\n   476→\\t}\\n   477→\\n   478→\\tauthorName, _ := checkpoint.GetGitAuthorFromRepo(repo)\\n   479→\\tnow := time.Now()\\n   480→\\n   481→\\ttitle := titleFromPrompt(prompt)\\n   482→\\tif title == \\\"\\\" {\\n   483→\\t\\ttitle = trail.HumanizeBranchName(branchName)\\n   484→\\t}\\n   485→\\n   486→\\tmetadata := &trail.Metadata{\\n   487→\\t\\tTrailID:   trailID,\\n   488→\\t\\tBranch:    branchName,\\n   489→\\t\\tBase:      baseBranch,\\n   490→\\t\\tTitle:     title,\\n   491→\\t\\tStatus:    trail.StatusInProgress,\\n   492→\\t\\tAuthor:    authorName,\\n   493→\\t\\tAssignees: []string{},\\n   494→\\t\\tLabels:    []string{},\\n   495→\\t\\tCreatedAt: now,\\n   496→\\t\\tUpdatedAt: now,\\n   497→\\t}\\n   498→\\n   499→\\tif err := store.Write(metadata, nil, nil); err != nil {\\n   500→\\t\\treturn fmt.Errorf(\\\"failed to create trail: %w\\\", err)\\n   501→\\t}\\n   502→\\n   503→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Created trail for branch: %s\\\\n\\\", branchName)\\n   504→\\treturn nil\\n   505→}\\n   506→\\n   507→// titleFromPrompt extracts a trail title from the user's prompt.\\n   508→// Uses the first line, trimmed and truncated to 80 characters.\\n   509→// Returns empty string if prompt is empty.\\n   510→func titleFromPrompt(prompt string) string {\\n   511→\\tif prompt == \\\"\\\" {\\n   512→\\t\\treturn \\\"\\\"\\n   513→\\t}\\n   514→\\tline, _, _ := strings.Cut(prompt, \\\"\\\\n\\\")\\n   515→\\ttitle := strings.TrimSpace(line)\\n   516→\\tif len(title) > 80 {\\n   517→\\t\\ttitle = title[:77] + \\\"...\\\"\\n   518→\\t}\\n   519→\\treturn title\\n   520→}\\n   521→\\n   522→// hasFlag is a simple helper that checks os.Args for --flag presence.\\n   523→// Used to distinguish between \\\"flag not provided\\\" and \\\"flag provided with empty value\\\".\\n   524→func hasFlag(name string) bool {\\n   525→\\tfor _, arg := range os.Args {\\n   526→\\t\\tif arg == \\\"--\\\"+name || strings.HasPrefix(arg, \\\"--\\\"+name+\\\"=\\\") {\\n   527→\\t\\t\\treturn true\\n   528→\\t\\t}\\n   529→\\t}\\n   530→\\treturn false\\n   531→}\\n   532→\\n   533→func truncate(s string, maxLen int) string {\\n   534→\\tif len(s) <= maxLen {\\n   535→\\t\\treturn s\\n   536→\\t}\\n   537→\\tif maxLen <= 3 {\\n   538→\\t\\treturn s[:maxLen]\\n   539→\\t}\\n   540→\\treturn s[:maxLen-3] + \\\"...\\\"\\n   541→}\\n   542→\\n   543→func formatValidStatuses() string {\\n   544→\\tstatuses := trail.ValidStatuses()\\n   545→\\tnames := make([]string, len(statuses))\\n   546→\\tfor i, s := range statuses {\\n   547→\\t\\tnames[i] = string(s)\\n   548→\\t}\\n   549→\\treturn strings.Join(names, \\\", \\\")\\n   550→}\\n   551→\\n   552→func containsString(slice []string, s string) bool {\\n   553→\\tfor _, v := range slice {\\n   554→\\t\\tif v == s {\\n   555→\\t\\t\\treturn true\\n   556→\\t\\t}\\n   557→\\t}\\n   558→\\treturn false\\n   559→}\\n   560→\\n   561→func removeString(slice []string, s string) []string {\\n   562→\\tvar result []string\\n   563→\\tfor _, v := range slice {\\n   564→\\t\\tif v != s {\\n   565→\\t\\t\\tresult = append(result, v)\\n   566→\\t\\t}\\n   567→\\t}\\n   568→\\treturn result\\n   569→}\\n   570→\"}]},\"uuid\":\"8cf57d53-92ba-479d-b80e-49310496b2ba\",\"timestamp\":\"2026-02-20T18:37:05.929Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/dip/Repositories/cli/cmd/entire/cli/trail_cmd.go\",\"content\":\"package cli\\n\\nimport (\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"io\\\"\\n\\t\\\"os\\\"\\n\\t\\\"sort\\\"\\n