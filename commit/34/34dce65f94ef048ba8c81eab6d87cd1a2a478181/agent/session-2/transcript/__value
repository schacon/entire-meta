07→\\t\\tAgentID:                event.SubagentID,\\n   608→\\t\\tModifiedFiles:          relModifiedFiles,\\n   609→\\t\\tNewFiles:               relNewFiles,\\n   610→\\t\\tDeletedFiles:           relDeletedFiles,\\n   611→\\t\\tTranscriptPath:         event.SessionRef,\\n   612→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   613→\\t\\tCheckpointUUID:         checkpointUUID,\\n   614→\\t\\tAuthorName:             author.Name,\\n   615→\\t\\tAuthorEmail:            author.Email,\\n   616→\\t\\tSubagentType:           subagentType,\\n   617→\\t\\tTaskDescription:        taskDescription,\\n   618→\\t\\tAgentType:              agentType,\\n   619→\\t}\\n   620→\\n   621→\\tif err := strat.SaveTaskStep(ctx); err != nil {\\n   622→\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n   623→\\t}\\n   624→\\n   625→\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   626→\\treturn nil\\n   627→}\\n   628→\\n   629→// --- Helper functions ---\\n   630→\\n   631→// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n   632→// Prefers pre-prompt state, falls back to session state.\\n   633→func resolveTranscriptOffset(preState *PrePromptState, sessionID string) int {\\n   634→\\tif preState != nil && preState.TranscriptOffset > 0 {\\n   635→\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state found: parsing transcript from offset %d\\\\n\\\", preState.TranscriptOffset)\\n   636→\\t\\treturn preState.TranscriptOffset\\n   637→\\t}\\n   638→\\n   639→\\t// Fall back to session state (e.g., auto-commit strategy updates it after each save)\\n   640→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   641→\\tif loadErr != nil {\\n   642→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state: %v\\\\n\\\", loadErr)\\n   643→\\t\\treturn 0\\n   644→\\t}\\n   645→\\tif sessionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n   646→\\t\\tfmt.Fprintf(os