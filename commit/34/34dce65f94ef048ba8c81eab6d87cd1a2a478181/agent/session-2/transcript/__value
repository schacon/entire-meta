\t\\t// Can't open TTY (e.g., running in CI), use default\\n    84→\\t\\treturn defaultYes\\n    85→\\t}\\n    86→\\tdefer tty.Close()\\n    87→\\n    88→\\t// Show context if provided\\n    89→\\tif context != \\\"\\\" {\\n    90→\\t\\tfmt.Fprintf(tty, \\\"%s\\\\n\\\", context)\\n    91→\\t}\\n    92→\\n    93→\\t// Show prompt with default indicator\\n    94→\\t// Write to tty directly, not stderr, since git hooks may redirect stderr to /dev/null\\n    95→\\tvar hint string\\n    96→\\tif defaultYes {\\n    97→\\t\\thint = \\\"[Y/n]\\\"\\n    98→\\t} else {\\n    99→\\t\\thint = \\\"[y/N]\\\"\\n   100→\\t}\\n   101→\\tfmt.Fprintf(tty, \\\"%s %s \\\", prompt, hint)\\n   102→\\n   103→\\t// Read response\\n   104→\\treader := bufio.NewReader(tty)\\n   105→\\tresponse, err := reader.ReadString('\\\\n')\\n   106→\\tif err != nil {\\n   107→\\t\\treturn defaultYes\\n   108→\\t}\\n   109→\\n   110→\\tresponse = strings.TrimSpace(strings.ToLower(response))\\n   111→\\tswitch response {\\n   112→\\tcase \\\"y\\\", \\\"yes\\\":\\n   113→\\t\\treturn true\\n   114→\\tcase \\\"n\\\", \\\"no\\\":\\n   115→\\t\\treturn false\\n   116→\\tdefault:\\n   117→\\t\\t// Empty or invalid input - use default\\n   118→\\t\\treturn defaultYes\\n   119→\\t}\\n   120→}\\n   121→\\n   122→// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   123→// If the message contains only our trailer (no actual user content), strip it\\n   124→// so git will abort the commit due to empty message.\\n   125→//\\n   126→//nolint:unparam // error return required by interface but hooks must return nil\\n   127→func (s *ManualCommitStrategy) CommitMsg(commitMsgFile string) error {\\n   128→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n   129→\\tif err != nil {\\n   130→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   131→\\t}\\n   132→\\n   133→\\tmessage := string(content)\\n   134→\\n   135→\\t// Check if