rr)\\n   145→\\t\\t}\\n   146→\\t}\\n   147→\\n   148→\\t// Auto-create trail for non-main branches\\n   149→\\tautoCreateTrailOnTurnStart()\\n   150→\\n   151→\\treturn nil\\n   152→}\\n   153→\\n   154→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   155→// detects file changes, saves step + checkpoint, transitions phase.\\n   156→//\\n   157→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   158→func handleLifecycleTurnEnd(ag agent.Agent, event *agent.Event) error {\\n   159→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   160→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   161→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   162→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   163→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   164→\\t)\\n   165→\\n   166→\\tsessionID := event.SessionID\\n   167→\\tif sessionID == \\\"\\\" {\\n   168→\\t\\tsessionID = unknownSessionID\\n   169→\\t}\\n   170→\\n   171→\\ttranscriptRef := event.SessionRef\\n   172→\\tif transcriptRef == \\\"\\\" {\\n   173→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   174→\\t}\\n   175→\\tif !fileExists(transcriptRef) {\\n   176→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   177→\\t}\\n   178→\\n   179→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   180→\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n   181→\\t\\tfmt.Fprintln(os.Stderr, \\\"Entire: skipping checkpoint. Will activate after first commit.\\\")\\n   182→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   183→\\t}\\n   184→\\n   185→\\t// Create session metadata directory\\n   186→\\tsession