go-git/v5/plumbing\\\"\\n    12→\\t\\\"github.com/go-git/go-git/v5/plumbing/filemode\\\"\\n    13→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    14→\\t\\\"github.com/stretchr/testify/assert\\\"\\n    15→\\t\\\"github.com/stretchr/testify/require\\\"\\n    16→)\\n    17→\\n    18→// TestFilesOverlapWithContent_ModifiedFile tests that a modified file (exists in parent)\\n    19→// counts as overlap regardless of content changes.\\n    20→func TestFilesOverlapWithContent_ModifiedFile(t *testing.T) {\\n    21→\\tt.Parallel()\\n    22→\\tdir := setupGitRepo(t)\\n    23→\\n    24→\\trepo, err := git.PlainOpen(dir)\\n    25→\\trequire.NoError(t, err)\\n    26→\\n    27→\\t// Create initial file and commit\\n    28→\\ttestFile := filepath.Join(dir, \\\"test.txt\\\")\\n    29→\\trequire.NoError(t, os.WriteFile(testFile, []byte(\\\"original content\\\"), 0o644))\\n    30→\\twt, err := repo.Worktree()\\n    31→\\trequire.NoError(t, err)\\n    32→\\t_, err = wt.Add(\\\"test.txt\\\")\\n    33→\\trequire.NoError(t, err)\\n    34→\\t_, err = wt.Commit(\\\"Initial commit\\\", &git.CommitOptions{\\n    35→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n    36→\\t})\\n    37→\\trequire.NoError(t, err)\\n    38→\\n    39→\\t// Create shadow branch with same file content as session created\\n    40→\\tsessionContent := []byte(\\\"session modified content\\\")\\n    41→\\tcreateShadowBranchWithContent(t, repo, \\\"abc1234\\\", \\\"e3b0c4\\\", map[string][]byte{\\n    42→\\t\\t\\\"test.txt\\\": sessionContent,\\n    43→\\t})\\n    44→\\n    45→\\t// Modify the file with DIFFERENT content (user edited session's work)\\n    46→\\trequire.NoError(t, os.WriteFile(testFile, []byte(\\\"user modified further\\\"), 0o644))\\n    47→\\t_, err = wt.Add(\\\"test.txt\\\")\\n    48→\\trequire.NoError(t, err)\\n    49→\\theadCommit, err := wt.Commit(\\\"Modify file\\\", &git.CommitOptions{\\n    50→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n    51→\\t})\\n    52→\\trequire.NoError(t, err)\\n    53→\\n    54→\\t// Get HEAD commit\\n    55→\\tcommit, err := repo.CommitObject(headCommit)\\n    56→\\trequire.NoError(t, err)\\n    57→\\n    58→\\t// Test: Modified file should count as overlap even with different content\\n    59→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"abc1234\\\", \\\"e3b0c4\\\")\\n    60→\\tresult := filesOverlapWithContent(repo, shadowBranch, commit, []string{\\\"test.txt\\\"})\\n    61→\\tassert.True(t, result, \\\"Modified file should count as overlap (user edited session's work)\\\")\\n    62→}\\n    63→\\n    64→// TestFilesOverlapWithContent_NewFile_ContentMatch tests that a new file with\\n    65→// matching content counts as overlap.\\n    66→func TestFilesOverlapWithContent_NewFile_ContentMatch(t *testing.T) {\\n    67→\\tt.Parallel()\\n    68→\\tdir := setupGitRepo(t)\\n    69→\\n    70→\\trepo, err := git.PlainOpen(dir)\\n    71→\\trequire.NoError(t, err)\\n    72→\\n    73→\\t// Create shadow branch with a new file\\n    74→\\toriginalContent := []byte(\\\"session created this content\\\")\\n    75→\\tcreateShadowBranchWithContent(t, repo, \\\"def5678\\\", \\\"e3b0c4\\\", map[string][]byte{\\n    76→\\t\\t\\\"newfile.txt\\\": originalContent,\\n    77→\\t})\\n    78→\\n    79→\\t// Commit the same file with SAME content (user commits session's work unchanged)\\n    80→\\ttestFile := filepath.Join(dir, \\\"newfile.txt\\\")\\n    81→\\trequire.NoError(t, os.WriteFile(testFile, originalContent, 0o644))\\n    82→\\n    83→\\twt, err := repo.Worktree()\\n    84→\\trequire.NoError(t, err)\\n    85→\\t_, err = wt.Add(\\\"newfile.txt\\\")\\n    86→\\trequire.NoError(t, err)\\n    87→\\theadCommit, err := wt.Commit(\\\"Add new file\\\", &git.CommitOptions{\\n    88→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n    89→\\t})\\n    90→\\trequire.NoError(t, err)\\n    91→\\n    92→\\tcommit, err := repo.CommitObject(headCommit)\\n    93→\\trequire.NoError(t, err)\\n    94→\\n    95→\\t// Test: New file with matching content should count as overlap\\n    96→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"def5678\\\", \\\"e3b0c4\\\")\\n    97→\\tresult := filesOverlapWithContent(repo, shadowBranch, commit, []string{\\\"newfile.txt\\\"})\\n    98→\\tassert.True(t, result, \\\"New file with matching content should count as overlap\\\")\\n    99→}\\n   100→\\n   101→// TestFilesOverlapWithContent_NewFile_ContentMismatch tests that a new file with\\n   102→// completely different content does NOT count as overlap (reverted & replaced scenario).\\n   103→func TestFilesOverlapWithContent_NewFile_ContentMismatch(t *testing.T) {\\n   104→\\tt.Parallel()\\n   105→\\tdir := setupGitRepo(t)\\n   106→\\n   107→\\trepo, err := git.PlainOpen(dir)\\n   108→\\trequire.NoError(t, err)\\n   109→\\n   110→\\t// Create shadow branch with a file\\n   111→\\tsessionContent := []byte(\\\"session created this\\\")\\n   112→\\tcreateShadowBranchWithContent(t, repo, \\\"ghi9012\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   113→\\t\\t\\\"replaced.txt\\\": sessionContent,\\n   114→\\t})\\n   115→\\n   116→\\t// Commit a file with COMPLETELY DIFFERENT content (user reverted & replaced)\\n   117→\\ttestFile := filepath.Join(dir, \\\"replaced.txt\\\")\\n   118→\\trequire.NoError(t, os.WriteFile(testFile, []byte(\\\"user wrote something totally unrelated\\\"), 0o644))\\n   119→\\n   120→\\twt, err := repo.Worktree()\\n   121→\\trequire.NoError(t, err)\\n   122→\\t_, err = wt.Add(\\\"replaced.txt\\\")\\n   123→\\trequire.NoError(t, err)\\n   124→\\theadCommit, err := wt.Commit(\\\"Add replaced file\\\", &git.CommitOptions{\\n   125→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   126→\\t})\\n   127→\\trequire.NoError(t, err)\\n   128→\\n   129→\\tcommit, err := repo.CommitObject(headCommit)\\n   130→\\trequire.NoError(t, err)\\n   131→\\n   132→\\t// Test: New file with different content should NOT count as overlap\\n   133→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"ghi9012\\\", \\\"e3b0c4\\\")\\n   134→\\tresult := filesOverlapWithContent(repo, shadowBranch, commit, []string{\\\"replaced.txt\\\"})\\n   135→\\tassert.False(t, result, \\\"New file with different content should NOT count as overlap (reverted & replaced)\\\")\\n   136→}\\n   137→\\n   138→// TestFilesOverlapWithContent_FileNotInCommit tests that a file in filesTouched\\n   139→// but not in the commit doesn't count as overlap.\\n   140→func TestFilesOverlapWithContent_FileNotInCommit(t *testing.T) {\\n   141→\\tt.Parallel()\\n   142→\\tdir := setupGitRepo(t)\\n   143→\\n   144→\\trepo, err := git.PlainOpen(dir)\\n   145→\\trequire.NoError(t, err)\\n   146→\\n   147→\\t// Create shadow branch with files\\n   148→\\tfileAContent := []byte(\\\"file A content\\\")\\n   149→\\tfileBContent := []byte(\\\"file B content\\\")\\n   150→\\tcreateShadowBranchWithContent(t, repo, \\\"jkl3456\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   151→\\t\\t\\\"fileA.txt\\\": fileAContent,\\n   152→\\t\\t\\\"fileB.txt\\\": fileBContent,\\n   153→\\t})\\n   154→\\n   155→\\t// Only commit fileA (not fileB)\\n   156→\\tfileA := filepath.Join(dir, \\\"fileA.txt\\\")\\n   157→\\trequire.NoError(t, os.WriteFile(fileA, fileAContent, 0o644))\\n   158→\\n   159→\\twt, err := repo.Worktree()\\n   160→\\trequire.NoError(t, err)\\n   161→\\t_, err = wt.Add(\\\"fileA.txt\\\")\\n   162→\\trequire.NoError(t, err)\\n   163→\\theadCommit, err := wt.Commit(\\\"Add only file A\\\", &git.CommitOptions{\\n   164→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   165→\\t})\\n   166→\\trequire.NoError(t, err)\\n   167→\\n   168→\\tcommit, err := repo.CommitObject(headCommit)\\n   169→\\trequire.NoError(t, err)\\n   170→\\n   171→\\t// Test: Only fileB in filesTouched, which is not in commit\\n   172→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"jkl3456\\\", \\\"e3b0c4\\\")\\n   173→\\tresult := filesOverlapWithContent(repo, shadowBranch, commit, []string{\\\"fileB.txt\\\"})\\n   174→\\tassert.False(t, result, \\\"File not in commit should not count as overlap\\\")\\n   175→\\n   176→\\t// Test: fileA in filesTouched and in commit - should overlap (new file with matching content)\\n   177→\\tresult = filesOverlapWithContent(repo, shadowBranch, commit, []string{\\\"fileA.txt\\\"})\\n   178→\\tassert.True(t, result, \\\"File in commit with matching content should count as overlap\\\")\\n   179→}\\n   180→\\n   181→// TestFilesOverlapWithContent_DeletedFile tests that a deleted file\\n   182→// (existed in parent, not in HEAD) DOES count as overlap.\\n   183→// The agent's action of deleting the file is being committed.\\n   184→func TestFilesOverlapWithContent_DeletedFile(t *testing.T) {\\n   185→\\tt.Parallel()\\n   186→\\tdir := setupGitRepo(t)\\n   187→\\n   188→\\trepo, err := git.PlainOpen(dir)\\n   189→\\trequire.NoError(t, err)\\n   190→\\n   191→\\t// Create and commit a file that will be deleted\\n   192→\\ttoDelete := filepath.Join(dir, \\\"to_delete.txt\\\")\\n   193→\\trequire.NoError(t, os.WriteFile(toDelete, []byte(\\\"content to delete\\\"), 0o644))\\n   194→\\n   195→\\twt, err := repo.Worktree()\\n   196→\\trequire.NoError(t, err)\\n   197→\\t_, err = wt.Add(\\\"to_delete.txt\\\")\\n   198→\\trequire.NoError(t, err)\\n   199→\\t_, err = wt.Commit(\\\"Add file to delete\\\", &git.CommitOptions{\\n   200→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   201→\\t})\\n   202→\\trequire.NoError(t, err)\\n   203→\\n   204→\\t// Create shadow branch (simulating agent work that includes the deletion)\\n   205→\\tcreateShadowBranchWithContent(t, repo, \\\"del1234\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   206→\\t\\t\\\"other.txt\\\": []byte(\\\"other content\\\"),\\n   207→\\t})\\n   208→\\n   209→\\t// Delete the file and commit the deletion\\n   210→\\t_, err = wt.Remove(\\\"to_delete.txt\\\")\\n   211→\\trequire.NoError(t, err)\\n   212→\\tdeleteCommit, err := wt.Commit(\\\"Delete file\\\", &git.CommitOptions{\\n   213→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   214→\\t})\\n   215→\\trequire.NoError(t, err)\\n   216→\\n   217→\\tcommit, err := repo.CommitObject(deleteCommit)\\n   218→\\trequire.NoError(t, err)\\n   219→\\n   220→\\t// Test: deleted file in filesTouched should count as overlap\\n   221→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"del1234\\\", \\\"e3b0c4\\\")\\n   222→\\tresult := filesOverlapWithContent(repo, shadowBranch, commit, []string{\\\"to_delete.txt\\\"})\\n   223→\\tassert.True(t, result, \\\"Deleted file should count as overlap (agent's deletion being committed)\\\")\\n   224→}\\n   225→\\n   226→// TestFilesOverlapWithContent_NoShadowBranch tests fallback when shadow branch doesn't exist.\\n   227→func TestFilesOverlapWithContent_NoShadowBranch(t *testing.T) {\\n   228→\\tt.Parallel()\\n   229→\\tdir := setupGitRepo(t)\\n   230→\\n   231→\\trepo, err := git.PlainOpen(dir)\\n   232→\\trequire.NoError(t, err)\\n   233→\\n   234→\\t// Create a commit without any shadow branch\\n   235→\\ttestFile := filepath.Join(dir, \\\"test.txt\\\")\\n   236→\\trequire.NoError(t, os.WriteFile(testFile, []byte(\\\"content\\\"), 0o644))\\n   237→\\twt, err := repo.Worktree()\\n   238→\\trequire.NoError(t, err)\\n   239→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   240→\\trequire.NoError(t, err)\\n   241→\\theadCommit, err := wt.Commit(\\\"Test commit\\\", &git.CommitOptions{\\n   242→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   243→\\t})\\n   244→\\trequire.NoError(t, err)\\n   245→\\n   246→\\tcommit, err := repo.CommitObject(headCommit)\\n   247→\\trequire.NoError(t, err)\\n   248→\\n   249→\\t// Test: Non-existent shadow branch should fall back to assuming overlap\\n   250→\\tresult := filesOverlapWithContent(repo, \\\"entire/nonexistent-e3b0c4\\\", commit, []string{\\\"test.txt\\\"})\\n   251→\\tassert.True(t, result, \\\"Missing shadow branch should fall back to assuming overlap\\\")\\n   252→}\\n   253→\\n   254→// TestFilesWithRemainingAgentChanges_FileNotCommitted tests that files not in the commit\\n   255→// are kept in the remaining list.\\n   256→func TestFilesWithRemainingAgentChanges_FileNotCommitted(t *testing.T) {\\n   257→\\tt.Parallel()\\n   258→\\tdir := setupGitRepo(t)\\n   259→\\n   260→\\trepo, err := git.PlainOpen(dir)\\n   261→\\trequire.NoError(t, err)\\n   262→\\n   263→\\t// Create shadow branch with two files\\n   264→\\tcreateShadowBranchWithContent(t, repo, \\\"abc1234\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   265→\\t\\t\\\"fileA.txt\\\": []byte(\\\"content A\\\"),\\n   266→\\t\\t\\\"fileB.txt\\\": []byte(\\\"content B\\\"),\\n   267→\\t})\\n   268→\\n   269→\\t// Only commit fileA\\n   270→\\tfileA := filepath.Join(dir, \\\"fileA.txt\\\")\\n   271→\\trequire.NoError(t, os.WriteFile(fileA, []byte(\\\"content A\\\"), 0o644))\\n   272→\\twt, err := repo.Worktree()\\n   273→\\trequire.NoError(t, err)\\n   274→\\t_, err = wt.Add(\\\"fileA.txt\\\")\\n   275→\\trequire.NoError(t, err)\\n   276→\\theadCommit, err := wt.Commit(\\\"Add file A only\\\", &git.CommitOptions{\\n   277→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   278→\\t})\\n   279→\\trequire.NoError(t, err)\\n   280→\\n   281→\\tcommit, err := repo.CommitObject(headCommit)\\n   282→\\trequire.NoError(t, err)\\n   283→\\n   284→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"abc1234\\\", \\\"e3b0c4\\\")\\n   285→\\tcommittedFiles := map[string]struct{}{\\\"fileA.txt\\\": {}}\\n   286→\\n   287→\\t// fileB was not committed - should be in remaining\\n   288→\\tremaining := filesWithRemainingAgentChanges(repo, shadowBranch, commit, []string{\\\"fileA.txt\\\", \\\"fileB.txt\\\"}, committedFiles)\\n   289→\\tassert.Equal(t, []string{\\\"fileB.txt\\\"}, remaining, \\\"Uncommitted file should be in remaining\\\")\\n   290→}\\n   291→\\n   292→// TestFilesWithRemainingAgentChanges_FullyCommitted tests that files committed with\\n   293→// matching content are NOT in the remaining list.\\n   294→func TestFilesWithRemainingAgentChanges_FullyCommitted(t *testing.T) {\\n   295→\\tt.Parallel()\\n   296→\\tdir := setupGitRepo(t)\\n   297→\\n   298→\\trepo, err := git.PlainOpen(dir)\\n   299→\\trequire.NoError(t, err)\\n   300→\\n   301→\\tcontent := []byte(\\\"exact same content\\\")\\n   302→\\n   303→\\t// Create shadow branch with file\\n   304→\\tcreateShadowBranchWithContent(t, repo, \\\"def5678\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   305→\\t\\t\\\"test.txt\\\": content,\\n   306→\\t})\\n   307→\\n   308→\\t// Commit the file with SAME content\\n   309→\\ttestFile := filepath.Join(dir, \\\"test.txt\\\")\\n   310→\\trequire.NoError(t, os.WriteFile(testFile, content, 0o644))\\n   311→\\twt, err := repo.Worktree()\\n   312→\\trequire.NoError(t, err)\\n   313→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   314→\\trequire.NoError(t, err)\\n   315→\\theadCommit, err := wt.Commit(\\\"Add file with same content\\\", &git.CommitOptions{\\n   316→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   317→\\t})\\n   318→\\trequire.NoError(t, err)\\n   319→\\n   320→\\tcommit, err := repo.CommitObject(headCommit)\\n   321→\\trequire.NoError(t, err)\\n   322→\\n   323→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"def5678\\\", \\\"e3b0c4\\\")\\n   324→\\tcommittedFiles := map[string]struct{}{\\\"test.txt\\\": {}}\\n   325→\\n   326→\\t// File was fully committed - should NOT be in remaining\\n   327→\\tremaining := filesWithRemainingAgentChanges(repo, shadowBranch, commit, []string{\\\"test.txt\\\"}, committedFiles)\\n   328→\\tassert.Empty(t, remaining, \\\"Fully committed file should not be in remaining\\\")\\n   329→}\\n   330→\\n   331→// TestFilesWithRemainingAgentChanges_PartialCommit tests that files committed with\\n   332→// different content (partial commit via git add -p) ARE in the remaining list.\\n   333→func TestFilesWithRemainingAgentChanges_PartialCommit(t *testing.T) {\\n   334→\\tt.Parallel()\\n   335→\\tdir := setupGitRepo(t)\\n   336→\\n   337→\\trepo, err := git.PlainOpen(dir)\\n   338→\\trequire.NoError(t, err)\\n   339→\\n   340→\\t// Shadow branch has the full agent content\\n   341→\\tfullContent := []byte(\\\"line 1\\\\nline 2\\\\nline 3\\\\nline 4\\\\n\\\")\\n   342→\\tcreateShadowBranchWithContent(t, repo, \\\"ghi9012\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   343→\\t\\t\\\"test.txt\\\": fullContent,\\n   344→\\t})\\n   345→\\n   346→\\t// User commits only partial content (simulating git add -p)\\n   347→\\tpartialContent := []byte(\\\"line 1\\\\nline 2\\\\n\\\")\\n   348→\\ttestFile := filepath.Join(dir, \\\"test.txt\\\")\\n   349→\\trequire.NoError(t, os.WriteFile(testFile, partialContent, 0o644))\\n   350→\\twt, err := repo.Worktree()\\n   351→\\trequire.NoError(t, err)\\n   352→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   353→\\trequire.NoError(t, err)\\n   354→\\theadCommit, err := wt.Commit(\\\"Partial commit\\\", &git.CommitOptions{\\n   355→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   356→\\t})\\n   357→\\trequire.NoError(t, err)\\n   358→\\n   359→\\tcommit, err := repo.CommitObject(headCommit)\\n   360→\\trequire.NoError(t, err)\\n   361→\\n   362→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"ghi9012\\\", \\\"e3b0c4\\\")\\n   363→\\tcommittedFiles := map[string]struct{}{\\\"test.txt\\\": {}}\\n   364→\\n   365→\\t// Content doesn't match - file should be in remaining (has more agent changes)\\n   366→\\tremaining := filesWithRemainingAgentChanges(repo, shadowBranch, commit, []string{\\\"test.txt\\\"}, committedFiles)\\n   367→\\tassert.Equal(t, []string{\\\"test.txt\\\"}, remaining, \\\"Partially committed file should be in remaining\\\")\\n   368→}\\n   369→\\n   370→// TestFilesWithRemainingAgentChanges_NoShadowBranch tests fallback to file-level subtraction.\\n   371→func TestFilesWithRemainingAgentChanges_NoShadowBranch(t *testing.T) {\\n   372→\\tt.Parallel()\\n   373→\\tdir := setupGitRepo(t)\\n   374→\\n   375→\\trepo, err := git.PlainOpen(dir)\\n   376→\\trequire.NoError(t, err)\\n   377→\\n   378→\\t// Create a commit without any shadow branch\\n   379→\\ttestFile := filepath.Join(dir, \\\"test.txt\\\")\\n   380→\\trequire.NoError(t, os.WriteFile(testFile, []byte(\\\"content\\\"), 0o644))\\n   381→\\twt, err := repo.Worktree()\\n   382→\\trequire.NoError(t, err)\\n   383→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   384→\\trequire.NoError(t, err)\\n   385→\\theadCommit, err := wt.Commit(\\\"Test commit\\\", &git.CommitOptions{\\n   386→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n   387→\\t})\\n   388→\\trequire.NoError(t, err)\\n   389→\\n   390→\\tcommit, err := repo.CommitObject(headCommit)\\n   391→\\trequire.NoError(t, err)\\n   392→\\n   393→\\t// Non-existent shadow branch should fall back to file-level subtraction\\n   394→\\tcommittedFiles := map[string]struct{}{\\\"test.txt\\\": {}}\\n   395→\\tremaining := filesWithRemainingAgentChanges(repo, \\\"entire/nonexistent-e3b0c4\\\", commit, []string{\\\"test.txt\\\", \\\"other.txt\\\"}, committedFiles)\\n   396→\\n   397→\\t// With file-level subtraction: test.txt is in committedFiles, other.txt is not\\n   398→\\tassert.Equal(t, []string{\\\"other.txt\\\"}, remaining, \\\"Fallback should use file-level subtraction\\\")\\n   399→}\\n   400→\\n   401→// TestStagedFilesOverlapWithContent_ModifiedFile tests that a modified file\\n   402→// (exists in HEAD) always counts as overlap.\\n   403→func TestStagedFilesOverlapWithContent_ModifiedFile(t *testing.T) {\\n   404→\\tt.Parallel()\\n   405→\\tdir := setupGitRepo(t)\\n   406→\\n   407→\\trepo, err := git.PlainOpen(dir)\\n   408→\\trequire.NoError(t, err)\\n   409→\\n   410→\\t// Initial file is created by setupGitRepo\\n   411→\\t// Modify it and stage\\n   412→\\ttestFile := filepath.Join(dir, \\\"test.txt\\\")\\n   413→\\trequire.NoError(t, os.WriteFile(testFile, []byte(\\\"modified content\\\"), 0o644))\\n   414→\\twt, err := repo.Worktree()\\n   415→\\trequire.NoError(t, err)\\n   416→\\t_, err = wt.Add(\\\"test.txt\\\")\\n   417→\\trequire.NoError(t, err)\\n   418→\\n   419→\\t// Create shadow branch (content doesn't matter for modified files)\\n   420→\\tcreateShadowBranchWithContent(t, repo, \\\"abc1234\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   421→\\t\\t\\\"test.txt\\\": []byte(\\\"shadow content\\\"),\\n   422→\\t})\\n   423→\\n   424→\\t// Get shadow tree\\n   425→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"abc1234\\\", \\\"e3b0c4\\\")\\n   426→\\tshadowRef, err := repo.Reference(plumbing.NewBranchReferenceName(shadowBranch), true)\\n   427→\\trequire.NoError(t, err)\\n   428→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   429→\\trequire.NoError(t, err)\\n   430→\\tshadowTree, err := shadowCommit.Tree()\\n   431→\\trequire.NoError(t, err)\\n   432→\\n   433→\\t// Modified file should count as overlap regardless of content\\n   434→\\tresult := stagedFilesOverlapWithContent(repo, shadowTree, []string{\\\"test.txt\\\"}, []string{\\\"test.txt\\\"})\\n   435→\\tassert.True(t, result, \\\"Modified file should always count as overlap\\\")\\n   436→}\\n   437→\\n   438→// TestStagedFilesOverlapWithContent_NewFile_ContentMatch tests that a new file\\n   439→// with matching content counts as overlap.\\n   440→func TestStagedFilesOverlapWithContent_NewFile_ContentMatch(t *testing.T) {\\n   441→\\tt.Parallel()\\n   442→\\tdir := setupGitRepo(t)\\n   443→\\n   444→\\trepo, err := git.PlainOpen(dir)\\n   445→\\trequire.NoError(t, err)\\n   446→\\n   447→\\t// Create a NEW file (doesn't exist in HEAD)\\n   448→\\tcontent := []byte(\\\"new file content\\\")\\n   449→\\tnewFile := filepath.Join(dir, \\\"newfile.txt\\\")\\n   450→\\trequire.NoError(t, os.WriteFile(newFile, content, 0o644))\\n   451→\\twt, err := repo.Worktree()\\n   452→\\trequire.NoError(t, err)\\n   453→\\t_, err = wt.Add(\\\"newfile.txt\\\")\\n   454→\\trequire.NoError(t, err)\\n   455→\\n   456→\\t// Create shadow branch with SAME content\\n   457→\\tcreateShadowBranchWithContent(t, repo, \\\"def5678\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   458→\\t\\t\\\"newfile.txt\\\": content,\\n   459→\\t})\\n   460→\\n   461→\\t// Get shadow tree\\n   462→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"def5678\\\", \\\"e3b0c4\\\")\\n   463→\\tshadowRef, err := repo.Reference(plumbing.NewBranchReferenceName(shadowBranch), true)\\n   464→\\trequire.NoError(t, err)\\n   465→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   466→\\trequire.NoError(t, err)\\n   467→\\tshadowTree, err := shadowCommit.Tree()\\n   468→\\trequire.NoError(t, err)\\n   469→\\n   470→\\t// New file with matching content should count as overlap\\n   471→\\tresult := stagedFilesOverlapWithContent(repo, shadowTree, []string{\\\"newfile.txt\\\"}, []string{\\\"newfile.txt\\\"})\\n   472→\\tassert.True(t, result, \\\"New file with matching content should count as overlap\\\")\\n   473→}\\n   474→\\n   475→// TestStagedFilesOverlapWithContent_NewFile_ContentMismatch tests that a new file\\n   476→// with different content does NOT count as overlap (reverted & replaced scenario).\\n   477→func TestStagedFilesOverlapWithContent_NewFile_ContentMismatch(t *testing.T) {\\n   478→\\tt.Parallel()\\n   479→\\tdir := setupGitRepo(t)\\n   480→\\n   481→\\trepo, err := git.PlainOpen(dir)\\n   482→\\trequire.NoError(t, err)\\n   483→\\n   484→\\t// Create a NEW file with different content than shadow branch\\n   485→\\tnewFile := filepath.Join(dir, \\\"newfile.txt\\\")\\n   486→\\trequire.NoError(t, os.WriteFile(newFile, []byte(\\\"user replaced content\\\"), 0o644))\\n   487→\\twt, err := repo.Worktree()\\n   488→\\trequire.NoError(t, err)\\n   489→\\t_, err = wt.Add(\\\"newfile.txt\\\")\\n   490→\\trequire.NoError(t, err)\\n   491→\\n   492→\\t// Create shadow branch with DIFFERENT content (agent's original)\\n   493→\\tcreateShadowBranchWithContent(t, repo, \\\"ghi9012\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   494→\\t\\t\\\"newfile.txt\\\": []byte(\\\"agent original content\\\"),\\n   495→\\t})\\n   496→\\n   497→\\t// Get shadow tree\\n   498→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"ghi9012\\\", \\\"e3b0c4\\\")\\n   499→\\tshadowRef, err := repo.Reference(plumbing.NewBranchReferenceName(shadowBranch), true)\\n   500→\\trequire.NoError(t, err)\\n   501→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   502→\\trequire.NoError(t, err)\\n   503→\\tshadowTree, err := shadowCommit.Tree()\\n   504→\\trequire.NoError(t, err)\\n   505→\\n   506→\\t// New file with different content should NOT count as overlap\\n   507→\\tresult := stagedFilesOverlapWithContent(repo, shadowTree, []string{\\\"newfile.txt\\\"}, []string{\\\"newfile.txt\\\"})\\n   508→\\tassert.False(t, result, \\\"New file with mismatched content should not count as overlap\\\")\\n   509→}\\n   510→\\n   511→// TestStagedFilesOverlapWithContent_NoOverlap tests that non-overlapping files\\n   512→// return false.\\n   513→func TestStagedFilesOverlapWithContent_NoOverlap(t *testing.T) {\\n   514→\\tt.Parallel()\\n   515→\\tdir := setupGitRepo(t)\\n   516→\\n   517→\\trepo, err := git.PlainOpen(dir)\\n   518→\\trequire.NoError(t, err)\\n   519→\\n   520→\\t// Stage a file NOT in filesTouched\\n   521→\\totherFile := filepath.Join(dir, \\\"other.txt\\\")\\n   522→\\trequire.NoError(t, os.WriteFile(otherFile, []byte(\\\"other content\\\"), 0o644))\\n   523→\\twt, err := repo.Worktree()\\n   524→\\trequire.NoError(t, err)\\n   525→\\t_, err = wt.Add(\\\"other.txt\\\")\\n   526→\\trequire.NoError(t, err)\\n   527→\\n   528→\\t// Create shadow branch\\n   529→\\tcreateShadowBranchWithContent(t, repo, \\\"jkl3456\\\", \\\"e3b0c4\\\", map[string][]byte{\\n   530→\\t\\t\\\"session.txt\\\": []byte(\\\"session content\\\"),\\n   531→\\t})\\n   532→\\n   533→\\t// Get shadow tree\\n   534→\\tshadowBranch := checkpoint.ShadowBranchNameForCommit(\\\"jkl3456\\\", \\\"e3b0c4\\\")\\n   535→\\tshadowRef, err := repo.Reference(plumbing.NewBranchReferenceName(shadowBranch), true)\\n   536→\\trequire.NoError(t, err)\\n   537→\\tshadowCommit, err := repo.CommitObject(shadowRef.Hash())\\n   538→\\trequire.NoError(t, err)\\n   539→\\tshadowTree, err := shadowCommit.Tree()\\n   540→\\trequire.NoError(t, err)\\n   541→\\n   542→\\t// Staged file \\\"other.txt\\\" is not in filesTouched \\\"session.txt\\\"\\n   543→\\tresult := stagedFilesOverlapWithContent(repo, shadowTree, []string{\\\"other.txt\\\"}, []string{\\\"session.txt\\\"})\\n   544→\\tassert.False(t, result, \\\"Non-overlapping files should return false\\\")\\n   545→}\\n   546→\\n   547→// TestStagedFilesOverlapWithContent_DeletedFile tests that a deleted file\\n   548→// (exists in HEAD but staged for deletion) DOES count as overlap.\\n   549→// The agent's action of deleting the file is being committed, so the session\\n   550→// context should be linked to this commit.\\n   551→func TestStagedFilesOverlapWithContent_DeletedFile(t *testing.T) {\\n   552→\\tt.Parallel()\\n   553→\\n   554→\\tdir := t.TempDir()\\n   555→\\trepo, err := git.PlainInit(dir, false)\\n   556→\\trequire.NoError(t, err)\\n   557→\\n   558→\\tworktree, err := repo.Worktree()\\n   559→\\trequire.NoError(t, err)\\n   560→\\n   561→\\t// Create and commit a file that will be deleted\\n   562→\\tfilePath := filepath.Join(dir, \\\"to_delete.txt\\\")\\n   563→\\terr = os.WriteFile(filePath, []byte(