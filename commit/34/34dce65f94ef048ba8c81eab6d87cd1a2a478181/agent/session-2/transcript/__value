ults to \\\"info\\\".\\n    44→\\tLogLevel string `json:\\\"log_level,omitempty\\\"`\\n    45→\\n    46→\\t// StrategyOptions contains strategy-specific configuration\\n    47→\\tStrategyOptions map[string]any `json:\\\"strategy_options,omitempty\\\"`\\n    48→\\n    49→\\t// Telemetry controls anonymous usage analytics.\\n    50→\\t// nil = not asked yet (show prompt), true = opted in, false = opted out\\n    51→\\tTelemetry *bool `json:\\\"telemetry,omitempty\\\"`\\n    52→}\\n    53→\\n    54→// Load loads the Entire settings from .entire/settings.json,\\n    55→// then applies any overrides from .entire/settings.local.json if it exists.\\n    56→// Returns default settings if neither file exists.\\n    57→// Works correctly from any subdirectory within the repository.\\n    58→func Load() (*EntireSettings, error) {\\n    59→\\t// Get absolute paths for settings files\\n    60→\\tsettingsFileAbs, err := paths.AbsPath(EntireSettingsFile)\\n    61→\\tif err != nil {\\n    62→\\t\\tsettingsFileAbs = EntireSettingsFile // Fallback to relative\\n    63→\\t}\\n    64→\\tlocalSettingsFileAbs, err := paths.AbsPath(EntireSettingsLocalFile)\\n    65→\\tif err != nil {\\n    66→\\t\\tlocalSettingsFileAbs = EntireSettingsLocalFile // Fallback to relative\\n    67→\\t}\\n    68→\\n    69→\\t// Load base settings\\n    70→\\tsettings, err := loadFromFile(settingsFileAbs)\\n    71→\\tif err != nil {\\n    72→\\t\\treturn nil, fmt.Errorf(\\\"reading settings file: %w\\\", err)\\n    73→\\t}\\n    74→\\n    75→\\t// Apply local overrides if they exist\\n    76→\\tlocalData, err := os.ReadFile(localSettingsFileAbs) //nolint:gosec // path is from AbsPath or constant\\n    77→\\tif err != nil {\\n    78→\\t\\tif !os.IsNotExist(err) {\\n    79→\\t\\t\\treturn nil, fmt.Errorf(\\\"reading local settings file: %w\\\", err)\\n    80→\\t\\t}\\n    81→\\t\\t// Local file doesn't exist, continue without overrides\\n    82→\\t} else {\\n    83→\\t\\tif err := mergeJSON(settings, localData); err != nil {\\n    84→\\t\\t\\treturn nil, fmt.Errorf(\\\"merging local settings: %w\\\", err)\\n    85→\\t\\t}\\n    86→\\t}\\n    87→\\n    88→\\tapplyDefaults(settings)\\n    89→\\n    90→\\treturn settings, nil\\n    91→}\\n    92→\\n    93→// LoadFromFile loads settings from a specific file path without merging local overrides.\\n    94→// Returns default settings if the file doesn't exist.\\n    95→// Use this when you need to display individual settings files separately.\\n    96→func LoadFromFile(filePath string) (*EntireSettings, error) {\\n    97→\\treturn loadFromFile(filePath)\\n    98→}\\n    99→\\n   100→// loadFromFile loads settings from a specific file path.\\n   101→// Returns default settings if the file doesn't exist.\\n   102→func loadFromFile(filePath string) (*EntireSettings, error) {\\n   103→\\tsettings := &EntireSettings{\\n   104→\\t\\tStrategy: DefaultStrategyName,\\n   105→\\t\\tEnabled:  true, // Default to enabled\\n   106→\\t}\\n   107→\\n   108→\\tdata, err := os.ReadFile(filePath) //nolint:gosec // path is from caller\\n   109→\\tif err != nil {\\n   110→\\t\\tif os.IsNotExist(err) {\\n   111→\\t\\t\\treturn settings, nil\\n   112→\\t\\t}\\n   113→\\t\\treturn nil, fmt.Errorf(\\\"%w\\\", err)\\n   114→\\t}\\n   115→\\n   116→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   117→\\tdec.DisallowUnknownFields()\\n   118→\\tif err := dec.Decode(settings); err != nil {\\n   119→\\t\\treturn nil, fmt.Errorf(\\\"parsing settings file: %w\\\", err)\\n   120→\\t}\\n   121→\\tapplyDefaults(settings)\\n   122→\\n   123→\\treturn settings, nil\\n   124→}\\n   125→\\n   126→// mergeJSON merges JSON data into existing settings.\\n   127→// Only non-zero values from the JSON override existing settings.\\n   128→func mergeJSON(settings *EntireSettings, data []byte) error {\\n   129→\\t// First, validate that there are no unknown keys using strict decoding\\n   130→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   131→\\tdec.DisallowUnknownF