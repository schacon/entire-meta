err != nil {\\n   733→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: post-commit action handler error: %v\\\\n\\\", err)\\n   734→\\t\\t}\\n   735→\\n   736→\\t\\t// Record checkpoint ID for ACTIVE sessions so HandleTurnEnd can finalize\\n   737→\\t\\t// with full transcript. IDLE/ENDED sessions already have complete transcripts.\\n   738→\\t\\t// NOTE: This check runs AFTER TransitionAndLog updated the phase. It relies on\\n   739→\\t\\t// ACTIVE + GitCommit → ACTIVE (phase stays ACTIVE). If that state machine\\n   740→\\t\\t// transition ever changed, this guard would silently stop recording IDs.\\n   741→\\t\\tif handler.condensed && state.Phase.IsActive() {\\n   742→\\t\\t\\tstate.TurnCheckpointIDs = append(state.TurnCheckpointIDs, checkpointID.String())\\n   743→\\t\\t}\\n   744→\\n   745→\\t\\t// Carry forward remaining uncommitted files so the next commit gets its\\n   746→\\t\\t// own checkpoint ID. This applies to ALL phases — if a user splits their\\n   747→\\t\\t// commit across two `git commit` invocations, each gets a 1:1 checkpoint.\\n   748→\\t\\t// Uses content-aware comparison: if user did `git add -p` and committed\\n   749→\\t\\t// partial changes, the file still has remaining agent changes to carry forward.\\n   750→\\t\\tif handler.condensed {\\n   751→\\t\\t\\tremainingFiles := filesWithRemainingAgentChanges(repo, shadowBranchName, commit, filesTouchedBefore, committedFileSet)\\n   752→\\t\\t\\tstate.FilesTouched = remainingFiles\\n   753→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward decision (content-aware)\\\",\\n   754→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   755→\\t\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   756→\\t\\t\\t\\tslog.Int(\\\"committed_files\\\", len(committedFileSet)),\\n   757→\\t\\t\\t\\tslog.Int(\\\"remaining_files\\\", len(remainingFiles)),\\n   758→\\t\\t\\t\\tslog.Any(\\\"remaining\\\", remainingFiles),\\n   759→\\t\\t\\t\\tslog.Any(\\\"committed_files\\\", committedFileSet),\\n   760→\\t\\t\\t)\\n   761→\\t\\t\\tif len(remainingFiles) > 0 {\\n   762→\\t\\t\\t\\ts.carryForwardToNewShadowBranch(logCtx, repo, state, remainingFiles)\\n   763→\\t\\t\\t}\\n   764→\\t\\t}\\n   765→\\n   766→\\t\\t// Save the updated state\\n   767→\\t\\tif err := s.saveSessionState(state); err != nil {\\n   768→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to update session state: %v\\\\n\\\", err)\\n   769→\\t\\t}\\n   770→\\n   771→\\t\\t// Only preserve shadow branch for active sessions that were NOT condensed.\\n   772→\\t\\t// Condensed sessions already have their data on entire/checkpoints/v1.\\n   773→\\t\\tif state.Phase.IsActive() && !handler.condensed {\\n   774→\\t\\t\\tuncondensedActiveOnBranch[shadowBranchName] = true\\n   775→\\t\\t}\\n   776→\\t}\\n   777→\\n   778→\\t// Clean up shadow branches — only delete when ALL sessions on the branch are non-active\\n   779→\\t// or were condensed during this PostCommit.\\n   780→\\tfor shadowBranchName := range shadowBranchesToDelete {\\n   781→\\t\\tif uncondensedActiveOnBranch[shadowBranchName] {\\n   782→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: preserving shadow branch (active session exists)\\\",\\n   783→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   784→\\t\\t\\t)\\n   785→\\t\\t\\tcontinue\\n   786→\\t\\t}\\n   787→\\t\\tif err := deleteShadowBranch(repo, shadowBranchName); err != nil {\\n   788→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to clean up %s: %v\\\\n\\\", shadowBranchName, err)\\n   789→\\t\\t} else {\\n   790→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Cleaned up shadow branch: %s\\\\n\\\", shadowBranchName)\\n   791→\\t\\t\\tlogging.Info(logCtx, \\\"shadow branch deleted\\\",\\n   792→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   793→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   794→\\t\\t\\t)\\n   795→\\t\\t}\\n   796→\\t}\\n   797→\\n   798→\\treturn nil\\n   799→}\\n   800→\\n   801→// condenseAndUpdateState runs condensation for a session and updates state afterward.\\n   802→// Returns true if condensation succeeded.\\n   803→func (s *ManualCommitStrategy) condenseAndUpdateState(\\n   804→\\tlogCtx context.Context,\\n   805→\\trepo *git.Repository,\\n   806→\\tcheckpointID id.CheckpointID,\\n   807→\\tstate *SessionState,\\n   808→\\thead *plumbing.Reference,\\n   809→\\tshadowBranchName string,\\n   810→\\tshadowBranchesToDelete map[string]struct{},\\n   811→\\tcommittedFiles map[string]struct{},\\n   812→) bool {\\n   813→\\tresult, err := s.CondenseSession(repo, checkpointID, state, committedFiles)\\n   814→\\tif err != nil {\\n   815→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: condensation failed for session %s: %v\\\\n\\\",\\n   816→\\t\\t\\tstate.SessionID, err)\\n   817→\\t\\tlogging.Warn(logCtx, \\\"post-commit: condensation failed\\\",\\n   818→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   819→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   820→\\t\\t)\\n   821→\\t\\treturn false\\n   822→\\t}\\n   823→\\n   824→\\t// Link checkpoint to trail (best-effort)\\n   825→\\tappendCheckpointToTrail(repo, result.CheckpointID, head.Hash(), result.Prompts)\\n   826→\\n   827→\\t// Track this shadow branch for cleanup\\n   828→\\tshadowBranchesToDelete[shadowBranchName] = struct{}{}\\n   829→\\n   830→\\t// Update session state for the new base commit\\n   831→\\tnewHead := head.Hash().String()\\n   832→\\tstate.BaseCommit = newHead\\n   833→\\tstate.AttributionBaseCommit = newHead\\n   834→\\tstate.StepCount = 0\\n   835→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   836→\\n   837→\\t// Clear attribution tracking — condensation already used these values\\n   838→\\tstate.PromptAttributions = nil\\n   839→\\tstate.PendingPromptAttribution = nil\\n   840→\\tstate.FilesTouched = nil\\n   841→\\n   842→\\t// Save checkpoint ID so subsequent commits can reuse it (e.g., amend restores trailer)\\n   843→\\tstate.LastCheckpointID = checkpointID\\n   844→\\n   845→\\tshortID := state.SessionID\\n   846→\\tif len(shortID) > 8 {\\n   847→\\t\\tshortID = shortID[:8]\\n   848→\\t}\\n   849→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Condensed session %s: %s (%d checkpoints)\\\\n\\\",\\n   850→\\t\\tshortID, result.CheckpointID, result.CheckpointsCount)\\n   851→\\n   852→\\tlogging.Info(logCtx, \\\"session condensed\\\",\\n   853→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   854→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   855→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   856→\\t\\tslog.Int(\\\"transcript_lines\\\", result.TotalTranscriptLines),\\n   857→\\t)\\n   858→\\n   859→\\treturn true\\n   860→}\\n   861→\\n   862→// updateBaseCommitIfChanged updates BaseCommit to newHead if it changed.\\n   863→// Only updates ACTIVE sessions. IDLE/ENDED sessions should NOT have their\\n   864→// BaseCommit updated, as this would cause them to be incorrectly associated\\n   865→// with a new shadow branch and potentially condensed on future commits.\\n   866→func (s *ManualCommitStrategy) updateBaseCommitIfChanged(logCtx context.Context, state *SessionState, newHead string) {\\n   867→\\t// Only update ACTIVE sessions. IDLE/ENDED sessions are kept around for\\n   868→\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n   869→\\tif !state.Phase.IsActive() {\\n   870→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updateBaseCommitIfChanged skipped non-active session\\\",\\n   871→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   872→\\t\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   873→\\t\\t)\\n   874→\\t\\treturn\\n   875→\\t}\\n   876→\\tif state.BaseCommit != newHead {\\n   877→\\t\\tstate.BaseCommit = newHead\\n   878→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updated BaseCommit\\\",\\n   879→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   880→\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n   881→\\t\\t)\\n   882→\\t}\\n   883→}\\n   884→\\n   885→// postCommitUpdateBaseCommitOnly updates BaseCommit for all sessions on the current\\n   886→// worktree when a commit has no Entire-Checkpoint trailer. This prevents BaseCommit\\n   887→// from going stale, which would cause future PrepareCommitMsg calls to skip the\\n   888→// session (BaseCommit != currentHeadHash filter).\\n   889→//\\n   890→// Unlike the full PostCommit flow, this does NOT fire EventGitCommit or trigger\\n   891→// condensation — it only keeps BaseCommit in sync with HEAD.\\n   892→func (s *ManualCommitStrategy) postCommitUpdateBaseCommitOnly(logCtx context.Context, head *plumbing.Reference) {\\n   893→\\tworktreePath, err := GetWorktreePath()\\n   894→\\tif err != nil {\\n   895→\\t\\treturn // Silent failure — hooks must be resilient\\n   896→\\t}\\n   897→\\n   898→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   899→\\tif err != nil || len(sessions) == 0 {\\n   900→\\t\\treturn\\n   901→\\t}\\n   902→\\n   903→\\tnewHead := head.Hash().String()\\n   904→\\tfor _, state := range sessions {\\n   905→\\t\\t// Only update active sessions. Idle/ended sessions are kept around for\\n   906→\\t\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n   907→\\t\\tif !state.Phase.IsActive() {\\n   908→\\t\\t\\tcontinue\\n   909→\\t\\t}\\n   910→\\t\\tif state.BaseCommit != newHead {\\n   911→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit (no trailer): updating BaseCommit\\\",\\n   912→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   913→\\t\\t\\t\\tslog.String(\\\"old_base\\\", truncateHash(state.BaseCommit)),\\n   914→\\t\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n   915→\\t\\t\\t)\\n   916→\\t\\t\\tstate.BaseCommit = newHead\\n   917→\\t\\t\\tif err := s.saveSessionState(state); err != nil {\\n   918→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to update session state: %v\\\\n\\\", err)\\n   919→\\t\\t\\t}\\n   920→\\t\\t}\\n   921→\\t}\\n   922→}\\n   923→\\n   924→// truncateHash safely truncates a git hash to 7 chars for logging.\\n   925→func truncateHash(h string) string {\\n   926→\\tif len(h) > 7 {\\n   927→\\t\\treturn h[:7]\\n   928→\\t}\\n   929→\\treturn h\\n   930→}\\n   931→\\n   932→// filterSessionsWithNewContent returns sessions that have new transcript content\\n   933→// beyond what was already condensed.\\n   934→func (s *ManualCommitStrategy) filterSessionsWithNewContent(repo *git.Repository, sessions []*SessionState) []*SessionState {\\n   935→\\tvar result []*SessionState\\n   936→\\n   937→\\tfor _, state := range sessions {\\n   938→\\t\\thasNew, err := s.sessionHasNewContent(repo, state)\\n   939→\\t\\tif err != nil {\\n   940→\\t\\t\\t// On error, include the session (fail open for hooks)\\n   941→\\t\\t\\tresult = append(result, state)\\n   942→\\t\\t\\tcontinue\\n   943→\\t\\t}\\n   944→\\t\\tif hasNew {\\n   945→\\t\\t\\tresult = append(result, state)\\n   946→\\t\\t}\\n   947→\\t}\\n   948→\\n   949→\\treturn result\\n   950→}\\n   951→\\n   952→// sessionHasNewContent checks if a session has new transcript content\\n   953→// beyond what was already condensed.\\n   954→func (s *ManualCommitStrategy) sessionHasNewContent(repo *git.Repository, state *SessionState) (bool, error) {\\n   955→\\tlogCtx := logging.WithComponent(context.Background(), \\\"manual-commit\\\")\\n   956→\\n   957→\\t// Get shadow branch\\n   958→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   959→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   960→\\tref, err := repo.Reference(refName, true)\\n   961→\\tif err != nil {\\n   962→\\t\\t// No shadow branch means no Stop has happened since the last condensation.\\n   963→\\t\\t// However, the agent may have done work (including comm