eckpoint\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    16→)\\n    17→\\n    18→// GenerateFromTranscript generates a summary from raw transcript bytes.\\n    19→// This is the shared implementation used by both explain --generate and auto-summarize.\\n    20→//\\n    21→// Parameters:\\n    22→//   - ctx: context for cancellation\\n    23→//   - transcriptBytes: raw transcript bytes (JSONL or JSON format depending on agent)\\n    24→//   - filesTouched: list of files modified during the session\\n    25→//   - agentType: the agent type to determine transcript format\\n    26→//   - generator: summary generator to use (if nil, uses default ClaudeGenerator)\\n    27→//\\n    28→// Returns nil, error if transcript is empty or cannot be parsed.\\n    29→func GenerateFromTranscript(ctx context.Context, transcriptBytes []byte, filesTouched []string, agentType agent.AgentType, generator Generator) (*checkpoint.Summary, error) {\\n    30→\\tif len(transcriptBytes) == 0 {\\n    31→\\t\\treturn nil, errors.New(\\\"empty transcript\\\")\\n    32→\\t}\\n    33→\\n    34→\\t// Build condensed transcript for summarization\\n    35→\\tcondensed, err := BuildCondensedTranscriptFromBytes(transcriptBytes, agentType)\\n    36→\\tif err != nil {\\n    37→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    38→\\t}\\n    39→\\tif len(condensed) == 0 {\\n    40→\\t\\treturn nil, errors.New(\\\"transcript has no content to summarize\\\")\\n    41→\\t}\\n    42→\\n    43→\\tinput := Input{\\n    44→\\t\\tTranscript:   condensed,\\n    45→\\t\\tFilesTouched: filesTouched,\\n    46→\\t}\\n    47→\\n    48→\\t// Use default generator if none provided\\n    49→\\tif generator == nil {\\n    50→\\t\\tgenerator = &ClaudeGenerator{}\\n    51→\\t}\\n    52→\\n    53→\\tsummary, err := generator.Generate(ctx, input)\\n    54→\\tif err != nil {\\n    55→\\t\\treturn nil, fmt.Errorf(\\\"failed to generate summary: %w\\\", err)\\n    56→\\t}\\n    57→\\n    58→\\treturn summary, nil\\n    59→}\\n    60→\\n    61→// Generator generates checkpoint summaries using an LLM.\\n    62→type Generator interface {\\n    63→\\t// Generate creates a summary from checkpoint data.\\n    64→\\t// Returns the generated summary or an error if generation fails.\\n    65→\\tGenerate(ctx context.Context, input Input) (*checkpoint.Summary, error)\\n    66→}\\n    67→\\n    68→// Input contains condensed checkpoint data for summarization.\\n    69→type Input struct {\\n    70→\\t// Transcript is the condensed transcript entries\\n    71→\\tTranscript []Entry\\n    72→\\n    73→\\t// FilesTouched are the files modified during the session\\n    74→\\tFilesTouched []string\\n    75→}\\n    76→\\n    77→// EntryType represents the type of a transcript entry.\\n    78→type EntryType string\\n    79→\\n    80→const (\\n    81→\\t// EntryTypeUser indicates a user prompt entry.\\n    82→\\tEntryTypeUser EntryType = \\\"user\\\"\\n    83→\\t// EntryTypeAssistant indicates an assistant response entry.\\n    84→\\tEntryTypeAssistant EntryType = \\\"assistant\\\"\\n    85→\\t// EntryTypeTool indicates a tool call entry.\\n    86→\\tEntryTypeTool EntryType = \\\"tool\\\"\\n    87→)\\n    88→\\n    89→// Entry represents one item in the condensed transcript.\\n    90→type Entry struct {\\n    91→\\t// Type is the entry type (user, assistant, tool)\\n    92→\\tType EntryType\\n    93→\\n    94→\\t// Content is the text content for user/assistant entries\\n    95→\\tContent string\\n    96→\\n    97→\\t// ToolName is the name of the tool (for tool entries)\\n    98→\\tToolName string\\n    99→\\n   100→\\t// ToolDetail is a description or file path (for tool entries)\\n   101→\\tToolDetail string\\n   102→}\\n   103→\\n   104→// minimalDetailTools lists tools that should show only essential details in summaries.\\n   105→// These tools often have verbose outputs that don't add value to summarization.\\n   106→// The detail shown is typically just a path, URL, or identifier rather than full content.\\n   107→var minimalDetailTools = map[string]bool{\\n   108→\\t\\\"Skill\\\":    true, // Show skill name only, not loaded content\\n   109→\\t\\\"Read\\\":     true, // Show file path only, not file contents\\n   110→\\t\\\"WebFetch\\\": true, // Show URL only, not fetched content\\n   111→}\\n   112→\\n   113→// BuildCondensedTranscriptFromBytes parses transcript bytes and extracts a condensed view.\\n   114→// This is a convenience function that combines parsing and condensing.\\n   115→// The agentType parameter determines which parser to use (Claude/OpenCode JSONL vs Gemini JSON).\\n   116→func BuildCondensedTranscriptFromBytes(content []byte, agentType agent.AgentType) ([]Entry, error) {\\n   117→\\tswitch agentType {\\n   118→\\tcase agent.AgentTypeGemini:\\n   119→\\t\\treturn buildCondensedTranscriptFromGemini(content)\\n   120→\\tcase agent.AgentTypeOpenCode:\\n   121→\\t\\treturn buildCondensedTranscriptFromOpenCode(content)\\n   122→\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeUnknown:\\n   123→\\t\\t// Claude format - fall through to shared logic below\\n   124→\\t}\\n   125→\\t// Claude format (JSONL) - handles Claude Code, Unknown, and any future agent types\\n   126→\\tlines, err := transcript.ParseFromBytes(content)\\n   127→\\tif err != nil {\\n   128→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   129→\\t}\\n   130→\\treturn BuildCondensedTranscript(lines), nil\\n   131→}\\n   132→\\n   133→// buildCondensedTranscriptFromGemini parses Gemini JSON transcript and extracts a condensed view.\\n   134→func buildCondensedTranscriptFromGemini(content []byte) ([]Entry, error) {\\n   135→\\tgeminiTranscript, err := geminicli.ParseTranscript(content)\\n   136→\\tif err != nil {\\n   137→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse Gemini transcript: %w\\\", err)\\n   138→\\t}\\n   139→\\n   140→\\tvar entries []Entry\\n   141→\\tfor _, msg := range geminiTranscript.Messages {\\n   142→\\t\\tswitch msg.Type {\\n   143→\\t\\tcase geminicli.MessageTypeUser:\\n   144→\\t\\t\\tif msg.Content != \\\"\\\" {\\n   145→\\t\\t\\t\\tentries = append(entries, Entry{\\n   146→\\t\\t\\t\\t\\tType:    EntryTypeUser,\\n   147→\\t\\t\\t\\t\\tContent: msg.Content,\\n   148→\\t\\t\\t\\t})\\n   149→\\t\\t\\t}\\n   150→\\t\\tcase geminicli.MessageTypeGemini:\\n   151→\\t\\t\\t// Add assistant content\\n   152→\\t\\t\\tif msg.Content != \\\"\\\" {\\n   153→\\t\\t\\t\\tentries = append(entries, Entry{\\n   154→\\t\\t\\t\\t\\tType:    EntryTypeAssistant,\\n   155→\\t\\t\\t\\t\\tContent: msg.Content,\\n   156→\\t\\t\\t\\t})\\n   157→\\t\\t\\t}\\n   158→\\t\\t\\t// Add tool calls\\n   159→\\t\\t\\tfor _, tc := range msg.ToolCalls {\\n   160→\\t\\t\\t\\tentries = append(entries, Entry{\\n   161→\\t\\t\\t\\t\\tType:       EntryTypeTool,\\n   162→\\t\\t\\t\\t\\tToolName:   tc.Name,\\n   163→\\t\\t\\t\\t\\tToolDetail: extractGenericToolDetail(tc.Args),\\n   164→\\t\\t\\t\\t})\\n   165→\\t\\t\\t}\\n   166→\\t\\t}\\n   167→\\t}\\n   168→\\n   169→\\treturn entries, nil\\n   170→}\\n   171→\\n   172→// buildCondensedTranscriptFromOpenCode parses OpenCode JSONL transcript and extracts a condensed view.\\n   173→func buildCondensedTranscriptFromOpenCode(content []byte) ([]Entry, error) {\\n   174→\\tmessages, err := opencode.ParseMessages(content)\\n   175→\\tif err != nil {\\n   176→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse OpenCode transcript: %w\\\", err)\\n   177→\\t}\\n   178→\\n   179→\\tvar entries []Entry\\n   180→\\tfor _, msg := range messages {\\n   181→\\t\\tswitch msg.Role {\\n   182→\\t\\tcase \\\"user\\\":\\n   183→\\t\\t\\tif msg.Content != \\\"\\\" {\\n   184→\\t\\t\\t\\tentries = append(entries, Entry{\\n   185→\\t\\t\\t\\t\\tType:    EntryTypeUser,\\n   186→\\t\\t\\t\\t\\tContent: msg.Content,\\n   187→\\t\\t\\t\\t})\\n   188→\\t\\t\\t}\\n   189→\\t\\tcase \\\"assistant\\\":\\n   190→\\t\\t\\tif msg.Content != \\\"\\\" {\\n   191→\\t\\t\\t\\tentries = append(entries, Entry{\\n   192→\\t\\t\\t\\t\\tType:    EntryTypeAssistant,\\n   193→\\t\\t\\t\\t\\tContent: msg.Content,\\n   194→\\t\\t\\t\\t})\\n   195→\\t\\t\\t}\\n   196→\\t\\t\\tfor _, part := range msg.Parts {\\n   197→\\t\\t\\t\\tif part.Type == \\\"tool\\\" && part.State != nil {\\n   198→\\t\\t\\t\\t\\tentries = append(entries, Entry{\\n   199→\\t\\t\\t\\t\\t\\tType:       EntryTypeTool,\\n   200→\\t\\t\\t\\t\\t\\tToolName:   part.Tool,\\n   201→\\t\\t\\t\\t\\t\\tToolDetail: extractGenericToolDetail(part.State.Input),\\n   202→\\t\\t\\t\\t\\t})\\n   203→\\t\\t\\t\\t}\\n   204→\\t\\t\\t}\\n   205→\\t\\t}\\n   206→\\t}\\n   207→\\n   208→\\treturn entries, nil\\n   209→}\\n   210→\\n   211→// extractGenericToolDetail extracts an appropriate detail string from a tool's input/args map.\\n   212→// Checks common fields in order of preference. Used by both OpenCode and Gemini condensation.\\n   213→func extractGenericToolDetail(input map[string]interface{}) string {\\n   214→\\tfor _, key := range []string{\\\"description\\\", \\\"command\\\", \\\"file_path\\\", \\\"path\\\", \\\"pattern\\\"} {\\n   215→\\t\\tif v, ok := input[key].(string); ok && v != \\\"\\\" {\\n   216→\\t\\t\\treturn v\\n   217→\\t\\t}\\n   218→\\t}\\n   219→\\treturn \\\"\\\"\\n   220→}\\n   221→\\n   222→// BuildCondensedTranscript extracts a condensed view of the transcript.\\n   223→// It processes user prompts, assistant responses, and tool calls into\\n   224→// a simplified format suitable for LLM summarization.\\n   225→func BuildCondensedTranscript(lines []transcript.Line) []Entry {\\n   226→\\tvar entries []Entry\\n   227→\\n   228→\\tfor _, line := range lines {\\n   229→\\t\\tswitch line.Type {\\n   230→\\t\\tcase transcript.TypeUser:\\n   231→\\t\\t\\tif entry := extractUserEntry(line); entry != nil {\\n   232→\\t\\t\\t\\tentries = append(entries, *entry)\\n   233→\\t\\t\\t}\\n   234→\\t\\tcase transcript.TypeAssistant:\\n   235→\\t\\t\\tassistantEntries := extractAssistantEntries(line)\\n   236→\\t\\t\\tentries = append(entries, assistantEntries...)\\n   237→\\t\\t}\\n   238→\\t}\\n   239→\\n   240→\\treturn entries\\n   241→}\\n   242→\\n   243→// skillContentPrefix identifies user messages that are skill content injections.\\n   244→// These are injected after a Skill tool call and contain the full skill instructions.\\n   245→const skillContentPrefix = \\\"Base directory for this skill:\\\"\\n   246→\\n   247→// extractUserEntry extracts a user entry from a transcript line.\\n   248→// Returns nil if the line doesn't contain a valid user prompt or is skill content.\\n   249→func extractUserEntry(line transcript.Line) *Entry {\\n   250→\\tcontent := transcript.ExtractUserContent(line.Message)\\n   251→\\tif content == \\\"\\\" {\\n   252→\\t\\treturn nil\\n   253→\\t}\\n   254→\\n   255→\\t// Skip skill content injections - these are verbose skill instructions\\n   256→\\t// injected as user messages after Skill tool invocations in Claude Code.\\n   257→\\t// The prefix \\\"Base directory for this skill:\\\" is added by the superpowers\\n   258→\\t// plugin when loading skill content. This filtering reduces transcript noise\\n   259→\\t// since skill content is documentation, not user intent.\\n   260→\\tif strings.HasPrefix(content, skillContentPrefix) {\\n   261→\\t\\treturn nil\\n   262→\\t}\\n   263→\\n   264→\\treturn &Entry{\\n   265→\\t\\tType:    EntryTypeUser,\\n   266→\\t\\tContent: content,\\n   267→\\t}\\n   268→}\\n   269→\\n   270→// extractAssistantEntries extracts assistant and tool entries from a transcript line.\\n   271→func extractAssistantEntries(line transcript.Line) []Entry {\\n   272→\\tvar msg transcript.AssistantMessage\\n   273→\\tif err := json.Unmarshal(line.Message, &msg); err != nil {\\n   274→\\t\\treturn nil\\n   275→\\t}\\n   276→\\n   277→\\tvar entries []Entry\\n   278→\\n   279→\\tfor _, block := range msg.Content {\\n   280→\\t\\tswitch block.Type {\\n   281→\\t\\tcase transcript.ContentTypeText:\\n   282→\\t\\t\\tif block.Text != \\\"\\\" {\\n   283→\\t\\t\\t\\tentries = append(entries, Entry{\\n   284→\\t\\t\\t\\t\\tType:    EntryTypeAssistant,\\n   285→\\t\\t\\t\\t\\tContent: block.Text,\\n   286→\\t\\t\\t\\t})\\n   287→\\t\\t\\t}\\n   288→\\t\\tcase transcript.ContentTypeToolUse:\\n   289→\\t\\t\\tvar input transcript.ToolInput\\n   290→\\t\\t\\t_ = json.Unmarshal(block.Input, &input) //nolint:errcheck // Best-effort parsing\\n   291→\\n   292→\\t\\t\\tdetail := extractToolDetail(block.Name, input)\\n   293→\\n   294→\\t\\t\\tentries = append(entries, Entry{\\n   295→\\t\\t\\t\\tType:       EntryTypeTool,\\n   296→\\t\\t\\t\\tToolName:   block.Name,\\n   297→\\t\\t\\t\\tToolDetail: detail,\\n   298→\\t\\t\\t})\\n   299→\\t\\t}\\n   300→\\t}\\n   301→\\n   302→\\treturn entries\\n   303→}\\n   304→\\n   305→// extractToolDetail extracts an appropriate detail string for a tool call.\\n   306→// For tools in minimalDetailTools, only essential identifiers are shown.\\n   307→// For other tools, the full detail chain is used.\\n   308→func extractToolDetail(toolName string, input transcript.ToolInput) string {\\n   309→\\t// For minimal detail tools, extract only the essential identifier\\n   310→\\tif minimalDetailTools[toolName] {\\n   311→\\t\\tswitch toolName {\\n   312→\\t\\tcase \\\"Skill\\\":\\n   313→\\t\\t\\treturn input.Skill\\n   314→\\t\\tcase \\\"Read\\\":\\n   315→\\t\\t\\tif input.FilePath != \\\"\\\" {\\n   316→\\t\\t\\t\\treturn input.FilePath\\n   317→\\t\\t\\t}\\n   318→\\t\\t\\treturn input.NotebookPath\\n   319→\\t\\tcase \\\"WebFetch\\\":\\n   320→\\t\\t\\treturn input.URL\\n   321→\\t\\t}\\n   322→\\t}\\n   323→\\n   324→\\t// For other tools, use the full detail chain\\n   325→\\tif input.Description != \\\"\\\" {\\n   326→\\t\\treturn input.Description\\n   327→\\t}\\n   328→\\tif input.Command != \\\"\\\" {\\n   329→\\t\\treturn input.Command\\n   330→\\t}\\n   331→\\tif input.FilePath != \\\"\\\" {\\n   332→\\t