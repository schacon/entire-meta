ases:\\n  1033→\\t// 1. Transcript has grown since last condensation (new prompts/responses)\\n  1034→\\t// 2. FilesTouched has files not yet committed (carry-forward scenario)\\n  1035→\\t//\\n  1036→\\t// For PrepareCommitMsg context, we verify staged files overlap with session's files\\n  1037→\\t// using content-aware matching to detect reverted files.\\n  1038→\\t// For PostCommit context, getStagedFiles() is empty (files already committed),\\n  1039→\\t// so we return true and let the caller do the overlap check via filesOverlapWithContent.\\n  1040→\\n  1041→\\thasTranscriptGrowth := transcriptLines > state.CheckpointTranscriptStart\\n  1042→\\thasUncommittedFiles := len(state.FilesTouched) > 0\\n  1043→\\n  1044→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: transcript check\\\",\\n  1045→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1046→\\t\\tslog.Int(\\\"transcript_lines\\\", transcriptLines),\\n  1047→\\t\\tslog.Int(\\\"checkpoint_transcript_start\\\", state.CheckpointTranscriptStart),\\n  1048→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1049→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1050→\\t)\\n  1051→\\n  1052→\\tif !hasTranscriptGrowth && !hasUncommittedFiles {\\n  1053→\\t\\treturn false, nil // No new content and no carry-forward files\\n  1054→\\t}\\n  1055→\\n  1056→\\t// Check if staged files overlap with session's files with content-aware matching.\\n  1057→\\t// This is primarily for PrepareCommitMsg; in PostCommit, stagedFiles is empty.\\n  1058→\\tstagedFiles := getStagedFiles(repo)\\n  1059→\\tif len(stagedFiles) > 0 {\\n  1060→\\t\\tresult := stagedFilesOverlapWithContent(repo, tree, stagedFiles, state.FilesTouched)\\n  1061→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: staged files overlap check\\\",\\n  1062→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1063→\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1064→\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n  1065→\\t\\t)\\n  1066→\\t\\treturn result, nil\\n  1067→\\t}\\n  1068→\\n  1069→\\t// No staged files - either PostCommit context or edge case.\\n  1070→\\t// Return transcript growth status. For PostCommit with hasTranscriptFile=true,\\n  1071→\\t// if there's no transcript growth, the session hasn't done new work since last checkpoint.\\n  1072→\\t// (Carry-forward creates a shadow branch WITHOUT transcript, handled in the block above.)\\n  1073→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no staged files, returning transcript growth\\\",\\n  1074→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1075→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1076→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1077→\\t)\\n  1078→\\treturn hasTranscriptGrowth, nil\\n  1079→}\\n  1080→\\n  1081→// sessionHasNewContentFromLiveTranscript checks if a session has new content\\n  1082→// by examining the live transcript file. This is used when no shadow branch exists\\n  1083→// (i.e., no Stop has happened yet) but the agent may have done work.\\n  1084→//\\n  1085→// Returns true if:\\n  1086→//  1. The transcript has grown since the last condensation, AND\\n  1087→//  2. The new transcript portion contains file modifications, AND\\n  1088→//  3. At least one modified file overlaps with the currently staged files\\n  1089→//\\n  1090→// The overlap check ensures we don't add checkpoint trailers to commits that are\\n  1091→// unrelated to the agent's recent changes.\\n  1092→//\\n  1093→// This handles the scenario where the agent commits mid-session before Stop.\\n  1094→func (s *ManualCommitStrategy) sessionHasNewContentFromLiveTranscript(repo *git.Repository, state *SessionState) (bool, error) {\\n  1095→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1096→\\n  1097→\\tmodifiedFiles, ok := s.extractNewModifiedFilesFromLiveTranscript(state)\\n  1098→\\tif !ok || len(modifiedFiles) == 0 {\\n  1099→\\t\\treturn false, nil\\n  1100→\\t}\\n  1101→\\n  1102→\\tlogging.Debug(logCtx, \\\"live transcript check: found file modifications\\\",\\n  1103→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1104→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1105→\\t)\\n  1106→\\n  1107→\\t// Check if any modified files overlap with currently staged files\\n  1108→\\t// This ensures we only add checkpoint trailers to commits that include\\n  1109→\\t// files the agent actually modified\\n  1110→\\tstagedFiles := getStagedFiles(repo)\\n  1111→\\n  1112→\\tlogging.Debug(logCtx, \\\"live transcript check: comparing staged vs modified\\\",\\n  1113→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1114→\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1115→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1116→\\t)\\n  1117→\\n  1118→\\tif !hasOverlappingFiles(stagedFiles, modifiedFiles) {\\n  1119→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no overlap between staged and modified files\\\",\\n  1120→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1121→\\t\\t)\\n  1122→\\t\\treturn false, nil // No overlap - staged files are unrelated to agent's work\\n  1123→\\t}\\n  1124→\\n  1125→\\treturn true, nil\\n  1126→}\\n  1127→\\n  1128→// extractFilesFromLiveTranscript extracts modified file paths from the live transcript.\\n  1129→// Returns empty slice if extraction fails (fail-open behavior for hooks).\\n  1130→// Extracts files from the transcript starting at CheckpointTranscriptStart, which gives\\n  1131→// files touched since the last condensation — used for carry-forward computation.\\n  1132→func (s *ManualCommitStrategy) extractFilesFromLiveTranscript(state *SessionState) []string {\\n  1133→\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n  1134→}\\n  1135→\\n  1136→// extractNewModifiedFilesFromLiveTranscript extracts modified files from the live\\n  1137→// transcript that are NEW since the last condensation. Returns the normalized file list\\n  1138→// and whether the extraction succeeded. Used by sessionHasNewContentFromLiveTranscript\\n  1139→// to detect agent work.\\n  1140→func (s *ManualCommitStrategy) extractNewModifiedFilesFromLiveTranscript(state *SessionState) ([]string, bool) {\\n  1141→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1142→\\n  1143→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1144→\\t\\treturn nil, false\\n  1145→\\t}\\n  1146→\\n  1147→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1148→\\tif err != nil {\\n  1149→\\t\\treturn nil, false\\n  1150→\\t}\\n  1151→\\n  1152→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1153→\\tif !ok {\\n  1154→\\t\\treturn nil, false\\n  1155→\\t}\\n  1156→\\n  1157→\\t// Check if transcript has grown since last condensation\\n  1158→\\tcurrentPos, err := analyzer.GetTranscriptPosition(state.TranscriptPath)\\n  1159→\\tif err != nil {\\n  1160→\\t\\treturn nil, false\\n  1161→\\t}\\n  1162→\\tif currentPos <= state.CheckpointTranscriptStart {\\n  1163→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no new content\\\",\\n  1164→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1165→\\t\\t\\tslog.Int(\\\"current_pos\\\", currentPos),\\n  1166→\\t\\t\\tslog.Int(\\\"start_offset\\\", state.CheckpointTranscriptStart),\\n  1167→\\t\\t)\\n  1168→\\t\\treturn nil, true // No new content, but extraction succeeded\\n  1169→\\t}\\n  1170→\\n  1171→\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart), true\\n  1172→}\\n  1173→\\n  1174→// extractModifiedFilesFromLiveTranscript extracts modified files from the live transcript\\n  1175→// (including subagent transcripts) starting from the given offset, and normalizes them\\n  1176→// to repo-relative paths. Returns the normalized file list.\\n  1177→func (s *ManualCommitStrategy) extractModifiedFilesFromLiveTranscript(state *SessionState, offset int) []string {\\n  1178→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1179→\\n  1180→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1181→\\t\\treturn nil\\n  1182→\\t}\\n  1183→\\n  1184→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1185→\\tif err != nil {\\n  1186→\\t\\treturn nil\\n  1187→\\t}\\n  1188→\\n  1189→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1190→\\tif !ok {\\n  1191→\\t\\treturn nil\\n  1192→\\t}\\n  1193→\\n  1194→\\tvar modifiedFiles []string\\n  1195→\\n  1196→\\t// For Claude Code, use ExtractAllModifiedFiles which parses the main transcript\\n  1197→\\t// AND subagent transcripts in a single pass, avoiding redundant parsing.\\n  1198→\\tif state.AgentType == agent.AgentTypeClaudeCode {\\n  1199→\\t\\tsubagentsDir := filepath.Join(filepath.Dir(state.TranscriptPath), state.SessionID, \\\"subagents\\\")\\n  1200→\\t\\tallFiles, extractErr := claudecode.ExtractAllModifiedFiles(state.TranscriptPath, offset, subagentsDir)\\n  1201→\\t\\tif extractErr != nil {\\n  1202→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: extraction failed\\\",\\n  1203→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1204→\\t\\t\\t\\tslog.String(\\\"error\\\", extractErr.Error()),\\n  1205→\\t\\t\\t)\\n  1206→\\t\\t} else {\\n  1207→\\t\\t\\tmodifiedFiles = allFiles\\n  1208→\\t\\t}\\n  1209→\\t} else {\\n  1210→\\t\\tfiles, _, err := analyzer.ExtractModifiedFilesFromOffset(state.TranscriptPath, offset)\\n  1211→\\t\\tif err != nil {\\n  1212→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: main transcript extraction failed\\\",\\n  1213→\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1214→\\t\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1215→\\t\\t\\t)\\n  1216→\\t\\t} else {\\n  1217→\\t\\t\\tmodifiedFiles = files\\n  1218→\\t\\t}\\n  1219→\\t}\\n  1220→\\n  1221→\\tif len(modifiedFiles) == 0 {\\n  1222→\\t\\treturn nil\\n  1223→\\t}\\n  1224→\\n  1225→\\t// Normalize to repo-relative paths.\\n  1226→\\t// Transcript tool_use entries contain absolute paths (e.g., /Users/alex/project/src/main.go)\\n  1227→\\t// but getStagedFiles/committedFiles use repo-relative paths (e.g., src/main.go).\\n  1228→\\tbasePath := state.WorktreePath\\n  1229→\\tif basePath == \\\"\\\" {\\n  1230→\\t\\tif wp, wpErr := GetWorktreePath(); wpErr == nil {\\n  1231→\\t\\t\\tbasePath = wp\\n  1232→\\t\\t}\\n  1233→\\t}\\n  1234→\\tif basePath != \\\"\\\" {\\n  1235→\\t\\tnormalized := make([]string, 0, len(modifiedFiles))\\n  1236→\\t\\tfor _, f := range modifiedFiles {\\n  1237→\\t\\t\\tif rel := paths.ToRelativePath(f, basePath); rel != \\\"\\\" {\\n  1238→\\t\\t\\t\\tnormalized = append(normalized, rel)\\n  1239→\\t\\t\\t} else {\\n  1240→\\t\\t\\t\\tnormalized = append(normalized, f)\\n  1241→\\t\\t\\t}\\n  1242→\\t\\t}\\n  1243→\\t\\tmodifiedFiles = normalized\\n  1244→\\t}\\n  1245→\\n  1246→\\treturn modifiedFiles\\n  1247→}\\n  1248→\\n  1249→// addTrailerForAgentCommit handles the fast path when an agent is committing\\n  1250→// (ACTIVE session + no TTY). Generates a checkpoint ID and adds the trailer\\n  1251→// directly, bypassing content detection and interactive prompts.\\n  1252→func (s *ManualCommitStrategy) addTrailerForAgentCommit(logCtx context.Context, commitMsgFile string, state *SessionState, source string) error {\\n  1253→\\tcpID, err := id.Generate()\\n  1254→\\tif err != nil {\\n  1255→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1256→\\t}\\n  1257→\\n  1258→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n  1259→\\tif err != nil {\\n  1260→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1261→\\t}\\n  1262→\\n  1263→\\tmessage := string(content)\\n  1264→\\n  1265→\\t// Don't add if trailer already exists\\n  1266→\\tif _, found := trailers.ParseCheckpoint(message); found {\\n  1267→\\t\\treturn nil\\n  1268→\\t}\\n  1269→\\n  1270→\\tmessage = addCheckpointTrailer(message, cpID)\\n  1271→\\n  1272→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: agent commit trailer added\\\",\\n  1273→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n  1274→\\t\\tslog.String(\\\"source\\\", source),\\n  1275→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n  1276→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1277→\\t)\\n  1278→\\n  1279→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n  1280→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1281→\\t}\\n  1282→\\treturn nil\\n  1283→}\\n  1284→\\n  1285→// addCheckpointTrailer adds the Entire-Checkpoint trailer to a commit message.\\n  1286→// Handles proper trailer formatting (blank line before trailers if needed).\\n  1287→func addCheckpointTrailer(message string, checkpointID id.CheckpointID) string {\\n  1288→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1289→\\n  1290→\\t// If message already ends with trailers (lines starting with key:), just append\\n  1291→\\t// Otherwise, add a blank line first\\n  1292→\\tlines := strings.Split(strings.TrimRight(message, \\\"\\\\n\\\"), \\\"\\\\n\\\")\\n  1293→\\n  1294→\\t// Check if the message already ends with a trailer paragraph.\\n  1295→\\t// Git trailers must be in a separate paragraph (preceded by a blank line).\\n  1296→\\t// A single-paragraph message (e.g., just a subject line) cannot have trailers,\\n  1297→\\t// even if the subject contains \\\": \\\" (like conventional commits: \\\"docs: Add foo\\\").\\n  1298→\\t//\\n  1299→\\t// Scan from the bottom: find the last paragraph of non-comment content,\\n  1300→\\t// then check if it looks like trailers AND has a blank line above it.\\n  1301→\\thasTrailers := false\\n  1302→\\ti := len(lines) - 1\\n  1303→\\n  1304→\\t// Skip trailing comment lines\\n  1305→\\tfor i >= 0 && strings.HasPrefix(strings.TrimSpace(lines[i]), \\\"#\\\") {\\n  1306→\\t\\ti--\\n  1307→\\t}\\n  1308→\\n  1309→\\t// Check if the last non-comment line looks like a trailer\\n  1310→\\tif i >= 0 {\\n  1311→\\t\\tline := strings.TrimSpace(lines[i])\\n  1312→\\t\\tif line != \\\"\\\" && strings.Contains(line, \\\": \\\") {\\n  1313→\\t\\t\\t// Found a trailer-like line. Now scan upward past the trailer block\\n  1314→\\t\\t\\t// to verify there's a blank line (paragraph separator) above it.\\n  1315→\\t\\t\\tfor i > 0 {\\n  1316→\\t\\t\\t\\ti--\\n  1317→\\t\\t\\t\\tabove := strings.TrimSpace(lines[i])\\n  1318→\\t\\t\\t\\tif strings.HasPrefix(above, \\\"#\\\") {\\n  1319→\\t\\t\\t\\t\\tcontinue\\n  1320→\\t\\t\\t\\t}\\n  1321→\\t\\t\\t\\tif above == \\\"\\\" {\\n  1322→\\t\\t\\t\\t\\t// Blank line found above trailer block — real trailers\\n  1323→\\t\\t\\t\\t\\thasTrailers = true\\n  1324→\\t\\t\\t\\t\\tbreak\\n  1325→\\t\\t\\t\\t}\\n  1326→\\t\\t\\t\\tif !strings.Contains(above, \\\": \\\") {\\n  1327→\\t\\t\\t\\t\\t// Non-trailer, non-blank line — this is message body, not trailers\\n  1328→\\t\\t\\t\\t\\tbreak\\n  1329→\\t\\t\\t\\t}\\n  1330→\\t\\t\\t\\t// Another trailer-like line, keep scanning upward\\n  1331→\\t\\t\\t}\\n  1332→\\t\\t}\\n  1333→\\t}\\n  1334→\\n  1335→\\tif hasTrailers {\\n  1336→\\t\\t// Append trailer directly\\n  1337→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1338→\\t}\\n  1339→\\n  1340→\\t// Add blank line before trailer\\n  1341→\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1342→}\\n  1343→\\n  1344→// addCheckpointTrailerWithComment adds the Entire-Checkpoint trailer with an explanatory comment.\\n  1345→// The trailer is placed above the git comment block but below the user's message area,\\n  1346→// with a comment explaining that the user can remove it if they don't want to link the commit\\n  1347→// to the agent session. If prompt is non-empty, it's shown as context.\\n  1348→func addCheckpointTrailerWithComment(message string, checkpointID id.CheckpointID, agentName, prompt string) string {\\n  1349→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1350→\\tcommentLines := []string{\\n  1351→\\t\\t\\\"# Remove the Entire-Checkpoint trailer above if you don't want to link this commit to \\\" + agentName + \\\" session context.\\\",\\n  1352→\\t}\\n  1353→\\tif prompt != \\\"\\\" {\\n  1354→\\t\\tcommentLines = append(commentLines, \\\"# Last Prompt: \\\"+prompt)\\n  1355→\\t}\\n  1356→\\tcommentLines = append(commentLines, \\\"# The trailer will be added to your next commit based on this branch.\\\")\\n  1357→\\tcomment := strings.Join(commentLines, \\\"\\\\n\\\")\\n  1358→\\n  1359→\\tlines := strings.Split(message, \\\"\\\\n\\\")\\n  1360→\\n  1361→\\t// Find where the git comment block starts (first # line)\\n  1362→\\tcommentStart := -1\\n  1363→\\tfor i, line := range lines {\\n  1364→\\t\\tif strings.HasPrefix(line, \\\"#\\\") {\\n  1365→\\t\\t\\tcommentStart = i\\n  1366→\\t\\t\\tbreak\\n  1367→\\t\\t}\\n  1368→\\t}\\n  1369→\\n  1370→\\tif commentStart == -1 {\\n  1371→\\t\\t// No git comments, append trailer at the end\\n  1372→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\"\\n  1373→\\t}\\n  1374→\\n  1375→\\t// Split into user content and git comments\\n  1376→\\tuserContent := strings.Join(lines[:commentStart], \\\"\\\\n\\\")\\n  1377→\\tgitComments := strings.Join(lines[commentStart:], \\\"\\\\n\\\")\\n  1378→\\n  1379→\\t// Build result: user content, blank line, trailer, comment, blank line, git comments\\n  1380→\\tuserContent = strings.TrimRight(userContent, \\\"\\\\n\\\")\\n  1381→\\tif userContent == \\\"\\\" {\\n  1382→\\t\\t// No user content yet - leave space for them to type, then trailer\\n  1383→\\t\\t// Two newlines: first for user's message line, second for blank separator\\n  1384→\\t\\treturn \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1385→\\t}\\n  1386→\\treturn userContent + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1387→}\\n  1388→\\n  1389→// InitializeSession creates session state for a new session or updates an existing one.\\n  1390→// This implements the optional SessionInitializer interface.\\n  1391→// Called during UserPromptSubmit to allow git hooks to detect active sessions.\\n  1392→//\\n  1393→// If the session already exists and HEAD has moved (e.g., user committed), updates\\n  1394→// BaseCommit to the new HEAD so future checkpoints go to the correct shadow branch.\\n  1395→//\\n  1396→// If there's an existing shadow branch with commits from a different session ID,\\n  1397→// returns a SessionIDConflictError to prevent orphaning existing session work.\\n  1398→//\\n  1399→// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n  1400→// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n  1401→// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\n  1402→func (s *ManualCommitStrategy) InitializeSession(sessionID string, agentType agent.AgentType, transcriptPath string, userPrompt string) error {\\n  1403→\\trepo, err := OpenRepository()\\n  1404→\\tif err != nil {\\n  1405→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n  1406→\\t}\\n  1407→\\n  1408→\\t// Check if session already exists\\n  1409→\\tstate, err := s.loadSessionState(sessionID)\\n  1410→\\tif err != nil {\\n  1411→\\t\\treturn fmt.Errorf(\\\"failed to check session state: %w\\\", err)\\n  1412→\\t}\\n  1413→\\n  1414→\\tif state != nil && state.BaseCommit != \\\"\\\" {\\n  1415→\\t\\t// Session is fully initialized — apply phase transition for TurnStart.\\n  1416→\\t\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1417→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1418→\\t\\t}\\n  1419→\\n  1420→\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n  1421→\\t\\tturnID, err := id.Generate()\\n  1422→\\t\\tif err != nil {\\n  1423→\\t\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n  1424→\\t\\t}\\n  1425→\\t\\tstate.TurnID = turnID.String()\\n  1426→\\n  1427→\\t\\t// Backfill AgentType if empty or set to the generic default \\\"Agent\\\"\\n  1428→\\t\\tif !isSpecificAgentType(state.AgentType) && agentType != \\\"\\\" {\\n  1429→\\t\\t\\tstate.AgentType = agentType\\n  1430→\\t\\t}\\n  1431→\\n  1432→\\t\\t// Backfill FirstPrompt if empty (for sessions created before the first_prompt field was added)\\n  1433→\\t\\tif state.FirstPrompt == \\\"\\\" && userPrompt != \\\"\\\" {\\n  1434→\\t\\t\\tstate.FirstPrompt = truncatePromptForStorage(userPrompt)\\n  1435→\\t\\t}\\n  1436→\\n  1437→\\t\\t// Update transcript path if provided (may change on session resume)\\n  1438→\\t\\tif transcriptPath != \\\"\\\" && state.TranscriptPath != transcriptPath {\\n  1439→\\t\\t\\tstate.TranscriptPath = transcriptPath\\n  1440→\\t\\t}\\n  1441→\\n  1442→\\t\\t// Clear checkpoint IDs on every new prompt.\\n  1443→\\t\\t// LastCheckpointID is set during PostCommit, cleared at new prompt.\\n  1444→\\t\\t// TurnCheckpointIDs tracks mid-turn checkpoints for stop-time finalization.\\n  1445→\\t\\tstate.LastCheckpointID = \\\"\\\"\\n  1446→\\t\\tstate.TurnCheckpointIDs = nil\\n  1447→\\n  1448→\\t\\t// Calculate attribution at prompt start (BEFORE agent makes any changes)\\n  1449→\\t\\t// This captures user edits since the last checkpoint (or base commit for first prompt).\\n  1450→\\t\\t// IMPORTANT: Always calculate attribution, even for the first checkpoint, to capture\\n  1451→\\t\\t// user edits made before the first prompt. The inner CalculatePromptAttribution handles\\n  1452→\\t\\t// nil lastCheckpointTree by falling back to baseTree.\\n  1453→\\t\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n  1454→\\t\\tstate.PendingPromptAttribution = &promptAttr\\n  1455→\\n  1456→\\t\\t// Check if HEAD has moved (user pulled/rebased or committed)\\n  1457→\\t\\t// migrateShadowBranchIfNeeded handles renaming the shadow branch and updating state.BaseCommit\\n  1458→\\t\\tif _, err := s.migrateShadowBranchIfNeeded(repo, state); err != nil {\\n  1459→\\t\\t\\treturn fmt.Errorf(\\\"failed to check/migrate shadow branch: %w\\\", err)\\n  1460→\\t\\t}\\n  1461→\\n  1462→\\t\\tif err := s.saveSessionState(state); err != nil {\\n  1463→\\t\\t\\treturn fmt.Errorf(\\\"failed to update session state: %w\\\", err)\\n  1464→\\t\\t}\\n  1465→\\t\\treturn nil\\n  1466→\\t}\\n  1467→\\t// If state exists but BaseCommit is empty, it's a partial state from concurrent warning\\n  1468→\\t// Continue below to properly initialize it\\n  1469→\\n  1470→\\t// Initialize new session\\n  1471→\\tstate, err = s.initializeSession(repo, sessionID, agentType, transcriptPath, userPrompt)\\n  1472→\\tif err != nil {\\n  1473→\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n  1474→\\t}\\n  1475→\\n  1476→\\t// Apply phase transition: new session starts as ACTIVE.\\n  1477→\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1478→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1479→\\t}\\n  1480→\\n  1481→\\t// Calculate attribution for pre-prompt edits\\n  1482→\\t// This captures any user edits made before the first prompt\\n  1483→\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n  1484→\\tstate.PendingPromptAttribution = &promptAttr\\n  1485→\\tif err = s.saveSessionState(state); err != nil {\\n  1486→\\t\\treturn fmt.Errorf(\\\"failed to save attribution: %w\\\", err)\\n  1487→\\t}\\n  1488→\\n  1489→\\tfmt.Fprintf(os.Stderr, \\\"Initialized shadow session: %s\\\\n\\\", sessionID)\\n  1490→\\treturn nil\\n  1491→}\\n  1492→\\n  1493→// calculatePromptAttributionAtStart calculates attribution at prompt start (before agent runs).\\n  1494→// This captures user changes since the last checkpoint - no filtering needed since\\n  1495→// the agent hasn't made any changes yet.\\n  1496→//\\n  1497→// IMPORTANT: This reads from the worktree (not staging area) to match what WriteTemporary\\n  1498→// captures in checkpoints. If we read staged content but checkpoints capture worktree content,\\n  1499→// unstaged changes would be in the checkpoint but not counted in PromptAttribution, causing\\n  1500→// them to be incorrectly attributed to the agent later.\\n  1501→func (s *ManualCommitStrategy) calculatePromptAttributionAtStart(\\n  1502→\\trepo *git.Repository,\\n  1503→\\tstate *SessionState,\\n  1504→) PromptAttribution {\\n  1505→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n  1506→\\tnextCheckpointNum := state.StepCount + 1\\n  1507→\\tresult := PromptAttribution{CheckpointNumber: nextCheckpointNum}\\n  1508→\\n  1509→\\t// Get last checkpoint tree from shadow branch (if it exists)\\n  1510→\\t// For the first checkpoint, no shadow branch exists yet - this is fine,\\n  1511→\\t// CalculatePromptAttribution will use baseTree as the reference instead.\\n  1512→\\tvar lastCheckpointTree *object.Tree\\n  1513→\\tshadowBranchName := checkpoint.ShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n  1514→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1515→\\tref, err := repo.Reference(refName, true)\\n  1516→\\tif err != nil {\\n  1517→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: no shadow branch yet (first checkpoint)\\\",\\n  1518→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName))\\n  1519→\\t\\t// Continue with lastCheckpointTree = nil\\n  1520→\\t} else {\\n  1521→\\t\\tshadowCommit, err := repo.CommitObject(ref.Hash())\\n  1522→\\t\\tif err != nil {\\n  1523→\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: failed to get shadow commit\\\",\\n  1524→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", ref.Hash().String()),\\n  1525→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1526→\\t\\t\\t// Continue with lastCheckpointTree = nil\\n  1527→\\t\\t} else {\\n  1528→\\t\\t\\tlastCheckpointTree, err = shadowCommit.Tree()\\n  1529→\\t\\t\\tif err != nil {\\n  1530→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: failed to get shadow tree\\\",\\n  1531→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1532→\\t\\t\\t\\t// Continue with lastCheckpointTree = nil\\n  1533→\\t\\t\\t}\\n  1534→\\t\\t}\\n  1535→\\t}\\n  1536→\\n  1537→\\t// Get base tree for agent lines calculation\\n  1538→\\tvar baseTree *object.Tree\\n  1539→\\tif baseCommit, err := repo.CommitObject(plumbing.NewHash(state.BaseCommit)); err == nil {\\n  1540→\\t\\tif tree, treeErr := baseCommit.Tree(); treeErr == nil {\\n  1541→\\t\\t\\tbaseTree = tree\\n  1542→\\t\\t} else {\\n  1543→\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: base tree unavailable\\\",\\n  1544→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n  1545→\\t\\t}\\n  1546→\\t} else {\\n  1547→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: base commit unavailable\\\",\\n  1548→\\t\\t\\tslog.String(\\\"base_commit\\\", state.BaseCommit),\\n  1549→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1550→\\t}\\n  1551→\\n  1552→\\tworktree, err := repo.Worktree()\\n  1553→\\tif err != nil {\\n  1554→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution skipped: failed to get worktree\\\",\\n  1555→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1556→\\t\\treturn result\\n  1557→\\t}\\n  1558→\\n  1559→\\t// Get worktree status to find ALL changed files\\n  1560→\\tstatus, err := worktree.Status()\\n  1561→\\tif err != nil {\\n  1562→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution skipped: failed to get worktree status\\\",\\n  1563→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1564→\\t\\treturn result\\n  1565→\\t}\\n  1566→\\n  1567→\\tworktreeRoot := worktree.Filesystem.Root()\\n  1568→\\n  1569→\\t// Build map of changed files with their worktree content\\n  1570→\\t// IMPORTANT: We read from worktree (not staging area) to match what WriteTemporary\\n  1571→\\t// captures in checkpoints. This ensures attribution is consistent.\\n  1572→\\tchangedFiles := make(map[string]string)\\n  1573→\\tfor filePath, fileStatus := range status {\\n  1574→\\t\\t// Skip unmodified files\\n  1575→\\t\\tif fileStatus.Worktree == git.Unmodified && fileStatus.Staging == git.Unmodified {\\n  1576→\\t\\t\\tcontinue\\n  1577→\\t\\t}\\n  1578→\\t\\t// Skip .entire metadata directory (session data, not user code)\\n  1579→\\t\\tif strings.HasPrefix(filePath, paths.EntireMetadataDir+\\\"/\\\") || strings.HasPrefix(filePath, \\\".entire/\\\") {\\n  1580→\\t\\t\\tcontinue\\n  1581→\\t\\t}\\n  1582→\\n  1583→\\t\\t// Always read from worktree to match checkpoint behavior\\n  1584→\\t\\tfullPath := filepath.Join(worktreeRoot, filePath)\\n  1585→\\t\\tvar content string\\n  1586→\\t\\tif data, err := os.ReadFile(fullPath); err == nil { //nolint:gosec // filePath is from git worktree status\\n  1587→\\t\\t\\t// Use git's binary detection algorithm (matches getFileContent behavior).\\n  1588→\\t\\t\\t// Binary files are excluded from line-based attribution calculations.\\n  1589→\\t\\t\\tisBinary, binErr := binary.IsBinary(bytes.NewReader(data))\\n  1590→\\t\\t\\tif binErr == nil && !isBinary {\\n  1591→\\t\\t\\t\\tcontent = string(data)\\n  1592→\\t\\t\\t}\\n  1593→\\t\\t}\\n  1594→\\t\\t// else: file deleted, unreadable, or binary - content remains empty string\\n  1595→\\n  1596→\\t\\tchangedFiles[filePath] = content\\n  1597→\\t}\\n  1598→\\n  1599→\\t// Use CalculatePromptAttribution from manual_commit_attribution.go\\n  1600→\\tresult = CalculatePromptAttribution(baseTree, lastCheckpointTree, changedFiles, nextCheckpointNum)\\n  1601→\\n  1602→\\treturn result\\n  1603→}\\n  1604→\\n  1605→// getStagedFiles returns a list of files staged for commit.\\n  1606→func getStagedFiles(repo *git.Repository) []string {\\n  1607→\\tworktree, err := repo.Worktree()\\n  1608→\\tif err != nil {\\n  1609→\\t\\treturn nil\\n  1610→\\t}\\n  1611→\\n  1612→\\tstatus, err := worktree.Status()\\n  1613→\\tif err != nil {\\n  1614→\\t\\treturn nil\\n  1615→\\t}\\n  1616→\\n  1617→\\tvar staged []string\\n  1618→\\tfor path, fileStatus := range status {\\n  1619→\\t\\t// Check if file is staged (in index)\\n  1620→\\t\\tif fileStatus.Staging != git.Unmodified && fileStatus.Staging != git.Untracked {\\n  1621→\\t\\t\\tstaged = append(staged, path)\\n  1622→\\t\\t}\\n  1623→\\t}\\n  1624→\\treturn staged\\n  1625→}\\n  1626→\\n  1627→// getLastPrompt retrieves the most recent user prompt from a session's shadow branch.\\n  1628→// Returns empty string if no prompt can be retrieved.\\n  1629→func (s *ManualCommitStrategy) getLastPrompt(repo *git.Repository, state *SessionState) string {\\n  1630→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n  1631→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1632→\\tref, err := repo.Reference(refName, true)\\n  1633→\\tif err != nil {\\n  1634→\\t\\treturn \\\"\\\"\\n  1635→\\t}\\n  1636→\\n  1637→\\t// Extract session data to get prompts for commit message generation\\n  1638→\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini)\\n  1639→\\t// Pass 0 for checkpointTranscriptStart since we're extracting all prompts, not calculating token usage\\n  1640→\\tsessionData, err := s.extractSessionData(repo, ref.Hash(), state.SessionID, nil, state.AgentType, \\\"\\\", 0)\\n  1641→\\tif err != nil || len(sessionData.Prompts) == 0 {\\n  1642→\\t\\treturn \\\"\\\"\\n  1643→\\t}\\n  1644→\\n  1645→\\t// Return the last prompt (most recent work before commit)\\n  1646→\\treturn sessionData.Prompts[len(sessionData.Prompts)-1]\\n  1647→}\\n  1648→\\n  1649→// HandleTurnEnd dispatches strategy-specific actions emitted when an agent turn ends.\\n  1650→// The primary job is to finalize all checkpoints from this turn with the full transcript.\\n  1651→//\\n  1652→// During a turn, PostCommit writes provisional transcript data (whatever was available\\n  1653→// at commit time). HandleTurnEnd replaces that with the complete session transcript\\n  1654→// (from prompt to stop event), ensuring every checkpoint has the full context.\\n  1655→//\\n  1656→//nolint:unparam // error return required by interface but hooks must return nil\\n  1657→func (s *ManualCommitStrategy) HandleTurnEnd(state *SessionState) error {\\n  1658→\\t// Finalize all checkpoints from this turn with the full transcript.\\n  1659→\\t//\\n  1660→\\t// IMPORTANT: This is best-effort - errors are logged but don't fail the hook.\\n  1661→\\t// Failing here would prevent session cleanup and could leave state inconsistent.\\n  1662→\\t// The provisional transcript from PostCommit is already persisted, so the\\n  1663→\\t// checkpoint isn't lost - it just won't have the complete transcript.\\n  1664→\\terrCount := s.finalizeAllTurnCheckpoints(state)\\n  1665→\\tif errCount > 0 {\\n  1666→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1667→\\t\\tlogging.Warn(logCtx, \\\"HandleTurnEnd completed with errors (best-effort)\\\",\\n  1668→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1669→\\t\\t\\tslog.Int(\\\"error_count\\\", errCount),\\n  1670→\\t\\t)\\n  1671→\\t}\\n  1672→\\treturn nil\\n  1673→}\\n  1674→\\n  1675→// finalizeAllTurnCheckpoints replaces the provisional transcript in each checkpoint\\n  1676→// created during this turn with the full session transcript.\\n  1677→//\\n  1678→// This is called at turn end (stop hook). During the turn, PostCommit wrote whatever\\n  1679→// transcript was available at commit time. Now we have the complete transcript and\\n  1680→// replace it so every checkpoint has the full prompt-to-stop context.\\n  1681→//\\n  1682→// Returns the number of errors encountered (best-effort: continues processing on error).\\n  1683→func (s *ManualCommitStrategy) finalizeAllTurnCheckpoints(state *SessionState) int {\\n  1684→\\tif len(state.TurnCheckpointIDs) == 0 {\\n  1685→\\t\\treturn 0 // No mid-turn commits to finalize\\n  1686→\\t}\\n  1687→\\n  1688→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1689→\\n  1690→\\tlogging.Info(logCtx, \\\"finalizing turn checkpoints with full transcript\\\",\\n  1691→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1692→\\t\\tslog.Int(\\\"checkpoint_count\\\", len(state.TurnCheckpointIDs)),\\n  1693→\\t)\\n  1694→\\n  1695→\\terrCount := 0\\n  1696→\\n  1697→\\t// Read full transcript from live transcript file\\n  1698→\\tif state.TranscriptPath == \\\"\\\" {\\n  1699→\\t\\tlogging.Warn(logCtx, \\\"finalize: no transcript path, skipping\\\",\\n  1700→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1701→\\t\\t)\\n  1702→\\t\\tstate.TurnCheckpointIDs = nil\\n  1703→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1704→\\t}\\n  1705→\\n  1706→\\tfullTranscript, err := os.ReadFile(state.TranscriptPath)\\n  1707→\\tif err != nil || len(fullTranscript) == 0 {\\n  1708→\\t\\tmsg := \\\"finalize: empty transcript, skipping\\\"\\n  1709→\\t\\tif err != nil {\\n  1710→\\t\\t\\tmsg = \\\"finalize: failed to read transcript, skipping\\\"\\n  1711→\\t\\t}\\n  1712→\\t\\tlogging.Warn(logCtx, msg,\\n  1713→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1714→\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1715→\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1716→\\t\\t)\\n  1717→\\t\\tstate.TurnCheckpointIDs = nil\\n  1718→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1719→\\t}\\n  1720→\\n  1721→\\t// Extract prompts and context from the full transcript\\n  1722→\\tprompts := extractUserPrompts(state.AgentType, string(fullTranscript))\\n  1723→\\tcontextBytes := generateContextFromPrompts(prompts)\\n  1724→\\n  1725→\\t// Redact secrets before writing — matches WriteCommitted behavior.\\n  1726→\\t// The live transcript on disk contains raw content; redaction must happen\\n  1727→\\t// before anything is persisted to the metadata branch.\\n  1728→\\tfullTranscript, err = redact.JSONLBytes(fullTranscript)\\n  1729→\\tif err != nil {\\n  1730→\\t\\tlogging.Warn(logCtx, \\\"finalize: transcript redaction failed, skipping\\\",\\n  1731→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1732→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1733→\\t\\t)\\n  1734→\\t\\tstate.TurnCheckpointIDs = nil\\n  1735→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1736→\\t}\\n  1737→\\tfor i, p := range prompts {\\n  1738→\\t\\tprompts[i] = redact.String(p)\\n  1739→\\t}\\n  1740→\\tcontextBytes = redact.Bytes(contextBytes)\\n  1741→\\n  1742→\\t// Open repository and create checkpoint store\\n  1743→\\trepo, err := OpenRepository()\\n  1744→\\tif err != nil {\\n  1745→\\t\\tlogging.Warn(logCtx, \\\"finalize: failed to open repository\\\",\\n  1746→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1747→\\t\\t)\\n  1748→\\t\\tstate.TurnCheckpointIDs = nil\\n  1749→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1750→\\t}\\n  1751→\\tstore := checkpoint.NewGitStore(repo)\\n  1752→\\n  1753→\\t// Update each checkpoint with the full transcript\\n  1754→\\tfor _, cpIDStr := range state.TurnCheckpointIDs {\\n  1755→\\t\\tcpID, parseErr := id.NewCheckpointID(cpIDStr)\\n  1756→\\t\\tif parseErr != nil {\\n  1757→\\t\\t\\tlogging.Warn(logCtx, \\\"finalize: invalid checkpoint ID, skipping\\\",\\n  1758→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1759→\\t\\t\\t\\tslog.String(\\\"error\\\", parseErr.Error()),\\n  1760→\\t\\t\\t)\\n  1761→\\t\\t\\terrCount++\\n  1762→\\t\\t\\tcontinue\\n  1763→\\t\\t}\\n  1764→\\n  1765→\\t\\tupdateErr := store.UpdateCommitted(context.Background(), checkpoint.UpdateCommittedOptions{\\n  1766→\\t\\t\\tCheckpointID: cpID,\\n  1767→\\t\\t\\tSessionID:    state.SessionID,\\n  1768→\\t\\t\\tTranscript:   fullTranscript,\\n  1769→\\t\\t\\tPrompts:      prompts,\\n  1770→\\t\\t\\tContext:      contextBytes,\\n  1771→\\t\\t\\tAgent:        state.AgentType,\\n  1772→\\t\\t})\\n  1773→\\t\\tif updateErr != nil {\\n  1774→\\t\\t\\tlogging.Warn(logCtx, \\\"finalize: failed to update checkpoint\\\",\\n  1775→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1776→\\t\\t\\t\\tslog.String(\\\"error\\\", updateErr.Error()),\\n  1777→\\t\\t\\t)\\n  1778→\\t\\t\\terrCount++\\n  1779→\\t\\t\\tcontinue\\n  1780→\\t\\t}\\n  1781→\\n  1782→\\t\\tlogging.Info(logCtx, \\\"finalize: checkpoint updated with full transcript\\\",\\n  1783→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1784→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1785→\\t\\t)\\n  1786→\\t}\\n  1787→\\n  1788→\\t// Clear turn checkpoint IDs. Do NOT update CheckpointTranscriptStart here — it was\\n  1789→\\t// already set correctly by PostCommit: condenseAndUpdateState sets it to the total\\n  1790→\\t// transcript lines when condensing, and carryForwardToNewShadowBranch resets it to 0\\n  1791→\\t// when carry-forward is active. Overwriting here would break carry-forward by making\\n  1792→\\t// sessionHasNewContent think the transcript is fully consumed (no growth