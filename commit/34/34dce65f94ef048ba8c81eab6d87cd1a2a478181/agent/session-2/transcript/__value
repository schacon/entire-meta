1→\\t\\\"strings\\\"\\n    12→\\t\\\"sync\\\"\\n    13→\\t\\\"time\\\"\\n    14→\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/buildinfo\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n    22→\\n    23→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    24→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    25→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    26→)\\n    27→\\n    28→// isNotFoundError checks if an error represents a \\\"not found\\\" condition in go-git.\\n    29→// This includes entry not found, file not found, directory not found, and object not found.\\n    30→func isNotFoundError(err error) bool {\\n    31→\\treturn errors.Is(err, object.ErrEntryNotFound) ||\\n    32→\\t\\terrors.Is(err, object.ErrFileNotFound) ||\\n    33→\\t\\terrors.Is(err, object.ErrDirectoryNotFound) ||\\n    34→\\t\\terrors.Is(err, plumbing.ErrObjectNotFound) ||\\n    35→\\t\\terrors.Is(err, plumbing.ErrReferenceNotFound)\\n    36→}\\n    37→\\n    38→// commitOrHead attempts to create a commit. If the commit would be empty (files already\\n    39→// committed), it returns HEAD hash instead. This handles the case where files were\\n    40→// modified during a session but already committed by the user before the hook runs.\\n    41→func commitOrHead(repo *git.Repository, worktree *git.Worktree, msg string, author *object.Signature) (plumbing.Hash, error) {\\n    42→\\tcommitHash, err := worktree.Commit(msg, &git.CommitOptions{Author: author})\\n    43→\\tif errors.Is(err, git.ErrEmptyCommit) {\\n    44→\\t\\tfmt.Fprintf(os.Stderr, \\\"No changes to commit (files already committed)\\\\n\\\")\\n    45→\\t\\thead, err := repo.Head()\\n    46→\\t\\tif err != nil {\\n    47→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n    48→\\t\\t}\\n    49→\\t\\treturn head.Hash(), nil\\n    50→\\t}\\n    51→\\tif err != nil {\\n    52→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to commit: %w\\\", err)\\n    53→\\t}\\n    54→\\treturn commitHash, nil\\n    55→}\\n    56→\\n    57→// AutoCommitStrategy implements the auto-commit strategy:\\n    58→// - Code changes are committed to the active branch (like commit strategy)\\n    59→// - Session logs are committed to a shadow branch (like manual-commit strategy)\\n    60→// - Code commits can reference the shadow branch via trailers\\n    61→type AutoCommitStrategy struct {\\n    62→\\t// checkpointStore manages checkpoint data on entire/checkpoints/v1 branch\\n    63→\\tcheckpointStore *checkpoint.GitStore\\n    64→\\t// checkpointStoreOnce ensures thread-safe lazy initialization\\n    65→\\tcheckpointStoreOnce sync.Once\\n    66→\\t// checkpointStoreErr captures any error during initialization\\n    67→\\tcheckpointStoreErr error\\n    68→}\\n    69→\\n    70→// getCheckpointStore returns the checkpoint store, initializing it lazily if needed.\\n    71→// Thread-safe via sync.Once.\\n    72→func (s *AutoCommitStrategy) getCheckpointStore() (*checkpoint.GitStore, error) {\\n    73→\\ts.checkpointStoreOnce.Do(func() {\\n    74→\\t\\trepo, err := OpenRepository()\\n    75→\\t\\tif err != nil {\\n    76→\\t\\t\\ts.checkpointStoreErr = fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n    77→\\t\\t\\treturn\\n    78→\\t\\t}\\n    79→\\t\\ts.checkpointStore = checkpoint.NewGitStore(repo)\\n    80→\\t})\\n    81→\\treturn s.checkpointStore, s.checkpointStoreErr\\n    82→}\\n    83→\\n    84→// NewAutoCommitStrategy creates a new AutoCommitStrategy instance.\\n    85→//\\n    86→\\n    87→func NewAutoCommitStrategy() Strategy {\\n    88→\\treturn &AutoCommitStrategy{}\\n    89→}\\n    90→\\n    91→func (s *AutoCommitStrategy) Name() string {\\n    92→\\treturn StrategyNameAutoCommit\\n    93→}\\n    94→\\n    95→func (s *AutoCommitStrategy) Description() string {\\n    96→\\treturn \\\"Auto-commits code to active branch with metadata on entire/checkpoints/v1\\\"\\n    97→}\\n    98→\\n    99→func (s *AutoCommitStrategy) ValidateRepository() error {\\n   100→\\trepo, err := OpenRepository()\\n   101→\\tif err != nil {\\n   102→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   103→\\t}\\n   104→\\n   105→\\t_, err = repo.Worktree()\\n   106→\\tif err != nil {\\n   107→\\t\\treturn fmt.Errorf(\\\"failed to access worktree: %w\\\", err)\\n   108→\\t}\\n   109→\\n   110→\\treturn nil\\n   111→}\\n   112→\\n   113→// PrePush is called by the git pre-push hook before pushing to a remote.\\n   114→// It pushes the entire/checkpoints/v1 branch alongside the user's push.\\n   115→// Configuration options (stored in .entire/settings.json under strategy_options.push_sessions):\\n   116→//   - \\\"auto\\\": always push automatically\\n   117→//   - \\\"prompt\\\" (default): ask user with option to enable auto\\n   118→//   - \\\"false\\\"/\\\"off\\\"/\\\"no\\\": never push\\n   119→func (s *AutoCommitStrategy) PrePush(remote string) error {\\n   120→\\tif err := pushSessionsBranchCommon(remote, paths.MetadataBranchName); err != nil {\\n   121→\\t\\treturn err\\n   122→\\t}\\n   123→\\treturn PushTrailsBranch(remote)\\n   124→}\\n   125→\\n   126→func (s *AutoCommitStrategy) SaveStep(ctx StepContext) error {\\n   127→\\trepo, err := OpenRepository()\\n   128→\\tif err != nil {\\n   129→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   130→\\t}\\n   131→\\n   132→\\t// Generate checkpoint ID for this commit\\n   133→\\tcpID, err := id.Generate()\\n   134→\\tif err != nil {\\n   135→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   136→\\t}\\n   137→\\t// Step 1: Commit code changes to active branch with checkpoint ID trailer\\n   138→\\t// We do code first to avoid orphaned metadata if this step fails.\\n   139→\\t// If metadata commit fails after this, the code commit exists but GetRewindPoints\\n   140→\\t// already handles missing metadata gracefully (skips commits without metadata).\\n   141→\\tcodeResult, err := s.commitCodeToActive(repo, ctx, cpID)\\n   142→\\tif err != nil {\\n   143→\\t\\treturn fmt.Errorf(\\\"failed to commit code to active branch: %w\\\", err)\\n   144→\\t}\\n   145→\\n   146→\\t// If no code commit was created (no changes), skip metadata creation\\n   147→\\t// This prevents orphaned metadata commits that don't correspond to any code commit\\n   148→\\tif !codeResult.Created {\\n   149→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   150→\\t\\tlogging.Info(logCtx, \\\"checkpoint skipped (no changes)\\\",\\n   151→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n   152→\\t\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"session\\\"),\\n   153→\\t\\t)\\n   154→\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipped checkpoint (no changes since last commit)\\\\n\\\")\\n   155→\\t\\treturn nil\\n   156→\\t}\\n   157→\\n   158→\\t// Step 2: Commit metadata to entire/checkpoints/v1 branch using sharded path\\n   159→\\t// Path is <checkpointID[:2]>/<checkpointID[2:]>/ for direct lookup\\n   160→\\t_, err = s.commitMetadataToMetadataBranch(repo, ctx, cpID)\\n   161→\\tif err != nil {\\n   162→\\t\\treturn fmt.Errorf(\\\"failed to commit metadata to entire/checkpoints/v1 branch: %w\\\", err)\\n   163→\\t}\\n   164→\\n   165→\\t// Log checkpoint creation\\n   166→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   167→\\tlogging.Info(logCtx, \\\"checkpoint saved\\\",\\n   168→\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n   169→\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"session\\\"),\\n   170→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   171→\\t\\tslog.Int(\\\"modified_files\\\", len(ctx.ModifiedFiles)),\\n   172→\\t\\tslog.Int(\\\"new_files\\\", len(ctx.NewFiles)),\\n   173→\\t\\tslog.Int(\\\"deleted_files\\\", len(ctx.DeletedFiles)),\\n   174→\\t)\\n   175→\\n   176→\\treturn nil\\n   177→}\\n   178→\\n   179→// commitCodeResult contains the result of committing code to the active branch.\\n   180→type commitCodeResult struct {\\n   181→\\tCommitHash plumbing.Hash\\n   182→\\tCreated    bool // True if a new commit was created, false if skipped (no changes)\\n   183→}\\n   184→\\n   185→// commitCodeToActive commits code changes to the active branch.\\n   186→// Adds an Entire-Checkpoint trailer for metadata lookup that survives amend/rebase.\\n   187→// Returns the result containing commit hash and whether a commit was created.\\n   188→func (s *AutoCommitStrategy) commitCodeToActive(repo *git.Repository, ctx StepContext, checkpointID id.CheckpointID) (commitCodeResult, error) {\\n   189→\\t// Check if there are any code changes to commit\\n   190→\\tif len(ctx.ModifiedFiles) == 0 && len(ctx.NewFiles) == 0 && len(ctx.DeletedFiles) == 0 {\\n   191→\\t\\tfmt.Fprintf(os.Stderr, \\\"No code changes to commit to active branch\\\\n\\\")\\n   192→\\t\\t// Return current HEAD hash but mark as not created\\n   193→\\t\\thead, err := repo.Head()\\n   194→\\t\\tif err != nil {\\n   195→\\t\\t\\treturn commitCodeResult{}, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   196→\\t\\t}\\n   197→\\t\\treturn commitCodeResult{CommitHash: head.Hash(), Created: false}, nil\\n   198→\\t}\\n   199→\\n   200→\\tworktree, err := repo.Worktree()\\n   201→\\tif err != nil {\\n   202→\\t\\treturn commitCodeResult{}, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   203→\\t}\\n   204→\\n   205→\\t// Get HEAD hash before commit to detect if commitOrHead actually creates a new commit\\n   206→\\t// (commitOrHead returns HEAD hash without error when git.ErrEmptyCommit occurs)\\n   207→\\theadBefore, err := repo.Head()\\n   208→\\tif err != nil {\\n   209→\\t\\treturn commitCodeResult{}, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   210→\\t}\\n   211→\\n   212→\\t// Stage code changes\\n   213→\\tStageFiles(worktree, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles, StageForSession)\\n   214→\\n   215→\\t// Add checkpoint ID trailer to commit message\\n   216→\\tcommitMsg := ctx.CommitMessage + \\\"\\\\n\\\\n\\\" + trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n   217→\\n   218→\\tauthor := &object.Signature{\\n   219→\\t\\tName:  ctx.AuthorName,\\n   220→\\t\\tEmail: ctx.AuthorEmail,\\n   221→\\t\\tWhen:  time.Now(),\\n   222→\\t}\\n   223→\\tcommitHash, err := commitOrHead(repo, worktree, commitMsg, author)\\n   224→\\tif err != nil {\\n   225→\\t\\treturn commitCodeResult{}, err\\n   226→\\t}\\n   227→\\n   228→\\t// Check if a new commit was actually created by comparing with HEAD before\\n   229→\\tcreated := commitHash != headBefore.Hash()\\n   230→\\tif created {\\n   231→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed code changes to active branch (%s)\\\\n\\\", commitHash.String()[:7])\\n   232→\\t}\\n   233→\\treturn commitCodeResult{CommitHash: commitHash, Created: created}, nil\\n   234→}\\n   235→\\n   236→// commitMetadataToMetadataBranch commits session metadata to the entire/checkpoints/v1 branch.\\n   237→// Metadata is stored at sharded path: <checkpointID[:2]>/<checkpointID[2:]>/\\n   238→// This allows direct lookup from the checkpoint ID trailer on the code commit.\\n   239→// Uses checkpoint.WriteCommitted for git operations.\\n   240→func (s *AutoCommitStrategy) commitMetadataToMetadataBranch(repo *git.Repository, ctx StepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n   241→\\tstore, err := s.getCheckpointStore()\\n   242→\\tif err != nil {\\n   243→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   244→\\t}\\n   245→\\n   246→\\t// Extract session ID from metadata dir\\n   247→\\tsessionID := filepath.Base(ctx.MetadataDir)\\n   248→\\n   249→\\t// Get current branch name\\n   250→\\tbranchName := GetCurrentBranchName(repo)\\n   251→\\n   252→\\t// Combine all file changes into FilesTouched (same as manual-commit)\\n   253→\\tfilesTouched := mergeFilesTouched(nil, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles)\\n   254→\\n   255→\\t// Load TurnID from session state (correlates checkpoints from the same turn)\\n   256→\\tvar turnID string\\n   257→\\tif state, loadErr := LoadSessionState(sessionID); loadErr == nil && state != nil {\\n   258→\\t\\tturnID = state.TurnID\\n   259→\\t}\\n   260→\\n   261→\\t// Write committed checkpoint using the checkpoint store\\n   262→\\t// Pass TranscriptPath so writeTranscript generates content_hash.txt\\n   263→\\ttranscriptPath := filepath.Join(ctx.MetadataDirAbs, paths.TranscriptFileName)\\n   264→\\terr = store.WriteCommitted(context.Background(), checkpoint.WriteCommittedOptions{\\n   265→\\t\\tCheckpointID:                checkpointID,\\n   266→\\t\\tSessionID:                   sessionID,\\n   267→\\t\\tStrategy:                    StrategyNameAutoCommit, // Use new strategy name\\n   268→\\t\\tBranch:                      branchName,\\n   269→\\t\\tMetadataDir:                 ctx.MetadataDirAbs, // Copy all files from metadata dir\\n   270→\\t\\tTranscriptPath:              transcriptPath,     // For content hash generation\\n   271→\\t\\tAuthorName:                  ctx.AuthorName,\\n   272→\\t\\tAuthorEmail:                 ctx.AuthorEmail,\\n   273→\\t\\tAgent:                       ctx.AgentType,\\n   274→\\t\\tTurnID:                      turnID,\\n   275→\\t\\tTranscriptIdentifierAtStart: ctx.StepTranscriptIdentifier,\\n   276→\\t\\tCheckpointTranscriptStart:   ctx.StepTranscriptStart,\\n   277→\\t\\tTokenUsage:                  ctx.TokenUsage,\\n   278→\\t\\tCheckpointsCount:            1,            // Each auto-commit checkpoint = 1\\n   279→\\t\\tFilesTouched:                filesTouched, // Track modified files (same as manual-commit)\\n   280→\\t})\\n   281→\\tif err != nil {\\n   282→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write committed checkpoint: %w\\\", err)\\n   283→\\t}\\n   284→\\n   285→\\tfmt.Fprintf(os.Stderr, \\\"Committed session metadata to %s (%s)\\\\n\\\", paths.MetadataBranchName, checkpointID)\\n   286→\\treturn plumbing.ZeroHash, nil // Commit hash not needed by callers\\n   287→}\\n   288→\\n   289→func (s *AutoCommitStrategy) GetRewindPoints(limit int) ([]RewindPoint, error) {\\n   290→\\t// For auto-commit strategy, rewind points are found by looking for Entire-Checkpoint trailers\\n   291→\\t// in the current branch's commit history. The checkpoint ID provides direct lookup\\n   292→\\t// to metadata on entire/checkpoints/v1 branch.\\n   293→\\trepo, err := OpenRepository()\\n   294→\\tif err != nil {\\n   295→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   296→\\t}\\n   297→\\n   298→\\thead, err := repo.Head()\\n   299→\\tif err != nil {\\n   300→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   301→\\t}\\n   302→\\n   303→\\t// Get metadata branch tree for lookups\\n   304→\\tmetadataTree, err := GetMetadataBranchTree(repo)\\n   305→\\tif err != nil {\\n   306→\\t\\t// No metadata branch yet is fine\\n   307→\\t\\treturn []RewindPoint{}, nil //nolint:nilerr // Expected when no metadata exists\\n   308→\\t}\\n   309→\\n   310→\\t// Get the main branch commit hash to determine branch-only commits\\n   311→\\tmainBranchHash := GetMainBranchHash(repo)\\n   312→\\n   313→\\t// Walk current branch history looking for commits with checkpoint trailers\\n   314→\\titer, err := repo.Log(&git.LogOptions{\\n   315→\\t\\tFrom:  head.Hash(),\\n   316→\\t\\tOrder: git.LogOrderCommitterTime,\\n   317→\\t})\\n   318→\\tif err != nil {\\n   319→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   320→\\t}\\n   321→\\n   322→\\tvar points []RewindPoint\\n   323→\\tcount := 0\\n   324→\\n   325→\\terr = iter.ForEach(func(c *object.Commit) error {\\n   326→\\t\\tif count >= logsOnlyScanLimit || len(points) >= limit {\\n   327→\\t\\t\\treturn errStop\\n   328→\\t\\t}\\n   329→\\t\\tcount++\\n   330→\\n   331→\\t\\t// Check for Entire-Checkpoint trailer\\n   332→\\t\\tcpID, found := trailers.ParseCheckpoint(c.Message)\\n   333→\\t\\tif !found {\\n   334→\\t\\t\\treturn nil\\n   335→\\t\\t}\\n   336→\\n   337→\\t\\t// Look up metadata from sharded path\\n   338→\\t\\tcheckpointPath := cpID.Path()\\n   339→\\t\\tmetadata, err := ReadCheckpointMetadata(metadataTree, checkpointPath)\\n   340→\\t\\tif err != nil {\\n   341→\\t\\t\\t// Checkpoint exists in commit but no metadata found - skip this commit\\n   342→\\t\\t\\treturn nil //nolint:nilerr // Intentional: skip commits without metadata\\n   343→\\t\\t}\\n   344→\\n   345→\\t\\tmessage := strings.Split(c.Message, \\\"\\\\n\\\")[0]\\n   346→\\n   347→\\t\\t// Determine if this is a full rewind or logs-only\\n   348→\\t\\t// Full rewind is allowed if commit is only on this branch (not reachable from main)\\n   349→\\t\\tisLogsOnly := false\\n   350→\\t\\tif mainBranchHash != plumbing.ZeroHash {\\n   351→\\t\\t\\tif IsAncestorOf(repo, c.Hash, mainBranchHash) {\\n   352→\\t\\t\\t\\tisLogsOnly = true\\n   353→\\t\\t\\t}\\n   354→\\t\\t}\\n   355→\\n   356→\\t\\t// Build metadata path - for task checkpoints, include the task path\\n   357→\\t\\tmetadataDir := checkpointPath\\n   358→\\t\\tif metadata.IsTask && metadata.ToolUseID != \\\"\\\" {\\n   359→\\t\\t\\tmetadataDir = checkpointPath + \\\"/tasks/\\\" + metadata.ToolUseID\\n   360→\\t\\t}\\n   361→\\n   362→\\t\\t// Read session prompt from metadata tree\\n   363→\\t\\tsessionPrompt := ReadSessionPromptFromTree(metadataTree, checkpointPath)\\n   364→\\n   365→\\t\\tpoints = append(points, RewindPoint{\\n   366→\\t\\t\\tID:               c.Hash.String(),\\n   367→\\t\\t\\tMessage:          message,\\n   368→\\t\\t\\tMetadataDir:      metadataDir,\\n   369→\\t\\t\\tDate:             c.Author.When,\\n   370→\\t\\t\\tIsLogsOnly:       isLogsOnly,\\n   371→\\t\\t\\tCheckpointID:     cpID,\\n   372→\\t\\t\\tIsTaskCheckpoint: metadata.IsTask,\\n   373→\\t\\t\\tToolUseID:        metadata.ToolUseID,\\n   374→\\t\\t\\tAgent:            metadata.Agent,\\n   375→\\t\\t\\tSessionID:        metadata.SessionID,\\n   376→\\t\\t\\tSessionPrompt:    sessionPrompt,\\n   377→\\t\\t})\\n   378→\\n   379→\\t\\treturn nil\\n   380→\\t})\\n   381→\\n   382→\\tif err != nil && !errors.Is(err, errStop) {\\n   383→\\t\\treturn nil, fmt.Errorf(\\\"failed to iterate commits: %w\\\", err)\\n   384→\\t}\\n   385→\\n   386→\\treturn points, nil\\n   387→}\\n   388→\\n   389→// findTaskMetadataPathForCommit looks up the task metadata path for a task checkpoint commit\\n   390→// by searching the entire/checkpoints/v1 branch commit history for the checkpoint directory.\\n   391→// Returns (\\\"\\\", nil) if metadata is not found - this is expected for commits without metadata.\\n   392→func (s *AutoCommitStrategy) findTaskMetadataPathForCommit(repo *git.Repository, commitSHA, toolUseID string) (string, error) {\\n   393→\\t// Get the entire/checkpoints/v1 branch\\n   394→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   395→\\tref, err := repo.Reference(refName, true)\\n   396→\\tif err != nil {\\n   397→\\t\\tif isNotFoundError(err) {\\n   398→\\t\\t\\treturn \\\"\\\", nil // No metadata branch yet\\n   399→\\t\\t}\\n   400→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get metadata branch: %w\\\", err)\\n   401→\\t}\\n   402→\\n   403→\\t// Search commit history for a commit referencing this code commit SHA and tool use ID\\n   404→\\tshortSHA := commitSHA\\n   405→\\tif len(shortSHA) > 7 {\\n   406→\\t\\tshortSHA = shortSHA[:7]\\n   407→\\t}\\n   408→\\n   409→\\titer, err := repo.Log(&git.LogOptions{From: ref.Hash()})\\n   410→\\tif err != nil {\\n   411→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   412→\\t}\\n   413→\\n   414→\\tvar foundTaskPath string\\n   415→\\terr = iter.ForEach(func(commit *object.Commit) error {\\n   416→\\t\\t// Check if commit message contains \\\"Commit: <sha>\\\" and the tool use ID\\n   417→\\t\\tif strings.Contains(commit.Message, \\\"Commit: \\\"+shortSHA) &&\\n   418→\\t\\t\\tstrings.Contains(commit.Message, toolUseID) {\\n   419→\\t\\t\\t// Parse task metadata trailer\\n   420→\\t\\t\\tif taskPath, found := trailers.ParseTaskMetadata(commit.Message); found {\\n   421→\\t\\t\\t\\tfoundTaskPath = taskPath\\n   422→\\t\\t\\t\\treturn errStop // Found it\\n   423→\\t\\t\\t}\\n   424→\\t\\t}\\n   425→\\t\\treturn nil\\n   426→\\t})\\n   427→\\tif err != nil && !errors.Is(err, errStop) {\\n   428→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to iterate commits: %w\\\", err)\\n   429→\\t}\\n   430→\\n   431→\\treturn foundTaskPath, nil\\n   432→}\\n   433→\\n   434→func (s *AutoCommitStrategy) Rewind(point RewindPoint) error {\\n   435→\\tcommitHash := plumbing.NewHash(point.ID)\\n   436→\\tshortID, err := HardResetWithProtection(commitHash)\\n   437→\\tif err != nil {\\n   438→\\t\\treturn err\\n   439→\\t}\\n   440→\\n   441→\\tfmt.Println()\\n   442→\\tfmt.Printf(\\\"Reset to commit %s\\\\n\\\", shortID)\\n   443→\\tfmt.Println()\\n   444→\\n   445→\\treturn nil\\n   446→}\\n   447→\\n   448→func (s *AutoCommitStrategy) CanRewind() (bool, string, error) {\\n   449→\\treturn checkCanRewind()\\n   450→}\\n   451→\\n   452→// PreviewRewind returns what will happen if rewinding to the given point.\\n   453→// For auto-commit strategy, this returns nil since git reset doesn't delete untracked files.\\n   454→func (s *AutoCommitStrategy) PreviewRewind(_ RewindPoint) (*RewindPreview, error) {\\n   455→\\t// Auto-commit uses git reset --hard which doesn't affect untracked files\\n   456→\\t// Return empty preview to indicate no untracked files will be deleted\\n   457→\\treturn &RewindPreview{}, nil\\n   458→}\\n   459→\\n   460→// EnsureSetup ensures the strategy's required setup is in place.\\n   461→// For auto-commit strategy:\\n   462→// - Ensure .entire/.gitignore has all required entries\\n   463→// - Create orphan entire/checkpoints/v1 branch if it doesn't exist\\n   464→// - Install git hooks if missing (self-healing for third-party overwrites)\\n   465→func (s *AutoCommitStrategy) EnsureSetup() error {\\n   466→\\tif err := EnsureEntireGitignore(); err != nil {\\n   467→\\t\\treturn err\\n   468→\\t}\\n   469→\\n   470→\\trepo, err := OpenRepository()\\n   471→\\tif err != nil {\\n   472→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   473→\\t}\\n   474→\\n   475→\\t// Ensure the entire/checkpoints/v1 orphan branch exists\\n   476→\\tif err := EnsureMetadataBranch(repo); err != nil {\\n   477→\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n   478→\\t}\\n   479→\\n   480→\\t// Install generic hooks if missing (they delegate to strategy at runtime)\\n   481→\\tif !IsGitHookInstalled() {\\n   482→\\t\\tif _, err := InstallGitHook(true); err != nil {\\n   483→\\t\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   484→\\t\\t}\\n   485→\\t}\\n   486→\\n   487→\\treturn nil\\n   488→}\\n   489→\\n   490→// GetSessionInfo returns session information for linking commits.\\n   491→// For auto-commit strategy, we don't track active sessions - metadata is stored on\\n   492→// entire/checkpoints/v1 branch when SaveStep is called. Active branch commits\\n   493→// are kept clean (no trailers), so this returns ErrNoSession.\\n   494→// Use ListSessions() or GetSession() to retrieve session info from the metadata branch.\\n   495→func (s *AutoCommitStrategy) GetSessionInfo() (*SessionInfo, error) {\\n   496→\\t// Dual strategy doesn't track active sessions like shadow does.\\n   497→\\t// Session metadata is stored on entire/checkpoints/v1 branch and can be\\n   498→\\t// retrieved via ListSessions() or GetSession().\\n   499→\\treturn nil, ErrNoSession\\n   500→}\\n   501→\\n   502→// SaveTaskStep creates a checkpoint commit for a completed task.\\n   503→// For auto-commit strategy:\\n   504→// 1. Commit code changes to active branch (no trailers - clean history)\\n   505→// 2. Commit task metadata to entire/checkpoints/v1 branch with checkpoint format\\n   506→func (s *AutoCommitStrategy) SaveTaskStep(ctx TaskStepContext) error {\\n   507→\\trepo, err := OpenRepository()\\n   508→\\tif err != nil {\\n   509→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   510→\\t}\\n   511→\\n   512→\\t// Ensure entire/checkpoints/v1 branch exists\\n   513→\\tif err := EnsureMetadataBranch(repo); err != nil {\\n   514→\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n   515→\\t}\\n   516→\\n   517→\\t// Generate checkpoint ID for this task checkpoint\\n   518→\\tcpID, err := id.Generate()\\n   519→\\tif err != nil {\\n   520→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   521→\\t}\\n   522→\\n   523→\\t// Step 1: Commit code changes to active branch with checkpoint ID trailer\\n   524→\\t// We do code first to avoid orphaned metadata if this step fails.\\n   525→\\t_, err = s.commitTaskCodeToActive(repo, ctx, cpID)\\n   526→\\tif err != nil {\\n   527→\\t\\treturn fmt.Errorf(\\\"failed to commit task code to active branch: %w\\\", err)\\n   528→\\t}\\n   529→\\n   530→\\t// Step 2: Commit task metadata to entire/checkpoints/v1 branch at sharded path\\n   531→\\t_, err = s.commitTaskMetadataToMetadataBranch(repo, ctx, cpID)\\n   532→\\tif err != nil {\\n   533→\\t\\treturn fmt.Errorf(\\\"failed to commit task metadata to entire/checkpoints/v1 branch: %w\\\", err)\\n   534→\\t}\\n   535→\\n   536→\\t// Log task checkpoint creation\\n   537→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   538→\\tattrs := []any{\\n   539→\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n   540→\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"task\\\"),\\n   541→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   542→\\t\\tslog.String(\\\"checkpoint_uuid\\\", ctx.CheckpointUUID),\\n   543→\\t\\tslog.String(\\\"tool_use_id\\\", ctx.ToolUseID),\\n   544→\\t\\tslog.String(\\\"subagent_type\\\", ctx.SubagentType),\\n   545→\\t\\tslog.Int(\\\"modified_files\\\", len(ctx.ModifiedFiles)),\\n   546→\\t\\tslog.Int(\\\"new_files\\\", len(ctx.NewFiles)),\\n   547→\\t\\tslog.Int(\\\"deleted_files\\\", len(ctx.DeletedFiles)),\\n   548→\\t}\\n   549→\\tif ctx.IsIncremental {\\n   550→\\t\\tattrs = append(attrs,\\n   551→\\t\\t\\tslog.Bool(\\\"is_incremental\\\", true),\\n   552→\\t\\t\\tslog.String(\\\"incremental_type\\\", ctx.IncrementalType),\\n   553→\\t\\t\\tslog.Int(\\\"incremental_sequence\\\", ctx.IncrementalSequence),\\n   554→\\t\\t)\\n   555→\\t}\\n   556→\\tlogging.Info(logCtx, \\\"task checkpoint saved\\\", attrs...)\\n   557→\\n   558→\\treturn nil\\n   559→}\\n   560→\\n   561→// commitTaskCodeToActive commits task code changes to the active branch.\\n   562→// Adds an Entire-Checkpoint trailer for metadata lookup that survives amend/rebase.\\n   563→// Skips commit creation if there are no file changes.\\n   564→func (s *AutoCommitStrategy) commitTaskCodeToActive(repo *git.Repository, ctx TaskStepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n   565→\\thasFileChanges := len(ctx.ModifiedFiles) > 0 || len(ctx.NewFiles) > 0 || len(ctx.DeletedFiles) > 0\\n   566→\\n   567→\\t// If no file changes, skip code commit\\n   568→\\tif !hasFileChanges {\\n   569→\\t\\tfmt.Fprintf(os.Stderr, \\\"No code changes to commit for task checkpoint\\\\n\\\")\\n   570→\\t\\t// Return current HEAD hash so metadata can still be stored\\n   571→\\t\\thead, err := repo.Head()\\n   572→\\t\\tif err != nil {\\n   573→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   574→\\t\\t}\\n   575→\\t\\treturn head.Hash(), nil\\n   576→\\t}\\n   577→\\n   578→\\tworktree, err := repo.Worktree()\\n   579→\\tif err != nil {\\n   580→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   581→\\t}\\n   582→\\n   583→\\t// Stage code changes\\n   584→\\tStageFiles(worktree, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles, StageForTask)\\n   585→\\n   586→\\t// Build commit message with checkpoint trailer\\n   587→\\tshortToolUseID := ctx.ToolUseID\\n   588→\\tif len(shortToolUseID) > id.ShortIDLength {\\n   589→\\t\\tshortToolUseID = shortToolUseID[:id.ShortIDLength]\\n   590→\\t}\\n   591→\\n   592→\\tvar subject string\\n   593→\\tif ctx.IsIncremental {\\n   594→\\t\\tsubject = FormatIncrementalSubject(\\n   595→\\t\\t\\tctx.IncrementalType,\\n   596→\\t\\t\\tctx.SubagentType,\\n   597→\\t\\t\\tctx.TaskDescription,\\n   598→\\t\\t\\tctx.TodoContent,\\n   599→\\t\\t\\tctx.IncrementalSequence,\\n   600→\\t\\t\\tshortToolUseID,\\n   601→\\t\\t)\\n   602→\\t} else {\\n   603→\\t\\tsubject = FormatSubagentEndMessage(ctx.SubagentType, ctx.TaskDescription, shortToolUseID)\\n   604→\\t}\\n   605→\\n   606→\\t// Add checkpoint ID trailer to commit message\\n   607→\\tcommitMsg := subject + \\\"\\\\n\\\\n\\\" + trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n   608→\\n   609→\\tauthor := &object.Signature{\\n   610→\\t\\tName:  ctx.AuthorName,\\n   611→\\t\\tEmail: ctx.AuthorEmail,\\n   612→\\t\\tWhen:  time.Now(),\\n   613→\\t}\\n   614→\\n   615→\\tcommitHash, err := commitOrHead(repo, worktree, commitMsg, author)\\n   616→\\tif err != nil {\\n   617→\\t\\treturn plumbing.ZeroHash, err\\n   618→\\t}\\n   619→\\n   620→\\tif ctx.IsIncremental {\\n   621→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed incremental checkpoint #%d to active branch (%s)\\\\n\\\", ctx.IncrementalSequence, commitHash.String()[:7])\\n   622→\\t} else {\\n   623→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed task checkpoint to active branch (%s)\\\\n\\\", commitHash.String()[:7])\\n   624→\\t}\\n   625→\\treturn commitHash, nil\\n   626→}\\n   627→\\n   628→// commitTaskMetadataToMetadataBranch commits task metadata to the entire/checkpoints/v1 branch.\\n   629→// Uses sharded path: <checkpointID[:2]>/<checkpointID[2:]>/tasks/<tool-use-id>/\\n   630→// Returns the metadata commit hash.\\n   631→// When IsIncremental is true, only writes the incremental checkpoint file, skipping transcripts.\\n   632→// Uses checkpoint.WriteCommitted for git operations.\\n   633→func (s *AutoCommitStrategy) commitTaskMetadataToMetadataBranch(repo *git.Repository, ctx TaskStepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n   634→\\tstore, err := s.getCheckpointStore()\\n   635→\\tif err != nil {\\n   636→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   637→\\t}\\n   638→\\n   639→\\t// Format commit subject line for better git log readability\\n   640→\\tshortToolUseID := ctx.ToolUseID\\n   641→\\tif len(shortToolUseID) > id.ShortIDLength {\\n   642→\\t\\tshortToolUseID = shortToolUseID[:id.ShortIDLength]\\n   643→\\t}\\n   644→\\n   645→\\tvar messageSubject string\\n   646→\\tif ctx.IsIncremental {\\n   647→\\t\\tmessageSubject = FormatIncrementalSubject(\\n   648→\\t\\t\\tctx.IncrementalType,\\n   649→\\t\\t\\tctx.SubagentType,\\n   650→\\t\\t\\tctx.TaskDescription,\\n   651→\\t\\t\\tctx.TodoContent,\\n   652→\\t\\t\\tctx.IncrementalSequence,\\n   653→\\t\\t\\tshortToolUseID,\\n   654→\\t\\t)\\n   655→\\t} else {\\n   656→\\t\\tmessageSubject = FormatSubagentEndMessage(ctx.SubagentType, ctx.TaskDescription, shortToolUseID)\\n   657→\\t}\\n   658→\\n   659→\\t// Get current branch name\\n   660→\\tbranchName := GetCurrentBranchName(repo)\\n   661→\\n   662→\\t// Write committed checkpoint using the checkpoint store\\n   663→\\terr = store.WriteCommitted(context.Background(), checkpoint.WriteCommittedOptions{\\n   664→\\t\\tCheckpointID:           checkpointID,\\n   665→\\t\\tSessionID:              ctx.SessionID,\\n   666→\\t\\tStrategy:               StrategyNameAutoCommit,\\n   667→\\t\\tBranch:                 branchName,\\n   668→\\t\\tIsTask:                 true,\\n   669→\\t\\tToolUseID:              ctx.ToolUseID,\\n   670→\\t\\tAgentID:                ctx.AgentID,\\n   671→\\t\\tCheckpointUUID:         ctx.CheckpointUUID,\\n   672→\\t\\tTranscriptPath:         ctx.TranscriptPath,\\n   673→\\t\\tSubagentTranscriptPath: ctx.SubagentTranscriptPath,\\n   674→\\t\\tIsIncremental:          ctx.IsIncremental,\\n   675→\\t\\tIncrementalSequence:    ctx.IncrementalSequence,\\n   676→\\t\\tIncrementalType:        ctx.IncrementalType,\\n   677→\\t\\tIncrementalData:        ctx.IncrementalData,\\n   678→\\t\\tCommitSubject:          messageSubject,\\n   679→\\t\\tAuthorName:             ctx.AuthorName,\\n   680→\\t\\tAuthorEmail:            ctx.AuthorEmail,\\n   681→\\t\\tAgent:                  ctx.AgentType,\\n   682→\\t})\\n   683→\\tif err != nil {\\n   684→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write task checkpoint: %w\\\", err)\\n   685→\\t}\\n   686→\\n   687→\\tif ctx.IsIncremental {\\n   688→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed incremental checkpoint metadata to %s (%s)\\\\n\\\", paths.MetadataBranchName, checkpointID)\\n   689→\\t} else {\\n   690→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed task metadata to %s (%s)\\\\n\\\", paths.MetadataBranchName, checkpointID)\\n   691→\\t}\\n   692→\\treturn plumbing.ZeroHash, nil // Commit hash not needed by callers\\n   693→}\\n   694→\\n   695→// GetTaskCheckpoint returns the task checkpoint for a given rewind point.\\n   696→// For auto-commit strategy, checkpoints are stored on the entire/checkpoints/v1 branch in checkpoint directories.\\n   697→// Returns ErrNotTaskCheckpoint if the point is not a task checkpoint.\\n   698→func (s *AutoCommitStrategy) GetTaskCheckpoint(point RewindPoint) (*TaskCheckpoint, error) {\\n   699→\\tif !point.IsTaskCheckpoint {\\n   700→\\t\\treturn nil, ErrNotTaskCheckpoint\\n   701→\\t}\\n   702→\\n   703→\\trepo, err := OpenRepository()\\n   704→\\tif err != nil {\\n   705→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   706→\\t}\\n   707→\\n   708→\\t// Get the entire/checkpoints/v1 branch\\n   709→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   710→\\tref, err := repo.Reference(refName, true)\\n   711→\\tif err != nil {\\n   712→\\t\\treturn nil, fmt.Errorf(\\\"metadata branch %s not found: %w\\\", paths.MetadataBranchName, err)\\n   713→\\t}\\n   714→\\n   715→\\tmetadataCommit, err := repo.CommitObject(ref.Hash())\\n   716→\\tif err != nil {\\n   717→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch commit: %w\\\", err)\\n   718→\\t}\\n   719→\\n   720→\\ttree, err := metadataCommit.Tree()\\n   721→\\tif err != nil {\\n   722→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata tree: %w\\\", err)\\n   723→\\t}\\n   724→\\n   725→\\t// Find checkpoint using the metadata path from rewind point\\n   726→\\t// MetadataDir for auto-commit task checkpoints is: cond-YYYYMMDD-HHMMSS-XXXXXXXX/tasks/<tool-use-id>\\n   727→\\tcheckpointPath := point.MetadataDir + \\\"/checkpoint.json\\\"\\n   728→\\tfile, err := tree.File(checkpointPath)\\n   729→\\tif err != nil {\\n   730→\\t\\t// Try finding via commit SHA lookup\\n   731→\\t\\ttaskCheckpointPath, findErr := s.findTaskCheckpointPath(repo, point.ID, point.ToolUseID)\\n   732→\\t\\tif findErr != nil {\\n   733→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", checkpointPath, err)\\n   734→\\t\\t}\\n   735→\\t\\tfile, err = tree.File(taskCheckpointPath)\\n   736→\\t\\tif err != nil {\\n   737→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", taskCheckpointPath, err)\\n   738→\\t\\t}\\n   739→\\t}\\n   740→\\n   741→\\tcontent, err := file.Contents()\\n   742→\\tif err != nil {\\n   743→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   744→\\t}\\n   745→\\n   746→\\tvar checkpoint TaskCheckpoint\\n   747→\\tif err := json.Unmarshal([]byte(content), &checkpoint); err != nil {\\n   748→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse checkpoint: %w\\\", err)\\n   749→\\t}\\n   750→\\n   751→\\treturn &checkpoint, nil\\n   752→}\\n   753→\\n   754→// GetTaskCheckpointTranscript returns the session transcript for a task checkpoint.\\n   755→// For auto-commit strategy, transcripts are stored on the entire/checkpoints/v1 branch in checkpoint directories.\\n   756→// Returns ErrNotTaskCheckpoint if the point is not a task checkpoint.\\n   757→func (s *AutoCommitStrategy) GetTaskCheckpointTranscript(point RewindPoint) ([]byte, error) {\\n   758→\\tif !point.IsTaskCheckpoint {\\n   759→\\t\\treturn nil, ErrNotTaskCheckpoint\\n   760→\\t}\\n   761→\\n   762→\\trepo, err := OpenRepository()\\n   763→\\tif err != nil {\\n   764→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   765→\\t}\\n   766→\\n   767→\\t// Get the entire/checkpoints/v1 branch\\n   768→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   769→\\tref, err := repo.Reference(refName, true)\\n   770→\\tif err != nil {\\n   771→\\t\\treturn nil, fmt.Errorf(\\\"metadata branch %s not found: %w\\\", paths.MetadataBranchName, err)\\n   772→\\t}\\n   773→\\n   774→\\tmetadataCommit, err := repo.CommitObject(ref.Hash())\\n   775→\\tif err != nil {\\n   776→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch commit: %w\\\", err)\\n   777→\\t}\\n   778→\\n   779→\\ttree, err := metadataCommit.Tree()\\n   780→\\tif err != nil {\\n   781→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata tree: %w\\\", err)\\n   782→\\t}\\n   783→\\n   784→\\t// MetadataDir for auto-commit task checkpoints is: <id[:2]>/<id[2:]>/tasks/<tool-use-id>\\n   785→\\t// Extract the checkpoint path by removing \\\"/tasks/<tool-use-id>\\\"\\n   786→\\tmetadataDir := point.MetadataDir\\n   787→\\tif idx := strings.Index(metadataDir, \\\"/tasks/\\\"); idx > 0 {\\n   788→\\t\\tcheckpointPath := metadataDir[:idx]\\n   789→\\n   790→\\t\\t// Use the first session's transcript path from sessions array\\n   791→\\t\\ttranscriptPath := \\\"\\\"\\n   792→\\t\\tsummaryFile, summaryErr := tree.File(checkpointPath + \\\"/\\\" + paths.MetadataFileName)\\n   793→\\t\\tif summaryErr == nil {\\n   794→\\t\\t\\tsummaryContent, contentErr := summaryFile.Contents()\\n   795→\\t\\t\\tif contentErr == nil {\\n   796→\\t\\t\\t\\tvar summary checkpoint.CheckpointSummary\\n   797→\\t\\t\\t\\tif json.Unmarshal([]byte(summaryContent), &summary) == nil && len(summary.Sessions) > 0 {\\n   798→\\t\\t\\t\\t\\t// Use first session's transcript path (task checkpoints have only one session)\\n   799→\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n   800→\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n   801→\\t\\t\\t\\t\\tif summary.Sessions[0].Transcript != \\\"\\\" {\\n   802→\\t\\t\\t\\t\\t\\ttranscriptPath = strings.TrimPrefix(summary.Sessions[0].Transcript, \\\"/\\\")\\n   803→\\t\\t\\t\\t\\t}\\n   804→\\t\\t\\t\\t}\\n   805→\\t\\t\\t}\\n   806→\\t\\t}\\n   807→\\n   808→\\t\\t// Fall back to old format if sessions map not available\\n   809→\\t\\tif transcriptPath == \\\"\\\" {\\n   810→\\t\\t\\ttranscriptPath = checkpointPath + \\\"/\\\" + paths.TranscriptFileName\\n   811→\\t\\t}\\n   812→\\n   813→\\t\\tfile, err := tree.File(transcriptPath)\\n   814→\\t\\tif err != nil {\\n   815→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find transcript at %s: %w\\\", transcriptPath, err)\\n   816→\\t\\t}\\n   817→\\t\\tcontent, err := file.Contents()\\n   818→\\t\\tif err != nil {\\n   819→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   820→\\t\\t}\\n   821→\\t\\treturn []byte(content), nil\\n   822→\\t}\\n   823→\\n   824→\\treturn nil, fmt.Errorf(\\\"invalid metadata path format: %s\\\", metadataDir)\\n   825→}\\n   826→\\n   827→// findTaskCheckpointPath finds the full path to a task checkpoint on the entire/checkpoints/v1 branch.\\n   828→// Searches checkpoint directories for the task checkpoint matching the commit SHA and tool use ID.\\n   829→func (s *AutoCommitStrategy) findTaskCheckpointPath(repo *git.Repository, commitSHA, toolUseID string) (string, error) {\\n   830→\\t// Use findTaskMetadataPathForCommit which searches commit history\\n   831→\\ttaskPath, err := s.findTaskMetadataPathForCommit(repo, commitSHA, toolUseID)\\n   832→\\tif err != nil {\\n   833→\\t\\treturn \\\"\\\", err\\n   834→\\t}\\n   835→\\tif taskPath == \\\"\\\" {\\n   836→\\t\\treturn \\\"\\\", errors.New(\\\"task checkpoint not found\\\")\\n   837→\\t}\\n   838→\\t// taskPath is like: cond-YYYYMMDD-HHMMSS-XXXXXXXX/tasks/<tool-use-id>/checkpoints/001-<tool-use-id>.json\\n   839→\\t// We need: cond-YYYYMMDD-HHMMSS-XXXXXXXX/tasks/<tool-use-id>/checkpoint.json\\n   840→\\tif idx := strings.Index(taskPath, \\\"/checkpoints/\\\"); idx > 0 {\\n   841→\\t\\treturn taskPath[:idx] + \\\"/checkpoint.json\\\", nil\\n   842→\\t}\\n   843→\\treturn taskPath + \\\"/checkpoint.json\\\", nil\\n   844→}\\n   845→\\n   846→// GetMetadataRef returns a reference to the metadata for the given checkpoint.\\n   847→// For auto-commit strategy, returns the checkpoint path on entire/checkpoints/v1 branch.\\n   848→func (s *AutoCommitStrategy) GetMetadataRef(checkpoint Checkpoint) string {\\n   849→\\tif checkpoint.CheckpointID.IsEmpty() {\\n   850→\\t\\treturn \\\"\\\"\\n   851→\\t}\\n   852→\\treturn paths.MetadataBranchName + \\\":\\\" + checkpoint.CheckpointID.Path()\\n   853→}\\n   854→\\n   855→// GetSessionMetadataRef returns a reference to the most recent metadata for a session.\\n   856→func (s *AutoCommitStrategy) GetSessionMetadataRef(sessionID string) string {\\n   857→\\tsession, err := GetSession(sessionID)\\n   858→\\tif err != nil || len(session.Checkpoints) == 0 {\\n   859→\\t\\treturn \\\"\\\"\\n   860→\\t}\\n   861→\\t// Checkpoints are ordered with most recent first\\n   862→\\treturn s.GetMetadataRef(session.Checkpoints[0])\\n   863→}\\n   864→\\n   865→// GetSessionContext returns the context.md content for a session.\\n   866→// For auto-commit strategy, reads from the entire/checkpoints/v1 branch using the checkpoint store.\\n   867→func (s *AutoCommitStrategy) GetSessionContext(sessionID string) string {\\n   868→\\tsession, err := GetSession(sessionID)\\n   869→\\tif err != nil || len(session.Checkpoints) == 0 {\\n   870→\\t\\treturn \\\"\\\"\\n   871→\\t}\\n   872→\\n   873→\\t// Get the most recent checkpoint\\n   874→\\tcp := session.Checkpoints[0]\\n   875→\\tif cp.CheckpointID.IsEmpty() {\\n   876→\\t\\treturn \\\"\\\"\\n   877→\\t}\\n   878→\\n   879→\\tstore, err := s.getCheckpointStore()\\n   880→\\tif err != nil {\\n   881→\\t\\treturn \\\"\\\"\\n   882→\\t}\\n   883→\\n   884→\\tcontent, err := store.ReadSessionContentByID(context.Background(), cp.CheckpointID, sessionID)\\n   885→\\tif err != nil || content == nil {\\n   886→\\t\\treturn \\\"\\\"\\n   887→\\t}\\n   888→\\n   889→\\treturn content.Context\\n   890→}\\n   891→\\n   892→// GetCheckpointLog returns the session transcript for a specific checkpoint.\\n   893→// For auto-commit strategy, looks up checkpoint by ID on the entire/checkpoints/v1 branch using the checkpoint store.\\n   894→func (s *AutoCommitStrategy) GetCheckpointLog(cp Checkpoint) ([]byte, error) {\\n   895→\\tif cp.CheckpointID.IsEmpty() {\\n   896→\\t\\treturn nil, ErrNoMetadata\\n   897→\\t}\\n   898→\\n   899→\\tstore, err := s.getCheckpointStore()\\n   900→\\tif err != nil {\\n   901→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   902→\\t}\\n   903→\\n   904→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), cp.CheckpointID)\\n   905→\\tif err != nil {\\n   906→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   907→\\t}\\n   908→\\tif content == nil {\\n   909→\\t\\treturn nil, ErrNoMetadata\\n   910→\\t}\\n   911→\\n   912→\\treturn content.Transcript, nil\\n   913→}\\n   914→\\n   915→// InitializeSession creates session state for a new session.\\n   916→// This is called during UserPromptSubmit hook to set up tracking for the session.\\n   917→// For auto-commit strategy, this creates a SessionState file in .git/entire-sessions/\\n   918→// to track CheckpointTranscriptStart (transcript offset) across checkpoints.\\n   919→// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n   920→// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n   921→// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\n   922→func (s *AutoCommitStrategy) InitializeSession(sessionID string, agentType agent.AgentType, transcriptPath string, userPrompt string) error {\\n   923→\\trepo, err := OpenRepository()\\n   924→\\tif err != nil {\\n   925→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   926→\\t}\\n   927→\\n   928→\\t// Get current HEAD commit to track as base\\n   929→\\thead, err := repo.Head()\\n   930→\\tif err != nil {\\n   931→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   932→\\t}\\n   933→\\n   934→\\tbaseCommit := head.Hash().String()\\n   935→\\n   936→\\t// Check if session state already exists (e.g., session resuming)\\n   937→\\texisting, err := LoadSessionState(sessionID)\\n   938→\\tif err != nil {\\n   939→\\t\\treturn fmt.Errorf(\\\"failed to check existing session state: %w\\\", err)\\n   940→\\t}\\n   941→\\tif existing != nil {\\n   942→\\t\\t// Session already initialized — update last interaction time on every prompt submit\\n   943→\\t\\tnow := time.Now()\\n   944→\\t\\texisting.LastInteractionTime = &now\\n   945→\\n   946→\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n   947→\\t\\tturnID, err := id.Generate()\\n   948→\\t\\tif err != nil {\\n   949→\\t\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n   950→\\t\\t}\\n   951→\\t\\texisting.TurnID = turnID.String()\\n   952→\\t\\texisting.TurnCheckpointIDs = nil\\n   953→\\n   954→\\t\\t// Backfill FirstPrompt if empty (for sessions\\n   955→\\t\\t// created before the first_prompt field was added, or resumed sessions)\\n   956→\\t\\tif existing.FirstPrompt == \\\"\\\" && userPrompt != \\\"\\\" {\\n   957→\\t\\t\\texisting.FirstPrompt = truncatePromptForStorage(userPrompt)\\n   958→\\t\\t}\\n   959→\\n   960→\\t\\tif err := SaveSessionState(existing); err != nil {\\n   961→\\t\\t\\treturn fmt.Errorf(\\\"failed to update session state: %w\\\", err)\\n   962→\\t\\t}\\n   963→\\t\\treturn nil\\n   964→\\t}\\n   965→\\n   966→\\t// Generate TurnID for the first turn\\n   967→\\tturnID, err := id.Generate()\\n   968→\\tif err != nil {\\n   969→\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n   970→\\t}\\n   971→\\n   972→\\t// Create new session state\\n   973→\\tnow := time.Now()\\n   974→\\tstate := &SessionState{\\n   975→\\t\\tSessionID:           sessionID,\\n   976→\\t\\tCLIVersion:          buildinfo.Version,\\n   977→\\t\\tBaseCommit:          baseCommit,\\n   978→\\t\\tStartedAt:           now,\\n   979→\\t\\tLastInteractionTime: &now,\\n   980→\\t\\tTurnID:              turnID.String(),\\n   981→\\t\\tStepCount:           0,\\n   982→\\t\\t// CheckpointTranscriptStart defaults to 0 (start from beginning of transcript)\\n   983→\\t\\tFilesTouched:   []string{},\\n   984→\\t\\tAgentType:      agentType,\\n   985→\\t\\tTranscriptPath: transcriptPath,\\n   986→\\t\\tFirstPrompt:    truncatePromptForStorage(userPrompt),\\n   987→\\t}\\n   988→\\n   989→\\tif err := SaveSessionState(state); err != nil {\\n   990→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   991→\\t}\\n   992→\\n   993→\\treturn nil\\n   994→}\\n   995→\\n   996→// ListOrphanedItems returns orphaned items created by the auto-commit strategy.\\n   997→// For auto-commit, checkpoints are orphaned when no commit has an Entire-Checkpoint\\n   998→// trailer referencing them (e.g., after rebasing or squashing).\\n   999→func (s *AutoCommitStrategy) ListOrphanedItems() ([]CleanupItem, error) {\\n  1000→\\trepo, err := OpenRepository()\\n  1001→\\tif err != nil {\\n  1002→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n  1003→\\t}\\n  1004→\\n  1005→\\t// Get checkpoint store (lazily initialized)\\n  1006→\\tcpStore, err := s.getCheckpointStore()\\n  1007→\\tif err != nil {\\n  1008→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n  1009→\\t}\\n  1010→\\n  1011→\\t// Get all checkpoints from entire/checkpoints/v1 branch\\n  1012→\\tcheckpoints, err := cpStore.ListCommitted(context.Background())\\n  1013→\\tif err != nil {\\n  1014→\\t\\treturn []CleanupItem{}, nil //nolint:nilerr // No checkpoints is not an error for cleanup\\n  1015→\\t}\\n  1016→\\n  1017→\\tif len(checkpoints) == 0 {\\n  1018→\\t\\treturn []CleanupItem{}, nil\\n  1019→\\t}\\n  1020→\\n  1021→\\t// Filter to only auto-commit checkpoints (identified by strategy in metadata)\\n  1022→\\tautoCommitCheckpoints := make(map[string]bool)\\n  1023→\\tfor _, cp := range checkpoints {\\n  1024→\\t\\tsummary, readErr := cpStore.ReadCommitted(context.Background(), cp.CheckpointID)\\n  1025→\\t\\tif readErr != nil || summary == nil {\\n  1026→\\t\\t\\tcontinue\\n  1027→\\t\\t}\\n  1028→\\t\\t// Only consider checkpoints created by this strategy\\n  1029→\\t\\tif summary.Strategy == StrategyNameAutoCommit {\\n  1030→\\t\\t\\tautoCommitCheckpoints[cp.CheckpointID.String()] = true\\n  1031→\\t\\t}\\n  1032→\\t}\\n  1033→\\n  1034→\\tif len(autoCommitCheckpoints) == 0 {\\n  1035→\\t\\treturn []CleanupItem{}, nil\\n  1036→\\t}\\n  1037→\\n  1038→\\t// Find checkpoint IDs referenced in commits\\n  1039→\\treferencedCheckpoints := s.findReferencedCheckpoints(repo)\\n  1040→\\n  1041→\\t// Find orphaned checkpoints\\n  1042→\\tvar items []CleanupItem\\n  1043→\\tfor checkpointID := range autoCommitCheckpoints {\\n  1044→\\t\\tif !referencedCheckpoints[checkpointID] {\\n  1045→\\t\\t\\titems = append(items, CleanupItem{\\n  1046→\\t\\t\\t\\tType:   CleanupTypeCheckpoint,\\n  1047→\\t\\t\\t\\tID:     checkpointID,\\n  1048→\\t\\t\\t\\tReason: \\\"no commit references this checkpoint\\\",\\n  1049→\\t\\t\\t})\\n  1050→\\t\\t}\\n  1051→\\t}\\n  1052→\\n  1053→\\treturn items, nil\\n  1054→}\\n  1055→\\n  1056→// findReferencedCheckpoints scans commits for Entire-Checkpoint trailers.\\n  1057→func (s *AutoCommitStrategy) findReferencedCheckpoints(repo *git.Repository) map[string]bool {\\n  1058→\\treferenced := make(map[string]bool)\\n  1059→\\n  1060→\\trefs, err := repo.References()\\n  1061→\\tif err != nil {\\n  1062→\\t\\treturn referenced\\n  1063→\\t}\\n  1064→\\n  1065→\\tvisited := make(map[plumbing.Hash]bool)\\n  1066→\\n  1067→\\t_ = refs.ForEach(func(ref *plumbing.Reference) error { //nolint:errcheck // Best effort\\n  1068→\\t\\tif !ref.Name().IsBranch() {\\n  1069→\\t\\t\\treturn nil\\n  1070→\\t\\t}\\n  1071→\\t\\t// Skip entire/* branches\\n  1072→\\t\\tbranchName := strings.TrimPrefix(ref.Name().String(), \\\"refs/heads/\\\")\\n  1073→\\t\\tif strings.HasPrefix(branchName, \\\"entire/\\\") {\\n  1074→\\t\\t\\treturn nil\\n  1075→\\t\\t}\\n  1076→\\n  1077→\\t\\titer, iterErr := repo.Log(&git.LogOptions{From: ref.Hash()})\\n  1078→\\t\\tif iterErr != nil {\\n  1079→\\t\\t\\treturn nil //nolint:nilerr // Best effort\\n  1080→\\t\\t}\\n  1081→\\n  1082→\\t\\tcount := 0\\n  1083→\\t\\t_ = iter.ForEach(func(c *object.Commit) error { //nolint:errcheck // Best effort\\n  1084→\\t\\t\\tcount++\\n  1085→\\t\\t\\tif count > 1000 {\\n  1086→\\t\\t\\t\\treturn errors.New(\\\"limit reached\\\")\\n  1087→\\t\\t\\t}\\n  1088→\\t\\t\\tif visited[c.Hash] {\\n  1089→\\t\\t\\t\\treturn nil\\n  1090→\\t\\t\\t}\\n  1091→\\t\\t\\tvisited[c.Hash] = true\\n  1092→\\n  1093→\\t\\t\\tif cpID, found := trailers.ParseCheckpoint(c.Message); found {\\n  1094→\\t\\t\\t\\treferenced[cpID.String()] = true\\n  1095→\\t\\t\\t}\\n  1096→\\t\\t\\treturn nil\\n  1097→\\t\\t})\\n  1098→\\t\\treturn nil\\n  1099→\\t})\\n  1100→\\n  1101→\\treturn referenced\\n  1102→}\\n  1103→\\n  1104→//nolint:gochecknoinits // Standard pattern for strategy registration\\n  1105→func init() {\\n  1106→\\t// Register auto-commit as the primary strategy name\\n  1107→\\tRegister(StrategyNameAutoCommit, NewAutoCommitStrategy)\\n  1108→}\\n  1109→\"}]},\"uuid\":\"8da96ff4-7985-4084-9106-c50320a3ff94\",\"timestamp\":\"2026-02-20T17:54:03.781Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/dip/Repositories/cli/cmd/entire/cli/strategy/auto_commit.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"sync\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/buildinfo\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// isNotFoundError checks if an error represents a \\\"not found\\\" condition in go-git.\\n// This includes entry not found, file not found, directory not found, and object not found.\\nfunc isNotFoundError(err error) bool {\\n\\treturn errors.Is(err, object.ErrEntryNotFound) ||\\n\\t\\terrors.Is(err, object.ErrFileNotFound) ||\\n\\t\\terrors.Is(err, object.ErrDirectoryNotFound) ||\\n\\t\\terrors.Is(err, plumbing.ErrObjectNotFound) ||\\n\\t\\terrors.Is(err, plumbing.ErrReferenceNotFound)\\n}\\n\\n// commitOrHead attempts to create a commit. If the commit would be empty (files already\\n// committed), it returns HEAD hash instead. This handles the case where files were\\n// modified during a session but already committed by the user before the hook runs.\\nfunc commitOrHead(repo *git.Repository, worktree *git.Worktree, msg string, author *object.Signature) (plumbing.Hash, error) {\\n\\tcommitHash, err := worktree.Commit(msg, &git.CommitOptions{Author: author})\\n\\tif errors.Is(err, git.ErrEmptyCommit) {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"No changes to commit (files already committed)\\\\n\\\")\\n\\t\\thead, err := repo.Head()\\n\\t\\tif err != nil {\\n\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n\\t\\t}\\n\\t\\treturn head.Hash(), nil\\n\\t}\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to commit: %w\\\", err)\\n\\t}\\n\\treturn commitHash, nil\\n}\\n\\n// AutoCommitStrategy implements the auto-commit strategy:\\n// - Code changes are committed to the active branch (like commit strategy)\\n// - Session logs are committed to a shadow branch (like manual-commit strategy)\\n// - Code commits can reference the shadow branch via trailers\\ntype AutoCommitStrategy struct {\\n\\t// checkpointStore manages checkpoint data on entire/checkpoints/v1 branch\\n\\tcheckpointStore *checkpoint.GitStore\\n\\t// checkpointStoreOnce ensures thread-safe lazy initialization\\n\\tcheckpointStoreOnce sync.Once\\n\\t// checkpointStoreErr captures any error during initialization\\n\\tcheckpointStoreErr error\\n}\\n\\n// getCheckpointStore returns the checkpoint store, initializing it lazily if needed.\\n// Thread-safe via sync.Once.\\nfunc (s *AutoCommitStrategy) getCheckpointStore() (*checkpoint.GitStore, error) {\\n\\ts.checkpointStoreOnce.Do(func() {\\n\\t\\trepo, err := OpenRepository()\\n\\t\\tif err != nil {\\n\\t\\t\\ts.checkpointStoreErr = fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t\\t\\treturn\\n\\t\\t}\\n\\t\\ts.checkpointStore = checkpoint.NewGitStore(repo)\\n\\t})\\n\\treturn s.checkpointStore, s.checkpointStoreErr\\n}\\n\\n// NewAutoCommitStrategy creates a new AutoCommitStrategy instance.\\n//\\n\\nfunc NewAutoCommitStrategy() Strategy {\\n\\treturn &AutoCommitStrategy{}\\n}\\n\\nfunc (s *AutoCommitStrategy) Name() string {\\n\\treturn StrategyNameAutoCommit\\n}\\n\\nfunc (s *AutoCommitStrategy) Description() string {\\n\\treturn \\\"Auto-commits code to active branch with metadata on entire/checkpoints/v1\\\"\\n}\\n\\nfunc (s *AutoCommitStrategy) ValidateRepository() error {\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n\\t}\\n\\n\\t_, err = repo.Worktree()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to access worktree: %w\\\", err)\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// PrePush is called by the git pre-push hook before pushing to a remote.\\n// It pushes the entire/checkpoints/v1 branch alongside the user's push.\\n// Configuration options (stored in .entire/settings.json under strategy_options.push_sessions):\\n//   - \\\"auto\\\": always push automatically\\n//   - \\\"prompt\\\" (default): ask user with option to enable auto\\n//   - \\\"false\\\"/\\\"off\\\"/\\\"no\\\": never push\\nfunc (s *AutoCommitStrategy) PrePush(remote string) error {\\n\\tif err := pushSessionsBranchCommon(remote, paths.MetadataBranchName); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\treturn PushTrailsBranch(remote)\\n}\\n\\nfunc (s *AutoCommitStrategy) SaveStep(ctx StepContext) error {\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n\\t}\\n\\n\\t// Generate checkpoint ID for this commit\\n\\tcpID, err := id.Generate()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n\\t}\\n\\t// Step 1: Commit code changes to active branch with checkpoint ID trailer\\n\\t// We do code first to avoid orphaned metadata if this step fails.\\n\\t// If metadata commit fails after this, the code commit exists but GetRewindPoints\\n\\t// already handles missing metadata gracefully (skips commits without metadata).\\n\\tcodeResult, err := s.commitCodeToActive(repo, ctx, cpID)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to commit code to active branch: %w\\\", err)\\n\\t}\\n\\n\\t// If no code commit was created (no changes), skip metadata creation\\n\\t// This prevents orphaned metadata commits that don't correspond to any code commit\\n\\tif !codeResult.Created {\\n\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n\\t\\tlogging.Info(logCtx, \\\"checkpoint skipped (no changes)\\\",\\n\\t\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n\\t\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"session\\\"),\\n\\t\\t)\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipped checkpoint (no changes since last commit)\\\\n\\\")\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Step 2: Commit metadata to entire/checkpoints/v1 branch using sharded path\\n\\t// Path is <checkpointID[:2]>/<checkpointID[2:]>/ for direct lookup\\n\\t_, err = s.commitMetadataToMetadataBranch(repo, ctx, cpID)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to commit metadata to entire/checkpoints/v1 branch: %w\\\", err)\\n\\t}\\n\\n\\t// Log checkpoint creation\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n\\tlogging.Info(logCtx, \\\"checkpoint saved\\\",\\n\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"session\\\"),\\n\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n\\t\\tslog.Int(\\\"modified_files\\\", len(ctx.ModifiedFiles)),\\n\\t\\tslog.Int(\\\"new_files\\\", len(ctx.NewFiles)),\\n\\t\\tslog.Int(\\\"deleted_files\\\", len(ctx.DeletedFiles)),\\n\\t)\\n\\n\\treturn nil\\n}\\n\\n// commitCodeResult contains the result of committing code to the active branch.\\ntype commitCodeResult struct {\\n\\tCommitHash plumbing.Hash\\n\\tCreated    bool // True if a new commit was created, false if skipped (no changes)\\n}\\n\\n// commitCodeToActive commits code changes to the active branch.\\n// Adds an Entire-Checkpoint trailer for metadata lookup that survives amend/rebase.\\n// Returns the result containing commit hash and whether a commit was created.\\nfunc (s *AutoCommitStrategy) commitCodeToActive(repo *git.Repository, ctx StepContext, checkpointID id.CheckpointID) (commitCodeResult, error) {\\n\\t// Check if there are any code changes to commit\\n\\tif len(ctx.ModifiedFiles) == 0 && len(ctx.NewFiles) == 0 && len(ctx.DeletedFiles) == 0 {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"No code changes to commit to active branch\\\\n\\\")\\n\\t\\t// Return current HEAD hash but mark as not created\\n\\t\\thead, err := repo.Head()\\n\\t\\tif err != nil {\\n\\t\\t\\treturn commitCodeResult{}, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n\\t\\t}\\n\\t\\treturn commitCodeResult{CommitHash: head.Hash(), Created: false}, nil\\n\\t}\\n\\n\\tworktree, err := repo.Worktree()\\n\\tif err != nil {\\n\\t\\treturn commitCodeResult{}, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n\\t}\\n\\n\\t// Get HEAD hash before commit to detect if commitOrHead actually creates a new commit\\n\\t// (commitOrHead returns HEAD hash without error when git.ErrEmptyCommit occurs)\\n\\theadBefore, err := repo.Head()\\n\\tif err != nil {\\n\\t\\treturn commitCodeResult{}, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n\\t}\\n\\n\\t// Stage code changes\\n\\tStageFiles(worktree, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles, StageForSession)\\n\\n\\t// Add checkpoint ID trailer to commit message\\n\\tcommitMsg := ctx.CommitMessage + \\\"\\\\n\\\\n\\\" + trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n\\n\\tauthor := &object.Signature{\\n\\t\\tName:  ctx.AuthorName,\\n\\t\\tEmail: ctx.AuthorEmail,\\n\\t\\tWhen:  time.Now(),\\n\\t}\\n\\tcommitHash, err := commitOrHead(repo, worktree, commitMsg, author)\\n\\tif err != nil {\\n\\t\\treturn commitCodeResult{}, err\\n\\t}\\n\\n\\t// Check if a new commit was actually created by comparing with HEAD before\\n\\tcreated := commitHash != headBefore.Hash()\\n\\tif created {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed code changes to active branch (%s)\\\\n\\\", commitHash.String()[:7])\\n\\t}\\n\\treturn commitCodeResult{CommitHash: commitHash, Created: created}, nil\\n}\\n\\n// commitMetadataToMetadataBranch commits session metadata to the entire/checkpoints/v1 branch.\\n// Metadata is stored at sharded path: <checkpointID[:2]>/<checkpointID[2:]>/\\n// This allows direct lookup from the checkpoint ID trailer on the code commit.\\n// Uses checkpoint.WriteCommitted for git operations.\\nfunc (s *AutoCommitStrategy) commitMetadataToMetadataBranch(repo *git.Repository, ctx StepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Extract session ID from metadata dir\\n\\tsessionID := filepath.Base(ctx.MetadataDir)\\n\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Combine all file changes into FilesTouched (same as manual-commit)\\n\\tfilesTouched := mergeFilesTouched(nil, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles)\\n\\n\\t// Load TurnID from session state (correlates checkpoints from the same turn)\\n\\tvar turnID string\\n\\tif state, loadErr := LoadSessionState(sessionID); loadErr == nil && state != nil {\\n\\t\\tturnID = state.TurnID\\n\\t}\\n\\n\\t// Write committed checkpoint using the checkpoint store\\n\\t// Pass TranscriptPath so writeTranscript generates content_hash.txt\\n\\ttranscriptPath := filepath.Join(ctx.MetadataDirAbs, paths.TranscriptFileName)\\n\\terr = store.WriteCommitted(context.Background(), checkpoint.WriteCommittedOptions{\\n\\t\\tCheckpointID:                checkpointID,\\n\\t\\tSessionID:                   sessionID,\\n\\t\\tStrategy:                    StrategyNameAutoCommit, // Use new strategy name\\n\\t\\tBranch:                      branchName,\\n\\t\\tMetadataDir:                 ctx.MetadataDirAbs, // Copy all files from metadata dir\\n\\t\\tTranscriptPath:              transcriptPath,     // For content hash generation\\n\\t\\tAuthorName:                  ctx.AuthorName,\\n\\t\\tAuthorEmail:                 ctx.AuthorEmail,\\n\\t\\tAgent:                       ctx.AgentType,\\n\\t\\tTurnID:                      turnID,\\n\\t\\tTranscriptIdentifierAtStart: ctx.StepTranscriptIdentifier,\\n\\t\\tCheckpointTranscriptStart:   ctx.StepTranscriptStart,\\n\\t\\tTokenUsage:                  ctx.TokenUsage,\\n\\t\\tCheckpointsCount:            1,            // Each auto-commit checkpoint = 1\\n\\t\\tFilesTouched:                filesTouched, // Track modified files (same as manual-commit)\\n\\t})\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write committed checkpoint: %w\\\", err)\\n\\t}\\n\\n\\tfmt.Fprintf(os.Stderr, \\\"Committed session metadata to %s (%s)\\\\n\\\", paths.MetadataBranchName, checkpointID)\\n\\treturn plumbing.ZeroHash, nil // Commit hash not needed by callers\\n}\\n\\nfunc (s *AutoCommitStrategy) GetRewindPoints(limit int) ([]RewindPoint, error) {\\n\\t// For auto-commit strategy, rewind points are found by looking for Entire-Checkpoint trailers\\n\\t// in the current branch's commit history. The checkpoint ID provides direct lookup\\n\\t// to metadata on entire/checkpoints/v1 branch.\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n\\t}\\n\\n\\thead, err := repo.Head()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n\\t}\\n\\n\\t// Get metadata branch tree for lookups\\n\\tmetadataTree, err := GetMetadataBranchTree(repo)\\n\\tif err != nil {\\n\\t\\t// No metadata branch yet is fine\\n\\t\\treturn []RewindPoint{}, nil //nolint:nilerr // Expected when no metadata exists\\n\\t}\\n\\n\\t// Get the main branch commit hash to determine branch-only commits\\n\\tmainBranchHash := GetMainBranchHash(repo)\\n\\n\\t// Walk current branch history looking for commits with checkpoint trailers\\n\\titer, err := repo.Log(&git.LogOptions{\\n\\t\\tFrom:  head.Hash(),\\n\\t\\tOrder: git.LogOrderCommitterTime,\\n\\t})\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n\\t}\\n\\n\\tvar points []RewindPoint\\n\\tcount := 0\\n\\n\\terr = iter.ForEach(func(c *object.Commit) error {\\n\\t\\tif count >= logsOnlyScanLimit || len(points) >= limit {\\n\\t\\t\\treturn errStop\\n\\t\\t}\\n\\t\\tcount++\\n\\n\\t\\t// Check for Entire-Checkpoint trailer\\n\\t\\tcpID, found := trailers.ParseCheckpoint(c.Message)\\n\\t\\tif !found {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\t// Look up metadata from sharded path\\n\\t\\tcheckpointPath := cpID.Path()\\n\\t\\tmetadata, err := ReadCheckpointMetadata(metadataTree, checkpointPath)\\n\\t\\tif err != nil {\\n\\t\\t\\t// Checkpoint exists in commit but no metadata found - skip this commit\\n\\t\\t\\treturn nil //nolint:nilerr // Intentional: skip commits without metadata\\n\\t\\t}\\n\\n\\t\\tmessage := strings.Split(c.Message, \\\"\\\\n\\\")[0]\\n\\n\\t\\t// Determine if this is a full rewind or logs-only\\n\\t\\t// Full rewind is allowed if commit is only on this branch (not reachable from main)\\n\\t\\tisLogsOnly := false\\n\\t\\tif mainBranchHash != plumbing.ZeroHash {\\n\\t\\t\\tif IsAncestorOf(repo, c.Hash, mainBranchHash) {\\n\\t\\t\\t\\tisLogsOnly = true\\n\\t\\t\\t}\\n\\t\\t}\\n\\n\\t\\t// Build metadata path - for task checkpoints, include the task path\\n\\t\\tmetadataDir := checkpointPath\\n\\t\\tif metadata.IsTask && metadata.ToolUseID != \\\"\\\" {\\n\\t\\t\\tmetadataDir = checkpointPath + \\\"/tasks/\\\" + metadata.ToolUseID\\n\\t\\t}\\n\\n\\t\\t// Read session prompt from metadata tree\\n\\t\\tsessionPrompt := ReadSessionPromptFromTree(metadataTree, checkpointPath)\\n\\n\\t\\tpoints = append(points, RewindPoint{\\n\\t\\t\\tID:               c.Hash.String(),\\n\\t\\t\\tMessage:          message,\\n\\t\\t\\tMetadataDir:      metadataDir,\\n\\t\\t\\tDate:             c.Author.When,\\n\\t\\t\\tIsLogsOnly:       isLogsOnly,\\n\\t\\t\\tCheckpointID:     cpID,\\n\\t\\t\\tIsTaskCheckpoint: metadata.IsTask,\\n\\t\\t\\tToolUseID:        metadata.ToolUseID,\\n\\t\\t\\tAgent:            metadata.Agent,\\n\\t\\t\\tSessionID:        metadata.SessionID,\\n\\t\\t\\tSessionPrompt:    sessionPrompt,\\n\\t\\t})\\n\\n\\t\\treturn nil\\n\\t})\\n\\n\\tif err != nil && !errors.Is(err, errStop) {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to iterate commits: %w\\\", err)\\n\\t}\\n\\n\\treturn points, nil\\n}\\n\\n// findTaskMetadataPathForCommit looks up the task metadata path for a task checkpoint commit\\n// by searching the entire/checkpoints/v1 branch commit history for the checkpoint directory.\\n// Returns (\\\"\\\", nil) if metadata is not found - this is expected for commits without metadata.\\nfunc (s *AutoCommitStrategy) findTaskMetadataPathForCommit(repo *git.Repository, commitSHA, toolUseID string) (string, error) {\\n\\t// Get the entire/checkpoints/v1 branch\\n\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\tif isNotFoundError(err) {\\n\\t\\t\\treturn \\\"\\\", nil // No metadata branch yet\\n\\t\\t}\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get metadata branch: %w\\\", err)\\n\\t}\\n\\n\\t// Search commit history for a commit referencing this code commit SHA and tool use ID\\n\\tshortSHA := commitSHA\\n\\tif len(shortSHA) > 7 {\\n\\t\\tshortSHA = shortSHA[:7]\\n\\t}\\n\\n\\titer, err := repo.Log(&git.LogOptions{From: ref.Hash()})\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n\\t}\\n\\n\\tvar foundTaskPath string\\n\\terr = iter.ForEach(func(commit *object.Commit) error {\\n\\t\\t// Check if commit message contains \\\"Commit: <sha>\\\" and the tool use ID\\n\\t\\tif strings.Contains(commit.Message, \\\"Commit: \\\"+shortSHA) &&\\n\\t\\t\\tstrings.Contains(commit.Message, toolUseID) {\\n\\t\\t\\t// Parse task metadata trailer\\n\\t\\t\\tif taskPath, found := trailers.ParseTaskMetadata(commit.Message); found {\\n\\t\\t\\t\\tfoundTaskPath = taskPath\\n\\t\\t\\t\\treturn errStop // Found it\\n\\t\\t\\t}\\n\\t\\t}\\n\\t\\treturn nil\\n\\t})\\n\\tif err != nil && !errors.Is(err, errStop) {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to iterate commits: %w\\\", err)\\n\\t}\\n\\n\\treturn foundTaskPath, nil\\n}\\n\\nfunc (s *AutoCommitStrategy) Rewind(point RewindPoint) error {\\n\\tcommitHash := plumbing.NewHash(point.ID)\\n\\tshortID, err := HardResetWithProtection(commitHash)\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\tfmt.Println()\\n\\tfmt.Printf(\\\"Reset to commit %s\\\\n\\\", shortID)\\n\\tfmt.Println()\\n\\n\\treturn nil\\n}\\n\\nfunc (s *AutoCommitStrategy) CanRewind() (bool, string, error) {\\n\\treturn checkCanRewind()\\n}\\n\\n// PreviewRewind returns what will happen if rewinding to the given point.\\n// For auto-commit strategy, this returns nil since git reset doesn't delete untracked files.\\nfunc (s *AutoCommitStrategy) PreviewRewind(_ RewindPoint) (*RewindPreview, error) {\\n\\t// Auto-commit uses git reset --hard which doesn't affect untracked files\\n\\t// Return empty preview to indicate no untracked files will be deleted\\n\\treturn &RewindPreview{}, nil\\n}\\n\\n// EnsureSetup ensures the strategy's required setup is in place.\\n// For auto-commit strategy:\\n// - Ensure .entire/.gitignore has all required entries\\n// - Create orphan entire/checkpoints/v1 branch if it doesn't exist\\n// - Install git hooks if missing (self-healing for third-party overwrites)\\nfunc (s *AutoCommitStrategy) EnsureSetup() error {\\n\\tif err := EnsureEntireGitignore(); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n\\t}\\n\\n\\t// Ensure the entire/checkpoints/v1 orphan branch exists\\n\\tif err := EnsureMetadataBranch(repo); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n\\t}\\n\\n\\t// Install generic hooks if missing (they delegate to strategy at runtime)\\n\\tif !IsGitHookInstalled() {\\n\\t\\tif _, err := InstallGitHook(true); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// GetSessionInfo returns session information for linking commits.\\n// For auto-commit strategy, we don't track active sessions - metadata is stored on\\n// entire/checkpoints/v1 branch when SaveStep is called. Active branch commits\\n// are kept clean (no trailers), so this returns ErrNoSession.\\n// Use ListSessions() or GetSession() to retrieve session info from the metadata branch.\\nfunc (s *AutoCommitStrategy) GetSessionInfo() (*SessionInfo, error) {\\n\\t// Dual strategy doesn't track active sessions like shadow does.\\n\\t// Session metadata is stored on entire/checkpoints/v1 branch and can be\\n\\t// retrieved via ListSessions() or GetSession().\\n\\treturn nil, ErrNoSession\\n}\\n\\n// SaveTaskStep creates a checkpoint commit for a completed task.\\n// For auto-commit strategy:\\n// 1. Commit code changes to active branch (no trailers - clean history)\\n// 2. Commit task metadata to entire/checkpoints/v1 branch with checkpoint format\\nfunc (s *AutoCommitStrategy) SaveTaskStep(ctx TaskStepContext) error {\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n\\t}\\n\\n\\t// Ensure entire/checkpoints/v1 branch exists\\n\\tif err := EnsureMetadataBranch(repo); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n\\t}\\n\\n\\t// Generate checkpoint ID for this task checkpoint\\n\\tcpID, err := id.Generate()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n\\t}\\n\\n\\t// Step 1: Commit code changes to active branch with checkpoint ID trailer\\n\\t// We do code first to avoid orphaned metadata if this step fails.\\n\\t_, err = s.commitTaskCodeToActive(repo, ctx, cpID)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to commit task code to active branch: %w\\\", err)\\n\\t}\\n\\n\\t// Step 2: Commit task metadata to entire/checkpoints/v1 branch at sharded path\\n\\t_, err = s.commitTaskMetadataToMetadataBranch(repo, ctx, cpID)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to commit task metadata to entire/checkpoints/v1 branch: %w\\\", err)\\n\\t}\\n\\n\\t// Log task checkpoint creation\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n\\tattrs := []any{\\n\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"task\\\"),\\n\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n\\t\\tslog.String(\\\"checkpoint_uuid\\\", ctx.CheckpointUUID),\\n\\t\\tslog.String(\\\"tool_use_id\\\", ctx.ToolUseID),\\n\\t\\tslog.String(\\\"subagent_type\\\", ctx.SubagentType),\\n\\t\\tslog.Int(\\\"modified_files\\\", len(ctx.ModifiedFiles)),\\n\\t\\tslog.Int(\\\"new_files\\\", len(ctx.NewFiles)),\\n\\t\\tslog.Int(\\\"deleted_files\\\", len(ctx.DeletedFiles)),\\n\\t}\\n\\tif ctx.IsIncremental {\\n\\t\\tattrs = append(attrs,\\n\\t\\t\\tslog.Bool(\\\"is_incremental\\\", true),\\n\\t\\t\\tslog.String(\\\"incremental_type\\\", ctx.IncrementalType),\\n\\t\\t\\tslog.Int(\\\"incremental_sequence\\\", ctx.IncrementalSequence),\\n\\t\\t)\\n\\t}\\n\\tlogging.Info(logCtx, \\\"task checkpoint saved\\\", attrs...)\\n\\n\\treturn nil\\n}\\n\\n// commitTaskCodeToActive commits task code changes to the active branch.\\n// Adds an Entire-Checkpoint trailer for metadata lookup that survives amend/rebase.\\n// Skips commit creation if there are no file changes.\\nfunc (s *AutoCommitStrategy) commitTaskCodeToActive(repo *git.Repository, ctx TaskStepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n\\thasFileChanges := len(ctx.ModifiedFiles) > 0 || len(ctx.NewFiles) > 0 || len(ctx.DeletedFiles) > 0\\n\\n\\t// If no file changes, skip code commit\\n\\tif !hasFileChanges {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"No code changes to commit for task checkpoint\\\\n\\\")\\n\\t\\t// Return current HEAD hash so metadata can still be stored\\n\\t\\thead, err := repo.Head()\\n\\t\\tif err != nil {\\n\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n\\t\\t}\\n\\t\\treturn head.Hash(), nil\\n\\t}\\n\\n\\tworktree, err := repo.Worktree()\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n\\t}\\n\\n\\t// Stage code changes\\n\\tStageFiles(worktree, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles, StageForTask)\\n\\n\\t// Build commit message with checkpoint trailer\\n\\tshortToolUseID := ctx.ToolUseID\\n\\tif len(shortToolUseID) > id.ShortIDLength {\\n\\t\\tshortToolUseID = shortToolUseID[:id.ShortIDLength]\\n\\t}\\n\\n\\tvar subject string\\n\\tif ctx.IsIncremental {\\n\\t\\tsubject = FormatIncrementalSubject(\\n\\t\\t\\tctx.IncrementalType,\\n\\t\\t\\tctx.SubagentType,\\n\\t\\t\\tctx.TaskDescription,\\n\\t\\t\\tctx.TodoContent,\\n\\t\\t\\tctx.IncrementalSequence,\\n\\t\\t\\tshortToolUseID,\\n\\t\\t)\\n\\t} else {\\n\\t\\tsubject = FormatSubagentEndMessage(ctx.SubagentType, ctx.TaskDescription, shortToolUseID)\\n\\t}\\n\\n\\t// Add checkpoint ID trailer to commit message\\n\\tcommitMsg := subject + \\\"\\\\n\\\\n\\\" + trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n\\n\\tauthor := &object.Signature{\\n\\t\\tName:  ctx.AuthorName,\\n\\t\\tEmail: ctx.AuthorEmail,\\n\\t\\tWhen:  time.Now(),\\n\\t}\\n\\n\\tcommitHash, err := commitOrHead(repo, worktree, commitMsg, author)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, err\\n\\t}\\n\\n\\tif ctx.IsIncremental {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed incremental checkpoint #%d to active branch (%s)\\\\n\\\", ctx.IncrementalSequence, commitHash.String()[:7])\\n\\t} else {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed task checkpoint to active branch (%s)\\\\n\\\", commitHash.String()[:7])\\n\\t}\\n\\treturn commitHash, nil\\n}\\n\\n// commitTaskMetadataToMetadataBranch commits task metadata to the entire/checkpoints/v1 branch.\\n// Uses sharded path: <checkpointID[:2]>/<checkpointID[2:]>/tasks/<tool-use-id>/\\n// Returns the metadata commit hash.\\n// When IsIncremental is true, only writes the incremental checkpoint file, skipping transcripts.\\n// Uses checkpoint.WriteCommitted for git operations.\\nfunc (s *AutoCommitStrategy) commitTaskMetadataToMetadataBranch(repo *git.Repository, ctx TaskStepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Format commit subject line for better git log readability\\n\\tshortToolUseID := ctx.ToolUseID\\n\\tif len(shortToolUseID) > id.ShortIDLength {\\n\\t\\tshortToolUseID = shortToolUseID[:id.ShortIDLength]\\n\\t}\\n\\n\\tvar messageSubject string\\n\\tif ctx.IsIncremental {\\n\\t\\tmessageSubject = FormatIncrementalSubject(\\n\\t\\t\\tctx.IncrementalType,\\n\\t\\t\\tctx.SubagentType,\\n\\t\\t\\tctx.TaskDescription,\\n\\t\\t\\tctx.TodoContent,\\n\\t\\t\\tctx.IncrementalSequence,\\n\\t\\t\\tshortToolUseID,\\n\\t\\t)\\n\\t} else {\\n\\t\\tmessageSubject = FormatSubagentEndMessage(ctx.SubagentType, ctx.TaskDescription, shortToolUseID)\\n\\t}\\n\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Write committed checkpoint using the checkpoint store\\n\\terr = store.WriteCommitted(context.Background(), checkpoint.WriteCommittedOptions{\\n\\t\\tCheckpointID:           checkpointID,\\n\\t\\tSessionID:              ctx.SessionID,\\n\\t\\tStrategy:               StrategyNameAutoCommit,\\n\\t\\tBranch:                 branchName,\\n\\t\\tIsTask:                 true,\\n\\t\\tToolUseID:              ctx.ToolUseID,\\n\\t\\tAgentID:                ctx.AgentID,\\n\\t\\tCheckpointUUID:         ctx.CheckpointUUID,\\n\\t\\tTranscriptPath:         ctx.TranscriptPath,\\n\\t\\tSubagentTranscriptPath: ctx.SubagentTranscriptPath,\\n\\t\\tIsIncremental:          ctx.IsIncremental,\\n\\t\\tIncrementalSequence:    ctx.IncrementalSequence,\\n\\t\\tIncrementalType:        ctx.IncrementalType,\\n\\t\\tIncrementalData:        ctx.IncrementalData,\\n\\t\\tCommitSubject:          messageSubject,\\n\\t\\tAuthorName:             ctx.AuthorName,\\n\\t\\tAuthorEmail:            ctx.AuthorEmail,\\n\\t\\tAgent:                  ctx.AgentType,\\n\\t})\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write task checkpoint: %w\\\", err)\\n\\t}\\n\\n\\tif ctx.IsIncremental {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed incremental checkpoint metadata to %s (%s)\\\\n\\\", paths.MetadataBranchName, checkpointID)\\n\\t} else {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed task metadata to %s (%s)\\\\n\\\", paths.MetadataBranchName, checkpointID)\\n\\t}\\n\\treturn plumbing.ZeroHash, nil // Commit hash not needed by callers\\n}\\n\\n// GetTaskCheckpoint returns the task checkpoint for a given rewind point.\\n// For auto-commit strategy, checkpoints are stored on the entire/checkpoints/v1 branch in checkpoint directories.\\n// Returns ErrNotTaskCheckpoint if the point is not a task checkpoint.\\nfunc (s *AutoCommitStrategy) GetTaskCheckpoint(point RewindPoint) (*TaskCheckpoint, error) {\\n\\tif !point.IsTaskCheckpoint {\\n\\t\\treturn nil, ErrNotTaskCheckpoint\\n\\t}\\n\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\t// Get the entire/checkpoints/v1 branch\\n\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"metadata branch %s not found: %w\\\", paths.MetadataBranchName, err)\\n\\t}\\n\\n\\tmetadataCommit, err := repo.CommitObject(ref.Hash())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch commit: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := metadataCommit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata tree: %w\\\", err)\\n\\t}\\n\\n\\t// Find checkpoint using the metadata path from rewind point\\n\\t// MetadataDir for auto-commit task checkpoints is: cond-YYYYMMDD-HHMMSS-XXXXXXXX/tasks/<tool-use-id>\\n\\tcheckpointPath := point.MetadataDir + \\\"/checkpoint.json\\\"\\n\\tfile, err := tree.File(checkpointPath)\\n\\tif err != nil {\\n\\t\\t// Try finding via commit SHA lookup\\n\\t\\ttaskCheckpointPath, findErr := s.findTaskCheckpointPath(repo, point.ID, point.ToolUseID)\\n\\t\\tif findErr != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", checkpointPath, err)\\n\\t\\t}\\n\\t\\tfile, err = tree.File(taskCheckpointPath)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", taskCheckpointPath, err)\\n\\t\\t}\\n\\t}\\n\\n\\tcontent, err := file.Contents()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\n\\tvar checkpoint TaskCheckpoint\\n\\tif err := json.Unmarshal([]byte(content), &checkpoint); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to parse checkpoint: %w\\\", err)\\n\\t}\\n\\n\\treturn &checkpoint, nil\\n}\\n\\n// GetTaskCheckpointTranscript returns the session transcript for a task checkpoint.\\n// For auto-commit strategy, transcripts are stored on the entire/checkpoints/v1 branch in checkpoint directories.\\n// Returns ErrNotTaskCheckpoint if the point is not a task checkpoint.\\nfunc (s *AutoCommitStrategy) GetTaskCheckpointTranscript(point RewindPoint) ([]byte, error) {\\n\\tif !point.IsTaskCheckpoint {\\n\\t\\treturn nil, ErrNotTaskCheckpoint\\n\\t}\\n\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\t// Get the entire/checkpoints/v1 branch\\n\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"metadata branch %s not found: %w\\\", paths.MetadataBranchName, err)\\n\\t}\\n\\n\\tmetadataCommit, err := repo.CommitObject(ref.Hash())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch commit: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := metadataCommit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata tree: %w\\\", err)\\n\\t}\\n\\n\\t// MetadataDir for auto-commit task checkpoints is: <id[:2]>/<id[2:]>/tasks/<tool-use-id>\\n\\t// Extract the checkpoint path by removing \\\"/tasks/<tool-use-id>\\\"\\n\\tmetadataDir := point.MetadataDir\\n\\tif idx := strings.Index(metadataDir, \\\"/tasks/\\\"); idx > 0 {\\n\\t\\tcheckpointPath := metadataDir[:idx]\\n\\n\\t\\t// Use the first session's transcript path from sessions array\\n\\t\\ttranscriptPath := \\\"\\\"\\n\\t\\tsummaryFile, summaryErr := tree.File(checkpointPath + \\\"/\\\" + paths.MetadataFileName)\\n\\t\\tif summaryErr == nil {\\n\\t\\t\\tsummaryContent, contentErr := summaryFile.Contents()\\n\\t\\t\\tif contentErr == nil {\\n\\t\\t\\t\\tvar summary checkpoint.CheckpointSummary\\n\\t\\t\\t\\tif json.Unmarshal([]byte(summaryContent), &summary) == nil && len(summary.Sessions) > 0 {\\n\\t\\t\\t\\t\\t// Use first session's transcript path (task checkpoints have only one session)\\n\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n\\t\\t\\t\\t\\tif summary.Sessions[0].Transcript != \\\"\\\" {\\n\\t\\t\\t\\t\\t\\ttranscriptPath = strings.TrimPrefix(summary.Sessions[0].Transcript, \\\"/\\\")\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\n\\t\\t// Fall back to old format if sessions map not available\\n\\t\\tif transcriptPath == \\\"\\\" {\\n\\t\\t\\ttranscriptPath = checkpointPath + \\\"/\\\" + paths.TranscriptFileName\\n\\t\\t}\\n\\n\\t\\tfile, err := tree.File(transcriptPath)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find transcript at %s: %w\\\", transcriptPath, err)\\n\\t\\t}\\n\\t\\tcontent, err := file.Contents()\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n\\t\\t}\\n\\t\\treturn []byte(content), nil\\n\\t}\\n\\n\\treturn nil, fmt.Errorf(\\\"invalid metadata path format: %s\\\", metadataDir)\\n}\\n\\n// findTaskCheckpointPath finds the full path to a task checkpoint on the entire/checkpoints/v1 branch.\\n// Searches checkpoint directories for the task checkpoint matching the commit SHA and tool use ID.\\nfunc (s *AutoCommitStrategy) findTaskCheckpointPath(repo *git.Repository, commitSHA, toolUseID string) (string, error) {\\n\\t// Use findTaskMetadataPathForCommit which searches commit history\\n\\ttaskPath, err := s.findTaskMetadataPathForCommit(repo, commitSHA, toolUseID)\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", err\\n\\t}\\n\\tif taskPath == \\\"\\\" {\\n\\t\\treturn \\\"\\\", errors.New(\\\"task checkpoint not found\\\")\\n\\t}\\n\\t// taskPath is like: cond-YYYYMMDD-HHMMSS-XXXXXXXX/tasks/<tool-use-id>/checkpoints/001-<tool-use-id>.json\\n\\t// We need: cond-YYYYMMDD-HHMMSS-XXXXXXXX/tasks/<tool-use-id>/checkpoint.json\\n\\tif idx := strings.Index(taskPath, \\\"/checkpoints/\\\"); idx > 0 {\\n\\t\\treturn taskPath[:idx] + \\\"/checkpoint.json\\\", nil\\n\\t}\\n\\treturn taskPath + \\\"/checkpoint.json\\\", nil\\n}\\n\\n// GetMetadataRef returns a reference to the metadata for the given checkpoint.\\n// For auto-commit strategy, returns the checkpoint path on entire/checkpoints/v1 branch.\\nfunc (s *AutoCommitStrategy) GetMetadataRef(checkpoint Checkpoint) string {\\n\\tif checkpoint.CheckpointID.IsEmpty() {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\treturn paths.MetadataBranchName + \\\":\\\" + checkpoint.CheckpointID.Path()\\n}\\n\\n// GetSessionMetadataRef returns a reference to the most recent metadata for a session.\\nfunc (s *AutoCommitStrategy) GetSessionMetadataRef(sessionID string) string {\\n\\tsession, err := GetSession(sessionID)\\n\\tif err != nil || len(session.Checkpoints) == 0 {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\t// Checkpoints are ordered with most recent first\\n\\treturn s.GetMetadataRef(session.Checkpoints[0])\\n}\\n\\n// GetSessionContext returns the context.md content for a session.\\n// For auto-commit strategy, reads from the entire/checkpoints/v1 branch using the checkpoint store.\\nfunc (s *AutoCommitStrategy) GetSessionContext(sessionID string) string {\\n\\tsession, err := GetSession(sessionID)\\n\\tif err != nil || len(session.Checkpoints) == 0 {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\n\\t// Get the most recent checkpoint\\n\\tcp := session.Checkpoints[0]\\n\\tif cp.CheckpointID.IsEmpty() {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\n\\tcontent, err := store.ReadSessionContentByID(context.Background(), cp.CheckpointID, sessionID)\\n\\tif err != nil || content == nil {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\n\\treturn content.Context\\n}\\n\\n// GetCheckpointLog returns the session transcript for a specific checkpoint.\\n// For auto-commit strategy, looks up checkpoint by ID on the entire/checkpoints/v1 branch using the checkpoint store.\\nfunc (s *AutoCommitStrategy) GetCheckpointLog(cp Checkpoint) ([]byte, error) {\\n\\tif cp.CheckpointID.IsEmpty() {\\n\\t\\treturn nil, ErrNoMetadata\\n\\t}\\n\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(context.Background(), cp.CheckpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, ErrNoMetadata\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// InitializeSession creates session state for a new session.\\n// This is called during UserPromptSubmit hook to set up tracking for the session.\\n// For auto-commit strategy, this creates a SessionState file in .git/entire-sessions/\\n// to track CheckpointTranscriptStart (transcript offset) across checkpoints.\\n// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\nfunc (s *AutoCommitStrategy) InitializeSession(sessionID string, agentType agent.AgentType, transcriptPath string, userPrompt string) error {\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n\\t}\\n\\n\\t// Get current HEAD commit to track as base\\n\\thead, err := repo.Head()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n\\t}\\n\\n\\tbaseCommit := head.Hash().String()\\n\\n\\t// Check if session state already exists (e.g., session resuming)\\n\\texisting, err := LoadSessionState(sessionID)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to check existing session state: %w\\\", err)\\n\\t}\\n\\tif existing != nil {\\n\\t\\t// Session already initialized — update last interaction time on every prompt submit\\n\\t\\tnow := time.Now()\\n\\t\\texisting.LastInteractionTime = &now\\n\\n\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n\\t\\tturnID, err := id.Generate()\\n\\t\\tif err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n\\t\\t}\\n\\t\\texisting.TurnID = turnID.String()\\n\\t\\texisting.TurnCheckpointIDs = nil\\n\\n\\t\\t// Backfill FirstPrompt if empty (for sessions\\n\\t\\t// created before the first_prompt field was added, or resumed sessions)\\n\\t\\tif existing.FirstPrompt == \\\"\\\" && userPrompt != \\\"\\\" {\\n\\t\\t\\texisting.FirstPrompt = truncatePromptForStorage(userPrompt)\\n\\t\\t}\\n\\n\\t\\tif err := SaveSessionState(existing); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to update session state: %w\\\", err)\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Generate TurnID for the first turn\\n\\tturnID, err := id.Generate()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n\\t}\\n\\n\\t// Create new session state\\n\\tnow := time.Now()\\n\\tstate := &SessionState{\\n\\t\\tSessionID:           sessionID,\\n\\t\\tCLIVersion:          buildinfo.Version,\\n\\t\\tBaseCommit:          baseCommit,\\n\\t\\tStartedAt:           now,\\n\\t\\tLastInteractionTime: &now,\\n\\t\\tTurnID:              turnID.String(),\\n\\t\\tStepCount:           0,\\n\\t\\t// CheckpointTranscriptStart defaults to 0 (start from beginning of transcript)\\n\\t\\tFilesTouched:   []string{},\\n\\t\\tAgentType:      agentType,\\n\\t\\tTranscriptPath: transcriptPath,\\n\\t\\tFirstPrompt:    truncatePromptForStorage(userPrompt),\\n\\t}\\n\\n\\tif err := SaveSessionState(state); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// ListOrphanedItems returns orphaned items created by the auto-commit strategy.\\n// For auto-commit, checkpoints are orphaned when no commit has an Entire-Checkpoint\\n// trailer referencing them (e.g., after rebasing or squashing).\\nfunc (s *AutoCommitStrategy) ListOrphanedItems() ([]CleanupItem, error) {\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\t// Get checkpoint store (lazily initialized)\\n\\tcpStore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get all checkpoints from entire/checkpoints/v1 branch\\n\\tcheckpoints, err := cpStore.ListCommitted(context.Background())\\n\\tif err != nil {\\n\\t\\treturn []CleanupItem{}, nil //nolint:nilerr // No checkpoints is not an error for cleanup\\n\\t}\\n\\n\\tif len(checkpoints) == 0 {\\n\\t\\treturn []CleanupItem{}, nil\\n\\t}\\n\\n\\t// Filter to only auto-commit checkpoints (identified by strategy in metadata)\\n\\tautoCommitCheckpoints := make(map[string]bool)\\n\\tfor _, cp := range checkpoints {\\n\\t\\tsummary, readErr := cpStore.ReadCommitted(context.Background(), cp.CheckpointID)\\n\\t\\tif readErr != nil || summary == nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\t// Only consider checkpoints created by this strategy\\n\\t\\tif summary.Strategy == StrategyNameAutoCommit {\\n\\t\\t\\tautoCommitCheckpoints[cp.CheckpointID.String()] = true\\n\\t\\t}\\n\\t}\\n\\n\\tif len(autoCommitCheckpoints) == 0 {\\n\\t\\treturn []CleanupItem{}, nil\\n\\t}\\n\\n\\t// Find checkpoint IDs referenced in commits\\n\\treferencedCheckpoints := s.findReferencedCheckpoints(repo)\\n\\n\\t// Find orphaned checkpoints\\n\\tvar items []CleanupItem\\n\\tfor checkpointID := range autoCommitCheckpoints {\\n\\t\\tif !referencedCheckpoints[checkpointID] {\\n\\t\\t\\titems = append(items, CleanupItem{\\n\\t\\t\\t\\tType:   CleanupTypeCheckpoint,\\n\\t\\t\\t\\tID:     checkpointID,\\n\\t\\t\\t\\tReason: \\\"no commit references this checkpoint\\\",\\n\\t\\t\\t})\\n\\t\\t}\\n\\t}\\n\\n\\treturn items, nil\\n}\\n\\n// findReferencedCheckpoints scans commits for Entire-Checkpoint trailers.\\nfunc (s *AutoCommitStrategy) findReferencedCheckpoints(repo *git.Repository) map[string]bool {\\n\\treferenced := make(map[string]bool)\\n\\n\\trefs, err := repo.References()\\n\\tif err != nil {\\n\\t\\treturn referenced\\n\\t}\\n\\n\\tvisited := make(map[plumbing.Hash]bool)\\n\\n\\t_ = refs.ForEach(func(ref *plumbing.Reference) error { //nolint:errcheck // Best effort\\n\\t\\tif !ref.Name().IsBranch() {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\t// Skip entire/* branches\\n\\t\\tbranchName := strings.TrimPrefix(ref.Name().String(), \\\"refs/heads/\\\")\\n\\t\\tif strings.HasPrefix(branchName, \\\"entire/\\\") {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\titer, iterErr := repo.Log(&git.LogOptions{From: ref.Hash()})\\n\\t\\tif iterErr != nil {\\n\\t\\t\\treturn nil //nolint:nilerr // Best effort\\n\\t\\t}\\n\\n\\t\\tcount := 0\\n\\t\\t_ = iter.ForEach(func(c *object.Commit) error { //nolint:errcheck // Best effort\\n\\t\\t\\tcount++\\n\\t\\t\\tif count > 1000 {\\n\\t\\t\\t\\treturn errors.New(\\\"limit reached\\\")\\n\\t\\t\\t}\\n\\t\\t\\tif visited[c.Hash] {\\n\\t\\t\\t\\treturn nil\\n\\t\\t\\t}\\n\\t\\t\\tvisited[c.Hash] = true\\n\\n\\t\\t\\tif cpID, found := trailers.ParseCheckpoint(c.Message); found {\\n\\t\\t\\t\\treferenced[cpID.String()] = true\\n\\t\\t\\t}\\n\\t\\t\\treturn nil\\n\\t\\t})\\n\\t\