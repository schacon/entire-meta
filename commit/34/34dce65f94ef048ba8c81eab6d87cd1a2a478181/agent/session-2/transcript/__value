thub.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    28→)\\n    29→\\n    30→// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n    31→// Returns nil if the event was handled successfully.\\n    32→func DispatchLifecycleEvent(ag agent.Agent, event *agent.Event) error {\\n    33→\\tif ag == nil {\\n    34→\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    35→\\t}\\n    36→\\tif event == nil {\\n    37→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    38→\\t}\\n    39→\\n    40→\\tswitch event.Type {\\n    41→\\tcase agent.SessionStart:\\n    42→\\t\\treturn handleLifecycleSessionStart(ag, event)\\n    43→\\tcase agent.TurnStart:\\n    44→\\t\\treturn handleLifecycleTurnStart(ag, event)\\n    45→\\tcase agent.TurnEnd:\\n    46→\\t\\treturn handleLifecycleTurnEnd(ag, event)\\n    47→\\tcase agent.Compaction:\\n    48→\\t\\treturn handleLifecycleCompaction(ag, event)\\n    49→\\tcase agent.SessionEnd:\\n    50→\\t\\treturn handleLifecycleSessionEnd(ag, event)\\n    51→\\tcase agent.SubagentStart:\\n    52→\\t\\treturn handleLifecycleSubagentStart(ag, event)\\n    53→\\tcase agent.SubagentEnd:\\n    54→\\t\\treturn handleLifecycleSubagentEnd(ag, event)\\n    55→\\tdefault:\\n    56→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    57→\\t}\\n    58→}\\n    59→\\n    60→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    61→// fires state machine transition.\\n    62→func handleLifecycleSessionStart(ag agent.Agent, event *agent.Event) error {\\n    63→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n    64→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    65→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    66→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    67→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    68→\\t)\\n    69→\\n    70→\\tif event.SessionID == \\\"\\\" {\\n    71→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    72→\\t}\\n    73→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    74→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    75→\\t}\\n    76→\\n    77→\\t// Build informational message\\n    78→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    79→\\n    80→\\t// Check for concurrent sessions and append count if any\\n    81→\\tstrat := GetStrategy()\\n    82→\\tif concurrentChecker, ok := strat.(strategy.ConcurrentSessionChecker); ok {\\n    83→\\t\\tif count, err := concurrentChecker.CountOtherActiveSessionsWithCheckpoints(event.SessionID); err == nil && count > 0 {\\n    84→\\t\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    85→\\t\\t}\\n    86→\\t}\\n    87→\\n    88→\\t// Output informational message\\n    89→\\tif event.ResponseMessage != \\\"\\\" {\\n    90→\\t\\tmessage = event.ResponseMessage\\n    91→\\t}\\n    92→\\tif err := outputHookResponse(message); err != nil {\\n    93→\\t\\treturn err\\n    94→\\t}\\n    95→\\n    96→\\t// Fire EventSessionStart for the current session (if state exists).\\n    97→\\tif state, loadErr := strategy.LoadSessionState(event.SessionID); loadErr != nil {\\n    98→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state on start: %v\\\\n\\\", loadErr)\\n    99→\\t} else if state != nil {\\n   100→\\t\\tif transErr := strategy.TransitionAndLog(state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   101→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: session start transition failed: %v\\\\n\\\", transErr)\\n   102→\\t\\t}\\n   103→\\t\\tif saveErr := strategy.SaveSessionState(state); saveErr != nil {\\n   104→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session state on start: %v\\\\n\\\", saveErr)\\n   105→\\t\\t}\\n   106→\\t}\\n   107→\\n   108→\\treturn nil\\n   109→}\\n   110→\\n   111→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   112→// ensures strategy setup, initializes session.\\n   113→func handleLifecycleTurnStart(ag agent.Agent, event *agent.Event) error {\\n   114→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   115→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   116→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   117→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   118→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   119→\\t)\\n   120→\\n   121→\\tsessionID := event.SessionID\\n   122→\\tif sessionID == \\\"\\\" {\\n   123→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   124→\\t}\\n   125→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   126→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   127→\\t}\\n   128→\\n   129→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   130→\\tif err := CapturePrePromptState(ag, sessionID, event.SessionRef); err != nil {\\n   131→\\t\\treturn err\\n   132→\\t}\\n   133→\\n   134→\\t// Ensure strategy setup and initialize session\\n   135→\\tstrat := GetStrategy()\\n   136→\\n   137→\\tif err := strat.EnsureSetup(); err != nil {\\n   138→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to ensure strategy setup: %v\\\\n\\\", err)\\n   139→\\t}\\n   140→\\n   141→\\tif initializer, ok := strat.(strategy.SessionInitializer); ok {\\n   142→\\t\\tagentType := ag.Type()\\n   143→\\t\\tif err := initializer.InitializeSession(sessionID, agentType, event.SessionRef, event.Prompt); err != nil {\\n   144→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to initialize session state: %v\\\\n\\\", err)\\n   145→\\t\\t}\\n   146→\\t}\\n   147→\\n   148→\\t// Auto-create trail for non-main branches\\n   149→\\tautoCreateTrailOnTurnStart(event.Prompt)\\n   150→\\n   151→\\treturn nil\\n   152→}\\n   153→\\n   154→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   155→// detects file changes, saves step + checkpoint, transitions phase.\\n   156→//\\n   157→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   158→func handleLifecycleTurnEnd(ag agent.Agent, event *agent.Event) error {\\n   159→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   160→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   161→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   162→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   163→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   164→\\t)\\n   165→\\n   166→\\tsessionID := event.SessionID\\n   167→\\tif sessionID == \\\"\\\" {\\n   168→\\t\\tsessionID = unknownSessionID\\n   169→\\t}\\n   170→\\n   171→\\ttranscriptRef := event.SessionRef\\n   172→\\tif transcriptRef == \\\"\\\" {\\n   173→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   174→\\t}\\n   175→\\tif !fileExists(transcriptRef) {\\n   176→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   177→\\t}\\n   178→\\n   179→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   180→\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n   181→\\t\\tfmt.Fprintln(os.Stderr, \\\"Entire: skipping checkpoint. Will activate after first commit.\\\")\\n   182→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   183→\\t}\\n   184→\\n   185→\\t// Create session metadata directory\\n   186→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   187→\\tsessionDirAbs, err := paths.AbsPath(sessionDir)\\n   188→\\tif err != nil {\\n   189→\\t\\tsessionDirAbs = sessionDir\\n   190→\\t}\\n   191→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   192→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   193→\\t}\\n   194→\\n   195→\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n   196→\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n   197→\\t\\tif err := preparer.PrepareTranscript(transcriptRef); err != nil {\\n   198→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to prepare transcript: %v\\\\n\\\", err)\\n   199→\\t\\t}\\n   200→\\t}\\n   201→\\n   202→\\t// Copy transcript to session directory\\n   203→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   204→\\tif err != nil {\\n   205→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   206→\\t}\\n   207→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   208→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   209→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   210→\\t}\\n   211→\\tfmt.Fprintf(os.Stderr, \\\"Copied transcript to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName)\\n   212→\\n   213→\\t// Copy export JSON if it exists alongside the transcript (written by OpenCode plugin).\\n   214→\\t// This is used by `opencode import` during resume/rewind to restore the session\\n   215→\\t// into OpenCode's SQLite database with the original session ID.\\n   216→\\texportSrc := strings.TrimSuffix(transcriptRef, filepath.Ext(transcriptRef)) + \\\".export.json\\\"\\n   217→\\tif exportData, readErr := os.ReadFile(exportSrc); readErr == nil { //nolint:gosec // Path derived from agent hook\\n   218→\\t\\texportDest := filepath.Join(sessionDirAbs, paths.ExportDataFileName)\\n   219→\\t\\tif writeErr := os.WriteFile(exportDest, exportData, 0o600); writeErr != nil {\\n   220→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to write export data: %v\\\\n\\\", writeErr)\\n   221→\\t\\t}\\n   222→\\t}\\n   223→\\n   224→\\t// Load pre-prompt state (captured on TurnStart)\\n   225→\\tpreState, err := LoadPrePromptState(sessionID)\\n   226→\\tif err != nil {\\n   227→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-prompt state: %v\\\\n\\\", err)\\n   228→\\t}\\n   229→\\n   230→\\t// Determine transcript offset\\n   231→\\ttranscriptOffset := resolveTranscriptOffset(preState, sessionID)\\n   232→\\n   233→\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n   234→\\tvar allPrompts []string\\n   235→\\tvar summary string\\n   236→\\tvar modifiedFiles []string\\n   237→\\tvar newTranscriptPosition int\\n   238→\\n   239→\\t// Compute subagents directory for agents that support subagent extraction.\\n   240→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   241→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   242→\\n   243→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   244→\\t\\t// Extract prompts\\n   245→\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n   246→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract prompts: %v\\\\n\\\", promptErr)\\n   247→\\t\\t} else {\\n   248→\\t\\t\\tallPrompts = prompts\\n   249→\\t\\t}\\n   250→\\n   251→\\t\\t// Extract summary\\n   252→\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n   253→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract summary: %v\\\\n\\\", sumErr)\\n   254→\\t\\t} else {\\n   255→\\t\\t\\tsummary = s\\n   256→\\t\\t}\\n   257→\\n   258→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   259→\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n   260→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptRef, transcriptOffset, subagentsDir); fileErr != nil {\\n   261→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files (with subagents): %v\\\\n\\\", fileErr)\\n   262→\\t\\t\\t} else {\\n   263→\\t\\t\\t\\tmodifiedFiles = files\\n   264→\\t\\t\\t}\\n   265→\\t\\t\\t// Get position from basic analyzer\\n   266→\\t\\t\\tif _, pos, posErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); posErr == nil {\\n   267→\\t\\t\\t\\tnewTranscriptPosition = pos\\n   268→\\t\\t\\t}\\n   269→\\t\\t} else {\\n   270→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   271→\\t\\t\\tif files, pos, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   272→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files: %v\\\\n\\\", fileErr)\\n   273→\\t\\t\\t} else {\\n   274→\\t\\t\\t\\tmodifiedFiles = files\\n   275→\\t\\t\\t\\tnewTranscriptPosition = pos\\n   276→\\t\\t\\t}\\n   277→\\t\\t}\\n   278→\\t}\\n   279→\\n   280→\\t// Write prompts file\\n   281→\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   282→\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   283→\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   284→\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   285→\\t}\\n   286→\\tfmt.Fprintf(os.Stderr, \\\"Extracted %d prompt(s) to: %s\\\\n\\\", len(allPrompts), sessionDir+\\\"/\\\"+paths.PromptFileName)\\n   287→\\n   288→\\t// Write summary file\\n   289→\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   290→\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   291→\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   292→\\t}\\n   293→\\tfmt.Fprintf(os.Stderr, \\\"Extracted summary to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName)\\n   294→\\n   295→\\t// Generate commit message from last prompt\\n   296→\\tlastPrompt := \\\"\\\"\\n   297→\\tif len(allPrompts) > 0 {\\n   298→\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   299→\\t}\\n   300→\\tcommitMessage := generateCommitMessage(lastPrompt)\\n   301→\\tfmt.Fprintf(os.Stderr, \\\"Using commit message: %s\\\\n\\\", commitMessage)\\n   302→\\n   303→\\t// Get repo root for path normalization\\n   304→\\trepoRoot, err := paths.RepoRoot()\\n   305→\\tif err != nil {\\n   306→\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   307→\\t}\\n   308→\\n   309→\\tvar preUntrackedFiles []string\\n   310→\\tif preState != nil {\\n   311→\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state: %d pre-existing untracked files\\\\n\\\", len(preState.UntrackedFiles))\\n   312→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   313→\\t}\\n   314→\\n   315→\\t// Detect file changes via git status\\n   316→\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n   317→\\tif err != nil {\\n   318→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   319→\\t}\\n   320→\\n   321→\\t// Filter and normalize all paths\\n   322→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   323→\\tvar relNewFiles, relDeletedFiles []string\\n   324→\\tif changes != nil {\\n   325→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   326→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   327→\\t}\\n   328→\\n   329→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   330→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   331→\\t// and should not be re-adde