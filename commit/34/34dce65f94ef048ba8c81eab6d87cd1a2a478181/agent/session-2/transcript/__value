1409→\\tif state != nil && state.BaseCommit != \\\"\\\" {\\n  1410→\\t\\t// Session is fully initialized — apply phase transition for TurnStart.\\n  1411→\\t\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1412→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1413→\\t\\t}\\n  1414→\\n  1415→\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n  1416→\\t\\tturnID, err := id.Generate()\\n  1417→\\t\\tif err != nil {\\n  1418→\\t\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n  1419→\\t\\t}\\n  1420→\\t\\tstate.TurnID = turnID.String()\\n  1421→\\n  1422→\\t\\t// Backfill AgentType if empty or set to the generic default \\\"Agent\\\"\\n  1423→\\t\\tif !isSpecificAgentType(state.AgentType) && agentType != \\\"\\\" {\\n  1424→\\t\\t\\tstate.AgentType = agentType\\n  1425→\\t\\t}\\n  1426→\\n  1427→\\t\\t// Backfill FirstPrompt if empty (for sessions created before the first_prompt field was added)\\n  1428→\\t\\tif state.FirstPrompt == \\\"\\\" && userPrompt != \\\"\\\" {\\n  1429→\\t\\t\\tstate.FirstPrompt = truncatePromptForStorage(userPrompt)\\n  1430→\\t\\t}\\n  1431→\\n  1432→\\t\\t// Update transcript path if provided (may change on session resume)\\n  1433→\\t\\tif transcriptPath != \\\"\\\" && state.TranscriptPath != transcriptPath {\\n  1434→\\t\\t\\tstate.TranscriptPath = transcriptPath\\n  1435→\\t\\t}\\n  1436→\\n  1437→\\t\\t// Clear checkpoint IDs on every new prompt.\\n  1438→\\t\\t// LastCheckpointID is set during PostCommit, cleared at new prompt.\\n  1439→\\t\\t// TurnCheckpointIDs tracks mid-turn checkpoints for stop-time finalization.\\n  1440→\\t\\tstate.LastCheckpointID = \\\"\\\"\\n  1441→\\t\\tstate.TurnCheckpointIDs = nil\\n  1442→\\n  1443→\\t\\t// Calculate attribution at prompt start (BEFORE agent makes any changes)\\n  1444→\\t\\t// This captures user edits since the last checkpoint (or base commit for first prompt).\\n  1445→\\t\\t// IMPORTANT: Always calculate attribution, even for the first checkpoint, to capture\\n  1446→\\t\\t// user edits made before the first prompt. The inner CalculatePromptAttribution handles\\n  1447→\\t\\t// nil lastCheckpointTree by falling back to baseTree.\\n  1448→\\t\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n  1449→\\t\\tstate.PendingPromptAttribution = &promptAttr\\n  1450→\\n  1451→\\t\\t// Check if HEAD has moved (user pulled/rebased or committed)\\n  1452→\\t\\t// migrateShadowBranchIfNeeded handles renaming the shadow branch and updating state.BaseCommit\\n  1453→\\t\\tif _, err := s.migrateShadowBranchIfNeeded(repo, state); err != nil {\\n  1454→\\t\\t\\treturn fmt.Errorf(\\\"failed to check/migrate shadow branch: %w\\\", err)\\n  1455→\\t\\t}\\n  1456→\\n  1457→\\t\\tif err := s.saveSessionState(state); err != nil {\\n  1458→\\t\\t\\treturn fmt.Errorf(\\\"failed to update session state: %w\\\", err)\\n  1459→\\t\\t}\\n  1460→\\t\\treturn nil\\n  1461→\\t}\\n  1462→\\t// If state exists but BaseCommit is empty, it's a partial state from concurrent warning\\n  1463→\\t// Continue below to properly initialize it\\n  1464→\\n  1465→\\t// Initialize new session\\n  1466→\\tstate, err = s.initializeSession(repo, sessionID, agentType, transcriptPath, userPrompt)\\n  1467→\\tif err != nil {\\n  1468→\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n  1469→\\t}\\n  1470→\\n  1471→\\t// Apply phase transition: new session starts as ACTIVE.\\n  1472→\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1473→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1474→\\t}\\n  1475→\\n  1476→\\t// Calculate attribution for pre-prompt edits\\n  1477→\\t// This captures any user edits made before the first prompt\\n  1478→\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n  1479→\\tstate.PendingPromptAttribution = &promptAttr\\n  1480→\\tif err = s.saveSessionState(state); err != nil {\\n  1481→\\t\\treturn fmt.Errorf(\\\"failed to save attribution: %w\\\", err)\\n  1482→\\t}\\n  1483→\\n  1484→\\tfmt.Fprintf(os.Stderr, \\\"Initialized shadow session: %s\\\\n\\\", sessionID)\\n  1485→\\treturn nil\\n  1486→}\\n  1487→\\n  1488→// calculatePromptAttributionAtStart calculates attribution at prompt start (before agent runs).\\n  1489→// This captures user changes since the last checkpoint - no filtering needed since\\n  1490→// the agent hasn't made any changes yet.\\n  1491→//\\n  1492→// IMPORTANT: This reads from the worktree (not staging area) to match what WriteTemporary\\n  1493→// captures in checkpoints. If we read staged content but checkpoints capture worktree content,\\n  1494→// unstaged changes would be in the checkpoint but not counted in PromptAttribution, causing\\n  1495→// them to be incorrectly attributed to the agent later.\\n  1496→func (s *ManualCommitStrategy) calculatePromptAttributionAtStart(\\n  1497→\\trepo *git.Repository,\\n  1498→\\tstate *SessionState,\\n  1499→) PromptAttribution {\\n  1500→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n  1501→\\tnextCheckpointNum := state.StepCount + 1\\n  1502→\\tresult := PromptAttribution{CheckpointNumber: nextCheckpointNum}\\n  1503→\\n  1504→\\t// Get last checkpoint tree from shadow branch (if it exists)\\n  1505→\\t// For the first checkpoint, no shadow branch exists yet - this is fine,\\n  1506→\\t// CalculatePromptAttribution will use baseTree as the reference instead.\\n  1507→\\tvar lastCheckpointTree *object.Tree\\n  1508→\\tshadowBranchName := checkpoint.ShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n  1509→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1510→\\tref, err := repo.Reference(refName, true)\\n  1511→\\tif err != nil {\\n  1512→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: no shadow branch yet (first checkpoint)\\\",\\n  1513→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName))\\n  1514→\\t\\t// Continue with lastCheckpointTree = nil\\n  1515→\\t} else {\\n  1516→\\t\\tshadowCommit, err := repo.CommitObject(ref.Hash())\\n  1517→\\t\\tif err != nil {\\n  1518→\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: failed to get shadow commit\\\",\\n  1519→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", ref.Hash().String()),\\n  1520→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1521→\\t\\t\\t// Continue with lastCheckpointTree = nil\\n  1522→\\t\\t} else {\\n  1523→\\t\\t\\tlastCheckpointTree, err = shadowCommit.Tree()\\n  1524→\\t\\t\\tif err != nil {\\n  1525→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: failed to get shadow tree\\\",\\n  1526→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1527→\\t\\t\\t\\t// Continue with lastCheckpointTree = nil\\n  1528→\\t\\t\\t}\\n  1529→\\t\\t}\\n  1530→\\t}\\n  1531→\\n  1532→\\t// Get base tree for agent lines calculation\\n  1533→\\tvar baseTree *object.Tree\\n  1534→\\tif baseCommit, err := repo.CommitObject(plumbing.NewHash(state.BaseCommit)); err == nil {\\n  1535→\\t\\tif tree, treeErr := baseCommit.Tree(); treeErr == nil {\\n  1536→\\t\\t\\tbaseTree = tree\\n  1537→\\t\\t} else {\\n  1538→\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: base tree unavailable\\\",\\n  1539→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n  1540→\\t\\t}\\n  1541→\\t} else {\\n  1542→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: base commit unavailable\\\",\\n  1543→\\t\\t\\tslog.String(\\\"base_commit\\\", state.BaseCommit),\\n  1544→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1545→\\t}\\n  1546→\\n  1547→\\tworktree, err := repo.Worktree()\\n  1548→\\tif err != nil {\\n  1549→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution skipped: failed to get worktree\\\",\\n  1550→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1551→\\t\\treturn result\\n  1552→\\t}\\n  1553→\\n  1554→\\t// Get worktree status to find ALL changed files\\n  1555→\\tstatus, err := worktree.Status()\\n  1556→\\tif err != nil {\\n  1557→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution skipped: failed to get worktree status\\\",\\n  1558→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1559→\\t\\treturn result\\n  1560→\\t}\\n  1561→\\n  1562→\\tworktreeRoot := worktree.Filesystem.Root()\\n  1563→\\n  1564→\\t// Build map of changed files with their worktree content\\n  1565→\\t// IMPORTANT: We read from worktree (not staging area) to match what WriteTemporary\\n  1566→\\t// captures in checkpoints. This ensures attribution is consistent.\\n  1567→\\tchangedFiles := make(map[string]string)\\n  1568→\\tfor filePath, fileStatus := range status {\\n  1569→\\t\\t// Skip unmodified files\\n  1570→\\t\\tif fileStatus.Worktree == git.Unmodified && fileStatus.Staging == git.Unmodified {\\n  1571→\\t\\t\\tcontinue\\n  1572→\\t\\t}\\n  1573→\\t\\t// Skip .entire metadata directory (session data, not user code)\\n  1574→\\t\\tif strings.HasPrefix(filePath, paths.EntireMetadataDir+\\\"/\\\") || strings.HasPrefix(filePath, \\\".entire/\\\") {\\n  1575→\\t\\t\\tcontinue\\n  1576→\\t\\t}\\n  1577→\\n  1578→\\t\\t// Always read from worktree to match checkpoint behavior\\n  1579→\\t\\tfullPath := filepath.Join(worktreeRoot, filePath)\\n  1580→\\t\\tvar content string\\n  1581→\\t\\tif data, err := os.ReadFile(fullPath); err == nil { //nolint:gosec // filePath is from git worktree status\\n  1582→\\t\\t\\t// Use git's binary detection algorithm (matches getFileContent behavior).\\n  1583→\\t\\t\\t// Binary files are excluded from line-based attribution calculations.\\n  1584→\\t\\t\\tisBinary, binErr := binary.IsBinary(bytes.NewReader(data))\\n  1585→\\t\\t\\tif binErr == nil && !isBinary {\\n  1586→\\t\\t\\t\\tcontent = string(data)\\n  1587→\\t\\t\\t}\\n  1588→\\t\\t}\\n  1589→\\t\\t// else: file deleted, unreadable, or binary - content remains empty string\\n  1590→\\n  1591→\\t\\tchangedFiles[filePath] = content\\n  1592→\\t}\\n  1593→\\n  1594→\\t// Use CalculatePromptAttribution from manual_commit_attribution.go\\n  1595→\\tresult = CalculatePromptAttribution(baseTree, lastCheckpointTree, changedFiles, nextCheckpointNum)\\n  1596→\\n  1597→\\treturn result\\n  1598→}\\n  1599→\\n  1600→// getStagedFiles returns a list of files staged for commit.\\n  1601→func getStagedFiles(repo *git.Repository) []string {\\n  1602→\\tworktree, err := repo.Worktree()\\n  1603→\\tif err != nil {\\n  1604→\\t\\treturn nil\\n  1605→\\t}\\n  1606→\\n  1607→\\tstatus, err := worktree.Status()\\n  1608→\\tif err != nil {\\n  1609→\\t\\treturn nil\\n  1610→\\t}\\n  1611→\\n  1612→\\tvar staged []string\\n  1613→\\tfor path, fileStatus := range status {\\n  1614→\\t\\t// Check if file is staged (in index)\\n  1615→\\t\\tif fileStatus.Staging != git.Unmodified && fileStatus.Staging != git.Untracked {\\n  1616→\\t\\t\\tstaged = append(staged, path)\\n  1617→\\t\\t}\\n  1618→\\t}\\n  1619→\\treturn staged\\n  1620→}\\n  1621→\\n  1622→// getLastPrompt retrieves the most recent user prompt from a session's shadow branch.\\n  1623→// Returns empty string if no prompt can be retrieved.\\n  1624→func (s *ManualCommitStrategy) getLastPrompt(repo *git.Repository, state *SessionState) string {\\n  1625→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n  1626→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1627→\\tref, err := repo.Reference(refName, true)\\n  1628→\\tif err != nil {\\n  1629→\\t\\treturn \\\"\\\"\\n  1630→\\t}\\n  1631→\\n  1632→\\t// Extract session data to get prompts for commit message generation\\n  1633→\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini)\\n  1634→\\t// Pass 0 for checkpointTranscriptStart since we're extracting all prompts, not calculating token usage\\n  1635→\\tsessionData, err := s.extractSessionData(repo, ref.Hash(), state.SessionID, nil, state.AgentType, \\\"\\\", 0)\\n  1636→\\tif err != nil || len(sessionData.Prompts) == 0 {\\n  1637→\\t\\treturn \\\"\\\"\\n  1638→\\t}\\n  1639→\\n  1640→\\t// Return the last prompt (most recent work before commit)\\n  1641→\\treturn sessionData.Prompts[len(sessionData.Prompts)-1]\\n  1642→}\\n  1643→\\n  1644→// HandleTurnEnd dispatches strategy-specific actions emitted when an agent turn ends.\\n  1645→// The primary job is to finalize all checkpoints from this turn with the full transcript.\\n  1646→//\\n  1647→// During a turn, PostCommit writes provisional transcript data (whatever was available\\n  1648→// at commit time). HandleTurnEnd replaces that with the complete session transcript\\n  1649→// (from prompt to stop event), ensuring every checkpoint has the full context.\\n  1650→//\\n  1651→//nolint:unparam // error return required by interface but hooks must return nil\\n  1652→func (s *ManualCommitStrategy) HandleTurnEnd(state *SessionState) error {\\n  1653→\\t// Finalize all checkpoints from this turn with the full transcript.\\n  1654→\\t//\\n  1655→\\t// IMPORTANT: This is best-effort - errors are logged but don't fail the hook.\\n  1656→\\t// Failing here would prevent session cleanup and could leave state inconsistent.\\n  1657→\\t// The provisional transcript from PostCommit is already persisted, so the\\n  1658→\\t// checkpoint isn't lost - it just won't have the complete transcript.\\n  1659→\\terrCount := s.finalizeAllTurnCheckpoints(state)\\n  1660→\\tif errCount > 0 {\\n  1661→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1662→\\t\\tlogging.Warn(logCtx, \\\"HandleTurnEnd completed with errors (best-effort)\\\",\\n  1663→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1664→\\t\\t\\tslog.Int(\\\"error_count\\\", errCount),\\n  1665→\\t\\t)\\n  1666→\\t}\\n  1667→\\treturn nil\\n  1668→}\\n  1669→\\n  1670→// finalizeAllTurnCheckpoints replaces the provisional transcript in each checkpoint\\n  1671→// created during this turn with the full session transcript.\\n  1672→//\\n  1673→// This is called at turn end (stop hook). During the turn, PostCommit wrote whatever\\n  1674→// transcript was available at commit time. Now we have the complete transcript and\\n  1675→// replace it so every checkpoint has the full prompt-to-stop context.\\n  1676→//\\n  1677→// Returns the number of errors encountered (best-effort: continues processing on error).\\n  1678→func (s *ManualCommitStrategy) finalizeAllTurnCheckpoints(state *SessionState) int {\\n  1679→\\tif len(state.TurnCheckpointIDs) == 0 {\\n  1680→\\t\\treturn 0 // No mid-turn commits to finalize\\n  1681→\\t}\\n  1682→\\n  1683→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1684→\\n  1685→\\tlogging.Info(logCtx, \\\"finalizing turn checkpoints with full transcript\\\",\\n  1686→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1687→\\t\\tslog.Int(\\\"checkpoint_count\\\", len(state.TurnCheckpointIDs)),\\n  1688→\\t)\\n  1689→\\n  1690→\\terrCount := 0\\n  1691→\\n  1692→\\t// Read full transcript from live transcript file\\n  1693→\\tif state.TranscriptPath == \\\"\\\" {\\n  1694→\\t\\tlogging.Warn(logCtx, \\\"finalize: no transcript path, skipping\\\",\\n  1695→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1696→\\t\\t)\\n  1697→\\t\\tstate.TurnCheckpointIDs = nil\\n  1698→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1699→\\t}\\n  1700→\\n  1701→\\tfullTranscript, err := os.ReadFile(state.TranscriptPath)\\n  1702→\\tif err != nil || len(fullTranscript) == 0 {\\n  1703→\\t\\tmsg := \\\"finalize: empty transcript, skipping\\\"\\n  1704→\\t\\tif err != nil {\\n  1705→\\t\\t\\tmsg = \\\"finalize: failed to read transcript, skipping\\\"\\n  1706→\\t\\t}\\n  1707→\\t\\tlogging.Warn(logCtx, msg,\\n  1708→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1709→\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1710→\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1711→\\t\\t)\\n  1712→\\t\\tstate.TurnCheckpointIDs = nil\\n  1713→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1714→\\t}\\n  1715→\\n  1716→\\t// Extract prompts and context from the full transcript\\n  1717→\\tprompts := extractUserPrompts(state.AgentType, string(fullTranscript))\\n  1718→\\tcontextBytes := generateContextFromPrompts(prompts)\\n  1719→\\n  1720→\\t// Redact secrets before writing — matches WriteCommitted behavior.\\n  1721→\\t// The live transcript on disk contains raw content; redaction must happen\\n  1722→\\t// before anything is persisted to the metadata branch.\\n  1723→\\tfullTranscript, err = redact.JSONLBytes(fullTranscript)\\n  1724→\\tif err != nil {\\n  1725→\\t\\tlogging.Warn(logCtx, \\\"finalize: transcript redaction failed, skipping\\\",\\n  1726→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1727→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1728→\\t\\t)\\n  1729→\\t\\tstate.TurnCheckpointIDs = nil\\n  1730→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1731→\\t}\\n  1732→\\tfor i, p := range prompts {\\n  1733→\\t\\tprompts[i] = redact.String(p)\\n  1734→\\t}\\n  1735→\\tcontextBytes = redact.Bytes(contextBytes)\\n  1736→\\n  1737→\\t// Open repository and create checkpoint store\\n  1738→\\trepo, err := OpenRepository()\\n  1739→\\tif err != nil {\\n  1740→\\t\\tlogging.Warn(logCtx, \\\"finalize: failed to open repository\\\",\\n  1741→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1742→\\t\\t)\\n  1743→\\t\\tstate.TurnCheckpointIDs = nil\\n  1744→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1745→\\t}\\n  1746→\\tstore := checkpoint.NewGitStore(repo)\\n  1747→\\n  1748→\\t// Update