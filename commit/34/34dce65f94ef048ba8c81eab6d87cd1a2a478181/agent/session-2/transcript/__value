nt types exist and their CLI tool names\\n- Whether each CLI has a non-interactive generation mode (like claude's --print)\\n- What the `Agent` interface looks like\\n- Any existing patterns for detecting which CLI tools are installed\\n- File paths for all relevant code\",\"agentId\":\"afd4ce5\"},\"toolUseID\":\"agent_msg_01VrqRq5nKysh8fqb81MLaDZ\",\"parentToolUseID\":\"toolu_01F7E55JGeoWXjCTS4UHwaHC\",\"uuid\":\"01e83316-107e-4882-9c66-a7b6f3626492\",\"timestamp\":\"2026-02-20T18:42:15.701Z\"}\n{\"parentUuid\":\"01e83316-107e-4882-9c66-a7b6f3626492\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/dip/Repositories/cli\",\"sessionId\":\"6edd18ba-782c-4019-88d9-018079feea08\",\"version\":\"2.1.49\",\"gitBranch\":\"main\",\"slug\":\"wondrous-finding-raven\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_014ExrFydhxq1HuBxjcVoLb5\",\"type\":\"tool_result\",\"content\":\"     1→package agent\\n     2→\\n     3→import (\\n     4→\\t\\\"fmt\\\"\\n     5→\\t\\\"slices\\\"\\n     6→\\t\\\"sync\\\"\\n     7→)\\n     8→\\n     9→var (\\n    10→\\tregistryMu sync.RWMutex\\n    11→\\tregistry   = make(map[AgentName]Factory)\\n    12→)\\n    13→\\n    14→// Factory creates a new agent instance\\n    15→type Factory func() Agent\\n    16→\\n    17→// Register adds an agent factory to the registry.\\n    18→// Called from init() in each agent implementation.\\n    19→func Register(name AgentName, factory Factory) {\\n    20→\\tregistryMu.Lock()\\n    21→\\tdefer registryMu.Unlock()\\n    22→\\tregistry[name] = factory\\n    23→}\\n    24→\\n    25→// Get retrieves an agent by name.\\n    26→//\\n    27→\\n    28→func Get(name AgentName) (Agent, error) {\\n    29→\\tregistryMu.RLock()\\n    30→\\tdefer registryMu.RUnlock()\\n    31→\\n    32→\\tfactory, ok := registry[name]\\n    33→\\tif !ok {\\n    34→\\t\\treturn nil, fmt.Errorf(\\\"unknown agent: %s (available: %v)\\\", name, List())\\n    35→\\t}\\n    36→\\treturn factory(), nil\\n    37→}\\n    38→\\n    39→// List returns all registered agent names in sorted order.\\n    40→func List() []AgentName {\\n    41→\\tregistryMu.RLock()\\n    42→\\tdefer registryMu.RUnlock()\\n    43→\\n    44→\\tnames := make([]AgentName, 0, len(registry))\\n    45→\\tfor name := range registry {\\n    46→\\t\\tnames = append(names, name)\\n    47→\\t}\\n    48→\\tslices.Sort(names)\\n    49→\\treturn names\\n    50→}\\n    51→\\n    52→// DetectAll returns all agents whose DetectPresence reports true.\\n    53→// Agents are checked in sorted name order (via List()) for deterministic results.\\n    54→// Returns an empty slice when no agent is detected.\\n    55→func DetectAll() []Agent {\\n    56→\\tnames := List() // sorted, lock-safe\\n    57→\\n    58→\\tvar detected []Agent\\n    59→\\tfor _, name := range names {\\n    60→\\t\\tag, err := Get(name)\\n    61→\\t\\tif err != nil {\\n    62→\\t\\t\\tcontinue\\n    63→\\t\\t}\\n    64→\\t\\tif present, err := ag.DetectPresence(); err == nil && present {\\n    65→\\t\\t\\tdetected = append(detected, ag)\\n    66→\\t\\t}\\n    67→\\t}\\n    68→\\treturn detected\\n    69→}\\n    70→\\n    71→// Detect attempts to auto-detect which agent is being used.\\n    72→// Iterates registered agents in sorted name order for deterministic results.\\n    73→// Returns the first agent whose DetectPresence reports true.\\n    74→func Detect() (Agent, error) {\\n    75→\\tdetected := DetectAll()\\n    76→\\tif len(detected) == 0 {\\n    77→\\t\\treturn nil, fmt.Errorf(\\\"no agent detected (available: %v)\\\", List())\\n    78→\\t}\\n    79→\\treturn detected[0], nil\\n    80→}\\n    81→\\n    82→// AgentName is the registry key type for agents (e.g., \\\"claude-code\\\", \\\"gemini\\\").\\n    83→//\\n    84→//nolint:revive // stuttering is intentional - distinguishes from AgentType when both are used\\n    85→type AgentName string\\n    86→\\n    87→// AgentType is the display name type stored in metadata/trailers (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\").\\n    88→//\\n    89→//nolint:revive // stuttering is intentional - distinguishes from AgentName when both are used\\n    90→type AgentType string\\n    91→\\n    92→// Agent name constants (registry keys)\\n    93→const (\\n    94→\\tAgentNameClaudeCode AgentName = \\\"claude-code\\\"\\n    95→\\tAgentNameGemini     AgentName = \\\"gemini\\\"\\n    96→\\tAgentNameOpenCode   AgentName = \\\"opencode\\\"\\n    97→)\\n    98→\\n    99→// Agent type constants (type identifiers stored in metadata/trailers)\\n   100→const (\\n   101→\\tAgentTypeClaudeCode AgentType = \\\"Claude Code\\\"\\n   102→\\tAgentTypeGemini     AgentType = \\\"Gemini CLI\\\"\\n   103→\\tAgentTypeOpenCode   AgentType = \\\"OpenCode\\\"\\n   104→\\tAgentTypeUnknown    AgentType = \\\"Agent\\\" // Fallback for backwards compatibility\\n   105→)\\n   106→\\n   107→// DefaultAgentName is the registry key for the default agent.\\n   108→const DefaultAgentName AgentName = AgentNameClaudeCode\\n   109→\\n   110→// GetByAgentType retrieves an agent by its type identifier.\\n   111→//\\n   112→// Note: This uses a linear search that instantiates agents until a match is found.\\n   113→// This is acceptable because:\\n   114→//   - Agent count is small (~2-20 agents)\\n   115→//   - Agent factories are lightweight (empty struct allocation)\\n   116→//   - Called infrequently (commit hooks, rewind, debug commands - not hot paths)\\n   117→//   - Cost is ~400ns worst case vs milliseconds for I/O operations\\n   118→//\\n   119→// Only optimize if agent count exceeds 100 or profiling shows this as a bottleneck.\\n   120→func GetByAgentType(agentType AgentType) (Agent, error) {\\n   121→\\tregistryMu.RLock()\\n   122→\\tdefer registryMu.RUnlock()\\n   123→\\n   124→\\tfor _, factory := range registry {\\n   125→\\t\\tag := factory()\\n   126→\\t\\tif ag.Type() == agentType {\\n   127→\\t\\t\\treturn ag, nil\\n   128→\\t\\t}\\n   129→\\t}\\n   130→\\n   131→\\treturn nil, fmt.Errorf(\\\"unknown agent type: %s\\\", agentType)\\n   132→}\\n   133→\\n   134→// AllProtectedDirs returns the union of ProtectedDirs from all registered agents.\\n   135→func AllProtectedDirs() []string {\\n   136→\\t// Copy factories under the lock, then release before calling external code.\\n   137→\\tregistryMu.RLock()\\n   138→\\tfactories := make([]Factory, 0, len(registry))\\n   139→\\tfor _, f := range registry {\\n   140→\\t\\tfactories = append(factories, f)\\n   141→\\t}\\n   142→\\tregistryMu.RUnlock()\\n   143→\\n   144→\\tseen := make(map[string]struct{})\\n   145→\\tvar dirs []string\\n   146→\\tfor _, factory := range factories {\\n   147→\\t\\tfor _, d := range factory().ProtectedDirs() {\\n   148→\\t\\t\\tif _, ok := seen[d]; !ok {\\n   149→\\t\\t\\t\\tseen[d] = struct{}{}\\n   150→\\t\\t\\t\\tdirs = append(dirs, d)\\n   151→\\t\\t\\t}\\n   152→\\t\\t}\\n   153→\\t}\\n   154→\\tslices.Sort(dirs)\\n   155→\\treturn dirs\\n   156→}\\n   157→\\n   158→// Default returns the default agent.\\n   159→// Returns nil if the default agent is not registered.\\n   160→//\\n   161→//nolint:errcheck // Factory pattern returns interface; error is acceptable to ignore for default\\n   162→func Default() Agent {\\n   163→\\ta, _ := Get(DefaultAgentName)\\n   164→\\treturn a\\n   165→}\\n   166→\"}]},\"uuid\":\"cb007569-0342-417f-8a31-7647f3152ddd\",\"timestamp\":\"2026-02-20T18:42:15.711Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand how different agent CLI tools can be invoked for non-interactive text generation (like generating a trail title from a transcript).\\n\\nExplore these files and areas:\\n1. `cmd/entire/cli/agent/` - all agent types, interfaces, and registration\\n2. Look for how each agent's CLI is detected/invoked\\n3. Check if there's any existing pattern for invoking agents programmatically (besides the `summarize/claude.go` which uses `claude -