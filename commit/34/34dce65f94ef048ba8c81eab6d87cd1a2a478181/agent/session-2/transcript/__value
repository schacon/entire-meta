cli/cmd/entire/cli/checkpoint\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/trail\\\"\\n    16→\\n    17→\\t\\\"github.com/charmbracelet/huh\\\"\\n    18→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    19→\\t\\\"github.com/spf13/cobra\\\"\\n    20→)\\n    21→\\n    22→func newTrailCmd() *cobra.Command {\\n    23→\\tcmd := &cobra.Command{\\n    24→\\t\\tUse:   \\\"trail\\\",\\n    25→\\t\\tShort: \\\"Manage trails for your branches\\\",\\n    26→\\t\\tLong: `Trails are branch-centric work tracking abstractions. They describe the\\n    27→\\\"why\\\" and \\\"what\\\" of your work, while checkpoints capture the \\\"how\\\" and \\\"when\\\".\\n    28→\\n    29→Running 'entire trail' without a subcommand shows the trail for the current\\n    30→branch, or lists all trails if no trail exists for the current branch.`,\\n    31→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    32→\\t\\t\\treturn runTrailShow(cmd.OutOrStdout())\\n    33→\\t\\t},\\n    34→\\t}\\n    35→\\n    36→\\tcmd.AddCommand(newTrailListCmd())\\n    37→\\tcmd.AddCommand(newTrailCreateCmd())\\n    38→\\tcmd.AddCommand(newTrailUpdateCmd())\\n    39→\\tcmd.AddCommand(newTrailEnableCmd())\\n    40→\\tcmd.AddCommand(newTrailDisableCmd())\\n    41→\\n    42→\\treturn cmd\\n    43→}\\n    44→\\n    45→// runTrailShow shows the trail for the current branch, or falls through to list.\\n    46→func runTrailShow(w io.Writer) error {\\n    47→\\tbranch, err := GetCurrentBranch()\\n    48→\\tif err != nil {\\n    49→\\t\\treturn runTrailListAll(w, \\\"\\\", false)\\n    50→\\t}\\n    51→\\n    52→\\trepo, err := strategy.OpenRepository()\\n    53→\\tif err != nil {\\n    54→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n    55→\\t}\\n    56→\\n    57→\\tstore := trail.NewStore(repo)\\n    58→\\tmetadata, err := store.FindByBranch(branch)\\n    59→\\tif err != nil || metadata == nil {\\n    60→\\t\\treturn runTrailListAll(w, \\\"\\\", false)\\n    61→\\t}\\n    62→\\n    63→\\tprintTrailDetails(w, metadata)\\n    64→\\treturn nil\\n    65→}\\n    66→\\n    67→func printTrailDetails(w io.Writer, m *trail.Metadata) {\\n    68→\\tfmt.Fprintf(w, \\\"Trail: %s\\\\n\\\", m.Title)\\n    69→\\tfmt.Fprintf(w, \\\"  ID:      %s\\\\n\\\", m.TrailID)\\n    70→\\tfmt.Fprintf(w, \\\"  Branch:  %s\\\\n\\\", m.Branch)\\n    71→\\tfmt.Fprintf(w, \\\"  Base:    %s\\\\n\\\", m.Base)\\n    72→\\tfmt.Fprintf(w, \\\"  Status:  %s\\\\n\\\", m.Status)\\n    73→\\tfmt.Fprintf(w, \\\"  Author:  %s\\\\n\\\", m.Author)\\n    74→\\tif m.Description != \\\"\\\" {\\n    75→\\t\\tfmt.Fprintf(w, \\\"  Description: %s\\\\n\\\", m.Description)\\n    76→\\t}\\n    77→\\tif len(m.Labels) > 0 {\\n    78→\\t\\tfmt.Fprintf(w, \\\"  Labels:  %s\\\\n\\\", strings.Join(m.Labels, \\\", \\\"))\\n    79→\\t}\\n    80→\\tif len(m.Assignees) > 0 {\\n    81→\\t\\tfmt.Fprintf(w, \\\"  Assignees: %s\\\\n\\\", strings.Join(m.Assignees, \\\", \\\"))\\n    82→\\t}\\n    83→\\tfmt.Fprintf(w, \\\"  Created: %s\\\\n\\\", m.CreatedAt.Format(time.RFC3339))\\n    84→\\tfmt.Fprintf(w, \\\"  Updated: %s\\\\n\\\", m.UpdatedAt.Format(time.RFC3339))\\n    85→}\\n    86→\\n    87→func newTrailListCmd() *cobra.Command {\\n    88→\\tvar statusFilter string\\n    89→\\tvar jsonOutput bool\\n    90→\\n    91→\\tcmd := &cobra.Command{\\n    92→\\t\\tUse:   \\\"list\\\",\\n    93→\\t\\tShort: \\\"List all trails\\\",\\n    94→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    95→\\t\\t\\treturn runTrailListAll(cmd.OutOrStdout(), statusFilter, jsonOutput)\\n    96→\\t\\t},\\n    97→\\t}\\n    98→\\n    99→\\tcmd.Flags().StringVar(&statusFilter, \\\"status\\\", \\\"\\\", \\\"Filter by status (draft, open, in_progress, in_review, done, closed)\\\")\\n   100→\\tcmd.Flags().BoolVar(&jsonOutput, \\\"json\\\", false, \\\"Output as JSON\\\")\\n   101→\\n   102→\\treturn cmd\\n   103→}\\n   104→\\n   105→func runTrailListAll(w io.Writer, statusFilter string, jsonOutput bool) error {\\n   106→\\trepo, err := strategy.OpenRepository()\\n   107→\\tif err != nil {\\n   108→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   109→\\t}\\n   110→\\n   111→\\tstore := trail.NewStore(repo)\\n   112→\\ttrails, err := store.List()\\n   113→\\tif err != nil {\\n   114→\\t\\treturn fmt.Errorf(\\\"failed to list trails: %w\\\", err)\\n   115→\\t}\\n   116→\\n   117→\\tif trails == nil {\\n   118→\\t\\ttrails = []*trail.Metadata{}\\n   119→\\t}\\n   120→\\n   121→\\t// Apply status filter\\n   122→\\tif statusFilter != \\\"\\\" {\\n   123→\\t\\tstatus := trail.Status(statusFilter)\\n   124→\\t\\tif !status.IsValid() {\\n   125→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusFilter, formatValidStatuses())\\n   126→\\t\\t}\\n   127→\\t\\tvar filtered []*trail.Metadata\\n   128→\\t\\tfor _, t := range trails {\\n   129→\\t\\t\\tif t.Status == status {\\n   130→\\t\\t\\t\\tfiltered = append(filtered, t)\\n   131→\\t\\t\\t}\\n   132→\\t\\t}\\n   133→\\t\\ttrails = filtered\\n   134→\\t}\\n   135→\\n   136→\\t// Sort by updated_at descending\\n   137→\\tsort.Slice(trails, func(i, j int) bool {\\n   138→\\t\\treturn trails[i].UpdatedAt.After(trails[j].UpdatedAt)\\n   139→\\t})\\n   140→\\n   141→\\tif jsonOutput {\\n   142→\\t\\tenc := json.NewEncoder(w)\\n   143→\\t\\tenc.SetIndent(\\\"\\\", \\\"  \\\")\\n   144→\\t\\tif err := enc.Encode(trails); err != nil {\\n   145→\\t\\t\\treturn fmt.Errorf(\\\"failed to encode JSON: %w\\\", err)\\n   146→\\t\\t}\\n   147→\\t\\treturn nil\\n   148→\\t}\\n   149→\\n   150→\\tif len(trails) == 0 {\\n   151→\\t\\tfmt.Fprintln(w, \\\"No trails found.\\\")\\n   152→\\t\\tfmt.Fprintln(w)\\n   153→\\t\\tfmt.Fprintln(w, \\\"Commands:\\\")\\n   154→\\t\\tfmt.Fprintln(w, \\\"  entire trail create   Create a trail for the current branch\\\")\\n   155→\\t\\tfmt.Fprintln(w, \\\"  entire trail list     List all trails\\\")\\n   156→\\t\\tfmt.Fprintln(w, \\\"  entire trail update   Update trail metadata\\\")\\n   157→\\t\\tfmt.Fprintln(w, \\\"  entire trail enable   Enable automatic trail creation\\\")\\n   158→\\t\\tfmt.Fprintln(w, \\\"  entire trail disable  Disable automatic trail creation\\\")\\n   159→\\t\\treturn nil\\n   160→\\t}\\n   161→\\n   162→\\t// Table output\\n   163→\\tfmt.Fprintf(w, \\\"%-30s %-40s %-13s %-15s %s\\\\n\\\", \\\"BRANCH\\\", \\\"TITLE\\\", \\\"STATUS\\\", \\\"AUTHOR\\\", \\\"UPDATED\\\")\\n   164→\\tfor _, t := range trails {\\n   165→\\t\\tbranch := truncate(t.Branch, 30)\\n   166→\\t\\ttitle := truncate(t.Title, 40)\\n   167→\\t\\tfmt.Fprintf(w, \\\"%-30s %-40s %-13s %-15s %s\\\\n\\\",\\n   168→\\t\\t\\tbranch, title, t.Status, truncate(t.Author, 15), timeAgo(t.UpdatedAt))\\n   169→\\t}\\n   170→\\n   171→\\treturn nil\\n   172→}\\n   173→\\n   174→func newTrailCreateCmd() *cobra.Command {\\n   175→\\tvar title, description, base, branch, status string\\n   176→\\n   177→\\tcmd := &cobra.Command{\\n   178→\\t\\tUse:   \\\"create\\\",\\n   179→\\t\\tShort: \\\"Create a trail for the current or a new branch\\\",\\n   180→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   181→\\t\\t\\treturn runTrailCreate(cmd.OutOrStdout(), cmd.ErrOrStderr(), title, description, base, branch, status)\\n   182→\\t\\t},\\n   183→\\t}\\n   184→\\n   185→\\tcmd.Flags().StringVar(&title, \\\"title\\\", \\\"\\\", \\\"Trail title\\\")\\n   186→\\tcmd.Flags().StringVar(&description, \\\"description\\\", \\\"\\\", \\\"Trail description\\\")\\n   187→\\tcmd.Flags().StringVar(&base, \\\"base\\\", \\\"\\\", \\\"Base branch (defaults to detected default branch)\\\")\\n   188→\\tcmd.Flags().StringVar(&branch, \\\"branch\\\", \\\"\\\", \\\"Branch for the trail (defaults to current branch)\\\")\\n   189→\\tcmd.Flags().StringVar(&status, \\\"status\\\", \\\"\\\", \\\"Initial status (defaults to draft)\\\")\\n   190→\\n   191→\\treturn cmd\\n   192→}\\n   193→\\n   194→//nolint:cyclop // sequential steps for creating a trail — splitting would obscure the flow\\n   195→func runTrailCreate(w, errW io.Writer, title, description, base, branch, statusStr string) error {\\n   196→\\trepo, err := strategy.OpenRepository()\\n   197→\\tif err != nil {\\n   198→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   199→\\t}\\n   200→\\n   201→\\t// Determine branch\\n   202→\\tif branch == \\\"\\\" {\\n   203→\\t\\tbranch, err = GetCurrentBranch()\\n   204→\\t\\tif err != nil {\\n   205→\\t\\t\\treturn fmt.Errorf(\\\"failed to determine current branch: %w\\\", err)\\n   206→\\t\\t}\\n   207→\\t}\\n   208→\\n   209→\\t// Check if on default branch\\n   210→\\tif isDefault, _, defaultErr := IsOnDefaultBranch(); defaultErr == nil && isDefault {\\n   211→\\t\\tfmt.Fprintln(errW, \\\"Cannot create a trail on the default branch.\\\")\\n   212→\\t\\tfmt.Fprintln(errW, \\\"Create or switch to a feature branch first.\\\")\\n   213→\\t\\treturn NewSilentError(errors.New(\\\"cannot create trail on default branch\\\"))\\n   214→\\t}\\n   215→\\n   216→\\t// Determine base branch\\n   217→\\tif base == \\\"\\\" {\\n   218→\\t\\tbase = strategy.GetDefaultBranchName(repo)\\n   219→\\t\\tif base == \\\"\\\" {\\n   220→\\t\\t\\tbase = defaultBaseBranch\\n   221→\\t\\t}\\n   222→\\t}\\n   223→\\n   224→\\t// Check if trail already exists for this branch\\n   225→\\tstore := trail.NewStore(repo)\\n   226→\\texisting, err := store.FindByBranch(branch)\\n   227→\\tif err == nil && existing != nil {\\n   228→\\t\\tfmt.Fprintf(w, \\\"Trail already exists for branch %q (ID: %s)\\\\n\\\", branch, existing.TrailID)\\n   229→\\t\\treturn nil\\n   230→\\t}\\n   231→\\n   232→\\t// Determine title\\n   233→\\tif title == \\\"\\\" {\\n   234→\\t\\tdefaultTitle := trail.HumanizeBranchName(branch)\\n   235→\\n   236→\\t\\t// Interactive mode if flags not provided\\n   237→\\t\\tif !hasFlag(\\\"title\\\") {\\n   238→\\t\\t\\tvar inputTitle string\\n   239→\\t\\t\\tform := NewAcc