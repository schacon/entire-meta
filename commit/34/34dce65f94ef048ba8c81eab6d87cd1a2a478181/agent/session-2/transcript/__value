"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    14→)\\n    15→\\n    16→//nolint:gochecknoinits // Agent self-registration is the intended pattern\\n    17→func init() {\\n    18→\\tagent.Register(agent.AgentNameOpenCode, NewOpenCodeAgent)\\n    19→}\\n    20→\\n    21→//nolint:revive // OpenCodeAgent is clearer than Agent in this context\\n    22→type OpenCodeAgent struct{}\\n    23→\\n    24→// NewOpenCodeAgent creates a new OpenCode agent instance.\\n    25→func NewOpenCodeAgent() agent.Agent {\\n    26→\\treturn &OpenCodeAgent{}\\n    27→}\\n    28→\\n    29→// --- Identity ---\\n    30→\\n    31→func (a *OpenCodeAgent) Name() agent.AgentName   { return agent.AgentNameOpenCode }\\n    32→func (a *OpenCodeAgent) Type() agent.AgentType   { return agent.AgentTypeOpenCode }\\n    33→func (a *OpenCodeAgent) Description() string     { return \\\"OpenCode - AI-powered terminal coding agent\\\" }\\n    34→func (a *OpenCodeAgent) IsPreview() bool         { return true }\\n    35→func (a *OpenCodeAgent) ProtectedDirs() []string { return []string{\\\".opencode\\\"} }\\n    36→\\n    37→func (a *OpenCodeAgent) DetectPresence() (bool, error) {\\n    38→\\trepoRoot, err := paths.RepoRoot()\\n    39→\\tif err != nil {\\n    40→\\t\\trepoRoot = \\\".\\\"\\n    41→\\t}\\n    42→\\t// Check for .opencode directory or opencode.json config\\n    43→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\".opencode\\\")); err == nil {\\n    44→\\t\\treturn true, nil\\n    45→\\t}\\n    46→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\"opencode.json\\\")); err == nil {\\n    47→\\t\\treturn true, nil\\n    48→\\t}\\n    49→\\treturn false, nil\\n    50→}\\n    51→\\n    52→// --- Transcript Storage ---\\n    53→\\n    54→func (a *OpenCodeAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    55→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    56→\\tif err != nil {\\n    57→\\t\\treturn nil, fmt.Errorf(\\\"failed to read opencode transcript: %w\\\", err)\\n    58→\\t}\\n    59→\\treturn data, nil\\n    60→}\\n    61→\\n    62→func (a *OpenCodeAgent) ChunkTranscript(content []byte, maxSize int) ([][]byte, error) {\\n    63→\\t// OpenCode uses JSONL (one message per line) — use the shared JSONL chunker.\\n    64→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    65→\\tif err != nil {\\n    66→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk opencode transcript: %w\\\", err)\\n    67→\\t}\\n    68→\\treturn chunks, nil\\n    69→}\\n    70→\\n    71→func (a *OpenCodeAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    72→\\t// JSONL reassembly is simple concatenation.\\n    73→\\treturn agent.ReassembleJSONL(chunks), nil\\n    74→}\\n    75→\\n    76→// --- Legacy methods ---\\n    77→\\n    78→func (a *OpenCodeAgent) GetSessionID(input *agent.HookInput) string {\\n    79→\\treturn input.SessionID\\n    80→}\\n    81→\\n    82→// GetSessionDir returns the directory where Entire stores OpenCode session transcripts.\\n    83→// Transcripts are ephemeral handoff files between the TS plugin and the Go hook handler.\\n    84→// Once checkpointed, the data lives on git refs and the file is disposable.\\n    85→// Stored in os.TempDir()/entire-opencode/<sanitized-path>/ to avoid squatting on\\n    86→// OpenCode's own directories (~/.opencode/ is project-level, not home-level).\\n    87→func (a *OpenCodeAgent) GetSessionDir(repoPath string) (string, error) {\\n    88→\\t// Check for test environment override\\n    89→\\tif override := os.Getenv(\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR\\\"); override != \\\"\\\" {\\n    90→\\t\\treturn override, nil\\n    91→\\t}\\n    92→\\n    93→\\tprojectDir := SanitizePathForOpenCode(repoPath)\\n    94→\\treturn filepath.Join(os.TempDir(), \\\"entire-opencode\\\", projectDir), nil\\n    95→}\\n    96→\\n    97→func (a *OpenCodeAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n    98→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".jsonl\\\")\\n    99→}\\n   100→\\n   101→func (a *OpenCodeAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   102→\\tif input.SessionRef == \\\"\\\" {\\n   103→\\t\\treturn nil, errors.New(\\\"no session ref provided\\\")\\n   104→\\t}\\n   105→\\tdata, err := os.ReadFile(input.SessionRef)\\n   106→\\tif err != nil {\\n   107→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session: %w\\\", err)\\n   108→\\t}\\n   109→\\n   110→\\t// Parse to extract computed fields\\n   111→\\tmodifiedFiles, err := ExtractModifiedFiles(data)\\n   112→\\tif err != nil {\\n   113→\\t\\t// Non-fatal: we can still return the session without modified files\\n   114→\\t\\tmodifiedFiles = nil\\n   115→\\t}\\n   116→\\n   117→\\treturn &agent.AgentSession{\\n   118→\\t\\tAgentName:     a.Name(),\\n   119→\\t\\tSessionID:     input.SessionID,\\n   120→\\t\\tSessionRef:    input.SessionRef,\\n   121→\\t\\tNativeData:    data,\\n   122→\\t\\tModifiedFiles: modifiedFiles,\\n   123→\\t}, nil\\n   124→}\\n   125→\\n   126→func (a *OpenCodeAgent) WriteSession(session *agent.AgentSession) error {\\n   127→\\tif session == nil {\\n   128→\\t\\treturn errors.New(\\\"nil session\\\")\\n   129→\\t}\\n   130→\\tif session.SessionRef == \\\"\\\" {\\n   131→\\t\\treturn errors.New(\\\"no session ref to write to\\\")\\n   132→\\t}\\n   133→\\tif len(session.NativeData) == 0 {\\n   134→\\t\\treturn errors.New(\\\"no session data to write\\\")\\n   135→\\t}\\n   136→\\n   137→\\t// 1. Write JSONL file (for Entire's internal checkpoint use)\\n   138→\\tdir := filepath.Dir(session.SessionRef)\\n   139→\\t//nolint:gosec // G301: Session directory needs standard permissions\\n   140→\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   141→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   142→\\t}\\n   143→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   144→\\t\\treturn fmt.Errorf(\\\"failed to write session data: %w\\\", err)\\n   145→\\t}\\n   146→\\n   147→\\t// 2. If we have export data, import the session into OpenCode.\\n   148→\\t//    This enables `opencode -s <id>` for both resume and rewind.\\n   149→\\tif len(session.ExportData) == 0 {\\n   150→\\t\\treturn nil // No export data — skip import (graceful degradation)\\n   151→\\t}\\n   152→\\n   153→\\tif err := a.importSessionIntoOpenCode(session.SessionID, session.ExportData); err != nil {\\n   154→\\t\\t// Non-fatal: import is best-effort. The JSONL file is written,\\n   155→\\t\\t// and the user can always run `opencode import <file>` manually.\\n   156→\\t\\tfmt.Fprintf(os.Stderr, \\\"warning: could not import session into OpenCode: %v\\\\n\\\", err)\\n   157→\\t}\\n   158→\\n   159→\\treturn nil\\n   160→}\\n   161→\\n   162→// importSessionIntoOpenCode writes the export JSON to a temp file and runs\\n   163→// `opencode import` to restore the session into OpenCode's database.\\n   164→// For rewind (session already exists), the session is deleted first so the\\n   165→// reimport replaces it with the checkpoint-state messages.\\n   166→func (a *OpenCodeAgent) importSessionIntoOpenCode(sessionID string, exportData []byte) error {\\n   167→\\t// Delete the session first so reimport replaces it cleanly.\\n   168→\\t// opencode import uses ON CONFLICT DO NOTHING, so existing messages\\n   169→\\t// would be skipped without this step (breaking rewind).\\n   170→\\t// runOpenCodeSessionDelete treats \\\"not found\\\" as success.\\n   171→\\tif err := runOpenCodeSessionDelete(sessionID); err != nil {\\n   172→\\t\\treturn fmt.Errorf(\\\"failed to delete existing session: %w\\\", err)\\n   173→\\t}\\n   174→\\n   175→\\t// Write export JSON to a temp file for opencode import\\n   176→\\ttmpFile, err := os.CreateTemp(\\\"\\\", \\\"entire-opencode-export-*.json\\\")\\n   177→\\tif err != nil {\\n   178→\\t\\treturn fmt.Errorf(\\\"failed to create temp file: %w\\\", err)\\n   179→\\t}\\n   180→\\tdefer os.Remove(tmpFile.Name())\\n   181→\\n   182→\\tif _, err := tmpFile.Write(exportData); err != nil {\\n   183→\\t\\t_ = tmpFile.Close()\\n   184→\\t\\treturn fmt.Errorf(\\\"failed to write export data: %w\\\", err)\\n   185→\\t}\\n   186→\\tif err := tmpFile.Close(); err != nil {\\n   187→\\t\\treturn fmt.Errorf(\\\"failed to close temp file: %w\\\", err)\\n   188→\\t}\\n   189→\\n   190→\\treturn runOpenCodeImport(tmpFile.Name())\\n   191→}\\n   192→\\n   193→func (a *OpenCodeAgent) FormatResumeCommand(sessionID string) string {\\n   194→\\tif strings.TrimSpace(sessionID) == \\\"\\\" {\\n   195→\\t\\treturn \\\"opencode\\\"\\n   196→\\t}\\n   197→\\treturn \\\"opencode -s \\\" + sessionID\\n   198→}\\n   199→\\n   200→// nonAlphanumericRegex matches any non-alphanumeric character.\\n   201→var nonAlphanumericRegex = regexp.MustCompile(`[^a-zA-Z0-9]`)\\n   202→\\n   203→// SanitizePathForOpenCode converts a path to a safe directory name.\\n   204→// Replaces any non-alphanumeric character with a dash (same approach as Claude/Gemini).\\n   205→func SanitizePathForOpenCode(path string) string {\\n   206→\\treturn nonAlphanumericRegex.ReplaceAllString(path, \\\"-\\\")\\n   207→}\\n   208→\"}]},\"uuid\":\"38350dc3-a210-4bd6-bdc8-777be3c3bf2a\",\"timestamp\":\"2026-02-20T18:42:17.776Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand how different agent CLI tools can be invoked for non-interactive text generation (like generating a trail title from a transcript).\\n\\nExplore these files and areas:\\n1. `cmd/entire/cli/agent/` - all agent types, interfaces, and registration\\n2. Look for how each agent's CLI is detected/invoked\\n3. Check if there's any existing pattern for invoking agents programmatically (besides the `summarize/claude.go` which uses `claude --print`)\\n4. Check if Gemini CLI or OpenCode have non-interactive/print modes\\n5. Look at the agent.AgentType constants and agent registry\\n\\nReport back:\\n- What age