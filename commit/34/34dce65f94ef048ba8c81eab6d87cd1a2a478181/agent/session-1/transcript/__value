 {\\n   271→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files: %v\\\\n\\\", fileErr)\\n   272→\\t\\t\\t} else {\\n   273→\\t\\t\\t\\tmodifiedFiles = files\\n   274→\\t\\t\\t\\tnewTranscriptPosition = pos\\n   275→\\t\\t\\t}\\n   276→\\t\\t}\\n   277→\\t}\\n   278→\\n   279→\\t// Write prompts file\\n   280→\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   281→\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   282→\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   283→\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   284→\\t}\\n   285→\\tfmt.Fprintf(os.Stderr, \\\"Extracted %d prompt(s) to: %s\\\\n\\\", len(allPrompts), sessionDir+\\\"/\\\"+paths.PromptFileName)\\n   286→\\n   287→\\t// Write summary file\\n   288→\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   289→\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   290→\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   291→\\t}\\n   292→\\tfmt.Fprintf(os.Stderr, \\\"Extracted summary to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName)\\n   293→\\n   294→\\t// Generate commit message from last prompt\\n   295→\\tlastPrompt := \\\"\\\"\\n   296→\\tif len(allPrompts) > 0 {\\n   297→\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   298→\\t}\\n   299→\\tcommitMessage := generateCommitMessage(lastPrompt)\\n   300→\\tfmt.Fprintf(os.Stderr, \\\"Using commit message: %s\\\\n\\\", commitMessage)\\n   301→\\n   302→\\t// Get repo root for path normalization\\n   303→\\trepoRoot, err := paths.RepoRoot()\\n   304→\\tif err != nil {\\n   305→\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   306→\\t}\\n   307→\\n   308→\\tvar preUntrackedFiles []string\\n   309→\\tif preState != nil {\\n   310→\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state: %d pre-existing untracked files\\\\n\\\", len(preState.UntrackedFiles))\\n   311→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   312→\\t}\\n   313→\\n   314→\\t// Detect file changes via git status\\n   315→\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n   316→\\tif err != nil {\\n   317→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   318→\\t}\\n   319→\\n   320→\\t// Filter and normalize all paths\\n   321→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   322→\\tvar relNewFiles, relDeletedFiles []string\\n   323→\\tif changes != nil {\\n   324→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   325→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   326→\\t}\\n   327→\\n   328→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   329→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   330→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   331→\\t// if it exists in HEAD with the same content as the working tree.\\n   332→\\trelModifiedFiles = filterToUncommittedFiles(relModifiedFiles, repoRoot)\\n   333→\\n   334→\\t// Check if there are any changes\\n   335→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   336→\\tif totalChanges == 0 {\\n   337→\\t\\tfmt.Fprintf(os.Stderr, \\\"No files were modified during this session\\\\n\\\")\\n   338→\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipping commit\\\\n\\\")\\n   339→\\t\\ttransitionSessionTurnEnd(sessionID)\\n   340→\\t\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n   341→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   342→\\t\\t}\\n   343→\\t\\treturn nil\\n   344→\\t}\\n   345→\\n   346→\\t// Log file changes\\n   347→\\tlogFileChanges(relModifiedFiles, relNewFiles, relDeletedFiles)\\n   348→\\n   349→\\t// Create context file\\n   350→\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n   351→\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n   352→\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n   353→\\t}\\n   354→\\tfmt.Fprintf(os.Stderr, \\\"Created context file: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.ContextFileName)\\n   355→\\n   356→\\t// Get git author\\n   357→\\tauthor, err := GetGitAuthor()\\n   358→\\tif err != nil {\\n   359→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   360→\\t}\\n   361→\\n   362→\\t// Get strategy and agent type\\n   363→\\tstrat := GetStrategy()\\n   364→\\tagentType := ag.Type()\\n   365→\\n   366→\\t// Get transcript position/identifier from pre-prompt state\\n   367→\\tvar transcriptIdentifierAtStart string\\n   368→\\tvar transcriptLinesAtStart int\\n   369→\\tif preState != nil {\\n   370→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   371→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   372→\\t}\\n   373→\\n   374→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   375→\\tvar tokenUsage *agent.TokenUsage\\n   376→\\tif subagentExtractor, ok := ag.(agent.SubagentAwareExtractor); ok {\\n   377→\\t\\tusage, tokenErr := subagentExtractor.CalculateTotalTokenUsage(transcriptRef, transcriptLinesAtStart, subagentsDir)\\n   378→\\t\\tif tokenErr != nil {\\n   379→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage (with subagents): %v\\\\n\\\", tokenErr)\\n   380→\\t\\t} else {\\n   381→\\t\\t\\ttokenUsage = usage\\n   382→\\t\\t}\\n   383→\\t} else if calculator, ok := ag.(agent.TokenCalculator); ok {\\n   384→\\t\\t// Fall back to basic token calculation (main transcript only)\\n   385→\\t\\tusage, tokenErr := calculator.CalculateTokenUsage(transcriptRef, transcriptLinesAtStart)\\n   386→\\t\\tif tokenErr != nil {\\n   387→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage: %v\\\\n\\\", tokenErr)\\n   388→\\t\\t} else {\\n   389→\\t\\t\\ttokenUsage = usage\\n   390→\\t\\t}\\n   391→\\t}\\n   392→\\n   393→\\t// Build fully-populated step context and delegate to strategy\\n   394→\\tctx := strategy.StepContext{\\n   395→\\t\\tSessionID:                sessionID,\\n   396→\\t\\tModifiedFiles:            relModifiedFiles,\\n   397→\\t\\tNewFiles:                 relNewFiles,\\n   398→\\t\\tDeletedFiles:             relDeletedFiles,\\n   399→\\t\\tMetadataDir:              sessionDir,\\n   400→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   401→\\t\\tCommitMessage:            commitMessage,\\n   402→\\t\\tTranscriptPath:           transcriptRef,\\n   403→\\t\\tAuthorName:               author.Name,\\n   404→\\t\\tAuthorEmail:              author.Email,\\n   405→\\t\\tAgentType:                agentType,\\n   406→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   407→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   408→\\t\\tTokenUsage:               tokenUsage,\\n   409→\\t}\\n   410→\\n   411→\\tif err := strat.SaveStep(ctx); err != nil {\\n   412→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   413→\\t}\\n   414→\\n   415→\\t// Update session state transcript position for auto-commit strategy\\n   416→\\tif strat.Name() == strategy.StrategyNameAutoCommit && newTranscriptPosition > 0 {\\n   417→\\t\\tupdateAutoCommitTranscriptPosition(sessionID, newTranscriptPosition)\\n   418→\\t}\\n   419→\\n   420→\\t// Transition session phase and cleanup\\n   421→\\ttransitionSessionTurnEnd(sessionID)\\n   422→\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n   423→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   424→\\t}\\n   425→\\n   426→\\treturn nil\\n   427→}\\n   428→\\n   429→// handleLifecycleCompaction handles context compaction: saves current progress\\n   430→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   431→// Also resets the transcript offset since the transcript may be truncated.\\n   432→func handleLifecycleCompaction(ag agent.Agent, event *agent.Event) error {\\n   433→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   434→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   435→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   436→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   437→\\t)\\n   438→\\n   439→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   440→\\tsessionID := event.SessionID\\n   441→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   442→\\tif loadErr != nil {\\n   443→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for compaction: %v\\\\n\\\", loadErr)\\n   444→\\t}\\n   445→\\tif sessionState != nil {\\n   446→\\t\\tif transErr := strategy.TransitionAndLog(sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   447→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: compaction transition failed: %v\\\\n\\\", transErr)\\n   448→\\t\\t}\\n   449→\\n   450→\\t\\t// Reset transcript offset since the transcript may be truncated/reorganized\\n   451→\\t\\tsessionState.CheckpointTranscriptStart = 0\\n   452→\\n   453→\\t\\tif saveErr := strategy.SaveSessionState(sessionState); saveErr != nil {\\n   454→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to save session state after compaction: %v\\\\n\\\", saveErr)\\n   455→\\t\\t}\\n   456→\\t}\\n   457→\\n   458→\\tfmt.Fprintf(os.Stderr, \\\"Context compaction: transcript offset reset\\\\n\\\")\\n   459→\\treturn nil\\n   460→}\\n   461→\\n   462→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   463→func handleLifecycleSessionEnd(ag agent.Agent, event *agent.Event) error {\\n   464→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   465→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   466→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   467→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   468→\\t)\\n   469→\\n   470→\\tif event.SessionID == \\\"\\\" {\\n   471→\\t\\treturn nil // No session to update\\n   472→\\t}\\n   473→\\n   474→\\tif err := markSessionEnded(event.SessionID); err != nil {\\n   475→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to mark session ended: %v\\\\n\\\", err)\\n   476→\\t}\\n   477→\\treturn nil\\n   478→}\\n   479→\\n   480→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   481→func handleLifecycleSubagentStart(ag agent.Agent, event *agent.Event) error {\\n   482→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   483→\\tlogging.Info(logCtx, \\\"subagent-start\\\",\\n   484→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   485→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   486→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   487→\\t)\\n   488→\\n   489→\\t// Log context\\n   490→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent started\\\\n\\\")\\n   491→\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n   492→\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n   493→\\tfmt.Fprintf(os.Stderr, \\\"  Transcript: %s\\\\n\\\", event.SessionRef)\\n   494→\\n   495→\\t// Capture pre-task state\\n   496→\\tif err := CapturePreTaskState(event.ToolUseID); err != nil {\\n   497→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   498→\\t}\\n   499→\\n   500→\\treturn nil\\n   501→}\\n   502→\\n   503→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   504→func handleLifecycleSubagentEnd(ag agent.Agent, event *agent.Event) error {\\n   505→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   506→\\tlogging.Info(logCtx, \\\"subagent-end\\\",\\n   507→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   508→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   509→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   510→\\t\\tslog.String(\\\"subagent_id\\\", event.SubagentID),\\n   511→\\t)\\n   512→\\n   513→\\t// Extract subagent type and description from tool input\\n   514→\\tsubagentType, taskDescription := ParseSubagentTypeAndDescription(event.ToolInput)\\n   515→\\n   516→\\t// Determine subagent transcript path\\n   517→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   518→\\tvar subagentTranscriptPath string\\n   519→\\tif event.SubagentID != \\\"\\\" {\\n   520→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   521→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   522→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   523→\\t\\t}\\n   524→\\t}\\n   525→\\n   526→\\t// Log context\\n   527→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent completed\\\\n\\\")\\n   528→\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n   529→\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n   530→\\tif event.SubagentID != \\\"\\\" {\\n   531→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Agent ID: %s\\\\n\\\", event.SubagentID)\\n   532→\\t}\\n   533→\\tif subagentTranscriptPath != \\\"\\\" {\\n   534→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Subagent Transcript: %s\\\\n\\\", subagentTranscriptPath)\\n   535→\\t}\\n   536→\\n   537→\\t// Extract modified files from subagent transcript\\n   538→\\tvar modifiedFiles []string\\n   539→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   540→\\t\\ttranscriptToScan := event.SessionRef\\n   541→\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n   542→\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n   543→\\t\\t}\\n   544→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n   545→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files from subagent: %v\\\\n\\\", fileErr)\\n   546→\\t\\t} else {\\n   547→\\t\\t\\tmodifiedFiles = files\\n   548→\\t\\t}\\n   549→\\t}\\n   550→\\n   551→\\t// Load pre-task state and detect file changes\\n   552→\\tpreState, err := LoadPreTaskState(event.ToolUseID)\\n   553→\\tif err != nil {\\n   554→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-task state: %v\\\\n\\\", err)\\n   555→\\t}\\n   556→\\tvar preUntrackedFiles []string\\n   557→\\tif preState != nil {\\n   558→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   559→\\t}\\n   560→\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n   561→\\tif err != nil {\\n   562→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   563→\\t}\\n   564→\\n   565→\\t// Get repo root and normalize paths\\n   566→\\trepoRoot, err := paths.RepoRoot()\\n   567→\\tif err != nil {\\n   568→\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   569→\\t}\\n   570→\\n   571→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   572→\\tvar relNewFiles, relDeletedFiles []string\\n   573→\\tif changes != nil {\\n   574→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   575→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   576→\\t}\\n   577→\\n   578→\\t// If no changes, skip\\n   579→\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n   580→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] No file changes detected, skipping task checkpoint\\\\n\\\")\\n   581→\\t\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   582→\\t\\treturn nil\\n   583→\\t}\\n   584→\\n   585→\\t// Find checkpoint UUID from main transcript (best-effort)\\n   586→\\tvar checkpointUUID string\\n   587→\\t// Use the existing CLI-level checkpoint UUID finder\\n   588→\\tmainLines, _, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n   589→\\tif mainLines != nil {\\n   590→\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n   591→\\t}\\n   592→\\n   593→\\t// Get git author\\n   594→\\tauthor, err := GetGitAuthor()\\n   595→\\tif err != nil {\\n   596→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   597→\\t}\\n   598→\\n   599→\\t// Build task checkpoint context\\n   600→\\tstrat := GetStrategy()\\n   601→\\tagentType := ag.Type()\\n   602→\\n   603→\\tctx := strategy.TaskStepContext{\\n   604→\\t\\tSessionID:              event.SessionID,\\n   605→\\t\\tToolUseID:              event.ToolUseID,\\n   606→\\t\\tAgentID:                event.SubagentID,\\n   607→\\t\\tModifiedFiles:          relModifiedFiles,\\n   608→\\t\\tNewFiles:               relNewFiles,\\n   609→\\t\\tDeletedFiles:           relDeletedFiles,\\n   610→\\t\\tTranscriptPath:         event.SessionRef,\\n   611→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   612→\\t\\tCheckpointUUID:         checkpointUUID,\\n   613→\\t\\tAuthorName:             author.Name,\\n   614→\\t\\tAuthorEmail:            author.Email,\\n   615→\\t\\tSubagentType:           subagentType,\\n   616→\\t\\tTaskDescription:        taskDescription,\\n   617→\\t\\tAgentType:              agentType,\\n   618→\\t}\\n   619→\\n   620→\\tif err := strat.SaveTaskStep(ctx); err != nil {\\n   621→\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n   622→\\t}\\n   623→\\n   624→\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   625→\\treturn nil\\n   626→}\\n   627→\\n   628→// --- Helper functions ---\\n   629→\\n   630→// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n   631→// Prefers pre-prompt state, falls back to session state.\\n   632→func resolveTranscriptOffset(preState *PrePromptState, sessionID string) int {\\n   633→\\tif preState != nil && preState.TranscriptOffset > 0 {\\n   634→\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state found: parsing transcript from offset %d\\\\n\\\", preState.TranscriptOffset)\\n   635→\\t\\treturn preState.TranscriptOffset\\n   636→\\t}\\n   637→\\n   638→\\t// Fall back to session state (e.g., auto-commit strategy updates it after each save)\\n   639→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   640→\\tif loadErr != nil {\\n   641→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state: %v\\\\n\\\", loadErr)\\n   642→\\t\\treturn 0\\n   643→\\t}\\n   644→\\tif sessionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n   645→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session state found: parsing transcript from offset %d\\\\n\\\", sessionState.CheckpointTranscriptStart)\\n   646→\\t\\treturn sessionState.CheckpointTranscriptStart\\n   647→\\t}\\n   648→\\n   649→\\treturn 0\\n   650→}\\n   651→\\n   652→// updateAutoCommitTranscriptPosition updates the session state with the new transcript position\\n   653→// for the auto-commit strategy.\\n   654→func updateAutoCommitTranscriptPosition(sessionID string, newPosition int) {\\n   655→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   656→\\tif loadErr != nil {\\n   657→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state: %v\\\\n\\\", loadErr)\\n   658→\\t\\treturn\\n   659→\\t}\\n   660→\\tif sessionState == nil {\\n   661→\\t\\tsessionState = &strategy.SessionState{\\n   662→\\t\\t\\tSessionID: sessionID,\\n   663→\\t\\t}\\n   664→\\t}\\n   665→\\tsessionState.CheckpointTranscriptStart = newPosition\\n   666→\\tsessionState.St