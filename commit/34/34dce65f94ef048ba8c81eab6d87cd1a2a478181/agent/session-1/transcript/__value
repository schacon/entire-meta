Err error\\n    68→}\\n    69→\\n    70→// getCheckpointStore returns the checkpoint store, initializing it lazily if needed.\\n    71→// Thread-safe via sync.Once.\\n    72→func (s *AutoCommitStrategy) getCheckpointStore() (*checkpoint.GitStore, error) {\\n    73→\\ts.checkpointStoreOnce.Do(func() {\\n    74→\\t\\trepo, err := OpenRepository()\\n    75→\\t\\tif err != nil {\\n    76→\\t\\t\\ts.checkpointStoreErr = fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n    77→\\t\\t\\treturn\\n    78→\\t\\t}\\n    79→\\t\\ts.checkpointStore = checkpoint.NewGitStore(repo)\\n    80→\\t})\\n    81→\\treturn s.checkpointStore, s.checkpointStoreErr\\n    82→}\\n    83→\\n    84→// NewAutoCommitStrategy creates a new AutoCommitStrategy instance.\\n    85→//\\n    86→\\n    87→func NewAutoCommitStrategy() Strategy {\\n    88→\\treturn &AutoCommitStrategy{}\\n    89→}\\n    90→\\n    91→func (s *AutoCommitStrategy) Name() string {\\n    92→\\treturn StrategyNameAutoCommit\\n    93→}\\n    94→\\n    95→func (s *AutoCommitStrategy) Description() string {\\n    96→\\treturn \\\"Auto-commits code to active branch with metadata on entire/checkpoints/v1\\\"\\n    97→}\\n    98→\\n    99→func (s *AutoCommitStrategy) ValidateRepository() error {\\n   100→\\trepo, err := OpenRepository()\\n   101→\\tif err != nil {\\n   102→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   103→\\t}\\n   104→\\n   105→\\t_, err = repo.Worktree()\\n   106→\\tif err != nil {\\n   107→\\t\\treturn fmt.Errorf(\\\"failed to access worktree: %w\\\", err)\\n   108→\\t}\\n   109→\\n   110→\\treturn nil\\n   111→}\\n   112→\\n   113→// PrePush is called by the git pre-push hook before pushing to a remote.\\n   114→// It pushes the entire/checkpoints/v1 branch alongside the user's push.\\n   115→// Configuration options (stored in .entire/settings.json under strategy_options.push_sessions):\\n   116→//   - \\\"auto\\\": always push automatically\\n   117→//   - \\\"prompt\\\" (default): ask