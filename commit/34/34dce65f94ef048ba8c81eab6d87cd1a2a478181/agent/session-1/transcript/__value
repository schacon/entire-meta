ng()[:7])\\n   232→\\t}\\n   233→\\treturn commitCodeResult{CommitHash: commitHash, Created: created}, nil\\n   234→}\\n   235→\\n   236→// commitMetadataToMetadataBranch commits session metadata to the entire/checkpoints/v1 branch.\\n   237→// Metadata is stored at sharded path: <checkpointID[:2]>/<checkpointID[2:]>/\\n   238→// This allows direct lookup from the checkpoint ID trailer on the code commit.\\n   239→// Uses checkpoint.WriteCommitted for git operations.\\n   240→func (s *AutoCommitStrategy) commitMetadataToMetadataBranch(repo *git.Repository, ctx StepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n   241→\\tstore, err := s.getCheckpointStore()\\n   242→\\tif err != nil {\\n   243→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   244→\\t}\\n   245→\\n   246→\\t// Extract session ID from metadata dir\\n   247→\\tsessionID := filepath.Base(ctx.MetadataDir)\\n   248→\\n   249→\\t// Get current branch name\\n   250→\\tbranchName := GetCurrentBranchName(repo)\\n   251→\\n   252→\\t// Combine all file changes into FilesTouched (same as manual-commit)\\n   253→\\tfilesTouched := mergeFilesTouched(nil, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles)\\n   254→\\n   255→\\t// Load TurnID from session state (correlates checkpoints from the same turn)\\n   256→\\tvar turnID string\\n   257→\\tif state, loadErr := LoadSessionState(sessionID); loadErr == nil && state != nil {\\n   258→\\t\\tturnID = state.TurnID\\n   259→\\t}\\n   260→\\n   261→\\t// Write committed checkpoint using the checkpoint store\\n   262→\\t// Pass TranscriptPath so writeTranscript generates content_hash.txt\\n   263→\\ttranscriptPath := filepath.Join(ctx.MetadataDirAbs, paths.TranscriptFileName)\\n   264→\\terr = store.WriteCommitted(context.Background(), checkpoint.WriteCommittedOptions{\\n   265→\\t\\tCheckpointID:                checkpointID,\\n   266→\\t\\tSessionID:                   sessionID,\\n   267→\\t\\tStrategy:                    StrategyNameAutoCommit, // Use new strategy name\\n   268→\\t\\tBranch:                      branchName,\\n   269→\\t\\tMetadataDir:                 ctx.MetadataDirAbs, // Copy all files from metadata dir\\n   270→\\t\\tTranscriptPath:              transcriptPath,     // For content hash generation\\n   271→\\t\\tAuthorName:                  ctx.AuthorName,\\n   272→\\t\\tAuthorEmail:                 ctx.AuthorEmail,\\n   273→\\t\\tAgent:                       ctx.AgentType,\\n   274→\\t\\tTurnID:                      turnID,\\n   275→\\t\\tTranscriptIdentifierAtStart: ctx.StepTranscriptIdentifier,\\n   276→\\t\\tCheckpointTranscriptStart:   ctx.StepTranscriptStart,\\n   277→\\t\\tTokenUsage:                  ctx.TokenUsage,\\n   278→\\t\\tCheckpointsCount:            1,            // Each auto-commit checkpoint = 1\\n   279→\\t\\tFilesTouched:                filesTouched, // Track modified files (same as manual-commit)\\n   280→\\t})\\n   281→\\tif err != nil {\\n   282→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write committed checkpoint: %w\\\", err)\\n   283→\\t}\\n   284→\\n   285→\\tfmt.Fprintf(os.Stderr, \\\"Committed session metadata to %s (%s)\\\\n\\\", paths.MetadataBranchName, checkpointID)\\n   286→\\treturn plumbing.ZeroHash, nil // Commit hash not needed by callers\\n   287→}\\n   288→\\n   289→func (s *AutoCommitStrategy) GetRewindPoints(limit int) ([]RewindPoint, error) {\\n   290→\\t// For auto-commit strategy, rewind points are found by looking for Entire-Checkpoint trailers\\n   291→\\t// in the current branch's commit history. The checkpoint ID provides direct lookup\\n   292→\\t// to metadata on entire/checkpoints/v1 branch.\\n   293→\\trepo, err := OpenRepository()\\n   294→\\tif err != nil {\\n   295→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   296→\\t}\\n   297→\\n   298→\\thead, err := repo.Head()\\n   299→\\tif err != nil {\\n   300→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   301→\\t}\\n   302→\\n   303→\\t// Get metadata branch tree for lookups\\n   304→\\tmetadataTree, err := GetMetadataBranchTree(repo)\\n   305→\\tif err != nil {\\n   306→\\t\\t// No metadata branch yet is fine\\n   307→\\t\\treturn []RewindPoint{}, nil //nolint:nilerr // Expected when no metadata exists\\n   308→\\t}\\n   309→\\n   310→\\t// Get the main branch commit hash to determine branch-only commits\\n   311→\\tmainBranchHash := GetMainBranchHash(repo)\\n   312→\\n   313→\\t// Walk current branch history looking for commits with checkpoint trailers\\n   314→\\titer, err := repo.Log(&git.LogOptions{\\n   315→\\t\\tFrom:  head.Hash(),\\n   316→\\t\\tOrder: git.LogOrderCommitterTime,\\n   317→\\t})\\n   318→\\tif err != nil {\\n   319→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   320→\\t}\\n   321→\\n   322→\\tvar points []RewindPoint\\n   323→\\tcount := 0\\n   324→\\n   325→\\terr = iter.ForEach(func(c *object.Commit) error {\\n   326→\\t\\tif count >= logsOnlyScanLimit || len(points) >= limit {\\n   327→\\t\\t\\treturn errStop\\n   328→\\t\\t}\\n   329→\\t\\tcount++\\n   330→\\n   331→\\t\\t// Check for Entire-Checkpoint trailer\\n   332→\\t\\tcpID, found := trailers.ParseCheckpoint(c.Message)\\n   333→\\t\\tif !found {\\n   334→\\t\\t\\treturn nil\\n   335→\\t\\t}\\n   336→\\n   337→\\t\\t// Look up metadata from sharded path\\n   338→\\t\\tcheckpointPath := cpID.Path()\\n   339→\\t\\tmetadata, err := ReadCheckpointMetadata(metadataTree, checkpointPath)\\n   340→\\t\\tif err != nil {\\n   341→\\t\\t\\t// Checkpoint exists in commit but no metadata found - skip this commit\\n   342→\\t\\t\\treturn nil //nolint:nilerr // Intentional: skip commits without metadata\\n   343→\\t\\t}\\n   344→\\n   345→\\t\\tmessage := strings.Split(c.Message, \\\"\\\\n\\\")[0]\\n   346→\\n   347→\\t\\t// Determine if this is a full rewind or logs-only\\n   348→\\t\\t// Full rewind is allowed if commit is only on this branch (not reachable from main)\\n   349→\\t\\tisLogsOnly := false\\n   350→\\t\\tif mainBranchHash != plumbing.ZeroHash {\\n   351→\\t\\t\\tif IsAncestorOf(repo, c.Hash, mainBranchHash) {\\n   352→\\t\\t\\t\\tisLogsOnly = true\\n   353→\\t\\t\\t}\\n   354→\\t\\t}\\n   355→\\n   356→\\t\\t// Build metadata path - for task checkpoints, include the task path\\n   357→\\t\\tmetadataDir := checkpointPath\\n   358→\\t\\tif metadata.IsTask && metadata.ToolUseID != \\\"\\\" {\\n   359→\\t\\t\\tmetadataDir = checkpointPath + \\\"/tasks/\\\" + metadata.ToolUseID\\n   360→\\t\\t}\\n   361→\\n   362→\\t\\t// Read session prompt from metadata tree\\n   363→\\t\\tsessionPrompt := ReadSessionPromptFromTree(metadataTree, checkpointPath)\\n   364→\\n   365→\\t\\tpoints = append(points, RewindPoint{\\n   366→\\t\\t\\tID:               c.Hash.String(),\\n   367→\\t\\t\\tMessage:          message,\\n   368→\\t\\t\\tMetadataDir:      metadataDir,\\n   369→\\t\\t\\tDate:             c.Author.When,\\n   370→\\t\\t\\tIsLogsOnly:       isLogsOnly,\\n   371→\\t\\t\\tCheckpointID:     cpID,\\n   372→\\t\\t\\tIsTaskCheckpoint: metadata.IsTask,\\n   373→\\t\\t\\tToolUseID:        metadata.ToolUseID,\\n   374→\\t\\t\\tAgent:            metadata.Agent,\\n   375→\\t\\t\\tSessionID:        metadata.SessionID,\\n   376→\\t\\t\\tSessionPrompt:    sessionPrompt,\\n   377→\\t\\t})\\n   378→\\n   379→\\t\\treturn nil\\n   380→\\t})\\n   381→\\n   382→\\tif err != nil && !errors.Is(err, errStop) {\\n   383→\\t\\treturn nil, fmt.Errorf(\\\"failed to iterate commits: %w\\\", err)\\n   384→\\t}\\n   385→\\n   386→\\treturn points, nil\\n   387→}\\n   388→\\n   389→// findTaskMetadataPathForCommit looks up the task metadata path for a task checkpoint commit\\n   390→// by searching the entire/checkpoints/v1 branch commit history for the checkpoint directory.\\n   391→// Returns (\\\"\\\", nil) if metadata is not found - this is expected for commits without metadata.\\n   392→func (s *AutoCommitStrategy) findTaskMetadataPathForCommit(repo *git.Repository, commitSHA, toolUseID string) (string, error) {\\n   393→\\t// Get the entire/checkpoints/v1 branch\\n   394→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   395→\\tref, err := repo.Reference(refName, true)\\n   396→\\tif err != nil {\\n   397→\\t\\tif isNotFoundError(err) {\\n   398→\\t\\t\\treturn \\\"\\\", nil // No metadata branch yet\\n   399→\\t\\t}\\n   400→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get metadata branch: %w\\\", err)\\n   401→\\t}\\n   402→\\n   403→\\t// Search commit history for a commit referencing this code commit SHA and tool use ID\\n   404→\\tshortSHA := commitSHA\\n   405→\\tif len(shortSHA) > 7 {\\n   406→\\t\\tshortSHA = shortSHA[:7]\\n   407→\\t}\\n   408→\\n   409→\\titer, err := repo.Log(&git.LogOptions{From: ref.Hash()})\\n   410→\\tif err != nil {\\n   411→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   412→\\t}\\n   413→\\n   414→\\tvar foundTaskPath string\\n   415→\\terr = iter.ForEach(func(commit *object.Commit) error {\\n   416→\\t\\t// Check if commit message contains \\\"Commit: <sha>\\\" and the tool use ID\\n   417→\\t\\tif strings.Contains(commit.Message, \\\"Commit: \\\"+shortSHA) &&\\n   418→\\t\\t\\tstrings.Contains(commit.Message, toolUseID) {\\n   419→\\t\\t\\t// Parse task metadata trailer\\n   420→\\t\\t\\tif taskPath, found := trailers.ParseTaskMetadata(commit.Message); found {\\n   421→\\t\\t\\t\\tfoundTaskPath = taskPath\\n   422→\\t\\t\\t\\treturn errStop // Found it\\n   423→\\t\\t\\t}\\n   424→\\t\\t}\\n   425→\\t\\treturn nil\\n   426→\\t})\\n   427→\\tif err != nil && !errors.Is(err, errStop) {\\n   428→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to iterate commits: %w\\\", err)\\n   429→\\t}\\n   430→\\n   431→\\treturn foundTaskPath, nil\\n   432→}\\n   433→\\n   434→func (s *AutoCommitStrategy) Rewind(point RewindPoint) error {\\n   435→\\tcommitHash := plumbing.NewHash(point.ID)\\n   436→\\tshortID, err := HardResetWithProtection(commitHash)\\n   437→\\tif err != nil {\\n   438→\\t\\treturn err\\n   439→\\t}\\n   440→\\n   441→\\tfmt.Println()\\n   442→\\tfmt.Printf(\\\"Reset to commit %s\\\\n\\\", shortID)\\n   443→\\tfmt.Println()\\n   444→\\n   445→\\treturn nil\\n   446→}\\n   447→\\n   448→func (s *AutoCommitStrategy) CanRewind() (bool, string, error) {\\n   449→\\treturn checkCanRewind()\\n   450→}\\n   451→\\n   452→// PreviewRewind returns what will happen if rewinding to the given point.\\n   453→// For auto-commit strategy, this returns nil since git reset doesn't delete untracked files.\\n   454→func (s *AutoCommitStrategy) PreviewRewind(_ RewindPoint) (*RewindPreview, error) {\\n   455→\\t// Auto-commit uses git reset --hard which doesn't affect untracked files\\n   456→\\t// Return empty preview to indicate no untracked files will be deleted\\n   457→\\treturn &RewindPreview{}, nil\\n   458→}\\n   459→\\n   460→// EnsureSetup ensures the strategy's required setup is in place.\\n   461→// For auto-commit strategy:\\n   462→// - Ensure .entire/.gitignore has all required entries\\n   463→// - Create orphan entire/checkpoints/v1 branch if it doesn't exist\\n   464→// - Install git hooks if missing (self-healing for third-party overwrites)\\n   465→func (s *AutoCommitStrategy) EnsureSetup() error {\\n   466→\\tif err := EnsureEntireGitignore(); err != nil {\\n   467→\\t\\treturn err\\n   468→\\t}\\n   469→\\n   470→\\trepo, err := OpenRepository()\\n   471→\\tif err != nil {\\n   472→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   473→\\t}\\n   474→\\n   475→\\t// Ensure the entire/checkpoints/v1 orphan branch exists\\n   476→\\tif err := EnsureMetadataBranch(repo); err != nil {\\n   477→\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n   478→\\t}\\n   479→\\n   480→\\t// Install generic hooks if missing (they delegate to strategy at runtime)\\n   481→\\tif !IsGitHookInstalled() {\\n   482→\\t\\tif _, err := InstallGitHook(true); err != nil {\\n   483→\\t\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   484→\\t\\t}\\n   485→\\t}\\n   486→\\n   487→\\treturn nil\\n   488→}\\n   489→\\n   490→// GetSessionInfo returns session information for linking commits.\\n   491→// For auto-commit strategy, we don't track active sessions - metadata is stored on\\n   492→// entire/checkpoints/v1 branch when SaveStep is called. Active branch commits\\n   493→// are kept clean (no trailers), so this returns ErrNoSession.\\n   494→// Use ListSessions() or GetSession() to retrieve session info from the metadata branch.\\n   495→func (s *AutoCommitStrategy) GetSessionInfo() (*SessionInfo, error) {\\n   496→\\t// Dual strategy doesn't track active sessions like shadow does.\\n   497→\\t// Session metadata is stored on entire/checkpoints/v1 branch and can be\\n   498→\\t// retrieved via ListSessions() or GetSession().\\n   499→\\treturn nil, ErrNoSession\\n   500→}\\n   501→\\n   502→// SaveTaskStep creates a checkpoint commit for a completed task.\\n   503→// For auto-commit strategy:\\n   504→// 1. Commit code changes to active branch (no trailers - clean history)\\n   505→// 2. Commit task metadata to entire/checkpoints/v1 branch with checkpoint format\\n   506→func (s *AutoCommitStrategy) SaveTaskStep(ctx TaskStepContext) error {\\n   507→\\trepo, err := OpenRepository()\\n   508→\\tif err != nil {\\n   509→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   510→\\t}\\n   511→\\n   512→\\t// Ensure entire/checkpoints/v1 branch exists\\n   513→\\tif err := EnsureMetadataBranch(repo); err != nil {\\n   514→\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n   515→\\t}\\n   516→\\n   517→\\t// Generate checkpoint ID for this task checkpoint\\n   518→\\tcpID, err := id.Generate()\\n   519→\\tif err != nil {\\n   520→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   521→\\t}\\n   522→\\n   523→\\t// Step 1: Commit code changes to active branch with checkpoint ID trailer\\n   524→\\t// We do code first to avoid orphaned metadata if this step fails.\\n   525→\\t_, err = s.commitTaskCodeToActive(repo, ctx, cpID)\\n   526→\\tif err != nil {\\n   527→\\t\\treturn fmt.Errorf(\\\"failed to commit task code to active branch: %w\\\", err)\\n   528→\\t}\\n   529→\\n   530→\\t// Step 2: Commit task metadata to entire/checkpoints/v1 branch at sharded path\\n   531→\\t_, err = s.commitTaskMetadataToMetadataBranch(repo, ctx, cpID)\\n   532→\\tif err != nil {\\n   533→\\t\\treturn fmt.Errorf(\\\"failed to commit task metadata to entire/checkpoints/v1 branch: %w\\\", err)\\n   534→\\t}\\n   535→\\n   536→\\t// Log task checkpoint creation\\n   537→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   538→\\tattrs := []any{\\n   539→\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n   540→\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"task\\\"),\\n   541→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   542→\\t\\tslog.String(\\\"checkpoint_uuid\\\", ctx.CheckpointUUID),\\n   543→\\t\\tslog.String(\\\"tool_use_id\\\", ctx.ToolUseID),\\n   544→\\t\\tslog.String(\\\"subagent_type\\\", ctx.SubagentType),\\n   545→\\t\\tslog.Int(\\\"modified_files\\\", len(ctx.ModifiedFiles)),\\n   546→\\t\\tslog.Int(\\\"new_files\\\", len(ctx.NewFiles)),\\n   547→\\t\\tslog.Int(\\\"deleted_files\\\", len(ctx.DeletedFiles)),\\n   548→\\t}\\n   549→\\tif ctx.IsIncremental {\\n   550→\\t\\tattrs = append(attrs,\\n   551→\\t\\t\\tslog.Bool(\\\"is_incremental\\\", true),\\n   552→\\t\\t\\tslog.String(\\\"incremental_type\\\", ctx.IncrementalType),\\n   553→\\t\\t\\tslog.Int(\\\"incremental_sequence\\\", ctx.IncrementalSequence),\\n   554→\\t\\t)\\n   555→\\t}\\n   556→\\tlogging.Info(logCtx, \\\"task checkpoint saved\\\", attrs...)\\n   557→\\n   558→\\treturn nil\\n   559→}\\n   560→\\n   561→// commitTaskCodeToActive commits task code changes to the active branch.\\n   562→// Adds an Entire-Checkpoint trailer for metadata lookup that survives amend/rebase.\\n   563→// Skips commit creation if there are no file changes.\\n   564→func (s *AutoCommitStrategy) commitTaskCodeToActive(repo *git.Repository, ctx TaskStepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n   565→\\thasFileChanges := len(ctx.ModifiedFiles) > 0 || len(ctx.NewFiles) > 0 || len(ctx.DeletedFiles) > 0\\n   566→\\n   567→\\t// If no file changes, skip code commit\\n   568→\\tif !hasFileChanges {\\n   569→\\t\\tfmt.Fprintf(os.Stderr, \\\"No code changes to commit for task checkpoint\\\\n\\\")\\n   570→\\t\\t// Return current HEAD hash so metadata can still be stored\\n   571→\\t\\thead, err := repo.Head()\\n   572→\\t\\tif err != nil {\\n   573→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   574→\\t\\t}\\n   575→\\t\\treturn head.Hash(), nil\\n   576→\\t}\\n   577→\\n   578→\\tworktree, err := repo.Worktree()\\n   579→\\tif err != nil {\\n   580→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   581→\\t}\\n   582→\\n   583→\\t// Stage code changes\\n   584→\\tStageFiles(worktree, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles, StageForTask)\\n   585→\\n   586→\\t// Build commit message with checkpoint trailer\\n   587→\\tshortToolUseID := ctx.ToolUseID\\n   588→\\tif len(shortToolUseID) > id.ShortIDLength {\\n   589→\\t\\tshortToolUseID = shortToolUseID[:id.ShortIDLength]\\n   590→\\t}\\n   591→\\n   592→\\tvar subject string\\n   593→\\tif ctx.IsIncremental {\\n   594→\\t\\tsubject = FormatIncrementalSubject(\\n   595→\\t\\t\\tctx.IncrementalType,\\n   596→\\t\\t\\tctx.SubagentType,\\n   597→\\t\\t\\tctx.TaskDescription,\\n   598→\\t\\t\\tctx.TodoContent,\\n   599→\\t\\t\\tctx.IncrementalSequence,\\n   600→\\t\\t\\tshortToolUseID,\\n   601→\\t\\t)\\n   602→\\t} else {\\n   603→\\t\\tsubject = FormatSubagentEndMessage(ctx.SubagentType, ctx.TaskDescription, shortToolUseID)\\n   604→\\t}\\n   605→\\n   606→\\t// Add checkpoint ID trailer to commit message\\n   607→\\tcommitMsg := subject + \\\"\\\\n\\\\n\\\" + trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n   608→\\n   609→\\tauthor := &object.Signature{\\n   610→\\t\\tName:  ctx.AuthorName,\\n   611→\\t\\tEmail: ctx.AuthorEmail,\\n   612→\\t\\tWhen:  time.Now(),\\n   613→\\t}\\n   614→\\n   615→\\tcommitHash, err := commitOrHead(repo, worktree, commitMsg, author)\\n   616→\\tif err != nil {\\n   617→\\t\\treturn plumbing.ZeroHash, err\\n   618→\\t}\\n   619→\\n   620→\\tif ctx.IsIncremental {\\n   621→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed incremental checkpoint #%d to active branch (%s)\\\\n\\\", ctx.IncrementalSequence, commitHash.String()[:7])\\n   622→\\t} else {\\n   623→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed task checkpoint to active branch (%s)\\\\n\\\", commitHash.String()[:7])\\n   624→\\t}\\n   625→\\treturn commitHash, nil\\n   626→}\\n   627→\\n   628→// commitTaskMetadataToMetadataBranch commits task metadata to the entire/checkpoints/v1 branch.\\n   629→// Uses sharded path: <checkpointID[:2]>/<checkpointID[2:]>/tasks/<tool-use-id>/\\n   630→// Returns the metadata commit hash.\\n   631→// When IsIncremental is true, only writes the incremental checkpoint file, skipping transcripts.\\n   632→// Uses checkpoint.WriteCommitted for git operations.\\n   633→func (s *AutoCommitStrategy) commitTaskMetadataToMetadataBranch(repo *git.Repository, ctx TaskStepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n   634→\\tstore, err := s.getCheckpointStore()\\n   635→\\tif err != nil {\\n   636→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   637→\\t}\\n   638→\\n   639→\\t// Format commit subject line for better git log readability\\n   640→\\tshortToolUseID := ctx.ToolUseID\\n   641→\\tif len(shortToolUseID) > id.ShortIDLength {\\n   642→\\t\\tshortToolUseID = shortToolUseID[:id.ShortIDLength]\\n   643→\\t}\\n   644→\\n   645→\\tvar messageSubject string\\n   646→\\tif ctx.IsIncremental {\\n   647→\\t\\tmessageSubject = FormatIncrementalSubject(\\n   648→\\t\\t\\tctx.IncrementalType,\\n   649→\\t\\t\\tctx.SubagentType,\\n   650→\\t\\t\\tctx.TaskDescription,\\n   651→\\t\\t\\tctx.TodoContent,\\n   652→\\t\\t\\tctx.IncrementalSequence,\\n   653→\\t\\t\\tshortToolUseID,\\n   654→\\t\\t)\\n   655→\\t} else {\\n   656→\\t\\tmessageSubject = FormatSubagentEndMessage(ctx.SubagentType, ctx.TaskDescription, shortToolUseID)\\n   657→\\t}\\n   658→\\n   659→\\t// Get current branch name\\n   660→\\tbranchName := GetCurrentBranchName(repo)\\n   661→\\n   662→\\t// Write committed checkpoint using the checkpoint store\\n   663→\\terr = store.WriteCommitted(context.Background(), checkpoint.WriteCommittedOptions{\\n   664→\\t\\tCheckpointID:           checkpointID,\\n   665→\\t\\tSessionID:              ctx.SessionID,\\n   666→\\t\\tStrategy:               StrategyNameAutoCommit,\\n   667→\\t\\tBranch:                 branchName,\\n   668→\\t\\tIsTask:                 true,\\n   669→\\t\\tToolUseID:              ctx.ToolUseID,\\n   670→\\t\\tAgentID:                ctx.AgentID,\\n   671→\\t\\tCheckpointUUID:         ctx.CheckpointUUID,\\n   672→\\t\\tTranscriptPath:         ctx.TranscriptPath,\\n   673→\\t\\tSubagentTranscriptPath: ctx.SubagentTranscriptPath,\\n   674→\\t\\tIsIncremental:          ctx.IsIncremental,\\n   675→\\t\\tIncrementalSequence:    ctx.IncrementalSequence,\\n   676→\\t\\tIncrementalType:        ctx.IncrementalType,\\n   677→\\t\\tIncrementalData:        ctx.IncrementalData,\\n   678→\\t\\tCommitSubject:          messageSubject,\\n   679→\\t\\tAuthorName:             ctx.AuthorName,\\n   680→\\t\\tAuthorEmail:            ctx.AuthorEmail,\\n   681→\\t\\tAgent:                  ctx.AgentType,\\n   682→\\t})\\n   683→\\tif err != nil {\\n   684→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write task checkpoint: %w\\\", err)\\n   685→\\t}\\n   686→\\n   687→\\tif ctx.IsIncremental {\\n   688→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed incremental checkpoint metadata to %s (%s)\\\\n\\\", paths.MetadataBranchName, checkpointID)\\n   689→\\t} else {\\n   690→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed task metadata to %s (%s)\\\\n\\\", paths.MetadataBranchName, checkpointID)\\n   691→\\t}\\n   692→\\treturn plumbing.ZeroHash, nil // Commit hash not needed by callers\\n   693→}\\n   694→\\n   695→// GetTaskCheckpoint returns the task checkpoint for a given rewind point.\\n   696→// For auto-commit strategy, checkpoints are stored on the entire/checkpoints/v1 branch in checkpoint directories.\\n   697→// Returns ErrNotTaskCheckpoint if the point is not a task checkpoint.\\n   698→func (s *AutoCommitStrategy) GetTaskCheckpoint(point RewindPoint) (*TaskCheckpoint, error) {\\n   699→\\tif !point.IsTaskCheckpoint {\\n   700→\\t\\treturn nil, ErrNotTaskCheckpoint\\n   701→\\t}\\n   702→\\n   703→\\trepo, err := OpenRepository()\\n   704→\\tif err != nil {\\n   705→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   706→\\t}\\n   707→\\n   708→\\t// Get the entire/checkpoints/v1 branch\\n   709→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   710→\\tref, err := repo.Reference(refName, true)\\n   711→\\tif err != nil {\\n   712→\\t\\treturn nil, fmt.Errorf(\\\"metadata branch %s not found: %w\\\", paths.MetadataBranchName, err)\\n   713→\\t}\\n   714→\\n   715→\\tmetadataCommit, err := repo.CommitObject(ref.Hash())\\n   716→\\tif err != nil {\\n   717→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch commit: %w\\\", err)\\n   718→\\t}\\n   719→\\n   720→\\ttree, err := metadataCommit.Tree()\\n   721→\\tif err != nil {\\n   722→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata tree: %w\\\", err)\\n   723→\\t}\\n   724→\\n   725→\\t// Find checkpoint using the metadata path from rewin