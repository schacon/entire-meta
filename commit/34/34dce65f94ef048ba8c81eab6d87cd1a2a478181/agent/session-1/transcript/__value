r\\\",\\n   901→\\t\\tHidden: true,\\n   902→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   903→\\t\\t\\tw := cmd.OutOrStdout()\\n   904→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   905→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   906→\\t\\t\\t}\\n   907→\\t\\t\\treturn nil\\n   908→\\t\\t},\\n   909→\\t}\\n   910→}\\n   911→\\n   912→// shellCompletionComment is the comment preceding the completion line\\n   913→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   914→\\n   915→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   916→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   917→\\n   918→// shellCompletionTarget returns the rc file path and completion lines for the\\n   919→// user's current shell.\\n   920→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   921→\\thome, err := os.UserHomeDir()\\n   922→\\tif err != nil {\\n   923→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   924→\\t}\\n   925→\\n   926→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   927→\\tswitch {\\n   928→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   929→\\t\\treturn \\\"Zsh\\\",\\n   930→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   931→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   932→\\t\\t\\tnil\\n   933→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   934→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   935→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   936→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   937→\\t\\t}\\n   938→\\t\\treturn \\\"Bash\\\",\\n   939→\\t\\t\\tbashRC,\\n   940→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   941→\\t\\t\\tnil\\n   942→\\tcase strings.Contains(shell, \\\"f