789→\\n  1790→\\treturn errCount\\n  1791→}\\n  1792→\\n  1793→// filesChangedInCommit returns the set of files changed in a commit by diffing against its parent.\\n  1794→func filesChangedInCommit(commit *object.Commit) map[string]struct{} {\\n  1795→\\tresult := make(map[string]struct{})\\n  1796→\\n  1797→\\tcommitTree, err := commit.Tree()\\n  1798→\\tif err != nil {\\n  1799→\\t\\treturn result\\n  1800→\\t}\\n  1801→\\n  1802→\\tvar parentTree *object.Tree\\n  1803→\\tif commit.NumParents() > 0 {\\n  1804→\\t\\tparent, err := commit.Parent(0)\\n  1805→\\t\\tif err != nil {\\n  1806→\\t\\t\\treturn result\\n  1807→\\t\\t}\\n  1808→\\t\\tparentTree, err = parent.Tree()\\n  1809→\\t\\tif err != nil {\\n  1810→\\t\\t\\treturn result\\n  1811→\\t\\t}\\n  1812→\\t}\\n  1813→\\n  1814→\\tif parentTree == nil {\\n  1815→\\t\\t// Initial commit — all files are new\\n  1816→\\t\\tif iterErr := commitTree.Files().ForEach(func(f *object.File) error {\\n  1817→\\t\\t\\tresult[f.Name] = struct{}{}\\n  1818→\\t\\t\\treturn nil\\n  1819→\\t\\t}); iterErr != nil {\\n  1820→\\t\\t\\treturn result\\n  1821→\\t\\t}\\n  1822→\\t\\treturn result\\n  1823→\\t}\\n  1824→\\n  1825→\\tchanges, err := parentTree.Diff(commitTree)\\n  1826→\\tif err != nil {\\n  1827→\\t\\treturn result\\n  1828→\\t}\\n  1829→\\tfor _, change := range changes {\\n  1830→\\t\\tname := change.To.Name\\n  1831→\\t\\tif name == \\\"\\\" {\\n  1832→\\t\\t\\tname = change.From.Name\\n  1833→\\t\\t}\\n  1834→\\t\\tresult[name] = struct{}{}\\n  1835→\\t}\\n  1836→\\treturn result\\n  1837→}\\n  1838→\\n  1839→// subtractFiles returns files that are NOT in the exclude set.\\n  1840→func subtractFiles(files []string, exclude map[string]struct{}) []string {\\n  1841→\\tvar remaining []string\\n  1842→\\tfor _, f := range files {\\n  1843→\\t\\tif _, excluded := exclude[f]; !excluded {\\n  1844→\\t\\t\\tremaining = append(remaining, f)\\n  1845→\\t\\t}\\n  1846→\\t}\\n  1847→\\treturn remaining\\n  1848→}\\n  1849→\\