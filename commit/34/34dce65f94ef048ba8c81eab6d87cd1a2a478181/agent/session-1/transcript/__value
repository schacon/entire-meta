File, completionLine); err != nil {\\n   992→\\t\\treturn fmt.Errorf(\\\"failed to update %s: %w\\\", rcFile, err)\\n   993→\\t}\\n   994→\\n   995→\\tfmt.Fprintf(w, \\\"✓ Shell completion added to %s\\\\n\\\", rcFile)\\n   996→\\tfmt.Fprintln(w, \\\"  Restart your shell to activate\\\")\\n   997→\\n   998→\\treturn nil\\n   999→}\\n  1000→\\n  1001→// isCompletionConfigured checks if shell completion is already in the rc file.\\n  1002→func isCompletionConfigured(rcFile string) bool {\\n  1003→\\t//nolint:gosec // G304: rcFile is constructed from home dir + known filename, not user input\\n  1004→\\tcontent, err := os.ReadFile(rcFile)\\n  1005→\\tif err != nil {\\n  1006→\\t\\treturn false // File doesn't exist or can't read, treat as not configured\\n  1007→\\t}\\n  1008→\\treturn strings.Contains(string(content), \\\"entire completion\\\")\\n  1009→}\\n  1010→\\n  1011→// appendShellCompletion adds the completion line to the rc file.\\n  1012→func appendShellCompletion(rcFile, completionLine string) error {\\n  1013→\\tif err := os.MkdirAll(filepath.Dir(rcFile), 0o700); err != nil {\\n  1014→\\t\\treturn fmt.Errorf(\\\"creating directory: %w\\\", err)\\n  1015→\\t}\\n  1016→\\t//nolint:gosec // G302: Shell rc files need 0644 for user readability\\n  1017→\\tf, err := os.OpenFile(rcFile, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0o644)\\n  1018→\\tif err != nil {\\n  1019→\\t\\treturn fmt.Errorf(\\\"opening file: %w\\\", err)\\n  1020→\\t}\\n  1021→\\tdefer f.Close()\\n  1022→\\n  1023→\\t_, err = f.WriteString(\\\"\\\\n\\\" + shellCompletionComment + \\\"\\\\n\\\" + completionLine + \\\"\\\\n\\\")\\n  1024→\\tif err != nil {\\n  1025→\\t\\treturn fmt.Errorf(\\\"writing completion: %w\\\", err)\\n  1026→\\t}\\n  1027→\\treturn nil\\n  1028→}\\n  1029→\\n  1030→// promptTelemetryConsent asks the user if they want to enable telemetry.\\n  1031→// It modifies settings.Telemetry based on the user's choice or flags.\\n  1032→// The caller is responsible for saving settings.