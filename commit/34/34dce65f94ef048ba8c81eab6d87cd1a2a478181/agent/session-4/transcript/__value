s an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   224→// Only adds a trailer if there's actually new session content to condense.\\n   225→// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   226→// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   227→// For amended commits, preserves the existing checkpoint ID.\\n   228→//\\n   229→// The source parameter indicates how the commit was initiated:\\n   230→//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   231→//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   232→//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   233→//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   234→//\\n   235→\\n   236→func (s *ManualCommitStrategy) PrepareCommitMsg(commitMsgFile string, source string) error {\\n   237→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   238→\\n   239→\\t// Skip during rebase, cherry-pick, or revert operations\\n   240→\\t// These are replaying existing commits and should not be linked to agent sessions\\n   241→\\tif isGitSequenceOperation() {\\n   242→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n   243→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   244→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   245→\\t\\t)\\n   246→\\t\\treturn nil\\n   247→\\t}\\n   248→\\n   249→\\t// Skip for merge and squash sources\\n   250→\\t// These are auto-generated messages - not from Claude sessions\\n   251→\\tswitch source {\\n   252→\\tcase \\\"merge\\\", \\\"squash\\\":\\n   253→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n   254→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   255→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   256→\\t\\t)\\n   257→\\t\\treturn nil\\n   258→\\t}\\n   259→\\n   260→\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   261→\\tif source == \\\"commit\\\" {\\n   262→\\t\\treturn s.handleAmendCommitMsg(logCtx, commitMsgFile)\\n   263→\\t}\\n   264→\\n   265→\\trepo, err := OpenRepository()\\n   266→\\tif err != nil {\\n   267→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   268→\\t}\\n   269→\\n   270→\\tworktreePath, err := GetWorktreePath()\\n   271→\\tif err != nil {\\n   272→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   273→\\t}\\n   274→\\n   275→\\t// Find all active sessions for this worktree\\n   276→\\t// We match by worktree (not BaseCommit) because the user may have made\\n   277→\\t// intermediate commits without entering new prompts, causing HEAD to diverge\\n   278→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   279→\\tif err != nil || len(sessions) == 0 {\\n   280→\\t\\t// No active sessions or error listing - silently skip (hooks must be resilient)\\n   281→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no active sessions\\\",\\n   282→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   283→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   284→\\t\\t)\\n   285→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   286→\\t}\\n   287→\\n   288→\\t// Fast path: when an agent is committing (ACTIVE session + no TTY), skip\\n   289→\\t// content detection and interactive prompts. The agent can't respond to TTY\\n   290→\\t// prompts and the content detection can miss mid-session work (no shadow\\n   291→\\t// branch yet, transcript analysis may fail). Generate a checkpoint ID and\\n   292→\\t// add the trailer directly.\\n   293→\\tif !hasTTY() {\\n   294→\\t\\tfor _, state := range sessions {\\n   295→\\t\\t\\tif state.Phase.IsActive() {\\n   296→\\t\\t\\t\\treturn s.addTrailerForAgentCommit(logCtx, commitMsgFile, state, source)\\n   297→\\t\\t\\t}\\n   298→\\t\\t}\\n   299→\\t}\\n   300→\\n   301→\\t// Check if any session has new content to condense\\n   302→\\tsessionsWithContent := s.filterSessionsWithNewContent(repo, sessions)\\n   303→\\n   304→\\tif len(sessionsWithContent) == 0 {\\n   305→\\t\\t// No new content — no trailer needed\\n   306→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no content to link\\\",\\n   307→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   308→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   309→\\t\\t\\tslog.Int(\\\"sessions_found\\\", len(sessions)),\\n   310→\\t\\t)\\n   311→\\t\\treturn nil\\n   312→\\t}\\n   313→\\n   314→\\t// Read current commit message\\n   315→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   316→\\tif err != nil {\\n   317→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   318→\\t}\\n   319→\\n   320→\\tmessage := string(content)\\n   321→\\n   322→\\t// Check if trailer already exists (ParseCheckpoint validates format, so found==true means valid)\\n   323→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   324→\\t\\t// Trailer already exists (e.g., amend) - keep it\\n   325→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: trailer already exists\\\",\\n   326→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   327→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   328→\\t\\t\\tslog.String(\\\"existing_checkpoint_id\\\", existingCpID.String()),\\n   329→\\t\\t)\\n   330→\\t\\treturn nil\\n   331→\\t}\\n   332→\\n   333→\\t// Generate a fresh checkpoint ID\\n   334→\\tcheckpointID, err := id.Generate()\\n   335→\\tif err != nil {\\n   336→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   337→\\t}\\n   338→\\n   339→\\t// Determine agent type and last prompt from session\\n   340→\\tagentType := DefaultAgentType // default for backward compatibility\\n   341→\\tvar lastPrompt string\\n   342→\\tif len(sessionsWithContent) > 0 {\\n   343→\\t\\tfirstSession := sessionsWithContent[0]\\n   344→\\t\\tif firstSession.AgentType != \\\"\\\" {\\n   345→\\t\\t\\tagentType = firstSession.AgentType\\n   346→\\t\\t}\\n   347→\\t\\tlastPrompt = s.getLastPrompt(repo, firstSession)\\n   348→\\t}\\n   349→\\n   350→\\t// Prepare prompt for display: collapse newlines/whitespace, then truncate (rune-safe)\\n   351→\\tdisplayPrompt := stringutil.TruncateRunes(stringutil.CollapseWhitespace(lastPrompt), 80, \\\"...\\\")\\n   352→\\n   353→\\t// Add trailer differently based on commit source\\n   354→\\tswitch source {\\n   355→\\tcase \\\"message\\\":\\n   356→\\t\\t// Using -m or -F: ask user interactively whether to add trailer\\n   357→\\t\\t// (comments won't be stripped by git in this mode)\\n   358→\\n   359→\\t\\t// Build context string for interactive prompt\\n   360→\\t\\tvar promptContext string\\n   361→\\t\\tif displayPrompt != \\\"\\\" {\\n   362→\\t\\t\\tpromptContext = \\\"You have an active \\\" + string(agentType) + \\\" session.\\\\nLast Prompt: \\\" + displayPrompt\\n   363→\\t\\t}\\n   364→\\n   365→\\t\\tif !askConfirmTTY(\\\"Link this commit to \\\"+string(agentType)+\\\" session context?\\\", promptContext, true) {\\n   366→\\t\\t\\t// User declined - don't add trailer\\n   367→\\t\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: user declined trailer\\\",\\n   368→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   369→\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n   370→\\t\\t\\t)\\n   371→\\t\\t\\treturn nil\\n   372→\\t\\t}\\n   373→\\t\\tmessage = addCheckpointTrailer(message, checkpointID)\\n   374→\\tdefault:\\n   375→\\t\\t// Normal editor flow: add trailer with explanatory comment (will be stripped by git)\\n   376→\\t\\tmessage = addCheckpointTrailerWithComment(message, checkpointID, string(agentType), displayPrompt)\\n   377→\\t}\\n   378→\\n   379→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: trailer added\\\",\\n   380→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   381→\\t\\tslog.String(\\\"source\\\", source),\\n   382→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   383→\\t)\\n   384→\\n   385→\\t// Write updated message back\\n   386→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   387→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   388→\\t}\\n   389→\\n   390→\\treturn nil\\n   391→}\\n   392→\\n   393→// handleAmendCommitMsg handles the prepare-commit-msg hook for amend operations\\n   394→// (source=\\\"commit\\\"). It preserves existing trailers or restores from LastCheckpointID.\\n   395→func (s *ManualCommitStrategy) handleAmendCommitMsg(logCtx context.Context, commitMsgFile string) error {\\n   396→\\t// Read current commit message\\n   397→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   398→\\tif err != nil {\\n   399→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   400→\\t}\\n   401→\\n   402→\\tmessage := string(content)\\n   403→\\n   404→\\t// If message already has a trailer, keep it unchanged\\n   405→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   406→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend preserves existing trailer\\\",\\n   407→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   408→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", existingCpID.String()),\\n   409→\\t\\t)\\n   410→\\t\\treturn nil\\n   411→\\t}\\n   412→\\n   413→\\t// No trailer in message — check if any session has LastCheckpointID to restore\\n   414→\\tworktreePath, err := GetWorktreePath()\\n   415→\\tif err != nil {\\n   416→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   417→\\t}\\n   418→\\n   419→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   420→\\tif err != nil || len(sessions) == 0 {\\n   421→\\t\\treturn nil //nolint:nilerr // No sessions - nothing to restore\\n   422→\\t}\\n   423→\\n   424→\\t// For amend, HEAD^ is the commit being amended, and HEAD is where we are now.\\n   425→\\t// We need to match sessions whose BaseCommit equals HEAD (the commit being amended\\n   426→\\t// was created from this base). This prevents stale sessions from injecting\\n   427→\\t// unrelated checkpoint IDs.\\n   428→\\trepo, repoErr := OpenRepository()\\n   429→\\tif repoErr != nil {\\n   430→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   431→\\t}\\n   432→\\thead, headErr := repo.Head()\\n   433→\\tif headErr != nil {\\n   434→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   435→\\t}\\n   436→\\tcurrentHead := head.Hash().String()\\n   437→\\n   438→\\t// Find first matching session with LastCheckpointID to restore.\\n   439→\\t// LastCheckpointID is set after condensation completes.\\n   440→\\tfor _, state := range sessions {\\n   441→\\t\\tif state.BaseCommit != currentHead {\\n   442→\\t\\t\\tcontinue\\n   443→\\t\\t}\\n   444→\\t\\tif state.LastCheckpointID.IsEmpty() {\\n   445→\\t\\t\\tcontinue\\n   446→\\t\\t}\\n   447→\\t\\tcpID := state.LastCheckpointID\\n   448→\\t\\tsource := \\\"LastCheckpointID\\\"\\n   449→\\n   450→\\t\\t// Restore the trailer\\n   451→\\t\\tmessage = addCheckpointTrailer(message, cpID)\\n   452→\\t\\tif writeErr := os.WriteFile(commitMsgFile, []byte(message), 0o600); writeErr != nil {\\n   453→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   454→\\t\\t}\\n   455→\\n   456→\\t\\tlogging.Info(logCtx, \\\"prepare-commit-msg: restored trailer on amend\\\",\\n   457→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   458→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   459→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   460→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   461→\\t\\t)\\n   462→\\t\\treturn nil\\n   463→\\t}\\n   464→\\n   465→\\t// No checkpoint ID found - leave message unchanged\\n   466→\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend with no checkpoint to restore\\\",\\n   467→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   468→\\t)\\n   469→\\treturn nil\\n   470→}\\n   471→\\n   472→// PostCommit is called by the git post-commit hook after a commit is created.\\n   473→// Uses the session state machine to determine what action to take per session:\\n   474→//   - ACTIVE → condense immediately (each commit gets its own checkpoint)\\n   475→//   - IDLE → condense immediately\\n   476→//   - ENDED → condense if files touched, discard if empty\\n   477→//\\n   478→// After condensation for ACTIVE sessions, remaining uncommitted files are\\n   479→// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n   480→//\\n   481→// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n   482→// and were condensed during this PostCommit.\\n   483→\\n   484→// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n   485→// Each session in the loop gets its own handler with per-session context.\\n   486→// Handler methods use the *State parameter from ApplyTransition (same pointer\\n   487→// as the state being transitioned) rather than capturing state separately.\\n   488→type postCommitActionHandler struct {\\n   489→\\ts                      *ManualCommitStrategy\\n   490→\\tlogCtx                 context.Context\\n   491→\\trepo                   *git.Repository\\n   492→\\tcheckpointID           id.CheckpointID\\n   493→\\thead                   *plumbing.Reference\\n   494→\\tcommit                 *object.Commit\\n   495→\\tnewHead                string\\n   496→\\tshadowBranchName       string\\n   497→\\tshadowBranchesToDelete map[string]struct{}\\n   498→\\tcommittedFileSet       map[string]struct{}\\n   499→\\thasNew                 bool\\n   500→\\tfilesTouchedBefore     []string\\n   501→\\n   502→\\t// Output: set by handler methods, read by caller after TransitionAndLog.\\n   503→\\tcondensed bool\\n   504→}\\n   505→\\n   506→func (h *postCommitActionHandler) HandleCondense(state *session.State) error {\\n   507→\\tshouldCondense := h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   508→\\n   509→\\tlogging.Debug(h.logCtx, \\\"post-commit: HandleCondense decision\\\",\\n   510→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   511→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   512→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   513→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   514→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   515→\\t)\\n   516→\\n   517→\\tif shouldCondense {\\n   518→\\t\\th.condensed = h.s.condenseAndUpdateState(h.logCtx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet)\\n   519→\\t} else {\\n   520→\\t\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n   521→\\t}\\n   522→\\treturn nil\\n   523→}\\n   524→\\n   525→func (h *postCommitActionHandler) HandleCondenseIfFilesTouched(state *session.State) error {\\n   526→\\tshouldCondense := len(state.FilesTouched) > 0 && h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   527→\\n   528→\\tlogging.Debug(h.logCtx, \\\"post-commit: HandleCondenseIfFilesTouched decision\\\",\\n   529→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   530→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   531→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   532→\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n   533→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   534→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   535→\\t)\\n   536→\\n   537→\\tif shouldCondense {\\n   538→\\t\\th.condensed = h.s.condenseAndUpdateState(h.logCtx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet)\\n   539→\\t} else {\\n   540→\\t\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n   541→\\t}\\n   542→\\treturn nil\\n   543→}\\n   544→\\n   545→// shouldCondenseWithOverlapCheck returns true if the session should be condensed\\n   546→// into this commit. Requires both that hasNew is true AND that the session's files\\n   547→// overlap with the committed files with matching content.\\n   548→//\\n   549→// This prevents stale sessions (ACTIVE sessions where the agent was killed, or\\n   550→// ENDED/IDLE sessions with carry-forward files) from being condensed into every\\n   551→// unrelated commit.\\n   552→//\\n   553→// filesTouchedBefore is populated from:\\n   554→//   - state.FilesTouched for IDLE/ENDED sessions (set via SaveStep/SaveTaskStep -> mergeFilesTouched)\\n   555→//   - transcript extraction for ACTIVE sessions when FilesTouched is empty\\n   556→//\\n   557→// When filesTouchedBefore is empty:\\n   558→//   - For ACTIVE sessions: fail-open (trust hasNew) because the agent may be\\n   559→//     mid-turn before any files are saved to state.\\n   560→//   - For IDLE/ENDED sessions: return false because there are no files to\\n   561→//     overlap with the commit.\\n   562→func (h *postCommitActionHandler) shouldCondenseWithOverlapCheck(isActive bool) bool {\\n   563→\\tif !h.hasNew {\\n   564→\\t\\treturn false\\n   565→\\t}\\n   566→\\tif len(h.filesTouchedBefore) == 0 {\\n   567→\\t\\treturn isActive // ACTIVE: fail-open; IDLE/ENDED: no files = no overlap\\n   568→\\t}\\n   569→\\t// Only check files that were actually changed in this commit.\\n   570→\\t// Without this, files that exist in the tree but weren't changed\\n   571→\\t// would pass the \\\"modified file\\\" check in filesOverlapWithContent\\n   572→\\t// (because the file exists in the parent tree), causing stale\\n   573→\\t// sessions to be incorrectly condensed.\\n   574→\\tvar committedTouchedFiles []string\\n   575→\\tfor _, f := range h.filesTouchedBefore {\\n   576→\\t\\tif _, ok := h.committedFileSet[f]; ok {\\n   577→\\t\\t\\tcommittedTouchedFiles = append(committedTouchedFiles, f)\\n   578→\\t\\t}\\n   579→\\t}\\n   580→\\tif len(committedTouchedFiles) == 0 {\\n   581→\\t\\treturn false\\n   582→\\t}\\n   583→\\treturn filesOverlapWithContent(h.repo, h.shadowBranchName, h.commit, committedTouchedFiles)\\n   584→}\\n   585→\\n   586→func (h *postCommitActionHandler) HandleDiscardIfNoFiles(state *session.State) error {\\n   587→\\tif len(state.FilesTouched) == 0 {\\n   588→\\t\\tlogging.Debug(h.logCtx, \\\"post-commit: skipping empty ended session (no files to condense)\\\",\\n   589→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   590→\\t\\t)\\n   591→\\t}\\n   592→\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n   593→\\treturn nil\\n   594→}\\n   595→\\n   596→func (h *postCommitActionHandler) HandleWarnStaleSession(_ *session.State) error {\\n   597→\\t// Not produced by EventGitCommit; no-op for exhaustiveness.\\n   598→\\treturn nil\\n   599→}\\n   600→\\n   601→// During rebase/cherry-pick/revert operations, phase transitions are skipped entirely.\\n   602→//\\n   603→//nolint:unparam // error return required by interface but hooks must return nil\\n   604→func (s *ManualCommitStrategy) PostCommit() error {\\n   605→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   606→\\n   607→\\trepo, err := OpenRepository()\\n   608→\\tif err != nil {\\n   609→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   610→\\t}\\n   611→\\n   612→\\t// Get HEAD commit to check for trailer\\n   613→\\thead, err := repo.Head()\\n   614→\\tif err != nil {\\n   615→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   616→\\t}\\n   617→\\n   618→\\tcommit, err := repo.CommitObject(head.Hash())\\n   619→\\tif err != nil {\\n   620→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   621→\\t}\\n   622→\\n   623→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   624→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   625→\\tif !found {\\n   626→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   627→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   628→\\t\\ts.postCommitUpdateBaseCommitOnly(logCtx, head)\\n   629→\\t\\treturn nil\\n   630→\\t}\\n   631→\\n   632→\\tworktreePath, err := GetWorktreePath()\\n   633→\\tif err != nil {\\n   634→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   635→\\t}\\n   636→\\n   637→\\t// Find all active sessions for this worktree\\n   638→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   639→\\tif err != nil || len(sessions) == 0 {\\n   640→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   641→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   642→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   643→\\t\\t)\\n   644→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   645→\\t}\\n   646→\\n   647→\\t// Build transition context\\n   648→\\tisRebase := isGitSequenceOperation()\\n   649→\\ttransitionCtx := session.TransitionContext{\\n   650→\\t\\tIsRebaseInProgress: isRebase,\\n   651→\\t}\\n   652→\\n   653→\\tif isRebase {\\n   654→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   655→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   656→\\t\\t)\\n   657→\\t}\\n   658→\\n   659→\\t// Track shadow branch names and whether they can be deleted\\n   660→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   661→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   662→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   663→\\n   664→\\tnewHead := head.Hash().String()\\n   665→\\tcommittedFileSet := filesChangedInCommit(commit)\\n   666→\\n   667→\\tfor _, state := range sessions {\\n   668→\\t\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   669→\\n   670→\\t\\t// Check for new content (needed for TransitionContext and condensation).\\n   671→\\t\\t// Fail-open: if content check errors, assume new content exists so we\\n   672→\\t\\t// don't silently skip data that should have been condensed.\\n   673→\\t\\t//\\n   674→\\t\\t// For ACTIVE sessions: the commit has a checkpoint trailer (verified above),\\n   675→\\t\\t// meaning PrepareCommitMsg already determined this commit is session-related.\\n   676→\\t\\t// The trailer is only added when either:\\n   677→\\t\\t//   - No TTY (agent/subagent committing) — added unconditionally\\n   678→\\t\\t//   - TTY (human committing) — added after content detection confirmed agent work\\n   679→\\t\\t// In both cases, PrepareCommitMsg already validated this commit. We trust\\n   680→\\t\\t// that decision here. Transcript-based re-validation is unreliable because\\n   681→\\t\\t// subagent transcripts may not be available yet (subagent still running).\\n   682→\\t\\tvar hasNew bool\\n   683→\\t\\tif state.Phase.IsActive() {\\n   684→\\t\\t\\thasNew = true\\n   685→\\t\\t} else {\\n   686→\\t\\t\\tvar contentErr error\\n   687→\\t\\t\\thasNew, contentErr = s.sessionHasNewContent(repo, state)\\n   688→\\t\\t\\tif contentErr != nil {\\n   689→\\t\\t\\t\\thasNew = true\\n   690→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: error checking session content, assuming new content\\\",\\n   691→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   692→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", contentErr.Error()),\\n   693→\\t\\t\\t\\t)\\n   694→\\t\\t\\t}\\n   695→\\t\\t}\\n   696→\\t\\ttransitionCtx.HasFilesTouched = len(state.FilesTouched) > 0\\n   697→\\n   698→\\t\\t// Save FilesTouched BEFORE TransitionAndLog — the handler's condensation\\n   699→\\t\\t// clears it, but we need the original list for carry-forward computation.\\n   700→\\t\\t// For mid-session commits (ACTIVE, no shadow branch), state.FilesTouched may be empty\\n   701→\\t\\t// because no SaveStep/Stop has been called yet. Extract files from transcript.\\n   702→\\t\\tfilesTouchedBefore := make([]string, len(state.FilesTouched))\\n   703→\\t\\tcopy(filesTouchedBefore, state.FilesTouched)\\n   704→\\t\\tif len(filesTouchedBefore) == 0 && state.Phase.IsActive() && state.TranscriptPath != \\\"\\\" {\\n   705→\\t\\t\\tfilesTouchedBefore = s.extractFilesFromLiveTranscript(state)\\n   706→\\t\\t}\\n   707→\\n   708→\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward prep\\\",\\n   709→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   710→\\t\\t\\tslog.Bool(\\\"is_active\\\", state.Phase.IsActive()),\\n   711→\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n   712→\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   713→\\t\\t\\tslog.Any(\\\"files\\\", filesTouchedBefore),\\n   714→\\t\\t)\\n   715→\\n   716→\\t\\t// Run the state machine transition with handler for strategy-specific actions.\\n   717→\\t\\thandler := &postCommitActionHandler{\\n   718→\\t\\t\\ts:                      s,\\n   719→\\t\\t\\tlogCtx:                 logCtx,\\n   720→\\t\\t\\trepo:                   repo,\\n   721→\\t\\t\\tcheckpointID:           checkpointID,\\n   722→\\t\\t\\thead:                   head,\\n   723→\\t\\t\\tcommit:                 commit,\\n   724→\\t\\t\\tnewHead:                newHead,\\n   725→\\t\\t\\tshadowBranchName:       shadowBranchName,\\n   726→\\t\\t\\tshadowBranchesToDelete: shadowBranchesToDelete,\\n   727→\\t\\t\\tcommittedFileSet:       committedFileSet,\\n   728→\\t\\t\\thasNew:                 hasNew,\\n   729→\\t\\t\\tfilesTouchedBefore:     filesTouchedBefore,\\n   730→\\t\\t}\\n   731→\\n   732→\\t\\tif err := TransitionAndLog(state, session.EventGitCommit, transitionCtx, handler); err != nil {\\n   733→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: post-commit action handler error: %v\\\\n\\\", err)\\n   734→\\t\\t}\\n   735→\\n   736→\\t\\t// Record checkpoint ID for ACTIVE sessions so HandleTurnEnd can finalize\\n   737→\\t\\t// with full transcript. IDLE/ENDED sessions already have complete transcripts.\\n   738→\\t\\t// NOTE: This check runs AFTER TransitionAndLog updated the phase. It relies on\\n   739→\\t\\t// ACTIVE + GitCommit → ACTIVE (phase stays ACTIVE). If that state machine\\n   740→\\t\\t// transition ever changed, this guard would silently stop recording IDs.\\n   741→\\t\\tif handler.condensed && state.Phase.IsActive() {\\n   742→\\t\\t\\tstate.TurnCheckpointIDs = append(state.TurnCheckpointIDs, checkpointID.String())\\n   743→\\t\\t}\\n   744→\\n   745→\\t\\t// Carry forward remaining uncommitted files so the next commit gets its\\n   746→\\t\\t// own checkpoint ID. This applies to ALL phases — if a user splits their\\n   747→\\t\\t// commit across two `git commit` invocations, each gets a 1:1 checkpoint.\\n   748→\\t\\t// Uses content-aware comparison: if user did `git add -p` and committed\\n   749→\\t\\t// partial changes, the file still has remaining agent changes to carry forward.\\n   750→\\t\\tif handler.condensed {\\n   751→\\t\\t\\tremainingFiles := filesWithRemainingAgentChanges(repo, shadowBranchName, commit, filesTouchedBefore, committedFileSet)\\n   752→\\t\\t\\tstate.FilesTouched = remainingFiles\\n   753→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward decision (content-aware)\\\",\\n   754→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   755→\\t\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n   756→\\t\\t\\t\\tslog.Int(\\\"committed_files\\\", len(committedFileSet)),\\n   757→\\t\\t\\t\\tslog.Int(\\\"remaining_files\\\", len(remainingFiles)),\\n   758→\\t\\t\\t\\tslog.Any(\\\"remaining\\\", remainingFiles),\\n   759→\\t\\t\\t\\tslog.Any(\\\"committed_files\\\", committedFileSet),\\n   760→\\t\\t\\t)\\n   761→\\t\\t\\tif len(remainingFiles) > 0 {\\n   762→\\t\\t\\t\\ts.carryForwardToNewShadowBranch(logCtx, repo, state, remainingFiles)\\n   763→\\t\\t\\t}\\n   764→\\t\\t}\\n   765→\\n   766→\\t\\t// Save the updated state\\n   767→\\t\\tif err := s.saveSessionState(state); err != nil {\\n   768→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to update session state: %v\\\\n\\\", err)\\n   769→\\t\\t}\\n   770→\\n   771→\\t\\t// Only preserve shadow branch for active sessions that were NOT condensed.\\n   772→\\t\\t// Condensed sessions already have their data on entire/checkpoints/v1.\\n   773→\\t\\tif state.Phase.IsActive() && !handler.condensed {\\n   774→\\t\\t\\tuncondensedActiveOnBranch[shadowBranchName] = true\\n   775→\\t\\t}\\n   776→\\t}\\n   777→\\n   778→\\t// Clean up shadow branches — only delete when ALL sessions on the branch are non-active\\n   779→\\t// or were condensed during this PostCommit.\\n   780→\\tfor shadowBranchName := range shadowBranchesToDelete {\\n   781→\\t\\tif uncondensedActiveOnBranch[shadowBranchName] {\\n   782→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: preserving shadow branch (active session exists)\\\",\\n   783→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   784→\\t\\t\\t)\\n   785→\\t\\t\\tcontinue\\n   786→\\t\\t}\\n   787→\\t\\tif err := deleteShadowBranch(repo, shadowBranchName); err != nil {\\n   788→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to clean up %s: %v\\\\n\\\", shadowBranchName, err)\\n   789→\\t\\t} else {\\n   790→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Cleaned up shadow branch: %s\\\\n\\\", shadowBranchName)\\n   791→\\t\\t\\tlogging.Info(logCtx, \\\"shadow branch deleted\\\",\\n   792→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   793→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   794→\\t\\t\\t)\\n   795→\\t\\t}\\n   796→\\t}\\n   797→\\n   798→\\treturn nil\\n   799→}\\n   800→\\n   801→// condenseAndUpdateState runs condensation for a session and updates state afterward.\\n   802→// Returns true if condensation succeeded.\\n   803→func (s *ManualCommitStrategy) condenseAndUpdateState(\\n   804→\\tlogCtx context.Context,\\n   805→\\trepo *git.Repository,\\n   806→\\tcheckpointID id.CheckpointID,\\n   807→\\tstate *SessionState,\\n   808→\\thead *plumbing.Reference,\\n   809→\\tshadowBranchName string,\\n   810→\\tshadowBranchesToDelete map[string]struct{},\\n   811→\\tcommittedFiles map[string]struct{},\\n   812→) bool {\\n   813→\\tresult, err := s.CondenseSession(repo, checkpointID, state, committedFiles)\\n   814→\\tif err != nil {\\n   815→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: condensation failed for session %s: %v\\\\n\\\",\\n   816→\\t\\t\\tstate.SessionID, err)\\n   817→\\t\\tlogging.Warn(logCtx, \\\"post-commit: condensation failed\\\",\\n   818→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   819→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   820→\\t\\t)\\n   821→\\t\\treturn false\\n   822→\\t}\\n   823→\\n   824→\\t// Link checkpoint to trail (best-effort)\\n   825→\\tappendCheckpointToTrail(repo, result.CheckpointID, head.Hash(), result.Prompts)\\n   826→\\n   827→\\t// Track this shadow branch for cleanup\\n   828→\\tshadowBranchesToDelete[shadowBranchName] = struct{}{}\\n   829→\\n   830→\\t// Update session state for the new base commit\\n   831→\\tnewHead := head.Hash().String()\\n   832→\\tstate.BaseCommit = newHead\\n   833→\\tstate.AttributionBaseCommit = newHead\\n   834→\\tstate.StepCount = 0\\n   835→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   836→\\n   837→\\t// Clear attribution tracking — condensation already used these values\\n   838→\\tstate.PromptAttributions = nil\\n   839→\\tstate.PendingPromptAttribution = nil\\n   840→\\tstate.FilesTouched = nil\\n   841→\\n   842→\\t// Save checkpoint ID so subsequent commits can reuse it (e.g., amend restores trailer)\\n   843→\\tstate.LastCheckpointID = checkpointID\\n   844→\\n   845→\\tshortID := state.SessionID\\n   846→\\tif len(shortID) > 8 {\\n   847→\\t\\tshortID = shortID[:8]\\n   848→\\t}\\n   849→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Condensed session %s: %s (%d checkpoints)\\\\n\\\",\\n   850→\\t\\tshortID, result.CheckpointID, result.CheckpointsCount)\\n   851→\\n   852→\\tlogging.Info(logCtx, \\\"session condensed\\\",\\n   853→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   854→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   855→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   856→\\t\\tslog.Int(\\\"transcript_lines\\\", result.TotalTranscriptLines),\\n   857→\\t)\\n   858→\\n   859→\\treturn true\\n   860→}\\n   861→\\n   862→// updateBaseCommitIfChanged updates BaseCommit to newHead if it changed.\\n   863→// Only updates ACTIVE sessions. IDLE/ENDED sessions should NOT have their\\n   864→// BaseCommit updated, as this would cause them to be incorrectly associated\\n   865→// with a new shadow branch and potentially condensed on future commits.\\n   866→func (s *ManualCommitStrategy) updateBaseCommitIfChanged(logCtx context.Context, state *SessionState, newHead string) {\\n   867→\\t// Only update ACTIVE sessions. IDLE/ENDED sessions are kept around for\\n   868→\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n   869→\\tif !state.Phase.IsActive() {\\n   870→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updateBaseCommitIfChanged skipped non-active session\\\",\\n   871→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   872→\\t\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   873→\\t\\t)\\n   874→\\t\\treturn\\n   875→\\t}\\n   876→\\tif state.BaseCommit != newHead {\\n   877→\\t\\tstate.BaseCommit = newHead\\n   878→\\t\\tlogging.Debug(logCtx, \\\"post-commit: updated BaseCommit\\\",\\n   879→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   880→\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n   881→\\t\\t)\\n   882→\\t}\\n   883→}\\n   884→\\n   885→// postCommitUpdateBaseCommitOnly updates BaseCommit for all sessions on the current\\n   886→// worktree when a commit has no Entire-Checkpoint trailer. This prevents BaseCommit\\n   887→// from going stale, which would cause future PrepareCommitMsg calls to skip the\\n   888→// session (BaseCommit != currentHeadHash filter).\\n   889→//\\n   890→// Unlike the full PostCommit flow, this does NOT fire EventGitCommit or trigger\\n   891→// condensation — it only keeps BaseCommit in sync with HEAD.\\n   892→func (s *ManualCommitStrategy) postCommitUpdateBaseCommitOnly(logCtx context.Context, head *plumbing.Reference) {\\n   893→\\tworktreePath, err := GetWorktreePath()\\n   894→\\tif err != nil {\\n   895→\\t\\treturn // Silent failure — hooks must be resilient\\n   896→\\t}\\n   897→\\n   898→\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n   899→\\tif err != nil || len(sessions) == 0 {\\n   900→\\t\\treturn\\n   901→\\t}\\n   902→\\n   903→\\tnewHead := head.Hash().String()\\n   904→\\tfor _, state := range sessions {\\n   905→\\t\\t// Only update active sessions. Idle/ended sessions are kept around for\\n   906→\\t\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n   907→\\t\\tif !state.Phase.IsActive() {\\n   908→\\t\\t\\tcontinue\\n   909→\\t\\t}\\n   910→\\t\\tif state.BaseCommit != newHead {\\n   911→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit (no trailer): updating BaseCommit\\\",\\n   912→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   913→\\t\\t\\t\\tslog.String(\\\"old_base\\\", truncateHash(state.BaseCommit)),\\n   914→\\t\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n   915→\\t\\t\\t)\\n   916→\\t\\t\\tstate.BaseCommit = newHead\\n   917→\\t\\t\\tif err := s.saveSessionState(state); err != nil {\\n   918→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to update session state: %v\\\\n\\\", err)\\n   919→\\t\\t\\t}\\n   920→\\t\\t}\\n   921→\\t}\\n   922→}\\n   923→\\n   924→// truncateHash safely truncates a git hash to 7 chars for logging.\\n   925→func truncateHash(h string) string {\\n   926→\\tif len(h) > 7 {\\n   927→\\t\\treturn h[:7]\\n   928→\\t}\\n   929→\\treturn h\\n   930→}\\n   931→\\n   932→// filterSessionsWithNewContent returns sessions that have new transcript content\\n   933→// beyond what was already condensed.\\n   934→func (s *ManualCommitStrategy) filterSessionsWithNewContent(repo *git.Repository, sessions []*SessionState) []*SessionState {\\n   935→\\tvar result []*SessionState\\n   936→\\n   937→\\tfor _, state := range sessions {\\n   938→\\t\\thasNew, err := s.sessionHasNewContent(repo, state)\\n   939→\\t\\tif err != nil {\\n   940→\\t\\t\\t// On error, include the session (fail open for hooks)\\n   941→\\t\\t\\tresult = append(result, state)\\n   942→\\t\\t\\tcontinue\\n   943→\\t\\t}\\n   944→\\t\\tif hasNew {\\n   945→\\t\\t\\tresult = append(result, state)\\n   946→\\t\\t}\\n   947→\\t}\\n   948→\\n   949→\\treturn result\\n   950→}\\n   951→\\n   952→// sessionHasNewContent checks if a session has new transcript content\\n   953→// beyond what was already condensed.\\n   954→func (s *ManualCommitStrategy) sessionHasNewContent(repo *git.Repository, state *SessionState) (bool, error) {\\n   955→\\tlogCtx := logging.WithComponent(context.Background(), \\\"manual-commit\\\")\\n   956→\\n   957→\\t// Get shadow branch\\n   958→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   959→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   960→\\tref, err := repo.Reference(refName, true)\\n   961→\\tif err != nil {\\n   962→\\t\\t// No shadow branch means no Stop has happened since the last condensation.\\n   963→\\t\\t// However, the agent may have done work (including commits) without a Stop.\\n   964→\\t\\t// Check the live transcript to detect this scenario.\\n   965→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no shadow branch, checking live transcript\\\",\\n   966→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   967→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   968→\\t\\t)\\n   969→\\t\\treturn s.sessionHasNewContentFromLiveTranscript(repo, state)\\n   970→\\t}\\n   971→\\n   972→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   973→\\tif err != nil {\\n   974→\\t\\treturn false, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   975→\\t}\\n   976→\\n   977→\\ttree, err := commit.Tree()\\n   978→\\tif err != nil {\\n   979→\\t\\treturn false, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   980→\\t}\\n   981→\\n   982→\\t// Look for transcript file\\n   983→\\tmetadataDir := paths.EntireMetadataDir + \\\"/\\\" + state.SessionID\\n   984→\\tvar transcriptLines int\\n   985→\\tvar hasTranscriptFile bool\\n   986→\\n   987→\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   988→\\t\\thasTranscriptFile = true\\n   989→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   990→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n   991→\\t\\t}\\n   992→\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   993→\\t\\thasTranscriptFile = true\\n   994→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   995→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n   996→\\t\\t}\\n   997→\\t}\\n   998→\\n   999→\\t// If shadow branch exists but has no transcript (e.g., carry-forward from mid-session commit),\\n  1000→\\t// check if the session has FilesTouched. Carry-forward sets FilesTouched with remaining files.\\n  1001→\\tif !hasTranscriptFile {\\n  1002→\\t\\tif len(state.FilesTouched) > 0 {\\n  1003→\\t\\t\\t// Shadow branch has files from carry-forward - check if staged files overlap\\n  1004→\\t\\t\\t// AND have matching content (content-aware check).\\n  1005→\\t\\t\\tstagedFiles := getStagedFiles(repo)\\n  1006→\\t\\t\\tif len(stagedFiles) > 0 {\\n  1007→\\t\\t\\t\\t// PrepareCommitMsg context: check staged files overlap with content\\n  1008→\\t\\t\\t\\tresult := stagedFilesOverlapWithContent(repo, tree, stagedFiles, state.FilesTouched)\\n  1009→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript, carry-forward with staged files\\\",\\n  1010→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1011→\\t\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n  1012→\\t\\t\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1013→\\t\\t\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n  1014→\\t\\t\\t\\t)\\n  1015→\\t\\t\\t\\treturn result, nil\\n  1016→\\t\\t\\t}\\n  1017→\\t\\t\\t// PostCommit context: no staged files, but we have carry-forward files.\\n  1018→\\t\\t\\t// Return true and let the caller do the overlap check with committed files.\\n  1019→\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript, carry-forward without staged files (post-commit context)\\\",\\n  1020→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1021→\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n  1022→\\t\\t\\t)\\n  1023→\\t\\t\\treturn true, nil\\n  1024→\\t\\t}\\n  1025→\\t\\t// No transcript and no FilesTouched - fall back to live transcript check\\n  1026→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript and no files touched, checking live transcript\\\",\\n  1027→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1028→\\t\\t)\\n  1029→\\t\\treturn s.sessionHasNewContentFromLiveTranscript(repo, state)\\n  1030→\\t}\\n  1031→\\n  1032→\\t// Check if there's new content to condense. Two cases:\\n  1033→\\t// 1. Transcript has grown since last condensation (new prompts/responses)\\n  1034→\\t// 2. FilesTouched has files not yet committed (carry-forward scenario)\\n  1035→\\t//\\n  1036→\\t// For PrepareCommitMsg context, we verify staged files overlap with session's files\\n  1037→\\t// using content-aware matching to detect reverted files.\\n  1038→\\t// For PostCommit context, getStagedFiles() is empty (files already committed),\\n  1039→\\t// so we return true and let the caller do the overlap check via filesOverlapWithContent.\\n  1040→\\n  1041→\\thasTranscriptGrowth := transcriptLines > state.CheckpointTranscriptStart\\n  1042→\\thasUncommittedFiles := len(state.FilesTouched) > 0\\n  1043→\\n  1044→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: transcript check\\\",\\n  1045→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1046→\\t\\tslog.Int(\\\"transcript_lines\\\", transcriptLines),\\n  1047→\\t\\tslog.Int(\\\"checkpoint_transcript_start\\\", state.CheckpointTranscriptStart),\\n  1048→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1049→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1050→\\t)\\n  1051→\\n  1052→\\tif !hasTranscriptGrowth && !hasUncommittedFiles {\\n  1053→\\t\\treturn false, nil // No new content and no carry-forward files\\n  1054→\\t}\\n  1055→\\n  1056→\\t// Check if staged files overlap with session's files with content-aware matching.\\n  1057→\\t// This is primarily for PrepareCommitMsg; in PostCommit, stagedFiles is empty.\\n  1058→\\tstagedFiles := getStagedFiles(repo)\\n  1059→\\tif len(stagedFiles) > 0 {\\n  1060→\\t\\tresult := stagedFilesOverlapWithContent(repo, tree, stagedFiles, state.FilesTouched)\\n  1061→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: staged files overlap check\\\",\\n  1062→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1063→\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1064→\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n  1065→\\t\\t)\\n  1066→\\t\\treturn result, nil\\n  1067→\\t}\\n  1068→\\n  1069→\\t// No staged files - either PostCommit context or edge case.\\n  1070→\\t// Return transcript growth status. For PostCommit with hasTranscriptFile=true,\\n  1071→\\t// if there's no transcript growth, the session hasn't done new work since last checkpoint.\\n  1072→\\t// (Carry-forward creates a shadow branch WITHOUT transcript, handled in the block above.)\\n  1073→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no staged files, returning transcript growth\\\",\\n  1074→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1075→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1076→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1077→\\t)\\n  1078→\\treturn hasTranscriptGrowth, nil\\n  1079→}\\n  1080→\\n  1081→// sessionHasNewContentFromLiveTranscript checks if a session has new content\\n  1082→// by examining the live transcript file. This is used when no shadow branch exists\\n  1083→// (i.e., no Stop has happened yet) but the agent may have done work.\\n  1084→//\\n  1085→// Returns true if:\\n  1086→//  1. The transcript has grown since the last condensation, AND\\n  1087→//  2. The new transcript portion contains file modifications, AND\\n  1088→//  3. At least one modified file overlaps with the currently staged files\\n  1089→//\\n  1090→// The overlap check ensures we don't add checkpoint trailers to commits that are\\n  1091→// unrelated to the agent's recent changes.\\n  1092→//\\n  1093→// This handles the scenario where the agent commits mid-session before Stop.\\n  1094→func (s *ManualCommitStrategy) sessionHasNewContentFromLiveTranscript(repo *git.Repository, state *SessionState) (bool, error) {\\n  1095→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1096→\\n  1097→\\tmodifiedFiles, ok := s.extractNewModifiedFilesFromLiveTranscript(state)\\n  1098→\\tif !ok || len(modifiedFiles) == 0 {\\n  1099→\\t\\treturn false, nil\\n  1100→\\t}\\n  1101→\\n  1102→\\tlogging.Debug(logCtx, \\\"live transcript check: found file modifications\\\",\\n  1103→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1104→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1105→\\t)\\n  1106→\\n  1107→\\t// Check if any modified files overlap with currently staged files\\n  1108→\\t// This ensures we only add checkpoint trailers to commits that include\\n  1109→\\t// files the agent actually modified\\n  1110→\\tstagedFiles := getStagedFiles(repo)\\n  1111→\\n  1112→\\tlogging.Debug(logCtx, \\\"live transcript check: comparing staged vs modified\\\",\\n  1113→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1114→\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1115→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1116→\\t)\\n  1117→\\n  1118→\\tif !hasOverlappingFiles(stagedFiles, modifiedFiles) {\\n  1119→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no overlap between staged and modified files\\\",\\n  1120→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1121→\\t\\t)\\n  1122→\\t\\treturn false, nil // No overlap - staged files are unrelated to agent's work\\n  1123→\\t}\\n  1124→\\n  1125→\\treturn true, nil\\n  1126→}\\n  1127→\\n  1128→// extractFilesFromLiveTranscript extracts modified file paths from the live transcript.\\n  1129→// Returns empty slice if extraction fails (fail-open behavior for hooks).\\n  1130→// Extracts files from the transcript starting at CheckpointTranscriptStart, which gives\\n  1131→// files touched since the last condensation — used for carry-forward computation.\\n  1132→func (s *ManualCommitStrategy) extractFilesFromLiveTranscript(state *SessionState) []string {\\n  1133→\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n  1134→}\\n  1135→\\n  1136→// extractNewModifiedFilesFromLiveTranscript extracts modified files from the live\\n  1137→// transcript that are NEW since the last condensation. Returns the normalized file list\\n  1138→// and whether the extraction succeeded. Used by sessionHasNewContentFromLiveTranscript\\n  1139→// to detect agent work.\\n  1140→func (s *ManualCommitStrategy) extractNewModifiedFilesFromLiveTranscript(state *SessionState) ([]string, bool) {\\n  1141→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1142→\\n  1143→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1144→\\t\\treturn nil, false\\n  1145→\\t}\\n  1146→\\n  1147→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1148→\\tif err != nil {\\n  1149→\\t\\treturn nil, false\\n  1150→\\t}\\n  1151→\\n  1152→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1153→\\tif !ok {\\n  1154→\\t\\treturn nil, false\\n  1155→\\t}\\n  1156→\\n  1157→\\t// Check if transcript has grown since last condensation\\n  1158→\\tcurrentPos, err := analyzer.GetTranscriptPosition(state.TranscriptPath)\\n  1159→\\tif err != nil {\\n  1160→\\t\\treturn nil, false\\n  1161→\\t}\\n  1162→\\tif currentPos <= state.CheckpointTranscriptStart {\\n  1163→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no new content\\\",\\n  1164→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1165→\\t\\t\\tslog.Int(\\\"current_pos\\\", currentPos),\\n  1166→\\t\\t\\tslog.Int(\\\"start_offset\\\", state.CheckpointTranscriptStart),\\n  1167→\\t\\t)\\n  1168→\\t\\treturn nil, true // No new content, but extraction succeeded\\n  1169→\\t}\\n  1170→\\n  1171→\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart), true\\n  1172→}\\n  1173→\\n  1174→// extractModifiedFilesFromLiveTranscript extracts modified files from the live transcript\\n  1175→// (including subagent transcripts) starting from the given offset, and normalizes them\\n  1176→// to repo-relative paths. Returns the normalized file list.\\n  1177→func (s *ManualCommitStrategy) extractModifiedFilesFromLiveTranscript(state *SessionState, offset int) []string {\\n  1178→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1179→\\n  1180→\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n  1181→\\t\\treturn nil\\n  1182→\\t}\\n  1183→\\n  1184→\\tag, err := agent.GetByAgentType(state.AgentType)\\n  1185→\\tif err != nil {\\n  1186→\\t\\treturn nil\\n  1187→\\t}\\n  1188→\\n  1189→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1190→\\tif !ok {\\n  1191→\\t\\treturn nil\\n  1192→\\t}\\n  1193→\\n  1194→\\tvar modifiedFiles []string\\n  1195→\\n  1196→\\t// For Claude Code, use ExtractAllModifiedFiles which parses the main transcript\\n  1197→\\t// AND subagent transcripts in a single pass, avoiding redundant parsing.\\n  1198→\\tif state.AgentType == agent.AgentTypeClaudeCode {\\n  1199→\\t\\tsubagentsDir := filepath.Join(filepath.Dir(state.TranscriptPath), state.SessionID, \\\"subagents\\\")\\n  1200→\\t\\tallFiles, extractErr := claudecode.ExtractAllModifiedFiles(state.TranscriptPath, offset, subagentsDir)\\n  1201→\\t\\tif extractErr != nil {\\n  1202→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: extraction failed\\\",\\n  1203→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1204→\\t\\t\\t\\tslog.String(\\\"error\\\", extractErr.Error()),\\n  1205→\\t\\t\\t)\\n  1206→\\t\\t} else {\\n  1207→\\t\\t\\tmodifiedFiles = allFiles\\n  1208→\\t\\t}\\n  1209→\\t} else {\\n  1210→\\t\\tfiles, _, err := analyzer.ExtractModifiedFilesFromOffset(state.TranscriptPath, offset)\\n  1211→\\t\\tif err != nil {\\n  1212→\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: main transcript extraction failed\\\",\\n  1213→\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1214→\\t\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1215→\\t\\t\\t)\\n  1216→\\t\\t} else {\\n  1217→\\t\\t\\tmodifiedFiles = files\\n  1218→\\t\\t}\\n  1219→\\t}\\n  1220→\\n  1221→\\tif len(modifiedFiles) == 0 {\\n  1222→\\t\\treturn nil\\n  1223→\\t}\\n  1224→\\n  1225→\\t// Normalize to repo-relative paths.\\n  1226→\\t// Transcript tool_use entries contain absolute paths (e.g., /Users/alex/project/src/main.go)\\n  1227→\\t// but getStagedFiles/committedFiles use repo-relative paths (e.g., src/main.go).\\n  1228→\\tbasePath := state.WorktreePath\\n  1229→\\tif basePath == \\\"\\\" {\\n  1230→\\t\\tif wp, wpErr := GetWorktreePath(); wpErr == nil {\\n  1231→\\t\\t\\tbasePath = wp\\n  1232→\\t\\t}\\n  1233→\\t}\\n  1234→\\tif basePath != \\\"\\\" {\\n  1235→\\t\\tnormalized := make([]string, 0, len(modifiedFiles))\\n  1236→\\t\\tfor _, f := range modifiedFiles {\\n  1237→\\t\\t\\tif rel := paths.ToRelativePath(f, basePath); rel != \\\"\\\" {\\n  1238→\\t\\t\\t\\tnormalized = append(normalized, rel)\\n  1239→\\t\\t\\t} else {\\n  1240→\\t\\t\\t\\tnormalized = append(normalized, f)\\n  1241→\\t\\t\\t}\\n  1242→\\t\\t}\\n  1243→\\t\\tmodifiedFiles = normalized\\n  1244→\\t}\\n  1245→\\n  1246→\\treturn modifiedFiles\\n  1247→}\\n  1248→\\n  1249→// addTrailerForAgentCommit handles the fast path when an agent is committing\\n  1250→// (ACTIVE session + no TTY). Generates a checkpoint ID and adds the trailer\\n  1251→// directly, bypassing content detection and interactive prompts.\\n  1252→func (s *ManualCommitStrategy) addTrailerForAgentCommit(logCtx context.Context, commitMsgFile string, state *SessionState, source string) error {\\n  1253→\\tcpID, err := id.Generate()\\n  1254→\\tif err != nil {\\n  1255→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1256→\\t}\\n  1257→\\n  1258→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n  1259→\\tif err != nil {\\n  1260→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1261→\\t}\\n  1262→\\n  1263→\\tmessage := string(content)\\n  1264→\\n  1265→\\t// Don't add if trailer already exists\\n  1266→\\tif _, found := trailers.ParseCheckpoint(message); found {\\n  1267→\\t\\treturn nil\\n  1268→\\t}\\n  1269→\\n  1270→\\tmessage = addCheckpointTrailer(message, cpID)\\n  1271→\\n  1272→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: agent commit trailer added\\\",\\n  1273→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n  1274→\\t\\tslog.String(\\\"source\\\", source),\\n  1275→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n  1276→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1277→\\t)\\n  1278→\\n  1279→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n  1280→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1281→\\t}\\n  1282→\\treturn nil\\n  1283→}\\n  1284→\\n  1285→// addCheckpointTrailer adds the Entire-Checkpoint trailer to a commit message.\\n  1286→// Handles proper trailer formatting (blank line before trailers if needed).\\n  1287→func addCheckpointTrailer(message string, checkpointID id.CheckpointID) string {\\n  1288→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1289→\\n  1290→\\t// If message already ends with trailers (lines starting with key:), just append\\n  1291→\\t// Otherwise, add a blank line first\\n  1292→\\tlines := strings.Split(strings.TrimRight(message, \\\"\\\\n\\\"), \\\"\\\\n\\\")\\n  1293→\\n  1294→\\t// Check if the message already ends with a trailer paragraph.\\n  1295→\\t// Git trailers must be in a separate paragraph (preceded by a blank line).\\n  1296→\\t// A single-paragraph message (e.g., just a subject line) cannot have trailers,\\n  1297→\\t// even if the subject contains \\\": \\\" (like conventional commits: \\\"docs: Add foo\\\").\\n  1298→\\t//\\n  1299→\\t// Scan from the bottom: find the last paragraph of non-comment content,\\n  1300→\\t// then check if it looks like trailers AND has a blank line above it.\\n  1301→\\thasTrailers := false\\n  1302→\\ti := len(lines) - 1\\n  1303→\\n  1304→\\t// Skip trailing comment lines\\n  1305→\\tfor i >= 0 && strings.HasPrefix(strings.TrimSpace(lines[i]), \\\"#\\\") {\\n  1306→\\t\\ti--\\n  1307→\\t}\\n  1308→\\n  1309→\\t// Check if the last non-comment line looks like a trailer\\n  1310→\\tif i >= 0 {\\n  1311→\\t\\tline := strings.TrimSpace(lines[i])\\n  1312→\\t\\tif line != \\\"\\\" && strings.Contains(line, \\\": \\\") {\\n  1313→\\t\\t\\t// Found a trailer-like line. Now scan upward past the trailer block\\n  1314→\\t\\t\\t// to verify there's a blank line (paragraph separator) above it.\\n  1315→\\t\\t\\tfor i > 0 {\\n  1316→\\t\\t\\t\\ti--\\n  1317→\\t\\t\\t\\tabove := strings.TrimSpace(lines[i])\\n  1318→\\t\\t\\t\\tif strings.HasPrefix(above, \\\"#\\\") {\\n  1319→\\t\\t\\t\\t\\tcontinue\\n  1320→\\t\\t\\t\\t}\\n  1321→\\t\\t\\t\\tif above == \\\"\\\" {\\n  1322→\\t\\t\\t\\t\\t// Blank line found above trailer block — real trailers\\n  1323→\\t\\t\\t\\t\\thasTrailers = true\\n  1324→\\t\\t\\t\\t\\tbreak\\n  1325→\\t\\t\\t\\t}\\n  1326→\\t\\t\\t\\tif !strings.Contains(above, \\\": \\\") {\\n  1327→\\t\\t\\t\\t\\t// Non-trailer, non-blank line — this is message body, not trailers\\n  1328→\\t\\t\\t\\t\\tbreak\\n  1329→\\t\\t\\t\\t}\\n  1330→\\t\\t\\t\\t// Another trailer-like line, keep scanning upward\\n  1331→\\t\\t\\t}\\n  1332→\\t\\t}\\n  1333→\\t}\\n  1334→\\n  1335→\\tif hasTrailers {\\n  1336→\\t\\t// Append trailer directly\\n  1337→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1338→\\t}\\n  1339→\\n  1340→\\t// Add blank line before trailer\\n  1341→\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1342→}\\n  1343→\\n  1344→// addCheckpointTrailerWithComment adds the Entire-Checkpoint trailer with an explanatory comment.\\n  1345→// The trailer is placed above the git comment block but below the user's message area,\\n  1346→// with a comment explaining that the user can remove it if they don't want to link the commit\\n  1347→// to the agent session. If prompt is non-empty, it's shown as context.\\n  1348→func addCheckpointTrailerWithComment(message string, checkpointID id.CheckpointID, agentName, prompt string) string {\\n  1349→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1350→\\tcommentLines := []string{\\n  1351→\\t\\t\\\"# Remove the Entire-Checkpoint trailer above if you don't want to link this commit to \\\" + agentName + \\\" session context.\\\",\\n  1352→\\t}\\n  1353→\\tif prompt != \\\"\\\" {\\n  1354→\\t\\tcommentLines = append(commentLines, \\\"# Last Prompt: \\\"+prompt)\\n  1355→\\t}\\n  1356→\\tcommentLines = append(commentLines, \\\"# The trailer will be added to your next commit based on this branch.\\\")\\n  1357→\\tcomment := strings.Join(commentLines, \\\"\\\\n\\\")\\n  1358→\\n  1359→\\tlines := strings.Split(message, \\\"\\\\n\\\")\\n  1360→\\n  1361→\\t// Find where the git comment block starts (first # line)\\n  1362→\\tcommentStart := -1\\n  1363→\\tfor i, line := range lines {\\n  1364→\\t\\tif strings.HasPrefix(line, \\\"#\\\") {\\n  1365→\\t\\t\\tcommentStart = i\\n  1366→\\t\\t\\tbreak\\n  1367→\\t\\t}\\n  1368→\\t}\\n  1369→\\n  1370→\\tif commentStart == -1 {\\n  1371→\\t\\t// No git comments, append trailer at the end\\n  1372→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\"\\n  1373→\\t}\\n  1374→\\n  1375→\\t// Split into user content and git comments\\n  1376→\\tuserContent := strings.Join(lines[:commentStart], \\\"\\\\n\\\")\\n  1377→\\tgitComments := strings.Join(lines[commentStart:], \\\"\\\\n\\\")\\n  1378→\\n  1379→\\t// Build result: user content, blank line, trailer, comment, blank line, git comments\\n  1380→\\tuserContent = strings.TrimRight(userContent, \\\"\\\\n\\\")\\n  1381→\\tif userContent == \\\"\\\" {\\n  1382→\\t\\t// No user content yet - leave space for them to type, then trailer\\n  1383→\\t\\t// Two newlines: first for user's message line, second for blank separator\\n  1384→\\t\\treturn \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1385→\\t}\\n  1386→\\treturn userContent + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1387→}\\n  1388→\\n  1389→// InitializeSession creates session state for a new session or updates an existing one.\\n  1390→// This implements the optional SessionInitializer interface.\\n  1391→// Called during UserPromptSubmit to allow git hooks to detect active sessions.\\n  1392→//\\n  1393→// If the session already exists and HEAD has moved (e.g., user committed), updates\\n  1394→// BaseCommit to the new HEAD so future checkpoints go to the correct shadow branch.\\n  1395→//\\n  1396→// If there's an existing shadow branch with commits from a different session ID,\\n  1397→// returns a SessionIDConflictError to prevent orphaning existing session work.\\n  1398→//\\n  1399→// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n  1400→// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n  1401→// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\n  1402→func (s *ManualCommitStrategy) InitializeSession(sessionID string, agentType agent.AgentType, transcriptPath string, userPrompt string) error {\\n  1403→\\trepo, err := OpenRepository()\\n  1404→\\tif err != nil {\\n  1405→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n  1406→\\t}\\n  1407→\\n  1408→\\t// Check if session already exists\\n  1409→\\tstate, err := s.loadSessionState(sessionID)\\n  1410→\\tif err != nil {\\n  1411→\\t\\treturn fmt.Errorf(\\\"failed to check session state: %w\\\", err)\\n  1412→\\t}\\n  1413→\\n  1414→\\tif state != nil && state.BaseCommit != \\\"\\\" {\\n  1415→\\t\\t// Session is fully initialized — apply phase transition for TurnStart.\\n  1416→\\t\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1417→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1418→\\t\\t}\\n  1419→\\n  1420→\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n  1421→\\t\\tturnID, err := id.Generate()\\n  1422→\\t\\tif err != nil {\\n  1423→\\t\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n  1424→\\t\\t}\\n  1425→\\t\\tstate.TurnID = turnID.String()\\n  1426→\\n  1427→\\t\\t// Backfill AgentType if empty or set to the generic default \\\"Agent\\\"\\n  1428→\\t\\tif !isSpecificAgentType(state.AgentType) && agentType != \\\"\\\" {\\n  1429→\\t\\t\\tstate.AgentType = agentType\\n  1430→\\t\\t}\\n  1431→\\n  1432→\\t\\t// Backfill FirstPrompt if empty (for sessions created before the first_prompt field was added)\\n  1433→\\t\\tif state.FirstPrompt == \\\"\\\" && userPrompt != \\\"\\\" {\\n  1434→\\t\\t\\tstate.FirstPrompt = truncatePromptForStorage(userPrompt)\\n  1435→\\t\\t}\\n  1436→\\n  1437→\\t\\t// Update transcript path if provided (may change on session resume)\\n  1438→\\t\\tif transcriptPath != \\\"\\\" && state.TranscriptPath != transcriptPath {\\n  1439→\\t\\t\\tstate.TranscriptPath = transcriptPath\\n  1440→\\t\\t}\\n  1441→\\n  1442→\\t\\t// Clear checkpoint IDs on every new prompt.\\n  1443→\\t\\t// LastCheckpointID is set during PostCommit, cleared at new prompt.\\n  1444→\\t\\t// TurnCheckpointIDs tracks mid-turn checkpoints for stop-time finalization.\\n  1445→\\t\\tstate.LastCheckpointID = \\\"\\\"\\n  1446→\\t\\tstate.TurnCheckpointIDs = nil\\n  1447→\\n  1448→\\t\\t// Calculate attribution at prompt start (BEFORE agent makes any changes)\\n  1449→\\t\\t// This captures user edits since the last checkpoint (or base commit for first prompt).\\n  1450→\\t\\t// IMPORTANT: Always calculate attribution, even for the first checkpoint, to capture\\n  1451→\\t\\t// user edits made before the first prompt. The inner CalculatePromptAttribution handles\\n  1452→\\t\\t// nil lastCheckpointTree by falling back to baseTree.\\n  1453→\\t\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n  1454→\\t\\tstate.PendingPromptAttribution = &promptAttr\\n  1455→\\n  1456→\\t\\t// Check if HEAD has moved (user pulled/rebased or committed)\\n  1457→\\t\\t// migrateShadowBranchIfNeeded handles renaming the shadow branch and updating state.BaseCommit\\n  1458→\\t\\tif _, err := s.migrateShadowBranchIfNeeded(repo, state); err != nil {\\n  1459→\\t\\t\\treturn fmt.Errorf(\\\"failed to check/migrate shadow branch: %w\\\", err)\\n  1460→\\t\\t}\\n  1461→\\n  1462→\\t\\tif err := s.saveSessionState(state); err != nil {\\n  1463→\\t\\t\\treturn fmt.Errorf(\\\"failed to update session state: %w\\\", err)\\n  1464→\\t\\t}\\n  1465→\\t\\treturn nil\\n  1466→\\t}\\n  1467→\\t// If state exists but BaseCommit is empty, it's a partial state from concurrent warning\\n  1468→\\t// Continue below to properly initialize it\\n  1469→\\n  1470→\\t// Initialize new session\\n  1471→\\tstate, err = s.initializeSession(repo, sessionID, agentType, transcriptPath, userPrompt)\\n  1472→\\tif err != nil {\\n  1473→\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n  1474→\\t}\\n  1475→\\n  1476→\\t// Apply phase transition: new session starts as ACTIVE.\\n  1477→\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n  1478→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n  1479→\\t}\\n  1480→\\n  1481→\\t// Calculate attribution for pre-prompt edits\\n  1482→\\t// This captures any user edits made before the first prompt\\n  1483→\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n  1484→\\tstate.PendingPromptAttribution = &promptAttr\\n  1485→\\tif err = s.saveSessionState(state); err != nil {\\n  1486→\\t\\treturn fmt.Errorf(\\\"failed to save attribution: %w\\\", err)\\n  1487→\\t}\\n  1488→\\n  1489→\\tfmt.Fprintf(os.Stderr, \\\"Initialized shadow session: %s\\\\n\\\", sessionID)\\n  1490→\\treturn nil\\n  1491→}\\n  1492→\\n  1493→// calculatePromptAttributionAtStart calculates attribution at prompt start (before agent runs).\\n  1494→// This captures user changes since the last checkpoint - no filtering needed since\\n  1495→// the agent hasn't made any changes yet.\\n  1496→//\\n  1497→// IMPORTANT: This reads from the worktree (not staging area) to match what WriteTemporary\\n  1498→// captures in checkpoints. If we read staged content but checkpoints capture worktree content,\\n  1499→// unstaged changes would be in the checkpoint but not counted in PromptAttribution, causing\\n  1500→// them to be incorrectly attributed to the agent later.\\n  1501→func (s *ManualCommitStrategy) calculatePromptAttributionAtStart(\\n  1502→\\trepo *git.Repository,\\n  1503→\\tstate *SessionState,\\n  1504→) PromptAttribution {\\n  1505→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n  1506→\\tnextCheckpointNum := state.StepCount + 1\\n  1507→\\tresult := PromptAttribution{CheckpointNumber: nextCheckpointNum}\\n  1508→\\n  1509→\\t// Get last checkpoint tree from shadow branch (if it exists)\\n  1510→\\t// For the first checkpoint, no shadow branch exists yet - this is fine,\\n  1511→\\t// CalculatePromptAttribution will use baseTree as the reference instead.\\n  1512→\\tvar lastCheckpointTree *object.Tree\\n  1513→\\tshadowBranchName := checkpoint.ShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n  1514→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1515→\\tref, err := repo.Reference(refName, true)\\n  1516→\\tif err != nil {\\n  1517→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: no shadow branch yet (first checkpoint)\\\",\\n  1518→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName))\\n  1519→\\t\\t// Continue with lastCheckpointTree = nil\\n  1520→\\t} else {\\n  1521→\\t\\tshadowCommit, err := repo.CommitObject(ref.Hash())\\n  1522→\\t\\tif err != nil {\\n  1523→\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: failed to get shadow commit\\\",\\n  1524→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", ref.Hash().String()),\\n  1525→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1526→\\t\\t\\t// Continue with lastCheckpointTree = nil\\n  1527→\\t\\t} else {\\n  1528→\\t\\t\\tlastCheckpointTree, err = shadowCommit.Tree()\\n  1529→\\t\\t\\tif err != nil {\\n  1530→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: failed to get shadow tree\\\",\\n  1531→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1532→\\t\\t\\t\\t// Continue with lastCheckpointTree = nil\\n  1533→\\t\\t\\t}\\n  1534→\\t\\t}\\n  1535→\\t}\\n  1536→\\n  1537→\\t// Get base tree for agent lines calculation\\n  1538→\\tvar baseTree *object.Tree\\n  1539→\\tif baseCommit, err := repo.CommitObject(plumbing.NewHash(state.BaseCommit)); err == nil {\\n  1540→\\t\\tif tree, treeErr := baseCommit.Tree(); treeErr == nil {\\n  1541→\\t\\t\\tbaseTree = tree\\n  1542→\\t\\t} else {\\n  1543→\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: base tree unavailable\\\",\\n  1544→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n  1545→\\t\\t}\\n  1546→\\t} else {\\n  1547→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: base commit unavailable\\\",\\n  1548→\\t\\t\\tslog.String(\\\"base_commit\\\", state.BaseCommit),\\n  1549→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1550→\\t}\\n  1551→\\n  1552→\\tworktree, err := repo.Worktree()\\n  1553→\\tif err != nil {\\n  1554→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution skipped: failed to get worktree\\\",\\n  1555→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1556→\\t\\treturn result\\n  1557→\\t}\\n  1558→\\n  1559→\\t// Get worktree status to find ALL changed files\\n  1560→\\tstatus, err := worktree.Status()\\n  1561→\\tif err != nil {\\n  1562→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution skipped: failed to get worktree status\\\",\\n  1563→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n  1564→\\t\\treturn result\\n  1565→\\t}\\n  1566→\\n  1567→\\tworktreeRoot := worktree.Filesystem.Root()\\n  1568→\\n  1569→\\t// Build map of changed files with their worktree content\\n  1570→\\t// IMPORTANT: We read from worktree (not staging area) to match what WriteTemporary\\n  1571→\\t// captures in checkpoints. This ensures attribution is consistent.\\n  1572→\\tchangedFiles := make(map[string]string)\\n  1573→\\tfor filePath, fileStatus := range status {\\n  1574→\\t\\t// Skip unmodified files\\n  1575→\\t\\tif fileStatus.Worktree == git.Unmodified && fileStatus.Staging == git.Unmodified {\\n  1576→\\t\\t\\tcontinue\\n  1577→\\t\\t}\\n  1578→\\t\\t// Skip .entire metadata directory (session data, not user code)\\n  1579→\\t\\tif strings.HasPrefix(filePath, paths.EntireMetadataDir+\\\"/\\\") || strings.HasPrefix(filePath, \\\".entire/\\\") {\\n  1580→\\t\\t\\tcontinue\\n  1581→\\t\\t}\\n  1582→\\n  1583→\\t\\t// Always read from worktree to match checkpoint behavior\\n  1584→\\t\\tfullPath := filepath.Join(worktreeRoot, filePath)\\n  1585→\\t\\tvar content string\\n  1586→\\t\\tif data, err := os.ReadFile(fullPath); err == nil { //nolint:gosec // filePath is from git worktree status\\n  1587→\\t\\t\\t// Use git's binary detection algorithm (matches getFileContent behavior).\\n  1588→\\t\\t\\t// Binary files are excluded from line-based attribution calculations.\\n  1589→\\t\\t\\tisBinary, binErr := binary.IsBinary(bytes.NewReader(data))\\n  1590→\\t\\t\\tif binErr == nil && !isBinary {\\n  1591→\\t\\t\\t\\tcontent = string(data)\\n  1592→\\t\\t\\t}\\n  1593→\\t\\t}\\n  1594→\\t\\t// else: file deleted, unreadable, or binary - content remains empty string\\n  1595→\\n  1596→\\t\\tchangedFiles[filePath] = content\\n  1597→\\t}\\n  1598→\\n  1599→\\t// Use CalculatePromptAttribution from manual_commit_attribution.go\\n  1600→\\tresult = CalculatePromptAttribution(baseTree, lastCheckpointTree, changedFiles, nextCheckpointNum)\\n  1601→\\n  1602→\\treturn result\\n  1603→}\\n  1604→\\n  1605→// getStagedFiles returns a list of files staged for commit.\\n  1606→func getStagedFiles(repo *git.Repository) []string {\\n  1607→\\tworktree, err := repo.Worktree()\\n  1608→\\tif err != nil {\\n  1609→\\t\\treturn nil\\n  1610→\\t}\\n  1611→\\n  1612→\\tstatus, err := worktree.Status()\\n  1613→\\tif err != nil {\\n  1614→\\t\\treturn nil\\n  1615→\\t}\\n  1616→\\n  1617→\\tvar staged []string\\n  1618→\\tfor path, fileStatus := range status {\\n  1619→\\t\\t// Check if file is staged (in index)\\n  1620→\\t\\tif fileStatus.Staging != git.Unmodified && fileStatus.Staging != git.Untracked {\\n  1621→\\t\\t\\tstaged = append(staged, path)\\n  1622→\\t\\t}\\n  1623→\\t}\\n  1624→\\treturn staged\\n  1625→}\\n  1626→\\n  1627→// getLastPrompt retrieves the most recent user prompt from a session's shadow branch.\\n  1628→// Returns empty string if no prompt can be retrieved.\\n  1629→func (s *ManualCommitStrategy) getLastPrompt(repo *git.Repository, state *SessionState) string {\\n  1630→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n  1631→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1632→\\tref, err := repo.Reference(refName, true)\\n  1633→\\tif err != nil {\\n  1634→\\t\\treturn \\\"\\\"\\n  1635→\\t}\\n  1636→\\n  1637→\\t// Extract session data to get prompts for commit message generation\\n  1638→\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini)\\n  1639→\\t// Pass 0 for checkpointTranscriptStart since we're extracting all prompts, not calculating token usage\\n  1640→\\tsessionData, err := s.extractSessionData(repo, ref.Hash(), state.SessionID, nil, state.AgentType, \\\"\\\", 0)\\n  1641→\\tif err != nil || len(sessionData.Prompts) == 0 {\\n  1642→\\t\\treturn \\\"\\\"\\n  1643→\\t}\\n  1644→\\n  1645→\\t// Return the last prompt (most recent work before commit)\\n  1646→\\treturn sessionData.Prompts[len(sessionData.Prompts)-1]\\n  1647→}\\n  1648→\\n  1649→// HandleTurnEnd dispatches strategy-specific actions emitted when an agent turn ends.\\n  1650→// The primary job is to finalize all checkpoints from this turn with the full transcript.\\n  1651→//\\n  1652→// During a turn, PostCommit writes provisional transcript data (whatever was available\\n  1653→// at commit time). HandleTurnEnd replaces that with the complete session transcript\\n  1654→// (from prompt to stop event), ensuring every checkpoint has the full context.\\n  1655→//\\n  1656→//nolint:unparam // error return required by interface but hooks must return nil\\n  1657→func (s *ManualCommitStrategy) HandleTurnEnd(state *SessionState) error {\\n  1658→\\t// Finalize all checkpoints from this turn with the full transcript.\\n  1659→\\t//\\n  1660→\\t// IMPORTANT: This is best-effort - errors are logged but don't fail the hook.\\n  1661→\\t// Failing here would prevent session cleanup and could leave state inconsistent.\\n  1662→\\t// The provisional transcript from PostCommit is already persisted, so the\\n  1663→\\t// checkpoint isn't lost - it just won't have the complete transcript.\\n  1664→\\terrCount := s.finalizeAllTurnCheckpoints(state)\\n  1665→\\tif errCount > 0 {\\n  1666→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1667→\\t\\tlogging.Warn(logCtx, \\\"HandleTurnEnd completed with errors (best-effort)\\\",\\n  1668→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1669→\\t\\t\\tslog.Int(\\\"error_count\\\", errCount),\\n  1670→\\t\\t)\\n  1671→\\t}\\n  1672→\\treturn nil\\n  1673→}\\n  1674→\\n  1675→// finalizeAllTurnCheckpoints replaces the provisional transcript in each checkpoint\\n  1676→// created during this turn with the full session transcript.\\n  1677→//\\n  1678→// This is called at turn end (stop hook). During the turn, PostCommit wrote whatever\\n  1679→// transcript was available at commit time. Now we have the complete transcript and\\n  1680→// replace it so every checkpoint has the full prompt-to-stop context.\\n  1681→//\\n  1682→// Returns the number of errors encountered (best-effort: continues processing on error).\\n  1683→func (s *ManualCommitStrategy) finalizeAllTurnCheckpoints(state *SessionState) int {\\n  1684→\\tif len(state.TurnCheckpointIDs) == 0 {\\n  1685→\\t\\treturn 0 // No mid-turn commits to finalize\\n  1686→\\t}\\n  1687→\\n  1688→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1689→\\n  1690→\\tlogging.Info(logCtx, \\\"finalizing turn checkpoints with full transcript\\\",\\n  1691→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1692→\\t\\tslog.Int(\\\"checkpoint_count\\\", len(state.TurnCheckpointIDs)),\\n  1693→\\t)\\n  1694→\\n  1695→\\terrCount := 0\\n  1696→\\n  1697→\\t// Read full transcript from live transcript file\\n  1698→\\tif state.TranscriptPath == \\\"\\\" {\\n  1699→\\t\\tlogging.Warn(logCtx, \\\"finalize: no transcript path, skipping\\\",\\n  1700→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1701→\\t\\t)\\n  1702→\\t\\tstate.TurnCheckpointIDs = nil\\n  1703→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1704→\\t}\\n  1705→\\n  1706→\\tfullTranscript, err := os.ReadFile(state.TranscriptPath)\\n  1707→\\tif err != nil || len(fullTranscript) == 0 {\\n  1708→\\t\\tmsg := \\\"finalize: empty transcript, skipping\\\"\\n  1709→\\t\\tif err != nil {\\n  1710→\\t\\t\\tmsg = \\\"finalize: failed to read transcript, skipping\\\"\\n  1711→\\t\\t}\\n  1712→\\t\\tlogging.Warn(logCtx, msg,\\n  1713→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1714→\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1715→\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1716→\\t\\t)\\n  1717→\\t\\tstate.TurnCheckpointIDs = nil\\n  1718→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1719→\\t}\\n  1720→\\n  1721→\\t// Extract prompts and context from the full transcript\\n  1722→\\tprompts := extractUserPrompts(state.AgentType, string(fullTranscript))\\n  1723→\\tcontextBytes := generateContextFromPrompts(prompts)\\n  1724→\\n  1725→\\t// Redact secrets before writing — matches WriteCommitted behavior.\\n  1726→\\t// The live transcript on disk contains raw content; redaction must happen\\n  1727→\\t// before anything is persisted to the metadata branch.\\n  1728→\\tfullTranscript, err = redact.JSONLBytes(fullTranscript)\\n  1729→\\tif err != nil {\\n  1730→\\t\\tlogging.Warn(logCtx, \\\"finalize: transcript redaction failed, skipping\\\",\\n  1731→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1732→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1733→\\t\\t)\\n  1734→\\t\\tstate.TurnCheckpointIDs = nil\\n  1735→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1736→\\t}\\n  1737→\\tfor i, p := range prompts {\\n  1738→\\t\\tprompts[i] = redact.String(p)\\n  1739→\\t}\\n  1740→\\tcontextBytes = redact.Bytes(contextBytes)\\n  1741→\\n  1742→\\t// Open repository and create checkpoint store\\n  1743→\\trepo, err := OpenRepository()\\n  1744→\\tif err != nil {\\n  1745→\\t\\tlogging.Warn(logCtx, \\\"finalize: failed to open repository\\\",\\n  1746→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1747→\\t\\t)\\n  1748→\\t\\tstate.TurnCheckpointIDs = nil\\n  1749→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1750→\\t}\\n  1751→\\tstore := checkpoint.NewGitStore(repo)\\n  1752→\\n  1753→\\t// Update each checkpoint with the full transcript\\n  1754→\\tfor _, cpIDStr := range state.TurnCheckpointIDs {\\n  1755→\\t\\tcpID, parseErr := id.NewCheckpointID(cpIDStr)\\n  1756→\\t\\tif parseErr != nil {\\n  1757→\\t\\t\\tlogging.Warn(logCtx, \\\"finalize: invalid checkpoint ID, skipping\\\",\\n  1758→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1759→\\t\\t\\t\\tslog.String(\\\"error\\\", parseErr.Error()),\\n  1760→\\t\\t\\t)\\n  1761→\\t\\t\\terrCount++\\n  1762→\\t\\t\\tcontinue\\n  1763→\\t\\t}\\n  1764→\\n  1765→\\t\\tupdateErr := store.UpdateCommitted(context.Background(), checkpoint.UpdateCommittedOptions{\\n  1766→\\t\\t\\tCheckpointID: cpID,\\n  1767→\\t\\t\\tSessionID:    state.SessionID,\\n  1768→\\t\\t\\tTranscript:   fullTranscript,\\n  1769→\\t\\t\\tPrompts:      prompts,\\n  1770→\\t\\t\\tContext:      contextBytes,\\n  1771→\\t\\t\\tAgent:        state.AgentType,\\n  1772→\\t\\t})\\n  1773→\\t\\tif updateErr != nil {\\n  1774→\\t\\t\\tlogging.Warn(logCtx, \\\"finalize: failed to update checkpoint\\\",\\n  1775→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1776→\\t\\t\\t\\tslog.String(\\\"error\\\", updateErr.Error()),\\n  1777→\\t\\t\\t)\\n  1778→\\t\\t\\terrCount++\\n  1779→\\t\\t\\tcontinue\\n  1780→\\t\\t}\\n  1781→\\n  1782→\\t\\tlogging.Info(logCtx, \\\"finalize: checkpoint updated with full transcript\\\",\\n  1783→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1784→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1785→\\t\\t)\\n  1786→\\t}\\n  1787→\\n  1788→\\t// Clear turn checkpoint IDs. Do NOT update CheckpointTranscriptStart here — it was\\n  1789→\\t// already set correctly by PostCommit: condenseAndUpdateState sets it to the total\\n  1790→\\t// transcript lines when condensing, and carryForwardToNewShadowBranch resets it to 0\\n  1791→\\t// when carry-forward is active. Overwriting here would break carry-forward by making\\n  1792→\\t// sessionHasNewContent think the transcript is fully consumed (no growth).\\n  1793→\\tstate.TurnCheckpointIDs = nil\\n  1794→\\n  1795→\\treturn errCount\\n  1796→}\\n  1797→\\n  1798→// filesChangedInCommit returns the set of files changed in a commit by diffing against its parent.\\n  1799→func filesChangedInCommit(commit *object.Commit) map[string]struct{} {\\n  1800→\\tresult := make(map[string]struct{})\\n  1801→\\n  1802→\\tcommitTree, err := commit.Tree()\\n  1803→\\tif err != nil {\\n  1804→\\t\\treturn result\\n  1805→\\t}\\n  1806→\\n  1807→\\tvar parentTree *object.Tree\\n  1808→\\tif commit.NumParents() > 0 {\\n  1809→\\t\\tparent, err := commit.Parent(0)\\n  1810→\\t\\tif err != nil {\\n  1811→\\t\\t\\treturn result\\n  1812→\\t\\t}\\n  1813→\\t\\tparentTree, err = parent.Tree()\\n  1814→\\t\\tif err != nil {\\n  1815→\\t\\t\\treturn result\\n  1816→\\t\\t}\\n  1817→\\t}\\n  1818→\\n  1819→\\tif parentTree == nil {\\n  1820→\\t\\t// Initial commit — all files are new\\n  1821→\\t\\tif iterErr := commitTree.Files().ForEach(func(f *object.File) error {\\n  1822→\\t\\t\\tresult[f.Name] = struct{}{}\\n  1823→\\t\\t\\treturn nil\\n  1824→\\t\\t}); iterErr != nil {\\n  1825→\\t\\t\\treturn result\\n  1826→\\t\\t}\\n  1827→\\t\\treturn result\\n  1828→\\t}\\n  1829→\\n  1830→\\tchanges, err := parentTree.Diff(commitTree)\\n  1831→\\tif err != nil {\\n  1832→\\t\\treturn result\\n  1833→\\t}\\n  1834→\\tfor _, change := range changes {\\n  1835→\\t\\tname := change.To.Name\\n  1836→\\t\\tif name == \\\"\\\" {\\n  1837→\\t\\t\\tname = change.From.Name\\n  1838→\\t\\t}\\n  1839→\\t\\tresult[name] = struct{}{}\\n  1840→\\t}\\n  1841→\\treturn result\\n  1842→}\\n  1843→\\n  1844→// subtractFiles returns files that are NOT in the exclude set.\\n  1845→func subtractFiles(files []string, exclude map[string]struct{}) []string {\\n  1846→\\tvar remaining []string\\n  1847→\\tfor _, f := range files {\\n  1848→\\t\\tif _, excluded := exclude[f]; !excluded {\\n  1849→\\t\\t\\tremaining = append(remaining, f)\\n  1850→\\t\\t}\\n  1851→\\t}\\n  1852→\\treturn remaining\\n  1853→}\\n  1854→\\n  1855→// carryForwardToNewShadowBranch creates a new shadow branch at the current HEAD\\n  1856→// containing the remaining uncommitted files and all session metadata.\\n  1857→// This enables the next commit to get its own unique checkpoint.\\n  1858→func (s *ManualCommitStrategy) carryForwardToNewShadowBranch(\\n  1859→\\tlogCtx context.Context,\\n  1860→\\trepo *git.Repository,\\n  1861→\\tstate *SessionState,\\n  1862→\\tremainingFiles []string,\\n  1863→) {\\n  1864→\\tstore := checkpoint.NewGitStore(repo)\\n  1865→\\n  1866→\\t// Don't include metadata directory in carry-forward. The carry-forward branch\\n  1867→\\t// only needs to preserve file content for comparison - not the transcript.\\n  1868→\\t// Including the transcript would cause sessionHasNewContent to always return true\\n  1869→\\t// because CheckpointTranscriptStart is reset to 0 for carry-forward.\\n  1870→\\tresult, err := store.WriteTemporary(context.Background(), checkpoint.WriteTemporaryOptions{\\n  1871→\\t\\tSessionID:         state.SessionID,\\n  1872→\\t\\tBaseCommit:        state.BaseCommit,\\n  1873→\\t\\tWorktreeID:        state.WorktreeID,\\n  1874→\\t\\tModifiedFiles:     remainingFiles,\\n  1875→\\t\\tMetadataDir:       \\\"\\\",\\n  1876→\\t\\tMetadataDirAbs:    \\\"\\\",\\n  1877→\\t\\tCommitMessage:     \\\"carry forward: uncommitted session files\\\",\\n  1878→\\t\\tIsFirstCheckpoint: false,\\n  1879→\\t})\\n  1880→\\tif err != nil {\\n  1881→\\t\\tlogging.Warn(logCtx, \\\"post-commit: carry-forward failed\\\",\\n  1882→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1883→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1884→\\t\\t)\\n  1885→\\t\\treturn\\n  1886→\\t}\\n  1887→\\tif result.Skipped {\\n  1888→\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward skipped (no changes)\\\",\\n  1889→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1890→\\t\\t)\\n  1891→\\t\\treturn\\n  1892→\\t}\\n  1893→\\n  1894→\\t// Update state for the carry-forward checkpoint.\\n  1895→\\t// CheckpointTranscriptStart = 0 is intentional: each checkpoint is self-contained with\\n  1896→\\t// the full transcript. This trades storage efficiency for simplicity:\\n  1897→\\t// - Pro: Each checkpoint is independently readable without needing to stitch together\\n  1898→\\t//   multiple checkpoints to understand the session history\\n  1899→\\t// - Con: For long sessions with multiple partial commits, each checkpoint includes\\n  1900→\\t//   the full transcript, which could be large\\n  1901→\\t// An alternative would be incremental checkpoints (only new content since last condensation),\\n  1902→\\t// but this would complicate checkpoint retrieval and require careful tracking of dependencies.\\n  1903→\\tstate.StepCount = 1\\n  1904→\\tstate.CheckpointTranscriptStart = 0\\n  1905→\\tstate.LastCheckpointID = \\\"\\\"\\n  1906→\\t// NOTE: TurnCheckpointIDs is intentionally NOT cleared here. Those checkpoint\\n  1907→\\t// IDs from earlier in the turn still need finalization with the full transcript\\n  1908→\\t// when HandleTurnEnd runs at stop time.\\n  1909→\\n  1910→\\tlogging.Info(logCtx, \\\"post-commit: carried forward remaining files\\\",\\n  1911→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1912→\\t\\tslog.Int(\\\"remaining_files\\\", len(remainingFiles)),\\n  1913→\\t)\\n  1914→}\\n  1915→\\n  1916→// appendCheckpointToTrail links a checkpoint to the trail for the current branch.\\n  1917→// Best-effort: silently returns on any error (trails are non-critical metadata).\\n  1918→func appendCheckpointToTrail(repo *git.Repository, cpID id.CheckpointID, commitSHA plumbing.Hash, prompts []string) {\\n  1919→\\tbranchName := GetCurrentBranchName(repo)\\n  1920→\\tif branchName == \\\"\\\" {\\n  1921→\\t\\treturn\\n  1922→\\t}\\n  1923→\\tdefaultBranch := GetDefaultBranchName(repo)\\n  1924→\\tif branchName == defaultBranch {\\n  1925→\\t\\treturn\\n  1926→\\t}\\n  1927→\\n  1928→\\tstore := trail.NewStore(repo)\\n  1929→\\texisting, err := store.FindByBranch(branchName)\\n  1930→\\tif err != nil || existing == nil {\\n  1931→\\t\\treturn\\n  1932→\\t}\\n  1933→\\n  1934→\\tvar summary string\\n  1935→\\tif len(prompts) > 0 {\\n  1936→\\t\\tsummary = truncateForSummary(prompts[len(prompts)-1], 200)\\n  1937→\\t}\\n  1938→\\n  1939→\\t//nolint:errcheck,gosec // best-effort: trail checkpoint linking is non-critical\\n  1940→\\tstore.AddCheckpoint(existing.TrailID, trail.CheckpointRef{\\n  1941→\\t\\tCheckpointID: cpID.String(),\\n  1942→\\t\\tCommitSHA:    commitSHA.String(),\\n  1943→\\t\\tCreatedAt:    time.Now().UTC(),\\n  1944→\\t\\tSummary:      summary,\\n  1945→\\t})\\n  1946→}\\n  1947→\\n  1948→// truncateForSummary truncates a string to maxLen, adding \\\"...\\\" if truncated.\\n  1949→// Takes the first line only to keep summaries concise.\\n  1950→func truncateForSummary(s string, maxLen int) string {\\n  1951→\\tline, _, _ := strings.Cut(s, \\\"\\\\n\\\")\\n  1952→\\tline = strings.TrimSpace(line)\\n  1953→\\tif len(line) <= maxLen {\\n  1954→\\t\\treturn line\\n  1955→\\t}\\n  1956→\\tif maxLen <= 3 {\\n  1957→\\t\\treturn line[:maxLen]\\n  1958→\\t}\\n  1959→\\treturn line[:maxLen-3] + \\\"...\\\"\\n  1960→}\\n  1961→\"}]},\"uuid\":\"701d3698-6e4d-48bf-990e-820fe7850f54\",\"timestamp\":\"2026-02-20T19:06:31.719Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/dip/Repositories/cli/cmd/entire/cli/strategy/manual_commit_hooks.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"bufio\\\"\\n\\t\\\"bytes\\\"\\n\\t\\\"context\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/stringutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/trail\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n\\t\\\"github.com/entireio/cli/redact\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n\\t\\\"github.com/go-git/go-git/v5/utils/binary\\\"\\n)\\n\\n// hasTTY checks if /dev/tty is available for interactive prompts.\\n// Returns false when running as an agent subprocess (no controlling terminal).\\n//\\n// In test environments, ENTIRE_TEST_TTY overrides the real check:\\n//   - ENTIRE_TEST_TTY=1 → simulate human (TTY available)\\n//   - ENTIRE_TEST_TTY=0 → simulate agent (no TTY)\\nfunc hasTTY() bool {\\n\\tif v := os.Getenv(\\\"ENTIRE_TEST_TTY\\\"); v != \\\"\\\" {\\n\\t\\treturn v == \\\"1\\\"\\n\\t}\\n\\n\\t// Gemini CLI sets GEMINI_CLI=1 when running shell commands.\\n\\t// Gemini subprocesses may have access to the user's TTY, but they can't\\n\\t// actually respond to interactive prompts. Treat them as non-TTY.\\n\\t// See: https://geminicli.com/docs/tools/shell/\\n\\tif os.Getenv(\\\"GEMINI_CLI\\\") != \\\"\\\" {\\n\\t\\treturn false\\n\\t}\\n\\n\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n\\tif err != nil {\\n\\t\\treturn false\\n\\t}\\n\\t_ = tty.Close()\\n\\treturn true\\n}\\n\\n// askConfirmTTY prompts the user for a yes/no confirmation via /dev/tty.\\n// This works even when stdin is redirected (e.g., git commit -m).\\n// Returns true for yes, false for no. If TTY is unavailable, returns the default.\\n// If context is non-empty, it is displayed on a separate line before the prompt.\\nfunc askConfirmTTY(prompt string, context string, defaultYes bool) bool {\\n\\t// In test mode, don't try to interact with the real TTY — just use the default.\\n\\t// ENTIRE_TEST_TTY=1 simulates \\\"a human is present\\\" for the hasTTY() check\\n\\t// but we can't actually read from the TTY in tests.\\n\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n\\t\\treturn defaultYes\\n\\t}\\n\\n\\t// Gemini CLI sets GEMINI_CLI=1 when running shell commands (including git commit).\\n\\t// The agent can't respond to TTY prompts, so use the default to avoid hanging.\\n\\t// See: https://geminicli.com/docs/tools/shell/\\n\\tif os.Getenv(\\\"GEMINI_CLI\\\") != \\\"\\\" {\\n\\t\\treturn defaultYes\\n\\t}\\n\\n\\t// Open /dev/tty for both reading and writing\\n\\t// This is the controlling terminal, which works even when stdin/stderr are redirected\\n\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n\\tif err != nil {\\n\\t\\t// Can't open TTY (e.g., running in CI), use default\\n\\t\\treturn defaultYes\\n\\t}\\n\\tdefer tty.Close()\\n\\n\\t// Show context if provided\\n\\tif context != \\\"\\\" {\\n\\t\\tfmt.Fprintf(tty, \\\"%s\\\\n\\\", context)\\n\\t}\\n\\n\\t// Show prompt with default indicator\\n\\t// Write to tty directly, not stderr, since git hooks may redirect stderr to /dev/null\\n\\tvar hint string\\n\\tif defaultYes {\\n\\t\\thint = \\\"[Y/n]\\\"\\n\\t} else {\\n\\t\\thint = \\\"[y/N]\\\"\\n\\t}\\n\\tfmt.Fprintf(tty, \\\"%s %s \\\", prompt, hint)\\n\\n\\t// Read response\\n\\treader := bufio.NewReader(tty)\\n\\tresponse, err := reader.ReadString('\\\\n')\\n\\tif err != nil {\\n\\t\\treturn defaultYes\\n\\t}\\n\\n\\tresponse = strings.TrimSpace(strings.ToLower(response))\\n\\tswitch response {\\n\\tcase \\\"y\\\", \\\"yes\\\":\\n\\t\\treturn true\\n\\tcase \\\"n\\\", \\\"no\\\":\\n\\t\\treturn false\\n\\tdefault:\\n\\t\\t// Empty or invalid input - use default\\n\\t\\treturn defaultYes\\n\\t}\\n}\\n\\n// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n// If the message contains only our trailer (no actual user content), strip it\\n// so git will abort the commit due to empty message.\\n//\\n//nolint:unparam // error return required by interface but hooks must return nil\\nfunc (s *ManualCommitStrategy) CommitMsg(commitMsgFile string) error {\\n\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\n\\tmessage := string(content)\\n\\n\\t// Check if our trailer is present (ParseCheckpoint validates format, so found==true means valid)\\n\\tif _, found := trailers.ParseCheckpoint(message); !found {\\n\\t\\t// No trailer, nothing to do\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Check if there's any user content (non-comment, non-trailer lines)\\n\\tif !hasUserContent(message) {\\n\\t\\t// No user content - strip the trailer so git aborts\\n\\t\\tmessage = stripCheckpointTrailer(message)\\n\\t\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// hasUserContent checks if the message has any content besides comments and our trailer.\\nfunc hasUserContent(message string) bool {\\n\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n\\t\\ttrimmed := strings.TrimSpace(line)\\n\\t\\t// Skip empty lines\\n\\t\\tif trimmed == \\\"\\\" {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\t// Skip comment lines\\n\\t\\tif strings.HasPrefix(trimmed, \\\"#\\\") {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\t// Skip our trailer line\\n\\t\\tif strings.HasPrefix(trimmed, trailerPrefix) {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\t// Found user content\\n\\t\\treturn true\\n\\t}\\n\\treturn false\\n}\\n\\n// stripCheckpointTrailer removes the Entire-Checkpoint trailer line from the message.\\nfunc stripCheckpointTrailer(message string) string {\\n\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n\\tvar result []string\\n\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n\\t\\tif !strings.HasPrefix(strings.TrimSpace(line), trailerPrefix) {\\n\\t\\t\\tresult = append(result, line)\\n\\t\\t}\\n\\t}\\n\\treturn strings.Join(result, \\\"\\\\n\\\")\\n}\\n\\n// isGitSequenceOperation checks if git is currently in the middle of a rebase,\\n// cherry-pick, or revert operation. During these operations, commits are being\\n// replayed and should not be linked to agent sessions.\\n//\\n// Detects:\\n//   - rebase: .git/rebase-merge/ or .git/rebase-apply/ directories\\n//   - cherry-pick: .git/CHERRY_PICK_HEAD file\\n//   - revert: .git/REVERT_HEAD file\\nfunc isGitSequenceOperation() bool {\\n\\t// Get git directory (handles worktrees and relative paths correctly)\\n\\tgitDir, err := GetGitDir()\\n\\tif err != nil {\\n\\t\\treturn false // Can't determine, assume not in sequence operation\\n\\t}\\n\\n\\t// Check for rebase state directories\\n\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-merge\\\")); err == nil {\\n\\t\\treturn true\\n\\t}\\n\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-apply\\\")); err == nil {\\n\\t\\treturn true\\n\\t}\\n\\n\\t// Check for cherry-pick and revert state files\\n\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"CHERRY_PICK_HEAD\\\")); err == nil {\\n\\t\\treturn true\\n\\t}\\n\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"REVERT_HEAD\\\")); err == nil {\\n\\t\\treturn true\\n\\t}\\n\\n\\treturn false\\n}\\n\\n// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n// Only adds a trailer if there's actually new session content to condense.\\n// The actual condensation happens in PostCommit - if the user removes the trailer,\\n// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n// For amended commits, preserves the existing checkpoint ID.\\n//\\n// The source parameter indicates how the commit was initiated:\\n//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n//\\n\\nfunc (s *ManualCommitStrategy) PrepareCommitMsg(commitMsgFile string, source string) error {\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n\\n\\t// Skip during rebase, cherry-pick, or revert operations\\n\\t// These are replaying existing commits and should not be linked to agent sessions\\n\\tif isGitSequenceOperation() {\\n\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\t\\tslog.String(\\\"source\\\", source),\\n\\t\\t)\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Skip for merge and squash sources\\n\\t// These are auto-generated messages - not from Claude sessions\\n\\tswitch source {\\n\\tcase \\\"merge\\\", \\\"squash\\\":\\n\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\t\\tslog.String(\\\"source\\\", source),\\n\\t\\t)\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n\\tif source == \\\"commit\\\" {\\n\\t\\treturn s.handleAmendCommitMsg(logCtx, commitMsgFile)\\n\\t}\\n\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\n\\tworktreePath, err := GetWorktreePath()\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\n\\t// Find all active sessions for this worktree\\n\\t// We match by worktree (not BaseCommit) because the user may have made\\n\\t// intermediate commits without entering new prompts, causing HEAD to diverge\\n\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n\\tif err != nil || len(sessions) == 0 {\\n\\t\\t// No active sessions or error listing - silently skip (hooks must be resilient)\\n\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no active sessions\\\",\\n\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\t\\tslog.String(\\\"source\\\", source),\\n\\t\\t)\\n\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n\\t}\\n\\n\\t// Fast path: when an agent is committing (ACTIVE session + no TTY), skip\\n\\t// content detection and interactive prompts. The agent can't respond to TTY\\n\\t// prompts and the content detection can miss mid-session work (no shadow\\n\\t// branch yet, transcript analysis may fail). Generate a checkpoint ID and\\n\\t// add the trailer directly.\\n\\tif !hasTTY() {\\n\\t\\tfor _, state := range sessions {\\n\\t\\t\\tif state.Phase.IsActive() {\\n\\t\\t\\t\\treturn s.addTrailerForAgentCommit(logCtx, commitMsgFile, state, source)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Check if any session has new content to condense\\n\\tsessionsWithContent := s.filterSessionsWithNewContent(repo, sessions)\\n\\n\\tif len(sessionsWithContent) == 0 {\\n\\t\\t// No new content — no trailer needed\\n\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no content to link\\\",\\n\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\t\\tslog.String(\\\"source\\\", source),\\n\\t\\t\\tslog.Int(\\\"sessions_found\\\", len(sessions)),\\n\\t\\t)\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Read current commit message\\n\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\n\\tmessage := string(content)\\n\\n\\t// Check if trailer already exists (ParseCheckpoint validates format, so found==true means valid)\\n\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n\\t\\t// Trailer already exists (e.g., amend) - keep it\\n\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: trailer already exists\\\",\\n\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\t\\tslog.String(\\\"source\\\", source),\\n\\t\\t\\tslog.String(\\\"existing_checkpoint_id\\\", existingCpID.String()),\\n\\t\\t)\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Generate a fresh checkpoint ID\\n\\tcheckpointID, err := id.Generate()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n\\t}\\n\\n\\t// Determine agent type and last prompt from session\\n\\tagentType := DefaultAgentType // default for backward compatibility\\n\\tvar lastPrompt string\\n\\tif len(sessionsWithContent) > 0 {\\n\\t\\tfirstSession := sessionsWithContent[0]\\n\\t\\tif firstSession.AgentType != \\\"\\\" {\\n\\t\\t\\tagentType = firstSession.AgentType\\n\\t\\t}\\n\\t\\tlastPrompt = s.getLastPrompt(repo, firstSession)\\n\\t}\\n\\n\\t// Prepare prompt for display: collapse newlines/whitespace, then truncate (rune-safe)\\n\\tdisplayPrompt := stringutil.TruncateRunes(stringutil.CollapseWhitespace(lastPrompt), 80, \\\"...\\\")\\n\\n\\t// Add trailer differently based on commit source\\n\\tswitch source {\\n\\tcase \\\"message\\\":\\n\\t\\t// Using -m or -F: ask user interactively whether to add trailer\\n\\t\\t// (comments won't be stripped by git in this mode)\\n\\n\\t\\t// Build context string for interactive prompt\\n\\t\\tvar promptContext string\\n\\t\\tif displayPrompt != \\\"\\\" {\\n\\t\\t\\tpromptContext = \\\"You have an active \\\" + string(agentType) + \\\" session.\\\\nLast Prompt: \\\" + displayPrompt\\n\\t\\t}\\n\\n\\t\\tif !askConfirmTTY(\\\"Link this commit to \\\"+string(agentType)+\\\" session context?\\\", promptContext, true) {\\n\\t\\t\\t// User declined - don't add trailer\\n\\t\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: user declined trailer\\\",\\n\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n\\t\\t\\t)\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\tmessage = addCheckpointTrailer(message, checkpointID)\\n\\tdefault:\\n\\t\\t// Normal editor flow: add trailer with explanatory comment (will be stripped by git)\\n\\t\\tmessage = addCheckpointTrailerWithComment(message, checkpointID, string(agentType), displayPrompt)\\n\\t}\\n\\n\\tlogging.Info(logCtx, \\\"prepare-commit-msg: trailer added\\\",\\n\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\tslog.String(\\\"source\\\", source),\\n\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n\\t)\\n\\n\\t// Write updated message back\\n\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleAmendCommitMsg handles the prepare-commit-msg hook for amend operations\\n// (source=\\\"commit\\\"). It preserves existing trailers or restores from LastCheckpointID.\\nfunc (s *ManualCommitStrategy) handleAmendCommitMsg(logCtx context.Context, commitMsgFile string) error {\\n\\t// Read current commit message\\n\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\n\\tmessage := string(content)\\n\\n\\t// If message already has a trailer, keep it unchanged\\n\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend preserves existing trailer\\\",\\n\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\t\\tslog.String(\\\"checkpoint_id\\\", existingCpID.String()),\\n\\t\\t)\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// No trailer in message — check if any session has LastCheckpointID to restore\\n\\tworktreePath, err := GetWorktreePath()\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\n\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n\\tif err != nil || len(sessions) == 0 {\\n\\t\\treturn nil //nolint:nilerr // No sessions - nothing to restore\\n\\t}\\n\\n\\t// For amend, HEAD^ is the commit being amended, and HEAD is where we are now.\\n\\t// We need to match sessions whose BaseCommit equals HEAD (the commit being amended\\n\\t// was created from this base). This prevents stale sessions from injecting\\n\\t// unrelated checkpoint IDs.\\n\\trepo, repoErr := OpenRepository()\\n\\tif repoErr != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\thead, headErr := repo.Head()\\n\\tif headErr != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\tcurrentHead := head.Hash().String()\\n\\n\\t// Find first matching session with LastCheckpointID to restore.\\n\\t// LastCheckpointID is set after condensation completes.\\n\\tfor _, state := range sessions {\\n\\t\\tif state.BaseCommit != currentHead {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tif state.LastCheckpointID.IsEmpty() {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tcpID := state.LastCheckpointID\\n\\t\\tsource := \\\"LastCheckpointID\\\"\\n\\n\\t\\t// Restore the trailer\\n\\t\\tmessage = addCheckpointTrailer(message, cpID)\\n\\t\\tif writeErr := os.WriteFile(commitMsgFile, []byte(message), 0o600); writeErr != nil {\\n\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t\\t}\\n\\n\\t\\tlogging.Info(logCtx, \\\"prepare-commit-msg: restored trailer on amend\\\",\\n\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\tslog.String(\\\"source\\\", source),\\n\\t\\t)\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// No checkpoint ID found - leave message unchanged\\n\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend with no checkpoint to restore\\\",\\n\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t)\\n\\treturn nil\\n}\\n\\n// PostCommit is called by the git post-commit hook after a commit is created.\\n// Uses the session state machine to determine what action to take per session:\\n//   - ACTIVE → condense immediately (each commit gets its own checkpoint)\\n//   - IDLE → condense immediately\\n//   - ENDED → condense if files touched, discard if empty\\n//\\n// After condensation for ACTIVE sessions, remaining uncommitted files are\\n// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n//\\n// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n// and were condensed during this PostCommit.\\n\\n// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n// Each session in the loop gets its own handler with per-session context.\\n// Handler methods use the *State parameter from ApplyTransition (same pointer\\n// as the state being transitioned) rather than capturing state separately.\\ntype postCommitActionHandler struct {\\n\\ts                      *ManualCommitStrategy\\n\\tlogCtx                 context.Context\\n\\trepo                   *git.Repository\\n\\tcheckpointID           id.CheckpointID\\n\\thead                   *plumbing.Reference\\n\\tcommit                 *object.Commit\\n\\tnewHead                string\\n\\tshadowBranchName       string\\n\\tshadowBranchesToDelete map[string]struct{}\\n\\tcommittedFileSet       map[string]struct{}\\n\\thasNew                 bool\\n\\tfilesTouchedBefore     []string\\n\\n\\t// Output: set by handler methods, read by caller after TransitionAndLog.\\n\\tcondensed bool\\n}\\n\\nfunc (h *postCommitActionHandler) HandleCondense(state *session.State) error {\\n\\tshouldCondense := h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n\\n\\tlogging.Debug(h.logCtx, \\\"post-commit: HandleCondense decision\\\",\\n\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n\\t)\\n\\n\\tif shouldCondense {\\n\\t\\th.condensed = h.s.condenseAndUpdateState(h.logCtx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet)\\n\\t} else {\\n\\t\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n\\t}\\n\\treturn nil\\n}\\n\\nfunc (h *postCommitActionHandler) HandleCondenseIfFilesTouched(state *session.State) error {\\n\\tshouldCondense := len(state.FilesTouched) > 0 && h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n\\n\\tlogging.Debug(h.logCtx, \\\"post-commit: HandleCondenseIfFilesTouched decision\\\",\\n\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n\\t)\\n\\n\\tif shouldCondense {\\n\\t\\th.condensed = h.s.condenseAndUpdateState(h.logCtx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet)\\n\\t} else {\\n\\t\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n\\t}\\n\\treturn nil\\n}\\n\\n// shouldCondenseWithOverlapCheck returns true if the session should be condensed\\n// into this commit. Requires both that hasNew is true AND that the session's files\\n// overlap with the committed files with matching content.\\n//\\n// This prevents stale sessions (ACTIVE sessions where the agent was killed, or\\n// ENDED/IDLE sessions with carry-forward files) from being condensed into every\\n// unrelated commit.\\n//\\n// filesTouchedBefore is populated from:\\n//   - state.FilesTouched for IDLE/ENDED sessions (set via SaveStep/SaveTaskStep -> mergeFilesTouched)\\n//   - transcript extraction for ACTIVE sessions when FilesTouched is empty\\n//\\n// When filesTouchedBefore is empty:\\n//   - For ACTIVE sessions: fail-open (trust hasNew) because the agent may be\\n//     mid-turn before any files are saved to state.\\n//   - For IDLE/ENDED sessions: return false because there are no files to\\n//     overlap with the commit.\\nfunc (h *postCommitActionHandler) shouldCondenseWithOverlapCheck(isActive bool) bool {\\n\\tif !h.hasNew {\\n\\t\\treturn false\\n\\t}\\n\\tif len(h.filesTouchedBefore) == 0 {\\n\\t\\treturn isActive // ACTIVE: fail-open; IDLE/ENDED: no files = no overlap\\n\\t}\\n\\t// Only check files that were actually changed in this commit.\\n\\t// Without this, files that exist in the tree but weren't changed\\n\\t// would pass the \\\"modified file\\\" check in filesOverlapWithContent\\n\\t// (because the file exists in the parent tree), causing stale\\n\\t// sessions to be incorrectly condensed.\\n\\tvar committedTouchedFiles []string\\n\\tfor _, f := range h.filesTouchedBefore {\\n\\t\\tif _, ok := h.committedFileSet[f]; ok {\\n\\t\\t\\tcommittedTouchedFiles = append(committedTouchedFiles, f)\\n\\t\\t}\\n\\t}\\n\\tif len(committedTouchedFiles) == 0 {\\n\\t\\treturn false\\n\\t}\\n\\treturn filesOverlapWithContent(h.repo, h.shadowBranchName, h.commit, committedTouchedFiles)\\n}\\n\\nfunc (h *postCommitActionHandler) HandleDiscardIfNoFiles(state *session.State) error {\\n\\tif len(state.FilesTouched) == 0 {\\n\\t\\tlogging.Debug(h.logCtx, \\\"post-commit: skipping empty ended session (no files to condense)\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t)\\n\\t}\\n\\th.s.updateBaseCommitIfChanged(h.logCtx, state, h.newHead)\\n\\treturn nil\\n}\\n\\nfunc (h *postCommitActionHandler) HandleWarnStaleSession(_ *session.State) error {\\n\\t// Not produced by EventGitCommit; no-op for exhaustiveness.\\n\\treturn nil\\n}\\n\\n// During rebase/cherry-pick/revert operations, phase transitions are skipped entirely.\\n//\\n//nolint:unparam // error return required by interface but hooks must return nil\\nfunc (s *ManualCommitStrategy) PostCommit() error {\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\n\\t// Get HEAD commit to check for trailer\\n\\thead, err := repo.Head()\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\n\\tcommit, err := repo.CommitObject(head.Hash())\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\n\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n\\tif !found {\\n\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n\\t\\ts.postCommitUpdateBaseCommitOnly(logCtx, head)\\n\\t\\treturn nil\\n\\t}\\n\\n\\tworktreePath, err := GetWorktreePath()\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\n\\t// Find all active sessions for this worktree\\n\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n\\tif err != nil || len(sessions) == 0 {\\n\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n\\t\\t)\\n\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n\\t}\\n\\n\\t// Build transition context\\n\\tisRebase := isGitSequenceOperation()\\n\\ttransitionCtx := session.TransitionContext{\\n\\t\\tIsRebaseInProgress: isRebase,\\n\\t}\\n\\n\\tif isRebase {\\n\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\t)\\n\\t}\\n\\n\\t// Track shadow branch names and whether they can be deleted\\n\\tshadowBranchesToDelete := make(map[string]struct{})\\n\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n\\tuncondensedActiveOnBranch := make(map[string]bool)\\n\\n\\tnewHead := head.Hash().String()\\n\\tcommittedFileSet := filesChangedInCommit(commit)\\n\\n\\tfor _, state := range sessions {\\n\\t\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\n\\t\\t// Check for new content (needed for TransitionContext and condensation).\\n\\t\\t// Fail-open: if content check errors, assume new content exists so we\\n\\t\\t// don't silently skip data that should have been condensed.\\n\\t\\t//\\n\\t\\t// For ACTIVE sessions: the commit has a checkpoint trailer (verified above),\\n\\t\\t// meaning PrepareCommitMsg already determined this commit is session-related.\\n\\t\\t// The trailer is only added when either:\\n\\t\\t//   - No TTY (agent/subagent committing) — added unconditionally\\n\\t\\t//   - TTY (human committing) — added after content detection confirmed agent work\\n\\t\\t// In both cases, PrepareCommitMsg already validated this commit. We trust\\n\\t\\t// that decision here. Transcript-based re-validation is unreliable because\\n\\t\\t// subagent transcripts may not be available yet (subagent still running).\\n\\t\\tvar hasNew bool\\n\\t\\tif state.Phase.IsActive() {\\n\\t\\t\\thasNew = true\\n\\t\\t} else {\\n\\t\\t\\tvar contentErr error\\n\\t\\t\\thasNew, contentErr = s.sessionHasNewContent(repo, state)\\n\\t\\t\\tif contentErr != nil {\\n\\t\\t\\t\\thasNew = true\\n\\t\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: error checking session content, assuming new content\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", contentErr.Error()),\\n\\t\\t\\t\\t)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t\\ttransitionCtx.HasFilesTouched = len(state.FilesTouched) > 0\\n\\n\\t\\t// Save FilesTouched BEFORE TransitionAndLog — the handler's condensation\\n\\t\\t// clears it, but we need the original list for carry-forward computation.\\n\\t\\t// For mid-session commits (ACTIVE, no shadow branch), state.FilesTouched may be empty\\n\\t\\t// because no SaveStep/Stop has been called yet. Extract files from transcript.\\n\\t\\tfilesTouchedBefore := make([]string, len(state.FilesTouched))\\n\\t\\tcopy(filesTouchedBefore, state.FilesTouched)\\n\\t\\tif len(filesTouchedBefore) == 0 && state.Phase.IsActive() && state.TranscriptPath != \\\"\\\" {\\n\\t\\t\\tfilesTouchedBefore = s.extractFilesFromLiveTranscript(state)\\n\\t\\t}\\n\\n\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward prep\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\tslog.Bool(\\\"is_active\\\", state.Phase.IsActive()),\\n\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n\\t\\t\\tslog.Any(\\\"files\\\", filesTouchedBefore),\\n\\t\\t)\\n\\n\\t\\t// Run the state machine transition with handler for strategy-specific actions.\\n\\t\\thandler := &postCommitActionHandler{\\n\\t\\t\\ts:                      s,\\n\\t\\t\\tlogCtx:                 logCtx,\\n\\t\\t\\trepo:                   repo,\\n\\t\\t\\tcheckpointID:           checkpointID,\\n\\t\\t\\thead:                   head,\\n\\t\\t\\tcommit:                 commit,\\n\\t\\t\\tnewHead:                newHead,\\n\\t\\t\\tshadowBranchName:       shadowBranchName,\\n\\t\\t\\tshadowBranchesToDelete: shadowBranchesToDelete,\\n\\t\\t\\tcommittedFileSet:       committedFileSet,\\n\\t\\t\\thasNew:                 hasNew,\\n\\t\\t\\tfilesTouchedBefore:     filesTouchedBefore,\\n\\t\\t}\\n\\n\\t\\tif err := TransitionAndLog(state, session.EventGitCommit, transitionCtx, handler); err != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: post-commit action handler error: %v\\\\n\\\", err)\\n\\t\\t}\\n\\n\\t\\t// Record checkpoint ID for ACTIVE sessions so HandleTurnEnd can finalize\\n\\t\\t// with full transcript. IDLE/ENDED sessions already have complete transcripts.\\n\\t\\t// NOTE: This check runs AFTER TransitionAndLog updated the phase. It relies on\\n\\t\\t// ACTIVE + GitCommit → ACTIVE (phase stays ACTIVE). If that state machine\\n\\t\\t// transition ever changed, this guard would silently stop recording IDs.\\n\\t\\tif handler.condensed && state.Phase.IsActive() {\\n\\t\\t\\tstate.TurnCheckpointIDs = append(state.TurnCheckpointIDs, checkpointID.String())\\n\\t\\t}\\n\\n\\t\\t// Carry forward remaining uncommitted files so the next commit gets its\\n\\t\\t// own checkpoint ID. This applies to ALL phases — if a user splits their\\n\\t\\t// commit across two `git commit` invocations, each gets a 1:1 checkpoint.\\n\\t\\t// Uses content-aware comparison: if user did `git add -p` and committed\\n\\t\\t// partial changes, the file still has remaining agent changes to carry forward.\\n\\t\\tif handler.condensed {\\n\\t\\t\\tremainingFiles := filesWithRemainingAgentChanges(repo, shadowBranchName, commit, filesTouchedBefore, committedFileSet)\\n\\t\\t\\tstate.FilesTouched = remainingFiles\\n\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: carry-forward decision (content-aware)\\\",\\n\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\tslog.Int(\\\"files_touched_before\\\", len(filesTouchedBefore)),\\n\\t\\t\\t\\tslog.Int(\\\"committed_files\\\", len(committedFileSet)),\\n\\t\\t\\t\\tslog.Int(\\\"remaining_files\\\", len(remainingFiles)),\\n\\t\\t\\t\\tslog.Any(\\\"remaining\\\", remainingFiles),\\n\\t\\t\\t\\tslog.Any(\\\"committed_files\\\", committedFileSet),\\n\\t\\t\\t)\\n\\t\\t\\tif len(remainingFiles) > 0 {\\n\\t\\t\\t\\ts.carryForwardToNewShadowBranch(logCtx, repo, state, remainingFiles)\\n\\t\\t\\t}\\n\\t\\t}\\n\\n\\t\\t// Save the updated state\\n\\t\\tif err := s.saveSessionState(state); err != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to update session state: %v\\\\n\\\", err)\\n\\t\\t}\\n\\n\\t\\t// Only preserve shadow branch for active sessions that were NOT condensed.\\n\\t\\t// Condensed sessions already have their data on entire/checkpoints/v1.\\n\\t\\tif state.Phase.IsActive() && !handler.condensed {\\n\\t\\t\\tuncondensedActiveOnBranch[shadowBranchName] = true\\n\\t\\t}\\n\\t}\\n\\n\\t// Clean up shadow branches — only delete when ALL sessions on the branch are non-active\\n\\t// or were condensed during this PostCommit.\\n\\tfor shadowBranchName := range shadowBranchesToDelete {\\n\\t\\tif uncondensedActiveOnBranch[shadowBranchName] {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: preserving shadow branch (active session exists)\\\",\\n\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n\\t\\t\\t)\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tif err := deleteShadowBranch(repo, shadowBranchName); err != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to clean up %s: %v\\\\n\\\", shadowBranchName, err)\\n\\t\\t} else {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Cleaned up shadow branch: %s\\\\n\\\", shadowBranchName)\\n\\t\\t\\tlogging.Info(logCtx, \\\"shadow branch deleted\\\",\\n\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n\\t\\t\\t)\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// condenseAndUpdateState runs condensation for a session and updates state afterward.\\n// Returns true if condensation succeeded.\\nfunc (s *ManualCommitStrategy) condenseAndUpdateState(\\n\\tlogCtx context.Context,\\n\\trepo *git.Repository,\\n\\tcheckpointID id.CheckpointID,\\n\\tstate *SessionState,\\n\\thead *plumbing.Reference,\\n\\tshadowBranchName string,\\n\\tshadowBranchesToDelete map[string]struct{},\\n\\tcommittedFiles map[string]struct{},\\n) bool {\\n\\tresult, err := s.CondenseSession(repo, checkpointID, state, committedFiles)\\n\\tif err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: condensation failed for session %s: %v\\\\n\\\",\\n\\t\\t\\tstate.SessionID, err)\\n\\t\\tlogging.Warn(logCtx, \\\"post-commit: condensation failed\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n\\t\\t)\\n\\t\\treturn false\\n\\t}\\n\\n\\t// Link checkpoint to trail (best-effort)\\n\\tappendCheckpointToTrail(repo, result.CheckpointID, head.Hash(), result.Prompts)\\n\\n\\t// Track this shadow branch for cleanup\\n\\tshadowBranchesToDelete[shadowBranchName] = struct{}{}\\n\\n\\t// Update session state for the new base commit\\n\\tnewHead := head.Hash().String()\\n\\tstate.BaseCommit = newHead\\n\\tstate.AttributionBaseCommit = newHead\\n\\tstate.StepCount = 0\\n\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n\\n\\t// Clear attribution tracking — condensation already used these values\\n\\tstate.PromptAttributions = nil\\n\\tstate.PendingPromptAttribution = nil\\n\\tstate.FilesTouched = nil\\n\\n\\t// Save checkpoint ID so subsequent commits can reuse it (e.g., amend restores trailer)\\n\\tstate.LastCheckpointID = checkpointID\\n\\n\\tshortID := state.SessionID\\n\\tif len(shortID) > 8 {\\n\\t\\tshortID = shortID[:8]\\n\\t}\\n\\tfmt.Fprintf(os.Stderr, \\\"[entire] Condensed session %s: %s (%d checkpoints)\\\\n\\\",\\n\\t\\tshortID, result.CheckpointID, result.CheckpointsCount)\\n\\n\\tlogging.Info(logCtx, \\\"session condensed\\\",\\n\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n\\t\\tslog.Int(\\\"transcript_lines\\\", result.TotalTranscriptLines),\\n\\t)\\n\\n\\treturn true\\n}\\n\\n// updateBaseCommitIfChanged updates BaseCommit to newHead if it changed.\\n// Only updates ACTIVE sessions. IDLE/ENDED sessions should NOT have their\\n// BaseCommit updated, as this would cause them to be incorrectly associated\\n// with a new shadow branch and potentially condensed on future commits.\\nfunc (s *ManualCommitStrategy) updateBaseCommitIfChanged(logCtx context.Context, state *SessionState, newHead string) {\\n\\t// Only update ACTIVE sessions. IDLE/ENDED sessions are kept around for\\n\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n\\tif !state.Phase.IsActive() {\\n\\t\\tlogging.Debug(logCtx, \\\"post-commit: updateBaseCommitIfChanged skipped non-active session\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n\\t\\t)\\n\\t\\treturn\\n\\t}\\n\\tif state.BaseCommit != newHead {\\n\\t\\tstate.BaseCommit = newHead\\n\\t\\tlogging.Debug(logCtx, \\\"post-commit: updated BaseCommit\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n\\t\\t)\\n\\t}\\n}\\n\\n// postCommitUpdateBaseCommitOnly updates BaseCommit for all sessions on the current\\n// worktree when a commit has no Entire-Checkpoint trailer. This prevents BaseCommit\\n// from going stale, which would cause future PrepareCommitMsg calls to skip the\\n// session (BaseCommit != currentHeadHash filter).\\n//\\n// Unlike the full PostCommit flow, this does NOT fire EventGitCommit or trigger\\n// condensation — it only keeps BaseCommit in sync with HEAD.\\nfunc (s *ManualCommitStrategy) postCommitUpdateBaseCommitOnly(logCtx context.Context, head *plumbing.Reference) {\\n\\tworktreePath, err := GetWorktreePath()\\n\\tif err != nil {\\n\\t\\treturn // Silent failure — hooks must be resilient\\n\\t}\\n\\n\\tsessions, err := s.findSessionsForWorktree(worktreePath)\\n\\tif err != nil || len(sessions) == 0 {\\n\\t\\treturn\\n\\t}\\n\\n\\tnewHead := head.Hash().String()\\n\\tfor _, state := range sessions {\\n\\t\\t// Only update active sessions. Idle/ended sessions are kept around for\\n\\t\\t// LastCheckpointID reuse and should not be advanced to HEAD.\\n\\t\\tif !state.Phase.IsActive() {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tif state.BaseCommit != newHead {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit (no trailer): updating BaseCommit\\\",\\n\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\tslog.String(\\\"old_base\\\", truncateHash(state.BaseCommit)),\\n\\t\\t\\t\\tslog.String(\\\"new_head\\\", truncateHash(newHead)),\\n\\t\\t\\t)\\n\\t\\t\\tstate.BaseCommit = newHead\\n\\t\\t\\tif err := s.saveSessionState(state); err != nil {\\n\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to update session state: %v\\\\n\\\", err)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n}\\n\\n// truncateHash safely truncates a git hash to 7 chars for logging.\\nfunc truncateHash(h string) string {\\n\\tif len(h) > 7 {\\n\\t\\treturn h[:7]\\n\\t}\\n\\treturn h\\n}\\n\\n// filterSessionsWithNewContent returns sessions that have new transcript content\\n// beyond what was already condensed.\\nfunc (s *ManualCommitStrategy) filterSessionsWithNewContent(repo *git.Repository, sessions []*SessionState) []*SessionState {\\n\\tvar result []*SessionState\\n\\n\\tfor _, state := range sessions {\\n\\t\\thasNew, err := s.sessionHasNewContent(repo, state)\\n\\t\\tif err != nil {\\n\\t\\t\\t// On error, include the session (fail open for hooks)\\n\\t\\t\\tresult = append(result, state)\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tif hasNew {\\n\\t\\t\\tresult = append(result, state)\\n\\t\\t}\\n\\t}\\n\\n\\treturn result\\n}\\n\\n// sessionHasNewContent checks if a session has new transcript content\\n// beyond what was already condensed.\\nfunc (s *ManualCommitStrategy) sessionHasNewContent(repo *git.Repository, state *SessionState) (bool, error) {\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"manual-commit\\\")\\n\\n\\t// Get shadow branch\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\t// No shadow branch means no Stop has happened since the last condensation.\\n\\t\\t// However, the agent may have done work (including commits) without a Stop.\\n\\t\\t// Check the live transcript to detect this scenario.\\n\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no shadow branch, checking live transcript\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n\\t\\t)\\n\\t\\treturn s.sessionHasNewContentFromLiveTranscript(repo, state)\\n\\t}\\n\\n\\tcommit, err := repo.CommitObject(ref.Hash())\\n\\tif err != nil {\\n\\t\\treturn false, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn false, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\t// Look for transcript file\\n\\tmetadataDir := paths.EntireMetadataDir + \\\"/\\\" + state.SessionID\\n\\tvar transcriptLines int\\n\\tvar hasTranscriptFile bool\\n\\n\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n\\t\\thasTranscriptFile = true\\n\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n\\t\\t}\\n\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n\\t\\thasTranscriptFile = true\\n\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n\\t\\t}\\n\\t}\\n\\n\\t// If shadow branch exists but has no transcript (e.g., carry-forward from mid-session commit),\\n\\t// check if the session has FilesTouched. Carry-forward sets FilesTouched with remaining files.\\n\\tif !hasTranscriptFile {\\n\\t\\tif len(state.FilesTouched) > 0 {\\n\\t\\t\\t// Shadow branch has files from carry-forward - check if staged files overlap\\n\\t\\t\\t// AND have matching content (content-aware check).\\n\\t\\t\\tstagedFiles := getStagedFiles(repo)\\n\\t\\t\\tif len(stagedFiles) > 0 {\\n\\t\\t\\t\\t// PrepareCommitMsg context: check staged files overlap with content\\n\\t\\t\\t\\tresult := stagedFilesOverlapWithContent(repo, tree, stagedFiles, state.FilesTouched)\\n\\t\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript, carry-forward with staged files\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n\\t\\t\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n\\t\\t\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n\\t\\t\\t\\t)\\n\\t\\t\\t\\treturn result, nil\\n\\t\\t\\t}\\n\\t\\t\\t// PostCommit context: no staged files, but we have carry-forward files.\\n\\t\\t\\t// Return true and let the caller do the overlap check with committed files.\\n\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript, carry-forward without staged files (post-commit context)\\\",\\n\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n\\t\\t\\t)\\n\\t\\t\\treturn true, nil\\n\\t\\t}\\n\\t\\t// No transcript and no FilesTouched - fall back to live transcript check\\n\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript and no files touched, checking live transcript\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t)\\n\\t\\treturn s.sessionHasNewContentFromLiveTranscript(repo, state)\\n\\t}\\n\\n\\t// Check if there's new content to condense. Two cases:\\n\\t// 1. Transcript has grown since last condensation (new prompts/responses)\\n\\t// 2. FilesTouched has files not yet committed (carry-forward scenario)\\n\\t//\\n\\t// For PrepareCommitMsg context, we verify staged files overlap with session's files\\n\\t// using content-aware matching to detect reverted files.\\n\\t// For PostCommit context, getStagedFiles() is empty (files already committed),\\n\\t// so we return true and let the caller do the overlap check via filesOverlapWithContent.\\n\\n\\thasTranscriptGrowth := transcriptLines > state.CheckpointTranscriptStart\\n\\thasUncommittedFiles := len(state.FilesTouched) > 0\\n\\n\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: transcript check\\\",\\n\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\tslog.Int(\\\"transcript_lines\\\", transcriptLines),\\n\\t\\tslog.Int(\\\"checkpoint_transcript_start\\\", state.CheckpointTranscriptStart),\\n\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n\\t)\\n\\n\\tif !hasTranscriptGrowth && !hasUncommittedFiles {\\n\\t\\treturn false, nil // No new content and no carry-forward files\\n\\t}\\n\\n\\t// Check if staged files overlap with session's files with content-aware matching.\\n\\t// This is primarily for PrepareCommitMsg; in PostCommit, stagedFiles is empty.\\n\\tstagedFiles := getStagedFiles(repo)\\n\\tif len(stagedFiles) > 0 {\\n\\t\\tresult := stagedFilesOverlapWithContent(repo, tree, stagedFiles, state.FilesTouched)\\n\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: staged files overlap check\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n\\t\\t)\\n\\t\\treturn result, nil\\n\\t}\\n\\n\\t// No staged files - either PostCommit context or edge case.\\n\\t// Return transcript growth status. For PostCommit with hasTranscriptFile=true,\\n\\t// if there's no transcript growth, the session hasn't done new work since last checkpoint.\\n\\t// (Carry-forward creates a shadow branch WITHOUT transcript, handled in the block above.)\\n\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no staged files, returning transcript growth\\\",\\n\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n\\t)\\n\\treturn hasTranscriptGrowth, nil\\n}\\n\\n// sessionHasNewContentFromLiveTranscript checks if a session has new content\\n// by examining the live transcript file. This is used when no shadow branch exists\\n// (i.e., no Stop has happened yet) but the agent may have done work.\\n//\\n// Returns true if:\\n//  1. The transcript has grown since the last condensation, AND\\n//  2. The new transcript portion contains file modifications, AND\\n//  3. At least one modified file overlaps with the currently staged files\\n//\\n// The overlap check ensures we don't add checkpoint trailers to commits that are\\n// unrelated to the agent's recent changes.\\n//\\n// This handles the scenario where the agent commits mid-session before Stop.\\nfunc (s *ManualCommitStrategy) sessionHasNewContentFromLiveTranscript(repo *git.Repository, state *SessionState) (bool, error) {\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n\\n\\tmodifiedFiles, ok := s.extractNewModifiedFilesFromLiveTranscript(state)\\n\\tif !ok || len(modifiedFiles) == 0 {\\n\\t\\treturn false, nil\\n\\t}\\n\\n\\tlogging.Debug(logCtx, \\\"live transcript check: found file modifications\\\",\\n\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n\\t)\\n\\n\\t// Check if any modified files overlap with currently staged files\\n\\t// This ensures we only add checkpoint trailers to commits that include\\n\\t// files the agent actually modified\\n\\tstagedFiles := getStagedFiles(repo)\\n\\n\\tlogging.Debug(logCtx, \\\"live transcript check: comparing staged vs modified\\\",\\n\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n\\t)\\n\\n\\tif !hasOverlappingFiles(stagedFiles, modifiedFiles) {\\n\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no overlap between staged and modified files\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t)\\n\\t\\treturn false, nil // No overlap - staged files are unrelated to agent's work\\n\\t}\\n\\n\\treturn true, nil\\n}\\n\\n// extractFilesFromLiveTranscript extracts modified file paths from the live transcript.\\n// Returns empty slice if extraction fails (fail-open behavior for hooks).\\n// Extracts files from the transcript starting at CheckpointTranscriptStart, which gives\\n// files touched since the last condensation — used for carry-forward computation.\\nfunc (s *ManualCommitStrategy) extractFilesFromLiveTranscript(state *SessionState) []string {\\n\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n}\\n\\n// extractNewModifiedFilesFromLiveTranscript extracts modified files from the live\\n// transcript that are NEW since the last condensation. Returns the normalized file list\\n// and whether the extraction succeeded. Used by sessionHasNewContentFromLiveTranscript\\n// to detect agent work.\\nfunc (s *ManualCommitStrategy) extractNewModifiedFilesFromLiveTranscript(state *SessionState) ([]string, bool) {\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n\\n\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n\\t\\treturn nil, false\\n\\t}\\n\\n\\tag, err := agent.GetByAgentType(state.AgentType)\\n\\tif err != nil {\\n\\t\\treturn nil, false\\n\\t}\\n\\n\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n\\tif !ok {\\n\\t\\treturn nil, false\\n\\t}\\n\\n\\t// Check if transcript has grown since last condensation\\n\\tcurrentPos, err := analyzer.GetTranscriptPosition(state.TranscriptPath)\\n\\tif err != nil {\\n\\t\\treturn nil, false\\n\\t}\\n\\tif currentPos <= state.CheckpointTranscriptStart {\\n\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no new content\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\tslog.Int(\\\"current_pos\\\", currentPos),\\n\\t\\t\\tslog.Int(\\\"start_offset\\\", state.CheckpointTranscriptStart),\\n\\t\\t)\\n\\t\\treturn nil, true // No new content, but extraction succeeded\\n\\t}\\n\\n\\treturn s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart), true\\n}\\n\\n// extractModifiedFilesFromLiveTranscript extracts modified files from the live transcript\\n// (including subagent transcripts) starting from the given offset, and normalizes them\\n// to repo-relative paths. Returns the normalized file list.\\nfunc (s *ManualCommitStrategy) extractModifiedFilesFromLiveTranscript(state *SessionState, offset int) []string {\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n\\n\\tif state.TranscriptPath == \\\"\\\" || state.AgentType == \\\"\\\" {\\n\\t\\treturn nil\\n\\t}\\n\\n\\tag, err := agent.GetByAgentType(state.AgentType)\\n\\tif err != nil {\\n\\t\\treturn nil\\n\\t}\\n\\n\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n\\tif !ok {\\n\\t\\treturn nil\\n\\t}\\n\\n\\tvar modifiedFiles []string\\n\\n\\t// For Claude Code, use ExtractAllModifiedFiles which parses the main transcript\\n\\t// AND subagent transcripts in a single pass, avoiding redundant parsing.\\n\\tif state.AgentType == agent.AgentTypeClaudeCode {\\n\\t\\tsubagentsDir := filepath.Join(filepath.Dir(state.TranscriptPath), state.SessionID, \\\"subagents\\\")\\n\\t\\tallFiles, extractErr := claudecode.ExtractAllModifiedFiles(state.TranscriptPath, offset, subagentsDir)\\n\\t\\tif extractErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: extraction failed\\\",\\n\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\tslog.String(\\\"error\\\", extractErr.Error()),\\n\\t\\t\\t)\\n\\t\\t} else {\\n\\t\\t\\tmodifiedFiles = allFiles\\n\\t\\t}\\n\\t} else {\\n\\t\\tfiles, _, err := analyzer.ExtractModifiedFilesFromOffset(state.TranscriptPath, offset)\\n\\t\\tif err != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"extractModifiedFilesFromLiveTranscript: main transcript extraction failed\\\",\\n\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n\\t\\t\\t\\tslog.Any(\\\"error\\\", err),\\n\\t\\t\\t)\\n\\t\\t} else {\\n\\t\\t\\tmodifiedFiles = files\\n\\t\\t}\\n\\t}\\n\\n\\tif len(modifiedFiles) == 0 {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Normalize to repo-relative paths.\\n\\t// Transcript tool_use entries contain absolute paths (e.g., /Users/alex/project/src/main.go)\\n\\t// but getStagedFiles/committedFiles use repo-relative paths (e.g., src/main.go).\\n\\tbasePath := state.WorktreePath\\n\\tif basePath == \\\"\\\" {\\n\\t\\tif wp, wpErr := GetWorktreePath(); wpErr == nil {\\n\\t\\t\\tbasePath = wp\\n\\t\\t}\\n\\t}\\n\\tif basePath != \\\"\\\" {\\n\\t\\tnormalized := make([]string, 0, len(modifiedFiles))\\n\\t\\tfor _, f := range modifiedFiles {\\n\\t\\t\\tif rel := paths.ToRelativePath(f, basePath); rel != \\\"\\\" {\\n\\t\\t\\t\\tnormalized = append(normalized, rel)\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tnormalized = append(normalized, f)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t\\tmodifiedFiles = normalized\\n\\t}\\n\\n\\treturn modifiedFiles\\n}\\n\\n// addTrailerForAgentCommit handles the fast path when an agent is committing\\n// (ACTIVE session + no TTY). Generates a checkpoint ID and adds the trailer\\n// directly, bypassing content detection and interactive prompts.\\nfunc (s *ManualCommitStrategy) addTrailerForAgentCommit(logCtx context.Context, commitMsgFile string, state *SessionState, source string) error {\\n\\tcpID, err := id.Generate()\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\n\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n\\tif err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\n\\tmessage := string(content)\\n\\n\\t// Don't add if trailer already exists\\n\\tif _, found := trailers.ParseCheckpoint(message); found {\\n\\t\\treturn nil\\n\\t}\\n\\n\\tmessage = addCheckpointTrailer(message, cpID)\\n\\n\\tlogging.Info(logCtx, \\\"prepare-commit-msg: agent commit trailer added\\\",\\n\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n\\t\\tslog.String(\\\"source\\\", source),\\n\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t)\\n\\n\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n\\t}\\n\\treturn nil\\n}\\n\\n// addCheckpointTrailer adds the Entire-Checkpoint trailer to a commit message.\\n// Handles proper trailer formatting (blank line before trailers if needed).\\nfunc addCheckpointTrailer(message string, checkpointID id.CheckpointID) string {\\n\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n\\n\\t// If message already ends with trailers (lines starting with key:), just append\\n\\t// Otherwise, add a blank line first\\n\\tlines := strings.Split(strings.TrimRight(message, \\\"\\\\n\\\"), \\\"\\\\n\\\")\\n\\n\\t// Check if the message already ends with a trailer paragraph.\\n\\t// Git trailers must be in a separate paragraph (preceded by a blank line).\\n\\t// A single-paragraph message (e.g., just a subject line) cannot have trailers,\\n\\t// even if the subject contains \\\": \\\" (like conventional commits: \\\"docs: Add foo\\\").\\n\\t//\\n\\t// Scan from the bottom: find the last paragraph of non-comment content,\\n\\t// then check if it looks like trailers AND has a blank line above it.\\n\\thasTrailers := false\\n\\ti := len(lines) - 1\\n\\n\\t// Skip trailing comment lines\\n\\tfor i >= 0 && strings.HasPrefix(strings.TrimSpace(lines[i]), \\\"#\\\") {\\n\\t\\ti--\\n\\t}\\n\\n\\t// Check if the last non-comment line looks like a trailer\\n\\tif i >= 0 {\\n\\t\\tline := strings.TrimSpace(lines[i])\\n\\t\\tif line != \\\"\\\" && strings.Contains(line, \\\": \\\") {\\n\\t\\t\\t// Found a trailer-like line. Now scan upward past the trailer block\\n\\t\\t\\t// to verify there's a blank line (paragraph separator) above it.\\n\\t\\t\\tfor i > 0 {\\n\\t\\t\\t\\ti--\\n\\t\\t\\t\\tabove := strings.TrimSpace(lines[i])\\n\\t\\t\\t\\tif strings.HasPrefix(above, \\\"#\\\") {\\n\\t\\t\\t\\t\\tcontinue\\n\\t\\t\\t\\t}\\n\\t\\t\\t\\tif above == \\\"\\\" {\\n\\t\\t\\t\\t\\t// Blank line found above trailer block — real trailers\\n\\t\\t\\t\\t\\thasTrailers = true\\n\\t\\t\\t\\t\\tbreak\\n\\t\\t\\t\\t}\\n\\t\\t\\t\\tif !strings.Contains(above, \\\": \\\") {\\n\\t\\t\\t\\t\\t// Non-trailer, non-blank line — this is message body, not trailers\\n\\t\\t\\t\\t\\tbreak\\n\\t\\t\\t\\t}\\n\\t\\t\\t\\t// Another trailer-like line, keep scanning upward\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\tif hasTrailers {\\n\\t\\t// Append trailer directly\\n\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n\\t}\\n\\n\\t// Add blank line before trailer\\n\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n}\\n\\n// addCheckpointTrailerWithComment adds the Entire-Checkpoint trailer with an explanatory comment.\\n// The trailer is placed above the git comment block but below the user's message area,\\n// with a comment explaining that the user can remove it if they don't want to link the commit\\n// to the agent session. If prompt is non-empty, it's shown as context.\\nfunc addCheckpointTrailerWithComment(message string, checkpointID id.CheckpointID, agentName, prompt string) string {\\n\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n\\tcommentLines := []string{\\n\\t\\t\\\"# Remove the Entire-Checkpoint trailer above if you don't want to link this commit to \\\" + agentName + \\\" session context.\\\",\\n\\t}\\n\\tif prompt != \\\"\\\" {\\n\\t\\tcommentLines = append(commentLines, \\\"# Last Prompt: \\\"+prompt)\\n\\t}\\n\\tcommentLines = append(commentLines, \\\"# The trailer will be added to your next commit based on this branch.\\\")\\n\\tcomment := strings.Join(commentLines, \\\"\\\\n\\\")\\n\\n\\tlines := strings.Split(message, \\\"\\\\n\\\")\\n\\n\\t// Find where the git comment block starts (first # line)\\n\\tcommentStart := -1\\n\\tfor i, line := range lines {\\n\\t\\tif strings.HasPrefix(line, \\\"#\\\") {\\n\\t\\t\\tcommentStart = i\\n\\t\\t\\tbreak\\n\\t\\t}\\n\\t}\\n\\n\\tif commentStart == -1 {\\n\\t\\t// No git comments, append trailer at the end\\n\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\"\\n\\t}\\n\\n\\t// Split into user content and git comments\\n\\tuserContent := strings.Join(lines[:commentStart], \\\"\\\\n\\\")\\n\\tgitComments := strings.Join(lines[commentStart:], \\\"\\\\n\\\")\\n\\n\\t// Build result: user content, blank line, trailer, comment, blank line, git comments\\n\\tuserContent = strings.TrimRight(userContent, \\\"\\\\n\\\")\\n\\tif userContent == \\\"\\\" {\\n\\t\\t// No user content yet - leave space for them to type, then trailer\\n\\t\\t// Two newlines: first for user's message line, second for blank separator\\n\\t\\treturn \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n\\t}\\n\\treturn userContent + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n}\\n\\n// InitializeSession creates session state for a new session or updates an existing one.\\n// This implements the optional SessionInitializer interface.\\n// Called during UserPromptSubmit to allow git hooks to detect active sessions.\\n//\\n// If the session already exists and HEAD has moved (e.g., user committed), updates\\n// BaseCommit to the new HEAD so future checkpoints go to the correct shadow branch.\\n//\\n// If there's an existing shadow branch with commits from a different session ID,\\n// returns a SessionIDConflictError to prevent orphaning existing session work.\\n//\\n// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\nfunc (s *ManualCommitStrategy) InitializeSession(sessionID string, agentType agent.AgentType, transcriptPath string, userPrompt string) error {\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n\\t}\\n\\n\\t// Check if session already exists\\n\\tstate, err := s.loadSessionState(sessionID)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to check session state: %w\\\", err)\\n\\t}\\n\\n\\tif state != nil && state.BaseCommit != \\\"\\\" {\\n\\t\\t// Session is fully initialized — apply phase transition for TurnStart.\\n\\t\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n\\t\\t}\\n\\n\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n\\t\\tturnID, err := id.Generate()\\n\\t\\tif err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n\\t\\t}\\n\\t\\tstate.TurnID = turnID.String()\\n\\n\\t\\t// Backfill AgentType if empty or set to the generic default \\\"Agent\\\"\\n\\t\\tif !isSpecificAgentType(state.AgentType) && agentType != \\\"\\\" {\\n\\t\\t\\tstate.AgentType = agentType\\n\\t\\t}\\n\\n\\t\\t// Backfill FirstPrompt if empty (for sessions created before the first_prompt field was added)\\n\\t\\tif state.FirstPrompt == \\\"\\\" && userPrompt != \\\"\\\" {\\n\\t\\t\\tstate.FirstPrompt = truncatePromptForStorage(userPrompt)\\n\\t\\t}\\n\\n\\t\\t// Update transcript path if provided (may change on session resume)\\n\\t\\tif transcriptPath != \\\"\\\" && state.TranscriptPath != transcriptPath {\\n\\t\\t\\tstate.TranscriptPath = transcriptPath\\n\\t\\t}\\n\\n\\t\\t// Clear checkpoint IDs on every new prompt.\\n\\t\\t// LastCheckpointID is set during PostCommit, cleared at new prompt.\\n\\t\\t// TurnCheckpointIDs tracks mid-turn checkpoints for stop-time finalization.\\n\\t\\tstate.LastCheckpointID = \\\"\\\"\\n\\t\\tstate.TurnCheckpointIDs = nil\\n\\n\\t\\t// Calculate attribution at prompt start (BEFORE agent makes any changes)\\n\\t\\t// This captures user edits since the last checkpoint (or base commit for first prompt).\\n\\t\\t// IMPORTANT: Always calculate attribution, even for the first checkpoint, to capture\\n\\t\\t// user edits made before the first prompt. The inner CalculatePromptAttribution handles\\n\\t\\t// nil lastCheckpointTree by falling back to baseTree.\\n\\t\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n\\t\\tstate.PendingPromptAttribution = &promptAttr\\n\\n\\t\\t// Check if HEAD has moved (user pulled/rebased or committed)\\n\\t\\t// migrateShadowBranchIfNeeded handles renaming the shadow branch and updating state.BaseCommit\\n\\t\\tif _, err := s.migrateShadowBranchIfNeeded(repo, state); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to check/migrate shadow branch: %w\\\", err)\\n\\t\\t}\\n\\n\\t\\tif err := s.saveSessionState(state); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to update session state: %w\\\", err)\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\t// If state exists but BaseCommit is empty, it's a partial state from concurrent warning\\n\\t// Continue below to properly initialize it\\n\\n\\t// Initialize new session\\n\\tstate, err = s.initializeSession(repo, sessionID, agentType, transcriptPath, userPrompt)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n\\t}\\n\\n\\t// Apply phase transition: new session starts as ACTIVE.\\n\\tif transErr := TransitionAndLog(state, session.EventTurnStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: turn start transition failed: %v\\\\n\\\", transErr)\\n\\t}\\n\\n\\t// Calculate attribution for pre-prompt edits\\n\\t// This captures any user edits made before the first prompt\\n\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n\\tstate.PendingPromptAttribution = &promptAttr\\n\\tif err = s.saveSessionState(state); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save attribution: %w\\\", err)\\n\\t}\\n\\n\\tfmt.Fprintf(os.Stderr, \\\"Initialized shadow session: %s\\\\n\\\", sessionID)\\n\\treturn nil\\n}\\n\\n// calculatePromptAttributionAtStart calculates attribution at prompt start (before agent runs).\\n// This captures user changes since the last checkpoint - no filtering needed since\\n// the agent hasn't made any changes yet.\\n//\\n// IMPORTANT: This reads from the worktree (not staging area) to match what WriteTemporary\\n// captures in checkpoints. If we read staged content but checkpoints capture worktree content,\\n// unstaged changes would be in the checkpoint but not counted in PromptAttribution, causing\\n// them to be incorrectly attributed to the agent later.\\nfunc (s *ManualCommitStrategy) calculatePromptAttributionAtStart(\\n\\trepo *git.Repository,\\n\\tstate *SessionState,\\n) PromptAttribution {\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\tnextCheckpointNum := state.StepCount + 1\\n\\tresult := PromptAttribution{CheckpointNumber: nextCheckpointNum}\\n\\n\\t// Get last checkpoint tree from shadow branch (if it exists)\\n\\t// For the first checkpoint, no shadow branch exists yet - this is fine,\\n\\t// CalculatePromptAttribution will use baseTree as the reference instead.\\n\\tvar lastCheckpointTree *object.Tree\\n\\tshadowBranchName := checkpoint.ShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: no shadow branch yet (first checkpoint)\\\",\\n\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName))\\n\\t\\t// Continue with lastCheckpointTree = nil\\n\\t} else {\\n\\t\\tshadowCommit, err := repo.CommitObject(ref.Hash())\\n\\t\\tif err != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: failed to get shadow commit\\\",\\n\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", ref.Hash().String()),\\n\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t// Continue with lastCheckpointTree = nil\\n\\t\\t} else {\\n\\t\\t\\tlastCheckpointTree, err = shadowCommit.Tree()\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: failed to get shadow tree\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t\\t// Continue with lastCheckpointTree = nil\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Get base tree for agent lines calculation\\n\\tvar baseTree *object.Tree\\n\\tif baseCommit, err := repo.CommitObject(plumbing.NewHash(state.BaseCommit)); err == nil {\\n\\t\\tif tree, treeErr := baseCommit.Tree(); treeErr == nil {\\n\\t\\t\\tbaseTree = tree\\n\\t\\t} else {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: base tree unavailable\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n\\t\\t}\\n\\t} else {\\n\\t\\tlogging.Debug(logCtx, \\\"prompt attribution: base commit unavailable\\\",\\n\\t\\t\\tslog.String(\\\"base_commit\\\", state.BaseCommit),\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\tworktree, err := repo.Worktree()\\n\\tif err != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"prompt attribution skipped: failed to get worktree\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\treturn result\\n\\t}\\n\\n\\t// Get worktree status to find ALL changed files\\n\\tstatus, err := worktree.Status()\\n\\tif err != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"prompt attribution skipped: failed to get worktree status\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\treturn result\\n\\t}\\n\\n\\tworktreeRoot := worktree.Filesystem.Root()\\n\\n\\t// Build map of changed files with their worktree content\\n\\t// IMPORTANT: We read from worktree (not staging area) to match what WriteTemporary\\n\\t// captures in checkpoints. This ensures attribution is consistent.\\n\\tchangedFiles := make(map[string]string)\\n\\tfor filePath, fileStatus := range status {\\n\\t\\t// Skip unmodified files\\n\\t\\tif fileStatus.Worktree == git.Unmodified && fileStatus.Staging == git.Unmodified {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\t// Skip .entire metadata directory (session data, not user code)\\n\\t\\tif strings.HasPrefix(filePath, paths.EntireMetadataDir+\\\"/\\\") || strings.HasPrefix(filePath, \\\".entire/\\\") {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Always read