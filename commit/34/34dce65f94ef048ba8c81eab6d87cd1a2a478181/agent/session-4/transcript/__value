\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/buildinfo\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n    22→\\n    23→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    24→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    25→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    26→)\\n    27→\\n    28→// isNotFoundError checks if an error represents a \\\"not found\\\" condition in go-git.\\n    29→// This includes entry not found, file not found, directory not found, and object not found.\\n    30→func isNotFoundError(err error) bool {\\n    31→\\treturn errors.Is(err, object.ErrEntryNotFound) ||\\n    32→\\t\\terrors.Is(err, object.ErrFileNotFound) ||\\n    33→\\t\\terrors.Is(err, object.ErrDirectoryNotFound) ||\\n    34→\\t\\terrors.Is(err, plumbing.ErrObjectNotFound) ||\\n    35→\\t\\terrors.Is(err, plumbing.ErrReferenceNotFound)\\n    36→}\\n    37→\\n    38→// commitOrHead attempts to create a commit. If the commit would be empty (files already\\n    39→// committed), it returns HEAD hash instead. This handles the case where files were\\n    40→// modified during a session but already committed by the user before the hook runs.\\n    41→func commitOrHead(repo *git.Repository, worktree *git.Worktree, msg string, author *object.Signature) (plumbing.Hash, error) {\\n    42→\\tcommitHash, err := worktree.Commit(msg, &git.CommitOptions{Author: author})\\n    43→\\tif errors.Is(err, git.ErrEmptyCommit) {\\n    44→\\t\\tfmt.Fprintf(os.Stderr, \\\"No changes to commit (files already committed)\\\\n\\\")\\n    45→\\t\\thead, err := repo.Head()\\n    46→\\t\\tif err != nil {\\n    47→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n    48→\\t\\t}\\n    49→\\t\\treturn head.Hash(), nil\\n    50→\\t}\\n    51→\\tif err != nil {\\n    52→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to commit: %w\\\", err)\\n    53→\\t}\\n    54→\\treturn commitHash, nil\\n    55→}\\n    56→\\n    57→// AutoCommitStrategy implements the auto-commit strategy:\\n    58→// - Code changes are committed to the active branch (like commit strategy)\\n    59→// - Session logs are committed to a shadow branch (like manual-commit strategy)\\n    60→// - Code commits can reference the shadow branch via trailers\\n    61→type AutoCommitStrategy struct {\\n    62→\\t// checkpointStore manages checkpoint data on entire/checkpoints/v1 branch\\n    63→\\tcheckpointStore *checkpoint.GitStore\\n    64→\\t// checkpointStoreOnce ensures thread-safe lazy initialization\\n    65→\\tcheckpointStoreOnce sync.Once\\n    66→\\t// checkpointStoreErr captures any error during initialization\\n    67→\\tcheckpointStoreErr error\\n    68→}\\n    69→\\n    70→// getCheckpointStore returns the checkpoint store, initializing it lazily if needed.\\n    71→// Thread-safe via sync.Once.\\n    72→func (s *AutoCommitStrategy) getCheckpointStore() (*checkpoint.GitStore, error) {\\n    73→\\ts.checkpointStoreOnce.Do(func() {\\n    74→\\t\\trepo, err := OpenRepository()\\n    75→\\t\\tif err != nil {\\n    76→\\t\\t\\ts.checkpointStoreErr = fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n    77→\\t\\t\\treturn\\n    78→\\t\\t}\\n    79→\\t\\ts.checkpointStore = checkpoint.NewGitStore(repo)\\n    80→\\t})\\n    81→\\treturn s.checkpointStore, s.checkpointStoreErr\\n    82→}\\n    83→\\n    84→// NewAutoCommitStrategy creates a new AutoCommitStrategy instance.\\n    85→//\\n    86→\\n    87→func NewAutoCommitStrategy() Strategy {\\n    88→\\treturn &AutoCommitStrategy{}\\n    89→}\\n    90→\\n    91→func (s *AutoCommitStrategy) Name() string {\\n    92→\\treturn StrategyNameAutoCommit\\n    93→}\\n    94→\\n    95→func (s *AutoCommitStrategy) Description() string {\\n    96→\\treturn \\\"Auto-commits code to active branch with metadata on entire/checkpoints/v1\\\"\\n    97→}\\n    98→\\n    99→func (s *AutoCommitStrategy) ValidateRepository() error {\\n   100→\\trepo, err := OpenRepository()\\n   101→\\tif err != nil {\\n   102→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   103→\\t}\\n   104→\\n   105→\\t_, err = repo.Worktree()\\n   106→\\tif err != nil {\\n   107→\\t\\treturn fmt.Errorf(\\\"failed to access worktree: %w\\\", err)\\n   108→\\t}\\n   109→\\n   110→\\treturn nil\\n   111→}\\n   112→\\n   113→// PrePush is called by the git pre-push hook before pushing to a remote.\\n   114→// It pushes the entire/checkpoints/v1 branch alongside the user's push.\\n   115→// Configuration options (stored in .entire/settings.json under strategy_options.push_sessions):\\n   116→//   - \\\"auto\\\": always push automatically\\n   117→//   - \\\"prompt\\\" (default): ask user with option to enable auto\\n   118→//   - \\\"false\\\"/\\\"off\\\"/\\\"no\\\": never push\\n   119→func (s *AutoCommitStrategy) PrePush(remote string) error {\\n   120→\\tif err := pushSessionsBranchCommon(remote, paths.MetadataBranchName); err != nil {\\n   121→\\t\\treturn err\\n   122→\\t}\\n   123→\\treturn PushTrailsBranch(remote)\\n   124→}\\n   125→\\n   126→func (s *AutoCommitStrategy) SaveStep(ctx StepContext) error {\\n   127→\\trepo, err := OpenRepository()\\n   128→\\tif err != nil {\\n   129→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   130→\\t}\\n   131→\\n   132→\\t// Generate checkpoint ID for this commit\\n   133→\\tcpID, err := id.Generate()\\n   134→\\tif err != nil {\\n   135→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   136→\\t}\\n   137→\\t// Step 1: Commit code changes to active branch with checkpoint ID trailer\\n   138→\\t// We do code first to avoid orphaned metadata if this step fails.\\n   139→\\t// If metadata commit fails after this, the code commit exists but GetRewindPoints\\n   140→\\t// already handles missing metadata gracefully (skips commits without metadata).\\n   141→\\tcodeResult, err := s.commitCodeToActive(repo, ctx, cpID)\\n   142→\\tif err != nil {\\n   143→\\t\\treturn fmt.Errorf(\\\"failed to commit code to active branch: %w\\\", err)\\n   144→\\t}\\n   145→\\n   146→\\t// If no code commit was created (no changes), skip metadata creation\\n   147→\\t// This prevents orphaned metadata commits that don't correspond to any code commit\\n   148→\\tif !codeResult.Created {\\n   149→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   150→\\t\\tlogging.Info(logCtx, \\\"checkpoint skipped (no changes)\\\",\\n   151→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n   152→\\t\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"session\\\"),\\n   153→\\t\\t)\\n   154→\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipped checkpoint (no changes since last commit)\\\\n\\\")\\n   155→\\t\\treturn nil\\n   156→\\t}\\n   157→\\n   158→\\t// Step 2: Commit metadata to entire/checkpoints/v1 branch using sharded path\\n   159→\\t// Path is <checkpointID[:2]>/<checkpointID[2:]>/ for direct lookup\\n   160→\\t_, err = s.commitMetadataToMetadataBranch(repo, ctx, cpID)\\n   161→\\tif err != nil {\\n   162→\\t\\treturn fmt.Errorf(\\\"failed to commit metadata to entire/checkpoints/v1 branch: %w\\\", err)\\n   163→\\t}\\n   164→\\n   165→\\t// Link checkpoint to trail (best-effort)\\n   166→\\tappendCheckpointToTrail(repo, cpID, codeResult.CommitHash, nil)\\n   167→\\n   168→\\t// Log checkpoint creation\\n   169→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   170→\\tlogging.Info(logCtx, \\\"checkpoint saved\\\",\\n   171→\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n   172→\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"session\\\"),\\n   173→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   174→\\t\\tslog.Int(\\\"modified_files\\\", len(ctx.ModifiedFiles)),\\n   175→\\t\\tslog.Int(\\\"new_files\\\", len(ctx.NewFiles)),\\n   176→\\t\\tslog.Int(\\\"deleted_files\\\", len(ctx.DeletedFiles)),\\n   177→\\t)\\n   178→\\n   179→\\treturn nil\\n   180→}\\n   181→\\n   182→// commitCodeResult contains the result of committing code to the active branch.\\n   183→type commitCodeResult struct {\\n   184→\\tCommitHash plumbing.Hash\\n   185→\\tCreated    bool // True if a new commit was created, false if skipped (no changes)\\n   186→}\\n   187→\\n   188→// commitCodeToActive commits code changes to the active branch.\\n   189→// Adds an Entire-Checkpoint trailer for metadata lookup that survives amend/rebase.\\n   190→// Returns the result containing commit hash and whether a commit was created.\\n   191→func (s *AutoCommitStrategy) commitCodeToActive(repo *git.Repository, ctx StepContext, checkpointID id.CheckpointID) (commitCodeResult, error) {\\n   192→\\t// Check if there are any code changes to commit\\n   193→\\tif len(ctx.ModifiedFiles) == 0 && len(ctx.NewFiles) == 0 && len(ctx.DeletedFiles) == 0 {\\n   194→\\t\\tfmt.Fprintf(os.Stderr, \\\"No code changes to commit to active branch\\\\n\\\")\\n   195→\\t\\t// Return current HEAD hash but mark as not created\\n   196→\\t\\thead, err := repo.Head()\\n   197→\\t\\tif err != nil {\\n   198→\\t\\t\\treturn commitCodeResult{}, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   199→\\t\\t}\\n   200→\\t\\treturn commitCodeResult{CommitHash: head.Hash(), Created: false}, nil\\n   201→\\t}\\n   202→\\n   203→\\tworktree, err := repo.Worktree()\\n   204→\\tif err != nil {\\n   205→\\t\\treturn commitCodeResult{}, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   206→\\t}\\n   207→\\n   208→\\t// Get HEAD hash before commit to detect if commitOrHead actually creates a new commit\\n   209→\\t// (commitOrHead returns HEAD hash without error when git.ErrEmptyCommit occurs)\\n   210→\\theadBefore, err := repo.Head()\\n   211→\\tif err != nil {\\n   212→\\t\\treturn commitCodeResult{}, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   213→\\t}\\n   214→\\n   215→\\t// Stage code changes\\n   216→\\tStageFiles(worktree, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles, StageForSession)\\n   217→\\n   218→\\t// Add checkpoint ID trailer to commit message\\n   219→\\tcommitMsg := ctx.CommitMessage + \\\"\\\\n\\\\n\\\" + trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n   220→\\n   221→\\tauthor := &object.Signature{\\n   222→\\t\\tName:  ctx.AuthorName,\\n   223→\\t\\tEmail: ctx.AuthorEmail,\\n   224→\\t\\tWhen:  time.Now(),\\n   225→\\t}\\n   226→\\tcommitHash, err := commitOrHead(repo, worktree, commitMsg, author)\\n   227→\\tif err != nil {\\n   228→\\t\\treturn commitCodeResult{}, err\\n   229→\\t}\\n   230→\\n   231→\\t// Check if a new commit was actually created by comparing with HEAD before\\n   232→\\tcreated := commitHash != headBefore.Hash()\\n   233→\\tif created {\\n   234→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed code changes to active branch (%s)\\\\n\\\", commitHash.String()[:7])\\n   235→\\t}\\n   236→\\treturn commitCodeResult{CommitHash: commitHash, Created: created}, nil\\n   237→}\\n   238→\\n   239→// commitMetadataToMetadataBranch commits session metadata to the entire/checkpoints/v1 branch.\\n   240→// Metadata is stored at sharded path: <checkpointID[:2]>/<checkpointID[2:]>/\\n   241→// This allows direct lookup from the checkpoint ID trailer on the code commit.\\n   242→// Uses checkpoint.WriteCommitted for git operations.\\n   243→func (s *AutoCommitStrategy) commitMetadataToMetadataBranch(repo *git.Repository, ctx StepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n   244→\\tstore, err := s.getCheckpointStore()\\n   245→\\tif err != nil {\\n   246→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   247→\\t}\\n   248→\\n   249→\\t// Extract session ID from metadata dir\\n   250→\\tsessionID := filepath.Base(ctx.MetadataDir)\\n   251→\\n   252→\\t// Get current branch name\\n   253→\\tbranchName := GetCurrentBranchName(repo)\\n   254→\\n   255→\\t// Combine all file changes into FilesTouched (same as manual-commit)\\n   256→\\tfilesTouched := mergeFilesTouched(nil, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles)\\n   257→\\n   258→\\t// Load TurnID from session state (correlates checkpoints from the same turn)\\n   259→\\tvar turnID string\\n   260→\\tif state, loadErr := LoadSessionState(sessionID); loadErr == nil && state != nil {\\n   261→\\t\\tturnID = state.TurnID\\n   262→\\t}\\n   263→\\n   264→\\t// Write committed checkpoint using the checkpoint store\\n   265→\\t// Pass TranscriptPath so writeTranscript generates content_hash.txt\\n   266→\\ttranscriptPath := filepath.Join(ctx.MetadataDirAbs, paths.TranscriptFileName)\\n   267→\\terr = store.WriteCommitted(context.Background(), checkpoint.WriteCommittedOptions{\\n   268→\\t\\tCheckpointID:                checkpointID,\\n   269→\\t\\tSessionID:                   sessionID,\\n   270→\\t\\tStrategy:                    StrategyNameAutoCommit, // Use new strategy name\\n   271→\\t\\tBranch:                      branchName,\\n   272→\\t\\tMetadataDir:                 ctx.MetadataDirAbs, // Copy all files from metadata dir\\n   273→\\t\\tTranscriptPath:              transcriptPath,     // For content hash generation\\n   274→\\t\\tAuthorName:                  ctx.AuthorName,\\n   275→\\t\\tAuthorEmail:                 ctx.AuthorEmail,\\n   276→\\t\\tAgent:                       ctx.AgentType,\\n   277→\\t\\tTurnID:                      turnID,\\n   278→\\t\\tTranscriptIdentifierAtStart: ctx.StepTranscriptIdentifier,\\n   279→\\t\\tCheckpointTranscriptStart:   ctx.StepTranscriptStart,\\n   280→\\t\\tTokenUsage:                  ctx.TokenUsage,\\n   281→\\t\\tCheckpointsCount:            1,            // Each auto-commit checkpoint = 1\\n   282→\\t\\tFilesTouched:                filesTouched, // Track modified files (same as manual-commit)\\n   283→\\t})\\n   284→\\tif err != nil {\\n   285→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write committed checkpoint: %w\\\", err)\\n   286→\\t}\\n   287→\\n   288→\\tfmt.Fprintf(os.Stderr, \\\"Committed session metadata to %s (%s)\\\\n\\\", paths.MetadataBranchName, checkpointID)\\n   289→\\treturn plumbing.ZeroHash, nil // Commit hash not needed by callers\\n   290→}\\n   291→\\n   292→func (s *AutoCommitStrategy) GetRewindPoints(limit int) ([]RewindPoint, error) {\\n   293→\\t// For auto-commit strategy, rewind points are found by looking for Entire-Checkpoint trailers\\n   294→\\t// in the current branch's commit history. The checkpoint ID provides direct lookup\\n   295→\\t// to metadata on entire/checkpoints/v1 branch.\\n   296→\\trepo, err := OpenRepository()\\n   297→\\tif err != nil {\\n   298→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   299→\\t}\\n   300→\\n   301→\\thead, err := repo.Head()\\n   302→\\tif err != nil {\\n   303→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   304→\\t}\\n   305→\\n   306→\\t// Get metadata branch tree for lookups\\n   307→\\tmetadataTree, err := GetMetadataBranchTree(repo)\\n   308→\\tif err != nil {\\n   309→\\t\\t// No metadata branch yet is fine\\n   310→\\t\\treturn []RewindPoint{}, nil //nolint:nilerr // Expected when no metadata exists\\n   311→\\t}\\n   312→\\n   313→\\t// Get the main branch commit hash to determine branch-only commits\\n   314→\\tmainBranchHash := GetMainBranchHash(repo)\\n   315→\\n   316→\\t// Walk current branch history looking for commits with checkpoint trailers\\n   317→\\titer, err := repo.Log(&git.LogOptions{\\n   318→\\t\\tFrom:  head.Hash(),\\n   319→\\t\\tOrder: git.LogOrderCommitterTime,\\n   320→\\t})\\n   321→\\tif err != nil {\\n   322→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   323→\\t}\\n   324→\\n   325→\\tvar points []RewindPoint\\n   326→\\tcount := 0\\n   327→\\n   328→\\terr = iter.ForEach(func(c *object.Commit) error {\\n   329→\\t\\tif count >= logsOnlyScanLimit || len(points) >= limit {\\n   330→\\t\\t\\treturn errStop\\n   331→\\t\\t}\\n   332→\\t\\tcount++\\n   333→\\n   334→\\t\\t// Check for Entire-Checkpoint trailer\\n   335→\\t\\tcpID, found := trailers.ParseCheckpoint(c.Message)\\n   336→\\t\\tif !found {\\n   337→\\t\\t\\treturn nil\\n   338→\\t\\t}\\n   339→\\n   340→\\t\\t// Look up metadata from sharded path\\n   341→\\t\\tcheckpointPath := cpID.Path()\\n   342→\\t\\tmetadata, err := ReadCheckpointMetadata(metadataTree, checkpointPath)\\n   343→\\t\\tif err != nil {\\n   344→\\t\\t\\t// Checkpoint exists in commit but no metadata found - skip this commit\\n   345→\\t\\t\\treturn nil //nolint:nilerr // Intentional: skip commits without metadata\\n   346→\\t\\t}\\n   347→\\n   348→\\t\\tmessage := strings.Split(c.Message, \\\"\\\\n\\\")[0]\\n   349→\\n   350→\\t\\t// Determine if this is a full rewind or logs-only\\n   351→\\t\\t// Full rewind is allowed if commit is only on this branch (not reachable from main)\\n   352→\\t\\tisLogsOnly := false\\n   353→\\t\\tif mainBranchHash != plumbing.ZeroHash {\\n   354→\\t\\t\\tif IsAncestorOf(repo, c.Hash, mainBranchHash) {\\n   355→\\t\\t\\t\\tisLogsOnly = true\\n   356→\\t\\t\\t}\\n   357→\\t\\t}\\n   358→\\n   359→\\t\\t// Build metadata path - for task checkpoints, include the task path\\n   360→\\t\\tmetadataDir := checkpointPath\\n   361→\\t\\tif metadata.IsTask && metadata.ToolUseID != \\\"\\\" {\\n   362→\\t\\t\\tmetadataDir = checkpointPath + \\\"/tasks/\\\" + metadata.ToolUseID\\n   363→\\t\\t}\\n   364→\\n   365→\\t\\t// Read session prompt from metadata tree\\n   366→\\t\\tsessionPrompt := ReadSessionPromptFromTree(metadataTree, checkpointPath)\\n   367→\\n   368→\\t\\tpoints = append(points, RewindPoint{\\n   369→\\t\\t\\tID:               c.Hash.String(),\\n   370→\\t\\t\\tMessage:          message,\\n   371→\\t\\t\\tMetadataDir:      metadataDir,\\n   372→\\t\\t\\tDate:             c.Author.When,\\n   373→\\t\\t\\tIsLogsOnly:       isLogsOnly,\\n   374→\\t\\t\\tCheckpointID:     cpID,\\n   375→\\t\\t\\tIsTaskCheckpoint: metadata.IsTask,\\n   376→\\t\\t\\tToolUseID:        metadata.ToolUseID,\\n   377→\\t\\t\\tAgent:            metadata.Agent,\\n   378→\\t\\t\\tSessionID:        metadata.SessionID,\\n   379→\\t\\t\\tSessionPrompt:    sessionPrompt,\\n   380→\\t\\t})\\n   381→\\n   382→\\t\\treturn nil\\n   383→\\t})\\n   384→\\n   385→\\tif err != nil && !errors.Is(err, errStop) {\\n   386→\\t\\treturn nil, fmt.Errorf(\\\"failed to iterate commits: %w\\\", err)\\n   387→\\t}\\n   388→\\n   389→\\treturn points, nil\\n   390→}\\n   391→\\n   392→// findTaskMetadataPathForCommit looks up the task metadata path for a task checkpoint commit\\n   393→// by searching the entire/checkpoints/v1 branch commit history for the checkpoint directory.\\n   394→// Returns (\\\"\\\", nil) if metadata is not found - this is expected for commits without metadata.\\n   395→func (s *AutoCommitStrategy) findTaskMetadataPathForCommit(repo *git.Repository, commitSHA, toolUseID string) (string, error) {\\n   396→\\t// Get the entire/checkpoints/v1 branch\\n   397→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   398→\\tref, err := repo.Reference(refName, true)\\n   399→\\tif err != nil {\\n   400→\\t\\tif isNotFoundError(err) {\\n   401→\\t\\t\\treturn \\\"\\\", nil // No metadata branch yet\\n   402→\\t\\t}\\n   403→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get metadata branch: %w\\\", err)\\n   404→\\t}\\n   405→\\n   406→\\t// Search commit history for a commit referencing this code commit SHA and tool use ID\\n   407→\\tshortSHA := commitSHA\\n   408→\\tif len(shortSHA) > 7 {\\n   409→\\t\\tshortSHA = shortSHA[:7]\\n   410→\\t}\\n   411→\\n   412→\\titer, err := repo.Log(&git.LogOptions{From: ref.Hash()})\\n   413→\\tif err != nil {\\n   414→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   415→\\t}\\n   416→\\n   417→\\tvar foundTaskPath string\\n   418→\\terr = iter.ForEach(func(commit *object.Commit) error {\\n   419→\\t\\t// Check if commit message contains \\\"Commit: <sha>\\\" and the tool use ID\\n   420→\\t\\tif strings.Contains(commit.Message, \\\"Commit: \\\"+shortSHA) &&\\n   421→\\t\\t\\tstrings.Contains(commit.Message, toolUseID) {\\n   422→\\t\\t\\t// Parse task metadata trailer\\n   423→\\t\\t\\tif taskPath, found := trailers.ParseTaskMetadata(commit.Message); found {\\n   424→\\t\\t\\t\\tfoundTaskPath = taskPath\\n   425→\\t\\t\\t\\treturn errStop // Found it\\n   426→\\t\\t\\t}\\n   427→\\t\\t}\\n   428→\\t\\treturn nil\\n   429→\\t})\\n   430→\\tif err != nil && !errors.Is(err, errStop) {\\n   431→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to iterate commits: %w\\\", err)\\n   432→\\t}\\n   433→\\n   434→\\treturn foundTaskPath, nil\\n   435→}\\n   436→\\n   437→func (s *AutoCommitStrategy) Rewind(point RewindPoint) error {\\n   438→\\tcommitHash := plumbing.NewHash(point.ID)\\n   439→\\tshortID, err := HardResetWithProtection(commitHash)\\n   440→\\tif err != nil {\\n   441→\\t\\treturn err\\n   442→\\t}\\n   443→\\n   444→\\tfmt.Println()\\n   445→\\tfmt.Printf(\\\"Reset to commit %s\\\\n\\\", shortID)\\n   446→\\tfmt.Println()\\n   447→\\n   448→\\treturn nil\\n   449→}\\n   450→\\n   451→func (s *AutoCommitStrategy) CanRewind() (bool, string, error) {\\n   452→\\treturn checkCanRewind()\\n   453→}\\n   454→\\n   455→// PreviewRewind returns what will happen if rewinding to the given point.\\n   456→// For auto-commit strategy, this returns nil since git reset doesn't delete untracked files.\\n   457→func (s *AutoCommitStrategy) PreviewRewind(_ RewindPoint) (*RewindPreview, error) {\\n   458→\\t// Auto-commit uses git reset --hard which doesn't affect untracked files\\n   459→\\t// Return empty preview to indicate no untracked files will be deleted\\n   460→\\treturn &RewindPreview{}, nil\\n   461→}\\n   462→\\n   463→// EnsureSetup ensures the strategy's required setup is in place.\\n   464→// For auto-commit strategy:\\n   465→// - Ensure .entire/.gitignore has all required entries\\n   466→// - Create orphan entire/checkpoints/v1 branch if it doesn't exist\\n   467→// - Install git hooks if missing (self-healing for third-party overwrites)\\n   468→func (s *AutoCommitStrategy) EnsureSetup() error {\\n   469→\\tif err := EnsureEntireGitignore(); err != nil {\\n   470→\\t\\treturn err\\n   471→\\t}\\n   472→\\n   473→\\trepo, err := OpenRepository()\\n   474→\\tif err != nil {\\n   475→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   476→\\t}\\n   477→\\n   478→\\t// Ensure the entire/checkpoints/v1 orphan branch exists\\n   479→\\tif err := EnsureMetadataBranch(repo); err != nil {\\n   480→\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n   481→\\t}\\n   482→\\n   483→\\t// Install generic hooks if missing (they delegate to strategy at runtime)\\n   484→\\tif !IsGitHookInstalled() {\\n   485→\\t\\tif _, err := InstallGitHook(true); err != nil {\\n   486→\\t\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   487→\\t\\t}\\n   488→\\t}\\n   489→\\n   490→\\treturn nil\\n   491→}\\n   492→\\n   493→// GetSessionInfo returns session information for linking commits.\\n   494→// For auto-commit strategy, we don't track active sessions - metadata is stored on\\n   495→// entire/checkpoints/v1 branch when SaveStep is called. Active branch commits\\n   496→// are kept clean (no trailers), so this returns ErrNoSession.\\n   497→// Use ListSessions() or GetSession() to retrieve session info from the metadata branch.\\n   498→func (s *AutoCommitStrategy) GetSessionInfo() (*SessionInfo, error) {\\n   499→\\t// Dual strategy doesn't track active sessions like shadow does.\\n   500→\\t// Session metadata is stored on entire/checkpoints/v1 branch and can be\\n   501→\\t// retrieved via ListSessions() or GetSession().\\n   502→\\treturn nil, ErrNoSession\\n   503→}\\n   504→\\n   505→// SaveTaskStep creates a checkpoint commit for a completed task.\\n   506→// For auto-commit strategy:\\n   507→// 1. Commit code changes to active branch (no trailers - clean history)\\n   508→// 2. Commit task metadata to entire/checkpoints/v1 branch with checkpoint format\\n   509→func (s *AutoCommitStrategy) SaveTaskStep(ctx TaskStepContext) error {\\n   510→\\trepo, err := OpenRepository()\\n   511→\\tif err != nil {\\n   512→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   513→\\t}\\n   514→\\n   515→\\t// Ensure entire/checkpoints/v1 branch exists\\n   516→\\tif err := EnsureMetadataBranch(repo); err != nil {\\n   517→\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n   518→\\t}\\n   519→\\n   520→\\t// Generate checkpoint ID for this task checkpoint\\n   521→\\tcpID, err := id.Generate()\\n   522→\\tif err != nil {\\n   523→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   524→\\t}\\n   525→\\n   526→\\t// Step 1: Commit code changes to active branch with checkpoint ID trailer\\n   527→\\t// We do code first to avoid orphaned metadata if this step fails.\\n   528→\\t_, err = s.commitTaskCodeToActive(repo, ctx, cpID)\\n   529→\\tif err != nil {\\n   530→\\t\\treturn fmt.Errorf(\\\"failed to commit task code to active branch: %w\\\", err)\\n   531→\\t}\\n   532→\\n   533→\\t// Step 2: Commit task metadata to entire/checkpoints/v1 branch at sharded path\\n   534→\\t_, err = s.commitTaskMetadataToMetadataBranch(repo, ctx, cpID)\\n   535→\\tif err != nil {\\n   536→\\t\\treturn fmt.Errorf(\\\"failed to commit task metadata to entire/checkpoints/v1 branch: %w\\\", err)\\n   537→\\t}\\n   538→\\n   539→\\t// Log task checkpoint creation\\n   540→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   541→\\tattrs := []any{\\n   542→\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n   543→\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"task\\\"),\\n   544→\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   545→\\t\\tslog.String(\\\"checkpoint_uuid\\\", ctx.CheckpointUUID),\\n   546→\\t\\tslog.String(\\\"tool_use_id\\\", ctx.ToolUseID),\\n   547→\\t\\tslog.String(\\\"subagent_type\\\", ctx.SubagentType),\\n   548→\\t\\tslog.Int(\\\"modified_files\\\", len(ctx.ModifiedFiles)),\\n   549→\\t\\tslog.Int(\\\"new_files\\\", len(ctx.NewFiles)),\\n   550→\\t\\tslog.Int(\\\"deleted_files\\\", len(ctx.DeletedFiles)),\\n   551→\\t}\\n   552→\\tif ctx.IsIncremental {\\n   553→\\t\\tattrs = append(attrs,\\n   554→\\t\\t\\tslog.Bool(\\\"is_incremental\\\", true),\\n   555→\\t\\t\\tslog.String(\\\"incremental_type\\\", ctx.IncrementalType),\\n   556→\\t\\t\\tslog.Int(\\\"incremental_sequence\\\", ctx.IncrementalSequence),\\n   557→\\t\\t)\\n   558→\\t}\\n   559→\\tlogging.Info(logCtx, \\\"task checkpoint saved\\\", attrs...)\\n   560→\\n   561→\\treturn nil\\n   562→}\\n   563→\\n   564→// commitTaskCodeToActive commits task code changes to the active branch.\\n   565→// Adds an Entire-Checkpoint trailer for metadata lookup that survives amend/rebase.\\n   566→// Skips commit creation if there are no file changes.\\n   567→func (s *AutoCommitStrategy) commitTaskCodeToActive(repo *git.Repository, ctx TaskStepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n   568→\\thasFileChanges := len(ctx.ModifiedFiles) > 0 || len(ctx.NewFiles) > 0 || len(ctx.DeletedFiles) > 0\\n   569→\\n   570→\\t// If no file changes, skip code commit\\n   571→\\tif !hasFileChanges {\\n   572→\\t\\tfmt.Fprintf(os.Stderr, \\\"No code changes to commit for task checkpoint\\\\n\\\")\\n   573→\\t\\t// Return current HEAD hash so metadata can still be stored\\n   574→\\t\\thead, err := repo.Head()\\n   575→\\t\\tif err != nil {\\n   576→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   577→\\t\\t}\\n   578→\\t\\treturn head.Hash(), nil\\n   579→\\t}\\n   580→\\n   581→\\tworktree, err := repo.Worktree()\\n   582→\\tif err != nil {\\n   583→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   584→\\t}\\n   585→\\n   586→\\t// Stage code changes\\n   587→\\tStageFiles(worktree, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles, StageForTask)\\n   588→\\n   589→\\t// Build commit message with checkpoint trailer\\n   590→\\tshortToolUseID := ctx.ToolUseID\\n   591→\\tif len(shortToolUseID) > id.ShortIDLength {\\n   592→\\t\\tshortToolUseID = shortToolUseID[:id.ShortIDLength]\\n   593→\\t}\\n   594→\\n   595→\\tvar subject string\\n   596→\\tif ctx.IsIncremental {\\n   597→\\t\\tsubject = FormatIncrementalSubject(\\n   598→\\t\\t\\tctx.IncrementalType,\\n   599→\\t\\t\\tctx.SubagentType,\\n   600→\\t\\t\\tctx.TaskDescription,\\n   601→\\t\\t\\tctx.TodoContent,\\n   602→\\t\\t\\tctx.IncrementalSequence,\\n   603→\\t\\t\\tshortToolUseID,\\n   604→\\t\\t)\\n   605→\\t} else {\\n   606→\\t\\tsubject = FormatSubagentEndMessage(ctx.SubagentType, ctx.TaskDescription, shortToolUseID)\\n   607→\\t}\\n   608→\\n   609→\\t// Add checkpoint ID trailer to commit message\\n   610→\\tcommitMsg := subject + \\\"\\\\n\\\\n\\\" + trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n   611→\\n   612→\\tauthor := &object.Signature{\\n   613→\\t\\tName:  ctx.AuthorName,\\n   614→\\t\\tEmail: ctx.AuthorEmail,\\n   615→\\t\\tWhen:  time.Now(),\\n   616→\\t}\\n   617→\\n   618→\\tcommitHash, err := commitOrHead(repo, worktree, commitMsg, author)\\n   619→\\tif err != nil {\\n   620→\\t\\treturn plumbing.ZeroHash, err\\n   621→\\t}\\n   622→\\n   623→\\tif ctx.IsIncremental {\\n   624→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed incremental checkpoint #%d to active branch (%s)\\\\n\\\", ctx.IncrementalSequence, commitHash.String()[:7])\\n   625→\\t} else {\\n   626→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed task checkpoint to active branch (%s)\\\\n\\\", commitHash.String()[:7])\\n   627→\\t}\\n   628→\\treturn commitHash, nil\\n   629→}\\n   630→\\n   631→// commitTaskMetadataToMetadataBranch commits task metadata to the entire/checkpoints/v1 branch.\\n   632→// Uses sharded path: <checkpointID[:2]>/<checkpointID[2:]>/tasks/<tool-use-id>/\\n   633→// Returns the metadata commit hash.\\n   634→// When IsIncremental is true, only writes the incremental checkpoint file, skipping transcripts.\\n   635→// Uses checkpoint.WriteCommitted for git operations.\\n   636→func (s *AutoCommitStrategy) commitTaskMetadataToMetadataBranch(repo *git.Repository, ctx TaskStepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n   637→\\tstore, err := s.getCheckpointStore()\\n   638→\\tif err != nil {\\n   639→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   640→\\t}\\n   641→\\n   642→\\t// Format commit subject line for better git log readability\\n   643→\\tshortToolUseID := ctx.ToolUseID\\n   644→\\tif len(shortToolUseID) > id.ShortIDLength {\\n   645→\\t\\tshortToolUseID = shortToolUseID[:id.ShortIDLength]\\n   646→\\t}\\n   647→\\n   648→\\tvar messageSubject string\\n   649→\\tif ctx.IsIncremental {\\n   650→\\t\\tmessageSubject = FormatIncrementalSubject(\\n   651→\\t\\t\\tctx.IncrementalType,\\n   652→\\t\\t\\tctx.SubagentType,\\n   653→\\t\\t\\tctx.TaskDescription,\\n   654→\\t\\t\\tctx.TodoContent,\\n   655→\\t\\t\\tctx.IncrementalSequence,\\n   656→\\t\\t\\tshortToolUseID,\\n   657→\\t\\t)\\n   658→\\t} else {\\n   659→\\t\\tmessageSubject = FormatSubagentEndMessage(ctx.SubagentType, ctx.TaskDescription, shortToolUseID)\\n   660→\\t}\\n   661→\\n   662→\\t// Get current branch name\\n   663→\\tbranchName := GetCurrentBranchName(repo)\\n   664→\\n   665→\\t// Write committed checkpoint using the checkpoint store\\n   666→\\terr = store.WriteCommitted(context.Background(), checkpoint.WriteCommittedOptions{\\n   667→\\t\\tCheckpointID:           checkpointID,\\n   668→\\t\\tSessionID:              ctx.SessionID,\\n   669→\\t\\tStrategy:               StrategyNameAutoCommit,\\n   670→\\t\\tBranch:                 branchName,\\n   671→\\t\\tIsTask:                 true,\\n   672→\\t\\tToolUseID:              ctx.ToolUseID,\\n   673→\\t\\tAgentID:                ctx.AgentID,\\n   674→\\t\\tCheckpointUUID:         ctx.CheckpointUUID,\\n   675→\\t\\tTranscriptPath:         ctx.TranscriptPath,\\n   676→\\t\\tSubagentTranscriptPath: ctx.SubagentTranscriptPath,\\n   677→\\t\\tIsIncremental:          ctx.IsIncremental,\\n   678→\\t\\tIncrementalSequence:    ctx.IncrementalSequence,\\n   679→\\t\\tIncrementalType:        ctx.IncrementalType,\\n   680→\\t\\tIncrementalData:        ctx.IncrementalData,\\n   681→\\t\\tCommitSubject:          messageSubject,\\n   682→\\t\\tAuthorName:             ctx.AuthorName,\\n   683→\\t\\tAuthorEmail:            ctx.AuthorEmail,\\n   684→\\t\\tAgent:                  ctx.AgentType,\\n   685→\\t})\\n   686→\\tif err != nil {\\n   687→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write task checkpoint: %w\\\", err)\\n   688→\\t}\\n   689→\\n   690→\\tif ctx.IsIncremental {\\n   691→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed incremental checkpoint metadata to %s (%s)\\\\n\\\", paths.MetadataBranchName, checkpointID)\\n   692→\\t} else {\\n   693→\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed task metadata to %s (%s)\\\\n\\\", paths.MetadataBranchName, checkpointID)\\n   694→\\t}\\n   695→\\treturn plumbing.ZeroHash, nil // Commit hash not needed by callers\\n   696→}\\n   697→\\n   698→// GetTaskCheckpoint returns the task checkpoint for a given rewind point.\\n   699→// For auto-commit strategy, checkpoints are stored on the entire/checkpoints/v1 branch in checkpoint directories.\\n   700→// Returns ErrNotTaskCheckpoint if the point is not a task checkpoint.\\n   701→func (s *AutoCommitStrategy) GetTaskCheckpoint(point RewindPoint) (*TaskCheckpoint, error) {\\n   702→\\tif !point.IsTaskCheckpoint {\\n   703→\\t\\treturn nil, ErrNotTaskCheckpoint\\n   704→\\t}\\n   705→\\n   706→\\trepo, err := OpenRepository()\\n   707→\\tif err != nil {\\n   708→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   709→\\t}\\n   710→\\n   711→\\t// Get the entire/checkpoints/v1 branch\\n   712→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   713→\\tref, err := repo.Reference(refName, true)\\n   714→\\tif err != nil {\\n   715→\\t\\treturn nil, fmt.Errorf(\\\"metadata branch %s not found: %w\\\", paths.MetadataBranchName, err)\\n   716→\\t}\\n   717→\\n   718→\\tmetadataCommit, err := repo.CommitObject(ref.Hash())\\n   719→\\tif err != nil {\\n   720→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch commit: %w\\\", err)\\n   721→\\t}\\n   722→\\n   723→\\ttree, err := metadataCommit.Tree()\\n   724→\\tif err != nil {\\n   725→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata tree: %w\\\", err)\\n   726→\\t}\\n   727→\\n   728→\\t// Find checkpoint using the metadata path from rewind point\\n   729→\\t// MetadataDir for auto-commit task checkpoints is: cond-YYYYMMDD-HHMMSS-XXXXXXXX/tasks/<tool-use-id>\\n   730→\\tcheckpointPath := point.MetadataDir + \\\"/checkpoint.json\\\"\\n   731→\\tfile, err := tree.File(checkpointPath)\\n   732→\\tif err != nil {\\n   733→\\t\\t// Try finding via commit SHA lookup\\n   734→\\t\\ttaskCheckpointPath, findErr := s.findTaskCheckpointPath(repo, point.ID, point.ToolUseID)\\n   735→\\t\\tif findErr != nil {\\n   736→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", checkpointPath, err)\\n   737→\\t\\t}\\n   738→\\t\\tfile, err = tree.File(taskCheckpointPath)\\n   739→\\t\\tif err != nil {\\n   740→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", taskCheckpointPath, err)\\n   741→\\t\\t}\\n   742→\\t}\\n   743→\\n   744→\\tcontent, err := file.Contents()\\n   745→