n is the intended pattern\\n    25→func init() {\\n    26→\\tagent.Register(agent.AgentNameKiro, NewKiroAgent)\\n    27→}\\n    28→\\n    29→// KiroAgent implements the Agent interface for Amazon's Kiro CLI.\\n    30→//\\n    31→//nolint:revive // KiroAgent is clearer than Agent in this context\\n    32→type KiroAgent struct{}\\n    33→\\n    34→// NewKiroAgent creates a new Kiro agent instance.\\n    35→func NewKiroAgent() agent.Agent {\\n    36→\\treturn &KiroAgent{}\\n    37→}\\n    38→\\n    39→// --- Identity ---\\n    40→\\n    41→func (k *KiroAgent) Name() types.AgentName   { return agent.AgentNameKiro }\\n    42→func (k *KiroAgent) Type() types.AgentType   { return agent.AgentTypeKiro }\\n    43→func (k *KiroAgent) Description() string     { return \\\"Kiro - Amazon AI coding CLI\\\" }\\n    44→func (k *KiroAgent) IsPreview() bool         { return true }\\n    45→func (k *KiroAgent) ProtectedDirs() []string { return []string{\\\".kiro\\\"} }\\n    46→\\n    47→// DetectPresence checks if Kiro is configured in the repository.\\n    48→func (k *KiroAgent) DetectPresence(ctx context.Context) (bool, error) {\\n    49→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    50→\\tif err != nil {\\n    51→\\t\\tworktreeRoot = \\\".\\\"\\n    52→\\t}\\n    53→\\tif _, err := os.Stat(filepath.Join(worktreeRoot, \\\".kiro\\\")); err == nil {\\n    54→\\t\\treturn true, nil\\n    55→\\t}\\n    56→\\treturn false, nil\\n    57→}\\n    58→\\n    59→// --- Transcript Storage ---\\n    60→\\n    61→// ReadTranscript reads the cached transcript JSON for a session.\\n    62→func (k *KiroAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    63→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    64→\\tif err != nil {\\n    65→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    66→\\t}\\n    67→\\treturn data, nil\\n    68→}\\n    69→\\n    70→// ChunkTranscript splits a JSON transcript into chunks.\\n    71→/