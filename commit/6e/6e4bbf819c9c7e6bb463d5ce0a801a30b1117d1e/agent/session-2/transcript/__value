 to install.\\n    59→type ideHookDef struct {\\n    60→\\tFilename    string // e.g. \\\"entire-prompt-submit\\\"\\n    61→\\tTriggerType string // e.g. \\\"promptSubmit\\\"\\n    62→\\tCLIVerb     string // e.g. \\\"user-prompt-submit\\\"\\n    63→}\\n    64→\\n    65→// ideHookDefs lists the 4 IDE hook files to install.\\n    66→// No agentSpawn IDE hook — the IDE has no such trigger.\\n    67→// The first promptSubmit serves as session start.\\n    68→var ideHookDefs = []ideHookDef{\\n    69→\\t{Filename: \\\"entire-prompt-submit\\\", TriggerType: \\\"promptSubmit\\\", CLIVerb: HookNameUserPromptSubmit},\\n    70→\\t{Filename: \\\"entire-stop\\\", TriggerType: \\\"agentStop\\\", CLIVerb: HookNameStop},\\n    71→\\t{Filename: \\\"entire-pre-tool-use\\\", TriggerType: \\\"preToolUse\\\", CLIVerb: HookNamePreToolUse},\\n    72→\\t{Filename: \\\"entire-post-tool-use\\\", TriggerType: \\\"postToolUse\\\", CLIVerb: HookNamePostToolUse},\\n    73→}\\n    74→\\n    75→// InstallHooks installs Entire hooks in .kiro/agents/entire.json (CLI hooks)\\n    76→// and .kiro/hooks/*.kiro.hook (IDE hooks).\\n    77→// Returns the total number of hooks installed (CLI + IDE).\\n    78→func (k *KiroAgent) InstallHooks(ctx context.Context, localDev bool, force bool) (int, error) {\\n    79→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    80→\\tif err != nil {\\n    81→\\t\\tworktreeRoot = \\\".\\\"\\n    82→\\t}\\n    83→\\n    84→\\thooksPath := filepath.Join(worktreeRoot, \\\".kiro\\\", hooksDir, HooksFileName)\\n    85→\\n    86→\\t// If hooks are already installed and not forcing, check if they're current\\n    87→\\tif !force {\\n    88→\\t\\tif existing, readErr := os.ReadFile(hooksPath); readErr == nil { //nolint:gosec // path constructed from repo root\\n    89→\\t\\t\\tvar file kiroAgentFile\\n    90→\\t\\t\\tif json.Unmarshal(existing, &file) == nil &&\\n    91→\\t\\t\\t\\tallHooksPresent(file.Hooks, localDev) &&\\n    92→\\t\\t\\t\\tallIDEHooksPresent(worktreeRoot, localDev) &&\\n    93→\\t\\t\\t\\ttrustedCommandsPresent(worktreeRoot, localDev) {\\n    94→\\t\\t\\t\\treturn 0, nil\\n    95→\\t\\t\\t}\\n    96→\\t\\t}\\n    97→\\t}\\n    98→\\n    99→\\tcmdPrefix := hookCmdPrefix(localDev)\\n   100→\\n   101→\\tfile := kiroAgentFile{\\n   102→\\t\\tName: \\\"entire\\\",\\n   103→\\t\\t// Include all default Kiro tools so the agent profile doesn't restrict them.\\n   104→\\t\\tTools: []string{\\n   105→\\t\\t\\t\\\"read\\\", \\\"write\\\", \\\"shell\\\", \\\"grep\\\", \\\"glob\\\",\\n   106→\\t\\t\\t\\\"aws\\\", \\\"report\\\", \\\"introspect\\\", \\\"knowledge\\\",\\n   107→\\t\\t\\t\\\"thinking\\\", \\\"todo\\\", \\\"delegate\\\",\\n   108→\\t\\t},\\n   109→\\t\\tHooks: kiroHooks{\\n   110→\\t\\t\\tAgentSpawn:       []kiroHookEntry{{Command: cmdPrefix + HookNameAgentSpawn}},\\n   111→\\t\\t\\tUserPromptSubmit: []kiroHookEntry{{Command: cmdPrefix + HookNameUserPromptSubmit}},\\n   112→\\t\\t\\tPreToolUse:       []kiroHookEntry{{Command: cmdPrefix + HookNamePreToolUse}},\\n   113→\\t\\t\\tPostToolUse:      []kiroHookEntry{{Command: cmdPrefix + HookNamePostToolUse}},\\n   114→\\t\\t\\tStop:             []kiroHookEntry{{Command: cmdPrefix + HookNameStop}},\\n   115→\\t\\t},\\n   116→\\t}\\n   117→\\n   118→\\tif err := os.MkdirAll(filepath.Dir(hooksPath), 0o750); err != nil {\\n   119→\\t\\treturn 0, fmt.Errorf(\\\"failed to create .kiro/agents directory: %w\\\", err)\\n   120→\\t}\\n   121→\\n   122→\\toutput, err := jsonutil.MarshalIndentWithNewline(file, \\\"\\\", \\\"  \\\")\\n   123→\\tif err != nil {\\n   124→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal hooks config: %w\\\", err)\\n   125→\\t}\\n   126→\\n   127→\\tif err := os.WriteFile(hooksPath, output, 0o600); err != nil {\\n   128→\\t\\treturn 0, fmt.Errorf(\\\"failed to write hooks config: %w\\\", err)\\n   129→\\t}\\n   130→\\n   131→\\t// Install IDE hooks (.kiro/hooks/*.kiro.hook)\\n   132→\\tideCount, err := installIDEHooks(worktreeRoot, cmdPrefix)\\n   133→\\tif err != nil {\\n   134→\\t\\treturn 0, fmt.Errorf(\\\"failed to install IDE hooks: %w\\\", err)\\n   135→\\t}\\n   136→\\n   137→\\t// Configure trusted commands in .vscode/settings.json\\n   138→\\tif err := installTrustedCommands(worktreeRoot, localDev); err != nil {\\n   139→\\t\\treturn 0, fmt.Errorf(\\\"failed to configure trusted commands: %w\\\", err)\\n   140→\\t}\\n   141→\\n   142→\\treturn len(k.HookNames()) + ideCount, nil\\n   143→}\\n   144→\\n   145→// UninstallHooks removes the Entire hooks config file and IDE hook files.\\n   146→func (k *KiroAgent) UninstallHooks(ctx context.Context) error {\\n   147→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n   148→\\tif err != nil {\\n   149→\\t\\tworktreeRoot = \\\".\\\"\\n   150→\\t}\\n   151→\\n   152→\\t// Remove CLI agent file\\n   153→\\thooksPath := filepath.Join(worktreeRoot, \\\".kiro\\\", hooksDir, HooksFileName)\\n   154→\\tif err := os.Remove(hooksPath); err != nil && !os.IsNotExist(err) {\\n   155→\\t\\treturn fmt.Errorf(\\\"failed to remove hooks config: %w\\\", err)\\n   156→\\t}\\n   157→\\n   158→\\t// Remove IDE hook files\\n   159→\\tfor _, def := range ideHookDefs {\\n   160→\\t\\tidePath := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir, def.Filename+ideHookFileSuffix)\\n   161→\\t\\tif err := os.Remove(idePath); err != nil && !os.IsNotExist(err) {\\n   162→\\t\\t\\treturn fmt.Errorf(\\\"failed to remove IDE hook %s: %w\\\", def.Filename, err)\\n   163→\\t\\t}\\n   164→\\t}\\n   165→\\n   166→\\t// Remove trusted commands from .vscode/settings.json\\n   167→\\tif err := uninstallTrustedCommands(worktreeRoot); err != nil {\\n   168→\\t\\treturn fmt.Errorf(\\\"failed to remove trusted commands: %w\\\", err)\\n   169→\\t}\\n   170→\\n   171→\\treturn nil\\n   172→}\\n   173→\\n   174→// AreHooksInstalled checks if Entire hooks are installed.\\n   175→// Returns true if EITHER CLI agent hooks or IDE hooks are present.\\n   176→func (k *KiroAgent) AreHooksInstalled(ctx context.Context) bool {\\n   177→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n   178→\\tif err != nil {\\n   179→\\t\\tworktreeRoot = \\\".\\\"\\n   180→\\t}\\n   181→\\n   182→\\t// Check CLI agent hooks\\n   183→\\thooksPath := filepath.Join(worktreeRoot, \\\".kiro\\\", hooksDir, HooksFileName)\\n   184→\\tdata, err := os.ReadFile(hooksPath) //nolint:gosec // path constructed from repo root\\n   185→\\tif err == nil {\\n   186→\\t\\tvar file kiroAgentFile\\n   187→\\t\\tif json.Unmarshal(data, &file) == nil {\\n   188→\\t\\t\\tif hasEntireHook(file.Hooks.AgentSpawn) ||\\n   189→\\t\\t\\t\\thasEntireHook(file.Hooks.UserPromptSubmit) ||\\n   190→\\t\\t\\t\\thasEntireHook(file.Hooks.Stop) {\\n   191→\\t\\t\\t\\treturn true\\n   192→\\t\\t\\t}\\n   193→\\t\\t}\\n   194→\\t}\\n   195→\\n   196→\\t// Check IDE hooks — any Entire IDE hook file means hooks are installed\\n   197→\\treturn anyIDEHookPresent(worktreeRoot)\\n   198→}\\n   199→\\n   200→// GetSupportedHooks returns the hook types Kiro supports.\\n   201→func (k *KiroAgent) GetSupportedHooks() []agent.HookType {\\n   202→\\treturn []agent.HookType{\\n   203→\\t\\tagent.HookSessionStart,\\n   204→\\t\\tagent.HookUserPromptSubmit,\\n   205→\\t\\tagent.HookPreToolUse,\\n   206→\\t\\tagent.HookPostToolUse,\\n   207→\\t\\tagent.HookStop,\\n   208→\\t}\\n   209→}\\n   210→\\n   211→func allHooksPresent(hooks kiroHooks, localDev bool) bool {\\n   212→\\tcmdPrefix := hookCmdPrefix(localDev)\\n   213→\\n   214→\\treturn hookCommandExists(hooks.AgentSpawn, cmdPrefix+HookNameAgentSpawn) &&\\n   215→\\t\\thookCommandExists(hooks.UserPromptSubmit, cmdPrefix+HookNameUserPromptSubmit) &&\\n   216→\\t\\thookCommandExists(hooks.PreToolUse, cmdPrefix+HookNamePreToolUse) &&\\n   217→\\t\\thookCommandExists(hooks.PostToolUse, cmdPrefix+HookNamePostToolUse) &&\\n   218→\\t\\thookCommandExists(hooks.Stop, cmdPrefix+HookNameStop)\\n   219→}\\n   220→\\n   221→func hookCommandExists(entries []kiroHookEntry, command string) bool {\\n   222→\\tfor _, entry := range entries {\\n   223→\\t\\tif entry.Command == command {\\n   224→\\t\\t\\treturn true\\n   225→\\t\\t}\\n   226→\\t}\\n   227→\\treturn false\\n   228→}\\n   229→\\n   230→func isEntireHook(command string) bool {\\n   231→\\tfor _, prefix := range entireHookPrefixes {\\n   232→\\t\\tif strings.HasPrefix(command, prefix) {\\n   233→\\t\\t\\treturn true\\n   234→\\t\\t}\\n   235→\\t}\\n   236→\\treturn false\\n   237→}\\n   238→\\n   239→func hasEntireHook(entries []kiroHookEntry) bool {\\n   240→\\tfor _, entry := range entries {\\n   241→\\t\\tif isEntireHook(entry.Command) {\\n   242→\\t\\t\\treturn true\\n   243→\\t\\t}\\n   244→\\t}\\n   245→\\treturn false\\n   246→}\\n   247→\\n   248→func hookCmdPrefix(localDev bool) string {\\n   249→\\tif localDev {\\n   250→\\t\\treturn localDevCmdPrefix + \\\"hooks kiro \\\"\\n   251→\\t}\\n   252→\\treturn prodHookCmdPrefix\\n   253→}\\n   254→\\n   255→// installIDEHooks creates .kiro/hooks/*.kiro.hook files for the Kiro IDE.\\n   256→func installIDEHooks(worktreeRoot, cmdPrefix string) (int, error) {\\n   257→\\tdir := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir)\\n   258→\\tif err := os.MkdirAll(dir, 0o750); err != nil {\\n   259→\\t\\treturn 0, fmt.Errorf(\\\"failed to create .kiro/hooks directory: %w\\\", err)\\n   260→\\t}\\n   261→\\n   262→\\tfor _, def := range ideHookDefs {\\n   263→\\t\\thook := kiroIDEHookFile{\\n   264→\\t\\t\\tEnabled:     true,\\n   265→\\t\\t\\tName:        def.Filename,\\n   266→\\t\\t\\tDescription: \\\"Entire CLI \\\" + def.TriggerType + \\\" hook\\\",\\n   267→\\t\\t\\tVersion:     ideHookVersion,\\n   268→\\t\\t\\tWhen: kiroIDEHookWhen{\\n   269→\\t\\t\\t\\tType: def.TriggerType,\\n   270→\\t\\t\\t},\\n   271→\\t\\t\\tThen: kiroIDEHookThen{\\n   272→\\t\\t\\t\\tType:    \\\"runCommand\\\",\\n   273→\\t\\t\\t\\tCommand: cmdPrefix + def.CLIVerb,\\n   274→\\t\\t\\t},\\n   275→\\t\\t}\\n   276→\\n   277→\\t\\tdata, err := jsonutil.MarshalIndentWithNewline(hook, \\\"\\\", \\\"  \\\")\\n   278→\\t\\tif err != nil {\\n   279→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal IDE hook %s: %w\\\", def.Filename, err)\\n   280→\\t\\t}\\n   281→\\n   282→\\t\\tpath := filepath.Join(dir, def.Filename+ideHookFileSuffix)\\n   283→\\t\\tif err := os.WriteFile(path, data, 0o600); err != nil {\\n   284→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to write IDE hook %s: %w\\\", def.Filename, err)\\n   285→\\t\\t}\\n   286→\\t}\\n   287→\\n   288→\\treturn len(ideHookDefs), nil\\n   289→}\\n   290→\\n   291→// allIDEHooksPresent checks that all 4 IDE hook files exist and have correct commands.\\n   292→func allIDEHooksPresent(worktreeRoot string, localDev bool) bool {\\n   293→\\tcmdPrefix := hookCmdPrefix(localDev)\\n   294→\\n   295→\\tfor _, def := range ideHookDefs {\\n   296→\\t\\tpath := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir, def.Filename+ideHookFileSuffix)\\n   297→\\t\\tdata, err := os.ReadFile(path) //nolint:gosec // path constructed from repo root\\n   298→\\t\\tif err != nil {\\n   299→\\t\\t\\treturn false\\n   300→\\t\\t}\\n   301→\\t\\tvar hook kiroIDEHookFile\\n   302→\\t\\tif err := json.Unmarshal(data, &hook); err != nil {\\n   303→\\t\\t\\treturn false\\n   304→\\t\\t}\\n   305→\\t\\tif hook.Then.Command != cmdPrefix+def.CLIVerb {\\n   306→\\t\\t\\treturn false\\n   307→\\t\\t}\\n   308→\\t}\\n   309→\\treturn true\\n   310→}\\n   311→\\n   312→// anyIDEHookPresent checks if any Entire IDE hook file exists.\\n   313→func anyIDEHookPresent(worktreeRoot string) bool {\\n   314→\\tfor _, def := range ideHookDefs {\\n   315→\\t\\tpath := filepath.Join(worktreeRoot, \\\".kiro\\\", ideHooksDir, def.Filename+ideHookFileSuffix)\\n   316→\\t\\tdata, err := os.ReadFile(path) //nolint:gosec // path constructed from repo root\\n   317→\\t\\tif err != nil {\\n   318→\\t\\t\\tcontinue\\n   319→\\t\\t}\\n   320→\\t\\tvar hook kiroIDEHookFile\\n   321→\\t\\tif json.Unmarshal(data, &hook) == nil && isEntireIDEHook(hook) {\\n   322→\\t\\t\\treturn true\\n   323→\\t\\t}\\n   324→\\t}\\n   325→\\treturn false\\n   326→}\\n   327→\\n   328→// isEntireIDEHook checks if an IDE hook file belongs to Entire.\\n   329→func isEntireIDEHook(hook kiroIDEHookFile) bool {\\n   330→\\treturn strings.HasPrefix(hook.Name, \\\"entire-\\\") && isEntireHook(hook.Then.Command)\\n   331→}\\n   332→\\n   333→// trustedCommand returns the trusted command pattern for the given mode.\\n   334→func trustedCommand(localDev bool) string {\\n   335→\\tif localDev {\\n   336→\\t\\treturn localDevCmdPrefix + \\\"hooks *\\\"\\n   337→\\t}\\n   338→\\treturn prodTrustedCommand\\n   339→}\\n   340→\\n   341→// isEntireTrustedCommand checks if a command string is an Entire trusted command.\\n   342→func isEntireTrustedCommand(cmd string) bool {\\n   343→\\treturn cmd == prodTrustedCommand || cmd == localDevCmdPrefix+\\\"hooks *\\\"\\n   344→}\\n   345→\\n   346→// trustedCommandsPresent checks if the appropriate trusted command is in .vscode/settings.json.\\n   347→func trustedCommandsPresent(worktreeRoot string, localDev bool) bool {\\n   348→\\tsettingsPath := filepath.Join(worktreeRoot, vscodeSettingsDir, vscodeSettingsFile)\\n   349→\\tdata, err := os.ReadFile(settingsPath) //nolint:gosec // path constructed from repo root\\n   350→\\tif err != nil {\\n   351→\\t\\treturn false\\n   352→\\t}\\n   353→\\n   354→\\tvar rawSettings map[string]json.RawMessage\\n   355→\\tif err := json.Unmarshal(data, &rawSettings); err != nil {\\n   356→\\t\\treturn false\\n   357→\\t}\\n   358→\\n   359→\\traw, ok := rawSettings[trustedCommandsKey]\\n   360→\\tif !ok {\\n   361→\\t\\treturn false\\n   362→\\t}\\n   363→\\n   364→\\tvar commands []string\\n   365→\\tif err := json.Unmarshal(raw, &commands); err != nil {\\n   366→\\t\\treturn false\\n   367→\\t}\\n   368→\\n   369→\\twant := trustedCommand(localDev)\\n   370→\\tfor _, c := range commands {\\n   371→\\t\\tif c == want {\\n   372→\\t\\t\\treturn true\\n   373→\\t\\t}\