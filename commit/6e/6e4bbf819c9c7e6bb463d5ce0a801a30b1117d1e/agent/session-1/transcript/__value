re-prompt state,\\n   118→// ensures strategy setup, initializes session.\\n   119→func handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   120→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   121→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   122→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   123→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   124→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   125→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   126→\\t)\\n   127→\\n   128→\\tsessionID := event.SessionID\\n   129→\\tif sessionID == \\\"\\\" {\\n   130→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   131→\\t}\\n   132→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   133→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   134→\\t}\\n   135→\\n   136→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   137→\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n   138→\\t\\treturn err\\n   139→\\t}\\n   140→\\n   141→\\t// Ensure strategy setup and initialize session\\n   142→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   143→\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n   144→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   145→\\t}\\n   146→\\n   147→\\tstrat := GetStrategy(ctx)\\n   148→\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt, event.Model); err != nil {\\n   149→\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n   150→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   151→\\t}\\n   152→\\n   153→\\treturn nil\\n   154→}\\n   155→\\n   156→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   157→// detects file changes, saves step + checkpoint, transitions phase.\\n   158→//\\n   159→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   160→func handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   161→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   162→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   163→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   164→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   165→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   166→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   167→\\t)\\n   168→\\n   169→\\tsessionID := event.SessionID\\n   170→\\tif sessionID == \\\"\\\" {\\n   171→\\t\\tsessionID = unknownSessionID\\n   172→\\t}\\n   173→\\n   174→\\ttranscriptRef := event.SessionRef\\n   175→\\tif transcriptRef == \\\"\\\" {\\n   176→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   177→\\t}\\n   178→\\n   179→\\t// If agent implements TranscriptPreparer, materialize the transcript file.\\n   180→\\t// This must run BEFORE fileExists: agents like OpenCode lazily fetch transcripts\\n   181→\\t// via `opencode export`, so the file doesn't exist until PrepareTranscript creates it.\\n   182→\\t// Claude Code's PrepareTranscript just flushes (always succeeds). Agents without\\n   183→\\t// TranscriptPreparer (Gemini, Droid) are unaffected.\\n   184→\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n   185→\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n   186→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n   187→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   188→\\t\\t}\\n   189→\\t}\\n   190→\\n   191→\\tif !fileExists(transcriptRef) {\\n   192→\\t\\treturn fmt.Errorf(\\\"transcript file