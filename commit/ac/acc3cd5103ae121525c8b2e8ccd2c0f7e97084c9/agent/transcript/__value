ath) //nolint:gosec // path is constructed from repo root + fixed path\\n   395→\\tif err != nil {\\n   396→\\t\\treturn false\\n   397→\\t}\\n   398→\\n   399→\\tvar settings FactorySettings\\n   400→\\tif err := json.Unmarshal(data, &settings); err != nil {\\n   401→\\t\\treturn false\\n   402→\\t}\\n   403→\\n   404→\\t// Check for at least one of our hooks (new or old format)\\n   405→\\treturn hookCommandExists(settings.Hooks.Stop, \\\"entire hooks factoryai-droid stop\\\") ||\\n   406→\\t\\thookCommandExists(settings.Hooks.Stop, \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid stop\\\")\\n   407→}\\n   408→\\n   409→// Helper functions for hook management\\n   410→\\n   411→func hookCommandExists(matchers []FactoryHookMatcher, command string) bool {\\n   412→\\tfor _, matcher := range matchers {\\n   413→\\t\\tfor _, hook := range matcher.Hooks {\\n   414→\\t\\t\\tif hook.Command == command {\\n   415→\\t\\t\\t\\treturn true\\n   416→\\t\\t\\t}\\n   417→\\t\\t}\\n   418→\\t}\\n   419→\\treturn false\\n   420→}\\n   421→\\n   422→func hookCommandExistsWithMatcher(matchers []FactoryHookMatcher, matcherName, command string) bool {\\n   423→\\tfor _, matcher := range matchers {\\n   424→\\t\\tif matcher.Matcher == matcherName {\\n   425→\\t\\t\\tfor _, hook := range matcher.Hooks {\\n   426→\\t\\t\\t\\tif hook.Command == command {\\n   427→\\t\\t\\t\\t\\treturn true\\n   428→\\t\\t\\t\\t}\\n   429→\\t\\t\\t}\\n   430→\\t\\t}\\n   431→\\t}\\n   432→\\treturn false\\n   433→}\\n   434→\\n   435→func addHookToMatcher(matchers []FactoryHookMatcher, matcherName, command string) []FactoryHookMatcher {\\n   436→\\tentry := FactoryHookEntry{Type: \\\"command\\\", Command: command}\\n   437→\\tfor i := range matchers {\\n   438→\\t\\tif matchers[i].Matcher == matcherName {\\n   439→\\t\\t\\tmatchers[i].Hooks = append(matchers[i].Hooks, entry)\\n   440→\\t\\t\\treturn matchers\\n   441→\\t\\t}\\n   442→\\t}\\n   443→\\treturn append(matchers, Facto