lo.go\\\"))\\n    24→\\n    25→\\t// Get first checkpoint\\n    26→\\tpoints1 := env.GetRewindPoints()\\n    27→\\trequire.GreaterOrEqual(t, len(points1), 1)\\n    28→\\tfirstPointID := points1[0].ID\\n    29→\\tt.Logf(\\\"First checkpoint: %s\\\", safeIDPrefix(firstPointID))\\n    30→\\n    31→\\t// Save original content\\n    32→\\toriginalContent := env.ReadFile(\\\"hello.go\\\")\\n    33→\\n    34→\\t// 2. Agent modifies the file\\n    35→\\tt.Log(\\\"Step 2: Modifying file\\\")\\n    36→\\tresult, err = env.RunAgent(PromptModifyHelloGo.Prompt)\\n    37→\\trequire.NoError(t, err)\\n    38→\\tAssertAgentSuccess(t, result, err)\\n    39→\\n    40→\\t// Verify content changed\\n    41→\\tmodifiedContent := env.ReadFile(\\\"hello.go\\\")\\n    42→\\tassert.NotEqual(t, originalContent, modifiedContent, \\\"Content should have changed\\\")\\n    43→\\tassert.Contains(t, modifiedContent, \\\"E2E Test\\\", \\\"Should contain new message\\\")\\n    44→\\n    45→\\t// Get second checkpoint\\n    46→\\tpoints2 := env.GetRewindPoints()\\n    47→\\trequire.GreaterOrEqual(t, len(points2), 2, \\\"Should have at least 2 checkpoints\\\")\\n    48→\\tt.Logf(\\\"Now have %d checkpoints\\\", len(points2))\\n    49→\\n    50→\\t// 3. Rewind to first checkpoint\\n    51→\\tt.Log(\\\"Step 3: Rewinding to first checkpoint\\\")\\n    52→\\terr = env.Rewind(firstPointID)\\n    53→\\trequire.NoError(t, err)\\n    54→\\n    55→\\t// 4. Verify content was restored\\n    56→\\tt.Log(\\\"Step 4: Verifying content restored\\\")\\n    57→\\trestoredContent := env.ReadFile(\\\"hello.go\\\")\\n    58→\\tassert.Equal(t, originalContent, restoredContent, \\\"Content should be restored to original\\\")\\n    59→\\tassert.NotContains(t, restoredContent, \\\"E2E Test\\\", \\\"Should not contain modified message\\\")\\n    60→}\\n    61→\\n    62→// TestE2E_RewindAfterCommit tests that pre-commit checkpoint IDs become invalid after commit.\\n    63→//\\n    64→// Expected behavior:\\n    65→// 1. Before commit: checkpoints are on shadow branch with shadow branch commit IDs\\n    66→// 2. After commit: shadow branch is condensed and deleted\\n    67→// 3. New logs-only checkpoints appear with DIFFERENT IDs (user commit hashes)\\n    68→// 4. Attempting to rewind using the old shadow branch ID fails with \\\"not found\\\"\\n    69→func TestE2E_RewindAfterCommit(t *testing.T) {\\n    70→\\tt.Parallel()\\n    71→\\n    72→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n    73→\\n    74→\\t// 1. Agent creates file\\n    75→\\tt.Log(\\\"Step 1: Creating file\\\")\\n    76→\\tresult, err := env.RunAgent(PromptCreateHelloGo.Prompt)\\n    77→\\trequire.NoError(t, err)\\n    78→\\tAssertAgentSuccess(t, result, err)\\n    79→\\n    80→\\t// Get checkpoint before commit - this is a shadow branch commit ID\\n    81→\\tpointsBefore := env.GetRewindPoints()\\n    82→\\trequire.GreaterOrEqual(t, len(pointsBefore), 1, \\\"Should have checkpoint before commit\\\")\\n    83→\\tpreCommitPointID := pointsBefore[0].ID\\n    84→\\tt.Logf(\\\"Pre-commit checkpoint ID (shadow branch): %s\\\", safeIDPrefix(preCommitPointID))\\n    85→\\n    86→\\t// Verify this point is NOT logs-only (it's on shadow branch)\\n    87→\\tassert.False(t, pointsBefore[0].IsLogsOnly, \\\"Pre-commit checkpoint should NOT be logs-only\\\")\\n    88→\\n    89→\\t// 2. User commits - this condenses and deletes the shadow branch\\n    90→\\tt.Log(\\\"Step 2: Committing (triggers condensation)\\\")\\n    91→\\tenv.GitCommitWithShadowHooks(\\\"Add hello world\\\", \\\"hello.go\\\")\\n    92→\\n    93→\\t// 3. Verify checkpoint was created\\n    94→\\tcheckpointID, err := env.GetLatestCheckpointIDFromHistory()\\n    95→\\trequire.NoError(t, err, \\\"Should find checkpoint in commit history\\\")\\n    96→\\tt.Logf(\\\"Committed checkpoint ID: %s\\\", checkpointID)\\n    97→\\n    98→\\t// 4. Get rewind points after commit\\n    99→\\tt.Log(\\\"Step 3: Getting rewind points after commit\\\")\\n   100→\\tpointsAfter := env.GetRewindPoints()\\n   101→\\tt.Logf(\\\"Found %d rewind points after commit\\\", len(pointsAfter))\\n   102→\\n   103→\\t// Find the logs-only point (should be from the user commit)\\n   104→\\tvar logsOnlyPoint *RewindPoint\\n   105→\\tfor i, p := range pointsAfter {\\n   106→\\t\\tt.Logf(\\\"  Point %d: ID=%s, IsLogsOnly=%v, CondensationID=%s\\\",\\n   107→\\t\\t\\ti, safeIDPrefix(p.ID), p.IsLogsOnly, p.CondensationID)\\n   108→\\t\\tif p.IsLogsOnly {\\n   109→\\t\\t\\tpointCopy := p\\n   110→\\t\\t\\tlogsOnlyPoint = &pointCopy\\n   111→\\t\\t}\\n   112→\\t}\\n   113→\\trequire.NotNil(t, logsOnlyPoint, \\\"Should have a logs-only point after commit\\\")\\n   114→\\n   115→\\t// The logs-only point should have a DIFFERENT ID than the pre-commit shadow branch ID\\n   116→\\tassert.NotEqual(t, preCommitPointID, logsOnlyPoint.ID,\\n   117→\\t\\t\\\"Logs-only point ID should differ from shadow branch ID\\\")\\n   118→\\n   119→\\t// 5. Attempt to rewind to the OLD shadow branch ID - should fail\\n   120→\\tt.Log(\\\"Step 4: Attempting rewind to old shadow branch ID (should fail)\\\")\\n   121→\\terr = env.Rewind(preCommitPointID)\\n   122→\\n   123→\\t// The old shadow branch was deleted, so the ID is no longer valid\\n   124→\\tassert.Error(t, err, \\\"Rewind to deleted shadow branch ID should fail\\\")\\n   125→\\tassert.Contains(t, err.Error(), \\\"not found\\\",\\n   126→\\t\\t\\\"Error should indicate the rewind point was not found\\\")\\n   127→\\tt.Logf(\\\"Rewind correctly failed: %v\\\", err)\\n   128→}\\n   129→\\n   130→// TestE2E_RewindMultipleFiles tests rewinding changes across multiple files.\\n   131→func TestE2E_RewindMultipleFiles(t *testing.T) {\\n   132→\\tt.Parallel()\\n   133→\\n   134→\\tenv := NewFeatureBranchEnv(t, \\\"manual-commit\\\")\\n   135→\\n   136→\\t// 1. Agent creates multiple files\\n   137→\\tt.Log(\\\"Step 1: Creating first file\\\")\\n   138→\\tresult, err := env.RunAgent(PromptCreateHelloGo.Prompt)\\n   139→\\trequ