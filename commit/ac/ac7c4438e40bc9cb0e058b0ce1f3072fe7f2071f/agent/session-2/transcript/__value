ath.Dir(sessionFile), 0o750); err != nil {\\n   720→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   721→\\t}\\n   722→\\n   723→\\tfmt.Fprintf(os.Stderr, \\\"Writing transcript to: %s\\\\n\\\", sessionFile)\\n   724→\\tif err := os.WriteFile(sessionFile, content, 0o600); err != nil {\\n   725→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   726→\\t}\\n   727→\\n   728→\\treturn sessionID, nil\\n   729→}\\n   730→\\n   731→// restoreTaskCheckpointTranscript restores a truncated transcript for a task checkpoint.\\n   732→// Uses GetTaskCheckpointTranscript to fetch the transcript from the strategy.\\n   733→//\\n   734→// NOTE: The transcript parsing/truncation/writing pipeline (transcript.ParseFromBytes,\\n   735→// TruncateTranscriptAtUUID, writeTranscript) assumes Claude's JSONL format.\\n   736→// This is acceptable because task checkpoints are currently only created by Claude Code's\\n   737→// PostToolUse hook. If other agents gain sub-agent support, this will need a\\n   738→// format-aware refactor (agent-specific parsing, truncation, and serialization).\\n   739→func restoreTaskCheckpointTranscript(strat strategy.Strategy, point strategy.RewindPoint, sessionID, checkpointUUID string, agent agentpkg.Agent) error {\\n   740→\\t// Get transcript content from strategy\\n   741→\\tcontent, err := strat.GetTaskCheckpointTranscript(point)\\n   742→\\tif err != nil {\\n   743→\\t\\treturn fmt.Errorf(\\\"failed to get task checkpoint transcript: %w\\\", err)\\n   744→\\t}\\n   745→\\n   746→\\t// Parse the transcript\\n   747→\\tparsed, err := transcript.ParseFromBytes(content)\\n   748→\\tif err != nil {\\n   749→\\t\\treturn fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   750→\\t}\\n   751→\\n   752→\\t// Truncate at checkpoint UUID\\n   753→\\ttruncated := TruncateTranscriptAtUUID(parsed, checkpointUUID)\\n   754→\\n   755→\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   756→\\tif err != nil {\\n   757→\\t\\treturn err\\n   758→\\t}\\n   759→\\n   760→\\t// Ensure parent directory exists\\n   761→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   762→\\t\\treturn fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   763→\\t}\\n   764→\\n   765→\\tfmt.Fprintf(os.Stderr, \\\"Writing truncated transcript to: %s\\\\n\\\", sessionFile)\\n   766→\\n   767→\\tif err := writeTranscript(sessionFile, truncated); err != nil {\\n   768→\\t\\treturn fmt.Errorf(\\\"failed to write truncated transcript: %w\\\", err)\\n   769→\\t}\\n   770→\\n   771→\\treturn nil\\n   772→}\\n   773→\\n   774→// handleLogsOnlyRewindInteractive handles rewind for logs-only points with a sub-choice menu.\\n   775→func handleLogsOnlyRewindInteractive(start strategy.Strategy, point strategy.RewindPoint, shortID string) error {\\n   776→\\tvar action string\\n   777→\\n   778→\\tform := NewAccessibleForm(\\n   779→\\t\\thuh.NewGroup(\\n   780→\\t\\t\\thuh.NewSelect[string]().\\n   781→\\t\\t\\t\\tTitle(\\\"Logs-only point: \\\"+shortID).\\n   782→\\t\\t\\t\\tDescription(\\\"This commit has session logs but no checkpoint state. Choose an action:\\\").\\n   783→\\t\\t\\t\\tOptions(\\n   784→\\t\\t\\t\\t\\thuh.NewOption(\\\"Restore logs only (keep current files)\\\", \\\"logs\\\"),\\n   785→\\t\\t\\t\\t\\thuh.NewOption(\\\"Checkout commit (detached HEAD, for viewing)\\\", \\\"checkout\\\"),\\n   786→\\t\\t\\t\\t\\thuh.NewOption(\\\"Reset branch to this commit (destructive!)\\\", \\\"reset\\\"),\\n   787→\\t\\t\\t\\t\\thuh.NewOption(\\\"Cancel\\\", \\\"cancel\\\"),\\n   788→\\t\\t\\t\\t).\\n   789→\\t\\t\\t\\tValue(&action),\\n   790→\\t\\t),\\n   791→\\t)\\n   792→\\n   793→\\tif err := form.Run(); err != nil {\\n   794→\\t\\treturn fmt.Errorf(\\\"action selection cancelled: %w\\\", err)\\n   795→\\t}\\n   796→\\n   797→\\tswitch action {\\n   798→\\tcase \\\"logs\\\":\\n   799→\\t\\treturn handleLogsOnlyRestore(start, point)\\n   800→\\tcase \\\"checkout\\\":\\n   801→\\t\\treturn handleLogsOnlyCheckout(start, point, shortID)\\n   802→\\tcase \\\"reset\\\":\\n   803→\\t\\treturn handleLogsOnlyReset(start, point, shortID)\\n   804→\\tcase \\\"cancel\\\":\\n   805→\\t\\tfmt.Println(\\\"Rewind cancelled.\\\")\\n   806→\\t\\treturn nil\\n   807→\\t}\\n   808→\\n   809→\\treturn nil\\n   810→}\\n   811→\\n   812→// handleLogsOnlyRestore restores only the session logs without changing files.\\n   813→func handleLogsOnlyRestore(start strategy.Strategy, point strategy.RewindPoint) error {\\n   814→\\t// Resolve agent once for use throughout\\n   815→\\tagent, err := getAgent(point.Agent)\\n   816→\\tif err != nil {\\n   817→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   818→\\t}\\n   819→\\n   820→\\t// Initialize logging context with agent from checkpoint\\n   821→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   822→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   823→\\n   824→\\tlogging.Debug(ctx, \\\"logs-only restore started\\\",\\n   825→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   826→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   827→\\t)\\n   828→\\n   829→\\t// Check if strategy supports logs-only restoration\\n   830→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   831→\\tif !ok {\\n   832→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   833→\\t}\\n   834→\\n   835→\\t// Restore logs\\n   836→\\tsessions, err := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   837→\\tif err != nil {\\n   838→\\t\\tlogging.Error(ctx, \\\"logs-only restore failed\\\",\\n   839→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   840→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   841→\\t\\t)\\n   842→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   843→\\t}\\n   844→\\n   845→\\tlogging.Debug(ctx, \\\"logs-only restore completed\\\",\\n   846→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   847→\\t)\\n   848→\\n   849→\\t// Show resume commands for all sessions\\n   850→\\tfmt.Println(\\\"Restored session logs.\\\")\\n   851→\\tprintMultiSessionResumeCommands(sessions)\\n   852→\\treturn nil\\n   853→}\\n   854→\\n   855→// handleLogsOnlyCheckout restores logs and checks out the commit (detached HEAD).\\n   856→func handleLogsOnlyCheckout(start strategy.Strategy, point strategy.RewindPoint, shortID string) error {\\n   857→\\t// Resolve agent once for use throughout\\n   858→\\tagent, err := getAgent(point.Agent)\\n   859→\\tif err != nil {\\n   860→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   861→\\t}\\n   862→\\n   863→\\t// Initialize logging context with agent from checkpoint\\n   864→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   865→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   866→\\n   867→\\tlogging.Debug(ctx, \\\"logs-only checkout started\\\",\\n   868→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   869→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   870→\\t)\\n   871→\\n   872→\\t// First, restore the logs\\n   873→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   874→\\tif !ok {\\n   875→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   876→\\t}\\n   877→\\n   878→\\tsessions, err := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   879→\\tif err != nil {\\n   880→\\t\\tlogging.Error(ctx, \\\"logs-only checkout failed during log restoration\\\",\\n   881→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   882→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   883→\\t\\t)\\n   884→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   885→\\t}\\n   886→\\n   887→\\t// Show warning about detached HEAD\\n   888→\\tvar confirm bool\\n   889→\\tconfirmForm := NewAccessibleForm(\\n   890→\\t\\thuh.NewGroup(\\n   891→\\t\\t\\thuh.NewConfirm().\\n   892→\\t\\t\\t\\tTitle(\\\"Create detached HEAD?\\\").\\n   893→\\t\\t\\t\\tDescription(\\\"This will checkout the commit directly. You'll be in 'detached HEAD' state.\\\\nAny uncommitted changes will be lost!\\\").\\n   894→\\t\\t\\t\\tValue(&confirm),\\n   895→\\t\\t),\\n   896→\\t)\\n   897→\\n   898→\\tif err := confirmForm.Run(); err != nil {\\n   899→\\t\\treturn fmt.Errorf(\\\"confirmation cancelled: %w\\\", err)\\n   900→\\t}\\n   901→\\n   902→\\tif !confirm {\\n   903→\\t\\tfmt.Println(\\\"Checkout cancelled. Session logs were still restored.\\\")\\n   904→\\t\\tprintMultiSessionResumeCommands(sessions)\\n   905→\\t\\treturn nil\\n   906→\\t}\\n   907→\\n   908→\\t// Perform git checkout\\n   909→\\tif err := CheckoutBranch(point.ID); err != nil {\\n   910→\\t\\tlogging.Error(ctx, \\\"logs-only checkout failed during git checkout\\\",\\n   911→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   912→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   913→\\t\\t)\\n   914→\\t\\treturn fmt.Errorf(\\\"failed to checkout commit: %w\\\", err)\\n   915→\\t}\\n   916→\\n   917→\\tlogging.Debug(ctx, \\\"logs-only checkout completed\\\",\\n   918→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   919→\\t)\\n   920→\\n   921→\\tfmt.Printf(\\\"Checked out %s (detached HEAD).\\\\n\\\", shortID)\\n   922→\\tprintMultiSessionResumeCommands(sessions)\\n   923→\\treturn nil\\n   924→}\\n   925→\\n   926→// handleLogsOnlyReset restores logs and resets the branch to the commit (destructive).\\n   927→func handleLogsOnlyReset(start strategy.Strategy, point strategy.RewindPoint, shortID string) error {\\n   928→\\t// Resolve agent once for use throughout\\n   929→\\tagent, agentErr := getAgent(point.Agent)\\n   930→\\tif agentErr != nil {\\n   931→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", agentErr)\\n   932→\\t}\\n   933→\\n   934→\\t// Initialize logging context with agent from checkpoint\\n   935→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   936→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   937→\\n   938→\\tlogging.Debug(ctx, \\\"logs-only reset (interactive) started\\\",\\n   939→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   940→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   941→\\t)\\n   942→\\n   943→\\t// First, restore the logs\\n   944→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   945→\\tif !ok {\\n   946→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   947→\\t}\\n   948→\\n   949→\\tsessions, restoreErr := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   950→\\tif restoreErr != nil {\\n   951→\\t\\tlogging.Error(ctx, \\\"logs-only reset failed during log restoration\\\",\\n   952→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   953→\\t\\t\\tslog.String(\\\"error\\\", restoreErr.Error()),\\n   954→\\t\\t)\\n   955→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", restoreErr)\\n   956→\\t}\\n   957→\\n   958→\\t// Get current HEAD before reset (for recovery message)\\n   959→\\tcurrentHead, err := getCurrentHeadHash()\\n   960→\\tif err != nil {\\n   961→\\t\\t// Non-fatal - just won't show recovery message\\n   962→\\t\\tcurrentHead = \\\"\\\"\\n   963→\\t}\\n   964→\\n   965→\\t// Get detailed uncommitted changes warning from strategy\\n   966→\\tvar uncommittedWarning string\\n   967→\\tif _, warn, err := start.CanRewind(); err == nil {\\n   968→\\t\\tuncommittedWarning = warn\\n   969→\\t}\\n   970→\\n   971→\\t// Check for safety issues\\n   972→\\twarnings, err := checkResetSafety(point.ID, uncommittedWarning)\\n   973→\\tif err != nil {\\n   974→\\t\\treturn fmt.Errorf(\\\"failed to check reset safety: %w\\\", err)\\n   975→\\t}\\n   976→\\n   977→\\t// Build confirmation message based on warnings\\n   978→\\tvar confirmTitle, confirmDesc string\\n   979→\\tif len(warnings) > 0 {\\n   980→\\t\\tconfirmTitle = \\\"⚠️  Reset branch with warnings?\\\"\\n   981→\\t\\tconfirmDesc = \\\"WARNING - the following issues were detected:\\\\n\\\" +\\n   982→\\t\\t\\tstrings.Join(warnings, \\\"\\\\n\\\") +\\n   983→\\t\\t\\t\\\"\\\\n\\\\nThis will move your branch to \\\" + shortID + \\\" and DISCARD commits after it!\\\"\\n   984→\\t} else {\\n   985→\\t\\tconfirmTitle = \\\"Reset branch to \\\" + shortID + \\\"?\\\"\\n   986→\\t\\tconfirmDesc = \\\"This will move your branch pointer to this commit.\\\\nCommits after this point will be orphaned (but recoverable via reflog).\\\"\\n   987→\\t}\\n   988→\\n   989→\\tvar confirm bool\\n   990→\\tconfirmForm := NewAccessibleForm(\\n   991→\\t\\thuh.NewGroup(\\n   992→\\t\\t\\thuh.NewConfirm().\\n   993→\\t\\t\\t\\tTitle(confirmTitle).\\n   994→\\t\\t\\t\\tDescription(confirmDesc).\\n   995→\\t\\t\\t\\tValue(&confirm),\\n   996→\\t\\t),\\n   997→\\t)\\n   998→\\n   999→\\tif err := confirmForm.Run(); err != nil {\\n  1000→\\t\\treturn fmt.Errorf(\\\"confirmation cancelled: %w\\\", err)\\n  1001→\\t}\\n  1002→\\n  1003→\\tif !confirm {\\n  1004→\\t\\tfmt.Println(\\\"Reset cancelled. Session logs were still restored.\\\")\\n  1005→\\t\\tprintMultiSessionResumeCommands(sessions)\\n  1006→\\t\\treturn nil\\n  1007→\\t}\\n  1008→\\n  1009→\\t// Perform git reset --hard\\n  1010→\\tif err := performGitResetHard(point.ID); err != nil {\\n  1011→\\t\\tlogging.Error(ctx, \\\"logs-only reset failed during git reset\\\",\\n  1012→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n  1013→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1014→\\t\\t)\\n  1015→\\t\\treturn fmt.Errorf(\\\"failed to reset branch: %w\\\", err)\\n  1016→\\t}\\n  1017→\\n  1018→\\tlogging.Debug(ctx, \\\"logs-only reset (interactive) completed\\\",\\n  1019→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n  1020→\\t)\\n  1021→\\n  1022→\\tfmt.Printf(\\\"Reset branch to %s.\\\\n\\\", shortID)\\n  1023→\\tprintMultiSe