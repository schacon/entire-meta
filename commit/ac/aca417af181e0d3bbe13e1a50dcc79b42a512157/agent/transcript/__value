   178→// PromptAttribution captures line-level attribution data at the start of each prompt.\\n   179→// By recording what changed since the last checkpoint BEFORE the agent works,\\n   180→// we can accurately separate user edits from agent contributions.\\n   181→type PromptAttribution struct {\\n   182→\\t// CheckpointNumber is which checkpoint this was recorded before (1-indexed)\\n   183→\\tCheckpointNumber int `json:\\\"checkpoint_number\\\"`\\n   184→\\n   185→\\t// UserLinesAdded is lines added by user since the last checkpoint\\n   186→\\tUserLinesAdded int `json:\\\"user_lines_added\\\"`\\n   187→\\n   188→\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   189→\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   190→\\n   191→\\t// AgentLinesAdded is total agent lines added so far (base → last checkpoint).\\n   192→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   193→\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   194→\\n   195→\\t// AgentLinesRemoved is total agent lines removed so far (base → last checkpoint).\\n   196→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   197→\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   198→\\n   199→\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   200→\\t// This enables distinguishing user self-modifications from agent modifications.\\n   201→\\t// See docs/architecture/attribution.md for details.\\n   202→\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   203→}\\n   204→\\n   205→// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   206→// Call this after deserializing a State from JSON.\\n   207→func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   208→\\t// Normalize legacy phase values. \\\"active_committed\\\" was removed with the\\n   209→\\t// 1:1 checkpoint model in favor of the state machine handling commits\\n   210→\\t// during ACTIVE phase with immediate condensation.\\n   211→\\tif s.Phase == \\\"active_committed\\\" {\\n   212→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   213→\\t\\tlogging.Info(logCtx, \\\"migrating legacy active_committed phase to active\\\",\\n   214→\\t\\t\\tslog.String(\\\"session_id\\\", s.SessionID),\\n   215→\\t\\t)\\n   216→\\t\\ts.Phase = PhaseActive\\n   217→\\t}\\n   218→\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n   219→\\ts.Phase = PhaseFromString(string(s.Phase))\\n   220→\\n   221→\\t// Migrate transcript fields: CheckpointTranscriptStart replaces both\\n   222→\\t// CondensedTranscriptLines and TranscriptLinesAtStart from older state files.\\n   223→\\tif s.CheckpointTranscriptStart == 0 {\\n   224→\\t\\tif s.CondensedTranscriptLines > 0 {\\n   225→\\t\\t\\ts.CheckpointTranscriptStart = s.CondensedTranscriptLines\\n   226→\\t\\t} else if s.TranscriptLinesAtStart > 0 {\\n   227→\\t\\t\\ts.CheckpointTranscriptStart = s.TranscriptLinesAtStart\\n   228→\\t\\t}\\n   229→\\t}\\n   230→\\t// Clear deprecated fields so they aren't re-persisted.\\n   231→\\t// Note: this is a one-way migration. If the state is re-saved, older CLI versions\\n   232→\\t// will see 0 for these fields and fall back to scoping from the transcript start.\\n   233→\\t// This is acceptable since CLI upgrades are monotonic and the worst case is\\n   234→\\t// redundant transcript content in a condensation, not data loss.\\n   235→\\ts.CondensedTranscriptLines = 0\\n   236→\\ts.TranscriptLinesAtStart = 0\\n   237→\\n   238→\\t// Backfill AttributionBaseCommit for sessions created before this field existed.\\n   239→\\t// Without this, a mid-turn commit would migrate BaseCommit and the fallback in\\n   240→\\t// calculateSessionAttributions would use the migrated value, producing zero attribution.\\n   241→\\tif s.AttributionBaseCommit == \\\"\\\" && s.BaseCommit != \\\"\\\" {\\n   242→\\t\\ts.AttributionBaseCommit = s.BaseCommit\\n   243→\\t}\\n   244→}\\n   245→\\n   246→// IsStale returns true when a session hasn't seen interaction for longer than\\n   247→// StaleSessionThreshold. Falls back to StartedAt when LastInteractionTime is\\n   248→// nil (sessions created before interaction tracking was added).\\n   249→func (s *State) IsStale() bool {\\n   250→\\tvar since time.Duration\\n   251→\\tif s.LastInteractionTime != nil {\\n   252→\\t\\tsince = time.Since(*s.LastInteractionTime)\\n   253→\\t} else {\\n   254→\\t\\tsince = time.Since(s.StartedAt)\\n   255→\\t}\\n   256→\\treturn since > StaleSessionThreshold\\n   257→}\\n   258→\\n   259→// StateStore provides low-level operations for managing session state files.\\n   260→//\\n   261→// StateStore is a primitive for session state persistence. It is NOT the same as\\n   262→// the Sessions interface - it only handles state files in .git/entire-sessions/,\\n   263→// not the full session data which includes checkpoint content.\\n   264→//\\n   265→// Use StateStore directly in strategies for performance-critical state operations.\\n   266→// Use the Sessions interface (when implemented) for high-level session management.\\n   267→type StateStore struct {\\n   268→\\t// stateDir is the directory where session state files are stored\\n   269→\\tstateDir string\\n   270→}\\n   271→\\n   272→// NewStateStore creates a new state store.\\n   273→// Uses the git common dir to store session state (shared across worktrees).\\n   274→func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   275→\\tcommonDir, err := getGitCommonDir(ctx)\\n   276→\\tif err != nil {\\n   277→\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   278→\\t}\\n   279→\\treturn &StateStore{\\n   280→\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   281→\\t}, nil\\n   282→}\\n   283→\\n   284→// NewStateStoreWithDir creates a new state store with a custom directory.\\n   285→// This is useful for testing.\\n   286→func NewStateStoreWithDir(stateDir string) *StateStore {\\n   287→\\treturn &StateStore{stateDir: stateDir}\\n   288→}\\n   289→\\n   290→// Load loads the session state for the given session ID.\\n   291→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   292→// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   293→func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   294→\\t// Validate session ID to prevent path traversal\\n   295→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   296→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   297→\\t}\\n   298→\\n   299→\\tstateFile := s.stateFilePath(sessionID)\\n   300→\\n   301→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is derived from sessionID\\n   302→\\tif os.IsNotExist(err) {\\n   303→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   304→\\t}\\n   305→\\tif err != nil {\\n   306→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   307→\\t}\\n   308→\\n   309→\\tvar state State\\n   310→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   311→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal session state: %w\\\", err)\\n   312→\\t}\\n   313→\\tstate.NormalizeAfterLoad(ctx)\\n   314→\\n   315→\\tif state.IsStale() {\\n   316→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   317→\\t\\tlogging.Debug(logCtx, \\\"deleting stale session state\\\",\\n   318→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   319→\\t\\t)\\n   320→\\t\\t_ = s.Clear(ctx, sessionID) //nolint:errcheck // best-effort cleanup of stale session\\n   321→\\t\\treturn nil, nil             //nolint:nilnil // stale session treated as not found\\n   322→\\t}\\n   323→\\n   324→\\treturn &state, nil\\n   325→}\\n   326→\\n   327→// Save saves the session state atomically.\\n   328→func (s *StateStore) Save(ctx context.Context, state *State) error {\\n   329→\\t_ = ctx // Reserved for future use\\n   330→\\n   331→\\t// Validate session ID to prevent path traversal\\n   332→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n   333→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   334→\\t}\\n   335→\\n   336→\\tif err := os.MkdirAll(s.stateDir, 0o750); err != nil {\\n   337→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   338→\\t}\\n   339→\\n   340→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   341→\\tif err != nil {\\n   342→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   343→\\t}\\n   344→\\n   345→\\tstateFile := s.stateFilePath(state.SessionID)\\n   346→\\n   347→\\t// Atomic write: write to temp file, then rename\\n   348→\\ttmpFile := stateFile + \\\".tmp\\\"\\n   349→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n   350→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   351→\\t}\\n   352→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n   353→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n   354→\\t}\\n   355→\\treturn nil\\n   356→}\\n   357→\\n   358→// Clear removes the session state file for the given session ID.\\n   359→func (s *StateStore) Clear(ctx context.Context, sessionID string) error {\\n   360→\\t_ = ctx // Reserved for future use\\n   361→\\n   362→\\t// Validate session ID to prevent path traversal\\n   363→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   364→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   365→\\t}\\n   366→\\n   367→\\t// Remove all files for this session (state .json, .model hint, any future hint files).\\n   368→\\tmatches, _ := filepath.Glob(filepath.Join(s.stateDir, sessionID+\\\".*\\\")) //nolint:errcheck // pattern is always valid\\n   369→\\tfor _, f := range matches {\\n   370→\\t\\t_ = os.Remove(f)\\n   371→\\t}\\n   372→\\n   373→\\treturn nil\\n   374→}\\n   375→\\n   376→// RemoveAll removes the entire session state directory.\\n   377→// This is used during uninstall to completely remove all session state.\\n   378→func (s *StateStore) RemoveAll() error {\\n   379→\\tif err := os.RemoveAll(s.stateDir); err != nil {\\n   380→\\t\\treturn fmt.Errorf(\\\"failed to remove session state directory: %w\\\", err)\\n   381→\\t}\\n   382→\\treturn nil\\n   383→}\\n   384→\\n   385→// List returns all session states.\\n   386→func (s *StateStore) List(ctx context.Context) ([]*State, error) {\\n   387→\\tentries, err := os.ReadDir(s.stateDir)\\n   388→\\tif os.IsNotExist(err) {\\n   389→\\t\\treturn nil, nil\\n   390→\\t}\\n   391→\\tif err != nil {\\n   392→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state directory: %w\\\", err)\\n   393→\\t}\\n   394→\\n   395→\\tvar states []*State\\n   396→\\tfor _, entry := range entries {\\n   397→\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   398→\\t\\t\\tcontinue\\n   399→\\t\\t}\\n   400→\\t\\tif strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   401→\\t\\t\\tcontinue // Skip temp files\\n   402→\\t\\t}\\n   403→\\n   404→\\t\\tsessionID := strings.TrimSuffix(entry.Name(), \\\".json\\\")\\n   405→\\t\\tstate, err := s.Load(ctx, sessionID)\\n   406→\\t\\tif err != nil {\\n   407→\\t\\t\\tcontinue // Skip corrupted state files\\n   408→\\t\\t}\\n   409→\\t\\tif state == nil {\\n   410→\\t\\t\\tcontinue // Not found or stale (Load handles cleanup)\\n   411→\\t\\t}\\n   412→\\n   413→\\t\\tstates = append(states, state)\\n   414→\\t}\\n   415→\\treturn states, nil\\n   416→}\\n   417→\\n   418→// stateFilePath returns the path to a session state file.\\n   419→func (s *StateStore) stateFilePath(sessionID string) string {\\n   420→\\treturn filepath.Join(s.stateDir, sessionID+\\\".json\\\")\\n   421→}\\n   422→\\n   423→// gitCommonDirCache caches the git common dir to avoid repeated subprocess calls.\\n   424→// Keyed by working directory to handle directory changes (same pattern as paths.WorktreeRoot).\\n   425→var (\\n   426→\\tgitCommonDirMu       sync.RWMutex\\n   427→\\tgitCommonDirCache    string\\n   428→\\tgitCommonDirCacheDir string\\n   429→)\\n   430→\\n   431→// ClearGitCommonDirCache clears the cached git common dir.\\n   432→// Useful for testing when changing directories.\\n   433→func ClearGitCommonDirCache() {\\n   434→\\tgitCommonDirMu.Lock()\\n   435→\\tgitCommonDirCache = \\\"\\\"\\n   436→\\tgitCommonDirCacheDir = \\\"\\\"\\n   437→\\tgitCommonDirMu.Unlock()\\n   438→}\\n   439→\\n   440→// getGitCommonDir returns the path to the shared git directory.\\n   441→// In a regular checkout, this is .git/\\n   442→// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n   443→// The result is cached per working directory.\\n   444→func getGitCommonDir(ctx context.Context) (string, error) {\\n   445→\\tcwd, err := os.Getwd() //nolint:forbidigo // used for cache key, not git-relative paths\\n   446→\\tif err != nil {\\n   447→\\t\\tcwd = \\\"\\\"\\n   448→\\t}\\n   449→\\n   450→\\t// Check cache with read lock first\\n   451→\\tgitCommonDirMu.RLock()\\n   452→\\tif gitCommonDirCache != \\\"\\\" && gitCommonDirCacheDir == cwd {\\n   453→\\t\\tcached := gitCommonDirCache\\n   454→\\t\\tgitCommonDirMu.RUnlock()\\n   455→\\t\\treturn cached, nil\\n   456→\\t}\\n   457→\\tgitCommonDirMu.RUnlock()\\n   458→\\n   459→\\t// Cache miss — resolve via git subprocess\\n   460→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-common-dir\\\")\\n   461→\\tcmd.Dir = \\\".\\\"\\n   462→\\toutput, err := cmd.Output()\\n   463→\\tif err != nil {\\n   464→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   465→\\t}\\n   466→\\n   467→\\tcommonDir := strings.TrimSpace(string(output))\\n   468→\\n   469→\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\n   470→\\t// so we need to make it absolute if it isn't already\\n   471→\\tif !filepath.IsAbs(commonDir) {\\n   472→\\t\\tcommonDir = filepath.Join(\\\".\\\", commonDir)\\n   473→\\t}\\n   474→\\tcommonDir = filepath.Clean(commonDir)\\n   475→\\n   476→\\tgitCommonDirMu.Lock()\\n   477→\\tgitCommonDirCache = commonDir\\n   478→\\tgitCommonDirCacheDir = cwd\\n   479→\\tgitCommonDirMu.Unlock()\\n   480→\\n   481→\\treturn commonDir, nil\\n   482→}\\n   483→\"}]},\"uuid\":\"d2dd0c45-724f-4715-b8a0-6c79af19748d\",\"timestamp\":\"2026-03-06T09:35:48.420Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a06cfa9d33cf16fc8\"},\"toolUseID\":\"agent_msg_01XSDr8jBWbdwcFV35eXq8X5\",\"parentToolUseID\":\"toolu_01UWDnAr5aaAjsAFwPivhPYC\",\"uuid\":\"47b1a5f8-cce8-4b7a-9590-37d093478aed\",\"timestamp\":\"2026-03-06T09:35:48.421Z\"}\n{\"parentUuid\":\"47b1a5f8-cce8-4b7a-9590-37d093478aed\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/4\",\"sessionId\":\"26fd10e5-9929-4364-b5e7-540290e8931b\",\"version\":\"2.1.70\",\"gitBranch\":\"alex/stop-hook-updates-remote-checkpoints\",\"slug\":\"composed-humming-rocket\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-06T09:35:48.433Z\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_011EPRhGGQzENZH5mbxhz4N9\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01LyLyHviGaBtBkhLdfh4v5U\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/alex/workspace/cli/.worktrees/4/cmd/entire/cli/strategy/manual_commit_session.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":3,\"cache_creation_input_tokens\":5599,\"ca