    string\\n    26→\\tHeadBefore       string\\n    27→\\tCheckpointBefore string\\n    28→\\tConsoleLog       *os.File\\n    29→\\tsession          agents.Session // interactive session, if started via StartSession\\n    30→\\tskipArtifacts    bool           // suppresses artifact capture on scenario restart\\n    31→}\\n    32→\\n    33→// SetupRepo creates a fresh git repository in a temporary directory, seeds it\\n    34→// with an initial commit, and runs `entire enable` for the given agent.\\n    35→// Artifact capture is registered as a cleanup function.\\n    36→//\\n    37→// When E2E_KEEP_REPOS is set, the temporary directory is not cleaned up\\n    38→// so it can be inspected after the test. A symlink in the artifact dir\\n    39→// points to the preserved repo.\\n    40→func SetupRepo(t *testing.T, agent agents.Agent) *RepoState {\\n    41→\\tt.Helper()\\n    42→\\n    43→\\tkeepRepos := os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\"\\n    44→\\n    45→\\t// Always use os.MkdirTemp instead of t.TempDir(). Go's t.TempDir()\\n    46→\\t// creates nested subdirectories (TestName.../001/) whose structure\\n    47→\\t// confuses some agents' (e.g. opencode) working-directory resolution.\\n    48→\\tdir, err := os.MkdirTemp(\\\"\\\", \\\"e2e-repo-*\\\")\\n    49→\\tif err != nil {\\n    50→\\t\\tt.Fatalf(\\\"create temp dir: %v\\\", err)\\n    51→\\t}\\n    52→\\tif keepRepos {\\n    53→\\t\\tt.Logf(\\\"E2E_KEEP_REPOS: repo will be preserved at %s\\\", dir)\\n    54→\\t} else {\\n    55→\\t\\tt.Cleanup(func() { os.RemoveAll(dir) })\\n    56→\\t}\\n    57→\\n    58→\\t// Resolve symlinks (macOS: /var -> /private/var) so paths match\\n    59→\\t// what agent CLIs see when they resolve their own CWD.\\n    60→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n    61→\\t\\tdir = resolved\\n    62→\\t}\\n    63→\\n    64→\\tGit(t, dir, \\\"init\\\")\\n    65→\\tGit(t, dir, \\\"config\\\", \\\"user.name\\\", \\\"E2E Test\\\")\\n    66→\\tGit(t, dir, \\\"config\\\", \\\"user.email\\\", \\\"e2e@test.local\\\")\\n    67→\\tGit(t, dir, \\\"commit\\\", \\\"--allow-empty\\\", \\\"-m\\\", \\\"initial commit\\\")\\n    68→\\n    69→\\tentire.Enable(t, dir, agent.EntireAgent())\\n    70→\\tif agent.Name() == \\\"factoryai-droid\\\" {\\n    71→\\t\\tif err := configureDroidRepoSettings(dir); err != nil {\\n    72→\\t\\t\\tt.Fatalf(\\\"configure droid repo settings: %v\\\", err)\\n    73→\\t\\t}\\n    74→\\t}\\n    75→\\tPatchSettings(t, dir, map[string]any{\\\"log_level\\\": \\\"debug\\\"})\\n    76→\\n    77→\\t// OpenCode's non-interactive mode auto-rejects external_directory permission\\n    78→\\t// since there's no user to prompt. Write a config to allow it.\\n    79→\\tif agent.Name() == \\\"opencode\\\" {\\n    80→\\t\\tcfg := `{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}}`\\n    81→\\t\\tif key := os.Getenv(\\\"ANTHROPIC_API_KEY\\\"); key != \\\"\\\" {\\n    82→\\t\\t\\tcfg = fmt.Sprintf(`{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}, \\\"provider\\\": {\\\"anthropic\\\": {\\\"options\\\": {\\\"apiKey\\\": %q}}}}`, key)\\n    83→\\t\\t}\\n    84→\\t\\tif err := os.WriteFile(filepath.Join(dir, \\\"opencode.json\\\"), []byte(cfg+\\\"\\\\n\\\"), 0o644); err != nil {\\n    85→\\t\\t\\tt.Fatalf(\\\"write opencode.json: %v\\\", err)\\n    86→\\t\\t}\\n    87→\\t}\\n    88→\\n    89→\\t// Create artifact dir eagerly so console.log is written to disk\\n    90→\\t// incrementally. Even if the test is killed by a global timeout,\\n    91→\\t// partial output survives.\\n    92→\\tartDir := artifactDir(t)\\n    93→\\tconsoleLog, err := os.Create(filepath.Join(artDir, \\\"console.log\\\"))\\n    94→\\tif err != nil {\\n    95→\\t\\tt.Fatalf(\\\"create console.log: %v\\\", err)\\n    96→\\t}\\n    97→\\n    98→\\tstate := &RepoState{\\n    99→\\t\\tAgent:            agent,\\n   100→\\t\\tDir:              dir,\\n   101→\\t\\tArtifactDir:      artDir,\\n   102→\\t\\tHeadBefore:       GitOutput(t, dir, \\\"rev-parse\\\", \\\"HEAD\\\"),\\n   103→\\t\\tCheckpointBefore: GitOutput(t, dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\"),\\n   104→\\t\\tConsoleLog:       consoleLog,\\n   105→\\t}\\n   106→\\n   107→\\tt.Cleanup(func() {\\n   108→\\t\\t_ = consoleLog.Close()\\n   109→\\t\\tif !state.skipArtifacts {\\n   110→\\t\\t\\tCaptureArtifacts(t, state)\\n   111→\\t\\t}\\n   112→\\t})\\n   113→\\n   114→\\treturn state\\n   115→}\\n   116→\\n   117→func configureDroidRepoSettings(repoDir string) error {\\n   118→\\thome, err := os.UserHomeDir()\\n   119→\\tif err != nil {\\n   120→\\t\\treturn fmt.Errorf(\\\"get home dir: %w\\\", err)\\n   121→\\t}\\n   122→\\n   123→\\tglobalSettingsPath := filepath.Join(home, \\\".factory\\\", \\\"settings.json\\\")\\n   124→\\trepoSettingsPath := filepath.Join(repoDir, droidRepoSettingsPath)\\n   125→\\n   126→\\tif err := mergeDroidCustomModels(globalSettingsPath, repoSettingsPath); err != nil {\\n   127→\\t\\treturn err\\n   128→\\t}\\n   129→\\tif err := ensureGitInfoExcludeContains(repoDir, droidRepoSettingsPath); err != nil {\\n   130→\\t\\treturn fmt.Errorf(\\\"exclude droid settings from git: %w\\\", err)\\n   131→\\t}\\n   132→\\treturn nil\\n   133→}\\n   134→\\n   135→func mergeDroidCustomModels(globalSettingsPath, repoSettingsPath string) error {\\n   136→\\tglobalSettings, err := loadJSONMap(globalSettingsPath, \\\"global droid settings\\\")\\n   137→\\tif err != nil {\\n   138→\\t\\treturn err\\n   139→\\t}\\n   140→\\n   141→\\tcustomModels, ok := globalSettings[\\\"customModels\\\"]\\n   142→\\tif !ok {\\n   143→\\t\\treturn fmt.Errorf(\\n   144→\\t\\t\\t\\\"global droid settings at %s missing customModels; repo-local %s shadows global settings\\\",\\n   145→\\t\\t\\tglobalSettingsPath,\\n   146→\\t\\t\\trepoSettingsPath,\\n   147→\\t\\t)\\n   148→\\t}\\n   149→\\n   150→\\tvar models []json.RawMessage\\n   151→\\tif err := json.Unmarshal(customModels, &models); err != nil {\\n   152→\\t\\treturn fmt.Errorf(\\\"parse customModels in %s: %w\\\", globalSettingsPath, err)\\n   153→\\t}\\n   154→\\tif len(models) == 0 {\\n   155→\\t\\treturn fmt.Errorf(\\\"global droid settings at %s has empty customModels\\\", globalSettingsPath)\\n   156→\\t}\\n   157→\\n   158→\\trepoSettings, err := loadJSONMap(repoSettingsPath, \\\"repo-local droid settings\\\")\\n   159→\\tif err != nil {\\n   160→\\t\\treturn err\\n   161→\\t}\\n   162→\\trepoSettings[\\\"customModels\\\"] = customModels\\n   163→\\n   164→\\t// Set the active custom model so interactive mode uses the BYOK model\\n   165→\\t// instead of prompting for selection. The value must match the Model\\n   166→\\t// field from the customModels entry (not the displayName).\\n   167→\\tmodelJSON, err := json.Marshal(agents.DefaultDroidModel())\\n   168→\\tif err != nil {\\n   169→\\t\\treturn fmt.Errorf(\\\"marshal model setting: %w\\\", err)\\n   170→\\t}\\n   171→\\trepoSettings[\\\"model\\\"] = json.RawMessage(modelJSON)\\n   172→\\n   173→\\t// High autonomy prevents Droid from asking for confirmation during\\n   174→\\t// interactive E2E tests, which would cause hangs waiting for input.\\n   175→\\trepoSettings[\\\"autonomyMode\\\"] = json.RawMessage(`\\\"auto-high\\\"`)\\n   176→\\trepoSettings[\\\"completionSound\\\"] = json.RawMessage(`\\\"off\\\"`)\\n   177→\\n   178→\\tout, err := json.MarshalIndent(repoSettings, \\\"\\\", \\\"  \\\")\\n   179→\\tif err != nil {\\n   180→\\t\\treturn fmt.Errorf(\\\"marshal repo-local droid settings: %w\\\", err)\\n   181→\\t}\\n   182→\\tout = append(out, '\\\\n')\\n   183→\\n   184→\\tif err := os.WriteFile(repoSettingsPath, out, 0o600); err != nil {\\n   185→\\t\\treturn fmt.Errorf(\\\"write repo-local droid settings %s: %w\\\", repoSettingsPath, err)\\n   186→\\t}\\n   187→\\treturn nil\\n   188→}\\n   189→\\n   190→func loadJSONMap(path, description string) (map[string]json.RawMessage, error) {\\n   191→\\tdata, err := os.ReadFile(path)\\n   192→\\tif err != nil {\\n   193→\\t\\treturn nil, fmt.Errorf(\\\"read %s at %s: %w\\\", description, path, err)\\n   194→\\t}\\n   195→\\n   196→\\tvar parsed map[string]json.RawMessage\\n   197→\\tif err := json.Unmarshal(data, &parsed); err != nil {\\n   198→\\t\\treturn nil, fmt.Errorf(\\\"parse %s at %s: %w\\\", description, path, err)\\n   199→\\t}\\n   200→\\tif parsed == nil {\\n   201→\\t\\tparsed = make(map[string]json.RawMessage)\\n   202→\\t}\\n   203→\\treturn parsed, nil\\n   204→}\\n   205→\\n   206→func ensureGitInfoExcludeContains(repoDir, entry string) error {\\n   207→\\texcludePath := filepath.Join(repoDir, \\\".git\\\", \\\"info\\\", \\\"exclude\\\")\\n   208→\\n   209→\\tdata, err := os.ReadFile(excludePath)\\n   210→\\tif err != nil && !errors.Is(err, os.ErrNotExist) {\\n   211→\\t\\treturn fmt.Errorf(\\\"read %s: %w\\\", excludePath, err)\\n   212→\\t}\\n   213→\\n   214→\\tnormalized := strings.ReplaceAll(string(data), \\\"\\\\r\\\\n\\\", \\\"\\\\n\\\")\\n   215→\\tfor _, line := range strings.Split(normalized, \\\"\\\\n\\\") {\\n   216→\\t\\tif strings.TrimSpace(line) == entry {\\n   217→\\t\\t\\treturn nil\\n   218→\\t\\t}\\n   219→\\t}\\n   220→\\n   221→\\tvar b strings.Builder\\n   222→\\tif len(data) > 0 {\\n   223→\\t\\tb.Write(data)\\n   224→\\t\\tif data[len(data)-1] != '\\\\n' {\\n   225→\\t\\t\\tb.WriteByte('\\\\n')\\n   226→\\t\\t}\\n   227→\\t}\\n   228→\\tb.WriteString(entry)\\n   229→\\tb.WriteByte('\\\\n')\\n   230→\\n   231→\\tif err := os.MkdirAll(filepath.Dir(excludePath), 0o755); err != nil {\\n   232→\\t\\treturn fmt.Errorf(\\\"create %s: %w\\\", filepath.Dir(excludePath), err)\\n   233→\\t}\\n   234→\\tif err := os.WriteFile(excludePath, []byte(b.String()), 0o644); err != nil {\\n   235→\\t\\treturn fmt.Errorf(\\\"write %s: %w\\\", excludePath, err)\\n   236→\\t}\\n   237→\\treturn nil\\n   238→}\\n   239→\\n   240→// ForEachAgent runs fn as a parallel subtest for every registered agent.\\n   241→// It handles repo setup, concurrency gating, context timeout, and cleanup.\\n   242→// The timeout is scaled by each agent's TimeoutMultiplier.\\n   243→//\\n   244→// If RunPrompt detects a transient API error (e.g. rate limit, token refresh\\n   245→// failure), it panics with errScenarioRestart. ForEachAgent recovers from the\\n   246→// panic and restarts the entire scenario with a fresh repository, up to\\n   247→// maxScenarioRestarts times. This avoids stale CLI session state from the\\n   248→// failed attempt poisoning the retry.\\n   249→func ForEachAgent(t *testing.T, timeout time.Duration, fn func(t *testing.T, s *RepoState, ctx context.Context)) {\\n   250→\\tt.Helper()\\n   251→\\tt.Parallel()\\n   252→\\tall := agents.All()\\n   253→\\tif len(all) == 0 {\\n   254→\\t\\tt.Skip(\\\"no agents registered (check E2E_AGENT filter)\\\")\\n   255→\\t}\\n   256→\\tfor _, agent := range all {\\n   257→\\t\\tt.Run(agent.Name(), func(t *testing.T) {\\n   258→\\t\\t\\t// Use the global test deadline for slot wait so we don't\\n   259→\\t\\t\\t// skip prematurely — only bail if the whole binary is dying.\\n   260→\\t\\t\\tslotCtx := context.Background()\\n   261→\\t\\t\\tif deadline, ok := t.Deadline(); ok {\\n   262→\\t\\t\\t\\tvar cancel context.CancelFunc\\n   263→\\t\\t\\t\\tslotCtx, cancel = context.WithDeadline(slotCtx, deadline)\\n   264→\\t\\t\\t\\tdefer cancel()\\n   265→\\t\\t\\t}\\n   266→\\t\\t\\tif err := agents.AcquireSlot(slotCtx, agent); err != nil {\\n   267→\\t\\t\\t\\tt.Fatalf(\\\"timed out waiting for agent slot: %v\\\", err)\\n   268→\\t\\t\\t}\\n   269→\\t\\t\\tdefer agents.ReleaseSlot(agent)\\n   270→\\n   271→\\t\\t\\t// Per-test timeout starts after slot is acquired, scaled\\n   272→\\t\\t\\t// by the agent's multiplier (e.g. 2.5× for gemini).\\n   273→\\t\\t\\tscaled := time.Duration(float64(timeout) * agent.TimeoutMultiplier())\\n   274→\\n   275→\\t\\t\\tvar prevState *RepoState\\n   276→\\t\\t\\tfor attempt := range maxScenarioRestarts + 1 {\\n   277→\\t\\t\\t\\ts := SetupRepo(t, agent)\\n   278→\\t\\t\\t\\tctx, cancel := context.WithTimeout(context.Background(), scaled)\\n   279→\\n   280→\\t\\t\\t\\t// On restart, suppress artifact capture from the previous\\n   281→\\t\\t\\t\\t// failed attempt so it doesn't overwrite the final one.\\n   282→\\t\\t\\t\\tif prevState != nil {\\n   283→\\t\\t\\t\\t\\tprevState.skipArtifacts = true\\n   284→\\t\\t\\t\\t}\\n   285→\\n   286→\\t\\t\\t\\trestarted := runScenario(t, s, ctx, fn)\\n   287→\\t\\t\\t\\tcancel()\\n   288→\\n   289→\\t\\t\\t\\tif !restarted {\\n   290→\\t\\t\\t\\t\\treturn\\n   291→\\t\\t\\t\\t}\\n   292→\\t\\t\\t\\tprevState = s\\n   293→\\t\\t\\t\\tif attempt >= maxScenarioRestarts {\\n   294→\\t\\t\\t\\t\\tt.Fatalf(\\\"exhausted %d scenario attempts due to transient API errors\\\", maxScenarioRestarts+1)\\n   295→\\t\\t\\t\\t}\\n   296→\\t\\t\\t\\tt.Logf(\\\"transient error, restarting scenario (attempt %d/%d)\\\", attempt+2, maxScenarioRestarts+1)\\n   297→\\t\\t\\t}\\n   298→\\t\\t})\\n   299→\\t}\\n   300→}\\n   301→\\n   302→// runScenario runs the test function and recovers from errScenarioRestart\\n   303→// panics triggered by transient API errors in RunPrompt. Returns true if\\n   304→// the scenario should be restarted with a fresh repository.\\n   305→func runScenario(t *testing.T, s *RepoState, ctx context.Context, fn func(t *testing.T, s *RepoState, ctx context.Context)) (restarted bool) {\\n   306→\\tt.Helper()\\n   307→\\tdefer func() {\\n   308→\\t\\tif r := recover(); r != nil {\\n   309→\\t\\t\\tif _, ok := r.(errScenarioRestart); ok {\\n   310→\\t\\t\\t\\trestarted = true\\n   311→\\t\\t\\t\\treturn\\n   312→\\t\\t\\t}\\n   313→\\t\\t\\tpanic(r) // re-panic for unexpected panics\\n   314→\\t\\t}\\n   315→\\t}()\\n   316→\\tfn(t, s, ctx)\\n   317→\\treturn false\\n   318→}\\n   319→\\n   320→const maxScenarioRestarts = 2 // restart up to 2 times = 3 total attempts\\n   321→\\n   322→// errScenarioRestart is panicked by RunPrompt when a transient API error is\\n   323→// detected. ForEachAgent recovers from this panic and restarts the test\\n   324→// scenario with a fresh repository, avoiding stale CLI state from the failed\\n   325→// attempt.\\n   326→type errScenarioRestart struct {\\n   327→\\tmsg string\\n   328→}\\n   329→\\n   330→// RunPrompt runs an agent prompt, logs the command and output to ConsoleLog,\\n   331→// and returns the result. If the agent reports a transient API error, it\\n   332→// panics with errScenarioRestart to trigger a full scenario restart in\\n   333→// ForEachAgent (see runScenario).\\n   334→func (s *RepoState) RunPrompt(t *testing.T, ctx context.Context, prompt string, opts ...agents.Option) (agents.Output, error) {\\n   335→\\tt.Helper()\\n   336→\\tout, err := s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n   337→\\ts.logPromptResult(out)\\n   338→\\n   339→\\tif err != nil && s.Agent.IsTransientError(out, err) {\\n   340→\\t\\terrMsg := fmt.Sprintf(\\\"transient API error (stderr: %s)\\\", strings.TrimSpace(out.Stderr))\\n   341→\\t\\tt.Logf(\\\"%s — restarting scenario\\\", errMsg)\\n   342→\\t\\tfmt.Fprintf(s.ConsoleLog, \\\"> [transient] %s — restarting scenario\\\\n\\\", errMsg)\\n   343→\\t\\tpanic(errScenarioRestart{msg: errMsg})\\n   344→\\t}\\n   345→\\n   346→\\treturn out, err\\n   347→}\\n   348→\\n   349→func (s *RepoState) logPromptResult(out agents.Output) {\\n   350→\\ts.ConsoleLog.WriteString(\\\"> \\\" + out.Command + \\\"\\\\n\\\")\\n   351→\\ts.ConsoleLog.WriteString(\\\"stdout:\\\\n\\\" + out.Stdout + \\\"\\\\n\\\")\\n   352→\\ts.ConsoleLog.WriteString(\\\"stderr:\\\\n\\\" + out.Stderr + \\\"\\\\n\\\")\\n   353→}\\n   354→\\n   355→// Git runs a git command in the repo and logs it to ConsoleLog.\\n   356→func (s *RepoState) Git(t *testing.T, args ...string) {\\n   357→\\tt.Helper()\\n   358→\\ts.ConsoleLog.WriteString(\\\"> git \\\" + strings.Join(args, \\\" \\\") + \\\"\\\\n\\\")\\n   359→\\tGit(t, s.Dir, args...)\\n   360→}\\n   361→\\n   362→// StartSession starts an interactive session and registers it for pane\\n   363→// capture in artifacts. Returns nil if the agent does not support interactive\\n   364→// mode. The session is closed automatically during test cleanup.\\n   365→func (s *RepoState) StartSession(t *testing.T, ctx context.Context) agents.Session {\\n   366→\\tt.Helper()\\n   367→\\tsession, err := s.Agent.StartSession(ctx, s.Dir)\\n   368→\\tif err != nil {\\n   369→\\t\\tt.Fatalf(\\\"start session: %v\\\", err)\\n   370→\\t}\\n   371→\\tif session == nil {\\n   372→\\t\\treturn nil\\n   373→\\t}\\n   374→\\ts.session = session\\n   375→\\treturn session\\n   376→}\\n   377→\\n   378→// WaitFor waits for a pattern in the interactive session's pane and logs the\\n   379→// pane content to ConsoleLog after the wait completes (success or failure).\\n   380→func (s *RepoState) WaitFor(t *testing.T, session agents.Session, pattern string, timeout time.Duration) {\\n   381→\\tt.Helper()\\n   382→\\tcontent, err := session.WaitFor(pattern, timeout)\\n   383→\\tfmt.Fprintf(s.ConsoleLog, \\\"> pane after WaitFor(%q):\\\\n%s\\\\n\\\", pattern, content)\\n   384→\\tif err != nil {\\n   385→\\t\\tt.Fatalf(\\\"WaitFor(%q): %v\\\", pattern, err)\\n   386→\\t}\\n   387→}\\n   388→\\n   389→// Send sends input to an interactive session and logs it to ConsoleLog.\\n   390→// Fails the test on error.\\n   391→func (s *RepoState) Send(t *testing.T, session agents.Session, input string) {\\n   392→\\tt.Helper()\\n   393→\\ts.ConsoleLog.WriteString(\\\"> send: \\\" + input + \\\"\\\\n\\\")\\n   394→\\tif err := session.Send(input); err != nil {\\n   395→\\t\\tt.Fatalf(\\\"send failed: %v\\\", err)\\n   396→\\t}\\n   397→}\\n   398→\\n   399→// PatchSettings merges extra keys into .entire/settings.json.\\n   400→func PatchSettings(t *testing.T, dir string, extra map[string]any) {\\n   401→\\tt.Helper()\\n   402→\\tpath