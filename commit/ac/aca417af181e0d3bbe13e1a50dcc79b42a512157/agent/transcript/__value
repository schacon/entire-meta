   111→// fileExt is the shared file extension pattern used across all prompt-parsing regexes.\\n   112→const fileExt = `go|md|txt|js|ts|py|rb|rs|toml|yaml|json`\\n   113→\\n   114→var (\\n   115→\\t// \\\"create a [single|new|...] [markdown|text] file [at|called] <path>\\\"\\n   116→\\tcreateFileRe = regexp.MustCompile(`(?i)create\\\\s+(?:a\\\\s+)?(?:\\\\w+\\\\s+)*?(?:markdown\\\\s+|text\\\\s+)?file\\\\s+(?:at\\\\s+|called\\\\s+)?([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   117→\\t// \\\"create N files: <path> about <topic>, <path> about <topic>\\\"\\n   118→\\tcreateMultiRe = regexp.MustCompile(`(?i)create\\\\s+(?:\\\\w+\\\\s+)*?(?:four|three|two|\\\\d+)\\\\s+(?:\\\\w+\\\\s+)*?(?:markdown\\\\s+)?files?:?\\\\s+(.+)`)\\n   119→\\t// \\\"modify <path>\\\"\\n   120→\\tmodifyFileRe = regexp.MustCompile(`(?i)modify\\\\s+(?:the\\\\s+)?(?:file\\\\s+)?(?:at\\\\s+)?([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   121→\\t// \\\"modify [these] N [existing] files[:]\\\"\\n   122→\\tmodifyMultiRe = regexp.MustCompile(`(?i)modify\\\\s+(?:these\\\\s+)?(?:three|four|two|\\\\d+)\\\\s+(?:\\\\w+\\\\s+)*?files?[.:]\\\\s*(.+)`)\\n   123→\\t// \\\"add ... to <path>\\\" (e.g. \\\"add another stanza to poem.txt\\\")\\n   124→\\taddToFileRe = regexp.MustCompile(`(?i)add\\\\s+(?:another\\\\s+|a\\\\s+|some\\\\s+)?\\\\w+\\\\s+to\\\\s+([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   125→\\t// \\\"delete <path>\\\"\\n   126→\\tdeleteFileRe = regexp.MustCompile(`(?i)delete\\\\s+(?:the\\\\s+)?(?:file\\\\s+)?(?:at\\\\s+)?([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   127→\\t// \\\"commit\\\" anywhere in the prompt, but not \\\"do not commit\\\" / \\\"don't commit\\\"\\n   128→\\tcommitRe = regexp.MustCompile(`(?i)(?:then\\\\s+|now\\\\s+)?(?:git\\\\s+)?commit\\\\b`)\\n   129→\\t// Negative: \\\"do not commit\\\" / \\\"don't commit\\\" with optional object, at sentence boundary\\n   130→\\t// Matches: \\\"Do not commit.\\\", \\\"Do not commit the file.\\\", \\\"Do not commit them,\\\"\\n   131→\\t// Does NOT match: \\\"Do not commit any other files\\\" (different intent)\\n   132→\\tnoCommitRe = regexp.MustCompile(`(?i)(?:do\\\\s+not|don'?t)\\\\s+commit(?:\\\\s+(?:it|them|the\\\\s+\\\\w+))?(?:\\\\.|,|$)`)\\n   133→\\t// \\\"commit each file separately\\\" — interleave create+commit\\n   134→\\tcommitSeparatelyRe = regexp.MustCompile(`(?i)commit\\\\s+each\\\\s+file\\\\s+separately`)\\n   135→\\t// Individual file in multi-create: \\\"docs/a.md about apples\\\"\\n   136→\\t// Topic capture stops at comma, \\\"and\\\", period followed by space+uppercase, or end\\n   137→\\tmultiFileItemRe = regexp.MustCompile(`([^\\\\s,]+\\\\.(?:` + fileExt + `))\\\\s+(?:about\\\\s+|with\\\\s+|containing\\\\s+)?(.+?)(?:,\\\\s*|\\\\s+and\\\\s+|\\\\.\\\\s+[A-Z]|\\\\.\\\\s*$)`)\\n   138→\\t// Individual file in multi-modify: \\\"src/model.go should define ...\\\"\\n   139→\\tmodifyItemRe = regexp.MustCompile(`([^\\\\s,]+\\\\.(?:` + fileExt + `))\\\\s+should\\\\s+(.+?)(?:,|$)`)\\n   140→\\t// \\\"In src/a.go, add ...\\\" pattern for multi-modify\\n   141→\\tinFileRe = regexp.MustCompile(`[Ii]n\\\\s+([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   142→\\t// Inline content: \\\"with content 'package main; func Foo() {}'\\\"\\n   143→\\tinlineContentRe = regexp.MustCompile(`(?i)with\\\\s+content\\\\s+['\\\"]([^'\\\"]+)['\\\"]`)\\n   144→\\t// Numbered steps: \\\"(1) ... (2) ... (3) ...\\\"\\n   145→\\tnumberedStepRe = regexp.MustCompile(`\\\\(\\\\d+\\\\)\\\\s+`)\\n   146→\\t// Explicit git command: \\\"Run: git add ... && git commit -m '...'\\\"\\n   147→\\texplicitGitRe = regexp.MustCompile(`(?i)run:?\\\\s+git\\\\s+add\\\\s+.+(?:&&\\\\s*git\\\\s+commit|;\\\\s*git\\\\s+commit)`)\\n   148→\\t// \\\"about the colour red\\\" → \\\"the colour red\\\"\\n   149→\\ttopicRe = regexp.MustCompile(`(?i)about\\\\s+(.+?)(?:\\\\.|,|\\\\s+Do\\\\s|\\\\s+do\\\\s|\\\\s+then\\\\s|$)`)\\n   150→\\t// Fallback: extract any file path from text\\n   151→\\tanyFileRe = regexp.MustCompile(`([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   152→)\\n   153→\\n   154→func parsePrompt(prompt string) []action {\\n   155→\\t// Check for numbered-step prompts — parse each step independently to\\n   156→\\t// preserve ordering (e.g., create, commit, then create more).\\n   157→\\tif numberedStepRe.MatchString(prompt) {\\n   158→\\t\\treturn parseNumberedSteps(prompt)\\n   159→\\t}\\n   160→\\tvar actions []action\\n   161→\\n   162→\\t// Multi-file modify: \\\"modify these three files: src/model.go should ..., src/view.go should ...\\\"\\n   163→\\t// Also matches: \\\"Modify two existing files. In src/a.go, add ...\\\"\\n   164→\\tif m := modifyMultiRe.FindStringSubmatch(prompt); m != nil {\\n   165→\\t\\t// Try \\\"should\\\" pattern first\\n   166→\\t\\titems := modifyItemRe.FindAllStringSubmatch(m[1], -1)\\n   167→\\t\\tfor _, item := range items {\\n   168→\\t\\t\\tactions = append(actions, action{\\n   169→\\t\\t\\t\\tkind:    \\\"modify\\\",\\n   170→\\t\\t\\t\\tpath:    item[1],\\n   171→\\t\\t\\t\\tcontent: \\\"// \\\" + strings.TrimSpace(item[2]) + \\\"\\\\n\\\",\\n   172→\\t\\t\\t})\\n   173→\\t\\t}\\n   174→\\t\\t// Try \\\"In <path>\\\" pattern as fallback\\n   175→\\t\\tif len(actions) == 0 {\\n   176→\\t\\t\\tfor _, item := range inFileRe.FindAllStringSubmatch(m[1], -1) {\\n   177→\\t\\t\\t\\tactions = append(actions, action{\\n   178→\\t\\t\\t\\t\\tkind:    \\\"modify\\\",\\n   179→\\t\\t\\t\\t\\tpath:    item[1],\\n   180→\\t\\t\\t\\t\\tcontent: \\\"// Modified by vogon agent\\\\n\\\",\\n   181→\\t\\t\\t\\t})\\n   182→\\t\\t\\t}\\n   183→\\t\\t}\\n   184→\\t\\t// Last resort: extract any file paths\\n   185→\\t\\tif len(actions) == 0 {\\n   186→\\t\\t\\tfor _, fm := range anyFileRe.FindAllStringSubmatch(m[1], -1) {\\n   187→\\t\\t\\t\\tactions = append(actions, action{\\n   188→\\t\\t\\t\\t\\tkind:    \\\"modify\\\",\\n   189→\\t\\t\\t\\t\\tpath:    fm[1],\\n   190→\\t\\t\\t\\t\\tcontent: \\\"// Modified by vogon agent\\\\n\\\",\\n   191→\\t\\t\\t\\t})\\n   192→\\t\\t\\t}\\n   193→\\t\\t}\\n   194→\\t}\\n   195→\\n   196→\\t// Multi-file create: \\\"create four markdown files: docs/a.md about apples, ...\\\"\\n   197→\\tif len(actions) == 0 || hasModifyOnly(actions) {\\n   198→\\t\\tif m := createMultiRe.FindStringSubmatch(prompt); m != nil {\\n   199→\\t\\t\\titems := multiFileItemRe.FindAllStringSubmatch(m[1], -1)\\n   200→\\t\\t\\tfor _, item := range items {\\n   201→\\t\\t\\t\\tactions = append(actions, action{\\n   202→\\t\\t\\t\\t\\tkind:    \\\"create\\\",\\n   203→\\t\\t\\t\\t\\tpath:    item[1],\\n   204→\\t\\t\\t\\t\\tcontent: fmt.Sprintf(\\\"# %s\\\\n\\\\nA paragraph about %s.\\\\n\\\", strings.TrimSpace(item[2]), strings.TrimSpace(item[2])),\\n   205→\\t\\t\\t\\t})\\n   206→\\t\\t\\t}\\n   207→\\t\\t}\\n   208→\\t}\\n   209→\\n   210→\\t// Single file create — also runs if we only have modifies (combined prompts)\\n   211→\\tif !hasCreate(actions) {\\n   212→\\t\\tif m := createFileRe.FindStringSubmatch(prompt); m != nil {\\n   213→\\t\\t\\ttopic := extractTopic(prompt)\\n   214→\\t\\t\\tcontent := fmt.Sprintf(\\\"# %s\\\\n\\\\nA paragraph about %s.\\\\n\\\", topic, topic)\\n   215→\\t\\t\\tif ic := inlineContentRe.FindStringSubmatch(prompt); ic != nil {\\n   216→\\t\\t\\t\\tcontent = ic[1] + \\\"\\\\n\\\"\\n   217→\\t\\t\\t}\\n   218→\\t\\t\\tactions = append(actions, action{\\n   219→\\t\\t\\t\\tkind:    \\\"create\\\",\\n   220→\\t\\t\\t\\tpath:    m[1],\\n   221→\\t\\t\\t\\tcontent: content,\\n   222→\\t\\t\\t})\\n   223→\\t\\t}\\n   224→\\t}\\n   225→\\n   226→\\t// Single file modify — also runs if we only have creates (combined prompts)\\n   227→\\tif !hasModify(actions) {\\n   228→\\t\\tif m := modifyFileRe.FindStringSubmatch(prompt); m != nil {\\n   229→\\t\\t\\tactions = append(actions, action{\\n   230→\\t\\t\\t\\tkind:    \\\"modify\\\",\\n   231→\\t\\t\\t\\tpath:    m[1],\\n   232→\\t\\t\\t\\tcontent: \\\"// Modified by vogon agent\\\\n\\\",\\n   233→\\t\\t\\t})\\n   234→\\t\\t}\\n   235→\\t}\\n   236→\\n   237→\\t// \\\"add ... to <path>\\\" as modify (e.g. \\\"add another stanza to poem.txt\\\")\\n   238→\\tif !hasModify(actions) {\\n   239→\\t\\tif m := addToFileRe.FindStringSubmatch(prompt); m != nil {\\n   240→\\t\\t\\tactions = append(actions, action{\\n   241→\\t\\t\\t\\tkind:    \\\"modify\\\",\\n   242→\\t\\t\\t\\tpath:    m[1],\\n   243→\\t\\t\\t\\tcontent: \\\"// Modified by vogon agent\\\\n\\\",\\n   244→\\t\\t\\t})\\n   245→\\t\\t}\\n   246→\\t}\\n   247→\\n   248→\\t// Delete\\n   249→\\tif m := deleteFileRe.FindStringSubmatch(prompt); m != nil {\\n   250→\\t\\tactions = append(actions, action{kind: \\\"delete\\\", path: m[1]})\\n   251→\\t}\\n   252→\\n   253→\\t// Commit: check for \\\"commit each file separately\\\" (interleaved) vs normal.\\n   254→\\t// Skip if prompt contains \\\"do not commit\\\" / \\\"don't commit\\\".\\n   255→\\tif !noCommitRe.MatchString(prompt) {\\n   256→\\t\\tif commitSeparatelyRe.MatchString(prompt) {\\n   257→\\t\\t\\tactions = interleaveCommits(actions)\\n   258→\\t\\t} else if commitRe.MatchString(prompt) {\\n   259→\\t\\t\\tactions = append(actions, action{kind: \\\"commit\\\"})\\n   260→\\t\\t}\\n   261→\\t}\\n   262→\\n   263→\\treturn actions\\n   264→}\\n   265→\\n   266→// parseNumberedSteps splits \\\"(1) ... (2) ... (3) ...\\\" prompts into individual\\n   267→// steps and parses each one, preserving ordering. This handles prompts like:\\n   268→// \\\"(1) Create file A. (2) Create file B. (3) git commit. (4) Create file C.\\\"\\n   269→func parseNumberedSteps(prompt string) []action {\\n   270→\\t// Split on numbered markers: \\\"(1) \\\", \\\"(2) \\\", etc.\\n   271→\\tindices := numberedStepRe.FindAllStringIndex(prompt, -1)\\n   272→\\tif len(indices) == 0 {\\n   273→\\t\\treturn nil\\n   274→\\t}\\n   275→\\n   276→\\tvar steps []string\\n   277→\\tfor i, idx := range indices {\\n   278→\\t\\tstart := idx[1] // after the \\\"(N) \\\" marker\\n   279→\\t\\tvar end int\\n   280→\\t\\tif i+1 < len(indices) {\\n   281→\\t\\t\\tend = indices[i+1][0]\\n   282→\\t\\t} else {\\n   283→\\t\\t\\tend = len(prompt)\\n   284→\\t\\t}\\n   285→\\t\\tstep := strings.TrimSpace(prompt[start:end])\\n   286→\\t\\tif step != \\\"\\\" {\\n   287→\\t\\t\\tsteps = append(steps, step)\\n   288→\\t\\t}\\n   289→\\t}\\n   290→\\n   291→\\tvar actions []action\\n   292→\\tfor _, step := range steps {\\n   293→\\t\\t// Explicit git command: \\\"Run: git add ... && git commit ...\\\"\\n   294→\\t\\tif explicitGitRe.MatchString(step) {\\n   295→\\t\\t\\tactions = append(actions, action{kind: \\\"commit\\\"})\\n   296→\\t\\t\\tcontinue\\n   297→\\t\\t}\\n   298→\\n   299→\\t\\t// Create file with optional inline content\\n   300→\\t\\tif m := createFileRe.FindStringSubmatch(step); m != nil {\\n   301→\\t\\t\\tcontent := fmt.Sprintf(\\\"# %s\\\\n\\\\nGenerated content.\\\\n\\\", m[1])\\n   302→\\t\\t\\tif ic := inlineContentRe.FindStringSubmatch(step); ic != nil {\\n   303→\\t\\t\\t\\tcontent = ic[1] + \\\"\\\\n\\\"\\n   304→\\t\\t\\t}\\n   305→\\t\\t\\tactions = append(actions, action{kind: \\\"create\\\", path: m[1], content: content})\\n   306→\\t\\t\\tcontinue\\n   307→\\t\\t}\\n   308→\\n   309→\\t\\t// Modify file\\n   310→\\t\\tif m := modifyFileRe.FindStringSubmatch(step); m != nil {\\n   311→\\t\\t\\tactions = append(actions, action{kind: \\\"modify\\\", path: m[1], content: \\\"// Modified by vogon agent\\\\n\\\"})\\n   312→\\t\\t\\tcontinue\\n   313→\\t\\t}\\n   314→\\n   315→\\t\\t// Delete file\\n   316→\\t\\tif m := deleteFileRe.FindStringSubmatch(step); m != nil {\\n   317→\\t\\t\\tactions = append(actions, action{kind: \\\"delete\\\", path: m[1]})\\n   318→\\t\\t\\tcontinue\\n   319→\\t\\t}\\n   320→\\n   321→\\t\\t// Bare commit instruction\\n   322→\\t\\tif commitRe.MatchString(step) && !noCommitRe.MatchString(step) {\\n   323→\\t\\t\\tactions = append(actions, action{kind: \\\"commit\\\"})\\n   324→\\t\\t}\\n   325→\\t}\\n   326→\\treturn actions\\n   327→}\\n   328→\\n   329→func hasCreate(actions []action) bool {\\n   330→\\tfor _, a := range actions {\\n   331→\\t\\tif a.kind == \\\"create\\\" {\\n   332→\\t\\t\\treturn true\\n   333→\\t\\t}\\n   334→\\t}\\n   335→\\treturn false\\n   336→}\\n   337→\\n   338→func hasModify(actions []action) bool {\\n   339→\\tfor _, a := range actions {\\n   340→\\t\\tif a.kind == \\\"modify\\\" {\\n   341→\\t\\t\\treturn true\\n   342→\\t\\t}\\n   343→\\t}\\n   344→\\treturn false\\n   345→}\\n   346→\\n   347→func hasModifyOnly(actions []action) bool {\\n   348→\\tif len(actions) == 0 {\\n   349→\\t\\treturn false\\n   350→\\t}\\n   351→\\tfor _, a := range actions {\\n   352→\\t\\tif a.kind != \\\"modify\\\" {\\n   353→\\t\\t\\treturn false\\n   354→\\t\\t}\\n   355→\\t}\\n   356→\\treturn true\\n   357→}\\n   358→\\n   359→// interleaveCommits inserts a commit after each create/modify action.\\n   360→func interleaveCommits(actions []action) []action {\\n   361→\\tvar result []action\\n   362→\\tfor _, a := range actions {\\n   363→\\t\\tresult = append(result, a)\\n   364→\\t\\tif a.kind == \\\"create\\\" || a.kind == \\\"modify\\\" {\\n   365→\\t\\t\\tresult = append(result, action{kind: \\\"commit\\\"})\\n   366→\\t\\t}\\n   367→\\t}\\n   368→\\treturn result\\n   369→}\\n   370→\\n   371→func extractTopic(prompt string) string {\\n   372→\\tif m := topicRe.FindStringSubmatch(prompt); m != nil {\\n   373→\\t\\treturn strings.TrimSpace(m[1])\\n   374→\\t}\\n   375→\\treturn \\\"the topic\\\"\\n   376→}\\n   377→\\n   378→func executeActions(dir string, actions []action) {\\n   379→\\tvar pendingFiles []string\\n   380→\\tfor _, a := range actions {\\n   381→\\t\\tswitch a.kind {\\n   382→\\t\\tcase \\\"create\\\":\\n   383→\\t\\t\\tcreateFile(dir, a.path, a.content)\\n   384→\\t\\t\\tpendingFiles = append(pendingFiles, a.path)\\n   385→\\t\\tcase \\\"modify\\\":\\n   386→\\t\\t\\tmodifyFile(dir, a.path, a.content)\\n   387→\\t\\t\\tpendingFiles = append(pendingFiles, a.path)\\n   388→\\t\\tcase \\\"delete\\\":\\n   3