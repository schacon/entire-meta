(t, dir, ref)\\n   201→\\tAssertCheckpointExists(t, dir, trailer)\\n   202→}\\n   203→\\n   204→// AssertCheckpointHasSingleSession asserts checkpoint metadata has exactly one session.\\n   205→func AssertCheckpointHasSingleSession(t *testing.T, dir string, checkpointID string) {\\n   206→\\tt.Helper()\\n   207→\\tmeta := ReadCheckpointMetadata(t, dir, checkpointID)\\n   208→\\tassert.Len(t, meta.Sessions, 1,\\n   209→\\t\\t\\\"expected 1 session in checkpoint %s, got %d\\\", checkpointID, len(meta.Sessions))\\n   210→}\\n   211→\\n   212→// AssertCheckpointMetadataComplete asserts essential fields in checkpoint metadata are populated.\\n   213→func AssertCheckpointMetadataComplete(t *testing.T, dir string, checkpointID string) {\\n   214→\\tt.Helper()\\n   215→\\tmeta := ReadCheckpointMetadata(t, dir, checkpointID)\\n   216→\\tassert.NotEmpty(t, meta.CLIVersion, \\\"checkpoint %s: cli_version should be set\\\", checkpointID)\\n   217→\\tassert.NotEmpty(t, meta.Strategy, \\\"checkpoint %s: strategy should be set\\\", checkpointID)\\n   218→\\tassert.NotEmpty(t, meta.Sessions, \\\"checkpoint %s: should have at least 1 session\\\", checkpointID)\\n   219→\\tassert.Equal(t, checkpointID, meta.CheckpointID,\\n   220→\\t\\t\\\"checkpoint metadata ID should match expected\\\")\\n   221→}\\n   222→\\n   223→// WaitForCheckpointAdvanceFrom polls until the checkpoint branch advances from\\n   224→// the given ref, or fails the test after timeout. Use this when waiting for a\\n   225→// second (or subsequent) checkpoint after recording the branch position.\\n   226→func WaitForCheckpointAdvanceFrom(t *testing.T, dir string, fromRef string, timeout time.Duration) {\\n   227→\\tt.Helper()\\n   228→\\tdeadline := time.Now().Add(timeout)\\n   229→\\tfor time.Now().Before(deadline) {\\n   230→\\t\\tafter := GitOutput(t, dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n   231→\\t\\tif after != fromRef {\\n   232→\\t\\t\\treturn\\n   233→\\t\\t}\\n   234→\\t\\ttime.Sleep(200