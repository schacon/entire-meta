\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  2181→\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  2182→\\t\\t)\\n  2183→\\t\\tstate.TurnCheckpointIDs = nil\\n  2184→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  2185→\\t}\\n  2186→\\n  2187→\\t// Open repository (needed for shadow branch prompt reading and checkpoint store)\\n  2188→\\trepo, err := OpenRepository(ctx)\\n  2189→\\tif err != nil {\\n  2190→\\t\\tlogging.Warn(logCtx, \\\"finalize: failed to open repository\\\",\\n  2191→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  2192→\\t\\t)\\n  2193→\\t\\tstate.TurnCheckpointIDs = nil\\n  2194→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  2195→\\t}\\n  2196→\\n  2197→\\tprompts := readPromptsFromShadowBranch(ctx, repo, state)\\n  2198→\\tif len(prompts) == 0 {\\n  2199→\\t\\tprompts = readPromptsFromFilesystem(ctx, state.SessionID)\\n  2200→\\t}\\n  2201→\\n  2202→\\t// Redact secrets before writing — matches WriteCommitted behavior.\\n  2203→\\t// The live transcript on disk contains raw content; redaction must happen\\n  2204→\\t// before anything is persisted to the metadata branch.\\n  2205→\\tfullTranscript, err = redact.JSONLBytes(fullTranscript)\\n  2206→\\tif err != nil {\\n  2207→\\t\\tlogging.Warn(logCtx, \\\"finalize: transcript redaction failed, skipping\\\",\\n  2208→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  2209→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  2210→\\t\\t)\\n  2211→\\t\\tstate.TurnCheckpointIDs = nil\\n  2212→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  2213→\\t}\\n  2214→\\tfor i, p := range prompts {\\n  2215→\\t\\tprompts[i] = redact.String(p)\\n  2216→\\t}\\n  2217→\\n  2218→\\tstore := checkpoint.NewGitStore(repo)\\n  2219→\\n  2220→\\t// Update each checkpoint with the full transcript\\n  2221→\\tfor _, cpIDStr := range state.TurnCheckpointIDs {\\n  2222→\\t\\tcpID, parseErr := id.NewCheckpointID(cpIDS