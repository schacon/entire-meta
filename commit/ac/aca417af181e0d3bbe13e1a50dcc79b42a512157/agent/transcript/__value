  524→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   525→\\n   526→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   527→\\n   528→\\tvar meta SessionMetadata\\n   529→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   530→\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   531→\\t}\\n   532→\\n   533→\\treturn meta\\n   534→}\\n   535→\\n   536→// WaitForSessionMetadata polls until session metadata exists on the checkpoint\\n   537→// branch for the given checkpoint ID and session index, then returns it.\\n   538→// This handles the race where the checkpoint branch advances before session\\n   539→// metadata is fully committed.\\n   540→func WaitForSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int, timeout time.Duration) SessionMetadata {\\n   541→\\tt.Helper()\\n   542→\\n   543→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   544→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   545→\\n   546→\\tdeadline := time.Now().Add(timeout)\\n   547→\\tfor time.Now().Before(deadline) {\\n   548→\\t\\traw := gitOutputSafe(dir, \\\"show\\\", blob)\\n   549→\\t\\tif raw != \\\"\\\" {\\n   550→\\t\\t\\tvar meta SessionMetadata\\n   551→\\t\\t\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   552→\\t\\t\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   553→\\t\\t\\t}\\n   554→\\t\\t\\treturn meta\\n   555→\\t\\t}\\n   556→\\t\\ttime.Sleep(500 * time.Millisecond)\\n   557→\\t}\\n   558→\\tt.Fatalf(\\\"session metadata %s did not appear within %s\\\", blob, timeout)\\n   559→\\treturn SessionMetadata{}\\n   560→}\\n   561→\\n   562→// SetupBareRemote creates a bare git repo, adds it as \\\"origin\\\", and pushes\\n   563→// the initial commit. Returns the bare repo path.\\n   564→func SetupBareRemote(t *testing.T, s *RepoState) string {\\n   565→\\tt.Helper()\\n   566→\\n   567→\\tvar bareDir string