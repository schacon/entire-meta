ession_id %s across checkpoints\\\", sm.SessionID)\\n   315→\\t\\tseen[sm.SessionID] = true\\n   316→\\t}\\n   317→}\\n   318→\\n   319→// ValidateCheckpointDeep performs comprehensive validation of checkpoint metadata\\n   320→// on the checkpoint branch, including transcript JSONL validity, content hash\\n   321→// verification, and prompt content checking.\\n   322→func ValidateCheckpointDeep(t *testing.T, dir string, v DeepCheckpointValidation) {\\n   323→\\tt.Helper()\\n   324→\\n   325→\\t// Basic metadata validation\\n   326→\\tAssertCheckpointExists(t, dir, v.CheckpointID)\\n   327→\\tAssertCheckpointMetadataComplete(t, dir, v.CheckpointID)\\n   328→\\n   329→\\tif v.Strategy != \\\"\\\" {\\n   330→\\t\\tmeta := ReadCheckpointMetadata(t, dir, v.CheckpointID)\\n   331→\\t\\tassert.Equal(t, v.Strategy, meta.Strategy,\\n   332→\\t\\t\\t\\\"checkpoint %s: strategy mismatch\\\", v.CheckpointID)\\n   333→\\t}\\n   334→\\n   335→\\tif len(v.FilesTouched) > 0 {\\n   336→\\t\\tAssertCheckpointFilesTouched(t, dir, v.CheckpointID, v.FilesTouched)\\n   337→\\t}\\n   338→\\n   339→\\tpath := CheckpointPath(v.CheckpointID)\\n   340→\\n   341→\\t// Validate session metadata exists and has checkpoint_id\\n   342→\\tsessionBlob := fmt.Sprintf(\\\"entire/checkpoints/v1:%s/0/metadata.json\\\", path)\\n   343→\\tsessionRaw := gitOutputSafe(dir, \\\"show\\\", sessionBlob)\\n   344→\\tif assert.NotEmpty(t, sessionRaw, \\\"session metadata should exist at %s\\\", sessionBlob) {\\n   345→\\t\\tvar sessionMeta map[string]any\\n   346→\\t\\tif assert.NoError(t, json.Unmarshal([]byte(sessionRaw), &sessionMeta)) {\\n   347→\\t\\t\\tassert.Equal(t, v.CheckpointID, sessionMeta[\\\"checkpoint_id\\\"],\\n   348→\\t\\t\\t\\t\\\"session metadata checkpoint_id should match\\\")\\n   349→\\t\\t\\tassert.NotEmpty(t, sessionMeta[\\\"created_at\\\"], \\\"session metadata should have created_at\\\")\\n   350→\\t\\t}\\n   351→\\t}\\n   352→\\n   353→\\t// Validate transcript is valid JSONL\\n   354→\\ttranscriptBlob := fmt.Sprintf(\\\"entire/checkpoints/v1:%s/0/full.jsonl\\\", path)\\n   355→\\ttranscriptRaw := gitOutputSafe(dir, \\\"show\\\", transcriptBlob)\\n   356→\\tif assert.NotEmpty(t, transcriptRaw, \\\"transcript should exist at %s\\\", transcriptBlob) {\\n   357→\\t\\tlines := strings.Split(transcriptRaw, \\\"\\\\n\\\")\\n   358→\\t\\tnonEmpty := 0\\n   359→\\t\\tfor _, line := range lines {\\n   360→\\t\\t\\tif strings.TrimSpace(line) != \\\"\\\" {\\n   361→\\t\\t\\t\\tnonEmpty++\\n   362→\\t\\t\\t}\\n   363→\\t\\t}\\n   364→\\t\\tassert.Positive(t, nonEmpty, \\\"transcript should have at least one line\\\")\\n   365→\\n   366→\\t\\tfor _, expected := range v.ExpectedTranscriptContent {\\n   367→\\t\\t\\tassert.Contains(t, transcriptRaw, expected,\\n   368→\\t\\t\\t\\t\\\"transcript should contain %q\\\", expected)\\n   369→\\t\\t}\\n   370→\\n   371→\\t\\t// Validate content hash\\n   372→\\t\\thashBlob := fmt.Sprintf(\\\"entire/checkpoints/v1:%s/0/content_hash.txt\\\", path)\\n   373→\\t\\thashRaw := gitOutputSafe(dir, \\\"show\\\", hashBlob)\\n   374→\\t\\tif hashRaw != \\\"\\\" {\\n   375→\\t\\t\\thash := sha256.Sum256([]byte(transcriptRaw))\\n   376→\\t\\t\\texpectedHash := \\\"sha256:\\\" + hex.EncodeToString(hash[:])\\n   377→\\t\\t\\tassert.Equal(t, expectedHash, strings.TrimSpace(hashRaw),\\n   378→\\t\\t\\t\\t\\\"content hash should match transcript SHA-256\\\")\\n   379→\\t\\t}\\n   380→\\t}\\n   381→\\n   382→\\t// Validate prompt.txt if expected prompts specified\\n   383→\\tif len(v.ExpectedPrompts) > 0 {\\n   384→\\t\\tpromptBlob := fmt.Sprintf(\\\"entire/checkpoints/v1:%s/0/prompt.txt\\\", path)\\n   385→\\t\\tpromptRaw := gitOutputSafe(dir, \\\"show\\\", promptBlob)\\n   386→\\t\\tfor _, expected := range v.ExpectedPrompts {\\n   387→\\t\\t\\tassert.Contains(t, promptRaw, expected,\\n   388→\\t\\t\\t\\t\\\"prompt.txt should contain %q\\\", expected)\\n   389→\\t\\t}\\n   390→\\t}\\n   391→}\\n   392→\"}]},\"uuid\":\"f4ccff36-0ace-4