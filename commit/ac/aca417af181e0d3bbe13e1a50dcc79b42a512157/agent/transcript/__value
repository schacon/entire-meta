  - true or not set: push automatically (default)\\n    26→func pushSessionsBranchCommon(ctx context.Context, remote, branchName string) error {\\n    27→\\t// Check if pushing is disabled\\n    28→\\tif isPushSessionsDisabled(ctx) {\\n    29→\\t\\treturn nil\\n    30→\\t}\\n    31→\\n    32→\\treturn pushBranchIfNeeded(ctx, remote, branchName)\\n    33→}\\n    34→\\n    35→// pushBranchIfNeeded pushes a branch to the remote if it has unpushed changes.\\n    36→// Does not check any settings — callers are responsible for gating.\\n    37→func pushBranchIfNeeded(ctx context.Context, remote, branchName string) error {\\n    38→\\trepo, err := OpenRepository(ctx)\\n    39→\\tif err != nil {\\n    40→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n    41→\\t}\\n    42→\\n    43→\\t// Check if branch exists locally\\n    44→\\tbranchRef := plumbing.NewBranchReferenceName(branchName)\\n    45→\\tlocalRef, err := repo.Reference(branchRef, true)\\n    46→\\tif err != nil {\\n    47→\\t\\t// No branch, nothing to push\\n    48→\\t\\treturn nil //nolint:nilerr // Expected when no sessions exist yet\\n    49→\\t}\\n    50→\\n    51→\\t// Check if there's actually something to push (local differs from remote)\\n    52→\\tif !hasUnpushedSessionsCommon(repo, remote, localRef.Hash(), branchName) {\\n    53→\\t\\t// Nothing to push - skip silently\\n    54→\\t\\treturn nil\\n    55→\\t}\\n    56→\\n    57→\\treturn doPushBranch(ctx, remote, branchName)\\n    58→}\\n    59→\\n    60→// hasUnpushedSessionsCommon checks if the local branch differs from the remote.\\n    61→// Returns true if there's any difference that needs syncing (local ahead, remote ahead, or diverged).\\n    62→func hasUnpushedSessionsCommon(repo *git.Repository, remote string, localHash plumbing.Hash, branchName string) bool {\\n    63→\\t// Check for remote tracking ref: refs/remotes/<remote>/<branch>\\n    64→\\tremoteRefName := plumbing.NewRemoteReferenceName(remote, branchName)\\n    65→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n    66→\\tif err != nil {\\n    67→\\t\\t// Remote branch doesn't exist yet - we have content to push\\n    68→\\t\\treturn true\\n    69→\\t}\\n    70→\\n    71→\\t// If local and remote point to same commit, nothing to sync\\n    72→\\t// This is the only case where we skip - any difference needs handling\\n    73→\\treturn localHash != remoteRef.Hash()\\n    74→}\\n    75→\\n    76→// isPushSessionsDisabled checks if push_sessions is disabled in settings.\\n    77→// Returns true if push_sessions is explicitly set to false.\\n    78→func isPushSessionsDisabled(ctx context.Context) bool {\\n    79→\\ts, err := settings.Load(ctx)\\n    80→\\tif err != nil {\\n    81→\\t\\treturn false // Default: push is enabled\\n    82→\\t}\\n    83→\\treturn s.IsPushSessionsDisabled()\\n    84→}\\n    85→\\n    86→// doPushBranch pushes the given branch to the remote with fetch+merge recovery.\\n    87→func doPushBranch(ctx context.Context, remote, branchName string) error {\\n    88→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Pushing %s to %s...\\\\n\\\", branchName, remote)\\n    89→\\n    90→\\t// Try pushing first\\n    91→\\tif err := tryPushSessionsCommon(ctx, remote, branchName); err == nil {\\n    92→\\t\\treturn nil\\n    93→\\t}\\n    94→\\n    95→\\t// Push failed - likely non-fast-forward. Try to fetch and merge.\\n    96→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Syncing %s with remote...\\\\n\\\", branchName)\\n    97→\\n    98→\\tif err := fetchAndMergeSessionsCommon(ctx, remote, branchName); err != nil {\\n    99→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: couldn't sync %s: %v\\\\n\\\", branchName, err)\\n   100→\\t\\treturn nil // Don't fail the main push\\n   101→\\t}\\n   102→\\n   103→\\t// Try pushing again after merge\\n   104→\\tif err := tryPushSessionsCommon(ctx, remote, branchName); err != nil {\\n   105→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to push %s after sync: %v\\\\n\\\", 