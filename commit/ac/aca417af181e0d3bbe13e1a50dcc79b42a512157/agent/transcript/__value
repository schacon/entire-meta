urnEnd updates\\n    21→// the provisional transcript (written at commit time) with the full transcript\\n    22→// (available at turn end).\\n    23→//\\n    24→// Flow:\\n    25→// 1. Agent starts working (ACTIVE)\\n    26→// 2. Agent makes file changes\\n    27→// 3. User commits while agent is ACTIVE → provisional transcript condensed\\n    28→// 4. Agent continues work (updates transcript)\\n    29→// 5. Agent finishes (SimulateStop) → transcript finalized via UpdateCommitted\\n    30→//\\n    31→// This verifies that the final transcript on entire/checkpoints/v1 includes\\n    32→// work done AFTER the commit.\\n    33→func TestShadow_DeferredTranscriptFinalization(t *testing.T) {\\n    34→\\tt.Parallel()\\n    35→\\n    36→\\tenv := NewFeatureBranchEnv(t)\\n    37→\\n    38→\\tsess := env.NewSession()\\n    39→\\n    40→\\t// Start session (ACTIVE)\\n    41→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(sess.ID, \\\"Create feature function\\\", sess.TranscriptPath); err != nil {\\n    42→\\t\\tt.Fatalf(\\\"user-prompt-submit failed: %v\\\", err)\\n    43→\\t}\\n    44→\\n    45→\\tstate, err := env.GetSessionState(sess.ID)\\n    46→\\tif err != nil {\\n    47→\\t\\tt.Fatalf(\\\"GetSessionState failed: %v\\\", err)\\n    48→\\t}\\n    49→\\tif state.Phase != session.PhaseActive {\\n    50→\\t\\tt.Errorf(\\\"Expected ACTIVE phase, got %s\\\", state.Phase)\\n    51→\\t}\\n    52→\\n    53→\\t// Create file and initial transcript\\n    54→\\tenv.WriteFile(\\\"feature.go\\\", \\\"package main\\\\n\\\\nfunc Feature() {}\\\\n\\\")\\n    55→\\tsess.CreateTranscript(\\\"Create feature function\\\", []FileChange{\\n    56→\\t\\t{Path: \\\"feature.go\\\", Content: \\\"package main\\\\n\\\\nfunc Feature() {}\\\\n\\\"},\\n    57→\\t})\\n    58→\\n    59→\\t// Debug: verify session state before commit\\n    60→\\tpreCommitState, _ := env.GetSessionState(sess.ID)\\n    61→\\tif preCommitState == nil {\\n    62→\\t\\tt.Fatal(\\\"Session state should exist before commit\\\")\\n    63→\\t}\\n    64→\\tt.Logf(\\\"Pre-commit session state: phase=%s, worktreePath=%s, baseCommit=%s\\\",\\n    65→\\t\\tpreCommitState.Phase, preCommitState.WorktreePath, preCommitState.BaseCommit[:7])\\n    66→\\n    67→\\t// User commits while agent is still ACTIVE\\n    68→\\t// This triggers condensation with the provisional transcript\\n    69→\\t// Using custom commit with verbose output for debugging\\n    70→\\t{\\n    71→\\t\\tenv.GitAdd(\\\"feature.go\\\")\\n    72→\\t\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n    73→\\t\\tif err := os.WriteFile(msgFile, []byte(\\\"Add feature\\\"), 0o644); err != nil {\\n    74→\\t\\t\\tt.Fatalf(\\\"failed to write commit message: %v\\\", err)\\n    75→\\t\\t}\\n    76→\\n    77→\\t\\t// Run prepare-commit-msg\\n    78→\\t\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile, \\\"message\\\")\\n    79→\\t\\tprepCmd.Dir = env.RepoDir\\n    80→\\t\\tprepCmd.Env = append(testutil.GitIsolatedEnv(), \\\"ENTIRE_TEST_TTY=1\\\")\\n    81→\\t\\tprepOutput, prepErr := prepCmd.CombinedOutput()\\n    82→\\t\\tt.Logf(\\\"prepare-commit-msg output: %s (err: %v)\\\", prepOutput, prepErr)\\n    83→\\n    84→\\t\\t// Read modified message\\n    85→\\t\\tmodifiedMsg, _ := os.ReadFile(msgFile)\\n    86→\\t\\tt.Logf(\\\"Commit message after prepare-commit-msg: %s\\\", modifiedMsg)\\n    87→\\n    88→\\t\\t// Create commit\\n    89→\\t\\trepo, _ := git.PlainOpen(env.RepoDir)\\n    90→\\t\\tworktree, _ := repo.Worktree()\\n    91→\\t\\t_, err := worktree.Commit(string(modifiedMsg), &git.CommitOptions{\\n    92→\\t\\t\\tAuthor: &object.Signature{\\n    93→\\t\\t\\t\\tName:  \\\"Test User\\\",\\n    94→\\t\\t\\t\\tEmail: \\\"test@example.com\\\",\\n    95→\\t\\t\\t\\tWhen:  time.Now(),\\n    96→\\t\\t\\t},\\n    97→\\t\\t})\\n    98→\\t\\tif err != nil {\\n    99→\\t\\t\\tt.Fatalf(\\\"failed to commit: %v\\\", err)\\n   100→\\t\\t}\\n   101→\\n   102→\\t\\t// Run post-commit\\n   103→\\t\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n   104→\\t\\tpostCmd.Dir = env.RepoDir\\n   105→\\t\\tpostOutput, postErr := postCmd.CombinedOutput()\\n   106→\\t\\tt.Logf(\\\"post-commit output: %s (err: %v)\\\", postOutput, postErr)\\n   107→\\t}\\n   108→\\tcommitHash := env.GetHeadHash()\\n   109→\\n   110→\\tcheckpointID := env.GetCheckpointIDFromCommitMessage(commitHash)\\n   111→\\tif checkpointID == \\\"\\\" {\\n   112→\\t\\tt.Fatal(\\\"Commit should have checkpoint trailer\\\")\\n   113→\\t}\\n   114→\\tt.Logf(\\\"Checkpoint ID after mid-session commit: %s\\\", checkpointID)\\n   115→\\n   116→\\t// Debug: verify session state after commit\\n   117→\\tpostCommitState, _ := env.GetSessionState(sess.ID)\\n   118→\\tif postCommitState != nil {\\n   119→\\t\\tt.Logf(\\\"Post-commit session state: phase=%s, baseCommit=%s, turnCheckpointIDs=%v\\\",\\n   120→\\t\\t\\tpostCommitState.Phase, postCommitState.BaseCommit[:7], postCommitState.TurnCheckpointIDs)\\n   121→\\t} else {\\n   122→\\t\\tt.Log(\\\"Post-commit session state is nil (shouldn't happen)\\\")\\n   123→\\t}\\n   124→\\n   125→\\t// Debug: list all branches\\n   126→\\tbranches := env.ListBranchesWithPrefix(\\\"\\\")\\n   127→\\tt.Logf(\\\"All branches after commit: %v\\\", branches)\\n   128→\\n   129→\\t// Verify checkpoint exists on metadata branch (provisional)\\n   130→\\tif !env.BranchExists(paths.MetadataBranchName) {\\n   131→\\t\\tt.Fatal(\\\"entire/checkpoints/v1 branch should exist\\\")\\n   132→\\t}\\n   133→\\n   134→\\t// Read the provisional transcript\\n   135→\\ttranscriptPath := SessionFilePath(checkpointID, paths.TranscriptFileName)\\n   136→\\n   137→\\t// Verify the path structure matches expected sharded format: <id[:2]>/<id[2:]>/0/full.jsonl\\n   138→\\texpectedPrefix := checkpointID[:2] + \\\"/\\\" + checkpointID[2:] + \\\"/0/\\\"\\n   139→\\tif !strings.HasPrefix(transcriptPath, expectedPrefix) {\\n   140→\\t\\tt.Errorf(\\\"Unexpected path structure: got %s, expected prefix %s\\\", transcriptPath, expectedPrefix)\\n   141→\\t}\\n   142→\\n   143→\\tprovisionalContent, found := env.ReadFileFromBranch(paths.MetadataBranchName, transcriptPath)\\n   144→\\tif !found {\\n   145→\\t\\tt.Fatalf(\\\"Provisional transcript should exist at %s\\\", transcriptPath)\\n   146→\\t}\\n   147→\\tt.Logf(\\\"Provisional transcript length: %d bytes\\\", len(provisionalContent))\\n   148→\\n   149→\\t// Verify session state has TurnCheckpointIDs for deferred finalization\\n   150→\\tstate, err = env.GetSessionState(sess.ID)\\n   151→\\tif err != nil {\\n   152→\\t\\tt.Fatalf(\\\"GetSessionState failed: %v\\\", err)\\n   153→\\t}\\n   154→\\tif len(state.TurnCheckpointIDs) == 0 {\\n   155→\\t\\tt.Error(\\\"TurnCheckpointIDs should contain the checkpoint ID for finalization\\\")\\n   156→\\t}\\n   157→\\n   158→\\t// Agent continues work - add more to transcript\\n   159→\\tsess.TranscriptBuilder.AddUserMessage(\\\"Also add a helper function\\\")\\n   160→\\tsess.TranscriptBuilder.AddAssistantMessage(\\\"Adding helper function now\\\")\\n   161→\\ttoolID := sess.TranscriptBuilder.AddToolUse(\\\"mcp__acp__Write\\\", \\\"helper.go\\\", \\\"package main\\\\n\\\\nfunc Helper() {}\\\\n\\\")\\n   162→\\tsess.TranscriptBuilder.AddToolResult(toolID)\\n   163→\\tsess.TranscriptBuilder.AddAssistantMessage(\\\"Done with both changes!\\\")\\n   164→\\n   165→\\t// Write updated transcript\\n   166→\\tif err := sess.TranscriptBuilder.WriteToFile(sess.TranscriptPath); err != nil {\\n   167→\\t\\tt.Fatalf(\\\"Failed to write updated transcript: %v\\\", err)\\n   168→\\t}\\n   169→\\n   170→\\t// Also create the file in worktree (for consistency, though not committed yet)\\n   171→\\tenv.WriteFile(\\\"helper.go\\\", \\\"package main\\\\n\\\\nfunc Helper() {}\\\\n\\\")\\n   172→\\n   173→\\t// Agent finishes turn - this triggers HandleTurnEnd which should finalize the transcript\\n   174→\\tif err := env.SimulateStop(sess.ID, sess.TranscriptPath); err != nil {\\n   175→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   176→\\t}\\n   177→\\n   178→\\t// Read the finalized transcript\\n   179→\\tfinalContent, found := env.ReadFileFromBranch(paths.MetadataBranchName, transcriptPath)\\n   180→\\tif !found {\\n   181→\\t\\tt.Fatalf(\\\"Finalized transcript should exist at %s\\\", transcriptPath)\\n   182→\\t}\\n   183→\\tt.Logf(\\\"Finalized transcript length: %d bytes\\\", len(finalContent))\\n   184→\\n   185→\\t// The finalized transcript should be longer (include post-commit work)\\n   186→\\tif len(finalContent) <= len(provisionalContent) {\\n   187→\\t\\tt.Errorf(\\\"Finalized transcript should be longer than provisional.\\\\n\\\"+\\n   188→\\t\\t\\t\\\"Provisional: %d bytes\\\\nFinalized: %d bytes\\\",\\n   189→\\t\\t\\tlen(provisionalContent), len(finalContent))\\n   190→\\t}\\n   191→\\n   192→\\t// Verify the finalized transcript contains the additional work\\n   193→\\tif !strings.Contains(finalContent, \\\"Also add a helper function\\\") {\\n   194→\\t\\tt.Error(\\\"Finalized transcript should contain post-commit user message\\\")\\n   195→\\t}\\n   196→\\tif !strings.Contains(finalContent, \\\"helper.go\\\") {\\n   197→\\t\\tt.Error(\\\"Finalized transcript should contain helper.go tool use\\\")\\n   198→\\t}\\n   199→\\n   200→\\t// Verify session is now IDLE\"}]},\"uuid\":\"1b3566ff-0200-41b1-907c-95847522ac81\",\"timestamp\":\"2026-03-06T09:40:29.315Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"af7c93e0c1adece2b\"},\"toolUseID\":\"agent_msg_01CmLC3Wno36ByRtSQGnvsi6\",\"parentToolUseID\":\"toolu_01Rn6BCx2kK4aCCcyuER2Fb9\",\"uuid\":\"b0df995b-46d2-484c-9a54-3ccf49861398\",\"timestamp\":\"2026-03-06T09:40:29.683Z\"}\n{\"parentUuid\":\"b0df995b-46d2-484c-9a54-3ccf49861398\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/4\",\"sessionId\":\"26fd10e5-9929-436