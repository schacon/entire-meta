\n   670→\\n   671→\\t// Build task checkpoint context - strategy handles metadata creation\\n   672→\\t// Note: Incremental checkpoints are now created during task execution via handleClaudeCodePostTodo,\\n   673→\\t// so we don't need to collect/cleanup staging area here.\\n   674→\\tctx := strategy.TaskCheckpointContext{\\n   675→\\t\\tSessionID:              input.SessionID,\\n   676→\\t\\tToolUseID:              input.ToolUseID,\\n   677→\\t\\tAgentID:                input.AgentID,\\n   678→\\t\\tModifiedFiles:          relModifiedFiles,\\n   679→\\t\\tNewFiles:               relNewFiles,\\n   680→\\t\\tDeletedFiles:           relDeletedFiles,\\n   681→\\t\\tTranscriptPath:         input.TranscriptPath,\\n   682→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   683→\\t\\tCheckpointUUID:         checkpointUUID,\\n   684→\\t\\tAuthorName:             author.Name,\\n   685→\\t\\tAuthorEmail:            author.Email,\\n   686→\\t\\tSubagentType:           subagentType,\\n   687→\\t\\tTaskDescription:        taskDescription,\\n   688→\\t\\tAgentType:              agentType,\\n   689→\\t}\\n   690→\\n   691→\\t// Call strategy to save task checkpoint - strategy handles all metadata creation\\n   692→\\tif err := strat.SaveTaskCheckpoint(ctx); err != nil {\\n   693→\\t\\treturn fmt.Errorf(\\\"failed to save task checkpoint: %w\\\", err)\\n   694→\\t}\\n   695→\\n   696→\\t// Cleanup pre-task state (ignore error - cleanup is best-effort)\\n   697→\\t_ = CleanupPreTaskState(input.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   698→\\n   699→\\treturn nil\\n   700→}\\n   701→\\n   702→// handleClaudeCodeSessionStart handles the SessionStart hook for Claude Code.\\n   703→func handleClaudeCodeSessionStart() error {\\n   704→\\treturn handleSessionStartCommon()\\n   705→}\\n   706→\\n   707→// handleClaudeCodeSessionEnd handles the SessionEnd hook for Claude Code.\\n   708→// This fires when the user explicitly closes the session.\\n   709→// Updates the session state with EndedAt timestamp.\\n   710→func handleClaudeCodeSessionEnd() error {\\n   711→\\tag, err := GetCurrentHookAgent()\\n   712→\\tif err != nil {\\n   713→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   714→\\t}\\n   715→\\n   716→\\tinput, err := ag.ParseHookInput(agent.HookSessionEnd, os.Stdin)\\n   717→\\tif err != nil {\\n   718→\\t\\treturn fmt.Errorf(\\\"failed to parse hook input: %w\\\", err)\\n   719→\\t}\\n   720→\\n   721→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"hooks\\\"), ag.Name())\\n   722→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   723→\\t\\tslog.String(\\\"hook\\\", \\\"session-end\\\"),\\n   724→\\t\\tslog.String(\\\"hook_type\\\", \\\"agent\\\"),\\n   725→\\t\\tslog.String(\\\"model_session_id\\\", input.SessionID),\\n   726→\\t)\\n   727→\\n   728→\\tif input.SessionID == \\\"\\\" {\\n   729→\\t\\treturn nil // No session to update\\n   730→\\t}\\n   731→\\n   732→\\t// Best-effort cleanup - don't block session closure on failure\\n   733→\\tif err := markSessionEnded(input.SessionID); err != nil {\\n   734→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to mark session ended: %v\\\\n\\\", err)\\n   735→\\t}\\n   736→\\treturn nil\\n   737→}\\n   738→\\n   739→// transitionSessionTurnEnd fires EventTurnEnd to move the session from\\n   740→// ACTIVE → IDLE. Best-effort: logs warnings on failure rather than\\n   741→// returning errors.\\n   742→func transitionSessionTurnEnd(sessionID string) {\\n   743→\\tturnState, loadErr := strategy.LoadSessionState(sessionID)\\n   744→\\tif loadErr != nil {\\n   745→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for turn end: %v\\\\n\\\", loadErr)\\n   746→\\t\\treturn\\n   747→\\t}\\n   748→\\tif turnState == nil {\\n   749→\\t\\treturn\\n   750→\\t}\\n   751→\\tstrategy.TransitionAndLog(turnState, session.EventTurnEnd, session.TransitionContext{})\\n   752→\\n   753→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   754→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   755→\\tstrat := GetStrategy()\\n   756→\\tif handler, ok := strat.(strategy.TurnEndHandler); ok {\\n   757→\\t\\tif err := handler.HandleTurnEnd(turnState); err != nil {\\n   758→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: turn-end action dispatch failed: %v\\\\n\\\", err)\\n   759→\\t\\t}\\n   760→\\t}\\n   761→\\n   762→\\tif updateErr := strategy.SaveSessionState(turnState); updateErr != nil {\\n   763→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session phase on turn end: %v\\\\n\\\", updateErr)\\n   764→\\t}\\n   765→}\\n   766→\\n   767→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   768→func markSessionEnded(sessionID string) error {\\n   769→\\tstate, err := strategy.LoadSessionState(sessionID)\\n   770→\\tif err != nil {\\n   771→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   772→\\t}\\n   773→\\tif state == nil {\\n   774→\\t\\treturn nil // No state file, nothing to update\\n   775→\\t}\\n   776→\\n   777→\\tstrategy.TransitionAndLog(state, session.EventSessionStop, session.TransitionContext{})\\n   778→\\n   779→\\tnow := time.Now()\\n   780→\\tstate.EndedAt = &now\\n   781→\\n   782→\\tif err := strategy.SaveSessionState(state); err != nil {\\n   783→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   784→\\t}\\n   785→\\treturn nil\\n   786→}\\n   787→\\n   788→// stopHookSentinel is the string that appears in Claude Code's hook_progress\\n   789→// transcript entry when it launches our stop hook. Used to detect that the\\n   790→// transcript file has been fully flushed before we copy it.\\n   791→const stopHookSentinel = \\\"hooks claude-code stop\\\"\\n   792→\\n   793→// waitForTranscriptFlush polls the transcript file tail for the hook_progress\\n   794→// sentinel entry that Claude Code writes when launching the stop hook.\\n   795→// Once this entry appears in the file, all prior entries (assistant replies,\\n   796→// tool results) are guaranteed to have been flushed.\\n   797→//\\n   798→// hookStartTime is the approximate time our process started, used to avoid\\n   799→// matching stale sentinel entries from previous stop hook invocations.\\n   800→//\\n   801→// Falls back silently after a timeout — the transcript copy will proceed\\n   802→// with whatever data is available.\\n   803→func waitForTranscriptFlush(transcriptPath string, hookStartTime time.Time) {\\n   804→\\tconst (\\n   805→\\t\\tmaxWait      = 3 * time.Second\\n   806→\\t\\tpollInterval = 50 * time.Millisecond\\n   807→\\t\\ttailBytes    = 4096 // Read last 4KB — sentinel is near the end\\n   808→\\t\\tmaxSkew      = 2 * time.Second\\n   809→\\t)\\n   810→\\n   811→\\tlogCtx := logging.WithComponent(context.Background(), \\\"hooks\\\")\\n   812→\\tdeadline := time.Now().Add(maxWait)\\n   813→\\tfor time.Now().Before(deadline) {\\n   814→\\t\\tif checkStopSentinel(transcriptPath, tailBytes, hookStartTime, maxSkew) {\\n   815→\\t\\t\\tlogging.Debug(logCtx, \\\"transcript flush sentinel found\\\",\\n   816→\\t\\t\\t\\tslog.Duration(\\\"wait\\\", time.Since(hookStartTime)),\\n   817→\\t\\t\\t)\\n   818→\\t\\t\\treturn\\n   819→\\t\\t}\\n   820→\\t\\ttime.Sleep(pollInterval)\\n   821→\\t}\\n   822→\\t// Timeout — proceed with whatever is on disk.\\n   823→\\tlogging.Warn(logCtx, \\\"transcript flush sentinel not found within timeout, proceeding\\\",\\n   824→\\t\\tslog.Duration(\\\"timeout\\\", maxWait),\\n   825→\\t)\\n   826→}\\n   827→\\n   828→// checkStopSentinel reads the tail of the transcript file and looks for a\\n   829→// hook_progress entry containing the stop hook sentinel, with a timestamp\\n   830→// close to hookStartTime.\\n   831→func checkStopSentinel(path string, tailBytes int64, hookStartTime time.Time, maxSkew time.Duration) bool {\\n   832→\\tf, err := os.Open(path) //nolint:gosec // path