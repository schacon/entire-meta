ts own BaseCommit update so there is no\\n   595→\\t\\t// fallthrough conditional at the end. On condensation failure,\\n   596→\\t\\t// BaseCommit is intentionally NOT updated to preserve access to\\n   597→\\t\\t// the shadow branch (which is named after the old BaseCommit).\\n   598→\\t\\tfor _, action := range remaining {\\n   599→\\t\\t\\tswitch action {\\n   600→\\t\\t\\tcase session.ActionCondense:\\n   601→\\t\\t\\t\\t// For ACTIVE sessions, any commit during the turn is session-related.\\n   602→\\t\\t\\t\\t// For IDLE/ENDED sessions (e.g., carry-forward), also require that the\\n   603→\\t\\t\\t\\t// committed files overlap with the session's remaining files AND have\\n   604→\\t\\t\\t\\t// matching content — otherwise an unrelated commit (or a commit with\\n   605→\\t\\t\\t\\t// completely replaced content) would incorrectly get this session's checkpoint.\\n   606→\\t\\t\\t\\tshouldCondense := hasNew\\n   607→\\t\\t\\t\\tif shouldCondense && !state.Phase.IsActive() {\\n   608→\\t\\t\\t\\t\\tshouldCondense = filesOverlapWithContent(repo, shadowBranchName, commit, state.FilesTouched)\\n   609→\\t\\t\\t\\t}\\n   610→\\t\\t\\t\\tif shouldCondense {\\n   611→\\t\\t\\t\\t\\tcondensed = s.condenseAndUpdateState(logCtx, repo, checkpointID, state, head, shadowBranchName, shadowBranchesToDelete)\\n   612→\\t\\t\\t\\t\\t// condenseAndUpdateState updates BaseCommit on success.\\n   613→\\t\\t\\t\\t\\t// On failure, BaseCommit is preserved so the shadow branch remains accessible.\\n   614→\\t\\t\\t\\t} else {\\n   615→\\t\\t\\t\\t\\t// No new content or unrelated commit — just update BaseCommit\\n   616→\\t\\t\\t\\t\\ts.updateBaseCommitIfChanged(logCtx, state, newHead)\\n   617→\\t\\t\\t\\t}\\n   618→\\t\\t\\tcase session.ActionCondenseIfFilesTouched:\\n   619→\\t\\t\\t\\t// The state machine already gates this action on HasFilesTouched,\\n   620→\\t\\t\\t\\t// but hasNew is an additional content-level check (transcript has\\n   621→\\t\\t\\t\\t// new content beyond what was previously condensed).\\n   622→\\t\\t\\t\\tif len(state.FilesTouched) > 0 && hasNew {\\n   623→\\t\\t\\t\\t\\tcondensed = s.condenseAndUpdateState(logCtx, repo, checkpointID, state, head, shadowBranchName, shadowBranchesToDelete)\\n   624→\\t\\t\\t\\t\\t// On failure, BaseCommit is preserved (same as ActionCondense).\\n   625→\\t\\t\\t\\t} else {\\n   626→\\t\\t\\t\\t\\ts.updateBaseCommitIfChanged(logCtx, state, newHead)\\n   627→\\t\\t\\t\\t}\\n   628→\\t\\t\\tcase session.ActionDiscardIfNoFiles:\\n   629→\\t\\t\\t\\tif len(state.FilesTouched) == 0 {\\n   630→\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: skipping empty ended session (no files to condense)\\\",\\n   631→\\t\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   632→\\t\\t\\t\\t\\t)\\n   633→\\t\\t\\t\\t}\\n   634→\\t\\t\\t\\ts.updateBaseCommitIfChanged(logCtx, state, newHead)\\n   635→\\t\\t\\tcase session.ActionClearEndedAt, session.ActionUpdateLastInteraction:\\n   636→\\t\\t\\t\\t// Handled by session.ApplyCommonActions above\\n   637→\\t\\t\\tcase session.ActionWarnStaleSession:\\n   638→\\t\\t\\t\\t// Not produced by EventGitCommit; listed for switch exhaustiveness\\n   639→\\t\\t\\t}\\n   640→\\t\\t}\\n   641→\\n   642→\\t\\t// Record checkpoint ID for ACTIVE sessions so HandleTurnEnd can finalize\\n   643→\\t\\t// with full transcript. IDLE/ENDED sessions already have complete transcripts.\\n   644→\\t\\tif condensed && state.Phase.IsActive() {\\n   645→\\t\\t\\tstate.TurnCheckpointIDs = append(state.TurnCheckpointIDs, checkpointID.String())\\n   646→\\t\\t}\\n   647→\\n   648→\\t\\t// Carry forward remaining uncommitted files so the next commit gets its\\n   649→\\t\\t// own checkpoint ID. This applies to ALL phases — if a user splits their\\n   650→\\t\\t// commit across two `git commit` invocations, each gets a 1:1 checkpoint.\\n   651→\\t\\t// Uses content-aware comparison: if user did `git add -p` and committed\\n   652→\\t\\t// partial changes, the file st