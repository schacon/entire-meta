\\n  1275→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1276→\\t}\\n  1277→\\n  1278→\\t// Add blank line before trailer\\n  1279→\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\"\\n  1280→}\\n  1281→\\n  1282→// addCheckpointTrailerWithComment adds the Entire-Checkpoint trailer with an explanatory comment.\\n  1283→// The trailer is placed above the git comment block but below the user's message area,\\n  1284→// with a comment explaining that the user can remove it if they don't want to link the commit\\n  1285→// to the agent session. If prompt is non-empty, it's shown as context.\\n  1286→func addCheckpointTrailerWithComment(message string, checkpointID id.CheckpointID, agentName, prompt string) string {\\n  1287→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1288→\\tcommentLines := []string{\\n  1289→\\t\\t\\\"# Remove the Entire-Checkpoint trailer above if you don't want to link this commit to \\\" + agentName + \\\" session context.\\\",\\n  1290→\\t}\\n  1291→\\tif prompt != \\\"\\\" {\\n  1292→\\t\\tcommentLines = append(commentLines, \\\"# Last Prompt: \\\"+prompt)\\n  1293→\\t}\\n  1294→\\tcommentLines = append(commentLines, \\\"# The trailer will be added to your next commit based on this branch.\\\")\\n  1295→\\tcomment := strings.Join(commentLines, \\\"\\\\n\\\")\\n  1296→\\n  1297→\\tlines := strings.Split(message, \\\"\\\\n\\\")\\n  1298→\\n  1299→\\t// Find where the git comment block starts (first # line)\\n  1300→\\tcommentStart := -1\\n  1301→\\tfor i, line := range lines {\\n  1302→\\t\\tif strings.HasPrefix(line, \\\"#\\\") {\\n  1303→\\t\\t\\tcommentStart = i\\n  1304→\\t\\t\\tbreak\\n  1305→\\t\\t}\\n  1306→\\t}\\n  1307→\\n  1308→\\tif commentStart == -1 {\\n  1309→\\t\\t// No git comments, append trailer at the end\\n  1310→\\t\\treturn strings.TrimRight(message, \\\"\\\\n\\\") + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\"\\n  1311→\\t}\\n  1312→\\n  1313→\\t// Split into user content and git comments\\n  1314→\\tuserContent := strings.Join(lines[:commentStart], \\\"\\\\n\\\")\\n  1315→\\tgitComments := strings.Join(lines[commentStart:], \\\"\\\\n\\\")\\n  1316→\\n  1317→\\t// Build result: user content, blank line, trailer, comment, blank line, git comments\\n  1318→\\tuserContent = strings.TrimRight(userContent, \\\"\\\\n\\\")\\n  1319→\\tif userContent == \\\"\\\" {\\n  1320→\\t\\t// No user content yet - leave space for them to type, then trailer\\n  1321→\\t\\t// Two newlines: first for user's message line, second for blank separator\\n  1322→\\t\\treturn \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1323→\\t}\\n  1324→\\treturn userContent + \\\"\\\\n\\\\n\\\" + trailer + \\\"\\\\n\\\" + comment + \\\"\\\\n\\\\n\\\" + gitComments\\n  1325→}\\n  1326→\\n  1327→// InitializeSession creates session state for a new session or updates an existing one.\\n  1328→// This implements the optional SessionInitializer interface.\\n  1329→// Called during UserPromptSubmit to allow git hooks to detect active sessions.\\n  1330→//\\n  1331→// If the session already exists and HEAD has moved (e.g., user committed), updates\\n  1332→// BaseCommit to the new HEAD so future checkpoints go to the correct shadow branch.\\n  1333→//\\n  1334→// If there's an existing shadow branch with commits from a different session ID,\\n  1335→// returns a SessionIDConflictError to prevent orphaning existing session work.\\n  1336→//\\n  1337→// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n  1338→// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n  1339→// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\n  1340→func (s *ManualCommitStrategy) InitializeSession(sessionID string, agentType agent.AgentType, transcriptPath string, userPrompt string) error {\\n  1341→\\trepo, err := OpenRepository()\\n  1342→\\tif err != nil {\\n  1343→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n  1344→\\t}\\n  1345→\\n  1346→\\t// Check if session already exists\\n  1347→\\tstate, err := s.loadSessionState(sessionID)\\n  1348→\\tif err != nil {\\n  1349→\\t\\treturn fmt.Errorf(\\\"failed to check session state: %w\\\", err)\\n  1350→\\t}\\n  1351→\\n  1352→\\tif state != nil && state.BaseCommit != \\\"\\\" {\\n  1353→\\t\\t// Session is fully initialized — apply phase transition for TurnStart\\n  1354→\\t\\tTransitionAndLog(state, session.EventTurnStart, session.TransitionContext{})\\n  1355→\\n  1356→\\t\\t// Generate a new TurnID for each turn (correlates carry-forward checkpoints)\\n  1357→\\t\\tturnID, err := id.Generate()\\n  1358→\\t\\tif err != nil {\\n  1359→\\t\\t\\treturn fmt.Errorf(\\\"failed to generate turn ID: %w\\\", err)\\n  1360→\\t\\t}\\n  1361→\\t\\tstate.TurnID = turnID.String()\\n  1362→\\n  1363→\\t\\t// Backfill AgentType if empty or set to the generic default \\\"Agent\\\"\\n  1364→\\t\\tif !isSpecificAgentType(state.AgentType) && agentType != \\\"\\\" {\\n  1365→\\t\\t\\tstate.AgentType = agentType\\n  1366→\\t\\t}\\n  1367→\\n  1368→\\t\\t// Backfill FirstPrompt if empty (for sessions created before the first_prompt field was added)\\n  1369→\\t\\tif state.FirstPrompt == \\\"\\\" && userPrompt != \\\"\\\" {\\n  1370→\\t\\t\\tstate.FirstPrompt = truncatePromptForStorage(userPrompt)\\n  1371→\\t\\t}\\n  1372→\\n  1373→\\t\\t// Update transcript path if provided (may change on session resume)\\n  1374→\\t\\tif transcriptPath != \\\"\\\" && state.TranscriptPath != transcriptPath {\\n  1375→\\t\\t\\tstate.TranscriptPath = transcriptPath\\n  1376→\\t\\t}\\n  1377→\\n  1378→\\t\\t// Clear checkpoint IDs on every new prompt.\\n  1379→\\t\\t// LastCheckpointID is set during PostCommit, cleared at new prompt.\\n  1380→\\t\\t// TurnCheckpointIDs tracks mid-turn checkpoints for stop-time finalization.\\n  1381→\\t\\tstate.LastCheckpointID = \\\"\\\"\\n  1382→\\t\\tstate.TurnCheckpointIDs = nil\\n  1383→\\n  1384→\\t\\t// Calculate attribution at prompt start (BEFORE agent makes any changes)\\n  1385→\\t\\t// This captures user edits since the last checkpoint (or base commit for first prompt).\\n  1386→\\t\\t// IMPORTANT: Always calculate attribution, even for the first checkpoint, to capture\\n  1387→\\t\\t// user edits made before the first prompt. The inner CalculatePromptAttribution handles\\n  1388→\\t\\t// nil lastCheckpointTree by falling back to baseTree.\\n  1389→\\t\\tpromptAttr := s.calculatePromptAttributionAtStart(repo, state)\\n  1390→\\t\\tstate.PendingPromptAttribution = &promptAttr\\n  1391→\\n  1392→\\t\\t// Check if HEAD has moved (user pulled/rebased or committed)\\n  1393→\\t\\t// migrateShadowBranchIfNeeded handles renaming the shadow branch and updating state.BaseCommit\\n  1394→\\t\\tif _, err := s.migrateShadowBranchIfNeeded(repo, state); err != nil {\\n  1395→\\t\\t\\treturn fmt.Errorf(\\\"failed to check/migrate shadow branch: %w\\\", err)\\n  1396→\\t\\t}\\n  1397→\\n  1398→\\t\\tif err := s.saveSessionState(state); err != nil {\\n  1399→\\t\\t\\treturn fmt.Errorf(\\\"failed to update session state: %w\\\", err)\\n  1400→\\t\\t}\\n  1401→\\t\\treturn nil\\n  1402→\\t}\\n  1403→\\t// If state exists but BaseCommit is empty, it's a partial state from concurrent warning\\n  1404→\\t// Continue below to properly initialize it\\n  1405→\\n  1406→\\t// Initialize new session\\n  1407→\\tstate, err = s.initializeSession(repo, sessionID, agentType, transcriptPath, userPrompt)\\n  1408→\\tif err != nil {\\n  1409→\\t\\treturn fmt.Errorf(\\\"failed to initialize session: %w\\\", err)\\n  1410→\\t}\\n  1411→\\n  1412→\\t// Apply phase transition: new session starts as ACTIVE\\n  1413→\\tTransitionAndLog(state, session.EventTurnStart, session.TransitionContext{})\\n  1414→\\n  1415→\\t//