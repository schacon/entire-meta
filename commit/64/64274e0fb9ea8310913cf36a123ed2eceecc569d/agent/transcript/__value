ssionID == \\\"\\\" {\\n   465→\\t\\tsessionID = paths.ExtractSessionIDFromTranscriptPath(input.TranscriptPath)\\n   466→\\t}\\n   467→\\n   468→\\t// Get next checkpoint sequence\\n   469→\\tseq := GetNextCheckpointSequence(sessionID, taskToolUseID)\\n   470→\\n   471→\\t// Extract the todo content from the tool_input.\\n   472→\\t// PostToolUse receives the NEW todo list where the just-completed work is\\n   473→\\t// marked as \\\"completed\\\". The last completed item is the work that was just done.\\n   474→\\ttodoContent := ExtractLastCompletedTodoFromToolInput(input.ToolInput)\\n   475→\\tif todoContent == \\\"\\\" {\\n   476→\\t\\t// No completed items - this is likely the first TodoWrite (planning phase).\\n   477→\\t\\t// Check if there are any todos at all to avoid duplicate messages.\\n   478→\\t\\ttodoCount := CountTodosFromToolInput(input.ToolInput)\\n   479→\\t\\tif todoCount > 0 {\\n   480→\\t\\t\\t// Use \\\"Planning: N todos\\\" format for the first TodoWrite\\n   481→\\t\\t\\ttodoContent = fmt.Sprintf(\\\"Planning: %d todos\\\", todoCount)\\n   482→\\t\\t}\\n   483→\\t\\t// If todoCount == 0, todoContent remains empty and FormatIncrementalMessage\\n   484→\\t\\t// will fall back to \\\"Checkpoint #N\\\" format\\n   485→\\t}\\n   486→\\n   487→\\t// Get agent type from the currently executing hook agent (authoritative source)\\n   488→\\tvar agentType agent.AgentType\\n   489→\\tif hookAgent, agentErr := GetCurrentHookAgent(); agentErr == nil {\\n   490→\\t\\tagentType = hookAgent.Type()\\n   491→\\t}\\n   492→\\n   493→\\t// Build incremental checkpoint context\\n   494→\\tctx := strategy.TaskCheckpointContext{\\n   495→\\t\\tSessionID:           sessionID,\\n   496→\\t\\tToolUseID:           taskToolUseID,\\n   497→\\t\\tModifiedFiles:       changes.Modified,\\n   498→\\t\\tNewFiles:            changes.New,\\n   499→\\t\\tDeletedFiles:        changes.Deleted,\\n   500→\\t\\tTranscriptPath:      input.TranscriptPath,\\n   501→\\t\\tAuthorName:    