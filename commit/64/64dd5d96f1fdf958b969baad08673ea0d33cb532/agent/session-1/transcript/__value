→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    25→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    26→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    27→\\t\\\"github.com/entireio/cli/perf\\\"\\n    28→)\\n    29→\\n    30→// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n    31→// Returns nil if the event was handled successfully.\\n    32→func DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    33→\\tif ag == nil {\\n    34→\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    35→\\t}\\n    36→\\tif event == nil {\\n    37→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    38→\\t}\\n    39→\\n    40→\\tswitch event.Type {\\n    41→\\tcase agent.SessionStart:\\n    42→\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n    43→\\tcase agent.TurnStart:\\n    44→\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n    45→\\tcase agent.TurnEnd:\\n    46→\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n    47→\\tcase agent.Compaction:\\n    48→\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n    49→\\tcase agent.SessionEnd:\\n    50→\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n    51→\\tcase agent.SubagentStart:\\n    52→\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n    53→\\tcase agent.SubagentEnd:\\n    54→\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n    55→\\tdefault:\\n    56→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    57→\\t}\\n    58→}\\n    59→\\n    60→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    61→// fires state machine transition.\\n    62→func handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    63→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n    64→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    65→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    66→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    67→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    68→\\t\\tslog.String(\\\"model\\\", event.Model),\\n    69→\\t)\\n    70→\\n    71→\\tif event.SessionID == \\\"\\\" {\\n    72→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    73→\\t}\\n    74→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    75→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    76→\\t}\\n    77→\\n    78→\\t// Build informational message\\n    79→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    80→\\n    81→\\t// Check for concurrent sessions and append count if any\\n    82→\\t_, countSessionsSpan := perf.Start(ctx, \\\"count_active_sessions\\\")\\n    83→\\tstrat := GetStrategy(ctx)\\n    84→\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n    85→\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    86→\\t}\\n    87→\\tcountSessionsSpan.End()\\n    88→\\n    89→\\t// Output informational message if the agent supports hook responses.\\n    90→\\t// Claude Code reads JSON from stdout; agents that don't implement\\n    91→\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n    92→\\t_, hookResponseSpan := perf.Start(ctx, \\\"write_hook_response\\\")\\n    93→\\tif event.ResponseMessage != \\\"\\\" {\\n    94→\\t\\tmessage = event.ResponseMessage\\n    95→\\t}\\n    96→\\tif writer, ok := ag.(agent.HookResponseWriter); ok {\\n    97→\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n    98→\\t\\t\\thookResponseSpan.End()\\n    99→\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n   100→\\t\\t}\\n   101→\\t}\\n   102→\\thookResponseSpan.End()\\n   103→\\n   104→\\t// Fire EventSessionStart for the current session (if state exists).\\n   105→\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n   106→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n   107→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   108→\\t} else if state != nil {\\n   109→\\t\\tpersistEventMetadataToState(event, state)\\n   110→\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   111→\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n   112→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   113→\\t\\t}\\n   114→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   115→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n   116→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   117→\\t\\t}\\n   118→\\t}\\n   119→\\n   120→\\treturn nil\\n   121→}\\n   122→\\n   123→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   124→// ensures strategy setup, initializes session.\\n   125→func handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   126→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   127→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   128→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   129→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   130→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   131→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   132→\\t)\\n   133→\\n   134→\\tsessionID := event.SessionID\\n   135→\\tif sessionID == \\\"\\\" {\\n   136→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   137→\\t}\\n   138→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   139→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   140→\\t}\\n   141→\\n   142→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   143→\\t_, captureSpan := perf.Start(ctx, \\\"capture_pre_prompt_state\\\")\\n   144→\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n   145→\\t\\tcaptureSpan.End()\\n   146→\\t\\treturn err\\n   147→\\t}\\n   148→\\tcaptureSpan.End()\\n   149→\\n   150→\\t// Ensure strategy setup and initialize session\\n   151→\\t_, initSpan := perf.Start(ctx, \\\"init_session\\\")\\n   152→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   153→\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n   154→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   155→\\t}\\n   156→\\n   157→\\tstrat := GetStrategy(ctx)\\n   158→\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt, event.Model); err != nil {\\n   159→\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n   160→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   161→\\t}\\n   162→\\tinitSpan.End()\\n   163→\\n   164→\\treturn nil\\n   165→}\\n   166→\\n   167→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   168→// detects file changes, saves step + checkpoint, transitions phase.\\n   169→//\\n   170→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   171→func handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   172→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   173→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   174→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   175→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   176→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   177→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   178→\\t)\\n   179→\\n   180→\\tsessionID := event.SessionID\\n   181→\\tif sessionID == \\\"\\\" {\\n   182→\\t\\tsessionID = unknownSessionID\\n   183→\\t}\\n   184→\\n   185→\\ttranscriptRef := event.SessionRef\\n   186→\\tif transcriptRef == \\\"\\\" {\\n   187→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   188→\\t}\\n   189→\\n   190→\\t// If agent implements TranscriptPreparer, materialize the transcript file.\\n   191→\\t// This must run BEFORE fileExists: agents like OpenCode lazily fetch transcripts\\n   192→\\t// via `opencode export`, so the file doesn't exist until PrepareTranscript creates it.\\n   193→\\t// Claude Code's PrepareTranscript just flushes (always succeeds). Agents without\\n   194→\\t// TranscriptPreparer (Gemini, Droid) are unaffected.\\n   195→\\t_, prepareSpan := perf.Start(ctx, \\\"prepare_and_validate_transcript\\\")\\n   196→\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n   197→\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n   198→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n   199→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   200→\\t\\t}\\n   201→\\t}\\n   202→\\n   203→\\tif !fileExists(transcriptRef) {\\n   204→\\t\\tprepareSpan.End()\\n   205→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   206→\\t}\\n   207→\\n   208→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   209→\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n   210→\\t\\tprepareSpan.End()\\n   211→\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n   212→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   213→\\t}\\n   214→\\tprepareSpan.End()\\n   215→\\n   216→\\t// Create session metadata directory\\n   217→\\t_, copySpan := perf.Start(ctx, \\\"copy_transcript\\\")\\n   218→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   219→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   220→\\tif err != nil {\\n   221→\\t\\tsessionDirAbs = sessionDir\\n   222→\\t}\\n   223→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   224→\\t\\tcopySpan.End()\\n   225→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   226→\\t}\\n   227→\\n   228→\\t// Copy transcript to session directory\\n   229→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   230→\\tif err != nil {\\n   231→\\t\\tcopySpan.End()\\n   232→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   233→\\t}\\n   234→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   235→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   236→\\t\\tcopySpan.End()\\n   237→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   238→\\t}\\n   239→\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n   240→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n   241→\\tcopySpan.End()\\n   242→\\n   243→\\t// Load pre-prompt state (captured on TurnStart)\\n   244→\\t_, extractSpan := perf.Start(ctx, \\\"extract_metadata\\\")\\n   245→\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n   246→\\tif err != nil {\\n   247→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n   248→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   249→\\t}\\n   250→\\n   251→\\t// Determine transcript offset\\n   252→\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n   253→\\n   254→\\t// Compute subagents directory for agents that support subagent extraction.\\n   255→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   256→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   257→\\n   258→\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n   259→\\tvar allPrompts []string\\n   260→\\tvar summary string\\n   261→\\tvar modifiedFiles []string\\n   262→\\n   263→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   264→\\t\\t// Extract prompts\\n   265→\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n   266→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract prompts\\\",\\n   267→\\t\\t\\t\\tslog.String(\\\"error\\\", promptErr.Error()))\\n   268→\\t\\t} else {\\n   269→\\t\\t\\tallPrompts = prompts\\n   270→\\t\\t}\\n   271→\\n   272→\\t\\t// Extract summary\\n   273→\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n   274→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract summary\\\",\\n   275→\\t\\t\\t\\tslog.String(\\\"error\\\", sumErr.Error()))\\n   276→\\t\\t} else {\\n   277→\\t\\t\\tsummary = s\\n   278→\\t\\t}\\n   279→\\n   280→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   281→\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n   282→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n   283→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n   284→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   285→\\t\\t\\t} else {\\n   286→\\t\\t\\t\\tmodifiedFiles = files\\n   287→\\t\\t\\t}\\n   288→\\t\\t} else {\\n   289→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   290→\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   291→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n   292→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   293→\\t\\t\\t} else {\\n   294→\\t\\t\\t\\tmodifiedFiles = files\\n   295→\\t\\t\\t}\\n   296→\\t\\t}\\n   297→\\t}\\n   298→\\textractSpan.End()\\n   299→\\n   300→\\t// Write prompts file\\n   301→\\t_, writeFilesSpan := perf.Start(ctx, \\\"write_session_files\\\")\\n   302→\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   303→\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   304→\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   305→\\t\\twriteFilesSpan.End()\\n   306→\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   307→\\t}\\n   308→\\tlogging.Debug(logCtx, \\\"extracted prompts\\\",\\n   309→\\t\\tslog.Int(\\\"count\\\", len(allPrompts)),\\n   310→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.PromptFileName))\\n   311→\\n   312→\\t// Write summary file\\n   313→\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   314→\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   315→\\t\\twriteFilesSpan.End()\\n   316→\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   317→\\t}\\n   318→\\tlogging.Debug(logCtx, \\\"extracted summary\\\",\\n   319→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName))\\n   320→\\n   321→\\t// Generate commit message from last prompt\\n   322→\\tlastPrompt := \\\"\\\"\\n   323→\\tif len(allPrompts) > 0 {\\n   324→\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   325→\\t}\\n   326→\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n   327→\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n   328→\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n   329→\\twriteFilesSpan.End()\\n   330→\\n   331→\\t// Get worktree root for path normalization\\n   332→\\t_, detectSpan := perf.Start(ctx, \\\"detect_file_changes\\\")\\n   333→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   334→\\tif err != nil {\\n   335→\\t\\tdetectSpan.End()\\n   336→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   337→\\t}\\n   338→\\n   339→\\tvar preUntrackedFiles []string\\n   340→\\tif preState != nil {\\n   341→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n   342→\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n   343→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   344→\\t}\\n   345→\\n   346→\\t// Detect file changes via git status\\n   347→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   348→\\tif err != nil {\\n   349→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   350→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   351→\\t}\\n   352→\\tdetectSpan.End()\\n   353→\\n   354→\\t// Filter and normalize all paths\\n   355→\\t_, normalizeSpan := perf.Start(ctx, \\\"filter_and_normalize_paths\\\")\\n   356→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   357→\\tvar relNewFiles, relDeletedFiles []string\\n   358→\\tif changes != nil {\\n   359→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   360→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   361→\\n   362→\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n   363→\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n   364→\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n   365→\\t\\t// Git status catches any tracked file with working-tree changes.\\n   366→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   367→\\t}\\n   368→\\n   369→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   370→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   371→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   372→\\t// if it exists in HEAD with the same content as the working tree.\\n   373→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   374→\\tnormalizeSpan.End()\\n   375→\\n   376→\\t// Check if there are any changes\\n   377→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   378→\\tif totalChanges == 0 {\\n   379→\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n   380→\\t\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n   381→\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   382→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   383→\\t\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   384→\\t\\t}\\n   385→\\t\\treturn nil\\n   386→\\t}\\n   387→\\n   388→\\t// Log file changes\\n   389→\\tlogFileChanges(ctx, relModifiedFiles, relNewFiles, relDeletedFiles)\\n   390→\\n   391→\\t// Create context file, get author, build StepContext, and save step\\n   392→\\t_, saveStepSpan := perf.Start(ctx, \\\"build_and_save_step\\\")\\n   393→\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n   394→\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n   395→\\t\\tsaveStepSpan.End()\\n   396→\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n   397→\\t}\\n   398→\\tlogging.Debug(logCtx, \\\"created context file\\\",\\n   399→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.ContextFileName))\\n   400→\\n   401→\\t// Get git author\\n   402→\\tauthor, err := GetGitAuthor(ctx)\\n   403→\\tif err != nil {\\n   404→\\t\\tsaveStepSpan.End()\\n   405→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   406→\\t}\\n   407→\\n   408→\\t// Get strategy and agent type\\n   409→\\tstrat := GetStrategy(ctx)\\n   410→\\tagentType := ag.Type()\\n   411→\\n   412→\\t// Get transcript position/identifier from pre-prompt state\\n   413→\\tvar transcriptIdentifierAtStart string\\n   414→\\tvar transcriptLinesAtStart int\\n   415→\\tif preState != nil {\\n   416→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   417→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   418→\\t}\\n   419→\\n   420→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   421→\\ttokenUsage := agent.CalculateTokenUsage(ctx, ag, transcriptData, transcriptLinesAtStart, subagentsDir)\\n   422→\\n   423→\\t// Build fully-populated step context and delegate to strategy\\n   424→\\tstepCtx := strategy.StepContext{\\n   425→\\t\\tSessionID:                sessionID,\\n   426→\\t\\tModifiedFiles:            relModifiedFiles,\\n   427→\\t\\tNewFiles:                 relNewFiles,\\n   428→\\t\\tDeletedFiles:             relDeletedFiles,\\n   429→\\t\\tMetadataDir:              sessionDir,\\n   430→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   431→\\t\\tCommitMessage:            commitMessage,\\n   432→\\t\\tTranscriptPath:           transcriptRef,\\n   433→\\t\\tAuthorName:               author.Name,\\n   434→\\t\\tAuthorEmail:              author.Email,\\n   435→\\t\\tAgentType:                agentType,\\n   436→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   437→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   438→\\t\\tTokenUsage:               tokenUsage,\\n   439→\\t}\\n   440→\\n   441→\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   442→\\t\\tsaveStepSpan.End()\\n   443→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   444→\\t}\\n   445→\\tsaveStepSpan.End()\\n   446→\\n   447→\\t// Transition session phase and cleanup\\n   448→\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n   449→\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   450→\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   451→\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   452→\\t}\\n   453→\\n   454→\\treturn nil\\n   455→}\\n   456→\\n   457→// handleLifecycleCompaction handles context compaction: saves current progress\\n   458→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   459→// Also resets the transcript offset since the transcript may be truncated.\\n   460→func handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   461→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   462→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   463→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   464→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   465→\\t)\\n   466→\\n   467→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   468→\\tsessionID := event.SessionID\\n   469→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   470→\\tif loadErr != nil {\\n   471→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for compaction\\\",\\n   472→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   473→\\t}\\n   474→\\tif sessionState != nil {\\n   475→\\t\\tif transErr := strategy.TransitionAndLog(ctx, sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   476→\\t\\t\\tlogging.Warn(logCtx, \\\"compaction transition failed\\\",\\n   477→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   478→\\t\\t}\\n   479→\\n   480→\\t\\tif saveErr := strategy.SaveSessionState(ctx, sessionState); saveErr != nil {\\n   481→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to save session state after compaction\\\",\\n   482→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   483→\\t\\t}\\n   484→\\t}\\n   485→\\n   486→\\tlogging.Info(logCtx, \\\"context compaction detected\\\")\\n   487→\\treturn nil\\n   488→}\\n   489→\\n   490→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   491→func handleLifecycleSessionEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   492→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   493→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   494→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   495→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   496→\\t)\\n   497→\\n   498→\\tif event.SessionID == \\\"\\\" {\\n   499→\\t\\treturn nil // No session to update\\n   500→\\t}\\n   501→\\n   502→\\t// Note: We intentionally don't clean up cached transcripts here.\\n   503→\\t// Post-session commits (carry-forward in ENDED phase) may still need\\n   504→\\t// the transcript to extract file changes. Cleanup is handled by\\n   505→\\t// `entire clean` or when the session state is fully removed.\\n   506→\\n   507→\\tif err := markSessionEnded(ctx, event.SessionID); err != nil {\\n   508→\\t\\tlogging.Warn(logCtx, \\\"failed to mark session ended\\\",\\n   509→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   510→\\t}\\n   511→\\treturn nil\\n   512→}\\n   513→\\n   514→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   515→func handleLifecycleSubagentStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   516→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   517→\\tlogging.Info(logCtx, \\\"subagent started\\\",\\n   518→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   519→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   520→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   521→\\t\\tslog.String(\\\"transcript\\\", event.SessionRef),\\n   522→\\t)\\n   523→\\n   524→\\t// Capture pre-task state\\n   525→\\tif err := CapturePreTaskState(ctx, event.ToolUseID); err != nil {\\n   526→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   527→\\t}\\n   528→\\n   529→\\treturn nil\\n   530→}\\n   531→\\n   532→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   533→func handleLifecycleSubagentEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   534→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   535→\\tif event.SubagentType == \\\"\\\" && event.TaskDescription == \\\"\\\" {\\n   536→\\t\\t// Extract subagent type and description from tool input\\n   537→\\t\\tevent.SubagentType, event.TaskDescription = ParseSubagentTypeAndDescription(event.ToolInput)\\n   538→\\t}\\n   539→\\n   540→\\t// Determine subagent transcript path\\n   541→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   542→\\tvar subagentTranscriptPath string\\n   543→\\tif event.SubagentID != \\\"\\\" {\\n   544→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   545→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   546→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   547→\\t\\t}\\n   548→\\t}\\n   549→\\n   550→\\t// Log context\\n   551→\\tsubagentEndAttrs := []any{\\n   552→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   553→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   554→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   555→\\t}\\n   556→\\tif event.SubagentID != \\\"\\\" {\\n   557→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"agent_id\\\", event.SubagentID))\\n   558→\\t}\\n   559→\\tif subagentTranscriptPath != \\\"\\\" {\\n   560→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"subagent_transcript\\\", subagentTranscriptPath))\\n   561→\\t}\\n   562→\\tlogging.Info(logCtx, \\\"subagent completed\\\", subagentEndAttrs...)\\n   563→\\n   564→\\t// Extract modified files from subagent transcript\\n   565→\\tvar modifiedFiles []string\\n   566→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   567→\\t\\ttranscriptToScan := event.SessionRef\\n   568→\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n   569→\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n   570→\\t\\t}\\n   571→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n   572→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files from subagent\\\",\\n   573→\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   574→\\t\\t} else {\\n   575→\\t\\t\\tmodifiedFiles = files\\n   576→\\t\\t}\\n   577→\\t}\\n   578→\\n   579→\\t// Load pre-task state and detect file changes\\n   580→\\tpreState, err := LoadPreTaskState(ctx, event.ToolUseID)\\n   581→\\tif err != nil {\\n   582→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-task state\\\",\\n   583→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   584→\\t}\\n   585→\\tvar preUntrackedFiles []string\\n   586→\\tif preState != nil {\\n   587→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   588→\\t}\\n   589→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   590→\\tif err != nil {\\n   591→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   592→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   593→\\t}\\n   594→\\n   595→\\t// Get worktree root and normalize paths\\n   596→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   597→\\tif err != nil {\\n   598→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   599→\\t}\\n   600→\\n   601→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   602→\\tvar relNewFiles, relDeletedFiles []string\\n   603→\\tif changes != nil {\\n   604→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   605→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   606→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   607→\\t}\\n   608→\\n   609→\\t// If no changes, skip\\n   610→\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n   611→\\t\\tlogging.Info(logCtx, \\\"no file changes detected, skipping task checkpoint\\\")\\n   612→\\t\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   613→\\t\\treturn nil\\n   614→\\t}\\n   615→\\n   616→\\t// Find checkpoint UUID from main transcript (best-effort)\\n   617→\\tvar checkpointUUID string\\n   618→\\t// Use the existing CLI-level checkpoint UUID finder\\n   619→\\tmainLines, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n   620→\\tif mainLines != nil {\\n   621→\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n   622→\\t}\\n   623→\\n   624→\\t// Get git author\\n   625→\\tauthor, err := GetGitAuthor(ctx)\\n   626→\\tif err != nil {\\n   627→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   628→\\t}\\n   629→\\n   630→\\t// Build task checkpoint context\\n   631→\\tstrat := GetStrategy(ctx)\\n   632→\\tagentType := ag.Type()\\n   633→\\n   634→\\ttaskStepCtx := strategy.TaskStepContext{\\n   635→\\t\\tSessionID:              event.SessionID,\\n   636→\\t\\tToolUseID:              event.ToolUseID,\\n   637→\\t\\tAgentID:                event.SubagentID,\\n   638→\\t\\tModifiedFiles:          relModifiedFiles,\\n   639→\\t\\tNewFiles:               relNewFiles,\\n   640→\\t\\tDeletedFiles:           relDeletedFiles,\\n   641→\\t\\tTranscriptPath:         event.SessionRef,\\n   642→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   643→\\t\\tCheckpointUUID:         checkpointUUID,\\n   644→\\t\\tAuthorName:             author.Name,\\n   645→\\t\\tAuthorEmail:            author.Email,\\n   646→\\t\\tSubagentType:           event.SubagentType,\\n   647→\\t\\tTaskDescription:        event.TaskDescription,\\n   648→\\t\\tAgentType:              agentType,\\n   649→\\t}\\n   650→\\n   651→\\tif err := strat.SaveTaskStep(ctx, taskStepCtx); err != nil {\\n   652→\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n   653→\\t}\\n   654→\\n   655→\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   656→\\treturn nil\\n   657→}\\n   658→\\n   659→// --- Helper functions ---\\n   660→\\n   661→// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n   662→// Prefers pre-prompt state, falls back to session state.\\n   663→func resolveTranscriptOffset(ctx context.Context, preState *PrePromptState, sessionID string) int {\\n   664→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   665→\\tif preState != nil && preState.TranscriptOffset > 0 {\\n   666→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state found, parsing transcript from offset\\\",\\n   667→\\t\\t\\tslog.Int(\\\"offset\\\", preState.TranscriptOffset))\\n   668→\\t\\treturn preState.TranscriptOffset\\n   669→\\t}\\n   670→\\n   671→\\t// Fall back to session state\\n   672→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   673→\\tif loadErr != nil {\\n   674→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state\\\",\\n   675→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   676→\\t\\treturn 0\\n   677→\\t}\\n   678→\\tif sessionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n   679→\\t\\tlogging.Debug(logCtx, \\\"session state found, parsing transcript from offset\\\",\\n   680→\\t\\t\\tslog.Int(\\\"offset\\\", sessionState.CheckpointTranscriptStart))\\n   681→\\t\\treturn sessionState.CheckpointTranscriptStart\\n   682→\\t}\\n   683→\\n   684→\\treturn 0\\n   685→}\\n   686→\\n   687→// createContextFile creates a context.md file for the session checkpoint.\\n   688→// This is a unified version that works for all agents.\\n   689→func createContextFile(contextFile, commitMessage, sessionID string, prompts []string, summary string) error {\\n   690→\\tvar sb strings.Builder\\n   691→\\n   692→\\tsb.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   693→\\tfmt.Fprintf(&sb, \\\"Session ID: %s\\\\n\\\", sessionID)\\n   694→\\tfmt.Fprintf(&sb, \\\"Commit Message: %s\\\\n\\\\n\\\", commitMessage)\\n   695→\\n   696→\\tif len(prompts) > 0 {\\n   697→\\t\\tsb.WriteString(\\\"## Prompts\\\\n\\\\n\\\")\\n   698→\\t\\tfor i, p := range prompts {\\n   699→\\t\\t\\tfmt.Fprintf(&sb, \\\"### Prompt %d\\\\n\\\\n%s\\\\n\\\\n\\\", i+1, p)\\n   700→\\t\\t}\\n   701→\\t}\\n   702→\\n   703→\\tif summary != \\\"\\\" {\\n   704→\\t\\tsb.WriteString(\\\"## Summary\\\\n\\\\n\\\")\\n   705→\\t\\tsb.WriteString(summary)\\n   706→\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   707→\\t}\\n   708→\\n   709→\\tif err := os.WriteFile(contextFile, []byte(sb.String()), 0o600); err != nil {\\n   710→\\t\\treturn fmt.Errorf(\\\"failed to write context file: %w\\\", err)\\n   711→\\t}\\n   712→\\treturn nil\\n   713→}\\n   714→\\n   715→// parseTranscriptForCheckpointUUID is a thin wrapper around transcript parsing for checkpoint UUID lookup.\\n   716→// Returns parsed transcript lines for use with FindCheckpointUUID.\\n   717→func parseTranscriptForCheckpointUUID(transcriptPath string) ([]transcriptLine, error) {\\n   718→\\tlines, err := transcript.ParseFromFileAtLine(transcriptPath, 0)\\n   719→\\tif err != nil {\\n   720→\\t\\treturn nil, fmt.Errorf(\\\"parsing transcript for checkpoint UUID: %w\\\", err)\\n   721→\\t}\\n   722→\\treturn lines, nil\\n   723→}\\n   724→\\n   725→// transitionSessionTurnEnd transitions the session phase to IDLE and dispatches turn-end actions.\\n   726→func transitionSessionTurnEnd(ctx context.Context, sessionID string, event *agent.Event) {\\n   727→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   728→\\tturnState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   729→\\tif loadErr != nil {\\n   730→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for turn end\\\",\\n   731→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   732→\\t\\treturn\\n   733→\\t}\\n   734→\\tif turnState == nil {\\n   735→\\t\\treturn\\n   736→\\t}\\n   737→\\n   738→\\tpersistEventMetadataToState(event, turnState)\\n   739→\\n   740→\\tif err := strategy.TransitionAndLog(ctx, turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   741→\\t\\tlogging.Warn(logCtx, \\\"turn-end transition failed\\\",\\n   742→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   743→\\t}\\n   744→\\n   745→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   746→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   747→\\tstrat := GetStrategy(ctx)\\n   748→\\tif err := strat.HandleTurnEnd(ctx, turnState); err != nil {\\n   749→\\t\\tlogging.Warn(logCtx, \\\"turn-end action dispatch failed\\\",\\n   750→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   751→\\t}\\n   752→\\n   753→\\tif updateErr := strategy.SaveSessionState(ctx, turnState); updateErr != nil {\\n   754→\\t\\tlogging.Warn(logCtx, \\\"failed to update session phase on turn end\\\",\\n   755→\\t\\t\\tslog.String(\\\"error\\\", updateErr.Error()))\\n   756→\\t}\\n   757→}\\n   758→\\n   759→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   760→func markSessionEnded(ctx context.Context, sessionID string) error {\\n   761→\\tstate, err := strategy.LoadSessionState(ctx, sessionID)\\n   762→\\tif err != nil {\\n   763→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   764→\\t}\\n   765→\\tif state == nil {\\n   766→\\t\\treturn nil // No state file, nothing to update\\n   767→\\t}\\n   768→\\n   769→\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStop, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   770→\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"lifecycle\\\"), \\\"session stop transition failed\\\",\\n   771→\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   772→\\t}\\n   773→\\n   774→\\tnow := time.Now()\\n   775→\\tstate.EndedAt = &now\\n   776→\\n   777→\\tif err := strategy.SaveSessionState(ctx, state); err != nil {\\n   778→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   779→\\t}\\n   780→\\treturn nil\\n   781→}\\n   782→\\n   783→// logFileChanges logs the files modified, created, and deleted during a session.\\n   784→func logFileChanges(ctx context.Context, modified, newFiles, deleted []string) {\\n   785→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   786→\\tlogging.Debug(logCtx, \\\"files changed during session\\\",\\n   787→\\t\\tslog.Int(\\\"modified\\\", len(modified)),\\n   788→\\t\\tslog.Int(\\\"new\\\", len(newFiles)),\\n   789→\\t\\tslog.Int(\\\"deleted\\\", len(deleted)))\\n   790→}\\n   791→\\n   792→func persistEventMetadataToState(event *agent.Event, state *strategy.SessionState) {\\n   793→\\t// Update ModelName if provided (model is known by turn-end even on first turn)\\n   794→\\tif event.Model != \\\"\\\" {\\n   795→\\t\\tstate.ModelName = event.Model\\n   796→\\t}\\n   797→}\\n   798→\"}]},\"uuid\":\"1d56375b-6a41-419f-8d54-0d791661c7c9\",\"timestamp\":\"2026-03-05T01:03:52.662Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/pfleidi/entire/cli/.worktrees/performance-logging-investigation/cmd/entire/cli/lifecycle.go\",\"content\":\"// lifecycle.go implements the generic lifecycle event dispatcher.\\n// It routes normalized events from any agent to the appropriate framework actions.\\n//\\n// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n// the dispatcher handles all orchestration: state transitions, strategy calls,\\n// file change detection, metadata generation.\\npackage cli\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n\\t\\\"github.com/entireio/cli/perf\\\"\\n)\\n\\n// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n// Returns nil if the event was handled successfully.\\nfunc DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tif ag == nil {\\n\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n\\t}\\n\\tif event == nil {\\n\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n\\t}\\n\\n\\tswitch event.Type {\\n\\tcase agent.SessionStart:\\n\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n\\tcase agent.TurnStart:\\n\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n\\tcase agent.TurnEnd:\\n\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n\\tcase agent.Compaction:\\n\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n\\tcase agent.SessionEnd:\\n\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n\\tcase agent.SubagentStart:\\n\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n\\tcase agent.SubagentEnd:\\n\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n\\tdefault:\\n\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n\\t}\\n}\\n\\n// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n// fires state machine transition.\\nfunc handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"session-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t\\tslog.String(\\\"model\\\", event.Model),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Build informational message\\n\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n\\n\\t// Check for concurrent sessions and append count if any\\n\\t_, countSessionsSpan := perf.Start(ctx, \\\"count_active_sessions\\\")\\n\\tstrat := GetStrategy(ctx)\\n\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n\\t}\\n\\tcountSessionsSpan.End()\\n\\n\\t// Output informational message if the agent supports hook responses.\\n\\t// Claude Code reads JSON from stdout; agents that don't implement\\n\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n\\t_, hookResponseSpan := perf.Start(ctx, \\\"write_hook_response\\\")\\n\\tif event.ResponseMessage != \\\"\\\" {\\n\\t\\tmessage = event.ResponseMessage\\n\\t}\\n\\tif writer, ok := ag.(agent.HookResponseWriter); ok {\\n\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n\\t\\t\\thookResponseSpan.End()\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\thookResponseSpan.End()\\n\\n\\t// Fire EventSessionStart for the current session (if state exists).\\n\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n\\t} else if state != nil {\\n\\t\\tpersistEventMetadataToState(event, state)\\n\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n\\t\\t}\\n\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n// ensures strategy setup, initializes session.\\nfunc handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t\\tslog.String(\\\"model\\\", event.Model),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n\\t_, captureSpan := perf.Start(ctx, \\\"capture_pre_prompt_state\\\")\\n\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n\\t\\tcaptureSpan.End()\\n\\t\\treturn err\\n\\t}\\n\\tcaptureSpan.End()\\n\\n\\t// Ensure strategy setup and initialize session\\n\\t_, initSpan := perf.Start(ctx, \\\"init_session\\\")\\n\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\tstrat := GetStrategy(ctx)\\n\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt, event.Model); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\tinitSpan.End()\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n// detects file changes, saves step + checkpoint, transitions phase.\\n//\\n//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\nfunc handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t\\tslog.String(\\\"model\\\", event.Model),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\tsessionID = unknownSessionID\\n\\t}\\n\\n\\ttranscriptRef := event.SessionRef\\n\\tif transcriptRef == \\\"\\\" {\\n\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n\\t}\\n\\n\\t// If agent implements TranscriptPreparer, materialize the transcript file.\\n\\t// This must run BEFORE fileExists: agents like OpenCode lazily fetch transcripts\\n\\t// via `opencode export`, so the file doesn't exist until PrepareTranscript creates it.\\n\\t// Claude Code's PrepareTranscript just flushes (always succeeds). Agents without\\n\\t// TranscriptPreparer (Gemini, Droid) are unaffected.\\n\\t_, prepareSpan := perf.Start(ctx, \\\"prepare_and_validate_transcript\\\")\\n\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\tif !fileExists(transcriptRef) {\\n\\t\\tprepareSpan.End()\\n\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n\\t}\\n\\n\\t// Early check: bail out quickly if the repo has no commits yet.\\n\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n\\t\\tprepareSpan.End()\\n\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n\\t}\\n\\tprepareSpan.End()\\n\\n\\t// Create session metadata directory\\n\\t_, copySpan := perf.Start(ctx, \\\"copy_transcript\\\")\\n\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n\\tif err != nil {\\n\\t\\tsessionDirAbs = sessionDir\\n\\t}\\n\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n\\t\\tcopySpan.End()\\n\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n\\t}\\n\\n\\t// Copy transcript to session directory\\n\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n\\tif err != nil {\\n\\t\\tcopySpan.End()\\n\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n\\t}\\n\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n\\t\\tcopySpan.End()\\n\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n\\tcopySpan.End()\\n\\n\\t// Load pre-prompt state (captured on TurnStart)\\n\\t_, extractSpan := perf.Start(ctx, \\\"extract_metadata\\\")\\n\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\t// Determine transcript offset\\n\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n\\n\\t// Compute subagents directory for agents that support subagent extraction.\\n\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n\\n\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n\\tvar allPrompts []string\\n\\tvar summary string\\n\\tvar modifiedFiles []string\\n\\n\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n\\t\\t// Extract prompts\\n\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract prompts\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", promptErr.Error()))\\n\\t\\t} else {\\n\\t\\t\\tallPrompts = prompts\\n\\t\\t}\\n\\n\\t\\t// Extract summary\\n\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract summary\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", sumErr.Error()))\\n\\t\\t} else {\\n\\t\\t\\tsummary = s\\n\\t\\t}\\n\\n\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t}\\n\\t\\t} else {\\n\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\textractSpan.End()\\n\\n\\t// Write prompts file\\n\\t_, writeFilesSpan := perf.Start(ctx, \\\"write_session_files\\\")\\n\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n\\t\\twriteFilesSpan.End()\\n\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"extracted prompts\\\",\\n\\t\\tslog.Int(\\\"count\\\", len(allPrompts)),\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.PromptFileName))\\n\\n\\t// Write summary file\\n\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n\\t\\twriteFilesSpan.End()\\n\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"extracted summary\\\",\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName))\\n\\n\\t// Generate commit message from last prompt\\n\\tlastPrompt := \\\"\\\"\\n\\tif len(allPrompts) > 0 {\\n\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n\\t}\\n\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n\\twriteFilesSpan.End()\\n\\n\\t// Get worktree root for path normalization\\n\\t_, detectSpan := perf.Start(ctx, \\\"detect_file_changes\\\")\\n\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n\\tif err != nil {\\n\\t\\tdetectSpan.End()\\n\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n\\t}\\n\\n\\tvar preUntrackedFiles []string\\n\\tif preState != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n\\t}\\n\\n\\t// Detect file changes via git status\\n\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\tdetectSpan.End()\\n\\n\\t// Filter and normalize all paths\\n\\t_, normalizeSpan := perf.Start(ctx, \\\"filter_and_normalize_paths\\\")\\n\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n\\tvar relNewFiles, relDeletedFiles []string\\n\\tif changes != nil {\\n\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n\\n\\t\\t// Merge git-status modified files as a fal