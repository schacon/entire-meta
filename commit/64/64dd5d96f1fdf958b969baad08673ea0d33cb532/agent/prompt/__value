= range s.children {\n             if !child.ended { child.ended = true; child.duration = time.Since(child.start) }\n             attrs = append(attrs, slog.Int64(fmt.Sprintf(\"steps.%s_ms\", child.name), child.duration.Milliseconds()))\n         }\n         for _, a := range s.attrs { attrs = append(attrs, a) }\n         logging.Debug(s.ctx, \"perf\", attrs...)\n     }\n     \n     func (s *Span) Measure(name string, fn func()) {\n         ctx := contextWithSpan(s.ctx, s)\n         _, child := Start(ctx, name)\n         fn()\n         child.End()\n     }\n     ```\n\n   - **`perf/span_test.go`** (created)\n     - 8 unit tests: root span creation, child nesting, duration recording, idempotent End, auto-end children, Measure helper, nil context, multiple children\n     - All use `t.Parallel()`\n\n   - **`cmd/entire/cli/hook_registry.go`** (modified)\n     - Replaced `time.Now()` + `logging.LogDuration()` with `perf.Start(ctx, hookName)` + `defer span.End()`\n     - Removed `\"time\"` import, added `\"github.com/entireio/cli/perf\"`\n     - Test file also updated to expect new perf log format\n\n   - **`cmd/entire/cli/lifecycle.go`** (modified)\n     - Instrumented SessionStart, TurnStart, and TurnEnd handlers\n     - Used descriptive span variable names ending in `Span` and operation names derived from actual code\n     - SessionStart spans: `countSessionsSpan`/\"count_active_sessions\", `hookResponseSpan`/\"write_hook_response\"\n     - TurnStart spans: `captureSpan`/\"capture_pre_prompt_state\", `initSpan`/\"init_session\"\n     - TurnEnd spans: `prepareSpan`/\"prepare_and_validate_transcript\", `copySpan`/\"copy_transcript\", `extractSpan`/\"extract_metadata\", `writeFilesSpan`/\"write_session_files\", `detectSpan`/\"detect_file_changes\", `normalizeSpan`/\"filter_and_normalize_paths\", `saveStepSpan`/\"build_and_save_step\"\n\n   - **`cmd/entire/cli/strategy/manual_commit_hooks.go`** (modified)\n     - PrepareCommitMsg: 6 spans (open_repository, find_sessions_for