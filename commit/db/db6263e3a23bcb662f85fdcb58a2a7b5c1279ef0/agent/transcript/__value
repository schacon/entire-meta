ext and delegate to strategy\\n   445→\\tstepCtx := strategy.StepContext{\\n   446→\\t\\tSessionID:                sessionID,\\n   447→\\t\\tModifiedFiles:            relModifiedFiles,\\n   448→\\t\\tNewFiles:                 relNewFiles,\\n   449→\\t\\tDeletedFiles:             relDeletedFiles,\\n   450→\\t\\tMetadataDir:              sessionDir,\\n   451→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   452→\\t\\tCommitMessage:            commitMessage,\\n   453→\\t\\tTranscriptPath:           transcriptRef,\\n   454→\\t\\tAuthorName:               author.Name,\\n   455→\\t\\tAuthorEmail:              author.Email,\\n   456→\\t\\tAgentType:                agentType,\\n   457→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   458→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   459→\\t\\tTokenUsage:               tokenUsage,\\n   460→\\t}\\n   461→\\n   462→\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   463→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   464→\\t}\\n   465→\\n   466→\\t// Transition session phase and cleanup\\n   467→\\ttransitionSessionTurnEnd(ctx, sessionID, event.Model)\\n   468→\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   469→\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   470→\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   471→\\t}\\n   472→\\n   473→\\treturn nil\\n   474→}\\n   475→\\n   476→// handleLifecycleCompaction handles context compaction: saves current progress\\n   477→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   478→// Also resets the transcript offset since the transcript may be truncated.\\n   479→func handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   480→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   481→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   482→\\t\\tsl