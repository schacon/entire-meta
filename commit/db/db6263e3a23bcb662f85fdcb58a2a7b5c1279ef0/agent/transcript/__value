\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    17→)\\n    18→\\n    19→// Compile-time interface assertions for new interfaces.\\n    20→var (\\n    21→\\t_ agent.TranscriptAnalyzer     = (*ClaudeCodeAgent)(nil)\\n    22→\\t_ agent.TranscriptPreparer     = (*ClaudeCodeAgent)(nil)\\n    23→\\t_ agent.TokenCalculator        = (*ClaudeCodeAgent)(nil)\\n    24→\\t_ agent.SubagentAwareExtractor = (*ClaudeCodeAgent)(nil)\\n    25→\\t_ agent.HookResponseWriter     = (*ClaudeCodeAgent)(nil)\\n    26→)\\n    27→\\n    28→// WriteHookResponse outputs a JSON hook response to stdout.\\n    29→// Claude Code reads this JSON and displays the systemMessage to the user.\\n    30→func (c *ClaudeCodeAgent) WriteHookResponse(message string) error {\\n    31→\\tresp := struct {\\n    32→\\t\\tSystemMessage string `json:\\\"systemMessage,omitempty\\\"`\\n    33→\\t}{SystemMessage: message}\\n    34→\\tif err := json.NewEncoder(os.Stdout).Encode(resp); err != nil {\\n    35→\\t\\treturn fmt.Errorf(\\\"failed to encode hook response: %w\\\", err)\\n    36→\\t}\\n    37→\\treturn nil\\n    38→}\\n    39→\\n    40→// HookNames returns the hook verbs Claude Code supports.\\n    41→// These become subcommands: entire hooks claude-code <verb>\\n    42→func (c *ClaudeCodeAgent) HookNames() []string {\\n    43→\\treturn []string{\\n    44→\\t\\tHookNameSessionStart,\\n    45→\\t\\tHookNameSessionEnd,\\n    46→\\t\\tHookNameStop,\\n    47→\\t\\tHookNameUserPromptSubmit,\\n    48→\\t\\tHookNamePreTask,\\n    49→\\t\\tHookNamePostTask,\\n    50→\\t\\tHookNamePostTodo,\\n    51→\\t}\\n    52→}\\n    53→\\n    54→// ParseHookEvent translates a Claude Code hook into a normalized lifecycle Event.\\n    55→// Returns nil if the hook has no lifecycle significance.\\n    56→func (c *ClaudeCodeAgent) ParseHookEvent(_ context.Context, hookName string, stdin io.Reader) (*agent.Event, error) {\\n    57→\\tswitch hookName {\\n    58→\\tcase HookNameSessionStart:\\n    59→\\t\\treturn c.parseSessionStart(stdin)\\n    60→\\tcase HookNameUserPromptSubmit:\\n    61→\\t\\treturn c.parseTurnStart(stdin)\\n    62→\\tcase HookNameStop:\\n    63→\\t\\treturn c.parseTurnEnd(stdin)\\n    64→\\tcase HookNameSessionEnd:\\n    65→\\t\\treturn c.parseSessionEnd(stdin)\\n    66→\\tcase HookNamePreTask:\\n    67→\\t\\treturn c.parseSubagentStart(stdin)\\n    68→\\tcase HookNamePostTask:\\n    69→\\t\\treturn c.parseSubagentEnd(stdin)\\n    70→\\tcase HookNamePostTodo:\\n    71→\\t\\t// PostTodo is Claude-specific; handled outside the generic dispatcher.\\n    72→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    73→\\tdefault:\\n    74→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    75→\\t}\\n    76→}\\n    77→\\n    78→// ReadTranscript reads the raw JSONL transcript bytes for a session.\\n    79→func (c *ClaudeCodeAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    80→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n    81→\\tif err != nil {\\n    82→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    83→\\t}\\n    84→\\treturn data, nil\\n    85→}\\n    86→\\n    87→// ExtractPrompts extracts user prompts from the transcript starting at the given line offset.\\n    88→func (c *ClaudeCodeAgent) ExtractPrompts(sessionRef string, fromOffset int) ([]string, error) {\\n    89→\\tlines, err := transcript.ParseFromFileAtLine(sessionRef, fromOffset)\\n    90→\\tif err != nil {\\n    91→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    92→\\t}\\n    93→\\n    94→\\tvar prompts []string\\n    95→\\tfor i := range lines {\\n    96→\\t\\tif lines[i].Type != transcript.TypeUser {\\n    97→\\t\\t\\tcontinue\\n    98→\\t\\t}\\n    99→\\t\\tcontent := transcript.ExtractUserContent(lines[i].Message)\\n   100→\\t\\tif content != \\\"\\\" {\\n   101→\\t\\t\\tprompts = append(prompts, textutil.StripIDEContextTags(content))\\n   102→\\t\\t}\\n   103→\\t}\\n   104→\\treturn prompts, nil\\n   105→}\\n   106→\\n   107→// ExtractSummary extracts the last assistant message as a session summary.\\n   108→func (c *ClaudeCodeAgent) ExtractSummary(sessionRef string) (string, error) {\\n   109→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n   110→\\tif err != nil {\\n   111→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   112→\\t}\\n   113→\\n   114→\\tlines, parseErr := transcript.ParseFromBytes(data)\\n   115→\\tif parseErr != nil {\\n   116→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse transcript: %w\\\", parseErr)\\n   117→\\t}\\n   118→\\n   119→\\t// Walk backward to find last assistant text block\\n   120→\\tfor i := len(lines) - 1; i >= 0; i-- {\\n   121→\\t\\tif lines[i].Type != transcript.TypeAssistant {\\n   122→\\t\\t\\tcontinue\\n   123→\\t\\t}\\n   124→\\t\\tvar msg transcript.AssistantMessage\\n   125→\\t\\tif err := json.Unmarshal(lines[i].Message, &msg); err != nil {\\n   126→\\t\\t\\tcontinue\\n   127→\\t\\t}\\n   128→\\t\\tfor _, block := range msg.Content {\\n   129→\\t\\t\\tif block.Type == transcript.ContentTypeText && block.Text != \\\"\\\" {\\n   130→\\t\\t\\t\\treturn block.Text, nil\\n   131→\\t\\t\\t}\\n   132→\\t\\t}\\n   133→\\t}\\n   134→\\treturn \\\"\\\", nil\\n   135→}\\n   136→\\n   137→// PrepareTranscript waits for Claude Code's async transcript flush to complete.\\n   138→// Claude writes a hook_progress sentinel entry after flushing all pending writes.\\n   139→func (c *ClaudeCodeAgent) PrepareTranscript(ctx context.Context, sessionRef string) error {\\n   140→\\twaitForTranscriptFlush(ctx, sessionRef, time.Now())\\n   141→\\treturn nil\\n   142→}\\n   143→\\n   144→// CalculateTokenUsage computes token usage from the transcript starting at the given line offset.\\n   145→func (c *ClaudeCodeAgent) CalculateTokenUsage(transcriptData []byte, fromOffset int) (*agent.TokenUsage, error) {\\n   146→\\treturn c.CalculateTotalTokenUsage(transcriptData, fromOffset, \\\"\\\")\\n   147→}\\n   148→\\n   149→// --- Internal hook parsing functions ---\\n   150→\\n   151→func (c *ClaudeCodeAgent) parseSessionStart(stdin io.Reader) (*agent.Event, error) {\\n   152→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   153→\\tif err != nil {\\n   154→\\t\\treturn nil, err\\n   155→\\t}\\n   156→\\treturn &agent.Event{\\n   157→\\t\\tType:       agent.SessionStart,\\n   158→\\t\\tSessionID:  raw.SessionID,\\n   159→\\t\\tSessionRef: raw.TranscriptPath,\\n   160→\\t\\tTimestamp:  time.Now(),\\n   161→\\t}, nil\\n   162→}\\n   163→\\n   164→func (c *ClaudeCodeAgent) parseTurnStart(stdin io.Reader) (*agent.Event, error) {\\n   165→\\traw, err := agent.ReadAndParseHookInput[userPromptSubmitRaw](stdin)\\n   166→\\tif err != nil {\\n   167→\\t\\treturn nil, err\\n   168→\\t}\\n   169→\\treturn &agent.Event{\\n   170→\\t\\tType:       agent.TurnStart,\\n   171→\\t\\tSessionID:  raw.SessionID,\\n   172→\\t\\tSessionRef: raw.TranscriptPath,\\n   173→\\t\\tPrompt:     raw.Prompt,\\n   174→\\t\\tTimestamp:  time.Now(),\\n   175→\\t}, nil\\n   176→}\\n   177→\\n   178→func (c *ClaudeCodeAgent) parseTurnEnd(stdin io.Reader) (*agent.Event, error) {\\n   179→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   180→\\tif err != nil {\\n   181→\\t\\treturn nil, err\\n   182→\\t}\\n   183→\\treturn &agent.Event{\\n   184→\\t\\tType:       agent.TurnEnd,\\n   185→\\t\\tSessionID:  raw.SessionID,\\n   186→\\t\\tSessionRef: raw.TranscriptPath,\\n   187→\\t\\tTimestamp:  time.Now(),\\n   188→\\t}, nil\\n   189→}\\n   190→\\n   191→func (c *ClaudeCodeAgent) parseSessionEnd(stdin io.Reader) (*agent.Event, error) {\\n   192→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   193→\\tif err != nil {\\n   194→\\t\\treturn nil, err\\n   195→\\t}\\n   196→\\treturn &agent.Event{\\n   197→\\t\\tType:       agent.SessionEnd,\\n   198→\\t\\tSessionID:  raw.SessionID,\\n   199→\\t\\tSessionRef: raw.TranscriptPath,\\n   200→\\t\\tTimestamp:  time.Now(),\\n   201→\\t}, nil\\n   202→}\\n   203→\\n   204→func (c *ClaudeCodeAgent) parseSubagentStart(stdin io.Reader) (*agent.Event, error) {\\n   205→\\traw, err := agent.ReadAndParseHookInput[taskHookInputRaw](stdin)\\n   206→\\tif err != nil {\\n   207→\\t\\treturn nil, err\\n   208→\\t}\\n   209→\\treturn &agent.Event{\\n   210→\\t\\tType:       agent.SubagentStart,\\n   211→\\t\\tSessionID:  raw.SessionID,\\n   212→\\t\\tSessionRef: raw.TranscriptPath,\\n   213→\\t\\tToolUseID:  raw.ToolUseID,\\n   214→\\t\\tToolInput:  raw.ToolInput,\\n   215→\\t\\tTimestamp:  time.Now(),\\n   216→\\t}, nil\\n   217→}\\n   218→\\n   219→func (c *ClaudeCodeAgent) parseSubagentEnd(stdin io.Reader) (*agent.Event, error) {\\n   220→\\traw, err := agent.ReadAndParseHookInput[postToolHookInputRaw](stdin)\\n   221→\\tif err != nil {\\n   222→\\t\\treturn nil, err\\n   223→\\t}\\n   224→\\tevent := &agent.Event{\\n   225→\\t\\tType:       agent.SubagentEnd,\\n   226→\\t\\tSessionID:  raw.SessionID,\\n   227→\\t\\tSessionRef: raw.TranscriptPath,\\n   228→\\t\\tToolUseID:  raw.ToolUseID,\\n   229→\\t\\tToolInput:  raw.ToolInput,\\n   230→\\t\\tTimestamp:  time.Now(),\\n   231→\\t}\\n   232→\\tif raw.ToolResponse.AgentID != \\\"\\\" {\\n   233→\\t\\tevent.SubagentID = raw.ToolResponse.AgentID\\n   234→\\t}\\n   235→\\treturn event, nil\\n   236→}\\n   237→\\n   238→// --- Transcript flush sentinel ---\\n   239→\\n   240→// stopHookSentinel is the string that appears in Claude Code's hook_progress\\n   241→// entry when the stop hook has been invoked, indicating the transcript is fully flushed.\\n   242→const stopHookSentinel = \\\"hooks claude-code stop\\\"\\n   243→\\n   244→// waitForTranscriptFlush polls the transcript file for the stop hook sentinel.\\n   245→// Falls back silently after a timeout.\\n   246→func waitForTranscriptFlush(ctx context.Context, transcriptPath string, hookStartTime time.Time) {\\n   247→\\tconst (\\n   248→\\t\\tmaxWait      = 3 * time.Second\\n   249→\\t\\tpollInterval = 50 * time.Millisecond\\n   250→\\t\\ttailBytes    = 4096\\n   251→\\t\\tmaxSkew      = 2 * time.Second\\n   252→\\t)\\n   253→\\n   254→\\tlogCtx := logging.WithComponent(ctx, \\\"agent.claudecode\\\")\\n   255→\\n   256→\\t// Fast path: skip the poll loop when the sentinel can't possibly appear.\\n   257→\\t// - File doesn't exist: nothing to poll.\\n   258→\\t// - File is stale (unmodified for 2+ min): agent isn't running anymore.\\n   259→\\t//   This avoids 3s timeouts per stale \\\"active\\\" session (e.g., agent crashed\\n   260→\\t//   without firing stop hook).\\n   261→\\tconst staleThreshold = 2 * time.Minute\\n   262→\\tinfo, err := os.Stat(transcriptPath)\\n   263→\\tif err != nil {\\n   264→\\t\\t// Most likely the file doesn't exist; other errors (permission, etc.)\\n   265→\\t\\t// would also prevent polling, so skip the wait either way.\\n   266→\\t\\treturn\\n   267→\\t}\\n   268→\\tfileAge := time.Since(info.ModTime())\\n   269→\\tif fileAge > staleThreshold {\\n   270→\\t\\tlogging.Debug(logCtx, \\\"transcript file is stale, skipping sentinel wait\\\",\\n   271→\\t\\t\\tslog.Duration(\\\"file_age\\\", fileAge),\\n   272→\\t\\t)\\n   273→\\t\\treturn\\n   274→\\t}\\n   275→\\n   276→\\tdeadline := time.Now().Add(maxWait)\\n   277→\\tfor time.Now().Before(deadline) {\\n   278→\\t\\tif checkStopSentinel(transcriptPath, tailBytes, hookStartTime, maxSkew) {\\n   279→\\t\\t\\tlogging.Debug(logCtx, \\\"transcript flush sentinel found\\\",\\n   280→\\t\\t\\t\\tslog.Duration(\\\"wait\\\", time.Since(hookStartTime)),\\n   281→\\t\\t\\t)\\n   282→\\t\\t\\treturn\\n   283→\\t\\t}\\n   284→\\t\\ttime.Sleep(pollInterval)\\n   285→\\t}\\n   286→\\tlogging.Warn(logCtx, \\\"transcript flush sentinel not found within timeout, proceeding\\\",\\n   287→\\t\\tslog.Duration(\\\"timeout\\\", maxWait),\\n   288→\\t)\\n   289→}\\n   290→\\n   291→// checkStopSentinel reads the tail of the transcript file and looks for the sentinel.\\n   292→func checkStopSentinel(path string, tailBytes int64, hookStartTime time.Time, maxSkew time.Duration) bool {\\n   293→\\tf, err := os.Open(path) //nolint:gosec // path comes from agent hook input\\n   294→\\tif err != nil {\\n   295→\\t\\treturn false\\n   296→\\t}\\n   297→\\tdefer f.Close()\\n   298→\\n   299→\\tinfo, err := f.Stat()\\n   300→\\tif err != nil {\\n   301→\\t\\treturn false\\n   302→\\t}\\n   303→\\toffset := info.Size() - tailBytes\\n   304→\\tif offset < 0 {\\n   305→\\t\\toffset = 0\\n   306→\\t}\\n   307→\\tbuf := make([]byte, info.Size()-offset)\\n   308→\\tif _, err := f.ReadAt(buf, offset); err != nil {\\n   309→\\t\\treturn false\\n   310→\\t}\\n   311→\\n   312→\\tlines := strings.Split(string(buf), \\\"\\\\n\\\")\\n   313→\\tfor _, line := range lines {\\n   314→\\t\\tline = strings.TrimSpace(line)\\n   315→\\t\\tif line == \\\"\\\" || !strings.Contains(line, stopHookSentinel) {\\n   316→\\t\\t\\tcontinue\\n   317→\\t\\t}\\n   318→\\n   319→\\t\\tvar entry struct {\\n   320→\\t\\t\\tTimestamp string `json:\\\"timestamp\\\"`\\n   321→\\t\\t}\\n   322→\\t\\tif json.Unmarshal([]byte(line), &entry) != nil || entry.Timestamp == \\\"\\\" {\\n   323→\\t\\t\\tcontinue\\n   324→\\t\\t}\\n   325→\\t\\tts, err := time.Parse(time.RFC3339Nano, entry.Timestamp)\\n   326→\\t\\tif err != nil {\\n   327→\\t\\t\\tts, err = time.Parse(time.RFC3339, entry.Timestamp)\\n   328→\\t\\t\\tif err != nil {\\n   329→\\t\\t\\t\\tcontinue\\n   330→\\t\\t\\t}\\n   331→\\t\\t}\\n   332→\\t\\t// Validate timestamp is within acceptable range:\\n   333→\\t\\t// - Not too far in the past (before hook started minus skew)\\n   334→\\t\\t// - Not too far in the future (after hook started plus skew)\\n   335→\\t\\tlowerBound := hookStartTime.Add(-maxSkew)\\n   336→\\t\\tupperBound := hookStartTime.Add(maxSkew)\\n   337→\\t\\tif ts.After(lowerBound) &&