fecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    32→\\tif ag == nil {\\n    33→\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    34→\\t}\\n    35→\\tif event == nil {\\n    36→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    37→\\t}\\n    38→\\n    39→\\tswitch event.Type {\\n    40→\\tcase agent.SessionStart:\\n    41→\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n    42→\\tcase agent.TurnStart:\\n    43→\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n    44→\\tcase agent.TurnEnd:\\n    45→\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n    46→\\tcase agent.Compaction:\\n    47→\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n    48→\\tcase agent.SessionEnd:\\n    49→\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n    50→\\tcase agent.SubagentStart:\\n    51→\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n    52→\\tcase agent.SubagentEnd:\\n    53→\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n    54→\\tdefault:\\n    55→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    56→\\t}\\n    57→}\\n    58→\\n    59→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    60→// fires state machine transition.\\n    61→func handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    62→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n    63→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    64→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    65→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    66→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    67→\\t)\\n    68→\\n    69→\\tif event.SessionID == \\\"\\\" {\\n    70→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    71→\\t}\\n    72→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    74→\\t}\\n    75→\\n    76→\\t// Build informational message\\n    77→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    78→\\n    79→\\t// Check for concurrent sessions and append count if any\\n    80→\\tstrat := GetStrategy(ctx)\\n    81→\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n    82→\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    83→\\t}\\n    84→\\n    85→\\t// Output informational message if the agent supports hook responses.\\n    86→\\t// Claude Code reads JSON from stdout; agents that don't implement\\n    87→\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n    88→\\tif event.ResponseMessage != \\\"\\\" {\\n    89→\\t\\tmessage = event.ResponseMessage\\n    90→\\t}\\n    91→\\tif writer, ok := ag.(agent.HookResponseWriter); ok {\\n    92→\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n    93→\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n    94→\\t\\t}\\n    95→\\t}\\n    96→\\n    97→\\t// Fire EventSessionStart for the current session (if state exists).\\n    98→\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n    99→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n   100→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   101→\\t} else if state != nil {\\n   102→\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   103→\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n   104→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   105→\\t\\t}\\n   106→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   107→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n   108→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   109→\\t\\t}\\n   110→\\t}\\n   111→\\n   112→\\treturn nil\\n   113→}\\n   114→\\n   115→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   116→// ensures strategy setup, initializes session.\\n   117→func handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   118→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   119→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   120→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   121→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   122→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   123→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   124→\\t)\\n   125→\\n   126→\\tsessionID := event.SessionID\\n   127→\\tif sessionID == \\\"\\\" {\\n   128→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   129→\\t}\\n   130→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   131→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   132→\\t}\\n   133→\\n   134→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   135→\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n   136→\\t\\treturn err\\n   137→\\t}\\n   138→\\n   139→\\t// Ensure strategy setup and initialize session\\n   140→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   141→\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n   142→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   143→\\t}\\n   144→\\n   145→\\tstrat := GetStrategy(ctx)\\n   146→\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt, event.Model); err != nil {\\n   147→\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n   148→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   149→\\t}\\n   150→\\n   151→\\treturn nil\\n   152→}\\n   153→\\n   154→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   155→// detects file changes, saves step + checkpoint, transitions phase.\\n   156→//\\n   157→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   158→func handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   159→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   160→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   161→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   162→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   163→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   164→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   165→\\t)\\n   166→\\n   167→\\tsessionID := event.SessionID\\n   168→\\tif sessionID == \\\"\\\" {\\n   169→\\t\\tsessionID = unknownSessionID\\n   170→\\t}\\n   171→\\n   172→\\ttranscriptRef := event.SessionRef\\n   173→\\tif transcriptRef == \\\"\\\" {\\n   174→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   175→\\t}\\n   176→\\tif !fileExists(transcriptRef) {\\n   177→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   178→\\t}\\n   179→\\n   180→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   181→\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n   182→\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n   183→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   184→\\t}\\n   185→\\n   186→\\t// Create session metadata directory\\n   187→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   188→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   189→\\tif err != nil {\\n   190→\\t\\tsessionDirAbs = sessionDir\\n   191→\\t}\\n   192→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   193→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   194→\\t}\\n   195→\\n   196→\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n   197→\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n   198→\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n   199→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n   200→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   201→\\t\\t}\\n   202→\\t}\\n   203→\\n   204→\\t// Copy transcript to session directory\\n   205→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   206→\\tif err != nil {\\n   207→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   208→\\t}\\n   209→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   210→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   211→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   212→\\t}\\n   213→\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n   214→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n   215→\\n   216→\\t// Load pre-prompt state (captured on TurnStart)\\n   217→\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n   218→\\tif err != nil {\\n   219→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n   220→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   221→\\t}\\n   222→\\n   223→\\t// Determine transcript offset\\n   224→\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n   225→\\n   226→\\t// Compute subagents directory for agents that support subagent extraction.\\n   227→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   228→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   229→\\n   230→\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n   231→\\tvar allPrompts []string\\n   232→\\tvar summary string\\n   233→\\tvar modifiedFiles []string\\n   234→\\n   235→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   236→\\t\\t// Extract prompts\\n   237→\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n   238→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract prompts\\\",\\n   239→\\t\\t\\t\\tslog.String(\\\"error\\\", promptErr.Error()))\\n   240→\\t\\t} else {\\n   241→\\t\\t\\tallPrompts = prompts\\n   242→\\t\\t}\\n   243→\\n   244→\\t\\t// Extract summary\\n   245→\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n   246→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract summary\\\",\\n   247→\\t\\t\\t\\tslog.String(\\\"error\\\", sumErr.Error()))\\n   248→\\t\\t} else {\\n   249→\\t\\t\\tsummary = s\\n   250→\\t\\t}\\n   251→\\n   252→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   253→\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n   254→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n   255→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n   256→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   257→\\t\\t\\t} else {\\n   258→\\t\\t\\t\\tmodifiedFiles = files\\n   259→\\t\\t\\t}\\n   260→\\t\\t} else {\\n   261→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   262→\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   263→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n   264→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   265→\\t\\t\\t} else {\\n   266→\\t\\t\\t\\tmodifiedFiles = files\\n   267→\\t\\t\\t}\\n   268→\\t\\t}\\n   269→\\t}\\n   270→\\n   271→\\t// Write prompts file\\n   272→\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   273→\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   274→\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   275→\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   276→\\t}\\n   277→\\tlogging.Debug(logCtx, \\\"extracted prompts\\\",\\n   278→\\t\\tslog.Int(\\\"count\\\", len(allPrompts)),\\n   279→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.PromptFileName))\\n   280→\\n   281→\\t// Write summary file\\n   282→\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   283→\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   284→\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   285→\\t}\\n   286→\\tlogging.Debug(logCtx, \\\"extracted summary\\\",\\n   287→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName))\\n   288→\\n   289→\\t// Generate commit message from last prompt\\n   290→\\tlastPrompt := \\\"\\\"\\n   291→\\tif len(allPrompts) > 0 {\\n   292→\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   293→\\t}\\n   294→\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n   295→\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n   296→\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n   297→\\n   298→\\t// Get worktree root for path normalization\\n   299→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   300→\\tif err != nil {\\n   301→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   302→\\t}\\n   303→\\n   304→\\tvar preUntrackedFiles []string\\n   305→\\tif preState != nil {\\n   306→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n   307→\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n   308→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   309→\\t}\\n   310→\\n   311→\\t// Detect file changes via git status\\n   312→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   313→\\tif err != nil {\\n   314→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   315→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   316→\\t}\\n   317→\\n   318→\\t// Filter and normalize all paths\\n   319→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   320→\\tvar relNewFiles, relDeletedFiles []string\\n   321→\\tif changes != nil {\\n   322→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   323→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   324→\\n   325→\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n   326→\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n   327→\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n   328→\\t\\t// Git status catches any tracked file with working-tree changes.\\n   329→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   330→\\t}\\n   331→\\n   332→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   333→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   334→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   335→\\t// if it exists in HEAD with the same content as the working tree.\\n   336→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   337→\\n   338→\\t// Check if there are any changes\\n   339→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   340→\\tif totalChanges == 0 {\\n   341→\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n   342→\\t\\ttransitionSessionTurnEnd(ctx, sessionID, event.Model)\\n   343→\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   344→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   345→\\t\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   346→\\t\\t}\\n   347→\\t\\treturn nil\\n   348→\\t}\\n   349→\\n   350→\\t// Log file changes\\n   351→\\tlogFileChanges(ctx, relModifiedFiles, relNewFiles, relDeletedFiles)\\n   352→\\n   353→\\t// Create context file\\n   354→\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n   355→\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n   356→\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n   357→\\t}\\n   358→\\tlogging.Debug(logCtx, \\\"created context file\\\",\\n   359→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.ContextFileName))\\n   360→\\n   361→\\t// Get git author\\n   362→\\tauthor, err := GetGitAuthor(ctx)\\n   363→\\tif err != nil {\\n   364→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   365→\\t}\\n   366→\\n   367→\\t// Get strategy and agent type\\n   368→\\tstrat := GetStrategy(ctx)\\n   369→\\tagentType := ag.Type()\\n   370→\\n   371→\\t// Get transcript position/identifier from pre-prompt state\\n   372→\\tvar transcriptIdentifierAtStart string\\n   373→\\tvar transcriptLinesAtStart int\\n   374→\\tif preState != nil {\\n   375→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   376→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   377→\\t}\\n   378→\\n   379→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   380→\\ttokenUsage := agent.CalculateTokenUsage(ctx, ag, transcriptData, transcriptLinesAtStart, subagentsDir)\\n   381→\\n   382→\\t// Build fully-populated step context and delegate to strategy\\n   383→\\tstepCtx := strategy.StepContext{\\n   384→\\t\\tSessionID:                sessionID,\\n   385→\\t\\tModifiedFiles:            relModifiedFiles,\\n   386→\\t\\tNewFiles:                 relNewFiles,\\n   387→\\t\\tDeletedFiles:             relDeletedFiles,\\n   388→\\t\\tMetadataDir:              sessionDir,\\n   389→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   390→\\t\\tCommitMessage:            commitMessage,\\n   391→\\t\\tTranscriptPath:           transcriptRef,\\n   392→\\t\\tAuthorName:               author.Name,\\n   393→\\t\\tAuthorEmail:              author.Email,\\n   394→\\t\\tAgentType:                agentType,\\n   395→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   396→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   397→\\t\\tTokenUsage:               tokenUsage,\\n   398→\\t}\\n   399→\\n   400→\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   401→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   402→\\t}\\n   403→\\n   404→\\t// Transition session phase and cleanup\\n   405→\\ttransitionSessionTurnEnd(ctx, sessionID, event.Model)\\n   406→\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   407→\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   408→\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   409→\\t}\\n   410→\\n   411→\\treturn nil\\n   412→}\\n   413→\\n   414→// handleLifecycleCompaction handles context compaction: saves current progress\\n   415→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   416→// Also resets the transcript offset since the transcript may be truncated.\\n   417→func handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   418→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   419→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   420→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   421→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   422→\\t)\\n   423→\\n   424→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   425→\\tsessionID := event.SessionID\\n   426→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   427→\\tif loadErr != nil {\\n   428→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for compaction\\\",\\n   429→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   430→\\t}\\n   431→\\tif sessionState != nil {\\n   432→\\t\\tif transErr := strategy.TransitionAndLog(ctx, sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   433→\\t\\t\\tlogging.Warn(logCtx, \\\"compaction transition failed\\\",\\n   434→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   435→\\t\\t}\\n   436→\\n   437→\\t\\tif saveErr := strategy.SaveSessionState(ctx, sessionState); saveErr != nil {\\n   438→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to save session state after compaction\\\",\\n   439→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   440→\\t\\t}\\n   441→\\t}\\n   442→\\n   443→\\tlogging.Info(logCtx, \\\"context compaction detected\\\")\\n   444→\\treturn nil\\n   445→}\\n   446→\\n   447→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   448→func handleLifecycleSessionEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   449→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   450→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   451→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   452→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   453→\\t)\\n   454→\\n   455→\\tif event.SessionID == \\\"\\\" {\\n   456→\\t\\treturn nil // No session to update\\n   457→\\t}\\n   458→\\n   459→\\t// Note: We intentionally don't clean up cached transcripts here.\\n   460→\\t// Post-session commits (carry-forward in ENDED phase) may still need\\n   461→\\t// the transcript to extract file changes. Cleanup is handled by\\n   462→\\t// `entire clean` or when the session state is fully removed.\\n   463→\\n   464→\\tif err := markSessionEnded(ctx, event.SessionID); err != nil {\\n   465→\\t\\tlogging.Warn(logCtx, \\\"failed to mark session ended\\\",\\n   466→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   467→\\t}\\n   468→\\treturn nil\\n   469→}\\n   470→\\n   471→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   472→func handleLifecycleSubagentStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   473→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   474→\\tlogging.Info(logCtx, \\\"subagent started\\\",\\n   475→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   476→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   477→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   478→\\t\\tslog.String(\\\"transcript\\\", event.SessionRef),\\n   479→\\t)\\n   480→\\n   481→\\t// Capture pre-task state\\n   482→\\tif err := CapturePreTaskState(ctx, event.ToolUseID); err != nil {\\n   483→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   484→\\t}\\n   485→\\n   486→\\treturn nil\\n   487→}\\n   488→\\n   489→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   490→func handleLifecycleSubagentEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   491→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   492→\\tif event.SubagentType == \\\"\\\" && event.TaskDescription == \\\"\\\" {\\n   493→\\t\\t// Extract subagent type and description from tool input\\n   494→\\t\\tevent.SubagentType, event.TaskDescription = ParseSubagentTypeAndDescription(event.ToolInput)\\n   495→\\t}\\n   496→\\n   497→\\t// Determine subagent transcript path\\n   498→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   499→\\tvar subagentTranscriptPath string\\n   500→\\tif event.SubagentID != \\\"\\\" {\\n   501→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   502→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   503→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   504→\\t\\t}\\n   505→\\t}\\n   506→\\n   507→\\t// Log context\\n   508→\\tsubagentEndAttrs := []any{\\n   509→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   510→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   511→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   512→\\t}\\n   513→\\tif event.SubagentID != \\\"\\\" {\\n   514→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"agent_id\\\", event.SubagentID))\\n   515→\\t}\\n   516→\\tif subagentTranscriptPath != \\\"\\\" {\\n   517→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"subagent_transcript\\\", subagentTranscriptPath))\\n   518→\\t}\\n   519→\\tlogging.Info(logCtx, \\\"subagent completed\\\", subagentEndAttrs...)\\n   520→\\n   521→\\t// Extract modified files from subagent transcript\\n   522→\\tvar modifiedFiles []string\\n   523→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   524→\\t\\ttranscriptToScan := event.SessionRef\\n   525→\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n   526→\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n   527→\\t\\t}\\n   528→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n   529→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files from subagent\\\",\\n   530→\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   531→\\t\\t} else {\\n   532→\\t\\t\\tmodifiedFiles = files\\n   533→\\t\\t}\\n   534→\\t}\\n   535→\\n   536→\\t// Load pre-task state and detect file changes\\n   537→\\tpreState, err := LoadPreTaskState(ctx, event.ToolUseID)\\n   538→\\tif err != nil {\\n   539→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-task state\\\",\\n   540→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   541→\\t}\\n   542→\\tvar preUntrackedFiles []string\\n   543→\\tif preState != nil {\\n   544→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   545→\\t}\\n   546→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   547→\\tif err != nil {\\n   548→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   549→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   550→\\t}\\n   551→\\n   552→\\t// Get worktree root and normalize paths\\n   553→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   554→\\tif err != nil {\\n   555→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   556→\\t}\\n   557→\\n   558→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   559→\\tvar relNewFiles, relDeletedFiles []string\\n   560→\\tif changes != nil {\\n   561→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   562→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   563→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   564→\\t}\\n   565→\\n   566→\\t// If no changes, skip\\n   567→\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n   568→\\t\\tlogging.Info(logCtx, \\\"no file changes detected, skipping task checkpoint\\\")\\n   569→\\t\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   570→\\t\\treturn nil\\n   571→\\t}\\n   572→\\n   573→\\t// Find checkpoint UUID from main transcript (best-effort)\\n   574→\\tvar checkpointUUID string\\n   575→\\t// Use the existing CLI-level checkpoint UUID finder\\n   576→\\tmainLines, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n   577→\\tif mainLines != nil {\\n   578→\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n   579→\\t}\\n   580→\\n   581→\\t// Get git author\\n   582→\\tauthor, err := GetGitAuthor(ctx)\\n   583→\\tif err != nil {\\n   584→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   585→\\t}\\n   586→\\n   587→\\t// Build task checkpoint context\\n   588→\\tstrat := GetStrategy(ctx)\\n   589→\\tagentType := ag.Type()\\n   590→\\n   591→\\ttaskStepCtx := strategy.TaskStepContext{\\n   592→\\t\\tSessionID:              event.SessionID,\\n   593→\\t\\tToolUseID:              event.ToolUseID,\\n   594→\\t\\tAgentID:                event.SubagentID,\\n   595→\\t\\tModifiedFiles:          relModifiedFiles,\\n   596→\\t\\tNewFiles:               relNewFiles,\\n   597→\\t\\tDeletedFiles:           relDeletedFiles,\\n   598→\\t\\tTranscriptPath:         event.SessionRef,\\n   599→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   600→\\t\\tCheckpointUUID:         checkpointUUID,\\n   601→\\t\\tAuthorName:             author.Name,\\n   602→\\t\\tAuthorEmail:            author.Email,\\n   603→\\t\\tSubagentType:           event.SubagentType,\\n   604→\\t\\tTaskDescription:        event.TaskDescription,\\n   605→\\t\\tAgentType:              agentType,\\n   606→\\t}\\n   607→\\n   608→\\tif err := strat.SaveTaskStep(ctx, taskStepCtx); err != nil {\\n   609→\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n   610→\\t}\\n   611→\\n   612→\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   613→\\treturn nil\\n   614→}\\n   615→\\n   616→// --- Helper functions ---\\n   617→\\n   618→// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n   619→// Prefers pre-prompt state, falls back to session state.\\n   620→func resolveTranscriptOffset(ctx context.Context, preState *PrePromptState, sessionID string) int {\\n   621→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   622→\\tif preState != nil && preState.TranscriptOffset > 0 {\\n   623→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state found, parsing transcript from offset\\\",\\n   624→\\t\\t\\tslog.Int(\\\"offset\\\", preState.TranscriptOffset))\\n   625→\\t\\treturn preState.TranscriptOffset\\n   626→\\t}\\n   627→\\n   628→\\t// Fall back to session state\\n   629→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   630→\\tif loadErr != nil {\\n   631→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state\\\",\\n   632→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   633→\\t\\treturn 0\\n   634→\\t}\\n   635→\\tif sessionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n   636→\\t\\tlogging.Debug(logCtx, \\\"session state found, parsing transcript from offset\\\",\\n   637→\\t\\t\\tslog.Int(\\\"offset\\\", sessionState.CheckpointTranscriptStart))\\n   638→\\t\\treturn sessionState.CheckpointTranscriptStart\\n   639→\\t}\\n   640→\\n   641→\\treturn 0\\n   642→}\\n   643→\\n   644→// createContextFile creates a context.md file for the session checkpoint.\\n   645→// This is a unified version that works for all agents.\\n   646→func createContextFile(contextFile, commitMessage, sessionID string, prompts []string, summary string) error {\\n   647→\\tvar sb strings.Builder\\n   648→\\n   649→\\tsb.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   650→\\tfmt.Fprintf(&sb, \\\"Session ID: %s\\\\n\\\", sessionID)\\n   651→\\tfmt.Fprintf(&sb, \\\"Commit Message: %s\\\\n\\\\n\\\", commitMessage)\\n   652→\\n   653→\\tif len(prompts) > 0 {\\n   654→\\t\\tsb.WriteString(\\\"## Prompts\\\\n\\\\n\\\")\\n   655→\\t\\tfor i, p := range prompts {\\n   656→\\t\\t\\tfmt.Fprintf(&sb, \\\"### Prompt %d\\\\n\\\\n%s\\\\n\\\\n\\\", i+1, p)\\n   657→\\t\\t}\\n   658→\\t}\\n   659→\\n   660→\\tif summary != \\\"\\\" {\\n   661→\\t\\tsb.WriteString(\\\"## Summary\\\\n\\\\n\\\")\\n   662→\\t\\tsb.WriteString(summary)\\n   663→\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   664→\\t}\\n   665→\\n   666→\\tif err := os.WriteFile(contextFile, []byte(sb.String()), 0o600); err != nil {\\n   667→\\t\\treturn fmt.Errorf(\\\"failed to write context file: %w\\\", err)\\n   668→\\t}\\n   669→\\treturn nil\\n   670→}\\n   671→\\n   672→// parseTranscriptForCheckpointUUID is a thin wrapper around transcript parsing for checkpoint UUID lookup.\\n   673→// Returns parsed transcript lines for use with FindCheckpointUUID.\\n   674→func parseTranscriptForCheckpointUUID(transcriptPath string) ([]transcriptLine, error) {\\n   675→\\tlines, err := transcript.ParseFromFileAtLine(transcriptPath, 0)\\n   676→\\tif err != nil {\\n   677→\\t\\treturn nil, fmt.Errorf(\\\"parsing transcript for checkpoint UUID: %w\\\", err)\\n   678→\\t}\\n   679→\\treturn lines, nil\\n   680→}\\n   681→\\n   682→// transitionSessionTurnEnd transitions the session phase to IDLE and dispatches turn-end actions.\\n   683→func transitionSessionTurnEnd(ctx context.Context, sessionID string, model string) {\\n   684→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   685→\\tturnState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   686→\\tif loadErr != nil {\\n   687→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for turn end\\\",\\n   688→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   689→\\t\\treturn\\n   690→\\t}\\n   691→\\tif turnState == nil {\\n   692→\\t\\treturn\\n   693→\\t}\\n   694→\\n   695→\\t// Update ModelName if provided (model is known by turn-end even on first turn)\\n   696→\\tif model != \\\"\\\" {\\n   697→\\t\\tturnState.ModelName = model\\n   698→\\t}\\n   699→\\n   700→\\tif err := strategy.TransitionAndLog(ctx, turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   701→\\t\\tlogging.Warn(logCtx, \\\"turn-end transition failed\\\",\\n   702→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   703→\\t}\\n   704→\\n   705→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   706→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   707→\\tstrat := GetStrategy(ctx)\\n   708→\\tif err := strat.HandleTurnEnd(ctx, turnState); err != nil {\\n   709→\\t\\tlogging.Warn(logCtx, \\\"turn-end action dispatch failed\\\",\\n   710→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   711→\\t}\\n   712→\\n   713→\\tif updateErr := strategy.SaveSessionState(ctx, turnState); updateErr != nil {\\n   714→\\t\\tlogging.Warn(logCtx, \\\"failed to update session phase on turn end\\\",\\n   715→\\t\\t\\tslog.String(\\\"error\\\", updateErr.Error()))\\n   716→\\t}\\n   717→}\\n   718→\\n   719→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   720→func markSessionEnded(ctx context.Context, sessionID string) error {\\n   721→\\tstate, err := strategy.LoadSessionState(ctx, sessionID)\\n   722→\\tif err != nil {\\n   723→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   724→\\t}\\n   725→\\tif state == nil {\\n   726→\\t\\treturn nil // No state file, nothing to update\\n   727→\\t}\\n   728→\\n   729→\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStop, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   730→\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"lifecycle\\\"), \\\"session stop transition failed\\\",\\n   731→\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   732→\\t}\\n   733→\\n   734→\\tnow := time.Now()\\n   735→\\tstate.EndedAt = &now\\n   736→\\n   737→\\tif err := strategy.SaveSessionState(ctx, state); err != nil {\\n   738→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   739→\\t}\\n   740→\\treturn nil\\n   741→}\\n   742→\\n   743→// logFileChanges logs the files modified, created, and deleted during a session.\\n   744→func logFileChanges(ctx context.Context, modified, newFiles, deleted []string) {\\n   745→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   746→\\tlogging.Debug(logCtx, \\\"files changed during session\\\",\\n   747→\\t\\tslog.Int(\\\"modified\\\", len(modified)),\\n   748→\\t\\tslog.Int(\\\"new\\\", len(newFiles)),\\n   749→\\t\\tslog.Int(\\\"deleted\\\", len(deleted)))\\n   750→}\\n   751→\"}]},\"uuid\":\"48baf5f7-a342-4411-808f-5e7e512e9fff\",\"timestamp\":\"2026-03-03T05:31:09.457Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alex/workspace/cli/.worktrees/1/cmd/entire/cli/lifecycle.go\",\"content\":\"// lifecycle.go implements the generic lifecycle event dispatcher.\\n// It routes normalized events from any agent to the appropriate framework actions.\\n//\\n// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n// the dispatcher handles all orchestration: state transitions, strategy calls,\\n// file change detection, metadata generation.\\npackage cli\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n)\\n\\n// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n// Returns nil if the event was handled successfully.\\nfunc DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tif ag == nil {\\n\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n\\t}\\n\\tif event == nil {\\n\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n\\t}\\n\\n\\tswitch event.Type {\\n\\tcase agent.SessionStart:\\n\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n\\tcase agent.TurnStart:\\n\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n\\tcase agent.TurnEnd:\\n\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n\\tcase agent.Compaction:\\n\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n\\tcase agent.SessionEnd:\\n\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n\\tcase agent.SubagentStart:\\n\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n\\tcase agent.SubagentEnd:\\n\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n\\tdefault:\\n\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n\\t}\\n}\\n\\n// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n// fires state machine transition.\\nfunc handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"session-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Build informational message\\n\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n\\n\\t// Check for concurrent sessions and append count if any\\n\\tstrat := GetStrategy(ctx)\\n\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n\\t}\\n\\n\\t// Output informational message if the agent supports hook responses.\\n\\t// Claude Code reads JSON from stdout; agents that don't implement\\n\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n\\tif event.ResponseMessage != \\\"\\\" {\\n\\t\\tmessage = event.ResponseMessage\\n\\t}\\n\\tif writer, ok := ag.(agent.HookResponseWriter); ok {\\n\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// Fire EventSessionStart for the current session (if state exists).\\n\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n\\t} else if state != nil {\\n\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n\\t\\t}\\n\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n// ensures strategy setup, initializes session.\\nfunc handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t\\tslog.String(\\\"model\\\", event.Model),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Ensure strategy setup and initialize session\\n\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\tstrat := GetStrategy(ctx)\\n\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt, event.Model); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n// detects file changes, saves step + checkpoint, transitions phase.\\n//\\n//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\nfunc handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t\\tslog.String(\\\"model\\\", event.Model),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\tsessionID = unknownSessionID\\n\\t}\\n\\n\\ttranscriptRef := event.SessionRef\\n\\tif transcriptRef == \\\"\\\" {\\n\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n\\t}\\n\\tif !fileExists(transcriptRef) {\\n\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n\\t}\\n\\n\\t// Early check: bail out quickly if the repo has no commits yet.\\n\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n\\t}\\n\\n\\t// Create session metadata directory\\n\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n\\tif err != nil {\\n\\t\\tsessionDirAbs = sessionDir\\n\\t}\\n\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n\\t}\\n\\n\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\t// Copy transcript to session directory\\n\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n\\t}\\n\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n\\n\\t// Load pre-prompt state (captured on TurnStart)\\n\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\t// Determine transcript offset\\n\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n\\n\\t// Compute subagents directory for agents that support subagent extraction.\\n\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n\\n\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n\\tvar allPrompts []string\\n\\tvar summary string\\n\\tvar modifiedFiles []string\\n\\n\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n\\t\\t// Extract prompts\\n\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract prompts\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", promptErr.Error()))\\n\\t\\t} else {\\n\\t\\t\\tallPrompts = prompts\\n\\t\\t}\\n\\n\\t\\t// Extract summary\\n\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract summary\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", sumErr.Error()))\\n\\t\\t} else {\\n\\t\\t\\tsummary = s\\n\\t\\t}\\n\\n\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t}\\n\\t\\t} else {\\n\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write prompts file\\n\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"extracted prompts\\\",\\n\\t\\tslog.Int(\\\"count\\\", len(allPrompts)),\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.PromptFileName))\\n\\n\\t// Write summary file\\n\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"extracted summary\\\",\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName))\\n\\n\\t// Generate commit message from last prompt\\n\\tlastPrompt := \\\"\\\"\\n\\tif len(allPrompts) > 0 {\\n\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n\\t}\\n\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n\\n\\t// Get worktree root for path normalization\\n\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n\\t}\\n\\n\\tvar preUntrackedFiles []string\\n\\tif preState != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n\\t}\\n\\n\\t// Detect file changes via git status\\n\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\t// Filter and normalize all paths\\n\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n\\tvar relNewFiles, relDeletedFiles []string\\n\\tif changes != nil {\\n\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n\\n\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n\\t\\t// Git status catches any tracked file with working-tree changes.\\n\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n\\t}\\n\\n\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n\\t// if it exists in HEAD with the same content as the working tree.\\n\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n\\n\\t// Check if there are any changes\\n\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n\\tif totalChanges == 0 {\\n\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n\\t\\ttransitionSessionTurnEnd(ctx, sessionID, event.Model)\\n\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Log file changes\\n\\tlogFileChanges(ctx, relModifiedFiles, relNewFiles, relDeletedFiles)\\n\\n\\t// Create context file\\n\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"created context file\\\",\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.ContextFileName))\\n\\n\\t// Get git author\\n\\tauthor, err := GetGitAuthor(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n\\t}\\n\\n\\t// Get strategy and agent type\\n\\tstrat := GetStrategy(ctx)\\n\\tagentType := ag.Type()\\n\\n\\t// Get transcript position/identifier from pre-prompt state\\n\\tvar transcriptIdentifierAtStart string\\n\\tvar transcriptLinesAtStart int\\n\\tif preState != nil {\\n\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n\\t}\\n\\n\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n\\ttokenUsage := agent.CalculateTokenUsage(ctx, ag, transcriptData, transcriptLinesAtStart, subagentsDir)\\n\\n\\t// Build fully-populated step context and delegate to strategy\\n\\tstepCtx := strategy.StepContext{\\n\\t\\tSessionID:                sessionID,\\n\\t\\tModifiedFiles:            relModifiedFiles,\\n\\t\\tNewFiles:                 relNewFiles,\\n\\t\\tDeletedFiles:             relDeletedFiles,\\n\\t\\tMetadataDir:              sessionDir,\\n\\t\\tMetadataDirAbs:           sessionDirAbs,\\n\\t\\tCommitMessage:            commitMessage,\\n\\t\\tTranscriptPath:           transcriptRef,\\n\\t\\tAuthorName:               author.Name,\\n\\t\\tAuthorEmail:              author.Email,\\n\\t\\tAgentType:                agentType,\\n\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n\\t\\tTokenUsage:               tokenUsage,\\n\\t}\\n\\n\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n\\t}\\n\\n\\t// Transition session phase and cleanup\\n\\ttransitionSessionTurnEnd(ctx, sessionID, event.Model)\\n\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleCompaction handles context compaction: saves current progress\\n// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n// Also resets the transcript offset since the transcript may be truncated.\\nfunc handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"compaction\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t)\\n\\n\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n\\tsessionID := event.SessionID\\n\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n\\tif loadErr != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for compaction\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n\\t}\\n\\tif sessionState != nil {\\n\\t\\tif transErr := strategy.TransitionAndLog(ctx, sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"compaction transition failed\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n\\t\\t}\\n\\n\\t\\tif saveErr := strategy.SaveSessionState(ctx, sessionState); saveErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to save session state after compaction\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\tlogging.Info(logCtx, \\\"context compaction detected\\\")\\n\\treturn nil\\n}\\n\\n// handleLifecycleSessionEnd handles session end: marks the session as ended.\\nfunc handleLifecycleSessionEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"session-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" {\\n\\t\\treturn nil // No session to update\\n\\t}\\n\\n\\t// Note: We intentionally don't clean up cached transcripts here.\\n\\t// Post-session commits (carry-forward in ENDED phase) may still need\\n\\t// the transcript to extract file changes. Cleanup is handled by\\n\\t// `entire clean` or when the session state is fully removed.\\n\\n\\tif err := markSessionEnded(ctx, event.SessionID); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to mark session ended\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\treturn nil\\n}\\n\\n// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\nfunc handleLifecycleSubagentStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"subagent started\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n\\t\\tslog.String(\\\"transcript\\\", event.SessionRef),\\n\\t)\\n\\n\\t// Capture pre-task state\\n\\tif err := CapturePreTaskState(ctx, event.ToolUseID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\nfunc handleLifecycleSubagentEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tif event.SubagentType == \\\"\\\" && event.TaskDescription == \\\"\\\" {\\n\\t\\t// Extract subagent type and description from tool input\\n\\t\\tevent.SubagentType, event.TaskDescription = ParseSubagentTypeAndDescription(event.ToolInput)\\n\\t}\\n\\n\\t// Determine subagent transcript path\\n\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n\\tvar subagentTranscriptPath string\\n\\tif event.SubagentID != \\\"\\\" {\\n\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n\\t\\tif !fileExists(subagentTranscriptPath) {\\n\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n\\t\\t}\\n\\t}\\n\\n\\t// Log context\\n\\tsubagentEndAttrs := []any{\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n\\t}\\n\\tif event.SubagentID != \\\"\\\" {\\n\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"agent_id\\\", event.SubagentID))\\n\\t}\\n\\tif subagentTranscriptPath != \\\"\\\" {\\n\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"subagent_transcript\\\", subagentTranscriptPath))\\n\\t}\\n\\tlogging.Info(logCtx, \\\"subagent completed\\\", subagentEndAttrs...)\\n\\n\\t// Extract modified files from subagent transcript\\n\\tvar modifiedFiles []string\\n\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n\\t\\ttranscriptToScan := event.SessionRef\\n\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n\\t\\t}\\n\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files from subagent\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n\\t\\t} else {\\n\\t\\t\\tmodifiedFiles = files\\n\\t\\t}\\n\\t}\\n\\n\\t// Load pre-task state and detect file changes\\n\\tpreState, err := LoadPreTaskState(ctx, event.ToolUseID)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-task state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\tvar preUntrackedFiles []string\\n\\tif preState != nil {\\n\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n\\t}\\n\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\t// Get worktree root and normalize paths\\n\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n\\t}\\n\\n\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n\\tvar relNewFiles, relDeletedFiles []string\\n\\tif changes != nil {\\n\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n\\t}\\n\\n\\t// If no changes, skip\\n\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n\\t\\tlogging.Info(logCtx, \\\"no file changes detected, skipping task checkpoint\\\")\\n\\t\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Find checkpoint UUID from main transcript (best-effort)\\n\\tvar checkpointUUID string\\n\\t// Use the existing CLI-level checkpoint UUID finder\\n\\tmainLines, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n\\tif mainLines != nil {\\n\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n\\t}\\n\\n\\t// Get git author\\n\\tauthor, err := GetGitAuthor(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n\\t}\\n\\n\\t// Build task checkpoint context\\n\\tstrat := GetStrategy(ctx)\\n\\tagentType := ag.Type()\\n\\n\\ttaskStepCtx := strategy.TaskStepContext{\\n\\t\\tSessionID:              event.SessionID,\\n\\t\\tToolUseID:              event.ToolUseID,\\n\\t\\tAgentID:                event.SubagentID,\\n\\t\\tModifiedFiles:          relModifiedFiles,\\n\\t\\tNewFiles:               relNewFiles,\\n\\t\\tDeletedFiles:           relDeletedFiles,\\n\\t\\tTranscriptPath:         event.SessionRef,\\n\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n\\t\\tCheckpointUUID:         checkpointUUID,\\n\\t\\tAuthorName:             author.Name,\\n\\t\\tAuthorEmail:            author.Email,\\n\\t\\tSubagentType:           event.SubagentType,\\n\\t\\tTaskDescription:        event.TaskDescription,\\n\\t\\tAgentType:              agentType,\\n\\t}\\n\\n\\tif err := strat.SaveTaskStep(ctx, taskStepCtx); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n\\t}\\n\\n\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n\\treturn nil\\n}\\n\\n// --- Helper functions ---\\n\\n// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n// Prefers pre-prompt state, falls back to session state.\\nfunc resolveTranscriptOffset(ctx context.Context, preState *PrePromptState, sessionID string) int {\\n\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n\\tif preState != nil && preState.TranscriptOffset > 0 {\\n\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state found, parsing transcript from offset\\\",\\n\\t\\t\\tslog.Int(\\\"offset\\\", preState.TranscriptOffset))\\n\\t\\treturn preState.TranscriptOffset\\n\\t}\\n\\n\\t// Fall back to session state\\n\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n\\tif loadErr != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load session state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n\\t\\treturn 0\\n\\t}\\n\\tif sessionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n\\t\\tlogging.Debug(logCtx, \\\"session state found, parsing transcript from offset\\\",\\n\\t\\t\\tslog.Int(\\\"offset\\\", sessionState.CheckpointTranscriptStart))\\n\\t\\treturn sessionState.CheckpointTranscriptStart\\n\\t}\\n\\n\\treturn 0\\n}\\n\\n// createContextFile creates a context.md file for the session checkpoint.\\n// This is a unified version that works for all agents.\\nfunc createContextFile(contextFile, commitMessage, sessionID string, prompts []string, summary string) error {\\n\\tvar sb strings.Builder\\n\\n\\tsb.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n\\tfmt.Fprintf(&sb, \\\"Session ID: %s\\\\n\\\", sessionID)\\n\\tfmt.Fprintf(&sb, \\\"Commit Message: %s\\\\n\\\\n\\\", commitMessage)\\n\\n\\tif len(prompts) > 0 {\\n\\t\\tsb.WriteString(\\\