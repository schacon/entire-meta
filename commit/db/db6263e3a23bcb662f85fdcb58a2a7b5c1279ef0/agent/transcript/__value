ess\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01YJDR8riFXprzSEVFySChJV\",\"type\":\"tool_result\",\"content\":\"     1→package session\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"encoding/json\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"log/slog\\\"\\n     8→\\t\\\"os\\\"\\n     9→\\t\\\"os/exec\\\"\\n    10→\\t\\\"path/filepath\\\"\\n    11→\\t\\\"strings\\\"\\n    12→\\t\\\"sync\\\"\\n    13→\\t\\\"time\\\"\\n    14→\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    21→)\\n    22→\\n    23→const (\\n    24→\\t// SessionStateDirName is the directory name for session state files within git common dir.\\n    25→\\tSessionStateDirName = \\\"entire-sessions\\\"\\n    26→\\n    27→\\t// StaleSessionThreshold is the duration after which an ended session is considered stale\\n    28→\\t// and will be automatically deleted during load/list operations.\\n    29→\\tStaleSessionThreshold = 7 * 24 * time.Hour\\n    30→)\\n    31→\\n    32→// State represents the state of an active session.\\n    33→// This is stored in .git/entire-sessions/<session-id>.json\\n    34→type State struct {\\n    35→\\t// SessionID is the unique session identifier\\n    36→\\tSessionID string `json:\\\"session_id\\\"`\\n    37→\\n    38→\\t// CLIVersion is the version of the CLI that created this session\\n    39→\\tCLIVersion string `json:\\\"cli_version,omitempty\\\"`\\n    40→\\n    41→\\t// BaseCommit tracks the current shadow branch base. Initially set to HEAD when the\\n    42→\\t// session starts, but updated on migration (pull/rebase) and after condensation.\\n    43→\\t// Used for shadow branch naming and checkpoint storage — NOT for attribution.\\n    44→\\tBaseCommit string `json:\\\"base_commit\\\"`\\n    45→\\n    46→\\t// AttributionBaseCommit is the commit used as the reference point for attribution calculations.\\n    47→\\t// Unlike BaseCommit (which tracks the shadow branch and moves with migration), this field\\n    48→\\t// preserves the original base commit so deferred condensation can correctly calculate\\n    49→\\t// agent vs human line attribution. Updated only after successful condensation.\\n    50→\\tAttributionBaseCommit string `json:\\\"attribution_base_commit,omitempty\\\"`\\n    51→\\n    52→\\t// WorktreePath is the absolute path to the worktree root\\n    53→\\tWorktreePath string `json:\\\"worktree_path,omitempty\\\"`\\n    54→\\n    55→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n    56→\\t// Derived from .git/worktrees/<name>/, stable across git worktree move\\n    57→\\tWorktreeID string `json:\\\"worktree_id,omitempty\\\"`\\n    58→\\n    59→\\t// StartedAt is when the session was started\\n    60→\\tStartedAt time.Time `json:\\\"started_at\\\"`\\n    61→\\n    62→\\t// EndedAt is when the session was explicitly closed by the user.\\n    63→\\t// nil means the session is still active or was not cleanly closed.\\n    64→\\tEndedAt *time.Time `json:\\\"ended_at,omitempty\\\"`\\n    65→\\n    66→\\t// Phase is the lifecycle stage of this session (see phase.go).\\n    67→\\t// Empty means idle (backward compat with pre-state-machine files).\\n    68→\\tPhase Phase `json:\\\"phase,omitempty\\\"`\\n    69→\\n    70→\\t// TurnID is a unique identifier for the current agent turn.\\n    71→\\t// Lifecycle:\\n    72→\\t//   - Generated fresh in InitializeSession at each turn start\\n    73→\\t//   - Shared across all checkpoints within the same turn\\n    74→\\t//   - Used to correlate related checkpoints when a turn's work spans multiple commits\\n    75→\\t//   - Persists until the next InitializeSession call generates a new one\\n    76→\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n    77→\\n    78→\\t// TurnCheckpointIDs tracks all checkpoint IDs condensed during the current turn.\\n    79→\\t// Lifecycle:\\n    80→\\t//   - Set in PostCommit when a checkpoint is condensed for an ACTIVE session\\n    81→\\t//   - Consumed in HandleTurnEnd to finalize all checkpoints with the full transcript\\n    82→\\t//   - Cleared in HandleTurnEnd after finalization completes\\n    83→\\t//   - Cleared in InitializeSession when a new prompt starts\\n    84→\\t//   - Cleared when session is reset (ResetSession deletes the state file entirely)\\n    85→\\tTurnCheckpointIDs []string `json:\\\"turn_checkpoint_ids,omitempty\\\"`\\n    86→\\n    87→\\t// LastInteractionTime is updated on agent-interaction events (TurnStart,\\n    88→\\t// TurnEnd, SessionStop, Compaction) but NOT on git commit hooks.\\n    89→\\t// Used for stale session detection in \\\"entire doctor\\\".\\n    90→\\tLastInteractionTime *time.Time `json:\\\"last_interaction_time,omitempty\\\"`\\n    91→\\n    92→\\t// StepCount is the number of checkpoints/steps created in this session.\\n    93→\\t// JSON tag kept as \\\"checkpoint_count\\\" for backward compatibility with existing state files.\\n    94→\\tStepCount int `json:\\\"checkpoint_count\\\"`\\n    95→\\n    96→\\t// CheckpointTranscriptStart is the transcript line offset where the current\\n    97→\\t// checkpoint cycle began. Set to 0 at session start, updated to current\\n    98→\\t// transcript length after each condensation. Used to scope the transcript\\n    99→\\t// for checkpoint condensation: \\\"everything since last checkpoint\\\".\\n   100→\\tCheckpointTranscriptStart int `json:\\\"checkpoint_transcript_start,omitempty\\\"`\\n   101→\\n   102→\\t// Deprecated: CondensedTranscriptLines is replaced by CheckpointTranscriptStart.\\n   103→\\t// Kept for backward compatibility with existing state files.\\n   104→\\t// Use NormalizeAfterLoad() to migrate.\\n   105→\\tCondensedTranscriptLines int `json:\\\"condensed_transcript_lines,omitempty\\\"`\\n   106→\\n   107→\\t// UntrackedFilesAtStart tracks files that existed at session start (to preserve during rewind)\\n   108→\\tUntrackedFilesAtStart []string `json:\\\"untracked_files_at_start,omitempty\\\"`\\n   109→\\n   110→\\t// FilesTouched tracks files modified/created/deleted during this session\\n   111→\\tFilesTouched []string `json:\\\"files_touched,omitempty\\\"`\\n   112→\\n   113→\\t// LastCheckpointID is the checkpoint ID from the most recent condensation.\\n   114→\\t// Used to restore the Entire-Checkpoint trailer on amend and to identify\\n   115→\\t// sessions that have been condensed at least once. Cleared on new prompt.\\n   116→\\tLastCheckpointID id.CheckpointID `json:\\\"last_checkpoint_id,omitempty\\\"`\\n   117→\\n   118→\\t// FullyCondensed indicates this session has been condensed and has no remaining\\n   119→\\t// carry-forward files. PostCommit skips fully-condensed sessions entirely.\\n   120→\\t// Set after successful condensation when no files remain for carry-forward\\n   121→\\t// and the session phase is ENDED. Cleared on session reactivation (ENDED →\\n   122→\\t// ACTIVE via TurnStart, or ENDED → IDLE via SessionStart) by ActionClearEndedAt.\\n   123→\\tFullyCondensed bool `json:\\\"fully_condensed,omitempty\\\"`\\n   124→\\n   125→\\t// AgentType identifies the agent that created this session (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\", \\\"Cursor\\\")\\n   126→\\tAgentType types.AgentType `json:\\\"agent_type,omitempty\\\"`\\n   127→\\n   128→\\t// ModelName is the LLM model used in this session (e.g., \\\"claude-sonnet-4-20250514\\\", \\\"gpt-4o\\\").\\n   129→\\t// Set from hook data when the agent provides it.\\n   130→\\tModelName string `json:\\\"model_name,omitempty\\\"`\\n   131→\\n   132→\\t// Token usage tracking (accumulated across all checkpoints in this session)\\n   133→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   134→\\n   135→\\t// Deprecated: TranscriptLinesAtStart is replaced by CheckpointTranscriptStart.\\n   136→\\t// Kept for backward compatibility with existing state files.\\n   137→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   138→\\n   139→\\t// TranscriptIdentifierAtStart is the last transcript identifier when the session started.\\n   140→\\t// Used for identifier-based transcript scoping (UUID for Claude, message ID for Gemini).\\n   141→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"`\\n   142→\\n   143→\\t// TranscriptPath is the path to the live transcript file (for mid-session commit detection)\\n   144→\\tTranscriptPath string `json:\\\"transcript_path,omitempty\\\"`\\n   145→\\n   146→\\t// FirstPrompt is the first user prompt that started this session (truncated for display)\\n   147→\\tFirstPrompt string `json:\\\"first_prompt,omitempty\\\"`\\n   148→\\n   149→\\t// PromptAttributions tracks user and agent line changes at each prompt start.\\n   150→\\t// This enables accurate attribution by capturing user edits between checkpoints.\\n   151→\\tPromptAttributions []PromptAttribution `json:\\\"prompt_attributions,omitempty\\\"`\\n   152→\\n   153→\\t// PendingPromptAttribution holds attribution calculated at prompt start (before agent runs).\\n   154→\\t// This is moved to PromptAttributions when SaveStep is called.\\n   155→\\tPendingPromptAttribution *PromptAttribution `json:\\\"pending_prompt_attribution,omitempty\\\"`\\n   156→}\\n   157→\\n   158→// PromptAttribution captures line-level attribution data at the start of each prompt.\\n   159→// By recording what changed since the last checkpoint BEFORE the agent works,\\n   160→// we can accurately separate user edits from agent contributions.\\n   161→type PromptAttribution struct {\\n   162→\\t// CheckpointNumber is which checkpoint this was recorded before (1-indexed)\\n   163→\\tCheckpointNumber int `json:\\\"checkpoint_number\\\"`\\n   164→\\n   165→\\t// UserLinesAdded is lines added by user since the last checkpoint\\n   166→\\tUserLinesAdded int `json:\\\"user_lines_added\\\"`\\n   167→\\n   168→\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   169→\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   170→\\n   171→\\t// AgentLinesAdded is total agent lines added so far (base → last checkpoint).\\n   172→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   173→\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   174→\\n   175→\\t// AgentLinesRemoved is total agent lines removed so far (base → last checkpoint).\\n   176→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   177→\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   178→\\n   179→\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   180→\\t// This enables distinguishing user self-modifications from agent modifications.\\n   181→\\t// See docs/architecture/attribution.md for details.\\n   182→\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   183→}\\n   184→\\n   185→// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   186→// Call this after deserializing a State from JSON.\\n   187→func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   188→\\t// Normalize legacy phase values. \\\"active_committed\\\" was removed with the\\n   189→\\t// 1:1 checkpoint model in favor of the state machine handling commits\\n   190→\\t// during ACTIVE phase with immediate condensation.\\n   191→\\tif s.Phase == \\\"active_committed\\\" {\\n   192→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   193→\\t\\tlogging.Info(logCtx, \\\"migrating legacy active_committed phase to active\\\",\\n   194→\\t\\t\\tslog.String(\\\"session_id\\\", s.SessionID),\\n   195→\\t\\t)\\n   196→\\t\\ts.Phase = PhaseActive\\n   197→\\t}\\n   198→\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n   199→\\ts.Phase = PhaseFromString(string(s.Phase))\\n   200→\\n   201→\\t// Migrate transcript fields: CheckpointTranscriptStart replaces both\\n   202→\\t// CondensedTranscriptLines and TranscriptLinesAtStart from older state files.\\n   203→\\tif s.CheckpointTranscriptStart == 0 {\\n   204→\\t\\tif s.CondensedTranscriptLines > 0 {\\n   205→\\t\\t\\ts.CheckpointTranscriptStart = s.CondensedTranscriptLines\\n   206→\\t\\t} else if s.TranscriptLinesAtStart > 0 {\\n   207→\\t\\t\\ts.CheckpointTranscriptStart = s.TranscriptLinesAtStart\\n   208→\\t\\t}\\n   209→\\t}\\n   210→\\t// Clear deprecated fields so they aren't re-persisted.\\n   211→\\t// Note: this is a one-way migration. If the state is re-saved, older CLI versions\\n   212→\\t// will see 0 for these fields and fall back to scoping from the transcript start.\\n   213→\\t// This is acceptable since CLI upgrades are monotonic and the worst case is\\n   214→\\t// redundant transcript content in a condensation, not data loss.\\n   215→\\ts.CondensedTranscriptLines = 0\\n   216→\\ts.TranscriptLinesAtStart = 0\\n   217→\\n   218→\\t// Backfill AttributionBaseCommit for sessions created before this field existed.\\n   219→\\t// Without this, a mid-turn commit would migrate BaseCommit and the fallback in\\n   220→\\t// calculateSessionAttributions would use the migrated value, producing zero attribution.\\n   221→\\tif s.AttributionBaseCommit == \\\"\\\" && s.BaseCommit != \\\"\\\" {\\n   222→\\t\\ts.AttributionBaseCommit = s.BaseCommit\\n   223→\\t}\\n   224→}\\n   225→\\n   226→// IsStale returns true when the last time a session saw interaction exceeds StaleSessionThreshold.\\n   227→// If LastInteractionTime isn't set, we don't consider a session stale to avoid aggressively\\n   228→// deleting things.\\n   229→func (s *State) IsStale() bool {\\n   230→\\treturn s.LastInteractionTime != nil && time.Since(*s.LastInteractionTime) > StaleSessionThreshold\\n   231→}\\n   232→\\n   233→// StateStore provides low-level operations for managing session state files.\\n   234→//\\n   235→// StateStore is a primitive for session state persistence. It is NOT the same as\\n   236→// the Sessions interface - it only handles state files in .git/entire-sessions/,\\n   237→// not the full session data which includes checkpoint content.\\n   238→//\\n   239→// Use StateStore directly in strategies for performance-critical state operations.\\n   240→// Use the Sessions interface (when implemented) for high-level session management.\\n   241→type StateStore struct {\\n   242→\\t// stateDir is the directory where session state files are stored\\n   243→\\tstateDir string\\n   244→}\\n   245→\\n   246→// NewStateStore creates a new state store.\\n   247→// Uses the git common dir to store session state (shared across worktrees).\\n   248→func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   249→\\tcommonDir, err := getGitCommonDir(ctx)\\n   250→\\tif err != nil {\\n   251→\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   252→\\t}\\n   253→\\treturn &StateStore{\\n   254→\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   255→\\t}, nil\\n   256→}\\n   257→\\n   258→// NewStateStoreWithDir creates a new state store with a custom directory.\\n   259→// This is useful for testing.\\n   260→func NewStateStoreWithDir(stateDir string) *StateStore {\\n   261→\\treturn &StateStore{stateDir: stateDir}\\n   262→}\\n   263→\\n   264→// Load loads the session state for the given session ID.\\n   265→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   266→// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   267→func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   268→\\t// Validate session ID to prevent path traversal\\n   269→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   270→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   271→\\t}\\n   272→\\n   273→\\tstateFile := s.stateFilePath(sessionID)\\n   274→\\n   275→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is derived from sessionID\\n   276→\\tif os.IsNotExist(err) {\\n   277→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   278→\\t}\\n   279→\\tif err != nil {\\n   280→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   281→\\t}\\n   282→\\n   283→\\tvar state State\\n   284→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   285→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal session state: %w\\\", err)\\n   286→\\t}\\n   287→\\tstate.NormalizeAfterLoad(ctx)\\n   288→\\n   289→\\tif state.IsStale() {\\n   290→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   291→\\t\\tlogging.Debug(logCtx, \\\"deleting stale session state\\\",\\n   292→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   293→\\t\\t)\\n   294→\\t\\t_ = s.Clear(ctx, sessionID) //nolint:errcheck // best-effort cleanup of stale session\\n   295→\\t\\treturn nil, nil             //nolint:nilnil // stale session treated as not found\\n   296→\\t}\\n   297→\\n   298→\\treturn &state, nil\\n   299→}\\n   300→\\n   301→// Save saves the session state atomically.\\n   302→func (s *StateStore) Save(ctx context.Context, state *State) error {\\n   303→\\t_ = ctx // Reserved for future use\\n   304→\\n   305→\\t// Validate session ID to prevent path traversal\\n   306→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n   307→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   308→\\t}\\n   309→\\n   310→\\tif err := os.MkdirAll(s.stateDir, 0o750); err != nil {\\n   311→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   312→\\t}\\n   313→\\n   314→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   315→\\tif err != nil {\\n   316→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   317→\\t}\\n   318→\\n   319→\\tstateFile := s.stateFilePath(state.SessionID)\\n   320→\\n   321→\\t// Atomic write: write to temp file, then rename\\n   322→\\ttmpFile := stateFile + \\\".tmp\\\"\\n   323→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n   324→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   325→\\t}\\n   326→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n   327→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n   328→\\t}\\n   329→\\treturn nil\\n   330→}\\n   331→\\n   332→// Clear removes the session state file for the given session ID.\\n   333→func (s *StateStore) Clear(ctx context.Context, sessionID string) error {\\n   334→\\t_ = ctx // Reserved for future use\\n   335→\\n   336→\\t// Validate session ID to prevent path traversal\\n   337→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   338→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   339→\\t}\\n   340→\\n   341→\\tstateFile := s.stateFilePath(sessionID)\\n   342→\\n   343→\\tif err := os.Remove(stateFile); err != nil {\\n   344→\\t\\tif os.IsNotExist(err) {\\n   345→\\t\\t\\treturn nil // Already gone, not an error\\n   346→\\t\\t}\\n   347→\\t\\treturn fmt.Errorf(\\\"failed to remove session state file: %w\\\", err)\\n   348→\\t}\\n   349→\\treturn nil\\n   350→}\\n   351→\\n   352→// RemoveAll removes the entire session state directory.\\n   353→// This is used during uninstall to completely remove all session state.\\n   354→func (s *StateStore) RemoveAll() error {\\n   355→\\tif err := os.RemoveAll(s.stateDir); err != nil {\\n   356→\\t\\treturn fmt.Errorf(\\\"failed to remove session state directory: %w\\\", err)\\n   357→\\t}\\n   358→\\treturn nil\\n   359→}\\n   360→\\n   361→// List returns all session states.\\n   362→func (s *StateStore) List(ctx context.Context) ([]*State, error) {\\n   363→\\tentries, err := os.ReadDir(s.stateDir)\\n   364→\\tif os.IsNotExist(err) {\\n   365→\\t\\treturn nil, nil\\n   366→\\t}\\n   367→\\tif err != nil {\\n   368→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state directory: %w\\\", err)\\n   369→\\t}\\n   370→\\n   371→\\tvar states []*State\\n   372→\\tfor _, entry := range entries {\\n   373→\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   374→\\t\\t\\tcontinue\\n   375→\\t\\t}\\n   376→\\t\\tif strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   377→\\t\\t\\tcontinue // Skip temp files\\n   378→\\t\\t}\\n   379→\\n   380→\\t\\tsessionID := strings.TrimSuffix(entry.Name(), \\\".json\\\")\\n   381→\\t\\tstate, err := s.Load(ctx, sessionID)\\n   382→\\t\\tif err != nil {\\n   383→\\t\\t\\tcontinue // Skip corrupted state files\\n   384→\\t\\t}\\n   385→\\t\\tif state == nil {\\n   386→\\t\\t\\tcontinue // Not found or stale (Load handles cleanup)\\n   387→\\t\\t}\\n   388→\\n   389→\\t\\tstates = append(states, state)\\n   390→\\t}\\n   391→\\treturn states, nil\\n   392→}\\n   393→\\n   394→// stateFilePath returns the path to a session state file.\\n   395→func (s *StateStore) stateFilePath(sessionID string) string {\\n   396→\\treturn filepath.Join(s.stateDir, sessionID+\\\".json\\\")\\n   397→}\\n   398→\\n   399→// gitCommonDirCache caches the git common dir to avoid repeated subprocess calls.\\n   400→// Keyed by working directory to handle directory changes (same pattern as paths.WorktreeRoot).\\n   401→var (\\n   402→\\tgitCommonDirMu       sync.RWMutex\\n   403→\\tgitCommonDirCache    string\\n   404→\\tgitCommonDirCacheDir string\\n   405→)\\n   406→