   98→\\n    99→\\t// Store model hint if the agent provided model info on SessionStart\\n   100→\\tif event.Model != \\\"\\\" {\\n   101→\\t\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n   102→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint on session start\\\",\\n   103→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   104→\\t\\t}\\n   105→\\t}\\n   106→\\n   107→\\t// Fire EventSessionStart for the current session (if state exists).\\n   108→\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n   109→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n   110→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   111→\\t} else if state != nil {\\n   112→\\t\\tif event.Model != \\\"\\\" {\\n   113→\\t\\t\\tstate.ModelName = event.Model\\n   114→\\t\\t}\\n   115→\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   116→\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n   117→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   118→\\t\\t}\\n   119→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   120→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n   121→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   122→\\t\\t}\\n   123→\\t}\\n   124→\\n   125→\\treturn nil\\n   126→}\\n   127→\\n   128→// handleLifecycleModelUpdate stores the model name as a hint file so that\\n   129→// subsequent TurnStart/TurnEnd hooks (which run as separate CLI processes)\\n   130→// can pick it up even when the agent doesn't include model info in those hooks.\\n   131→func handleLifecycleModelUpdate(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   132→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   133→\\tlogging.Info(logCtx, \\\"model-update\\\",\\n   134→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   135→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   136→\\t)\\n   137→\\n   138→\\tif event.SessionID == \\\"\\\" || event.Model == \\\"\\\" {\\n   139→\\t\\treturn nil\\n   140→\\t}\\n   141→\\n   142→\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n   143→\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint\\\",\\n   144→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   145→\\t}\\n   146→\\n   147→\\t// Also update session state if it already exists\\n   148→\\tif state, err := strategy.LoadSessionState(ctx, event.SessionID); err == nil && state != nil {\\n   149→\\t\\tstate.ModelName = event.Model\\n   150→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   151→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state with model\\\",\\n   152→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   153→\\t\\t}\\n   154→\\t}\\n   155→\\n   156→\\treturn nil\\n   157→}\\n   158→\\n   159→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   160→// ensures strategy setup, initializes session.\\n   161→func handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   162→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   163→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   164→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   165→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   166→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   167→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   168→\\t)\\n   169→\\n   170→\\tsessionID := event.SessionID\\n   171→\\tif sessionID == \\\"\\\" {\\n   172→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   173→\\t}\\n   174→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   175→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   176→\\t}\\n   177→\\n   178→\\t// Fill model from hint file if the agent didn't provide it on this hook\\n   179→\\tif event.Model == \\\"\\\" {\\n   180→\\t\\tif hint := strategy.LoadModelHint(ctx, sessionID); hint != \\\"\\\" {\\n   181→\\t\\t\\tevent.Model = hint\\n   182→\\t\\t\\tlogging.Debug(logCtx, \\\"loaded model from hint file\\\",\\n   183→\\t\\t\\t\\tslog.String(\\\"model\\\", hint))\\n   184→\\t\\t}\\n   185→\\t}\\n   186→\\n   187→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   188→\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n   189→\\t\\treturn err\\n   190→\\t}\\n   191→\\n   192→\\t// Ensure strategy setup and initialize session\\n   193→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   194→\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n   195→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   196→\\t}\\n   197→\\n   198→\\tstrat := GetStrategy(ctx)\\n   199→\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt, event.Model); err != nil {\\n   200→\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n   201→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   202→\\t}\\n   203→\\n   204→\\treturn nil\\n   205→}\\n   206→\\n   207→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   208→// detects file changes, saves step + checkpoint, transitions phase.\\n   209→//\\n   210→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   211→func handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   212→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   213→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   214→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   215→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   216→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   217→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   218→\\t)\\n   219→\\n   220→\\tsessionID := event.SessionID\\n   221→\\tif sessionID == \\\"\\\" {\\n   222→\\t\\tsessionID = unknownSessionID\\n   223→\\t}\\n   224→\\n   225→\\t// Fill model from hint file if the agent didn't provide it on this hook\\n   226→\\tif event.Model == \\\"\\\" && sessionID != unknownSessionID {\\n   227→\\t\\tif hint := strategy.LoadModelHint(ctx, sessionID); hint != \\\"\\\" {\\n   228→\\t\\t\\tevent.Model = hint\\n   229→\\t\\t\\tlogging.Debug(logCtx, \\\"loaded model from hint file\\\",\\n   230→\\t\\t\\t\\tslog.String(\\\"model\\\", hint))\\n   231→\\t\\t}\\n   232→\\t}\\n   233→\\n   234→\\ttranscriptRef := event.SessionRef\\n   235→\\tif transcriptRef == \\\"\\\" {\\n   236→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   237→\\t}\\n   238→\\tif !fileExists(transcriptRef) {\\n   239→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   240→\\t}\\n   241→\\n   242→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   243→\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n   244→\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n   245→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   246→\\t}\\n   247→\\n   248→\\t// Create session metadata directory\\n   249→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   250→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   251→\\tif err != nil {\\n   252→\\t\\tsessionDirAbs = sessionDir\\n   253→\\t}\\n   254→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   255→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   256→\\t}\\n   257→\\n   258→\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n   259→\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n   260→\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n   261→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n   262→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   263→\\t\\t}\\n   264→\\t}\\n   265→\\n   266→\\t// Copy transcript to session directory\\n   267→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   268→\\tif err != nil {\\n   269→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   270→\\t}\\n   271→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   272→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   273→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   274→\\t}\\n   275→\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n   276→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n   277→\\n   278→\\t// Load pre-prompt state (captured on TurnStart)\\n   279→\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n   280→\\tif err != nil {\\n   281→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n   282→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   283→\\t}\\n   284→\\n   285→\\t// Determine transcript offset\\n   286→\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n   287→\\n   288→\\t// Compute subagents directory for agents that support subagent extraction.\\n   289→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   290→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   291→\\n   292→\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n   293→\\tvar allPrompts []string\\n   294→\\tvar summary string\\n   295→\\tvar modifiedFiles []string\\n   296→\\n   297→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   298→\\t\\t// Extract prompts\\n   299→\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n   300→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract prompts\\\",\\n   301→\\t\\t\\t\\tslog.String(\\\"error\\\", promptErr.Error()))\\n   302→\\t\\t} else {\\n   303→\\t\\t\\tallPrompts = prompts\\n   304→\\t\\t}\\n   305→\\n   306→\\t\\t// Extract summary\\n   307→\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n   308→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract summary\\\",\\n   309→\\t\\t\\t\\tslog.String(\\\"error\\\", sumErr.Error()))\\n   310→\\t\\t} else {\\n   311→\\t\\t\\tsummary = s\\n   312→\\t\\t}\\n   313→\\n   314→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   315→\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n   316→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n   317→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n   318→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   319→\\t\\t\\t} else {\\n   320→\\t\\t\\t\\tmodifiedFiles = files\\n   321→\\t\\t\\t}\\n   322→\\t\\t} else {\\n   323→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   324→\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   325→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n   326→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   327→\\t\\t\\t} else {\\n   328→\\t\\t\\t\\tmodifiedFiles = files\\n   329→\\t\\t\\t}\\n   330→\\t\\t}\\n   331→\\t}\\n   332→\\n   333→\\t// Write prompts file\\n   334→\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   335→\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   336→\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   337→\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   338→\\t}\\n   339→\\tlogging.Debug(logCtx, \\\"extracted prompts\\\",\\n   340→\\t\\tslog.Int(\\\"count\\\", len(allPrompts)),\\n   341→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.PromptFileName))\\n   342→\\n   343→\\t// Write summary file\\n   344→\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   345→\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   346→\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   347→\\t}\\n   348→\\tlogging.Debug(logCtx, \\\"extracted summary\\\",\\n   349→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName))\\n   350→\\n   351→\\t// Generate commit message from last prompt\\n   352→\\tlastPrompt := \\\"\\\"\\n   353→\\tif len(allPrompts) > 0 {\\n   354→\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   355→\\t}\\n   356→\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n   357→\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n   358→\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n   359→\\n   360→\\t// Get worktree root for path normalization\\n   361→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   362→\\tif err != nil {\\n   363→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   364→\\t}\\n   365→\\n   366→\\tvar preUntrackedFiles []string\\n   367→\\tif preState != nil {\\n   368→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n   369→\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n   370→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   371→\\t}\\n   372→\\n   373→\\t// Detect file changes via git status\\n   374→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   375→\\tif err != nil {\\n   376→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   377→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   378→\\t}\\n   379→\\n   380→\\t// Filter and normalize all paths\\n   381→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   382→\\tvar relNewFiles, relDeletedFiles []string\\n   383→\\tif changes != nil {\\n   384→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   385→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   386→\\n   387→\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n   388→\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n   389→\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n   390→\\t\\t// Git status catches any tracked file with working-tree changes.\\n   391→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   392→\\t}\\n   393→\\n   394→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   395→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   396→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   397→\\t// if it exists in HEAD with the same content as the working tree.\\n   398→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   399→\\n   400→\\t// Check if there are any changes\\n   401→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   402→\\tif totalChanges == 0 {\\n   403→\\t\\tlogging.Info(logCtx, \\\"no file