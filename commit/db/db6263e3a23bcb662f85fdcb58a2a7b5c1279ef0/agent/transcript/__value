     turnID.String(),\\n   238→\\t\\tStepCount:             0,\\n   239→\\t\\tUntrackedFilesAtStart: untrackedFiles,\\n   240→\\t\\tAgentType:             agentType,\\n   241→\\t\\tModelName:             model,\\n   242→\\t\\tTranscriptPath:        transcriptPath,\\n   243→\\t\\tFirstPrompt:           truncatePromptForStorage(userPrompt),\\n   244→\\t}\\n   245→\\n   246→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   247→\\t\\treturn nil, err\\n   248→\\t}\\n   249→\\n   250→\\treturn state, nil\\n   251→}\\n   252→\\n   253→// getShadowBranchNameForCommit returns the shadow branch name for the given base commit and worktree ID.\\n   254→// worktreeID should be empty for the main worktree or the internal git worktree name for linked worktrees.\\n   255→func getShadowBranchNameForCommit(baseCommit, worktreeID string) string {\\n   256→\\treturn checkpoint.ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   257→}\\n   258→\"}]},\"uuid\":\"f2364d10-de12-43d6-8f56-438e1e0f9064\",\"timestamp\":\"2026-03-03T06:09:41.100Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a4a7dbdc374441efc\"},\"toolUseID\":\"agent_msg_01Rg6nCdi3ksGGGdy6HPKf16\",\"parentToolUseID\":\"toolu_01AZDGSNmcm6Ja4Sg9ySEb5m\",\"uuid\":\"61dff6b7-e8e9-4501-ae40-29fd9f3016fe\",\"timestamp\":\"2026-03-03T06:09:41.160Z\"}\n{\"parentUuid\":\"61dff6b7-e8e9-4501-ae40-29fd9f3016fe\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/1\",\"sessionId\":\"993f4b55-d917-4933-8513-05c115a0f7ef\",\"version\":\"2.1.63\",\"gitBranch\":\"feat/model-in-session-info\",\"slug\":\"crispy-sprouting-cake\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-03T06:09:41.179Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01JxhiRGMWKaq6Vens3dKNju\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01NrfpHQp4Dtgk2tQ9eZd8rr\"