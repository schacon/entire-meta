   58→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n    59→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n    60→\\t}\\n    61→\\n    62→\\tstateDir, err := getSessionStateDir(ctx)\\n    63→\\tif err != nil {\\n    64→\\t\\treturn fmt.Errorf(\\\"failed to get session state directory: %w\\\", err)\\n    65→\\t}\\n    66→\\n    67→\\tif err := os.MkdirAll(stateDir, 0o750); err != nil {\\n    68→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n    69→\\t}\\n    70→\\n    71→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n    72→\\tif err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n    74→\\t}\\n    75→\\n    76→\\tstateFile, err := sessionStateFile(ctx, state.SessionID)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn fmt.Errorf(\\\"failed to get session state file path: %w\\\", err)\\n    79→\\t}\\n    80→\\n    81→\\t// Atomic write: write to temp file, then rename\\n    82→\\ttmpFile := stateFile + \\\".tmp\\\"\\n    83→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n    84→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n    85→\\t}\\n    86→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n    87→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n    88→\\t}\\n    89→\\treturn nil\\n    90→}\\n    91→\\n    92→// ListSessionStates returns all session states from the state directory.\\n    93→// This is a package-level function that doesn't require a specific strategy instance.\\n    94→func ListSessionStates(ctx context.Context) ([]*SessionState, error) {\\n    95→\\tstore, err := session.NewStateStore(ctx)\\n    96→\\tif err != nil {\\n    97→\\t\\treturn nil, fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n    98→\\t}\\n    99→\\n   100→\\tstates, err := store.List(ctx)\\n   101→\\tif err != nil {\\n   102→\\t\\treturn nil, fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   103→\\t}\\n   104→\\treturn states, nil\\n   105→}\\n   106→\\n   107→// FindMostRecentSession returns the session ID of the most recently interacted session\\n   108→// (by LastInteractionTime) in the current worktree. Returns empty string if no sessions exist.\\n   109→// Scoping to the current worktree prevents cross-worktree pollution in log routing.\\n   110→// Falls back to unfiltered search if the worktree path can't be determined.\\n   111→func FindMostRecentSession(ctx context.Context) string {\\n   112→\\tstates, err := ListSessionStates(ctx)\\n   113→\\tif err != nil || len(states) == 0 {\\n   114→\\t\\treturn \\\"\\\"\\n   115→\\t}\\n   116→\\n   117→\\t// Scope to current worktree to prevent cross-worktree pollution.\\n   118→\\tworktreePath, wpErr := paths.WorktreeRoot(ctx)\\n   119→\\tif wpErr == nil && worktreePath != \\\"\\\" {\\n   120→\\t\\tvar filtered []*SessionState\\n   121→\\t\\tfor _, s := range states {\\n   122→\\t\\t\\tif s.WorktreePath == worktreePath {\\n   123→\\t\\t\\t\\tfiltered = append(filtered, s)\\n   124→\\t\\t\\t}\\n   125→\\t\\t}\\n   126→\\t\\tif len(filtered) > 0 {\\n   127→\\t\\t\\tstates = filtered\\n   128→\\t\\t}\\n   129→\\t\\t// If no sessions match the worktree, fall back to all sessions\\n   130→\\t}\\n   131→\\n   132→\\tvar best *SessionState\\n   133→\\tfor _, s := range states {\\n   134→\\t\\tif s.LastInteractionTime == nil {\\n   135→\\t\\t\\tcontinue\\n   136→\\t\\t}\\n   137→\\t\\tif best == nil || s.LastInteractionTime.After(*best.LastInteractionTime) {\\n   138→\\t\\t\\tbest = s\\n   139→\\t\\t}\\n   140→\\t}\\n   141→\\tif best != nil {\\n   142→\\t\\treturn best.SessionID\\n   143→\\t}\\n   144→\\n   145→\\t// Fallback: return most recently started session\\n   146→\\tfor _, s := range states {\\n   147→\\t\\tif best == nil || s.StartedAt.After(best.StartedAt) {\\n   148→\\t\\t\\tbest = s\\n   149→\\t\\t}\\n   150→\\t}\\n   151→\\tif best != nil {\\n   152→\\t\\treturn best.SessionID\\n   153→\\t}\\n   154→\\treturn \\\"\\\"\\n   155→}\\n   156→\\n   157→// TransitionAndLog runs a session phase transition, applies actions via the\\n   158→// handler, and logs the transition. Returns the first handler error from\\n   159→// ApplyTransition (if any) so callers can surface it. The error is also\\n   160→// logged internally for diagnostics.\\n   161→// This is the single entry point for all state machine transitions to ensure\\n   162→// consistent logging of phase changes.\\n   163→func TransitionAndLog(goCtx context.Context, state *SessionState, event session.Event, ctx session.TransitionContext, handler session.ActionHandler) error {\\n   164→\\toldPhase := state.Phase\\n   165→\\tresult := session.Transition(oldPhase, event, ctx)\\n   166→\\tlogCtx := logging.WithComponent(goCtx, \\\"session\\\")\\n   167→\\n   168→\\thandlerErr := session.ApplyTransition(goCtx, state, result, handler)\\n   169→\\tif handlerErr != nil {\\n   170→\\t\\tlogging.Error(logCtx, \\\"action handler error during transition\\\",\\n   171→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   172→\\t\\t\\tslog.String(\\\"event\\\", event.String()),\\n   173→\\t\\t\\tslog.Any(\\\"error\\\", handlerErr),\\n   174→\\t\\t)\\n   175→\\t}\\n   176→\\n   177→\\tif result.NewPhase != oldPhase {\\n   178→\\t\\tlogging.Info(logCtx, \\\"phase transition\\\",\\n   179→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   180→\\t\\t\\tslog.String(\\\"event\\\", event.String()),\\n   181→\\t\\t\\tslog.String(\\\"from\\\", string(oldPhase)),\\n   182→\\t\\t\\tslog.String(\\\"to\\\", string(result.NewPhase)),\\n   183→\\t\\t)\\n   184→\\t} else {\\n   185→\\t\\tlogging.Debug(logCtx, \\\"phase unchanged\\\",\\n   186→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   187→\\t\\t\\tslog.String(\\\"event\\\", event.String()),\\n   188→\\t\\t\\tslog.String(\\\"phase\\\", string(result.NewPhase)),\\n   189→\\t\\t\\tslog.Any(\\\"result\\\", result),\\n   190→\\t\\t)\\n   191→\\t}\\n   192→\\n   193→\\tif handlerErr != nil {\\n   194→\\t\\treturn fmt.Errorf(\\\"transition %s: %w\\\", event, handlerErr)\\n   195→\\t}\\n   196→\\treturn nil\\n   197→}\\n   198→\\n   199→// StoreModelHint writes the LLM model name to a hint file for cross-process persistence.\\n   200→// Model info may arrive on a different hook invocation (separate CLI process) than TurnStart/TurnEnd.\\n   201→// The hint file bridges this gap so subsequent hooks can read the model.\\n   202→func StoreModelHint(ctx context.Context, sessionID, model string) error {\\n   203→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   204→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   205→\\t}\\n   206→\\tif model == \\\"\\\" {\\n   207→\\t\\treturn nil\\n   208→\\t}\\n   209→\\n   210→\\tstateDir, err := getSessionStateDir(ctx)\\n   211→\\tif err != nil {\\n   212→\\t\\treturn fmt.Errorf(\\\"failed to get session state directory: %w\\\", err)\\n   213→\\t}\\n   214→\\tif err := os.MkdirAll(stateDir, 0o750); err != nil {\\n   215→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   216→\\t}\\n   217→\\n   218→\\thintFile := filepath.Join(stateDir, sessionID+\\\".model\\\")\\n   219→\\tif err := os.WriteFile(hintFile, []byte(model), 0o600); err != nil {\\n   220→\\t\\treturn fmt.Errorf(\\\"failed to write model hint file: %w\\\", err)\\n   221→\\t}\\n   222→\\treturn nil\\n   223→}\\n   224→\\n   225→// LoadModelHint reads the LLM model name from the hint file for the given session.\\n   226→// Returns empty string if the hint file doesn't exist or can't be read.\\n   227→func LoadModelHint(ctx context.Context, sessionID string) string {\\n   228→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   229→\\t\\treturn \\\"\\\"\\n   230→\\t}\\n   231→\\n   232→\\tstateDir, err := getSessionStateDir(ctx)\\n   233→\\tif err != nil {\\n   234→\\t\\treturn \\\"\\\"\\n   235→\\t}\\n   236→\\n   237→\\tdata, err := os.ReadFile(filepath.Join(stateDir, sessionID+\\\".model\\\")) //nolint:gosec // sessionID is validated above\\n   238→\\tif err != nil {\\n   239→\\t\\treturn \\\"\\\"\\n   240→\\t}\\n   241→\\treturn string(data)\\n   242→}\\n   243→\\n   244→// ClearSessionState removes the session state file for the given session ID.\\n   245→func ClearSessionState(ctx context.Context, sessionID string) error {\\n   246→\\t// Validate session ID to prevent path traversal\\n   247→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   248→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   249→\\t}\\n   250→\\n   251→\\tstateFile, err := sessionStateFile(ctx, sessionID)\\n   252→\\tif err != nil {\\n   253→\\t\\treturn fmt.Errorf(\\\"failed to get session state file path: %w\\\", err)\\n   254→\\t}\\n   255→\\n   256→\\tif err := os.Remove(stateFile); err != nil {\\n   257→\\t\\tif os.IsNotExist(err) {\\n   258→\\t\\t\\treturn nil // Already gone, not an error\\n   259→\\t\\t}\\n   260→\\t\\treturn fmt.Errorf(\\\"failed to remove session state file: %w\\\", err)\\n   261→\\t}\\n   262→\\n   263→\\t// Best-effort cleanup of the model hint file\\n   264→\\thintFile := stateFile[:len(stateFile)-len(\\\".json\\\")] + \\\".model\\\"\\n   265→\\tif err := os.Remove(hintFile); err != nil && !os.IsNotExist(err) {\\n   266→\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"session\\\"), \\\"failed to remove model hint file\\\",\\n   267→\\t\\t\\tslog.String(\\\"path\\\", hintFile),\\n   268→\\t\\t\\tslog.Any(\\\"error\\\", err))\\n   269→\\t}\\n   270→\\n   271→\\treturn nil\\n   272→}\\n   273→\"}]},\"uuid\":\"ac6b8c20-c6b9-40e9-af97-0f3d6d9cef21\",\"timestamp\":\"2026-03-03T06:09:41.234Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a4a7dbdc374441efc\"},\"toolUseID\":\"agent_msg_01Rg6nCdi3ksGGGdy6HPKf16\",\"parentToolUseID\":\"toolu_0