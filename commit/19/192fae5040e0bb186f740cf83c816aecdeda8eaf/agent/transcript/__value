pts = append(prompts, textutil.StripIDEContextTags(content))\\n    89→\\t\\t}\\n    90→\\t}\\n    91→\\treturn prompts, nil\\n    92→}\\n    93→\\n    94→// ExtractSummary extracts the last assistant message as a session summary.\\n    95→func (c *ClaudeCodeAgent) ExtractSummary(sessionRef string) (string, error) {\\n    96→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n    97→\\tif err != nil {\\n    98→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    99→\\t}\\n   100→\\n   101→\\tlines, parseErr := transcript.ParseFromBytes(data)\\n   102→\\tif parseErr != nil {\\n   103→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse transcript: %w\\\", parseErr)\\n   104→\\t}\\n   105→\\n   106→\\t// Walk backward to find last assistant text block\\n   107→\\tfor i := len(lines) - 1; i >= 0; i-- {\\n   108→\\t\\tif lines[i].Type != transcript.TypeAssistant {\\n   109→\\t\\t\\tcontinue\\n   110→\\t\\t}\\n   111→\\t\\tvar msg transcript.AssistantMessage\\n   112→\\t\\tif err := json.Unmarshal(lines[i].Message, &msg); err != nil {\\n   113→\\t\\t\\tcontinue\\n   114→\\t\\t}\\n   115→\\t\\tfor _, block := range msg.Content {\\n   116→\\t\\t\\tif block.Type == transcript.ContentTypeText && block.Text != \\\"\\\" {\\n   117→\\t\\t\\t\\treturn block.Text, nil\\n   118→\\t\\t\\t}\\n   119→\\t\\t}\\n   120→\\t}\\n   121→\\treturn \\\"\\\", nil\\n   122→}\\n   123→\\n   124→// PrepareTranscript waits for Claude Code's async transcript flush to complete.\\n   125→// Claude writes a hook_progress sentinel entry after flushing all pending writes.\\n   126→func (c *ClaudeCodeAgent) PrepareTranscript(sessionRef string) error {\\n   127→\\twaitForTranscriptFlush(sessionRef, time.Now())\\n   128→\\treturn nil\\n   129→}\\n   130→\\n   131→// CalculateTokenUsage computes token usage from the transcript starting at the given line offset.\\n   132→func (c *ClaudeCodeAgent) CalculateTokenUsage(sessionRef string, fromOffset int) (*agent.TokenUsage, error) {\\n   133→\\t// Subagent transcripts live in <transcriptDir>/<sessionID>/subagents/\\n   134→\\t// but we don't have the sessionID here. The caller should pass the transcript path\\n   135→\\t// which may contain the session ID in its directory structure.\\n   136→\\t// For now, compute subagentsDir from the transcript path structure.\\n   137→\\treturn CalculateTotalTokenUsage(sessionRef, fromOffset, \\\"\\\")\\n   138→}\\n   139→\\n   140→// --- Internal hook parsing functions ---\\n   141→\\n   142→func (c *ClaudeCodeAgent) parseSessionStart(stdin io.Reader) (*agent.Event, error) {\\n   143→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   144→\\tif err != nil {\\n   145→\\t\\treturn nil, err\\n   146→\\t}\\n   147→\\treturn &agent.Event{\\n   148→\\t\\tType:       agent.SessionStart,\\n   149→\\t\\tSessionID:  raw.SessionID,\\n   150→\\t\\tSessionRef: raw.TranscriptPath,\\n   151→\\t\\tTimestamp:  time.Now(),\\n   152→\\t}, nil\\n   153→}\\n   154→\\n   155→func (c *ClaudeCodeAgent) parseTurnStart(stdin io.Reader) (*agent.Event, error) {\\n   156→\\traw, err := agent.ReadAndParseHookInput[userPromptSubmitRaw](stdin)\\n   157→\\tif err != nil {\\n   158→\\t\\treturn nil, err\\n   159→\\t}\\n   160→\\treturn &agent.Event{\\n   161→\\t\\tType:       agent.TurnStart,\\n   162→\\t\\tSessionID:  raw.SessionID,\\n   163→\\t\\tSessionRef: raw.TranscriptPath,\\n   164→\\t\\tPrompt:     raw.Prompt,\\n   165→\\t\\tTimestamp:  time.Now(),\\n   166→\\t}, nil\\n   167→}\\n   168→\\n   169→func (c *ClaudeCodeAgent) parseTurnEnd(stdin io.Reader) (*agent.Event, error) {\\n   170→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   171→\\tif err != nil {\\n   172→\\t\\treturn nil, err\\n   173→\\t}\\n   174→\\treturn &agent.Event{\\n   175→\\t\\tType:       agent.TurnEnd,\\n   176→\\t\\tSessionID:  raw.SessionID,\\n   177→\\t\\tSessionRef: raw.TranscriptPath,\\n   178→\\t\\tTimestamp:  time.Now(),\\n   179→\\t}, nil\\n   180→}\\n   181→\\n   182→func (c *ClaudeCodeAgent) parseSessionEnd(stdin io.Reader) (*agent.Event, error) {\\n   183→\\traw, err := agent.ReadAndParseHookInput[sessionInfoRaw](stdin)\\n   184→\\tif err != nil {\\n   185→\\t\\treturn nil, err\\n   186→\\t}\\n   187→\\treturn &agent.Event{\\n   188→\\t\\tType:       agent.SessionEnd,\\n   189→\\t\\tSessionID:  raw.SessionID,\\n   190→\\t\\tSessionRef: raw.TranscriptPath,\\n   191→\\t\\tTimestamp:  time.Now(),\\n   192→\\t}, nil\\n   193→}\\n   194→\\n   195→func (c *ClaudeCodeAgent) parseSubagentStart(stdin io.Reader) (*agent.Event, error) {\\n   196→\\traw, err := agent.ReadAndParseHookInput[taskHookInputRaw](stdin)\\n   197→\\tif err != nil {\\n   198→\\t\\treturn nil, err\\n   199→\\t}\\n   200→\\treturn &agent.Event{\\n   201→\\t\\tType:       agent.SubagentStart,\\n   202→\\t\\tSessionID:  raw.SessionID,\\n   203→\\t\\tSessionRef: raw.TranscriptPath,\\n   204→\\t\\tToolUseID:  raw.ToolUseID,\\n   205→\\t\\tToolInput:  raw.ToolInput,\\n   206→\\t\\tTimestamp:  time.Now(),\\n   207→\\t}, nil\\n   208→}\\n   209→\\n   210→func (c *ClaudeCodeAgent) parseSubagentEnd(stdin io.Reader) (*agent.Event, error) {\\n   211→\\traw, err := agent.ReadAndParseHookInput[postToolHookInputRaw](stdin)\\n   212→\\tif err != nil {\\n   213→\\t\\treturn nil, err\\n   214→\\t}\\n   215→\\tevent := &agent.Event{\\n   216→\\t\\tType:       agent.SubagentEnd,\\n   217→\\t\\tSessionID:  raw.SessionID,\\n   218→\\t\\tSessionRef: raw.TranscriptPath,\\n   219→\\t\\tToolUseID:  raw.ToolUseID,\\n   220→\\t\\tToolInput:  raw.ToolInput,\\n   221→\\t\\tTimestamp:  time.Now(),\\n   222→\\t}\\n   223→\\tif raw.ToolResponse.AgentID != \\\"\\\" {\\n   224→\\t\\tevent.SubagentID = raw.ToolResponse.AgentID\\n   225→\\t}\\n   226→\\treturn event, nil\\n   227→}\\n   228→\\n   229→// --- Transcript flush sentinel ---\\n   230→\\n   231→// stopHookSentinel is the string that appears in Claude Code's hook_progress\\n   232→// entry when the stop hook has been invoked, indicating the transcript is fully flushed.\\n   233→const stopHookSentinel = \\\"hooks claude-code stop\\\"\\n   234→\\n   235→// waitForTranscriptFlush polls the transcript file for the stop hook sentinel.\\n   236→// Falls back silently after a timeout.\\n   237→func waitForTranscriptFlush(transcriptPath string, hookStartTime time.Time) {\\n   238→\\tconst (\\n   239→\\t\\tmaxWait      = 3 * time.Second\\n   240→\\t\\tpollInterval = 50 * time.Millisecond\\n   241→\\t\\ttailBytes    = 4096\\n   242→\\t\\tmaxSkew      = 2 * time.Second\\n   243→\\t)\\n   244→\\n   245→\\tlogCtx := logging.WithComponent(context.Background(), \\\"agent.claudecode\\\")\\n   246→\\tdeadline := time.Now().Add(maxWait)\\n   247→\\tfor time.Now().Before(deadline) {\\n   248→\\t\\tif checkStopSentinel(transcriptPath, tailBytes, hookStartTime, maxSkew) {\\n   249→\\t\\t\\tlogging.Debug(logCtx, \\\"transcript flush sentinel found\\\",\\n   250→\\t\\t\\t\\tslog.Duration(\\\"wait\\\", time.Since(hookStartTime)),\\n   251→\\t\\t\\t)\\n   252→\\t\\t\\treturn\\n   253→\\t\\t}\\n   254→\\t\\ttime.Sleep(pollInterval)\\n   255→\\t}\\n   256→\\tlogging.Warn(logCtx, \\\"transcript flush sentinel not found within timeout, proceeding\\\",\\n   257→\\t\\tslog.Duration(\\\"timeout\\\", maxWait),\\n   258→\\t)\\n   259→}\\n   260→\\n   261→// checkStopSentinel reads the tail of the transcript file and looks for the sentinel.\\n   262→func checkStopSentinel(path string, tailBytes int64, hookStartTime time.Time, maxSkew time.Duration) bool {\\n   263→\\tf, err := os.Open(path) //nolint:gosec // path comes from agent hook input\\n   264→\\tif err != nil {\\n   265→\\t\\treturn false\\n   266→\\t}\\n   267→\\tdefer f.Close()\\n   268→\\n   269→\\tinfo, err := f.Stat()\\n   270→\\tif err != nil {\\n   271→\\t\\treturn false\\n   272→\\t}\\n   273→\\toffset := info.Size() - tailBytes\\n   274→\\tif offset < 0 {\\n   275→\\t\\toffset = 0\\n   276→\\t}\\n   277→\\tbuf := make([]byte, info.Size()-offset)\\n   278→\\tif _, err := f.ReadAt(buf, offset); err != nil {\\n   279→\\t\\treturn false\\n   280→\\t}\\n   281→\\n   282→\\tlines := strings.Split(string(buf), \\\"\\\\n\\\")\\n   283→\\tfor _, line := range lines {\\n   284→\\t\\tline = strings.TrimSpace(line)\\n   285→\\t\\tif line == \\\"\\\" || !strings.Contains(line, stopHookSentinel) {\\n   286→\\t\\t\\tcontinue\\n   287→\\t\\t}\\n   288→\\n   289→\\t\\tvar entry struct {\\n   290→\\t\\t\\tTimestamp string `json:\\\"timestamp\\\"`\\n   291→\\t\\t}\\n   292→\\t\\tif json.Unmarshal([]byte(line), &entry) != nil || entry.Timestamp == \\\"\\\" {\\n   293→\\t\\t\\tcontinue\\n   294→\\t\\t}\\n   295→\\t\\tts, err := time.Parse(time.RFC3339Nano, entry.Timestamp)\\n   296→\\t\\tif err != nil {\\n   297→\\t\\t\\tts, err = time.Parse(time.RFC3339, entry.Timestamp)\\n   298→\\t\\t\\tif err != nil {\\n   299→\\t\\t\\t\\tcontinue\\n   300→\\t\\t\\t}\\n   301→\\t\\t}\\n   302→\\t\\t// Validate timestamp is within acceptable range:\\n   303→\\t\\t// - Not too far in the past (before hook started minus skew)\\n   304→\\t\\t// - Not too far in the future (after hook started plus skew)\\n   305→\\t\\tlowerBound := hookStartTime.Add(-maxSkew)\\n   306→\\t\\tupperBound := hookStartTime.Add(maxSkew)\\n   307→\\t\\tif ts.After(lowerBound) && ts.Before(upperBound) {\\n   308→\\t\\t\\treturn true\\n   309→\\t\\t}\\n   310→\\t}\\n   311→\\treturn false\\n   312→}\\n   313→\"}]},\"uuid\":\"a33faab0-e4e6-46fe-b183-60816871323f\",\"timestamp\":\"2026-02-22T05:27:33.794Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand the full execution path when Claude Code hooks fire during session start and stop. Find and read:\\n\\n1. The Claude Code agent hook installation - what hooks get installed and what commands they run. Look in `cmd/entire/cli/agent/` for the claude-code agent implementation, specifically `InstallHooks()` and the hook file contents.\\n\\n2. The hook command hand