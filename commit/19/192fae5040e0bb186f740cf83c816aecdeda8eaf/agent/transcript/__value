ntext to the writer\\n   215→func logPostTaskHookContext(w io.Writer, input *PostTaskHookInput, subagentTranscriptPath string) {\\n   216→\\t_, _ = fmt.Fprintln(w, \\\"[entire] PostToolUse[Task] hook invoked\\\")\\n   217→\\t_, _ = fmt.Fprintf(w, \\\"  Session ID: %s\\\\n\\\", input.SessionID)\\n   218→\\t_, _ = fmt.Fprintf(w, \\\"  Tool Use ID: %s\\\\n\\\", input.ToolUseID)\\n   219→\\n   220→\\tif input.AgentID != \\\"\\\" {\\n   221→\\t\\t_, _ = fmt.Fprintf(w, \\\"  Agent ID: %s\\\\n\\\", input.AgentID)\\n   222→\\t} else {\\n   223→\\t\\t_, _ = fmt.Fprintln(w, \\\"  Agent ID: (none)\\\")\\n   224→\\t}\\n   225→\\n   226→\\t_, _ = fmt.Fprintf(w, \\\"  Transcript: %s\\\\n\\\", input.TranscriptPath)\\n   227→\\n   228→\\tif subagentTranscriptPath != \\\"\\\" {\\n   229→\\t\\t_, _ = fmt.Fprintf(w, \\\"  Subagent Transcript: %s\\\\n\\\", subagentTranscriptPath)\\n   230→\\t} else {\\n   231→\\t\\t_, _ = fmt.Fprintln(w, \\\"  Subagent Transcript: (none)\\\")\\n   232→\\t}\\n   233→}\\n   234→\\n   235→// hookResponse represents a JSON response.\\n   236→// Used to control whether Agent continues processing the prompt.\\n   237→type hookResponse struct {\\n   238→\\tSystemMessage string `json:\\\"systemMessage,omitempty\\\"`\\n   239→}\\n   240→\\n   241→// outputHookResponse outputs a JSON response to stdout\\n   242→func outputHookResponse(reason string) error {\\n   243→\\tresp := hookResponse{\\n   244→\\t\\tSystemMessage: reason,\\n   245→\\t}\\n   246→\\tif err := json.NewEncoder(os.Stdout).Encode(resp); err != nil {\\n   247→\\t\\treturn fmt.Errorf(\\\"failed to encode hook response: %w\\\", err)\\n   248→\\t}\\n   249→\\treturn nil\\n   250→}\\n   251→\"}]},\"uuid\":\"3a64c2ba-5735-44f9-9b50-e0f96253cc45\",\"timestamp\":\"2026-02-22T05:27:45.152Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand the full execution path when Claude Code hooks fire during session start and stop. Find and read:\\n\\n1. The Claude Code agent