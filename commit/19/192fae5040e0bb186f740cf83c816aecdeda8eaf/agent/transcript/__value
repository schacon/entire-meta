 25→\\n    26→\\t// TranscriptOffset is the unified transcript position when this state was captured.\\n    27→\\t// For Claude Code (JSONL), this is the line count.\\n    28→\\t// For Gemini CLI (JSON), this is the message count.\\n    29→\\t// Zero means not set or session just started.\\n    30→\\tTranscriptOffset int `json:\\\"transcript_offset,omitempty\\\"`\\n    31→\\n    32→\\t// LastTranscriptIdentifier is the agent-specific identifier at the transcript position.\\n    33→\\t// UUID for Claude Code, message ID for Gemini CLI. Optional metadata.\\n    34→\\tLastTranscriptIdentifier string `json:\\\"last_transcript_identifier,omitempty\\\"`\\n    35→\\n    36→\\t// Deprecated: StartMessageIndex is the old Gemini-specific field.\\n    37→\\t// Migrated to TranscriptOffset on load.\\n    38→\\tStartMessageIndex int `json:\\\"start_message_index,omitempty\\\"`\\n    39→\\n    40→\\t// Deprecated: StepTranscriptStart is the old Claude-specific field.\\n    41→\\t// Migrated to TranscriptOffset on load.\\n    42→\\tStepTranscriptStart int `json:\\\"step_transcript_start,omitempty\\\"`\\n    43→\\n    44→\\t// Deprecated: LastTranscriptLineCount is the oldest name for transcript position.\\n    45→\\t// Migrated to TranscriptOffset on load.\\n    46→\\tLastTranscriptLineCount int `json:\\\"last_transcript_line_count,omitempty\\\"`\\n    47→}\\n    48→\\n    49→// PreUntrackedFiles returns the untracked files list, or nil if the receiver is nil.\\n    50→// This nil-vs-empty distinction lets DetectFileChanges know whether to skip new-file detection.\\n    51→// When the receiver is non-nil but UntrackedFiles is nil (e.g., old state files deserialized with\\n    52→// \\\"untracked_files\\\": null), returns an empty non-nil slice so that all current untracked files\\n    53→// are correctly treated as new.\\n    54→func (s *PrePromptState) PreUntrackedFiles() []string {\\n    55→\\tif s == nil {\\n    56→\\t\\treturn nil\\n    57→\\t}\\n    58→\\tif s.UntrackedFiles == nil {\\n    59→\\t\\treturn []string{}\\n    60→\\t}\\n    61→\\treturn s.UntrackedFiles\\n    62→}\\n    63→\\n    64→// normalizePrePromptState migrates deprecated fields after loading from JSON.\\n    65→func (s *PrePromptState) normalizePrePromptState() {\\n    66→\\t// Migrate the oldest field to the intermediate field first\\n    67→\\tif s.StepTranscriptStart == 0 && s.LastTranscriptLineCount > 0 {\\n    68→\\t\\ts.StepTranscriptStart = s.LastTranscriptLineCount\\n    69→\\t}\\n    70→\\ts.LastTranscriptLineCount = 0\\n    71→\\n    72→\\t// Migrate all deprecated fields to the unified TranscriptOffset\\n    73→\\tif s.TranscriptOffset == 0 {\\n    74→\\t\\tif s.StepTranscriptStart > 0 {\\n    75→\\t\\t\\ts.TranscriptOffset = s.StepTranscriptStart\\n    76→\\t\\t} else if s.StartMessageIndex > 0 {\\n    77→\\t\\t\\ts.TranscriptOffset = s.StartMessageIndex\\n    78→\\t\\t}\\n    79→\\t}\\n    80→\\ts.StepTranscriptStart = 0\\n    81→\\ts.StartMessageIndex = 0\\n    82→}\\n    83→\\n    84→// CapturePrePromptState captures current untracked files and transcript position before a prompt\\n    85→// and saves them to a state file.\\n    86→//\\n    87→// The agent parameter is used to determine the transcript position via TranscriptAnalyzer.\\n    88→// If the agent does not implement TranscriptAnalyzer, the transcript offset will be 0.\\n    89→// The sessionRef parameter is optional — if empty, transcript position won't be captured.\\n    90→//\\n    91→// Works correctly from any subdirectory within the repository.\\n    92→func CapturePrePromptState(ag agent.Agent, sessionID, sessionRef string) error {\\n    93→\\tif sessionID == \\\"\\\" {\\n    94→\\t\\tsessionID = unknownSessionID\\n    95→\\t}\\n    96→\\n    97→\\t// Get absolute path for tmp directory\\n    98→\\ttmpDirAbs, err := paths.AbsPath(paths.EntireTmpDir)\\n    99→\\tif err != nil {\\n   100→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   101→\\t}\\n   102→\\n   103→\\t// Create tmp directory if it doesn't exist\\n   104→\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   105→\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n   106→\\t}\\n   107→\\n   108→\\t// Get list of untracked files (excluding .entire directory itself)\\n   109→\\tuntrackedFiles, err := getUntrackedFilesForState()\\n   110→\\tif err != nil {\\n   111→\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n   112→\\t}\\n   113→\\n   114→\\t// Get transcript position using TranscriptAnalyzer if available\\n   115→\\tvar transcriptOffset int\\n   116→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok && sessionRef != \\\"\\\" {\\n   117→\\t\\tpos, posErr := analyzer.GetTranscriptPosition(sessionRef)\\n   118→\\t\\tif posErr != nil {\\n   119→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to get transcript position: %v\\\\n\\\", posErr)\\n   120→\\t\\t} else {\\n   121→\\t\\t\\ttranscriptOffset = pos\\n   122→\\t\\t}\\n   123→\\t}\\n   124→\\n   125→\\t// Create state file\\n   126→\\tstateFile := prePromptStateFile(sessionID)\\n   127→\\tstate := PrePromptState{\\n   128→\\t\\tSessionID:        sessionID,\\n   129→\\t\\tTimestamp:        time.Now().UTC().Format(time.RFC3339),\\n   130→\\t\\tUntrackedFiles:   untrackedFiles,\\n   131→\\t\\tTranscriptOffset: transcriptOffset,\\n   132→\\t}\\n   133→\\n   134→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   135→\\tif err != nil {\\n   136→\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n   137→\\t}\\n   138→\\n   139→\\tif err := os.WriteFile(stateFile, data, 0o600); err != nil {\\n   140→\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   141→\\t}\\n   142→\\n   143→\\tfmt.Fprintf(os.Stderr, \\\"Captured state before prompt: %d untracked files, transcript offset: %d\\\\n\\\",\\n   144→\\t\\tlen(untrackedFiles), transcriptOffset)\\n   145→\\treturn nil\\n   146→}\\n   147→\\n   148→// LoadPrePromptState loads previously captured state.\\n   149→// Returns nil if no state file exists.\\n   150→func LoadPrePromptState(sessionID string) (*PrePromptState, error) {\\n   151→\\tstateFile := prePromptStateFile(sessionID)\\n   152→\\n   153→\\tif !fileExists(stateFile) {\\n   154→\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   155→\\t}\\n   156→\\n   157→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // Reading from controlled git metadata path\\n   158→\\tif err != nil {\\n   159→\\t\\treturn nil, fmt.Errorf(\\\"failed to read state file: %w\\\", err)\\n   160→\\t}\\n   161→\\n   162→\\tvar state PrePromptState\\n   163→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   164→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal state: %w\\\", err)\\n   165→\\t}\\n   166→\\n   167→\\tstate.normalizePrePromptState()\\n   168→\\n   169→\\treturn &state, nil\\n   170→}\\n   171→\\n   172→// CleanupPrePromptState removes the state file after use\\n   173→func CleanupPrePromptState(sessionID string) error {\\n   174→\\tstateFile := prePromptStateFile(sessionID)\\n   175→\\tif fileExists(stateFile) {\\n   176→\\t\\treturn os.Remove(stateFile) //nolint:wrapcheck // already present in codebase\\n   177→\\t}\\n   178→\\treturn nil\\n   179→}\\n   180→\\n   181→// FileChanges holds categorized file changes from git status.\\n   182→type FileChanges struct {\\n   183→\\tModified []string // Modified or staged files\\n   184→\\tNew      []string // Untracked files (filtered if previouslyUntracked provided)\\n   185→\\tDeleted  []string // Deleted files (staged or unstaged)\\n   186→}\\n   187→\\n   188→// DetectFileChanges returns categorized file changes from the current git status.\\n   189→//\\n   190→// previouslyUntracked controls new-file detection:\\n   191→//   - nil: all untracked files go into New\\n   192→//   - non-nil: only untracked files NOT in the pre-existing set go into New\\n   193→//\\n   194→// Modified includes both worktree and staging modified/added files.\\n   195→// Deleted includes both staged and unstaged deletions.\\n   196→// All results exclude .entire/ directory.\\n   197→func DetectFileChanges(previouslyUntracked []string) (*FileChanges, error) {\\n   198→\\trepo, err := openRepository()\\n   199→\\tif err != nil {\\n   200→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   201→\\t}\\n   202→\\n   203→\\tworktree, err := repo.Worktree()\\n   204→\\tif err != nil {\\n   205→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   206→\\t}\\n   207→\\n   208→\\tstatus, err := worktree.Status()\\n   209→\\tif err != nil {\\n   210→\\t\\treturn nil, fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n   211→\\t}\\n   212→\\n   213→\\t// Build set of pre-existing untracked files for quick lookup\\n   214→\\tvar preExisting map[string]bool\\n   215→\\tif previouslyUntracked != nil {\\n   216→\\t\\tpreExisting = make(map[string]bool, len(previouslyUntracked))\\n   217→\\t\\tfor _, f := range previouslyUntracked {\\n   218→\\t\\t\\tpreExisting[f] = true\\n   219→\\t\\t}\\n   220→\\t}\\n   221→\\n   222→\\tvar changes FileChanges\\n   223→\\tfor file, st := range status {\\n   224→\\t\\tif paths.IsInfrastructurePath(file) {\\n   225→\\t\\t\\tcontinue\\n   226→\\t\\t}\\n   227→\\n   228→\\t\\tswitch {\\n   229→\\t\\tcase st.Worktree == git.Untracked:\\n   230→\\t\\t\\tif preExisting != nil {\\n   231→\\t\\t\\t\\tif !preExisting[file] {\\n   232→\\t\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   233→\\t\\t\\t\\t}\\n   234→\\t\\t\\t} else {\\n   235→\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   236→\\t\\t\\t}\\n   237→\\t\\tcase st.Worktree == git.Deleted || st.Staging == git.Deleted:\\n   238→\\t\\t\\tchanges.Deleted = append(changes.Deleted, file)\\n   239→\\t\\tcase st.Worktree == git.Modified || st.Staging == git.Modified ||\\n   240→\\t\\t\\tst.Worktree == git.Added || st.Staging == git.Added:\\n   241→\\t\\t\\tchanges.Modified = append(changes.Modified, file)\\n   242→\\t\\t}\\n   243→\\t}\\n   244→\\n   245→\\treturn &changes, nil\\n   246→}\\n   247→\\n   248→// filterToUncommittedFiles removes files from the list that are already committed to HEAD\\n   249→// with matching content. This prevents re-adding files that an agent committed mid-turn\\n   250→// (already condensed by PostCommit) back to FilesTouched via SaveStep. Files not in\\n   251→// HEAD or with different content in the working tree are kept. Fails open: if any git\\n   252→// operation errors, returns the original list unchanged.\\n   253→func filterToUncommittedFiles(files []string, repoRoot string) []string {\\n   254→\\tif len(files) == 0 {\\n   255→\\t\\treturn files\\n   256→\\t}\\n   257→\\n   258→\\trepo, err := openRepository()\\n   259→\\tif err != nil {\\n   260→\\t\\treturn files // fail open\\n   261→\\t}\\n   262→\\n   263→\\thead, err := repo.Head()\\n   264→\\tif err != nil {\\n   265→\\t\\treturn files // fail open (empty repo, detached HEAD, etc.)\\n   266→\\t}\\n   267→\\n   268→\\tcommit, err := repo.CommitObject(head.Hash())\\n   269→\\tif err != nil {\\n   270→\\t\\treturn files // fail open\\n   271→\\t}\\n   272→\\n   273→\\theadTree, err := commit.Tree()\\n   274→\\tif err != nil {\\n   275→\\t\\treturn files // fail open\\n   276→\\t}\\n   277→\\n   278→\\tvar result []string\\n   279→\\tfor _, relPath := range files {\\n   280→\\t\\theadFile, err := headTree.File(relPath)\\n   281→\\t\\tif err != nil {\\n   282→\\t\\t\\t// File not in HEAD — it's uncommitted\\n   283→\\t\\t\\tresult = append(result, relPath)\\n   284→\\t\\t\\tcontinue\\n   285→\\t\\t}\\n   286→\\n   287→\\t\\t// File is in HEAD — compare content with working tree\\n   288→\\t\\tabsPath := filepath.Join(repoRoot, relPath)\\n   289→\\t\\tworkingContent, err := os.ReadFile(absPath) //nolint:gosec // path from controlled source\\n   290→\\t\\tif err != nil {\\n   291→\\t\\t\\t// Can't read working tree file (deleted?) — keep it\\n   292→\\t\\t\\tresult = append(result, relPath)\\n   293→\\t\\t\\tcontinue\\n   294→\\t\\t}\\n   295→\\n   296→\\t\\theadContent, err := headFile.Contents()\\n   297→\\t\\tif err != nil {\\n   298→\\t\\t\\tresult = append(result, relPath)\\n   299→\\t\\t\\tcontinue\\n   300→\\t\\t}\\n   301→\\n   302→\\t\\tif string(workingContent) != headContent {\\n   303→\\t\\t\\t// Working tree differs from HEAD — uncommitted changes\\n   304→\\t\\t\\tresult = append(result, relPath)\\n   305→\\t\\t}\\n   306→\\t\\t// else: content matches HEAD — already committed, skip\\n   307→\\t}\\n   308→\\n   309→\\treturn result\\n   310→}\\n   311→\\n   312→// FilterAndNormalizePaths converts absolute paths to relative and filters out\\n   313→// infrastructure paths and paths outside the repo.\\n   314→func FilterAndNormalizePaths(files []string, cwd string) []string {\\n   315→\\tvar result []string\\n   316→\\tfor _, file := range files {\\n   317→\\t\\trelPath := paths.ToRelativePath(file, cwd)\\n   318→\\t\\tif relPath == \\\"\\\" {\\n   319→\\t\\t\\tcontinue // outside repo\\n   320→\\t\\t}\\n   321→\\t\\tif paths.IsInfrastructurePath(relPath) {\\n   322→\\t\\t\\tcontinue // skip .entire directory\\n   323→\\t\\t}\\n   324→\\t\\tresult = append(result, relPath)\\n   325→\\t}\\n   326→\\treturn result\\n   327→}\\n   328→\\n   329→// prePromptStateFile returns the absolute path to the pre-prompt state file for a session.\\n   330→// Works correctly from any subdirectory within the repository.\\n   331→func prePromptStateFile(sessionID string) string {\\n   332→\\ttmpDirAbs, err := paths.AbsPath(paths.EntireTmpDir)\\n   333→\\tif err != nil {\\n   334→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   335→\\t}\\n   336→\\treturn filepath.Join(tmpDirAbs, fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID))\\n   337→}\\n   338→\\n   339→// getUntrackedFilesForState returns a list of untracked files using go-git\\n   340→// Excludes .entire directory\\n   341→func getUntrackedFilesForState() ([]string, error) {\\n   342→\\trepo, err := openRepository()\\n   343→\\tif err != nil {\\n   344→\\t\\treturn nil, err\\n   345→\\t}\\n   346→\\n   347→\\tworktree, err := repo.Worktree()\\n   348→\\tif err != nil {\\n   349→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   350→\\t}\\n   351→\\n   352→\\tstatus, err := worktree.Status()\\n   353→\\tif err != nil {\\n   354→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   355→\\t}\\n   356→\\n   357→\\tuntrackedFiles := []string{}\\n   358→\\tfor file, st := range status {\\n   359→\\t\\tif st.Worktree == git.Untracked {\\n   360→\\t\\t\\t// Exclude .entire directory\\n   361→\\t\\t\\tif !strings.HasPrefix(file, paths.EntireDir+\\\"/\\\") && file != paths.EntireDir {\\n   362→\\t\\t\\t\\tuntrackedFiles = append(untrackedFiles, file)\\n   363→\\t\\t\\t}\\n   364→\\t\\t}\\n   365→\\t}\\n   366→\\n   367→\\treturn untrackedFiles, nil\\n   368→}\\n   369→\\n   370→// PreTaskState stores the state captured before a task execution\\n   371→type PreTaskState struct {\\n   372→\\tToolUseID      string   `json:\\\"tool_use_id\\\"`\\n   373→\\tTimestamp      string   `json:\\\"timestamp\\\"`\\n   374→\\tUntrackedFiles []string `json:\\\"untracked_files\\\"`\\n   375→}\\n   376→\\n   377→// PreUntrackedFiles returns the untracked files list, or nil if the receiver is nil.\\n   378→// See PrePromptState.PreUntrackedFiles for nil-vs-empty semantics.\\n   379→func (s *PreTaskState) PreUntrackedFiles() []string {\\n   380→\\tif s == nil {\\n   381→\\t\\treturn nil\\n   382→\\t}\\n   383→\\tif s.UntrackedFiles == nil {\\n   384→\\t\\treturn []string{}\\n   385→\\t}\\n   386→\\treturn s.UntrackedFiles\\n   387→}\\n   388→\\n   389→// CapturePreTaskState captures current untracked files before a Task execution\\n   390→// and saves them to a state file.\\n   391→// Works correctly from any subdirectory within the repository