\",\"content\":[{\"tool_use_id\":\"toolu_01Wzo4Nv2dSrD6LivS1ssew6\",\"type\":\"tool_result\",\"content\":\"     1→package agent\\n     2→\\n     3→import (\\n     4→\\t\\\"encoding/json\\\"\\n     5→\\t\\\"errors\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"io\\\"\\n     8→\\t\\\"time\\\"\\n     9→)\\n    10→\\n    11→// EventType represents a normalized lifecycle event from any agent.\\n    12→// Agents translate their native hooks into these event types via ParseHookEvent.\\n    13→type EventType int\\n    14→\\n    15→const (\\n    16→\\t// SessionStart indicates the agent session has begun.\\n    17→\\tSessionStart EventType = iota + 1\\n    18→\\n    19→\\t// TurnStart indicates the user submitted a prompt and the agent is about to work.\\n    20→\\tTurnStart\\n    21→\\n    22→\\t// TurnEnd indicates the agent finished responding to a prompt.\\n    23→\\tTurnEnd\\n    24→\\n    25→\\t// Compaction indicates the agent is about to compress its context window.\\n    26→\\t// This triggers the same save logic as TurnEnd but also resets the transcript offset.\\n    27→\\tCompaction\\n    28→\\n    29→\\t// SessionEnd indicates the session has been terminated.\\n    30→\\tSessionEnd\\n    31→\\n    32→\\t// SubagentStart indicates a subagent (task) has been spawned.\\n    33→\\tSubagentStart\\n    34→\\n    35→\\t// SubagentEnd indicates a subagent (task) has completed.\\n    36→\\tSubagentEnd\\n    37→)\\n    38→\\n    39→// String returns a human-readable name for the event type.\\n    40→func (e EventType) String() string {\\n    41→\\tswitch e {\\n    42→\\tcase SessionStart:\\n    43→\\t\\treturn \\\"SessionStart\\\"\\n    44→\\tcase TurnStart:\\n    45→\\t\\treturn \\\"TurnStart\\\"\\n    46→\\tcase TurnEnd:\\n    47→\\t\\treturn \\\"TurnEnd\\\"\\n    48→\\tcase Compaction:\\n    49→\\t\\treturn \\\"Compaction\\\"\\n    50→\\tcase SessionEnd:\\n    51→\\t\\treturn \\\"SessionEnd\\\"\\n    52→\\tcase SubagentStart:\\n    53→\\t\\treturn \\\"SubagentStart\\\"\\n    54→\\tcase SubagentEnd:\\n    55→\\t\\treturn \\\"SubagentEnd\\\"\\n    56→\\tdefault:\\n    57→\\t\\treturn \\\"Unknown\\\"\\n    58→\\t}\\n    59→}\\n    60→\\n    61→// Event is a normalized lifecycle event produced by an agent's ParseHookEvent method.\\n    62→// The framework dispatcher uses these events to drive checkpoint/session lifecycle actions.\\n    63→type Event struct {\\n    64→\\t// Type is the kind of lifecycle event.\\n    65→\\tType EventType\\n    66→\\n    67→\\t// SessionID identifies the agent session.\\n    68→\\tSessionID string\\n    69→\\n    70→\\t// PreviousSessionID is non-empty when this event represents a session continuation\\n    71→\\t// or handoff (e.g., Claude starting a new session ID after exiting plan mode).\\n    72→\\tPreviousSessionID string\\n    73→\\n    74→\\t// SessionRef is an agent-specific reference to the transcript (typically a file path).\\n    75→\\tSessionRef string\\n    76→\\n    77→\\t// Prompt is the user's prompt text (populated on TurnStart events).\\n    78→\\tPrompt string\\n    79→\\n    80→\\t// Timestamp is when the event occurred.\\n    81→\\tTimestamp time.Time\\n    82→\\n    83→\\t// ToolUseID identifies the tool invocation (for SubagentStart/SubagentEnd events).\\n    84→\\tToolUseID string\\n    85→\\n    86→\\t// SubagentID identifies the subagent instance (for SubagentEnd events).\\n    87→\\tSubagentID string\\n    88→\\n    89→\\t// ToolInput is the raw tool input JSON (for subagent type/description extraction).\\n    90→\\tToolInput json.RawMessage\\n    91→\\n    92→\\t// ResponseMessage is an optional message to display to the user via the agent.\\n    93→\\tResponseMessage string\\n    94→\\n    95→\\t// Metadata holds agent-specific state that the framework stores and makes available\\n    96→\\t// on subsequent events. Examples: Pi's activeLeafId, Cursor's is_background_agent.\\n    97→\\tMetadata map[string]string\\n    98→}\\n    99→\\n   100→// ReadAndParseHookInput reads all by