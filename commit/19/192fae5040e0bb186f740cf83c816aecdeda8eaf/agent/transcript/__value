 63→\\t// Set up log level getter so logging can read from settings\\n    64→\\tlogging.SetLogLevelGetter(GetLogLevel)\\n    65→\\n    66→\\t// Read session ID for the slog attribute (empty string is fine - log file is fixed)\\n    67→\\tsessionID := strategy.FindMostRecentSession()\\n    68→\\tif err := logging.Init(sessionID); err != nil {\\n    69→\\t\\t// Init failed - logging will use stderr fallback\\n    70→\\t\\treturn func() {}\\n    71→\\t}\\n    72→\\treturn logging.Close\\n    73→}\\n    74→\\n    75→// hookLogCleanup stores the cleanup function for hook logging.\\n    76→// Set by PersistentPreRunE, called by PersistentPostRunE.\\n    77→var hookLogCleanup func()\\n    78→\\n    79→func newHooksGitCmd() *cobra.Command {\\n    80→\\tcmd := &cobra.Command{\\n    81→\\t\\tUse:    \\\"git\\\",\\n    82→\\t\\tShort:  \\\"Git hook handlers\\\",\\n    83→\\t\\tLong:   \\\"Commands called by git hooks. These delegate to the current strategy.\\\",\\n    84→\\t\\tHidden: true, // Internal command, not for direct user use\\n    85→\\t\\tPersistentPreRunE: func(_ *cobra.Command, _ []string) error {\\n    86→\\t\\t\\thookLogCleanup = initHookLogging()\\n    87→\\t\\t\\treturn nil\\n    88→\\t\\t},\\n    89→\\t\\tPersistentPostRunE: func(_ *cobra.Command, _ []string) error {\\n    90→\\t\\t\\tif hookLogCleanup != nil {\\n    91→\\t\\t\\t\\thookLogCleanup()\\n    92→\\t\\t\\t}\\n    93→\\t\\t\\treturn nil\\n    94→\\t\\t},\\n    95→\\t}\\n    96→\\n    97→\\tcmd.AddCommand(newHooksGitPrepareCommitMsgCmd())\\n    98→\\tcmd.AddCommand(newHooksGitCommitMsgCmd())\\n    99→\\tcmd.AddCommand(newHooksGitPostCommitCmd())\\n   100→\\tcmd.AddCommand(newHooksGitPrePushCmd())\\n   101→\\n   102→\\treturn cmd\\n   103→}\\n   104→\\n   105→func newHooksGitPrepareCommitMsgCmd() *cobra.Command {\\n   106→\\treturn &cobra.Command{\\n   107→\\t\\tUse:   \\\"prepare-commit-msg <commit-msg-file> [source]\\\",\\n   108→\\t\\tShort: \\\"Handle prepare-commit-msg git hook\\\",\\n   109→\\t\\tArgs:  cobra.RangeArgs(1, 2),\\n   110→\\t\\tRunE: func(_ *cobra.Command, args []string) error {\\n   111→\\t\\t\\tcommitMsgFile := args[0]\\n   112→\\t\\t\\tvar source string\\n   113→\\t\\t\\tif len(args) > 1 {\\n   114→\\t\\t\\t\\tsource = args[1]\\n   115→\\t\\t\\t}\\n   116→\\n   117→\\t\\t\\tg := newGitHookContext(\\\"prepare-commit-msg\\\")\\n   118→\\t\\t\\tg.logInvoked(slog.String(\\\"source\\\", source))\\n   119→\\n   120→\\t\\t\\tif handler, ok := g.strategy.(strategy.PrepareCommitMsgHandler); ok {\\n   121→\\t\\t\\t\\thookErr := handler.PrepareCommitMsg(commitMsgFile, source)\\n   122→\\t\\t\\t\\tg.logCompleted(hookErr, slog.String(\\\"source\\\", source))\\n   123→\\t\\t\\t}\\n   124→\\n   125→\\t\\t\\treturn nil\\n   126→\\t\\t},\\n   127→\\t}\\n   128→}\\n   129→\\n   130→func newHooksGitCommitMsgCmd() *cobra.Command {\\n   131→\\treturn &cobra.Command{\\n   132→\\t\\tUse:   \\\"commit-msg <commit-msg-file>\\\",\\n   133→\\t\\tShort: \\\"Handle commit-msg git hook\\\",\\n   134→\\t\\tArgs:  cobra.ExactArgs(1),\\n   135→\\t\\tRunE: func(_ *cobra.Command, args []string) error {\\n   136→\\t\\t\\tcommitMsgFile := args[0]\\n   137→\\n   138→\\t\\t\\tg := newGitHookContext(\\\"commit-msg\\\")\\n   139→\\t\\t\\tg.logInvoked()\\n   140→\\n   141→\\t\\t\\tif handler, ok := g.strategy.(strategy.CommitMsgHandler); ok {\\n   142→\\t\\t\\t\\thookErr := handler.CommitMsg(commitMsgFile)\\n   143→\\t\\t\\t\\tg.logCompleted(hookErr)\\n   144→\\t\\t\\t\\treturn hookErr //nolint:wrapcheck // Thin delegation layer - wrapping adds no value\\n   145→\\t\\t\\t}\\n   146→\\n   147→\\t\\t\\treturn nil\\n   148→\\t\\t},\\n   149→\\t}\\n   150→}\\n   151→\\n   152→func newHooksGitPostCommitCmd() *cobra.Command {\\n   153→\\treturn &cobra.Command{\\n   154→\\t\\tUse:   \\\"post-commit\\\",\\n   155→\\t\\tShort: \\\"Handle post-commit git hook\\\",\\n   156→\\t\\tArgs:  cobra.NoArgs,\\n   157→\\t\\tRunE: func(_ *cobra.Command, _ []string) error {\\n   158→\\t\\t\\tg := newGit