equal to) target.\\n    50→// Returns true if target can reach commit by following parent links.\\n    51→// Limits search to 1000 commits to avoid excessive traversal.\\n    52→func IsAncestorOf(repo *git.Repository, commit, target plumbing.Hash) bool {\\n    53→\\tif commit == target {\\n    54→\\t\\treturn true\\n    55→\\t}\\n    56→\\n    57→\\titer, err := repo.Log(&git.LogOptions{From: target})\\n    58→\\tif err != nil {\\n    59→\\t\\treturn false\\n    60→\\t}\\n    61→\\tdefer iter.Close()\\n    62→\\n    63→\\tfound := false\\n    64→\\tcount := 0\\n    65→\\t_ = iter.ForEach(func(c *object.Commit) error { //nolint:errcheck // Best-effort search, errors are non-fatal\\n    66→\\t\\tcount++\\n    67→\\t\\tif count > 1000 {\\n    68→\\t\\t\\treturn errStop\\n    69→\\t\\t}\\n    70→\\t\\tif c.Hash == commit {\\n    71→\\t\\t\\tfound = true\\n    72→\\t\\t\\treturn errStop\\n    73→\\t\\t}\\n    74→\\t\\treturn nil\\n    75→\\t})\\n    76→\\n    77→\\treturn found\\n    78→}\\n    79→\\n    80→// ListCheckpoints returns all checkpoints from the entire/checkpoints/v1 branch.\\n    81→// Scans sharded paths: <id[:2]>/<id[2:]>/ directories containing metadata.json.\\n    82→// Used by both manual-commit and auto-commit strategies.\\n    83→func ListCheckpoints() ([]CheckpointInfo, error) {\\n    84→\\trepo, err := OpenRepository()\\n    85→\\tif err != nil {\\n    86→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n    87→\\t}\\n    88→\\n    89→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n    90→\\tref, err := repo.Reference(refName, true)\\n    91→\\tif err != nil {\\n    92→\\t\\t//nolint:nilerr // No sessions branch yet is expected, return empty list\\n    93→\\t\\treturn []CheckpointInfo{}, nil\\n    94→\\t}\\n    95→\\n    96→\\tcommit, err := repo.CommitObject(ref.Hash())\\n    97→\\tif err != nil {\\n    98→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n    99→\\t}\\n   100→\\n   101→\\ttree, err := commit.Tree()\\n   102→\\tif err != nil {\\n   103→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   104→\\t}\\n   105→\\n   106→\\tvar checkpoints []CheckpointInfo\\n   107→\\n   108→\\t// Scan sharded structure: <2-char-prefix>/<remaining-id>/metadata.json\\n   109→\\t// The tree has 2-character directories (hex buckets)\\n   110→\\tfor _, bucketEntry := range tree.Entries {\\n   111→\\t\\tif bucketEntry.Mode != filemode.Dir {\\n   112→\\t\\t\\tcontinue\\n   113→\\t\\t}\\n   114→\\t\\t// Bucket should be 2 hex chars\\n   115→\\t\\tif len(bucketEntry.Name) != 2 {\\n   116→\\t\\t\\tcontinue\\n   117→\\t\\t}\\n   118→\\n   119→\\t\\tbucketTree, treeErr := repo.TreeObject(bucketEntry.Hash)\\n   120→\\t\\tif treeErr != nil {\\n   121→\\t\\t\\tcontinue\\n   122→\\t\\t}\\n   123→\\n   124→\\t\\t// Each entry in the bucket is the remaining part of the checkpoint ID\\n   125→\\t\\tfor _, checkpointEntry := range bucketTree.Entries {\\n   126→\\t\\t\\tif checkpointEntry.Mode != filemode.Dir {\\n   127→\\t\\t\\t\\tcontinue\\n   128→\\t\\t\\t}\\n   129→\\n   130→\\t\\t\\tcheckpointTree, cpTreeErr := repo.TreeObject(checkpointEntry.Hash)\\n   131→\\t\\t\\tif cpTreeErr != nil {\\n   132→\\t\\t\\t\\tcontinue\\n   133→\\t\\t\\t}\\n   134→\\n   135→\\t\\t\\t// Reconstruct checkpoint ID: <bucket><remaining>\\n   136→\\t\\t\\tcheckpointIDStr := bucketEntry.Name + checkpointEntry.Name\\n   137→\\t\\t\\tcheckpointID, cpErr := id.NewCheckpointID(checkpointIDStr)\\n   138→\\t\\t\\tif cpErr != nil {\\n   139→\\t\\t\\t\\t// Skip invalid checkpoint IDs\\n   140→\\t\\t\\t\\tcontinue\\n   141→\\t\\t\\t}\\n   142→\\n   143→\\t\\t\\tinfo := CheckpointInfo{\\n   144→\\t\\t\\t\\tCheckpointID: checkpointID,\\n   145→\\t\\t\\t}\\n   146→\\n   147→\\t\\t\\t// Get details from metadata file (CheckpointSummary format)\\n   148→\\t\\t\\tif metadataFile, fileErr := checkpointTree.File(paths.MetadataFileName); fileErr == nil {\\n   149→\\t\\t\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n   150→\\t\\t\\t\\t\\tvar summary checkpoint.CheckpointSummary\\n   151→\\t\\t\\t\\t\\tif json.Unmarshal([]byte(content), &summary) == nil && len(summary.Sessions) > 0 {\\n   152→\\t\\t\\t\\t\\t\\tinfo.CheckpointsCount = summary.CheckpointsCount\\n   153→\\t\\t\\t\\t\\t\\tinfo.FilesTouched = summary.FilesTouched\\n   154→\\t\\t\\t\\t\\t\\tinfo.SessionCount = len(summary.Sessions)\\n   155→\\n   156→\\t\\t\\t\\t\\t\\t// Read session-level metadata for Agent, SessionID, CreatedAt, SessionIDs\\n   157→\\t\\t\\t\\t\\t\\tfor i, sessionPaths := range summary.Sessions {\\n   158→\\t\\t\\t\\t\\t\\t\\tif sessionPaths.Metadata != \\\"\\\" {\\n   159→\\t\\t\\t\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n   160→\\t\\t\\t\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n   161→\\t\\t\\t\\t\\t\\t\\t\\tsessionMetadataPath := strings.TrimPrefix(sessionPaths.Metadata, \\\"/\\\")\\n   162→\\t\\t\\t\\t\\t\\t\\t\\tif sessionFile, sErr := tree.File(sessionMetadataPath); sErr == nil {\\n   163→\\t\\t\\t\\t\\t\\t\\t\\t\\tif sessionContent, scErr := sessionFile.Contents(); scErr == nil {\\n   164→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata checkpoint.CommittedMetadata\\n   165→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   166→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionIDs = append(info.SessionIDs, sessionMetadata.SessionID)\\n   167→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t// Use first session's metadata for Agent, SessionID, CreatedAt\\n   168→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif i == 0 {\\n   169→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   170→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   171→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   172→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.IsTask = sessionMetadata.IsTask\\n   173→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.ToolUseID = sessionMetadata.ToolUseID\\n   174→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   175→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   176→\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   177→\\t\\t\\t\\t\\t\\t\\t\\t}\\n   178→\\t\\t\\t\\t\\t\\t\\t}\\n   179→\\t\\t\\t\\t\\t\\t}\\n   180→\\t\\t\\t\\t\\t}\\n   181→\\t\\t\\t\\t}\\n   182→\\t\\t\\t}\\n   183→\\n   184→\\t\\t\\tcheckpoints = append(checkpoints, info)\\n   185→\\t\\t}\\n   186→\\t}\\n   187→\\n   188→\\t// Sort by time (most recent first)\\n   189→\\tsort.Slice(checkpoints, func(i, j int) bool {\\n   190→\\t\\treturn checkpoints[i].CreatedAt.After(checkpoints[j].CreatedAt)\\n   191→\\t})\\n   192→\\n   193→\\treturn checkpoints, nil\\n   194→}\\n   195→\\n   196→const (\\n   197→\\tentireGitignore    = \\\".entire/.gitignore\\\"\\n   198→\\tentireDir          = \\\".entire\\\"\\n   199→\\tgitDir             = \\\".git\\\"\\n   200→\\tshadowBranchPrefix = \\\"entire/\\\"\\n   201→\\n   202→\\t// DefaultAgentType is the generic fallback agent type name\\n   203→\\tDefaultAgentType = agent.AgentTypeUnknown\\n   204→)\\n   205→\\n   206→// isProtectedPath returns true if relPath is inside a directory that should\\n   207→// never be modified or deleted during rewind or other destructive operations.\\n   208→// Protected directories include git internals, entire metadata, and all\\n   209→// registered agent config directories.\\n   210→func isProtectedPath(relPath string) bool {\\n   211→\\tfor _, dir := range protectedDirs() {\\n   212→\\t\\tif relPath == dir || strings.HasPrefix(relPath, dir+string(filepath.Separator)) {\\n   213→\\t\\t\\treturn true\\n   214→\\t\\t}\\n   215→\\t}\\n   216→\\treturn false\\n   217→}\\n   218→\\n   219→// protectedDirs returns the list of directories to protect. This combines\\n   220→// static infrastructure dirs with agent-reported dirs from the registry.\\n   221→// The result is cached via sync.Once since it's called per-file when filtering untracked files.\\n   222→//\\n   223→// NOTE: The cache is never invalidated. In production this is fine (the agent registry\\n   224→// is populated at init time and never changes). However, tests that mutate the agent\\n   225→// registry after the first call to protectedDirs/isProtectedPath will see stale results.\\n   226→// If you need to test isProtectedPath with a custom registry, either:\\n   227→//   - run those tests in a separate process, or\\n   228→//   - call resetProtectedDirsForTest() to clear the cache.\\n   229→func protectedDirs() []string {\\n   230→\\tprotectedDirsOnce.Do(func() {\\n   231→\\t\\tprotectedDirsCache = append([]string{gitDir, entireDir}, agent.AllProtectedDirs()...)\\n   232→\\t})\\n   233→\\treturn protectedDirsCache\\n   234→}\\n   235→\\n   236→var (\\n   237→\\tprotectedDirsOnce  sync.Once\\n   238→\\tprotectedDirsCache []string\\n   239→)\\n   240→\\n   241→// isSpecificAgentType returns true if the agent type is a known, specific value\\n   242→// (not empty and not the generic \\\"Agent\\\" fallback).\\n   243→func isSpecificAgentType(t agent.AgentType) bool {\\n   244→\\treturn t != \\\"\\\" && t != DefaultAgentType\\n   245→}\\n   246→\\n   247→// resolveAgentType picks the best agent type from the context and existing state.\\n   248→// Priority: existing state (if specific) > context value > default fallback.\\n   249→func resolveAgentType(ctxAgentType agent.AgentType, state *SessionState) agent.AgentType {\\n   250→\\tif state != nil && isSpecificAgentType(state.AgentType) {\\n   251→\\t\\treturn state.AgentType\\n   252→\\t}\\n   253→\\tif ctxAgentType != \\\"\\\" {\\n   254→\\t\\treturn ctxAgentType\\n   255→\\t}\\n   256→\\treturn DefaultAgentType\\n   257→}\\n   258→\\n   259→// ensureMetadataBranch creates the orphan entire/checkpoints/v1 branch if it doesn't exist.\\n   260→// This branch has no parent and starts with an empty tree.\\n   261→func EnsureMetadataBranch(repo *git.Repository) error {\\n   262→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   263→\\n   264→\\t// Check if branch already exists\\n   265→\\t_, err := repo.Reference(refName, true)\\n   266→\\tif err == nil {\\n   267→\\t\\t// Branch already exists\\n   268→\\t\\treturn nil\\n   269→\\t}\\n   270→\\n   271→\\t// Create empty tree (no files)\\n   272→\\temptyTree := &object.Tree{Entries: []object.TreeEntry{}}\\n   273→\\tobj := repo.Storer.NewEncodedObject()\\n   274→\\tif err := emptyTree.Encode(obj); err != nil {\\n   275→\\t\\treturn fmt.Errorf(\\\"failed to encode empty tree: %w\\\", err)\\n   276→\\t}\\n   277→\\temptyTreeHash, err := repo.Storer.SetEncodedObject(obj)\\n   278→\\tif err != nil {\\n   279→\\t\\treturn fmt.Errorf(\\\"failed to store empty tree: %w\\\", err)\\n   280→\\t}\\n   281→\\n   282→\\t// Create orphan commit (no parent)\\n   283→\\tnow := time.Now()\\n   284→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   285→\\tsig := object.Signature{\\n   286→\\t\\tName:  authorName,\\n   287→\\t\\tEmail: authorEmail,\\n   288→\\t\\tWhen:  now,\\n   289→\\t}\\n   290→\\n   291→\\tcommit := &object.Commit{\\n   292→\\t\\tTreeHash:  emptyTreeHash,\\n   293→\\t\\tAuthor:    sig,\\n   294→\\t\\tCommitter: sig,\\n   295→\\t\\tMessage:   \\\"Initialize metadata branch\\\\n\\\\nThis branch stores session metadata for the auto-commit strategy.\\\\n\\\",\\n   296→\\t}\\n   297→\\t// Note: No ParentHashes - this is an orphan commit\\n   298→\\n   299→\\tcommitObj := repo.Storer.NewEncodedObject()\\n   300→\\tif err := commit.Encode(commitObj); err != nil {\\n   301→\\t\\treturn fmt.Errorf(\\\"failed to encode orphan commit: %w\\\", err)\\n   302→\\t}\\n   303→\\tcommitHash, err := repo.Storer.SetEncodedObject(commitObj)\\n   304→\\tif err != nil {\\n   305→\\t\\treturn fmt.Errorf(\\\"failed to store orphan commit: %w\\\", err)\\n   306→\\t}\\n   307→\\n   308→\\t// Create branch reference\\n   309→\\tref := plumbing.NewHashReference(refName, commitHash)\\n   310→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   311→\\t\\treturn fmt.Errorf(\\\"failed to create metadata branch: %w\\\", err)\\n   312→\\t}\\n   313→\\n   314→\\tfmt.Fprintf(os.Stderr, \\\"✓ Created orphan branch '%s' for session metadata\\\\n\\\", paths.MetadataBranchName)\\n   315→\\treturn nil\\n   316→}\\n   317→\\n   318→// readCheckpointMetadata reads metadata.json from a checkpoint path on entire/checkpoints/v1.\\n   319→// With the new format, root metadata.json is a CheckpointSummary with Agents array.\\n   320→// This function reads the summary and extracts relevant fields into CheckpointInfo,\\n   321→// also reading session-level metadata for IsTask/ToolUseID fields.\\n   322→func ReadCheckpointMetadata(tree *object.Tree, checkpointPath string) (*CheckpointInfo, error) {\\n   323→\\tmetadataPath := checkpointPath + \\\"/metadata.json\\\"\\n   324→\\tfile, err := tree.File(metadataPath)\\n   325→\\tif err != nil {\\n   326→\\t\\treturn nil, fmt.Errorf(\\\"failed to find metadata at %s: %w\\\", metadataPath, err)\\n   327→\\t}\\n   328→\\n   329→\\tcontent, err := file.Contents()\\n   330→\\tif err != nil {\\n   331→\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata: %w\\\", err)\\n   332→\\t}\\n   333→\\n   334→\\t// Try to parse as CheckpointSummary first (new format)\\n   335→\\tvar summary checkpoint.CheckpointSummary\\n   336→\\tif err := json.Unmarshal([]byte(content), &summary); err == nil {\\n   337→\\t\\t// If we have sessions array, this is the new format\\n   338→\\t\\tif len(summary.Sessions) > 0 {\\n   339→\\t\\t\\tinfo := &CheckpointInfo{\\n   340→\\t\\t\\t\\tCheckpointID:     summary.CheckpointID,\\n   341→\\t\\t\\t\\tCheckpointsCount: summary.CheckpointsCount,\\n   342→\\t\\t\\t\\tFilesTouched:     summary.FilesTouched,\\n   343→\\t\\t\\t\\tSessionCount:     len(summary.Sessions),\\n   344→\\t\\t\\t}\\n   345→\\n   346→\\t\\t\\t// Read all sessions' metadata to populate SessionIDs and get other fields from first session\\n   347→\\t\\t\\tvar sessionIDs []string\\n   348→\\t\\t\\tfor i, sessionPaths := range summary.Sessions {\\n   349→\\t\\t\\t\\tif sessionPaths.Metadata != \\\"\\\" {\\n   350→\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n   351→\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n   352→\\t\\t\\t\\t\\tsessionMetadataPath := strings.TrimPrefix(sessionPaths.Metadata, \\\"/\\\")\\n   353→\\t\\t\\t\\t\\tif sessionFile, err := tree.File(sessionMetadataPath); err == nil {\\n   354→\\t\\t\\t\\t\\t\\tif sessionContent, err := sessionFile.Contents(); err == nil {\\n   355→\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata checkpoint.CommittedMetadata\\n   356→\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   357→\\t\\t\\t\\t\\t\\t\\t\\tsessionIDs = append(sessionIDs, sessionMetadata.SessionID)\\n   358→\\t\\t\\t\\t\\t\\t\\t\\t// Use first session for Agent, SessionID, CreatedAt, IsTask, ToolUseID\\n   359→\\t\\t\\t\\t\\t\\t\\t\\tif i == 0 {\\n   360→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   361→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   362→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   363→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.IsTask = sessionMetadata.IsTask\\n   364→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.ToolUseID = sessionMetadata.ToolUseID\\n   365→\\t\\t\\t\\t\\t\\t\\t\\t}\\n   366→\\t\\t\\t\\t\\t\\t\\t}\\n   367→\\t\\t\\t\\t\\t\\t}\\n   368→\\t\\t\\t\\t\\t}\\n   369→\\t\\t\\t\\t}\\n   370→\\t\\t\\t}\\n   371→\\t\\t\\tinfo.SessionIDs = sessionIDs\\n   372→\\n   373→\\t\\t\\treturn info, nil\\n   374→\\t\\t}\\n   375→\\t}\\n   376→\\n   377→\\t// Fall back to parsing as CheckpointInfo (old format or direct info)\\n   378→\\tvar metadata CheckpointInfo\\n   379→\\tif err := json.Unmarshal([]byte(content), &metadata); err != nil {\\n   380→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata: %w\\\", err)\\n   381→\\t}\\n   382→\\n   383→\\treturn &metadata, nil\\n   384→}\\n   385→\\n   386→// GetMetadataBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\n   387→func GetMetadataBranchTree(repo *git.Repository) (*object.Tree, error) {\\n   388→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   389→\\tref, err := repo.Reference(refName, true)\\n   390→\\tif err != nil {\\n   391→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch reference: %w\\\", err)\\n   392→\\t}\\n   393→\\n   394→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   395→\\tif err != nil {\\n   396→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch commit: %w\\\", err)\\n   397→\\t}\\n   398→\\n   399→\\ttree, err := commit.Tree()\\n   400→\\tif err != nil {\\n   401→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch tree: %w\\\", err)\\n   402→\\t}\\n   403→\\treturn tree, nil\\n   404→}\\n   405→\\n   406→// ExtractFirstPrompt extracts and truncates the first meaningful prompt from prompt content.\\n   407→// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\". Skips empty prompts and separator-only content.\\n   408→// Returns empty string if no valid prompt is found.\\n   409→func ExtractFirstPrompt(content string) string {\\n   410→\\tif content == \\\"\\\" {\\n   411→\\t\\treturn \\\"\\\"\\n   412→\\t}\\n   413→\\n   414→\\t// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\"\\n   415→\\t// Find the first non-empty prompt\\n   416→\\tprompts := strings.Split(content, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   417→\\tvar firstPrompt string\\n   418→\\tfor _, p := range prompts {\\n   419→\\t\\tcleaned := strings.TrimSpace(p)\\n   420→\\t\\t// Skip empty prompts or prompts that are just dashes/separators\\n   421→\\t\\tif cleaned == \\\"\\\" || isOnlySeparators(cleaned) {\\n   422→\\t\\t\\tcontinue\\n   423→\\t\\t}\\n   424→\\t\\tfirstPrompt = cleaned\\n   425→\\t\\tbreak\\n   426→\\t}\\n   427→\\n   428→\\tif firstPrompt == \\\"\\\" {\\n   429→\\t\\treturn \\\"\\\"\\n   430→\\t}\\n   431→\\n   432→\\treturn TruncateDescription(firstPrompt, MaxDescriptionLength)\\n   433→}\\n   434→\\n   435→// ReadSessionPromptFromTree reads the first meaningful prompt from a checkpoint's prompt.txt file in a git tree.\\n   436→// Returns an empty string if the prompt cannot be read.\\n   437→func ReadSessionPromptFromTree(tree *object.Tree, checkpointPath string) string {\\n   438→\\tpromptPath := checkpointPath + \\\"/\\\" + paths.PromptFileName\\n   439→\\tfile, err := tree.File(promptPath)\\n   440→\\tif err != nil {\\n   441→\\t\\treturn \\\"\\\"\\n   442→\\t}\\n   443→\\n   444→\\tcontent, err := file.Contents()\\n   445→\\tif err != nil {\\n   446→\\t\\treturn \\\"\\\"\\n   447→\\t}\\n   448→\\n   449→\\treturn ExtractFirstPrompt(content)\\n   450→}\\n   451→\\n   452→// ReadAgentTypeFromTree reads the agent type from a checkpoint's metadata.json file in a git tree.\\n   453→// If metadata.json doesn't exist (shadow branches), it falls back to detecting the agent\\n   454→// from the presence of agent-specific config files (.gemini/settings.json or .claude/).\\n   455→// Returns agent.AgentTypeUnknown if the agent type cannot be determined.\\n   456→func ReadAgentTypeFromTree(tree *object.Tree, checkpointPath string) agent.AgentType {\\n   457→\\t// First, try to read from metadata.json (present in condensed/committed checkpoints)\\n   458→\\tmetadataPath := checkpointPath + \\\"/\\\" + paths.MetadataFileName\\n   459→\\tif file, err := tree.File(metadataPath); err == nil {\\n   460→\\t\\tif content, err := file.Contents(); err == nil {\\n   461→\\t\\t\\tvar metadata checkpoint.CommittedMetadata\\n   462→\\t\\t\\tif err := json.Unmarshal([]byte(content), &metadata); err == nil && metadata.Agent != \\\"\\\" {\\n   463→\\t\\t\\t\\treturn metadata.Agent\\n   464→\\t\\t\\t}\\n   465→\\t\\t}\\n   466→\\t}\\n   467→\\n   468→\\t// Fall back to detecting agent from config files (shadow branches don't have metadata.json).\\n   469→\\t// Order: Gemini (most specific check), Claude (established default), OpenCode (newest/preview).\\n   470→\\tif _, err := tree.File(\\\".gemini/settings.json\\\"); err == nil {\\n   471→\\t\\treturn agent.AgentTypeGemini\\n   472→\\t}\\n   473→\\tif _, err := tree.Tree(\\\".claude\\\"); err == nil {\\n   474→\\t\\treturn agent.AgentTypeClaudeCode\\n   475→\\t}\\n   476→\\t// OpenCode: .opencode directory or opencode.json config\\n   477→\\tif _, err := tree.Tree(\\\".opencode\\\"); err == nil {\\n   478→\\t\\treturn agent.AgentTypeOpenCode\\n   479→\\t}\\n   480→\\tif _, err := tree.File(\\\"opencode.json\\\"); err == nil {\\n   481→\\t\\treturn agent.AgentTypeOpenCode\\n   482→\\t}\\n   483→\\n   484→\\treturn agent.AgentTypeUnknown\\n   485→}\\n   486→\\n   487→// isOnlySeparators checks if a string contains only dashes, spaces, and newlines.\\n   488→func isOnlySeparators(s string) bool {\\n   489→\\tfor _, r := range s {\\n   490→\\t\\tif r != '-' && r != ' ' && r != '\\\\n' && r != '\\\\r' && r != '\\\\t' {\\n   491→\\t\\t\\treturn false\\n   492→\\t\\t}\\n   493→\\t}\\n   494→\\treturn true\\n   495→}\\n   496→\\n   497→// ReadAllSessionPromptsFromTree reads the first prompt for all sessions in a multi-session checkpoint.\\n   498→// Returns a slice of prompts parallel to sessionIDs (oldest to newest).\\n   499→// For single-session checkpoints, returns a slice with just the root prompt.\\n   500→func ReadAllSessionPromptsFromTree(tree *object.Tree, checkpointPath string, sessionCount int, sessionIDs []string) []string {\\n   501→\\tif sessionCount <= 1 || len(sessionIDs) <= 1 {\\n   502→\\t\\t// Single session - just return the root prompt\\n   503→\\t\\tprompt := ReadSessionPromptFromTree(tree, checkpointPath)\\n   504→\\t\\tif prompt != \\\"\\\" {\\n   505→\\t\\t\\treturn []string{prompt}\\n   506→\\t\\t}\\n   507→\\t\\treturn nil\\n   508→\\t}\\n   509→\\n   510→\\t// Multi-session: read prompts from archived folders (0/, 1/, etc.) and root\\n   511→\\tprompts := make([]string, len(sessionIDs))\\n   512→\\n   513→\\t// Read archived session prompts (folders 0, 1, ... N-2)\\n   514→\\tfor i := range sessionCount - 1 {\\n   515→\\t\\tarchivedPath := fmt.Sprintf(\\\"%s/%d\\\", checkpointPath, i)\\n   516→\\t\\tprompts[i] = ReadSessionPromptFromTree(tree, archivedPath)\\n   517→\\t}\\n   518→\\n   519→\\t// Read the most recent session prompt (at root level)\\n   520→\\tprompts[len(prompts)-1] = ReadSessionPromptFromTree(tree, checkpointPath)\\n   521→\\n   522→\\treturn prompts\\n   523→}\\n   524→\\n   525→// GetRemoteMetadataBranchTree returns the tree object for origin/entire/checkpoints/v1.\\n   526→func GetRemoteMetadataBranchTree(repo *git.Repository) (*object.Tree, error) {\\n   527→\\trefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n   528→\\tref, err := repo.Reference(refName, true)\\n   529→\\tif err != nil {\\n   530→\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch reference: %w\\\", err)\\n   531→\\t}\\n   532→\\n   533→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   534→\\tif err != nil {\\n   535→\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch commit: %w\\\", err)\\n   536→\\t}\\n   537→\\n   538→\\ttree, err := commit.Tree()\\n   539→\\tif err != nil {\\n   540→\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch tree: %w\\\", err)\\n   541→\\t}\\n   542→\\treturn tree, nil\\n   543→}\\n   544→\\n   545→// OpenRepository opens the git repository with linked worktree support enabled.\\n   546→// It uses git.PlainOpenWithOptions with EnableDotGitCommonDir set to true,\\n   547→// which is required for proper operation in git worktrees created via 'git worktree add'.\\n   548→//\\n   549→// Without EnableDotGitCommonDir, go-git operations in worktrees can silently fail:\\n   550→// - Commits appear to succeed but are not persisted\\n   551→// - Refs are written to incorrect locations\\n   552→// - The worktree's HEAD/index don't get updated properly\\n   553→//\\n   554→// This happens because worktrees use .git as a file (pointing to the main repo)\\n   555→// rather than a directory, and go-git needs to route paths correctly between\\n   556→// shared (.git/) and per-worktree (.git/worktrees/<name>/) locations.\\n   557→//\\n   558→// The function first uses 'git rev-parse --show-toplevel' to find the repository\\n   559→// root, which works correctly even when called from a subdirectory within the repo.\\n   560→func OpenRepository() (*git.Repository, error) {\\n   561→\\t// First, find the repository root using git rev-parse --show-toplevel\\n   562→\\t// This works correctly from any subdirectory within the repository\\n   563→\\trepoRoot, err := GetWorktreePath()\\n   564→\\tif err != nil {\\n   565→\\t\\t// Fallback to current directory if git command fails\\n   566→\\t\\t// (e.g., if git is not installed or we're not in a repo)\\n   567→\\t\\trepoRoot = \\\".\\\"\\n   568→\\t}\\n   569→\\n   570→\\trepo, err := git.PlainOpenWithOptions(repoRoot, &git.PlainOpenOptions{\\n   571→\\t\\tEnableDotGitCommonDir: true,\\n   572→\\t})\\n   573→\\tif err != nil {\\n   574→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   575→\\t}\\n   576→\\treturn repo, nil\\n   577→}\\n   578→\\n   579→// IsInsideWorktree returns true if the current directory is inside a git worktree\\n   580→// (as opposed to the main repository). Worktrees have .git as a file pointing\\n   581→// to the main repo, while the main repo has .git as a directory.\\n   582→// This function works correctly from any subdirectory within the repository.\\n   583→func IsInsideWorktree() bool {\\n   584→\\t// First find the repository root\\n   585→\\trepoRoot, err := GetWorktreePath()\\n   586→\\tif err != nil {\\n   587→\\t\\treturn false\\n   588→\\t}\\n   589→\\n   590→\\tgitPath := filepath.Join(repoRoot, gitDir)\\n   591→\\tgitInfo, err := os.Stat(gitPath)\\n   592→\\tif err != nil {\\n   593→\\t\\treturn false\\n   594→\\t}\\n   595→\\treturn !gitInfo.IsDir()\\n   596→}\\n   597→\\n   598→// GetMainRepoRoot returns the root directory of the main repository.\\n   599→// In the main repo, this is the worktree path (repo root).\\n   600→// In a worktree, this parses the .git file to find the main repo.\\n   601→// This function works correctly from any subdirectory within the repository.\\n   602→//\\n   603→// Per gitrepository-layout(5), a worktree's .git file is a \\\"gitfile\\\" containing\\n   604→// \\\"gitdir: <path>\\\" pointing to $GIT_DIR/worktrees/<id> in the main repository.\\n   605→// See: https://git-scm.com/docs/gitrepository-layout\\n   606→func GetMainRepoRoot() (string, error) {\\n   607→\\t// First find the worktree/repo root\\n   608→\\trepoRoot, err := GetWorktreePath()\\n   609→\\tif err != nil {\\n   610→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get worktree path: %w\\\", err)\\n   611→\\t}\\n   612→\\n   613→\\tif !IsInsideWorktree() {\\n   614→\\t\\treturn repoRoot, nil\\n   615→\\t}\\n   616→\\n   617→\\t// Worktree .git file contains: \\\"gitdir: /path/to/main/.git/worktrees/<id>\\\"\\n   618→\\tgitFilePath := filepath.Join(repoRoot, gitDir)\\n   619→\\tcontent, err := os.ReadFile(gitFilePath) //nolint:gosec // G304: gitFilePath is constructed from repo root, not user input\\n   620→\\tif err != nil {\\n   621→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read .git file: %w\\\", err)\\n   622→\\t}\\n   623→\\n   624→\\tgitdir := strings.TrimSpace(string(content))\\n   625→\\tgitdir = strings.TrimPrefix(gitdir, \\\"gitdir: \\\")\\n   626→\\n   627→\\t// Extract main repo root: everything before \\\"/.git/\\\"\\n   628→\\tidx := strings.LastIndex(gitdir, \\\"/.git/\\\")\\n   629→\\tif idx < 0 {\\n   630→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"unexpected gitdir format: %s\\\", gitdir)\\n   631→\\t}\\n   632→\\treturn gitdir[:idx], nil\\n   633→}\\n   634→\\n   635→// GetGitCommonDir returns the path to the shared git directory.\\n   636→// In a regular checkout, this is .git/\\n   637→// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n   638→// Uses git rev-parse --git-common-dir for reliable handling of worktrees.\\n   639→func GetGitCommonDir() (string, error) {\\n   640→\\tctx := context.Background()\\n   641→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-common-dir\\\")\\n   642→\\tcmd.Dir = \\\".\\\"\\n   643→\\toutput, err := cmd.Output()\\n   644→\\tif err != nil {\\n   645→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   646→\\t}\\n   647→\\n   648→\\tcommonDir := strings.TrimSpace(string(output))\\n   649→\\n   650→\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\n   651→\\t// so we need to make it absolute if it isn't already\\n   652→\\tif !filepath.IsAbs(commonDir) {\\n   653→\\t\\tcommonDir = filepath.Join(\\\".\\\", commonDir)\\n   654→\\t}\\n   655→\\n   656→\\treturn filepath.Clean(commonDir), nil\\n   657→}\\n   658→\\n   659→// GetWorktreePath returns the absolute path to the current worktree root.\\n   660→// This is the working directory path, not the git directory.\\n   661→func GetWorktreePath() (string, error) {\\n   662→\\tctx := context.Background()\\n   663→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--show-toplevel\\\")\\n   664→\\toutput, err := cmd.Output()\\n   665→\\tif err != nil {\\n   666→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get worktree path: %w\\\", err)\\n   667→\\t}\\n   668→\\treturn strings.TrimSpace(string(output)), nil\\n   669→}\\n   670→\\n   671→// EnsureEntireGitignore ensures all required entries are in .entire/.gitignore\\n   672→// Works correctly from any subdirectory within the repository.\\n   673→func EnsureEntireGitignore() error {\\n   674→\\t// Get absolute path for the gitignore file\\n   675→\\tgitignoreAbs, err := paths.AbsPath(entireGitignore)\\n   676→\\tif err != nil {\\n   677→\\t\\tgitignoreAbs = entireGitignore // Fallback to relative\\n   678→\\t}\\n   679→\\n   680→\\t// Read existing content\\n   681→\\tvar content string\\n   682→\\tif data, err := os.ReadFile(gitignoreAbs); err == nil { //nolint:gosec // path is from AbsPath or constant\\n   683→\\t\\tcontent = string(data)\\n   684→\\t}\\n   685→\\n   686→\\t// All entries that should be in .entire/.gitignore\\n   687→\\trequiredEntries := []string{\\n   688→\\t\\t\\\"tmp/\\\",\\n   689→\\t\\t\\\"settings.local.json\\\",\\n   690→\\t\\t\\\"metadata/\\\",\\n   691→\\t\\t\\\"logs/\\\",\\n   692→\\t}\\n   693→\\n   694→\\t// Track what needs to be added\\n   695→\\tvar toAdd []string\\n   696→\\tfor _, entry := range requiredEntries {\\n   697→\\t\\tif !strings.Contains(content, entry) {\\n   698→\\t\\t\\ttoAdd = append(toAdd, entry)\\n   699→\\t\\t}\\n   700→\\t}\\n   701→\\n   702→\\t// Nothing to add\\n   703→\\tif len(toAdd) == 0 {\\n   704→\\t\\treturn nil\\n   705→\\t}\\n   706→\\n   707→\\t// Ensure .entire directory exists\\n   708→\\tif err := os.MkdirAll(filepath.Dir(gitignoreAbs), 0o750); err != nil {\\n   709→\\t\\treturn fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   710→\\t}\\n   711→\\n   712→\\t// Append missing entries to gitignore\\n   713→\\tvar sb strings.Builder\\n   714→\\tfor _, entry := range toAdd {\\n   715→\\t\\tsb.WriteString(entry + \\\"\\\\n\\\")\\n   716→\\t}\\n   717→\\tcontent += sb.String()\\n   718→\\n   719→\\tif err := os.WriteFile(gitignoreAbs, []byte(content), 0o644); err != nil { //nolint:gosec // path is from AbsPath or constant\\n   720→\\t\\treturn fmt.Errorf(\\\"failed to write gitignore: %w\\\", err)\\n   721→\\t}\\n   722→\\treturn nil\\n   723→}\\n   724→\\n   725→// checkCanRewind checks if working directory is clean enough for rewind.\\n   726→// Returns (canRewind, reason, error). Shared by shadow and linear-shadow strategies.\\n   727→func checkCanRewind() (bool, string, error) {\\n   728→\\trepo, err := OpenRepository()\\n   729→\\tif err != nil {\\n   730→\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   731→\\t}\\n   732→\\n   733→\\tworktree, err := repo.Worktree()\\n   734→\\tif err != nil {\\n   735→\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   736→\\t}\\n   737→\\n   738→\\tstatus, err := worktree.Status()\\n   739→\\tif err != nil {\\n   740→\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n   741→\\t}\\n   742→\\n   743→\\tif status.IsClean() {\\n   744→\\t\\treturn true, \\\"\\\", nil\\n   745→\\t}\\n   746→\\n   747→\\tvar modified, added, deleted []string\\n   748→\\tfor file, st := range status {\\n   749→\\t\\t// Skip .entire directory\\n   750→\\t\\tif paths.IsInfrastructurePath(file) {\\n   751→\\t\\t\\tcontinue\\n   752→\\t\\t}\\n   753→\\n   754→\\t\\t// Skip untracked files\\n   755→\\t\\tif st.Worktree == git.Untracked {\\n   756→\\t\\t\\tcontinue\\n   757→\\t\\t}\\n   758→\\n   759→\\t\\tswitch {\\n   760→\\t\\tcase st.Staging == git.Added || st.Worktree == git.Added:\\n   761→\\t\\t\\tadded = append(added, file)\\n   762→\\t\\tcase st.Staging == git.Deleted || st.Worktree == git.Deleted:\\n   763→\\t\\t\\tdeleted = append(deleted, file)\\n   764→\\t\\tcase st.Staging == git.Modified || st.Worktree == git.Modified:\\n   765→\\t\\t\\tmodified = append(modified, file)\\n   766→\\t\\t}\\n   767→\\t}\\n   768→\\n   769→\\tif len(modified) == 0 && len(added) == 0 && len(deleted) == 0 {\\n   770→\\t\\treturn true, \\\"\\\", nil\\n   771→\\t}\\n   772→\\n   773→\\tvar msg strings.Builder\\n   774→\\tmsg.WriteString(\\\"You have uncommitted changes:\\\\n\\\")\\n   775→\\tfor _, f := range modified {\\n   776→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  modified:   %s\\\\n\\\", f))\\n   777→\\t}\\n   778→\\tfor _, f := range added {\\n   779→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  added:      %s\\\\n\\\", f))\\n   780→\\t}\\n   781→\\tfor _, f := range deleted {\\n   782→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  deleted:    %s\\\\n\\\", f))\\n   783→\\t}\\n   784→\\tmsg.WriteString(\\\"\\\\nPlease commit or stash your changes before rewinding.\\\")\\n   785→\\n   786→\\treturn false, msg.String(), nil\\n   787→}\\n   788→\\n   789→// checkCanRewindWithWarning checks working directory and returns a warning with diff stats.\\n   790→// Unlike checkCanRewind, this always returns canRewind=true but includes a warning message\\n   791→// with +/- line stats for uncommitted changes. Used by manual-commit strategy.\\n   792→func checkCanRewindWithWarning() (bool, string, error) {\\n   793→\\trepo, err := OpenRepository()\\n   794→\\tif err != nil {\\n   795→\\t\\t// Can't open repo - still allow rewind but without stats\\n   796→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if repo can't be opened\\n   797→\\t}\\n   798→\\n   799→\\tworktree, err := repo.Worktree()\\n   800→\\tif err != nil {\\n   801→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if worktree can't be accessed\\n   802→\\t}\\n   803→\\n   804→\\tstatus, err := worktree.Status()\\n   805→\\tif err != nil {\\n   806→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if status can't be retrieved\\n   807→\\t}\\n   808→\\n   809→\\tif status.IsClean() {\\n   810→\\t\\treturn true, \\\"\\\", nil\\n   811→\\t}\\n   812→\\n   813→\\t// Get HEAD commit tree for comparison - if we can't get it, just return without stats\\n   814→\\thead, err := repo.Head()\\n   815→\\tif err != nil {\\n   816→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even without HEAD (e.g., empty repo)\\n   817→\\t}\\n   818→\\n   819→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   820→\\tif err != nil {\\n   821→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if commit lookup fails\\n   822→\\t}\\n   823→\\n   824→\\theadTree, err := headCommit.Tree()\\n   825→\\tif err != nil {\\n   826→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if tree lookup fails\\n   827→\\t}\\n   828→\\n   829→\\ttype fileChange struct {\\n   830→\\t\\tstatus   string // \\\"modified\\\", \\\"added\\\", \\\"deleted\\\"\\n   831→\\t\\tadded    int\\n   832→\\t\\tremoved  int\\n   833→\\t\\tfilename string\\n   834→\\t}\\n   835→\\n   836→\\tvar changes []fileChange\\n   837→\\t// Use repo root, not cwd - git status returns paths relative to repo root\\n   838→\\trepoRoot, err := GetWorktreePath()\\n   839→\\tif err != nil {\\n   840→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if repo root lookup fails\\n   841→\\t}\\n   842→\\n   843→\\tfor file, st := range status {\\n   844→\\t\\t// Skip .entire directory\\n   845→\\t\\tif paths.IsInfrastructurePath(file) {\\n   846→\\t\\t\\tcontinue\\n   847→\\t\\t}\\n   848→\\n   849→\\t\\t// Skip untracked files\\n   850→\\t\\tif st.Worktree == git.Untracked {\\n   851→\\t\\t\\tcontinue\\n   852→\\t\\t}\\n   853→\\n   854→\\t\\tvar change fileChange\\n   855→\\t\\tchange.filename = file\\n   856→\\n   857→\\t\\tswitch {\\n   858→\\t\\tcase st.Staging == git.Added || st.Worktree == git.Added:\\n   859→\\t\\t\\tchange.status = \\\"added\\\"\\n   860→\\t\\t\\t// New file - count all lines as added\\n   861→\\t\\t\\tabsPath := filepath.Join(repoRoot, file)\\n   862→\\t\\t\\tif content, err := os.ReadFile(absPath); err == nil { //nolint:gosec // absPath is repo root + relative path from git status\\n   863→\\t\\t\\t\\tchange.added = countLines(content)\\n   864→\\t\\t\\t}\\n   865→\\t\\tcase st.Staging == git.Deleted || st.Worktree == git.Deleted:\\n   866→\\t\\t\\tchange.status = \\\"deleted\\\"\\n   867→\\t\\t\\t// Deleted file - count lines from HEAD as removed\\n   868→\\t\\t\\tif entry, err := headTree.File(file); err == nil {\\n   869→\\t\\t\\t\\tif content, err := entry.Contents(); err == nil {\\n   870→\\t\\t\\t\\t\\tchange.removed = countLines([]byte(content))\\n   871→\\t\\t\\t\\t}\\n   872→\\t\\t\\t}\\n   873→\\t\\tcase st.Staging == git.Modified || st.Worktree == git.Modified:\\n   874→\\t\\t\\tchange.status = \\\"modified\\\"\\n   875→\\t\\t\\t// Modified file - compute diff stats\\n   876→\\t\\t\\tvar headContent, workContent []byte\\n   877→\\t\\t\\tif entry, err := headTree.File(file); err == nil {\\n   878→\\t\\t\\t\\tif content, err := entry.Contents(); err == nil {\\n   879→\\t\\t\\t\\t\\theadContent = []byte(content)\\n   880→\\t\\t\\t\\t}\\n   881→\\t\\t\\t}\\n   882→\\t\\t\\tabsPath := filepath.Join(repoRoot, file)\\n   883→\\t\\t\\tif content, err := os.ReadFile(absPath); err == nil { //nolint:gosec // absPath is repo root + relative path from git status\\n   884→\\t\\t\\t\\tworkContent = content\\n   885→\\t\\t\\t}\\n   886→\\t\\t\\tif headContent != nil && workContent != nil {\\n   887→\\t\\t\\t\\tchange.added, change.removed = computeDiffStats(headContent, workContent)\\n   888→\\t\\t\\t}\\n   889→\\t\\tdefault:\\n   890→\\t\\t\\tcontinue\\n   891→\\t\\t}\\n   892→\\n   893→\\t\\tchanges = append(changes, change)\\n   894→\\t}\\n   895→\\n   896→\\tif len(changes) == 0 {\\n   897→\\t\\treturn true, \\\"\\\", nil\\n   898→\\t}\\n   899→\\n   900→\\t// Sort changes by filename for consistent output\\n   901→\\tsort.Slice(changes, func(i, j int) bool {\\n   902→\\t\\treturn changes[i].filename < changes[j].filename\\n   903→\\t})\\n   904→\\n   905→\\tvar msg strings.Builder\\n   906→\\tmsg.WriteString(\\\"The following uncommitted changes will be reverted:\\\\n\\\")\\n   907→\\n   908→\\ttotalAdded, totalRemoved := 0, 0\\n   909→\\tfor _, c := range changes {\\n   910→\\t\\ttotalAdded += c.added\\n   911→\\t\\ttotalRemoved += c.removed\\n   912→\\n   913→\\t\\tvar stats string\\n   914→\\t\\tswitch {\\n   915→\\t\\tcase c.added > 0 && c.removed > 0:\\n   916→\\t\\t\\tstats = fmt.Sprintf(\\\"+%d/-%d\\\", c.added, c.removed)\\n   917→\\t\\tcase c.added > 0:\\n   918→\\t\\t\\tstats = fmt.Sprintf(\\\"+%d\\\", c.added)\\n   919→\\t\\tcase c.removed > 0:\\n   920→\\t\\t\\tstats = fmt.Sprintf(\\\"-%d\\\", c.removed)\\n   921→\\t\\t}\\n   922→\\n   923→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  %-10s %s\\\", c.status+\\\":\\\", c.filename))\\n   924→\\t\\tif stats != \\\"\\\" {\\n   925→\\t\\t\\tmsg.WriteString(fmt.Sprintf(\\\" (%s)\\\", stats))\\n   926→\\t\\t}\\n   927→\\t\\tmsg.WriteString(\\\"\\\\n\\\")\\n   928→\\t}\\n   929→\\n   930→\\tif totalAdded > 0 || totalRemoved > 0 {\\n   931→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"\\\\nTotal: +%d/-%d lines\\\\n\\\", totalAdded, totalRemoved))\\n   932→\\t}\\n   933→\\n   934→\\treturn true, msg.String(), nil\\n   935→}\\n   936→\\n   937→// countLines counts the number of lines in content.\\n   938→func countLines(content []byte) int {\\n   939→\\tif len(content) == 0 {\\n   940→\\t\\treturn 0\\n   941→\\t}\\n   942→\\tcount := 1\\n   943→\\tfor _, b := range content {\\n   944→\\t\\tif b == '\\\\n' {\\n   945→\\t\\t\\tcount++\\n   946→\\t\\t}\\n   947→\\t}\\n   948→\\t// Don't count trailing newline as extra line\\n   949→\\tif len(content) > 0 && content[len(content)-1] == '\\\\n' {\\n   950→\\t\\tcount--\\n   951→\\t}\\n   952→\\treturn count\\n   953→}\\n   954→\\n   955→// computeDiffStats computes added and removed line counts between old and new content.\\n   956→// Uses a simple line-based diff algorithm.\\n   957→func computeDiffStats(oldContent, newContent []byte) (added, removed int) {\\n   958→\\toldLines := splitLines(oldContent)\\n   959→\\tnewLines := splitLines(newContent)\\n   960→\\n   961→\\t// Build a set of old lines with counts\\n   962→\\toldSet := make(map[string]int)\\n   963→\\tfor _, line := range oldLines {\\n   964→\\t\\toldSet[line]++\\n   965→\\t}\\n   966→\\n   967→\\t// Check which new lines are truly new\\n   968→\\tfor _, line := range newLines {\\n   969→\\t\\tif oldSet[line] > 0 {\\n   970→\\t\\t\\toldSet[line]--\\n   971→\\t\\t} else {\\n   972→\\t\\t\\tadded++\\n   973→\\t\\t}\\n   974→\\t}\\n   975→\\n   976→\\t// Remaining old lines are removed\\n   977→\\tfor _, count := range oldSet {\\n   978→\\t\\tremoved += count\\n   979→\\t}\\n   980→\\n   981→\\treturn added, removed\\n   982→}\\n   983→\\n   984→// splitLines splits content into lines, preserving empty lines.\\n   985→func splitLines(content []byte) []string {\\n   986→\\tif len(content) == 0 {\\n   987→\\t\\treturn nil\\n   988→\\t}\\n   989→\\ts := string(content)\\n   990→\\t// Remove trailing newline to avoid empty last element\\n   991→\\ts = strings.TrimSuffix(s, \\\"\\\\n\\\")\\n   992→\\treturn strings.Split(s, \\\"\\\\n\\\")\\n   993→}\\n   994→\\n   995→// fileExists checks if a file exists at the given path.\\n   996→func fileExists(path string) bool {\\n   997→\\t_, err := os.Stat(path)\\n   998→\\treturn err == nil\\n   999→}\\n  1000→\\n  1001→// StageFilesContext describes what type of staging operation this is (for messages).\\n  1002→type StageFilesContext string\\n  1003→\\n  1004→const (\\n  1005→\\t// StageForSession is used when staging files for a session checkpoint.\\n  1006→\\tStageForSession StageFilesContext = \\\"session\\\"\\n  1007→\\t// StageForTask is used when staging files for a task checkpoint.\\n  1008→\\tStageForTask StageFilesContext = \\\"task\\\"\\n  1009→)\\n  1010→\\n  1011→// StageFiles stages modified, new, and deleted files to the git worktree.\\n  1012→//\\n  1013→// This function handles three categories of file changes:\\n  1014→//  1. Modified files: existing files that have been changed\\n  1015→//  2. New files: files that were created during the session\\n  1016→//  3. Deleted files: files that were removed during the session\\n  1017→//\\n  1018→// Error Handling Strategy:\\n  1019→//   - Individual file staging errors are logged to stderr but don't fail the operation\\n  1020→//   - This ensures that partial staging succeeds even if some files have issues\\n  1021→//   - If a modified file no longer exists, it's treated as a deletion\\n  1022→//\\n  1023→// The stageCtx parameter is used for user-facing messages to indicate whether\\n  1024→// this is staging for a session checkpoint or a task checkpoint.\\n  1025→func StageFiles(worktree *git.Worktree, modified, newFiles, deleted []string, stageCtx StageFilesContext) {\\n  1026→\\t// Get repo root for resolving file paths\\n  1027→\\t// This is critical because fileExists() uses os.Stat() which resolves relative to CWD,\\n  1028→\\t// but worktree.Add/Remove resolve relative to repo root. If CWD != repo root,\\n  1029→\\t// fileExists() could return false for existing files, causing worktree.Remove()\\n  1030→\\t// to incorrectly delete them.\\n  1031→\\trepoRoot := worktree.Filesystem.Root()\\n  1032→\\n  1033→\\t// Stage modified files\\n  1034→\\tfor _, file := range modified {\\n  1035→\\t\\t// Resolve path relative to repo root for existence check\\n  1036→\\t\\tabsPath := filepath.Join(repoRoot, file)\\n  1037→\\t\\tif fileExists(absPath) {\\n  1038→\\t\\t\\tif _, err := worktree.Add(file); err != nil {\\n  1039→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage %s: %v\\\\n\\\", file, err)\\n  1040→\\t\\t\\t} else {\\n  1041→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged: %s\\\\n\\\", file)\\n  1042→\\t\\t\\t}\\n  1043→\\t\\t} else {\\n  1044→\\t\\t\\t// File was deleted - stage the deletion\\n  1045→\\t\\t\\tif _, err := worktree.Remove(file); err != nil {\\n  1046→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  File not found or deleted: %s\\\\n\\\", file)\\n  1047→\\t\\t\\t}\\n  1048→\\t\\t}\\n  1049→\\t}\\n  1050→\\n  1051→\\t// Stage new files\\n  1052→\\tif len(newFiles) > 0 {\\n  1053→\\t\\tfmt.Fprintf(os.Stderr, \\\"Staging %d new files created during %s:\\\\n\\\", len(newFiles), stageCtx)\\n  1054→\\t\\tfor _, file := range newFiles {\\n  1055→\\t\\t\\tif _, err := worktree.Add(file); err != nil {\\n  1056→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage %s: %v\\\\n\\\", file, err)\\n  1057→\\t\\t\\t} else {\\n  1058→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged new file: %s\\\\n\\\", file)\\n  1059→\\t\\t\\t}\\n  1060→\\t\\t}\\n  1061→\\t}\\n  1062→\\n  1063→\\t// Stage deleted files\\n  1064→\\tfor _, file := range deleted {\\n  1065→\\t\\tif _, err := worktree.Remove(file); err != nil {\\n  1066→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage deleted file %s: %v\\\\n\\\", file, err)\\n  1067→\\t\\t} else {\\n  1068→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged deleted file: %s\\\\n\\\", file)\\n  1069→\\t\\t}\\n  1070→\\t}\\n  1071→}\\n  1072→\\n  1073→// getTaskCheckpointFromTree retrieves a task checkpoint from a commit tree.\\n  1074→// Shared implementation for shadow and linear-shadow strategies.\\n  1075→func getTaskCheckpointFromTree(point RewindPoint) (*TaskCheckpoint, error) {\\n  1076→\\tif !point.IsTaskCheckpoint {\\n  1077→\\t\\treturn nil, ErrNotTaskCheckpoint\\n  1078→\\t}\\n  1079→\\n  1080→\\trepo, err := OpenRepository()\\n  1081→\\tif err != nil {\\n  1082→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n  1083→\\t}\\n  1084→\\n  1085→\\tcommitHash := plumbing.NewHash(point.ID)\\n  1086→\\tcommit, err := repo.CommitObject(commitHash)\\n  1087→\\tif err != nil {\\n  1088→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n  1089→\\t}\\n  1090→\\n  1091→\\ttree, err := commit.Tree()\\n  1092→\\tif err != nil {\\n  1093→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n  1094→\\t}\\n  1095→\\n  1096→\\t// Read checkpoint.json from the tree\\n  1097→\\tcheckpointPath := point.MetadataDir + \\\"/checkpoint.json\\\"\\n  1098→\\tfile, err := tree.File(checkpointPath)\\n  1099→\\tif err != nil {\\n  1100→\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", checkpointPath, err)\\n  1101→\\t}\\n  1102→\\n  1103→\\tcontent, err := file.Contents()\\n  1104→\\tif err != nil {\\n  1105→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n  1106→\\t}\\n  1107→\\n  1108→\\tvar checkpoint TaskCheckpoint\\n  1109→\\tif err := json.Unmarshal([]byte(content), &checkpoint); err != nil {\\n  1110→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse checkpoint: %w\\\", err)\\n  1111→\\t}\\n  1112→\\n  1113→\\treturn &checkpoint, nil\\n  1114→}\\n  1115→\\n  1116→// getTaskTranscriptFromTree retrieves a task transcript from a commit tree.\\n  1117→// Shared implementation for shadow and linear-shadow strategies.\\n  1118→func getTaskTranscriptFromTree(point RewindPoint) ([]byte, error) {\\n  1119→\\tif !point.IsTaskCheckpoint {\\n  1120→\\t\\treturn nil, ErrNotTaskCheckpoint\\n  1121→\\t}\\n  1122→\\n  1123→\\trepo, err := OpenRepository()\\n  1124→\\tif err != nil {\\n  1125→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n  1126→\\t}\\n  1127→\\n  1128→\\tcommitHash := plumbing.NewHash(point.ID)\\n  1129→\\tcommit, err := repo.CommitObject(commitHash)\\n  1130→\\tif err != nil {\\n  1131→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n  1132→\\t}\\n  1133→\\n  1134→\\ttree, err := commit.Tree()\\n  1135→\\tif err != nil {\\n  1136→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n  1137→\\t}\\n  1138→\\n  1139→\\t// MetadataDir format: .entire/metadata/<session>/tasks/<toolUseID>\\n  1140→\\t// Session transcript is at: .entire/metadata/<session>/<TranscriptFileName>\\n  1141→\\tsessionDir := filepath.Dir(filepath.Dir(point.MetadataDir))\\n  1142→\\n  1143→\\t// Try current format first, then legacy\\n  1144→\\ttranscriptPath := sessionDir + \\\"/\\\" + paths.TranscriptFileName\\n  1145→\\tfile, err := tree.File(transcriptPath)\\n  1146→\\tif err != nil {\\n  1147→\\t\\ttranscriptPath = sessionDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n  1148→\\t\\tfile, err = tree.File(transcriptPath)\\n  1149→\\t\\tif err != nil {\\n  1150→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find transcript: %w\\\", err)\\n  1151→\\t\\t}\\n  1152→\\t}\\n  1153→\\n  1154→\\tcontent, err := file.Contents()\\n  1155→\\tif err != nil {\\n  1156→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n  1157→\\t}\\n  1158→\\n  1159→\\treturn []byte(content), nil\\n  1160→}\\n  1161→\\n  1162→// ErrBranchNotFound is returned by DeleteBranchCLI when the branch does not exist.\\n  1163→var ErrBranchNotFound = errors.New(\\\"branch not found\\\")\\n  1164→\\n  1165→// DeleteBranchCLI deletes a git branch using the git CLI.\\n  1166→// Uses `git branch -D` instead of go-git's RemoveReference because go-git v5\\n  1167→// doesn't properly persist deletions when refs are packed (.git/packed-refs)\\n  1168→// or in a worktree context. This is the same class of go-git v5 bug that\\n  1169→// affects checkout and reset --hard (see HardResetWithProtection).\\n  1170→//\\n  1171→// Returns ErrBranchNotFound if the branch does not exist, allowing callers\\n  1172→// to use errors.Is for idempotent deletion patterns.\\n  1173→func DeleteBranchCLI(branchName string) error {\\n  1174→\\tctx := context.Background()\\n  1175→\\n  1176→\\t// Pre-check: verify the branch exists so callers get a structured error\\n  1177→\\t// instead of parsing git's output string (which varies across locales).\\n  1178→\\t// git show-ref exits 1 for \\\"not found\\\" and 128+ for fatal errors (corrupt\\n  1179→\\t// repo, permissions, not a git directory). Only map exit code 1 to\\n  1180→\\t// ErrBranchNotFound; propagate other failures as-is.\\n  1181→\\tcheck := exec.CommandContext(ctx, \\\"git\\\", \\\"show-ref\\\", \\\"--verify\\\", \\\"--quiet\\\", \\\"refs/heads/\\\"+branchName) //nolint:gosec // branchName comes from internal shadow branch naming\\n  1182→\\tif err := check.Run(); err != nil {\\n  1183→\\t\\tvar exitErr *exec.ExitError\\n  1184→\\t\\tif errors.As(err, &exitErr) && exitErr.ExitCode() == 1 {\\n  1185→\\t\\t\\treturn fmt.Errorf(\\\"%w: %s\\\", ErrBranchNotFound, branchName)\\n  1186→\\t\\t}\\n  1187→\\t\\treturn fmt.Errorf(\\\"failed to check branch %s: %w\\\", branchName, err)\\n  1188→\\t}\\n  1189→\\n  1190→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", branchName)\\n  1191→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1192→\\t\\treturn fmt.Errorf(\\\"failed to delete branch %s: %s: %w\\\", branchName, strings.TrimSpace(string(output)), err)\\n  1193→\\t}\\n  1194→\\treturn nil\\n  1195→}\\n  1196→\\n  1197→// branchExistsCLI checks if a branch exists using git CLI.\\n  1198→// Returns nil if the branch exists, or an error if it does not.\\n  1199→func branchExistsCLI(branchName string) error {\\n  1200→\\tctx := context.Background()\\n  1201→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"show-ref\\\", \\\"--verify\\\", \\\"--quiet\\\", \\\"refs/heads/\\\"+branchName) //nolint:gosec // branchName comes from internal shadow branch naming\\n  1202→\\tif err := cmd.Run(); err != nil {\\n  1203→\\t\\treturn fmt.Errorf(\\\"branch %s not found: %w\\\", branchName, err)\\n  1204→\\t}\\n  1205→\\treturn nil\\n  1206→}\\n  1207→\\n  1208→// HardResetWithProtection performs a git reset --hard to the specified commit.\\n  1209→// Uses the git CLI instead of go-git because go-git's HardReset incorrectly\\n  1210→// deletes untracked directories (like .entire/) even when they're in .gitignore.\\n  1211→// Returns the short commit ID (7 chars) on success for display purposes.\\n  1212→func HardResetWithProtection(commitHash plumbing.Hash) (shortID string, err error) {\\n  1213→\\tctx := context.Background()\\n  1214→\\thashStr := commitHash.String()\\n  1215→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"reset\\\", \\\"--hard\\\", hashStr) //nolint:gosec // hashStr is a plumbing.Hash, not user input\\n  1216→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1217→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"reset failed: %s: %w\\\", strings.TrimSpace(string(output)), err)\\n  1218→\\t}\\n  1219→\\n  1220→\\t// Return short commit ID for display\\n  1221→\\tshortID = hashStr\\n  1222→\\tif len(shortID) > 7 {\\n  1223→\\t\\tshortID = shortID[:7]\\n  1224→\\t}\\n  1225→\\treturn shortID, nil\\n  1226→}\\n  1227→\\n  1228→// collectUntrackedFiles collects untracked files in the working directory that are\\n  1229→// NOT ignored by .gitignore. This is used to capture the initial state when starting\\n  1230→// a session, ensuring untracked files present at session start are preserved during rewind.\\n  1231→// Uses \\\"git ls-files --others --exclude-standard -z\\\" to respect .gitignore rules,\\n  1232→// avoiding bloated session state from large ignored directories like node_modules/.\\n  1233→// Returns paths relative to the repository root.\\n  1234→func collectUntrackedFiles() ([]string, error) {\\n  1235→\\trepoRoot, err := GetWorktreePath()\\n  1236→\\tif err != nil {\\n  1237→\\t\\trepoRoot = \\\".\\\"\\n  1238→\\t}\\n  1239→\\n  1240→\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"ls-files\\\", \\\"--others\\\", \\\"--exclude-standard\\\", \\\"-z\\\")\\n  1241→\\tcmd.Dir = repoRoot\\n  1242→\\toutput, err := cmd.Output()\\n  1243→\\tif err != nil {\\n  1244→\\t\\tvar exitErr *exec.ExitError\\n  1245→\\t\\tif errors.As(err, &exitErr) {\\n  1246→\\t\\t\\treturn nil, fmt.Errorf(\\\"git ls-files failed: %s: %w\\\", strings.TrimSpace(string(exitErr.Stderr)), err)\\n  1247→\\t\\t}\\n  1248→\\t\\treturn nil, fmt.Errorf(\\\"git ls-files failed: %w\\\", err)\\n  1249→\\t}\\n  1250→\\n  1251→\\traw := string(output)\\n  1252→\\tif raw == \\\"\\\" {\\n  1253→\\t\\treturn nil, nil\\n  1254→\\t}\\n  1255→\\n  1256→\\tvar files []string\\n  1257→\\tfor _, f := range strings.Split(raw, \\\"\\\\x00\\\") {\\n  1258→\\t\\t// Defense-in-depth: filter protected paths even though --exclude-standard should already handle them\\n  1259→\\t\\tif f != \\\"\\\" && !isProtectedPath(f) {\\n  1260→\\t\\t\\tfiles = append(files, f)\\n  1261→\\t\\t}\\n  1262→\\t}\\n  1263→\\treturn files, nil\\n  1264→}\\n  1265→\\n  1266→// ExtractSessionIDFromCommit extracts the session ID from a commit's trailers.\\n  1267→// It checks the Entire-Session trailer first, then falls back to extracting from\\n  1268→// the metadata directory path in the Entire-Metadata trailer.\\n  1269→// Returns empty string if no session ID is found.\\n  1270→func ExtractSessionIDFromCommit(commit *object.Commit) string {\\n  1271→\\t// Try Entire-Session trailer first\\n  1272→\\tif sessionID, found := trailers.ParseSession(commit.Message); found {\\n  1273→\\t\\treturn sessionID\\n  1274→\\t}\\n  1275→\\n  1276→\\t// Try extracting from metadata directory (last path component)\\n  1277→\\tif metadataDir, found := trailers.ParseMetadata(commit.Message); found {\\n  1278→\\t\\treturn filepath.Base(metadataDir)\\n  1279→\\t}\\n  1280→\\n  1281→\\treturn \\\"\\\"\\n  1282→}\\n  1283→\\n  1284→// NOTE: The following git tree helper functions have been moved to checkpoint/ package:\\n  1285→// - FlattenTree -> checkpoint.FlattenTree\\n  1286→// - CreateBlobFromContent -> checkpoint.CreateBlobFromContent\\n  1287→// - BuildTreeFromEntries -> checkpoint.BuildTreeFromEntries\\n  1288→// - sortTreeEntries (internal to checkpoint package)\\n  1289→// - treeNode, insertIntoTree, buildTreeObject (internal to checkpoint package)\\n  1290→//\\n  1291→// See push_common.go and session_test.go for usage examples.\\n  1292→\\n  1293→// createCommit creates a commit object\\n  1294→func createCommit(repo *git.Repository, treeHash, parentHash plumbing.Hash, message, authorName, authorEmail string) (plumbing.Hash, error) { //nolint:unparam // already present in codebase\\n  1295→\\tnow := time.Now()\\n  1296→\\tsig := object.Signature{\\n  1297→\\t\\tName:  authorName,\\n  1298→\\t\\tEmail: authorEmail,\\n  1299→\\t\\tWhen:  now,\\n  1300→\\t}\\n  1301→\\n  1302→\\tcommit := &object.Commit{\\n  1303→\\t\\tTreeHash:  treeHash,\\n  1304→\\t\\tAuthor:    sig,\\n  1305→\\t\\tCommitter: sig,\\n  1306→\\t\\tMessage:   message,\\n  1307→\\t}\\n  1308→\\n  1309→\\t// Add parent if not a new branch\\n  1310→\\tif parentHash != plumbing.ZeroHash {\\n  1311→\\t\\tcommit.ParentHashes = []plumbing.Hash{parentHash}\\n  1312→\\t}\\n  1313→\\n  1314→\\tobj := repo.Storer.NewEncodedObject()\\n  1315→\\tif err := commit.Encode(obj); err != nil {\\n  1316→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n  1317→\\t}\\n  1318→\\n  1319→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n  1320→\\tif err != nil {\\n  1321→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store commit: %w\\\", err)\\n  1322→\\t}\\n  1323→\\n  1324→\\treturn hash, nil\\n  1325→}\\n  1326→\\n  1327→// getSessionDescriptionFromTree reads the first line of prompt.txt or context.md from a git tree.\\n  1328→// This is the tree-based equivalent of getSessionDescription (which reads from filesystem).\\n  1329→//\\n  1330→// If metadataDir is provided, looks for files at metadataDir/prompt.txt or metadataDir/context.md.\\n  1331→// If metadataDir is empty, first tries the root of the tree (for when the tree is already\\n  1332→// the session directory, e.g., auto-commit strategy's sharded metadata), then falls back to\\n  1333→// searching for .entire/metadata/*/prompt.txt or context.md (for full worktree trees).\\n  1334→func getSessionDescriptionFromTree(tree *object.Tree, metadataDir string) string {\\n  1335→\\t// Helper to read first line from a file in tree\\n  1336→\\treadFirstLine := func(path string) string {\\n  1337→\\t\\tfile, err := tree.File(path)\\n  1338→\\t\\tif err != nil {\\n  1339→\\t\\t\\treturn \\\"\\\"\\n  1340→\\t\\t}\\n  1341→\\t\\tcontent, err := file.Contents()\\n  1342→\\t\\tif err != nil {\\n  1343→\\t\\t\\treturn \\\"\\\"\\n  1344→\\t\\t}\\n  1345→\\t\\tlines := strings.SplitN(content, \\\"\\\\n\\\", 2)\\n  1346→\\t\\tif len(lines) > 0 && lines[0] != \\\"\\\" {\\n  1347→\\t\\t\\tdesc := strings.TrimSpace(lines[0])\\n  1348→\\t\\t\\t// Remove markdown header prefix if present\\n  1349→\\t\\t\\treturn strings.TrimPrefix(desc, \\\"# \\\")\\n  1350→\\t\\t}\\n  1351→\\t\\treturn \\\"\\\"\\n  1352→\\t}\\n  1353→\\n  1354→\\t// If metadataDir is provided, look there directly\\n  1355→\\tif metadataDir != \\\"\\\" {\\n  1356→\\t\\tif desc := readFirstLine(metadataDir + \\\"/\\\" + paths.PromptFileName); desc != \\\"\\\" {\\n  1357→\\t\\t\\treturn desc\\n  1358→\\t\\t}\\n  1359→\\t\\tif desc := readFirstLine(metadataDir + \\\"/\\\" + paths.ContextFileName); desc != \\\"\\\" {\\n  1360→\\t\\t\\treturn desc\\n  1361→\\t\\t}\\n  1362→\\t\\treturn NoDescription\\n  1363→\\t}\\n  1364→\\n  1365→\\t// No metadataDir provided - first try looking at the root of the tree\\n  1366→\\t// (used when the tree is already the session directory)\\n  1367→\\tif desc := readFirstLine(paths.PromptFileName); desc != \\\"\\\" {\\n  1368→\\t\\treturn desc\\n  1369→\\t}\\n  1370→\\tif desc := readFirstLine(paths.ContextFileName); desc != \\\"\\\" {\\n  1371→\\t\\treturn desc\\n  1372→\\t}\\n  1373→\\n  1374→\\t// Fall back to searching for .entire/metadata/*/prompt.txt or context.md\\n  1375→\\t// (used when the tree is the full worktree)\\n  1376→\\tvar desc string\\n  1377→\\t//nolint:errcheck // We ignore errors here as we're just searching for a description\\n  1378→\\t_ = tree.Files().ForEach(func(f *object.File) error {\\n  1379→\\t\\tif desc != \\\"\\\" {\\n  1380→\\t\\t\\treturn nil // Already found description\\n  1381→\\t\\t}\\n  1382→\\t\\tname := f.Name\\n  1383→\\t\\tif strings.Contains(name, \\\".entire/metadata/\\\") {\\n  1384→\\t\\t\\tif strings.HasSuffix(name, \\\"/\\\"+paths.PromptFileName) || strings.HasSuffix(name, \\\"/\\\"+paths.ContextFileName) {\\n  1385→\\t\\t\\t\\tcontent, err := f.Contents()\\n  1386→\\t\\t\\t\\tif err != nil {\\n  1387→\\t\\t\\t\\t\\treturn nil //nolint:nilerr // Skip files we can't read, continue searching\\n  1388→\\t\\t\\t\\t}\\n  1389→\\t\\t\\t\\tlines := strings.SplitN(content, \\\"\\\\n\\\", 2)\\n  1390→\\t\\t\\t\\tif len(lines) > 0 && lines[0] != \\\"\\\" {\\n  1391→\\t\\t\\t\\t\\tdesc = strings.TrimSpace(lines[0])\\n  1392→\\t\\t\\t\\t\\tdesc = strings.TrimPrefix(desc, \\\"# \\\")\\n  1393→\\t\\t\\t\\t}\\n  1394→\\t\\t\\t}\\n  1395→\\t\\t}\\n  1396→\\t\\treturn nil\\n  1397→\\t})\\n  1398→\\n  1399→\\tif desc != \\\"\\\" {\\n  1400→\\t\\treturn desc\\n  1401→\\t}\\n  1402→\\treturn NoDescription\\n  1403→}\\n  1404→\\n  1405→// GetGitAuthorFromRepo retrieves the git user.name and user.email,\\n  1406→// checking both the repository-local config and the global ~/.gitconfig.\\n  1407→// Delegates to checkpoint.GetGitAuthorFromRepo — this wrapper exists so\\n  1408→// callers within the strategy package don't need a qualified import.\\n  1409→func GetGitAuthorFromRepo(repo *git.Repository) (name, email string) {\\n  1410→\\treturn checkpoint.GetGitAuthorFromRepo(repo)\\n  1411→}\\n  1412→\\n  1413→// GetCurrentBranchName returns the short name of the current branch if HEAD points to a branch.\\n  1414→// Returns an empty string if in detached HEAD state or if there's an error reading HEAD.\\n  1415→// This is used to capture branch metadata for checkpoints.\\n  1416→func GetCurrentBranchName(repo *git.Repository) string {\\n  1417→\\thead, err := repo.Head()\\n  1418→\\tif err != nil || !head.Name().IsBranch() {\\n  1419→\\t\\treturn \\\"\\\"\\n  1420→\\t}\\n  1421→\\treturn head.Name().Short()\\n  1422→}\\n  1423→\\n  1424→// getMainBranchHash returns the hash of the main branch (main or master).\\n  1425→// Returns ZeroHash if no main branch is found.\\n  1426→func GetMainBranchHash(repo *git.Repository) plumbing.Hash {\\n  1427→\\t// Try common main branch names\\n  1428→\\tfor _, branchName := range []string{branchMain, branchMaster} {\\n  1429→\\t\\t// Try local branch