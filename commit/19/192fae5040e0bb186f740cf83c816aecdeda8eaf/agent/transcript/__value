s the full context.\\n  1650→//\\n  1651→//nolint:unparam // error return required by interface but hooks must return nil\\n  1652→func (s *ManualCommitStrategy) HandleTurnEnd(state *SessionState) error {\\n  1653→\\t// Finalize all checkpoints from this turn with the full transcript.\\n  1654→\\t//\\n  1655→\\t// IMPORTANT: This is best-effort - errors are logged but don't fail the hook.\\n  1656→\\t// Failing here would prevent session cleanup and could leave state inconsistent.\\n  1657→\\t// The provisional transcript from PostCommit is already persisted, so the\\n  1658→\\t// checkpoint isn't lost - it just won't have the complete transcript.\\n  1659→\\terrCount := s.finalizeAllTurnCheckpoints(state)\\n  1660→\\tif errCount > 0 {\\n  1661→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1662→\\t\\tlogging.Warn(logCtx, \\\"HandleTurnEnd completed with errors (best-effort)\\\",\\n  1663→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1664→\\t\\t\\tslog.Int(\\\"error_count\\\", errCount),\\n  1665→\\t\\t)\\n  1666→\\t}\\n  1667→\\treturn nil\\n  1668→}\\n  1669→\\n  1670→// finalizeAllTurnCheckpoints replaces the provisional transcript in each checkpoint\\n  1671→// created during this turn with the full session transcript.\\n  1672→//\\n  1673→// This is called at turn end (stop hook). During the turn, PostCommit wrote whatever\\n  1674→// transcript was available at commit time. Now we have the complete transcript and\\n  1675→// replace it so every checkpoint has the full prompt-to-stop context.\\n  1676→//\\n  1677→// Returns the number of errors encountered (best-effort: continues processing on error).\\n  1678→func (s *ManualCommitStrategy) finalizeAllTurnCheckpoints(state *SessionState) int {\\n  1679→\\tif len(state.TurnCheckpointIDs) == 0 {\\n  1680→\\t\\treturn 0 // No mid-turn commits to finalize\\n  1681→\\t}\\n  1682→\\n  1683→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1684→\\n  1685→\\tlogging.Info(logCtx, \\\"finalizing turn checkpoints with full transcript\\\",\\n  1686→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1687→\\t\\tslog.Int(\\\"checkpoint_count\\\", len(state.TurnCheckpointIDs)),\\n  1688→\\t)\\n  1689→\\n  1690→\\terrCount := 0\\n  1691→\\n  1692→\\t// Read full transcript from live transcript file\\n  1693→\\tif state.TranscriptPath == \\\"\\\" {\\n  1694→\\t\\tlogging.Warn(logCtx, \\\"finalize: no transcript path, skipping\\\",\\n  1695→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1696→\\t\\t)\\n  1697→\\t\\tstate.TurnCheckpointIDs = nil\\n  1698→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1699→\\t}\\n  1700→\\n  1701→\\tfullTranscript, err := os.ReadFile(state.TranscriptPath)\\n  1702→\\tif err != nil || len(fullTranscript) == 0 {\\n  1703→\\t\\tmsg := \\\"finalize: empty transcript, skipping\\\"\\n  1704→\\t\\tif err != nil {\\n  1705→\\t\\t\\tmsg = \\\"finalize: failed to read transcript, skipping\\\"\\n  1706→\\t\\t}\\n  1707→\\t\\tlogging.Warn(logCtx, msg,\\n  1708→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1709→\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1710→\\t\\t\\tslog.Any(\\\"error\\\", err),\\n  1711→\\t\\t)\\n  1712→\\t\\tstate.TurnCheckpointIDs = nil\\n  1713→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1714→\\t}\\n  1715→\\n  1716→\\t// Extract prompts and context from the full transcript\\n  1717→\\tprompts := extractUserPrompts(state.AgentType, string(fullTranscript))\\n  1718→\\tcontextBytes := generateContextFromPrompts(prompts)\\n  1719→\\n  1720→\\t// Redact secrets before writing — matches WriteCommitted behavior.\\n  1721→\\t// The live transcript on disk contains raw content; redaction must happen\\n  1722→\\t// before anything is persisted to the metadata branch.\\n  1723→\\tfullTranscript, err = redact.JSONLBytes(fullTranscript)\\n  1724→\\tif err != nil {\\n  1725→\\t\\tlogging.Warn(logCtx, \\\"finalize: transcript redaction failed, skipping\\\",\\n  1726→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1727→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1728→\\t\\t)\\n  1729→\\t\\tstate.TurnCheckpointIDs = nil\\n  1730→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1731→\\t}\\n  1732→\\tfor i, p := range prompts {\\n  1733→\\t\\tprompts[i] = redact.String(p)\\n  1734→\\t}\\n  1735→\\tcontextBytes = redact.Bytes(contextBytes)\\n  1736→\\n  1737→\\t// Open repository and create checkpoint store\\n  1738→\\trepo, err := OpenRepository()\\n  1739→\\tif err != nil {\\n  1740→\\t\\tlogging.Warn(logCtx, \\\"finalize: failed to open repository\\\",\\n  1741→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1742→\\t\\t)\\n  1743→\\t\\tstate.TurnCheckpointIDs = nil\\n  1744→\\t\\treturn 1 // Count as error - all checkpoints will be skipped\\n  1745→\\t}\\n  1746→\\tstore := checkpoint.NewGitStore(repo)\\n  1747→\\n  1748→\\t// Update each checkpoint with the full transcript\\n  1749→\\tfor _, cpIDStr := range state.TurnCheckpointIDs {\\n  1750→\\t\\tcpID, parseErr := id.NewCheckpointID(cpIDStr)\\n  1751→\\t\\tif parseErr != nil {\\n  1752→\\t\\t\\tlogging.Warn(logCtx, \\\"finalize: invalid checkpoint ID, skipping\\\",\\n  1753→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1754→\\t\\t\\t\\tslog.String(\\\"error\\\", parseErr.Error()),\\n  1755→\\t\\t\\t)\\n  1756→\\t\\t\\terrCount++\\n  1757→\\t\\t\\tcontinue\\n  1758→\\t\\t}\\n  1759→\\n  1760→\\t\\tupdateErr := store.UpdateCommitted(context.Background(), checkpoint.UpdateCommittedOptions{\\n  1761→\\t\\t\\tCheckpointID: cpID,\\n  1762→\\t\\t\\tSessionID:    state.SessionID,\\n  1763→\\t\\t\\tTranscript:   fullTranscript,\\n  1764→\\t\\t\\tPrompts:      prompts,\\n  1765→\\t\\t\\tContext:      contextBytes,\\n  1766→\\t\\t\\tAgent:        state.AgentType,\\n  1767→\\t\\t})\\n  1768→\\t\\tif updateErr != nil {\\n  1769→\\t\\t\\tlogging.Warn(logCtx, \\\"finalize: failed to update checkpoint\\\",\\n  1770→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1771→\\t\\t\\t\\tslog.String(\\\"error\\\", updateErr.Error()),\\n  1772→\\t\\t\\t)\\n  1773→\\t\\t\\terrCount++\\n  1774→\\t\\t\\tcontinue\\n  1775→\\t\\t}\\n  1776→\\n  1777→\\t\\tlogging.Info(logCtx, \\\"finalize: checkpoint updated with full transcript\\\",\\n  1778→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpIDStr),\\n  1779→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1780→\\t\\t)\\n  1781→\\t}\\n  1782→\\n  1783→\\t// Clear turn checkpoint IDs. Do NOT update CheckpointTranscriptStart here — it was\\n  1784→\\t// already set correctly by PostCommit: condenseAndUpdateState sets it to the total\\n  1785→\\t// transcript lines when condensing, and carryForwardToNewShadowBranch resets it to 0\\n  1786→\\t// when carry-forward is active. Overwriting here would break carry-forward by making\\n  1787→\\t// sessionHasNewContent think the transcript is fully consumed (no growth).\\n  1788→\\tstate.TurnCheckpointIDs = nil\\n  1789→\\n  1790→\\treturn errCount\\n  1791→}\\n  1792→\\n  1793→// filesChangedInCommit returns the set of files changed in a commit by diffing against its parent.\\n  1794→func filesChangedInCommit(commit *object.Commit) map[string]struct{} {\\n  1795→\\tresult := make(map[string]struct{})\\n  1796→\\n  1797→\\tcommitTree, err := commit.Tree()\\n  1798→\\tif err != nil {\\n  1799→\\t\\treturn result\\n  1800→\\t}\\n  1801→\\n  1802→\\tvar parentTree *object.Tree\\n  1803→\\tif commit.NumParents() > 0 {\\n  1804→\\t\\tparent, err := commit.Parent(0)\\n  1805→\\t\\tif err != nil {\\n  1806→\\t\\t\\treturn result\\n  1807→\\t\\t}\\n  1808→\\t\\tparentTree, err = parent.Tree()\\n  1809→\\t\\tif err != nil {\\n  1810→\\t\\t\\treturn result\\n  1811→\\t\\t}\\n  1812→\\t}\\n  1813→\\n  1814→\\tif parentTree == nil {\\n  1815→\\t\\t// Initial commit — all files are new\\n  1816→\\t\\tif iterErr := commitTree.Files().ForEach(func(f *object.File) error {\\n  1817→\\t\\t\\tresult[f.Name] = struct{}{}\\n  1818→\\t\\t\\treturn nil\\n  1819→\\t\\t}); iterErr != nil {\\n  1820→\\t\\t\\treturn result\\n  1821→\\t\\t}\\n  1822→\\t\\treturn result\\n  1823→\\t}\\n  1824→\\n  1825→\\tchanges, err := parentTree.Diff(commitTree)\\n  1826→\\tif err != nil {\\n  1827→\\t\\treturn result\\n  1828→\\t}\\n  1829→\\tfor _, change := range changes {\\n  1830→\\t\\tname := change.To.Name\\n  1831→\\t\\tif name == \\\"\\\" {\\n  1832→\\t\\t\\tname = change.From.Name\\n  1833→\\t\\t}\\n  1834→\\t\\tresult[name] = struct{}{}\\n  1835→\\t}\\n  1836→\\treturn result\\n  1837→}\\n  1838→\\n  1839→// subtractFiles returns files that are NOT in the exclude set.\\n  1840→func subtractFiles(files []string, exclude map[string]struct{}) []string {\\n  1841→\\tvar remaining []string\\n  1842→\\tfor _, f := range files {\\n  1843→\\t\\tif _, excluded := exclude[f]; !excluded {\\n  1844→\\t\\t\\tremaining = append(remaining, f)\\n  1845→\\t\\t}\\n  1846→\\t}\\n  1847→\\treturn remaining\\n  1848→}\\n  1849→\\n  1850→// carryForwardToNewShadowBranch creates a new shadow branch at the current HEAD\\n  1851→// containing the remaining uncommitted files and all session metadata.\\n  1852→// This enables the next commit to get its own unique checkpoint.\\n  1853→func (s *ManualCommitStrategy) carryForwardToNewShadowBranch(\\n  1854→\\tlogCtx context.Context,\\n  1855→\\trepo *git.Repository,\\n  1856→\\tstate *SessionState,\\n  1857→\\tremainingFiles []string,\\n  1858→) {\\n  1859→\\tstore := checkpoint.NewGitStore(repo)\\n  1860→\\n  1861→\\t// Don't include metadata directory in carry-forward. The carry-forward branch\\n  1862→\\t// only needs to preserve file content for comparison - not the transcript.\\n  1863→\\t// Including the transcript would cause sessionHasNewContent to always return true\\n  1864→\\t// because CheckpointTranscriptStart is reset to 0 for carry-forward.