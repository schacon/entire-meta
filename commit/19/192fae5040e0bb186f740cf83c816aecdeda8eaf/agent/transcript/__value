88→\\t_, _ = fmt.Fprintln(w, \\\"[entire] PreToolUse[Task] hook invoked\\\")\\n    89→\\t_, _ = fmt.Fprintf(w, \\\"  Session ID: %s\\\\n\\\", input.SessionID)\\n    90→\\t_, _ = fmt.Fprintf(w, \\\"  Tool Use ID: %s\\\\n\\\", input.ToolUseID)\\n    91→\\t_, _ = fmt.Fprintf(w, \\\"  Transcript: %s\\\\n\\\", input.TranscriptPath)\\n    92→}\\n    93→\\n    94→// SubagentCheckpointHookInput represents the JSON input from PostToolUse hooks for\\n    95→// subagent checkpoint creation (TodoWrite, Edit, Write)\\n    96→type SubagentCheckpointHookInput struct {\\n    97→\\tSessionID      string          `json:\\\"session_id\\\"`\\n    98→\\tTranscriptPath string          `json:\\\"transcript_path\\\"`\\n    99→\\tToolName       string          `json:\\\"tool_name\\\"`\\n   100→\\tToolUseID      string          `json:\\\"tool_use_id\\\"`\\n   101→\\tToolInput      json.RawMessage `json:\\\"tool_input\\\"`\\n   102→\\tToolResponse   json.RawMessage `json:\\\"tool_response\\\"`\\n   103→}\\n   104→\\n   105→// parseSubagentCheckpointHookInput parses PostToolUse hook input for subagent checkpoints\\n   106→func parseSubagentCheckpointHookInput(r io.Reader) (*SubagentCheckpointHookInput, error) {\\n   107→\\tdata, err := io.ReadAll(r)\\n   108→\\tif err != nil {\\n   109→\\t\\treturn nil, fmt.Errorf(\\\"failed to read input: %w\\\", err)\\n   110→\\t}\\n   111→\\n   112→\\tif len(data) == 0 {\\n   113→\\t\\treturn nil, errors.New(\\\"empty input\\\")\\n   114→\\t}\\n   115→\\n   116→\\tvar input SubagentCheckpointHookInput\\n   117→\\tif err := json.Unmarshal(data, &input); err != nil {\\n   118→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse JSON: %w\\\", err)\\n   119→\\t}\\n   120→\\n   121→\\treturn &input, nil\\n   122→}\\n   123→\\n   124→// taskToolInput represents the tool_input structure for the Task tool.\\n   125→// Used to extract subagent_type and description for descriptive commit messages.\\n   126→type taskToolInput struct {\\n   127→\\tSubagentType string `json:\\\"subagent_type\\\"`\\n   128→\\tDescription  string `json:\\\"description\\\"`\\n   129→}\\n   130→\\n   131→// ParseSubagentTypeAndDescription extracts subagent_type and description from Task tool_input.\\n   132→// Returns empty strings if parsing fails or fields are not present.\\n   133→func ParseSubagentTypeAndDescription(toolInput json.RawMessage) (agentType, description string) {\\n   134→\\tif len(toolInput) == 0 {\\n   135→\\t\\treturn \\\"\\\", \\\"\\\"\\n   136→\\t}\\n   137→\\n   138→\\tvar input taskToolInput\\n   139→\\tif err := json.Unmarshal(toolInput, &input); err != nil {\\n   140→\\t\\treturn \\\"\\\", \\\"\\\"\\n   141→\\t}\\n   142→\\n   143→\\treturn input.SubagentType, input.Description\\n   144→}\\n   145→\\n   146→// todoWriteToolInput represents the tool_input structure for the TodoWrite tool.\\n   147→// Used to extract the todos array which is then passed to strategy.ExtractInProgressTodo.\\n   148→type todoWriteToolInput struct {\\n   149→\\tTodos json.RawMessage `json:\\\"todos\\\"`\\n   150→}\\n   151→\\n   152→// ExtractTodoContentFromToolInput extracts the content of the in-progress todo item from TodoWrite tool_input.\\n   153→// Falls back to the first pending item if no in-progress item is found.\\n   154→// Returns empty string if no suitable item is found or JSON is invalid.\\n   155→//\\n   156→// This function unwraps the outer tool_input object to extract the todos array,\\n   157→// then delegates to strategy.ExtractInProgressTodo for the actual parsing logic.\\n   158→func ExtractTodoContentFromToolInput(toolInput json.RawMessage) string {\\n   159→\\tif len(toolInput) == 0 {\\n   160→\\t\\treturn \\\"\\\"\\n   161→\\t}\\n   162→\\n   163→\\t// First extract the todos array from tool_input\\n   164→\\tvar input todoWriteToolInput\\n   165→\\tif err := json.Unmarshal(toolInput, &input); err != nil {\\n   166→\\t\\treturn \\\"\\\"\\n   167→\\t}\\n   168→\\n   169→\\t// Delegate to strategy package for the actual extracti