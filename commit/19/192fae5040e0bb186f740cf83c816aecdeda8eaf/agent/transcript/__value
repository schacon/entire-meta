e only the hook types we need to modify\\n   280→\\tvar sessionStart, sessionEnd, stop, userPromptSubmit, preToolUse, postToolUse []ClaudeHookMatcher\\n   281→\\tparseHookType(rawHooks, \\\"SessionStart\\\", &sessionStart)\\n   282→\\tparseHookType(rawHooks, \\\"SessionEnd\\\", &sessionEnd)\\n   283→\\tparseHookType(rawHooks, \\\"Stop\\\", &stop)\\n   284→\\tparseHookType(rawHooks, \\\"UserPromptSubmit\\\", &userPromptSubmit)\\n   285→\\tparseHookType(rawHooks, \\\"PreToolUse\\\", &preToolUse)\\n   286→\\tparseHookType(rawHooks, \\\"PostToolUse\\\", &postToolUse)\\n   287→\\n   288→\\t// Remove Entire hooks from all hook types\\n   289→\\tsessionStart = removeEntireHooks(sessionStart)\\n   290→\\tsessionEnd = removeEntireHooks(sessionEnd)\\n   291→\\tstop = removeEntireHooks(stop)\\n   292→\\tuserPromptSubmit = removeEntireHooks(userPromptSubmit)\\n   293→\\tpreToolUse = removeEntireHooksFromMatchers(preToolUse)\\n   294→\\tpostToolUse = removeEntireHooksFromMatchers(postToolUse)\\n   295→\\n   296→\\t// Marshal modified hook types back to rawHooks\\n   297→\\tmarshalHookType(rawHooks, \\\"SessionStart\\\", sessionStart)\\n   298→\\tmarshalHookType(rawHooks, \\\"SessionEnd\\\", sessionEnd)\\n   299→\\tmarshalHookType(rawHooks, \\\"Stop\\\", stop)\\n   300→\\tmarshalHookType(rawHooks, \\\"UserPromptSubmit\\\", userPromptSubmit)\\n   301→\\tmarshalHookType(rawHooks, \\\"PreToolUse\\\", preToolUse)\\n   302→\\tmarshalHookType(rawHooks, \\\"PostToolUse\\\", postToolUse)\\n   303→\\n   304→\\t// Also remove the metadata deny rule from permissions\\n   305→\\tvar rawPermissions map[string]json.RawMessage\\n   306→\\tif permRaw, ok := rawSettings[\\\"permissions\\\"]; ok {\\n   307→\\t\\tif err := json.Unmarshal(permRaw, &rawPermissions); err != nil {\\n   308→\\t\\t\\t// If parsing fails, just skip permissions cleanup\\n   309→\\t\\t\\trawPermissions = nil\\n   310→\\t\\t}\\n   311→\\t}\\n   312→\\n   313→\\tif rawPermissions != nil {\\n   314→\\t\\tif denyRaw, ok := rawP