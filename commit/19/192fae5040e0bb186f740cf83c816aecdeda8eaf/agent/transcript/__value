turn len(branches)\\n  1204→}\\n  1205→\\n  1206→// checkEntireDirExists checks if the .entire directory exists.\\n  1207→func checkEntireDirExists() bool {\\n  1208→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n  1209→\\tif err != nil {\\n  1210→\\t\\tentireDirAbs = paths.EntireDir\\n  1211→\\t}\\n  1212→\\t_, err = os.Stat(entireDirAbs)\\n  1213→\\treturn err == nil\\n  1214→}\\n  1215→\\n  1216→// removeAgentHooks removes hooks from all agents that support hooks.\\n  1217→func removeAgentHooks(w io.Writer) error {\\n  1218→\\tvar errs []error\\n  1219→\\tfor _, name := range agent.List() {\\n  1220→\\t\\tag, err := agent.Get(name)\\n  1221→\\t\\tif err != nil {\\n  1222→\\t\\t\\tcontinue\\n  1223→\\t\\t}\\n  1224→\\t\\ths, ok := ag.(agent.HookSupport)\\n  1225→\\t\\tif !ok {\\n  1226→\\t\\t\\tcontinue\\n  1227→\\t\\t}\\n  1228→\\t\\twasInstalled := hs.AreHooksInstalled()\\n  1229→\\t\\tif err := hs.UninstallHooks(); err != nil {\\n  1230→\\t\\t\\terrs = append(errs, err)\\n  1231→\\t\\t} else if wasInstalled {\\n  1232→\\t\\t\\tfmt.Fprintf(w, \\\"  Removed %s hooks\\\\n\\\", ag.Type())\\n  1233→\\t\\t}\\n  1234→\\t}\\n  1235→\\treturn errors.Join(errs...)\\n  1236→}\\n  1237→\\n  1238→// removeAllSessionStates removes all session state files and the directory.\\n  1239→func removeAllSessionStates() (int, error) {\\n  1240→\\tstore, err := session.NewStateStore()\\n  1241→\\tif err != nil {\\n  1242→\\t\\treturn 0, fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n  1243→\\t}\\n  1244→\\n  1245→\\t// Count states before removing\\n  1246→\\tstates, err := store.List(context.Background())\\n  1247→\\tif err != nil {\\n  1248→\\t\\treturn 0, fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n  1249→\\t}\\n  1250→\\tcount := len(states)\\n  1251→\\n  1252→\\t// Remove the entire directory\\n  1253→\\tif err := store.RemoveAll(); err != nil {\\n  1254→\\t\\treturn 0, fmt.Errorf(\\\"failed to remove session states: %w\\\", err)\\n  1255→\