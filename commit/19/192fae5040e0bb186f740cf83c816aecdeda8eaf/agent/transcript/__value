63→\\t)\\n  1064→\\n  1065→\\tif err := form.Run(); err != nil {\\n  1066→\\t\\treturn fmt.Errorf(\\\"telemetry prompt: %w\\\", err)\\n  1067→\\t}\\n  1068→\\n  1069→\\tsettings.Telemetry = &consent\\n  1070→\\treturn nil\\n  1071→}\\n  1072→\\n  1073→// runUninstall completely removes Entire from the repository.\\n  1074→func runUninstall(w, errW io.Writer, force bool) error {\\n  1075→\\t// Check if we're in a git repository\\n  1076→\\tif _, err := paths.RepoRoot(); err != nil {\\n  1077→\\t\\tfmt.Fprintln(errW, \\\"Not a git repository. Nothing to uninstall.\\\")\\n  1078→\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n  1079→\\t}\\n  1080→\\n  1081→\\t// Gather counts for display\\n  1082→\\tsessionStateCount := countSessionStates()\\n  1083→\\tshadowBranchCount := countShadowBranches()\\n  1084→\\tgitHooksInstalled := strategy.IsGitHookInstalled()\\n  1085→\\tagentsWithInstalledHooks := GetAgentsWithHooksInstalled()\\n  1086→\\tentireDirExists := checkEntireDirExists()\\n  1087→\\n  1088→\\t// Check if there's anything to uninstall\\n  1089→\\tif !entireDirExists && !gitHooksInstalled && sessionStateCount == 0 &&\\n  1090→\\t\\tshadowBranchCount == 0 && len(agentsWithInstalledHooks) == 0 {\\n  1091→\\t\\tfmt.Fprintln(w, \\\"Entire is not installed in this repository.\\\")\\n  1092→\\t\\treturn nil\\n  1093→\\t}\\n  1094→\\n  1095→\\t// Show confirmation prompt unless --force\\n  1096→\\tif !force {\\n  1097→\\t\\tfmt.Fprintln(w, \\\"\\\\nThis will completely remove Entire from this repository:\\\")\\n  1098→\\t\\tif entireDirExists {\\n  1099→\\t\\t\\tfmt.Fprintln(w, \\\"  - .entire/ directory\\\")\\n  1100→\\t\\t}\\n  1101→\\t\\tif gitHooksInstalled {\\n  1102→\\t\\t\\tfmt.Fprintln(w, \\\"  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\\")\\n  1103→\\t\\t}\\n  1104→\\t\\tif sessionStateCount > 0 {\\n  1105→\\t\\t\\tfmt.Fprintf(w, \\\"  - Session state files (%d)\\\\n\\\", sessionStateCount)\\n  1106→\\t\\t}\\n  1