unc (c *ClaudeCodeAgent) InstallHooks(localDev bool, force bool) (int, error) {\\n    47→\\t// Use repo root instead of CWD to find .claude directory\\n    48→\\t// This ensures hooks are installed correctly when run from a subdirectory\\n    49→\\trepoRoot, err := paths.RepoRoot()\\n    50→\\tif err != nil {\\n    51→\\t\\t// Fallback to CWD if not in a git repo (e.g., during tests)\\n    52→\\t\\trepoRoot, err = os.Getwd() //nolint:forbidigo // Intentional fallback when RepoRoot() fails (tests run outside git repos)\\n    53→\\t\\tif err != nil {\\n    54→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to get current directory: %w\\\", err)\\n    55→\\t\\t}\\n    56→\\t}\\n    57→\\n    58→\\tsettingsPath := filepath.Join(repoRoot, \\\".claude\\\", ClaudeSettingsFileName)\\n    59→\\n    60→\\t// Read existing settings if they exist\\n    61→\\tvar rawSettings map[string]json.RawMessage\\n    62→\\n    63→\\t// rawHooks preserves unknown hook types (e.g., \\\"Notification\\\", \\\"SubagentStop\\\")\\n    64→\\tvar rawHooks map[string]json.RawMessage\\n    65→\\n    66→\\t// rawPermissions preserves unknown permission fields (e.g., \\\"ask\\\")\\n    67→\\tvar rawPermissions map[string]json.RawMessage\\n    68→\\n    69→\\texistingData, readErr := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from cwd + fixed path\\n    70→\\tif readErr == nil {\\n    71→\\t\\tif err := json.Unmarshal(existingData, &rawSettings); err != nil {\\n    72→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse existing settings.json: %w\\\", err)\\n    73→\\t\\t}\\n    74→\\t\\tif hooksRaw, ok := rawSettings[\\\"hooks\\\"]; ok {\\n    75→\\t\\t\\tif err := json.Unmarshal(hooksRaw, &rawHooks); err != nil {\\n    76→\\t\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse hooks in settings.json: %w\\\", err)\\n    77→\\t\\t\\t}\\n    78→\\t\\t}\\n    79→\\t\\tif permRaw, ok := rawSettings[\\\"permissions\\\"]; ok {\\n    80→\\t\\t\\tif err := json.Unmarshal(permRaw, &rawPermissions); err != nil {\\n    81→\\t\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse permissions in settings.json: %w\\\", err)\\n    82→\\t\\t\\t}\\n    83→\\t\\t}\\n    84→\\t} else {\\n    85→\\t\\trawSettings = make(map[string]json.RawMessage)\\n    86→\\t}\\n    87→\\n    88→\\tif rawHooks == nil {\\n    89→\\t\\trawHooks = make(map[string]json.RawMessage)\\n    90→\\t}\\n    91→\\tif rawPermissions == nil {\\n    92→\\t\\trawPermissions = make(map[string]json.RawMessage)\\n    93→\\t}\\n    94→\\n    95→\\t// Parse only the hook types we need to modify\\n    96→\\tvar sessionStart, sessionEnd, stop, userPromptSubmit, preToolUse, postToolUse []ClaudeHookMatcher\\n    97→\\tparseHookType(rawHooks, \\\"SessionStart\\\", &sessionStart)\\n    98→\\tparseHookType(rawHooks, \\\"SessionEnd\\\", &sessionEnd)\\n    99→\\tparseHookType(rawHooks, \\\"Stop\\\", &stop)\\n   100→\\tparseHookType(rawHooks, \\\"UserPromptSubmit\\\", &userPromptSubmit)\\n   101→\\tparseHookType(rawHooks, \\\"PreToolUse\\\", &preToolUse)\\n   102→\\tparseHookType(rawHooks, \\\"PostToolUse\\\", &postToolUse)\\n   103→\\n   104→\\t// If force is true, remove all existing Entire hooks first\\n   105→\\tif force {\\n   106→\\t\\tsessionStart = removeEntireHooks(sessionStart)\\n   107→\\t\\tsessionEnd = removeEntireHooks(sessionEnd)\\n   108→\\t\\tstop = removeEntireHooks(stop)\\n   109→\\t\\tuserPromptSubmit = removeEntireHooks(userPromptSubmit)\\n   110→\\t\\tpreToolUse = removeEntireHooksFromMatchers(preToolUse)\\n   111→\\t\\tpostToolUse = removeEntireHooksFromMatchers(postToolUse)\\n   112→\\t}\\n   113→\\n   114→\\t// Define hook commands\\n   115→\\tvar sessionStartCmd, sessionEndCmd, stopCmd, userPromptSubmitCmd, preTaskCmd, postTaskCmd, postTodoCmd string\\n   116→\\tif localDev {\\n   117→\\t\\tsessionStartCmd = \\\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code session-start\\\"\\n   118→\\t\\tsessionEndCmd = \\\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code session-end\\\"\\n   119→\\t\\tstopCmd = \\\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code stop\\\"\\n   120→\\t\\tuserPromptSubmitCmd = \\\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code user-prompt-submit\\\"\\n   121→\\t\\tpreTaskCmd = \\\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code pre-task\\\"\\n   122→\\t\\tpostTaskCmd = \\\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code post-task\\\"\\n   123→\\t\\tpostTodoCmd = \\\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code post-todo\\\"\\n   124→\\t} else {\\n   125→\\t\\tsessionStartCmd = \\\"entire hooks claude-code session-start\\\"\\n   126→\\t\\tsessionEndCmd = \\\"entire hooks claude-code session-end\\\"\\n   127→\\t\\tstopCmd = \\\"entire hooks claude-code stop\\\"\\n   128→\\t\\tuserPromptSubmitCmd = \\\"entire hooks claude-code user-prompt-submit\\\"\\n   129→\\t\\tpreTaskCmd = \\\"entire hooks claude-code pre-task\\\"\\n   130→\\t\\tpostTaskCmd = \\\"entire hooks claude-code post-task\\\"\\n   131→\\t\\tpostTodoCmd = \\\"entire hooks claude-code post-todo\\\"\\n   132→\\t}\\n   133→\\n   134→\\tcount := 0\\n   135→\\n   136→\\t// Add hooks if they don't exist\\n   137→\\tif !hookCommandExists(sessionStart, sessionStartCmd) {\\n   138→\\t\\tsessionStart = addHookToMatcher(sessionStart, \\\"\\\", sessionStartCmd)\\n   139→\\t\\tcount++\\n   140→\\t}\\n   141→\\tif !hookCommandExists(sessionEnd, sessionEndCmd) {\\n   142→\\t\\tsessionEnd = addHookToMatcher(sessionEnd, \\\"\\\", sessionEndCmd)\\n   143→\\t\\tcount++\\n   144→\\t}\\n   145→\\tif !hookCommandExists(stop, stopCmd) {\\n   146→\\t\\tstop = addHookToMatcher(stop, \\\"\\\", stopCmd)\\n   147→\\t\\tcount++\\n   148→\\t}\\n   149→\\tif !hookCommandExists(userPromptSubmit, userPromptSubmitCmd) {\\n   150→\\t\\tuserPromptSubmit = addHookToMatcher(userPromptSubmit, \\\"\\\", userPromptSubmitCmd)\\n   151→\\t\\tcount++\\n   152→\\t}\\n   153→\\tif !hookCommandExistsWithMatcher(preToolUse, \\\"Task\\\", preTaskCmd) {\\n   154→\\t\\tpreToolUse = addHookToMatcher(preToolUse, \\\"Task\\\", preTaskCmd)\\n   155→\\t\\tcount++\\n   156→\\t}\\n   157→\\tif !hookCommandExistsWithMatcher(postToolUse, \\\"Task\\\", postTaskCmd) {\\n   158→\\t\\tpostToolUse = addHookToMatcher(postToolUse, \\\"Task\\\", postTaskCmd)\\n   159→\\t\\tcount++\\n   160→\\t}\\n   161→\\tif !hookCommandExistsWithMatcher(postToolUse, \\\"TodoWrite\\\", postTodoCmd) {\\n   162→\\t\\tpostToolUse = addHookToMatcher(postToolUse, \\\"TodoWrite\\\", postTodoCmd)\\n   163→\\t\\tcount++\\n   164→\\t}\\n   165→\\n   166→\\t// Add permissions.deny rule if not present\\n   167→\\tpermissionsChanged := false\\n   168→\\tvar denyRules []string\\n   169→\\tif denyRaw, ok := rawPermissions[\\\"deny\\\"]; ok {\\n   170→\\t\\tif err := json.Unmarshal(denyRaw, &denyRules); err != nil {\\n   171→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse permissions.deny in settings.json: %w\\\", err)\\n   172→\\t\\t}\\n   173→\\t}\\n   174→\\tif !slices.Contains(denyRules, metadataDenyRule) {\\n   175→\\t\\tdenyRules = append(denyRules, metadataDenyRule)\\n   176→\\t\\tdenyJSON, err := json.Marshal(denyRules)\\n   177→\\t\\tif err != nil {\\n   178→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal permissions.deny: %w\\\", err)\\n   179→\\t\\t}\\n   180→\\t\\trawPermissions[\\\"deny\\\"] = denyJSON\\n   181→\\t\\tpermissionsChanged = true\\n   182→\\t}\\n   183→\\n   184→\\tif count == 0 && !permissionsChanged {\\n   185→\\t\\treturn 0, nil // All hooks and permissions already installed\\n   186→\\t}\\n   187→\\n   188→\\t// Marshal modified hook types back to rawHooks\\n   189→\\tmarshalHookType(rawHooks, \\\"SessionStart\\\", sessionStart)\\n   190→\\tmarshalHookType(rawHooks, \\\"SessionEnd\\\", sessionEnd)\\n   191→\\tmarshalHookType(rawHooks, \\\"Stop\\\", stop)\\n   192→\\tmarshalHookType(rawHooks, \\\"UserPromptSubmit\\\", userPromptSubmit)\\n   193→\\tmarshalHookType(rawHooks, \\\"PreToolUse\\\", preToolUse)\\n   194→\\tmarshalHookType(rawHooks, \\\"PostToolUse\\\", postToolUse)\\n   195→\\n   196→\\t// Marshal hooks and update raw settings\\n   197→\\thooksJSON, err := json.Marshal(rawHooks)\\n   198→\\tif err != nil {\\n   199→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal hooks: %w\\\", err)\\n   200→\\t}\\n   201→\\trawSettings[\\\"hooks\\\"] = hooksJSON\\n   202→\\n   203→\\t// Marshal permissions and update raw settings\\n   204→\\tpermJSON, err := json.Marshal(rawPermissions)\\n   205→\\tif err != nil {\\n   206→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal permissions: %w\\\", err)\\n   207→\\t}\\n   208→\\trawSettings[\\\"permissions\\\"] = permJSON\\n   209→\\n   210→\\t// Write back to file\\n   211→\\tif err := os.MkdirAll(filepath.Dir(settingsPath), 0o750); err != nil {\\n   212→\\t\\treturn 0, fmt.Errorf(\\\"failed to create .claude directory: %w\\\", err)\\n   213→\\t}\\n   214→\\n   215→\\toutput, err := jsonutil.MarshalIndentWithNewline(rawSettings, \\\"\\\", \\\"  \\\")\\n   216→\\tif err != nil {\\n   217→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal settings: %w\\\", err)\\n   218→\\t}\\n   219→\\n   220→\\tif err := os.WriteFile(settingsPath, output, 0o600); err != nil {\\n   221→\\t\\treturn 0, fmt.Errorf(\\\"failed to write settings.json: %w\\\", err)\\n   222→\\t}\\n   223→\\n   224→\\treturn count, nil\\n   225→}\\n   226→\\n   227→// parseHookType parses a specific hook type from rawHooks into the target slice.\\n   228→// Silently ignores parse errors (leaves target unchanged).\\n   229→func parseHookType(rawHooks map[string]json.RawMessage, hookType string, target *[]ClaudeHookMatcher) {\\n   230→\\tif data, ok := rawHooks[hookType]; ok {\\n   231→\\t\\t//nolint:errcheck,gosec // Intentionally ignoring parse errors - leave target as nil/empty\\n   232→\\t\\tjson.Unmarshal(data, target)\\n   233→\\t}\\n   234→}\\n   235→\\n   236→// marshalHookType marshals a hook type back to rawHooks.\\n   237→// If the sli