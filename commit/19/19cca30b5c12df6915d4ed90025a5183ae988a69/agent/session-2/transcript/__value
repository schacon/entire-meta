   908→\\t}\\n   909→\\treturn StatusUnchanged\\n   910→}\\n   911→\\n   912→// StatusToText returns a human-readable status string.\\n   913→func StatusToText(status SessionRestoreStatus) string {\\n   914→\\tswitch status {\\n   915→\\tcase StatusNew:\\n   916→\\t\\treturn \\\"(new)\\\"\\n   917→\\tcase StatusUnchanged:\\n   918→\\t\\treturn \\\"(unchanged)\\\"\\n   919→\\tcase StatusCheckpointNewer:\\n   920→\\t\\treturn \\\"(checkpoint is newer)\\\"\\n   921→\\tcase StatusLocalNewer:\\n   922→\\t\\treturn \\\"(local is newer)\\\" // shouldn't appear in non-conflict list\\n   923→\\tdefault:\\n   924→\\t\\treturn \\\"\\\"\\n   925→\\t}\\n   926→}\\n   927→\\n   928→// PromptOverwriteNewerLogs asks the user for confirmation to overwrite local\\n   929→// session logs that have newer timestamps than the checkpoint versions.\\n   930→func PromptOverwriteNewerLogs(sessions []SessionRestoreInfo) (bool, error) {\\n   931→\\t// Separate conflicting and non-conflicting sessions\\n   932→\\tvar conflicting, nonConflicting []SessionRestoreInfo\\n   933→\\tfor _, s := range sessions {\\n   934→\\t\\tif s.Status == StatusLocalNewer {\\n   935→\\t\\t\\tconflicting = append(conflicting, s)\\n   936→\\t\\t} else {\\n   937→\\t\\t\\tnonConflicting = append(nonConflicting, s)\\n   938→\\t\\t}\\n   939→\\t}\\n   940→\\n   941→\\tfmt.Fprintf(os.Stderr, \\\"\\\\nWarning: Local session log(s) have newer entries than the checkpoint:\\\\n\\\")\\n   942→\\tfor _, info := range conflicting {\\n   943→\\t\\t// Show prompt if available, otherwise fall back to session ID\\n   944→\\t\\tif info.Prompt != \\\"\\\" {\\n   945→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  \\\\\\\"%s\\\\\\\"\\\\n\\\", info.Prompt)\\n   946→\\t\\t} else {\\n   947→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Session: %s\\\\n\\\", info.SessionID)\\n   948→\\t\\t}\\n   949→\\t\\tfmt.Fprintf(os.Stderr, \\\"    Local last entry:      %s\\\\n\\\", info.LocalTime.Local().Format(\\\"2006-01-02 15:04:05\\\"))\\n   950→\\t\\tfmt.Fprintf