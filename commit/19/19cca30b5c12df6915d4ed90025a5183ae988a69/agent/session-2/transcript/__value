I coding assistant\\\"\\n    49→}\\n    50→\\n    51→// DetectPresence checks if Gemini CLI is configured in the repository.\\n    52→func (g *GeminiCLIAgent) DetectPresence() (bool, error) {\\n    53→\\t// Get repo root to check for .gemini directory\\n    54→\\t// This is needed because the CLI may be run from a subdirectory\\n    55→\\trepoRoot, err := paths.RepoRoot()\\n    56→\\tif err != nil {\\n    57→\\t\\t// Not in a git repo, fall back to CWD-relative check\\n    58→\\t\\trepoRoot = \\\".\\\"\\n    59→\\t}\\n    60→\\n    61→\\t// Check for .gemini directory\\n    62→\\tgeminiDir := filepath.Join(repoRoot, \\\".gemini\\\")\\n    63→\\tif _, err := os.Stat(geminiDir); err == nil {\\n    64→\\t\\treturn true, nil\\n    65→\\t}\\n    66→\\t// Check for .gemini/settings.json\\n    67→\\tsettingsFile := filepath.Join(repoRoot, \\\".gemini\\\", \\\"settings.json\\\")\\n    68→\\tif _, err := os.Stat(settingsFile); err == nil {\\n    69→\\t\\treturn true, nil\\n    70→\\t}\\n    71→\\treturn false, nil\\n    72→}\\n    73→\\n    74→// GetHookConfigPath returns the path to Gemini's hook config file.\\n    75→func (g *GeminiCLIAgent) GetHookConfigPath() string {\\n    76→\\treturn \\\".gemini/settings.json\\\"\\n    77→}\\n    78→\\n    79→// SupportsHooks returns true as Gemini CLI supports lifecycle hooks.\\n    80→func (g *GeminiCLIAgent) SupportsHooks() bool {\\n    81→\\treturn true\\n    82→}\\n    83→\\n    84→// ParseHookInput parses Gemini CLI hook input from stdin.\\n    85→func (g *GeminiCLIAgent) ParseHookInput(hookType agent.HookType, reader io.Reader) (*agent.HookInput, error) {\\n    86→\\tdata, err := io.ReadAll(reader)\\n    87→\\tif err != nil {\\n    88→\\t\\treturn nil, fmt.Errorf(\\\"failed to read input: %w\\\", err)\\n    89→\\t}\\n    90→\\n    91→\\tif len(data) == 0 {\\n    92→\\t\\treturn nil, errors.New(\\\"empty input\\\")\\n    93→\\t}\\n    94→\\n    95→\\tinput := &agent.HookInput{\\n    96→\\t\\tHookType:  hookType,\\n    97→\\t\\tTimestamp: time.Now(),\\n    98→\\t\\tRawData:   make(map[string]interface{}),\\n    99→\\t}\\n   100→\\n   101→\\t// Parse based on hook type\\n   102→\\tswitch hookType {\\n   103→\\tcase agent.HookSessionStart, agent.HookSessionEnd, agent.HookStop:\\n   104→\\t\\tvar raw sessionInfoRaw\\n   105→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   106→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse session info: %w\\\", err)\\n   107→\\t\\t}\\n   108→\\t\\tinput.SessionID = raw.SessionID\\n   109→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   110→\\t\\t// Store Gemini-specific fields in RawData\\n   111→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   112→\\t\\tinput.RawData[\\\"hook_event_name\\\"] = raw.HookEventName\\n   113→\\t\\tif raw.Source != \\\"\\\" {\\n   114→\\t\\t\\tinput.RawData[\\\"source\\\"] = raw.Source\\n   115→\\t\\t}\\n   116→\\t\\tif raw.Reason != \\\"\\\" {\\n   117→\\t\\t\\tinput.RawData[\\\"reason\\\"] = raw.Reason\\n   118→\\t\\t}\\n   119→\\n   120→\\tcase agent.HookUserPromptSubmit:\\n   121→\\t\\t// BeforeAgent is Gemini's equivalent to Claude's UserPromptSubmit\\n   122→\\t\\t// It provides the user's prompt in the \\\"prompt\\\" field\\n   123→\\t\\tvar raw agentHookInputRaw\\n   124→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   125→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse agent hook input: %w\\\", err)\\n   126→\\t\\t}\\n   127→\\t\\tinput.SessionID = raw.SessionID\\n   128→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   129→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   130→\\t\\tinput.RawData[\\\"hook_event_name\\\"] = raw.HookEventName\\n   131→\\t\\tif raw.Prompt != \\\"\\\" {\\n   132→\\t\\t\\tinput.UserPrompt = raw.Prompt\\n   133→\\t\\t\\tinput.RawData[\\\"prompt\\\"] = raw.Prompt\\n   134→\\t\\t}\\n   135→\\n   136→\\tcase agent.HookPreToolUse, agent.HookPostToolUse:\\n   137→\\t\\tvar raw toolHookInputRaw\\n   138→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   139→\\t