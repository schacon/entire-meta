wer                             // Checkpoint has newer entries\\n   826→\\tStatusLocalNewer                                  // Local has newer entries (conflict)\\n   827→)\\n   828→\\n   829→// SessionRestoreInfo contains information about a session being restored.\\n   830→type SessionRestoreInfo struct {\\n   831→\\tSessionID      string\\n   832→\\tPrompt         string               // First prompt preview for display\\n   833→\\tStatus         SessionRestoreStatus // Status of this session\\n   834→\\tLocalTime      time.Time\\n   835→\\tCheckpointTime time.Time\\n   836→}\\n   837→\\n   838→// classifySessionsForRestore checks all sessions in a checkpoint and returns info\\n   839→// about each session, including whether local logs have newer timestamps.\\n   840→// repoRoot is used to compute per-session agent directories.\\n   841→// Sessions without agent metadata are skipped (cannot determine target directory).\\n   842→func (s *ManualCommitStrategy) classifySessionsForRestore(ctx context.Context, repoRoot string, store cpkg.Store, checkpointID id.CheckpointID, summary *cpkg.CheckpointSummary) []SessionRestoreInfo {\\n   843→\\tvar sessions []SessionRestoreInfo\\n   844→\\n   845→\\ttotalSessions := len(summary.Sessions)\\n   846→\\t// Check all sessions (0-based indexing)\\n   847→\\tfor i := range totalSessions {\\n   848→\\t\\tcontent, err := store.ReadSessionContent(ctx, checkpointID, i)\\n   849→\\t\\tif err != nil || content == nil || len(content.Transcript) == 0 {\\n   850→\\t\\t\\tcontinue\\n   851→\\t\\t}\\n   852→\\n   853→\\t\\tsessionID := content.Metadata.SessionID\\n   854→\\t\\tif sessionID == \\\"\\\" || content.Metadata.Agent == \\\"\\\" {\\n   855→\\t\\t\\tcontinue\\n   856→\\t\\t}\\n   857→\\n   858→\\t\\tsessionAgent, agErr := ResolveAgentForRewind(content.Metadata.Agent)\\n   859→\\t\\tif agErr != nil {\\n   860→\\t\\t\\tcontinue\\n   861→\\t\\t}\\n   862→\\n   863→\\t\\t// Compute transcript path from current repo location.\\n   86