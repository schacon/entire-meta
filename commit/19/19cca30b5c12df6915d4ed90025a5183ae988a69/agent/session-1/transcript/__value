\treturn h[:7]\\n   872→\\t}\\n   873→\\treturn h\\n   874→}\\n   875→\\n   876→// filterSessionsWithNewContent returns sessions that have new transcript content\\n   877→// beyond what was already condensed.\\n   878→func (s *ManualCommitStrategy) filterSessionsWithNewContent(repo *git.Repository, sessions []*SessionState) []*SessionState {\\n   879→\\tvar result []*SessionState\\n   880→\\n   881→\\tfor _, state := range sessions {\\n   882→\\t\\thasNew, err := s.sessionHasNewContent(repo, state)\\n   883→\\t\\tif err != nil {\\n   884→\\t\\t\\t// On error, include the session (fail open for hooks)\\n   885→\\t\\t\\tresult = append(result, state)\\n   886→\\t\\t\\tcontinue\\n   887→\\t\\t}\\n   888→\\t\\tif hasNew {\\n   889→\\t\\t\\tresult = append(result, state)\\n   890→\\t\\t}\\n   891→\\t}\\n   892→\\n   893→\\treturn result\\n   894→}\\n   895→\\n   896→// sessionHasNewContent checks if a session has new transcript content\\n   897→// beyond what was already condensed.\\n   898→func (s *ManualCommitStrategy) sessionHasNewContent(repo *git.Repository, state *SessionState) (bool, error) {\\n   899→\\tlogCtx := logging.WithComponent(context.Background(), \\\"manual-commit\\\")\\n   900→\\n   901→\\t// Get shadow branch\\n   902→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   903→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   904→\\tref, err := repo.Reference(refName, true)\\n   905→\\tif err != nil {\\n   906→\\t\\t// No shadow branch means no Stop has happened since the last condensation.\\n   907→\\t\\t// However, the agent may have done work (including commits) without a Stop.\\n   908→\\t\\t// Check the live transcript to detect this scenario.\\n   909→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no shadow branch, checking live transcript\\\",\\n   910→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   911→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   912→\\t\\t)\\n   913→\\t\\treturn s.sessionHasNewContentFromLiveTranscript(repo, state)\\n   914→\\t}\\n   915→\\n   916→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   917→\\tif err != nil {\\n   918→\\t\\treturn false, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   919→\\t}\\n   920→\\n   921→\\ttree, err := commit.Tree()\\n   922→\\tif err != nil {\\n   923→\\t\\treturn false, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   924→\\t}\\n   925→\\n   926→\\t// Look for transcript file\\n   927→\\tmetadataDir := paths.EntireMetadataDir + \\\"/\\\" + state.SessionID\\n   928→\\tvar transcriptLines int\\n   929→\\tvar hasTranscriptFile bool\\n   930→\\n   931→\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   932→\\t\\thasTranscriptFile = true\\n   933→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   934→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n   935→\\t\\t}\\n   936→\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   937→\\t\\thasTranscriptFile = true\\n   938→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   939→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n   940→\\t\\t}\\n   941→\\t}\\n   942→\\n   943→\\t// If shadow branch exists but has no transcript (e.g., carry-forward from mid-session commit),\\n   944→\\t// check if the session has FilesTouched. Carry-forward sets FilesTouched with remaining files.\\n   945→\\tif !hasTranscriptFile {\\n   946→\\t\\tif len(state.FilesTouched) > 0 {\\n   947→\\t\\t\\t// Shadow branch has files from carry-forward - check if staged files overlap\\n   948→\\t\\t\\t// AND have matching content (content-aware check).\\n   949→\\t\\t\\tstagedFiles := getStagedFiles(repo)\\n   950→\\t\\t\\tif len(stagedFiles) > 0 {\\n   951→\\t\\t\\t\\t// PrepareCommitMsg contex