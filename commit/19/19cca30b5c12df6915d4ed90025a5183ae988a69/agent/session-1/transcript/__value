e new work since last checkpoint.\\n  1016→\\t// (Carry-forward creates a shadow branch WITHOUT transcript, handled in the block above.)\\n  1017→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no staged files, returning transcript growth\\\",\\n  1018→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1019→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1020→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1021→\\t)\\n  1022→\\treturn hasTranscriptGrowth, nil\\n  1023→}\\n  1024→\\n  1025→// sessionHasNewContentFromLiveTranscript checks if a session has new content\\n  1026→// by examining the live transcript file. This is used when no shadow branch exists\\n  1027→// (i.e., no Stop has happened yet) but the agent may have done work.\\n  1028→//\\n  1029→// Returns true if:\\n  1030→//  1. The transcript has grown since the last condensation, AND\\n  1031→//  2. The new transcript portion contains file modifications, AND\\n  1032→//  3. At least one modified file overlaps with the currently staged files\\n  1033→//\\n  1034→// The overlap check ensures we don't add checkpoint trailers to commits that are\\n  1035→// unrelated to the agent's recent changes.\\n  1036→//\\n  1037→// This handles the scenario where the agent commits mid-session before Stop.\\n  1038→func (s *ManualCommitStrategy) sessionHasNewContentFromLiveTranscript(repo *git.Repository, state *SessionState) (bool, error) {\\n  1039→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n  1040→\\n  1041→\\tmodifiedFiles, ok := s.extractNewModifiedFilesFromLiveTranscript(state)\\n  1042→\\tif !ok || len(modifiedFiles) == 0 {\\n  1043→\\t\\treturn false, nil\\n  1044→\\t}\\n  1045→\\n  1046→\\tlogging.Debug(logCtx, \\\"live transcript check: found file modifications\\\",\\n  1047→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1048→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1049→\\t)\\n