   117→\\n   118→// InitRepo initializes a git repository in the test environment.\\n   119→func (env *TestEnv) InitRepo() {\\n   120→\\tenv.T.Helper()\\n   121→\\n   122→\\trepo, err := git.PlainInit(env.RepoDir, false)\\n   123→\\tif err != nil {\\n   124→\\t\\tenv.T.Fatalf(\\\"failed to init git repo: %v\\\", err)\\n   125→\\t}\\n   126→\\n   127→\\t// Configure git user for commits\\n   128→\\tcfg, err := repo.Config()\\n   129→\\tif err != nil {\\n   130→\\t\\tenv.T.Fatalf(\\\"failed to get repo config: %v\\\", err)\\n   131→\\t}\\n   132→\\tcfg.User.Name = \\\"E2E Test User\\\"\\n   133→\\tcfg.User.Email = \\\"e2e-test@example.com\\\"\\n   134→\\n   135→\\t// Disable GPG signing for test commits\\n   136→\\tif cfg.Raw == nil {\\n   137→\\t\\tcfg.Raw = config.New()\\n   138→\\t}\\n   139→\\tcfg.Raw.Section(\\\"commit\\\").SetOption(\\\"gpgsign\\\", \\\"false\\\")\\n   140→\\n   141→\\tif err := repo.SetConfig(cfg); err != nil {\\n   142→\\t\\tenv.T.Fatalf(\\\"failed to set repo config: %v\\\", err)\\n   143→\\t}\\n   144→}\\n   145→\\n   146→// WriteFile creates a file with the given content in the test repo.\\n   147→func (env *TestEnv) WriteFile(path, content string) {\\n   148→\\tenv.T.Helper()\\n   149→\\n   150→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   151→\\n   152→\\t// Create parent directories\\n   153→\\tdir := filepath.Dir(fullPath)\\n   154→\\t//nolint:gosec // test code, permissions are intentionally standard\\n   155→\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   156→\\t\\tenv.T.Fatalf(\\\"failed to create directory %s: %v\\\", dir, err)\\n   157→\\t}\\n   158→\\n   159→\\t//nolint:gosec // test code, permissions are intentionally standard\\n   160→\\tif err := os.WriteFile(fullPath, []byte(content), 0o644); err != nil {\\n   161→\\t\\tenv.T.Fatalf(\\\"failed to write file %s: %v\\\", path, err)\\n   162→\\t}\\n   163→}\\n   164→\\n   165→// ReadFile reads a file from the test repo.\\n   166→func (env *TestEnv) ReadFile(path string) string {\\n   167→\\tenv.T.Helper()\\n   168→\\n   169→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   170→\\t//nolint:gosec // test code, path is from test setup\\n   171→\\tdata, err := os.ReadFile(fullPath)\\n   172→\\tif err != nil {\\n   173→\\t\\tenv.T.Fatalf(\\\"failed to read file %s: %v\\\", path, err)\\n   174→\\t}\\n   175→\\treturn string(data)\\n   176→}\\n   177→\\n   178→// TryReadFile reads a file from the test repo, returning empty string if not found.\\n   179→func (env *TestEnv) TryReadFile(path string) string {\\n   180→\\tenv.T.Helper()\\n   181→\\n   182→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   183→\\t//nolint:gosec // test code, path is from test setup\\n   184→\\tdata, err := os.ReadFile(fullPath)\\n   185→\\tif err != nil {\\n   186→\\t\\treturn \\\"\\\"\\n   187→\\t}\\n   188→\\treturn string(data)\\n   189→}\\n   190→\\n   191→// FileExists checks if a file exists in the test repo.\\n   192→func (env *TestEnv) FileExists(path string) bool {\\n   193→\\tenv.T.Helper()\\n   194→\\n   195→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   196→\\t_, err := os.Stat(fullPath)\\n   197→\\treturn err == nil\\n   198→}\\n   199→\\n   200→// GitAdd stages files for commit.\\n   201→func (env *TestEnv) GitAdd(paths ...string) {\\n   202→\\tenv.T.Helper()\\n   203→\\n   204→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   205→\\tif err != nil {\\n   206→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   207→\\t}\\n   208→\\n   209→\\tworktree, err := repo.Worktree()\\n   210→\\tif err != nil {\\n   211→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   212→\\t}\\n   213→\\n   214→\\tfor _, path := range paths {\\n   215→\\t\\tif _, err := worktree.Add(path); err != nil {\\n   216→\\t\\t\\tenv.T.Fatalf(\\\"failed to add file %s: %v\\\", path, err)\\n   217→\\t\\t}\\n   218→\\t}\\n   219→}\\n   220→\\n   221→// GitAddAll stages all files (git add .).\\n   222→func (env *TestEnv) GitAddAll() {\\n   223→\\tenv.T.Helper()\\n   224→\\n   225→\\t//nolint:gosec // test code, \\\".\\\" is safe\\n   226→\\tcmd := exec.Command(\\\"git\\\", \\\"add\\\", \\\".\\\")\\n   227→\\tcmd.Dir = env.RepoDir\\n   228→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   229→\\t\\tenv.T.Fatalf(\\\"git add . failed: %v\\\\nOutput: %s\\\", err, output)\\n   230→\\t}\\n   231→}\\n   232→\\n   233→// GitCommit creates a commit with all staged files.\\n   234→func (env *TestEnv) GitCommit(message string) {\\n   235→\\tenv.T.Helper()\\n   236→\\n   237→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   238→\\tif err != nil {\\n   239→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   240→\\t}\\n   241→\\n   242→\\tworktree, err := repo.Worktree()\\n   243→\\tif err != nil {\\n   244→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   245→\\t}\\n   246→\\n   247→\\t_, err = worktree.Commit(message, &git.CommitOptions{\\n   248→\\t\\tAuthor: &object.Signature{\\n   249→\\t\\t\\tName:  \\\"E2E Test User\\\",\\n   250→\\t\\t\\tEmail: \\\"e2e-test@example.com\\\",\\n   251→\\t\\t\\tWhen:  time.Now(),\\n   252→\\t\\t},\\n   253→\\t})\\n   254→\\tif err != nil {\\n   255→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   256→\\t}\\n   257→}\\n   258→\\n   259→// GitCommitWithShadowHooks stages and commits files, running the prepare-commit-msg\\n   260→// and post-commit hooks like a real workflow.\\n   261→func (env *TestEnv) GitCommitWithShadowHooks(message string, files ...string) {\\n   262→\\tenv.T.Helper()\\n   263→\\n   264→\\t// Stage files using go-git\\n   265→\\tfor _, file := range files {\\n   266→\\t\\tenv.GitAdd(file)\\n   267→\\t}\\n   268→\\n   269→\\t// Create a temp file for the commit message\\n   270→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n   271→\\t//nolint:gosec // test code, permissions are intentionally standard\\n   272→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\