uman is present\\\" for the hasTTY() check\\n\\t// but we can't actually read from the TTY in tests.\\n\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n\\t\\treturn defaultYes\\n\\t}\\n\\n\\t// Gemini CLI sets GEMINI_CLI=1 when running shell commands (including git commit).\\n\\t// The agent can't respond to TTY prompts, so use the default to avoid hanging.\\n\\t// See: https://geminicli.com/docs/tools/shell/\\n\\tif os.Getenv(\\\"GEMINI_CLI\\\") != \\\"\\\" {\\n\\t\\treturn defaultYes\\n\\t}\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":10,\"cache_creation_input_tokens\":119,\"cache_read_input_tokens\":122562,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":119},\"output_tokens\":7,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"}},\"requestId\":\"req_011CYGCT742gUofThKUR91xD\",\"type\":\"assistant\",\"uuid\":\"ed0014b9-c9bc-42c5-b83f-b20e3b3a0019\",\"timestamp\":\"2026-02-18T20:53:25.029Z\"}\n{\"type\":\"file-history-snapshot\",\"messageId\":\"ed0014b9-c9bc-42c5-b83f-b20e3b3a0019\",\"snapshot\":{\"messageId\":\"f0fd1707-ed4b-4a03-b062-7c20de2d962f\",\"trackedFileBackups\":{\"cmd/entire/cli/e2e_test/agent_runner.go\":{\"backupFileName\":\"4baa4e8b725dcdb8@v3\",\"version\":3,\"backupTime\":\"2026-02-18T20:42:24.188Z\"},\"cmd/entire/cli/strategy/manual_commit_hooks.go\":{\"backupFileName\":\"942da33babc3e8b6@v1\",\"version\":1,\"backupTime\":\"2026-02-18T20:53:52.544Z\"}},\"timestamp\":\"2026-02-18T20:53:15.649Z\"},\"isSnapshotUpdate\":true}\n{\"parentUuid\":\"ed0014b9-c9bc-42c5-b83f-b20e3b3a0019\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli\",\"sessionId\":\"4a9dde92-9a32-4a2f-ae0b-c9f6e026cd16\",\"version\":\"2.1.17\",\"gitBranch\":\"main\",\"slug\":\"bright-drifting-jellyfish\",\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01XnisDAn7AdgFCCsXC1CagG\",\"type