 317→\\n   318→\\t// Run post-commit hook\\n   319→\\t//nolint:gosec,noctx // test code, args are from trusted test setup, no context needed\\n   320→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n   321→\\tpostCmd.Dir = env.RepoDir\\n   322→\\tpostCmd.Env = append(os.Environ(),\\n   323→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".claude\\\"),\\n   324→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".gemini\\\"),\\n   325→\\t)\\n   326→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n   327→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n   328→\\t}\\n   329→}\\n   330→\\n   331→// GitRm stages file deletions using git rm.\\n   332→func (env *TestEnv) GitRm(paths ...string) {\\n   333→\\tenv.T.Helper()\\n   334→\\n   335→\\targs := append([]string{\\\"rm\\\", \\\"--\\\"}, paths...)\\n   336→\\t//nolint:gosec // test code, args are from trusted test setup\\n   337→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   338→\\tcmd.Dir = env.RepoDir\\n   339→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   340→\\t\\tenv.T.Fatalf(\\\"git rm failed: %v\\\\nOutput: %s\\\", err, output)\\n   341→\\t}\\n   342→}\\n   343→\\n   344→// GitCommitStagedWithShadowHooks commits whatever is already staged (without adding files first),\\n   345→// running the prepare-commit-msg and post-commit hooks like a real workflow.\\n   346→// Use this after GitRm or when files are already staged.\\n   347→func (env *TestEnv) GitCommitStagedWithShadowHooks(message string) {\\n   348→\\tenv.T.Helper()\\n   349→\\n   350→\\t// Create a temp file for the commit message\\n   351→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n   352→\\t//nolint:gosec // test code, permissions are intentionally standard\\n   353→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n   354→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n   355→\\t}\\n   356→\\n   357→\\t// Run prepare-commit-msg hook\\n   358→\\t//nolint:gosec,noctx // test code, args are from trusted test setup, no context needed\\n   359→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile, \\\"message\\\")\\n   360→\\tprepCmd.Dir = env.RepoDir\\n   361→\\tprepCmd.Env = append(os.Environ(),\\n   362→\\t\\t\\\"ENTIRE_TEST_TTY=1\\\",\\n   363→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".claude\\\"),\\n   364→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".gemini\\\"),\\n   365→\\t)\\n   366→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n   367→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n   368→\\t}\\n   369→\\n   370→\\t// Read the modified message\\n   371→\\t//nolint:gosec // test code, path is from test setup\\n   372→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n   373→\\tif err != nil {\\n   374→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n   375→\\t}\\n   376→\\n   377→\\t// Create the commit using go-git with the modified message\\n   378→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   379→\\tif err != nil {\\n   380→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   381→\\t}\\n   382→\\n   383→\\tworktree, err := repo.Worktree()\\n   384→\\tif err != nil {\\n   385→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   386→\\t}\\n   387→\\n   388→\\t_, err = worktree.Commit(string(modifiedMsg), &git.CommitOptions{\\n   389→\\t\\tAuthor: &object.Signature{\\n   390→\\t\\t\\tName:  \\\"E2E Test User\\\",\\n   391→\\t\\t\\tEmail: \\\"e2e-test@example.com\\\",\\n   392→\\t\\t\\tWhen:  time.Now(),\\n   393→\\t\\t},\\n   394→\\t})\\n   395→\\tif err != nil {\\n   396→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   397→\\t}\\n   398→\\n   399→\\t// Run post-commit hook\\n   400→\\t//nolint:gosec,noctx // test code, args are from trusted test setup, no context needed\\n   401→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n   402→\\tpostCmd.Dir = env.RepoDir\\n   403→\\tpostCmd.Env = append(os.Environ(),\\n   404→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".claude\\\"),\\n   405→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".gemini\\\"),\\n   406→\\t)\\n   407→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n   408→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n   409→\\t}\\n   410→}\\n   411→\\n   412→// GitCommitWithTrailerRemoved stages and commits files, simulating what happens when\\n   413→// a user removes the Entire-Checkpoint trailer during commit message editing.\\n   414→// This tests the opt-out behavior where removing the trailer skips condensation.\\n   415→func (env *TestEnv) GitCommitWithTrailerRemoved(message string, files ...string) {\\n   416→\\tenv.T.Helper()\\n   417→\\n   418→\\t// Stage files using go-git\\n   419→\\tfor _, file := range files {\\n   420→\\t\\tenv.GitAdd(file)\\n   421→\\t}\\n   422→\\n   423→\\t// Create a temp file for the commit message\\n   424→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n   425→\\t//nolint:gosec // test code, permissions are intentionally standard\\n   426→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n   427→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n   428→\\t}\\n   429→\\n   430→\\t// Run prepare-commit-msg hook\\n   431→\\t//nolint:gosec,noctx // test code, args are from trusted test setup, no context needed\\n   432→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile)\\n   433→\\tprepCmd.Dir = env.RepoDir\\n   434→\\tprepCmd.Env = append(os.Environ(),\\n   435→\\t\\t\\\"ENTIRE_TEST_TTY=1\\\",\\n   436→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".claude\\\"),\\n   437→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".gemini\\\"),\\n   438→\\t)\\n   439→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n   440→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n   441→\\t}\\n   442→\\n   443→\\t// Read the modified message (with trailer added by hook)\\n   444→\\t//nolint:gosec // test code, path is from test setup\\n   445→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n   446→\\tif err != nil {\\n   447→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n   448→\\t}\\n   449→\\n   450→\\t// REMOVE the Entire-Checkpoint trailer (simulating user editing the message)\\n   451→\\tlines := strings.Split(string(modifiedMsg), \\\"\\\\n\\\")\\n   452→\\tvar cleanedLines []string\\n   453→\\tfor _, line := range lines {\\n   454→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   455→\\t\\t\\tcontinue\\n   456→\\t\\t}\\n   457→\\t\\tif strings.Contains(line, \\\"Remove the Entire-Checkpoint trailer\\\") {\\n   458→\\t\\t\\tcontinue\\n   459→\\t\\t}\\n   460→\\t\\tif strings.Contains(line, \\\"trailer will be added to your next commit\\\") {\\n   461→\\t\\t\\tcontinue\\n   462→\\t\\t}\\n   463→\\t\\tcleanedLines = append(cleanedLines, line)\\n   464→\\t}\\n   465→\\tcleanedMsg := strings.TrimRight(strings.Join(cleanedLines, \\\"\\\\n\\\"), \\\"\\\\n\\\") + \\\"\\\\n\\\"\\n   466→\\n   467→\\t// Create the commit using go-git with the cleaned message (no trailer)\\n   468→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   469→\\tif err != nil {\\n   470→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   471→\\t}\\n   472→\\n   473→\\tworktree, err := repo.Worktree()\\n   474→\\tif err != nil {\\n   475→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   476→\\t}\\n   477→\\n   478→\\t_, err = worktree.Commit(cleanedMsg, &git.CommitOptions{\\n   479→\\t\\tAuthor: &object.Signature{\\n   480→\\t\\t\\tName:  \\\"E2E Test User\\\",\\n   481→\\t\\t\\tEmail: \\\"e2e-test@example.com\\\",\\n   482→\\t\\t\\tWhen:  time.Now(),\\n   483→\\t\\t},\\n   484→\\t})\\n   485→\\tif err != nil {\\n   486→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   487→\\t}\\n   488→\\n   489→\\t// Run post-commit hook - since trailer was removed, no condensation should happen\\n   490→\\t//nolint:gosec,noctx // test code, args are from trusted test setup, no context needed\\n   491→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n   492→\\tpostCmd.Dir = env.RepoDir\\n   493→\\tpostCmd.Env = append(os.Environ(),\\n   494→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".claude\\\"),\\n   495→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+filepath.Join(env.RepoDir, \\\".gemini\\\"),\\n   496→\\t)\\n   497→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n   498→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n   499→\\t}\\n   500→}\\n   501→\\n   502→// GitCheckoutNewBranch creates and checks out a new branch.\\n   503→func (env *TestEnv) GitCheckoutNewBranch(branchName string) {\\n   504→\\tenv.T.Helper()\\n   505→\\n   506→\\t//nolint:noctx // test code, no context needed for git checkout\\n   507→\\tcmd := exec.Command(\\\"git\\\", \\\"checkout\\\", \\\"-b\\\", branchName)\\n   508→\\tcmd.Dir = env.RepoDir\\n   509→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   510→\\t\\tenv.T.Fatalf(\\\"failed to checkout new branch %s: %v\\\\nOutput: %s\\\", branchName, err, output)\\n   511→\\t}\\n   512→}\\n   513→\\n   514→// GetHeadHash returns the current HEAD commit hash.\\n   515→func (env *TestEnv) GetHeadHash() string {\\n   516→\\tenv.T.Helper()\\n   517→\\n   518→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   519→\\tif err != nil {\\n   520→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   521→\\t}\\n   522→\\n   523→\\thead, err := repo.Head()\\n   524→\\tif err != nil {\\n   525→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   526→\\t}\\n   527→\\n   528→\\treturn head.Hash().String()\\n   529→}\\n   530→\\n   531→// RewindPoint mirrors the rewind --list JSON output.\\n   532→type RewindPoint struct {\\n   533→\\tID               string    `json:\\\"id\\\"`\\n   534→\\tMessage          string    `json:\\\"message\\\"`\\n   535→\\tMetadataDir      string    `json:\\\"metadata_dir\\\"`\\n   536→\\tDate             time.Time `json:\\\"date\\\"`\\n   537→\\tIsTaskCheckpoint bool      `json:\\\"is_task_checkpoint\\\"`\\n   538→\\tToolUseID        string    `json:\\\"tool_use_id\\\"`\\n   539→\\tIsLogsOnly       bool      `json:\\\"is_logs_only\\\"`\\n   540→\\tCondensationID   string    `json:\\\"condensation_id\\\"`\\n   541→}\\n   542→\\n   543→// GetRewindPoints returns available rewind points using the CLI.\\n   544→func (env *TestEnv) GetRewindPoints() []RewindPoint {\\n   545→\\tenv.T.Helper()\\n   546→\\n   547→\\t//nolint:gosec,noctx // test code, args are static, no context needed\\n   548→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--list\\\")\\n   549→\\tcmd.Dir = env.RepoDir\\n   550→\\n   551→\\toutput, err := cmd.CombinedOutput()\\n   552→\\tif err != nil {\\n   553→\\t\\tenv.T.Fatalf(\\\"rewind --list failed: %v\\\\nOutput: %s\\\", err, output)\\n   554→\\t}\\n   555→\\n   556→\\t// Parse JSON output\\n   557→\\tvar jsonPoints []struct {\\n   558→\\t\\tID               string `json:\\\"id\\\"`\\n   559→\\t\\tMessage          string `json:\\\"message\\\"`\\n   560→\\t\\tMetadataDir      string `json:\\\"metadata_dir\\\"`\\n   561→\\t\\tDate             string `json:\\\"date\\\"`\\n   562→\\t\\tIsTaskCheckpoint bool   `json:\\\"is_task_checkpoint\\\"`\\n   563→\\t\\tToolUseID        string `json:\\\"tool_use_id\\\"`\\n   564→\\t\\tIsLogsOnly       bool   `json:\\\"is_logs_only\\\"`\\n   565→\\t\\tCondensationID   string `json:\\\"condensation_id\\\"`\\n   566→\\t}\\n   567→\\n   568→\\tif err := json.Unmarshal(output, &jsonPoints); err != nil {\\n   569→\\t\\tenv.T.Fatalf(\\\"failed to parse rewind points: %v\\\\nOutput: %s\\\", err, output)\\n   570→\\t}\\n   571→\\n   572→\\tpoints := make([]RewindPoint, len(jsonPoints))\\n   573→\\tfor i, jp := range jsonPoints {\\n   574→\\t\\t//nolint:errcheck // date parsing failure is acceptable, defaults to zero time\\n   575→\\t\\tdate, _ := time.Parse(time.RFC3339, jp.Date)\\n   576→\\t\\tpoints[i] = RewindPoint{\\n   577→\\t\\t\\tID:               jp.ID,\\n   578→\\t\\t\\tMessage:          jp.Message,\\n   579→\\t\\t\\tMetadataDir:      jp.MetadataDir,\\n   580→\\t\\t\\tDate:             date,\\n   581→\\t\\t\\tIsTaskCheckpoint: jp.IsTaskCheckpoint,\\n   582→\\t\\t\\tToolUseID:        jp.ToolUseID,\\n   583→\\t\\t\\tIsLogsOnly:       jp.IsLogsOnly,\\n   584→\\t\\t\\tCondensationID:   jp.CondensationID,\\n   585→\\t\\t}\\n   586→\\t}\\n   587→\\n   588→\\treturn points\\n   589→}\\n   590→\\n   591→// Rewind performs a rewind to the specified commit ID using the CLI.\\n   592→func (env *TestEnv) Rewind(commitID string) error {\\n   593→\\tenv.T.Helper()\\n   594→\\n   595→\\t//nolint:gosec,noctx // test code, commitID is from test setup, no context needed\\n   596→\\tcmd := exec.Command(getTestBinary(), \\\"rewind\\\", \\\"--to\\\", commitID)\\n   597→\\tcmd.Dir = env.RepoDir\\n   598→\\n   599→\\toutput, err := cmd.CombinedOutput()\\n   600→\\tif err != nil {\\n   601→\\t\\treturn errors.New(\\\"rewind failed: \\\" + string(output))\\n   602→\\t}\\n   603→\\n   604→\\tenv.T.Logf(\\\"Rewind output: %s\\\", output)\\n   605→\\treturn nil\\n   606→}\\n   607→\\n   608→// BranchExists checks if a branch exists in the repository.\\n   609→func (env *TestEnv) BranchExists(branchName string) bool {\\n   610→\\tenv.T.Helper()\\n   611→\\n   612→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   613→\\tif err != nil {\\n   614→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   615→\\t}\\n   616→\\n   617→\\trefs, err := repo.References()\\n   618→\\tif err != nil {\\n   619→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   620→\\t}\\n   621→\\n   622→\\tfound := false\\n   623→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   624→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   625→\\t\\tif ref.Name().Short() == branchName {\\n   626→\\t\\t\\tfound = true\\n   627→\\t\\t}\\n   628→\\t\\treturn nil\\n   629→\\t})\\n   630→\\n   631→\\treturn found\\n   632→}\\n   633→\\n   634→// ListBranchesWithPrefix returns all branches that start with the given prefix.\\n   635→func (env *TestEnv) ListBranchesWithPrefix(prefix string) []string {\\n   636→\\tenv.T.Helper()\\n   637→\\n   638→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   639→\\tif err != nil {\\n   640→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   641→\\t}\\n   642→\\n   643→\\trefs, err := repo.References()\\n   644→\\tif err != nil {\\n   645→\\t\\tenv.T.Fatalf(\\\"failed to get references: %v\\\", err)\\n   646→\\t}\\n   647→\\n   648→\\tvar branches []string\\n   649→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   650→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   651→\\t\\tname := ref.Name().Short()\\n   652→\\t\\tif strings.HasPrefix(name, prefix) {\\n   653→\\t\\t\\tbranches = append(branches, name)\\n   654→\\t\\t}\\n   655→\\t\\treturn nil\\n   656→\\t})\\n   657→\\n   658→\\treturn branches\\n   659→}\\n   660→\\n   661→// GetCommitMessage returns the commit message for the given commit hash.\\n   662→func (env *TestEnv) GetCommitMessage(hash string) string {\\n   663→\\tenv.T.Helper()\\n   664→\\n   665→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   666→\\tif err != nil {\\n   667→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   668→\\t}\\n   669→\\n   670→\\tcommitHash := plumbing.NewHash(hash)\\n   671→\\tcommit, err := repo.CommitObject(commitHash)\\n   672→\\tif err != nil {\\n   673→\\t\\tenv.T.Fatalf(\\\"failed to get commit %s: %v\\\", hash, err)\\n   674→\\t}\\n   675→\\n   676→\\treturn commit.Message\\n   677→}\\n   678→\\n   679→// GetLatestCheckpointIDFromHistory walks backwards from HEAD and returns\\n   680→// the checkpoint ID from the first commit with an Entire-Checkpoint trailer.\\n   681→// Returns an error if no checkpoint trailer is found in any commit.\\n   682→func (env *TestEnv) GetLatestCheckpointIDFromHistory() (string, error) {\\n   683→\\tenv.T.Helper()\\n   684→\\n   685→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   686→\\tif err != nil {\\n   687→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   688→\\t}\\n   689→\\n   690→\\thead, err := repo.Head()\\n   691→\\tif err != nil {\\n   692→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   693→\\t}\\n   694→\\n   695→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   696→\\tif err != nil {\\n   697→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   698→\\t}\\n   699→\\n   700→\\tvar checkpointID string\\n   701→\\t//nolint:errcheck,gosec // ForEach callback returns error to stop iteration, not a real error\\n   702→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   703→\\t\\t// Look for Entire-Checkpoint trailer\\n   704→\\t\\tfor _, line := range strings.Split(c.Message, \\\"\\\\n\\\") {\\n   705→\\t\\t\\tline = strings.TrimSpace(line)\\n   706→\\t\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   707→\\t\\t\\t\\tcheckpointID = strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   708→\\t\\t\\t\\treturn errors.New(\\\"stop iteration\\\")\\n   709→\\t\\t\\t}\\n   710→\\t\\t}\\n   711→\\t\\treturn nil\\n   712→\\t})\\n   713→\\n   714→\\tif checkpointID == \\\"\\\" {\\n   715→\\t\\treturn \\\"\\\", errors.New(\\\"no commit with Entire-Checkpoint trailer found in history\\\")\\n   716→\\t}\\n   717→\\n   718→\\treturn checkpointID, nil\\n   719→}\\n   720→\\n   721→// GetLatestCheckpointID returns the checkpoint ID from HEAD commit, or empty string if none.\\n   722→// This is a convenience wrapper that doesn't fail the test on missing checkpoint.\\n   723→func (env *TestEnv) GetLatestCheckpointID() string {\\n   724→\\tenv.T.Helper()\\n   725→\\n   726→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   727→\\tif err != nil {\\n   728→\\t\\treturn \\\"\\\"\\n   729→\\t}\\n   730→\\n   731→\\thead, err := repo.Head()\\n   732→\\tif err != nil {\\n   733→\\t\\treturn \\\"\\\"\\n   734→\\t}\\n   735→\\n   736→\\tcommit, err := repo.CommitObject(head.Hash())\\n   737→\\tif err != nil {\\n   738→\\t\\treturn \\\"\\\"\\n   739→\\t}\\n   740→\\n   741→\\t// Look for Entire-Checkpoint trailer in HEAD commit only\\n   742→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n   743→\\t\\tline = strings.TrimSpace(line)\\n   744→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   745→\\t\\t\\treturn strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   746→\\t\\t}\\n   747→\\t}\\n   748→\\treturn \\\"\\\"\\n   749→}\\n   750→\\n   751→// safeIDPrefix returns first 12 chars of ID or the full ID if shorter.\\n   752→// Use this when logging checkpoint IDs to avoid index out of bounds panic.\\n   753→func safeIDPrefix(id string) string {\\n   754→\\tif len(id) >= 12 {\\n   755→\\t\\treturn id[:12]\\n   756→\\t}\\n   757→\\treturn id\\n   758→}\\n   759→\\n   760→// RunCLI runs the entire CLI with the given arguments and returns stdout.\\n   761→func (env *TestEnv) RunCLI(args ...string) string {\\n   762→\\tenv.T.Helper()\\n   763→\\toutput, err := env.RunCLIWithError(args...)\\n   764→\\tif err != nil {\\n   765→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   766→\\t}\\n   767→\\treturn output\\n   768→}\\n   769→\\n   770→// RunCLIWithError runs the entire CLI and returns output and error.\\n   771→func (env *TestEnv) RunCLIWithError(args ...string) (string, error) {\\n   772→\\tenv.T.Helper()\\n   773→\\n   774→\\t//nolint:gosec,noctx // test code, args are from test setup, no context needed\\n   775→\\tcmd := exec.Command(getTestBinary(), args...)\\n   776→\\tcmd.Dir = env.RepoDir\\n   777→\\n   778→\\toutput, err := cmd.CombinedOutput()\\n   779→\\treturn string(output), err\\n   780→}\\n   781→\\n   782→// RunAgent runs the agent with the given prompt and returns the result.\\n   783→func (env *TestEnv) RunAgent(prompt string) (*AgentResult, error) {\\n   784→\\tenv.T.Helper()\\n   785→\\tresult, err := env.Agent.RunPrompt(context.Background(), env.RepoDir, prompt)\\n   786→\\tif err != nil && result != nil {\\n   787→\\t\\tenv.T.Logf(\\\"Agent failed with exit code %d\\\", result.ExitCode)\\n   788→\\t\\tif result.Stderr != \\\"\\\" {\\n   789→\\t\\t\\tenv.T.Logf(\\\"Agent stderr: %s\\\", result.Stderr)\\n   790→\\t\\t}\\n   791→\\t\\tif result.Stdout != \\\"\\\" {\\n   792→\\t\\t\\tenv.T.Logf(\\\"Agent stdout: %s\\\", result.Stdout)\\n   793→\\t\\t}\\n   794→\\t}\\n   795→\\t//nolint:wrapcheck // test helper, caller handles error\\n   796→\\treturn result, err\\n   797→}\\n   798→\\n   799→// RunAgentWithTools runs the agent with specific tools enabled.\\n   800→func (env *TestEnv) RunAgentWithTools(prompt string, tools []string) (*AgentResult, error) {\\n   801→\\tenv.T.Helper()\\n   802→\\tresult, err := env.Agent.RunPromptWithTools(context.Background(), env.RepoDir, prompt, tools)\\n   803→\\tif err != nil && result != nil {\\n   804→\\t\\tenv.T.Logf(\\\"Agent failed with exit code %d\\\", result.ExitCode)\\n   805→\\t\\tif result.Stderr != \\\"\\\" {\\n   806→\\t\\t\\tenv.T.Logf(\\\"Agent stderr: %s\\\", result.Stderr)\\n   807→\\t\\t}\\n   808→\\t\\tif result.Stdout != \\\"\\\" {\\n   809→\\t\\t\\tenv.T.Logf(\\\"Agent stdout: %s\\\", result.Stdout)\\n   810→\\t\\t}\\n   811→\\t}\\n   812→\\t//nolint:wrapcheck // test helper, caller handles error\\n   813→\\treturn result, err\\n   814→}\\n   815→\\n   816→// GitStash runs git stash to save uncommitted changes.\\n   817→// Uses -u flag to include untracked files (new files created by agent).\\n   818→func (env *TestEnv) GitStash() {\\n   819→\\tenv.T.Helper()\\n   820→\\n   821→\\t//nolint:noctx // test code, no context needed for git stash\\n   822→\\tcmd := exec.Command(\\\"git\\\", \\\"stash\\\", \\\"-u\\\")\\n   823→\\tcmd.Dir = env.RepoDir\\n   824→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   825→\\t\\tenv.T.Fatalf(\\\"git stash failed: %v\\\\nOutput: %s\\\", err, output)\\n   826→\\t}\\n   827→}\\n   828→\\n   829→// GitStashPop runs git stash pop to restore stashed changes.\\n   830→func (env *TestEnv) GitStashPop() {\\n   831→\\tenv.T.Helper()\\n   832→\\n   833→\\t//nolint:noctx // test code, no context needed for git stash pop\\n   834→\\tcmd := exec.Command(\\\"git\\\", \\\"stash\\\", \\\"pop\\\")\\n   835→\\tcmd.Dir = env.RepoDir\\n   836→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   837→\\t\\tenv.T.Fatalf(\\\"git stash pop failed: %v\\\\nOutput: %s\\\", err, output)\\n   838→\\t}\\n   839→}\\n   840→\\n   841→// GitCheckoutFile reverts a file to its committed state.\\n   842→func (env *TestEnv) GitCheckoutFile(path string) {\\n   843→\\tenv.T.Helper()\\n   844→\\n   845→\\t//nolint:gosec,noctx // test code, path is from test setup, no context needed\\n   846→\\tcmd := exec.Command(\\\"git\\\", \\\"checkout\\\", \\\"--\\\", path)\\n   847→\\tcmd.Dir = env.RepoDir\\n   848→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   849→\\t\\tenv.T.Fatalf(\\\"git checkout -- %s failed: %v\\\\nOutput: %s\\\", path, err, output)\\n   850→\\t}\\n   851→}\\n   852→\\n   853→// DeleteFile removes a file from the test repo.\\n   854→func (env *TestEnv) DeleteFile(path string) {\\n   855→\\tenv.T.Helper()\\n   856→\\n   857→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   858→\\tif err := os.Remove(fullPath); err != nil {\\n   859→\\t\\tenv.T.Fatalf(\\\"failed to delete file %s: %v\\\", path, err)\\n   860→\\t}\\n   861→}\\n   862→\\n   863→// GetCommitCount returns the number of commits on the current branch.\\n   864→func (env *TestEnv) GetCommitCount() int {\\n   865→\\tenv.T.Helper()\\n   866→\\n   867→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   868→\\tif err != nil {\\n   869→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   870→\\t}\\n   871→\\n   872→\\thead, err := repo.Head()\\n   873→\\tif err != nil {\\n   874→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   875→\\t}\\n   876→\\n   877→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   878→\\tif err != nil {\\n   879→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   880→\\t}\\n   881→\\n   882→\\tcount := 0\\n   883→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   884→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   885→\\t\\tcount++\\n   886→\\t\\treturn nil\\n   887→\\t})\\n   888→\\n   889→\\treturn count\\n   890→}\\n   891→\\n   892→// GetAllCheckpointIDsFromHistory walks backwards from HEAD and returns\\n   893→// all checkpoint IDs from commits with Entire-Checkpoint trailers.\\n   894→func (env *TestEnv) GetAllCheckpointIDsFromHistory() []string {\\n   895→\\tenv.T.Helper()\\n   896→\\n   897→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   898→\\tif err != nil {\\n   899→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   900→\\t}\\n   901→\\n   902→\\thead, err := repo.Head()\\n   903→\\tif err != nil {\\n   904→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   905→\\t}\\n   906→\\n   907→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   908→\\tif err != nil {\\n   909→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   910→\\t}\\n   911→\\n   912→\\tvar checkpointIDs []string\\n   913→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   914→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   915→\\t\\tfor _, line := range strings.Split(c.Message, \\\"\\\\n\\\") {\\n   916→\\t\\t\\tline = strings.TrimSpace(line)\\n   917→\\t\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   918→\\t\\t\\t\\tid := strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   919→\\t\\t\\t\\tcheckpointIDs = append(checkpointIDs, id)\\n   920→\\t\\t\\t}\\n   921→\\t\\t}\\n   922→\\t\\treturn nil\\n   923→\\t})\\n   924→\\n   925→\\treturn checkpointIDs\\n   926→}\\n   927→\\n   928→// ReadFileFromBranch reads a file's content from a specific branch's tree.\\n   929→// Returns the content and true if found, empty string and false if not found.\\n   930→func (env *TestEnv) ReadFileFromBranch(branchName, filePath string) (string, bool) {\\n   931→\\tenv.T.Helper()\\n   932→\\n   933→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   934→\\tif err != nil {\\n   935→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   936→\\t}\\n   937→\\n   938→\\t// Get the branch reference\\n   939→\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   940→\\tif err != nil {\\n   941→\\t\\t// Try as a remote-style ref\\n   942→\\t\\tref, err = repo.Reference(plumbing.ReferenceName(\\\"refs/heads/\\\"+branchName), true)\\n   943→\\t\\tif err != nil {\\n   944→\\t\\t\\treturn \\\"\\\", false\\n   945→\\t\\t}\\n   946→\\t}\\n   947→\\n   948→\\t// Get the commit\\n   949→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   950→\\tif err != nil {\\n   951→\\t\\treturn \\\"\\\", false\\n   952→\\t}\\n   953→\\n   954→\\t// Get the tree\\n   955→\\ttree, err := commit.Tree()\\n   956→\\tif err != nil {\\n   957→\\t\\treturn \\\"\\\", false\\n   958→\\t}\\n   959→\\n   960→\\t// Get the file\\n   961→\\tfile, err := tree.File(filePath)\\n   962→\\tif err != nil {\\n   963→\\t\\treturn \\\"\\\", false\\n   964→\\t}\\n   965→\\n   966→\\t// Get the content\\n   967→\\tcontent, err := file.Contents()\\n   968→\\tif err != nil {\\n   969→\\t\\treturn \\\"\\\", false\\n   970→\\t}\\n   971→\\n   972→\\treturn content, true\\n   973→}\\n   974→\\n   975→// CheckpointValidation contains expected values for checkpoint validation.\\n   976→type CheckpointValidation struct {\\n   977→\\t// CheckpointID is the expected checkpoint ID\\n   978→\\tCheckpointID string\\n   979→\\n   980→\\t// Strategy is the expected strategy name (optional)\\n   981→\\tStrategy string\\n   982→\\n   983→\\t// FilesTouched are the expected files in files_touched (optional)\\n   984→\\tFilesTouched []string\\n   985→\\n   986→\\t// ExpectedPrompts are strings that should appear in prompt.txt (optional)\\n   987→\\tExpectedPrompts []string\\n   988→\\n   989→\\t// ExpectedTranscriptContent are strings that should appear in full.jsonl (optional)\\n   990→\\tExpectedTranscriptContent []string\\n   991→}\\n   992→\\n   993→// ValidateCheckpoint performs comprehensive validation of a checkpoint on the metadata branch.\\n   994→func (env *TestEnv) ValidateCheckpoint(v CheckpointValidation) {\\n   995→\\tenv.T.Helper()\\n   996→\\n   997→\\tmetadataBranch := \\\"entire/checkpoints/v1\\\"\\n   998→\\n   999→\\t// Compute sharded path: <id[:2]>/<id[2:]>/\\n  1000→\\tif len(v.CheckpointID) < 3 {\\n  1001→\\t\\tenv.T.Fatalf(\\\"Checkpoint ID too short: %s\\\", v.CheckpointID)\\n  1002→\\t}\\n  1003→\\tshardedPath := v.CheckpointID[:2] + \\\"/\\\" + v.CheckpointID[2:]\\n  1004→\\n  1005→\\t// Validate root metadata.json exists and has expected fields\\n  1006→\\tsummaryPath := shardedPath + \\\"/metadata.json\\\"\\n  1007→\\tsummaryContent, found := env.ReadFileFromBranch(metadataBranch, summaryPath)\\n  1008→\\tif !found {\\n  1009→\\t\\tenv.T.Errorf(\\\"CheckpointSummary not found at %s\\\", summaryPath)\\n  1010→\\t} else {\\n  1011→\\t\\tvar summary map[string]any\\n  1012→\\t\\tif err := json.Unmarshal([]byte(summaryContent), &summary); err != nil {\\n  1013→\\t\\t\\tenv.T.Errorf(\\\"Failed to parse CheckpointSummary: %v\\\", err)\\n  1014→\\t\\t} else {\\n  1015→\\t\\t\\t// Validate checkpoint_id\\n  1016→\\t\\t\\tif cpID, ok := summary[\\\"checkpoint_id\\\"].(string); !ok || cpID != v.CheckpointID {\\n  1017→\\t\\t\\t\\tenv.T.Errorf(\\\"CheckpointSummary.checkpoint_id = %v, want %s\\\", summary[\\\"checkpoint_id\\\"], v.CheckpointID)\\n  1018→\\t\\t\\t}\\n  1019→\\t\\t\\t// Validate strategy if specified\\n  1020→\\t\\t\\tif v.Strategy != \\\"\\\" {\\n  1021→\\t\\t\\t\\tif strategy, ok := summary[\\\"strategy\\\"].(string); !ok || strategy != v.Strategy {\\n  1022→\\t\\t\\t\\t\\tenv.T.Errorf(\\\"CheckpointSummary.strategy = %v, want %s\\\", summary[\\\"strategy\\\"], v.Strategy)\\n  1023→\\t\\t\\t\\t}\\n  1024→\\t\\t\\t}\\n  1025→\\t\\t\\t// Validate sessions array exists\\n  1026→\\t\\t\\tif sessions, ok := summary[\\\"sessions\\\"].([]any); !ok || len(sessions) == 0 {\\n  1027→\\t\\t\\t\\tenv.T.Error(\\\"CheckpointSummary.sessions should have at least one entry\\\")\\n  1028→\\t\\t\\t}\\n  1029→\\t\\t\\t// Validate files_touched if specified\\n  1030→\\t\\t\\tif len(v.FilesTouched) > 0 {\\n  1031→\\t\\t\\t\\tif filesTouched, ok := summary[\\\"files_touched\\\"].([]any); ok {\\n  1032→\\t\\t\\t\\t\\ttouchedSet := make(map[string]bool)\\n  1033→\\t\\t\\t\\t\\tfor _, f := range filesTouched {\\n  1034→\\t\\t\\t\\t\\t\\tif s, ok := f.(string); ok {\\n  1035→\\t\\t\\t\\t\\t\\t\\ttouchedSet[s] = true\\n  1036→\\t\\t\\t\\t\\t\\t}\\n  1037→\\t\\t\\t\\t\\t}\\n  1038→\\t\\t\\t\\t\\tfor _, expected := range v.FilesTouched {\\n  1039→\\t\\t\\t\\t\\t\\tif !touchedSet[expected] {\\n  1040→\\t\\t\\t\\t\\t\\t\\tenv.T.Errorf(\\\"CheckpointSummary.files_touched missing %q\\\", expected)\\n  1041→\\t\\t\\t\\t\\t\\t}\\n  1042→\\t\\t\\t\\t\\t}\\n  1043→\\t\\t\\t\\t}\\n  1044→\\t\\t\\t}\\n  1045→\\t\\t}\\n  1046→\\t}\\n  1047→\\n  1048→\\t// Validate session metadata.json exists\\n  1049→\\tsessionMetadataPath := shardedPath + \\\"/0/metadata.json\\\"\\n  1050→\\tsessionContent, found := env.ReadFileFromBranch(metadataBranch, sessionMetadataPath)\\n  1051→\\tif !found {\\n  1052→\\t\\tenv.T.Errorf(\\\"Session metadata not found at %s\\\", sessionMetadataPath)\\n  1053→\\t} else {\\n  1054→\\t\\tvar metadata map[string]any\\n  1055→\\t\\tif err := json.Unmarshal([]byte(sessionContent), &metadata); err != nil {\\n  1056→\\t\\t\\tenv.T.Errorf(\\\"Failed to parse session metadata: %v\\\", err)\\n  1057→\\t\\t} else {\\n  1058→\\t\\t\\t// Validate checkpoint_id matches\\n  1059→\\t\\t\\tif cpID, ok := metadata[\\\"checkpoint_id\\\"].(string); !ok || cpID != v.CheckpointID {\\n  1060→\\t\\t\\t\\tenv.T.Errorf(\\\"Session metadata.checkpoint_id = %v, want %s\\\", metadata[\\\"checkpoint_id\\\"], v.CheckpointID)\\n  1061→\\t\\t\\t}\\n  1062→\\t\\t\\t// Validate created_at exists\\n  1063→\\t\\t\\tif _, ok := metadata[\\\"created_at\\\"].(string); !ok {\\n  1064→\\t\\t\\t\\tenv.T.Error(\\\"Session metadata.created_at should exist\\\")\\n  1065→\\t\\t\\t}\\n  1066→\\t\\t}\\n  1067→\\t}\\n  1068→\\n  1069→\\t// Validate transcript is valid JSONL (only enforce for Claude Code, log warnings for others)\\n  1070→\\ttranscriptPath := shardedPath + \\\"/0/full.jsonl\\\"\\n  1071→\\ttranscriptContent, found := env.ReadFileFromBranch(metadataBranch, transcriptPath)\\n  1072→\\tif !found {\\n  1073→\\t\\tenv.T.Errorf(\\\"Transcript not found at %s\\\", transcriptPath)\\n  1074→\\t} else {\\n  1075→\\t\\t// Check each line is valid JSON\\n  1076→\\t\\t// Only enforce JSONL format for Claude Code - other agents may have different formats\\n  1077→\\t\\tisClaudeCode := env.Agent.Name() == AgentNameClaudeCode\\n  1078→\\t\\tlines := strings.Split(transcriptContent, \\\"\\\\n\\\")\\n  1079→\\t\\tvalidLines := 0\\n  1080→\\t\\tfor i, line := range lines {\\n  1081→\\t\\t\\tline = strings.TrimSpace(line)\\n  1082→\\t\\t\\tif line == \\\"\\\" {\\n  1083→\\t\\t\\t\\tcontinue\\n  1084→\\t\\t\\t}\\n  1085→\\t\\t\\tvalidLines++\\n  1086→\\t\\t\\tvar obj map[string]any\\n  1087→\\t\\t\\tif err := json.Unmarshal([]byte(line), &obj); err != nil {\\n  1088→\\t\\t\\t\\tif isClaudeCode {\\n  1089→\\t\\t\\t\\t\\tenv.T.Errorf(\\\"Transcript line %d is not valid JSON: %v\\\", i+1, err)\\n  1090→\\t\\t\\t\\t}\\n  1091→\\t\\t\\t\\t// For non-Claude agents, just log (transcript format may differ)\\n  1092→\\t\\t\\t}\\n  1093→\\t\\t}\\n  1094→\\t\\tif validLines == 0 {\\n  1095→\\t\\t\\tenv.T.Error(\\\"Transcript is empty (no valid JSONL lines)\\\")\\n  1096→\\t\\t}\\n  1097→\\t\\t// Check expected content\\n  1098→\\t\\tfor _, expected := range v.ExpectedTranscriptContent {\\n  1099→\\t\\t\\tif !strings.Contains(transcriptContent, expected) {\\n  1100→\\t\\t\\t\\tenv.T.Errorf(\\\"Transcript should contain %q\\\", expected)\\n  1101→\\t\\t\\t}\\n  1102→\\t\\t}\\n  1103→\\t}\\n  1104→\\n  1105→\\t// Validate prompt.txt contains expected prompts\\n  1106→\\tif len(v.ExpectedPrompts) > 0 {\\n  1107→\\t\\tpromptPath := shardedPath + \\\"/0/prompt.txt\\\"\\n  1108→\\t\\tpromptContent, found := env.ReadFileFromBranch(metadataBranch, promptPath)\\n  1109→\\t\\tif !found {\\n  1110→\\t\\t\\tenv.T.Errorf(\\\"Prompt file not found at %s\\\", promptPath)\\n  1111→\\t\\t} else {\\n  1112→\\t\\t\\tfor _, expected := range v.ExpectedPrompts {\\n  1113→\\t\\t\\t\\tif !strings.Contains(promptContent, expected) {\\n  1114→\\t\\t\\t\\t\\tenv.T.Errorf(\\\"Prompt file should contain %q\\\", expected)\\n  1115→\\t\\t\\t\\t}\\n  1116→\\t\\t\\t}\\n  1117→\\t\\t}\\n  1118→\\t}\\n  1119→\\n  1120→\\t// Validate content hash exists and matches transcript\\n  1121→\\thashPath := shardedPath + \\\"/0/content_hash.txt\\\"\\n  1122→\\thashContent, found := env.ReadFileFromBranch(metadataBranch, hashPath)\\n  1123→\\tif !found {\\n  1124→\\t\\tenv.T.Errorf(\\\"Content hash not found at %s\\\", hashPath)\\n  1125→\\t} else if transcriptContent != \\\"\\\" {\\n  1126→\\t\\t// Verify hash matches\\n  1127→\\t\\thash := sha256.Sum256([]byte(transcriptContent))\\n  1128→\\t\\texpectedHash := \\\"sha256:\\\" + hex.EncodeToString(hash[:])\\n  1129→\\t\\tstoredHash := strings.TrimSpace(hashContent)\\n  1130→\\t\\tif storedHash != expectedHash {\\n  1131→\\t\\t\\tenv.T.Errorf(\\\"Content hash mismatch:\\\\n  stored:   %s\\\\n  expected: %s\\\", storedHash, expectedHash)\\n  1132→\\t\\t}\\n  1133→\\t}\\n  1134→}\\n  1135→\\n\\n<system-reminder>\\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\\n</system-reminder>\\n\"}]},\"uuid\":\"7721923c-ec65-4023-9255-3080fe165bf1\",\"timestamp\":\"2026-02-18T20:00:06.881Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/e2e_test/testenv.go\",\"content\":\"//go:build e2e\\n\\npackage e2e\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"crypto/sha256\\\"\\n\\t\\\"encoding/hex\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"os\\\"\\n\\t\\\"os/exec\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"testing\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/format/config\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// defaultAgent holds the agent to test with, determined in TestMain.\\nvar defaultAgent string\\n\\n// testBinaryPath holds the path to the CLI binary built once in TestMain.\\n// All tests share this binary to avoid repeated builds.\\nvar testBinaryPath string\\n\\n// TestEnv manages an isolated test environment for E2E tests with real agent 