\\t}\\n   519→\\n   520→\\tif !restored {\\n   521→\\t\\t// Fall back to local file\\n   522→\\t\\tif err := restoreSessionTranscript(transcriptFile, sessionID, agent); err != nil {\\n   523→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to restore session transcript: %v\\\\n\\\", err)\\n   524→\\t\\t}\\n   525→\\t}\\n   526→\\n   527→\\tfmt.Printf(\\\"Rewound to %s. %s\\\\n\\\", selectedPoint.ID[:7], agent.FormatResumeCommand(sessionID))\\n   528→\\treturn nil\\n   529→}\\n   530→\\n   531→// handleLogsOnlyRewindNonInteractive handles logs-only rewind in non-interactive mode.\\n   532→// Defaults to restoring logs only (no checkout) for safety.\\n   533→func handleLogsOnlyRewindNonInteractive(start strategy.Strategy, point strategy.RewindPoint) error {\\n   534→\\t// Resolve agent once for use throughout\\n   535→\\tagent, err := getAgent(point.Agent)\\n   536→\\tif err != nil {\\n   537→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   538→\\t}\\n   539→\\n   540→\\t// Initialize logging context with agent from checkpoint\\n   541→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   542→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   543→\\n   544→\\tlogging.Debug(ctx, \\\"logs-only rewind started\\\",\\n   545→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   546→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   547→\\t)\\n   548→\\n   549→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   550→\\tif !ok {\\n   551→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   552→\\t}\\n   553→\\n   554→\\tsessions, err := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   555→\\tif err != nil {\\n   556→\\t\\tlogging.Error(ctx, \\\"logs-only rewind failed\\\",\\n   557→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   558→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   559→\\t\\t)\\n   560→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   561→\\t}\\n   562→\\n   563→\\tlogging.Debug(ctx, \\\"logs-only rewind completed\\\",\\n   564→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   565→\\t)\\n   566→\\n   567→\\t// Show resume commands for all sessions\\n   568→\\tprintMultiSessionResumeCommands(sessions)\\n   569→\\n   570→\\tfmt.Println(\\\"Note: Working directory unchanged. Use interactive mode for full checkout.\\\")\\n   571→\\treturn nil\\n   572→}\\n   573→\\n   574→// handleLogsOnlyResetNonInteractive handles reset in non-interactive mode.\\n   575→// This performs a git reset --hard to the target commit.\\n   576→func handleLogsOnlyResetNonInteractive(start strategy.Strategy, point strategy.RewindPoint) error {\\n   577→\\t// Resolve agent once for use throughout\\n   578→\\tagent, err := getAgent(point.Agent)\\n   579→\\tif err != nil {\\n   580→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   581→\\t}\\n   582→\\n   583→\\t// Initialize logging context with agent from checkpoint\\n   584→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   585→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   586→\\n   587→\\tlogging.Debug(ctx, \\\"logs-only reset started\\\",\\n   588→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   589→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   590→\\t)\\n   591→\\n   592→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   593→\\tif !ok {\\n   594→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   595→\\t}\\n   596→\\n   597→\\t// Get current HEAD before reset (for recovery message)\\n   598→\\tcurrentHead, headErr := getCurrentHeadHash()\\n   599→\\tif headErr != nil {\\n   600→\\t\\tcurrentHead = \\\"\\\"\\n   601→\\t}\\n   602→\\n   603→\\t// Restore logs first\\n   604→\\tsessions, err := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   605→\\tif err != nil {\\n   606→\\t\\tlogging.Error(ctx, \\\"logs-only reset failed during log restoration\\\",\\n   607→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   608→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   609→\\t\\t)\\n   610→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   611→\\t}\\n   612→\\n   613→\\t// Perform git reset --hard\\n   614→\\tif err := performGitResetHard(point.ID); err != nil {\\n   615→\\t\\tlogging.Error(ctx, \\\"logs-only reset failed during git reset\\\",\\n   616→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   617→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   618→\\t\\t)\\n   619→\\t\\treturn fmt.Errorf(\\\"failed to reset branch: %w\\\", err)\\n   620→\\t}\\n   621→\\n   622→\\tlogging.Debug(ctx, \\\"logs-only reset completed\\\",\\n   623→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   624→\\t)\\n   625→\\n   626→\\tshortID := point.ID\\n   627→\\tif len(shortID) > 7 {\\n   628→\\t\\tshortID = shortID[:7]\\n   629→\\t}\\n   630→\\n   631→\\tfmt.Printf(\\\"Reset branch to %s.\\\\n\\\", shortID)\\n   632→\\n   633→\\t// Show resume commands for all sessions\\n   634→\\tprintMultiSessionResumeCommands(sessions)\\n   635→\\n   636→\\t// Show recovery instructions\\n   637→\\tif currentHead != \\\"\\\" && currentHead != point.ID {\\n   638→\\t\\tcurrentShort := currentHead\\n   639→\\t\\tif len(currentShort) > 7 {\\n   640→\\t\\t\\tcurrentShort = currentShort[:7]\\n   641→\\t\\t}\\n   642→\\t\\tfmt.Printf(\\\"\\\\nTo undo this reset: git reset --hard %s\\\\n\\\", currentShort)\\n   643→\\t}\\n   644→\\n   645→\\treturn nil\\n   646→}\\n   647→\\n   648→func restoreSessionTranscript(transcriptFile, sessionID string, agent agentpkg.Agent) error {\\n   649→\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   650→\\tif err != nil {\\n   651→\\t\\treturn err\\n   652→\\t}\\n   653→\\n   654→\\t// Ensure parent directory exists\\n   655→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   656→\\t\\treturn fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   657→\\t}\\n   658→\\n   659→\\tfmt.Fprintf(os.Stderr, \\\"Copying transcript:\\\\n  From: %s\\\\n  To: %s\\\\n\\\", transcriptFile, sessionFile)\\n   660→\\tif err := copyFile(transcriptFile, sessionFile); err != nil {\\n   661→\\t\\treturn fmt.Errorf(\\\"failed to copy transcript: %w\\\", err)\\n   662→\\t}\\n   663→\\n   664→\\treturn nil\\n   665→}\\n   666→\\n   667→// restoreSessionTranscriptFromStrategy restores a session transcript from checkpoint storage.\\n   668→// This is used for strategies that store transcripts in git branches rather than local files.\\n   669→// Returns the session ID that was actually used (may differ from input if checkpoint provides one).\\n   670→func restoreSessionTranscriptFromStrategy(cpID id.CheckpointID, sessionID string, agent agentpkg.Agent) (string, error) {\\n   671→\\t// Get transcript content from checkpoint storage\\n   672→\\tcontent, returnedSessionID, exportData, err := checkpoint.LookupSessionLog(cpID)\\n   673→\\tif err != nil {\\n   674→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get session log: %w\\\", err)\\n   675→\\t}\\n   676→\\n   677→\\t// Use session ID returned from checkpoint if available\\n   678→\\t// Otherwise fall back to the passed-in sessionID\\n   679→\\tif returnedSessionID != \\\"\\\" {\\n   680→\\t\\tsessionID = returnedSessionID\\n   681→\\t}\\n   682→\\n   683→\\t// If export data is available (e.g., OpenCode), use WriteSession which handles\\n   684→\\t// both file writing and native storage import (SQLite for OpenCode).\\n   685→\\tif len(exportData) > 0 {\\n   686→\\t\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   687→\\t\\tif err != nil {\\n   688→\\t\\t\\treturn \\\"\\\", err\\n   689→\\t\\t}\\n   690→\\t\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   691→\\t\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   692→\\t\\t}\\n   693→\\t\\tagentSession := &agentpkg.AgentSession{\\n   694→\\t\\t\\tSessionID:  sessionID,\\n   695→\\t\\t\\tAgentName:  agent.Name(),\\n   696→\\t\\t\\tSessionRef: sessionFile,\\n   697→\\t\\t\\tNativeData: content,\\n   698→\\t\\t\\tExportData: exportData,\\n   699→\\t\\t}\\n   700→\\t\\tif err := agent.WriteSession(agentSession); err != nil {\\n   701→\\t\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write session: %w\\\", err)\\n   702→\\t\\t}\\n   703→\\t\\treturn sessionID, nil\\n   704→\\t}\\n   705→\\n   706→\\treturn writeTranscriptToAgentSession(content, sessionID, agent)\\n   707→}\\n   708→\\n   709→// restoreSessionTranscriptFromShadow restores a session transcript from a shadow branch commit.\\n   710→// This is used for uncommitted checkpoints where the transcript is stored in the shadow branch tree.\\n   711→func restoreSessionTranscriptFromShadow(commitHash, metadataDir, sessionID string, agent agentpkg.Agent) (string, error) {\\n   712→\\t// Open repository\\n   713→\\trepo, err := git.PlainOpenWithOptions(\\\".\\\", &git.PlainOpenOptions{DetectDotGit: true})\\n   714→\\tif err != nil {\\n   715→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   716→\\t}\\n   717→\\n   718→\\t// Parse commit hash\\n   719→\\thash := plumbing.NewHash(commitHash)\\n   720→\\tif hash.IsZero() {\\n   721→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"invalid commit hash: %s\\\", commitHash)\\n   722→\\t}\\n   723→\\n   724→\\t// Get transcript from shadow branch commit tree\\n   725→\\tstore := checkpoint.NewGitStore(repo)\\n   726→\\tcontent, err := store.GetTranscriptFromCommit(hash, metadataDir, agent.Type())\\n   727→\\tif err != nil {\\n   728→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get transcript from shadow branch: %w\\\", err)\\n   729→\\t}\\n   730→\\n   731→\\t// Read export data from shadow branch tree if available (e.g., OpenCode export JSON).\\n   732→\\texportData := store.GetExportDataFromCommit(hash, metadataDir)\\n   733→\\n   734→\\t// If export data is available, use WriteSession which handles both file writing\\n   735→\\t// and native storage import (SQLite for OpenCode).\\n   736→\\tif len(exportData) > 0 {\\n   737→\\t\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   738→\\t\\tif err != nil {\\n   739→\\t\\t\\treturn \\\"\\\", err\\n   740→\\t\\t}\\n   741→\\t\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   742→\\t\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   743→\\t\\t}\\n   744→\\t\\tagentSession := &agentpkg.AgentSession{\\n   745→\\t\\t\\tSessionID:  sessionID,\\n   746→\\t\\t\\tAgentName:  agent.Name(),\\n   747→\\t\\t\\tSessionRef: sessionFile,\\n   748→\\t\\t\\tNativeData: content,\\n   749→\\t\\t\\tExportData: exportData,\\n   750→\\t\\t}\\n   751→\\t\\tif err := agent.WriteSession(agentSession); err != nil {\\n   752→\\t\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write session: %w\\\", err)\\n   753→\\t\\t}\\n   754→\\t\\treturn sessionID, nil\\n   755→\\t}\\n   756→\\n   757→\\treturn writeTranscriptToAgentSession(content, sessionID, agent)\\n   758→}\\n   759→\\n   760→// writeTranscriptToAgentSession writes transcript content to the agent's session storage.\\n   761→func writeTranscriptToAgentSession(content []byte, sessionID string, agent agentpkg.Agent) (string, error) {\\n   762→\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   763→\\tif err != nil {\\n   764→\\t\\treturn \\\"\\\", err\\n   765→\\t}\\n   766→\\n   767→\\t// Ensure parent directory exists\\n   768→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   769→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   770→\\t}\\n   771→\\n   772→\\tfmt.Fprintf(os.Stderr, \\\"Writing transcript to: %s\\\\n\\\", sessionFile)\\n   773→\\tif err := os.WriteFile(sessionFile, content, 0o600); err != nil {\\n   774→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   775→\\t}\\n   776→\\n   777→\\treturn sessionID, nil\\n   778→}\\n   779→\\n   780→// restoreTaskCheckpointTranscript restores a truncated transcript for a task checkpoint.\\n   781→// Uses GetTaskCheckpointTranscript to fetch the transcript from the strategy.\\n   782→//\\n   783→// NOTE: The transcript parsing/truncation/writing pipeline (transcript.ParseFromBytes,\\n   784→// TruncateTranscriptAtUUID, writeTranscript) assumes Claude's JSONL format.\\n   785→// This is acceptable because task checkpoints are currently only created by Claude Code's\\n   786→// PostToolUse hook. If other agents gain sub-agent support, this will need a\\n   787→// format-aware refactor (agent-specific parsing, truncation, and serialization).\\n   788→func restoreTaskCheckpointTranscript(strat strategy.Strategy, point strategy.RewindPoint, sessionID, checkpointUUID string, agent agentpkg.Agent) error {\\n   789→\\t// Get transcript content from strategy\\n   790→\\tcontent, err := strat.GetTaskCheckpointTranscript(point)\\n   791→\\tif err != nil {\\n   792→\\t\\treturn fmt.Errorf(\\\"failed to get task checkpoint transcript: %w\\\", err)\\n   793→\\t}\\n   794→\\n   795→\\t// Parse the transcript\\n   796→\\tparsed, err := transcript.ParseFromBytes(content)\\n   797→\\tif err != nil {\\n   798→\\t\\treturn fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   799→\\t}\\n   800→\\n   801→\\t// Truncate at checkpoint UUID\\n   802→\\ttruncated := TruncateTranscriptAtUUID(parsed, checkpointUUID)\\n   803→\\n   804→\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   805→\\tif err != nil {\\n   806→\\t\\treturn err\\n   807→\\t}\\n   808→\\n   809→\\t// Ensure parent directory exists\\n   810→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   811→\\t\\treturn fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   81