anges) == 0 {\\n   901→\\t\\treturn true, \\\"\\\", nil\\n   902→\\t}\\n   903→\\n   904→\\t// Sort changes by filename for consistent output\\n   905→\\tsort.Slice(changes, func(i, j int) bool {\\n   906→\\t\\treturn changes[i].filename < changes[j].filename\\n   907→\\t})\\n   908→\\n   909→\\tvar msg strings.Builder\\n   910→\\tmsg.WriteString(\\\"The following uncommitted changes will be reverted:\\\\n\\\")\\n   911→\\n   912→\\ttotalAdded, totalRemoved := 0, 0\\n   913→\\tfor _, c := range changes {\\n   914→\\t\\ttotalAdded += c.added\\n   915→\\t\\ttotalRemoved += c.removed\\n   916→\\n   917→\\t\\tvar stats string\\n   918→\\t\\tswitch {\\n   919→\\t\\tcase c.added > 0 && c.removed > 0:\\n   920→\\t\\t\\tstats = fmt.Sprintf(\\\"+%d/-%d\\\", c.added, c.removed)\\n   921→\\t\\tcase c.added > 0:\\n   922→\\t\\t\\tstats = fmt.Sprintf(\\\"+%d\\\", c.added)\\n   923→\\t\\tcase c.removed > 0:\\n   924→\\t\\t\\tstats = fmt.Sprintf(\\\"-%d\\\", c.removed)\\n   925→\\t\\t}\\n   926→\\n   927→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  %-10s %s\\\", c.status+\\\":\\\", c.filename))\\n   928→\\t\\tif stats != \\\"\\\" {\\n   929→\\t\\t\\tmsg.WriteString(fmt.Sprintf(\\\" (%s)\\\", stats))\\n   930→\\t\\t}\\n   931→\\t\\tmsg.WriteString(\\\"\\\\n\\\")\\n   932→\\t}\\n   933→\\n   934→\\tif totalAdded > 0 || totalRemoved > 0 {\\n   935→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"\\\\nTotal: +%d/-%d lines\\\\n\\\", totalAdded, totalRemoved))\\n   936→\\t}\\n   937→\\n   938→\\treturn true, msg.String(), nil\\n   939→}\\n   940→\\n   941→// countLines counts the number of lines in content.\\n   942→func countLines(content []byte) int {\\n   943→\\tif len(content) == 0 {\\n   944→\\t\\treturn 0\\n   945→\\t}\\n   946→\\tcount := 1\\n   947→\\tfor _, b := range content {\\n   948→\\t\\tif b == '\\\\n' {\\n   949→\\t\\t\\tcount++\\n   950→\\t\\t}\\n   951→\\t}\\n   952→\\t// Don't count trailing newline as extra line\\n   953→\\tif len(content) > 0 && content[len(content)-1] == '\\\\n' {\\n   954→\\t\\tcount--\\n   955→\\t}\\n   956→\\treturn count\\n   957→}\\n   958→\\n   959→// computeDiffStats computes added and removed line counts between old and new content.\\n   960→// Uses a simple line-based diff algorithm.\\n   961→func computeDiffStats(oldContent, newContent []byte) (added, removed int) {\\n   962→\\toldLines := splitLines(oldContent)\\n   963→\\tnewLines := splitLines(newContent)\\n   964→\\n   965→\\t// Build a set of old lines with counts\\n   966→\\toldSet := make(map[string]int)\\n   967→\\tfor _, line := range oldLines {\\n   968→\\t\\toldSet[line]++\\n   969→\\t}\\n   970→\\n   971→\\t// Check which new lines are truly new\\n   972→\\tfor _, line := range newLines {\\n   973→\\t\\tif oldSet[line] > 0 {\\n   974→\\t\\t\\toldSet[line]--\\n   975→\\t\\t} else {\\n   976→\\t\\t\\tadded++\\n   977→\\t\\t}\\n   978→\\t}\\n   979→\\n   980→\\t// Remaining old lines are removed\\n   981→\\tfor _, count := range oldSet {\\n   982→\\t\\tremoved += count\\n   983→\\t}\\n   984→\\n   985→\\treturn added, removed\\n   986→}\\n   987→\\n   988→// splitLines splits content into lines, preserving empty lines.\\n   989→func splitLines(content []byte) []string {\\n   990→\\tif len(content) == 0 {\\n   991→\\t\\treturn nil\\n   992→\\t}\\n   993→\\ts := string(content)\\n   994→\\t// Remove trailing newline to avoid empty last element\\n   995→\\ts = strings.TrimSuffix(s, \\\"\\\\n\\\")\\n   996→\\treturn strings.Split(s, \\\"\\\\n\\\")\\n   997→}\\n   998→\\n   999→// fileExists checks if a file exists at the given path.\\n  1000→func fileExists(path string) bool {\\n  1001→\\t_, err := os.Stat(path)\\n  1002→\\treturn err == nil\\n  1003→}\\n  1004→\\n  1005→// StageFilesContext describes what type of staging operation this is (for messages).\\n  1006→type StageFilesContext string\\n  1007→\\n  1008→const (\\n  1009→\\t// StageForSession is used when staging files for a session checkpoint.\\n  1010→\\tStageForSession StageFilesContext = \\\"session\\\"\\n  1011→\\t// StageForTask is used when staging files for a task checkpoint.\\n  1012→\\tStageForTask StageFilesContext = \\\"task\\\"\\n  1013→)\\n  1014→\\n  1015→// StageFiles stages modified, new, and deleted files to the git worktree.\\n  1016→//\\n  1017→// This function handles three categories of file changes:\\n  1018→//  1. Modified files: existing files that have been changed\\n  1019→//  2. New files: files that were created during the session\\n  1020→//  3. Deleted files: files that were removed during the session\\n  1021→//\\n  1022→// Error Handling Strategy:\\n  1023→//   - Individual file staging errors are logged to stderr but don't fail the operation\\n  1024→//   - This ensures that partial staging succeeds even if some files have issues\\n  1025→//   - If a modified file no longer exists, it's treated as a deletion\\n  1026→//\\n  1027→// The stageCtx parameter is used for user-facing messages to indicate whether\\n  1028→// this is staging for a session checkpoint or a task checkpoint.\\n  1029→func StageFiles(worktree *git.Worktree, modified, newFiles, deleted []string, stageCtx StageFilesContext) {\\n  1030→\\t// Get repo root for resolving file paths\\n  1031→\\t// This is critical because fileExists() uses os.Stat() which resolves relative to CWD,\\n  1032→\\t// but worktree.Add/Remove resolve relative to repo root. If CWD != repo root,\\n  1033→\\t// fileExists() could return false for existing files, causing worktree.Remove()\\n  1034→\\t// to incorrectly delete them.\\n  1035→\\trepoRoot := worktree.Filesystem.Root()\\n  1036→\\n  1037→\\t// Stage modified files\\n  1038→\\tfor _, file := range modified {\\n  1039→\\t\\t// Resolve path relative to repo root for existence check\\n  1040→\\t\\tabsPath := filepath.Join(repoRoot, file)\\n  1041→\\t\\tif fileExists(absPath) {\\n  1042→\\t\\t\\tif _, err := worktree.Add(file); err != nil {\\n  1043→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage %s: %v\\\\n\\\", file, err)\\n  1044→\\t\\t\\t} else {\\n  1045→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged: %s\\\\n\\\", file)\\n  1046→\\t\\t\\t}\\n  1047→\\t\\t} else {\\n  1048→\\t\\t\\t// File was deleted - stage the deletion\\n  1049→\\t\\t\\tif _, err := worktree.Remove(file); err != nil {\\n  1050→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  File not found or deleted: %s\\\\n\\\", file)\\n  1051→\\t\\t\\t}\\n  1052→\\t\\t}\\n  1053→\\t}\\n  1054→\\n  1055→\\t// Stage new files\\n  1056→\\tif len(newFiles) > 0 {\\n  1057→\\t\\tfmt.Fprintf(os.Stderr, \\\"Staging %d new files created during %s:\\\\n\\\", len(newFiles), stageCtx)\\n  1058→\\t\\tfor _, file := range newFiles {\\n  1059→\\t\\t\\tif _, err := worktree.Add(file); err != nil {\\n  1060→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage %s: %v\\\\n\\\", file, err)\\n  1061→\\t\\t\\t} else {\\n  1062→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged new file: %s\\\\n\\\", file)\\n  1063→\\t\\t\\t}\\n  1064→\\t\\t}\\n  1065→\\t}\\n  1066→\\n  1067→\\t// Stage deleted files\\n  1068→\\tfor _, file := range deleted {\\n  1069→\\t\\tif _, err := worktree.Remove(file); err != nil {\\n  1070→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage deleted file %s: %v\\\\n\\\", file, err)\\n  1071→\\t\\t} else {\\n  1072→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged deleted file: %s\\\\n\\\", file)\\n  1073→\\t\\t}\\n  1074→\\t}\\n  1075→}\\n  1076→\\n  1077→// getTaskCheckpointFromTree retrieves a task checkpoint from a commit tree.\\n  1078→// Shared implementation for shadow and linear-shadow strategies.\\n  1079→func getTaskCheckpointFromTree(point RewindPoint) (*TaskCheckpoint, error) {\\n  1080→\\tif !point.IsTaskCheckpoint {\\n  1081→\\t\\treturn nil, ErrNotTaskCheckpoint\\n  1082→\\t}\\n  1083→\\n  1084→\\trepo, err := OpenRepository()\\n  1085→\\tif err != nil {\\n  1086→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n  1087→\\t}\\n  1088→\\n  1089→\\tcommitHash := plumbing.NewHash(point.ID)\\n  1090→\\tcommit, err := repo.CommitObject(commitHash)\\n  1091→\\tif err != nil {\\n  1092→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n  1093→\\t}\\n  1094→\\n  1095→\\ttree, err := commit.Tree()\\n  1096→\\tif err != nil {\\n  1097→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n  1098→\\t}\\n  1099→\\n  1100→\\t// Read checkpoint.json from the tree\\n  1101→\\tcheckpointPath := point.MetadataDir + \\\"/checkpoint.json\\\"\\n  1102→\\tfile, err := tree.File(checkpointPath)\\n  1103→\\tif err != nil {\\n  1104→\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", checkpointPath, err)\\n  1105→\\t}\\n  1106→\\n  1107→\\tcontent, err := file.Contents()\\n  1108→\\tif err != nil {\\n  1109→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n  1110→\\t}\\n  1111→\\n  1112→\\tvar checkpoint TaskCheckpoint\\n  1113→\\tif err := json.Unmarshal([]byte(content), &checkpoint); err != nil {\\n  1114→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse checkpoint: %w\\\", err)\\n  1115→\\t}\\n  1116→\\n  1117→\\treturn &checkpoint, nil\\n  1118→}\\n  1119→\\n  1120→// getTaskTranscriptFromTree retrieves a task transcript from a commit tree.\\n  1121→// Shared implementation for shadow and linear-shadow strategies.\\n  1122→func getTaskTranscriptFromTree(point RewindPoint) ([]byte, error) {\\n  1123→\\tif !point.IsTaskCheckpoint {\\n  1124→\\t\\treturn nil, ErrNotTaskCheckpoint\\n  1125→\\t}\\n  1126→\\n  1127→\\trepo, err := OpenRepository()\\n  1128→\\tif err != nil {\\n  1129→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n  1130→\\t}\\n  1131→\\n  1132→\\tcommitHash := plumbing.NewHash(point.ID)\\n  1133→\\tcommit, err := repo.CommitObject(commitHash)\\n  1134→\\tif err != nil {\\n  1135→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n  1136→\\t}\\n  1137→\\n  1138→\\ttree, err := commit.Tree()\\n  1139→\\tif err != nil {\\n  1140→\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n  1141→\\t}\\n  1142→\\n  1143→\\t// MetadataDir format: .entire/metadata/<session>/tasks/<toolUseID>\\n  1144→\\t// Session transcript is at: .entire/metadata/<session>/<TranscriptFileName>\\n  1145→\\tsessionDir := filepath.Dir(filepath.Dir(point.MetadataDir))\\n  1146→\\n  1147→\\t// Try current format first, then legacy\\n  1148→\\ttranscriptPath := sessionDir + \\\"/\\\" + paths.TranscriptFileName\\n  1149→\\tfile, err := tree.File(transcriptPath)\\n  1150→\\tif err != nil {\\n  1151→\\t\\ttranscriptPath = sessionDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n  1152→\\t\\tfile, err = tree.File(transcriptPath)\\n  1153→\\t\\tif err != nil {\\n  1154→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find transcript: %w\\\", err)\\n  1155→\\t\\t}\\n  1156→\\t}\\n  1157→\\n  1158→\\tcontent, err := file.Contents()\\n  1159→\\tif err != nil {\\n  1160→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n  1161→\\t}\\n  1162→\\n  1163→\\treturn []byte(content), nil\\n  1164→}\\n  1165→\\n  1166→// ErrBranchNotFound is returned by DeleteBranchCLI when the branch does not exist.\\n  1167→var ErrBranchNotFound = errors.New(\\\"branch not found\\\")\\n  1168→\\n  1169→// DeleteBranchCLI deletes a git branch using the git CLI.\\n  1170→// Uses `git branch -D` instead of go-git's RemoveReference because go-git v5\\n  1171→// doesn't properly persist deletions when refs are packed (.git/packed-refs)\\n  1172→// or in a worktree context. This is the same class of go-git v5 bug that\\n  1173→// affects checkout and reset --hard (see HardResetWithProtection).\\n  1174→//\\n  1175→// Returns ErrBranchNotFound if the branch does not exist, allowing callers\\n  1176→// to use errors.Is for idempotent deletion patterns.\\n  1177→func DeleteBranchCLI(branchName string) error {\\n  1178→\\tctx := context.Background()\\n  1179→\\n  1180→\\t// Pre-check: verify the branch exists so callers get a structured error\\n  1181→\\t// instead of parsing git's output string (which varies across locales).\\n  1182→\\t// git show-ref exits 1 for \\\"not found\\\" and 128+ for fatal errors (corrupt\\n  1183→\\t// repo, permissions, not a git directory). Only map exit code 1 to\\n  1184→\\t// ErrBranchNotFound; propagate other failures as-is.\\n  1185→\\tcheck := exec.CommandContext(ctx, \\\"git\\\", \\\"show-ref\\\", \\\"--verify\\\", \\\"--quiet\\\", \\\"refs/heads/\\\"+branchName) //nolint:gosec // branchName comes from internal shadow branch naming\\n  1186→\\tif err := check.Run(); err != nil {\\n  1187→\\t\\tvar exitErr *exec.ExitError\\n  1188→\\t\\tif errors.As(err, &exitErr) && exitErr.ExitCode() == 1 {\\n  1189→\\t\\t\\treturn fmt.Errorf(\\\"%w: %s\\\", ErrBranchNotFound, branchName)\\n  1190→\\t\\t}\\n  1191→\\t\\treturn fmt.Errorf(\\\"failed to check branch %s: %w\\\", branchName, err)\\n  1192→\\t}\\n  1193→\\n  1194→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", branchName)\\n  1195→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1196→\\t\\treturn fmt.Errorf(\\\"failed to delete branch %s: %s: %w\\\", branchName, strings.TrimSpace(string(output)), err)\\n  1197→\\t}\\n  1198→\\treturn nil\\n  1199→}\\n  1200→\\n  1201→// branchExistsCLI checks if a branch exists using git CLI.\\n  1202→// Returns nil if the branch exists, or an error if it does not.\\n  1203→func branchExistsCLI(branchName string) error {\\n  1204→\\tctx := context.Background()\\n  1205→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"show-ref\\\", \\\"--verify\\\", \\\"--quiet\\\", \\\"refs/heads/\\\"+branchName) //nolint:gosec // branchName comes from internal shadow branch naming\\n  1206→\\tif err := cmd.Run(); err != nil {\\n  1207→\\t\\treturn fmt.Errorf(\\\"branch %s not found: %w\\\", branchName, err)\\n  1208→\\t}\\n  1209→\\treturn nil\\n  1210→}\\n  1211→\\n  1212→// HardResetWithProtection performs a git reset --hard to the specified commit.\\n  1213→// Uses the git CLI instead of go-git because go-git's HardReset incorrectly\\n  1214→// deletes untracked directories (like .entire/) even when they're in .gitignore.\\n  1215→// Returns the short commit ID (7 chars) on success for display purposes.\\n  1216→func HardResetWithProtection(commitHash plumbing.Hash) (shortID string, err error) {\\n  1217→\\tctx := context.Background()\\n  1218→\\thashStr := commitHash.String()\\n  1219→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"reset\\\", \\\"--hard\\\", hashStr) //nolint:gosec // hashStr is a plumbing.Hash, not user input\\n  1220→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1221→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"reset failed: %s: %w\\\", strings.TrimSpace(string(output)), err)\\n  1222→\\t}\\n  1223→\\n  1224→\\t// Return short commit ID for display\\n  1225→\\tshortID = hashStr\\n  1226→\\tif len(shortID) > 7 {\\n  1227→\\t\\tshortID = shortID[:7]\\n  1228→\\t}\\n  1229→\\treturn shortID, nil\\n  1230→}\\n  1231→\\n  1232→// collectUntrackedFiles collects untracked files in the working directory that are\\n  1233→// NOT ignored by .gitignore. This is used to capture the initial state when starting\\n  1234→// a session, ensuring untracked files present at session start are preserved during rewind.\\n  1235→// Uses \\\"git ls-files --others --exclude-standard -z\\\" to respect .gitignore rules,\\n  1236→// avoiding bloated session state from large ignored directories like node_modules/.\\n  1237→// Returns paths relative to the repository root.\\n  1238→func collectUntrackedFiles() ([]string, error) {\\n  1239→\\trepoRoot, err := GetWorktreePath()\\n  1240→\\tif err != nil {\\n  1241→\\t\\trepoRoot = \\\".\\\"\\n  1242→\\t}\\n  1243→\\n  1244→\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"ls-files\\\", \\\"--others\\\", \\\"--exclude-standard\\\", \\\"-z\\\")\\n  1245→\\tcmd.Dir = repoRoot\\n  1246→\\toutput, err := cmd.Output()\\n  1247→\\tif err != nil {\\n  1248→\\t\\tvar exitErr *exec.ExitError\\n  1249→\\t\\tif errors.As(err, &exitErr) {\\n  1250→\\t\\t\\treturn nil, fmt.Errorf(\\\"git ls-files failed: %s: %w\\\", strings.TrimSpace(string(exitErr.Stderr)), err)\\n  1251→\\t\\t}\\n  1252→\\t\\treturn nil, fmt.Errorf(\\\"git ls-files failed: %w\\\", err)\\n  1253→\\t}\\n  1254→\\n  1255→\\traw := string(output)\\n  1256→\\tif raw == \\\"\\\" {\\n  1257→\\t\\treturn nil, nil\\n  1258→\\t}\\n  1259→\\n  1260→\\tvar files []string\\n  1261→\\tfor _, f := range strings.Split(raw, \\\"\\\\x00\\\") {\\n  1262→\\t\\t// Defense-in-depth: filter protected paths even though --exclude-standard should already handle them\\n  1263→\\t\\tif f != \\\"\\\" && !isProtectedPath(f) {\\n  1264→\\t\\t\\tfiles = append(files, f)\\n  1265→\\t\\t}\\n  1266→\\t}\\n  1267→\\treturn files, nil\\n  1268→}\\n  1269→\\n  1270→// ExtractSessionIDFromCommit extracts the session ID from a commit's trailers.\\n  1271→// It checks the Entire-Session trailer first, then falls back to extracting from\\n  1272→// the metadata directory path in the Entire-Metadata trailer.\\n  1273→// Returns empty string if no session ID is found.\\n  1274→func ExtractSessionIDFromCommit(commit *object.Commit) string {\\n  1275→\\t// Try Entire-Session trailer first\\n  1276→\\tif sessionID, found := trailers.ParseSession(commit.Message); found {\\n  1277→\\t\\treturn sessionID\\n  1278→\\t}\\n  1279→\\n  1280→\\t// Try extracting from metadata directory (last path component)\\n  1281→\\tif metadataDir, found := trailers.ParseMetadata(commit.Message); found {\\n  1282→\\t\\treturn filepath.Base(metadataDir)\\n  1283→\\t}\\n  1284→\\n  1285→\\treturn \\\"\\\"\\n  1286→}\\n  1287→\\n  1288→// NOTE: The following git tree helper functions have been moved to checkpoint/ package:\\n  1289→// - FlattenTree -> checkpoint.FlattenTree\\n  1290→// - CreateBlobFromContent -> checkpoint.CreateBlobFromContent\\n  1291→// - BuildTreeFromEntries -> checkpoint.BuildTreeFromEntries\\n  1292→// - sortTreeEntries (internal to checkpoint package)\\n  1293→// - treeNode, insertIntoTree, buildTreeObject (internal to checkpoint package)\\n  1294→//\\n  1295→// See push_common.go and session_test.go for usage examples.\\n  1296→\\n  1297→// createCommit creates a commit object\\n  1298→func createCommit(repo *git.Repository, treeHash, parentHash plumbing.Hash, message, authorName, authorEmail string) (plumbing.Hash, error) { //nolint:unparam // already present in codebase\\n  1299→\\tnow := time.Now()\\n  1300→\\tsig := object.Signature{\\n  1301→\\t\\tName:  authorName,\\n  1302→\\t\\tEmail: authorEmail,\\n  1303→\\t\\tWhen:  now,\\n  1304→\\t}\\n  1305→\\n  1306→\\tcommit := &object.Commit{\\n  1307→\\t\\tTreeHash:  treeHash,\\n  1308→\\t\\tAuthor:    sig,\\n  1309→\\t\\tCommitter: sig,\\n  1310→\\t\\tMessage:   message,\\n  1311→\\t}\\n  1312→\\n  1313→\\t// Add parent if not a new branch\\n  1314→\\tif parentHash != plumbing.ZeroHash {\\n  1315→\\t\\tcommit.ParentHashes = []plumbing.Hash{parentHash}\\n  1316→\\t}\\n  1317→\\n  1318→\\tobj := repo.Storer.NewEncodedObject()\\n  1319→\\tif err := commit.Encode(obj); err != nil {\\n  1320→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n  1321→\\t}\\n  1322→\\n  1323→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n  1324→\\tif err != nil {\\n  1325→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store commit: %w\\\", err)\\n  1326→\\t}\\n  1327→\\n  1328→\\treturn hash, nil\\n  1329→}\\n  1330→\\n  1331→// getSessionDescriptionFromTree reads the first line of prompt.txt or context.md from a git tree.\\n  1332→// This is the tree-based equivalent of getSessionDescription (which reads from filesystem).\\n  1333→//\\n  1334→// If metadataDir is provided, looks for files at metadataDir/prompt.txt or metadataDir/context.md.\\n  1335→// If metadataDir is empty, first tries the root of the tree (for when the tree is already\\n  1336→// the session directory, e.g., auto-commit strategy's sharded metadata), then falls back to\\n  1337→// searching for .entire/metadata/*/prompt.txt or context.md (for full worktree trees).\\n  1338→func getSessionDescriptionFromTree(tree *object.Tree, metadataDir string) string {\\n  1339→\\t// Helper to read first line from a file in tree\\n  1340→\\treadFirstLine := func(path string) string {\\n  1341→\\t\\tfile, err := tree.File(path)\\n  1342→\\t\\tif err != nil {\\n  1343→\\t\\t\\treturn \\\"\\\"\\n  1344→\\t\\t}\\n  1345→\\t\\tcontent, err := file.Contents()\\n  1346→\\t\\tif err != nil {\\n  1347→\\t\\t\\treturn \\\"\\\"\\n  1348→\\t\\t}\\n  1349→\\t\\tlines := strings.SplitN(content, \\\"\\\\n\\\", 2)\\n  1350→\\t\\tif len(lines) > 0 && lines[0] != \\\"\\\" {\\n  1351→\\t\\t\\tdesc := strings.TrimSpace(lines[0])\\n  1352→\\t\\t\\t// Remove markdown header prefix if present\\n  1353→\\t\\t\\treturn strings.TrimPrefix(desc, \\\"# \\\")\\n  1354→\\t\\t}\\n  1355→\\t\\treturn \\\"\\\"\\n  1356→\\t}\\n  1357→\\n  1358→\\t// If metadataDir is provided, look there directly\\n  1359→\\tif metadataDir != \\\"\\\" {\\n  1360→\\t\\tif desc := readFirstLine(metadataDir + \\\"/\\\" + paths.PromptFileName); desc != \\\"\\\" {\\n  1361→\\t\\t\\treturn desc\\n  1362→\\t\\t}\\n  1363→\\t\\tif desc := readFirstLine(metadataDir + \\\"/\\\" + paths.ContextFileName); desc != \\\"\\\" {\\n  1364→\\t\\t\\treturn desc\\n  1365→\\t\\t}\\n  1366→\\t\\treturn NoDescription\\n  1367→\\t}\\n  1368→\\n  1369→\\t// No metadataDir provided - first try looking at the root of the tree\\n  1370→\\t// (used when the tree is already the session directory)\\n  1371→\\tif desc := readFirstLine(paths.PromptFileName); desc != \\\"\\\" {\\n  1372→\\t\\treturn desc\\n  1373→\\t}\\n  1374→\\tif desc := readFirstLine(paths.ContextFileName); desc != \\\"\\\" {\\n  1375→\\t\\treturn desc\\n  1376→\\t}\\n  1377→\\n  1378→\\t// Fall back to searching for .entire/metadata/*/prompt.txt or context.md\\n  1379→\\t// (used when the tree i