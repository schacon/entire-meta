eckpoint.CheckpointSummary\\n   336→\\tif err := json.Unmarshal([]byte(content), &summary); err == nil {\\n   337→\\t\\t// If we have sessions array, this is the new format\\n   338→\\t\\tif len(summary.Sessions) > 0 {\\n   339→\\t\\t\\tinfo := &CheckpointInfo{\\n   340→\\t\\t\\t\\tCheckpointID:     summary.CheckpointID,\\n   341→\\t\\t\\t\\tCheckpointsCount: summary.CheckpointsCount,\\n   342→\\t\\t\\t\\tFilesTouched:     summary.FilesTouched,\\n   343→\\t\\t\\t\\tSessionCount:     len(summary.Sessions),\\n   344→\\t\\t\\t}\\n   345→\\n   346→\\t\\t\\t// Read all sessions' metadata to populate SessionIDs and get other fields from first session\\n   347→\\t\\t\\tvar sessionIDs []string\\n   348→\\t\\t\\tfor i, sessionPaths := range summary.Sessions {\\n   349→\\t\\t\\t\\tif sessionPaths.Metadata != \\\"\\\" {\\n   350→\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n   351→\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n   352→\\t\\t\\t\\t\\tsessionMetadataPath := strings.TrimPrefix(sessionPaths.Metadata, \\\"/\\\")\\n   353→\\t\\t\\t\\t\\tif sessionFile, err := tree.File(sessionMetadataPath); err == nil {\\n   354→\\t\\t\\t\\t\\t\\tif sessionContent, err := sessionFile.Contents(); err == nil {\\n   355→\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata checkpoint.CommittedMetadata\\n   356→\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   357→\\t\\t\\t\\t\\t\\t\\t\\tsessionIDs = append(sessionIDs, sessionMetadata.SessionID)\\n   358→\\t\\t\\t\\t\\t\\t\\t\\t// Use first session for Agent, SessionID, CreatedAt, IsTask, ToolUseID\\n   359→\\t\\t\\t\\t\\t\\t\\t\\tif i == 0 {\\n   360→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   361→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   362→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   363→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.IsTask = sessionMetadata.IsTask\\n   364→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.ToolUseID = sessionMetadata.ToolUseID\\n   365→\\t\\t\\t\\t\\t\\t\\t\\t}\\n   366→\\t\\t\\t\\t\\t\\t\\t}\\n   367→\\t\\t\\t\\t\\t\\t}\\n   368→\\t\\t\\t\\t\\t}\\n   369→\\t\\t\\t\\t}\\n   370→\\t\\t\\t}\\n   371→\\t\\t\\tinfo.SessionIDs = sessionIDs\\n   372→\\n   373→\\t\\t\\treturn info, nil\\n   374→\\t\\t}\\n   375→\\t}\\n   376→\\n   377→\\t// Fall back to parsing as CheckpointInfo (old format or direct info)\\n   378→\\tvar metadata CheckpointInfo\\n   379→\\tif err := json.Unmarshal([]byte(content), &metadata); err != nil {\\n   380→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata: %w\\\", err)\\n   381→\\t}\\n   382→\\n   383→\\treturn &metadata, nil\\n   384→}\\n   385→\\n   386→// GetMetadataBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\n   387→func GetMetadataBranchTree(repo *git.Repository) (*object.Tree, error) {\\n   388→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   389→\\tref, err := repo.Reference(refName, true)\\n   390→\\tif err != nil {\\n   391→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch reference: %w\\\", err)\\n   392→\\t}\\n   393→\\n   394→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   395→\\tif err != nil {\\n   396→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch commit: %w\\\", err)\\n   397→\\t}\\n   398→\\n   399→\\ttree, err := commit.Tree()\\n   400→\\tif err != nil {\\n   401→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch tree: %w\\\", err)\\n   402→\\t}\\n   403→\\treturn tree, nil\\n   404→}\\n   405→\\n   406→// ExtractFirstPrompt extracts and truncates the first meaningful prompt from prompt content.\\n   407→// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\". Skips empty prompts and separator-only content.\\n   408→// Returns empty string if no valid prompt is found.\\n   409→func ExtractFirstPrompt(content string) string {\\n   410→\\tif content == \\\"\\\" {\\n   411→\\t\\treturn \\\"\\\"\\n   412→\\t}\\n   413→\\n   414→\\t// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\"\\n   415→\\t// Find the first non-empty prompt\\n   416→\\tprompts := strings.Split(content, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   417→\\tvar firstPrompt string\\n   418→\\tfor _, p := range prompts {\\n   419→\\t\\tcleaned := strings.TrimSpace(p)\\n   420→\\t\\t// Skip empty prompts or prompts that are just dashes/separators\\n   421→\\t\\tif cleaned == \\\"\\\" || isOnlySeparators(cleaned) {\\n   422→\\t\\t\\tcontinue\\n   423→\\t\\t}\\n   424→\\t\\tfirstPrompt = cleaned\\n   425→\\t\\tbreak\\n   426→\\t}\\n   427→\\n   428→\\tif firstPrompt == \\\"\\\" {\\n   429→\\t\\treturn \\\"\\\"\\n   430→\\t}\\n   431→\\n   432→\\treturn TruncateDescription(firstPrompt, MaxDescriptionLength)\\n   433→}\\n   434→\\n   435→// ReadSessionPromptFromTree reads the first meaningful prompt from a checkpoint's prompt.txt file in a git tree.\\n   436→// Returns an empty string if the prompt cannot be read.\\n   437→func ReadSessionPromptFromTree(tree *object.Tree, checkpointPath string) string {\\n   438→\\tpromptPath := checkpointPath + \\\"/\\\" + paths.PromptFileName\\n   439→\\tfile, err := tree.File(promptPath)\\n   440→\\tif err != nil {\\n   441→\\t\\treturn \\\"\\\"\\n   442→\\t}\\n   443→\\n   444→\\tcontent, err := file.Contents()\\n   445→\\tif err != nil {\\n   446→\\t\\treturn \\\"\\\"\\n   447→\\t}\\n   448→\\n   449→\\treturn ExtractFirstPrompt(content)\\n   450→}\\n   451→\\n   452→// ReadAgentTypeFromTree reads the agent type from a checkpoint's metadata.json file in a git tree.\\n   453→// If metadata.json doesn't exist (shadow branches), it falls back to detecting the agent\\n   454→// from the presence of agent-specific config files (.gemini/settings.json or .claude/).\\n   455→// Returns agent.AgentTypeUnknown if the agent type cannot be determined.\\n   456→func ReadAgentTypeFromTree(tree *object.Tree, checkpointPath string) agent.AgentType {\\n   457→\\t// First, try to read from metadata.json (present in condensed/committed checkpoints)\\n   458→\\tmetadataPath := checkpointPath + \\\"/\\\" + paths.MetadataFileName\\n   459→\\tif file, err := tree.File(metadataPath); err == nil {\\n   460→\\t\\tif content, err := file.Contents(); err == nil {\\n   461→\\t\\t\\tvar metadata checkpoint.CommittedMetadata\\n   462→\\t\\t\\tif err := json.Unmarshal([]byte(content), &metadata); err == nil && metadata.Agent != \\\"\\\" {\\n   463→\\t\\t\\t\\treturn metadata.Agent\\n   464→\\t\\t\\t}\\n   465→\\t\\t}\\n   466→\\t}\\n   467→\\n   468→\\t// Fall back to detecting agent from config files (shadow branches don't have metadata.json).\\n   469→\\t// Order: Gemini (most specific check), Claude (established default), OpenCode (newest/preview).\\n   470→\\tif _, err := tree.File(\\\".gemini/settings.json\\\"); err == nil {\\n   471→\\t\\treturn agent.AgentTypeGemini\\n   472→\\t}\\n   473→\\tif _, err := tree.Tree(\\\".claude\\\"); err == nil {\\n   474→\\t\\treturn agent.AgentTypeClaudeCode\\n   475→\\t}\\n   476→\\t// OpenCode: .opencode directory or opencode.json config\\n   477→\\tif _, err := tree.Tree(\\\".opencode\\\"); err == nil {\\n   478→\\t\\treturn agent.AgentTypeOpenCode\\n   479→\\t}\\n   480→\\tif _, err := tree.File(\\\"opencode.json\\\"); err == nil {\\n   481→\\t\\treturn agent.AgentTypeOpenCode\\n   482→\\t}\\n   483→\\n   484→\\treturn agent.AgentTypeUnknown\\n   485→}\\n   486→\\n   487→// isOnlySeparators checks if a string contains only dashes, spaces, and newlines.\\n   488→func isOnlySeparators(s string) bool {\\n   489→\\tfor _, r := range s {\\n   490→\\t\\tif r != '-' && r != ' ' && r != '\\\\n' && r != '\\\\r' && r != '\\\\t' {\\n   491→\\t\\t\\treturn false\\n   492→\\t\\t}\\n   493→\\t}\\n   494→\\treturn true\\n   495→}\\n   496→\\n   497→// ReadAllSessionPromptsFromTree reads the first prompt for all sessions in a multi-session checkpoint.\\n   498→// Returns a slice of prompts parallel to sessionIDs (oldest to newest).\\n   499→// For single-session checkpoints, returns a slice with just the root prompt.\\n   500→func ReadAllSessionPromptsFromTree(tree *object.Tree, checkpointPath string, sessionCount int, sessionIDs []string) []string {\\n   501→\\tif sessionCount <= 1 || len(sessionIDs) <= 1 {\\n   502→\\t\\t// Single session - just return the root prompt\\n   503→\\t\\tprompt := ReadSessionPromptFromTree(tree, checkpointPath)\\n   504→\\t\\tif prompt != \\\"\\\" {\\n   505→\\t\\t\\treturn []string{prompt}\\n   506→\\t\\t}\\n   507→\\t\\treturn nil\\n   508→\\t}\\n   509→\\n   510→\\t// Multi-session: read prompts from archived folders (0/, 1/, etc.) and root\\n   511→\\tprompts := make([]string, len(sessionIDs))\\n   512→\\n   513→\\t// Read archived session prompts (folders 0, 1, ... N-2)\\n   514→\\tfor i := range sessionCount - 1 {\\n   515→\\t\\tarchivedPath := fmt.Sprintf(\\\"%s/%d\\\", checkpointPath, i)\\n   516→\\t\\tprompts[i] = ReadSessionPromptFromTree(tree, archivedPath)\\n   517→\\t}\\n   518→\\n   519→\\t// Read the most recent session prompt (at root level)\\n   520→\\tprompts[len(prompts)-1] = ReadSessionPromptFromTree(tree, checkpointPath)\\n   521→\\n   522→\\treturn prompts\\n   523→}\\n   524→\\n   525→// GetRemoteMetadataBranchTree returns the tree object for origin/entire/checkpoints/v1.\\n   526→func GetRemoteMetadataBranchTree(repo *git.Repository) (*object.Tree, error) {\\n   527→\\trefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n   528→\\tref, err := repo.Reference(refName, true)\\n   529→\\tif err != nil {\\n   530→\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch reference: %w\\\", err)\\n   531→\\t}\\n   532→\\n   533→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   534→\\tif err != nil {\\n   535→\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch commit: %w\\\", err)\\n   536→\\t}\\n   537→\\n   538→\\ttree, err := commit.Tree()\\n   539→\\tif err != nil {\\n   540→\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch tree: %w\\\", err)\\n   541→\\t}\\n   542→\\treturn tree, nil\\n   543→}\\n   544→\\n   545→// OpenRepository opens the git repository with linked worktree support enabled.\\n   546→// It uses git.PlainOpenWithOptions with EnableDotGitCommonDir set to true,\\n   547→// which is required for proper operation in git worktrees created via 'git worktree add'.\\n   548→//\\n   549→// Without EnableDotGitCommonDir, go-git operations in worktrees can silently fail:\\n   550→// - Commits appear to succeed but are not persisted\\n   551→// - Refs are written to incorrect locations\\n   552→// - The worktree's HEAD/index don't get updated properly\\n   553→//\\n   554→// This happens because worktrees use .git as a file (pointing to the main repo)\\n   555→// rather than a directory, and go-git needs to route paths correctly between\\n   556→// shared (.git/) and per-worktree (.git/worktrees/<name>/) locations.\\n   557→//\\n   558→// The function first uses 'git rev-parse --show-toplevel' to find the repository\\n   559→// root, which works correctly even when called from a subdirectory within the repo.\\n   560→func OpenRepository() (*git.Repository, error) {\\n   561→\\trepoRoot, err := paths.RepoRoot()\\n   562→\\tif err != nil {\\n   563→\\t\\t// Fallback to current directory if git command fails\\n   564→\\t\\t// (e.g., if git is not installed or we're not in a repo)\\n   565→\\t\\trepoRoot = \\\".\\\"\\n   566→\\t}\\n   567→\\n   568→\\trepo, err := git.PlainOpenWithOptions(repoRoot, &git.PlainOpenOptions{\\n   569→\\t\\tEnableDotGitCommonDir: true,\\n   570→\\t})\\n   571→\\tif err != nil {\\n   572→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   573→\\t}\\n   574→\\treturn repo, nil\\n   575→}\\n   576→\\n   577→// IsInsideWorktree returns true if the current directory is inside a git worktree\\n   578→// (as opposed to the main repository). Worktrees have .git as a file pointing\\n   579→// to the main repo, while the main repo has .git as a directory.\\n   580→// This function works correctly from any subdirectory within the repository.\\n   581→func IsInsideWorktree() bool {\\n   582→\\t// First find the repository root\\n   583→\\trepoRoot, err := GetWorktreePath()\\n   584→\\tif err != nil {\\n   585→\\t\\treturn false\\n   586→\\t}\\n   587→\\n   588→\\tgitPath := filepath.Join(repoRoot, gitDir)\\n   589→\\tgitInfo, err := os.Stat(gitPath)\\n   590→\\tif err != nil {\\n   591→\\t\\treturn false\\n   592→\\t}\\n   593→\\treturn !gitInfo.IsDir()\\n   594→}\\n   595→\\n   596→// GetMainRepoRoot returns the root directory of the main repository.\\n   597→// In the main repo, this is the worktree path (repo root).\\n   598→// In a worktree, this parses the .git file to find the main repo.\\n   599→// This function works correctly from any subdirectory within the repository.\\n   600→//\\n   601→// Per gitrepository-layout(5), a worktree's .git file is a \\\"gitfile\\\" containing\\n   602→// \\\"gitdir: <path>\\\" pointing to $GIT_DIR/worktrees/<id> in the main repository.\\n   603→// See: https://git-scm.com/docs/gitrepository-layout\\n   604→func GetMainRepoRoot() (string, error) {\\n   605→\\t// First find the worktree/repo root\\n   606→\\trepoRoot, err := GetWorktreePath()\\n   607→\\tif err != nil {\\n   608→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get worktree path: %w\\\", err)\\n   609→\\t}\\n   610→\\n   611→\\tif !IsInsideWorktree() {\\n   612→\\t\\treturn repoRoot, nil\\n   613→\\t}\\n   614→\\n   615→\\t// Worktree .git file contains: \\\"gitdir: /path/to/main/.git/worktrees/<id>\\\"\\n   616→\\tgitFilePath := filepath.Join(repoRoot, gitDir)\\n   617→\\tcontent, err := os.ReadFile(gitFilePath) //nolint:gosec // G304: gitFilePath is constructed from repo root, not user input\\n   618→\\tif err != nil {\\n   619→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read .git file: %w\\\", err)\\n   620→\\t}\\n   621→\\n   622→\\tgitdir := strings.TrimSpace(string(content))\\n   623→\\tgitdir = strings.TrimPrefix(gitdir, \\\"gitdir: \\\")\\n   624→\\n   625→\\t// Extract main repo root: everything before \\\"/.git/\\\"\\n   626→\\tidx := strings.LastIndex(gitdir, \\\"/.git/\\\")\\n   627→\\tif idx < 0 {\\n   628→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"unexpected gitdir format: %s\\\", gitdir)\\n   629→\\t}\\n   630→\\treturn gitdir[:idx], nil\\n   631→}\\n   632→\\n   633→// GetGitCommonDir returns the path to the shared git directory.\\n   634→// In a regular checkout, this is .git/\\n   635→// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n   636→// Uses git rev-parse --git-common-dir for reliable handling of worktrees.\\n   637→func GetGitCommonDir() (string, error) {\\n   638→\\tctx := context.Background()\\n   639→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-common-dir\\\")\\n   640→\\tcmd.Dir = \\\".\\\"\\n   641→\\toutput, err := cmd.Output()\\n   642→\\tif err != nil {\\n   643→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   644→\\t}\\n   645→\\n   646→\\tcommonDir := strings.TrimSpace(string(output))\\n   647→\\n   648→\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\n   649→\\t// so we need to make it absolute if it isn't already\\n   650→\\tif !filepath.IsAbs(commonDir) {\\n   651→\\t\\tcommonDir = filepath.Join(\\\".\\\", commonDir)\\n   652→\\t}\\n   653→\\n   654→\\treturn filepath.Clean(commonDir), nil\\n   655→}\\n   656→\\n   657→// GetWorktreePath returns the absolute path to the current worktree root.\\n   658→// This is the working directory path, not the git directory.\\n   659→// In a worktree, this returns the worktree's own root (not the main repo).\\n   660→// The result is cached per working directory via paths.RepoRoot().\\n   661→func GetWorktreePath() (string, error) {\\n   662→\\troot, err := paths.RepoRoot()\\n   663→\\tif err != nil {\\n   664→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get worktree path: %w\\\", err)\\n   665→\\t}\\n   666→\\treturn root, nil\\n   667→}\\n   668→\\n   669→// ClearWorktreePathCache clears the cached worktree path.\\n   670→// This is primarily useful for testing when changing directories.\\n   671→func ClearWorktreePathCache() {\\n   672→\\tpaths.ClearRepoRootCache()\\n   673→}\\n   674→\\n   675→// EnsureEntireGitignore ensures all required entries are in .entire/.gitignore\\n   676→// Works correctly from any subdirectory within the repository.\\n   677→func EnsureEntireGitignore() error {\\n   678→\\t// Get absolute path for the gitignore file\\n   679→\\tgitignoreAbs, err := paths.AbsPath(entireGitignore)\\n   680→\\tif err != nil {\\n   681→\\t\\tgitignoreAbs = entireGitignore // Fallback to relative\\n   682→\\t}\\n   683→\\n   684→\\t// Read existing content\\n   685→\\tvar content string\\n   686→\\tif data, err := os.ReadFile(gitignoreAbs); err == nil { //nolint:gosec // path is from AbsPath or constant\\n   687→\\t\\tcontent = string(data)\\n   688→\\t}\\n   689→\\n   690→\\t// All entries that should be in .entire/.gitignore\\n   691→\\trequiredEntries := []string{\\n   692→\\t\\t\\\"tmp/\\\",\\n   693→\\t\\t\\\"settings.local.json\\\",\\n   694→\\t\\t\\\"metadata/\\\",\\n   695→\\t\\t\\\"logs/\\\",\\n   696→\\t}\\n   697→\\n   698→\\t// Track what needs to be added\\n   699→\\tvar toAdd []string\\n   700→\\tfor _, entry := range requiredEntries {\\n   701→\\t\\tif !strings.Contains(content, entry) {\\n   702→\\t\\t\\ttoAdd = append(toAdd, entry)\\n   703→\\t\\t}\\n   704→\\t}\\n   705→\\n   706→\\t// Nothing to add\\n   707→\\tif len(toAdd) == 0 {\\n   708→\\t\\treturn nil\\n   709→\\t}\\n   710→\\n   711→\\t// Ensure .entire directory exists\\n   712→\\tif err := os.MkdirAll(filepath.Dir(gitignoreAbs), 0o750); err != nil {\\n   713→\\t\\treturn fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   714→\\t}\\n   715→\\n   716→\\t// Append missing entries to gitignore\\n   717→\\tvar sb strings.Builder\\n   718→\\tfor _, entry := range toAdd {\\n   719→\\t\\tsb.WriteString(entry + \\\"\\\\n\\\")\\n   720→\\t}\\n   721→\\tcontent += sb.String()\\n   722→\\n   723→\\tif err := os.WriteFile(gitignoreAbs, []byte(content), 0o644); err != nil { //nolint:gosec // path is from AbsPath or constant\\n   724→\\t\\treturn fmt.Errorf(\\\"failed to write gitignore: %w\\\", err)\\n   725→\\t}\\n   726→\\treturn nil\\n   727→}\\n   728→\\n   729→// checkCanRewind checks if working directory is clean enough for rewind.\\n   730→// Returns (canRewind, reason, error). Shared by shadow and linear-shadow strategies.\\n   731→func checkCanRewind() (bool, string, error) {\\n   732→\\trepo, err := OpenRepository()\\n   733→\\tif err != nil {\\n   734→\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   735→\\t}\\n   736→\\n   737→\\tworktree, err := repo.Worktree()\\n   738→\\tif err != nil {\\n   739→\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   740→\\t}\\n   741→\\n   742→\\tstatus, err := worktree.Status()\\n   743→\\tif err != nil {\\n   744→\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n   745→\\t}\\n   746→\\n   747→\\tif status.IsClean() {\\n   748→\\t\\treturn true, \\\"\\\", nil\\n   749→\\t}\\n   750→\\n   751→\\tvar modified, added, deleted []string\\n   752→\\tfor file, st := range status {\\n   753→\\t\\t// Skip .entire directory\\n   754→\\t\\tif paths.IsInfrastructurePath(file) {\\n   755→\\t\\t\\tcontinue\\n   756→\\t\\t}\\n   757→\\n   758→\\t\\t// Skip untracked files\\n   759→\\t\\tif st.Worktree == git.Untracked {\\n   760→\\t\\t\\tcontinue\\n   761→\\t\\t}\\n   762→\\n   763→\\t\\tswitch {\\n   764→\\t\\tcase st.Staging == git.Added || st.Worktree == git.Added:\\n   765→\\t\\t\\tadded = append(added, file)\\n   766→\\t\\tcase st.Staging == git.Deleted || st.Worktree == git.Deleted:\\n   767→\\t\\t\\tdeleted = append(deleted, file)\\n   768→\\t\\tcase st.Staging == git.Modified || st.Worktree == git.Modified:\\n   769→\\t\\t\\tmodified = append(modified, file)\\n   770→\\t\\t}\\n   771→\\t}\\n   772→\\n   773→\\tif len(modified) == 0 && len(added) == 0 && len(deleted) == 0 {\\n   774→\\t\\treturn true, \\\"\\\", nil\\n   775→\\t}\\n   776→\\n   777→\\tvar msg strings.Builder\\n   778→\\tmsg.WriteString(\\\"You have uncommitted changes:\\\\n\\\")\\n   779→\\tfor _, f := range modified {\\n   780→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  modified:   %s\\\\n\\\", f))\\n   781→\\t}\\n   782→\\tfor _, f := range added {\\n   783→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  added:      %s\\\\n\\\", f))\\n   784→\\t}\\n   785→\\tfor _, f := range deleted {\\n   786→\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  deleted:    %s\\\\n\\\", f))\\n   787→\\t}\\n   788→\\tmsg.WriteString(\\\"\\\\nPlease commit or stash your changes before rewinding.\\\")\\n   789→\\n   790→\\treturn false, msg.String(), nil\\n   791→}\\n   792→\\n   793→// checkCanRewindWithWarning checks working directory and returns a warning with diff stats.\\n   794→// Unlike checkCanRewind, this always returns canRewind=true but includes a warning message\\n   795→// with +/- line stats for uncommitted changes. Used by manual-commit strategy.\\n   796→func checkCanRewindWithWarning() (bool, string, error) {\\n   797→\\trepo, err := OpenRepository()\\n   798→\\tif err != nil {\\n   799→\\t\\t// Can't open repo - still allow rewind but without stats\\n   800→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if repo can't be opened\\n   801→\\t}\\n   802→\\n   803→\\tworktree, err := repo.Worktree()\\n   804→\\tif err != nil {\\n   805→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if worktree can't be accessed\\n   806→\\t}\\n   807→\\n   808→\\tstatus, err := worktree.Status()\\n   809→\\tif err != nil {\\n   810→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if status can't be retrieved\\n   811→\\t}\\n   812→\\n   813→\\tif status.IsClean() {\\n   814→\\t\\treturn true, \\\"\\\", nil\\n   815→\\t}\\n   816→\\n   817→\\t// Get HEAD commit tree for comparison - if we can't get it, just return without stats\\n   818→\\thead, err := repo.Head()\\n   819→\\tif err != nil {\\n   820→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even without HEAD (e.g., empty repo)\\n   821→\\t}\\n   822→\\n   823→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   824→\\tif err != nil {\\n   825→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if commit lookup fails\\n   826→\\t}\\n   827→\\n   828→\\theadTree, err := headCommit.Tree()\\n   829→\\tif err != nil {\\n   830→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if tree lookup fails\\n   831→\\t}\\n   832→\\n   833→\\ttype fileChange struct {\\n   834→\\t\\tstatus   string // \\\"modified\\\", \\\"added\\\", \\\"deleted\\\"\\n   835→\\t\\tadded    int\\n   836→\\t\\tremoved  int\\n   837→\\t\\tfilename string\\n   838→\\t}\\n   839→\\n   840→\\tvar changes []fileChange\\n   841→\\t// Use repo root, not cwd - git status returns paths relative to repo root\\n   842→\\trepoRoot, err := GetWorktreePath()\\n   843→\\tif err != nil {\\n   844→\\t\\treturn true, \\\"\\\", nil //nolint:nilerr // Rewind allowed even if repo root lookup fails\\n   845→\\t}\\n   846→\\n   847→\\tfor file, st := range status {\\n   848→\\t\\t// Skip .entire directory\\n   849→\\t\\tif paths.IsInfrastructurePath(file) {\\n   850→\\t\\t\\tcontinue\\n   851→\\t\\t}\\n   852→\\n   853→\\t\\t// Skip untracked files\\n   854→\\t\\tif st.Worktree == git.Untracked {\\n   855→\\t\\t\\tcontinue\\n   856→\\t\\t}\\n   857→\\n   858→\\t\\tvar change fileChange\\n   859→\\t\\tchange.filename = file\\n   860→\\n   861→\\t\\tswitch