eliable handling of worktrees.\\nfunc GetGitCommonDir() (string, error) {\\n\\tctx := context.Background()\\n\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-common-dir\\\")\\n\\tcmd.Dir = \\\".\\\"\\n\\toutput, err := cmd.Output()\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n\\t}\\n\\n\\tcommonDir := strings.TrimSpace(string(output))\\n\\n\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\n\\t// so we need to make it absolute if it isn't already\\n\\tif !filepath.IsAbs(commonDir) {\\n\\t\\tcommonDir = filepath.Join(\\\".\\\", commonDir)\\n\\t}\\n\\n\\treturn filepath.Clean(commonDir), nil\\n}\\n\\n// GetWorktreePath returns the absolute path to the current worktree root.\",\"numLines\":60,\"startLine\":598,\"totalLines\":1520}},\"sourceToolAssistantUUID\":\"636b9190-6832-4d4e-9037-40b4aadb8825\"}\n{\"parentUuid\":\"4ab95432-decc-427d-a44a-6f4b20cccc26\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/evisdrenova/code/entire/devenv/cli\",\"sessionId\":\"408b8c7a-970e-44d6-97d2-5055b778a417\",\"version\":\"2.1.42\",\"gitBranch\":\"commit_optimizations\",\"slug\":\"greedy-crunching-rabbit\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01P9NZDGJGrGVMVi2qQtbXgP\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"So the codebase already has three distinct functions for three distinct things:\\n\\n| Function | What it returns | Example from worktree at `/wt` with main repo at `/repo` |\\n|---|---|---|\\n| `GetWorktreePath()` / `paths.RepoRoot()` | Working tree toplevel (`git rev-parse --show-toplevel`) | `/wt` |\\n| `GetMainRepoRoot()` | Main repository root (parses `.git` gitfile) | `/repo` |\\n| `GetGitCommonDir()` | Shared `.git/` directory (`git rev-parse --git-common-dir`) | `/repo/.git` |\\n\\n**The answer to your question:** `GetWorktreePath()` and `paths.RepoRoot()` do the ex