d before the rewind.\\n   322→\\t// Returns nil if preview is not supported\\n   323→\\tPreviewRewind(ctx context.Context, point RewindPoint) (*RewindPreview, error)\\n   324→\\n   325→\\t// GetTaskCheckpoint returns the task checkpoint for a given rewind point.\\n   326→\\t// For strategies that store checkpoints on disk (commit, manual-commit), this reads from the filesystem.\\n   327→\\t// Returns nil, nil if not a task checkpoint or checkpoint not found.\\n   328→\\tGetTaskCheckpoint(ctx context.Context, point RewindPoint) (*TaskCheckpoint, error)\\n   329→\\n   330→\\t// GetTaskCheckpointTranscript returns the session transcript for a task checkpoint.\\n   331→\\t// For strategies that store transcripts on disk (commit, manual-commit), this reads from the filesystem.\\n   332→\\tGetTaskCheckpointTranscript(ctx context.Context, point RewindPoint) ([]byte, error)\\n   333→\\n   334→\\t// GetSessionInfo returns session information for linking commits.\\n   335→\\t// This is used by the context command to generate trailers.\\n   336→\\t// Returns ErrNoSession if no session info is available.\\n   337→\\tGetSessionInfo(ctx context.Context) (*SessionInfo, error)\\n   338→\\n   339→\\t// NOTE: ListSessions and GetSession are standalone functions in session.go.\\n   340→\\t// They read from entire/checkpoints/v1 and merge with SessionSource if implemented.\\n   341→\\n   342→\\t// GetMetadataRef returns a reference to the metadata commit for the given checkpoint.\\n   343→\\t// Format: \\\"<branch>@<commit-sha>\\\" (e.g., \\\"entire/checkpoints/v1@abc123\\\").\\n   344→\\t// Returns empty string if not applicable (e.g., commit strategy with filesystem metadata).\\n   345→\\tGetMetadataRef(ctx context.Context, checkpoint Checkpoint) string\\n   346→\\n   347→\\t// GetSessionMetadataRef returns a reference to the most recent metadata commit for a session.\\n   348→\\t// Format: \\\"<branch>@<commit-sha>\\\" (e.g., \\\"entire/checkpoints/v1@abc123\\\").\\n   349→\\t// Returns empty string if not applicable or session not found.\\n   350→\\tGetSessionMetadataRef(ctx context.Context, sessionID string) string\\n   351→\\n   352→\\t// GetSessionContext returns the context.md content for a session.\\n   353→\\t// Returns empty string if not available.\\n   354→\\tGetSessionContext(ctx context.Context, sessionID string) string\\n   355→\\n   356→\\t// GetCheckpointLog returns the session transcript for a specific checkpoint.\\n   357→\\t// For strategies that store transcripts in git branches (manual-commit),\\n   358→\\t// this reads from the checkpoint's commit tree.\\n   359→\\t// For strategies that store on disk (commit), reads from the filesystem.\\n   360→\\t// Returns ErrNoMetadata if transcript is not available.\\n   361→\\tGetCheckpointLog(ctx context.Context, checkpoint Checkpoint) ([]byte, error)\\n   362→\\t// InitializeSession creates session state for a new session.\\n   363→\\t// Called during UserPromptSubmit hook before any checkpoints are created.\\n   364→\\t// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n   365→\\t// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n   366→\\t// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\n   367→\\tInitializeSession(ctx context.Context, sessionID string, agentType agent.AgentType, transcriptPath string, userPrompt string) error\\n   368→\\t// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   369→\\t// It can modify the commit message file to add trailers, etc.\\n   370→\\t// The source parameter indicates how the commit was initiated:\\n   371→\\t//   - \\\"\\\" or \\\"template\\\": normal editor flow\\n   372→\\t//   - \\\"message\\\": using -m or -F flag\\n   373→\\t//   - \\\"merge\\\": merge commit\\n   374→\\t//   - \\\"squash\\\": squash merge\\n   375→\\t//   - \\\"commit\\\": amend with -c/-C\\n   376→\\t// Should return nil on errors to not block commits (log warnings to stderr).\\n   377→\\tPrepareCommitMsg(ctx context.Context, commitMsgFile string, source string) error\\n   378→\\t// PostCommit is called by the git post-commit hook after a commit is created.\\n   379→\\t// Used to perform actions like condensing session data after commits.\\n   380→\\t// Should return nil on errors to not block subsequent operations (log warnings to stderr).\\n   381→\\tPostCommit(ctx context.Context) error\\n   382→\\t// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   383→\\t// Used to validate or modify the final commit message before the commit is created.\\n   384→\\t// If this returns an error, the commit is aborted.\\n   385→\\tCommitMsg(ctx context.Context, commitMsgFile string) error\\n   386→\\t// PrePush is called by the git pre-push hook before pushing to a remote.\\n   387→\\t// Used to push session branches (e.g., entire/checkpoints/v1) alongside user pushes.\\n   388→\\t// The remote parameter is the name of the remote being pushed to.\\n   389→\\t// Should return nil on errors to not block pushes (log warnings to stderr).\\n   390→\\tPrePush(ctx context.Context, remote string) error\\n   391→\\t// HandleTurnEnd performs strategy-specific cleanup at the end of a turn.\\n   392→\\t// Work items are read from state (e.g. TurnCheckpointIDs), not from the\\n   393→\\t// action list. The state has already been updated by ApplyTransition;\\n   394→\\t// the caller saves it after this method returns.\\n   395→\\tHandleTurnEnd(ctx context.Context, state *session.State) error\\n   396→\\t// RestoreLogsOnly restores session logs from a logs-only rewind point.\\n   397→\\t// Does not modify the working directory - only restores the transcript\\n   398→\\t// to the agent's session directory (determined per-session from checkpoint metadata).\\n   399→\\t// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   400→\\t// Returns info about each 