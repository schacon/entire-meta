\t}\\n   170→\\n   171→\\t// Setup .entire directory\\n   172→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   173→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   174→\\t}\\n   175→\\n   176→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   177→\\tsettings, err := LoadEntireSettings(ctx)\\n   178→\\tif err != nil {\\n   179→\\t\\t// If we can't load, start with defaults\\n   180→\\t\\tsettings = &EntireSettings{}\\n   181→\\t}\\n   182→\\t// Update the specific fields\\n   183→\\tsettings.LocalDev = localDev\\n   184→\\tsettings.Enabled = true\\n   185→\\n   186→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   187→\\tif skipPushSessions {\\n   188→\\t\\tif settings.StrategyOptions == nil {\\n   189→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   190→\\t\\t}\\n   191→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   192→\\t}\\n   193→\\n   194→\\t// Determine which settings file to write to\\n   195→\\t// First run always creates settings.json (no prompt)\\n   196→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   197→\\tif err != nil {\\n   198→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   199→\\t}\\n   200→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   201→\\n   202→\\tif showNotification {\\n   203→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   204→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   205→\\t}\\n   206→\\n   207→\\t// Helper to save settings to the appropriate file\\n   208→\\tsaveSettings := func() error {\\n   209→\\t\\tif shouldUseLocal {\\n   210→\\t\\t\\treturn SaveEntireSettingsLocal(ctx, settings)\\n   211→\\t\\t}\\n   212→\\t\\treturn SaveEntireSettings(ctx, settings)\\n   213→\\t}\\n   214→\\n   215→\\t// Save settings before telemetry prompt so config is persisted even if the user cancels\\n   216→\\tif err := saveSettings(); err != nil {\\n   217→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   218→\\t}\\n   219→\\n   220→\\tif _, err := strategy.InstallGitHook(ctx, true, localDev); err != nil {\\n   221→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   222→\\t}\\n   223→\\tstrategy.CheckAndWarnHookManagers(ctx, w, localDev)\\n   224→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   225→\\n   226→\\tconfigDisplay := configDisplayProject\\n   227→\\tif shouldUseLocal {\\n   228→\\t\\tconfigDisplay = configDisplayLocal\\n   229→\\t}\\n   230→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   231→\\n   232→\\t// Ask about telemetry consent (only if not already asked)\\n   233→\\tfmt.Fprintln(w)\\n   234→\\tif err := promptTelemetryConsent(settings, telemetry); err != nil {\\n   235→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   236→\\t}\\n   237→\\t// Save again to persist telemetry choice\\n   238→\\tif err := saveSettings(); err != nil {\\n   239→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   240→\\t}\\n   241→\\n   242→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   243→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   244→\\t}\\n   245→\\n   246→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   247→\\n   248→\\treturn nil\\n   249→}\\n   250→\\n   251→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   252→func runEnable(ctx context.Context, w io.Writer) error {\\n   253→\\tsettings, err := LoadEntireSettings(ctx)\\n   254→\\tif err != nil {\\n   255→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   256→\\t}\\n   257→\\n   258→\\tsettings.Enabled = true\\n   259→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   260→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   261→\\t}\\n   262→\\n   263→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   264→\\treturn nil\\n   265→}\\n   266→\\n   267→func runDisable(ctx context.Context, w io.Writer, useProjectSettings bool) error {\\n   268→\\tsettings, err := LoadEntireSettings(ctx)\\n   269→\\tif err != nil {\\n   270→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   271→\\t}\\n   272→\\n   273→\\tsettings.Enabled = false\\n   274→\\n   275→\\t// If --project flag is specified, always write to project settings\\n   276→\\tif useProjectSettings {\\n   277→\\t\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   278→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   279→\\t\\t}\\n   280→\\t} else {\\n   281→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   282→\\t\\tif err := SaveEntireSettingsLocal(ctx, settings); err != nil {\\n   283→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   284→\\t\\t}\\n   285→\\t}\\n   286→\\n   287→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   288→\\treturn nil\\n   289→}\\n   290→\\n   291→// DisabledMessage is the message shown when Entire is disabled\\n   292→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   293→\\n   294→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   295→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   296→// On error reading settings, defaults to enabled (returns false).\\n   297→func checkDisabledGuard(ctx context.Context, w io.Writer) bool {\\n   298→\\tenabled, err := IsEnabled(ctx)\\n   299→\\tif err != nil {\\n   300→\\t\\t// Default to enabled on error\\n   301→\\t\\treturn false\\n   302→\\t}\\n   303→\\tif !enabled {\\n   304→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   305→\\t\\treturn true\\n   306→\\t}\\n   307→\\treturn false\\n   308→}\\n   309→\\n   310→// uninstallDeselectedAgentHooks removes hooks for agents that were previously\\n   311→// installed but are not in the selected list. This handles the case where a user\\n   312→// re-runs `entire enable` and deselects an agent.\\n   313→func uninstallDeselectedAgentHooks(ctx context.Context, w io.Writer, selectedAgents []agent.Agent) error {\\n   314→\\tinstalledNames := GetAgentsWithHooksInstalled(ctx)\\n   315→\\tif len(installedNames) == 0 {\\n   316→\\t\\treturn nil\\n   317→\\t}\\n   318→\\n   319→\\tselectedSet := make(map[agent.AgentName]struct{}, len(selectedAgents))\\n   320→\\tfor _, ag := range selectedAgents {\\n   321→\\t\\tselectedSet[ag.Name()] = struct{}{}\\n   322→\\t}\\n   323→\\n   324→\\tvar errs []error\\n   325→\\tfor _, name := range installedNames {\\n   326→\\t\\tif _, selected := selectedSet[name]; selected {\\n   327→\\t\\t\\tcontinue\\n   328→\\t\\t}\\n   329→\\t\\tag, err := agent.Get(name)\\n   330→\\t\\tif err != nil {\\n   331→\\t\\t\\tcontinue\\n   332→\\t\\t}\\n   333→\\t\\thookAgent, ok := ag.(agent.HookSupport)\\n   334→\\t\\tif !ok {\\n   335→\\t\\t\\tcontinue\\n   336→\\t\\t}\\n   337→\\t\\tif err := hookAgent.UninstallHooks(ctx); err != nil {\\n   338→\\t\\t\\terrs = append(errs, fmt.Errorf(\\\"failed to uninstall %s hooks: %w\\\", ag.Type(), err))\\n   339→\\t\\t} else {\\n   340→\\t\\t\\tfmt.Fprintf(w, \\\"Removed %s hooks\\\\n\\\", ag.Type())\\n   341→\\t\\t}\\n   342→\\t}\\n   343→\\treturn errors.Join(errs...)\\n   344→}\\n   345→\\n   346→// setupAgentHooks sets up hooks for a given agent.\\n   347→// Returns the number of hooks installed (0 if already installed).\\n   348→func setupAgentHooks(ctx context.Context, ag agent.Agent, localDev, forceHooks bool) (int, error) {\\n   349→\\thookAgent, ok := ag.(agent.HookSupport)\\n   350→\\tif !ok {\\n   351→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   352→\\t}\\n   353→\\n   354→\\tcount, err := hookAgent.InstallHooks(ctx, localDev, forceHooks)\\n   355→\\tif err != nil {\\n   356→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   357→\\t}\\n   358→\\n   359→\\treturn count, nil\\n   360→}\\n   361→\\n   362→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   363→// Returns the detected/selected agents and any error.\\n   364→//\\n   365→// On first run (no hooks installed):\\n   366→//   - Single detected agent: used automatically\\n   367→//   - Multiple/no detected agents: interactive multi-select prompt\\n   368→//\\n   369→// On re-run (hooks already installed):\\n   370→//   - Always shows the interactive multi-select\\n   371→//   - Pre-selects only agents that have hooks installed (respects prior deselection)\\n   372→//\\n   373→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   374→// It receives available agent names and returns the selected names.\\n   375→func detectOrSelectAgent(ctx context.Context, w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   376→\\t// Check for agents with hooks already installed (re-run detection)\\n   377→\\tinstalledAgentNames := GetAgentsWithHooksInstalled(ctx)\\n   378→\\thasInstalledHooks := len(installedAgentNames) > 0\\n   379→\\n   380→\\t// Try auto-detection\\n   381→\\tdetected := agent.DetectAll(ctx)\\n   382→\\n   383→\\t// First run: use existing auto-detect shortcuts\\n   384→\\tif !hasInstalledHooks {\\n   385→\\t\\tswitch {\\n   386→\\t\\tcase len(detected) == 1:\\n   387→\\t\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   388→\\t\\t\\treturn detected, nil\\n   389→\\n   390→\\t\\tcase len(detected) > 1:\\n   391→\\t\\t\\tagentTypes := make([]string, 0, len(detected))\\n   392→\\t\\t\\tfor _, ag := range detected {\\n   393→\\t\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   394→\\t\\t\\t}\\n   395→\\t\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   396→\\t\\t\\tfmt.Fprintln(w)\\n   397→\\t\\t}\\n   398→\\t}\\n   399→\\n   400→\\t// Check if we can prompt interactively\\n   401→\\tif !canPromptInteractively() {\\n   402→\\t\\tif hasInstalledHooks {\\n   403→\\t\\t\\t// Re-run without TTY — keep currently installed agents\\n   404→\\t\\t\\tagents := make([]agent.Agent, 0, len(installedAgentNames))\\n   405→\\t\\t\\tfor _, name := range installedAgentNames {\\n   406→\\t\\t\\t\\tag, err := agent.Get(name)\\n   407→\\t\\t\\t\\tif err != nil {\\n   408→\\t\\t\\t\\t\\tcontinue\\n   409→\\t\\t\\t\\t}\\n   410→\\t\\t\\t\\tagents = append(agents, ag)\\n   411→\\t\\t\\t}\\n   412→\\t\\t\\treturn agents, nil\\n   413→\\t\\t}\\n   414→\\t\\tif len(detected) > 0 {\\n   415→\\t\\t\\treturn detected, nil\\n   416→\\t\\t}\\n   417→\\t\\tdefaultAgent := agent.Default()\\n   418→\\t\\tif defaultAgent == nil {\\n   419→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   420→\\t\\t}\\n   421→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   422→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   423→\\t}\\n   424→\\n   425→\\tif !hasInstalledHooks && len(detected) == 0 {\\n   426→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., \\\"+strings.Join(agent.StringList(), \\\", \\\")+\\\").\\\")\\n   427→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   428→\\t\\tfmt.Fprintln(w)\\n   429→\\t}\\n   430→\\n   431→\\t// Build pre-selection set.\\n   432→\\t// On re-run: only pre-select agents with hooks installed (respect prior deselection).\\n   433→\\t// On first run: pre-select all detected agents.\\n   434→\\tpreSelectedSet := make(map[agent.AgentName]struct{})\\n   435→\\tif hasInstalledHooks {\\n   436→\\t\\tfor _, name := range installedAgentNames {\\n   437→\\t\\t\\tpreSelectedSet[name] = struct{}{}\\n   438→\\t\\t}\\n   439→\\t} else {\\n   440→\\t\\tfor _, ag := range detected {\\n   441→\\t\\t\\tpreSelectedSet[ag.Name()] = struct{}{}\\n   442→\\t\\t}\\n   443→\\t}\\n   444→\\n   445→\\t// Build options from registered agents\\n   446→\\tagentNames := agent.List()\\n   447→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   448→\\tfor _, name := range agentNames {\\n   449→\\t\\tag, err := agent.Get(name)\\n   450→\\t\\tif err != nil {\\n   451→\\t\\t\\tcontinue\\n   452→\\t\\t}\\n   453→\\t\\t// Only show agents that support hooks\\n   454→\\t\\tif _, ok := ag.(agent.HookSupport); !ok {\\n   455→\\t\\t\\tcontinue\\n   456→\\t\\t}\\n   457→\\t\\topt := huh.NewOption(string(ag.Type()), string(name))\\n   458→\\t\\tif _, isPreSelected := preSelectedSet[name]; isPreSelected {\\n   459→\\t\\t\\topt = opt.Selected(true)\\n   460→\\t\\t}\\n   461→\\t\\toptions = append(options, opt)\\n   462→\\t}\\n   463→\\n   464→\\tif len(options) == 0 {\\n   465→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   466→\\t}\\n   467→\\n   468→\\t// Collect available agent names for the selector\\n   469→\\tavailableNames := make([]string, 0, len(options))\\n   470→\\tfor _, opt := range options {\\n   471→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   472→\\t}\\n   473→\\n   474→\\tvar selectedAgentNames []string\\n   475→\\tif selectFn != nil {\\n   476→\\t\\tvar err error\\n   477→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   478→\\t\\tif err != nil {\\n   479→\\t\\t\\treturn nil, err\\n   480→\\t\\t}\\n   481→\\t\\tif len(selectedAgentNames) == 0 {\\n   482→\\t\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   483→\\t\\t}\\n   484→\\t} else {\\n   485→\\t\\tform := NewAccessibleForm(\\n   486→\\t\\t\\thuh.NewGroup(\\n   487→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   488→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   489→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   490→\\t\\t\\t\\t\\tOptions(options...).\\n   491→\\t\\t\\t\\t\\tValidate(func(selected []string) error {\\n   492→\\t\\t\\t\\t\\t\\tif len(selected) == 0 {\\n   493→\\t\\t\\t\\t\\t\\t\\treturn errors.New(\\\"please select at least one agent\\\")\\n   494→\\t\\t\\t\\t\\t\\t}\\n   495→\\t\\t\\t\\t\\t\\treturn nil\\n   496→\\t\\t\\t\\t\\t}).\\n   497→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   498→\\t\\t\\t),\\n   499→\\t\\t)\\n   500→\\t\\tif err := form.Run(); err != nil {\\n   501→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   502→\\t\\t}\\n   503→\\t}\\n   504→\\n   505→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   506→\\tfor _, name := range selectedAgentNames {\\n   507→\\t\\tselectedAgent, err := agent.Get(agent.AgentName(name))\\n   508→\\t\\tif err != nil {\\n   509→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   510→\\t\\t}\\n   511→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   512→\\t}\\n   513→\\n   514→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   515→\\tfor _, ag := range selectedAgents {\\n   516→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   517→\\t}\\n   518→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   519→\\treturn selectedAgents, nil\\n   520→}\\n   521→\\n   522→// canPromptInteractively checks if we can show interactive prompts.\\n   523→// Returns false when running in CI, tests, or other non-interactive environments.\\n   524→func canPromptInteractively() bool {\\n   525→\\t// Check for test environment\\n   526→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   527→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   528→\\t}\\n   529→\\n   530→\\t// Check if /dev/tty is available\\n   531→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   532→\\tif err != nil {\\n   533→\\t\\treturn false\\n   534→\\t}\\n   535→\\t_ = tty.Close()\\n   536→\\treturn true\\n   537→}\\n   538→\\n   539→// printAgentError writes an error message followed by available agents and usage.\\n   540→func printAgentError(w io.Writer, message string) {\\n   541→\\tagents := agent.List()\\n   542→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   543→\\tfmt.Fprintln(w)\\n   544→\\tfor _, a := range agents {\\n   545→\\t\\tsuffix := \\\"\\\"\\n   546→\\t\\tif a == agent.DefaultAgentName {\\n   547→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   548→\\t\\t}\\n   549→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   550→\\t}\\n   551→\\tfmt.Fprintln(w)\\n   552→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   553→}\\n   554→\\n   555→// printMissingAgentError writes a helpful error listing available agents.\\n   556→func printMissingAgentError(w io.Writer) {\\n   557→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   558→}\\n   559→\\n   560→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   561→func printWrongAgentError(w io.Writer, name string) {\\n   562→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   563→}\\n   564→\\n   565→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   566→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   567→func setupAgentHooksNonInteractive(ctx context.Context, w io.Writer, ag agent.Agent, localDev, forceHooks, skipPushSessions, telemetry bool) error {\\n   568→\\tagentName := ag.Name()\\n   569→\\t// Check if agent supports hooks\\n   570→\\thookAgent, ok := ag.(agent.HookSupport)\\n   571→\\tif !ok {\\n   572→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   573→\\t}\\n   574→\\n   575→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   576→\\n   577→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   578→\\tinstalledHooks, err := hookAgent.InstallHooks(ctx, localDev, forceHooks)\\n   579→\\tif err != nil {\\n   580→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   581→\\t}\\n   582→\\n   583→\\t// Setup .entire directory\\n   584→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   585→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   586→\\t}\\n   587→\\n   588→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   589→\\tsettings, err := LoadEntireSettings(ctx)\\n   590→\\tif err != nil {\\n   591→\\t\\t// If we can't load, start with defaults\\n   592→\\t\\tsettings = &EntireSettings{}\\n   593→\\t}\\n   594→\\tsettings.Enabled = true\\n   595→\\tif localDev {\\n   596→\\t\\tsettings.LocalDev = localDev\\n   597→\\t}\\n   598→\\n   599→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   600→\\tif skipPushSessions {\\n   601→\\t\\tif settings.StrategyOptions == nil {\\n   602→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   603→\\t\\t}\\n   604→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   605→\\t}\\n   606→\\n   607→\\t// Handle telemetry for non-interactive mode\\n   608→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   609→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   610→\\t\\tf := false\\n   611→\\t\\tsettings.Telemetry = &f\\n   612→\\t}\\n   613→\\n   614→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   615→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   616→\\t}\\n   617→\\n   618→\\tif _, err := strategy.InstallGitHook(ctx, true, localDev); err != nil {\\n   619→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   620→\\t}\\n   621→\\tstrategy.CheckAndWarnHookManagers(ctx, w, localDev)\\n   622→\\n   623→\\tif installedHooks == 0 {\\n   624→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   625→\\t\\tif ag.IsPreview() {\\n   626→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   627→\\t\\t}\\n   628→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   629→\\t} else {\\n   630→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   631→\\t\\tif ag.IsPreview() {\\n   632→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   633→\\t\\t}\\n   634→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   635→\\t}\\n   636→\\n   637→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   638→\\n   639→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   640→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   641→\\t}\\n   642→\\n   643→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   644→\\n   645→\\treturn nil\\n   646→}\\n   647→\\n   648→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   649→func validateSetupFlags(useLocal, useProject bool) error {\\n   650→\\tif useLocal && useProject {\\n   651→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   652→\\t}\\n   653→\\treturn nil\\n   654→}\\n   655→\\n   656→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   657→// - Whether settings.json already exists\\n   658→// - The --local and --project flags\\n   659→// Returns (useLocal, showNotification).\\n   660→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   661→\\t// Explicit --local flag always uses local settings\\n   662→\\tif useLocal {\\n   663→\\t\\treturn true, false\\n   664→\\t}\\n   665→\\n   666→\\t// Explicit --project flag always uses project settings\\n   667→\\tif useProject {\\n   668→\\t\\treturn false, false\\n   669→\\t}\\n   670→\\n   671→\\t// No flags specified - check if settings file exists\\n   672→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   673→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   674→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   675→\\t\\treturn true, true\\n   676→\\t}\\n   677→\\n   678→\\t// Settings file doesn't exist - create it\\n   679→\\treturn false, false\\n   680→}\\n   681→\\n   682→// setupEntireDirectory creates the .entire directory and gitignore.\\n   683→// Returns true if the directory was created, false if it already existed.\\n   684→func setupEntireDirectory(ctx context.Context) (bool, error) { //nolint:unparam // already present in codebase\\n   685→\\t// Get absolute path for the .entire directory\\n   686→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   687→\\tif err != nil {\\n   688→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   689→\\t}\\n   690→\\n   691→\\t// Check if directory already exists\\n   692→\\tcreated := false\\n   693→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   694→\\t\\tcreated = true\\n   695→\\t}\\n   696→\\n   697→\\t// Create .entire directory\\n   698→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   699→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   700→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   701→\\t}\\n   702→\\n   703→\\t// Create/update .gitignore with all required entries\\n   704→\\tif err := strategy.EnsureEntireGitignore(ctx); err != nil {\\n   705→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   706→\\t}\\n   707→\\n   708→\\treturn created, nil\\n   709→}\\n   710→\\n   711→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   712→func setupGitHook(ctx context.Context) error {\\n   713→\\ts, err := settings.Load(ctx)\\n   714→\\tlocalDev := err == nil && s.LocalDev\\n   715→\\tif _, err := strategy.InstallGitHook(ctx, false, localDev); err != nil {\\n   716→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   717→\\t}\\n   718→\\tstrategy.CheckAndWarnHookManagers(ctx, os.Stderr, localDev)\\n   719→\\treturn nil\\n   720→}\\n   721→\\n   722→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   723→func newSetupGitHookCmd() *cobra.Command {\\n   724→\\tcmd := &cobra.Command{\\n   725→\\t\\tUse:    \\\"git-hook\\\",\\n   726→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   727→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   728→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   729→\\t\\t\\treturn setupGitHook(cmd.Context())\\n   730→\\t\\t},\\n   731→\\t}\\n   732→\\n   733→\\treturn cmd\\n   734→}\\n   735→\\n   736→func newCurlBashPostInstallCmd() *cobra.Command {\\n   737→\\treturn &cobra.Command{\\n   738→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   739→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   740→\\t\\tHidden: true,\\n   741→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   742→\\t\\t\\tw := cmd.OutOrStdout()\\n   743→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   744→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   745→\\t\\t\\t}\\n   746→\\t\\t\\treturn nil\\n   747→\\t\\t},\\n   748→\\t}\\n   749→}\\n   750→\\n   751→// shellCompletionComment is the comment preceding the completion line\\n   752→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   753→\\n   754→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   755→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   756→\\n   757→// shellCompletionTarget returns the rc file path and completion lines for the\\n   758→// user's current shell.\\n   759→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   760→\\thome, err := os.UserHomeDir()\\n   761→\\tif err != nil {\\n   762→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   763→\\t}\\n   764→\\n   765→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   766→\\tswitch {\\n   767→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   768→\\t\\treturn \\\"Zsh\\\",\\n   769→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   770→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   771→\\t\\t\\tnil\\n   772→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   773→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   774→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   775→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   776→\\t\\t}\\n   777→\\t\\treturn \\\"Bash\\\",\\n   778→\\t\\t\\tbashRC,\\n   779→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   780→\\t\\t\\tnil\\n   781→\\tcase strings.Contains(shell, \\\"fish\\\"):\\n   782→\\t\\treturn \\\"Fish\\\",\\n   783→\\t\\t\\tfilepath.Join(home, \\\".config\\\", \\\"fish\\\", \\\"config.fish\\\"),\\n   784→\\t\\t\\t\\\"entire completion fish | source\\\",\\n   785→\\t\\t\\tnil\\n   786→\\tdefault:\\n   787→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   788→\\t}\\n   789→}\\n   790→\\n   791→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   792→// Only prompts if completion is not already configured.\\n   793→func promptShellCompletion(w io.Writer) error {\\n   794→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   795→\\tif err != nil {\\n   796→\\t\\tif errors.Is(err, errUnsupportedShell) {\\n   797→\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion not available for your shell. Supported: zsh, bash, fish.\\\\n\\\")\\n   798→\\t\\t\\treturn nil\\n   799→\\t\\t}\\n   800→\\t\\treturn fmt.Errorf(\\\"shell completion: %w\\\", err)\\n   801→\\t}\\n   802→\\n   803→\\tif isCompletionConfigured(rcFile) {\\n   804→\\t\\tfmt.Fprintf(w, \\\"✓ Shell completion already configured in %s\\\\n\\\", rcFile)\\n   805→\\t\\treturn nil\\n   806→\\t}\\n   807→\\n   808→\\tvar selected string\\n   809→\\tform := NewAccessibleForm(\\n   810→\\t\\thuh.NewGroup(\\n   811→\\t\\t\\thuh.NewSelect[string]().\\n   812→\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Enable shell completion? (detected: %s)\\\", shellName)).\\n   813→\\t\\t\\t\\tOptions(\\n   814→\\t\\t\\t\\t\\thuh.NewOption(\\\"Yes\\\", \\\"yes\\\"),\\n   815→\\t\\t\\t\\t\\thuh.NewOption(\\\"No\\\", \\\"no\\\"),\\n   816→\\t\\t\\t\\t).\\n   817→\\t\\t\\t\\tValue(&selected),\\n   818→\\t\\t),\\n   819→\\t)\\n   820→\\n   821→\\tif err := form.Run(); err != nil {\\n   822→\\t\\t//nolint:nilerr // User cancelled - not a fatal error, just skip\\n   823→\\t\\treturn nil\\n   824→\\t}\\n   825→\\n   826→\\tif selected != \\\"yes\\\" {\\n   827→\\t\\treturn nil\\n   828→\\t}\\n   829→\\n   830→\\tif err := appendShellCompletion(rcFile, completionLine); err != nil {\\n   831→\\t\\treturn fmt.Errorf(\\\"failed to update %s: %w\\\", rcFile, err)\\n   832→\\t}\\n   833→\\n   834→\\tfmt.Fprintf(w, \\\"✓ Shell completion added to %s\\\\n\\\", rcFile)\\n   835→\\tfmt.Fprintln(w, \\\"  Restart your shell to activate\\\")\\n   836→\\n   837→\\treturn nil\\n   838→}\\n   839→\\n   840→// isCompletionConfigured checks if shell completion is already in the rc file.\\n   841→func isCompletionConfigured(rcFile string) bool {\\n   842→\\t//nolint:gosec // G304: rcFile is constructed from home dir + known filename, not user input\\n   843→\\tcontent, err := os.ReadFile(rcFile)\\n   844→\\tif err != nil {\\n   845→\\t\\treturn false // File doesn't exist or can't read, treat as not configured\\n   846→\\t}\\n   847→\\treturn strings.Contains(string(content), \\\"entire completion\\\")\\n   848→}\\n   849→\\n   850→// appendShellCompletion adds the completion line to the rc file.\\n   851→func appendShellCompletion(rcFile, completionLine string) error {\\n   852→\\tif err := os.MkdirAll(filepath.Dir(rcFile), 0o700); err != nil {\\n   853→\\t\\treturn fmt.Errorf(\\\"creating directory: %w\\\", err)\\n   854→\\t}\\n   855→\\t//nolint:gosec // G302: Shell rc files need 0644 for user readability\\n   856→\\tf, err := os.OpenFile(rcFile, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0o644)\\n   857→\\tif err != nil {\\n   858→\\t\\treturn fmt.Errorf(\\\"opening file: %w\\\", err)\\n   859→\\t}\\n   860→\\tdefer f.Close()\\n   861→\\n   862→\\t_, err = f.WriteString(\\\"\\\\n\\\" + shellCompletionComment + \\\"\\\\n\\\" + completionLine + \\\"\\\\n\\\")\\n   863→\\tif err != nil {\\n   864→\\t\\treturn fmt.Errorf(\\\"writing completion: %w\\\", err)\\n   865→\\t}\\n   866→\\treturn nil\\n   867→}\\n   868→\\n   869→// promptTelemetryConsent asks the user if they want to enable telemetry.\\n   870→// It modifies settings.Telemetry based on the user's choice or flags.\\n   871→// The caller is responsible for saving settings.\\n   872→func promptTelemetryConsent(settings *EntireSettings, telemetryFlag bool) error {\\n   873→\\t// Handle --telemetry=false flag first (always overrides existing setting)\\n   874→\\tif !telemetryFlag {\\n   875→\\t\\tf := false\\n   876→\\t\\tsettings.Telemetry = &f\\n   877→\\t\\treturn nil\\n   878→\\t}\\n   879→\\n   880→\\t// Skip if already asked\\n   881→\\tif settings.Telemetry != nil {\\n   882→\\t\\treturn nil\\n   883→\\t}\\n   884→\\n   885→\\t// Skip if env var disables telemetry (record as disabled)\\n   886→\\tif os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   887→\\t\\tf := false\\n   888→\\t\\tsettings.Telemetry = &f\\n   889→\\t\\treturn nil\\n   890→\\t}\\n   891→\\n   892→\\tconsent := true // Default to Yes\\n   893→\\tform := NewAccessibleForm(\\n   894→\\t\\thuh.NewGroup(\\n   895→\\t\\t\\thuh.NewConfirm().\\n   896→\\t\\t\\t\\tTitle(\\\"Help improve Entire CLI?\\\").\\n   897→\\t\\t\\t\\tDescription(\\\"Share anonymous usage data. No code or personal info collected.\\\").\\n   898→\\t\\t\\t\\tAffirmative(\\\"Yes\\\").\\n   899→\\t\\t\\t\\tNegative(\\\"No\\\").\\n   900→\\t\\t\\t\\tValue(&consent),\\n   901→\\t\\t),\\n   902→\\t)\\n   903→\\n   904→\\tif err := form.Run(); err != nil {\\n   905→\\t\\treturn fmt.Errorf(\\\"telemetry prompt: %w\\\", err)\\n   906→\\t}\\n   907→\\n   908→\\tsettings.Telemetry = &consent\\n   909→\\treturn nil\\n   910→}\\n   911→\\n   912→// runUninstall completely removes Entire from the repository.\\n   913→func runUninstall(ctx context.Context, w, errW io.Writer, force bool) error {\\n   914→\\t// Check if we're in a git repository\\n   915→\\tif _, err := paths.WorktreeRoot(ctx); err != nil {\\n   916→\\t\\tfmt.Fprintln(errW, \\\"Not a git repository. Nothing to uninstall.\\\")\\n   917→\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n   918→\\t}\\n   919→\\n   920→\\t// Gather counts for display\\n   921→\\tsessionStateCount := countSessionStates(ctx)\\n   922→\\tshadowBranchCount := countShadowBranches(ctx)\\n   923→\\tgitHooksInstalled := strategy.IsGitHookInstalled(ctx)\\n   924→\\tagentsWithInstalledHooks := GetAgentsWithHooksInstalled(ctx)\\n   925→\\tentireDirExists := checkEntireDirExists(ctx)\\n   926→\\n   927→\\t// Check if there's anything to uninstall\\n   928→\\tif !entireDirExists && !gitHooksInstalled && sessionStateCount == 0 &&\\n   929→\\t\\tshadowBranchCount == 0 && len(agentsWithInstalledHooks) == 0 {\\n   930→\\t\\tfmt.Fprintln(w, \\\"Entire is not installed in this repository.\\\")\\n   931→\\t\\treturn nil\\n   932→\\t}\\n   933→\\n   934→\\t// Show confirmation prompt unless --force\\n   935→\\tif !force {\\n   936→\\t\\tfmt.Fprintln(w, \\\"\\\\nThis will completely remove Entire from this repository:\\\")\\n   937→\\t\\tif entireDirExists {\\n   938→\\t\\t\\tfmt.Fprintln(w, \\\"  - .entire/ directory\\\")\\n   939→\\t\\t}\\n   940→\\t\\tif gitHooksInstalled {\\n   941→\\t\\t\\tfmt.Fprintln(w, \\\"  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\\")\\n   942→\\t\\t}\\n   943→\\t\\tif sessionStateCount > 0 {\\n   944→\\t\\t\\tfmt.Fprintf(w, \\\"  - Session state files (%d)\\\\n\\\", sessionStateCount)\\n   945→\\t\\t}\\n   946→\\t\\tif shadowBranchCount > 0 {\\n   947→\\t\\t\\tfmt.Fprintf(w, \\\"  - Shadow branches (%d)\\\\n\\\", shadowBranchCount)\\n   948→\\t\\t}\\n   949→\\t\\tif len(agentsWithInstalledHooks) > 0 {\\n   950→\\t\\t\\tdisplayNames := make([]string, 0, len(agentsWithInstalledHooks))\\n   951→\\t\\t\\tfor _, name := range agentsWithInstalledHooks {\\n   952→\\t\\t\\t\\tif ag, err := agent.Get(name); err == nil {\\n   953→\\t\\t\\t\\t\\tdisplayNames = append(displayNames, string(ag.Type()))\\n   954→\\t\\t\\t\\t}\\n   955→\\t\\t\\t}\\n   956→\\t\\t\\tfmt.Fprintf(w, \\\"  - Agent hooks (%s)\\\\n\\\", strings.Join(displayNames, \\\", \\\"))\\n   957→\\t\\t}\\n   958→\\t\\tfmt.Fprintln(w)\\n   959→\\n   960→\\t\\tvar confirmed bool\\n   961→\\t\\tform := NewAccessibleForm(\\n   962→\\t\\t\\thuh.NewGroup(\\n   963→\\t\\t\\t\\thuh.NewConfirm().\\n   964→\\t\\t\\t\\t\\tTitle(\\\"Are you sure you want to uninstall Entire?\\\").\\n   965→\\t\\t\\t\\t\\tAffirmative(\\\"Yes, uninstall\\\").\\n   966→\\t\\t\\t\\t\\tNegative(\\\"Cancel\\\").\\n   967→\\t\\t\\t\\t\\tValue(&confirmed),\\n   968→\\t\\t\\t),\\n   969→\\t\\t)\\n   970→\\n   971→\\t\\tif err := form.Run(); err != nil {\\n   972→\\t\\t\\treturn fmt.Errorf(\\\"confirmation cancelled: %w\\\", err)\\n   973→\\t\\t}\\n   974→\\n   975→\\t\\tif !confirmed {\\n   976→\\t\\t\\tfmt.Fprintln(w, \\\"Uninstall cancelled.\\\")\\n   977→\\t\\t\\treturn nil\\n   978→\\t\\t}\\n   979→\\t}\\n   980→\\n   981→\\tfmt.Fprintln(w, \\\"\\\\nUninstalling Entire CLI...\\\")\\n   982→\\n   983→\\t// 1. Remove agent hooks (lowest risk)\\n   984→\\tif err := removeAgentHooks(ctx, w); err != nil {\\n   985→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove agent hooks: %v\\\\n\\\", err)\\n   986→\\t}\\n   987→\\n   988→\\t// 2. Remove git hooks\\n   989→\\tremoved, err := strategy.RemoveGitHook(ctx)\\n   990→\\tif err != nil {\\n   991→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove git hooks: %v\\\\n\\\", err)\\n   992→\\t} else if removed > 0 {\\n   993→\\t\\tfmt.Fprintf(w, \\\"  Removed git hooks (%d)\\\\n\\\", removed)\\n   994→\\t}\\n   995→\\n   996→\\t// 3. Remove session state files\\n   997→\\tstatesRemoved, err := removeAllSessionStates(ctx)\\n   998→\\tif err != nil {\\n   999→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove session states: %v\\\\n\\\", err)\\n  1000→\\t} else if statesRemoved > 0 {\\n  1001→\\t\\tfmt.Fprintf(w, \\\"  Removed session states (%d)\\\\n\\\", statesRemoved)\\n  1002→\\t}\\n  1003→\\n  1004→\\t// 4. Remove .entire/ directory\\n  1005→\\tif err := removeEntireDirectory(ctx); err != nil {\\n  1006→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove .entire directory: %v\\\\n\\\", err)\\n  1007→\\t} else if entireDirExists {\\n  1008→\\t\\tfmt.Fprintln(w, \\\"  Removed .entire directory\\\")\\n  1009→\\t}\\n  1010→\\n  1011→\\t// 5. Remove shadow branches\\n  1012→\\tbranchesRemoved, err := removeAllShadowBranches(ctx)\\n  1013→\\tif err != nil {\\n  1014→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to remove shadow branches: %v\\\\n\\\", err)\\n  1015→\\t} else if branchesRemoved > 0 {\\n  1016→\\t\\tfmt.Fprintf(w, \\\"  Removed %d shadow branches\\\\n\\\", branchesRemoved)\\n  1017→\\t}\\n  1018→\\n  1019→\\tfmt.Fprintln(w, \\\"\\\\nEntire CLI uninstalled successfully.\\\")\\n  1020→\\treturn nil\\n  1021→}\\n  1022→\\n  1023→// countSessionStates returns the number of active session state files.\\n  1024→func countSessionStates(ctx context.Context) int {\\n  1025→\\tstore, err := session.NewStateStore(ctx)\\n  1026→\\tif err != nil {\\n  1027→\\t\\treturn 0\\n  1028→\\t}\\n  1029→\\tstates, err := store.List(ctx)\\n  1030→\\tif err != nil {\\n  1031→\\t\\treturn 0\\n  1032→\\t}\\n  1033→\\treturn len(states)\\n  1034→}\\n  1035→\\n  1036→// countShadowBranches