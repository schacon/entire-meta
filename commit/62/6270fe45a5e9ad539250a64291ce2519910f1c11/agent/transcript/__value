al overrides.\\n    92→// Returns default settings if the file doesn't exist.\\n    93→// Use this when you need to display individual settings files separately.\\n    94→func LoadFromFile(filePath string) (*EntireSettings, error) {\\n    95→\\treturn loadFromFile(filePath)\\n    96→}\\n    97→\\n    98→// loadFromFile loads settings from a specific file path.\\n    99→// Returns default settings if the file doesn't exist.\\n   100→func loadFromFile(filePath string) (*EntireSettings, error) {\\n   101→\\tsettings := &EntireSettings{\\n   102→\\t\\tEnabled: true, // Default to enabled\\n   103→\\t}\\n   104→\\n   105→\\tdata, err := os.ReadFile(filePath) //nolint:gosec // path is from caller\\n   106→\\tif err != nil {\\n   107→\\t\\tif os.IsNotExist(err) {\\n   108→\\t\\t\\treturn settings, nil\\n   109→\\t\\t}\\n   110→\\t\\treturn nil, fmt.Errorf(\\\"%w\\\", err)\\n   111→\\t}\\n   112→\\n   113→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   114→\\tdec.DisallowUnknownFields()\\n   115→\\tif err := dec.Decode(settings); err != nil {\\n   116→\\t\\treturn nil, fmt.Errorf(\\\"parsing settings file: %w\\\", err)\\n   117→\\t}\\n   118→\\n   119→\\treturn settings, nil\\n   120→}\\n   121→\\n   122→// mergeJSON merges JSON data into existing settings.\\n   123→// Only non-zero values from the JSON override existing settings.\\n   124→func mergeJSON(settings *EntireSettings, data []byte) error {\\n   125→\\t// First, validate that there are no unknown keys using strict decoding\\n   126→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   127→\\tdec.DisallowUnknownFields()\\n   128→\\tvar temp EntireSettings\\n   129→\\tif err := dec.Decode(&temp); err != nil {\\n   130→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   131→\\t}\\n   132→\\n   133→\\t// Parse into a map to check which fields are present\\n   134→\\tvar raw map[string]json.RawMessage\\n   135→\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   136→\\t\\treturn fmt.Errorf(\\\"parsi