1→\\tif err := env.SimulateUserPromptSubmit(session2.ID); err != nil {\\n   302→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   303→\\t}\\n   304→\\n   305→\\tcontent2 := \\\"version 2\\\"\\n   306→\\tenv.WriteFile(\\\"file.txt\\\", content2)\\n   307→\\n   308→\\tsession2.CreateTranscript(\\n   309→\\t\\t\\\"Update to version 2\\\",\\n   310→\\t\\t[]FileChange{{Path: \\\"file.txt\\\", Content: content2}},\\n   311→\\t)\\n   312→\\tif err := env.SimulateStop(session2.ID, session2.TranscriptPath); err != nil {\\n   313→\\t\\tt.Fatalf(\\\"SimulateStop session2 failed: %v\\\", err)\\n   314→\\t}\\n   315→\\n   316→\\tfeatureBranch := env.GetCurrentBranch()\\n   317→\\n   318→\\t// Switch to main\\n   319→\\tenv.GitCheckoutBranch(masterBranch)\\n   320→\\n   321→\\t// Resume\\n   322→\\toutput, err := env.RunResume(featureBranch)\\n   323→\\tif err != nil {\\n   324→\\t\\tt.Fatalf(\\\"resume failed: %v\\\\nOutput: %s\\\", err, output)\\n   325→\\t}\\n   326→\\n   327→\\t// Should show session info (from the most recent session)\\n   328→\\tif !strings.Contains(output, \\\"Session:\\\") {\\n   329→\\t\\tt.Errorf(\\\"output should contain session info, got: %s\\\", output)\\n   330→\\t}\\n   331→\\n   332→\\t// The resume command shows the session from the last commit,\\n   333→\\t// which should be session2 (the most recent one)\\n   334→\\tif !strings.Contains(output, session2.ID) {\\n   335→\\t\\tt.Logf(\\\"Note: Expected session2 ID in output, but this depends on checkpoint lookup\\\")\\n   336→\\t}\\n   337→}\\n   338→\\n   339→// TestResume_CheckpointWithoutMetadata tests resume when a commit has an Entire-Checkpoint\\n   340→// trailer but the corresponding metadata is missing from entire/checkpoints/v1 branch.\\n   341→// This can happen if the metadata branch was corrupted or reset.\\n   342→func TestResume_CheckpointWithoutMetadata(t *testing.T) {\\n   343→\\tt.Parallel()\\n   344→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   345→\\n   346→\\t// First create a real session so the entire/checkpoints/v1 branch exists\\n   347→\\tsession := env.NewSession()\\n   348→\\tif err := env.SimulateUserPromptSubmit(session.ID); err != nil {\\n   349→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   350→\\t}\\n   351→\\tcontent := \\\"real session content\\\"\\n   352→\\tenv.WriteFile(\\\"real.txt\\\", content)\\n   353→\\tsession.CreateTranscript(\\n   354→\\t\\t\\\"Create real file\\\",\\n   355→\\t\\t[]FileChange{{Path: \\\"real.txt\\\", Content: content}},\\n   356→\\t)\\n   357→\\tif err := env.SimulateStop(session.ID, session.TranscriptPath); err != nil {\\n   358→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   359→\\t}\\n   360→\\n   361→\\t// Create a new branch for the orphan checkpoint test\\n   362→\\tenv.GitCheckoutNewBranch(\\\"feature/orphan-checkpoint\\\")\\n   363→\\n   364→\\t// Add some content and create a commit with a checkpoint trailer\\n   365→\\t// that points to non-existent metadata\\n   366→\\tenv.WriteFile(\\\"orphan.txt\\\", \\\"orphan content\\\")\\n   367→\\tenv.GitAdd(\\\"orphan.txt\\\")\\n   368→\\n   369→\\torphanCheckpointID := \\\"000000000000\\\" // Non-existent checkpoint\\n   370→\\tenv.GitCommitWithCheckpointID(\\\"Commit with orphan checkpoint\\\", orphanCheckpointID)\\n   371→\\n   372→\\tfeatureBranch := env.GetCurrentBranch()\\n   373→\\n   374→\\t// Switch to main\\n   375→\\tenv.GitCheckoutBranch(masterBranch)\\n   376→\\n   377→\\t// Resume - should not error but indicate no session available\\n   378→\\toutput, err := env.RunResume(featureBranch)\\n   379→\\tif err != nil {\\n   380→\\t\\tt.Fatalf(\\\"resume failed: %v\\\\nOutput: %s\\\", err, output)\\n   381→\\t}\\n   382→\\n   383→\\t// Verify we switched to the feature branch\\n   384→\\tif branch := env.GetCurrentBranch(); branch != featureBranch {\\n   385→\\t\\tt.Errorf(\\\"expected to be on %s, got %s\\\", featureBranch, branch)\\n   386→\\t}\\n   387→\\n   388→\\t// Should NOT show session info since metadata is missing\\n   389→\\t// The resume command should silently skip commits without valid metadata\\n   390→\\tif strings.Contains(output, \\\"Session:\\\") {\\n   391→\\t\\tt.Errorf(\\\"output should not contain 'Session:' when metadata is missing, got: %s\\\", output)\\n   392→\\t}\\n   393→}\\n   394→\\n   395→// TestResume_AfterMergingMain tests that resume finds the checkpoint from branch-only commits\\n   396→// when main has been merged into the feature branch (making HEAD a merge commit without trailers).\\n   397→// Since the only \\\"newer\\\" commits are merge commits, no confirmation should be required.\\n   398→func TestResume_AfterMergingMain(t *testing.T) {\\n   399→\\tt.Parallel()\\n   400→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   401→\\n   402→\\t// Create a session on the feature branch\\n   403→\\tsession := env.NewSession()\\n   404→\\tif err := env.SimulateUserPromptSubmit(session.ID); err != nil {\\n   405→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   406→\\t}\\n   407→\\n   408→\\tcontent := \\\"puts 'Hello from session'\\\"\\n   409→\\tenv.WriteFile(\\\"hello.rb\\\", content)\\n   410→\\n   411→\\tsession.CreateTranscript(\\n   412→\\t\\t\\\"Create a hello script\\\",\\n   413→\\t\\t[]FileChange{{Path: \\\"hello.rb\\\", Content: content}},\\n   414→\\t)\\n   415→\\tif err := env.SimulateStop(session.ID, session.TranscriptPath); err != nil {\\n   416→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   417→\\t}\\n   418→\\n   419→\\t// Remember the feature branch name\\n   420→\\tfeatureBranch := env.GetCurrentBranch()\\n   421→\\n   422→\\t// Switch to master and create a new commit (simulating work on main)\\n   423→\\tenv.GitCheckoutBranch(masterBranch)\\n   424→\\tenv.WriteFile(\\\"main_feature.txt\\\", \\\"new feature on main\\\")\\n   425→\\tenv.GitAdd(\\\"main_feature.txt\\\")\\n   426→\\tenv.GitCommit(\\\"Add new feature on main\\\")\\n   427→\\n   428→\\t// Switch back to feature branch\\n   429→\\tenv.GitCheckoutBranch(featureBranch)\\n   430→\\n   431→\\t// Merge main into feature branch (this creates a merge commit without Entire trailers)\\n   432→\\tenv.GitMerge(masterBranch)\\n   433→\\n   434→\\t// Verify HEAD is now a merge commit (doesn't have checkpoint trailer)\\n   435→\\theadMessage := env.GetHeadCommitMessage()\\n   436→\\tif !strings.HasPrefix(headMessage, \\\"Merge branch\\\") {\\n   437→\\t\\tt.Logf(\\\"Note: HEAD commit message: %s\\\", headMessage)\\n   438→\\t}\\n   439→\\n   440→\\t// Switch to master\\n   441→\\tenv.GitCheckoutBranch(masterBranch)\\n   442→\\n   443→\\t// Run resume WITHOUT --force - merge commits shouldn't require confirmation\\n   444→\\toutput, err := env.RunResume(featureBranch)\\n   445→\\tif err != nil {\\n   446→\\t\\tt.Fatalf(\\\"resume failed: %v\\\\nOutput: %s\\\", err, output)\\n   447→\\t}\\n   448→\\n   449→\\t// Should switch to the feature branch\\n   450→\\tif branch := env.GetCurrentBranch(); branch != featureBranch {\\n   451→\\t\\tt.Errorf(\\\"expected to be on %s, got %s\\\", featureBranch, branch)\\n   452→\\t}\\n   453→\\n   454→\\t// Should find the session from the older commit (before the merge)\\n   455→\\tif !strings.Contains(output, \\\"Session:\\\") {\\n   456→\\t\\tt.Errorf(\\\"output should contain 'Session:', got: %s\\\", output)\\n   457→\\t}\\n   458→\\tif !strings.Contains(output, \\\"claude -r\\\") {\\n   459→\\t\\tt.Errorf(\\\"output should contain 'claude -r', got: %s\\\", output)\\n   460→\\t}\\n   461→\\n   462→\\t// Should indicate it's skipping merge commits (informational, not a warning)\\n   463→\\tif !strings.Contains(output, \\\"skipping merge commit\\\") {\\n   464→\\t\\tt.Logf(\\\"Note: Expected 'skipping merge commit' message, got: %s\\\", output)\\n   465→\\t}\\n   466→}\\n   467→\\n   468→// RunResume executes the resume command and returns the combined output.\\n   469→// The subprocess is detached from the controlling terminal (via Setsid) to prevent\\n   470→// interactive prompts from hanging tests. This simulates non-interactive environments like CI.\\n   471→func (env *TestEnv) RunResume(branchName string) (string, error) {\\n   472→\\tenv.T.Helper()\\n   473→\\n   474→\\tctx := env.T.Context()\\n   475→\\tcmd := exec.CommandContext(ctx, getTestBinary(), \\\"resume\\\", branchName)\\n   476→\\tcmd.Dir = env.RepoDir\\n   477→\\tcmd.Env = append(os.Environ(),\\n   478→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+env.ClaudeProjectDir,\\n   479→\\t)\\n   480→\\t// Detach from controlling terminal so huh can't open /dev/tty for interactive prompts\\n   481→\\tcmd.SysProcAttr = &syscall.SysProcAttr{Setsid: true}\\n   482→\\n   483→\\toutput, err := cmd.CombinedOutput()\\n   484→\\treturn string(output), err\\n   485→}\\n   486→\\n   487→// RunResumeForce executes the resume command with --force flag.\\n   488→func (env *TestEnv) RunResumeForce(branchName string) (string, error) {\\n   489→\\tenv.T.Helper()\\n   490→\\n   491→\\tctx := env.T.Context()\\n   492→\\tcmd := exec.CommandContext(ctx, getTestBinary(), \\\"resume\\\", \\\"--force\\\", branchName)\\n   493→\\tcmd.Dir = env.RepoDir\\n   494→\\tcmd.Env = append(os.Environ(),\\n   495→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+env.ClaudeProjectDir,\\n   496→\\t)\\n   497→\\n   498→\\toutput, err := cmd.CombinedOutput()\\n   499→\\treturn string(output), err\\n   500→}\\n   501→\\n   502→// RunResumeInteractive executes the resume command with a pty, allowing\\n   503→// interactive prompt responses. The respond function receives the pty for\\n   504→// reading output and writing input. See RunCommandInteractive for details.\\n   505→func (env *TestEnv) RunResumeInteractive(branchName string, respond func(ptyFile *os.File) string) (string, error) {\\n   506→\\tenv.T.Helper()\\n   507→\\treturn env.RunCommandInteractive([]string{\\\"resume\\\", branchName}, respond)\\n   508→}\\n   509→\\n   510→// GitMerge merges a branch into the current branch.\\n   511→func (env *TestEnv) GitMerge(branchName string) {\\n   512→\\tenv.T.Helper()\\n   513→\\n   514→\\tctx := env.T.Context()\\n   515→\\t// Use --no-verify to skip hooks - the hooks use local_dev paths that don't work\\n   516→\\t// from test temp directories. This is fine since we're testing merge behavior,\\n   517→\\t// not hook execution during merge.\\n   518→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"merge\\\", branchName, \\\"-m\\\", \\\"Merge branch '\\\"+branchName+\\\"'\\\", \\\"--no-verify\\\")\\n   519→\\tcmd.Dir = env.RepoDir\\n   520→\\n   521→\\toutput, err := cmd.CombinedOutput()\\n   522→\\tif err != nil {\\n   523→\\t\\tenv.T.Fatalf(\\\"failed to merge branch %s: %v\\\\nOutput: %s\\\", branchName, err, output)\\n   524→\\t}\\n   525→}\\n   526→\\n   527→// GetHeadCommitMessage returns the message of the HEAD commit.\\n   528→func (env *TestEnv) GetHeadCommitMessage() string {\\n   529→\\tenv.T.Helper()\\n   530→\\n   531→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   532→\\tif err != nil {\\n   533→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   534→\\t}\\n   535→\\n   536→\\thead, err := repo.Head()\\n   537→\\tif err != nil {\\n   538→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   539→\\t}\\n   540→\\n   541→\\tcommit, err := repo.CommitObject(head.Hash())\\n   542→\\tif err != nil {\\n   543→\\t\\tenv.T.Fatalf(\\\"failed to get commit: %v\\\", err)\\n   544→\\t}\\n   545→\\n   546→\\treturn commit.Message\\n   547→}\\n   548→\\n   549→// GitCheckoutBranch checks out an existing branch.\\n   550→func (env *TestEnv) GitCheckoutBranch(branchName string) {\\n   551→\\tenv.T.Helper()\\n   552→\\n   553→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   554→\\tif err != nil {\\n   555→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   556→\\t}\\n   557→\\n   558→\\tworktree, err := repo.Worktree()\\n   559→\\tif err != nil {\\n   560→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   561→\\t}\\n   562→\\n   563→\\terr = worktree.Checkout(&git.CheckoutOptions{\\n   564→\\t\\tBranch: plumbing.NewBranchReferenceName(branchName),\\n   565→\\t})\\n   566→\\tif err != nil {\\n   567→\\t\\tenv.T.Fatalf(\\\"failed to checkout branch %s: %v\\\", branchName, err)\\n   568→\\t}\\n   569→}\\n   570→\\n   571→// TestResume_LocalLogNewerTimestamp_RequiresForce tests that when local log has newer\\n   572→// timestamps than the checkpoint, the command fails in non-interactive mode (no TTY)\\n   573→// and does NOT overwrite the local log. This ensures safe behavior in CI environments.\\n   574→func TestResume_LocalLogNewerTimestamp_RequiresForce(t *testing.T) {\\n   575→\\tt.Parallel()\\n   576→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   577→\\n   578→\\t// Create a session with a specific timestamp\\n   579→\\tsession := env.NewSession()\\n   580→\\tif err := env.SimulateUserPromptSubmit(session.ID); err != nil {\\n   581→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   582→\\t}\\n   583→\\n   584→\\tcontent := \\\"def hello; end\\\"\\n   585→\\tenv.WriteFile(\\\"hello.rb\\\", content)\\n   586→\\n   587→\\tsession.CreateTranscript(\\n   588→\\t\\t\\\"Create hello method\\\",\\n   589→\\t\\t[]FileChange{{Path: \\\"hello.rb\\\", Content: content}},\\n   590→\\t)\\n   591→\\tif err := env.SimulateStop(session.ID, session.TranscriptPath); err != nil {\\n   592→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   593→\\t}\\n   594→\\n   595→\\tfeatureBranch := env.GetCurrentBranch()\\n   596→\\n   597→\\t// Create a local log with a NEWER timestamp than the checkpoint\\n   598→\\tif err := os.MkdirAll(env.ClaudeProjectDir, 0o755); err != nil {\\n   599→\\t\\tt.Fatalf(\\\"failed to create Claude project dir: %v\\\", err)\\n   600→\\t}\\n   601→\\texistingLog := filepath.Join(env.ClaudeProjectDir, session.ID+\\\".jsonl\\\")\\n   602→\\t// Use a timestamp far in the future to ensure it's newer\\n   603→\\tfutureTimestamp := time.Now().Add(24 * time.Hour).UTC().Format(time.RFC3339)\\n   604→\\tnewerContent := fmt.Sprintf(`{\\\"type\\\":\\\"human\\\",\\\"timestamp\\\":\\\"%s\\\",\\\"message\\\":{\\\"content\\\":\\\"newer local work\\\"}}`, futureTimestamp)\\n   605→\\tif err := os.WriteFile(existingLog, []byte(newerContent), 0o644); err != nil {\\n   606→\\t\\tt.Fatalf(\\\"failed to write existing log: %v\\\", err)\\n   607→\\t}\\n   608→\\n   609→\\t// Switch to main\\n   610→\\tenv.GitCheckoutBranch(masterBranch)\\n   611→\\n   612→\\t// Resume WITHOUT --force in non-interactive mode (no TTY due to Setsid)\\n   613→\\t// Should fail because it can't prompt for confirmation\\n   614→\\toutput, err := env.RunResume(featureBranch)\\n   615→\\tif err == nil {\\n   616→\\t\\tt.Errorf(\\\"expected error when resuming without --force in non-interactive mode, got success.\\\\nOutput: %s\\\", output)\\n   617→\\t}\\n   618→\\n   619→\\t// Verify local log was NOT overwritten (safe behavior)\\n   620→\\tdata, err := os.ReadFile(existingLog)\\n   621→\\tif err != nil {\\n   622→\\t\\tt.Fatalf(\\\"failed to read log: %v\\\", err)\\n   623→\\t}\\n   624→\\tif !strings.Contains(string(data), \\\"newer local work\\\") {\\n   625→\\t\\tt.Errorf(\\\"local log should NOT have been overwritten without --force, but content changed to: %s\\\", string(data))\\n   626→\\t}\\n   627→}\\n   628→\\n   629→// TestResume_LocalLogNewerTimestamp_ForceOverwrites tests that when local log has newer\\n   630→// timestamps than the checkpoint, the --force flag bypasses the confirmation prompt\\n   631→// and overwrites the local log.\\n   632→func TestResume_LocalLogNewerTimestamp_ForceOverwrites(t *testing.T) {\\n   633→\\tt.Parallel()\\n   634→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   635→\\n   636→\\t// Create a session with a specific timestamp\\n   637→\\tsession := env.NewSession()\\n   638→\\tif err := env.SimulateUserPromptSubmit(session.ID); err != nil {\\n   639→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   640→\\t}\\n   641→\\n   642→\\tcontent := \\\"def hello; end\\\"\\n   643→\\tenv.WriteFile(\\\"hello.rb\\\", content)\\n   644→\\n   645→\\tsession.CreateTranscript(\\n   646→\\t\\t\\\"Create hello method\\\",\\n   647→\\t\\t[]FileChange{{Path: \\\"hello.rb\\\", Content: content}},\\n   648→\\t)\\n   649→\\tif err := env.SimulateStop(session.ID, session.TranscriptPath); err != nil {\\n   650→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   651→\\t}\\n   652→\\n   653→\\tfeatureBranch := env.GetCurrentBranch()\\n   654→\\n   655→\\t// Create a local log with a NEWER timestamp than the checkpoint\\n   656→\\tif err := os.MkdirAll(env.ClaudeProjectDir, 0o755); err != nil {\\n   657→\\t\\tt.Fatalf(\\\"failed to create Claude project dir: %v\\\", err)\\n   658→\\t}\\n   659→\\texistingLog := filepath.Join(env.ClaudeProjectDir, session.ID+\\\".jsonl\\\")\\n   660→\\t// Use a timestamp far in the future to ensure it's newer\\n   661→\\tfutureTimestamp := time.Now().Add(24 * time.Hour).UTC().Format(time.RFC3339)\\n   662→\\tnewerContent := fmt.Sprintf(`{\\\"type\\\":\\\"human\\\",\\\"timestamp\\\":\\\"%s\\\",\\\"message\\\":{\\\"content\\\":\\\"newer local work\\\"}}`, futureTimestamp)\\n   663→\\tif err := os.WriteFile(existingLog, []byte(newerContent), 0o644); err != nil {\\n   664→\\t\\tt.Fatalf(\\\"failed to write existing log: %v\\\", err)\\n   665→\\t}\\n   666→\\n   667→\\t// Switch to main\\n   668→\\tenv.GitCheckoutBranch(masterBranch)\\n   669→\\n   670→\\t// Resume WITH --force should succeed and overwrite the local log\\n   671→\\toutput, err := env.RunResumeForce(featureBranch)\\n   672→\\tif err != nil {\\n   673→\\t\\tt.Fatalf(\\\"resume --force failed: %v\\\\nOutput: %s\\\", err, output)\\n   674→\\t}\\n   675→\\n   676→\\t// Verify local log was overwritten with checkpoint content\\n   677→\\tdata, err := os.ReadFile(existingLog)\\n   678→\\tif err != nil {\\n   679→\\t\\tt.Fatalf(\\\"failed to read log: %v\\\", err)\\n   680→\\t}\\n   681→\\tif strings.Contains(string(data), \\\"newer local work\\\") {\\n   682→\\t\\tt.Errorf(\\\"local log should have been overwritten, but still has newer content: %s\\\", string(data))\\n   683→\\t}\\n   684→\\tif !strings.Contains(string(data), \\\"Create hello method\\\") {\\n   685→\\t\\tt.Errorf(\\\"restored log should contain checkpoint transcript, got: %s\\\", string(data))\\n   686→\\t}\\n   687→}\\n   688→\\n   689→// TestResume_LocalLogNewerTimestamp_UserConfirmsOverwrite tests that when the user\\n   690→// confirms the overwrite prompt interactively, the local log is overwritten.\\n   691→func TestResume_LocalLogNewerTimestamp_UserConfirmsOverwrite(t *testing.T) {\\n   692→\\tt.Parallel()\\n   693→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   694→\\n   695→\\t// Create a session with a specific timestamp\\n   696→\\tsession := env.NewSession()\\n   697→\\tif err := env.SimulateUserPromptSubmit(session.ID); err != nil {\\n   698→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   699→\\t}\\n   700→\\n   701→\\tcontent := \\\"def hello; end\\\"\\n   702→\\tenv.WriteFile(\\\"hello.rb\\\", content)\\n   703→\\n   704→\\tsession.CreateTranscript(\\n   705→\\t\\t\\\"Create hello method\\\",\\n   706→\\t\\t[]FileChange{{Path: \\\"hello.rb\\\", Content: content}},\\n   707→\\t)\\n   708→\\tif err := env.SimulateStop(session.ID, session.TranscriptPath); err != nil {\\n   709→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   710→\\t}\\n   711→\\n   712→\\tfeatureBranch := env.GetCurrentBranch()\\n   713→\\n   714→\\t// Create a local log with a NEWER timestamp than the checkpoint\\n   715→\\tif err := os.MkdirAll(env.ClaudeProjectDir, 0o755); err != nil {\\n   716→\\t\\tt.Fatalf(\\\"failed to create Claude project dir: %v\\\", err)\\n   717→\\t}\\n   718→\\texistingLog := filepath.Join(env.ClaudeProjectDir, session.ID+\\\".jsonl\\\")\\n   719→\\tfutureTimestamp := time.Now().Add(24 * time.Hour).UTC().Format(time.RFC3339)\\n   720→\\tnewerContent := fmt.Sprintf(`{\\\"type\\\":\\\"human\\\",\\\"timestamp\\\":\\\"%s\\\",\\\"message\\\":{\\\"content\\\":\\\"newer local work\\\"}}`, futureTimestamp)\\n   721→\\tif err := os.WriteFile(existingLog, []byte(newerContent), 0o644); err != nil {\\n   722→\\t\\tt.Fatalf(\\\"failed to write existing log: %v\\\", err)\\n   723→\\t}\\n   724→\\n   725→\\t// Switch to main\\n   726→\\tenv.GitCheckoutBranch(masterBranch)\\n   727→\\n   728→\\t// Resume interactively and confirm the overwrite\\n   729→\\toutput, err := env.RunResumeInteractive(featureBranch, func(ptyFile *os.File) string {\\n   730→\\t\\tout, promptErr := WaitForPromptAndRespond(ptyFile, \\\"[y/N]\\\", \\\"y\\\\n\\\", 10*time.Second)\\n   731→\\t\\tif promptErr != nil {\\n   732→\\t\\t\\tt.Logf(\\\"Warning: %v\\\", promptErr)\\n   733→\\t\\t}\\n   734→\\t\\treturn out\\n   735→\\t})\\n   736→\\tif err != nil {\\n   737→\\t\\tt.Fatalf(\\\"resume with user confirmation failed: %v\\\\nOutput: %s\\\", err, output)\\n   738→\\t}\\n   739→\\n   740→\\t// Verify local log was overwritten with checkpoint content\\n   741→\\tdata, err := os.ReadFile(existingLog)\\n   742→\\tif err != nil {\\n   743→\\t\\tt.Fatalf(\\\"failed to read log: %v\\\", err)\\n   744→\\t}\\n   745→\\tif strings.Contains(string(data), \\\"newer local work\\\") {\\n   746→\\t\\tt.Errorf(\\\"local log should have been overwritten after user confirmed, but still has newer content: %s\\\", string(data))\\n   747→\\t}\\n   748→\\tif !strings.Contains(string(data), \\\"Create hello method\\\") {\\n   749→\\t\\tt.Errorf(\\\"restored log should contain checkpoint transcript, got: %s\\\", string(data))\\n   750→\\t}\\n   751→}\\n   752→\\n   753→// TestResume_LocalLogNewerTimestamp_UserDeclinesOverwrite tests that when the user\\n   754→// declines the overwrite prompt interactively, the local log is pres