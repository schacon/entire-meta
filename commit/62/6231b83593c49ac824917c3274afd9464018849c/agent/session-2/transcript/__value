30→\\tenv.GitCheckoutBranch(masterBranch)\\n   131→\\n   132→\\t// Create a new branch from master\\n   133→\\tenv.GitCheckoutNewBranch(\\\"feature/no-session\\\")\\n   134→\\n   135→\\t// Create a commit without any session/checkpoint\\n   136→\\tenv.WriteFile(\\\"plain.txt\\\", \\\"no session here\\\")\\n   137→\\tenv.GitAdd(\\\"plain.txt\\\")\\n   138→\\tenv.GitCommit(\\\"Plain commit without session\\\")\\n   139→\\n   140→\\tplainBranch := env.GetCurrentBranch()\\n   141→\\n   142→\\t// Switch back to master\\n   143→\\tenv.GitCheckoutBranch(masterBranch)\\n   144→\\n   145→\\t// Resume to the plain branch - should indicate no checkpoint found\\n   146→\\toutput, err := env.RunResume(plainBranch)\\n   147→\\tif err != nil {\\n   148→\\t\\tt.Fatalf(\\\"resume failed: %v\\\\nOutput: %s\\\", err, output)\\n   149→\\t}\\n   150→\\n   151→\\t// Should indicate no checkpoint found\\n   152→\\tif !strings.Contains(output, \\\"No Entire checkpoint found\\\") {\\n   153→\\t\\tt.Errorf(\\\"output should indicate no checkpoint found, got: %s\\\", output)\\n   154→\\t}\\n   155→\\n   156→\\t// Should still switch to the branch\\n   157→\\tif branch := env.GetCurrentBranch(); branch != plainBranch {\\n   158→\\t\\tt.Errorf(\\\"expected to be on %s, got %s\\\", plainBranch, branch)\\n   159→\\t}\\n   160→}\\n   161→\\n   162→// TestResume_BranchDoesNotExist tests that resume returns an error for non-existent branches.\\n   163→func TestResume_BranchDoesNotExist(t *testing.T) {\\n   164→\\tt.Parallel()\\n   165→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   166→\\n   167→\\t// Try to resume a non-existent branch\\n   168→\\toutput, err := env.RunResume(\\\"nonexistent-branch\\\")\\n   169→\\n   170→\\t// Should fail\\n   171→\\tif err == nil {\\n   172→\\t\\tt.Errorf(\\\"expected error for non-existent branch, got success with output: %s\\\", output)\\n   173→\\t}\\n   174→\\n   175→\\t// Error should mention the branch\\n   176→\\tif !strings.Contains(output, \\\"nonexistent-branch\\\") && !strings.Contains(err.Error(), \\\"nonexistent-branch\\\") {\\n   177→\\t\\tt.Errorf(\\\"error should mention the branch name, got: %v, output: %s\\\", err, output)\\n   178→\\t}\\n   179→}\\n   180→\\n   181→// TestResume_UncommittedChanges tests that resume fails when there are uncommitted changes.\\n   182→func TestResume_UncommittedChanges(t *testing.T) {\\n   183→\\tt.Parallel()\\n   184→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   185→\\n   186→\\t// Create another branch\\n   187→\\tenv.GitCheckoutNewBranch(\\\"feature/target\\\")\\n   188→\\tenv.WriteFile(\\\"target.txt\\\", \\\"target content\\\")\\n   189→\\tenv.GitAdd(\\\"target.txt\\\")\\n   190→\\tenv.GitCommit(\\\"Target commit\\\")\\n   191→\\n   192→\\t// Go back to original branch\\n   193→\\tenv.GitCheckoutBranch(\\\"feature/test-branch\\\")\\n   194→\\n   195→\\t// Make uncommitted changes\\n   196→\\tenv.WriteFile(\\\"uncommitted.txt\\\", \\\"uncommitted content\\\")\\n   197→\\n   198→\\t// Try to resume to target branch\\n   199→\\toutput, err := env.RunResume(\\\"feature/target\\\")\\n   200→\\n   201→\\t// Should fail due to uncommitted changes\\n   202→\\tif err == nil {\\n   203→\\t\\tt.Errorf(\\\"expected error for uncommitted changes, got success with output: %s\\\", output)\\n   204→\\t}\\n   205→\\n   206→\\t// Error should mention uncommitted changes\\n   207→\\tif !strings.Contains(output, \\\"uncommitted\\\") && !strings.Contains(err.Error(), \\\"uncommitted\\\") {\\n   208→\\t\\tt.Errorf(\\\"error should mention uncommitted changes, got: %v, output: %s\\\", err, output)\\n   209→\\t}\\n   210→}\\n   211→\\n   212→// TestResume_SessionLogAlreadyExists tests that resume overwrites existing session logs\\n   213→// with the checkpoint's version. This ensures consistency when resuming from a different device.\\n   214→func TestResume_SessionLogAlreadyExists(t *testing.T) {\\n   215→\\tt.Parallel()\\n   216→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   217→\\n   218→\\t// Create a session\\n   219→\\tsession := env.NewSession()\\n   220→\\tif err := env.SimulateUserPromptSubmit(session.ID); err != nil {\\n   221→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   222→\\t}\\n   223→\\n   224→\\tcontent := \\\"def hello; end\\\"\\n   225→\\tenv.WriteFile(\\\"hello.rb\\\", content)\\n   226→\\n   227→\\tsession.CreateTranscript(\\n   228→\\t\\t\\\"Create hello method\\\",\\n   229→\\t\\t[]FileChange{{Path: \\\"hello.rb\\\", Content: content}},\\n   230→\\t)\\n   231→\\tif err := env.SimulateStop(session.ID, session.TranscriptPath); err != nil {\\n   232→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   233→\\t}\\n   234→\\n   235→\\tfeatureBranch := env.GetCurrentBranch()\\n   236→\\n   237→\\t// Pre-create a session log in Claude project dir with different content\\n   238→\\t// (simulating a stale/different version from another device)\\n   239→\\tif err := os.MkdirAll(env.ClaudeProjectDir, 0o755); err != nil {\\n   240→\\t\\tt.Fatalf(\\\"failed to create Claude project dir: %v\\\", err)\\n   241→\\t}\\n   242→\\texistingLog := filepath.Join(env.ClaudeProjectDir, session.ID+\\\".jsonl\\\")\\n   243→\\texistingContent := `{\\\"existing\\\": true}`\\n   244→\\tif err := os.WriteFile(existingLog, []byte(existingContent), 0o644); err != nil {\\n   245→\\t\\tt.Fatalf(\\\"failed to write existing log: %v\\\", err)\\n   246→\\t}\\n   247→\\n   248→\\t// Switch to main and back\\n   249→\\tenv.GitCheckoutBranch(masterBranch)\\n   250→\\n   251→\\t// Resume\\n   252→\\toutput, err := env.RunResume(featureBranch)\\n   253→\\tif err != nil {\\n   254→\\t\\tt.Fatalf(\\\"resume failed: %v\\\\nOutput: %s\\\", err, output)\\n   255→\\t}\\n   256→\\n   257→\\t// Existing log SHOULD be overwritten with checkpoint's transcript\\n   258→\\tdata, err := os.ReadFile(existingLog)\\n   259→\\tif err != nil {\\n   260→\\t\\tt.Fatalf(\\\"failed to read 