ch with a dummy commit for clone to work\\n\\tmainBlob := bareRepo.Storer.NewEncodedObject()\\n\\tmainBlob.SetType(plumbing.BlobObject)\\n\\tmainBlob.SetSize(4)\\n\\tmw, _ := mainBlob.Writer()\\n\\tmw.Write([]byte(\\\"test\\\"))\\n\\tmw.Close()\\n\\tmainBlobHash, _ := bareRepo.Storer.SetEncodedObject(mainBlob)\\n\\n\\tmainTree := &object.Tree{\\n\\t\\tEntries: []object.TreeEntry{\\n\\t\\t\\t{Name: \\\"README.md\\\", Mode: 0o100644, Hash: mainBlobHash},\\n\\t\\t},\\n\\t}\\n\\tmainTreeObj := bareRepo.Storer.NewEncodedObject()\\n\\tmainTree.Encode(mainTreeObj)\\n\\tmainTreeHash, _ := bareRepo.Storer.SetEncodedObject(mainTreeObj)\\n\\n\\tmainCommit := &object.Commit{\\n\\t\\tTreeHash:  mainTreeHash,\\n\\t\\tAuthor:    sig,\\n\\t\\tCommitter: sig,\\n\\t\\tMessage:   \\\"Initial commit\\\\n\\\",\\n\\t}\\n\\tmainCommitObj := bareRepo.Storer.NewEncodedObject()\\n\\tmainCommit.Encode(mainCommitObj)\\n\\tmainCommitHash, _ := bareRepo.Storer.SetEncodedObject(mainCommitObj)\\n\\n\\tmainRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(\\\"main\\\"), mainCommitHash)\\n\\tbareRepo.Storer.SetReference(mainRef)\\n\\t// Set HEAD to main\\n\\theadRef := plumbing.NewSymbolicReference(plumbing.HEAD, plumbing.NewBranchReferenceName(\\\"main\\\"))\\n\\tbareRepo.Storer.SetReference(headRef)\\n\\n\\t// Step 2: Clone the bare repo using native git (most realistic)\\n\\tcloneDir := filepath.Join(t.TempDir(), \\\"clone\\\")\\n\\tcmd := exec.Command(\\\"git\\\", \\\"clone\\\", bareDir, cloneDir)\\n\\tout, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"failed to clone: %v\\\\noutput: %s\\\", err, out)\\n\\t}\\n\\n\\t// Debug: List all refs in the clone\\n\\tt.Log(\\\"=== Refs after clone (git branch -a) ===\\\")\\n\\tcmd = exec.Command(\\\"git\\\", \\\"branch\\\", \\\"-a\\\")\\n\\tcmd.Dir = cloneDir\\n\\tout, _ = cmd.CombinedOutput()\\n\\tt.Logf(\\\"%s\\\", out)\\n\\n\\tt.Log(\\\"=== All refs (git for-each-ref) ===\\\")\\n\\tcmd = exec.Command(\\\"git\\\", 