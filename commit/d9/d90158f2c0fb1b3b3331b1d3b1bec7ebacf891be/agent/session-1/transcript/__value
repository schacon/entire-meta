sions(existing, incoming)\\n   457→\\t\\tif len(got) != 2 {\\n   458→\\t\\t\\tt.Fatalf(\\\"got %d sessions, want 2\\\", len(got))\\n   459→\\t\\t}\\n   460→\\t\\tif got[0].SessionID != \\\"s1\\\" || got[1].SessionID != \\\"s2\\\" {\\n   461→\\t\\t\\tt.Errorf(\\\"got [%s, %s], want [s1, s2]\\\", got[0].SessionID, got[1].SessionID)\\n   462→\\t\\t}\\n   463→\\t})\\n   464→\\n   465→\\tt.Run(\\\"duplicate keeps newer\\\", func(t *testing.T) {\\n   466→\\t\\tt.Parallel()\\n   467→\\t\\texisting := []strategy.RestoredSession{\\n   468→\\t\\t\\t{SessionID: \\\"s1\\\", Prompt: \\\"old\\\", CreatedAt: t0},\\n   469→\\t\\t}\\n   470→\\t\\tincoming := []strategy.RestoredSession{\\n   471→\\t\\t\\t{SessionID: \\\"s1\\\", Prompt: \\\"new\\\", CreatedAt: t1},\\n   472→\\t\\t}\\n   473→\\t\\tgot := deduplicateSessions(existing, incoming)\\n   474→\\t\\tif len(got) != 1 {\\n   475→\\t\\t\\tt.Fatalf(\\\"got %d sessions, want 1\\\", len(got))\\n   476→\\t\\t}\\n   477→\\t\\tif got[0].Prompt != \\\"new\\\" {\\n   478→\\t\\t\\tt.Errorf(\\\"got prompt %q, want %q\\\", got[0].Prompt, \\\"new\\\")\\n   479→\\t\\t}\\n   480→\\t})\\n   481→\\n   482→\\tt.Run(\\\"duplicate keeps existing when newer\\\", func(t *testing.T) {\\n   483→\\t\\tt.Parallel()\\n   484→\\t\\texisting := []strategy.RestoredSession{\\n   485→\\t\\t\\t{SessionID: \\\"s1\\\", Prompt: \\\"newer\\\", CreatedAt: t1},\\n   486→\\t\\t}\\n   487→\\t\\tincoming := []strategy.RestoredSession{\\n   488→\\t\\t\\t{SessionID: \\\"s1\\\", Prompt: \\\"older\\\", CreatedAt: t0},\\n   489→\\t\\t}\\n   490→\\t\\tgot := deduplicateSessions(existing, incoming)\\n   491→\\t\\tif len(got) != 1 {\\n   492→\\t\\t\\tt.Fatalf(\\\"got %d sessions, want 1\\\", len(got))\\n   493→\\t\\t}\\n   494→\\t\\tif got[0].Prompt != \\\"newer\\\" {\\n   495→\\t\\t\\tt.Errorf(\\\"got prompt %q, want %q\\\", got[0].Prompt, \\\"newer\\\")\\n   496→\\t\\t}\\n   497→\\t})\\n   498→\\n   499→\\tt.Run(\\\"three occurrences keeps latest\\\", func(t *testing.T) {\\n 