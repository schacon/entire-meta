object.Tree, checkpointIDs []id.CheckpointID) []*strategy.CheckpointInfo {\\n   228→\\tvar checkpoints []*strategy.CheckpointInfo\\n   229→\\tfor _, cpID := range checkpointIDs {\\n   230→\\t\\tmetadata, err := strategy.ReadCheckpointMetadata(tree, cpID.Path())\\n   231→\\t\\tif err != nil {\\n   232→\\t\\t\\tcontinue\\n   233→\\t\\t}\\n   234→\\t\\tcheckpoints = append(checkpoints, metadata)\\n   235→\\t}\\n   236→\\tsort.Slice(checkpoints, func(i, j int) bool {\\n   237→\\t\\treturn checkpoints[i].CreatedAt.Before(checkpoints[j].CreatedAt)\\n   238→\\t})\\n   239→\\treturn checkpoints\\n   240→}\\n   241→\\n   242→// branchCheckpointsResult contains the result of searching for checkpoints on a branch.\\n   243→type branchCheckpointsResult struct {\\n   244→\\tcheckpointIDs     []id.CheckpointID\\n   245→\\tcommitHash        string\\n   246→\\tcommitMessage     string\\n   247→\\tnewerCommitsExist bool // true if there are branch-only commits (not merge commits) without checkpoints\\n   248→\\tnewerCommitCount  int  // count of branch-only commits without checkpoints\\n   249→}\\n   250→\\n   251→// findBranchCheckpoints finds the most recent commit with an Entire-Checkpoint trailer\\n   252→// among commits that are unique to this branch (not reachable from the default branch).\\n   253→// This handles the case where main has been merged into the feature branch.\\n   254→func findBranchCheckpoints(repo *git.Repository, branchName string) (*branchCheckpointsResult, error) {\\n   255→\\tresult := &branchCheckpointsResult{}\\n   256→\\n   257→\\t// Get HEAD commit\\n   258→\\thead, err := repo.Head()\\n   259→\\tif err != nil {\\n   260→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   261→\\t}\\n   262→\\n   263→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   264→\\tif err != nil {\\n   265→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   266→\\t}\\n   267→\\n   268→\\t// First, check if HEAD itself has a checkpoint (most common case)\\n   269→\\tif cpIDs := trailers.ParseAllCheckpoints(headCommit.Message); len(cpIDs) > 0 {\\n   270→\\t\\tresult.checkpointIDs = cpIDs\\n   271→\\t\\tresult.commitHash = head.Hash().String()\\n   272→\\t\\tresult.commitMessage = headCommit.Message\\n   273→\\t\\tresult.newerCommitsExist = false\\n   274→\\t\\treturn result, nil\\n   275→\\t}\\n   276→\\n   277→\\t// HEAD doesn't have a checkpoint - find branch-only commits\\n   278→\\t// Get the default branch name\\n   279→\\tdefaultBranch := getDefaultBranchFromRemote(repo)\\n   280→\\tif defaultBranch == \\\"\\\" {\\n   281→\\t\\t// Fallback: try common names\\n   282→\\t\\tfor _, name := range []string{\\\"main\\\", \\\"master\\\"} {\\n   283→\\t\\t\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(name), true); err == nil {\\n   284→\\t\\t\\t\\tdefaultBranch = name\\n   285→\\t\\t\\t\\tbreak\\n   286→\\t\\t\\t}\\n   287→\\t\\t}\\n   288→\\t}\\n   289→\\n   290→\\t// If we can't find a default branch, or we're on it, just walk all commits\\n   291→\\tif defaultBranch == \\\"\\\" || defaultBranch == branchName {\\n   292→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil\\n   293→\\t}\\n   294→\\n   295→\\t// Get the default branch reference\\n   296→\\tdefaultRef, err := repo.Reference(plumbing.NewBranchReferenceName(defaultBranch), true)\\n   297→\\tif err != nil {\\n   298→\\t\\t// Default branch doesn't exist locally, fall back to walking all commits\\n   299→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   300→\\t}\\n   301→\\n   302→\\tdefaultCommit, err := repo.CommitObject(defaultRef.Hash())\\n   303→\\tif err != nil {\\n   304→\\t\\t// Can't get default commit, fall back to walking all commits\\n   305→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   306→\\t}\\n   307→\\n   308→\\t// Find merge base\\n   309→\\tmergeBase, err := headCommit.MergeBase(defaultCommit)\\n   310→\\tif err != nil || len(mergeBase) == 0 {\\n   311→\\t\\t// No common ancestor, fall back to walking all commits\\n   312→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   313→\\t}\\n   314→\\n   315→\\t// Walk from HEAD to merge base, looking for checkpoint\\n   316→\\treturn findCheckpointInHistory(headCommit, &mergeBase[0].Hash), nil\\n   317→}\\n   318→\\n   319→// findCheckpointInHistory walks commit history from start looking for a checkpoint trailer.\\n   320→// If stopAt is provided, stops when reaching that commit (exclusive).\\n   321→// Returns the first checkpoint found and info about commits between HEAD and the checkpoint.\\n   322→// It distinguishes between merge commits (bringing in other branches) and regular commits\\n   323→// (actual branch work) to avoid false warnings after merging main.\\n   324→func findCheckpointInHistory(start *object.Commit, stopAt *plumbing.Hash) *branchCheckpointsResult {\\n   325→\\tresult := &branchCheckpointsResult{}\\n   326→\\tbranchWorkCommits := 0 // Regular commits without checkpoints (actual work)\\n   327→\\tconst maxCommits = 100 // Limit search depth\\n   328→\\ttotalChecked := 0\\n   329→\\n   330→\\tcurrent := start\\n   331→\\tfor current != nil && totalChecked < maxCommits {\\n   332→\\t\\t// Stop if we've reached the boundary\\n   333→\\t\\tif stopAt != nil && current.Hash == *stopAt {\\n   334→\\t\\t\\tbreak\\n   335→\\t\\t}\\n   336→\\n   337→\\t\\t// Check for checkpoint trailer\\n   338→\\t\\tif cpIDs := trailers.ParseAllCheckpoints(current.Message); len(cpIDs) > 0 {\\n   339→\\t\\t\\tresult.checkpointIDs = cpIDs\\n   340→\\t\\t\\tresult.commitHash = current.Hash.String()\\n   341→\\t\\t\\tresult.commitMessage = current.Message\\n   342→\\t\\t\\t// Only warn about branch work commits, not merge commits\\n   343→\\t\\t\\tresult.newerCommitsExist = branchWorkCommits > 0\\n   344→\\t\\t\\tresult.newerCommitCount = branchWorkCommits\\n   345→\\t\\t\\treturn result\\n   346→\\t\\t}\\n   347→\\n   348→\\t\\t// Only count regular commits (not merge commits) as \\\"branch work\\\"\\n   349→\\t\\tif current.NumParents() <= 1 {\\n   350→\\t\\t\\tbranchWorkCommits++\\n   351→\\t\\t}\\n   352→\\n   353→\\t\\ttotalChecked++\\n   354→\\n   355→\\t\\t// Move to parent (first parent for merge commits - follows the main line)\\n   356→\\t\\tif current.NumParents() == 0 {\\n   357→\\t\\t\\tbreak\\n   358→\\t\\t}\\n   359→\\t\\tparent, err := current.Parent(0)\\n   360→\\t\\tif err != nil {\\n   361→\\t\\t\\t// Can't get parent, treat as end of history\\n   362→\\t\\t\\tbreak\\n   363→\\t\\t}\\n   364→\\t\\tcurrent = parent\\n   365→\\t}\\n   366→\\n   367→\\t// No checkpoint found\\n   368→\\treturn result\\n   369→}\\n   370→\\n   371→// promptResumeFromOlderCheckpoint asks the user if they want to resume from an older checkpoint.\\n   372→func promptResumeFromOlderCheckpoint() (bool, error) {\\n   373→\\tvar confirmed bool\\n   374→\\n   375→\\tform := NewAccessibleForm(\\n   376→\\t\\thuh.NewGroup(\\n   377→\\t\\t\\thuh.NewConfirm().\\n   378→\\t\\t\\t\\tTitle(\\\"Resume from this older checkpoint?\\\").\\n   379→\\t\\t\\t\\tValue(&confirmed),\\n   380→\\t\\t),\\n   381→\\t)\\n   382→\\n   383→\\tif err := form.Run(); err != nil {\\n   384→\\t\\tif errors.Is(err, huh.ErrUserAborted) {\\n   385→\\t\\t\\treturn false, nil\\n   386→\\t\\t}\\n   387→\\t\\treturn false, fmt.Errorf(\\\"failed to get confirmation: %w\\\", err)\\n   388→\\t}\\n   389→\\n   390→\\treturn confirmed, nil\\n   391→}\\n   392→\\n   393→// checkRemoteMetadata checks if checkpoint metadata exists on origin/entire/checkpoints/v1\\n   394→// and automatically fetches it if available.\\n   395→func checkRemoteMetadata(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID) error {\\n   396→\\t// Try to get remote metadata branch tree\\n   397→\\tremoteTree, err := strategy.GetRemoteMetadataBranchTree(repo)\\n   398→\\tif err != nil {\\n   399→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   400→\\t\\tfmt.Fprintf(os.Stderr, \\\"The entire/checkpoints/v1 branch may not exist locally or on the remote.\\\\n\\\")\\n   401→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   402→\\t}\\n   403→\\n   404→\\t// Check if the checkpoint exists on the remote\\n   405→\\tmetadata, err := strategy.ReadCheckpointMetadata(remoteTree, checkpointID.Path())\\n   406→\\tif err != nil {\\n   407→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   408→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   409→\\t}\\n   410→\\n   411→\\t// Metadata exists on remote but not locally - fetch it automatically\\n   412→\\tfmt.Fprintf(os.Stderr, \\\"Fetching session metadata from origin...\\\\n\\\")\\n   413→\\tif err := FetchMetadataBranch(ctx); err != nil {\\n   414→\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to fetch metadata: %v\\\\n\\\", err)\\n   415→\\t\\tfmt.Fprintf(os.Stderr, \\\"You can try manually: git fetch origin entire/checkpoints/v1:entire/checkpoints/v1\\\\n\\\")\\n   416→\\t\\treturn NewSilentError(errors.New(\\\"failed to fetch metadata\\\"))\\n   417→\\t}\\n   418→\\n   419→\\t// Now resume the session with the fetched metadata\\n   420→\\treturn resumeSession(ctx, metadata.SessionID, checkpointID, false)\\n   421→}\\n   422→\\n   423→// resumeSession restores and displays the resume command for a specific session.\\n   424→// For multi-session checkpoints, restores ALL sessions and shows commands for each.\\n   425→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   426→func resumeSession(ctx context.Context, sessionID string, checkpointID id.CheckpointID, force bool) error {\\n   427→\\t// Read checkpoint metadata first to get agent type (matching rewind pattern)\\n   428→\\trepo, err := openRepository(ctx)\\n   429→\\tif err != nil {\\n   430→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   431→\\t}\\n   432→\\n   433→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   434→\\tif err != nil {\\n   435→\\t\\treturn fmt.Errorf(\\\"failed to get metadata branch: %w\\\", err)\\n   436→\\t}\\n   437→\\n   438→\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n   439→\\tif err != nil {\\n   440→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint metadata: %w\\\", err)\\n   441→\\t}\\n   442→\\n   443→\\t// Resolve agent from checkpoint metadata (same as rewind)\\n   444→\\tag, err := strategy.ResolveAgentForRewind(metadata.Agent)\\n   445→\\tif err != nil {\\n   446→\\t\\treturn fmt.Errorf(\\\"failed to resolve agent: %w\\\", err)\\n   447→\\t}\\n   448→\\n   449→\\t// Initialize logging context with agent\\n   450→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"resume\\\"), ag.Name())\\n   451→\\n   452→\\tlogging.Debug(logCtx, \\\"resume session started\\\",\\n   453→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   454→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   455→\\t)\\n   456→\\n   457→\\t// Get worktree root for session directory lookup\\n   458→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   459→\\tif err != nil {\\n   460→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   461→\\t}\\n   462→\\n   463→\\tsessionDir, err := ag.GetSessionDir(repoRoot)\\n   464→\\tif err != nil {\\n   465→\\t\\treturn fmt.Errorf(\\\"failed to determine session directory: %w\\\", err)\\n   466→\\t}\\n   467→\\n   468→\\t// Create directory if it doesn't exist\\n   469→\\tif err := os.MkdirAll(sessionDir, 0o700); err != nil {\\n   470→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   471→\\t}\\n   472→\\n   473→\\t// Get strategy and restore sessions using full checkpoint data\\n   474→\\tstrat := GetStrategy(ctx)\\n   475→\\n   476→\\t// Use RestoreLogsOnly via LogsOnlyRestorer interface for multi-session support\\n   477→\\t// Create a logs-only rewind point with Agent populated (same as rewind)\\n   478→\\tpoint := strategy.RewindPoint{\\n   479→\\t\\tIsLogsOnly:   true,\\n   480→\\t\\tCheckpointID: checkpointID,\\n   481→\\t\\tAgent:        metadata.Agent,\\n   482→\\t}\\n   483→\\n   484→\\tsessions, restoreErr := strat.RestoreLogsOnly(ctx, point, force)\\n   485→\\tif restoreErr != nil || len(sessions) == 0 {\\n   486→\\t\\t// Fall back to single-session restore (e.g., old checkpoints without agent metadata)\\n   487→\\t\\treturn resumeSingleSession(ctx, ag, sessionID, checkpointID, repoRoot, force)\\n   488→\\t}\\n   489→\\n   490→\\tlogging.Debug(logCtx, \\\"resume session completed\\\",\\n   491→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   492→\\t\\tslog.Int(\\\"session_count\\\", len(sessions)),\\n   493→\\t)\\n   494→\\n   495→\\treturn displayRestoredSessions(sessions)\\n   496→}\\n   497→\\n   498→// displayRestoredSessions sorts sessions by CreatedAt and prints resume commands.\\n   499→// Used by both resumeSession (single checkpoint) and resumeMultipleCheckpoints (squash merge).\\n   500→func displayRestoredSessions(sessions []strategy.RestoredSession) error {\\n   501→\\tsort.SliceStable(sessions, func(i, j int) bool {\\n   502→\\t\\treturn sessions[i].CreatedAt.Before(sessions[j].CreatedAt)\\n   503→\\t})\\n   504→\\n   505→\\tif len(sessions) > 1 {\\n   506→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nRestored %d sessions. To continue, run:\\\\n\\\", len(sessions))\\n   507→\\t} else if len(sessions) == 1 {\\n   508→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session: %s\\\\n\\\", sessions[0].SessionID)\\n   509→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   510→\\t}\\n   511→\\n   512→\\tfor i, sess := range sessions {\\n   513→\\t\\tsessionAgent, err := strategy.ResolveAgentForRewind(sess.Agent)\\n   514→\\t\\tif err != nil {\\n   515→\\t\\t\\treturn fmt.Errorf(\\\"failed to resolve agent for session %s: %w\\\", sess.SessionID, err)\\n   516→\\t\\t}\\n   517→\\t\\tcmd := sessionAgent.FormatResumeCommand(sess.SessionID)\\n   518→\\n   519→\\t\\tisLast := i == len(sessions)-1\\n   520→\\t\\tswitch {\\n   521→\\t\\tcase len(sessions) > 1 && isLast && sess.Prompt != \\\"\\\":\\n   522→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # %s (most recent)\\\\n\\\", cmd, sess.Prompt)\\n   523→\\t\\tcase len(sessions) > 1 && isLast:\\n   524→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # (most recent)\\\\n\\\", cmd)\\n   525→\\t\\tcase sess.Prompt != \\\"\\\":\\n   526→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s  # %s\\\\n\\\", cmd, sess.Prompt)\\n   527→\\t\\tdefault:\\n   528→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", cmd)\\n   529→\\t\\t}\\n   530→\\t}\\n   531→\\n   532→\\treturn nil\\n   533→}\\n   534→\\n   535→// resumeSingleSession restores a single session (fallback when multi-session restore fails).\\n   536→// Always overwrites existing session logs to ensure consistency with checkpoint state.\\n   537→// If force is false, prompts for confirmation when local log has newer timestamps.\\n   538→func resumeSingleSession(ctx context.Context, ag agent.Agent, sessionID string, checkpointID id.CheckpointID, repoRoot string, force bool) error {\\n   539→\\tsessionLogPath, err := resolveTranscriptPath(ctx, sessionID, ag)\\n   540→\\tif err != nil {\\n   541→\\t\\treturn fmt.Errorf(\\\"failed to resolve transcript path: %w\\\", err)\\n   542→\\t}\\n   543→\\n   544→\\tif checkpointID.IsEmpty() {\\n   545→\\t\\tlogging.Debug(ctx, \\\"resume session: empty checkpoint ID\\\",\\n   546→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   547→\\t\\t)\\n   548→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session '%s' found in commit trailer but session log not available\\\\n\\\", sessionID)\\n   549→\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   550→\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", ag.FormatResumeCommand(sessionID))\\n   551→\\t\\treturn nil\\n   552→\\t}\\n   553→\\n   554→\\tlogContent, _, err := checkpoint.LookupSessionLog(ctx, checkpointID)\\n   555→\\tif err != nil {\\n   556→\\t\\tif errors.Is(err, checkpoint.ErrCheckpointNotFound) || errors.Is(err, checkpoint.ErrNoTranscript) {\\n   557→\\t\\t\\tlogging.Debug(ctx, \\\"resume session completed (no metadata)\\\",\\n   558→\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   559→\\t\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   560→\\t\\t\\t)\\n   561→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Session '%s' found in commit trailer but session log not available\\\\n\\\", sessionID)\\n   562→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   563→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", ag.FormatResumeCommand(sessionID))\\n   564→\\t\\t\\treturn nil\\n   565→\\t\\t}\\n   566→\\t\\tlogging.Error(ctx, \\\"resume session failed\\\",\\n   567→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   568→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   569→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   570→\\t\\t)\\n   571→\\t\\treturn fmt.Errorf(\\\"failed to get session log: %w\\\", err)\\n   572→\\t}\\n   573→\\n   574→\\t// Check if local file has newer timestamps than checkpoint\\n   575→\\tif !force {\\n   576→\\t\\tlocalTime := paths.GetLastTimestampFromFile(sessionLogPath)\\n   577→\\t\\tcheckpointTime := paths.GetLastTimestampFromBytes(logContent)\\n   578→\\t\\tstatus := strategy.ClassifyTimestamps(localTime, checkpointTime)\\n   579→\\n   580→\\t\\tif status == strategy.StatusLocalNewer {\\n   581→\\t\\t\\tsessions := []strategy.SessionRestoreInfo{{\\n   582→\\t\\t\\t\\tSessionID:      sessionID,\\n   583→\\t\\t\\t\\tStatus:         status,\\n   584→\\t\\t\\t\\tLocalTime:      localTime,\\n   585→\\t\\t\\t\\tCheckpointTime: checkpointTime,\\n   586→\\t\\t\\t}}\\n   587→\\t\\t\\tshouldOverwrite, promptErr := strategy.PromptOverwriteNewerLogs(sessions)\\n   588→\\t\\t\\tif promptErr != nil {\\n   589→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to get confirmation: %w\\\", promptErr)\\n   590→\\t\\t\\t}\\n   591→\\t\\t\\tif !shouldOverwrite {\\n   592→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled. Local session log preserved.\\\\n\\\")\\n   593→\\t\\t\\t\\treturn nil\\n   594→\\t\\t\\t}\\n   595→\\t\\t}\\n   596→\\t}\\n   597→\\n   598→\\t// Ensure parent directory exists\\n   599→\\tif err := os.MkdirAll(filepath.Dir(sessionLogPath), 0o750); err != nil {\\n   600→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   601→\\t}\\n   602→\\n   603→\\tagentSession := &agent.AgentSession{\\n   604→\\t\\tSessionID:  sessionID,\\n   605→\\t\\tAgentName:  ag.Name(),\\n   606→\\t\\tRepoPath:   repoRoot,\\n   607→\\t\\tSessionRef: sessionLogPath,\\n   608→\\t\\tNativeData: logContent,\\n   609→\\t}\\n   610→\\n   611→\\t// Write the session using the agent's WriteSession method\\n   612→\\tif err := ag.WriteSession(ctx, agentSession); err != nil {\\n   613→\\t\\tlogging.Error(ctx, \\\"resume session failed during write\\\",\\n   614→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   615→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   616→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   617→\\t\\t)\\n   618→\\t\\treturn fmt.Errorf(\\\"failed to write session: %w\\\", err)\\n   619→\\t}\\n   620→\\n   621→\\tlogging.Debug(ctx, \\\"resume session completed\\\",\\n   622→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   623→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   624→\\t)\\n   625→\\n   626→\\tfmt.Fprintf(os.Stderr, \\\"Session restored to: %s\\\\n\\\", sessionLogPath)\\n   627→\\tfmt.Fprintf(os.Stderr, \\\"Session: %s\\\\n\\\", sessionID)\\n   628→\\tfmt.Fprintf(os.Stderr, \\\"\\\\nTo continue this session, run:\\\\n\\\")\\n   629→\\tfmt.Fprintf(os.Stderr, \\\"  %s\\\\n\\\", ag.FormatResumeCommand(sessionID))\\n   630→\\n   631→\\treturn nil\\n   632→}\\n   633→\\n   634→func promptFetchFromRemote(branchName string) (bool, error) {\\n   635→\\tvar confirmed bool\\n   636→\\n   637→\\tform := NewAccessibleForm(\\n   638→\\t\\thuh.NewGroup(\\n   639→\\t\\t\\thuh.NewConfirm().\\n   640→\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Branch '%s' not found locally. Fetch from origin?\\\", branchName)).\\n   641→\\t\\t\\t\\tValue(&confirmed),\\n   642→\\t\\t),\\n   643→\\t)\\n   644→\\n   645→\\tif err := form.Run(); err != nil {\\n   646→\\t\\tif errors.Is(err, huh.ErrUserAborted) {\\n   647→\\t\\t\\treturn false, nil\\n   648→\\t\\t}\\n   649→\\t\\treturn false, fmt.Errorf(\\\"failed to get confirmation: %w\\\", err)\\n   650→\\t}\\n   651→\\n   652→\\treturn confirmed, nil\\n   653→}\\n   654→\\n   655→// firstLine returns the first line of a string\\n   656→func firstLine(s string) string {\\n   657→\\tfor i, c := range s {\\n   658→\\t\\tif c == '\\\\n' {\\n   659→\\t\\t\\treturn s[:i]\\n   660→\\t\\t}\\n   661→\\t}\\n   662→\\treturn s\\n   663→}\\n   664→\"}]},\"uuid\":\"32de9bbb-e3ea-44d2-ac34-57d2bcd30a55\",\"timestamp\":\"2026-03-04T10:29:05.122Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/resume.go\",\"content\":\"package cli\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"sort\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n\\n\\t\\\"github.com/charmbracelet/huh\\\"\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n\\t\\\"github.com/spf13/cobra\\\"\\n)\\n\\nfunc newResumeCmd() *cobra.Command {\\n\\tvar force bool\\n\\n\\tcmd := &cobra.Command{\\n\\t\\tUse:   \\\"resume <branch>\\\",\\n\\t\\tShort: \\\"Switch to a branch and resume its session\\\",\\n\\t\\tLong: `Switch to a local branch and resume the agent session from its last commit.\\n\\nThis command:\\n1. Checks out the specified branch\\n2. Finds the session ID from commits unique to this branch (not on main)\\n3. Restores the session log if it doesn't exist locally\\n4. Shows the command to resume the session\\n\\nIf the branch doesn't exist locally but exists on origin, you'll be prompted\\nto fetch it.\\n\\nIf newer commits without checkpoints exist on the branch (e.g., after merging main\\nor cherry-picking from elsewhere), this operation will reset your Git status to the\\nmost recent commit with a checkpoint.  You'll be prompted to confirm resuming in this case.`,\\n\\t\\tArgs: cobra.ExactArgs(1),\\n\\t\\tRunE: func(cmd *cobra.Command, args []string) error {\\n\\t\\t\\tif checkDisabledGuard(cmd.Context(), cmd.OutOrStdout()) {\\n\\t\\t\\t\\treturn nil\\n\\t\\t\\t}\\n\\t\\t\\treturn runResume(cmd.Context(), args[0], force)\\n\\t\\t},\\n\\t}\\n\\n\\tcmd.Flags().BoolVarP(&force, \\\"force\\\", \\\"f\\\", false, \\\"Resume from older checkpoint without confirmation\\\")\\n\\n\\treturn cmd\\n}\\n\\nfunc runResume(ctx context.Context, branchName string, force bool) error {\\n\\t// Check if we're already on this branch\\n\\tcurrentBranch, err := GetCurrentBranch(ctx)\\n\\tif err == nil && currentBranch == branchName {\\n\\t\\t// Already on the branch, skip checkout\\n\\t\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n\\t}\\n\\n\\t// Check if branch exists locally\\n\\texists, err := BranchExistsLocally(ctx, branchName)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to check branch: %w\\\", err)\\n\\t}\\n\\n\\tif !exists {\\n\\t\\t// Branch doesn't exist locally, check if it exists on remote\\n\\t\\tremoteExists, err := BranchExistsOnRemote(ctx, branchName)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to check remote branch: %w\\\", err)\\n\\t\\t}\\n\\n\\t\\tif !remoteExists {\\n\\t\\t\\treturn fmt.Errorf(\\\"branch '%s' not found locally or on origin\\\", branchName)\\n\\t\\t}\\n\\n\\t\\t// Ask user if they want to fetch from remote\\n\\t\\tshouldFetch, err := promptFetchFromRemote(branchName)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn err\\n\\t\\t}\\n\\t\\tif !shouldFetch {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\t// Fetch and checkout the remote branch\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Fetching branch '%s' from origin...\\\\n\\\", branchName)\\n\\t\\tif err := FetchAndCheckoutRemoteBranch(ctx, branchName); err != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n\\t\\t}\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n\\t} else {\\n\\t\\t// Branch exists locally, check for uncommitted changes before checkout\\n\\t\\thasChanges, err := HasUncommittedChanges(ctx)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to check for uncommitted changes: %w\\\", err)\\n\\t\\t}\\n\\t\\tif hasChanges {\\n\\t\\t\\treturn errors.New(\\\"you have uncommitted changes. Please commit or stash them first\\\")\\n\\t\\t}\\n\\n\\t\\t// Checkout the branch\\n\\t\\tif err := CheckoutBranch(ctx, branchName); err != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n\\t\\t}\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n\\t}\\n\\n\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n}\\n\\nfunc resumeFromCurrentBranch(ctx context.Context, branchName string, force bool) error {\\n\\trepo, err := openRepository(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n\\t}\\n\\n\\t// Find a commit with an Entire-Checkpoint trailer, looking at branch-only commits\\n\\tresult, err := findBranchCheckpoints(repo, branchName)\\n\\tif err != nil {\\n\\t\\treturn err\\n\\t}\\n\\tif len(result.checkpointIDs) == 0 {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"No Entire checkpoint found on branch '%s'\\\\n\\\", branchName)\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// If there are newer commits without checkpoints, ask for confirmation.\\n\\t// Merge commits (e.g., from merging main) don't count as \\\"work\\\" and are skipped silently.\\n\\tif result.newerCommitsExist && !force {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Found checkpoint in an older commit.\\\\n\\\")\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"There are %d newer commit(s) on this branch without checkpoints.\\\\n\\\", result.newerCommitCount)\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint from: %s %s\\\\n\\\\n\\\", result.commitHash[:7], firstLine(result.commitMessage))\\n\\n\\t\\tshouldResume, err := promptResumeFromOlderCheckpoint()\\n\\t\\tif err != nil {\\n\\t\\t\\treturn err\\n\\t\\t}\\n\\t\\tif !shouldResume {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled.\\\\n\\\")\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t}\\n\\n\\tcheckpointID := result.checkpointIDs[0]\\n\\n\\t// Multiple checkpoints (squash merge): resolve latest and resume from it\\n\\tif len(result.checkpointIDs) > 1 {\\n\\t\\tlatest, err := resolveLatestCheckpoint(repo, result.checkpointIDs)\\n\\t\\tif err != nil {\\n\\t\\t\\t// Fallback: use last trailer\\n\\t\\t\\tlatest = result.checkpointIDs[len(result.checkpointIDs)-1]\\n\\t\\t}\\n\\t\\tskipped := len(result.checkpointIDs) - 1\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Found %d checkpoints on the latest commit in this branch, resuming from the latest (%d older checkpoints skipped)\\\\n\\\",\\n\\t\\t\\tlen(result.checkpointIDs), skipped)\\n\\t\\tcheckpointID = latest\\n\\t}\\n\\n\\t// Get metadata branch tree for lookups\\n\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n\\tif err != nil {\\n\\t\\t// No local metadata branch, check if remote has it\\n\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n\\t}\\n\\n\\t// Look up metadata from sharded path\\n\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n\\tif err != nil {\\n\\t\\t// Checkpoint exists in commit but no local metadata - check remote\\n\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n\\t}\\n\\n\\treturn resumeSession(ctx, metadata.SessionID, checkpointID, force)\\n}\\n\\n// resolveLatestCheckpoint reads metadata for each checkpoint ID and returns\\n// the one with the latest CreatedAt. It tries the local metadata branch first,\\n// then fetches from remote, then falls back to the remote tree directly.\\nfunc resolveLatestCheckpoint(repo *git.Repository, checkpointIDs []id.CheckpointID) (id.CheckpointID, error) {\\n\\tmetadataTree, err := getMetadataTree(repo)\\n\\tif err != nil {\\n\\t\\treturn id.EmptyCheckpointID, err\\n\\t}\\n\\tsorted := collectCheckpointsByAge(metadataTree, checkpointIDs)\\n\\tif len(sorted) == 0 {\\n\\t\\treturn id.EmptyCheckpointID, fmt.Errorf(\\\"no checkpoint metadata found\\\")\\n\\t}\\n\\treturn sorted[len(sorted)-1].CheckpointID, nil\\n}\\n\\n// getMetadataTree returns the metadata branch tree, trying local first,\\n// then fetching from remote, then falling back to the remote tree directly.\\nfunc getMetadataTree(repo *git.Repository) (*object.Tree, error) {\\n\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n\\tif err == nil {\\n\\t\\treturn metadataTree, nil\\n\\t}\\n\\n\\t// Try fetching from remote\\n\\tif fetchErr := FetchMetadataBranch(context.Background()); fetchErr == nil {\\n\\t\\tmetadataTree, err = strategy.GetMetadataBranchTree(repo)\\n\\t\\tif err == nil {\\n\\t\\t\\treturn metadataTree, nil\\n\\t\\t}\\n\\t}\\n\\n\\t// Try remote tree directly\\n\\treturn strategy.GetRemoteMetadataBranchTree(repo)\\n}\\n\\n// collectCheckpointsByAge reads metadata for each checkpoint ID from the tree,\\n// skips any that can't be read, and returns them sorted by CreatedAt ascending.\\n// Sorting ensures the newest checkpoint is restored last and wins on disk,\\n// regardless of trailer order in the commit message.\\nfunc collectCheckpointsByAge(tree *object.Tree, checkpointIDs []id.CheckpointID) []*strategy.CheckpointInfo {\\n\\tvar checkpoints []*strategy.CheckpointInfo\\n\\tfor _, cpID := range checkpointIDs {\\n\\t\\tmetadata, err := strategy.ReadCheckpointMetadata(tree, cpID.Path())\\n\\t\\tif err != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\tcheckpoints = append(checkpoints, metadata)\\n\\t}\\n\\tsort.Slice(checkpoints, func(i, j int) bool {\\n\\t\\treturn checkpoints[i].CreatedAt.Before(checkpoints[j].CreatedAt)\\n\\t})\\n\\treturn checkpoints\\n}\\n\\n// branchCheckpointsResult contains the result of searching for checkpoints on a branch.\\ntype branchCheckpointsResult struct {\\n\\tcheckpointIDs     []id.CheckpointID\\n\\tcommitHash        string\\n\\tcommitMessage     string\\n\\tnewerCommitsExist bool // true if there are branch-only commits (not merge commits) without checkpoints\\n\\tnewerCommitCount  int  // count of branch-only commits without checkpoints\\n}\\n\\n// findBranchCheckpoints finds the most recent commit with an Entire-Checkpoint trailer\\n// among commits that are unique to this branch (not reachable from the default branch).\\n// This handles the case where main has been merged into the feature branch.\\nfunc findBranchCheckpoints(repo *git.Repository, branchName string) (*branchCheckpointsResult, error) {\\n\\tresult := &branchCheckpointsResult{}\\n\\n\\t// Get HEAD commit\\n\\thead, err := repo.Head()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n\\t}\\n\\n\\theadCommit, err := repo.CommitObject(head.Hash())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n\\t}\\n\\n\\t// First, check if HEAD itself has a checkpoint (most common case)\\n\\tif cpIDs := trailers.ParseAllCheckpoints(headCommit.Message); len(cpIDs) > 0 {\\n\\t\\tresult.checkpointIDs = cpIDs\\n\\t\\tresult.commitHash = head.Hash().String()\\n\\t\\tresult.commitMessage = headCommit.Message\\n\\t\\tresult.newerCommitsExist = false\\n\\t\\treturn result, nil\\n\\t}\\n\\n\\t// HEAD doesn't have a checkpoint - find branch-only commits\\n\\t// Get the default branch name\\n\\tdefaultBranch := getDefaultBranchFromRemote(repo)\\n\\tif defaultBranch == \\\"\\\" {\\n\\t\\t// Fallback: try common names\\n\\t\\tfor _, name := range []string{\\\"main\\\", \\\"master\\\"} {\\n\\t\\t\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(name), true); err == nil {\\n\\t\\t\\t\\tdefaultBranch = name\\n\\t\\t\\t\\tbreak\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// If we can't find a default branch, or we're on it, just walk all commits\\n\\tif defaultBranch == \\\"\\\" || defaultBranch == branchName {\\n\\t\\treturn findCheckpointInHistory(headCommit, nil), nil\\n\\t}\\n\\n\\t// Get the default branch reference\\n\\tdefaultRef, err := repo.Reference(plumbing.NewBranchReferenceName(defaultBranch), true)\\n\\tif err != nil {\\n\\t\\t// Default branch doesn't exist locally, fall back to walking all commits\\n\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n\\t}\\n\\n\\tdefaultCommit, err := repo.CommitObject(defaultRef.Hash())\\n\\tif err != nil {\\n\\t\\t// Can't get default commit, fall back to walking all commits\\n\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n\\t}\\n\\n\\t// Find merge base\\n\\tmergeBase, err := headCommit.MergeBase(defaultCommit)\\n\\tif err != nil || len(mergeBase) == 0 {\\n\\t\\t// No common ancestor, fall back to walking all commits\\n\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n\\t}\\n\\n\\t// Walk from HEAD to merge base, looking for checkpoint\\n\\treturn findCheckpointInHistory(headCommit, &mergeBase[0].Hash), nil\\n}\\n\\n// findCheckpointInHistory walks commit history from start looking for a checkpoint trailer.\\n// If stopAt is provided, stops when reaching that commit (exclusive).\\n// Returns the first checkpoint found and info about commits between HEAD and the checkpoint.\\n// It distinguishes between merge commits (bringing in other branches) and regular commits\\n// (actual branch work) to avoid false warnings after merging main.\\nfunc findCheckpointInHistory(start *object.Commit, stopAt *plumbing.Hash) *branchCheckpointsResult {\\n\\tresult := &branchCheckpointsResult{}\\n\\tbranchWorkCommits := 0 // Regular commits without checkpoints (actual work)\\n\\tconst maxCommits = 100 // Limit search depth\\n\\ttotalChecked := 0\\n\\n\\tcurrent := start\\n\\tfor current != nil && totalChecked < maxCommits {\\n\\t\\t// Stop if we've reached the boundary\\n\\t\\tif stopAt != nil && current.Hash == *stopAt {\\n\\t\\t\\tbreak\\n\\t\\t}\\n\\n\\t\\t// Check for checkpoint trailer\\n\\t\\tif cpIDs := trailers.ParseAllCheckpoints(current.Message); len(cpIDs) > 0 {\\n\\t\\t\\tresult.checkpointIDs = cpIDs\\n\\t\\t\\tresult.commitHash = current.Hash.String()\\n\\t\\t\\tresult.commitMessage = current.Message\\n\\t\\t\\t// Only warn about branch work commits, not merge commits\\n\\t\\t\\tresult.newerCommitsExist = branchWorkCommits > 0\\n\\t\\t\\tresult.newerCommitCount = branchWorkCommits\\n\\t\\t\\treturn result\\n\\t\\t}\\n\\n\\t\\t// Only count regular commits (not merge commits) as \\\"branch work\\\"\\n\\t\\tif current.NumParents() <= 1 {\\n\\t\\t\\tbranchWorkCommits++\\n\\t\\t}\\n\\n\\t\\tto