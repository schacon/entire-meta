":\"kind-finding-toast\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01KesA58zUg69ejtr2spbWFm\",\"type\":\"tool_result\",\"content\":\"     1→package agent\\n     2→\\n     3→import (\\n     4→\\t\\\"encoding/json\\\"\\n     5→\\t\\\"errors\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"io\\\"\\n     8→\\t\\\"time\\\"\\n     9→)\\n    10→\\n    11→// EventType represents a normalized lifecycle event from any agent.\\n    12→// Agents translate their native hooks into these event types via ParseHookEvent.\\n    13→type EventType int\\n    14→\\n    15→const (\\n    16→\\t// SessionStart indicates the agent session has begun.\\n    17→\\tSessionStart EventType = iota + 1\\n    18→\\n    19→\\t// TurnStart indicates the user submitted a prompt and the agent is about to work.\\n    20→\\tTurnStart\\n    21→\\n    22→\\t// TurnEnd indicates the agent finished responding to a prompt.\\n    23→\\tTurnEnd\\n    24→\\n    25→\\t// Compaction indicates the agent is about to compress its context window.\\n    26→\\t// This triggers the same save logic as TurnEnd but also resets the transcript offset.\\n    27→\\tCompaction\\n    28→\\n    29→\\t// SessionEnd indicates the session has been terminated.\\n    30→\\tSessionEnd\\n    31→\\n    32→\\t// SubagentStart indicates a subagent (task) has been spawned.\\n    33→\\tSubagentStart\\n    34→\\n    35→\\t// SubagentEnd indicates a subagent (task) has completed.\\n    36→\\tSubagentEnd\\n    37→)\\n    38→\\n    39→// String returns a human-readable name for the event type.\\n    40→func (e EventType) String() string {\\n    41→\\tswitch e {\\n    42→\\tcase SessionStart:\\n    43→\\t\\treturn \\\"SessionStart\\\"\\n    44→\\tcase TurnStart:\\n    45→\\t\\treturn \\\"TurnStart\\\"\\n    46→\\tcase TurnEnd:\\n    47→\\t\\treturn \\\"TurnEnd\\\"\\n    48→\\tcase Compaction:\\n    49→\\t\\treturn \\\"Compaction\\\"\\n    50→\\tcase SessionEnd:\\n    51→\\t\\treturn \\\"SessionEnd\\\"\\n    52→\\tcase SubagentStart:\\n    53→\\t\\treturn \\\"SubagentStart\\\"\\n    54→\\tcase SubagentEnd:\\n    55→\\t\\treturn \\\"SubagentEnd\\\"\\n    56→\\tdefault:\\n    57→\\t\\treturn \\\"Unknown\\\"\\n    58→\\t}\\n    59→}\\n    60→\\n    61→// Event is a normalized lifecycle event produced by an agent's ParseHookEvent method.\\n    62→// The framework dispatcher uses these events to drive checkpoint/session lifecycle actions.\\n    63→type Event struct {\\n    64→\\t// Type is the kind of lifecycle event.\\n    65→\\tType EventType\\n    66→\\n    67→\\t// SessionID identifies the agent session.\\n    68→\\tSessionID string\\n    69→\\n    70→\\t// PreviousSessionID is non-empty when this event represents a session continuation\\n    71→\\t// or handoff (e.g., Claude starting a new session ID after exiting plan mode).\\n    72→\\tPreviousSessionID string\\n    73→\\n    74→\\t// SessionRef is an agent-specific reference to the transcript (typically a file path).\\n    75→\\tSessionRef string\\n    76→\\n    77→\\t// Prompt is the user's prompt text (populated on TurnStart events).\\n    78→\\tPrompt string\\n    79→\\n    80→\\t// Model is the LLM model identifier (e.g., \\\"claude-sonnet-4-20250514\\\").\\n    81→\\t// Populated on TurnStart events when the agent provides model info.\\n    82→\\tModel string\\n    83→\\n    84→\\t// Timestamp is when the event occurred.\\n    85→\\tTimestamp time.Time\\n    86→\\n    87→\\t// ToolUseID identifies the tool invocation (for SubagentStart/SubagentEnd events).\\n    88→\\tToolUseID string\\n    89→\\n    90→\\t// SubagentID identifies the subagent instance (for SubagentEnd events).\\n    91→\\tSubagentID string\\n    92→\\n    93→\\t// ToolInput is the raw tool input JSON (for subagent type/description extraction).\\n    94→\\t// Used when both SubagentType and TaskDescription are empty (agents that don't provide\\n    95→\\t// these fields directly parse them from ToolInput).\\n    96→\\tToolInput json.RawMessage\\n    97→\\n    98→\\t// SubagentType is the kind of subagent (for SubagentStart/SubagentEnd events).\\n    99→\\t// Used with TaskDescription instead of ToolInput\\n   100→\\tSubagentType    string\\n   101→\\tTaskDescription string\\n   102→\\n   103→\\t// ModifiedFiles is a list of file paths modified by a subagent.\\n   104→\\t// Populated on SubagentEnd events when the agent provides this data\\n   105→\\t// directly via hook payload (e.g., Cursor's subagentStop).\\n   106→\\tModifiedFiles []string\\n   107→\\n   108→\\t// ResponseMessage is an optional message to display to the user via the agent.\\n   109→\\tResponseMessage string\\n   110→\\n   111→\\t// Metadata holds agent-specific state that the framework stores and makes available\\n   112→\\t// on subsequent events. Examples: Pi's activeLeafId, Cursor's is_background_agent.\\n   113→\\tMetadata map[string]string\\n   114→}\\n   115→\\n   116→// ReadAndParseHookInput reads all bytes from stdin and unmarshals JSON into the given type.\\n   117→// This is a shared helper for agent ParseHookEvent implementations.\\n   118→func ReadAndParseHookInput[T any](stdin io.Reader) (*T, error) {\\n   119→\\tdata, err := io.ReadAll(stdin)\\n   120→\\tif err != nil {\\n   121→\\t\\treturn nil, fmt.Errorf(\\\"failed to read hook input: %w\\\", err)\\n   122→\\t}\\n   123→\\tif len(data) == 0 {\\n   124→\\t\\treturn nil, errors.New(\\\"empty hook input\\\")\\n   125→\\t}\\n   126→\\tvar result T\\n   127→\\tif err := json.Unmarshal(data, &result); err != nil {\\n   128→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse hook input: %w\\\", err)\\n   129→\\t}\\n   130→\\treturn &result, nil\\n   131→}\\n   132→\"}]},\"uuid\":\"d9c67585-6338-41ab-80e7-fd740f3172cf\",\"timestamp\":\"2026-03-05T10:29:31.066Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"ad5c9d8d6c2a4581b\"},\"toolUseID\":\"agent_msg_01UGbVEAacMxqeKWuhp8pFbZ\",\"parentToolUseID\":\"toolu_01S6TniapzHM4wwEcR