→\\tfor _, entry := range entries {\\n   412→\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   413→\\t\\t\\tcontinue\\n   414→\\t\\t}\\n   415→\\t\\tif strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   416→\\t\\t\\tcontinue // Skip temp files\\n   417→\\t\\t}\\n   418→\\n   419→\\t\\tsessionID := strings.TrimSuffix(entry.Name(), \\\".json\\\")\\n   420→\\t\\tstate, err := s.Load(ctx, sessionID)\\n   421→\\t\\tif err != nil {\\n   422→\\t\\t\\tcontinue // Skip corrupted state files\\n   423→\\t\\t}\\n   424→\\t\\tif state == nil {\\n   425→\\t\\t\\tcontinue // Not found or stale (Load handles cleanup)\\n   426→\\t\\t}\\n   427→\\n   428→\\t\\tstates = append(states, state)\\n   429→\\t}\\n   430→\\treturn states, nil\\n   431→}\\n   432→\\n   433→// stateFilePath returns the path to a session state file.\\n   434→func (s *StateStore) stateFilePath(sessionID string) string {\\n   435→\\treturn filepath.Join(s.stateDir, sessionID+\\\".json\\\")\\n   436→}\\n   437→\\n   438→// gitCommonDirCache caches the git common dir to avoid repeated subprocess calls.\\n   439→// Keyed by working directory to handle directory changes (same pattern as paths.WorktreeRoot).\\n   440→var (\\n   441→\\tgitCommonDirMu       sync.RWMutex\\n   442→\\tgitCommonDirCache    string\\n   443→\\tgitCommonDirCacheDir string\\n   444→)\\n   445→\\n   446→// ClearGitCommonDirCache clears the cached git common dir.\\n   447→// Useful for testing when changing directories.\\n   448→func ClearGitCommonDirCache() {\\n   449→\\tgitCommonDirMu.Lock()\\n   450→\\tgitCommonDirCache = \\\"\\\"\\n   451→\\tgitCommonDirCacheDir = \\\"\\\"\\n   452→\\tgitCommonDirMu.Unlock()\\n   453→}\\n   454→\\n   455→// getGitCommonDir returns the path to the shared git directory.\\n   456→// In a regular checkout, this is .git/\\n   457→// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n   458→// The result is cached per working directory.\\n   459→func getGitCommonDir(ctx context.Context) (string, error) {\\n   460→\\tcwd, err := os.Getwd() //nolint:forbidigo // used for cache key, not git-relative paths\\n   461→\\tif err != nil {\\n   462→\\t\\tcwd = \\\"\\\"\\n   463→\\t}\\n   464→\\n   465→\\t// Check cache with read lock first\\n   466→\\tgitCommonDirMu.RLock()\\n   467→\\tif gitCommonDirCache != \\\"\\\" && gitCommonDirCacheDir == cwd {\\n   468→\\t\\tcached := gitCommonDirCache\\n   469→\\t\\tgitCommonDirMu.RUnlock()\\n   470→\\t\\treturn cached, nil\\n   471→\\t}\\n   472→\\tgitCommonDirMu.RUnlock()\\n   473→\\n   474→\\t// Cache miss — resolve via git subprocess\\n   475→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-common-dir\\\")\\n   476→\\tcmd.Dir = \\\".\\\"\\n   477→\\toutput, err := cmd.Output()\\n   478→\\tif err != nil {\\n   479→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   480→\\t}\\n   481→\\n   482→\\tcommonDir := strings.TrimSpace(string(output))\\n   483→\\n   484→\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\n   485→\\t// so we need to make it absolute if it isn't already\\n   486→\\tif !filepath.IsAbs(commonDir) {\\n   487→\\t\\tcommonDir = filepath.Join(\\\".\\\", commonDir)\\n   488→\\t}\\n   489→\\tcommonDir = filepath.Clean(commonDir)\\n   490→\\n   491→\\tgitCommonDirMu.Lock()\\n   492→\\tgitCommonDirCache = commonDir\\n   493→\\tgitCommonDirCacheDir = cwd\\n   494→\\tgitCommonDirMu.Unlock()\\n   495→\\n   496→\\treturn commonDir, nil\\n   497→}\\n   498→\"}]},\"uuid\":\"54b4ed3d-dbd7-4564-9feb-11730fb50dbc\",\"timestamp\":\"2026-03-16T19:40:46.750Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"acb7b395331159785\"},\"toolUseID\":\"agent_msg_01MuT2vosUZmsApctX8H8zge\",\"parentToolUseID\":\"toolu_01Fpz9L7KM6L8Y7WZEfdQ9gw\",\"uuid\":\"1bacf937-07e9-4f9c-a84c-6641d6c5e350\",\"timestamp\":\"2026-03-16T19:40:47.026Z\",\"userType\":\"external\",\"cwd\":\"/Users/soph/Work