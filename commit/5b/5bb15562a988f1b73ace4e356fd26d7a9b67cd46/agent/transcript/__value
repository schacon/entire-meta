:= json.Marshal(agents.DefaultDroidModel())\\n   194→\\tif err != nil {\\n   195→\\t\\treturn fmt.Errorf(\\\"marshal model setting: %w\\\", err)\\n   196→\\t}\\n   197→\\trepoSettings[\\\"model\\\"] = json.RawMessage(modelJSON)\\n   198→\\n   199→\\t// High autonomy prevents Droid from asking for confirmation during\\n   200→\\t// interactive E2E tests, which would cause hangs waiting for input.\\n   201→\\trepoSettings[\\\"autonomyMode\\\"] = json.RawMessage(`\\\"auto-high\\\"`)\\n   202→\\trepoSettings[\\\"completionSound\\\"] = json.RawMessage(`\\\"off\\\"`)\\n   203→\\n   204→\\tout, err := json.MarshalIndent(repoSettings, \\\"\\\", \\\"  \\\")\\n   205→\\tif err != nil {\\n   206→\\t\\treturn fmt.Errorf(\\\"marshal repo-local droid settings: %w\\\", err)\\n   207→\\t}\\n   208→\\tout = append(out, '\\\\n')\\n   209→\\n   210→\\tif err := os.WriteFile(repoSettingsPath, out, 0o600); err != nil {\\n   211→\\t\\treturn fmt.Errorf(\\\"write repo-local droid settings %s: %w\\\", repoSettingsPath, err)\\n   212→\\t}\\n   213→\\treturn nil\\n   214→}\\n   215→\\n   216→func loadJSONMap(path, description string) (map[string]json.RawMessage, error) {\\n   217→\\tdata, err := os.ReadFile(path)\\n   218→\\tif err != nil {\\n   219→\\t\\treturn nil, fmt.Errorf(\\\"read %s at %s: %w\\\", description, path, err)\\n   220→\\t}\\n   221→\\n   222→\\tvar parsed map[string]json.RawMessage\\n   223→\\tif err := json.Unmarshal(data, &parsed); err != nil {\\n   224→\\t\\treturn nil, fmt.Errorf(\\\"parse %s at %s: %w\\\", description, path, err)\\n   225→\\t}\\n   226→\\tif parsed == nil {\\n   227→\\t\\tparsed = make(map[string]json.RawMessage)\\n   228→\\t}\\n   229→\\treturn parsed, nil\\n   230→}\\n   231→\\n   232→func ensureGitInfoExcludeContains(repoDir, entry string) error {\\n   233→\\texcludePath := filepath.Join(repoDir, \\\".git\\\", \\\"info\\\", \\\"exclude\\\")\\n   234→\\n   235→\\tdata, err := os.ReadFile(excludePath)\\n   236→\\tif err != nil && !errors.Is(err, os.ErrNotExist) {\\n   237→\\t\\treturn fmt.Errorf(\\\"read %s: %w\\\", excludePath, err)\\n   238→\\t}\\n   239→\\n   240→\\tnormalized := strings.ReplaceAll(string(data), \\\"\\\\r\\\\n\\\", \\\"\\\\n\\\")\\n   241→\\tfor _, line := range strings.Split(normalized, \\\"\\\\n\\\") {\\n   242→\\t\\tif strings.TrimSpace(line) == entry {\\n   243→\\t\\t\\treturn nil\\n   244→\\t\\t}\\n   245→\\t}\\n   246→\\n   247→\\tvar b strings.Builder\\n   248→\\tif len(data) > 0 {\\n   249→\\t\\tb.Write(data)\\n   250→\\t\\tif data[len(data)-1] != '\\\\n' {\\n   251→\\t\\t\\tb.WriteByte('\\\\n')\\n   252→\\t\\t}\\n   253→\\t}\\n   254→\\tb.WriteString(entry)\\n   255→\\tb.WriteByte('\\\\n')\\n   256→\\n   257→\\tif err := os.MkdirAll(filepath.Dir(excludePath), 0o755); err != nil {\\n   258→\\t\\treturn fmt.Errorf(\\\"create %s: %w\\\", filepath.Dir(excludePath), err)\\n   259→\\t}\\n   260→\\tif err := os.WriteFile(excludePath, []byte(b.String()), 0o644); err != nil {\\n   261→\\t\\treturn fmt.Errorf(\\\"write %s: %w\\\", excludePath, err)\\n   262→\\t}\\n   263→\\treturn nil\\n   264→}\\n   265→\\n   266→// ForEachAgent runs fn as a parallel subtest for every registered agent.\\n   267→// It handles repo setup, concurrency gating, context timeout, and cleanup.\\n   268→// The timeout is scaled by each agent's TimeoutMultiplier.\\n   269→//\\n   270→// If RunPrompt detects a transient API error (e.g. rate limit, token refresh\\n   271→// failure), it panics with errScenarioRestart. ForEachAgent recovers from the\\n   272→// panic and restarts the entire scenario with a fresh repository, up to\\n   273→// maxScenarioRestarts times. This avoids stale CLI session state from the\\n   274→// failed attempt poisoning the retry.\\n   275→func ForEachAgent(t *testing.T, timeout time.Duration, fn func(t *testing.T, s *RepoState, ctx context.Context)) {\\n   276→\\tt.Helper()\\n   277→\\tt.Parallel()\\n   278→\\tall := agents.All()\\n   279→\\tif len(all) == 0 {\\n   280→\\t\\tt.Skip(\\\"no agents registered (check E2E_AGENT filter)\\\")\\n   281→\\t}\\n   282→\\tfor _, agent := range all {\\n   283→\\t\\tt.Run(agent.Name(), func(t *testing.T) {\\n   284→\\t\\t\\t// Use the global test deadline for slot wait so we don't\\n   285→\\t\\t\\t// skip prematurely — only bail if the whole binary is dying.\\n   286→\\t\\t\\tslotCtx := context.Background()\\n   287→\\t\\t\\tif deadline, ok := t.Deadline(); ok {\\n   288→\\t\\t\\t\\tvar cancel context.CancelFunc\\n   289→\\t\\t\\t\\tslotCtx, cancel = context.WithDeadline(slotCtx, deadline)\\n   290→\\t\\t\\t\\tdefer cancel()\\n   291→\\t\\t\\t}\\n   292→\\t\\t\\tif err := agents.AcquireSlot(slotCtx, agent); err != nil {\\n   293→\\t\\t\\t\\tt.Fatalf(\\\"timed out waiting for agent slot: %v\\\", err)\\n   294→\\t\\t\\t}\\n   295→\\t\\t\\tdefer agents.ReleaseSlot(agent)\\n   296→\\n   297→\\t\\t\\t// Per-test timeout starts after slot is acquired, scaled\\n   298→\\t\\t\\t// by the agent's multiplier (e.g. 2.5× for gemini).\\n   299→\\t\\t\\tscaled := time.Duration(float64(timeout) * agent.TimeoutMultiplier())\\n   300→\\n   301→\\t\\t\\tvar prevState *RepoState\\n   302→\\t\\t\\tfor attempt := range maxScenarioRestarts + 1 {\\n   303→\\t\\t\\t\\ts := SetupRepo(t, agent)\\n   304→\\t\\t\\t\\tctx, cancel := context.WithTimeout(context.Background(), scaled)\\n   305→\\n   306→\\t\\t\\t\\t// On restart, suppress artifact capture from the previous\\n   307→\\t\\t\\t\\t// failed attempt so it doesn't overwrite the final one.\\n   308→\\t\\t\\t\\tif prevState != nil {\\n   309→\\t\\t\\t\\t\\tprevState.skipArtifacts = true\\n   310→\\t\\t\\t\\t}\\n   311→\\n   312→\\t\\t\\t\\trestarted := runScenario(t, s, ctx, fn)\\n   313→\\t\\t\\t\\tcancel()\\n   314→\\n   315→\\t\\t\\t\\tif !restarted {\\n   316→\\t\\t\\t\\t\\treturn\\n   317→\\t\\t\\t\\t}\\n   318→\\t\\t\\t\\tprevState = s\\n   319→\\t\\t\\t\\tif attempt >= maxScenarioRestarts {\\n   320→\\t\\t\\t\\t\\tt.Fatalf(\\\"exhausted %d scenario attempts due to transient API errors\\\", maxScenarioRestarts+1)\\n   321→\\t\\t\\t\\t}\\n   322→\\t\\t\\t\\tt.Logf(\\\"transient error, restarting scenario (attempt %d/%d)\\\", attempt+2, maxScenarioRestarts+1)\\n   323→\\t\\t\\t}\\n   324→\\t\\t})\\n   325→\\t}\\n   326→}\\n   327→\\n   328→// runScenario runs the test function and recovers from errScenarioRestart\\n   329→// panics triggered by transient API errors in RunPrompt. Returns true if\\n   330→// the scenario should be restarted with a fresh repository.\\n   331→func runScenario(t *testing.T, s *RepoState, ctx context.Context, fn func(t *testing.T, s *RepoState, ctx context.Context)) (restarted bool) {\\n   332→\\tt.Helper()\\n   333→\\tdefer func() {\\n   334→\\t\\tif r := recover(); r != nil {\\n   335→\\t\\t\\tif _, ok := r.(errScenarioRestart); ok {\\n   336→\\t\\t\\t\\trestarted = true\\n   337→\\t\\t\\t\\treturn\\n   338→\\t\\t\\t}\\n   339→\\t\\t\\tpanic(r) // re-panic for unexpected panics\\n   340→\\t\\t}\\n   341→\\t}()\\n   342→\\tfn(t, s, ctx)\\n   343→\\treturn false\\n   344→}\\n   345→\\n   346→const maxScenarioRestarts = 2 // restart up to 2 times = 3 total attempts\\n   347→\\n   348→// errScenarioRestart is panicked by RunPrompt when a transient API error is\\n   349→// detected. ForEachAgent recovers from this panic and restarts the test\\n   350→// scenario with a fresh repository, avoiding stale CLI state from the failed\\n   351→// attempt.\\n   352→type errScenarioRestart struct {\\n   353→\\tmsg string\\n   354→}\\n   355→\\n   356→// RunPrompt runs an agent prompt, logs the command and output to ConsoleLog,\\n   357→// and returns the result. If the agent reports a transient API error, it\\n   358→// panics with errScenarioRestart to trigger a full scenario restart in\\n   359→// ForEachAgent (see runScenario).\\n   360→func (s *RepoState) RunPrompt(t *testing.T, ctx context.Context, prompt string, opts ...agents.Option) (agents.Output, error) {\\n   361→\\tt.Helper()\\n   362→\\tout, err := s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n   363→\\ts.logPromptResult(out)\\n   364→\\n   365→\\tif err != nil && s.Agent.IsTransientError(out, err) {\\n   366→\\t\\terrMsg := fmt.Sprintf(\\\"transient API error (stderr: %s)\\\", strings.TrimSpace(out.Stderr))\\n   367→\\t\\tt.Logf(\\\"%s — restarting scenario\\\", errMsg)\\n   368→\\t\\tfmt.Fprintf(s.ConsoleLog, \\\"> [transient] %s — restarting scenario\\\\n\\\", errMsg)\\n   369→\\t\\tpanic(errScenarioRestart{msg: errMsg})\\n   370→\\t}\\n   371→\\n   372→\\treturn out, err\\n   373→}\\n   374→\\n   375→func (s *RepoState) logPromptResult(out agents.Output) {\\n   376→\\ts.ConsoleLog.WriteString(\\\"> \\\" + out.Command + \\\"\\\\n\\\")\\n   377→\\ts.ConsoleLog.WriteString(\\\"stdout:\\\\n\\\" + out.Stdout + \\\"\\\\n\\\")\\n   378→\\ts.ConsoleLog.WriteString(\\\"stderr:\\\\n\\\" + out.Stderr + \\\"\\\\n\\\")\\n   379→}\\n   380→\\n   381→// Git runs a git command in the repo and logs it to ConsoleLog.\\n   382→func (s *RepoState) Git(t *testing.T, args ...string) {\\n   383→\\tt.Helper()\\n   384→\\ts.ConsoleLog.WriteString(\\\"> git \\\" + strings.Join(args, \\\" \\\") + \\\"\\\\n\\\")\\n   385→\\tGit(t, s.Dir, args...)\\n   386→}\\n   387→\\n   388→// StartSession starts an interactive session and registers it for pane\\n   389→// capture in artifacts. Returns nil if the agent does not support interactive\\n   390→// mode. The session is closed automatically during test cleanup.\\n   391→func (s *RepoState) StartSession(t *testing.T, ctx context.Context) agents.Session {\\n   392→\\tt.Helper()\\n   393→\\tsession, err := s.Agent.StartSession(ctx, s.Dir)\\n   394→\\tif err != nil {\\n   395→\\t\\tt.Fatalf(\\\"start session: %v\\\", err)\\n   396→\\t}\\n   397→\\tif session == nil {\\n   398→\\t\\treturn nil\\n   399→\\t}\\n   400→\\ts.session = session\\n   401→\\treturn session\\n   402→}\\n   403→\\n   404→// WaitFor waits for a pattern in the interactive session's pane and logs the\\n   405→// pane content to ConsoleLog after the wait completes (success or failure).\\n   406→func (s *RepoState) WaitFor(t *testing.T, session agents.Session, pattern string, timeout time.Duration) {\\n   407→\\tt.Helper()\\n   408→\\tcontent, err := session.WaitFor(pattern, timeout)\\n   409→\\tfmt.Fprintf(s.ConsoleLog, \\\"> pane after WaitFor(%q):\\\\n%s\\\\n\\\", pattern, content)\\n   410→\\tif err != nil {\\n   411→\\t\\tt.Fatalf(\\\"WaitFor(%q): %v\\\", pattern, err)\\n   412→\\t}\\n   413→}\\n   414→\\n   415→// IsExternalAgent returns true if the agent implements the ExternalAgent\\n   416→// interface and reports itself as external.\\n   417→func (s *RepoState) IsExternalAgent() bool {\\n   418→\\tea, ok := s.Agent.(agents.ExternalAgent)\\n   419→\\treturn ok && ea.IsExternalAgent()\\n   420→}\\n   421→\\n   422→// Send sends input to an interactive session and logs it to ConsoleLog.\\n   423→// Fails the test on error.\\n   424→func (s *RepoState) Send(t *testing.T, session agents.Session, input string) {\\n   425→\\tt.Helper()\\n   426→\\ts.ConsoleLog.WriteString(\\\"> send: \\\" + input + \\\"\\\\n\\\")\\n   427→\\tif err := session.Send(input); err != nil {\\n   428→\\t\\tt.Fatalf(\\\"send failed: %v\\\", err)\\n   429→\\t}\\n   430→}\\n   431→\\n   432→// PatchSettings merges extra keys into .entire/settings.json.\\n   433→func PatchSettings(t *testing.T, dir string, extra map[string]any) {\\n   434→\\tt.Helper()\\n   435→\\tpath := filepath.Join(dir, \\\".entire\\\", \\\"settings.json\\\")\\n   436→\\tdata, err := os.ReadFile(path)\\n   437→\\tif err != nil {\\n   438→\\t\\tt.Fatalf(\\\"read settings: %v\\\", err)\\n   439→\\t}\\n   440→\\tvar settings map[string]any\\n   441→\\tif err := json.Unmarshal(data, &settings); err != nil {\\n   442→\\t\\tt.Fatalf(\\\"parse settings: %v\\\", err)\\n   443→\\t}\\n   444→\\tfor k, v := range extra {\\n   445→\\t\\tsettings[k] = v\\n   446→\\t}\\n   447→\\tout, err := json.MarshalIndent(settings, \\\"\\\", \\\"  \\\")\\n   448→\\tif err != nil {\\n   449→\\t\\tt.Fatalf(\\\"marshal settings: %v\\\", err)\\n   450→\\t}\\n   451→\\tif err := os.WriteFile(path, out, 0o644); err != nil {\\n   452→\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n   453→\\t}\\n   454→}\\n   455→\\n   456→// Git runs a git command in the given directory and fails the test if it\\n   457→// returns a non-zero exit code.\\n   458→func Git(t *testing.T, dir string, args ...string) {\\n   459→\\tt.Helper()\\n   460→\\n   461→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   462→\\tif dir != \\\"\\\" {\\n   463→\\t\\tcmd.Dir = dir\\n   464→\\t}\\n   465→\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   466→\\n   467→\\tout, err := cmd.CombinedOutput()\\n   468→\\tif err != nil {\\n   469→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n   470→\\t}\\n   471→}\\n   472→\\n   473→// GitOutput runs a git command in the given directory, returns its trimmed\\n   474→// stdout, and fails the test on error.\\n   475→func GitOutput(t *testing.T, dir string, args ...string) string {\\n   476→\\tt.Helper()\\n   477→\\n   478→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   479→\\tif dir != \\\"\\\" {\\n   480→\\t\\tcmd.Dir = dir\\n   481→\\t}\\n   482→\\n   483→\\tout, err := cmd.Output()\\n   484→\\tif err != nil {\\n   485→\\t\\tvar stderr string\\n   486→\\t\\tee := &exec.ExitError{}\\n   487→\\t\\tif errors.As(err, &ee) {\\n   488→\\t\\t\\tstderr = string(ee.Stderr)\\n   489→\\t\\t}\\n   490→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, stderr)\\n   491→\\t}\\n   492→\\n   493→\\treturn strings.TrimSpace(string(out))\\n   494→}\\n   495→\\n   496→// NewCheckpointCommits returns the SHAs of commits added to the\\n   497→// entire/checkpoints/v1 branch since the test was set up, oldest first.\\n   498→func NewCheckpointCommits(t *testing.T, s *RepoState) []string {\\n   499→\\tt.Helper()\\n   500→\\n   501→\\tlog := GitOutput(t, s.Dir, \\\"log\\\", \\\"--reverse\\\", \\\"--format=%H\\\", s.CheckpointBefore+\\\"..entire/checkpoints/v1\\\")\\n   502→\\tif log == \\\"\\\" {\\n   503→\\t\\treturn nil\\n   504→\\t}\\n   505→\\treturn strings.Split(log, \\\"\\\\n\\\")\\n   506→}\\n   507→\\n   508→// CheckpointIDs lists all checkpoint IDs from the tree at the tip of the\\n   509→// checkpoint branch. It parses the two-level directory structure\\n   510→// ({prefix}/{suffix}/metadata.json) and returns the concatenated IDs.\\n   511→func CheckpointIDs(t *testing.T, dir string) []string {\\n   512→\\tt.Helper()\\n   513→\\tout := gitOutputSafe(dir, \\\"ls-tree\\\", \\\"-r\\\", \\\"--name-only\\\", \\\"entire/checkpoints/v1\\\")\\n   514→\\tif out == \\\"\\\" {\\n   515→\\t\\treturn nil\\n   516→\\t}\\n   517→\\tseen := map[string]bool{}\\n   518→\\tvar ids []string\\n   519→\\tfor _, line := range strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\") {\\n   520→\\t\\t// Match {prefix}/{suffix}/metadata.json (top-level, not session-level)\\n   521→\\t\\tparts := strings.Split(line, \\\"/\\\")\\n   522→\\t\\tif len(parts) == 3 && parts[2] == \\\"metadata.json\\\" {\\n   523→\\t\\t\\tid := parts[0] + parts[1]\\n   524→\\t\\t\\tif !seen[id] {\\n   525→\\t\\t\\t\\tseen[id] = true\\n   526→\\t\\t\\t\\tids = append(ids, id)\\n   527→\\t\\t\\t}\\n   528→\\t\\t}\\n   529→\\t}\\n   530→\\treturn ids\\n   531→}\\n   532→\\n   533→// ReadCheckpointMetadata reads the checkpoint-level metadata.json from the\\n   534→// tip of the checkpoint branch for the given checkpoint ID.\\n   535→func ReadCheckpointMetadata(t *testing.T, dir string, checkpointID string) CheckpointMetadata {\\n   536→\\tt.Helper()\\n   537→\\n   538→\\tpath := CheckpointPath(checkpointID) + \\\"/metadata.json\\\"\\n   539→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   540→\\n   541→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   542→\\n   543→\\tvar meta CheckpointMetadata\\n   544→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   545→\\t\\tt.Fatalf(\\\"unmarshal checkpoint metadata from %s: %v\\\", blob, err)\\n   546→\\t}\\n   547→\\n   548→\\treturn meta\\n   549→}\\n   550→\\n   551→// ReadSessionMetadata reads a session's metadata.json from the tip of the\\n   552→// checkpoint branch for the given checkpoint ID and session index.\\n   553→func ReadSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int) SessionMetadata {\\n   554→\\tt.Helper()\\n   555→\\n   556→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   557→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   558→\\n   559→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   560→\\n   561→\\tvar meta SessionMetadata\\n   562→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   563→\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   564→\\t}\\n   565→\\n   566→\\treturn meta\\n   567→}\\n   568→\\n   569→// WaitForSessionMetadata polls until session metadata exists on the checkpoint\\n   570→// branch for the given checkpoint ID and session index, then returns it.\\n   571→// This handles the race where the checkpoint branch advances before session\\n   572→// metadata is fully committed.\\n   573→func WaitForSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int, timeout time.Duration) SessionMetadata {\\n   574→\\tt.Helper()\\n   575→\\n   576→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   577→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   578→\\n   579→\\tdeadline := time.Now().Add(timeout)\\n   580→\\tfor time.Now().Before(deadline) {\\n   581→\\t\\traw := gitOutputSafe(dir, \\\"show\\\", blob)\\n   582→\\t\\tif raw != \\\"\\\" {\\n   583→\\t\\t\\tvar meta SessionMetadata\\n   584→\\t\\t\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   585→\\t\\t\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", 