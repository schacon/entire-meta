Name),\\n    48→\\t\\tslog.String(\\\"hook_type\\\", \\\"git\\\"),\\n    49→\\t\\tslog.String(\\\"strategy\\\", strategy.StrategyNameManualCommit),\\n    50→\\t}\\n    51→\\tlogging.Debug(g.ctx, g.hookName+\\\" hook invoked\\\", append(attrs, extraAttrs...)...)\\n    52→}\\n    53→\\n    54→// logCompleted records the error on the perf span.\\n    55→func (g *gitHookContext) logCompleted(err error) {\\n    56→\\tg.span.RecordError(err)\\n    57→}\\n    58→\\n    59→// initHookLogging initializes logging for hooks by finding the most recent session.\\n    60→// Returns a cleanup function that should be deferred.\\n    61→// If Entire is not set up or disabled, returns a no-op to avoid creating files.\\n    62→func initHookLogging(ctx context.Context) func() {\\n    63→\\t// Don't create any files if Entire is not set up or disabled.\\n    64→\\t// This is checked here as defense-in-depth (also checked in PersistentPreRunE).\\n    65→\\tif !settings.IsSetUpAndEnabled(ctx) {\\n    66→\\t\\treturn func() {}\\n    67→\\t}\\n    68→\\n    69→\\t// Set up log level getter so logging can read from settings\\n    70→\\tlogging.SetLogLevelGetter(GetLogLevel)\\n    71→\\n    72→\\t// Read session ID for the slog attribute (empty string is fine - log file is fixed)\\n    73→\\tsessionID := strategy.FindMostRecentSession(ctx)\\n    74→\\tif err := logging.Init(ctx, sessionID); err != nil {\\n    75→\\t\\t// Init failed - logging will use stderr fallback\\n    76→\\t\\treturn func() {}\\n    77→\\t}\\n    78→\\treturn logging.Close\\n    79→}\\n    80→\\n    81→// hookLogCleanup stores the cleanup function for hook logging.\\n    82→// Set by PersistentPreRunE, called by PersistentPostRunE.\\n    83→var hookLogCleanup func()\\n    84→\\n    85→func newHooksGitCmd() *cobra.Command {\\n    86→\\tcmd := &cobra.Command{\\n    87→\\t\\tUse:    \\\"git\\\",\\n    88→\\t\\tShort:  \\\"Git hook handlers\\\",\\n    89→\\t\\tLong:   \\\"Commands called by git hooks. These delegate to the c