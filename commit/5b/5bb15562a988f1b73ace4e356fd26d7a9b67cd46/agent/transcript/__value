\t\\treturn 0, fmt.Errorf(\\\"failed to create hooks directory: %w\\\", err)\\n   219→\\t}\\n   220→\\n   221→\\tcmdPrefix, err := hookCmdPrefix(localDev, absolutePath)\\n   222→\\tif err != nil {\\n   223→\\t\\treturn 0, err\\n   224→\\t}\\n   225→\\tspecs := buildHookSpecs(cmdPrefix)\\n   226→\\tinstalledCount := 0\\n   227→\\n   228→\\tfor _, spec := range specs {\\n   229→\\t\\thookPath := filepath.Join(hooksDir, spec.name)\\n   230→\\t\\tbackupPath := hookPath + backupSuffix\\n   231→\\t\\tbackupExists := fileExists(backupPath)\\n   232→\\n   233→\\t\\t// Back up existing non-Entire hooks\\n   234→\\t\\texisting, existingErr := os.ReadFile(hookPath) //nolint:gosec // path is controlled\\n   235→\\t\\tif existingErr == nil && !strings.Contains(string(existing), entireHookMarker) {\\n   236→\\t\\t\\tif !backupExists {\\n   237→\\t\\t\\t\\tif err := os.Rename(hookPath, backupPath); err != nil {\\n   238→\\t\\t\\t\\t\\treturn installedCount, fmt.Errorf(\\\"failed to back up %s: %w\\\", spec.name, err)\\n   239→\\t\\t\\t\\t}\\n   240→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Backed up existing %s to %s%s\\\\n\\\", spec.name, spec.name, backupSuffix)\\n   241→\\t\\t\\t} else {\\n   242→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: replacing %s (backup %s%s already exists from a previous install)\\\\n\\\", spec.name, spec.name, backupSuffix)\\n   243→\\t\\t\\t}\\n   244→\\t\\t\\tbackupExists = true\\n   245→\\t\\t}\\n   246→\\n   247→\\t\\t// Chain to backup if one exists\\n   248→\\t\\tcontent := spec.content\\n   249→\\t\\tif backupExists {\\n   250→\\t\\t\\tcontent = generateChainedContent(spec.content, spec.name)\\n   251→\\t\\t}\\n   252→\\n   253→\\t\\twritten, err := writeHookFile(hookPath, content)\\n   254→\\t\\tif err != nil {\\n   255→\\t\\t\\treturn installedCount, fmt.Errorf(\\\"failed to install %s hook: %w\\\", spec.name, err)\\n   256→\\t\\t}\\n   257→\\t\\tif written {\\n   258→\\t\\t\\tinstalledCount++\\n   259→\\t\\t}\\n   260→\\t}\