CURSOR_API_KEY env var or OAuth.\\n    66→\\t// On CI, ensure CURSOR_API_KEY is set. Locally, OAuth/keychain works.\\n    67→\\tif os.Getenv(\\\"CI\\\") != \\\"\\\" && os.Getenv(\\\"CURSOR_API_KEY\\\") == \\\"\\\" {\\n    68→\\t\\treturn errors.New(\\\"CURSOR_API_KEY must be set on CI for cursor-cli E2E tests\\\")\\n    69→\\t}\\n    70→\\treturn nil\\n    71→}\\n    72→\\n    73→func (a *CursorCLI) RunPrompt(ctx context.Context, dir string, prompt string, opts ...Option) (Output, error) {\\n    74→\\tcfg := &runConfig{}\\n    75→\\tfor _, o := range opts {\\n    76→\\t\\to(cfg)\\n    77→\\t}\\n    78→\\n    79→\\ttimeout := 90 * time.Second\\n    80→\\tif cfg.PromptTimeout > 0 {\\n    81→\\t\\ttimeout = cfg.PromptTimeout\\n    82→\\t}\\n    83→\\n    84→\\tdisplayCmd := a.Binary() + \\\" --force --workspace \\\" + dir + \\\" (interactive prompt: \\\" + prompt + \\\")\\\"\\n    85→\\n    86→\\t// Start an interactive tmux session so all hooks fire\\n    87→\\t// (beforeSubmitPrompt and stop don't fire in headless -p mode).\\n    88→\\ts, err := a.startInteractiveSession(dir)\\n    89→\\tif err != nil {\\n    90→\\t\\treturn Output{Command: displayCmd, ExitCode: -1},\\n    91→\\t\\t\\tfmt.Errorf(\\\"start interactive session: %w\\\", err)\\n    92→\\t}\\n    93→\\tdefer s.Close()\\n    94→\\n    95→\\t// Wait for trust dialog and accept it.\\n    96→\\tif err := a.acceptTrustDialogIfNeeded(s); err != nil {\\n    97→\\t\\treturn Output{Command: displayCmd, Stdout: s.Capture(), ExitCode: -1}, err\\n    98→\\t}\\n    99→\\n   100→\\t// Wait for the TUI to be ready.\\n   101→\\tif _, err := s.WaitFor(a.PromptPattern(), 30*time.Second); err != nil {\\n   102→\\t\\treturn Output{Command: displayCmd, Stdout: s.Capture(), ExitCode: -1},\\n   103→\\t\\t\\tfmt.Errorf(\\\"waiting for startup prompt: %w\\\", err)\\n   104→\\t}\\n   105→\\n   106→\\t// Send the prompt.\\n   107→\\tif err := s.Send(prompt); err != nil {\\n   108→\\t\\treturn Output{Command: displayCmd, Stdout: s.C