on\\\"\\n    23→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    25→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    26→\\t\\\"github.com/entireio/cli/perf\\\"\\n    27→)\\n    28→\\n    29→// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n    30→// Returns nil if the event was handled successfully.\\n    31→func DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    32→\\tif ag == nil {\\n    33→\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    34→\\t}\\n    35→\\tif event == nil {\\n    36→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    37→\\t}\\n    38→\\n    39→\\tswitch event.Type {\\n    40→\\tcase agent.SessionStart:\\n    41→\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n    42→\\tcase agent.TurnStart:\\n    43→\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n    44→\\tcase agent.TurnEnd:\\n    45→\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n    46→\\tcase agent.Compaction:\\n    47→\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n    48→\\tcase agent.SessionEnd:\\n    49→\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n    50→\\tcase agent.SubagentStart:\\n    51→\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n    52→\\tcase agent.SubagentEnd:\\n    53→\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n    54→\\tcase agent.ModelUpdate:\\n    55→\\t\\treturn handleLifecycleModelUpdate(ctx, ag, event)\\n    56→\\tdefault:\\n    57→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    58→\\t}\\n    59→}\\n    60→\\n    61→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    62→// fires state machine transition.\\n    63→func handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    64→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n    65→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    66→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    67→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    68→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    69→\\t\\tslog.String(\\\"model\\\", event.Model),\\n    70→\\t)\\n    71→\\n    72→\\tif event.SessionID == \\\"\\\" {\\n    73→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    74→\\t}\\n    75→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    76→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    77→\\t}\\n    78→\\n    79→\\t// Build informational message\\n    80→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    81→\\n    82→\\t// Check for concurrent sessions and append count if any\\n    83→\\t_, countSessionsSpan := perf.Start(ctx, \\\"count_active_sessions\\\")\\n    84→\\tstrat := GetStrategy(ctx)\\n    85→\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n    86→\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    87→\\t}\\n    88→\\tcountSessionsSpan.End()\\n    89→\\n    90→\\t// Output informational message if the agent supports hook responses.\\n    91→\\t// Claude Code reads JSON from stdout; agents that don't implement\\n    92→\\t// HookResponseWriter silently skip (avoids raw JSON in their terminal).\\n    93→\\t_, hookResponseSpan := perf.Start(ctx, \\\"write_hook_response\\\")\\n    94→\\tif event.ResponseMessage != \\\"\\\" {\\n    95→\\t\\tmessage = event.ResponseMessage\\n    96→\\t}\\n    97→\\tif writer, ok := agent.AsHookResponseWriter(ag); ok {\\n    98→\\t\\tif err := writer.WriteHookResponse(message); err != nil {\\n    99→\\t\\t\\thookResponseSpan.RecordError(err)\\n   100→\\t\\t\\thookResponseSpan.End()\\n   101→\\t\\t\\treturn fmt.Errorf(\\\"failed to write hook response: %w\\\", err)\\n   102→\\t\\t}\\n   103→\\t}\\n   104→\\thookResponseSpan.End()\\n   105→\\n   106→\\t// Store model hint if the agent provided model info on SessionStart\\n   107→\\tif event.Model != \\\"\\\" {\\n   108→\\t\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n   109→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint on session start\\\",\\n   110→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   111→\\t\\t}\\n   112→\\t}\\n   113→\\n   114→\\t// Fire EventSessionStart for the current session (if state exists).\\n   115→\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n   116→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n   117→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   118→\\t} else if state != nil {\\n   119→\\t\\tpersistEventMetadataToState(event, state)\\n   120→\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   121→\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n   122→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   123→\\t\\t}\\n   124→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   125→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n   126→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   127→\\t\\t}\\n   128→\\t}\\n   129→\\n   130→\\treturn nil\\n   131→}\\n   132→\\n   133→// handleLifecycleModelUpdate persists the model name for the current session.\\n   134→//\\n   135→// If the session state file already exists (e.g., Gemini's BeforeModel fires\\n   136→// after TurnStart), the model is written directly to state.ModelName — no hint\\n   137→// file needed. Otherwise falls back to StoreModelHint for cross-process\\n   138→// persistence (see its doc comment for the full rationale).\\n   139→func handleLifecycleModelUpdate(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   140→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   141→\\tlogging.Info(logCtx, \\\"model-update\\\",\\n   142→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   143→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   144→\\t)\\n   145→\\n   146→\\tif event.SessionID == \\\"\\\" || event.Model == \\\"\\\" {\\n   147→\\t\\treturn nil\\n   148→\\t}\\n   149→\\n   150→\\t// Prefer writing directly to session state when it exists\\n   151→\\tstate, loadErr := strategy.LoadSessionState(ctx, event.SessionID)\\n   152→\\tif loadErr != nil {\\n   153→\\t\\tlogging.Debug(logCtx, \\\"could not load session state for model update, using hint file\\\",\\n   154→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   155→\\t}\\n   156→\\tif loadErr == nil && state != nil {\\n   157→\\t\\tstate.ModelName = event.Model\\n   158→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   159→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state with model\\\",\\n   160→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   161→\\t\\t}\\n   162→\\t\\treturn nil\\n   163→\\t}\\n   164→\\n   165→\\t// State doesn't exist yet (or failed to load) — use hint file (see StoreModelHint doc)\\n   166→\\tif err := strategy.StoreModelHint(ctx, event.SessionID, event.Model); err != nil {\\n   167→\\t\\tlogging.Warn(logCtx, \\\"failed to store model hint\\\",\\n   168→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   169→\\t}\\n   170→\\n   171→\\treturn nil\\n   172→}\\n   173→\\n   174→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   175→// ensures strategy setup, initializes session.\\n   176→func handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   177→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   178→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   179→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   180→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   181→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   182→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   183→\\t)\\n   184→\\n   185→\\tsessionID := event.SessionID\\n   186→\\tif sessionID == \\\"\\\" {\\n   187→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   188→\\t}\\n   189→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   190→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   191→\\t}\\n   192→\\n   193→\\t// Fill model from hint file if the agent didn't provide it on this hook\\n   194→\\tif event.Model == \\\"\\\" {\\n   195→\\t\\tif hint := strategy.LoadModelHint(ctx, sessionID); hint != \\\"\\\" {\\n   196→\\t\\t\\tevent.Model = hint\\n   197→\\t\\t\\tlogging.Debug(logCtx, \\\"loaded model from hint file\\\",\\n   198→\\t\\t\\t\\tslog.String(\\\"model\\\", hint))\\n   199→\\t\\t}\\n   200→\\t}\\n   201→\\n   202→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   203→\\t_, captureSpan := perf.Start(ctx, \\\"capture_pre_prompt_state\\\")\\n   204→\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n   205→\\t\\tcaptureSpan.RecordError(err)\\n   206→\\t\\tcaptureSpan.End()\\n   207→\\t\\treturn err\\n   208→\\t}\\n   209→\\tcaptureSpan.End()\\n   210→\\n   211→\\t// Append prompt to prompt.txt on filesystem so it's available for\\n   212→\\t// mid-turn commits (before SaveStep writes it to the shadow branch).\\n   213→\\t// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\" to support multiple turns.\\n   214→\\tif event.Prompt != \\\"\\\" {\\n   215→\\t\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   216→\\t\\tif sessionDirAbs, absErr := paths.AbsPath(ctx, sessionDir); absErr == nil {\\n   217→\\t\\t\\tif mkErr := os.MkdirAll(sessionDirAbs, 0o750); mkErr == nil {\\n   218→\\t\\t\\t\\tpromptPath := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   219→\\t\\t\\t\\texisting, readErr := os.ReadFile(promptPath) //nolint:gosec // session metadata path\\n   220→\\t\\t\\t\\tvar content string\\n   221→\\t\\t\\t\\tif readErr == nil && len(existing) > 0 {\\n   222→\\t\\t\\t\\t\\tcontent = string(existing) + \\\"\\\\n\\\\n---\\\\n\\\\n\\\" + event.Prompt\\n   223→\\t\\t\\t\\t} else {\\n   224→\\t\\t\\t\\t\\tcontent = event.Prompt\\n   225→\\t\\t\\t\\t}\\n   226→\\t\\t\\t\\tif writeErr := os.WriteFile(promptPath, []byte(content), 0o600); writeErr != nil { //nolint:gosec // path from internal metadata, not user input\\n   227→\\t\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to write prompt.txt\\\",\\n   228→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", writeErr.Error()))\\n   229→\\t\\t\\t\\t}\\n   230→\\t\\t\\t}\\n   231→\\t\\t}\\n   232→\\t}\\n   233→\\n   234→\\t// Ensure strategy setup and initialize session\\n   235→\\t_, initSpan := perf.Start(ctx, \\\"init_session\\\")\\n   236→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   237→\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n   238→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   239→\\t}\\n   240→\\n   241→\\tstrat := GetStrategy(ctx)\\n   242→\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt, event.Model); err != nil {\\n   243→\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n   244→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   245→\\t}\\n   246→\\tinitSpan.End()\\n   247→\\n   248→\\treturn nil\\n   249→}\\n   250→\\n   251→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   252→// detects file changes, saves step + checkpoint, transitions phase.\\n   253→//\\n   254→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   255→func handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   256→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   257→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   258→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   259→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   260→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   261→\\t\\tslog.String(\\\"model\\\", event.Model),\\n   262→\\t)\\n   263→\\n   264→\\tsessionID := event.SessionID\\n   265→\\tif sessionID == \\\"\\\" {\\n   266→\\t\\tsessionID = unknownSessionID\\n   267→\\t}\\n   268→\\n   269→\\t// Fill model from hint file if the agent didn't provide it on this hook\\n   270→\\tif event.Model == \\\"\\\" && sessionID != unknownSessionID {\\n   271→\\t\\tif hint := strategy.LoadModelHint(ctx, sessionID); hint != \\\"\\\" {\\n   272→\\t\\t\\tevent.Model = hint\\n   273→\\t\\t\\tlogging.Debug(logCtx, \\\"loaded model from hint file\\\",\\n   274→\\t\\t\\t\\tslog.String(\\\"model\\\", hint))\\n   275→\\t\\t}\\n   276→\\t}\\n   277→\\n   278→\\ttranscriptRef := event.SessionRef\\n   279→\\tif transcriptRef == \\\"\\\" {\\n   280→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   281→\\t}\\n   282→\\n   283→\\t// If agent implements TranscriptPreparer, materialize the transcript file.\\n   284→\\t// This must run BEFORE fileExists: agents like OpenCode lazily fetch transcripts\\n   285→\\t// via `opencode export`, so the file doesn't exist until PrepareTranscript creates it.\\n   286→\\t// Claude Code's PrepareTranscript just flushes (always succeeds). Agents without\\n   287→\\t// TranscriptPreparer (Gemini, Droid) are unaffected.\\n   288→\\t_, prepareSpan := perf.Start(ctx, \\\"prepare_and_validate_transcript\\\")\\n   289→\\tif preparer, ok := agent.AsTranscriptPreparer(ag); ok {\\n   290→\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n   291→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n   292→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   293→\\t\\t}\\n   294→\\t}\\n   295→\\n   296→\\tif !fileExists(transcriptRef) {\\n   297→\\t\\tprepareSpan.RecordError(fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef))\\n   298→\\t\\tprepareSpan.End()\\n   299→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   300→\\t}\\n   301→\\n   302→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   303→\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n   304→\\t\\tprepareSpan.RecordError(strategy.ErrEmptyRepository)\\n   305→\\t\\tprepareSpan.End()\\n   306→\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n   307→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   308→\\t}\\n   309→\\tprepareSpan.End()\\n   310→\\n   311→\\t// Create session metadata directory\\n   312→\\t_, copySpan := perf.Start(ctx, \\\"copy_transcript\\\")\\n   313→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   314→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   315→\\tif err != nil {\\n   316→\\t\\tsessionDirAbs = sessionDir\\n   317→\\t}\\n   318→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   319→\\t\\tcopySpan.RecordError(err)\\n   320→\\t\\tcopySpan.End()\\n   321→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   322→\\t}\\n   323→\\n   324→\\t// Copy transcript to session directory\\n   325→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   326→\\tif err != nil {\\n   327→\\t\\tcopySpan.RecordError(err)\\n   328→\\t\\tcopySpan.End()\\n   329→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   330→\\t}\\n   331→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   332→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   333→\\t\\tcopySpan.RecordError(err)\\n   334→\\t\\tcopySpan.End()\\n   335→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   336→\\t}\\n   337→\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n   338→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n   339→\\tcopySpan.End()\\n   340→\\n   341→\\t// Load pre-prompt state (captured on TurnStart)\\n   342→\\t_, extractSpan := perf.Start(ctx, \\\"extract_metadata\\\")\\n   343→\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n   344→\\tif err != nil {\\n   345→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n   346→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   347→\\t}\\n   348→\\n   349→\\t// Determine transcript offset\\n   350→\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n   351→\\n   352→\\t// Compute subagents directory for agents that support subagent extraction.\\n   353→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   354→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   355→\\n   356→\\t// Extract metadata via agent interface (modified files)\\n   357→\\tvar modifiedFiles []string\\n   358→\\n   359→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok {\\n   360→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   361→\\t\\tif subagentExtractor, subOk := agent.AsSubagentAwareExtractor(ag); subOk {\\n   362→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n   363→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n   364→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   365→\\t\\t\\t} else {\\n   366→\\t\\t\\t\\tmodifiedFiles = files\\n   367→\\t\\t\\t}\\n   368→\\t\\t} else {\\n   369→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   370→\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   371→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n   372→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   373→\\t\\t\\t} else {\\n   374→\\t\\t\\t\\tmodifiedFiles = files\\n   375→\\t\\t\\t}\\n   376→\\t\\t}\\n   377→\\t}\\n   378→\\textractSpan.End()\\n   379→\\n   380→\\t// Generate commit message from last prompt (read from session state, set at TurnStart)\\n   381→\\t_, commitMsgSpan := perf.Start(ctx, \\\"generate_commit_message\\\")\\n   382→\\tlastPrompt := \\\"\\\"\\n   383→\\tif sessionState, stateErr := strategy.LoadSessionState(ctx, sessionID); stateErr == nil && sessionState != nil {\\n   384→\\t\\tlastPrompt = sessionState.LastPrompt\\n   385→\\t}\\n   386→\\tcommitMessage := generateCommitMessage(lastPrompt, ag.Type())\\n   387→\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n   388→\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n   389→\\tcommitMsgSpan.End()\\n   390→\\n   391→\\t// Get worktree root for path normalization\\n   392→\\t_, detectSpan := perf.Start(ctx, \\\"detect_file_changes\\\")\\n   393→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   394→\\tif err != nil {\\n   395→\\t\\tdetectSpan.RecordError(err)\\n   396→\\t\\tdetectSpan.End()\\n   397→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   398→\\t}\\n   399→\\n   400→\\tvar preUntrackedFiles []string\\n   401→\\tif preState != nil {\\n   402→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n   403→\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n   404→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   405→\\t}\\n   406→\\n   407→\\t// Detect file changes via git status\\n   408→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   409→\\tif err != nil {\\n   410→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   411→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   412→\\t}\\n   413→\\tdetectSpan.End()\\n   414→\\n   415→\\t// Filter and normalize all paths\\n   416→\\t_, normalizeSpan := perf.Start(ctx, \\\"filter_and_normalize_paths\\\")\\n   417→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   418→\\tvar relNewFiles, relDeletedFiles []string\\n   419→\\tif changes != nil {\\n   420→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   421→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   422→\\n   423→\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n   424→\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n   425→\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n   426→\\t\\t// Git status catches any tracked file with working-tree changes.\\n   427→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   428→\\t}\\n   429→\\n   430→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   431→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   432→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   433→\\t// if it exists in HEAD with the same content as the working tree.\\n   434→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   435→\\tnormalizeSpan.End()\\n   436→\\n   437→\\t// Check if there are any changes\\n   438→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   439→\\tif totalChanges == 0 {\\n   440→\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n   441→\\t\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n   442→\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   443→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   444→\\t\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   445→\\t\\t}\\n   446→\\t\\treturn nil\\n   447→\\t}\\n   448→\\n   449→\\t// Log file changes\\n   450→\\tlogFileChanges(ctx, relModifiedFiles, relNewFiles, relDeletedFiles)\\n   451→\\n   452→\\t// Get git author\\n   453→\\tauthor, err := GetGitAuthor(ctx)\\n   454→\\tif err != nil {\\n   455→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   456→\\t}\\n   457→\\n   458→\\t// Get strategy and agent type\\n   459→\\tstrat := GetStrategy(ctx)\\n   460→\\tagentType := ag.Type()\\n   461→\\n   462→\\t// Get transcript position/identifier from pre-prompt state\\n   463→\\tvar transcriptIdentifierAtStart string\\n   464→\\tvar transcriptLinesAtStart int\\n   465→\\tif preState != nil {\\n   466→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   467→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   468→\\t}\\n   469→\\n   470→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   471→\\ttokenUsage := agent.CalculateTokenUsage(ctx, ag, transcriptData, transcriptLinesAtStart, subagentsDir)\\n   472→\\n   473→\\t// Build fully-populated step context and delegate to strategy\\n   474→\\tstepCtx := strategy.StepContext{\\n   475→\\t\\tSessionID:                sessionID,\\n   476→\\t\\tModifiedFiles:            relModifiedFiles,\\n   477→\\t\\tNewFiles:                 relNewFiles,\\n   478→\\t\\tDeletedFiles:             relDeletedFiles,\\n   479→\\t\\tMetadataDir:              sessionDir,\\n   480→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   481→\\t\\tCommitMessage:            commitMessage,\\n   482→\\t\\tTranscriptPath:           transcriptRef,\\n   483→\\t\\tAuthorName:               author.Name,\\n   484→\\t\\tAuthorEmail:              author.Email,\\n   485→\\t\\tAgentType:                agentType,\\n   486→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   487→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   488→\\t\\tTokenUsage:               tokenUsage,\\n   489→\\t}\\n   490→\\n   491→\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   492→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   493→\\t}\\n   494→\\n   495→\\t// Transition session phase and cleanup\\n   496→\\ttransitionSessionTurnEnd(ctx, sessionID, event)\\n   497→\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   498→\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   499→\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   500→\\t}\\n   501→\\n   502→\\treturn nil\\n   503→}\\n   504→\\n   505→// handleLifecycleCompaction handles context compaction: saves current progress\\n   506→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   507→// Also resets the transcript offset since the transcript may be truncated.\\n   508→func handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   509→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   510→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   511→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   512→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   513→\\t)\\n   514→\\n   515→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   516→\\tsessionID := event.SessionID\\n   517→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   518→\\tif loadErr != nil {\\n   519→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for compaction\\\",\\n   520→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   521→\\t}\\n   522→\\tif sessionState != nil {\\n   523→\\t\\tpersistEventMetadataToState(event, sessionState)\\n   524→\\n   525→\\t\\tif transErr := strategy.TransitionAndLog(ctx, sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   526→\\t\\t\\tlogging.Warn(logCtx, \\\"compaction transition failed\\\",\\n   527→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   528→\\t\\t}\\n   529→\\n   530→\\t\\tif saveErr := strategy.SaveSessionState(ctx, sessionState); saveErr != nil {\\n   531→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to save session state after compaction\\\",\\n   532→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   533→\\t\\t}\\n   534→\\t}\\n   535→\\n   536→\\tlogging.Info(logCtx, \\\"context compaction detected\\\")\\n   537→\\treturn nil\\n   538→}\\n   539→\\n   540→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   541→func handleLifecycleSessionEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   542→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   543→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   544→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   545→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   546→\\t)\\n   547→\\n   548→\\tif event.SessionID == \\\"\\\" {\\n   549→\\t\\treturn nil // No session to update\\n   550→\\t}\\n   551→\\n   552→\\t// Note: We intentionally don't clean up cached transcripts here.\\n   553→\\t// Post-session commits (carry-forward in