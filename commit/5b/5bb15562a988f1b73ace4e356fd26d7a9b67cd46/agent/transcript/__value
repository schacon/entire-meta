checkpoint store: %w\\\", err)\\n   183→\\t}\\n   184→\\n   185→\\t// Get author info\\n   186→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   187→\\n   188→\\t// Determine attribution base commit\\n   189→\\tattrBase := state.AttributionBaseCommit\\n   190→\\tif attrBase == \\\"\\\" {\\n   191→\\t\\tattrBase = state.BaseCommit\\n   192→\\t}\\n   193→\\n   194→\\tattribution := calculateSessionAttributions(ctx, repo, ref, sessionData, state, attributionOpts{\\n   195→\\t\\theadTree:              o.headTree,\\n   196→\\t\\trepoDir:               o.repoDir,\\n   197→\\t\\tattributionBaseCommit: attrBase,\\n   198→\\t\\theadCommitHash:        o.headCommitHash,\\n   199→\\t})\\n   200→\\n   201→\\t// Get current branch name\\n   202→\\tbranchName := GetCurrentBranchName(repo)\\n   203→\\n   204→\\t// Generate summary if enabled\\n   205→\\tvar summary *cpkg.Summary\\n   206→\\tif settings.IsSummarizeEnabled(ctx) && len(sessionData.Transcript) > 0 {\\n   207→\\t\\tsummarizeCtx := logging.WithComponent(ctx, \\\"summarize\\\")\\n   208→\\n   209→\\t\\tvar scopedTranscript []byte\\n   210→\\t\\tswitch state.AgentType {\\n   211→\\t\\tcase agent.AgentTypeGemini:\\n   212→\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   213→\\t\\t\\tif sliceErr != nil {\\n   214→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n   215→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   216→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   217→\\t\\t\\t}\\n   218→\\t\\t\\tscopedTranscript = scoped\\n   219→\\t\\tcase agent.AgentTypeOpenCode:\\n   220→\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   221→\\t\\t\\tif sliceErr != nil {\\n   222→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n   223→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   224→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   225→\\t\\t\\t}\\n   226→\\t\\t\\tscopedTranscript = scoped\\n   227→\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeFactoryAIDroid, agent.AgentTypeUnknown:\\n   228→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   229→\\t\\t}\\n   230→\\t\\tif len(scopedTranscript) > 0 {\\n   231→\\t\\t\\tvar err error\\n   232→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   233→\\t\\t\\tif err != nil {\\n   234→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   235→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   236→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   237→\\t\\t\\t} else {\\n   238→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   239→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   240→\\t\\t\\t}\\n   241→\\t\\t}\\n   242→\\t}\\n   243→\\n   244→\\t// Write checkpoint metadata using the checkpoint store\\n   245→\\tif err := store.WriteCommitted(ctx, cpkg.WriteCommittedOptions{\\n   246→\\t\\tCheckpointID:                checkpointID,\\n   247→\\t\\tSessionID:                   state.SessionID,\\n   248→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   249→\\t\\tBranch:                      branchName,\\n   250→\\t\\tTranscript:                  sessionData.Transcript,\\n   251→\\t\\tPrompts:                     sessionData.Prompts,\\n   252→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   253→\\t\\tCheckpointsCount:            state.StepCount,\\n   254→\\t\\tEphemeralBranch:             shadowBranchName,\\n   255→\\t\\tAuthorName:                  authorName,\\n   256→\\t\\tAuthorEmail:                 authorEmail,\\n   257→\\t\\tAgent:                       state.AgentType,\\n   258→\\t\\tModel:                       state.ModelName,\\n   259→\\t\\tTurnID:                      state.TurnID,\\n   260→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   261→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   262→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   263→\\t\\tSessionMetrics:              buildSessionMetrics(state),\\n   264→\\t\\tInitialAttribution:          attribution,\\n   265→\\t\\tSummary:                     summary,\\n   266→\\t}); err != nil {\\n   267→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   268→\\t}\\n   269→\\n   270→\\treturn &CondenseResult{\\n   271→\\t\\tCheckpointID:         checkpointID,\\n   272→\\t\\tSessionID:            state.SessionID,\\n   273→\\t\\tCheckpointsCount:     state.StepCount,\\n   274→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   275→\\t\\tPrompts:              sessionData.Prompts,\\n   276→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   277→\\t\\tTranscript:           sessionData.Transcript,\\n   278→\\t}, nil\\n   279→}\\n   280→\\n   281→// buildSessionMetrics creates a SessionMetrics from session state if any metrics are available.\\n   282→// Returns nil if no hook-provided metrics exist (e.g., for agents that don't report them).\\n   283→func buildSessionMetrics(state *SessionState) *cpkg.SessionMetrics {\\n   284→\\tif state.SessionDurationMs == 0 && state.SessionTurnCount == 0 && state.ContextTokens == 0 && state.ContextWindowSize == 0 {\\n   285→\\t\\treturn nil\\n   286→\\t}\\n   287→\\treturn &cpkg.SessionMetrics{\\n   288→\\t\\tDurationMs:        state.SessionDurationMs,\\n   289→\\t\\tTurnCount:         state.SessionTurnCount,\\n   290→\\t\\tContextTokens:     state.ContextTokens,\\n   291→\\t\\tContextWindowSize: state.ContextWindowSize,\\n   292→\\t}\\n   293→}\\n   294→\\n   295→// attributionOpts provides pre-resolved git objects to avoid redundant reads.\\n   296→type attributionOpts struct {\\n   297→\\theadTree              *object.Tree // HEAD commit tree (already resolved by PostCommit)\\n   298→\\tshadowTree            *object.Tree // Shadow branch tree (already resolved by PostCommit)\\n   299→\\trepoDir               string       // Repository worktree path for git CLI commands\\n   300→\\tattributionBaseCommit string       // Base commit hash for non-agent file detection (empty = fall back to go-git tree walk)\\n   301→\\theadCommitHash        string       // HEAD commit hash for non-agent file detection (empty = fall back to go-git tree walk)\\n   302→}\\n   303→\\n   304→func calculateSessionAttributions(ctx context.Context, repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState, opts ...attributionOpts) *cpkg.InitialAttribution {\\n   305→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   306→\\t// This uses user edits captured at each prompt start (before agent works),\\n   307→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   308→\\t//\\n   309→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   310→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   311→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   312→\\tlogCtx := logging.WithComponent(ctx, \\\"attribution\\\")\\n   313→\\n   314→\\tvar o attributionOpts\\n   315→\\tif len(opts) > 0 {\\n   316→\\t\\to = opts[0]\\n   317→\\t}\\n   318→\\n   319→\\theadTree := o.headTree\\n   320→\\tif headTree == nil {\\n   321→\\t\\theadRef, headErr := repo.Head()\\n   322→\\t\\tif headErr != nil {\\n   323→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   324→\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   325→\\t\\t\\treturn nil\\n   326→\\t\\t}\\n   327→\\n   328→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   329→\\t\\tif commitErr != nil {\\n   330→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   331→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   332→\\t\\t\\treturn nil\\n   333→\\t\\t}\\n   334→\\n   335→\\t\\tvar treeErr error\\n   336→\\t\\theadTree, treeErr = headCommit.Tree()\\n   337→\\t\\tif treeErr != nil {\\n   338→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   339→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   340→\\t\\t\\treturn nil\\n   341→\\t\\t}\\n   342→\\t}\\n   343→\\n   344→\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n   345→\\tshadowTree := o.shadowTree\\n   346→\\tif shadowTree == nil {\\n   347→\\t\\tif shadowRef != nil {\\n   348→\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   349→\\t\\t\\tif shadowErr != nil {\\n   350→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   351→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   352→\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   353→\\t\\t\\t\\treturn nil\\n   354→\\t\\t\\t}\\n   355→\\t\\t\\tvar shadowTreeErr error\\n   356→\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   357→\\t\\t\\tif shadowTreeErr != nil {\\n   358→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   359→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   360→\\t\\t\\t\\treturn nil\\n   361→\\t\\t\\t}\\n   362→\\t\\t} else {\\n   363→\\t\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   364→\\t\\t\\t// because the agent's work is the commit itself.\\n   365→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   366→\\t\\t\\tshadowTree = headTree\\n   367→\\t\\t}\\n   368→\\t}\\n   369→\\n   370→\\t// Get base tree (state before session started)\\n   371→\\tvar baseTree *object.Tree\\n   372→\\tattrBase := state.AttributionBaseCommit\\n   373→\\tif attrBase == \\\"\\\" {\\n   374→\\t\\tattrBase = state.BaseCommit // backward compat\\n   375→\\t}\\n   376→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   377→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   378→\\t\\t\\tbaseTree = tree\\n   379→\\t\\t} else {\\n   380→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   381→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   382→\\t\\t}\\n   383→\\t} else {\\n   384→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   385→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   386→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   387→\\t}\\n   388→\\n   389→\\t// Log accumulated prompt attributions for debugging\\n   390→\\tvar totalUserAdded, totalUserRemoved int\\n   391→\\tfor i, pa := range state.PromptAttributions {\\n   392→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   393→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   394→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   395→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   396→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   397→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   398→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   399→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   400→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   401→\\t}\\n   402→\\n   403→\\tattribution := CalculateAttributionWithAccumulated(\\n   404→\\t\\tctx,\\n   405→\\t\\tbaseTree,\\n   406→\\t\\tshadowTree,\\n   407→\\t\\theadTree,\\n   408→\\t\\tsessionData.FilesTouched,\\n   409→\\t\\tstate.PromptAttributions,\\n   410→\\t\\to.repoDir,\\n   411→\\t\\to.attributionBaseCommit,\\n   412→\\t\\to.headCommitHash,\\n   413→\\t)\\n   414→\\n   415→\\tif attribution != nil {\\n   416→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   417→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   418→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   419→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   420→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   421→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   422→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   423→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   424→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   425→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   426→\\t}\\n   427→\\n   428→\\treturn attribution\\n   429→}\\n   430→\\n   431→// extractSessionData extracts session data from the shadow branch.\\n   432→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   433→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   434→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   435→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   436→// continued growing — the shadow branch copy would be stale.\\n   437→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   438→func (s *ManualCommitStrategy) extractSessionData(ctx context.Context, repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType types.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n   439→\\tag, _ := agent.GetByAgentType(agentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   440→\\tcommit, err := repo.CommitObject(shadowRef)\\n   441→\\tif err != nil {\\n   442→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   443→\\t}\\n   444→\\n   445→\\ttree, err := commit.Tree()\\n   446→\\tif err != nil {\\n   447→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   448→\\t}\\n   449→\\n   450→\\tdata := &ExtractedSessionData{}\\n   451→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   452→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   453→\\n   454→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   455→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   456→\\t// (SaveStep is only called when there are file modifications).\\n   457→\\tvar fullTranscript string\\n   458→\\tif liveTranscriptPath != \\\"\\\" {\\n   459→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   460→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   461→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   462→\\t\\tif isActive {\\n   463→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, liveTranscriptPath)\\n   464→\\t\\t}\\n   465→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   466→\\t\\t\\tfullTranscript = string(liveData)\\n   467→\\t\\t}\\n   468→\\t}\\n   469→\\tif fullTranscript == \\\"\\\" {\\n   470→\\t\\t// Fall back to shadow branch copy\\n   471→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   472→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   473→\\t\\t\\t\\tfullTranscript = content\\n   474→\\t\\t\\t}\\n   475→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   476→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   477→\\t\\t\\t\\tfullTranscript = content\\n   478→\\t\\t\\t}\\n   479→\\t\\t}\\n   480→\\t}\\n   481→\\n   482→\\t// Process transcript based on agent type\\n   483→\\tif fullTranscript != \\\"\\\" {\\n   484→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   485→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   486→\\t\\t// Read prompts from shadow branch tree (source of truth after SaveStep)\\n   487→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.PromptFileName); fileErr == nil {\\n   488→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil && content != \\\"\\\" {\\n   489→\\t\\t\\t\\tdata.Prompts = splitPromptContent(content)\\n   490→\\t\\t\\t}\\n   491→\\t\\t}\\n   492→\\t\\t// Filesystem fallback (written at turn start, covers mid-turn commits)\\n   493→\\t\\tif len(data.Prompts) == 0 {\\n   494→\\t\\t\\tdata.Prompts = readPromptsFromFilesystem(ctx, sessionID)\\n   495→\\t\\t}\\n   496→\\t}\\n   497→\\n   498→\\t// Use tracked files from session state (not all files in tree)\\n   499→\\tdata.FilesTouched = filesTouched\\n   500→\\n   501→\\t// Calculate token usage from the extracted transcript portion\\n   502→\\tif len(data.Transcript) > 0 {\\n   503→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ctx, ag, data.Transcript, checkpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   504→\\t}\\n   505→\\n   506→\\treturn data, nil\\n   507→}\\n   508→\\n   509→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   510→// This is used for mid-session commits where no shadow branch exists yet.\\n   511→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(ctx context.Context, state *SessionState) (*ExtractedSessionData, error) {\\n   512→\\tdata := &ExtractedSessionData{}\\n   513→\\n   514→\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   515→\\n   516→\\t// Read the live transcript\\n   517→\\tif state.TranscriptPath == \\\"\\\" {\\n   518→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   519→\\t}\\n   520→\\n   521→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   522→\\tif err != nil {\\n   523→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   524→\\t}\\n   525→\\n   526→\\tif len(liveData) == 0 {\\n   527→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   528→\\t}\\n   529→\\n   530→\\tfullTranscript := string(liveData)\\n   531→\\tdata.Transcript = liveData\\n   532→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   533→\\tdata.Prompts = readPromptsFromFilesystem(ctx, state.SessionID)\\n   534→\\n   535→\\t// Resolve files touched: prefers hook-populated state, falls back to transcript extraction\\n   536→\\tdata.FilesTouched = s.resolveFilesTouched(ctx, state)\\n   537→\\n   538→\\t// Calculate token usage from the extracted transcript portion\\n   539→\\tif len(data.Transcript) > 0 {\\n   540→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ctx, ag, data.Transcript, state.CheckpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   541→\\t}\\n   542→\\n   543→\\treturn data, nil\\n   544→}\\n   545→\\n   546→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   547→// For Claude Code and JSONL-based agents, this counts lines.\\n   548→// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n   549→// Returns 0 if the content is empty or malformed.\\n   550→func countTranscriptItems(agentType types.AgentType, content string) int {\\n   551→\\tif content == \\\"\\\" {\\n   552→\\t\\treturn 0\\n   553→\\t}\\n   554→\\n   555→\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n   556→\\tif agentType == agent.AgentTypeOpenCode {\\n   557→\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n   558→\\t\\tif err == nil && session != nil {\\n   559→\\t\\t\\treturn len(session.Messages)\\n   560→\\t\\t}\\n   561→\\t\\treturn 0\\n   562→\\t}\\n   563→\\n   564→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   565→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   566→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   567→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   568→\\t\\t\\treturn len(transcript.Messages)\\n   569→\\t\\t}\\n   570→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   571→\\t\\tif agentType == agent.AgentTypeGemini {\\n   572→\\t\\t\\treturn 0\\n   573→\\t\\t}\\n   574→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   575→\\t}\\n   576→\\n   577→\\t// Claude Code and other JSONL-based agents\\n   578→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   579→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   580→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   581→\\t\\tallLines = allLines[:len(allLines)-1]\\n   582→\\t}\\n   583→\\treturn len(allLines)\\n   584→}\\n   585→\\n   586→// extractUserPrompts extracts all user prompts from transcript content.\\n   587→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   588→func extractUserPrompts(agentType types.AgentType, content string) []string {\\n   589→\\tif content == \\\"\\\" {\\n   590→\\t\\treturn nil\\n   591→\\t}\\n   592→\\n   593→\\t// Droid has its own envelope format — use its parser to normalize first\\n   594→\\tif agentType == agent.AgentTypeFactoryAIDroid {\\n   595→\\t\\tlines, _, err := factoryaidroid.ParseDroidTranscriptFromBytes([]byte(content), 0)\\n   596→\\t\\tif err != nil {\\n   597→\\t\\t\\treturn nil\\n   598→\\t\\t}\\n   599→\\t\\tvar prompts []string\\n   600→\\t\\tfor _, line := range lines {\\n   601→\\t\\t\\tif line.Type != transcript.TypeUser {\\n   602→\\t\\t\\t\\tcontinue\\n   603→\\t\\t\\t}\\n   604→\\t\\t\\tif text := transcript.ExtractUserContent(line.Message); text != \\\"\\\" {\\n   605→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(text); stripped != \\\"\\\" {\\n   606→\\t\\t\\t\\t\\tprompts = append(prompts, stripped)\\n   607→\\t\\t\\t\\t}\\n   608→\\t\\t\\t}\\n   609→\\t\\t}\\n   610→\\t\\treturn prompts\\n   611→\\t}\\n   612→\\n   613→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   614→\\tif agentType == agent.AgentTypeOpenCode {\\n   615→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   616→\\t\\tif err == nil && len(prompts) > 0 {\\n   617→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   618→\\t\\t\\tfor _, prompt := range prompts {\\n   619→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   620→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   621→\\t\\t\\t\\t}\\n   622→\\t\\t\\t}\\n   623→\\t\\t\\treturn cleaned\\n   624→\\t\\t}\\n   625→\\t\\treturn nil\\n   626→\\t}\\n   627→\\n   628→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   629→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   630→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   631→\\t\\tif err == nil && len(prompts) > 0 {\\n   632→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   633→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   634→\\t\\t\\tfor _, prompt := range prompts {\\n   635→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   636→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   637→\\t\\t\\t\\t}\\n   638→\\t\\t\\t}\\n   639→\\t\\t\\treturn cleaned\\n   640→\\t\\t}\\n   641→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   642→\\t\\tif agentType == agent.AgentTypeGemini {\\n   643→\\t\\t\\treturn nil\\n   644→\\t\\t}\\n   645→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   646→\\t}\\n   647→\\n   648→\\t// Claude Code and other JSONL-based agents\\n   649→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   650→}\\n   651→\\n   652→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   653→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   654→func extractUserPromptsFromLines(lines []string) []string {\\n   655→\\tvar prompts []string\\n   656→\\tfor _, line := range lines {\\n   657→\\t\\tline = strings.TrimSpace(line)\\n   658→\\t\\tif line == \\\"\\\" {\\n   659→\\t\\t\\tcontinue\\n   660→\\t\\t}\\n   661→\\n   662→\\t\\tvar entry map[string]interface{}\\n   663→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   664→\\t\\t\\tcontinue\\n   665→\\t\\t}\\n   666→\\n   667→\\t\\t// Check for user message:\\n   668→\\t\\t// - Claude Code uses \\\"type\\\": \\\"human\\\" or \\\"type\\\": \\\"user\\\"\\n   669→\\t\\t// - Cursor uses \\\"role\\\": \\\"user\\\"\\n   670→\\t\\tmsgType, _ := entry[\\\"type\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   671→\\t\\tmsgRole, _ := entry[\\\"role\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   672→\\t\\tisUser := msgType == \\\"human\\\" || msgType == \\\"user\\\" || msgRole == \\\"user\\\"\\n   673→\\t\\tif !isUser {\\n   674→\\t\\t\\tcontinue\\n   675→\\t\\t}\\n   676→\\n   677→\\t\\t// Extract message content\\n   678→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   679→\\t\\tif !ok {\\n   680→\\t\\t\\tcontinue\\n   681→\\t\\t}\\n   682→\\n   683→\\t\\t// Handle string content\\n   684→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   685→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   686→\\t\\t\\tif cleaned != \\\"\\\" {\\n   687→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   688→\\t\\t\\t}\\n   689→\\t\\t\\tcontinue\\n   690→\\t\\t}\\n   691→\\n   692→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   693→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   694→\\t\\t\\tvar texts []string\\n   695→\\t\\t\\tfor _, item := range arr {\\n   696→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   697→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   698→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   699→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   700→\\t\\t\\t\\t\\t\\t}\\n   701→\\t\\t\\t\\t\\t}\\n   702→\\t\\t\\t\\t}\\n   703→\\t\\t\\t}\\n   704→\\t\\t\\tif len(texts) > 0 {\\n   705→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   706→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   707→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   708→\\t\\t\\t\\t}\\n   709→\\t\\t\\t}\\n   710→\\t\\t}\\n   711→\\t}\\n   712→\\treturn prompts\\n   713→}\\n   714→\\n   715→// splitPromptContent splits prompt.txt content on the \\\"\\\\n\\\\n---\\\\n\\\\n\\\" separator.\\n   716→// Returns nil if content is empty.\\n   717→func splitPromptContent(content string) []string {\\n   718→\\tif content == \\\"\\\" {\\n   719→\\t\\treturn nil\\n   720→\\t}\\n   721→\\tparts := strings.Split(content, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   722→\\tvar result []string\\n   723→\\tfor _, p := range parts {\\n   724→\\t\\ttrimmed := strings.TrimSpace(p)\\n   725→\\t\\tif trimmed != \\\"\\\" {\\n   726→\\t\\t\\tresult = append(result, trimmed)\\n   727→\\t\\t}\\n   728→\\t}\\n   729→\\treturn result\\n   730→}\\n   731→\\n   732→// readPromptsFromFilesystem reads prompt.txt from the filesystem session metadata directory.\\n   733→// This file is written at turn start and updated at each SaveStep, providing prompt data\\n   734→// even for mid-turn commits where the shadow branch may not have been updated.\\n   735→func readPromptsFromFilesystem(ctx context.Context, sessionID string) []string {\\n   736→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   737→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   738→\\tif err != nil {\\n   739→\\t\\treturn nil\\n   740→\\t}\\n   741→\\tdata, err := os.ReadFile(filepath.Join(sessionDirAbs, paths.PromptFileName)) //nolint:gosec // path from session ID\\n   742→\\tif err != nil || len(data) == 0 {\\n   743→\\t\\treturn nil\\n   744→\\t}\\n   745→\\treturn splitPromptContent(string(data))\\n   746→}\\n   747→\\n   748→// clearFilesystemPrompt removes the filesystem prompt.txt for a session.\\n   749→// Called after condensation so subsequent checkpoints start fresh.\\n   750→func clearFilesystemPrompt(ctx context.Context, sessionID string) {\\n   751→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   752→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   753→\\tif err != nil {\\n   754→\\t\\treturn\\n   755→\\t}\\n   756→\\tpromptPath := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   757→\\t_ = os.Remove(promptPath)\\n   758→}\\n   759→\\n   760→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   761→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   762→func (s *ManualCommitStrategy) CondenseSessionByID(ctx context.Context, sessionID string) error {\\n   763→\\tlogCtx := logging.WithComponent(ctx, \\\"condense