   204→\\t\\t)\\n   205→\\t\\ts.Phase = PhaseActive\\n   206→\\t}\\n   207→\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n   208→\\ts.Phase = PhaseFromString(string(s.Phase))\\n   209→\\n   210→\\t// Migrate transcript fields: CheckpointTranscriptStart replaces both\\n   211→\\t// CondensedTranscriptLines and TranscriptLinesAtStart from older state files.\\n   212→\\tif s.CheckpointTranscriptStart == 0 {\\n   213→\\t\\tif s.CondensedTranscriptLines > 0 {\\n   214→\\t\\t\\ts.CheckpointTranscriptStart = s.CondensedTranscriptLines\\n   215→\\t\\t} else if s.TranscriptLinesAtStart > 0 {\\n   216→\\t\\t\\ts.CheckpointTranscriptStart = s.TranscriptLinesAtStart\\n   217→\\t\\t}\\n   218→\\t}\\n   219→\\t// Clear deprecated fields so they aren't re-persisted.\\n   220→\\t// Note: this is a one-way migration. If the state is re-saved, older CLI versions\\n   221→\\t// will see 0 for these fields and fall back to scoping from the transcript start.\\n   222→\\t// This is acceptable since CLI upgrades are monotonic and the worst case is\\n   223→\\t// redundant transcript content in a condensation, not data loss.\\n   224→\\ts.CondensedTranscriptLines = 0\\n   225→\\ts.TranscriptLinesAtStart = 0\\n   226→\\n   227→\\t// Backfill AttributionBaseCommit for sessions created before this field existed.\\n   228→\\t// Without this, a mid-turn commit would migrate BaseCommit and the fallback in\\n   229→\\t// calculateSessionAttributions would use the migrated value, producing zero attribution.\\n   230→\\tif s.AttributionBaseCommit == \\\"\\\" && s.BaseCommit != \\\"\\\" {\\n   231→\\t\\ts.AttributionBaseCommit = s.BaseCommit\\n   232→\\t}\\n   233→}\\n   234→\\n   235→// IsStale returns true when a session hasn't seen interaction for longer than\\n   236→// StaleSessionThreshold. Falls back to StartedAt when LastInteractionTime is\\n   237→// nil (sessions created before interaction tracking was added).\\n   238→func (s *State) IsStale() bool {\\n   239→\\tvar since time.Duration\\n   240→\\tif s.LastInteractionTime != nil {\\n   241→\\t\\tsince = time.Since(*s.LastInteractionTime)\\n   242→\\t} else {\\n   243→\\t\\tsince = time.Since(s.StartedAt)\\n   244→\\t}\\n   245→\\treturn since > StaleSessionThreshold\\n   246→}\\n   247→\\n   248→// StateStore provides low-level operations for managing session state files.\\n   249→//\\n   250→// StateStore is a primitive for session state persistence. It is NOT the same as\\n   251→// the Sessions interface - it only handles state files in .git/entire-sessions/,\\n   252→// not the full session data which includes checkpoint content.\\n   253→//\\n   254→// Use StateStore directly in strategies for performance-critical state operations.\\n   255→// Use the Sessions interface (when implemented) for high-level session management.\\n   256→type StateStore struct {\\n   257→\\t// stateDir is the directory where session state files are stored\\n   258→\\tstateDir string\\n   259→}\\n   260→\\n   261→// NewStateStore creates a new state store.\\n   262→// Uses the git common dir to store session state (shared across worktrees).\\n   263→func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   264→\\tcommonDir, err := getGitCommonDir(ctx)\\n   265→\\tif err != nil {\\n   266→\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   267→\\t}\\n   268→\\treturn &StateStore{\\n   269→\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   270→\\t}, nil\\n   271→}\\n   272→\\n   273→// NewStateStoreWithDir creates a new state store with a custom directory.\\n   274→// This is useful for testing.\\n   275→func NewStateStoreWithDir(stateDir string) *StateStore {\\n   276→\\treturn &StateStore{stateDir: stateDir}\\n   277→}\\n   278→\\n   279→// Load loads the session state for the given session ID.\\n   280→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   281→// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   282→func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   283→\\t// Validate session ID to prevent path traversal\\n   284→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   285→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   286→\\t}\\n   287→\\n   288→\\troot, err := os.OpenRoot(s.stateDir)\\n   289→\\tif os.IsNotExist(err) {\\n   290→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   291→\\t}\\n   292→\\tif err != nil {\\n   293→\\t\\treturn nil, fmt.Errorf(\\\"failed to open session state directory: %w\\\", err)\\n   294→\\t}\\n   295→\\tdefer root.Close()\\n   296→\\n   297→\\tfileName := sessionID + \\\".json\\\"\\n   298→\\tdata, err := osroot.ReadFile(root, fileName)\\n   299→\\tif os.IsNotExist(err) {\\n   300→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   301→\\t}\\n   302→\\tif err != nil {\\n   303→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   304→\\t}\\n   305→\\n   306→\\tvar state State\\n   307→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   308→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal session state: %w\\\", err)\\n   309→\\t}\\n   310→\\tstate.NormalizeAfterLoad(ctx)\\n   311→\\n   312→\\tif state.IsStale() {\\n   313→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   314→\\t\\tlogging.Debug(logCtx, \\\"deleting stale session state\\\",\\n   315→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   316→\\t\\t)\\n   317→\\t\\t_ = s.Clear(ctx, sessionID) //nolint:errcheck // best-effort cleanup of stale session\\n   318→\\t\\treturn nil, nil             //nolint:nilnil // stale session treated as not found\\n   319→\\t}\\n   320→\\n   321→\\treturn &state, nil\\n   322→}\\n   323→\\n   324→// Save saves the session state atomically.\\n   325→func (s *StateStore) Save(ctx context.Context, state *State) error {\\n   326→\\t_ = ctx // Reserved for future use\\n   327→\\n   328→\\t// Validate session ID to prevent path traversal\\n   329→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n   330→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   331→\\t}\\n   332→\\n   333→\\tif err := os.MkdirAll(s.stateDir, 0o750); err != nil {\\n   334→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   335→\\t}\\n   336→\\n   337→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   338→\\tif err != nil {\\n   339→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   340→\\t}\\n   341→\\n   342→\\t// Use os.Root for traversal-resistant write of temp file.\\n   343→\\t// Rename is not available on os.Root, so we keep using os.Rename.\\n   344→\\troot, err := os.OpenRoot(s.stateDir)\\n   345→\\tif err != nil {\\n   346→\\t\\treturn fmt.Errorf(\\\"failed to open session state directory: %w\\\", err)\\n   347→\\t}\\n   348→\\tdefer root.Close()\\n   349→\\n   350→\\tfileName := state.SessionID + \\\".json\\\"\\n   351→\\ttmpFileName := fileName + \\\".tmp\\\"\\n   352→\\tif err := osroot.WriteFile(root, tmpFileName, data, 0o600); err != nil {\\n   353→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   354→\\t}\\n   355→\\n   356→\\t// Atomic rename: not available on os.Root, use os.Rename with validated paths.\\n   357→\\tstateFile := s.stateFilePath(state.SessionID)\\n   358→\\ttmpFile := stateFile + \\\".tmp\\\"\\n   359→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n   360→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n   361→\\t}\\n   362→\\treturn nil\\n   363→}\\n   364→\\n   365→// Clear removes the session state file for the given session ID.\\n   366→func (s *StateStore) Clear(ctx context.Context, 