// SetupRepo creates a fresh git repository in a temporary directory, seeds it\\n    34→// with an initial commit, and runs `entire enable` for the given agent.\\n    35→// Artifact capture is registered as a cleanup function.\\n    36→//\\n    37→// When E2E_KEEP_REPOS is set, the temporary directory is not cleaned up\\n    38→// so it can be inspected after the test. A symlink in the artifact dir\\n    39→// points to the preserved repo.\\n    40→func SetupRepo(t *testing.T, agent agents.Agent) *RepoState {\\n    41→\\tt.Helper()\\n    42→\\n    43→\\tkeepRepos := os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\"\\n    44→\\n    45→\\t// Always use os.MkdirTemp instead of t.TempDir(). Go's t.TempDir()\\n    46→\\t// creates nested subdirectories (TestName.../001/) whose structure\\n    47→\\t// confuses some agents' (e.g. opencode) working-directory resolution.\\n    48→\\tdir, err := os.MkdirTemp(\\\"\\\", \\\"e2e-repo-*\\\")\\n    49→\\tif err != nil {\\n    50→\\t\\tt.Fatalf(\\\"create temp dir: %v\\\", err)\\n    51→\\t}\\n    52→\\tif keepRepos {\\n    53→\\t\\tt.Logf(\\\"E2E_KEEP_REPOS: repo will be preserved at %s\\\", dir)\\n    54→\\t} else {\\n    55→\\t\\tt.Cleanup(func() { os.RemoveAll(dir) })\\n    56→\\t}\\n    57→\\n    58→\\t// Resolve symlinks (macOS: /var -> /private/var) so paths match\\n    59→\\t// what agent CLIs see when they resolve their own CWD.\\n    60→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n    61→\\t\\tdir = resolved\\n    62→\\t}\\n    63→\\n    64→\\tGit(t, dir, \\\"init\\\")\\n    65→\\tGit(t, dir, \\\"config\\\", \\\"user.name\\\", \\\"E2E Test\\\")\\n    66→\\tGit(t, dir, \\\"config\\\", \\\"user.email\\\", \\\"e2e@test.local\\\")\\n    67→\\tGit(t, dir, \\\"commit\\\", \\\"--allow-empty\\\", \\\"-m\\\", \\\"initial commit\\\")\\n    68→\\n    69→\\t// External agents need external_agents enabled in settings before enable,\\n    70→\\t// so the CLI can discover the agent binary via PATH during DiscoverAndRegister.\\n    71→\\tif ea, ok := agent.(agents.ExternalAgent); ok && ea.IsExternalAgent() {\\n    72→\\t\\tentireDir := filepath.Join(dir, \\\".entire\\\")\\n    73→\\t\\tif err := os.MkdirAll(entireDir, 0o755); err != nil {\\n    74→\\t\\t\\tt.Fatalf(\\\"create .entire for external agent: %v\\\", err)\\n    75→\\t\\t}\\n    76→\\t\\tif err := os.WriteFile(filepath.Join(entireDir, \\\"settings.json\\\"),\\n    77→\\t\\t\\t[]byte(\\\"{\\\\\\\"external_agents\\\\\\\": true}\\\\n\\\"), 0o644); err != nil {\\n    78→\\t\\t\\tt.Fatalf(\\\"write external_agents setting: %v\\\", err)\\n    79→\\t\\t}\\n    80→\\t}\\n    81→\\n    82→\\tentire.Enable(t, dir, agent.EntireAgent())\\n    83→\\tif agent.Name() == \\\"factoryai-droid\\\" {\\n    84→\\t\\tif err := configureDroidRepoSettings(dir); err != nil {\\n    85→\\t\\t\\tt.Fatalf(\\\"configure droid repo settings: %v\\\", err)\\n    86→\\t\\t}\\n    87→\\t}\\n    88→\\tPatchSettings(t, dir, map[string]any{\\\"log_level\\\": \\\"debug\\\"})\\n    89→\\n    90→\\t// Copilot CLI blocks on a \\\"No copilot instructions found\\\" notice in fresh\\n    91→\\t// repos that lack .github/copilot-instructions.md, preventing the interactive\\n    92→\\t// prompt from appearing.\\n    93→\\tif agent.Name() == \\\"copilot-cli\\\" {\\n    94→\\t\\tghDir := filepath.Join(dir, \\\".github\\\")\\n    95→\\t\\tif err := os.MkdirAll(ghDir, 0o755); err != nil {\\n    96→\\t\\t\\tt.Fatalf(\\\"create .github dir: %v\\\", err)\\n    97→\\t\\t}\\n    98→\\t\\tif err := os.WriteFile(filepath.Join(ghDir, \\\"copilot-instructions.md\\\"), []byte(\\\"# E2E Test\\\\n\\\"), 0o644); err != nil {\\n    99→\\t\\t\\tt.Fatalf(\\\"write copilot-instructions.md: %v\\\", err)\\n   100→\\t\\t}\\n   101→\\t}\\n   102→\\n   103→\\t// OpenCode's non-interactive mode auto-rejects external_directory permission\\n   104→\\t// since there's no user to prompt. Write a config to allow it.\\n   105→\\tif agent.Name() == \\\"opencode\\\" {\\n   106→\\t\\tcfg := `{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}}`\\n   107→\\t\\tif key := os.Getenv(\\\"ANTHROPIC_API_KEY\\\"); key != \\\"\\\" {\\n   108→\\t\\t\\tcfg = fmt.Sprintf(`{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}, \\\"provider\\\": {\\\"anthropic\\\": {\\\"options\\\": {\\\"apiKey\\\": %q}}}}`, key)\\n   109→\\t\\t}\\n   110→\\t\\tif err := os.WriteFile(filepath.Join(dir, \\\"opencode.json\\\"), []byte(cfg+\\\"\\\\n\\\"), 0o644); err != nil {\\n   111→\\t\\t\\tt.Fatalf(\\\"write opencode.json: %v\\\", err)\\n   112→\\t\\t}\\n   113→\\t}\\n   114→\\n   115→\\t// Create artifact dir eagerly so console.log is written to disk\\n   116→\\t// incrementally. Even if the test is killed by a global timeout,\\n   117→\\t// partial output survives.\\n   118→\\tartDir := artifactDir(t)\\n   119→\\tconsoleLog, err := os.Create(filepath.Join(artDir, \\\"console.log\\\"))\\n   120→\\tif err != nil {\\n   121→\\t\\tt.Fatalf(\\\"create console.log: %v\\\", err)\\n   122→\\t}\\n   123→\\n   124→\\tstate := &RepoState{\\n   125→\\t\\tAgent:            agent,\\n   126→\\t\\tDir:              dir,\\n   127→\\t\\tArtifactDir:      artDir,\\n   128→\\t\\tHeadBefore:       GitOutput(t, dir, \\\"rev-parse\\\", \\\"HEAD\\\"),\\n   129→\\t\\tCheckpointBefore: GitOutput(t, dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\"),\\n   130→\\t\\tConsoleLog:       consoleLog,\\n   131→\\t}\\n   132→\\n   133→\\tt.Cleanup(func() {\\n   134→\\t\\t_ = consoleLog.Close()\\n   135→\\t\\tif !state.skipArtifacts {\\n   136→\\t\\t\\tCaptureArtifacts(t, state)\\n   137→\\t\\t}\\n   138→\\t})\\n   139→\\n   140→\\treturn state\\n   141→}\\n   142→\\n   143→func configureDroidRepoSettings(repoDir string) error {\\n   144→\\thome, err := os.UserHomeDir()\\n   145→\\tif err != nil {\\n   146→\\t\\treturn fmt.Errorf(\\\"get home dir: %w\\\", err)\\n   147→\\t}\\n   148→\\n   149→\\tglobalSettingsPath := filepath.Join(home, \\\".factory\\\", \\\"settings.json\\\")\\n   150→\\trepoSettingsPath := filepath.Join(repoDir, droidRepoSettingsPath)\\n   151→\\n   152→\\tif err := mergeDroidCustomModels(globalSettingsPath, repoSettingsPath); err != nil {\\n   153→\\t\\treturn err\\n   154→\\t}\\n   155→\\tif err := ensureGitInfoExcludeContains(repoDir, droidRepoSettingsPath); err != nil {\\n   156→\\t\\treturn fmt.Errorf(\\\"exclude droid settings from git: %w\\\", err)\\n   157→\\t}\\n   158→\\treturn nil\\n   159→}\\n   160→\\n   161→func mergeDroidCustomModels(globalSettingsPath, repoSettingsPath string) error {\\n   162→\\tglobalSettings, err := loadJSONMap(globalSettingsPath, \\\"global droid settings\\\")\\n   163→\\tif err != nil {\\n   164→\\t\\treturn err\\n   165→\\t}\\n   166→\\n   167→\\tcustomModels, ok := globalSettings[\\\"customModels\\\"]\\n   168→\\tif !ok {\\n   169→\\t\\treturn fmt.Errorf(\\n   170→\\t\\t\\t\\\"global droid settings at %s missing customModels; repo-local %s shadows global settings\\\",\\n   171→\\t\\t\\tglobalSettingsPath,\\n   172→\\t\\t\\trepoSettingsPath,\\n   173→\\t\\t)\\n   174→\\t}\\n   175→\\n   176→\\tvar models []json.RawMessage\\n   177→\\tif err := json.Unmarshal(customModels, &models); err != nil {\\n   178→\\t\\treturn fmt.Errorf(\\\"parse customModels in %s: %w\\\", globalSettingsPath, err)\\n   179→\\t}\\n   180→\\tif len(models) == 0 {\\n   181→\\t\\treturn fmt.Errorf(\\\"global droid settings at %s has empty customModels\\\", globalSettingsPath)\\n   182→\\t}\\n   183→\\n   184→\\trepoSettings, err := loadJSONMap(repoSettingsPath, \\\"repo-local droid settings\\\")\\n   185→\\tif err != nil {\\n   186→\\t\\treturn err\\n   187→\\t}\\n   188→\\trepoSettings[\\\"customModels\\\"] = customModels\\n   189→\\n   190→\\t// Set the active custom model so interactive mode uses the BYOK model\\n   191→\\t// instead of prompting for selection. The value must match the Model\\n   192→\\t// field from the customModels entry (not the displayName).\\n   193→\\tmodelJSON, err := json.Marshal(agents.DefaultDroidModel())\\n   194→\\tif err != nil {\\n   195→\\t\\treturn fmt.Errorf(\\\"marshal model setting: %w\\\", err)\\n   196→\\t}\\n   197→\\trepoSettings[\\\"model\\\"] = json.RawMessage(modelJSON)\\n   198→\\n   199→\\t// High autonomy prevents Droid from asking for confirmation during\\n   200→\\t// interactive E2E tests, which would cause hangs waiting for input.\\n   201→\\trepoSettings[\\\"autonomyMode\\\"] = json.RawMessage(`\\\"auto-high\\\"`)\\n   202→\\trepoSettings[\\\"completionSound\\\"] = json.RawMessage(`\\\"off\\\"`)\\n   203→\\n   204→\\tout, err := json.MarshalIndent(repoSettings, \\\"\\\", \\\"  \\\")\\n   205→\\tif err != nil {\\n   206→\\t\\treturn fmt.Errorf(\\\"marshal repo-local droid settings: %w\\\", err)\\n   207→\\t}\\n   208→\\tout = append(out, '\\\\n')\\n   209→\\n   210→\\tif err := os.WriteFile(repoSettingsPath, out, 0o600); err != nil {\\n   211→\\t\\treturn fmt.Errorf(\\\"write repo-local droid settings %s: %w\\\", repoSettingsPath, err)\\n   212→\\t}\\n   213→\\treturn nil\\n   214→}\\n   215→\\n   216→func loadJSONMap(path, description string) (map[string]json.RawMessage, error) {\\n   217→\\tdata, err := os.ReadFile(path)\\n   218→\\tif err != nil {\\n   219→\\t\\treturn nil, fmt.Errorf(\\\"read %s at %s: %w\\\", description, path, err)\\n   220→\\t}\\n   221→\\n   222→\\tvar parsed map[string]json.RawMessage\\n   223→\\tif err := json.Unmarshal(data, &parsed); err != nil {\\n   224→\\t\\treturn nil, fmt.Errorf(\\\"parse %s at %s: %w\\\", description, path, err)\\n   225→\\t}\\n   226→\\tif parsed == nil {\\n   227→\\t\\tparsed = make(map[string]json.RawMessage)\\n   228→\\t}\\n   229→\\treturn parsed, nil\\n   230→}\\n   231→\\n   232→func ensureGitInfoExcludeContains(repoDir, entry string) error {\\n   233→\\texcludePath := filepath.Join(repoDir, \\\".git\\\", \\\"info\\\", \\\"exclude\\\")\\n   234→\\n   235→\\tdata, err := os.ReadFile(excludePath)\\n   236→\\tif err != nil && !errors.Is(err, os.ErrNotExist) {\\n   237→\\t\\treturn fmt.Errorf(\\\"read %s: %w\\\", excludePath, err)\\n   238→\\t}\\n   239→\\n   240→\\tnormalized := strings.ReplaceAll(string(data), \\\"\\\\r\\\\n\\\", \\\"\\\\n\\\")\\n   241→\\tfor _, line := range strings.Split(normalized, \\\"\\\\n\\\") {\\n   242→\\t\\tif strings.TrimSpace(line) == entry {\\n   243→\\t\\t\\treturn nil\\n   244→\\t\\t}\\n   245→\\t}\\n   246→\\n   247→\\tvar b strings.Builder\\n   248→\\tif len(data) > 0 {\\n   249→\\t\\tb.Write(data)\\n   250→\\t\\tif data[len(data)-1] != '\\\\n' {\\n   251→\\t\\t\\tb.WriteByte('\\\\n')\\n   252→\\t\\t}\\n   253→\\t}\\n   254→\\tb.WriteString(entry)\\n   255→\\tb.WriteByte('\\\\n')\\n   256→\\n   257→\\tif err := os.MkdirAll(filepath.Dir(excludePath), 0o755); err != nil {\\n   258→\\t\\treturn fmt.Errorf(\\\"create %s: %w\\\", filepath.Dir(excludePath), err)\\n   259→\\t}\\n   260→\\tif err := os.WriteFile(excludePath, []byte(b.String()), 0o644); err != nil {\\n   261→\\t\\treturn fmt.Errorf(\\\"write %s: %w\\\", excludePath, err)\\n   262→\\t}\\n   263→\\treturn nil\\n   264→}\\n   265→\\n   266→// ForEachAgent runs fn as a parallel subtest for every registered agent.\\n   267→// It handles repo setup, concurrency gating, context timeout, and cleanup.\\n   268→// The timeout is scaled by each agent's TimeoutMultiplier.\\n   269→//\\n   270→// If RunPrompt detects a transient API error (e.g. rate limit, token refresh\\n   271→// failure), it panics with errScenarioRestart. ForEachAgent recovers from the\\n   272→// panic and restarts the entire scenario with a fresh repository, up to\\n   273→// maxScenarioRestarts times. This avoids stale CLI session state from the\\n   274→// failed attempt poisoning the retry.\\n   275→func ForEachAgent(t *testing.T, timeout time.Duration, fn func(t *testing.T, s *RepoState, ctx context.Context)) {\\n   276→\\tt.Helper()\\n   277→\\tt.Parallel()\\n   278→\\tall :=