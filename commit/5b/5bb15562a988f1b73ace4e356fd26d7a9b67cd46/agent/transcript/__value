7→\\n    38→\\t\\t// Turn 2: Agent creates DIFFERENT files and commits them mid-turn.\\n    39→\\t\\t// The committed files (turn2a.md, turn2b.md) do NOT overlap with\\n    40→\\t\\t// Turn 1's tracked files (turn1.md).\\n    41→\\t\\t_, err = s.RunPrompt(t, ctx,\\n    42→\\t\\t\\t\\\"create two markdown files: docs/turn2a.md about bananas and docs/turn2b.md about cherries. Then git add and git commit both files with a short message. Do not commit any other files. Do not ask for confirmation, just make the changes. Do not include any trailers or metadata in the commit message. Do not use worktrees.\\\")\\n    43→\\t\\tif err != nil {\\n    44→\\t\\t\\tt.Fatalf(\\\"agent prompt 2 (turn 2) failed: %v\\\", err)\\n    45→\\t\\t}\\n    46→\\t\\ttestutil.AssertFileExists(t, s.Dir, \\\"docs/turn2a.md\\\")\\n    47→\\t\\ttestutil.AssertFileExists(t, s.Dir, \\\"docs/turn2b.md\\\")\\n    48→\\n    49→\\t\\t// The agent committed mid-turn, so there should be at least 1 new commit.\\n    50→\\t\\ttestutil.AssertNewCommits(t, s, 1)\\n    51→\\n    52→\\t\\t// CRITICAL: The mid-turn commit should have triggered condensation\\n    53→\\t\\t// to entire/checkpoints/v1, even though committed files differ from\\n    54→\\t\\t// Turn 1's tracked files. This is the regression assertion.\\n    55→\\t\\ttestutil.WaitForCheckpoint(t, s, 15*time.Second)\\n    56→\\t\\ttestutil.AssertCheckpointAdvanced(t, s)\\n    57→\\n    58→\\t\\tcpID := testutil.AssertHasCheckpointTrailer(t, s.Dir, \\\"HEAD\\\")\\n    59→\\t\\ttestutil.AssertCheckpointExists(t, s.Dir, cpID)\\n    60→\\t\\ttestutil.AssertNoShadowBranches(t, s.Dir)\\n    61→\\t})\\n    62→}\\n    63→\"}]},\"uuid\":\"5228cf62-308d-4299-affd-6fa2a14b05fe\",\"timestamp\":\"2026-03-16T19:07:51.434Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"aca612d3a1dc8b89f\"},\"toolUseID\":\"agent_msg_012kMgkfLobaSrWmVnxqmepM\",\"parentToolUseID\":\"toolu_01Eh8LYTz1hs1vKRjKVFJMnr\",\"uuid\":\"ef7d6a0b-6d41-4399-8985-d35619359a40\",\"timest