ble assignments for BSD env on macOS.\\n    46→\\tfor _, v := range unsetEnv {\\n    47→\\t\\tparts = append(parts, \\\"-u\\\", shellQuote(v))\\n    48→\\t}\\n    49→\\tparts = append(parts, \\\"PATH=\\\"+shellQuote(os.Getenv(\\\"PATH\\\")))\\n    50→\\tparts = append(parts, shellQuote(command))\\n    51→\\tfor _, a := range args {\\n    52→\\t\\tparts = append(parts, shellQuote(a))\\n    53→\\t}\\n    54→\\ttmuxArgs = append(tmuxArgs, strings.Join(parts, \\\" \\\"))\\n    55→\\n    56→\\tcmd := exec.Command(\\\"tmux\\\", tmuxArgs...)\\n    57→\\tif out, err := cmd.CombinedOutput(); err != nil {\\n    58→\\t\\treturn nil, fmt.Errorf(\\\"tmux new-session: %w\\\\n%s\\\", err, out)\\n    59→\\t}\\n    60→\\t// Keep the pane around after the command exits so we can capture error output.\\n    61→\\tsetCmd := exec.Command(\\\"tmux\\\", \\\"set-option\\\", \\\"-t\\\", name, \\\"remain-on-exit\\\", \\\"on\\\")\\n    62→\\t_ = setCmd.Run()\\n    63→\\treturn s, nil\\n    64→}\\n    65→\\n    66→func (s *TmuxSession) Send(input string) error {\\n    67→\\tpreSend := stableContent(s.Capture())\\n    68→\\t// Send text and Enter separately — Claude's TUI can swallow Enter\\n    69→\\t// if it arrives before the input handler finishes processing the text.\\n    70→\\tif err := s.SendKeys(input); err != nil {\\n    71→\\t\\treturn err\\n    72→\\t}\\n    73→\\ttime.Sleep(200 * time.Millisecond)\\n    74→\\tif err := s.SendKeys(\\\"Enter\\\"); err != nil {\\n    75→\\t\\treturn err\\n    76→\\t}\\n    77→\\n    78→\\t// Wait for the terminal to reflect the echoed input, then snapshot.\\n    79→\\t// This ensures WaitFor compares against post-echo content, preventing\\n    80→\\t// false matches on prompt characters (e.g. ❯) in the echoed input.\\n    81→\\tdeadline := time.Now().Add(5 * time.Second)\\n    82→\\tfor time.Now().Before(deadline) {\\n    83→\\t\\ttime.Sleep(200 * time.Millisecond)\\n    84→\\t\\tcurrent := stableContent(s.Capture())\\n    85→\\t\\tif current != preSend {\\n    86→\\t\\t\\ts.stableAtSend = current\\n    87→\\t\\t\\treturn nil\\n    88→\\t\\t}\\n    89→\\t}\\n    90→\\ts.stableAtSend = stableContent(s.Capture())\\n    91→\\treturn nil\\n    92→}\\n    93→\\n    94→// SendKeys sends raw tmux key names without appending Enter.\\n    95→func (s *TmuxSession) SendKeys(keys ...string) error {\\n    96→\\targs := append([]string{\\\"send-keys\\\", \\\"-t\\\", s.name}, keys...)\\n    97→\\tcmd := exec.Command(\\\"tmux\\\", args...)\\n    98→\\tout, err := cmd.CombinedOutput()\\n    99→\\tif err != nil {\\n   100→\\t\\treturn fmt.Errorf(\\\"tmux send-keys: %w\\\\n%s\\\", err, out)\"}]},\"uuid\":\"b1b04f83-ccaf-4acf-8284-cbf5a3852ab1\",\"timestamp\":\"2026-03-16T19:11:25.499Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"aca612d3a1dc8b89f\"},\"toolUseID\":\"agent_msg_012kMgkfLobaSrWmVnxqmepM\",\"parentToolUseID\":\"toolu_01Eh8LYTz1hs1vKRjKVFJMnr\",\"uuid\":\"ea742ecd-ca3c-4aa1-8c5f-0e67185e3dde\",\"timestamp\":\"2026-03-16T19:11:25.501Z\",\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli\",\"sessionId\":\"4a93df6c-18f9-424f-af2a-6ee3b41ac6aa\",\"version\":\"2.1.76\",\"gitBranch\":\"main\",\"slug\":\"vivid-doodling-bird\"}\n{\"parentUuid\":\"ea742ecd-ca3c-4aa1-8c5f-0e67185e3dde\",\"isSidechain\":false,\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-16T19:11:39.294Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01P9Q7Zi4Gje7aSdykBJx3uy\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01MGUr6GaCN4c6eHTKkjmHE7\",\"name\":\"Bash\",\"input\":{\"command\":\"git log --oneline --all -30 | grep -i cursor\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":0,\"cache_creation_input_tokens\":1689,\"cache_read_input_tokens\":120105,\"cache_creation\":{\"ephemeral_5m_input_tokens\":1689,\"ephemeral_1h_input_tokens\":0},\"output_toke