ull},\"requestId\":\"req_011CZ1LCKq9bUw3BQwgCZcBq\",\"uuid\":\"33463dba-9d32-43a8-a09f-398b68708253\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a102fa4f83d47968c\"},\"toolUseID\":\"agent_msg_01TqB5jPkoFuMErA44GqPJRo\",\"parentToolUseID\":\"toolu_01SctrUWhXHht4ic8dj2pSTg\",\"uuid\":\"f6b80411-2650-4066-9aea-a66a5f264a52\",\"timestamp\":\"2026-03-13T15:40:26.152Z\",\"userType\":\"external\",\"cwd\":\"/Users/ninawork/entire/devenv/cli\",\"sessionId\":\"f01db921-a255-4978-9c64-3a353600bda3\",\"version\":\"2.1.74\",\"gitBranch\":\"attach-session-id\",\"slug\":\"tingly-herding-sutton\"}\n{\"parentUuid\":\"f6b80411-2650-4066-9aea-a66a5f264a52\",\"isSidechain\":false,\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01LT3KEchswNi6EgCzHuk7R8\",\"type\":\"tool_result\",\"content\":\"     1→// Package checkpoint provides types and interfaces for checkpoint storage.\\n     2→//\\n     3→// A Checkpoint captures a point-in-time within a session, containing either\\n     4→// full state (Temporary) or metadata with a commit reference (Committed).\\n     5→//\\n     6→// See docs/architecture/sessions-and-checkpoints.md for the full domain model.\\n     7→package checkpoint\\n     8→\\n     9→import (\\n    10→\\t\\\"context\\\"\\n    11→\\t\\\"errors\\\"\\n    12→\\t\\\"time\\\"\\n    13→\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    17→\\n    18→\\t\\\"github.com/go-git/go-git/v6/plumbing\\\"\\n    19→)\\n    20→\\n    21→// Errors returned by checkpoint operations.\\n    22→var (\\n    23→\\t// ErrCheckpointNotFound is returned when a checkpoint ID doesn't exist.\\n    24→\\tErrCheckpointNotFound = errors.New(\\\"checkpoint not found\\\")\\n    25→\\n    26→\\t// ErrNoTranscript is returned when a checkpoint exists but has no transcript.\\n    27→\\tErrNoTranscript = errors.New(\\\"no transcript found for checkpoint\\\")\\n    28→)\\n    29→\\n    30→// Checkpoint represents a save point within a session.\\n    31→type Checkpoint struct {\\n    32→\\t// ID is the unique checkpoint identifier\\n    33→\\tID string\\n    34→\\n    35→\\t// SessionID is the session this checkpoint belongs to\\n    36→\\tSessionID string\\n    37→\\n    38→\\t// Timestamp is when this checkpoint was created\\n    39→\\tTimestamp time.Time\\n    40→\\n    41→\\t// Type indicates temporary (full state) or committed (metadata only)\\n    42→\\tType Type\\n    43→\\n    44→\\t// Message is a human-readable description of the checkpoint\\n    45→\\tMessage string\\n    46→}\\n    47→\\n    48→// Type indicates the storage location and lifecycle of a checkpoint.\\n    49→type Type int\\n    50→\\n    51→const (\\n    52→\\t// Temporary checkpoints contain full state (code + metadata) and are stored\\n    53→\\t// on shadow branches (entire/<commit-hash>). Used for intra-session rewind.\\n    54→\\tTemporary Type = iota\\n    55→\\n    56→\\t// Committed checkpoints contain metadata + commit reference and are stored\\n    57→\\t// on the entire/checkpoints/v1 branch. They are the permanent record.\\n    58→\\tCommitted\\n    59→)\\n    60→\\n    61→// Store provides low-level primitives for reading and writing checkpoints.\\n    62→// This is used by strategies to implement their storage approach.\\n    63→//\\n    64→// The interface matches the GitStore implementation signatures directly:\\n    65→// - WriteTemporary takes WriteTemporaryOptions and returns a result with commit hash and skip status\\n    66→// - ReadTemporary takes baseCommit (not sessionID) since shadow branches are keyed by commit\\n    67→// - List methods return implementation-specific info types for richer data\\n    68→type Store interface {\\n    69→\\t// WriteTemporary writes a temporary checkpoint (full state) to a shadow branch.\\n    70→\\t// Shadow branches are named entire/<base-commit-short-hash>.\\n    71→\\t// Returns a result containing the commit hash and whether the checkpoint was skipped.\\n    72→\\t// Checkpoints are skipped (deduplicated) when the tree hash matches the previous checkpoint.\\n    73→\\tWriteTemporary(ctx context.Context, opts WriteTemporaryOptions) (WriteTemporaryResult, error)\\n    74→\\n    75→\\t// ReadTemporary reads the latest checkpoint from a shadow branch.\\n    76→\\t// baseCommit is the commit hash the session is based on.\\n    77→\\t// worktreeID is the internal git worktree identifier (empty for main worktree).\\n    78→\\t// Returns nil, nil if the shadow branch doesn't exist.\\n    79→\\tReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error)\\n    80→\\n    81→\\t// ListTemporary lists all shadow branches with their checkpoint info.\\n    82→\\tListTemporary(ctx context.Context) ([]TemporaryInfo, error)\\n    83→\\n    84→\\t// WriteCommitted writes a committed checkpoint to the entire/checkpoints/v1 branch.\\n    85→\\t// Checkpoints are stored at sharded paths: <id[:2]>/<id[2:]>/\\n    86→\\tWriteCommitted(ctx context.Context, opts WriteCommittedOptions) error\\n    87→\\n    88→\\t// ReadCommitted reads a committed checkpoint's summary by ID.\\n    89→\\t// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n    90→\\t// Use ReadSessionContent to read actual transcript/prompts.\\n    91→\\t// Returns nil, nil if the checkpoint does not exist.\\n    92→\\tReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error)\\n    93→\\n    94→\\t// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n    95→\\t// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n    96→\\t// Returns the session's metadata, transcript, and prompts.\\n    97→\\tReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error)\\n    98→\\n    99→\\t// ReadSessionContentByID reads a session's content by its session ID.\\n   100→\\t// Useful when you have the session ID but don't know its index within the checkpoint.\\n   101→\\tReadSessionContentByID(ctx context.Context, checkpointID id.CheckpointID, sessionID string) (*SessionContent, error)\\n   102→\\n   103→\\t// ListCommitted lists all committed checkpoints.\\n   104→\\tListCommitted(ctx context.Context) ([]CommittedInfo, error)\\n   105→\\n   106→\\t// UpdateCommitted replaces the transcript and prompts for an existing\\n   107→\\t// committed checkpoint. Used at stop time to finalize checkpoints with the full\\n   108→\\t// session transcript (prompt to stop event).\\n   109→\\t// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   110→\\tUpdateCommitted(ctx context.Context, opts UpdateCommittedOptions) error\\n   111→}\\n   112→\\n   113→// WriteTemporaryResult contains the result of writing a temporary checkpoint.\\n   114→type WriteTemporaryResult struct {\\n   115→\\t// CommitHash is the hash of the created or existing checkpoint commit\\n   116→\\tCommitHash plumbing.Hash\\n   117→\\n   118→\\t// Skipped is true if the checkpoint was skipped due to no changes\\n   119→\\t// (tree hash matched the previous checkpoint)\\n   120→\\tSkipped bool\\n   121→}\\n   122→\\n   123→// WriteTemporaryOptions contains options for writing a temporary checkpoint.\\n   124→type WriteTemporaryOptions struct {\\n   125→\\t// SessionID is the session identifier\\n   126→\\tSessionID string\\n   127→\\n   128→\\t// BaseCommit is the commit hash this session is based on\\n   129→\\tBaseCommit string\\n   130→\\n   131→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n   132→\\t// Used to create worktree-specific shadow branch names\\n   133→\\tWorktreeID string\\n   134→\\n   135→\\t// ModifiedFiles are files that have been modified (relative paths)\\n   136→\\tModifiedFiles []string\\n   137→\\n   138→\\t// NewFiles are files that have been created (relative paths)\\n   139→\\tNewFiles []string\\n   140→\\n   141→\\t// DeletedFiles are files that have been deleted (relative paths)\\n   142→\\tDeletedFiles []string\\n   143→\\n   144→\\t// MetadataDir is the relative path to the metadata directory\\n   145→\\tMetadataDir string\\n   146→\\n   147→\\t// MetadataDirAbs is the absolute path to the metadata directory\\n   148→\\tMetadataDirAbs string\\n   149→\\n   150→\\t// CommitMessage is the commit subject line\\n   151→\\tCommitMessage string\\n   152→\\n   153→\\t// AuthorName is the name to use for commits\\n   154→\\tAuthorName string\\n   155→\\n   156→\\t// AuthorEmail is the email to use for commits\\n   157→\\tAuthorEmail string\\n   158→\\n   159→\\t// IsFirstCheckpoint indicates if this is the first checkpoint of the session\\n   160→\\t// When true, all working directory files are captured (not just modified)\\n   161→\\tIsFirstCheckpoint bool\\n   162→}\\n   163→\\n   164→// ReadTemporaryResult contains the result of reading a temporary checkpoint.\\n   165→type ReadTemporaryResult struct {\\n   166→\\t// CommitHash is the hash of the checkpoint commit\\n   167→\\tCommitHash plumbing.Hash\\n   168→\\n   169→\\t// TreeHash is the hash of the tree containing the checkpoint state\\n   170→\\tTreeHash plumbing.Hash\\n   171→\\n   172→\\t// SessionID is the session identifier from the commit trailer\\n   173→\\tSessionID string\\n   174→\\n   175→\\t// MetadataDir is the metadata directory path from the commit trailer\\n   176→\\tMetadataDir string\\n   177→\\n   178→\\t// Timestamp is when the checkpoint was created\\n   179→\\tTimestamp time.Time\\n   180→}\\n   181→\\n   182→// TemporaryInfo contains summary information about a shadow branch.\\n   183→type TemporaryInfo struct {\\n   184→\\t// BranchName is the full branch name (e.g., \\\"entire/abc1234\\\")\\n   185→\\tBranchName string\\n   186→\\n   187→\\t// BaseCommit is the short commit hash this branch is based on\\n   188→\\tBaseCommit string\\n   189→\\n   190→\\t// LatestCommit is the hash of the latest commit on the branch\\n   191→\\tLatestCommit plumbing.Hash\\n   192→\\n   193→\\t// SessionID is the session identifier from the latest commit\\n   194→\\tSessionID string\\n   195→\\n   196→\\t// Timestamp is when the latest checkpoint was created\\n   197→\\tTimestamp time.Time\\n   198→}\\n   199→\\n   200→// WriteCommittedOptions contains options for writing a committed checkpoint.\\n   201→type WriteCommittedOptions struct {\\n   202→\\t// CheckpointID is the stable 12-hex-char identifier\\n   203→\\tCheckpointID id.CheckpointID\\n   204→\\n   205→\\t// SessionID is the session identifier\\n   206→\\tSessionID string\\n   207→\\n   208→\\t// Strategy is the name of the strategy that created this checkpoint\\n   209→\\tStrategy string\\n   210→\\n   211→\\t// Branch is the branch name where the checkpoint was created (empty if detached HEAD)\\n   212→\\tBranch string\\n   213→\\n   214→\\t// Transcript is the session transcript content (full.jsonl)\\n   215→\\tTranscript []byte\\n   216→\\n   217→\\t// Prompts contains user prompts from the session\\n   218→\\tPrompts []string\\n   219→\\n   220→\\t// FilesTouched are files modified during the session\\n   221→\\tFilesTouched []string\\n   222→\\n   223→\\t// CheckpointsCount is the number of checkpoints in this session\\n   224→\\tCheckpointsCount int\\n   225→\\n   226→\\t// EphemeralBranch is the shadow branch name (for manual-commit strategy)\\n   227→\\tEphemeralBranch string\\n   228→\\n   229→\\t// AuthorName is the name to use for commits\\n   230→\\tAuthorName string\\n   231→\\n   232→\\t// AuthorEmail is the email to use for commits\\n   233→\\tAuthorEmail string\\n   234→\\n   235→\\t// MetadataDir is a directory containing additional metadata files to copy\\n   236→\\t// If set, all files in this directory will be copied to the checkpoint path\\n   237→\\t// This is useful for copying task metadata files, subagent transcripts, etc.\\n   238→\\tMetadataDir string\\n   239→\\n   240→\\t// Task checkpoint fields (for task/subagent checkpoints)\\n   241→\\tIsTask    bool   // Whether this is a task checkpoint\\n   242→\\tToolUseID string // Tool use ID for task checkpoints\\n   243→\\n   244→\\t// Additional task checkpoint fields for subagent checkpoints\\n   245→\\tAgentID                string // Subagent identifier\\n   246→\\tCheckpointUUID         string // UUID for transcript truncation when rewinding\\n   247→\\tTranscriptPath         string // Path to session transcript file (alternative to in-memory Transcript)\\n   248→\\tSubagentTranscriptPath string // Path to subagent's transcript file\\n   249→\\n   250→\\t// Incremental checkpoint fields\\n   251→\\tIsIncremental       bool   // Whether this is an incremental checkpoint\\n   252→\\tIncrementalSequence int    // Checkpoint sequence number\\n   253→\\tIncrementalType     string // Tool type that triggered this checkpoint\\n   254→\\tIncrementalData     []byte // Tool input payload for this checkpoint\\n   255→\\n   256→\\t// Commit message fields (used for task checkpoints)\\n   257→\\tCommitSubject string // Subject line for the metadata commit (overrides default)\\n   258→\\n   259→\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   260→\\tAgent types.AgentType\\n   261→\\n   262→\\t// Model is the LLM model used during the session (e.g., \\\"claude-sonnet-4-20250514\\\")\\n   263→\\tModel string\\n   264→\\n   265→\\t// TurnID correlates checkpoints from the same agent turn.\\n   266→\\tTurnID string\\n   267→\\n   268→\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n   269→\\tTranscriptIdentifierAtStart string // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n   270→\\tCheckpointTranscriptStart   int    // Transcript line offset at start of this checkpoint's data\\n   271→\\n   272→\\t// CheckpointTranscriptStart is written to both CommittedMetadata.CheckpointTranscriptStart\\n   273→\\t// and the deprecated CommittedMetadata.TranscriptLinesAtStart for backward compatibility.\\n   274→\\n   275→\\t// TokenUsage contains the token usage for this checkpoint\\n   276→\\tTokenUsage *agent.TokenUsage\\n   277→\\n   278→\\t// SessionMetrics contains hook-provided session metrics (duration, turns, context usage)\\n   279→\\tSessionMetrics *SessionMetrics\\n   280→\\n   281→\\t// InitialAttribution is line-level attribution calculated at commit time\\n   282→\\t// comparing checkpoint tree (agent work) to committed tree (may include human edits)\\n   283→\\tInitialAttribution *InitialAttribution\\n   284→\\n   285→\\t// Summary is an optional AI-generated summary for this checkpoint.\\n   286→\\t// This field may be nil when:\\n   287→\\t//   - summarization is disabled in settings\\n   288→\\t//   - summary generation failed (non-blocking, logged as warning)\\n   289→\\t//   - the transcript was empty or too short to summarize\\n   290→\\t//   - the checkpoint predates the summarization feature\\n   291→\\tSummary *Summary\\n   292→}\\n   293→\\n   294→// UpdateCommittedOptions contains options for updating an existing committed checkpoint.\\n   295→// Uses replace semantics: the transcript and prompts are fully replaced,\\n   296→// not appended. At stop time we have the complete session transcript and want every\\n   297→// checkpoint to contain it identically.\\n   298→type UpdateCommittedOptions struct {\\n   299→\\t// CheckpointID identifies the checkpoint to update\\n   300→\\tCheckpointID id.CheckpointID\\n   301→\\n   302→\\t// SessionID identifies which session slot to update within the checkpoint\\n   303→\\tSessionID string\\n   304→\\n   305→\\t// Transcript is the full session transcript (replaces existing)\\n   306→\\tTranscript []byte\\n   307→\\n   308→\\t// Prompts contains all user prompts (replaces existing)\\n   309→\\tPrompts []string\\n   310→\\n   311→\\t// Agent identifies the agent type (needed for transcript chunking)\\n   312→\\tAgent types.AgentType\\n   313→}\\n   314→\\n   315→// CommittedInfo contains summary information about a committed checkpoint.\\n   316→type CommittedInfo struct {\\n   317→\\t// CheckpointID is the stable 12-hex-char identifier\\n   318→\\tCheckpointID id.CheckpointID\\n   319→\\n   320→\\t// SessionID is the session identifier (most recent session for multi-session checkpoints)\\n   321→\\tSessionID string\\n   322→\\n   323→\\t// CreatedAt is when the checkpoint was created\\n   324→\\tCreatedAt time.Time\\n   325→\\n   326→\\t// CheckpointsCount is the total number of checkpoints across all sessions\\n   327→\\tCheckpointsCount int\\n   328→\\n   329→\\t// FilesTouched are files modified during all sessions\\n   330→\\tFilesTouched []string\\n   331→\\n   332→\\t// Agent identifies the agent that created this checkpoint\\n   333→\\tAgent types.AgentType\\n   334→\\n   335→\\t// IsTask indicates if this is a task checkpoint\\n   336→\\tIsTask bool\\n   337→\\n   338→\\t// ToolUseID is the tool use ID for task checkpoints\\n   339→\\tToolUseID string\\n   340→\\n   341→\\t// Multi-session support\\n   342→\\tSessionCount int      // Number of sessions (1 if single session)\\n   343→\\tSessionIDs   []string // All session IDs that contributed\\n   344→}\\n   345→\\n   346→// SessionContent contains the actual content for a session.\\n   347→// This is used when reading full session data (transcript, prompts, context)\\n   348→// as opposed to just the metadata/summary.\\n   349→type SessionContent struct {\\n   350→\\t// Metadata contains the session-specific metadata\\n   351→\\tMetadata CommittedMetadata\\n   352→\\n   353→\\t// Transcript is the session transcript content\\n   354→\\tTranscript []byte\\n   355→\\n   356→\\t// Prompts contains user prompts from this session\\n   357→\\tPrompts string\\n   358→}\\n   359→\\n   360→// CommittedMetadata contains the metadata stored in metadata.json for each checkpoint.\\n   361→type CommittedMetadata struct {\\n   362→\\tCLIVersion       string          `json:\\\"cli_version,omitempty\\\"`\\n   363→\\tCheckpointID     id.CheckpointID `json:\\\"checkpoint_id\\\"`\\n   364→\\tSessionID        string          `json:\\\"session_id\\\"`\\n   365→\\tStrategy         string          `json:\\\"strategy\\\"`\\n   366→\\tCreatedAt        time.Time       `json:\\\"created_at\\\"`\\n   367→\\tBranch           string          `json:\\\"branch,omitempty\\\"` // Branch where checkpoint was created (empty if detached HEAD)\\n   368→\\tCheckpointsCount int             `json:\\\"checkpoints_count\\\"`\\n   369→\\tFilesTouched     []string        `json:\\\"files_touched\\\"`\\n   370→\\n   371→\\t// Agent identifies the agent that created this checkpoint (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   372→\\tAgent types.AgentType `json:\\\"agent,omitempty\\\"`\\n   373→\\n   374→\\t// Model is the LLM model used during the session (e.g., \\\"claude-sonnet-4-20250514\\\")\\n   375→\\tModel string `json:\\\"model,omitempty\\\"`\\n   376→\\n   377→\\t// TurnID correlates checkpoints from the same agent turn.\\n   378→\\t// When a turn's work spans multiple commits, each gets its own checkpoint\\n   379→\\t// but they share the same TurnID for future aggregation/deduplication.\\n   380→\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n   381→\\n   382→\\t// Task checkpoint fields (only populated for task checkpoints)\\n   383→\\tIsTask    bool   `json:\\\"is_task,omitempty\\\"`\\n   384→\\tToolUseID string `json:\\\"tool_use_id,omitempty\\\"`\\n   385→\\n   386→\\t// Transcript position at checkpoint start - tracks what was added during this checkpoint\\n   387→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"` // Last identifier when checkpoint started (UUID for Claude, message ID for Gemini)\\n   388→\\tCheckpointTranscriptStart   int    `json:\\\"checkpoint_transcript_start,omitempty\\\"`    // Transcript line offset at start of this checkpoint's data\\n   389→\\n   390→\\t// Deprecated: Use CheckpointTranscriptStart instead. Written for backward compatibility with older CLI versions.\\n   391→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   392→\\n   393→\\t// Token usage for this checkpoint\\n   394→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   395→\\n   396→\\t// SessionMetrics contains hook-provided session metrics (duration, turns, context usage).\\n   397→\\t// Populated for agents that provide these metrics via hooks (e.g., Cursor).\\n   398→\\tSessionMetrics *SessionMetrics `json:\\\"session_metrics,omitempty\\\"`\\n   399→\\n   400→\\t// AI-generated summary of the checkpoint\\n   401→\\tSummary *Summary `json:\\\"summary,omitempty\\\"`\\n   402→\\n   403→\\t// InitialAttribution is line-level attribution calculated at commit time\\n   404→\\tInitialAttribution *InitialAttribution `json:\\\"initial_attribution,omitempty\\\"`\\n   405→}\\n   406→\\n   407→// GetTranscriptStart returns the transcript line offset at which this checkpoint's data begins.\\n   408→// Returns 0 for new checkpoints (start from beginning). For data written by older CLI versions,\\n   409→// falls back to the deprecated TranscriptLinesAtStart field.\\n   410→func (m CommittedMetadata) GetTranscriptStart() int {\\n   411→\\tif m.CheckpointTranscriptStart > 0 {\\n   412→\\t\\treturn m.CheckpointTranscriptStart\\n   413→\\t}\\n   414→\\treturn m.TranscriptLinesAtStart\\n   415→}\\n   416→\\n   417→// SessionFilePaths contains the absolute paths to session files from the git tree root.\\n   418→// Paths include the full checkpoint path prefix (e.g., \\\"/a1/b2c3d4e5f6/1/metadata.json\\\").\\n   419→// Used in CheckpointSummary.Sessions to map session IDs to their file locations.\\n   420→type SessionFilePaths struct {\\n   421→\\tMetadata    string `json:\\\"metadata\\\"`\\n   422→\\tTranscript  string `json:\\\"transcript\\\"`\\n   423→\\tContentHash string `json:\\\"content_hash\\\"`\\n   424→\\tPrompt      string `json:\\\"prompt\\\"`\\n   425→}\\n   426→\\n   427→// CheckpointSummary is the root-level metadata.json for a checkpoint.\\n   428→// It contains aggregated statistics from all sessions and a map of session IDs\\n   429→// to their file paths. Session-specific data (including initial_attribution)\\n   430→// is stored in the session's subdirectory metadata.json.\\n   431→//\\n   432→// Structure on entire/checkpoints/v1 branch:\\n   433→//\\n   434→//\\t<checkpoint-id[:2]>/<checkpoint-id[2:]>/\\n   435→//\\t├── metadata.json         # This CheckpointSummary\\n   436→//\\t├── 1/                    # First session\\n   437→//\\t│   ├── metadata.json     # Session-specific CommittedMetadata\\n   438→//\\t│   ├── full.jsonl\\n   439→//\\t│   ├── prompt.txt\\n   440→//\\t│   └── content_hash.txt\\n   441→//\\t├── 2/                    # Second session\\n   442→//\\t└── 3/                    # Third session...\\n   443→//\\n   444→//nolint:revive // Named CheckpointSummary to avoid conflict with existing Summary struct\\n   445→type CheckpointSummary struct {\\n   446→\\tCLIVersion       string             `json:\\\"cli_version,omitempty\\\"`\\n   447→\\tCheckpointID     id.CheckpointID    `json:\\\"checkpoint_id\\\"`\\n   448→\\tStrategy         string             `json:\\\"strategy\\\"`\\n   449→\\tBranch           string             `json:\\\"branch,omitempty\\\"`\\n   450→\\tCheckpointsCount int                `json:\\\"checkpoints_count\\\"`\\n   451→\\tFilesTouched     []string           `json:\\\"files_touched\\\"`\\n   452→\\tSessions         []SessionFilePaths `json:\\\"sessions\\\"`\\n   453→\\tTokenUsage       *agent.TokenUsage  `json:\\\"token_usage,omitempty\\\"`\\n   454→}\\n   455→\\n   456→// SessionMetrics contains hook-provided session metrics from agents that report\\n   457→// them via lifecycle hooks (e.g., Cursor). These supplement transcript-derived\\n   458→// metrics for agents whose transcripts lack usage/timing data.\\n   459→type SessionMetrics struct {\\n   460→\\tDurationMs        int64 `json:\\\"duration_ms,omitempty\\\"`\\n   461→\\tTurnCount         int   `json:\\\"turn_count,omitempty\\\"`\\n   462→\\tContextTokens     int   `json:\\\"context_tokens,omitempty\\\"`\\n   463→\\tContextWindowSize int   `json:\\\"context_window_size,omitempty\\\"`\\n   464→}\\n   465→\\n   466→// Summary contains AI-generated summary of a checkpoint.\\n   467→type Summary struct {\\n   468→\\tIntent    string           `json:\\\"intent\\\"`     // What user wanted to accomplish\\n   469→\\tOutcome   string           `json:\\\"outcome\\\"`    // What was achieved\\n   470→\\tLearnings LearningsSummary `json:\\\"learnings\\\"`  // Categorized learnings\\n   471→\\tFriction  []string         `json:\\\"friction\\\"`   // Problems/annoyances encountered\\n   472→\\tOpenItems []string         `json:\\\"open_items\\\"` // Tech debt, unfinished work\\n   473→}\\n   474→\\n   475→// LearningsSummary contains learnings grouped by scope.\\n   476→type LearningsSummary struct {\\n   477→\\tRepo     []string       `json:\\\"repo\\\"`     // Codebase-specific patterns/conventions\\n   478→\\tCode     []CodeLearning `json:\\\"code\\\"`     // File/module specific findings\\n   479→\\tWorkflow []string       `json:\\\"workflow\\\"` // General dev practices\\n   480→}\\n   481→\\n   482→// CodeLearning captures a learning tied to a specific code location.\\n   483→type CodeLearning struct {\\n   484→\\tPath    string `json:\\\"path\\\"`               // File path\\n   485→\\tLine    int    `json:\\\"line,omitempty\\\"`     // Start line number\\n   486→\\tEndLine int    `json:\\\"end_line,omitempty\\\"` // End line for ranges (optional)\\n   487→\\tFinding string `json:\\\"finding\\\"`            // What was learned\\n   488→}\\n   489→\\n   490→// InitialAttribution captures line-level attribution metrics at commit time.\\n   491→// This is a point-in-time snapshot comparing the checkpoint tree (agent work)\\n   492→// against the committed tree (may include human edits).\\n   493→//\\n   494→// Attribution Metrics:\\n   495→//   - TotalCommitted measures \\\"net additions\\\" (lines added that remain in the commit)\\n   496→//   - AgentPercentage represents \\\"of the new code added, what percentage came from the agent\\\"\\n   497→//   - Deletion work is tracked separately in HumanRemoved (not included in percentage)\\n   498→//\\n   499→// Deletion-Only Commits:\\n   500→// For commits with only deletions (no additions), TotalCommitted will be 0 and\\n   501→// AgentPercentage will be 0. This is by design - the percentage metric is only\\n   502→// meaningful for commits that add code. Deletion contributions are captured in\\n   503→// the HumanRemoved field but don't affect the attribution percentage.\\n   504→type InitialAttribution struct {\\n   505→\\tCalculatedAt    time.Time `json:\\\"calculated_at\\\"`\\n   506→\\tAgentLines      int       `json:\\\"agent_lines\\\"`      // Lines added by agent (base → shadow diff)\\n   507→\\tHumanAdded      int       `json:\\\"human_added\\\"`      // Lines added by human (excluding modifications)\\n   508→\\tHumanModified   int       `json:\\\"human_modified\\\"`   // Lines modified by human (estimate: min(added, removed))\\n   509→\\tHumanRemoved    int       `json:\\\"human_removed\\\"`    // Lines removed by human (excluding modifications)\\n   510→\\tTotalCommitted  int       `json:\\\"total_committed\\\"`  // Net additions in commit (agent + human new lines, not total file size)\\n   511→\\tAgentPercentage float64   `json:\\\"agent_percentage\\\"` // agent_lines / total_committed * 100 (0 for deletion-only commits)\\n   512→}\\n   513→\\n   514→// Info provides summary information for listing checkpoints.\\n   515→// This is the generic checkpoint info type.\\n   516→type Info struct {\\n   517→\\t// ID is the checkpoint identifier\\n   518→\\tID string\\n   519→\\n   520→\\t// SessionID identifies the session\\n   521→\\tSessionID string\\n   522→\\n   523→\\t// Type indicates temporary or committed\\n   524→\\tType Type\\n   525→\\n   526→\\t// CreatedAt is when the checkpoint was created\\n   527→\\tCreatedAt time.Time\\n   528→\\n   529→\\t// Message is a summary description\\n   530→\\tMessage string\\n   531→}\\n   532→\\n   533→// WriteTemporaryTaskOptions contains options for writing a task checkpoint.\\n   534→// Task checkpoints are created when a subagent completes and contain both\\n   535→// code changes and task-specific metadata.\\n   536→type WriteTemporaryTaskOptions struct {\\n   537→\\t// SessionID is the session identifier\\n   538→\\tSessionID string\\n   539→\\n   540→\\t// BaseCommit is the commit hash this session is based on\\n   541→\\tBaseCommit string\\n   542→\\n   543→\\t// WorktreeID is the internal git worktree identifier (empty for main worktree)\\n   544→\\t// Used to create worktree-specific shadow branch names\\n   545→\\tWorktreeID string\\n   546→\\n   547→\\t// ToolUseID is the unique identifier for this Task tool invocation\\n   548→\\tToolUseID string\\n   549→\\n   550→\\t// AgentID is the subagent identifier\\n   551→\\tAgentID string\\n   552→\\n   553→\\t// ModifiedFiles are files that have been modified (relative paths)\\n   554→\\tModifiedFiles []string\\n   555→\\n   556→\\t// NewFiles are files that have been created (relative paths)\\n   557→\\tNewFiles []string\\n   558→\\n   559→\\t// DeletedFiles are files that have been deleted (relative paths)\\n   560→\\tDeletedFiles []string\\n   561→\\n   562→\\t// TranscriptPath is the path to the main session transcript\\n   563→\\tTranscriptPath string\\n   564→\\n   565→\\t// SubagentTranscriptPath is the path to the subagent's transcript\\n   566→\\tSub