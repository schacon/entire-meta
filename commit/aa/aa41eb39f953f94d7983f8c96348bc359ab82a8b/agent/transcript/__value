essionID string) error {\\n   348→\\t_ = ctx // Reserved for future use\\n   349→\\n   350→\\t// Validate session ID to prevent path traversal\\n   351→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   352→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   353→\\t}\\n   354→\\n   355→\\t// Remove all files for this session (state .json, .model hint, any future hint files).\\n   356→\\tmatches, _ := filepath.Glob(filepath.Join(s.stateDir, sessionID+\\\".*\\\")) //nolint:errcheck // pattern is always valid\\n   357→\\tfor _, f := range matches {\\n   358→\\t\\t_ = os.Remove(f)\\n   359→\\t}\\n   360→\\n   361→\\treturn nil\\n   362→}\\n   363→\\n   364→// RemoveAll removes the entire session state directory.\\n   365→// This is used during uninstall to completely remove all session state.\\n   366→func (s *StateStore) RemoveAll() error {\\n   367→\\tif err := os.RemoveAll(s.stateDir); err != nil {\\n   368→\\t\\treturn fmt.Errorf(\\\"failed to remove session state directory: %w\\\", err)\\n   369→\\t}\\n   370→\\treturn nil\\n   371→}\\n   372→\\n   373→// List returns all session states.\\n   374→func (s *StateStore) List(ctx context.Context) ([]*State, error) {\\n   375→\\tentries, err := os.ReadDir(s.stateDir)\\n   376→\\tif os.IsNotExist(err) {\\n   377→\\t\\treturn nil, nil\\n   378→\\t}\\n   379→\\tif err != nil {\\n   380→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state directory: %w\\\", err)\\n   381→\\t}\\n   382→\\n   383→\\tvar states []*State\\n   384→\\tfor _, entry := range entries {\\n   385→\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   386→\\t\\t\\tcontinue\\n   387→\\t\\t}\\n   388→\\t\\tif strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   389→\\t\\t\\tcontinue // Skip temp files\\n   390→\\t\\t}\\n   391→\\n   392→\\t\\tsessionID := strings.TrimSuffix(entry.Name(), \\\".json\\\")\\n   393→\\t\\tstate, err := s.Load(ctx, sessionID)\\n   394→\\t\\tif err != nil {\\