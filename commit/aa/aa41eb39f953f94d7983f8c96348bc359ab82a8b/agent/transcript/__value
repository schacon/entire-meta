 id.CheckpointID\\n    75→\\n    76→\\t// Agent is the human-readable name of the agent that created this checkpoint\\n    77→\\t// (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n    78→\\tAgent types.AgentType\\n    79→\\n    80→\\t// SessionID is the session identifier for this checkpoint.\\n    81→\\t// Used to distinguish checkpoints from different concurrent sessions.\\n    82→\\tSessionID string\\n    83→\\n    84→\\t// SessionPrompt is the initial prompt that started this session.\\n    85→\\t// Used to help users identify which session a checkpoint belongs to.\\n    86→\\tSessionPrompt string\\n    87→\\n    88→\\t// SessionCount is the number of sessions in this checkpoint (1 for single-session).\\n    89→\\t// Only populated for logs-only points with multi-session checkpoints.\\n    90→\\tSessionCount int\\n    91→\\n    92→\\t// SessionIDs contains all session IDs when this is a multi-session checkpoint.\\n    93→\\t// The last entry is the most recent session (same as SessionID).\\n    94→\\t// Only populated for logs-only points with multi-session checkpoints.\\n    95→\\tSessionIDs []string\\n    96→\\n    97→\\t// SessionPrompts contains the first prompt for each session (parallel to SessionIDs).\\n    98→\\t// Used to display context when showing resume commands for multi-session checkpoints.\\n    99→\\tSessionPrompts []string\\n   100→}\\n   101→\\n   102→// RewindPreview describes what will happen when rewinding to a checkpoint.\\n   103→// Used to warn users about files that will be modified or deleted.\\n   104→type RewindPreview struct {\\n   105→\\t// FilesToRestore are files from the checkpoint that will be written/restored.\\n   106→\\tFilesToRestore []string\\n   107→\\n   108→\\t// FilesToDelete are untracked files that will be removed.\\n   109→\\t// These are files created after the checkpoint that aren't in the checkpoint tree\\n   110→\\t// and weren't present at session start.\\n   111→\\tFilesToDelete []string\\n   112→\\n   113→\\t//