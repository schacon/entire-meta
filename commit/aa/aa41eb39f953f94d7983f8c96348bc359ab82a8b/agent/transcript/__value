nscript.TypeUser {\\n   405→\\t\\t\\t\\tprompt := extractTextFromMessage(line.Message)\\n   406→\\t\\t\\t\\tif prompt != \\\"\\\" {\\n   407→\\t\\t\\t\\t\\treturn prompt\\n   408→\\t\\t\\t\\t}\\n   409→\\t\\t\\t}\\n   410→\\t\\t}\\n   411→\\t}\\n   412→\\n   413→\\t// Fallback: try Gemini JSON format {\\\"messages\\\": [...]}\\n   414→\\tif prompts, gemErr := geminicli.ExtractAllUserPrompts(data); gemErr == nil && len(prompts) > 0 {\\n   415→\\t\\treturn prompts[0]\\n   416→\\t}\\n   417→\\n   418→\\treturn \\\"\\\"\\n   419→}\\n   420→\\n   421→// extractTextFromMessage extracts the text content from a transcript message.\\n   422→func extractTextFromMessage(msg json.RawMessage) string {\\n   423→\\t// Try string content first (simple user messages)\\n   424→\\tvar simple struct {\\n   425→\\t\\tContent string `json:\\\"content\\\"`\\n   426→\\t}\\n   427→\\tif err := json.Unmarshal(msg, &simple); err == nil && simple.Content != \\\"\\\" {\\n   428→\\t\\treturn simple.Content\\n   429→\\t}\\n   430→\\n   431→\\t// Try array content (messages with tool results, text blocks, etc.)\\n   432→\\tvar array struct {\\n   433→\\t\\tContent []struct {\\n   434→\\t\\t\\tType string `json:\\\"type\\\"`\\n   435→\\t\\t\\tText string `json:\\\"text\\\"`\\n   436→\\t\\t} `json:\\\"content\\\"`\\n   437→\\t}\\n   438→\\tif err := json.Unmarshal(msg, &array); err == nil {\\n   439→\\t\\tfor _, block := range array.Content {\\n   440→\\t\\t\\tif block.Type == \\\"text\\\" && block.Text != \\\"\\\" {\\n   441→\\t\\t\\t\\treturn block.Text\\n   442→\\t\\t\\t}\\n   443→\\t\\t}\\n   444→\\t}\\n   445→\\n   446→\\treturn \\\"\\\"\\n   447→}\\n   448→\\n   449→// normalizeGeminiTranscript re-serializes a Gemini JSON transcript so that all\\n   450→// content fields are plain strings. Gemini user messages store content as\\n   451→// [{\\\"text\\\":\\\"...\\\"}] arrays, but the UI expects string content. Parsing through\\n   452→// geminicli.ParseTranscript normalizes this via GeminiMessa