 (string, error) {\\n    33→\\tstateDir, err := getSessionStateDir(ctx)\\n    34→\\tif err != nil {\\n    35→\\t\\treturn \\\"\\\", err\\n    36→\\t}\\n    37→\\treturn filepath.Join(stateDir, sessionID+\\\".json\\\"), nil\\n    38→}\\n    39→\\n    40→// LoadSessionState loads the session state for the given session ID.\\n    41→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n    42→// Stale sessions are automatically deleted by the underlying StateStore.\\n    43→func LoadSessionState(ctx context.Context, sessionID string) (*SessionState, error) {\\n    44→\\tstore, err := session.NewStateStore(ctx)\\n    45→\\tif err != nil {\\n    46→\\t\\treturn nil, fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n    47→\\t}\\n    48→\\n    49→\\tstate, err := store.Load(ctx, sessionID)\\n    50→\\tif err != nil {\\n    51→\\t\\treturn nil, fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n    52→\\t}\\n    53→\\treturn state, nil\\n    54→}\\n    55→\\n    56→// SaveSessionState saves the session state atomically.\\n    57→func SaveSessionState(ctx context.Context, state *SessionState) error {\\n    58→\\t// Validate session ID to prevent path traversal\\n    59→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n    60→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n    61→\\t}\\n    62→\\n    63→\\tstateDir, err := getSessionStateDir(ctx)\\n    64→\\tif err != nil {\\n    65→\\t\\treturn fmt.Errorf(\\\"failed to get session state directory: %w\\\", err)\\n    66→\\t}\\n    67→\\n    68→\\tif err := os.MkdirAll(stateDir, 0o750); err != nil {\\n    69→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n    70→\\t}\\n    71→\\n    72→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n    73→\\tif err != nil {\\n    74→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n    75→\\t}\\n    76→\\n    77→\\tstateFile, err := sessionStateFile(ctx, state.SessionID)\\n    78→\\tif err != nil {\\n    79→\\t\\treturn fmt.Errorf(\\\"failed to get session state file path: %w\\\", err)\\n    80→\\t}\\n    81→\\n    82→\\t// Atomic write: write to temp file, then rename\\n    83→\\ttmpFile := stateFile + \\\".tmp\\\"\\n    84→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n    85→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n    86→\\t}\\n    87→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n    88→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n    89→\\t}\\n    90→\\treturn nil\\n    91→}\\n    92→\\n    93→// ListSessionStates returns all session states from the state directory.\\n    94→// This is a package-level function that doesn't require a specific strategy instance.\\n    95→func ListSessionStates(ctx context.Context) ([]*SessionState, error) {\\n    96→\\tstore, err := session.NewStateStore(ctx)\\n    97→\\tif err != nil {\\n    98→\\t\\treturn nil, fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n    99→\\t}\\n   100→\\n   101→\\tstates, err := store.List(ctx)\\n   102→\\tif err != nil {\\n   103→\\t\\treturn nil, fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   104→\\t}\\n   105→\\treturn states, nil\\n   106→}\\n   107→\\n   108→// FindMostRecentSession returns the session ID of the most recently interacted session\\n   109→// (by LastInteractionTime) in the current worktree. Returns empty string if no sessions exist.\\n   110→// Scoping to the current worktree prevents cross-worktree pollution in log routing.\\n   111→// Falls back to unfiltered search if the worktree path can't be determined.\\n   112→func FindMostRecentSession(ctx context.Context) string {\\n   113→\\tstates, err := ListSessionStates(ctx)\\n   114→\\tif err != nil || len(states) == 0 {\\n   115→\\t\\treturn \\\"\\\"\\n   116→\\t}\\n   117→\\n   118→\\t// Scope to current worktree to prevent cross-worktree pollution.\\n   119→\\tworktreePath, wpErr := paths.WorktreeRoot(ctx)\\n   120→\\tif wpErr == nil && worktreePath != \\\"\\\" {\\n   121→\\t\\tvar filtered []*SessionState\\n   122→\\t\\tfor _, s := range states {\\n   123→\\t\\t\\tif s.WorktreePath == worktreePath {\\n   124→\\t\\t\\t\\tfiltered = append(filtered, s)\\n   125→\\t\\t\\t}\\n   126→\\t\\t}\\n   127→\\t\\tif len(filtered) > 0 {\\n   128→\\t\\t\\tstates = filtered\\n   129→\\t\\t}\\n   130→\\t\\t// If no sessions match the worktree, fall back to all sessions\\n   131→\\t}\\n   132→\\n   133→\\tvar best *SessionState\\n   134→\\tfor _, s := range states {\\n   135→\\t\\tif s.LastInteractionTime == nil {\\n   136→\\t\\t\\tcontinue\\n   137→\\t\\t}\\n   138→\\t\\tif best == nil || s.LastInteractionTime.After(*best.LastInteractionTime) {\\n   139→\\t\\t\\tbest = s\\n   140→\\t\\t}\\n   141→\\t}\\n   142→\\tif best != nil {\\n   143→\\t\\treturn best.SessionID\\n   144→\\t}\\n   145→\\n   146→\\t// Fallback: return most recently started session\\n   147→\\tfor _, s := range states {\\n   148→\\t\\tif best == nil || s.StartedAt.After(best.StartedAt) {\\n   149→\\t\\t\\tbest = s\\n   150→\\t\\t}\\n   151→\\t}\\n   152→\\tif best != nil {\\n   153→\\t\\treturn best.SessionID\\n   154→\\t}\\n   155→\\treturn \\\"\\\"\\n   156→}\\n   157→\\n   158→// TransitionAndLog runs a session phase transition, applies actions via the\\n   159→// handler, and logs the transition. Returns the first handler error from\\n   160→// ApplyTransition (if any) so callers can surface it. The error is also\\n   161→// logged internally for diagnostics.\\n   162→// This is the single entry point for all state machine transitions to ensure\\n   163→// consistent logging of phase changes.\\n   164→func TransitionAndLog(goCtx context.Context, state *SessionState, event session.Event, ctx session.TransitionContext, handler session.ActionHandler) error {\\n   165→\\toldPhase := state.Phase\\n   166→\\tresult := session.Transition(oldPhase, event, ctx)\\n   167→\\tlogCtx := logging.WithComponent(goCtx, \\\"session\\\")\\n   168→\\n   169→\\thandlerErr := session.ApplyTransition(goCtx, state, result, handler)\\n   170→\\tif handlerErr != nil {\\n   171→\\t\\tlogging.Error(logCtx, \\\"action handler error during transition\\\",\\n   172→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   173→\\t\\t\\tslog.String(\\\"event\\\", event.String()),\\n   174→\\t\\t\\tslog.Any(\\\"error\\\", handlerErr),\\n   175→\\t\\t)\\n   176→\\t}\\n   177→\\n   178→\\tif result.NewPhase != oldPhase {\\n   179→\\t\\tlogging.Info(logCtx, \\\"phase transition\\\",\\n   180→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   181→\\t\\t\\tslog.String(\\\"event\\\", event.String()),\\n   182→\\t\\t\\tslog.String(\\\"from\\\", string(oldPhase)),\\n   183→\\t\\t\\tslog.String(\\\"to\\\", string(result.NewPhase)),\\n   184→\\t\\t)\\n   185→\\t} else {\\n   186→\\t\\tlogging.Debug(logCtx, \\\"phase unchanged\\\",\\n   187→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   188→\\t\\t\\tslog.String(\\\"event\\\", event.String()),\\n   189→\\t\\t\\tslog.String(\\\"phase\\\", string(result.NewPhase)),\\n   190→\\t\\t\\tslog.Any(\\\"result\\\", result),\\n   191→\\t\\t)\\n   192→\\t}\\n   193→\\n   194→\\tif handlerErr != nil {\\n   195→\\t\\treturn fmt.Errorf(\\\"transition %s: %w\\\", event, handlerErr)\\n   196→\\t}\\n   197→\\treturn nil\\n   198→}\\n   199→\\n   200→// StoreModelHint writes the LLM model name to a lightweight hint file\\n   201→// (.git/entire-sessions/{session_id}.model) for cross-process persistence.\\n   202→//\\n   203→// Why a separate file instead of SessionState?\\n   204→//\\n   205→// SessionState requires BaseCommit (used for shadow branch naming, checkpoint\\n   206→// writing, doctor classification, etc.) and is only created during TurnStart\\n   207→// when the git repo is fully inspected. Some agents report the model on earlier\\n   208→// hooks that fire as separate CLI processes before TurnStart:\\n   209→//\\n   210→//   - Claude Code sends \\\"model\\\" on SessionStart (before any TurnStart)\\n   211→//   - Gemini CLI sends \\\"llm_request.model\\\" on BeforeModel (after TurnStart,\\n   212→//     so handleLifecycleModelUpdate writes to SessionState directly when it\\n   213→//     exists and only falls back to this hint file otherwise)\\n   214→//\\n   215→// The hint is read by handleLifecycleTurnStart/TurnEnd when event.Model is\\n   216→// empty, passed to InitializeSession, and persisted in state.ModelName. After\\n   217→// that the hint file is redundant — it sits unused until ClearSessionState\\n   218→// removes it alongside the session state file.\\n   219→func StoreModelHint(ctx context.Context, sessionID, model string) error {\\n   220→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   221→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   222→\\t}\\n   223→\\tif model == \\\"\\\" {\\n   224→\\t\\treturn nil\\n   225→\\t}\\n   226→\\n   227→\\tstateDir, err := getSessionStateDir(ctx)\\n   228→\\tif err != nil {\\n   229→\\t\\treturn fmt.Errorf(\\\"failed to get session state directory: %w\\\", err)\\n   230→\\t}\\n   231→\\tif err := os.MkdirAll(stateDir, 0o750); err != nil {\\n   232→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   233→\\t}\\n   234→\\n   235→\\thintFile := filepath.Join(stateDir, sessionID+\\\".model\\\")\\n   236→\\tif err := os.WriteFile(hintFile, []byte(model), 0o600); err != nil {\\n   237→\\t\\treturn fmt.Errorf(\\\"failed to write model hint file: %w\\\", err)\\n   238→\\t}\\n   239→\\treturn nil\\n   240→}\\n   241→\\n   242→// LoadModelHint reads the LLM model name from the hint file for the given session.\\n   243→// Returns empty string if the hint file doesn't exist or can't be read.\\n   244→func LoadModelHint(ctx context.Context, sessionID string) string {\\n