\n     4→\\t\\\"crypto/sha256\\\"\\n     5→\\t\\\"encoding/hex\\\"\\n     6→\\t\\\"encoding/json\\\"\\n     7→\\t\\\"fmt\\\"\\n     8→\\t\\\"os\\\"\\n     9→\\t\\\"path/filepath\\\"\\n    10→\\t\\\"regexp\\\"\\n    11→\\t\\\"strings\\\"\\n    12→\\t\\\"testing\\\"\\n    13→\\t\\\"time\\\"\\n    14→\\n    15→\\t\\\"github.com/stretchr/testify/assert\\\"\\n    16→\\t\\\"github.com/stretchr/testify/require\\\"\\n    17→)\\n    18→\\n    19→// DeepCheckpointValidation contains expected values for comprehensive checkpoint validation.\\n    20→type DeepCheckpointValidation struct {\\n    21→\\tCheckpointID              string\\n    22→\\tStrategy                  string\\n    23→\\tFilesTouched              []string\\n    24→\\tExpectedPrompts           []string\\n    25→\\tExpectedTranscriptContent []string\\n    26→}\\n    27→\\n    28→var hexIDPattern = regexp.MustCompile(`^[0-9a-f]{12}$`)\\n    29→\\n    30→// AssertFileExists asserts that at least one file matches the glob pattern\\n    31→// relative to dir.\\n    32→func AssertFileExists(t *testing.T, dir string, glob string) {\\n    33→\\tt.Helper()\\n    34→\\tmatches, err := filepath.Glob(filepath.Join(dir, glob))\\n    35→\\trequire.NoError(t, err)\\n    36→\\tassert.NotEmpty(t, matches, \\\"expected files matching %s in %s\\\", glob, dir)\\n    37→}\\n    38→\\n    39→// WaitForFileExists polls until at least one file matches the glob pattern\\n    40→// relative to dir, or fails the test after timeout. Handles the race where an\\n    41→// interactive agent's prompt pattern appears before file writes land on disk.\\n    42→func WaitForFileExists(t *testing.T, dir string, glob string, timeout time.Duration) {\\n    43→\\tt.Helper()\\n    44→\\tpattern := filepath.Join(dir, glob)\\n    45→\\tdeadline := time.Now().Add(timeout)\\n    46→\\tfor {\\n    47→\\t\\tmatches, err := filepath.Glob(pattern)\\n    48→\\t\\trequire.NoError(t, err)\\n    49→\\t\\tif len(matches) > 0 {\\n    50→\\t\\t\\treturn\\n    51→\\t\\t}\\n    52→\\t\\tif time.Now().After(deadline) {\\n    53→\\t\\t\\tt.Fatalf(\\\"expected files matching %s in %s within %s\\\", glob, dir, timeout)\\n    54→\\t\\t}\\n    55→\\t\\ttime.Sleep(500 * time.Millisecond)\\n    56→\\t}\\n    57→}\\n    58→\\n    59→// AssertNewCommits polls until at least `atLeast` new commits exist since setup,\\n    60→// or fails after 20 seconds. Polling handles the race where an interactive\\n    61→// agent's prompt pattern appears before its git commit lands on disk.\\n    62→func AssertNewCommits(t *testing.T, s *RepoState, atLeast int) {\\n    63→\\tt.Helper()\\n    64→\\tdeadline := time.Now().Add(20 * time.Second)\\n    65→\\tfor {\\n    66→\\t\\tout := GitOutput(t, s.Dir, \\\"log\\\", \\\"--oneline\\\", s.HeadBefore+\\\"..HEAD\\\")\\n    67→\\t\\tvar lines []string\\n    68→\\t\\tif out != \\\"\\\" {\\n    69→\\t\\t\\tlines = strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\")\\n    70→\\t\\t}\\n    71→\\t\\tif len(lines) >= atLeast {\\n    72→\\t\\t\\treturn\\n    73→\\t\\t}\\n    74→\\t\\tif time.Now().After(deadline) {\\n    75→\\t\\t\\tt.Fatalf(\\\"expected at least %d new commit(s), got %d after 20s\\\", atLeast, len(lines))\\n    76→\\t\\t}\\n    77→\\t\\ttime.Sleep(500 * time.Millisecond)\\n    78→\\t}\\n    79→}\\n    80→\\n    81→// WaitForCheckpoint polls until the checkpoint branch advances from its\\n    82→// initial state, or fails the test after timeout. Use this before any\\n    83→// assertions that depend on the checkpoint branch (post-commit hook is async).\\n    84→func WaitForCheckpoint(t *testing.T, s *RepoState, timeout time.Duration) {\\n    85→\\tt.Helper()\\n    86→\\tdeadline := time.Now().Add(timeout)\\n    87→\\tfor time.Now().Before(deadline) {\\n    88→\\t\\tafter := GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n    89→\\t\\tif after != s.CheckpointBefore {\\n    90→\\t\\t\\treturn\\n    91→\\t\\t}\\n    92→\\t\\ttime.Sleep(200 * time.Millisecond)\\n    93→\\t}\\n    94→\\tt.Fatalf(\\\"checkpoint branch did not advance within %s\\\", timeout)\\n    95→}\\n    96→\\n    97→// shadowBranches returns all shadow branches (entire/*) excluding entire/checkpoints/*.\\n    98→func shadowBranches(t *testing.T, dir string) []string {\\n    99→\\tt.Helper()\\n   100→\\tbranches := GitOutput(t, dir, \\\"for-each-ref\\\", \\\"--format=%(refname:short)\\\", \\\"refs/heads/entire/\\\")\\n   101→\\tvar shadow []string\\n   102→\\tfor _, b := range strings.Split(branches, \\\"\\\\n\\\") {\\n   103→\\t\\tb = strings.TrimSpace(b)\\n   104→\\t\\tif b == \\\"\\\" || strings.HasPrefix(b, \\\"entire/checkpoints\\\") {\\n   105→\\t\\t\\tcontinue\\n   106→\\t\\t}\\n   107→\\t\\tshadow = append(shadow, b)\\n   108→\\t}\\n   109→\\treturn shadow\\n   110→}\\n   111→\\n   112→// AssertNoShadowBranches asserts that no shadow branches (entire/*) remain,\\n   113→// excluding entire/checkpoints/*. Shadow branches should be cleaned up after\\n   114→// commits condense session data to the metadata branch.\\n   115→func AssertNoShadowBranches(t *testing.T, dir string) {\\n   116→\\tt.Helper()\\n   117→\\tshadow := shadowBranches(t, dir)\\n   118→\\tassert.Empty(t, shadow,\\n   119→\\t\\t\\\"shadow branches should be cleaned up after commit, found: %v\\\", shadow)\\n   120→}\\n   121→\\n   122→// AssertHasShadowBranches asserts that at least one shadow branch (entire/*)\\n   123→// exists, excluding entire/checkpoints/*. Use this when the shadow branch is\\n   124→// expected to persist (e.g., session is still idle).\\n   125→func AssertHasShadowBranches(t *testing.T, dir string) {\\n   126→\\tt.Helper()\\n   127→\\tshadow := shadowBranches(t, dir)\\n   128→\\tassert.NotEmpty(t, shadow,\\n   129→\\t\\t\\\"expected at least one shadow branch to persist, but none found\\\")\\n   130→}\\n   131→\\n   132→// AssertCheckpointAdvanced asserts the checkpoint branch moved forward.\\n   133→func AssertCheckpointAdvanced(t *testing.T, s *RepoState) {\\n   134→\\tt.Helper()\\n   135→\\tafter := GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n   136→\\tassert.NotEqual(t, s.CheckpointBefore, after, \\\"checkpoint branch did not advance\\\")\\n   137→}\\n   138→\\n   139→// AssertCheckpointNotAdvanced asserts the checkpoint branch has NOT moved.\\n   140→func AssertCheckpointNotAdvanced(t *testing.T, s *RepoState) {\\n   141→\\tt.Helper()\\n   142→\\tafter := GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n   143→\\tassert.Equal(t, s.CheckpointBefore, after, \\\"checkpoint branch advanced unexpectedly\\\")\\n   144→}\\n   145→\\n   146→// AssertCheckpointIDFormat asserts the checkpoint ID is 12 lowercase hex chars.\\n   147→func AssertCheckpointIDFormat(t *testing.T, checkpointID string) {\\n   148→\\tt.Helper()\\n   149→\\tassert.Regexp(t, hexIDPattern, checkpointID,\\n   150→\\t\\t\\\"checkpoint ID %q should be 12 lowercase hex chars\\\", checkpointID)\\n   151→}\\n   152→\\n   153→// AssertHasCheckpointTrailer asserts the commit has an Entire-Checkpoint trailer,\\n   154→// validates its format, and returns its value.\\n   155→func AssertHasCheckpointTrailer(t *testing.T, dir string, ref string) string {\\n   156→\\tt.Helper()\\n   157→\\ttrailer := GetCheckpointTrailer(t, dir, ref)\\n   158→\\trequire.NotEmpty(t, trailer, \\\"no Entire-Checkpoint trailer on %s\\\", ref)\\n   159→\\tAssertCheckpointIDFormat(t, trailer)\\n   160→\\treturn trailer\\n   161→}\\n   162→\\n   163→// AssertCheckpointInLastN asserts the given checkpoint ID appears in at\\n   164→// least n commits on the checkpoint branch (e.g. initial + catchup).\\n   165→// Uses --grep to find matching commits regardless of position, so extra\\n   166→// commits from multi-commit agent turns don't cause false failures.\\n   167→func AssertCheckpointInLastN(t *testing.T, dir string, checkpointID string, n int) {\\n   168→\\tt.Helper()\\n   169→\\tout := GitOutput(t, dir, \\\"log\\\", \\\"--grep=\\\"+checkpointID,\\n   170→\\t\\t\\\"--format=%s\\\", \\\"entire/checkpoints/v1\\\")\\n   171→\\tvar lines []string\\n   172→\\tfor _, line := range strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\") {\\n   173→\\t\\tif line != \\\"\\\" {\\n   174→\\t\\t\\tlines = append(lines, line)\\n   175→\\t\\t}\\n   176→\\t}\\n   177→\\tassert.GreaterOrEqual(t, len(lines), n,\\n   178→\\t\\t\\\"expected at least %d commits mentioning %s on checkpoint branch, got %d: %v\\\",\\n   179→\\t\\tn, checkpointID, len(lines), lines)\\n   180→}\\n   181→\\n   182→// AssertCheckpointExists asserts that the checkpoint ID is mentioned on\\n   183→// the checkpoint branch and that its metadata.json exists in the tree.\\n   184→func AssertCheckpointExists(t *testing.T, dir string, checkpointID string) {\\n   185→\\tt.Helper()\\n   186→\\tout := GitOutput(t, dir, \\\"log\\\", \\\"entire/checkpoints/v1\\\", \\\"--grep=\\\"+checkpointID, \\\"--oneline\\\")\\n   187→\\tassert.NotEmpty(t, out, \\\"checkpoint %s not found on checkpoint branch\\\", checkpointID)\\n   188→\\n   189→\\tpath := CheckpointPath(checkpointID) + \\\"/metadata.json\\\"\\n   190→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   191→\\traw := gitOutputSafe(dir, \\\"show\\\", blob)\\n   192→\\tassert.NotEmpty(t, raw,\\n   193→\\t\\t\\\"checkpoint %s metadata not found at %s\\\", checkpointID, path)\\n   194→}\\n   195→\\n   196→// AssertCommitLinkedToCheckpoint asserts the trailer exists AND the\\n   197→// checkpoint data exists on the checkpoint branch.\\n   198→func AssertCommitLinkedToCheckpoint(t *testing.T, dir string, ref string) {\\n   199→\\tt.Helper()\\n   200→\\ttrailer := AssertHasCheckpointTrailer(t, dir, ref)\\n   201→\\tAssertCheckpointExists(t, dir, trailer)\\n   202→}\\n   203→\\n   204→// AssertCheckpointHasSingleSession asserts checkpoint metadata has exactly one session.\\n   205→func AssertCheckpointHasSingleSession(t *testing.T, dir string, checkpointID string) {\\n   206→\\tt.Helper()\\n   207→\\tmeta := ReadCheckpointMetadata(t, dir, checkpointID)\\n   208→\\tassert.Len(t, meta.Sessions, 1,\\n   209→\\t\\t\\\"expected 1 session in checkpoint %s, got %d\\\", checkpointID, len(meta.Sessions))\\n   210→}\\n   211→\\n   212→// AssertCheckpointMetadataComplete asserts essential fields in checkpoint metadata are populated.\\n   213→func AssertCheckpointMetadataComplete(t *testing.T, dir string, checkpointID string) {\\n   214→\\tt.Helper()\\n   215→\\tmeta := ReadCheckpointMetadata(t, dir, checkpointID)\\n   216→\\tassert.NotEmpty(t, meta.CLIVersion, \\\"checkpoint %s: cli_version should be set\\\", checkpointID)\\n   217→\\tassert.NotEmpty(t, meta.Strategy, \\\"checkpoint %s: strategy should be set\\\", checkpointID)\\n   218→\\tassert.NotEmpty(t, meta.Sessions, \\\"checkpoint %s: should have at least 1 session\\\", checkpointID)\\n   219→\\tassert.Equal(t, checkpointID, meta.CheckpointID,\\n   220→\\t\\t\\\"checkpoint metadata ID should match expected\\\")\\n   221→}\\n   222→\\n   223→// WaitForCheckpointAdvanceFrom polls until the checkpoint branch advances from\\n   224→// the given ref, or fails the test after timeout. Use this when waiting for a\\n   225→// second (or subsequent) checkpoint after recording the branch position.\\n   226→func WaitForCheckpointAdvanceFrom(t *testing.T, dir string, fromRef string, timeout time.Duration) {\\n   227→\\tt.Helper()\\n   228→\\tdeadline := time.Now().Add(timeout)\\n   229→\\tfor time.Now().Before(deadline) {\\n   230→\\t\\tafter := GitOutput(t, dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n   231→\\t\\tif after != fromRef {\\n   232→\\t\\t\\treturn\\n   233→\\t\\t}\\n   234→\\t\\ttime.Sleep(200 * time.Millisecond)\\n   235→\\t}\\n   236→\\tt.Fatalf(\\\"checkpoint branch did not advance from %s within %s\\\", fromRef[:8], timeout)\\n   237→}\\n   238→\\n   239→// WaitForSessionIdle polls the session state files in .git/entire-sessions/\\n   240→// until no session has phase \\\"active\\\", or fails the test after timeout.\\n   241→// This handles the race where an agent's prompt pattern appears in the TUI\\n   242→// before the turn-end hook has completed (transitioning ACTIVE → IDLE).\\n   243→func WaitForSessionIdle(t *testing.T, dir string, timeout time.Duration) {\\n   244→\\tt.Helper()\\n   245→\\tstateDir := filepath.Join(dir, \\\".git\\\", \\\"entire-sessions\\\")\\n   246→\\tdeadline := time.Now().Add(timeout)\\n   247→\\tfor time.Now().Before(deadline) {\\n   248→\\t\\tentries, err := os.ReadDir(stateDir)\\n   249→\\t\\tif err != nil {\\n   250→\\t\\t\\t// Directory may not exist yet; keep polling\\n   251→\\t\\t\\ttime.Sleep(200 * time.Millisecond)\\n   252→\\t\\t\\tcontinue\\n   253→\\t\\t}\\n   254→\\t\\tanyActive := false\\n   255→\\t\\tfor _, entry := range entries {\\n   256→\\t\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") || strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   257→\\t\\t\\t\\tcontinue\\n   258→\\t\\t\\t}\\n   259→\\t\\t\\tdata, err := os.ReadFile(filepath.Join(stateDir, entry.Name()))\\n   260→\\t\\t\\tif err != nil {\\n   261→\\t\\t\\t\\tcontinue\\n   262→\\t\\t\\t}\\n   263→\\t\\t\\tvar state struct {\\n   264→\\t\\t\\t\\tPhase string `json:\\\"phase\\\"`\\n   265→\\t\\t\\t}\\n   266→\\t\\t\\tif err := json.Unmarshal(data, &state); err != nil {\\n   267→\\t\\t\\t\\tcontinue\\n   268→\\t\\t\\t}\\n   269→\\t\\t\\tif state.Phase == \\\"active\\\" {\\n   270→\\t\\t\\t\\tanyActive = true\\n   271→\\t\\t\\t\\tbreak\\n   272→\\t\\t\\t}\\n   273→\\t\\t}\\n   274→\\t\\tif !anyActive {\\n   275→\\t\\t\\treturn\\n   276→\\t\\t}\\n   277→\\t\\ttime.Sleep(200 * time.Millisecond)\\n   278→\\t}\\n   279→\\tt.Fatalf(\\\"session(s) did not transition to idle within %s\\\", timeout)\\n   280→}\\n   281→\\n   282→// AssertNoCheckpointTrailer asserts the commit does NOT have an Entire-Checkpoint trailer.\\n   283→func AssertNoCheckpointTrailer(t *testing.T, dir string, ref string) {\\n   284→\\tt.Helper()\\n   285→\\ttrailer := GetCheckpointTrailer(t, dir, ref)\\n   286→\\tassert.Empty(t, trailer, \\\"expected no Entire-Checkpoint trailer on %s, got %q\\\", ref, trailer)\\n   287→}\\n   288→\\n   289→// AssertCheckpointFilesTouched asserts the checkpoint metadata lists exactly\\n   290→// the expected files in files_touched (order-independent).\\n   291→func AssertCheckpointFilesTouched(t *testing.T, dir string, checkpointID string, expected []string) {\\n   292→\\tt.Helper()\\n   293→\\tmeta := ReadCheckpointMetadata(t, dir, checkpointID)\\n   294→\\tassert.ElementsMatch(t, expected, meta.FilesTouched,\\n   295→\\t\\t\\\"checkpoint %s: files_touched mismatch\\\", checkpointID)\\n   296→}\\n   297→\\n   298→// AssertCheckpointFilesTouchedContains asserts files_touched contains a\\n   299→// specific file path (subset check, unlike the exact-match AssertCheckpointFilesTouched).\\n   300→func AssertCheckpointFilesTouchedContains(t *testing.T, dir string, checkpointID string, file string) {\\n   301→\\tt.Helper()\\n   302→\\tmeta := ReadCheckpointMetadata(t, dir, checkpointID)\\n   303→\\tassert.Contains(t, meta.FilesTouched, file,\\n   304→\\t\\t\\\"checkpoint %s: files_touched should contain %s\\\", checkpointID, file)\\n   305→}\\n   306→\\n   307→// AssertDistinctSessions asserts session metadata across checkpoints has unique session IDs.\\n   308→func AssertDistinctSessions(t *testing.T, dir string, checkpointIDs []string) {\\n   309→\\tt.Helper()\\n   310→\\tseen := map[string]bool{}\\n   311→\\tfor _, cpID := range checkpointIDs {\\n   312→\\t\\tsm := ReadSessionMetadata(t, dir, cpID, 0)\\n   313→\\t\\tassert.False(t, seen[sm.SessionID],\\n   314→\\t\\t\\t\\\"duplicate session_id %s across checkpoints\\\", sm.SessionID)\\n   315→\\t\\tseen[sm.SessionID] = true\\n   316→\\t}\\n   317→}\\n   318→\\n   319→// ValidateCheckpointDeep performs comprehensive validation of checkpoint metadata\\n   320→// on the checkpoint branch, including transcript JSONL validity, content hash\\n   321→// verification, and prompt content checking.\\n   322→func ValidateCheckpointDeep(t *testing.T, dir string, v DeepCheckpointValidation) {\\n   323→\\tt.Helper()\\n   324→\\n   325→\\t// Basic metadata validation\\n   326→\\tAssertCheckpointExists(t, dir, v.CheckpointID)\\n   327→\\tAssertCheckpointMetadataComplete(t, dir, v.CheckpointID)\\n   328→\\n   329→\\tif v.Strategy != \\\"\\\" {\\n   330→\\t\\tmeta := ReadCheckpointMetadata(t, dir, v.CheckpointID)\\n   331→\\t\\tassert.Equal(t, v.Strategy, meta.Strategy,\\n   332→\\t\\t\\t\\\"checkpoint %s: strategy mismatch\\\", v.CheckpointID)\\n   333→\\t}\\n   334→\\n   335→\\tif len(v.FilesTouched) > 0 {\\n   336→\\t\\tAssertCheckpointFilesTouched(t, dir, v.CheckpointID, v.FilesTouched)\\n   337→\\t}\\n   338→\\n   339→\\tpath := CheckpointPath(v.CheckpointID)\\n   340→\\n   341→\\t// Validate session metadata exists and has checkpoint_id\\n   342→\\tsessionBlob := fmt.Sprintf(\\\"entire/checkpoints/v1:%s/0/metadata.json\\\", path)\\n   343→\\tsessionRaw := gitOutputSafe(dir, \\\"show\\\", sessionBlob)\\n   344→\\tif assert.NotEmpty(t, sessionRaw, \\\"session metadata should exist at %s\\\", sessionBlob) {\\n   345→\\t\\tvar sessionMeta map[string]any\\n   346→\\t\\tif assert.NoError(t, json.Unmarshal([]byte(sessionRaw), &sessionMeta)) {\\n   347→\\t\\t\\tassert.Equal(t, v.CheckpointID, sessionMeta[\\\"checkpoint_id\\\"],\\n   348→\\t\\t\\t\\t\\\"session metadata checkpoint_id should match\\\")\\n   349→\\t\\t\\tassert.NotEmpty(t, sessionMeta[\\\"created_at\\\"], \\\"session metadata should have created_at\\\")\\n   350→\\t\\t}\\n   351→\\t}\\n   352→\\n   353→\\t// Validate transcript is valid JSONL\\n   354→\\ttranscriptBlob := fmt.Sprintf(\\\"entire/checkpoints/v1:%s/0/full.jsonl\\\", path)\\n   355→\\ttranscriptRaw := gitOutputSafe(dir, \\\"show\\\", transcriptBlob)\\n   356→\\tif assert.NotEmpty(t, transcriptRaw, \\\"transcript should exist at %s\\\", transcriptBlob) {\\n   357→\\t\\tlines := strings.Split(transcriptRaw, \\\"\\\\n\\\")\\n   358→