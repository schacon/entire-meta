\")\\n    76→\\n    77→\\tout, err := cmd.CombinedOutput()\\n    78→\\tif err != nil {\\n    79→\\t\\tt.Fatalf(\\\"entire %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n    80→\\t}\\n    81→\\treturn strings.TrimSpace(string(out))\\n    82→}\\n    83→\\n    84→// runErr executes an `entire` subcommand in dir and returns any error.\\n    85→func runErr(dir string, args ...string) error {\\n    86→\\tcmd := exec.Command(BinPath(), args...)\\n    87→\\tcmd.Dir = dir\\n    88→\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n    89→\\n    90→\\tout, err := cmd.CombinedOutput()\\n    91→\\tif err != nil {\\n    92→\\t\\treturn &ExecError{\\n    93→\\t\\t\\tArgs:   args,\\n    94→\\t\\t\\tErr:    err,\\n    95→\\t\\t\\tOutput: string(out),\\n    96→\\t\\t}\\n    97→\\t}\\n    98→\\treturn nil\\n    99→}\\n   100→\\n   101→// ExecError wraps an entire CLI execution failure with its output.\\n   102→type ExecError struct {\\n   103→\\tArgs   []string\\n   104→\\tErr    error\\n   105→\\tOutput string\\n   106→}\\n   107→\\n   108→func (e *ExecError) Error() string {\\n   109→\\treturn \\\"entire \\\" + strings.Join(e.Args, \\\" \\\") + \\\": \\\" + e.Err.Error() + \\\"\\\\n\\\" + e.Output\\n   110→}\\n   111→\\n   112→func (e *ExecError) Unwrap() error {\\n   113→\\treturn e.Err\\n   114→}\\n   115→\\n   116→// Explain runs `entire explain --checkpoint <id>` and returns the output.\\n   117→func Explain(t *testing.T, dir, checkpointID string) string {\\n   118→\\tt.Helper()\\n   119→\\treturn run(t, dir, \\\"explain\\\", \\\"--checkpoint\\\", checkpointID)\\n   120→}\\n   121→\\n   122→// ExplainGenerate runs `entire explain --checkpoint <id> --generate`.\\n   123→// Returns (output, error) — doesn't fail test since callers may test failure cases.\\n   124→func ExplainGenerate(dir, checkpointID string) (string, error) {\\n   125→\\treturn runOutput(dir, \\\"explain\\\", \\\"--checkpoint\\\", checkpointID, \\\"--generate\\\")\\n   126→}\\n   127→\\n   128→// ExplainCommit runs `entire explain --commit <ref>`.\\n   129→// Returns (output, error) — for testing failure cases.\\n   130→func ExplainCommit(dir, ref string) (string, error) {\\n   131→\\treturn runOutput(dir, \\\"explain\\\", \\\"--commit\\\", ref)\\n   132→}\\n   133→\\n   134→// Resume runs `entire resume <branch> --force` and returns the output.\\n   135→func Resume(dir, branch string) (string, error) {\\n   136→\\treturn runOutput(dir, \\\"resume\\\", branch, \\\"--force\\\")\\n   137→}\\n   138→\\n   139→// runOutput executes an `entire` subcommand and returns (output, error).\\n   140→func runOutput(dir string, args ...string) (string, error) {\\n   141→\\tcmd := exec.Command(BinPath(), args...)\\n   142→\\tcmd.Dir = dir\\n   143→\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   144→\\n   145→\\tout, err := cmd.CombinedOutput()\\n   146→\\tif err != nil {\\n   147→\\t\\treturn string(out), &ExecError{\\n   148→\\t\\t\\tArgs:   args,\\n   149→\\t\\t\\tErr:    err,\\n   150→\\t\\t\\tOutput: string(out),\\n   151→\\t\\t}\\n   152→\\t}\\n   153→\\treturn strings.TrimSpace(string(out)), nil\\n   154→}\\n   155→\"}]},\"uuid\":\"7bf7bf62-ffd0-431f-a8d8-00915c4d6b6b\",\"timestamp\":\"2026-03-02T01:36:32.962Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a69128e2171f0e2b8\"},\"toolUseID\":\"agent_msg_013bwiFpjujw8x4bz2tDDUbi\",\"parentToolUseID\":\"toolu_019WDEupRn5tLJpXCTq9k2oC\",\"uuid\":\"0e8bdc23-9517-469e-917b-5f60209f54a6\",\"timestamp\":\"2026-03-02T01:36:33.155Z\"}\n{\"parentUuid\":\"0e8bdc23-9517-469e-917b-5f60209f54a6\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/3\",\"sessionId\":\"2335990a-d6c5-4425-96b8-9c47a378a3bd\",\"version\":\"2.1.63\",\"gitBranch\":\"alex/add-copilot-agent\",\"slug\":\"buzzing-tinkering-coral\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-02T01:36:33.166Z\",