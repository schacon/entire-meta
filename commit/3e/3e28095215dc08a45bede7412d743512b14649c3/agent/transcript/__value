sion: %w\\\\n%s\\\", err, out)\\n    44→\\t}\\n    45→\\t// Keep the pane around after the command exits so we can capture error output.\\n    46→\\tsetCmd := exec.Command(\\\"tmux\\\", \\\"set-option\\\", \\\"-t\\\", name, \\\"remain-on-exit\\\", \\\"on\\\")\\n    47→\\t_ = setCmd.Run()\\n    48→\\treturn s, nil\\n    49→}\\n    50→\\n    51→func (s *TmuxSession) Send(input string) error {\\n    52→\\tpreSend := stableContent(s.Capture())\\n    53→\\t// Send text and Enter separately — Claude's TUI can swallow Enter\\n    54→\\t// if it arrives before the input handler finishes processing the text.\\n    55→\\tif err := s.SendKeys(input); err != nil {\\n    56→\\t\\treturn err\\n    57→\\t}\\n    58→\\ttime.Sleep(200 * time.Millisecond)\\n    59→\\tif err := s.SendKeys(\\\"Enter\\\"); err != nil {\\n    60→\\t\\treturn err\\n    61→\\t}\\n    62→\\n    63→\\t// Wait for the terminal to reflect the echoed input, then snapshot.\\n    64→\\t// This ensures WaitFor compares against post-echo content, preventing\\n    65→\\t// false matches on prompt characters (e.g. ❯) in the echoed input.\\n    66→\\tdeadline := time.Now().Add(5 * time.Second)\\n    67→\\tfor time.Now().Before(deadline) {\\n    68→\\t\\ttime.Sleep(200 * time.Millisecond)\\n    69→\\t\\tcurrent := stableContent(s.Capture())\\n    70→\\t\\tif current != preSend {\\n    71→\\t\\t\\ts.stableAtSend = current\\n    72→\\t\\t\\treturn nil\\n    73→\\t\\t}\\n    74→\\t}\\n    75→\\ts.stableAtSend = stableContent(s.Capture())\\n    76→\\treturn nil\\n    77→}\\n    78→\\n    79→// SendKeys sends raw tmux key names without appending Enter.\\n    80→func (s *TmuxSession) SendKeys(keys ...string) error {\\n    81→\\targs := append([]string{\\\"send-keys\\\", \\\"-t\\\", s.name}, keys...)\\n    82→\\tcmd := exec.Command(\\\"tmux\\\", args...)\\n    83→\\tout, err := cmd.CombinedOutput()\\n    84→\\tif err != nil {\\n    85→\\t\\treturn fmt.Errorf(\\\"tmux send-keys: %w\\\\n%s\\\", err, out)\\n    86→\\t}\\n    87→\\treturn nil\\n    88→}\\n    89→\\n    90→const (\\n    91→\\tsettleTime   = 2 * time.Second\\n    92→\\tpollInterval = 500 * time.Millisecond\\n    93→)\\n    94→\\n    95→// stableContent returns the content with the last few lines stripped,\\n    96→// so that TUI status bar updates don't prevent the settle timer.\\n    97→func stableContent(content string) string {\\n    98→\\tlines := strings.Split(content, \\\"\\\\n\\\")\\n    99→\\tif len(lines) > 3 {\\n   100→\\t\\tlines = lines[:len(lines)-3]\\n   101→\\t}\\n   102→\\treturn strings.Join(lines, \\\"\\\\n\\\")\\n   103→}\\n   104→\\n   105→func (s *TmuxSession) WaitFor(pattern string, timeout time.Duration) (string, error) {\\n   106→\\tre, err := regexp.Compile(pattern)\\n   107→\\tif err != nil {\\n   108→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"invalid pattern: %w\\\", err)\\n   109→\\t}\\n   110→\\n   111→\\tdeadline := time.Now().Add(timeout)\\n   112→\\tvar matchedAt time.Time\\n   113→\\tvar lastStable string\\n   114→\\tcontentChanged := s.stableAtSend == \\\"\\\" // skip change requirement for initial waits\\n   115→\\n   116→\\tfor time.Now().Before(deadline) {\\n   117→\\t\\tcontent := s.Capture()\\n   118→\\t\\tstable := stableContent(content)\\n   119→\\n   120→\\t\\tif !re.MatchString(content) {\\n   121→\\t\\t\\t// Pattern lost — reset\\n   122→\\t\\t\\tmatchedAt = time.Time{}\\n   123→\\t\\t\\tlastStable = \\\"\\\"\\n   124→\\t\\t\\ttime.Sleep(pollInterval)\\n   125→\\t\\t\\tcontinue\\n   126→\\t\\t}\\n   127→\\n   128→\\t\\t// Detect content change since Send was called\\n   129→\\t\\tif !contentChanged && stable != s.stableAtSend {\\n   130→\\t\\t\\tcontentChanged = true\\n   131→\\t\\t}\\n   132→\\n   133→\\t\\tif stable != lastStable {\\n   134→\\t\\t\\t// Pattern matches but content is still changing — reset settle timer\\n   135→\\t\\t\\tmatchedAt = time.Now()\\n   136→\\t\\t\\tlastStable = stable\\n   137→\\t\\t\\ttime.Sleep(pollInterval)\\n   138→\\t\\t\\tcontinue\\n   139→\\t\\t}\\n   140→\\n   141→\\t\\t// Pattern matches and content hasn't changed since matchedAt.\\n   142→\\t\\t// Only settle if content changed at least once after Send\\n   143→\\t\\t// (prevents false settle on echoed input before agent starts).\\n   144→\\t\\tif contentChanged && time.Since(matchedAt) >= settleTime {\\n   145→\\t\\t\\treturn content, nil\\n   146→\\t\\t}\\n   147→\\n   148→\\t\\ttime.Sleep(pollInterval)\\n   149→\\t}\\n   150→\\tcontent := s.Capture()\\n   151→\\treturn content, fmt.Errorf(\\\"timed out waiting for %q after %s\\\\n--- pane content ---\\\\n%s\\\\n--- end pane content ---\\\", pattern, timeout, content)\\n   152→}\\n   153→\\n   154→func (s *TmuxSession) Capture() string {\\n   155→\\tcmd := exec.Command(\\\"tmux\\\", \\\"capture-pane\\\", \\\"-t\\\", s.name, \\\"-p\\\")\\n   156→\\tout, _ := cmd.Output()\\n   157→\\treturn strings.TrimRight(string(out), \\\"\\\\n\\\")\\n   158→}\\n   159→\\n   160→func (s *TmuxSession) Close() error {\\n   161→\\tfor _, fn := range s.cleanups {\\n   162→\\t\\tfn()\\n   163→\\t}\\n   164→\\tcmd := exec.Command(\\\"tmux\\\", \\\"kill-session\\\", \\\"-t\\\", s.name)\\n   165→\\tout, err := cmd.CombinedOutput()\\n   166→\\tif err != nil {\\n   167→\\t\\treturn fmt.Errorf(\\\"tmux kill-session: %w\\\\n%s\\\", err, out)\\n   168→\\t}\\n   169→\\treturn nil\\n   170→}\\n   171→\\n   172→// shellQuote wraps s in single quotes with proper escaping for POSIX shells.\\n   173→func shellQuote(s string) string {\\n   174→\\treturn \\\"'\\\" + strings.ReplaceAll(s, \\\"'\\\", \\\"'\\\\\\\\''\\\") + \\\"'\\\"\\n   175→}\\n   176→\"}]},\"uuid\":\"2ae8f869-079c-45f5-844b-2cf02065c744\",\"timestamp\":\"2026-03-02T01:36:29.051Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a69128e2171f0e2b8\"},\"toolUseID\":\"agent_msg_013bwiFpjujw8x4bz2tDDUbi\",\"parentToolUseID\":\"toolu_019WDEupRn5tLJpXCTq9k2oC\",\"uuid\":\"696386c6-4842-49ec-b8ef-1fe79c638a87\",\"timestamp\":\"2026-03-02T01:36:29.254Z\"}\n{\"parentUuid\":\"696386c6-4842-49ec-b8ef-1fe79c638a87\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/3\",\"sessionId\":\"2335990a-d6c5-4425-96b8-9c47a378a3bd\",\"version\":\"2.1.63\",\"gitBranch\":\"alex/add-copilot-agent\",\"slug\":\"buzzing-tinkering-coral\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-02T01:36:29.272Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01KPJY3ssjFLzQw6h6sbV1Nv\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01AwyzZV6aX1KxUr22TgNvTG\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/alex/workspace/cli/.worktrees/3/e2e/README.md\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":3,\"cache_creation_input_tokens\":15419,\"cache_read_input_tokens\":31014,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":15419},\"output_tokens\":3,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYdPwdymT9wuAekBXRhu9\",\"uuid\":\"1f2df381-a9e4-4dc8-93ec-bd95f4bce77a\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a69128e2171f0e2b8\"},\"toolUseID\":\"agent_msg_013bwiFpjujw8x4bz2tDDUbi\",\"parentToolUseID\":\"toolu_019WDEupRn5tLJpXCTq9k2oC\",\"uuid\":\"c471ac3f-6940-4e10-886f-5e2d7ed19d7b\",\"timestamp\":\"2026-03-02T01:36:29.275Z\"}\n{\"parentUuid\":\"c471ac3f-6940-4e10-886f-5e2d7ed19d7b\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/3\",\"sessionId\":\"2335990a-d6c5-4425-96b8-9c47a378a3bd\",\"version\":\"2.1.63\",\"gitBranch\":\"alex/add-copilot-agent\",\"slug\":\"buzzing-tinkering-coral\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01AwyzZV6aX1KxUr22TgNvTG\",\"type\":\"tool_result\",\"content\":\"     1→# E2E Tests\\n     2→\\n     3→End-to-end tests for the `entire` CLI against real agents (Claude Code, Gemini CLI, OpenCode).\\n     4→\\n     5→## Commands\\n     6→\\n     7→```bash\\n     8→mise run test:e2e [filter]                          # run filtered (or omit filter for all agents)\\n     9→mise run test:e2e --agent claude-code [filter]       # Claude Code only\\n    10→mise run test:e2e --agent gemini-cli [filter]        # Gemini CLI only\\n    11→mise run test:e2e --agent opencode [filter]          # OpenCode only\\n    12→go build ./...                                      # compile check (no agent CLI needed)\\n    13→```\\n    14→\\n    15→**Do NOT run E2E tests proactively.** They make real API calls that consume tokens and cost money. Only run when explicitly asked.\\n    16→\\n    17→## Structure\\n    18→\\n    19→```\\n    20→e2e/\\n    21→├── agents/       # Agent abstraction (Agent interface, tmux sessions, concurrency gates)\\n    22→├── bootstrap/    # CI pre-test setup (auth config, warmup)\\n    23→├── entire/       # `entire` CLI wrapper (enable, rewind, etc.)\\n    24→├── exploratory/  # Experimental tests, not run by CI\\n    25→├── tests/        # Blessed test files (run by CI)\\n    26→└── testutil/     # Repo setup, assertions, artifact capture\\n    27→```\\n    28→\\n    29→## Key Patterns\\n    30→\\n    31→- Every test uses `testutil.ForEachAgent` which runs it per registered agent with repo setup, concurrency gating, and timeout scaling.\\n    32→- All operations go through `RepoState` (`s.RunPrompt`, `s.Git`) so they're logged to `console.log`.\\n    33→- Use the `entire` package for CLI interactions, not raw `exec.Command`.\\n    34→- Skip tests pending CLI fixes with `t.Skip(\\\"ENT-XXX: reason\\\")`.\\n    35→\\n    36→## Adding a New Agent\\n    37→\\n    38→1. Create `agents/<name>.go` implementing the `Agent` interface.\\n    39→2. Register it in `init()` with `Register(&YourAgent{})`.\\n    40→3. Add a `Bootstrap()` method for any CI-specific setup (auth config, warmup).\\n    41→4. Add a `RegisterGate(\\\"<name>\\\", N)` call if concurrency needs limiting.\\n    42→5. Ensure the agent name is accepted by `mise run test:e2e --agent <name>`.\\n    43→6. Add the agent to `.github/workflows/e2e.yml` matrix and `e2e-isolated.yml` options.\\n    44→\\n    45→## Environment Variables\\n    46→\\n    47→| Variable | Description | Default |\\n    48→|----------|-------------|---------|\\n    49→| `E2E_AGENT` | Agent to test (`claude-code`, `gemini-cli`, `opencode`) | all registered |\\n    50→| `E2E_ENTIRE_BIN` | Path to a pre-built `entire` binary | builds from source |\\n    51→| `E2E_TIMEOUT` | Timeout per prompt | `2m` |\\n    52→| `E2E_KEEP_REPOS` | Set to `1` to preserve temp repos after test | unset |\\n    53→| `E2E_ARTIFACT_DIR` | Override artifact output directory | `e2e/artifacts/<timestamp>` |\\n    54→| `ANTHROPIC_API_KEY` | Required for Claude Code | — |\\n    55→| `GEMINI_API_KEY` | Required for Gemini CLI | — |\\n    56→\\n    57→## Debugging Failures\\n    58→\\n    59→Artifacts are captured to `e2e/artifacts/` on every run (git-log, git-tree, console.log, checkpoint metadata, entire logs). Set `E2E_KEEP_REPOS=1` to preserve the temp repo — a symlink appears in the artifact dir pointing to it.\\n    60→\\n    61→Use the `debug-e2e` skill (`.claude/skills/debug-e2e/`) for a structured workflow when investigating failures.\\n    62→\\n    63→### Reading artifacts\\n    64→\\n    65→- `console.log` — full operation transcript including agent stdout/stderr\\n    66→- `git-log.txt` — commit history at time of failure\\n    67→- `git-tree.txt` — working tree state\\n    68→- `entire-logs/` — internal CLI logs\\n    69→\\n    70→### Fixing flaky tests\\n    71→\\n    72→When a test passes on retry but failed once, the problem is usually agent non-determinism, not a CLI bug. Common patterns:\\n    73→\\n    74→- **Agent asked for confirmation instead of acting**: The model output contains \\\"Does this look right?\\\" or \\\"Should I proceed?\\\". Fix: append \\\"Do not ask for confirmation, just make the change.\\\" to the prompt.\\n    75→- **Agent wrote to wrong path or created extra files**: Fix: be more explicit about exact file paths and what _not_ to do.\\n    76→- **Agent committed when it shouldn't have**: Fix: add \\\"Do not commit\\\" to the prompt.\\n    77→- **Checkpoint wait timeout**: `WaitForCheckpoint` or `WaitForCheckpointAdvanceFrom` exceeded deadline. Fix: increase the timeout argument.\\n    78→\\n    79→To diagnose: read `console.log` in the failing test's artifact directory. Compare what the agent actually did vs what the test expected.\\n    80→\\n    81→## CI Workflows\\n    82→\\n    83→- **`.github/workflows/e2e.yml`** — Runs full suite on push to main. Matrix: `[claude, opencode, gemini]`.\\n    84→- **`.github/workflows/e2e-isolated.yml`** — Manual dispatch for debugging a single test. Inputs: agent + test name filter.\\n    85→\\n    86→Both workflows run `go run ./e2e/bootstrap` before tests to handle agent-specific CI setup (auth config, warmup).\\n    87→\"}]},\"uuid\":\"19ec4544-df39-4d30-8e39-8e7a59c42a09\",\"timestamp\":\"2026-03-02T01:36:29.288Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a69128e2171f0e2b8\"},\"toolUseID\":\"agent_msg_013bwiFpjujw8x4bz2tDDUbi\",\"parentToolUseID\":\"toolu_019WDEupRn5tLJpXCTq9k2oC\",\"uuid\":\"73430447-ae06-4e84-9db8-cab89fc845e6\",\"timestamp\":\"2026-03-02T01:36:29.498Z\"}\n{\"parentUuid\":\"73430447-ae06-4e84-9db8-cab89fc845e6\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/3\",\"sessionId\":\"2335990a-d6c5-4425-96b8-9c47a378a3bd\",\"version\":\"2.1.63\",\"gitBranch\":\"alex/add-copilot-agent\",\"slug\":\"buzzing-tinkering-coral\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-02T01