o/cli/e2e/agents\\\"\\n    16→\\t\\\"github.com/entireio/cli/e2e/entire\\\"\\n    17→)\\n    18→\\n    19→// RepoState holds the working state for a single test's cloned repository.\\n    20→type RepoState struct {\\n    21→\\tAgent            agents.Agent\\n    22→\\tDir              string\\n    23→\\tArtifactDir      string\\n    24→\\tHeadBefore       string\\n    25→\\tCheckpointBefore string\\n    26→\\tConsoleLog       *os.File\\n    27→\\tsession          agents.Session // interactive session, if started via StartSession\\n    28→\\tskipArtifacts    bool           // suppresses artifact capture on scenario restart\\n    29→}\\n    30→\\n    31→// SetupRepo creates a fresh git repository in a temporary directory, seeds it\\n    32→// with an initial commit, and runs `entire enable` for the given agent.\\n    33→// Artifact capture is registered as a cleanup function.\\n    34→//\\n    35→// When E2E_KEEP_REPOS is set, the temporary directory is not cleaned up\\n    36→// so it can be inspected after the test. A symlink in the artifact dir\\n    37→// points to the preserved repo.\\n    38→func SetupRepo(t *testing.T, agent agents.Agent) *RepoState {\\n    39→\\tt.Helper()\\n    40→\\n    41→\\tkeepRepos := os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\"\\n    42→\\n    43→\\t// Always use os.MkdirTemp instead of t.TempDir(). Go's t.TempDir()\\n    44→\\t// creates nested subdirectories (TestName.../001/) whose structure\\n    45→\\t// confuses some agents' (e.g. opencode) working-directory resolution.\\n    46→\\tdir, err := os.MkdirTemp(\\\"\\\", \\\"e2e-repo-*\\\")\\n    47→\\tif err != nil {\\n    48→\\t\\tt.Fatalf(\\\"create temp dir: %v\\\", err)\\n    49→\\t}\\n    50→\\tif keepRepos {\\n    51→\\t\\tt.Logf(\\\"E2E_KEEP_REPOS: repo will be preserved at %s\\\", dir)\\n    52→\\t} else {\\n    53→\\t\\tt.Cleanup(func() { os.RemoveAll(dir) })\\n    54→\\t}\\n    55→\\n    56→\\t// Resolve symlinks (macOS: /var -> /private/var) so paths match\\n    57→\\t// what agent CLIs see when they resolve their own CWD.\\n    58→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n    59→\\t\\tdir = resolved\\n    60→\\t}\\n    61→\\n    62→\\tGit(t, dir, \\\"init\\\")\\n    63→\\tGit(t, dir, \\\"config\\\", \\\"user.name\\\", \\\"E2E Test\\\")\\n    64→\\tGit(t, dir, \\\"config\\\", \\\"user.email\\\", \\\"e2e@test.local\\\")\\n    65→\\tGit(t, dir, \\\"commit\\\", \\\"--allow-empty\\\", \\\"-m\\\", \\\"initial commit\\\")\\n    66→\\n    67→\\tentire.Enable(t, dir, agent.EntireAgent())\\n    68→\\tPatchSettings(t, dir, map[string]any{\\\"log_level\\\": \\\"debug\\\"})\\n    69→\\n    70→\\t// OpenCode's non-interactive mode auto-rejects external_directory permission\\n    71→\\t// since there's no user to prompt. Write a config to allow it.\\n    72→\\tif agent.Name() == \\\"opencode\\\" {\\n    73→\\t\\tcfg := `{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}}`\\n    74→\\t\\tif key := os.Getenv(\\\"ANTHROPIC_API_KEY\\\"); key != \\\"\\\" {\\n    75→\\t\\t\\tcfg = fmt.Sprintf(`{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}, \\\"provider\\\": {\\\"anthropic\\\": {\\\"options\\\": {\\\"apiKey\\\": %q}}}}`, key)\\n    76→\\t\\t}\\n    77→\\t\\tif err := os.WriteFile(filepath.Join(dir, \\\"opencode.json\\\"), []byte(cfg+\\\"\\\\n\\\"), 0o644); err != nil {\\n    78→\\t\\t\\tt.Fatalf(\\\"write opencode.json: %v\\\", err)\\n    79→\\t\\t}\\n    80→\\t}\\n    81→\\n    82→\\t// Create artifact dir eagerly so console.log is written to disk\\n    83→\\t// incrementally. Even if the test is killed by a global timeout,\\n    84→\\t// partial output survives.\\n    85→\\tartDir := artifactDir(t)\\n    86→\\tconsoleLog, err := os.Create(filepath.Join(artDir, \\\"console.log\\\"))\\n    87→\\tif err != nil {\\n    88→\\t\\tt.Fatalf(\\\"create console.log: %v\\\", err)\\n    89→\\t}\\n    90→\\n    91→\\tstate := &RepoState{\\n    92→\\t\\tAgent:            agent,\\n    93→\\t\\tDir:              dir,\\n    94→\\t\\tArtifactDir:      artDir,\\n    95→\\t\\tHeadBefore:       GitOutput(t, dir, \\\"rev-parse\\\", \\\"HEAD\\\"),\\n    96→\\t\\tCheckpointBefore: GitOutput(t, dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\"),\\n    97→\\t\\tConsoleLog:       consoleLog,\\n    98→\\t}\\n    99→\\n   100→\\tt.Cleanup(func() {\\n   101→\\t\\t_ = consoleLog.Close()\\n   102→\\t\\tif !state.skipArtifacts {\\n   103→\\t\\t\\tCaptureArtifacts(t, state)\\n   104→\\t\\t}\\n   105→\\t})\\n   106→\\n   107→\\treturn state\\n   108→}\\n   109→\\n   110→// ForEachAgent runs fn as a parallel subtest for every registered agent.\\n   111→// It handles repo setup, concurrency gating, context timeout, and cleanup.\\n   112→// The timeout is scaled by each agent's TimeoutMultiplier.\\n   113→//\\n   114→// If RunPrompt detects a transient API error (e.g. rate limit, token refresh\\n   115→// failure), it panics with errScenarioRestart. ForEachAgent recovers from the\\n   116→// panic and restarts the entire scenario with a fresh repository, up to\\n   117→// maxScenarioRestarts times. This avoids stale CLI session state from the\\n   118→// failed attempt poisoning the retry.\\n   119→func ForEachAgent(t *testing.T, timeout time.Duration, fn func(t *testing.T, s *RepoState, ctx context.Context)) {\\n   120→\\tt.Helper()\\n   121→\\tt.Parallel()\\n   122→\\tall := agents.All()\\n   123→\\tif len(all) == 0 {\\n   124→\\t\\tt.Skip(\\\"no agents registered (check E2E_AGENT filter)\\\")\\n   125→\\t}\\n   126→\\tfor _, agent := range all {\\n   127→\\t\\tt.Run(agent.Name(), func(t *testing.T) {\\n   128→\\t\\t\\t// Use the global test deadline for slot wait so we don't\\n   129→\\t\\t\\t// skip prematurely — only bail if the whole binary is dying.\\n   130→\\t\\t\\tslotCtx := context.Background()\\n   131→\\t\\t\\tif deadline, ok := t.Deadline(); ok {\\n   132→\\t\\t\\t\\tvar cancel context.CancelFunc\\n   133→\\t\\t\\t\\tslotCtx, cancel = context.WithDeadline(slotCtx, deadline)\\n   134→\\t\\t\\t\\tdefer cancel()\\n   135→\\t\\t\\t}\\n   136→\\t\\t\\tif err := agents.AcquireSlot(slotCtx, agent); err != nil {\\n   137→\\t\\t\\t\\tt.Fatalf(\\\"timed out waiting for agent slot: %v\\\", err)\\n   138→\\t\\t\\t}\\n   139→\\t\\t\\tdefer agents.ReleaseSlot(agent)\\n   140→\\n   141→\\t\\t\\t// Per-test timeout starts after slot is acquired, scaled\\n   142→\\t\\t\\t// by the agent's multiplier (e.g. 2.5× for gemini).\\n   143→\\t\\t\\tscaled := time.Duration(float64(timeout) * agent.TimeoutMultiplier())\\n   144→\\n   145→\\t\\t\\tvar prevState *RepoState\\n   146→\\t\\t\\tfor attempt := range maxScenarioRestarts + 1 {\\n   147→\\t\\t\\t\\ts := SetupRepo(t, agent)\\n   148→\\t\\t\\t\\tctx, cancel := context.WithTimeout(context.Background(), scaled)\\n   149→\\n   150→\\t\\t\\t\\t// On restart, suppress artifact capture from the previous\\n   151→\\t\\t\\t\\t// failed attempt so it doesn't overwrite the final one.\\n   152→\\t\\t\\t\\tif prevState != nil {\\n   153→\\t\\t\\t\\t\\tprevState.skipArtifacts = true\\n   154→\\t\\t\\t\\t}\\n   155→\\n   156→\\t\\t\\t\\trestarted := runScenario(t, s, ctx, fn)\\n   157→\\t\\t\\t\\tcancel()\\n   158→\\n   159→\\t\\t\\t\\tif !restarted {\\n   160→\\t\\t\\t\\t\\treturn\\n   161→\\t\\t\\t\\t}\\n   162→\\t\\t\\t\\tprevState = s\\n   163→\\t\\t\\t\\tif attempt >= maxScenarioRestarts {\\n   164→\\t\\t\\t\\t\\tt.Fatalf(\\\"exhausted %d scenario attempts due to transient API errors\\\", maxScenarioRestarts+1)\\n   165→\\t\\t\\t\\t}\\n   166→\\t\\t\\t\\tt.Logf(\\\"transient error, restarting scenario (attempt %d/%d)\\\", attempt+2, maxScenarioRestarts+1)\\n   167→\\t\\t\\t}\\n   168→\\t\\t})\\n   169→\\t}\\n   170→}\\n   171→\\n   172→// runScenario runs the test function and recovers from errScenarioRestart\\n   173→// panics triggered by transient API errors in RunPrompt. Returns true if\\n   174→// the scenario should be restarted with a fresh repository.\\n   175→func runScenario(t *testing.T, s *RepoState, ctx context.Context, fn func(t *testing.T, s *RepoState, ctx context.Context)) (restarted bool) {\\n   176→\\tt.Helper()\\n   177→\\tdefer func() {\\n   178→\\t\\tif r := recover(); r != nil {\\n   179→\\t\\t\\tif _, ok := r.(errScenarioRestart); ok {\\n   180→\\t\\t\\t\\trestarted = true\\n   181→\\t\\t\\t\\treturn\\n   182→\\t\\t\\t}\\n   183→\\t\\t\\tpanic(r) // re-panic for unexpected panics\\n   184→\\t\\t}\\n   185→\\t}()\\n   186→\\tfn(t, s, ctx)\\n   187→\\treturn false\\n   188→}\\n   189→\\n   190→const maxScenarioRestarts = 2 // restart up to 2 times = 3 total attempts\\n   191→\\n   192→// errScenarioRestart is panicked by RunPrompt when a transient API error is\\n   193→// detected. ForEachAgent recovers from this panic and restarts the test\\n   194→// scenario with a fresh repository, avoiding stale CLI state from the failed\\n   195→// attempt.\\n   196→type errScenarioRestart struct {\\n   197→\\tmsg string\\n   198→}\\n   199→\\n   200→// RunPrompt runs an agent prompt, logs the command and output to ConsoleLog,\\n   201→// and returns the result. If the agent reports a transient API error, it\\n   202→// panics with errScenarioRestart to trigger a full scenario restart in\\n   203→// ForEachAgent (see runScenario).\\n   204→func (s *RepoState) RunPrompt(t *testing.T, ctx context.Context, prompt string, opts ...agents.Option) (agents.Output, error) {\\n   205→\\tt.Helper()\\n   206→\\tout, err := s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n   207→\\ts.logPromptResult(out)\\n   208→\\n   209→\\tif err != nil && s.Agent.IsTransientError(out, err) {\\n   210→\\t\\terrMsg := fmt.Sprintf(\\\"transient API error (stderr: %s)\\\", strings.TrimSpace(out.Stderr))\\n   211→\\t\\tt.Logf(\\\"%s — restarting scenario\\\", errMsg)\\n   212→\\t\\tfmt.Fprintf(s.ConsoleLog, \\\"> [transient] %s — restarting scenario\\\\n\\\", errMsg)\\n   213→\\t\\tpa