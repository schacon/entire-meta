\n    82→func (a *${AgentName}) PromptPattern() string      { return `${prompt-regex}` }\\n    83→func (a *${AgentName}) TimeoutMultiplier() float64 { return 1.0 }\\n    84→\\n    85→func (a *${AgentName}) Bootstrap() error {\\n    86→\\t// CI-specific setup: auth config, API key injection, warmup, etc.\\n    87→\\t// Must be idempotent. Called once before any tests run.\\n    88→\\treturn nil\\n    89→}\\n    90→\\n    91→func (a *${AgentName}) IsTransientError(out Output, err error) bool {\\n    92→\\tif err == nil {\\n    93→\\t\\treturn false\\n    94→\\t}\\n    95→\\tcombined := out.Stdout + out.Stderr\\n    96→\\tfor _, p := range []string{\\\"overloaded\\\", \\\"rate limit\\\", \\\"503\\\", \\\"529\\\"} {\\n    97→\\t\\tif strings.Contains(combined, p) {\\n    98→\\t\\t\\treturn true\\n    99→\\t\\t}\\n   100→\\t}\\n   101→\\treturn false\\n   102→}\\n   103→\\n   104→func (a *${AgentName}) RunPrompt(ctx context.Context, dir string, prompt string, opts ...Option) (Output, error) {\\n   105→\\tcfg := &runConfig{}\\n   106→\\tfor _, o := range opts {\\n   107→\\t\\to(cfg)\\n   108→\\t}\\n   109→\\n   110→\\targs := []string{/* agent CLI flags for non-interactive prompt execution */}\\n   111→\\tcmd := exec.CommandContext(ctx, a.Binary(), args...)\\n   112→\\tcmd.Dir = dir\\n   113→\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   114→\\tcmd.SysProcAttr = &syscall.SysProcAttr{Setpgid: true}\\n   115→\\tcmd.Cancel = func() error {\\n   116→\\t\\treturn syscall.Kill(-cmd.Process.Pid, syscall.SIGKILL)\\n   117→\\t}\\n   118→\\n   119→\\tvar stdout, stderr strings.Builder\\n   120→\\tcmd.Stdout = &stdout\\n   121→\\tcmd.Stderr = &stderr\\n   122→\\n   123→\\terr := cmd.Run()\\n   124→\\texitCode := 0\\n   125→\\tif err != nil {\\n   126→\\t\\texitErr := &exec.ExitError{}\\n   127→\\t\\tif errors.As(err, &exitErr) {\\n   128→\\t\\t\\texitCode = exitErr.ExitCode()\\n   129→\\t\\t} else {\\n   130→\\t\\t\\texitCode = -1\\n   131→\\t\\t}\\n   132→\\t}\\n