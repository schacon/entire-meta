est -v -run TestCommitHookPerformance -tags hookperf -timeout 10m ./cmd/entire/cli/strategy/\\nfunc TestCommitHookPerformance(t *testing.T) {\\n\\tscenarios := []struct {\\n\\t\\tname    string\\n\\t\\tended   int\\n\\t\\tidle    int\\n\\t\\tactive  int\\n\\t}{\\n\\t\\t{\\\"10sessions\\\", 8, 1, 1},\\n\\t\\t{\\\"50sessions\\\", 43, 6, 1},\\n\\t\\t{\\\"100sessions\\\", 88, 11, 1},\\n\\t\\t{\\\"200sessions\\\", 180, 19, 1},\\n\\t}\\n\\n\\ttype result struct {\\n\\t\\tname       string\\n\\t\\ttotal      int\\n\\t\\tsetup      time.Duration\\n\\t\\tprepare    time.Duration\\n\\t\\tpostCommit time.Duration\\n\\t}\\n\\tresults := make([]result, 0, len(scenarios))\\n\\n\\tfor _, sc := range scenarios {\\n\\t\\tt.Run(sc.name, func(t *testing.T) {\\n\\t\\t\\tsetupStart := time.Now()\\n\\n\\t\\t\\tdir := initHookPerfRepo(t)\\n\\t\\t\\tt.Chdir(dir)\\n\\t\\t\\tpaths.ClearWorktreeRootCache()\\n\\t\\t\\tsession.ClearGitCommonDirCache()\\n\\n\\t\\t\\tcreateHookPerfSettings(t, dir)\\n\\t\\t\\tseedHookPerfSessions(t, dir, sc.ended, sc.idle, sc.active)\\n\\n\\t\\t\\t// Stage a file change for the commit\\n\\t\\t\\trepo, err := git.PlainOpen(dir)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"open repo: %v\\\", err)\\n\\t\\t\\t}\\n\\t\\t\\twt, err := repo.Worktree()\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"worktree: %v\\\", err)\\n\\t\\t\\t}\\n\\t\\t\\ttestFile := filepath.Join(dir, \\\"src/file_0.go\\\")\\n\\t\\t\\tif err := os.WriteFile(testFile, []byte(\\\"package main\\\\n// user edit\\\\nfunc f() {}\\\\n\\\"), 0o644); err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"write: %v\\\", err)\\n\\t\\t\\t}\\n\\t\\t\\tif _, err := wt.Add(\\\"src/file_0.go\\\"); err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"add: %v\\\", err)\\n\\t\\t\\t}\\n\\n\\t\\t\\tsetupDur := time.Since(setupStart)\\n\\t\\t\\ttotalSessions := sc.ended + sc.idle + sc.active\\n\\n\\t\\t\\t// --- Time PrepareCommitMsg ---\\n\\t\\t\\t// Simulate TTY path (the expensive one) with commit_linking=always\\n\\t\\t\\t// so