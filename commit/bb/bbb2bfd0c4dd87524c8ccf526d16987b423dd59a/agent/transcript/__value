user edits between agent work and commit).\\n   217→\\tattribution := calculateSessionAttributions(ctx, repo, ref, sessionData, state, attributionOpts{\\n   218→\\t\\theadTree: o.headTree,\\n   219→\\t})\\n   220→\\t// Get current branch name\\n   221→\\tbranchName := GetCurrentBranchName(repo)\\n   222→\\n   223→\\t// Generate summary if enabled\\n   224→\\tvar summary *cpkg.Summary\\n   225→\\tif settings.IsSummarizeEnabled(ctx) && len(sessionData.Transcript) > 0 {\\n   226→\\t\\tsummarizeCtx := logging.WithComponent(ctx, \\\"summarize\\\")\\n   227→\\n   228→\\t\\t// Scope transcript to this checkpoint's portion.\\n   229→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   230→\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n   231→\\t\\tvar scopedTranscript []byte\\n   232→\\t\\tswitch state.AgentType {\\n   233→\\t\\tcase agent.AgentTypeGemini:\\n   234→\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   235→\\t\\t\\tif sliceErr != nil {\\n   236→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n   237→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   238→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   239→\\t\\t\\t}\\n   240→\\t\\t\\tscopedTranscript = scoped\\n   241→\\t\\tcase agent.AgentTypeOpenCode:\\n   242→\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   243→\\t\\t\\tif sliceErr != nil {\\n   244→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n   245→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   246→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   247→\\t\\t\\t}\\n   248→\\t\\t\\tscopedTranscript = scoped\\n   249→\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.Agent