rectly to avoid redundant\\n  1119→// shadow branch resolution (the shadow ref/commit/tree were already resolved by the caller).\\n  1120→func (s *ManualCommitStrategy) sessionHasNewContent(ctx context.Context, repo *git.Repository, state *SessionState, cachedShadowTree ...*object.Tree) (bool, error) {\\n  1121→\\tlogCtx := logging.WithComponent(ctx, \\\"manual-commit\\\")\\n  1122→\\n  1123→\\t// Use cached shadow tree if provided\\n  1124→\\tvar tree *object.Tree\\n  1125→\\tif len(cachedShadowTree) > 0 && cachedShadowTree[0] != nil {\\n  1126→\\t\\ttree = cachedShadowTree[0]\\n  1127→\\t} else {\\n  1128→\\t\\t// Resolve shadow branch from repo\\n  1129→\\t\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n  1130→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1131→\\t\\tref, err := repo.Reference(refName, true)\\n  1132→\\t\\tif err != nil {\\n  1133→\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no shadow branch, checking live transcript\\\",\\n  1134→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1135→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n  1136→\\t\\t\\t)\\n  1137→\\t\\t\\treturn s.sessionHasNewContentFromLiveTranscript(ctx, repo, state)\\n  1138→\\t\\t}\\n  1139→\\n  1140→\\t\\tcommit, err := repo.CommitObject(ref.Hash())\\n  1141→\\t\\tif err != nil {\\n  1142→\\t\\t\\treturn false, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n  1143→\\t\\t}\\n  1144→\\n  1145→\\t\\ttree, err = commit.Tree()\\n  1146→\\t\\tif err != nil {\\n  1147→\\t\\t\\treturn false, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n  1148→\\t\\t}\\n  1149→\\t}\\n  1150→\\n  1151→\\t// Look for transcript file\\n  1152→\\tmetadataDir := paths.EntireMetadataDir + \\\"/\\\" + state.SessionID\\n  1153→\\tvar transcriptLines int\\n  1154→\\tvar hasTranscriptFile bool\\n  1155→\\n  1156→\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n  1157→\\t\\thasTranscriptFile = true\\n  1158→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n  1159→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n  1160→\\t\\t}\\n  1161→\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n  1162→\\t\\thasTranscriptFile = true\\n  1163→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n  1164→\\t\\t\\ttranscriptLines = countTranscriptItems(state.AgentType, content)\\n  1165→\\t\\t}\\n  1166→\\t}\\n  1167→\\n  1168→\\t// If shadow branch exists but has no transcript (e.g., carry-forward from mid-session commit),\\n  1169→\\t// check if the session has FilesTouched. Carry-forward sets FilesTouched with remaining files.\\n  1170→\\tif !hasTranscriptFile {\\n  1171→\\t\\tif len(state.FilesTouched) > 0 {\\n  1172→\\t\\t\\t// Shadow branch has files from carry-forward - check if staged files overlap\\n  1173→\\t\\t\\t// AND have matching content (content-aware check).\\n  1174→\\t\\t\\tstagedFiles := getStagedFiles(repo)\\n  1175→\\t\\t\\tif len(stagedFiles) > 0 {\\n  1176→\\t\\t\\t\\t// PrepareCommitMsg context: check staged files overlap with content\\n  1177→\\t\\t\\t\\tresult := stagedFilesOverlapWithContent(ctx, repo, tree, stagedFiles, state.FilesTouched)\\n  1178→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript, carry-forward with staged files\\\",\\n  1179→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1180→\\t\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n  1181→\\t\\t\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1182→\\t\\t\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n  1183→\\t\\t\\t\\t)\\n  1184→\\t\\t\\t\\treturn result, nil\\n  1185→\\t\\t\\t}\\n  1186→\\t\\t\\t// PostCommit context: no staged files, but we have carry-forward files.\\n  1187→\\t\\t\\t// Return true and let the caller do the overlap check with committed files.\\n  1188→\\t\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript, carry-forward without staged files (post-commit context)\\\",\\n  1189→\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1190→\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n  1191→\\t\\t\\t)\\n  1192→\\t\\t\\treturn true, nil\\n  1193→\\t\\t}\\n  1194→\\t\\t// No transcript and no FilesTouched - fall back to live transcript check\\n  1195→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no transcript and no files touched, checking live transcript\\\",\\n  1196→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1197→\\t\\t)\\n  1198→\\t\\treturn s.sessionHasNewContentFromLiveTranscript(ctx, repo, state)\\n  1199→\\t}\\n  1200→\\n  1201→\\t// Check if there's new content to condense. Two cases:\\n  1202→\\t// 1. Transcript has grown since last condensation (new prompts/responses)\\n  1203→\\t// 2. FilesTouched has files not yet committed (carry-forward scenario)\\n  1204→\\t//\\n  1205→\\t// For PrepareCommitMsg context, we verify staged files overlap with session's files\\n  1206→\\t// using content-aware matching to detect reverted files.\\n  1207→\\t// For PostCommit context, getStagedFiles() is empty (files already committed),\\n  1208→\\t// so we return true and let the caller do the overlap check via filesOverlapWithContent.\\n  1209→\\n  1210→\\thasTranscriptGrowth := transcriptLines > state.CheckpointTranscriptStart\\n  1211→\\thasUncommittedFiles := len(state.FilesTouched) > 0\\n  1212→\\n  1213→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: transcript check\\\",\\n  1214→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1215→\\t\\tslog.Int(\\\"transcript_lines\\\", transcriptLines),\\n  1216→\\t\\tslog.Int(\\\"checkpoint_transcript_start\\\", state.CheckpointTranscriptStart),\\n  1217→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1218→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1219→\\t)\\n  1220→\\n  1221→\\tif !hasTranscriptGrowth && !hasUncommittedFiles {\\n  1222→\\t\\treturn false, nil // No new content and no carry-forward files\\n  1223→\\t}\\n  1224→\\n  1225→\\t// Check if staged files overlap with session's files with content-aware matching.\\n  1226→\\t// This is primarily for PrepareCommitMsg; in PostCommit, stagedFiles is empty.\\n  1227→\\tstagedFiles := getStagedFiles(repo)\\n  1228→\\tif len(stagedFiles) > 0 {\\n  1229→\\t\\tresult := stagedFilesOverlapWithContent(ctx, repo, tree, stagedFiles, state.FilesTouched)\\n  1230→\\t\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: staged files overlap check\\\",\\n  1231→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1232→\\t\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1233→\\t\\t\\tslog.Bool(\\\"result\\\", result),\\n  1234→\\t\\t)\\n  1235→\\t\\treturn result, nil\\n  1236→\\t}\\n  1237→\\n  1238→\\t// No staged files - either PostCommit context or edge case.\\n  1239→\\t// Return transcript growth status. For PostCommit with hasTranscriptFile=true,\\n  1240→\\t// if there's no transcript growth, the session hasn't done new work since last checkpoint.\\n  1241→\\t// (Carry-forward creates a shadow branch WITHOUT transcript, handled in the block above.)\\n  1242→\\tlogging.Debug(logCtx, \\\"sessionHasNewContent: no staged files, returning transcript growth\\\",\\n  1243→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1244→\\t\\tslog.Bool(\\\"has_transcript_growth\\\", hasTranscriptGrowth),\\n  1245→\\t\\tslog.Bool(\\\"has_uncommitted_files\\\", hasUncommittedFiles),\\n  1246→\\t)\\n  1247→\\treturn hasTranscriptGrowth, nil\\n  1248→}\\n  1249→\\n  1250→// sessionHasNewContentFromLiveTranscript checks if a session has new content\\n  1251→// by examining the live transcript file. This is used when no shadow branch exists\\n  1252→// (i.e., no Stop has happened yet) but the agent may have done work.\\n  1253→//\\n  1254→// Returns true if:\\n  1255→//  1. The transcript has grown since the last condensation, AND\\n  1256→//  2. The new transcript portion contains file modifications, AND\\n  1257→//  3. At least one modified file overlaps with the currently staged files\\n  1258→//\\n  1259→// The overlap check ensures we don't add checkpoint trailers to commits that are\\n  1260→// unrelated to the agent's recent changes.\\n  1261→//\\n  1262→// This handles the scenario where the agent commits mid-session before Stop.\\n  1263→func (s *ManualCommitStrategy) sessionHasNewContentFromLiveTranscript(ctx context.Context, repo *git.Repository, state *SessionState) (bool, error) {\\n  1264→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n  1265→\\n  1266→\\tmodifiedFiles, ok := s.extractNewModifiedFilesFromLiveTranscript(ctx, state)\\n  1267→\\tif !ok || len(modifiedFiles) == 0 {\\n  1268→\\t\\treturn false, nil\\n  1269→\\t}\\n  1270→\\n  1271→\\tlogging.Debug(logCtx, \\\"live transcript check: found file modifications\\\",\\n  1272→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1273→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1274→\\t)\\n  1275→\\n  1276→\\t// Check if any modified files overlap with currently staged files\\n  1277→\\t// This ensures we only add checkpoint trailers to commits that include\\n  1278→\\t// files the agent actually modified\\n  1279→\\tstagedFiles := getStagedFiles(repo)\\n  1280→\\n  1281→\\tlogging.Debug(logCtx, \\\"live transcript check: comparing staged vs modified\\\",\\n  1282→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1283→\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n  1284→\\t\\tslog.Int(\\\"modified_files\\\", len(modifiedFiles)),\\n  1285→\\t)\\n  1286→\\n  1287→\\tif !hasOverlappingFiles(stagedFiles, modifiedFiles) {\\n  1288→\\t\\tlogging.Debug(logCtx, \\\"live transcript check: no overlap between