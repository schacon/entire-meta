return nil, fmt.Errorf(\\\"parsing settings file: %w\\\", err)\\n   139→\\t}\\n   140→\\n   141→\\t// Validate commit_linking if set\\n   142→\\tif settings.CommitLinking != \\\"\\\" && settings.CommitLinking != CommitLinkingAlways && settings.CommitLinking != CommitLinkingPrompt {\\n   143→\\t\\treturn nil, fmt.Errorf(\\\"invalid commit_linking value %q: must be %q or %q\\\", settings.CommitLinking, CommitLinkingAlways, CommitLinkingPrompt)\\n   144→\\t}\\n   145→\\n   146→\\treturn settings, nil\\n   147→}\\n   148→\\n   149→// mergeJSON merges JSON data into existing settings.\\n   150→// Only non-zero values from the JSON override existing settings.\\n   151→func mergeJSON(settings *EntireSettings, data []byte) error {\\n   152→\\t// First, validate that there are no unknown keys using strict decoding\\n   153→\\tdec := json.NewDecoder(bytes.NewReader(data))\\n   154→\\tdec.DisallowUnknownFields()\\n   155→\\tvar temp EntireSettings\\n   156→\\tif err := dec.Decode(&temp); err != nil {\\n   157→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   158→\\t}\\n   159→\\n   160→\\t// Parse into a map to check which fields are present\\n   161→\\tvar raw map[string]json.RawMessage\\n   162→\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   163→\\t\\treturn fmt.Errorf(\\\"parsing JSON: %w\\\", err)\\n   164→\\t}\\n   165→\\n   166→\\t// Override enabled if present\\n   167→\\tif enabledRaw, ok := raw[\\\"enabled\\\"]; ok {\\n   168→\\t\\tvar e bool\\n   169→\\t\\tif err := json.Unmarshal(enabledRaw, &e); err != nil {\\n   170→\\t\\t\\treturn fmt.Errorf(\\\"parsing enabled field: %w\\\", err)\\n   171→\\t\\t}\\n   172→\\t\\tsettings.Enabled = e\\n   173→\\t}\\n   174→\\n   175→\\t// Override local_dev if present\\n   176→\\tif localDevRaw, ok := raw[\\\"local_dev\\\"]; ok {\\n   177→\\t\\tvar ld bool\\n   178→\\t\\tif err := json.Unmarshal(localDevRaw, &ld); err != nil {\\n   179→\\t\\t\\treturn fmt.Errorf(\\\"parsing local_dev field: %w\\\", err)\\n   180→\\t\\t}\\n   181→\\t\\tsettings.LocalDev = ld\\n   182→\\t}\\n   183→\\n   184→\\t// Override log_level if present and non-empty\\n   185→\\tif logLevelRaw, ok := raw[\\\"log_level\\\"]; ok {\\n   186→\\t\\tvar ll string\\n   187→\\t\\tif err := json.Unmarshal(logLevelRaw, &ll); err != nil {\\n   188→\\t\\t\\treturn fmt.Errorf(\\\"parsing log_level field: %w\\\", err)\\n   189→\\t\\t}\\n   190→\\t\\tif ll != \\\"\\\" {\\n   191→\\t\\t\\tsettings.LogLevel = ll\\n   192→\\t\\t}\\n   193→\\t}\\n   194→\\n   195→\\t// Merge strategy_options if present\\n   196→\\tif optionsRaw, ok := raw[\\\"strategy_options\\\"]; ok {\\n   197→\\t\\tvar opts map[string]any\\n   198→\\t\\tif err := json.Unmarshal(optionsRaw, &opts); err != nil {\\n   199→\\t\\t\\treturn fmt.Errorf(\\\"parsing strategy_options field: %w\\\", err)\"}]},\"uuid\":\"c1fd8704-0d49-43bd-bbe3-61c0cf8fab0a\",\"timestamp\":\"2026-02-27T19:44:54.067Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand how the Entire CLI installs/enables hooks in a repo, and how to disable them. The goal is to write a performance test that:\\n1. Clones a real repo\\n2. Creates a commit WITHOUT Entire hooks (control baseline)\\n3. Enables Entire hooks, creates a commit WITH hooks (test measurement)\\n\\nFind and read:\\n1. How `entire enable` installs hooks - what files does it create/modify? Look in `cmd/entire/cli/commands/` for the enable command\\n2. How hooks are invoked - look at the hook scripts in `.git/hooks/` or wherever they get installed\\n3. How to programmatically call PrepareCommitMsg and PostCommit from Go test code (we already know ManualCommitStrategy has these methods)\\n4. What `.entire/settings.json` needs to contain for hooks to work\\n5. How `entire disable` or cleanup works\\n\\nAlso find:\\n6. The `entire enable` command implementation to understand what setup steps are needed\\n7. Look at how existing integration tests set up Entire in a repo (check `cmd/entire/cli/