essionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n   609→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session state found: parsing transcript from offset %d\\\\n\\\", sessionState.CheckpointTranscriptStart)\\n   610→\\t\\treturn sessionState.CheckpointTranscriptStart\\n   611→\\t}\\n   612→\\n   613→\\treturn 0\\n   614→}\\n   615→\\n   616→// createContextFile creates a context.md file for the session checkpoint.\\n   617→// This is a unified version that works for all agents.\\n   618→func createContextFile(contextFile, commitMessage, sessionID string, prompts []string, summary string) error {\\n   619→\\tvar sb strings.Builder\\n   620→\\n   621→\\tsb.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   622→\\tfmt.Fprintf(&sb, \\\"Session ID: %s\\\\n\\\", sessionID)\\n   623→\\tfmt.Fprintf(&sb, \\\"Commit Message: %s\\\\n\\\\n\\\", commitMessage)\\n   624→\\n   625→\\tif len(prompts) > 0 {\\n   626→\\t\\tsb.WriteString(\\\"## Prompts\\\\n\\\\n\\\")\\n   627→\\t\\tfor i, p := range prompts {\\n   628→\\t\\t\\tfmt.Fprintf(&sb, \\\"### Prompt %d\\\\n\\\\n%s\\\\n\\\\n\\\", i+1, p)\\n   629→\\t\\t}\\n   630→\\t}\\n   631→\\n   632→\\tif summary != \\\"\\\" {\\n   633→\\t\\tsb.WriteString(\\\"## Summary\\\\n\\\\n\\\")\\n   634→\\t\\tsb.WriteString(summary)\\n   635→\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   636→\\t}\\n   637→\\n   638→\\tif err := os.WriteFile(contextFile, []byte(sb.String()), 0o600); err != nil {\\n   639→\\t\\treturn fmt.Errorf(\\\"failed to write context file: %w\\\", err)\\n   640→\\t}\\n   641→\\treturn nil\\n   642→}\\n   643→\\n   644→// parseTranscriptForCheckpointUUID is a thin wrapper around transcript parsing for checkpoint UUID lookup.\\n   645→// Returns parsed transcript lines for use with FindCheckpointUUID.\\n   646→func parseTranscriptForCheckpointUUID(transcriptPath string) ([]transcriptLine, error) {\\n   647→\\tlines, err := transcript.ParseFromFileAtLine(transcriptPath, 0)\\n   648→\\tif err != nil {\\n   649→\\t\\treturn nil, fmt.Errorf(\\\"parsing transcript for checkpoint UUID: %w\\\", err)\\n   650→\\t}\\n   651→\\treturn lines, nil\\n   652→}\\n   653→\\n   654→// transitionSessionTurnEnd transitions the session phase to IDLE and dispatches turn-end actions.\\n   655→func transitionSessionTurnEnd(ctx context.Context, sessionID string) {\\n   656→\\tturnState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   657→\\tif loadErr != nil {\\n   658→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for turn end: %v\\\\n\\\", loadErr)\\n   659→\\t\\treturn\\n   660→\\t}\\n   661→\\tif turnState == nil {\\n   662→\\t\\treturn\\n   663→\\t}\\n   664→\\tif err := strategy.TransitionAndLog(ctx, turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   665→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: turn-end transition failed: %v\\\\n\\\", err)\\n   666→\\t}\\n   667→\\n   668→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   669→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   670→\\tstrat := GetStrategy(ctx)\\n   671→\\tif err := strat.HandleTurnEnd(ctx, turnState); err != nil {\\n   672→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: turn-end action dispatch failed: %v\\\\n\\\", err)\\n   673→\\t}\\n   674→\\n   675→\\tif updateErr := strategy.SaveSessionState(ctx, turnState); updateErr != nil {\\n   676→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session phase on turn end: %v\\\\n\\\", updateErr)\\n   677→\\t}\\n   678→}\\n   679→\\n   680→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   681→func markSessionEnded(ctx context.Context, sessionID string) error {\\n   682→\\tstate, err := strategy.LoadSessionState(ctx, sessionID)\\n   683→\\tif err != nil {\\n   684→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   685→\\t}\\n   686→\\tif state == nil {\\n   687→\\t\\treturn nil // N