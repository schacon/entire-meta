1. How `entire enable` installs hooks - what files does it create/modify? Look in `cmd/entire/cli/commands/` for the enable command\\n2. How hooks are invoked - look at the hook scripts in `.git/hooks/` or wherever they get installed\\n3. How to programmatically call PrepareCommitMsg and PostCommit from Go test code (we already know ManualCommitStrategy has these methods)\\n4. What `.entire/settings.json` needs to contain for hooks to work\\n5. How `entire disable` or cleanup works\\n\\nAlso find:\\n6. The `entire enable` command implementation to understand what setup steps are needed\\n7. Look at how existing integration tests set up Entire in a repo (check `cmd/entire/cli/integration_test/`)\\n\\nProvide full file paths and key function signatures.\",\"agentId\":\"aec36e794af2f6ab2\"},\"toolUseID\":\"agent_msg_011FTUqL5nz1fiMoAaMyjPDn\",\"parentToolUseID\":\"toolu_01Vsij8P3mFaefaMv15QpaUb\",\"uuid\":\"79be8947-c384-4571-a6eb-8b431619039f\",\"timestamp\":\"2026-02-27T19:44:51.464Z\"}\n{\"parentUuid\":\"79be8947-c384-4571-a6eb-8b431619039f\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/evisdrenova/code/entire/devenv/cli\",\"sessionId\":\"20bfcd4a-f133-4981-8712-228da5357d19\",\"version\":\"2.1.56\",\"gitBranch\":\"sessionPruning\",\"slug\":\"clever-leaping-stream\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01F2WQ7u4nhQR3bzgvqxEKFB\",\"type\":\"tool_result\",\"content\":\"   280→\\n   281→// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   282→// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   283→// Only adds a trailer if there's actually new session content to condense.\\n   284→// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   285→// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   286→// For amended commits, preserves the existing checkpoint ID.\\n   287→//\\n   288→// The source parameter indicates how the commit was initiated:\\n   289→//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   290→//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   291→//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   292→//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   293→//\\n   294→\\n   295→func (s *ManualCommitStrategy) PrepareCommitMsg(ctx context.Context, commitMsgFile string, source string) error {\\n   296→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   297→\\n   298→\\t// Skip during rebase, cherry-pick, or revert operations\\n   299→\\t// These are replaying existing commits and should not be linked to agent sessions\\n   300→\\tif isGitSequenceOperation(ctx) {\\n   301→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n   302→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   303→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   304→\\t\\t)\\n   305→\\t\\treturn nil\\n   306→\\t}\\n   307→\\n   308→\\t// Skip for merge and squash sources\\n   309→\\t// These are auto-generated messages - not from Claude sessions\\n   310→\\tswitch source {\\n   311→\\tcase \\\"merge\\\", \\\"squash\\\":\\n   312→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n   313→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   314→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   315→\\t\\t)\\n   316→\\t\\treturn nil\\n   317→\\t}\\n   318→\\n   319→\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   320→\\tif source == \\\"commit\\\" {\\n   321→\\t\\treturn s.handleAmendCommitMsg(ctx, commitMsgFile)\\n   322→\\t}\\n   323→\\n   324→\\trepo, err := OpenRepository(ctx)\\n   325→\\tif err != nil {\\n   326→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   327→\\t}\\n   328→\\n   329→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   330→\\tif err != nil {\\n   331→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   332→\\t}\\n   333→\\n   334→\\t// Find all active sessions for this worktree\\n   335→\\t// We match by worktree (not BaseCommit) because the user may have made\\n   336→\\t// intermediate commits without entering new prompts, causing HEAD to diverge\\n   337→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   338→\\tif err != nil || len(sessions) == 0 {\\n   339→\\t\\t// No active sessions or error listing - silently skip (hooks must be resilient)\\n   340→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no active sessions\\\",\\n   341→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   342→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   343→\\t\\t)\\n   344→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   345→\\t}\\n   346→\\n   347→\\t// Fast path: when an agent is committing (ACTIVE session + no TTY), skip\\n   348→\\t// content detection and interactive prompts. The agent can't respond to TTY\\n   349→\\t// prompts and the content detection can miss mid-session work (no shadow\\n   350→\\t// branch yet, transcript analysis may fail). Generate a checkpoint ID and\\n   351→\\t// add the trailer directly.\\n   352→\\tif !hasTTY() {\\n   353→\\t\\tfor _, state := range sessions {\\n   354→\\t\\t\\tif state.Phase.IsActive() {\\n   355→\\t\\t\\t\\treturn s.addTrailerForAgentCommit(logCtx, commitMsgFile, state, source)\\n   356→\\t\\t\\t}\\n   357→\\t\\t}\\n   358→\\t}\\n   359→\\n   360→\\t// Check if any session has new content to condense\\n   361→\\tsessionsWithContent := s.filterSessionsWithNewContent(ctx, repo, sessions)\\n   362→\\n   363→\\tif len(sessionsWithContent) == 0 {\\n   364→\\t\\t// No new content — no trailer needed\\n   365→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no content to link\\\",\\n   366→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   367→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   368→\\t\\t\\tslog.Int(\\\"sessions_found\\\", len(sessions)),\\n   369→\\t\\t)\\n   370→\\t\\treturn nil\\n   371→\\t}\\n   372→\\n   373→\\t// Read current commit message\\n   374→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   375→\\tif err != nil {\\n   376→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   377→\\t}\\n   378→\\n   379→\\tmessage := string(content)\\n   380→\\n   381→\\t// Check if trailer already exists (ParseCheckpoint validates format, so found==true means valid)\\n   382→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   383→\\t\\t// Trailer already exists (e.g., amend) - keep it\\n   384→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: trailer already exists\\\",\\n   385→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   386→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   387→\\t\\t\\tslog.String(\\\"existing_checkpoint_id\\\", existingCpID.String()),\\n   388→\\t\\t)\\n   389→\\t\\treturn nil\\n   390→\\t}\\n   391→\\n   392→\\t// Generate a fresh checkpoint ID\\n   393→\\tcheckpointID, err := id.Generate()\\n   394→\\tif err != nil {\\n   395→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   396→\\t}\\n   397→\\n   398→\\t// Determine agent type and last prompt from session\\n   399→\\tvar agentType agent.AgentType\\n   400→\\tvar lastPrompt string\\n   401→\\tif len(sessionsWithContent) > 0 {\\n   402→\\t\\tfirstSession := sessionsWithContent[0]\\n   403→\\t\\tif firstSession.AgentType != \\\"\\\" {\\n   404→\\t\\t\\tagentType = firstSession.AgentType\\n   405→\\t\\t}\\n   406→\\t\\tlastPrompt = s.getLastPrompt(ctx, repo, firstSession)\\n   407→\\t}\\n   408→\\n   409→\\t// Prepare prompt for display: collapse newlines/whitespace, then truncate (rune-safe)\\n   410→\\tdisplayPrompt := stringutil.TruncateRunes(stringutil.CollapseWhitespace(lastPrompt), 80, \\\"...\\\")\\n   411→\\n   412→\\t// Load commit_linking setting to decide whether to prompt\\n   413→\\tcommitLinking := settings.CommitLinkingPrompt // safe default\\n   414→\\tif stngs, loadErr := settings.Load(ctx); loadErr == nil {\\n   415→\\t\\tcommitLinking = stngs.GetCommitLinking()\\n   416→\\t}\\n   417→\\n   418→\\t// Add trailer differently based on commit source\\n   419→\\tswitch source {\\n   420→\\tcase \\\"message\\\":\\n   421→\\t\\t// Using -m or -F: behavior depends on commit_linking setting\\n   422→\\t\\tif commitLinking == settings.CommitLinkingAlways {\\n   423→\\t\\t\\t// Auto-link: add trailer without prompting\\n   424→\\t\\t\\tmessage = addCheckpointTrailer(message, checkpointID)\\n   425→\\t\\t} else {\\n   426→\\t\\t\\t// Prompt mode: ask user interactively whether to add trailer\\n   427→\\t\\t\\t// (comments won't be stripped by git in this mode)\\n   428→\\t\\t\\theader := \\\"Entire: Active \\\" + string(agentType) + \\\" session detected\\\"\\n   429→\\t\\t\\tvar details []string\\n   430→\\t\\t\\tif displayPrompt != \\\"\\\" {\\n   431→\\t\\t\\t\\tdetails = append(details, \\\"Last prompt: \\\"+displayPrompt)\\n   432→\\t\\t\\t}\\n   433→\\n   434→\\t\\t\\tresult := askConfirmTTY(header, details, \\\"Link this commit to session context?\\\", true)\\n   435→\\t\\t\\tif result == ttyConfirmNo {\\n   436→\\t\\t\\t\\t// User declined - don't add trailer\\n   437→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: user declined trailer\\\",\\n   438→\\t\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   439→\\t\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n   440→\\t\\t\\t\\t)\\n   441→\\t\\t\\t\\treturn nil\\n   442→\\t\\t\\t}\\n   443→\\t\\t\\tif result == ttyConfirmAlways {\\n   444→\\t\\t\\t\\t// User chose \\\"always\\\" - persist to settings.local.json (non-fatal if it fails)\\n   445→\\t\\t\\t\\tif saveErr := saveCommitLinkingAlways(ctx); saveErr != nil {\\n   446→\\t\\t\\t\\t\\tlogging.Warn(logCtx, \\\"prepare-commit-msg: failed to save commit_linking=always\\\",\\n   447→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()),\\n   448→\\t\\t\\t\\t\\t)\\n   449→\\t\\t\\t\\t}\\n   450→\\t\\t\\t}\\n   451→\\t\\t\\tmessage = addCheckpointTrailer(message, checkpointID)\\n   452→\\t\\t}\\n   453→\\tdefault:\\n   454→\\t\\t// Normal editor flow: add trailer with explanatory comment (will be stripped by git)\\n   455→\\t\\tmessage = addCheckpointTrailerWithComment(message, checkpointID, string(agentType), displayPrompt)\\n   456→\\t}\\n   457→\\n   458→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: trailer added\\\",\\n   459→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   460→\\t\\tslog.String(\\\"source\\\", source),\\n   461→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   462→\\t)\\n   463→\\n   464→\\t// Write updated message back\\n   465→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   466→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   467→\\t}\\n   468→\\n   469→\\treturn nil\\n   470→}\\n   471→\\n   472→// handleAmendCommitMsg handles the prepare-commit-msg hook for amend operations\\n   473→// (source=\\\"commit\\\"). It preserves existing trailers or restores from LastCheckpointID.\\n   474→func (s *ManualCommitStrategy) handleAmendCommitMsg(ctx context.Context, commitMsgFile string) error {\\n   475→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   476→\\t// Read current commit message\\n   477→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   478→\\tif err != nil {\\n   479→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   480→\\t}\\n   481→\\n   482→\\tmessage := string(content)\\n   483→\\n   484→\\t// If message already has a trailer, keep it unchanged\\n   485→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   486→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend preserves existing trailer\\\",\\n   487→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   488→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", existingCpID.String()),\\n   489→\\t\\t)\\n   490→\\t\\treturn nil\\n   491→\\t}\\n   492→\\n   493→\\t// No trailer in message — check if any session has LastCheckpointID to restore\\n   494→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   495→\\tif err != nil {\\n   496→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   497→\\t}\\n   498→\\n   499→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   500→\\tif err != nil || len(sessions) == 0 {\\n   501→\\t\\treturn nil //nolint:nilerr // No sessions - nothing to restore\\n   502→\\t}\\n   503→\\n   504→\\t// For amend, HEAD^ is the commit being amended, and HEAD is where we are now.\\n   505→\\t// We need to match sessions whose BaseCommit equals HEAD (the commit being amended\\n   506→\\t// was created from this base). This prevents stale sessions from injecting\\n   507→\\t// unrelated checkpoint IDs.\\n   508→\\trepo, repoErr := OpenRepository(ctx)\\n   509→\\tif repoErr != nil {\\n   510→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   511→\\t}\\n   512→\\thead, headErr := repo.Head()\\n   513→\\tif headErr != nil {\\n   514→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   515→\\t}\\n   516→\\tcurrentHead := head.Hash().String()\\n   517→\\n   518→\\t// Find first matching session with LastCheckpointID to restore.\\n   519→\\t// LastCheckpointID is set after condensation completes.\\n   520→\\tfor _, state := range sessions {\\n   521→\\t\\tif state.BaseCommit != currentHead {\\n   522→\\t\\t\\tcontinue\\n 