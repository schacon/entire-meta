itActionHandler) HandleDiscardIfNoFiles(state *session.State) error {\\n   688→\\tif len(state.FilesTouched) == 0 {\\n   689→\\t\\tlogging.Debug(logging.WithComponent(h.ctx, \\\"checkpoint\\\"), \\\"post-commit: skipping empty ended session (no files to condense)\\\",\\n   690→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   691→\\t\\t)\\n   692→\\t}\\n   693→\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   694→\\treturn nil\\n   695→}\\n   696→\\n   697→func (h *postCommitActionHandler) HandleWarnStaleSession(_ *session.State) error {\\n   698→\\t// Not produced by EventGitCommit; no-op for exhaustiveness.\\n   699→\\treturn nil\\n   700→}\\n   701→\\n   702→// During rebase/cherry-pick/revert operations, phase transitions are skipped entirely.\\n   703→//\\n   704→\\n   705→func (s *ManualCommitStrategy) PostCommit(ctx context.Context) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   706→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   707→\\n   708→\\trepo, err := OpenRepository(ctx)\\n   709→\\tif err != nil {\\n   710→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   711→\\t}\\n   712→\\n   713→\\t// Get HEAD commit to check for trailer\\n   714→\\thead, err := repo.Head()\\n   715→\\tif err != nil {\\n   716→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   717→\\t}\\n   718→\\n   719→\\tcommit, err := repo.CommitObject(head.Hash())\\n   720→\\tif err != nil {\\n   721→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   722→\\t}\\n   723→\\n   724→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   725→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   726→\\tif !found {\\n   727→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   728→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   729→\