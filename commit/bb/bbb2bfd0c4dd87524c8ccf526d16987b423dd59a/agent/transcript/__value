\n   740→\\n   741→// SimulateGeminiAfterAgent is a convenience method on TestEnv.\\n   742→func (env *TestEnv) SimulateGeminiAfterAgent(sessionID, transcriptPath string) error {\\n   743→\\tenv.T.Helper()\\n   744→\\trunner := NewGeminiHookRunner(env.RepoDir, env.GeminiProjectDir, env.T)\\n   745→\\treturn runner.SimulateGeminiAfterAgent(sessionID, transcriptPath)\\n   746→}\\n   747→\\n   748→// SimulateGeminiSessionEnd is a convenience method on TestEnv.\\n   749→func (env *TestEnv) SimulateGeminiSessionEnd(sessionID, transcriptPath string) error {\\n   750→\\tenv.T.Helper()\\n   751→\\trunner := NewGeminiHookRunner(env.RepoDir, env.GeminiProjectDir, env.T)\\n   752→\\treturn runner.SimulateGeminiSessionEnd(sessionID, transcriptPath)\\n   753→}\\n   754→\\n   755→// --- OpenCode Hook Runner ---\\n   756→\\n   757→// OpenCodeHookRunner executes OpenCode hooks in the test environment.\\n   758→type OpenCodeHookRunner struct {\\n   759→\\tRepoDir            string\\n   760→\\tOpenCodeProjectDir string\\n   761→\\tT                  interface {\\n   762→\\t\\tHelper()\\n   763→\\t\\tFatalf(format string, args ...interface{})\\n   764→\\t\\tLogf(format string, args ...interface{})\\n   765→\\t}\\n   766→}\\n   767→\\n   768→// NewOpenCodeHookRunner creates a new OpenCode hook runner for the given repo directory.\\n   769→func NewOpenCodeHookRunner(repoDir, openCodeProjectDir string, t interface {\\n   770→\\tHelper()\\n   771→\\tFatalf(format string, args ...interface{})\\n   772→\\tLogf(format string, args ...interface{})\\n   773→}) *OpenCodeHookRunner {\\n   774→\\treturn &OpenCodeHookRunner{\\n   775→\\t\\tRepoDir:            repoDir,\\n   776→\\t\\tOpenCodeProjectDir: openCodeProjectDir,\\n   777→\\t\\tT:                  t,\\n   778→\\t}\\n   779→}\\n   780→\\n   781→func (r *OpenCodeHookRunner) runOpenCodeHookWithInput(hookName string, input interface{}) error {\\n   782→\\tr.T.Helper()\\n   783→\\n   784→\\tinputJSON, err := json.Marshal(input)\\n   785→\\tif err != nil {\\n   786→\\t\\treturn fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n   787→\\t}\\n   788→\\n   789→\\treturn r.runOpenCodeHookInRepoDir(hookName, inputJSON)\\n   790→}\\n   791→\\n   792→func (r *OpenCodeHookRunner) runOpenCodeHookInRepoDir(hookName string, inputJSON []byte) error {\\n   793→\\t// Command structure: entire hooks opencode <hook-name>\\n   794→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"opencode\\\", hookName)\\n   795→\\tcmd.Dir = r.RepoDir\\n   796→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   797→\\tcmd.Env = append(gitIsolatedEnv(),\\n   798→\\t\\t\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR=\\\"+r.OpenCodeProjectDir,\\n   799→\\t\\t\\\"ENTIRE_TEST_OPENCODE_MOCK_EXPORT=1\\\", // Use pre-written mock transcript instead of calling opencode export\\n   800→\\t)\\n   801→\\n   802→\\toutput, err := cmd.CombinedOutput()\\n   803→\\tif err != nil {\\n   804→\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n   805→\\t\\t\\thookName, err, inputJSON, output)\\n   806→\\t}\\n   807→\\n   808→\\tr.T.Logf(\\\"OpenCode hook %s output: %s\\\", hookName, output)\\n   809→\\treturn nil\\n   810→}\\n   811→\\n   812→// SimulateOpenCodeSessionStart simulates the session-start hook for OpenCode.\\n   813→// Note: The plugin now sends only session_id, not transcript_path.\\n   814→func (r *OpenCodeHookRunner) SimulateOpenCodeSessionStart(sessionID, _ string) error {\\n   815→\\tr.T.Helper()\\n   816→\\n   817→\\tinput := map[string]string{\\n   818→\\t\\t\\\"session_id\\\": sessionID,\\n   819→\\t}\\n   820→\\n   821→\\treturn r.runOpenCodeHookWithInput(\\\"session-start\\\", input)\\n   822→}\\n   823→\\n   824→// SimulateOpenCodeTurnStart simulates the turn-start hook for OpenCode.\\n   825→// This is equivalent to Claude Code's UserPromptSubmit.\\n   826→// Note: The plugin now sends only session_id and prompt, not transcript_path.\\n   827→func (r *OpenCodeHookRunner) SimulateOpenCodeTurnStart(sessionID, _, prompt string) error {\\n   828→\\tr.T.Helper()\\n   829→\\n   830→\\tinput := map[string]string{\\n   831→\\t\\t\\\"session_id\\\": sessionID,\\n   832→\\t\\t\\\"prompt\\\":     prompt,\\n   833→\\t}\\n   834→\\n   835→\\treturn r.runOpenCodeHookWithInput(\\\"turn-start\\\", input)\\n   836→}\\n   837→\\n   838→// SimulateOpenCodeTurnEnd simulates the turn-end hook for OpenCode.\\n   839→// This is equivalent to Claude Code's Stop hook.\\n   840→// Note: The plugin now sends only session_id. The Go handler calls `opencode export`\\n   841→// to get the transcript. For tests, we write a mock export JSON file first.\\n   842→func (r *OpenCodeHookRunner) SimulateOpenCodeTurnEnd(sessionID, transcriptPath string) error {\\n   843→\\tr.T.Helper()\\n   844→\\n   845→\\t// For integration tests, write the mock transcript to the location where the\\n   846→\\t// lifecycle handler expects it (.entire/tmp/<session_id>.json)\\n   847→\\tif transcriptPath != \\\"\\\" {\\n   848→\\t\\tsrcData, err := os.ReadFile(transcriptPath)\\n   849→\\t\\tif err != nil {\\n   850→\\t\\t\\tr.T.Fatalf(\\\"SimulateOpenCodeTurnEnd: failed to read transcript from %q: %v\\\", transcriptPath, err)\\n   851→\\t\\t}\\n   852→\\t\\tdestDir := filepath.Join(r.RepoDir, \\\".entire\\\", \\\"tmp\\\")\\n   853→\\t\\tif err := os.MkdirAll(destDir, 0o755); err != nil {\\n   854→\\t\\t\\tr.T.Fatalf(\\\"SimulateOpenCodeTurnEnd: failed to create directory %q: %v\\\", destDir, err)\\n   855→\\t\\t}\\n   856→\\t\\tdestPath := filepath.Join(destDir, sessionID+\\\".json\\\")\\n   857→\\t\\tif err := os.WriteFile(destPath, srcData, 0o644); err != nil {\\n   858→\\t\\t\\tr.T.Fatalf(\\\"SimulateOpenCodeTurnEnd: failed to write transcript to %q: %v\\\", destPath, err)\\n   859→\\t\\t}\\n   860→\\t}\\n   861→\\n   862→\\tinput := map[string]string{\\n   863→\\t\\t\\\"session_id\\\": sessionID,\\n   864→\\t}\\n   865→\\n   866→\\treturn r.runOpenCodeHookWithInput(\\\"turn-end\\\", input)\\n   867→}\\n   868→\\n   869→// SimulateOpenCodeSessionEnd simulates the session-end hook for OpenCode.\\n   870→// Note: The plugin now sends only session_id, not transcript_path.\\n   871→func (r *OpenCodeHookRunner) SimulateOpenCodeSessionEnd(sessionID, _ string) error {\\n   872→\\tr.T.Helper()\\n   873→\\n   874→\\tinput := map[string]string{\\n   875→\\t\\t\\\"session_id\\\": sessionID,\\n   876→\\t}\\n   877→\\n   878→\\treturn r.runOpenCodeHookWithInput(\\\"session-end\\\", input)\\n   879→}\\n   880→\\n   881→// OpenCodeSession represents a simulated OpenCode session.\\n   882→type OpenCodeSession struct {\\n   883→\\tID             string // Raw session ID (e.g., \\\"opencode-session-1\\\")\\n   884→\\tTranscriptPath string\\n   885→\\tenv            *TestEnv\\n   886→\\tmsgCounter     int\\n   887→\\t// messages accumulates all messages across turns, matching real `opencode export`\\n   888→\\t// behavior where each export returns the full session history.\\n   889→\\tmessages []map[string]interface{}\\n   890→}\\n   891→\\n   892→// NewOpenCodeSession creates a new simulated OpenCode session.\\n   893→func (env *TestEnv) NewOpenCodeSession() *OpenCodeSession {\\n   894→\\tenv.T.Helper()\\n   895→\\n   896→\\tenv.SessionCounter++\\n   897→\\tsessionID := fmt.Sprintf(\\\"opencode-session-%d\\\", env.SessionCounter)\\n   898→\\ttranscriptPath := filepath.Join(env.OpenCodeProjectDir, sessionID+\\\".json\\\")\\n   899→\\n   900→\\treturn &OpenCodeSession{\\n   901→\\t\\tID:             sessionID,\\n   902→\\t\\tTranscriptPath: transcriptPath,\\n   903→\\t\\tenv:            env,\\n   904→\\t}\\n   905→}\\n   906→\\n   907→// CreateOpenCodeTranscript creates an OpenCode export JSON transcript file for the session.\\n   908→// Each call appends new messages to the accumulated session history, matching real\\n   909→// `opencode export` behavior where each export returns the full session history.\\n   910→func (s *OpenCodeSession) CreateOpenCodeTranscript(prompt string, changes []Fi