h scenario.\\n   178→// Shallow clone keeps all remote refs but only one commit of history.\\n   179→func cloneSourceRepo(t *testing.T) string {\\n   180→\\tt.Helper()\\n   181→\\n   182→\\tdir := t.TempDir()\\n   183→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n   184→\\t\\tdir = resolved\\n   185→\\t}\\n   186→\\n   187→\\tt.Logf(\\\"Cloning %s (depth=1) ...\\\", hookPerfRepoURL)\\n   188→\\tstart := time.Now()\\n   189→\\n   190→\\t//nolint:gosec // test-only, URL is a constant\\n   191→\\tcmd := exec.Command(\\\"git\\\", \\\"clone\\\", \\\"--depth\\\", \\\"1\\\", hookPerfRepoURL, dir)\\n   192→\\tout, err := cmd.CombinedOutput()\\n   193→\\tif err != nil {\\n   194→\\t\\tt.Fatalf(\\\"git clone failed: %v\\\\n%s\\\", err, out)\\n   195→\\t}\\n   196→\\tt.Logf(\\\"Source clone completed in %s\\\", time.Since(start).Round(time.Millisecond))\\n   197→\\n   198→\\treturn dir\\n   199→}\\n   200→\\n   201→// localClone creates a fast local clone from the cached source repo.\\n   202→// Uses --no-hardlinks to get an independent copy (hardlinks don't work\\n   203→// across temp dirs on all platforms).\\n   204→func localClone(t *testing.T, sourceDir string) string {\\n   205→\\tt.Helper()\\n   206→\\n   207→\\tdir := t.TempDir()\\n   208→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n   209→\\t\\tdir = resolved\\n   210→\\t}\\n   211→\\n   212→\\t//nolint:gosec // test-only, sourceDir is from t.TempDir()\\n   213→\\tcmd := exec.Command(\\\"git\\\", \\\"clone\\\", \\\"--local\\\", sourceDir, dir)\\n   214→\\tout, err := cmd.CombinedOutput()\\n   215→\\tif err != nil {\\n   216→\\t\\tt.Fatalf(\\\"local clone failed: %v\\\\n%s\\\", err, out)\\n   217→\\t}\\n   218→\\n   219→\\treturn dir\\n   220→}\\n   221→\\n   222→// gitRun executes a git command in the given directory and fails the test on error.\\n   223→func gitRun(t *testing.T, dir string, args ...string) {\\n   224→\\tt.Helper()\\n   225→\\t//nolint:gosec // test-only helper\\n   226→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   227→\\tcmd.Dir = dir\\n   228→\\tout, err := cmd.CombinedOutput()\\n   229→\\tif err != nil {\\n   230→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n   231→\\t}\\n   232→}\\n   233→\\n   234→// createHookPerfSettings writes .entire/settings.json with commit_linking=always\\n   235→// so PrepareCommitMsg auto-links without prompting.\\n   236→func createHookPerfSettings(t *testing.T, dir string) {\\n   237→\\tt.Helper()\\n   238→\\tentireDir := filepath.Join(dir, \\\".entire\\\")\\n   239→\\tif err := os.MkdirAll(entireDir, 0o755); err != nil {\\n   240→\\t\\tt.Fatalf(\\\"mkdir .entire: %v\\\", err)\\n   241→\\t}\\n   242→\\tsettings := `{\\\"enabled\\\": true, \\\"strategy\\\": \\\"manual-commit\\\", \\\"commit_linking\\\": \\\"always\\\"}`\\n   243→\\tif err := os.WriteFile(filepath.Join(entireDir, \\\"settings.json\\\"), []byte(settings), 0o644); err != nil {\\n   244→\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n   245→\\t}\\n   246→}\\n   247→\\n   248→// seedHookPerfSessions creates session state files with realistic phase distribution.\\n   249→//\\n   250→// ENDED sessions: state file with LastCheckpointID set (already condensed).\\n   251→// IDLE sessions: state file + shadow branch checkpoint via SaveStep.\\n   252→// ACTIVE sessions: state file + shadow branch checkpoint + live transcript file.\\n   253→func seedHookPerfSessions(t *testing.T, dir string, ended, idle, active int) {\\n   254→\\tt.Helper()\\n   255→\\n   256→\\tctx := context.Background()\\n   257→\\n   258→\\t// Get HEAD hash for BaseCommit\\n   259→\\trepo, err := git.PlainOpen(dir)\\n   260→\\tif err != nil {\\n   261→\\t\\tt.Fatalf(\\\"open repo: %v\\\", err)\\n   262→\\t}\\n   263→\\thead, err := repo.Head()\\n   264→\\tif err != nil {\\n   265→\\t\\tt.Fatalf(\\\"head: %v\\\", err)\\n   266→\\t}\\n   267→\\tbaseCommit := head.Hash().String()\\n   268→\\n   269→\\t// Get worktree ID (empty string for main worktree)\\n   270→\\tworktreeID, err := paths.GetWorktreeID(dir)\\n   271→\\tif err != nil {\\n   272→\\t\\tt.Fatalf(\\\"worktree ID: %v\\\", err)\\n   273→\\t}\\n   274→\\n   275→\\t// Create state store in .git/entire-sessions/\\n   276→\\tstateDir := filepath.Join(dir, \\\".git\\\", session.SessionStateDirName)\\n   277→\\tif err := os.MkdirAll(stateDir, 0o755); err != nil {\\n   278→\\t\\tt.Fatalf(\\\"mkdir state dir: %v\\\", err)\\n   279→\\t}\\n   280→\\tstore := session.NewStateStoreWithDir(stateDir)\\n   281→\\n   282→\\tmodifiedFiles := []string{\\\"main.go\\\", \\\"go.mod\\\"}\\n   283→\\n   284→\\t// --- Seed ENDED sessions ---\\n   285→\\t// These have state files with LastCheckpointID but no shadow branch.\\n   286→\\t// In listAllSessionStates, they survive cleanup because LastCheckpointID is set.\\n   287→\\t// Each triggers a repo.Reference() lookup for the (missing) shadow branch.\\n   288→\\tfor i := range ended {\\n   289→\\t\\tsessionID := fmt.Sprintf(\\\"perf-ended-%d\\\", i)\\n   290→\\t\\tcpID := mustGenerateCheckpointID(t)\\n   291→\\t\\tnow := time.Now()\\n   292→\\n   293→\\t\\tstate := &session.State{\\n   294→\\t\\t\\tSessionID:           sessionID,\\n   295→\\t\\t\\tBaseCommit:          baseCommit,\\n   296→\\t\\t\\tWorktreePath:        dir,\\n   297→\\t\\t\\tWorktreeID:          worktreeID,\\n   298→\\t\\t\\tPhase:               session.PhaseEnded,\\n   299→\\t\\t\\tStartedAt:           now.Add(-time.Duration(i+1) * time.Hour),\\n   300→\\t\\t\\tLastCheckpointID:    cpID,\\n   301→\\t\\t\\tStepCount:           1,\\n   302→\\t\\t\\tFilesTouched:        modifiedFiles,\\n   303→\\t\\t\\tLastInteractionTime: &now,\\n   304→\\t\\t}\\n   305→\\t\\tif err := store.Save(ctx, state); err != nil {\\n   306→\\t\\t\\tt.Fatalf(\\\"save ended state %d: %v\\\", i, err)\\n   307→\\t\\t}\\n   308→\\t}\\n   309→\\n   310→\\t// --- Seed IDLE sessions ---\\n   311→\\t// These have shadow branch checkpoints (via SaveStep) and state files.\\n   312→\\ts := &ManualCommitStrategy{}\\n   313→\\tfor i := range idle {\\n   314→\\t\\tsessionID := fmt.Sprintf(\\\"perf-idle-%d\\\", i)\\n   315→\\t\\tseedSessionWithShadowBranch(t, s, dir, sessionID, session.PhaseIdle, modifiedFiles)\\n   316→\\t}\\n   317→\\n   318→\\t// --- Seed ACTIVE sessions ---\\n   319→\\t// These have shadow branch checkpoints + a live transcript file.\\n   320→\\tfor i := range active {\\n   321→\\t\\tsessionID := fmt.Sprintf(\\\"perf-active-%d\\\", i)\\n   322→\\t\\tseedSessionWithShadowBranch(t, s, dir, sessionID, session.PhaseActive, modifiedFiles)\\n   323→\\n   324→\\t\\t// Create a live transcript file (simulates agent in progress)\\n   325→\\t\\tclaudeProjectDir := filepath.Join(dir, \\\".claude\\\", \\\"projects\\\", \\\"test\\\", \\\"sessions\\\")\\n   326→\\t\\tif err := os.MkdirAll(claudeProjectDir, 0o755); err != nil {\\n   327→\\t\\t\\tt.Fatalf(\\\"mkdir claude sessions: %v\\\", err)\\n   328→\\t\\t}\\n   329→\\t\\ttranscript := `{\\\"type\\\":\\\"human\\\",\\\"message\\\":{\\\"content\\\":\\\"implement feature\\\"}}\\n   330→{\\\"type\\\":\\\"assistant\\\",\\\"message\\\":{\\\"content\\\":\\\"I'll implement that for you.\\\"}}\\n   331→{\\\"type\\\":\\\"tool_use\\\",\\\"name\\\":\\\"write\\\",\\\"input\\\":{\\\"path\\\":\\\"main.go\\\",\\\"content\\\":\\\"package main\\\\n// modified\\\\nfunc main() {}\\\\n\\\"}}\\n   332→`\\n   333→\\t\\ttranscriptFile := filepath.Join(claudeProjectDir, sessionID+\\\".jsonl\\\")\\n   334→\\t\\tif err := os.WriteFile(transcriptFile, []byte(transcript), 0o644); err != nil {\\n   335→\\t\\t\\tt.Fatalf(\\\"write live transcript: %v\\\", err)\\n   336→\\t\\t}\\n   337→\\t}\\n   338→\\n   339→\\t// Verify seeded sessions\\n   340→\\tstates, err := store.List(ctx)\\n   341→\\tif err != nil {\\n   342→\\t\\tt.Fatalf(\\\"list states: %v\\\", err)\\n   343→\\t}\\n   344→\\tt.Logf(\\\"  Seeded %d session state files (expected %d)\\\", len(states), ended+idle+active)\\n   345→}\\n   346→\\n   347→// seedSessionWithShadowBranch creates a session with a shadow branch checkpoint\\n   348→// using SaveStep, then sets the desired phase.\\n   349→func seedSessionWithShadowBranch(t *testing.T, s *ManualCommitStrategy, dir, sessionID string, phase session.Phase, modifiedFiles []string) {\\n   350→\\tt.Helper()\\n   351→\\tctx := context.Background()\\n   352→\\n   353→\\t// Modify files with agent content\\n   354→\\tfor _, f := range modifiedFiles {\\n   355→\\t\\tabs := filepath.Join(dir, f)\\n   356→\\t\\tcontent := fmt.Sprintf(\\\"package main\\\\n// modified by agent %s\\\\nfunc f() {}\\\\n\\\", sessionID)\\n   357→\\t\\tif err := os.WriteFile(abs, []byte(content), 0o644); err != nil {\\n   358→\\t\\t\\tt.Fatalf(\\\"write %s: %v\\\", f, err)\\n   359→\\t\\t}\\n   360→\\t}\\n   361→\\n   362→\\t// Create metadata directory with transcript\\n   363→\\tmetadataDir := \\\".entire/metadata/\\\" + sessionID\\n   364→\\tmetadataDirAbs := filepath.Join(dir, metadataDir)\\n   365→\\tif err := os.MkdirAll(metadataDirAbs, 0o755); err != nil {\\n   366→\\t\\tt.Fatalf(\\\"mkdir metadata: %v\\\", err)\\n   367→\\t}\\n   368→\\ttranscript := `{\\\"type\\\":\\\"human\\\",\\\"message\\\":{\\\"content\\\":\\\"implement feature\\\"}}\\n   369→{\\\"type\\\":\\\"assistant\\\",\\\"message\\\":{\\\"content\\\":\\\"I'll implement that for you.\\\"}}\\n   370→`\\n   371→\\tif err := os.WriteFile(filepath.Join(metadataDirAbs, paths.TranscriptFileName), []byte(transcript), 0o644); err != nil {\\n   372→\\t\\tt.Fatalf(\\\"write transcript: %v\\\", err)\\n   373→\\t}\\n   374→\\n   375→\\tpaths.ClearWorktreeRootCache()\\n   376→\\n   377→\\tif err := s.SaveStep(ctx, StepContext{\\n   378→\\t\\tSessionID:      sessionID,\\n   379→\\t\\tModifiedFiles:  modifiedFiles,\\n   380→\\t\\tNewFiles:       []string{},\\n   381→\\t\\tDeletedFiles:   []string{},\\n   382→\\t\\tMetadataDir:    metadataDir,\\n   383→\\t\\tMetadataDirAbs: metadataDirAbs,\\n   384→\\t\\tCommitMessage:  \\\"Checkpoint 1\\\",\\n   385→\\t\\tAuthorName:     \\\"Perf\\\",\\n   386→\\t\\tAuthorEmail:    \\\"perf@test.com\\\",\\n   387→\\t}); err != nil {\\n   388→\\t\\tt.Fatalf(\\\"SaveStep %s: %v\\\", sessionID, err)\\n   389→\\t}\\n   390→\\n   391→\\t// Set the session phase and files touched\\n   392→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   393→\\tif err != nil {\\n   394→\\t\\tt.Fatalf(\\\"load state %s: %v\\\", sessionID, err)\\n   395→\\t}\\n   396→\\tstate.Phase = phase\\n   397→\\tstate.FilesTouched = modifiedFiles\\n   398→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   399→\\t\\tt.Fatalf(\\\"save state %s: %v\\\", sessionID, err)\\n   400→\\t}\\n   401→}\\n   402→\\n   403→func mustGenerateCheckpointID(t *testing.T) id.CheckpointID {\\n   404→\\tt.Helper()\\n   405→\\tcpID, err := id.Generate()\\n   406→\\tif err != nil {\\n   407→\\t\\tt.Fatalf(\\\"generate checkpoint ID: %v\\\", err)\\n   408→\\t}\\n   409→\\treturn cpID\\n   410→}\\n   411→\"}]},\"uuid\":\"546f4299-c3b0-4ca0-a633-04841a8e914c\",\"timestamp\":\"2026-02-27T19:44:45.799Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand how the Entire CLI installs/enables hooks in a repo, and how to disable them. The goal is to write a performance test that:\\n1. Clones a real repo\\n2. Creates a commit WITHOUT Entire hooks (control baseline)\\n3. Enables Entire hooks, creates a commit WITH hooks (test measurement)\\n\\nFind and read:\\n1. How `entire enable` installs hooks - what files does it create/modify? Look in `cmd/entire/cli/commands/` for the enable command\\n2. How hooks are invoked - look at the hook scripts in `.git/hooks/` or wherever they get installed\\n3. How to programmatically call PrepareCommitMsg and PostCommit from Go test code (we already know ManualCommitStrategy has these methods)\\n4. What `.entire/settings.json` needs to contain for hooks to work\\n5. How `entire disable` or cleanup works\\n\\nAlso find:\\n6. The `entire ena