k must be silent on failure\\n   736→\\t}\\n   737→\\n   738→\\t// Find all active sessions for this worktree\\n   739→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   740→\\tif err != nil || len(sessions) == 0 {\\n   741→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   742→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   743→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   744→\\t\\t)\\n   745→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   746→\\t}\\n   747→\\n   748→\\t// Build transition context\\n   749→\\tisRebase := isGitSequenceOperation(ctx)\\n   750→\\ttransitionCtx := session.TransitionContext{\\n   751→\\t\\tIsRebaseInProgress: isRebase,\\n   752→\\t}\\n   753→\\n   754→\\tif isRebase {\\n   755→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   756→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   757→\\t\\t)\\n   758→\\t}\\n   759→\\n   760→\\t// Track shadow branch names and whether they can be deleted\\n   761→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   762→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   763→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   764→\\n   765→\\tnewHead := head.Hash().String()\\n   766→\\n   767→\\t// Pre-resolve HEAD tree and parent tree once for the entire PostCommit.\\n   768→\\t// These are immutable within this hook invocation and used by multiple\\n   769→\\t// per-session functions (filesChangedInCommit, filesOverlapWithContent,\\n   770→\\t// filesWithRemainingAgentChanges, calculateSessionAttributions).\\n   771→\\tvar headTree *object.Tree\\n   772→\\tif t, err := commit.Tree(); err == nil {\\n   773→\\t\\theadTree = t\\n   774→\\t}\\n   775→\\tvar parentTree *object.Tree\\n   776→\\tif commit.NumParents() > 0 {\\n   777→