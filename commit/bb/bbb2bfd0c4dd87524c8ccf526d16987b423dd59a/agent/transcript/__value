\\n    36→\\t\\tif err != nil {\\n    37→\\t\\t\\ts.stateStoreErr = fmt.Errorf(\\\"failed to create state store: %w\\\", err)\\n    38→\\t\\t\\treturn\\n    39→\\t\\t}\\n    40→\\t\\ts.stateStore = store\\n    41→\\t})\\n    42→\\treturn s.stateStore, s.stateStoreErr\\n    43→}\\n    44→\\n    45→// getCheckpointStore returns the checkpoint store, initializing it lazily if needed.\\n    46→// Thread-safe via sync.Once.\\n    47→func (s *ManualCommitStrategy) getCheckpointStore() (*checkpoint.GitStore, error) {\\n    48→\\ts.checkpointStoreOnce.Do(func() {\\n    49→\\t\\trepo, err := OpenRepository(context.Background())\\n    50→\\t\\tif err != nil {\\n    51→\\t\\t\\ts.checkpointStoreErr = fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n    52→\\t\\t\\treturn\\n    53→\\t\\t}\\n    54→\\t\\ts.checkpointStore = checkpoint.NewGitStore(repo)\\n    55→\\t})\\n    56→\\treturn s.checkpointStore, s.checkpointStoreErr\\n    57→}\\n    58→\\n    59→// NewManualCommitStrategy creates a new manual-commit strategy instance.\\n    60→func NewManualCommitStrategy() *ManualCommitStrategy {\"}]},\"uuid\":\"e53d98cc-469c-477e-b625-e67a7068ac48\",\"timestamp\":\"2026-02-27T19:44:53.207Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand how the Entire CLI installs/enables hooks in a repo, and how to disable them. The goal is to write a performance test that:\\n1. Clones a real repo\\n2. Creates a commit WITHOUT Entire hooks (control baseline)\\n3. Enables Entire hooks, creates a commit WITH hooks (test measurement)\\n\\nFind and read:\\n1. How `entire enable` installs hooks - what files does it create/modify? Look in `cmd/entire/cli/commands/` for the enable command\\n2. How hooks are invoked - look at the hook scripts in `.git/hooks/` or wherever they get installed\\n3. How to programmatically call PrepareCommitMsg and PostCommit from Go test code (we already know ManualCommitStrategy has these methods)\\n4. What `.entire/settings.js