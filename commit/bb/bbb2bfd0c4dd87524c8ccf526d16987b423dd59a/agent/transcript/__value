  107→\\t\\t\\t}\\n   108→\\t\\t\\treturn nil\\n   109→\\t\\t},\\n   110→\\t}\\n   111→\\n   112→\\tcmd.AddCommand(newHooksGitPrepareCommitMsgCmd())\\n   113→\\tcmd.AddCommand(newHooksGitCommitMsgCmd())\\n   114→\\tcmd.AddCommand(newHooksGitPostCommitCmd())\\n   115→\\tcmd.AddCommand(newHooksGitPrePushCmd())\\n   116→\\n   117→\\treturn cmd\\n   118→}\\n   119→\\n   120→func newHooksGitPrepareCommitMsgCmd() *cobra.Command {\\n   121→\\treturn &cobra.Command{\\n   122→\\t\\tUse:   \\\"prepare-commit-msg <commit-msg-file> [source]\\\",\\n   123→\\t\\tShort: \\\"Handle prepare-commit-msg git hook\\\",\\n   124→\\t\\tArgs:  cobra.RangeArgs(1, 2),\\n   125→\\t\\tRunE: func(cmd *cobra.Command, args []string) error {\\n   126→\\t\\t\\tif gitHooksDisabled {\\n   127→\\t\\t\\t\\treturn nil\\n   128→\\t\\t\\t}\\n   129→\\n   130→\\t\\t\\tcommitMsgFile := args[0]\\n   131→\\t\\t\\tvar source string\\n   132→\\t\\t\\tif len(args) > 1 {\\n   133→\\t\\t\\t\\tsource = args[1]\\n   134→\\t\\t\\t}\\n   135→\\n   136→\\t\\t\\tg := newGitHookContext(cmd.Context(), \\\"prepare-commit-msg\\\")\\n   137→\\t\\t\\tg.logInvoked(slog.String(\\\"source\\\", source))\\n   138→\\n   139→\\t\\t\\thookErr := g.strategy.PrepareCommitMsg(g.ctx, commitMsgFile, source)\\n   140→\\t\\t\\tg.logCompleted(hookErr, slog.String(\\\"source\\\", source))\\n   141→\\n   142→\\t\\t\\treturn nil\\n   143→\\t\\t},\\n   144→\\t}\\n   145→}\\n   146→\\n   147→func newHooksGitCommitMsgCmd() *cobra.Command {\\n   148→\\treturn &cobra.Command{\\n   149→\\t\\tUse:   \\\"commit-msg <commit-msg-file>\\\",\\n   150→\\t\\tShort: \\\"Handle commit-msg git hook\\\",\\n   151→\\t\\tArgs:  cobra.ExactArgs(1),\\n   152→\\t\\tRunE: func(cmd *cobra.Command, args []string) error {\\n   153→\\t\\t\\tif gitHooksDisabled {\\n   154→\\t\\t\\t\\treturn nil\\n   155→\\t\\t\\t}\\n   156→\\n   157→\\t\\t\\tcommitMsgFile := args[0]\\n   158→\\n   159→\\t\\t\\tg := newGitHookContext(cmd.Context(), \\\"commit-msg\\\")\\n   160→\\t\\t\\tg.logInvoked()\\n   161→\\n   162→\\t\\t\\thookErr := g.strategy.CommitMsg(g.ctx, commitMsgFile)\\n   163→\\t\\t\\tg.logCompleted(hookErr)\\n   164→\\t\\t\\treturn hookErr //nolint:wrapcheck // Thin delegation layer - wrapping adds no value\\n   165→\\t\\t},\\n   166→\\t}\\n   167→}\\n   168→\\n   169→func newHooksGitPostCommitCmd() *cobra.Command {\\n   170→\\treturn &cobra.Command{\\n   171→\\t\\tUse:   \\\"post-commit\\\",\\n   172→\\t\\tShort: \\\"Handle post-commit git hook\\\",\\n   173→\\t\\tArgs:  cobra.NoArgs,\\n   174→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   175→\\t\\t\\tif gitHooksDisabled {\\n   176→\\t\\t\\t\\treturn nil\\n   177→\\t\\t\\t}\\n   178→\\n   179→\\t\\t\\tg := newGitHookContext(cmd.Context(), \\\"post-commit\\\")\\n   180→\\t\\t\\tg.logInvoked()\\n   181→\\n   182→\\t\\t\\thookErr := g.strategy.PostCommit(g.ctx)\\n   183→\\t\\t\\tg.logCompleted(hookErr)\\n   184→\\n   185→\\t\\t\\treturn nil\\n   186→\\t\\t},\\n   187→\\t}\\n   188→}\\n   189→\\n   190→func newHooksGitPrePushCmd() *cobra.Command {\\n   191→\\treturn &cobra.Command{\\n   192→\\t\\tUse:   \\\"pre-push <remote>\\\",\\n   193→\\t\\tShort: \\\"Handle pre-push git hook\\\",\\n   194→\\t\\tArgs:  cobra.ExactArgs(1),\\n   195→\\t\\tRunE: func(cmd *cobra.Command, args []string) error {\\n   196→\\t\\t\\tif gitHooksDisabled {\\n   197→\\t\\t\\t\\treturn nil\\n   198→\\t\\t\\t}\\n   199→\\n   200→\\t\\t\\tremote := args[0]\\n   201→\\n   202→\\t\\t\\tg := newGitHookContext(cmd.Context(), \\\"pre-push\\\")\\n   203→\\t\\t\\tg.logInvoked(slog.String(\\\"remote\\\", remote))\\n   204→\\n   205→\\t\\t\\thookErr := g.strategy.PrePush(g.ctx, remote)\\n   206→\\t\\t\\tg.logCompleted(hookErr, slog.String(\\\"remote\\\", remote))\\n   207→\\n   208→\\t\\t\\treturn nil\\n   209→\\t\\t},\\n   210→\\t}\\n   211→}\\n   212→\"}]},\"uuid\":\"8a90363e-a031-4b55-9da1-3fb81f8b025f\",\"timestamp\":\"2026-02-27T19:44:30.063Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand how the Entire CLI installs/enables hooks in a repo, and how to disable them. The goal is to write a performance test that:\\n1. Clones a real repo\\n2. Creates a commit WITHOUT Entire hooks (control baseline)\\n3. Enables Entire hooks, creates a commit WITH hooks (test measurement)\\n\\nFind and read:\\n1. How `entire enable` installs hooks - what files does it create/modify? Look in `cmd/entire/cli/commands/` for the enable command\\n2. How hooks are invoked - look at the hook scripts in `.git/hooks/` or wherever they get installed\\n3. How to programmatically call PrepareCommitMsg and PostCommit from Go test code (we already know ManualCommitStrategy has these methods)\\n4. What `.entire/settings.json` needs to contain for hooks to work\\n5. How `entire disable` or cleanup works\\n\\nAlso find:\\n6. The `entire enable` command implementation to understand what setup steps are needed\\n7. Look at how existing integration tests set up Entire in a repo (check `cmd/entire/cli/integration_test/`)\\n\\nProvide full file paths and key function signatures.\",\"agentId\":\"aec36e794af2f6ab2\"},\"toolUseID\":\"agent_msg_011FTUqL5nz1fiMoAaMyjPDn\",\"parentToolUseID\":\"toolu_01Vsij8P3mFaefaMv15QpaUb\",\"uuid\":\"6fe235da-3cac-4460-af87-db9704ed90d6\",\"timestamp\":\"2026-02-27T19:44:30.508Z\"}\n{\"parentUuid\":\"6fe235da-3cac-4460-af87-db9704ed90d6\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/evisdrenova/code/entire/devenv/cli\",\"sessionId\":\"20bfcd4a-f133-4981-8712-228da5357d19\",\"version\":\"2.1.56\",\"gitBranch\":\"sessionPruning\",\"slug\":\"clever-leaping-stream\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-02-27T19:44:30.614Z\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_017nvPq9JqHqs7fhetefUZy7\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01CwhjoeS4ko1weWW6Kvoq8G\",\"name\":\"Read\",\"input\":{\"file_path\":