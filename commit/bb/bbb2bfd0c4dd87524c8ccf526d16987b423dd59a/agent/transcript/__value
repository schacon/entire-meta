t}\\n   539→\\tcase index%2 == 0:\\n   540→\\t\\t// Assistant message\\n   541→\\t\\tmsg[\\\"type\\\"] = \\\"assistant\\\"\\n   542→\\t\\tmsg[\\\"content\\\"] = generatePadding(\\\"I'll help you implement this feature. \\\", opts.AvgMessageBytes)\\n   543→\\tdefault:\\n   544→\\t\\t// Human message\\n   545→\\t\\tmsg[\\\"type\\\"] = \\\"human\\\"\\n   546→\\t\\tmsg[\\\"content\\\"] = generatePadding(\\\"Please update the implementation. \\\", opts.AvgMessageBytes/3)\\n   547→\\t}\\n   548→\\n   549→\\treturn msg\\n   550→}\\n   551→\\n   552→// SeedBranches creates N branches pointing at the current HEAD.\\n   553→// The branches are named with the given prefix (e.g., \\\"feature/bench-\\\" → \\\"feature/bench-000\\\").\\n   554→// This simulates a repo with many refs, which affects go-git ref scanning performance.\\n   555→func (br *BenchRepo) SeedBranches(b *testing.B, prefix string, count int) {\\n   556→\\tb.Helper()\\n   557→\\theadHash := plumbing.NewHash(br.HeadHash)\\n   558→\\tfor i := range count {\\n   559→\\t\\tname := fmt.Sprintf(\\\"%s%03d\\\", prefix, i)\\n   560→\\t\\tref := plumbing.NewHashReference(plumbing.NewBranchReferenceName(name), headHash)\\n   561→\\t\\tif err := br.Repo.Storer.SetReference(ref); err != nil {\\n   562→\\t\\t\\tb.Fatalf(\\\"create branch %s: %v\\\", name, err)\\n   563→\\t\\t}\\n   564→\\t}\\n   565→}\\n   566→\\n   567→// PackRefs runs `git pack-refs --all` to simulate a real repo where most refs\\n   568→// are in the packed-refs file. Large repos almost always have packed refs.\\n   569→func (br *BenchRepo) PackRefs(b *testing.B) {\\n   570→\\tb.Helper()\\n   571→\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"pack-refs\\\", \\\"--all\\\")\\n   572→\\tcmd.Dir = br.Dir\\n   573→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   574→\\t\\tb.Fatalf(\\\"git pack-refs: %v\\\\n%s\\\", err, output)\\n   575→\\t}\\n   576→}\\n   577→\\n   578→// SeedGitObjects creates loose git objects to bloat .git