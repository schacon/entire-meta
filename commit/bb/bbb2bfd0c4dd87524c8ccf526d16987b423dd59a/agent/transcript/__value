\\t\\tcloneStart := time.Now()\\n    66→\\t\\t\\tdir := localClone(t, cacheDir)\\n    67→\\t\\t\\tcloneDur := time.Since(cloneStart)\\n    68→\\n    69→\\t\\t\\tsetupStart := time.Now()\\n    70→\\t\\t\\tt.Chdir(dir)\\n    71→\\t\\t\\tpaths.ClearWorktreeRootCache()\\n    72→\\t\\t\\tsession.ClearGitCommonDirCache()\\n    73→\\n    74→\\t\\t\\tcreateHookPerfSettings(t, dir)\\n    75→\\t\\t\\tseedHookPerfSessions(t, dir, sc.ended, sc.idle, sc.active)\\n    76→\\n    77→\\t\\t\\t// Stage a file change for the commit using git CLI\\n    78→\\t\\t\\t// (avoids go-git worktree.Add which is slow on large repos).\\n    79→\\t\\t\\ttestFile := filepath.Join(dir, \\\"main.go\\\")\\n    80→\\t\\t\\tif err := os.WriteFile(testFile, []byte(\\\"package main\\\\n// user edit\\\\nfunc main() {}\\\\n\\\"), 0o644); err != nil {\\n    81→\\t\\t\\t\\tt.Fatalf(\\\"write: %v\\\", err)\\n    82→\\t\\t\\t}\\n    83→\\t\\t\\tgitRun(t, dir, \\\"add\\\", \\\"main.go\\\")\\n    84→\\n    85→\\t\\t\\tsetupDur := time.Since(setupStart)\\n    86→\\n    87→\\t\\t\\t// --- Time PrepareCommitMsg ---\\n    88→\\t\\t\\t// Simulate TTY path (the expensive one) with commit_linking=always\\n    89→\\t\\t\\t// so it auto-links without blocking on the TTY prompt.\\n    90→\\t\\t\\tt.Setenv(\\\"ENTIRE_TEST_TTY\\\", \\\"1\\\")\\n    91→\\t\\t\\tpaths.ClearWorktreeRootCache()\\n    92→\\t\\t\\tsession.ClearGitCommonDirCache()\\n    93→\\n    94→\\t\\t\\tcommitMsgFile := filepath.Join(dir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n    95→\\t\\t\\tif err := os.WriteFile(commitMsgFile, []byte(\\\"implement feature\\\\n\\\"), 0o644); err != nil {\\n    96→\\t\\t\\t\\tt.Fatalf(\\\"write commit msg: %v\\\", err)\\n    97→\\t\\t\\t}\\n    98→\\n    99→\\t\\t\\ts1 := &ManualCommitStrategy{}\\n   100→\\t\\t\\tprepStart := time.Now()\\n   101→\\t\\t\\tif err := s1.PrepareCommitMsg(context.Background(), commitMsgFile, \\\"message\\\"); err != nil {\\n   102→\\t\\t\\t\\tt.Fatalf(\\\"PrepareCommitMsg: %v\\\", err)\\n   103→