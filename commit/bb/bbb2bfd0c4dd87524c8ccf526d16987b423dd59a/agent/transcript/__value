rogress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01AUQeCuiCpHdSLuPQE8zVpz\",\"type\":\"tool_result\",\"content\":\"   150→\\t// If the file doesn't exist, start with an empty map so we only write commit_linking.\\n   151→\\tvar raw map[string]json.RawMessage\\n   152→\\tdata, readErr := os.ReadFile(localPath) //nolint:gosec // path is from AbsPath\\n   153→\\tif readErr == nil {\\n   154→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   155→\\t\\t\\treturn fmt.Errorf(\\\"parsing local settings: %w\\\", err)\\n   156→\\t\\t}\\n   157→\\t} else if !os.IsNotExist(readErr) {\\n   158→\\t\\treturn fmt.Errorf(\\\"reading local settings: %w\\\", readErr)\\n   159→\\t}\\n   160→\\tif raw == nil {\\n   161→\\t\\traw = make(map[string]json.RawMessage)\\n   162→\\t}\\n   163→\\n   164→\\traw[\\\"commit_linking\\\"] = json.RawMessage(`\\\"` + settings.CommitLinkingAlways + `\\\"`)\\n   165→\\n   166→\\tout, err := json.MarshalIndent(raw, \\\"\\\", \\\"  \\\")\\n   167→\\tif err != nil {\\n   168→\\t\\treturn fmt.Errorf(\\\"marshaling local settings: %w\\\", err)\\n   169→\\t}\\n   170→\\tout = append(out, '\\\\n')\\n   171→\\n   172→\\tif err := os.MkdirAll(filepath.Dir(localPath), 0o750); err != nil {\\n   173→\\t\\treturn fmt.Errorf(\\\"creating settings directory: %w\\\", err)\\n   174→\\t}\\n   175→\\t//nolint:gosec // G306: settings file is config, not secrets; 0o644 is appropriate\\n   176→\\tif err := os.WriteFile(localPath, out, 0o644); err != nil {\\n   177→\\t\\treturn fmt.Errorf(\\\"writing local settings: %w\\\", err)\\n   178→\\t}\\n   179→\\treturn nil\\n   180→}\\n   181→\\n   182→// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   183→// If the message contains only our trailer (no actual user content), strip it\\n   184→// so git will abort the commit due to empty message.\\n   185→\\n   186→func (s *ManualCommitStrategy) CommitMsg(_ context.Context, commitMsgFile string) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   187→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n   188→\\tif err != nil {\\n   189→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   190→\\t}\\n   191→\\n   192→\\tmessage := string(content)\\n   193→\\n   194→\\t// Check if our trailer is present (ParseCheckpoint validates format, so found==true means valid)\\n   195→\\tif _, found := trailers.ParseCheckpoint(message); !found {\\n   196→\\t\\t// No trailer, nothing to do\\n   197→\\t\\treturn nil\\n   198→\\t}\\n   199→\\n   200→\\t// Check if there's any user content (non-comment, non-trailer lines)\\n   201→\\tif !hasUserContent(message) {\\n   202→\\t\\t// No user content - strip the trailer so git aborts\\n   203→\\t\\tmessage = stripCheckpointTrailer(message)\\n   204→\\t\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   205→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   206→\\t\\t}\\n   207→\\t}\\n   208→\\n   209→\\treturn nil\\n   210→}\\n   211→\\n   212→// hasUserContent checks if the message has any content besides comments and our trailer.\\n   213→func hasUserContent(message string) bool {\\n   214→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   215→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   216→\\t\\ttrimmed := strings.TrimSpace(line)\\n   217→\\t\\t// Skip empty lines\\n   218→\\t\\tif trimmed == \\\"\\\" {\\n   219→\\t\\t\\tcontinue\\n   220→\\t\\t}\\n   221→\\t\\t// Skip comment lines\\n   222→\\t\\tif strings.HasPrefix(trimmed, \\\"#\\\") {\\n   223→\\t\\t\\tcontinue\\n   224→\\t\\t}\\n   225→\\t\\t// Skip our trailer line\\n   226→\\t\\tif strings.HasPrefix(trimmed, trailerPrefix) {\\n   227→\\t\\t\\tcontinue\\n   228→\\t\\t}\\n   229→\\t\\t// Found user content\\n   230→\\t\\treturn true\\n   231→\\t}\\n   232→\\treturn false\\n   233→}\\n   234→\\n   235→// stripCheckpointTrailer removes the Entire-Checkpoint trailer line from the message.\\n   236→func stripCheckpointTrailer(message string) string {\\n   237→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   238→\\tvar result []string\\n   239→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   240→\\t\\tif !strings.HasPrefix(strings.TrimSpace(line), trailerPrefix) {\\n   241→\\t\\t\\tresult = append(result, line)\\n   242→\\t\\t}\\n   243→\\t}\\n   244→\\treturn strings.Join(result, \\\"\\\\n\\\")\\n   245→}\\n   246→\\n   247→// isGitSequenceOperation checks if git is currently in the middle of a rebase,\\n   248→// cherry-pick, or revert operation. During these operations, commits are being\\n   249→// replayed and should not be linked to agent sessions.\\n   250→//\\n   251→// Detects:\\n   252→//   - rebase: .git/rebase-merge/ or .git/rebase-apply/ directories\\n   253→//   - cherry-pick: .git/CHERRY_PICK_HEAD file\\n   254→//   - revert: .git/REVERT_HEAD file\\n   255→func isGitSequenceOperation(ctx context.Context) bool {\\n   256→\\t// Get git directory (handles worktrees and relative paths correctly)\\n   257→\\tgitDir, err := GetGitDir(ctx)\\n   258→\\tif err != nil {\\n   259→\\t\\treturn false // Can't determine, assume not in sequence operation\\n   260→\\t}\\n   261→\\n   262→\\t// Check for rebase state directories\\n   263→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-merge\\\")); err == nil {\\n   264→\\t\\treturn true\\n   265→\\t}\\n   266→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-apply\\\")); err == nil {\\n   267→\\t\\treturn true\\n   268→\\t}\\n   269→\\n   270→\\t// Check for cherry-pick and revert state files\\n   271→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"CHERRY_PICK_HEAD\\\")); err == nil {\\n   272→\\t\\treturn true\\n   273→\\t}\\n   274→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"REVERT_HEAD\\\")); err == nil {\\n   275→\\t\\treturn true\\n   276→\\t}\\n   277→\\n   278→\\treturn false\\n   279→}\\n   280→\\n   281→// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   282→// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   283→// Only adds a trailer if there's actually new session content to condense.\\n   284→// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   285→// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   286→// For amended commits, preserves the existing checkpoint ID.\\n   287→//\\n   288→// The source parameter indicates how the commit was initiated:\\n   289→//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   290→//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   291→//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   292→//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   293→//\\n   294→\\n   295→func (s *ManualCommitStrategy) PrepareCommitMsg(ctx context.Context, commitMsgFile string, source string) error {\\n   296→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   297→\\n   298→\\t// Skip during rebase, cherry-pick, or revert operations\\n   299→\\t// These are replaying existing commits and should not be linked to agent sessions\\n   300→\\tif isGitSequenceOperation(ctx) {\\n   301→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n   302→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   303→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   304→\\t\\t)\\n   305→\\t\\treturn nil\\n   306→\\t}\\n   307→\\n   308→\\t// Skip for merge and squash sources\\n   309→\\t// These are auto-generated messages - not from Claude sessions\\n   310→\\tswitch source {\\n   311→\\tcase \\\"merge\\\", \\\"squash\\\":\\n   312→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n   313→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   314→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   315→\\t\\t)\\n   316→\\t\\treturn nil\\n   317→\\t}\\n   318→\\n   319→\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   320→\\tif source == \\\"commit\\\" {\\n   321→\\t\\treturn s.handleAmendCommitMsg(ctx, commitMsgFile)\\n   322→\\t}\\n   323→\\n   324→\\trepo, err := OpenRepository(ctx)\\n   325→\\tif err != nil {\\n   326→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   327→\\t}\\n   328→\\n   329→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   330→\\tif err != nil {\\n   331→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   332→\\t}\\n   333→\\n   334→\\t// Find all active sessions for this worktree\\n   335→\\t// We match by worktree (not BaseCommit) because the user may have made\\n   336→\\t// intermediate commits without entering new prompts, causing HEAD to diverge\\n   337→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   338→\\tif err != nil || len(sessions) == 0 {\\n   339→\\t\\t// No active sessions or error listing - silently skip (hooks must be resilient)\\n   340→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no active sessions\\\",\\n   341→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   342→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   343→\\t\\t)\\n   344→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   345→\\t}\\n   346→\\n   347→\\t// Fast path: when an agent is committing (ACTIVE session + no TTY), skip\\n   348→\\t// content detection and interactive prompts. The agent can't respond to TTY\\n   349→\\t// prompts and the content detection can miss mid-session work (no shadow\"}]},\"uuid\":\"0b89fdc7-0f4a-4eb3-992b-495e4