/ Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\n    33→func (s *ManualCommitStrategy) listCheckpoints(ctx context.Context) ([]CheckpointInfo, error) {\\n    34→\\tstore, err := s.getCheckpointStore()\\n    35→\\tif err != nil {\\n    36→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    37→\\t}\\n    38→\\n    39→\\tcommitted, err := store.ListCommitted(ctx)\\n    40→\\tif err != nil {\\n    41→\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n    42→\\t}\\n    43→\\n    44→\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n    45→\\tresult := make([]CheckpointInfo, 0, len(committed))\\n    46→\\tfor _, c := range committed {\\n    47→\\t\\tresult = append(result, CheckpointInfo{\\n    48→\\t\\t\\tCheckpointID:     c.CheckpointID,\\n    49→\\t\\t\\tSessionID:        c.SessionID,\\n    50→\\t\\t\\tCreatedAt:        c.CreatedAt,\\n    51→\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n    52→\\t\\t\\tFilesTouched:     c.FilesTouched,\\n    53→\\t\\t\\tAgent:            c.Agent,\\n    54→\\t\\t\\tIsTask:           c.IsTask,\\n    55→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    56→\\t\\t\\tSessionCount:     c.SessionCount,\\n    57→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    58→\\t\\t})\\n    59→\\t}\\n    60→\\n    61→\\treturn result, nil\\n    62→}\\n    63→\\n    64→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    65→func (s *ManualCommitStrategy) getCheckpointsForSession(ctx context.Context, sessionID string) ([]CheckpointInfo, error) {\\n    66→\\tall, err := s.listCheckpoints(ctx)\\n    67→\\tif err != nil {\\n    68→\\t\\treturn nil, err\\n    69→\\t}\\n    70→\\n    71→\\tvar result []CheckpointInfo\\n    72→\\tfor _, cp := range all {\\n    73→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    74→\\t\\t\\tresult = append(result, cp)\\n    75→\\t\\t}\\n    76→\\t}\\n    77→\\n    78→\\tif len(result) == 0 {\\n    79→\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n    80→\\t}\\n    81→\\n    82→\\treturn result, nil\\n    83→}\\n    84→\\n    85→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    86→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    87→func (s *ManualCommitStrategy) getCheckpointLog(ctx context.Context, checkpointID id.CheckpointID) ([]byte, error) {\\n    88→\\tstore, err := s.getCheckpointStore()\\n    89→\\tif err != nil {\\n    90→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    91→\\t}\\n    92→\\n    93→\\tcontent, err := store.ReadLatestSessionContent(ctx, checkpointID)\\n    94→\\tif err != nil {\\n    95→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    96→\\t}\\n    97→\\tif content == nil {\\n    98→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n    99→\\t}\\n   100→\\tif len(content.Transcript) == 0 {\\n   101→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   102→\\t}\\n   103→\\n   104→\\treturn content.Transcript, nil\\n   105→}\\n   106→\\n   107→// condenseOpts provides pre-resolved git objects to avoid redundant reads.\\n   108→type condenseOpts struct {\\n   109→\\tshadowRef *plumbing.Reference // Pre-resolved shadow branch ref (nil = resolve from repo)\\n   110→\\theadTree  *object.Tree        // Pre-resolved HEAD tree (passed through to calculateSessionAttributions)\\n   111→}\\n   112→\\n   113→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   114→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   115→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   116→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   117→//\\n   118→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   119→// In this case, data is extracted from the live transcript instead.\\n   120→func (s *ManualCommitStrategy) CondenseSession(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}, opts ...condenseOpts) (*CondenseResult, error) {\\n   121→\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   122→\\tvar o condenseOpts\\n   123→\\tif len(opts) > 0 {\\n   124→\\t\\to = opts[0]\\n   125→\\t}\\n   126→\\n   127→\\t// Get shadow branch — use pre-resolved ref if available, otherwise resolve from repo.\\n   128→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   129→\\tref := o.shadowRef\\n   130→\\tvar hasShadowBranch bool\\n   131→\\tif ref != nil {\\n   132→\\t\\thasShadowBranch = true\\n   133→\\t} else {\\n   134→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   135→\\t\\tvar err error\\n   136→\\t\\tref, err = repo.Reference(refName, true)\\n   137→\\t\\thasShadowBranch = err == nil\\n   138→\\t}\\n   139→\\n   140→\\tvar sessionData *ExtractedSessionData\\n   141→\\tif hasShadowBranch {\\n   142→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   143→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   144→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   145→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   146→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   147→\\t\\t// last turn had no code changes).\\n   148→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   149→\\t\\tvar extractErr error\\n   150→\\t\\tsessionData, extractErr = s.extractSessionData(ctx, repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n   151→\\t\\tif extractErr != nil {\\n   152→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", extractErr)\\n   153→\\t\\t}\\n   154→\\t} else {\\n   155→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   156→\\t\\t// Extract data directly from live transcript.\\n   157→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   158→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   159→\\t\\t}\\n   160→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   161→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   162→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   163→\\t\\tif state.Phase.IsActive() {\\n   164→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, state.TranscriptPath)\\n   165→\\t\\t}\\n   166→\\t\\tvar extractErr error\\n   167→\\t\\tsessionData, extractErr = s.extractSessionDataFromLiveTranscript(ctx, state)\\n   168→\\t\\tif extractErr != nil {\\n   169→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", extractErr)\\n   170→\\t\\t}\\n   171→\\t}\\n   172→\\n   173→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   174→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   175→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   176→\\tif len(committedFiles) > 0 {\\n   177→\\t\\t// Track if we had files before filtering to distinguish between:\\n   178→\\t\\t// - Session had files but none were committed (don't fallback)\\n   179→\\t\\t// - Session had no