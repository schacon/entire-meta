s) > 0 {\\n   319→\\t\\to = opts[0]\\n   320→\\t}\\n   321→\\n   322→\\theadTree := o.headTree\\n   323→\\tif headTree == nil {\\n   324→\\t\\theadRef, headErr := repo.Head()\\n   325→\\t\\tif headErr != nil {\\n   326→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   327→\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   328→\\t\\t\\treturn nil\\n   329→\\t\\t}\\n   330→\\n   331→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   332→\\t\\tif commitErr != nil {\\n   333→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   334→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   335→\\t\\t\\treturn nil\\n   336→\\t\\t}\\n   337→\\n   338→\\t\\tvar treeErr error\\n   339→\\t\\theadTree, treeErr = headCommit.Tree()\\n   340→\\t\\tif treeErr != nil {\\n   341→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   342→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   343→\\t\\t\\treturn nil\\n   344→\\t\\t}\\n   345→\\t}\\n   346→\\n   347→\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n   348→\\tshadowTree := o.shadowTree\\n   349→\\tif shadowTree == nil {\\n   350→\\t\\tif shadowRef != nil {\\n   351→\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   352→\\t\\t\\tif shadowErr != nil {\\n   353→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   354→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   355→\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   356→\\t\\t\\t\\treturn nil\\n   357→\\t\\t\\t}\\n   358→\\t\\t\\tvar shadowTreeErr error\\n   359→\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   360→\\t\\t\\tif shadowTreeErr != nil {\\n   361→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   362→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   363→\\t\\t\\t\\treturn nil\\n   364→\\t\\t\\t}\\n   365→\\t\\t} else {\\n   366→\\t\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   367→\\t\\t\\t// because the agent's work is the commit itself.\\n   368→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   369→\\t\\t\\tshadowTree = headTree\\n   370→\\t\\t}\\n   371→\\t}\\n   372→\\n   373→\\t// Get base tree (state before session started)\\n   374→\\tvar baseTree *object.Tree\\n   375→\\tattrBase := state.AttributionBaseCommit\\n   376→\\tif attrBase == \\\"\\\" {\\n   377→\\t\\tattrBase = state.BaseCommit // backward compat\\n   378→\\t}\\n   379→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   380→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   381→\\t\\t\\tbaseTree = tree\\n   382→\\t\\t} else {\\n   383→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   384→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   385→\\t\\t}\\n   386→\\t} else {\\n   387→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   388→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   389→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   390→\\t}\\n   391→\\n   392→\\t// Log accumulated prompt attributions for debugging\\n   393→\\tvar totalUserAdded, totalUserRemoved int\\n   394→\\tfor i, pa := range state.PromptAttributions {\\n   395→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   396→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   397→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   398→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   399→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   400→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   401→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   402→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   403→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   404→\\t}\\n   405→\\n   406→\\tattribution := CalculateAttributionWithAccumulated(\\n   407→\\t\\tctx,\\n   408→\\t\\tbaseTree,\\n   409→\\t\\tshadowTree,\\n   410→\\t\\theadTree,\\n   411→\\t\\tsessionData.FilesTouched,\\n   412→\\t\\tstate.PromptAttributions,\\n   413→\\t)\\n   414→\\n   415→\\tif attribution != nil {\\n   416→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   417→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   418→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   419→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   420→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   421→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   422→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   423→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   424→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   425→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   426→\\t}\\n   427→\\n   428→\\treturn attribution\\n   429→}\\n   430→\\n   431→// extractSessionData extracts session data from the shadow branch.\\n   432→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   433→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   434→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   435→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   436→// continued growing — the shadow branch copy would be stale.\\n   437→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   438→func (s *ManualCommitStrategy) extractSessionData(ctx context.Context, repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n   439→\\tag, _ := agent.GetByAgentType(agentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   440→\\tcommit, err := repo.CommitObject(shadowRef)\\n   441→\\tif err != nil {\\n   442→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   443→\\t}\\n   444→\\n   445→\\ttree, err := commit.Tree()\\n   446→\\tif err != nil {\\n   447→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   448→\\t}\\n   449→\\n   450→\\tdata := &ExtractedSessionData{}\\n   451→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   452→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   453→\\n   454→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   455→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   456→\\t// (SaveStep is only called when there are file modifications).\\n   457→\\tvar fullTranscript string\\n   458→\\tif liveTranscriptPath != \\\"\\\" {\\n   459→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   460→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   461→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   462→\\t\\tif isActive {\\n   463→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, liveTranscriptPath)\\n   464→\\t\\t}\\n   465→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   466→\\t\\t\\tfullTranscript = string(liveData)\\n   467→\\t\\t}\\n   468→\\t}\\n   469→\\tif fullTranscript == \\\"\\\" {\\n   470→\\t\\t// Fall back to shadow branch copy\\n   471→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   472→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   473→\\t\\t\\t\\tfullTranscript = content\\n   474→\\t\\t\\t}\\n   475→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   476→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   477→\\t\\t\\t\\tfullTranscript = content\\n   478→\\t\\t\\t}\\n   479→\\t\\t}\\n   480→\\t}\\n   481→\\n   482→\\t// Process transcript based on agent type\\n   483→\\tif fullTranscript != \\\"\\\" {\\n   484→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   485→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   486→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   487→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   488→\\t}\\n   489→\\n   490→\\t// Use tracked files from session state (not all files in tree)\\n   491→\\tdata.FilesTouched = filesTouched\\n   492→\\n   493→\\t// Calculate token usage from the extracted transcript portion\\n   494→\\tif len(data.Transcript) > 0 {\\n   495→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, checkpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   496→\\t}\\n   497→\\n   498→\\treturn data, nil\\n   499→}\\n   500→\\n   501→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   502→// This is used for mid-session commits where no shadow branch exists yet.\\n   503→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(ctx context.Context, state *SessionState) (*ExtractedSessionData, error) {\\n   504→\\tdata := &ExtractedSessionData{}\\n   505→\\n   506→\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   507→\\n   508→\\t// Read the live transcript\\n   509→\\tif state.TranscriptPath == \\\"\\\" {\\n   510→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   511→\\t}\\n   512→\\n   513→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   514→\\tif err != nil {\\n   515→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   516→\\t}\\n   517→\\n   518→\\tif len(liveData) == 0 {\\n   519→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   520→\\t}\\n   521→\\n   522→\\tfullTranscript := string(liveData)\\n   523→\\tdata.Transcript = liveData\\n   524→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   525→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   526→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   527→\\n   528→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   529→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   530→\\tif len(state.FilesTouched) > 0 {\\n   531→\\t\\tdata.FilesTouched = state.FilesTouched\\n   532→\\t} else {\\n   533→\\t\\t// Use the shared helper which includes subagent transcripts\\n   534→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(ctx, state, state.CheckpointTranscriptStart)\\n   535→\\t}\\n   536→\\n   537→\\t// Calculate token usage from the extracted transcript portion\\n   538→\\tif len(data.Transcript) > 0 {\\n   539→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, state.CheckpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   540→\\t}\\n   541→\\n   542→\\treturn data, nil\\n   543→}\\n   544→\\n   545→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   546→// For Claude Code and JSONL-based agents, this counts lines.\\n   547→// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n   548→// Returns 0 if the content is empty or malformed.\\n   549→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   550→\\tif content == \\\"\\\" {\\n   551→\\t\\treturn 0\\n   552→\\t}\\n   553→\\n   554→\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n   555→\\tif agentType == agent.AgentTypeOpenCode {\\n   556→\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n   557→\\t\\tif err == nil && session != nil {\\n   558→\\t\\t\\treturn len(session.Messages)\\n   559→\\t\\t}\\n   560→\\t\\treturn 0\\n   561→\\t}\\n   562→\\n   563→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   564→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   565→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   566→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   567→\\t\\t\\treturn len(transcript.Messages)\\n   568→\\t\\t}\\n   569→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   570→\\t\\tif agentType == agent.AgentTypeGemini {\\n   571→\\t\\t\\treturn 0\\n   572→\\t\\t}\\n   573→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   574→\\t}\\n   575→\\n   576→\\t// Claude Code and other JSONL-based agents\\n   577→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   578→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   579→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   580→\\t\\tallLines = allLines[:len(allLines)-1]\\n   581→\\t}\\n   582→\\treturn len(allLines)\\n   583→}\\n   584→\\n   585→// extractUserPrompts extracts all user prompts from transcript content.\\n   586→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   587→func extractUserPrompts(agentType agent.AgentType, content string) []string {\\n   588→\\tif content == \\\"\\\" {\\n   589→\\t\\treturn nil\\n   590→\\t}\\n   591→\\n   592→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   593→\\tif agentType == agent.AgentTypeOpenCode {\\n   594→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   595→\\t\\tif err == nil && len(prompts) > 0 {\\n   596→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   597→\\t\\t\\tfor _, prompt := range prompts {\\n   598→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   599→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   600→\\t\\t\\t\\t}\\n   601→\\t\\t\\t}\\n   602→\\t\\t\\treturn cleaned\\n   603→\\t\\t}\\n   604→\\t\\treturn nil\\n   605→\\t}\\n   606→\\n   607→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   608→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   609→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   610→\\t\\tif err == nil && len(prompts) > 0 {\\n   611→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   612→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   613→\\t\\t\\tfor _, prompt := range prompts {\\n   614→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   615→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   616→\\t\\t\\t\\t}\\n   617→\\t\\t\\t}\\n   618→\\t\\t\\treturn cleaned\\n   619→\\t\\t}\\n   620→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   621→\\t\\tif agentType == agent.AgentTypeGemini {\\n   622→\\t\\t\\treturn nil\\n   623→\\t\\t}\\n   624→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   625→\\t}\\n   626→\\n   627→\\t// Claude Code and other JSONL-based agents\\n   628→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   629→}\\n   630→\\n   631→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   632→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   633→func extractUserPromptsFromLines(lines []string) []string {\\n   634→\\tvar prompts []string\\n   635→\\tfor _, line := range lines {\\n   636→\\t\\tline = strings.TrimSpace(line)\\n   637→\\t\\tif line == \\\"\\\" {\\n   638→\\t\\t\\tcontinue\\n   639→\\t\\t}\\n   640→\\n   641→\\t\\tvar entry map[string]interface{}\\n   642→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   643→\\t\\t\\tcontinue\\n   644→\\t\\t}\\n   645→\\n   646→\\t\\t// Check for user message:\\n   647→\\t\\t// - Claude Code uses \\\"type\\\": \\\"human\\\" or \\\"type\\\": \\\"user\\\"\\n   648→\\t\\t// - Cursor uses \\\"role\\\": \\\"user\\\"\\n   649→\\t\\tmsgType, _ := entry[\\\"type\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   650→\\t\\tmsgRole, _ := entry[\\\"role\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   651→\\t\\tisUser := msgType == \\\"human\\\" || msgType == \\\"user\\\" || msgRole == \\\"user\\\"\\n   652→\\t\\tif !isUser {\\n   653→\\t\\t\\tcontinue\\n   654→\\t\\t}\\n   655→\\n   656→\\t\\t// Extract message content\\n   657→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   658→\\t\\tif !ok {\\n   659→\\t\\t\\tcontinue\\n   660→\\t\\t}\\n   661→\\n   662→\\t\\t// Handle string content\\n   663→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   664→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   665→\\t\\t\\tif cleaned != \\\"\\\" {\\n   666→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   667→\\t\\t\\t}\\n   668→\\t\\t\\tcontinue\\n   669→\\t\\t}\\n   670→\\n   671→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   672→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   673→\\t\\t\\tvar texts []string\\n   674→\\t\\t\\tfor _, item := range arr {\\n   675→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   676→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   677→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   678→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   679→\\t\\t\\t\\t\\t\\t}\\n   680→\\t\\t\\t\\t\\t}\\n   681→\\t\\t\\t\\t}\\n   682→\\t\\t\\t}\\n   683→\\t\\t\\tif len(texts) > 0 {\\n   684→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   685→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   686→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   687→\\t\\t\\t\\t}\\n   688→\\t\\t\\t}\\n   689→\\t\\t}\\n   690→\\t}\\n   691→\\treturn prompts\\n   692→}\\n   693→\\n   694→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   695→func generateContextFromPrompts(prompts []string) []byte {\\n   696→\\tif len(prompts) == 0 {\\n   697→\\t\\treturn nil\\n   698→\\t}\\n   699→\\n   700→\\tvar buf strings.Builder\\n   701→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   702→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   703→\\n   704→\\tfor i, prompt := range prompts {\\n   705→\\t\\t// Truncate very long prompts for readability.\\n   706→\\t\\t// Use rune-based truncation to avoid splitting multi-byte UTF-8 characters (e.g. CJK).\\n   707→\\t\\tconst maxDisplayPromptRunes = 500\\n   708→\\t\\tdisplayPrompt := stringutil.TruncateRunes(prompt, maxDisplayPromptRunes, \\\"...\\\")\\n   709→\\t\\tfmt.Fprintf(&buf, \\\"### Prompt %d\\\\n\\\\n\\\", i+1)\\n   710→\\t\\tbuf.WriteString(displayPrompt)\\n   711→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   712→\\t}\\n   713→\\n   714→\\treturn []byte(buf.String())\\n   715→}\\n   716→\\n   717→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   718→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   719→func (s *ManualCommitStrategy) CondenseSessionByID(ctx context.Context, sessionID string) error {\\n   720→\\tlogCtx := logging.WithComponent(ctx, \\\"condense-by-id\\\")\\n   721→\\n   722→\\t// Load session state\\n   723→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   724→\\tif err != nil {\\n   725→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   726→\\t}\\n   727→\\tif state == nil {\\n   728→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   729→\\t}\\n   730→\\n   731→\\t// Open repository\\n   732→\\trepo, err := OpenRepository(ctx)\\n   733→\\tif err != nil {\\n   734→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   735→\\t}\\n   736→\\n   737→\\t// Generate a checkpoint ID\\n   738→\\tcheckpointID, err := id.Generate()\\n   739→\\tif err != nil {\\n   740→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   741→\\t}\\n   742→\\n   743→\\t// Check if shadow branch exists (required for condensation)\\n   744→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   745→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   746→\\t_, refErr := repo.Reference(refName, true)\\n   747→\\thasShadowBranch := refErr == nil\\n   748→\\n   749→\\tif !hasShadowBranch {\\n   750→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   751→\\t\\t// Just clean up the state file.\\n   752→\\t\\tlogging.Info(logCtx, \\\"no shadow branch for session, clearing state only\\\",\\n   753→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   754→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   755→\\t\\t)\\n   756→\\t\\tif err := s.clearSessionState(ctx, sessionID); err != nil {\\n   757→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   758→\\t\\t}\\n   759→\\t\\treturn nil\\n   760→\\t}\\n   761→\\n   762→\\t// Condense the session\\n   763→\\tresult, err := s.CondenseSession(ctx, repo, checkpointID, state, nil)\\n   764→\\tif err != nil {\\n   765→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   766→\\t}\\n   767→\\n   768→\\tlogging.Info(logCtx, \\\"session condensed by ID\\\",\\n   769→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   770→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   771→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   772→\\t)\\n   773→\\n   774→\\t// Update session state: reset step count and transition to idle\\n   775→\\tstate.StepCount = 0\\n   776→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   777→\\tstate.Phase = session.PhaseIdle\\n   778→\\tstate.LastCheckpointID = checkpointID\\n   779→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   780→\\tstate.PromptAttributions = nil\\n   781→\\tstate.PendingPromptAttribution = nil\\n   782→\\n   783→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   784→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   785→\\t}\\n   786→\\n   787→\\t// Clean up shadow branch if no other sessions need it\\n   788→\\tif err := s.cleanupShadowBranchIfUnused(ctx, repo, shadowBranchName, sessionID); err != nil {\\n   789→\\t\\tlogging.Warn(logCtx, \\\"failed to clean up shadow branch\\\",\\n   790→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   791→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   792→\\t\\t)\\n   793→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   794→\\t}\\n   795→\\n   796→\\treturn nil\\n   797→}\\n   798→\\n   799→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   800→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(ctx context.Co