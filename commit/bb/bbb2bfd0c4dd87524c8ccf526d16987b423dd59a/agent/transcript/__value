 a new git hook context with logging initialized.\\n    28→func newGitHookContext(ctx context.Context, hookName string) *gitHookContext {\\n    29→\\tg := &gitHookContext{\\n    30→\\t\\thookName: hookName,\\n    31→\\t\\tstart:    time.Now(),\\n    32→\\t\\tctx:      logging.WithComponent(ctx, \\\"hooks\\\"),\\n    33→\\t}\\n    34→\\tg.strategy = GetStrategy(ctx)\\n    35→\\treturn g\\n    36→}\\n    37→\\n    38→// logInvoked logs that the hook was invoked.\\n    39→func (g *gitHookContext) logInvoked(extraAttrs ...any) {\\n    40→\\tattrs := []any{\\n    41→\\t\\tslog.String(\\\"hook\\\", g.hookName),\\n    42→\\t\\tslog.String(\\\"hook_type\\\", \\\"git\\\"),\\n    43→\\t\\tslog.String(\\\"strategy\\\", strategy.StrategyNameManualCommit),\\n    44→\\t}\\n    45→\\tlogging.Debug(g.ctx, g.hookName+\\\" hook invoked\\\", append(attrs, extraAttrs...)...)\\n    46→}\\n    47→\\n    48→// logCompleted logs hook completion with duration at DEBUG level.\\n    49→// The actual work logging (checkpoint operations) happens at INFO level in the handlers.\\n    50→func (g *gitHookContext) logCompleted(err error, extraAttrs ...any) {\\n    51→\\tattrs := []any{\\n    52→\\t\\tslog.String(\\\"hook\\\", g.hookName),\\n    53→\\t\\tslog.String(\\\"hook_type\\\", \\\"git\\\"),\\n    54→\\t\\tslog.String(\\\"strategy\\\", strategy.StrategyNameManualCommit),\\n    55→\\t\\tslog.Bool(\\\"success\\\", err == nil),\\n    56→\\t}\\n    57→\\tlogging.LogDuration(g.ctx, slog.LevelDebug, g.hookName+\\\" hook completed\\\", g.start, append(attrs, extraAttrs...)...)\\n    58→}\\n    59→\\n    60→// initHookLogging initializes logging for hooks by finding the most recent session.\\n    61→// Returns a cleanup function that should be deferred.\\n    62→// If Entire is not set up or disabled, returns a no-op to avoid creating files.\\n    63→func initHookLogging(ctx context.Context) func() {\\n    64→\\t// Don't create any files if Entire is not set up or disabled.\\n    65→\\t// This is chec