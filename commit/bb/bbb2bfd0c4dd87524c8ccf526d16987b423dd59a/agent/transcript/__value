nts using a clone of the entireio/cli repo\\n// so that go-git operates on a realistic object database, packed refs, and\\n// working tree.\\n//\\n// Prerequisites:\\n//   - GitHub access (gh auth login) for cloning the private repo\\n//\\n// Run: go test -v -run TestCommitHookPerformance -tags hookperf -timeout 10m ./cmd/entire/cli/strategy/\\nfunc TestCommitHookPerformance(t *testing.T) {\\n\\t// Clone once, reuse across scenarios via cheap local clones.\\n\\tcacheDir := cloneSourceRepo(t)\\n\\n\\tscenarios := []struct {\\n\\t\\tname   string\\n\\t\\tended  int\\n\\t\\tidle   int\\n\\t\\tactive int\\n\\t}{\\n\\t\\t{\\\"10sessions\\\", 8, 1, 1},\\n\\t\\t{\\\"50sessions\\\", 43, 6, 1},\\n\\t\\t{\\\"100sessions\\\", 88, 11, 1},\\n\\t\\t{\\\"200sessions\\\", 180, 19, 1},\\n\\t}\\n\\n\\ttype result struct {\\n\\t\\tname       string\\n\\t\\ttotal      int\\n\\t\\tclone      time.Duration\\n\\t\\tsetup      time.Duration\\n\\t\\tprepare    time.Duration\\n\\t\\tpostCommit time.Duration\\n\\t}\\n\\tresults := make([]result, 0, len(scenarios))\\n\\n\\tfor _, sc := range scenarios {\\n\\t\\tt.Run(sc.name, func(t *testing.T) {\\n\\t\\t\\ttotalSessions := sc.ended + sc.idle + sc.active\\n\\n\\t\\t\\t// Local clone from cached source (copies .git objects via hardlinks).\\n\\t\\t\\tcloneStart := time.Now()\\n\\t\\t\\tdir := localClone(t, cacheDir)\\n\\t\\t\\tcloneDur := time.Since(cloneStart)\\n\\n\\t\\t\\tsetupStart := time.Now()\\n\\t\\t\\tt.Chdir(dir)\\n\\t\\t\\tpaths.ClearWorktreeRootCache()\\n\\t\\t\\tsession.ClearGitCommonDirCache()\\n\\n\\t\\t\\tcreateHookPerfSettings(t, dir)\\n\\t\\t\\tseedHookPerfSessions(t, dir, sc.ended, sc.idle, sc.active)\\n\\n\\t\\t\\t// Stage a file change for the commit using git CLI\\n\\t\\t\\t// (avoids go-git worktree.Add which is slow on large repos).\\n\\t\\t\\ttestFile := filepath.Join(dir, \\\"main.go\\\")\\n\\t\\t\\tif err := os.WriteFile(testFile, []byte(\\\"package main\\\\n// user edit\\\\nfunc main() {}\\\\n\\\"), 0o644); err != nil