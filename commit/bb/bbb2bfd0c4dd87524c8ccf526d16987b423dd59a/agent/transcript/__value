ate) string {\\n  1844→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n  1845→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1846→\\tref, err := repo.Reference(refName, true)\\n  1847→\\tif err != nil {\\n  1848→\\t\\treturn \\\"\\\"\\n  1849→\\t}\\n  1850→\\n  1851→\\t// Extract session data to get prompts for commit message generation\\n  1852→\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini)\\n  1853→\\t// Pass 0 for checkpointTranscriptStart since we're extracting all prompts, not calculating token usage\\n  1854→\\tsessionData, err := s.extractSessionData(ctx, repo, ref.Hash(), state.SessionID, nil, state.AgentType, \\\"\\\", 0, state.Phase.IsActive())\\n  1855→\\tif err != nil || len(sessionData.Prompts) == 0 {\\n  1856→\\t\\treturn \\\"\\\"\\n  1857→\\t}\\n  1858→\\n  1859→\\t// Return the last prompt (most recent work before commit)\\n  1860→\\treturn sessionData.Prompts[len(sessionData.Prompts)-1]\\n  1861→}\\n  1862→\\n  1863→// HandleTurnEnd dispatches strategy-specific actions emitted when an agent turn ends.\\n  1864→// The primary job is to finalize all checkpoints from this turn with the full transcript.\\n  1865→//\\n  1866→// During a turn, PostCommit writes provisional transcript data (whatever was available\\n  1867→// at commit time). HandleTurnEnd replaces that with the complete session transcript\\n  1868→// (from prompt to stop event), ensuring every checkpoint has the full context.\\n  1869→//\\n  1870→\\n  1871→func (s *ManualCommitStrategy) HandleTurnEnd(ctx context.Context, state *SessionState) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n  1872→\\t// Finalize all checkpoints from this turn with the full transcript.\\n  1873→\\t//\\n  1874→\\t// IMPORTANT: This is best-effort - errors are logged but don't fail the hook.\\n  1875→\\t// Failing here would prevent session cleanup and could 