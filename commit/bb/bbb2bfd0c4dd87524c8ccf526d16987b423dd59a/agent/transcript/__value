27→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    28→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    29→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    30→\\t\\\"github.com/go-git/go-git/v5/utils/binary\\\"\\n    31→)\\n    32→\\n    33→// hasTTY checks if /dev/tty is available for interactive prompts.\\n    34→// Returns false when running as an agent subprocess (no controlling terminal).\\n    35→//\\n    36→// In test environments, ENTIRE_TEST_TTY overrides the real check:\\n    37→//   - ENTIRE_TEST_TTY=1 → simulate human (TTY available)\\n    38→//   - ENTIRE_TEST_TTY=0 → simulate agent (no TTY)\\n    39→func hasTTY() bool {\\n    40→\\tif v := os.Getenv(\\\"ENTIRE_TEST_TTY\\\"); v != \\\"\\\" {\\n    41→\\t\\treturn v == \\\"1\\\"\\n    42→\\t}\\n    43→\\n    44→\\t// Gemini CLI sets GEMINI_CLI=1 when running shell commands.\\n    45→\\t// Gemini subprocesses may have access to the user's TTY, but they can't\\n    46→\\t// actually respond to interactive prompts. Treat them as non-TTY.\\n    47→\\t// See: https://geminicli.com/docs/tools/shell/\\n    48→\\tif os.Getenv(\\\"GEMINI_CLI\\\") != \\\"\\\" {\\n    49→\\t\\treturn false\\n    50→\\t}\\n    51→\\n    52→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n    53→\\tif err != nil {\\n    54→\\t\\treturn false\\n    55→\\t}\\n    56→\\t_ = tty.Close()\\n    57→\\treturn true\\n    58→}\\n    59→\\n    60→// ttyConfirmResult represents the outcome of a TTY confirmation prompt.\\n    61→type ttyConfirmResult int\\n    62→\\n    63→const (\\n    64→\\tttyConfirmYes    ttyConfirmResult = iota // User confirmed (y/yes/enter with default=yes)\\n    65→\\tttyConfirmNo                             // User declined (n/no)\\n    66→\\tttyConfirmAlways                         // User chose \\\"always\\\" (a/always)\\n    67→)\\n    68→\\n    69→// askConfirmTTY prompts the user for a yes/no/always confirmation via /dev/tty.\\n    70→// This works even when stdin is redirected (e.g., git commit -m).\\n    71→// Returns ttyConfirmYes, ttyConfirmNo, or ttyConfirmAlways.\\n    72→// If TTY is unavailable, returns ttyConfirmYes when defaultYes is true, ttyConfirmNo otherwise.\\n    73→// header is displayed as the first line (e.g., \\\"Entire: Active Claude Code session\\\").\\n    74→// detail lines are displayed indented below the header.\\n    75→func askConfirmTTY(header string, details []string, prompt string, defaultYes bool) ttyConfirmResult {\\n    76→\\tdefaultResult := ttyConfirmNo\\n    77→\\tif defaultYes {\\n    78→\\t\\tdefaultResult = ttyConfirmYes\\n    79→\\t}\\n    80→\\n    81→\\t// In test mode, don't try to interact with the real TTY — just use the default.\\n    82→\\t// ENTIRE_TEST_TTY=1 simulates \\\"a human is present\\\" for the hasTTY() check\\n    83→\\t// but we can't actually read from the TTY in tests.\\n    84→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n    85→\\t\\treturn defaultResult\\n    86→\\t}\\n    87→\\n    88→\\t// Gemini CLI sets GEMINI_CLI=1 when running shell commands (including git commit).\\n    89→\\t// The agent can't respond to TTY prompts, so use the default to avoid hanging.\\n    90→\\t// See: https://geminicli.com/docs/tools/shell/\\n    91→\\tif os.Getenv(\\\"GEMINI_CLI\\\") != \\\"\\\" {\\n    92→\\t\\treturn defaultResult\\n    93→\\t}\\n    94→\\n    95→\\t// Open /dev/tty for both reading and writing\\n    96→\\t// This is the controlling terminal, which works even when stdin/stderr are redirected\\n    97→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n    98→\\tif err != nil {\\n    99→\\t\\t// Can't open TTY (e.g., running in CI), use default\\n   100→\\t\\treturn defaultResult\\n   101→\\t}\\n   102→\\tdefer tty.Close()\\n   103→\\n   104→\\t// Write to tty directly, not stderr, since git hooks may redirect stderr to /dev/null\\n   105→\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", header)\\n   106→\\tfor _, line := range details {\\n   107→\\t\\tfmt.Fprintf(tty, \\\"  %s\\\\n\\\", line)\\n   108→\\t}\\n   109→\\n   110→\\t// Show prompt with option descriptions\\n   111→\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", prompt)\\n   112→\\tif defaultYes {\\n   113→\\t\\tfmt.Fprint(tty, \\\"  [Y]es / [n]o / [a]lways (remember my choice): \\\")\\n   114→\\t} else {\\n   115→\\t\\tfmt.Fprint(tty, \\\"  [y]es / [N]o / [a]lways (remember my choice): \\\")\\n   116→\\t}\\n   117→\\n   118→\\t// Read response\\n   119→\\treader := bufio.NewReader(tty)\\n   120→\\tresponse, err := reader.ReadString('\\\\n')\\n   121→\\tif err != nil {\\n   122→\\t\\treturn defaultResult\\n   123→\\t}\\n   124→\\n   125→\\tresponse = strings.TrimSpace(strings.ToLower(response))\\n   126→\\tswitch response {\\n   127→\\tcase \\\"y\\\", \\\"yes\\\":\\n   128→\\t\\treturn ttyConfirmYes\\n   129→\\tcase \\\"n\\\", \\\"no\\\":\\n   130→\\t\\treturn ttyConfirmNo\\n   131→\\tcase \\\"a\\\", \\\"always\\\":\\n   132→\\t\\treturn ttyConfirmAlways\\n   133→\\tdefault:\\n   134→\\t\\t// Empty or invalid input - use default\\n   135→\\t\\treturn defaultResult\\n   136→\\t}\\n   137→}\\n   138→\\n   139→// saveCommitLinkingAlways persists commit_linking = \\\"always\\\" to settings.local.json.\\n   140→// Uses raw JSON merge to set only the commit_linking field without affecting other\\n   141→// fields. This avoids writing unintended defaults (e.g., enabled: true) when the\\n   142→// local settings file doesn't exist yet.\\n   143→func saveCommitLinkingAlways(ctx context.Context) error {\\n   144→\\tlocalPath, err := paths.AbsPath(ctx, settings.EntireSettingsLocalFile)\\n   145→\\tif err != nil {\\n   146→\\t\\treturn fmt.Errorf(\\\"resolving local settings path: %w\\\", err)\\n   147→\\t}\\n   148→\\n   149→\\t// Read existing file as raw JSON map to preserve all existing fields.\\n   150→\\t// If the file doesn't exist, start with an empty map so we only write commit_linking.\\n   151→\\tvar raw map[string]json.RawMessage\\n   152→\\tdata, readErr := os.ReadFile(localPath) //nolint:gosec // path is from AbsPath\\n   153→\\tif readErr == nil {\\n   154→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   155→\\t\\t\\treturn fmt.Errorf(\\\"parsing local settings: %w\\\", err)\\n   156→\\t\\t}\\n   157→\\t} else if !os.IsNotExist(readErr) {\\n   158→\\t\\treturn fmt.Errorf(\\\"reading local settings: %w\\\", readErr)\\n   159→\\t}\\n   160→\\tif raw == nil {\\n   161→\\t\\traw = make(map[string]json.RawMessage)\\n   162→\\t}\\n   163→\\n   164→\\traw[\\\"commit_linking\\\"] = json.RawMessage(`\\\"` + settings.CommitLinkingAlways + `\\\"`)\\n   165→\\n   166→\\tout, err := json.MarshalIndent(raw, \\\"\\\", \\\"  \\\")\\n   167→\\tif err != nil {\\n   168→\\t\\treturn fmt.Errorf(\\\"marshaling local settings: %w\\\", err)\\n   169→\\t}\\n   170→\\tout = append(out, '\\\\n')\\n   171→\\n   172→\\tif err := os.MkdirAll(filepath.Dir(localPath), 0o750); err != nil {\\n   173→\\t\\treturn fmt.Errorf(\\\"creating settings directory: %w\\\", err)\\n   174→\\t}\\n   175→\\t//nolint:gosec // G306: settings file is config, not secrets; 0o644 is appropriate\\n   176→\\tif err := os.WriteFile(localPath, out, 0o644); err != nil {\\n   177→\\t\\treturn fmt.Errorf(\\\"writing local settings: %w\\\", err)\\n   178→\\t}\\n   179→\\treturn nil\\n   180→}\\n   181→\\n   182→// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   183→// If the message contains only our trailer (no actual user content), strip it\\n   184→// so git will abort the commit due to empty message.\\n   185→\\n   186→func (s *ManualCommitStrategy) CommitMsg(_ context.Context, commitMsgFile string) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   187→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n   188→\\tif err != nil {\\n   189→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   190→\\t}\\n   191→\\n   192→\\tmessage := string(content)\\