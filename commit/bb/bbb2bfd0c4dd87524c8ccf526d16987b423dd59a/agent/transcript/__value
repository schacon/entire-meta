th holds the path to the CLI binary built once in TestMain.\\n    32→// All tests share this binary to avoid repeated builds.\\n    33→var testBinaryPath string\\n    34→\\n    35→// getTestBinary returns the path to the shared test binary.\\n    36→// It panics if TestMain hasn't run (testBinaryPath is empty).\\n    37→func getTestBinary() string {\\n    38→\\tif testBinaryPath == \\\"\\\" {\\n    39→\\t\\tpanic(\\\"testBinaryPath not set - TestMain must run before tests\\\")\\n    40→\\t}\\n    41→\\treturn testBinaryPath\\n    42→}\\n    43→\\n    44→// TestEnv manages an isolated test environment for integration tests.\\n    45→type TestEnv struct {\\n    46→\\tT                  *testing.T\\n    47→\\tRepoDir            string\\n    48→\\tClaudeProjectDir   string\\n    49→\\tGeminiProjectDir   string\\n    50→\\tOpenCodeProjectDir string\\n    51→\\tSessionCounter     int\\n    52→}\\n    53→\\n    54→// NewTestEnv creates a new isolated test environment.\\n    55→// It creates temp directories for the git repo and agent project files.\\n    56→// Note: Does NOT change working directory to allow parallel test execution.\\n    57→// Note: Does NOT use t.Setenv to allow parallel test execution - CLI commands\\n    58→// receive the env var via cmd.Env instead.\\n    59→func NewTestEnv(t *testing.T) *TestEnv {\\n    60→\\tt.Helper()\\n    61→\\n    62→\\t// Resolve symlinks on macOS where /var -> /private/var\\n    63→\\t// This ensures the CLI subprocess and test use consistent paths\\n    64→\\trepoDir := t.TempDir()\\n    65→\\tif resolved, err := filepath.EvalSymlinks(repoDir); err == nil {\\n    66→\\t\\trepoDir = resolved\\n    67→\\t}\\n    68→\\tclaudeProjectDir := t.TempDir()\\n    69→\\tif resolved, err := filepath.EvalSymlinks(claudeProjectDir); err == nil {\\n    70→\\t\\tclaudeProjectDir = resolved\\n    71→\\t}\\n    72→\\tgeminiProjectDir := t.TempDir()\\n    73→\\tif resolved, err := filepath.EvalSymlinks(geminiProjectDir); err == nil {\\n    74→\\t\\tgeminiProjectDir = resolved\\n    75→\\t}\\n    76→\\topenCodeProjectDir := t.TempDir()\\n    77→\\tif resolved, err := filepath.EvalSymlinks(openCodeProjectDir); err == nil {\\n    78→\\t\\topenCodeProjectDir = resolved\\n    79→\\t}\\n    80→\\n    81→\\tenv := &TestEnv{\\n    82→\\t\\tT:                  t,\\n    83→\\t\\tRepoDir:            repoDir,\\n    84→\\t\\tClaudeProjectDir:   claudeProjectDir,\\n    85→\\t\\tGeminiProjectDir:   geminiProjectDir,\\n    86→\\t\\tOpenCodeProjectDir: openCodeProjectDir,\\n    87→\\t}\\n    88→\\n    89→\\t// Note: Don't use t.Setenv here - it's incompatible with t.Parallel()\\n    90→\\t// CLI commands receive ENTIRE_TEST_*_PROJECT_DIR via cmd.Env instead\\n    91→\\n    92→\\treturn env\\n    93→}\\n    94→\\n    95→// Cleanup is a no-op retained for backwards compatibility.\\n    96→//\\n    97→// Previously this method restored the working directory after NewTestEnv changed it.\\n    98→// With the refactor to remove os.Chdir from NewTestEnv:\\n    99→// - Temp directories are now cleaned up automatically by t.TempDir()\\n   100→// - Working directory is never changed, so no restoration is needed\\n   101→//\\n   102→// This method is kept to avoid breaking existing tests that call defer env.Cleanup().\\n   103→// New tests should not call this method as it serves no purpose.\\n   104→//\\n   105→// Deprecated: This method is a no-op and will be removed in a future version.\\n   106→func (env *TestEnv) Cleanup() {\\n   107→\\t// No-op - temp dirs are cleaned up by t.TempDir()\\n   108→}\\n   109→\\n   110→// gitIsolatedEnv returns os.Environ() with git isolation variables set.\\n   111→// This prevents user/system git config (global gitignore, aliases, etc.) from\\n   112→// affecting test behavior. Use this for any exec.Command that runs git or the\\n   113→// CLI binary in integration tests.\\n   114→//\\n   115→// See https://git-scm.com/docs/git#Documentation/git.txt-GITCONFIGGLOBAL\\n   116→//\\n   117→// Existing GIT_CONFIG_GLOBAL/GIT_CONFIG_SYSTEM entries are filtered out before\\n   118→// appending overrides to ensure they take effect regardless of parent env.\\n   119→func gitIsolatedEnv() []string {\\n   120→\\tenv := os.Environ()\\n   121→\\tfiltered := make([]string, 0, len(env)+2)\\n   122→\\tfor _, e := range env {\\n   123→\\t\\tif strings.HasPrefix(e, \\\"GIT_CONFIG_GLOBAL=\\\") || strings.HasPrefix(e, \\\"GIT_CONFIG_SYSTEM=\\\") {\\n   124→\\t\\t\\tcontinue\\n   125→\\t\\t}\\n   126→\\t\\tfiltered = append(filtered, e)\\n   127→\\t}\\n   128→\\treturn append(filtered,\\n   129→\\t\\t\\\"GIT_CONFIG_GLOBAL=/dev/null\\\", // Isolate from user's global git config (e.g. global gitignore)\\n   130→\\t\\t\\\"GIT_CONFIG_SYSTEM=/dev/null\\\", // Isolate from system git config\\n   131→\\t)\\n   132→}\\n   133→\\n   134→// cliEnv returns the environment variables for CLI execution.\\n   135→// Includes Claude, Gemini, and OpenCode project dirs so tests work for any agent.\\n   136→// Delegates to gitIsolatedEnv() for git config isolation.\\n   137→func (env *TestEnv) cliEnv() []string {\\n   138→\\treturn append(gitIsolatedEnv(),\\n   139→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+env.ClaudeProjectDir,\\n   140→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+env.GeminiProjectDir,\\n   141→\\t\\t\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR=\\\"+env.OpenCodeProjectDir,\\n   142→\\t\\t\\\"ENTIRE_TEST_TTY=0\\\", // Prevent interactive prompts from blocking in tests\\n   143→\\t)\\n   144→}\\n   145→\\n   146→// RunCLI runs the entire CLI with the given arguments and returns stdout.\\n   147→func (env *TestEnv) RunCLI(args ...string) string {\\n   148→\\tenv.T.Helper()\\n   149→\\toutput, err := env.RunCLIWithError(args...)\\n   150→\\tif err != nil {\"}]},\"uuid\":\"6ae0d8e2-d086-4f32-8eee-be1b23211053\",\"timestamp\":\"2026-02-27T19:44:28.790Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand how the Entire CLI installs/enables hooks in a 