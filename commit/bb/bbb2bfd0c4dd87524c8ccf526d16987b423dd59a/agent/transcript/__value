 captures pre-prompt state (untracked files).\\n    48→func (r *HookRunner) SimulateUserPromptSubmit(sessionID string) error {\\n    49→\\tr.T.Helper()\\n    50→\\n    51→\\tinput := map[string]string{\\n    52→\\t\\t\\\"session_id\\\":      sessionID,\\n    53→\\t\\t\\\"transcript_path\\\": \\\"\\\", // Not used for user-prompt-submit\\n    54→\\t}\\n    55→\\n    56→\\treturn r.runHookWithInput(\\\"user-prompt-submit\\\", input)\\n    57→}\\n    58→\\n    59→// SimulateUserPromptSubmitWithTranscriptPath simulates the UserPromptSubmit hook\\n    60→// with an explicit transcript path. This is needed for mid-session commit detection\\n    61→// which reads the live transcript to detect ongoing sessions.\\n    62→func (r *HookRunner) SimulateUserPromptSubmitWithTranscriptPath(sessionID, transcriptPath string) error {\\n    63→\\tr.T.Helper()\\n    64→\\n    65→\\tinput := map[string]string{\\n    66→\\t\\t\\\"session_id\\\":      sessionID,\\n    67→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n    68→\\t}\\n    69→\\n    70→\\treturn r.runHookWithInput(\\\"user-prompt-submit\\\", input)\\n    71→}\\n    72→\\n    73→// SimulateUserPromptSubmitWithResponse simulates the UserPromptSubmit hook\\n    74→// and returns the parsed hook response (for testing blocking behavior).\\n    75→func (r *HookRunner) SimulateUserPromptSubmitWithResponse(sessionID string) (*HookResponse, error) {\\n    76→\\tr.T.Helper()\\n    77→\\n    78→\\tinput := map[string]string{\\n    79→\\t\\t\\\"session_id\\\":      sessionID,\\n    80→\\t\\t\\\"transcript_path\\\": \\\"\\\", // Not used for user-prompt-submit\\n    81→\\t}\\n    82→\\n    83→\\tinputJSON, err := json.Marshal(input)\\n    84→\\tif err != nil {\\n    85→\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n    86→\\t}\\n    87→\\n    88→\\toutput := r.runHookWithOutput(\\\"user-prompt-submit\\\", inputJSON)\\n    89→\\n    90→\\t// If hook failed with an error, return the error\\n    91→\\tif output.Err != nil {\\n    92→\\t\\treturn nil, fmt.Errorf(\\\"hook failed: %w\\\\nStderr: %s\\\\nStdout: %s\\\",\\n    93→\\t\\t\\toutput.Err, output.Stderr, output.Stdout)\\n    94→\\t}\\n    95→\\n    96→\\t// Parse JSON response from stdout\\n    97→\\tvar resp HookResponse\\n    98→\\tif len(output.Stdout) > 0 {\\n    99→\\t\\tif err := json.Unmarshal(output.Stdout, &resp); err != nil {\\n   100→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse hook response: %w\\\\nStdout: %s\\\",\\n   101→\\t\\t\\t\\terr, output.Stdout)\\n   102→\\t\\t}\\n   103→\\t}\\n   104→\\n   105→\\treturn &resp, nil\\n   106→}\\n   107→\\n   108→// SimulateStop simulates the Stop hook with session transcript info.\\n   109→func (r *HookRunner) SimulateStop(sessionID, transcriptPath string) error {\\n   110→\\tr.T.Helper()\\n   111→\\n   112→\\tinput := map[string]string{\\n   113→\\t\\t\\\"session_id\\\":      sessionID,\\n   114→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   115→\\t}\\n   116→\\n   117→\\treturn r.runHookWithInput(\\\"stop\\\", input)\\n   118→}\\n   119→\\n   120→// SimulateSessionEnd simulates the Claude Code session-end hook.\\n   121→// This transitions a session from IDLE (or ACTIVE) to ENDED phase.\\n   122→func (r *HookRunner) SimulateSessionEnd(sessionID string) error {\\n   123→\\tr.T.Helper()\\n   124→\\n   125→\\tinput := map[string]string{\\n   126→\\t\\t\\\"session_id\\\":      sessionID,\\n   127→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   128→\\t}\\n   129→\\n   130→\\treturn r.runHookWithInput(\\\"session-end\\\", input)\\n   131→}\\n   132→\\n   133→// PreTaskInput contains the input for PreToolUse[Task] hook.\\n   134→type PreTaskInput struct {\\n   135→\\tSessionID      string\\n   136→\\tTranscriptPath string\\n   137→\\tToolUseID      string\\n   138→\\tSubagentType   string // Optional: type of subagent (e.g., \\\"dev\\\", \\\"reviewer\\\")\\n   139→\\tDescription    string // Optional: task description\\n   140→}\\n   141→\\n   142→// SimulatePreTask simulates the PreToolUse[Task] hook.\\n   143→func (r *HookRunner) SimulatePreTask(sessionID, transcriptPath, toolUseID string) error {\\n   144→\\tr.T.Helper()\\n   145→\\n   146→\\treturn r.SimulatePreTaskWithInput(PreTaskInput{\\n   147→\\t\\tSessionID:      sessionID,\\n   148→\\t\\tTranscriptPath: transcriptPath,\\n   149→\\t\\tToolUseID:      toolUseID,\\n   150→\\t})\\n   151→}\\n   152→\\n   153→// SimulatePreTaskWithInput simulates the PreToolUse[Task] hook with full input.\\n   154→func (r *HookRunner) SimulatePreTaskWithInput(input PreTaskInput) error {\\n   155→\\tr.T.Helper()\\n   156→\\n   157→\\thookInput := map[string]interface{}{\\n   158→\\t\\t\\\"session_id\\\":      input.SessionID,\\n   159→\\t\\t\\\"transcript_path\\\": input.TranscriptPath,\\n   160→\\t\\t\\\"tool_use_id\\\":     input.ToolUseID,\\n   161→\\t\\t\\\"tool_input\\\": map[string]string{\\n   162→\\t\\t\\t\\\"subagent_type\\\": input.SubagentType,\\n   163→\\t\\t\\t\\\"description\\\":   input.Description,\\n   164→\\t\\t},\\n   165→\\t}\\n   166→\\n   167→\\treturn r.runHookWithInput(\\\"pre-task\\\", hookInput)\\n   168→}\\n   169→\\n   170→// PostTaskInput contains the input for PostToolUse[Task] hook.\\n   171→type PostTaskInput struct {\\n   172→\\tSessionID      string\\n   173→\\tTranscriptPath string\\n   174→\\tToolUseID      string\\n   175→\\tAgentID        string\\n   176→}\\n   177→\\n   178→// SimulatePostTask simulates the PostToolUse[Task] hook.\\n   179→func (r *HookRunner) SimulatePostTask(input PostTaskInput) error {\\n   180→\\tr.T.Helper()\\n   181→\\n   182→\\thookInput := map[string]interface{}{\\n   183→\\t\\t\\\"session_id\\\":      input.SessionID,\\n   184→\\t\\t\\\"transcript_path\\\": input.TranscriptPath,\\n   185→\\t\\t\\\"tool_use_id\\\":     input.ToolUseID,\\n   186→\\t\\t\\\"tool_input\\\":      map[string]string{},\\n   187→\\t\\t\\\"tool_response\\\": map[string]string{\\n   188→\\t\\t\\t\\\"agentId\\\": input.AgentID,\\n   189→\\t\\t},\\n   190→\\t}\\n   191→\\n   192→\\treturn r.runHookWithInput(\\\"post-task\\\", hookInput)\\n   193→}\\n   194→\\n   195→func (r *HookRunner) runHookWithInput(flag string, input interface{}) error {\\n   196→\\tr.T.Helper()\\n   197→\\n   198→\\tinputJSON, err := json.Marshal(input)\\n   199→\\tif err != nil {\\n   200→\\t\\treturn fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n   201→\\t}\\n   202→\\n   203→\\treturn r.runHookInRepoDir(flag, inputJSON)\\n   204→}\\n   205→\\n   206→func (r *HookRunner) runHookInRepoDir(hookName string, inputJSON []byte) error {\\n   207→\\t// Run using the shared test binary\\n   208→\\t// Command structure: entire hooks claude-code <hook-name>\\n   209→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"claude-code\\\", hookName)\\n   210→\\tcmd.Dir = r.RepoDir\\n   211→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   212→\\tcmd.Env = append(gitIsolatedEnv(),\\n   213→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+r.ClaudeProjectDir,\\n   214→\\t)\\n   215→\\n   216→\\toutput, err := cmd.CombinedOutput()\\n   217→\\tif err != nil {\\n   218→\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n   219→\\t\\t\\thookName, err, inputJSON, output)\\n   220→\\t}\\n   221→\\n   222→\\tr.T.Logf(\\\"Hook %s output: %s\\\", hookName, output)\\n   223→\\treturn nil\\n   224→}\\n   225→\\n   226→// Session represents a simulated Claude Code session.\\n   227→type Session struct {\\n   228→\\tID                string // Raw model session ID (e.g., \\\"test-session-1\\\")\\n   229→\\tTranscriptPath    string\\n   230→\\tTranscriptBuilder *TranscriptBuilder\\n   231→\\tenv               *TestEnv\\n   232→}\\n   233→\\n   234→// FileChange represents a file modification in a session.\\n   235→type FileChange struct {\\n   236→\\tPath    string\\n   237→\\tContent string\\n   238→}\\n   239→\\n   240→// NewSession creates a new simulated session.\\n   241→func (env *TestEnv) NewSession() *Session {\\n   242→\\tenv.T.Helper()\\n   243→\\n   244→\\tenv.SessionCounter++\\n   245→\\tsessionID := fmt.Sprintf(\\\"test-session-%d\\\", env.SessionCounter)\\n   246→\\n   247→\\ttranscriptPath := filepath.Join(env.RepoDir, \\\".entire\\\", \\\"tmp\\\", sessionID+\\\".jsonl\\\")\\n   248→\\n   249→\\treturn &Session{\\n   250→\\t\\tID:                sessionID,\\n   251→\\t\\tTranscriptPath:    transcriptPath,\\n   252→\\t\\tTranscriptBuilder: NewTranscriptBuilder(),\\n   253→\\t\\tenv:               env,\\n   254→\\t}\\n   255→}\\n   256→\\n   257→// CreateTranscript builds and writes a transcript for the session.\\n   258→func (s *Session) CreateTranscript(prompt string, changes []FileChange) string {\\n   259→\\ts.TranscriptBuilder.AddUserMessage(prompt)\\n   260→\\ts.TranscriptBuilder.AddAssistantMessage(\\\"I'll help you with that.\\\")\\n   261→\\n   262→\\tfor _, change := range changes {\\n   263→\\t\\ttoolID := s.TranscriptBuilder.AddToolUse(\\\"mcp__acp__Write\\\", change.Path, change.Content)\\n   264→\\t\\ts.TranscriptBuilder.AddToolResult(toolID)\\n   265→\\t}\\n   266→\\n   267→\\ts.TranscriptBuilder.AddAssistantMessage(\\\"Done!\\\")\\n   268→\\n   269→\\tif err := s.TranscriptBuilder.WriteToFile(s.TranscriptPath); err != nil {\\n   270→\\t\\ts.env.T.Fatalf(\\\"failed to write transcript: %v\\\", err)\\n   271→\\t}\\n   272→\\n   273→\\treturn s.TranscriptPath\\n   274→}\\n   275→\\n   276→// SimulateUserPromptSubmit is a convenience method on TestEnv.\\n   277→func (env *TestEnv) SimulateUserPromptSubmit(sessionID string) error {\\n   278→\\tenv.T.Helper()\\n   279→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   280→\\treturn runner.SimulateUserPromptSubmit(sessionID)\\n   281→}\\n   282→\\n   283→// SimulateUserPromptSubmitWithTranscriptPath is a convenience method on TestEnv.\\n   284→// This is needed for mid-session commit detection which reads the live transcript.\\n   285→func (env *TestEnv) SimulateUserPromptSubmitWithTranscriptPath(sessionID, transcriptPath string) error {\\n   286→\\tenv.T.Helper()\\n   287→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   288→\\treturn runner.SimulateUserPromptSubmitWithTranscriptPath(sessionID, transcriptPath)\\n   289→}\\n   290→\\n   291→// SimulateUserPromptSubmitWithResponse is a convenience method on TestEnv.\\n   292→func (env *TestEnv) SimulateUserPromptSubmitWithResponse(sessionID string) (*HookResponse, error) {\\n   293→\\tenv.T.Helper()\\n   294→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   295→\\treturn runner.SimulateUserPromptSubmitWithResponse(sessionID)\\n   296→}\\n   297→\\n   298→// SimulateStop is a convenience method on TestEnv.\\n   299→func (env *TestEnv) SimulateStop(sessionID, transcriptPath string) error {\\n   300→\\tenv.T.Helper()\\n   301→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   302→\\treturn runner.SimulateStop(sessionID, transcriptPath)\\n   303→}\\n   304→\\n   305→// SimulateSessionEnd is a convenience method on TestEnv.\\n   306→func (env *TestEnv) SimulateSessionEnd(sessionID string) error {\\n   307→\\tenv.T.Helper()\\n   308→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   309→\\treturn runner.SimulateSessionEnd(sessionID)\\n   310→}\\n   311→\\n   312→// SimulatePreTask is a convenience method on TestEnv.\\n   313→func (env *TestEnv) SimulatePreTask(sessionID, transcriptPath, toolUseID string) error {\\n   314→\\tenv.T.Helper()\\n   315→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   316→\\treturn runner.SimulatePreTask(sessionID, transcriptPath, toolUseID)\\n   317→}\\n   318→\\n   319→// SimulatePostTask is a convenience method on TestEnv.\\n   320→func (env *TestEnv) SimulatePostTask(input PostTaskInput) error {\\n   321→\\tenv.T.Helper()\\n   322→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   323→\\treturn runner.SimulatePostTask(input)\\n   324→}\\n   325→\\n   326→// Todo represents a single todo item in the PostTodoInput.\\n   327→type Todo struct {\\n   328→\\tContent    string `json:\\\"content\\\"`\\n   329→\\tStatus     string `json:\\\"status\\\"`\\n   330→\\tActiveForm string `json:\\\"activeForm\\\"`\\n   331→}\\n   332→\\n   333→// PostTodoInput contains the input for PostToolUse[TodoWrite] hook.\\n   334→type PostTodoInput struct {\\n   335→\\tSessionID      string\\n   336→\\tTranscriptPath string\\n   337→\\tToolUseID      string // The TodoWrite tool use ID\\n   338→\\tTodos          []Todo // The todo list\\n   339→}\\n   340→\\n   341→// SimulatePostTodo simulates the PostToolUse[TodoWrite] hook.\\n   342→func (r *HookRunner) SimulatePostTodo(input PostTodoInput) error {\\n   343→\\tr.T.Helper()\\n   344→\\n   345→\\thookInput := map[string]interface{}{\\n   346→\\t\\t\\\"session_id\\\":      input.SessionID,\\n   347→\\t\\t\\\"transcript_path\\\": input.TranscriptPath,\\n   348→\\t\\t\\\"tool_name\\\":       \\\"TodoWrite\\\",\\n   349→\\t\\t\\\"tool_use_id\\\":     input.ToolUseID,\\n   350→\\t\\t\\\"tool_input\\\": map[string]interface{}{\\n   351→\\t\\t\\t\\\"todos\\\": input.Todos,\\n   352→\\t\\t},\\n   353→\\t\\t\\\"tool_response\\\": map[string]interface{}{},\\n   354→\\t}\\n   355→\\n   356→\\treturn r.runHookWithInput(\\\"post-todo\\\", hookInput)\\n   357→}\\n   358→\\n   359→// SimulatePostTodo is a convenience method on TestEnv.\\n   360→func (env *TestEnv) SimulatePostTodo(input PostTodoInput) error {\\n   361→\\tenv.T.Helper()\\n   362→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   363→\\treturn runner.SimulatePostTodo(input)\\n   364→}\\n   365→\\n   366→// ClearSessionState removes the session state file for the given session ID.\\n   367→// This simulates what happens when a user commits their changes (session is \\\"completed\\\").\\n   368→// Used in tests to allow sequential sessions to run without triggering concurrent session warnings.\\n   369→func (env *TestEnv) ClearSessionState(sessionID string) error {\\n   370→\\tenv.T.Helper()\\n   371→\\n   372→\\t// Session state is stored in .git/entire-sessions/<session-id>.json\\n   373→\\tstateFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\", sessionID+\\\".json\\\")\\n   374→\\n   375→\\tif err := os.Remove(stateFile); err != nil && !os.IsNotExist(err) {\\n   376→\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   377→\\t}\\n   378→\\treturn nil\\n   379→}\\n   380→\\n   381→// HookOutput contains the result of running a hook.\\n   382→type HookOutput struct {\\n   383→\\tStdout []byte\\n   384→\\tStderr []byte\\n   385→\\tErr    error\\n   386→}\\n   387→\\n   388→// runHookWithOutput runs a hook and returns both stdout and stderr separately.\\n   389→func (r *HookRunner) runHookWithOutput(hookName string, inputJSON []byte) HookOutput {\\n   390→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"claude-code\\\", hookName)\\n   391→\\tcmd.Dir = r.RepoDir\\n   392→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   393→\\tcmd.Env = append(gitIsolatedEnv(),\\n   394→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+r.ClaudeProjectDir,\\n   395→\\t)\\n   396→\\n   397→\\tvar stdout, stderr bytes.Buffer\\n   398→\\tcmd.Stdout = &stdout\\n   399→\\tcmd.Stderr = &stderr\\n   400→\\n   401→\\terr := cmd.Run()\\n   402→\\treturn HookOutput{\\n   403→\\t\\tStdout: stdout.Bytes(),\\n   404→\\t\\tStderr: stderr.Bytes(),\\n   405→\\t\\tErr:    err,\\n   406→\\t}\\n   407→}\\n   408→\\n   409→// SimulateUserPromptSubmitWithOutput simulates the UserPromptSubmit hook and returns the output.\\n   410→func (r *HookRunner) SimulateUserPromptSubmitWithOutput(sessionID string) HookOutput {\\n   411→\\tr.T.Helper()\\n   412→\\n   413→\\tinput := map[string]string{\\n   414→\\t\\t\\\"session_id\\\":      sessionID,\\n   415→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   416→\\t}\\n   417→\\n   418→\\tinputJSON, err := json.Marshal(input)\\n   419→\\tif err != nil {\\n   420→\\t\\treturn HookOutput{Err: fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)}\\n   421→\\t}\\n   422→\\n   423→\\treturn r.runHookWithOutput(\\\"user-prompt-submit\\\", inputJSON)\\n   424→}\\n   425→\\n   426→// SimulateUserPromptSubmitWithOutput is a convenience method on TestEnv.\\n   427→func (env *TestEnv) SimulateUserPromptSubmitWithOutput(sessionID string) HookOutput {\\n   428→\\tenv.T.Helper()\\n   429→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   430→\\treturn runner.SimulateUserPromptSubmitWithOutput(sessionID)\\n   431→}\\n   432→\\n   433→// SimulateSessionStartWithOutput simulates the SessionStart hook and returns the output.\\n   434→func (r *HookRunner) SimulateSessionStartWithOutput(sessionID string) HookOutput {\\n   435→\\tr.T.Helper()\\n   436→\\n   437→\\tinput := map[string]string{\\n   438→\\t\\t\\\"session_id\\\":      sessionID,\\n   439→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   440→\\t}\\n   441→\\n   442→\\tinputJSON, err := json.Marshal(input)\\n   443→\\tif err != nil {\\n   444→\\t\\treturn HookOutput{Err: fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)}\\n   445→\\t}\\n   446→\\n   447→\\treturn r.runHookWithOutput(\\\"session-start\\\", inputJSON)\\n   448→}\\n   449→\\n   450→// SimulateSessionStartWithOutput is a convenience method on TestEnv.\\n   451→func (env *TestEnv) SimulateSessionStartWithOutput(sessionID string) HookOutput {\\n   452→\\tenv.T.Helper()\\n   453→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   454→\\treturn runner.SimulateSessionStartWithOutput(sessionID)\\n   455→}\\n   456→\\n   457→// GetSessionState reads and returns the session state for the given session ID.\\n   458→func (env *TestEnv) GetSessionState(sessionID string) (*strategy.SessionState, error) {\\n   459→\\tenv.T.Helper()\\n   460→\\n   461→\\tstateFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\", sessionID+\\\".json\\\")\\n   462→\\n   463→\\tdata, err := os.ReadFile(stateFile)\\n   464→\\tif os.IsNotExist(err) {\\n   465→\\t\\treturn nil, nil\\n   466→\\t}\\n   467→\\tif err != nil {\\n   468→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   469→\\t}\\n   470→\\n   471→\\tvar state strategy.SessionState\\n   472→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   473→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse session state: %w\\\", err)\\n   474→\\t}\\n   475→\\treturn &state, nil\\n   476→}\\n   477→\\n   478→// WriteSessionState writes the session state for the given session ID.\\n   479→// This is useful for tests that need to manipulate session state directly.\\n   480→func (env *TestEnv) WriteSessionState(sessionID string, state *strategy.SessionState) error {\\n   481→\\tenv.T.Helper()\\n   482→\\n   483→\\tstateDir := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\")\\n   484→\\tif err := os.MkdirAll(stateDir, 0o755); err != nil {\\n   485→\\t\\treturn fmt.Errorf(\\\"failed to create session state dir: %w\\\", err)\\n   486→\\t}\\n   487→\\n   488→\\tstateFile := filepath.Join(stateDir, sessionID+\\\".json\\\")\\n   489→\\n   490→\\tdata, err := json.MarshalIndent(state, \\\"\\\", \\\"  \\\")\\n   491→\\tif err != nil {\\n   492→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   493→\\t}\\n   494→\\n   495→\\tif err := os.WriteFile(stateFile, data, 0o644); err != nil {\\n   496→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   497→\\t}\\n   498→\\treturn nil\\n   499→}\\n   500→\\n   501→// GeminiHookRunner executes Gemini CLI hooks in the test environment.\\n   502→type GeminiHookRunner struct {\\n   503→\\tRepoDir          string\\n   504→\\tGeminiProjectDir string\\n   505→\\tT                interface {\\n   506→\\t\\tHelper()\\n   507→\\t\\tFatalf(format string, args ...interface{})\\n   508→\\t\\tLogf(format string, args ...interface{})\\n   509→\\t}\\n   510→}\\n   511→\\n   512→// NewGeminiHookRunner creates a new Gemini hook runner for the given repo directory.\\n   513→func NewGeminiHookRunner(repoDir, geminiProjectDir string, t interface {\\n   514→\\tHelper()\\n   515→\\tFatalf(format string, args ...interface{})\\n   516→\\tLogf(format string, args ...interface{})\\n   517→}) *GeminiHookRunner {\\n   518→\\treturn &GeminiHookRunner{\\n   519→\\t\\tRepoDir:          repoDir,\\n   520→\\t\\tGeminiProjectDir: geminiProjectDir,\\n   521→\\t\\tT:                t,\\n   522→\\t}\\n   523→}\\n   524→\\n   525→// runGeminiHookWithInput runs a Gemini hook with the given input.\\n   526→func (r *GeminiHookRunner) runGeminiHookWithInput(hookName string, input interface{}) error {\\n   527→\\tr.T.Helper()\\n   528→\\n   529→\\tinputJSON, err := json.Marshal(input)\\n   530→\\tif err != nil {\\n   531→\\t\\treturn fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n   532→\\t}\\n   533→\\n   534→\\treturn r.runGeminiHookInRepoDir(hookName, inputJSON)\\n   535→}\\n   536→\\n   537→func (r *GeminiHookRunner) runGeminiHookInRepoDir(hookName string, inputJSON []byte) error {\\n   538→\\t// Run using the shared test binary\\n   539→\\t// Command structure: entire hooks gemini <hook-name>\\n   540→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n   541→\\tcmd.Dir = r.RepoDir\\n   542→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   543→\\tcmd.Env = append(gitIsolatedEnv(),\\n   544→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n   545→\\t)\\n   546→\\n   547→\\toutput, err := cmd.CombinedOutput()\\n   548→\\tif err != nil {\\n   549→\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n   550→\\t\\t\\thookName, err, inputJSON, output)\\n   551→\\t}\\n   552→\\n   553→\\tr.T.Logf(\\\"Gemini hook %s output: %s\\\", hookName, output)\\n   554→\\treturn nil\\n   555→}\\n   556→\\n   557→// runGeminiHookWithOutput runs a Gemini hook and returns both stdout and stderr separately.\\n   558→func (r *GeminiHookRunner) runGeminiHookWithOutput(hookName string, inputJSON []byte) HookOutput {\\n   559→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n   560→\\tcmd.Dir = r.RepoDir\\n   561→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   562→\\tcmd.Env = append(gitIsolatedEnv(),\\n   563→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n   564→\\t)\\n   565→\\n   566→\\tvar stdout, stderr bytes.Buffer\\n   567→\\tcmd.Stdout = &stdout\\n   568→\\tcmd.Stderr = &stderr\\n   569→\\n   570→\\terr := cmd.Run()\\n   571→\\treturn HookOutput{\\n   572→\\t\\tStdout: stdout.Bytes(),\\n   573→\\t\\tStderr: stderr.Bytes(),\\n   574→\\t\\tErr:    err,\\n   575→\\t}\\n   576→}\\n   577→\\n   578→// SimulateGeminiBeforeAgent simulates the BeforeAgent hook for Gemini CLI.\\n   579→// This is equivalent to Claude Code's UserPromptSubmit.\\n   580→func (r *GeminiHookRunner) SimulateGeminiBeforeAgent(sessionID string) error {\\n   581→\\tr.T.Helper()\\n   582→\\n   583→\\tinput := map[string]string{\\n   584→\\t\\t\\\"session_id\\\":      sessionID,\\n   585→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   586→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   587→\\t\\t\\\"hook_event_name\\\": \\\"BeforeAgent\\\",\\n   588→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   589→\\t\\t\\\"prompt\\\":          \\\"test prompt\\\",\\n   590→\\t}\\n   591→\\n   592→\\treturn r.runGeminiHookWithInput(\\\"before-agent\\\", input)\\n   593→}\\n   594→\\n   595→// SimulateGeminiBeforeAgentWithOutput simulates the BeforeAgent hook and returns the output.\\n   596→func (r *GeminiHookRunner) SimulateGeminiBeforeAgentWithOutput(sessionID string) HookOutput {\\n   597→\\tr.T.Helper()\\n   598→\\n   599→\\tinput := map[string]string{\\n   600→\\t\\t\\\"session_id\\\":      sessionID,\\n   601→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   602→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   603→\\t\\t\\\"hook_event_name\\\": \\\"BeforeAgent\\\",\\n   604→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   605→\\t\\t\\\"prompt\\\":          \\\"test prompt\\\",\\n   606→\\t}\\n   607→\\n   608→\\tinputJSON, err := json.Marshal(input)\\n   609→\\tif err != nil {\\n   610→\\t\\treturn HookOutput{Err: fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)}\\n   611→\\t}\\n   612→\\n   613→\\treturn r.runGeminiHookWithOutput(\\\"before-agent\\\", inputJSON)\\n   614→}\\n   615→\\n   616→// SimulateGeminiAfterAgent simulates the AfterAgent hook for Gemini CLI.\\n   617→// This is the primary checkpoint creation hook, equivalent to Claude Code's Stop hook.\\n   618→func (r *GeminiHookRunner) SimulateGeminiAfterAgent(sessionID, transcriptPath string) error {\\n   619→\\tr.T.Helper()\\n   620→\\n   621→\\tinput := map[string]string{\\n   622→\\t\\t\\\"session_id\\\":      sessionID,\\n   623→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   624→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   625→\\t\\t\\\"hook_event_name\\\": \\\"AfterAgent\\\",\\n   626→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   627→\\t}\\n   628→\\n   629→\\treturn r.runGeminiHookWithInput(\\\"after-agent\\\", input)\\n   630→}\\n   631→\\n   632→// SimulateGeminiSessionEnd simulates the SessionEnd hook for Gemini CLI.\\n   633→// This is a cleanup/fallback hook that fires on explicit exit.\\n   634→func (r *GeminiHookRunner) SimulateGeminiSessionEnd(sessionID, transcriptPath string) error {\\n   635→\\tr.T.Helper()\\n   636→\\n   637→\\tinput := map[string]string{\\n   638→\\t\\t\\\"session_id\\\":      sessionID,\\n   639→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   640→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   641→\\t\\t\\\"hook_event_name\\\": \\\"SessionEnd\\\",\\n   642→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   643→\\t\\t\\\"reason\\\":          \\\"exit\\\",\\n   644→\\t}\\n   645→\\n   646→\\treturn r.runGeminiHookWithInput(\\\"session-end\\\", input)\\n   647→}\\n   648→\\n   649→// GeminiSession represents a simulated Gemini CLI session.\\n   650→type GeminiSession struct {\\n   651→\\tID             string // Raw model session ID (e.g., \\\"gemini-session-1\\\")\\n   652→\\tTranscriptPath string\\n   653→\\tenv            *TestEnv\\n   654→}\\n   655→\\n   656→// NewGeminiSession creates a new simulated Gemini session.\\n   657→func (env *TestEnv) NewGeminiSession() *GeminiSession {\\n   658→\\tenv.T.Helper()\\n   659→\\n   660→\\tenv.SessionCounter++\\n   661→\\tsessionID := fmt.Sprintf(\\\"gemini-session-%d\\\", env.SessionCounter)\\n   662→\\ttranscriptPath := filepath.Join(env.RepoDir, \\\".entire\\\", \\\"tmp\\\", sessionID+\\\".json\\\")\\n   663→\\n   664→\\treturn &GeminiSession{\\n   665→\\t\\tID:             sessionID,\\n   666→\\t\\tTranscriptPath: transcriptPath,\\n   667→\\t\\tenv:            env,\\n   668→\\t}\\n   669→}\\n   670→\\n   671→// CreateGeminiTranscript creates a Gemini JSON transcript file for the session.\\n   672→func (s *GeminiSession) CreateGeminiTranscript(prompt string, changes []FileChange) string {\\n   673→\\t// Build Gemini-format transcript (JSON, not JSONL)\\n   674→\\tmessages := []map[string]interface{}{\\n   675→\\t\\t{\\n   676→\\t\\t\\t\\\"type\\\":    \\\"user\\\",\\n   677→\\t\\t\\t\\\"content\\\": prompt,\\n   678→\\t\\t},\\n   679→\\t\\t{\\n   680→\\t\\t\\t\\\"type\\\":    \\\"assistant\\\",\\n   681→\\t\\t\\t\\\"content\\\": \\\"I'll help you with that.\\\",\\n   682→\\t\\t},\\n   683→\\t}\\n   684→\\n   685→\\tfor _, change := range changes {\\n   686→\\t\\tmessages = append(messages, map[string]interface{}{\\n   687→\\t\\t\\t\\\"type\\\": \\\"tool_use\\\",\\n   688→\\t\\t\\t\\\"name\\\": \\\"write_file\\\",\\n   689→\\t\\t\\t\\\"input\\\": map[string]string{\\n   690→\\t\\t\\t\\t\\\"path\\\":    change.Path,\\n   691→\\t\\t\\t\\t\\\"content\\\": change.Content,\\n   692→\\t\\t\\t},\\n   693→\\t\\t}