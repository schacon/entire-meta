\\n     7→\\t\\\"errors\\\"\\n     8→\\t\\\"os\\\"\\n     9→\\t\\\"time\\\"\\n    10→\\n    11→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    13→)\\n    14→\\n    15→// ErrNoMetadata is returned when a commit does not have an Entire metadata trailer.\\n    16→var ErrNoMetadata = errors.New(\\\"commit has no entire metadata\\\")\\n    17→\\n    18→// ErrNoSession is returned when no session info is available.\\n    19→var ErrNoSession = errors.New(\\\"no session info available\\\")\\n    20→\\n    21→// ErrNotTaskCheckpoint is returned when a rewind point is not a task checkpoint.\\n    22→var ErrNotTaskCheckpoint = errors.New(\\\"not a task checkpoint\\\")\\n    23→\\n    24→// ErrEmptyRepository is returned when the repository has no commits yet.\\n    25→var ErrEmptyRepository = errors.New(\\\"repository has no commits yet\\\")\\n    26→\\n    27→// SessionInfo contains information about the current session state.\\n    28→// This is used to generate trailers for linking commits to their AI session.\\n    29→type SessionInfo struct {\\n    30→\\t// SessionID is the session identifier extracted from the latest commit's metadata\\n    31→\\tSessionID string\\n    32→\\n    33→\\t// Reference is a strategy-specific reference string.\\n    34→\\t// For manual-commit strategy: \\\"entire/abc1234\\\" (the shadow branch name)\\n    35→\\t// Empty for commit strategy (metadata is in the same commit).\\n    36→\\tReference string\\n    37→\\n    38→\\t// CommitHash is the full SHA of the commit containing the session metadata.\\n    39→\\t// Empty for commit strategy.\\n    40→\\tCommitHash string\\n    41→}\\n    42→\\n    43→// RewindPoint represents a point to which the user can rewind.\\n    44→// This abstraction allows different strategies to use different\\n    45→// identifiers (commit hashes, branch names, stash refs, etc.)\\n    46→type RewindPoint struct {\\n    47→\\t// ID is the unique identifier for this rewind point\\n    48→\\t// (commit hash, branch name, stash ref, etc.)\\n    49→\\tID string\\n    50→\\n    51→\\t// Message is the human-readable description/summary\\n    52→\\tMessage string\\n    53→\\n    54→\\t// MetadataDir is the path to the metadata directory\\n    55→\\tMetadataDir string\\n    56→\\n    57→\\t// Date is when this rewind point was created\\n    58→\\tDate time.Time\\n    59→\\n    60→\\t// IsTaskCheckpoint indicates if this is a task checkpoint (vs a session checkpoint)\\n    61→\\tIsTaskCheckpoint bool\\n    62→\\n    63→\\t// ToolUseID is the tool use ID for task checkpoints (empty for session checkpoints)\\n    64→\\tToolUseID string\\n    65→\\n    66→\\t// IsLogsOnly indicates this is a commit with session logs but no shadow branch state.\\n    67→\\t// The logs can be restored from entire/checkpoints/v1, but file state requires git checkout.\\n    68→\\tIsLogsOnly bool\\n    69→\\n    70→\\t// CheckpointID is the stable 12-hex-char identifier for logs-only points.\\n    71→\\t// Used to retrieve logs from entire/checkpoints/v1/<id[:2]>/<id[2:]>/full.jsonl\\n    72→\\t// Empty for shadow branch checkpoints (uncommitted).\\n    73→\\tCheckpointID id.CheckpointID\\n    74→\\n    75→\\t// Agent is the human-readable name of the agent that created this checkpoint\\n    76→\\t// (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n    77→\\tAgent agent.AgentType\\n    78→\\n    79→\\t// SessionID is the session identifier for this checkpoint.\\n    80→\\t// Used to distinguish checkpoints from different concurrent sessions.\"}]},\"uuid\":\"1517d6d5-b64a-43d2-8d27-d2c41e62fcd6\",\"timestamp\":\"2026-02-27T19:44:52.563Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand how the Entire CLI installs/enables hooks in a repo, and how to disable them. The goal is to write a performance test that:\\n1. Clones a real repo\\n2. Creates a commit WITHOUT Entire hooks (control baseline