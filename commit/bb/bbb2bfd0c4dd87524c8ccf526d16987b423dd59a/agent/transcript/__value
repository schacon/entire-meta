  544→\\n   545→\\t// No checkpoint ID found - leave message unchanged\\n   546→\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend with no checkpoint to restore\\\",\\n   547→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   548→\\t)\\n   549→\\treturn nil\\n   550→}\\n   551→\\n   552→// PostCommit is called by the git post-commit hook after a commit is created.\\n   553→// Uses the session state machine to determine what action to take per session:\\n   554→//   - ACTIVE → condense immediately (each commit gets its own checkpoint)\\n   555→//   - IDLE → condense immediately\\n   556→//   - ENDED → condense if files touched, discard if empty\\n   557→//\\n   558→// After condensation for ACTIVE sessions, remaining uncommitted files are\\n   559→// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n   560→//\\n   561→// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n   562→// and were condensed during this PostCommit.\\n   563→\\n   564→// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n   565→// Each session in the loop gets its own handler with per-session context.\\n   566→// Handler methods use the *State parameter from ApplyTransition (same pointer\\n   567→// as the state being transitioned) rather than capturing state separately.\\n   568→type postCommitActionHandler struct {\\n   569→\\ts                      *ManualCommitStrategy\\n   570→\\tctx                    context.Context\\n   571→\\trepo                   *git.Repository\\n   572→\\tcheckpointID           id.CheckpointID\\n   573→\\thead                   *plumbing.Reference\\n   574→\\tcommit                 *object.Commit\\n   575→\\tnewHead                string\\n   576→\\tshadowBranchName       string\\n   577→\\tshadowBranchesToDelete map[string]struct{}\\n   578→\\tcommittedFileSet       map[string]struct{}\\n   579→\\thasNew                 bool\\n   580→\\tfilesTouchedBef