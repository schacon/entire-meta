1024, 100 * 1024 * 1024},\\n    46→}\\n    47→\\n    48→// TestPushPerformance measures real push times to GitHub for the entire/checkpoints/v1 branch\\n    49→// using real transcript data from the source repo.\\n    50→//\\n    51→// Prerequisites:\\n    52→//   - Must be run from a repo that has an entire/checkpoints/v1 branch with checkpoint data\\n    53→//   - Requires `gh` CLI authenticated with delete_repo scope\\n    54→//\\n    55→// Run with: go test -v -run TestPushPerformance -tags pushperf -timeout 30m ./cmd/entire/cli/checkpoint/\\n    56→func TestPushPerformance(t *testing.T) {\\n    57→\\tfullName := perfTestRepoOwner + \\\"/\\\" + perfTestRepoName\\n    58→\\n    59→\\t// Load real transcripts from source repo.\\n    60→\\tsrc := newTranscriptSource(t)\\n    61→\\n    62→\\t// Create the GitHub repo once for all subtests.\\n    63→\\trepoURL := createTempGitHubRepo(t, fullName)\\n    64→\\tt.Cleanup(func() {\\n    65→\\t\\tdeleteTempGitHubRepo(t, fullName)\\n    66→\\t})\\n    67→\\n    68→\\ttype scenario struct {\\n    69→\\t\\tname           string\\n    70→\\t\\tcheckpoints    int\\n    71→\\t\\ttranscriptSize int // used to pick the size tier\\n    72→\\t}\\n    73→\\n    74→\\tfirstPush := []scenario{\\n    75→\\t\\t// Small sessions\\n    76→\\t\\t{\\\"10cp_100KB\\\", 10, 100 * 1024},\\n    77→\\t\\t{\\\"50cp_500KB\\\", 50, 500 * 1024},\\n    78→\\t\\t// Average-sized sessions (~2.8MB real-world avg)\\n    79→\\t\\t{\\\"50cp_2500KB\\\", 50, 2500 * 1024},\\n    80→\\t\\t{\\\"100cp_2500KB\\\", 100, 2500 * 1024},\\n    81→\\t\\t{\\\"200cp_2500KB\\\", 200, 2500 * 1024},\\n    82→\\t\\t// Heavy sessions\\n    83→\\t\\t{\\\"50cp_10MB\\\", 50, 10 * 1024 * 1024},\\n    84→\\t\\t// Near-max sessions\\n    85→\\t\\t{\\\"10cp_50MB\\\", 10, 50 * 1024 * 1024},\\n    86→\\t}\\n    87→\\n    88→\\tfor _, sc := range firstPush {\\n    89→\\t\\tt.Run(\\\"FirstPush/\\\"+sc.name, func(t *testing.T) {\\n    90→\\t\\t\\trunFirstPushScenario(t, repoURL, src, sc.checkpoints, sc.transcriptSize)\\n    91→\\t\\t})\\n    92→\\t}\\n    93→\\n    94→\\tincremental := []scenario{\\n    95→\\t\\t{\\\"50cp_base_500KB\\\", 50, 500 * 1024},\\n    96→\\t\\t{\\\"50cp_base_2500KB\\\", 50, 2500 * 1024},\\n    97→\\t\\t{\\\"200cp_base_2500KB\\\", 200, 2500 * 1024},\\n    98→\\t\\t{\\\"50cp_base_10MB\\\", 50, 10 * 1024 * 1024},\\n    99→\\t}\\n   100→\\n   101→\\tfor _, sc := range incremental {\\n   102→\\t\\tt.Run(\\\"Incremental/\\\"+sc.name, func(t *testing.T) {\\n   103→\\t\\t\\trunIncrementalScenario(t, repoURL, src, sc.checkpoints, sc.transcriptSize)\\n   104→\\t\\t})\\n   105→\\t}\\n   106→}\\n   107→\\n   108→// runFirstPushScenario creates a local repo with N checkpoints and times the first push.\\n   109→func runFirstPushScenario(t *testing.T, remoteURL string, src *transcriptSource, numCheckpoints, transcriptSize int) {\\n   110→\\tt.Helper()\\n   111→\\n   112→\\tdir := t.TempDir()\\n   113→\\trepo := initLocalRepo(t, dir)\\n   114→\\tstore := checkpoint.NewGitStore(repo)\\n   115→\\n   116→\\tseedDur, totalBytes := seedCheckpoints(t, store, src, numCheckpoints, transcriptSize)\\n   117→\\tgcDur := timeGitGC(t, dir)\\n   118→\\n   119→\\tlooseKB, packKB, totalKB := measureRepoSize(t, dir)\\n   120→\\taddRemote(t, dir, remoteURL)\\n   121→\\n   122→\\tpushDur := timeForcePush(t, dir, \\\"origin\\\", \\\"entire/checkpoints/v1\\\")\\n   123→\\n   124→\\ttotalRawMB := float64(totalBytes) / (1024 * 1024)\\n   125→\\tthroughput := float64(0)\\n   126→\\tif pushDur.Seconds() > 0 {\\n   127→\\t\\tthroughput = totalRawMB / pushDur.Seconds()\\n   128→\\t}\\n   129→\\n   130→\\tt.Logf(\\\"\\\\n=== %s ===\\\", t.Name())\\n   131→\\tt.Logf(\\\"  Checkpoints:    %d\\\", numCheckpoints)\\n   132→\\tt.Logf(\\\"  Tier:           %s (real transcripts)\\\", tierNameForSize(transcriptSize))\\n   133→\\tt.Logf(\\\"  Total raw:      %.1f MB\\\", totalRawMB)\\n   134→\\tt.Logf(\\\"  Loose objects:  %d KB\\\", looseKB)\\n   135→\\tt.Logf(\\\"  Pack size:      %d KB\\\", packKB)\\n   136→\\tt.Logf(\\\"  Total .git:     %d KB\\\", totalKB)\\n   137→\\tt.Logf(\\\"  Compression:    %.1f%% (pack/raw)\\\", float64(packKB)*1024/float64(totalBytes)*100)\\n   138→\\tt.Logf(\\\"  Seed duration:  %s\\\", seedDur.Round(time.Millisecond))\\n   139→\\tt.Logf(\\\"  GC duration:    %s\\\", gcDur.Round(time.Millisecond))\\n   140→\\tt.Logf(\\\"  Push duration:  %s\\\", pushDur.Round(time.Millisecond))\\n   141→\\tt.Logf(\\\"  Throughput:     %.1f MB/s (raw data / wall time)\\\", throughput)\\n   142→}\\n   143→\\n   144→// runIncrementalScenario pushes a base set of checkpoints, then adds 1 and times the incremental push.\\n   145→func runIncrementalScenario(t *testing.T, remoteURL string, src *transcriptSource, baseCheckpoints, transcriptSize int) {\\n   146→\\tt.Helper()\\n   147→\\n   148→\\tdir := t.TempDir()\\n   149→\\trepo := initLocalRepo(t, dir)\\n   150→\\tstore := checkpoint.NewGitStore(repo)\\n   151→\\n   152→\\t// Seed and push baseline.\\n   153→\\tseedDur, totalBytes := seedCheckpoints(t, store, src, baseCheckpoints, transcriptSize)\\n   154→\\tgcDur := timeGitGC(t, dir)\\n   155→\\taddRemote(t, dir, remoteURL)\\n   156→\\n   157→\\tbasePushDur := timeForcePush(t, dir, \\\"origin\\\", \\\"entire/checkpoints/v1\\\")\\n   158→\\n   159→\\t// Reopen repo after GC so go-git sees the repacked objects.\\n   160→\\trepo, err := gogit.PlainOpen(dir)\\n   161→\\tif err != nil {\\n   162→\\t\\tt.Fatalf(\\\"PlainOpen after gc: %v\\\", err)\\n   163→\\t}\\n   164→\\tstore = checkpoint.NewGitStore(repo)\\n   165→\\n   166→\\t// Add 1 more checkpoint.\\n   167→\\t_, incrBytes := seedCheckpoints(t, store, src, 1, transcriptSize)\\n   168→\\ttimeGitGC(t, dir)\\n   169→\\n   170→\\t_, _, totalKB := measureRepoSize(t, dir)\\n   171→\\n   172→\\tincDur := timePush(t, dir, \\\"origin\\\", \\\"entire/checkpoints/v1\\\")\\n   173→\\n   174→\\tincrRawMB := float64(incrBytes) / (1024 * 1024)\\n   175→\\tthroughput := float64(0)\\n   176→\\tif incDur.Seconds() > 0 {\\n   177→\\t\\tthroughput = incrRawMB / incDur.Seconds()\\n   178→\\t}\\n   179→\\n   180→\\tt.Logf(\\\"\\\\n=== %s ===\\\", t.Name())\\n   181→\\tt.Logf(\\\"  Base checkpoints:  %d\\\", baseCheckpoints)\\n   182→\\tt.Logf(\\\"  Tier:              %s (real transcripts)\\\", tierNameForSize(transcriptSize))\\n   183→\\tt.Logf(\\\"  Total raw:         %.1f MB (base)\\\", float64(totalBytes)/(1024*1024))\\n   184→\\tt.Logf(\\\"  Total .git:        %d KB\\\", totalKB)\\n   185→\\tt.Logf(\\\"  Seed duration:     %s (base)\\\", seedDur.Round(time.Millisecond))\\n   186→\\tt.Logf(\\\"  GC duration:       %s (base)\\\", gcDur.Round(time.Millisecond))\\n   187→\\tt.Logf(\\\"  Base push:         %s\\\", basePushDur.Round(time.Millisecond))\\n   188→\\tt.Logf(\\\"  Incremental push:  %s (1 new × %s)\\\", incDur.Round(time.Millisecond), formatBytes(incrBytes))\\n   189→\\tt.Logf(\\\"  Throughput:        %.1f MB/s (raw data / wall time)\\\", throughput)\\n   190→}\\n   191→\\n   192→// --- Transcript source ---\\n   193→\\n   194→// blobRef is a reference to a transcript blob in the source repo.\\n   195→type blobRef struct {\\n   196→\\thash plumbing.Hash\\n   197→\\tsize int64\\n   198→}\\n   199→\\n   200→// transcriptSource provides real transcript data from the source repo's\\n   201→// entire/checkpoints/v1 branch, bucketed by size tier and loaded lazily.\\n   202→type transcriptSource struct {\\n   203→\\trepo  *gogit.Repository\\n   204→\\ttiers map[int][]blobRef // targetKey -> blob refs sorted by size\\n   205→}\\n   206→\\n   207→// newTranscriptSource scans the source repo's entire/checkpoints/v1 branch\\n   208→// and indexes all full.jsonl blobs by size tier.\\n   209→func newTranscriptSource(t *testing.T) *transcriptSource {\\n   210→\\tt.Helper()\\n   211→\\n   212→\\t// Find repo root.\\n   213→\\tout, err := exec.Command(\\\"git\\\", \\\"rev-parse\\\", \\\"--show-toplevel\\\").Output()\\n   214→\\tif err != nil {\\n   215→\\t\\tt.Fatalf(\\\"not in a git repo: %v\\\", err)\\n   216→\\t}\\n   217→\\trepoRoot := strings.TrimSpace(string(out))\\n   218→\\n   219→\\trepo, err := gogit.PlainOpen(repoRoot)\\n   220→\\tif err != nil {\\n   221→\\t\\tt.Fatalf(\\\"open source repo: %v\\\", err)\\n   222→\\t}\\n   223→\\n   224→\\t// Resolve entire/checkpoints/v1 branch.\\n   225→\\tref, err := repo.Reference(plumbing.ReferenceName(\\\"refs/heads/entire/checkpoints/v1\\\"), true)\\n   226→\\tif err != nil {\\n   227→\\t\\tt.Fatalf(\\\"entire/checkpoints/v1 branch not found (is this repo using Entire?): %v\\\", err)\\n   228→\\t}\\n   229→\\n   230→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   231→\\tif err != nil {\\n   232→\\t\\tt.Fatalf(\\\"resolve commit: %v\\\", err)\\n   233→\\t}\\n   234→\\n   235→\\ttree, err := commit.Tree()\\n   236→\\tif err != nil {\\n   237→\\t\\tt.Fatalf(\\\"resolve tree: %v\\\", err)\\n   238→\\t}\\n   239→\\n   240→\\t// Scan tree for full.jsonl entries and bucket by size tier.\\n   241→\\ttiers := make(map[int][]blobRef)\\n   242→\\terr = tree.Files().ForEach(func(f *object.File) error {\\n   243→\\t\\tif !strings.HasSuffix(f.Name, \\\"full.jsonl\\\") {\\n   244→\\t\\t\\treturn nil\\n   245→\\t\\t}\\n   246→\\t\\tfor _, tier := range sizeTiers {\\n   247→\\t\\t\\tif f.Size >= tier.minBytes && f.Size < tier.maxBytes {\\n   248→\\t\\t\\t\\ttiers[tier.targetKey] = append(tiers[tier.targetKey], blobRef{hash: f.Hash, size: f.Size})\\n   249→\\t\\t\\t\\tbreak\\n   250→\\t\\t\\t}\\n   251→\\t\\t}\\n   252→\\t\\treturn nil\\n   253→\\t})\\n   254→\\tif err != nil {\\n   255→\\t\\tt.Fatalf(\\\"scan tree: %v\\\", err)\\n   256→\\t}\\n   257→\\n   258→\\t// Sort each tier by size for deterministic ordering.\\n   259→\\tfor key := range tiers {\\n   260→\\t\\tsort.Slice(tiers[key], func(i, j int) bool {\\n   261→\\t\\t\\treturn tiers[key][i].size < tiers[key][j].size\\n   262→\\t\\t})\\n   263→\\t}\\n   264→\\n   265→\\t// Log what we found.\\n   266→\\tfor _, tier := range sizeTiers {\\n   267→\\t\\trefs := tiers[tier.targetKey]\\n   268→\\t\\tif len(refs) > 0 {\\n   269→\\t\\t\\tvar totalSize int64\\n   270→\\t\\t\\tfor _, r := range refs {\\n   271→\\t\\t\\t\\ttotalSize += r.size\\n   272→\\t\\t\\t}\\n   273→\\t\\t\\tt.Logf(\\\"  tier %-6s: %3d transcripts, avg %s\\\", tier.name, len(refs), formatBytes(totalSize/int64(len(refs))))\\n   274→\\t\\t}\\n   275→\\t}\\n   276→\\n   277→\\treturn &transcriptSource{repo: repo, tiers: tiers}\\n   278→}\\n   279→\\n   280→// get returns the content of a real transcript blob for the given size tier and index.\\n   281→// Cycles through available blobs if index exceeds the pool size.\\n   282→func (s *transcriptSource) get(t *testing.T, targetSize, index int) []byte {\\n   283→\\tt.Helper()\\n   284→\\n   285→\\trefs, ok := s.tiers[targetSize]\\n   286→\\tif !ok || len(refs) == 0 {\\n   287→\\t\\tt.Fatalf(\\\"no real transcripts available for tier %s\\\", tierNameForSize(targetSize))\\n   288→\\t}\\n   289→\\n   290→\\tref := refs[index%len(refs)]\\n   291→\\tblob, err := s.repo.BlobObject(ref.hash)\\n   292→\\tif err != nil {\\n   293→\\t\\tt.Fatalf(\\\"read blob %s: %v\\\", ref.hash, err)\\n   294→\\t}\\n   295→\\n   296→\\treader, err := blob.Reader()\\n   297→\\tif err != nil {\\n   298→\\t\\tt.Fatalf(\\\"blob reader %s: %v\\\", ref.hash, err)\\n   299→\\t}\\n   300→\\tdefer reader.Close()\\n   301→\\n   302→\\tcontent, err := io.ReadAll(reader)\\n   303→\\tif err != nil {\\n   304→\\t\\tt.Fatalf(\\\"read blob content %s: %v\\\", ref.hash, err)\\n   305→\\t}\\n   306→\\n   307→\\treturn content\\n   308→}\\n   309→\\n   310→// tierNameForSize returns the human-readable tier name for a target size.\\n   311→func tierNameForSize(targetSize int) string {\\n   312→\\tfor _, tier := range sizeTiers {\\n   313→\\t\\tif tier.targetKey == targetSize {\\n   314→\\t\\t\\treturn tier.name\\n   315→\\t\\t}\\n   316→\\t}\\n   317→\\treturn formatBytes(int64(targetSize))\\n   318→}\\n   319→\\n   320→// --- Checkpoint seeding ---\\n   321→\\n   322→// seedCheckpoints writes N checkpoints using real transcripts from the source repo.\\n   323→// Returns the seeding duration and total bytes written.\\n   324→func seedCheckpoints(t *testing.T, store *checkpoint.GitStore, src *transcriptSource, count, transcriptSize int) (time.Duration, int64) {\\n   325→\\tt.Helper()\\n   326→\\n   327→\\tctx := context.Background()\\n   328→\\tstart := time.Now()\\n   329→\\tvar totalBytes int64\\n   330→\\n   331→\\t// Log progress for large scenarios.\\n   332→\\tlogInterval := progressInterval(count, transcriptSize)\\n   333→\\n   334→\\tfor i := range count {\\n   335→\\t\\tif logInterval > 0 && i > 0 && i%logInterval == 0 {\\n   336→\\t\\t\\tt.Logf(\\\"  seeding: %d/%d checkpoints (%s elapsed)\\\", i, count, time.Since(start).Round(time.Millisecond))\\n   337→\\t\\t}\\n   338→\\n   339→\\t\\ttranscript := src.get(t, transcriptSize, i)\\n   340→\\t\\ttotalBytes += int64(len(transcript))\\n   341→\\n   342→\\t\\tcpID, err := id.Generate()\\n   343→\\t\\tif err != nil {\\n   344→\\t\\t\\tt.Fatalf(\\\"id.Generate: %v\\\", err)\\n   345→\\t\\t}\\n   346→\\t\\terr = store.WriteCommitted(ctx, checkpoint.WriteCommittedOptions{\\n   347→\\t\\t\\tCheckpointID:     cpID,\\n   348→\\t\\t\\tSessionID:        fmt.Sprintf(\\\"perf-session-%d\\\", i),\\n   349→\\t\\t\\tAgent:            agent.AgentTypeClaudeCode,\\n   350→\\t\\t\\tTranscript:       transcript,\\n   351→\\t\\t\\tPrompts:          []string{\\\"Implement the feature\\\"},\\n   352→\\t\\t\\tCheckpointsCount: 1,\\n   353→\\t\\t\\tAuthorName:       \\\"Push Perf Test\\\",\\n   354→\\t\\t\\tAuthorEmail:      \\\"test@example.com\\\",\\n   355→\\t\\t})\\n   356→\\t\\tif err != nil {\\n   357→\\t\\t\\tt.Fatalf(\\\"WriteCommitted checkpoint %d: %v\\\", i, err)\\n   358→\\t\\t}\\n   359→\\t}\\n   360→\\n   361→\\treturn time.Since(start), totalBytes\\n   362→}\\n   363→\\n   364→// progressInterval returns how often to log seeding progress, or 0 to skip.\\n   365→func progressInterval(count, transcriptSize int) int {\\n   366→\\ttotalBytes := int64(count) * int64(transcriptSize)\\n   367→\\tswitch {\\n   368→\\tcase totalBytes > 500*1024*1024: // >500MB total\\n   369→\\t\\treturn 5\\n   370→\\tcase totalBytes > 100*1024*1024: // >100MB total\\n   371→\\t\\treturn 10\\n   372→\\tcase totalBytes > 20*1024*1024: // >20MB total\\n   373→\\t\\treturn 25\\n   374→\\tdefault:\\n   375→\\t\\treturn 0 // no progress logging for small scenarios\\n   376→\\t}\\n   377→}\\n   378→\\n   379→// --- Helper functions ---\\n   380→\\n   381→// createTempGitHubRepo creates a private GitHub repo and returns its clone URL.\\n   382→func createTempGitHubRepo(t *testing.T, fullName string) string {\\n   383→\\tt.Helper()\\n   384→\\n   385→\\t// Delete any leftover repo from a previous failed run.\\n   386→\\t//nolint:gosec // test-only helper, fullName is a constant\\n   387→\\tcleanupCmd := exec.Command(\\\"gh\\\", \\\"repo\\\", \\\"delete\\\", fullName, \\\"--yes\\\")\\n   388→\\t_ = cleanupCmd.Run() // ignore error if repo doesn't exist\\n   389→\\n   390→\\t//nolint:gosec // test-only helper, fullName is a constant\\n   391→\\tcmd := exec.Command(\\\"gh\\\", \\\"repo\\\", \\\"create\\\", fullName, \\\"--private\\\", \\\"--clone=false\\\")\\n   392→\\tout, err := cmd.CombinedOutput()\\n   393→\\tif err != nil {\\n   394→\\t\\tt.Fatalf(\\\"gh repo create failed: %v\\\\n%s\\\", err, out)\\n   395→\\t}\\n   396→\\n   397→\\treturn fmt.Sprintf(\\\"https://github.com/%s.git\\\", fullName)\\n   398→}\\n   399→\\n   400→// deleteTempGitHubRepo deletes the GitHub repo.\\n   401→func deleteTempGitHubRepo(t *testing.T, fullName string) {\\n   402→\\tt.Helper()\\n   403→\\n   404→\\t//nolint:gosec // test-only helper, fullName is a constant\\n   405→\\tcmd := exec.Command(\\\"gh\\\", \\\"repo\\\", \\\"delete\\\", fullName, \\\"--yes\\\")\\n   406→\\tout, err := cmd.CombinedOutput()\\n   407→\\tif err != nil {\\n   408→\\t\\tt.Logf(\\\"warning: gh repo delete failed (may need manual cleanup): %v\\\\n%s\\\", err, out)\\n   409→\\t}\\n   410→}\\n   411→\\n   412→// initLocalRepo initializes a git repo with an initial commit.\\n   413→func initLocalRepo(t *testing.T, dir string) *gogit.Repository {\\n   414→\\tt.Helper()\\n   415→\\n   416→\\trepo, err := gogit.PlainInit(dir, false)\\n   417→\\tif err != nil {\\n   418→\\t\\tt.Fatalf(\\\"PlainInit: %v\\\", err)\\n   419→\\t}\\n   420→\\n   421→\\twt, err := repo.Worktree()\\n   422→\\tif err != nil {\\n   423→\\t\\tt.Fatalf(\\\"Worktree: %v\\\", err)\\n   424→\\t}\\n   425→\\n   426→\\t// Create a README so we have a valid initial commit.\\n   427→\\treadmePath := filepath.Join(dir, \\\"README.md\\\")\\n   428→\\tif err := os.WriteFile(readmePath, []byte(\\\"# push perf test\\\\n\\\"), 0o644); err != nil {\\n   429→\\t\\tt.Fatalf(\\\"WriteFile: %v\\\", err)\\n   430→\\t}\\n   431→\\tif _, err := wt.Add(\\\"README.md\\\"); err != nil {\\n   432→\\t\\tt.Fatalf(\\\"Add: %v\\\", err)\\n   433→\\t}\\n   434→\\tif _, err := wt.Commit(\\\"initial commit\\\", &gogit.CommitOptions{\\n   435→\\t\\tAuthor: &object.Signature{\\n   436→\\t\\t\\tName:  \\\"Push Perf Test\\\",\\n   437→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   438→\\t\\t\\tWhen:  time.Now(),\\n   439→\\t\\t},\\n   440→\\t}); err != nil {\\n   441→\\t\\tt.Fatalf(\\\"Commit: %v\\\", err)\\n   442→\\t}\\n   443→\\n   444→\\treturn repo\\n   445→}\\n   446→\\n   447→// addRemote adds a git remote to the local repo.\\n   448→func addRemote(t *testing.T, dir, url string) {\\n   449→\\tt.Helper()\\n   450→\\n   451→\\tcmd := exec.Command(\\\"git\\\", \\\"remote\\\", \\\"add\\\", \\\"origin\\\", url)\\n   452→\\tcmd.Dir = dir\\n   453→\\tout, err := cmd.CombinedOutput()\\n   454→\\tif err != nil {\\n   455→\\t\\t// Remote may already exist from a previous call; try set-url instead.\\n   456→\\t\\tcmd2 := exec.Command(\\\"git\\\", \\\"remote\\\", \\\"set-url\\\", \\\"origin\\\", url)\\n   457→\\t\\tcmd2.Dir = dir\\n   458→\\t\\tout2, err2 := cmd2.CombinedOutput()\\n   459→\\t\\tif err2 != nil {\\n   460→\\t\\t\\tt.Fatalf(\\\"git remote add/set-url failed: %v\\\\n%s\\\\n%s\\\", err, out, out2)\\n   461→\\t\\t}\\n   462→\\t}\\n   463→}\\n   464→\\n   465→// timeGitGC runs git gc to pack objects and returns the duration.\\n   466→func timeGitGC(t *testing.T, dir string) time.Duration {\\n   467→\\tt.Helper()\\n   468→\\n   469→\\tstart := time.Now()\\n   470→\\tcmd := exec.Command(\\\"git\\\", \\\"gc\\\", \\\"--aggressive\\\", \\\"--prune=now\\\")\\n   471→\\tcmd.Dir = dir\\n   472→\\tout, err := cmd.CombinedOutput()\\n   473→\\tif err != nil {\\n   474→\\t\\tt.Fatalf(\\\"git gc: %v\\\\n%s\\\", err, out)\\n   475→\\t}\\n   476→\\treturn time.Since(start)\\n   477→}\\n   478→\\n   479→// formatBytes returns a human-readable size string.\\n   480→func formatBytes(b int64) string {\\n   481→\\tswitch {\\n   482→\\tcase b >= 1024*1024:\\n   483→\\t\\treturn fmt.Sprintf(\\\"%.1f MB\\\", float64(b)/(1024*1024))\\n   484→\\tcase b >= 1024:\\n   485→\\t\\treturn fmt.Sprintf(\\\"%d KB\\\", b/1024)\\n   486→\\tdefault:\\n   487→\\t\\treturn fmt.Sprintf(\\\"%d B\\\", b)\\n   488→\\t}\\n   489→}\\n   490→\\n   491→// measureRepoSize returns the loose object size, pack size, and total .git size in KB.\\n   492→func measureRepoSize(t *testing.T, dir string) (looseKB, packKB, totalKB int64) {\\n   493→\\tt.Helper()\\n   494→\\n   495→\\t// Parse git count-objects -v for loose/pack sizes.\\n   496→\\tcmd := exec.Command(\\\"git\\\", \\\"count-objects\\\", \\\"-v\\\")\\n   497→\\tcmd.Dir = dir\\n   498→\\tout, err := cmd.Output()\\n   499→\\tif err != nil {\\n   500→\\t\\tt.Fatalf(\\\"git count-objects: %v\\\", err)\\n   501→\\t}\\n   502→\\n   503→\\tfor _, line := range strings.Split(string(out), \\\"\\\\n\\\") {\\n   504→\\t\\tparts := strings.SplitN(line, \\\": \\\", 2)\\n   505→\\t\\tif len(parts) != 2 {\\n   506→\\t\\t\\tcontinue\\n   507→\\t\\t}\\n   508→\\t\\tkey := strings.TrimSpace(parts[0])\\n   509→\\t\\tval := strings.TrimSpace(parts[1])\\n   510→\\t\\tswitch key {\\n   511→\\t\\tcase \\\"size\\\": // loose object size in KB\\n   512→\\t\\t\\tv, _ := strconv.ParseInt(val, 10, 64)\\n   513→\\t\\t\\tlooseKB = v\\n   514→\\t\\tcase \\\"size-pack\\\": // pack size in KB\\n   515→\\t\\t\\tv, _ := strconv.ParseInt(val, 10, 64)\\n   516→\\t\\t\\tpackKB = v\\n   517→\\t\\t}\\n   518→\\t}\\n   519→\\n   520→\\t// Total .git directory size via du.\\n   521→\\tduCmd := exec.Command(\\\"du\\\", \\\"-sk\\\", filepath.Join(dir, \\\".git\\\"))\\n   522→\\tduOut, duErr := duCmd.Output()\\n   523→\\tif duErr == nil {\\n   524→\\t\\tparts := strings.Fields(string(duOut))\\n   525→\\t\\tif len(parts) > 0 {\\n   526→\\t\\t\\tv, _ := strconv.ParseInt(parts[0], 10, 64)\\n   527→\\t\\t\\ttotalKB = v\\n   528→\\t\\t}\\n   529→\\t}\\n   530→\\n   531→\\treturn looseKB, packKB, totalKB\\n   532→}\\n   533→\\n   534→// timePush times a regular (fast-forward) git push and returns the wall-clock duration.\\n   535→func timePush(t *testing.T, dir, remote, branch string) time.Duration {\\n   536→\\tt.Helper()\\n   537→\\treturn doTimedPush(t, dir, \\\"git\\\", \\\"push\\\", remote, \\\"refs/heads/\\\"+branch)\\n   538→}\\n   539→\\n   540→// timeForcePush times a force push and returns the wall-clock duration.\\n   541→// Used when each subtest has independent history unrelated to what's already on the remote.\\n   542→func timeForcePush(t *testing.T, dir, remote, branch string) time.Duration {\\n   543→\\tt.Helper()\\n   544→\\treturn doTimedPush(t, dir, \\\"git\\\", \\\"push\\\", \\\"--force\\\", remote, \\\"refs/heads/\\\"+branch)\\n   545→}\\n   546→\\n   547→// doTimedPush runs a git push command and returns its wall-clock duration.\\n   548→func doTimedPush(t *testing.T, dir string, args ...string) time.Duration {\\n   549→\\tt.Helper()\\n   550→\\n   551→\\tvar stderr bytes.Buffer\\n   552→\\tcmd := exec.Command(args[0], args[1:]...)\\n   553→\\tcmd.Dir = dir\\n   554→\\tcmd.Stderr = &stderr\\n   555→\\n   556→\\tstart := time.Now()\\n   557→\\terr := cmd.Run()\\n   558→\\tdur := time.Since(start)\\n   559→\\n   560→\\tif err != nil {\\n   561→\\t\\tt.Fatalf(\\\"git push failed (%s): %v\\\\n%s\\\", dur, err, stderr.String())\\n   562→\\t}\\n   563→\\n   564→\\treturn dur\\n   565→}\\n   566→\\n   567→// --- Push profiling ---\\n   568→\\n   569→// pushPhase represents a timed phase within a git push operation.\\n   570→type pushPhase struct {\\n   571→\\tname     string\\n   572→\\tduration time.Duration\\n   573→}\\n   574→\\n   575→// pushProfileResult holds the detailed timing breakdown of a git push.\\n   576→type pushProfileResult struct {\\n   577→\\ttotal          time.Duration\\n   578→\\tphases         []pushPhase\\n   579→\\tprogressOutput string\\n   580→}\\n   581→\\n   582→// trace2Event represents a single GIT_TRACE2_EVENT JSON line.\\n   583→type trace2Event struct {\\n   584→\\tEvent      string   `json:\\\"event\\\"`\\n   585→\\tSID        string   `json:\\\"sid\\\"`\\n   586→\\tCategory   string   `json:\\\"category\\\"`\\n   587→\\tLabel      string   `json:\\\"label\\\"`\\n   588→\\tTRel       float64  `json:\\\"t_rel\\\"`\\n   589→\\tTAbs       float64  `json:\\\"t_abs\\\"`\\n   590→\\tNesting    int      `json:\\\"nesting\\\"`\\n   591→\\tArgv       []string `json:\\\"argv\\\"`\\n   592→\\tChildID    int      `json:\\\"child_id\\\"`\\n   593→\\tChildClass string   `json:\\\"child_class\\\"`\\n   594→\\tCode       int      `json:\\\"code\\\"`\\n   595→}\\n   596→\\n   597→// TestPushProfile runs a small number of scenarios with detailed push timing\\n   598→// breakdown using GIT_TRACE2_EVENT to identify where time is spent.\\n   599→//\\n   600→// Run with: go test -v -run TestPushProfile -tags pushperf -timeout 10m ./cmd/entire/cli/checkpoint/\\n   601→func TestPushProfile(t *testing.T) {\\n   602→\\tfullName := perfTestRepoOwner + \\\"/\\\" + perfTestRepoName\\n   603→\\tsrc := newTranscriptSource(t)\\n   604→\\trepoURL := createTempGitHubRepo(t, fullName)\\n   605→\\tt.Cleanup(func() { deleteTempGitHubRepo(t, fullName) })\\n   606→\\n   607→\\ttype scenario struct {\\n   608→\\t\\tname           string\\n   609→\\t\\tcheckpoints    int\\n   610→\\t\\ttranscriptSize int\\n   611→\\t}\\n   612→\\n   613→\\tfirstPush := []scenario{\\n   614→\\t\\t{\\\"10cp_100KB\\\", 10, 100 * 1024},\\n   615→\\t\\t{\\\"50cp_500KB\\\", 50, 500 * 1024},\\n   616→\\t\\t{\\\"50cp_2500KB\\\", 50, 2500 * 1024},\\n   617→\\t\\t{\\\"100cp_2500KB\\\", 100, 2500 * 1024},\\n   618→\\t\\t{\\\"200cp_2500KB\\\", 200, 2500 * 1024},\\n   619→\\t\\t{\\\"50cp_10MB\\\", 50, 10 * 1024 * 1024},\\n   620→\\t\\t{\\\"10cp_50MB\\\", 10, 50 * 1024 * 1024},\\n   621→\\t}\\n   622→\\n   623→\\tincremental := []scenario{\\n   624→\\t\\t{\\\"50cp_base_500KB\\\", 50, 500 * 1024},\\n   625→\\t\\t{\\\"50cp_base_2500KB\\\", 50, 2500 * 1024},\\n   626→\\t\\t{\\\"200cp_base_2500KB\\\", 200, 2500 * 1024},\\n   627→\\t\\t{\\\"50cp_base_10MB\\\", 50, 10 * 1024 * 1024},\\n   628→\\t}\\n   629→\\n   630→\\tvar results []profileResult\\n   631→\\n   632→\\tfor _, sc := range firstPush {\\n   633→\\t\\tt.Run(\\\"FirstPush/\\\"+sc.name, func(t *testing.T) {\\n   634→\\t\\t\\tdir := t.TempDir()\\n   635→\\t\\t\\trepo := initLocalRepo(t, dir)\\n   636→\\t\\t\\tstore := checkpoint.NewGitStore(repo)\\n   637→\\n   638→\\t\\t\\tseedDur, totalBytes := seedCheckpoints(t, store, src, sc.checkpoints, sc.transcriptSize)\\n   639→\\t\\t\\tgcDur := timeGitGC(t, dir)\\n   640→\\t\\t\\t_, pk, _ := measureRepoSize(t, dir)\\n   641→\\t\\t\\taddRemote(t, dir, repoURL)\\n   642→\\n   643→\\t\\t\\tprofile := profiledForcePush(t, dir, \\\"origin\\\", \\\"entire/checkpoints/v1\\\")\\n   644→\\n   645→\\t\\t\\tt.Logf(\\\"  Seed: %s, GC: %s\\\", seedDur.Round(time.Millisecond), gcDur.Round(time.Millisecond))\\n   646→\\t\\t\\tlogPushProfile(t, profile)\\n   647→\\n   648→\\t\\t\\tr := buildResult(\\\"FirstPush/\\\"+sc.name, float64(totalBytes)/(1024*1024), pk, profile)\\n   649→\\t\\t\\tresults = append(results, r)\\n   650→\\t\\t})\\n   651→\\t}\\n   652→\\n   653→\\tfor _, sc := range incremental {\\n   654→\\t\\tt.Run(\\\"Incremental/\\\"+sc.name, func(t *testing.T) {\\n   655→\\t\\t\\tdir := t.TempDir()\\n   656→\\t\\t\\trepo := initLocalRepo(t, dir)\\n   657→\\t\\t\\tstore := checkpoint.NewGitStore(repo)\\n   658→\\n   659→\\t\\t\\t// Seed and push baseline.\\n   660→\\t\\t\\t_, _ = seedCheckpoints(t, store, src, sc.checkpoints, sc.transcriptSize)\\n   661→\\t\\t\\ttimeGitGC(t, dir)\\n   662→\\t\\t\\taddRemote(t, dir, repoURL)\\n   663→\\t\\t\\ttimeForcePush(t, dir, \\\"origin\\\", \\\"entire/checkpoints/v1\\\")\\n   664→\\n   665→\\t\\t\\t// Reopen repo after GC.\\n   666→\\t\\t\\trepo, err := gogit.PlainOpen(dir)\\n   667→\\t\\t\\tif err != nil {\\n   668→\\t\\t\\t\\tt.Fatalf(\\\"PlainOpen after gc: %v\\\", err)\\n   669→\\t\\t\\t}\\n   670→\\t\\t\\tstore = checkpoint.NewGitStore(repo)\\n   671→\\n   672→\\t\\t\\t// Add 1 more checkpoint and profile the incremental push.\\n   673→\\t\\t\\t_, incrBytes := seedCheckpoints(t, store, src, 1, sc.transcriptSize)\\n   674→\\t\\t\\ttimeGitGC(t, dir)\\n   675→\\t\\t\\t_, pk, _ := measureRepoSize(t, dir)\\n   676→\\n   677→\\t\\t\\tprofile := profiledPush(t, dir, \\\"origin\\\", \\\"entire/checkpoints/v1\\\")\\n   678→\\n   679→\\t\\t\\tlogPushProfile(t, profile)\\n   680→\\n   681→\\t\\t\\tr := buildResult(\\\"Incremental/\\\"+sc.name, float64(incrBytes)/(1024*1024), pk, profile)\\n   682→\\t\\t\\tresults = append(results, r)\\n   683→\\t\\t})\\n   684→\\t}\\n   685→\\n   686→\\t// Print final summary table.\\n   687→\\tt.Logf(\\\"\\\\n\\\\n========== PUSH PROFILE SUMMARY TABLE ==========\\\")\\n   688→\\tt.Logf(\\\"%-30s | %8s | %8s | %10s | %10s | %10s | %10s | %10s\\\",\\n   689→\\t\\t\\\"Scenario\\\", \\\"Raw MB\\\", \\\"Pack KB\\\", \\\"Negotiate\\\", \\\"Pack+Send\\\", \\\"Remote\\\", \\\"Overhead\\\", \\\"TOTAL\\\")\\n   690→\\tt.Logf(\\\"%s\\\", strings.Repeat(\\\"-\\\", 120))\\n   691→\\tfor _, r := range results {\\n   692→\\t\\tt.Logf(\\\"%-30s | %8.1f | %8d | %10s | %10s | %10s | %10s | %10s\\\",\\n   693→\\t\\t\\tr.scenario, r.rawMB, r.packKB,\\n   694→\\t\\t\\tr.negotiate.Round(time.Millisecond),\\n   695→\\t\\t\\tr.packSend.Round(time.Millisecond),\\n   696→\\t\\t\\tr.remoteProc.Round(time.Millisecond),\\n   697→\\t\\t\\tr.overhead.Round(time.Millisecond),\\n   698→\\t\\t\\tr.totalPush.Round(time.Millisecond))\\n   699→\\t}\\n   700→\\tt.Logf(\\\"%s\\\", strings.Repeat(\\\"-\\\", 120))\\n   701→}\\n   702→\\n   703→// profileResult holds aggregated push phase timings for a single scenario.\\n   704→type profileResult struct {\\n   705→\\tscenario   string\\n   706→\\trawMB      float64\\n   707→\\tpackKB     int64\\n   708→\\tnegotiate  time.Duration\\n   709→\\tpackSend   time.Duration\\n   710→\\tremoteProc time.Duration\\n   711→\\toverhead   time.Duration\\n   712→\\ttotalPush  time.Duration\\n   713→}\\n   714→\\n   715→// buildResult extracts the key phase durations from a push profile.\\n   716→func buildResult(name string, rawMB float64, packKB int64, profile pushProfileResult) profileResult {\\n   717→\\tvar negotiate, packSend, remoteProc time.Duration\\n   718→\\tfor _, p := range profile.phases {\\n   719→\\t\\tn := strings.TrimSpace(p.name)\\n   720→\\t\\tswitch n {\\n   721→\\t\\tcase \\\"transport_push/get_refs_list\\\":\\n   722→\\t\\t\\tnegotiate = p.duration\\n   723→\\t\\tcase \\\"send_pack/pack_objects\\\":\\n   724→\\t\\t\\tpackSend = p.duration\\n   725→\\t\\tcase \\\"send_pack/receive_status\\\":\\n   726→\\t\\t\\tremoteProc = p.duration\\n   727→\\t\\t}\\n   728→\\t}\\n   729→\\toverhead := profile.total - negotiate - packSend - remoteProc\\n   730→\\tif overhead < 0 {\\n   731→\\t\\toverhead = 0\\n   732→\\t}\\n   733→\\treturn profileResult{\\n   734→\\t\\tscenario:   name,\\n   735→\\t\\trawMB:      rawMB,\\n   736→\\t\\tpackKB:     packKB,\\n   737→\\t\\tnegotiate:  negotiate,\\n   738→\\t\\tpackSend:   packSend,\\n   739→\\t\\tremoteProc: remoteProc,\\n   740→\\t\\toverhead:   overhead,\\n   741→\\t\\ttotalPush:  profile.total,\\n   742→\\t}\\n   743→}\\n   744→\\n   745→// profiledForcePush runs a force push with GIT_TRACE2_EVENT tracing enabled.\\n   746→func profiledForcePush(t *testing.T, dir, remote, branch string) pushProfileResult {\\n   747→\\tt.Helper()\\n   748→\\treturn doProfiledPush(t, dir, \\\"git\\\", \\\"push\\\", \\\"--force\\\", \\\"--progress\\\", remote, \\\"refs/heads/\\\"+branch)\\n   749→}\\n   750→\\n   751→// doProfiledPush runs a git push with GIT_TRACE2_EVENT tracing and returns the profile.\\n   752→func doProfiledPush(t *testing.T, dir string, args ...string) pushProfileResult {\\n   753→\\tt.Helper()\\n   754→\\n   755→\\ttraceDir := t.TempDir()\\n   756→\\ttraceFile := filepath.Join(traceDir, \\\"trace2.jsonl\\\")\\n   757→\\n   758→\\tvar stderr bytes.Buffer\\n   759→\\t//nolint:gosec // test-only, args are test constants\\n   760→\\tcmd := exec.Command(args[0], args[1:]...)\\n   761→\\tcmd.Dir = dir\\n   762→\\tcmd.Stderr = &stderr\\n   763→\\tcmd.Env = append(os.Environ(),\\n   764→\\t\\t\\\"GIT_TRACE2_EVENT=\\\"+traceFile,\\n   765→\\t)\\n   766→\\n   767→\\tstart := time.Now()\\n   768→\\terr := cmd.Run()\\n   769→\\ttotal := time.Since(start)\\n   770→\\n   771→\\tif err != nil {\\n   772→\\t\\tt.Fatalf(\\\"profiled push failed (%s): %v\\\\n%s\\\", total, err, stderr.String())\\n   773→\\t}\\n   774→\\n   775→\\ttraceData, err := os.ReadFile(traceFile)\\n   776→\\tif err != nil {\\n   777→\\t\\tt.Logf(\\\"warning: could not read trace file: %v\\\", err)\\n   778→\\t\\treturn pushProfileResult{total: total, progressOutput: stderr.String()}\\n   779→\\t}\\n   780→\\n   781→\\tphases := parseTrace2Phases(t, traceData)\\n   782→\\n   783→\\treturn pushProfileResult{\\n   784→\\t\\ttotal:          total,\\n   785→\\t\\tphases:         phases,\\n   786→\\t\\tprogressOutput: stderr.String(),