KfaCCZtnjXJkHi\",\"type\":\"tool_result\",\"content\":\"     1→package cli\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"errors\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"io\\\"\\n     8→\\t\\\"os\\\"\\n     9→\\t\\\"path/filepath\\\"\\n    10→\\t\\\"strings\\\"\\n    11→\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    17→\\n    18→\\t\\\"github.com/charmbracelet/huh\\\"\\n    19→\\t\\\"github.com/spf13/cobra\\\"\\n    20→\\t\\\"github.com/spf13/pflag\\\"\\n    21→)\\n    22→\\n    23→// Config path display strings\\n    24→const (\\n    25→\\tconfigDisplayProject = \\\".entire/settings.json\\\"\\n    26→\\tconfigDisplayLocal   = \\\".entire/settings.local.json\\\"\\n    27→)\\n    28→\\n    29→func newEnableCmd() *cobra.Command {\\n    30→\\tvar localDev bool\\n    31→\\tvar ignoreUntracked bool\\n    32→\\tvar useLocalSettings bool\\n    33→\\tvar useProjectSettings bool\\n    34→\\tvar agentName string\\n    35→\\tvar forceHooks bool\\n    36→\\tvar skipPushSessions bool\\n    37→\\tvar telemetry bool\\n    38→\\n    39→\\tcmd := &cobra.Command{\\n    40→\\t\\tUse:   \\\"enable\\\",\\n    41→\\t\\tShort: \\\"Enable Entire in current project\\\",\\n    42→\\t\\tLong: `Enable Entire with session tracking for your AI agent workflows.\\n    43→\\n    44→Uses the manual-commit strategy, which creates session checkpoints without\\n    45→modifying your active branch.`,\\n    46→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    47→\\t\\t\\tctx := cmd.Context()\\n    48→\\t\\t\\t// Check if we're in a git repository first - this is a prerequisite error,\\n    49→\\t\\t\\t// not a usage error, so we silence Cobra's output and use SilentError\\n    50→\\t\\t\\t// to prevent duplicate error output in main.go\\n    51→\\t\\t\\tif _, err := paths.WorktreeRoot(ctx); err != nil {\\n    52→\\t\\t\\t\\tfmt.Fprintln(cmd.ErrOrStderr(), \\\"Not a git repository. Please run 'entire enable' from within a git repository.\\\")\\n    53→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n    54→\\t\\t\\t}\\n    55→\\n    56→\\t\\t\\tif err := validateSetupFlags(useLocalSettings, useProjectSettings); err != nil {\\n    57→\\t\\t\\t\\treturn err\\n    58→\\t\\t\\t}\\n    59→\\n    60→\\t\\t\\t// Warn if repo has no commits yet\\n    61→\\t\\t\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n    62→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Note: This repository has no commits yet. Entire will be configured, but\\\")\\n    63→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"session checkpoints won't work until you create your first commit.\\\")\\n    64→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout())\\n    65→\\t\\t\\t}\\n    66→\\n    67→\\t\\t\\t// Non-interactive mode if --agent flag is provided\\n    68→\\t\\t\\tif cmd.Flags().Changed(\\\"agent\\\") && agentName == \\\"\\\" {\\n    69→\\t\\t\\t\\tprintMissingAgentError(cmd.ErrOrStderr())\\n    70→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n    71→\\t\\t\\t}\\n    72→\\n    73→\\t\\t\\tif agentName != \\\"\\\" {\\n    74→\\t\\t\\t\\tag, err := agent.Get(agent.AgentName(agentName))\\n    75→\\t\\t\\t\\tif err != nil {\\n    76→\\t\\t\\t\\t\\tprintWrongAgentError(cmd.ErrOrStderr(), agentName)\\n    77→\\t\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"wrong agent name\\\"))\\n    78→\\t\\t\\t\\t}\\n    79→\\t\\t\\t\\t// --agent is a targeted operation: set up this specific agent without\\n    80→\\t\\t\\t\\t// affecting other agents. Unlike the interactive path, it does not\\n    81→\\t\\t\\t\\t// uninstall hooks for other previously-enabled agents.\\n    82→\\t\\t\\t\\treturn setupAgentHooksNonInteractive(ctx, cmd.OutOrStdout(), ag, localDev, forceHooks, skipPushSessions, telemetry)\\n    83→\\t\\t\\t}\\n    84→\\t\\t\\t// Detect or prompt for agents\\n    85→\\t\\t\\tagents, err := detectOrSelectAgent(ctx, cmd.OutOrStdout(), nil)\\n    86→\\t\\t\\tif err != nil {\\n    87→\\t\\t\\t\\treturn fmt.Errorf(\\\"agent selection failed: %w\\\", err)\\n    88→\\t\\t\\t}\\n    89→\\n    90→\\t\\t\\treturn runEnableInteractive(ctx, cmd.OutOrStdout(), agents, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry)\\n    91→\\t\\t},\\n    92→\\t}\\n    93→\\tcmd.Flags().StringVar(&agentName, \\\"agent\\\", \\\"\\\", \\\"Agent to set up hooks for (e.g., \\\"+strings.Join(agent.StringList(), \\\", \\\")+\\\"). Enables non-interactive mode.\\\")\\n    94→\\tcmd.Flags().BoolVar(&localDev, \\\"local-dev\\\", false, \\\"Use go run instead of entire binary for hooks\\\")\\n    95→\\tcmd.Flags().MarkHidden(\\\"local-dev\\\") //nolint:errcheck,gosec // flag is defined above\\n    96→\\tcmd.Flags().BoolVar(&ignoreUntracked, \\\"ignore-untracked\\\", false, \\\"Commit all new files without tracking pre-existing untracked files\\\")\\n    97→\\tcmd.Flags().MarkHidden(\\\"ignore-untracked\\\") //nolint:errcheck,gosec // flag is defined above\\n    98→\\tcmd.Flags().BoolVar(&useLocalSettings, \\\"local\\\", false, \\\"Write settings to .entire/settings.local.json instead of .entire/settings.json\\\")\\n    99→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Write settings to .entire/settings.json even if it already exists\\\")\\n   100→\\tcmd.Flags().BoolVarP(&forceHooks, \\\"force\\\", \\\"f\\\", false, \\\"Force reinstall hooks (removes existing Entire hooks first)\\\")\\n   101→\\tcmd.Flags().BoolVar(&skipPushSessions, \\\"skip-push-sessions\\\", false, \\\"Disable automatic pushing of session logs on git push\\\")\\n   102→\\tcmd.Flags().BoolVar(&telemetry, \\\"telemetry\\\", true, \\\"Enable anonymous usage analytics\\\")\\n   103→\\n   104→\\t// Provide a helpful error when --agent is used without a value\\n   105→\\tdefaultFlagErr := cmd.FlagErrorFunc()\\n   106→\\tcmd.SetFlagErrorFunc(func(c *cobra.Command, err error) error {\\n   107→\\t\\tvar valErr *pflag.ValueRequiredError\\n   108→\\t\\tif errors.As(err, &valErr) && valErr.GetSpecifiedName() == \\\"agent\\\" {\\n   109→\\t\\t\\tprintMissingAgentError(c.ErrOrStderr())\\n   110→\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n   111→\\t\\t}\\n   112→\\t\\treturn defaultFlagErr(c, err)\\n   113→\\t})\\n   114→\\n   115→\\t// Add subcommands for automation/testing\\n   116→\\tcmd.AddCommand(newSetupGitHookCmd())\\n   117→\\n   118→\\treturn cmd\\n   119→}\\n   120→\\n   121→func newDisableCmd() *cobra.Command {\\n   122→\\tvar useProjectSettings bool\\n   123→\\tvar uninstall bool\\n   124→\\tvar force bool\\n   125→\\n   126→\\tcmd := &cobra.Command{\\n   127→\\t\\tUse:   \\\"disable\\\",\\n   128→\\t\\tShort: \\\"Disable Entire in current project\\\",\\n   129→\\t\\tLong: `Disable Entire integrations in the current project.\\n   130→\\n   131→By default, this command will disable Entire. Hooks will exit silently and commands will\\n   132→show a disabled message.\\n   133→\\n   134→To completely remove Entire integrations from this repository, use --uninstall:\\n   135→  - .entire/ directory (settings, logs, metadata)\\n   136→  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\n   137→  - Session state files (.git/entire-sessions/)\\n   138→  - Shadow branches (entire/<hash>)\\n   139→  - Agent hooks`,\\n   140→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   141→\\t\\t\\tctx := cmd.Context()\\n   142→\\t\\t\\tif uninstall {\\n   143→\\t\\t\\t\\treturn runUninstall(ctx, cmd.OutOrStdout(), cmd.ErrOrStderr(), force)\\n   144→\\t\\t\\t}\\n   145→\\t\\t\\treturn runDisable(ctx, cmd.OutOrStdout(), useProjectSettings)\\n   146→\\t\\t},\\n   147→\\t}\\n   148→\\n   149→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Update .entire/settings.json instead of .entire/settings.local.json\\\")\\n   150→\\tcmd.Flags().BoolVar(&uninstall, \\\"uninstall\\\", false, \\\"Completely remove Entire from this repository\\\")\\n   151→\\tcmd.Flags().BoolVar(&force, \\\"force\\\", false, \\\"Skip confirmation prompt (use with --uninstall)\\\")\\n   152→\\n   153→\\treturn cmd\\n   154→}\\n   155→\\n   156→// runEnableInteractive runs the interactive enable flow.\\n   157→// agents must be provided by the caller (via detectOrSelectAgent).\\n   158→func runEnableInteractive(ctx context.Context, w io.Writer, agents []agent.Agent, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry bool) error {\\n   159→\\t// Uninstall hooks for agents that were previously active but are no longer selected\\n   160→\\tif err := uninstallDeselectedAgentHooks(ctx, w, agents); err != nil {\\n   161→\\t\\treturn fmt.Errorf(\\\"failed to clean up deselected agents: %w\\\", err)\\n   162→\\t}\\n   163→\\n   164→\\t// Setup agent hooks for all selected agents\\n   165→\\tfor _, ag := range agents {\\n   166→\\t\\tif _, err := setupAgentHooks(ctx, ag, localDev, forceHooks); err != nil {\\n   167→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   168→\\t\\t}\\n   169→\\t}\\n   170→\\n   171→\\t// Setup .entire directory\\n   172→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   173→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   174→\\t}\\n   175→\\n   176→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   177→\\tsettings, err := LoadEntireSettings(ctx)\\n   178→\\tif err != nil {\\n   179→\\t\\t// If we can't load, start with defaults\\n   180→\\t\\tsettings = &EntireSettings{}\\n   181→\\t}\\n   182→\\t// Update the specific fields\\n   183→\\tsettings.LocalDev = localDev\\n   184→\\tsettings.Enabled = true\\n   185→\\n   186→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   187→\\tif skipPushSessions {\\n   188→\\t\\tif settings.StrategyOptions == nil {\\n   189→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   190→\\t\\t}\\n   191→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   192→\\t}\\n   193→\\n   194→\\t// Determine which settings file to write to\\n   195→\\t// First run always creates settings.json (no prompt)\\n   196→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   197→\\tif err != nil {\\n   198→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   199→\\t}\\n   200→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   201→\\n   202→\\tif showNotification {\\n   203→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   204→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   205→\\t}\\n   206→\\n   207→\\t// Save settings to the appropriate file.\\n   208→\\tsaveSettings := func() error {\\n   209→\\t\\tif shouldUseLocal {\\n   210→\\t\\t\\treturn SaveEntireSettingsLocal(ctx, settings)\\n   211→\\t\\t}\\n   212→\\t\\treturn SaveEntireSettings(ctx, settings)\\n   213→\\t}\\n   214→\\tif err := saveSettings(); err != nil {\\n   215→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   216→\\t}\\n   217→\\n   218→\\tif _, err := strategy.InstallGitHook(ctx, true, localDev); err != nil {\\n   219→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   220→\\t}\\n   221→\\tstrategy.CheckAndWarnHookManagers(ctx, w, localDev)\\n   222→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   223→\\n   224→\\tconfigDisplay := configDisplayProject\\n   225→\\tif shouldUseLocal {\\n   226→\\t\\tconfigDisplay = configDisplayLocal\\n   227→\\t}\\n   228→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   229→\\n   230→\\t// Ask about telemetry consent (only if not already asked)\\n   231→\\tfmt.Fprintln(w)\\n   232→\\tif err := promptTelemetryConsent(settings, telemetry); err != nil {\\n   233→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   234→\\t}\\n   235→\\t// Save again to persist telemetry choice\\n   236→\\tif err := saveSettings(); err != nil {\\n   237→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   238→\\t}\\n   239→\\n   240→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   241→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   242→\\t}\\n   243→\\n   244→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   245→\\n   246→\\treturn nil\\n   247→}\\n   248→\\n   249→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   250→func runEnable(ctx context.Context, w io.Writer) error {\\n   251→\\tsettings, err := LoadEntireSettings(ctx)\\n   252→\\tif err != nil {\\n   253→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   254→\\t}\\n   255→\\n   256→\\tsettings.Enabled = true\\n   257→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   258→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   259→\\t}\\n   260→\\n   261→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   262→\\treturn nil\\n   263→}\\n   264→\\n   265→func runDisable(ctx context.Context, w io.Writer, useProjectSettings bool) error {\\n   266→\\tsettings, err := LoadEntireSettings(ctx)\\n   267→\\tif err != nil {\\n   268→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   269→\\t}\\n   270→\\n   271→\\tsettings.Enabled = false\\n   272→\\n   273→\\t// If --project flag is specified, always write to project settings\\n   274→\\tif useProjectSettings {\\n   275→\\t\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   276→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   277→\\t\\t}\\n   278→\\t} else {\\n   279→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   280→\\t\\tif err := SaveEntireSettingsLocal(ctx, settings); err != nil {\\n   281→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   282→\\t\\t}\\n   283→\\t}\\n   284→\\n   285→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   286→\\treturn nil\\n   287→}\\n   288→\\n   289→// DisabledMessage is the message shown when Entire is disabled\\n   290→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   291→\\n   292→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   293→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   294→// On error reading settings, defaults to enabled (returns false).\\n   295→func checkDisabledGuard(ctx context.Context, w io.Writer) bool {\\n   296→\\tenabled, err := IsEnabled(ctx)\\n   297→\\tif err != nil {\\n   298→\\t\\t// Default to enabled on error\\n   299→\\t\\treturn false\\n   300→\\t}\\n   301→\\tif !enabled {\\n   302→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   303→\\t\\treturn true\\n   304→\\t}\\n   305→\\treturn false\\n   306→}\\n   307→\\n   308→// uninstallDeselectedAgentHooks removes hooks for agents that were previously\\n   309→// installed but are not in the selected list. This handles the case where a user\\n   310→// re-runs `entire enable` and deselects an agent.\\n   311→func uninstallDeselectedAgentHooks(ctx context.Context, w io.Writer, selectedAgents []agent.Agent) error {\\n   312→\\tinstalledNames := GetAgentsWithHooksInstalled(ctx)\\n   313→\\tif len(installedNames) == 0 {\\n   314→\\t\\treturn nil\\n   315→\\t}\\n   316→\\n   317→\\tselectedSet := make(map[agent.AgentName]struct{}, len(selectedAgents))\\n   318→\\tfor _, ag := range selectedAgents {\\n   319→\\t\\tselectedSet[ag.Name()] = struct{}{}\\n   320→\\t}\\n   321→\\n   322→\\tvar errs []error\\n   323→\\tfor _, name := range installedNames {\\n   324→\\t\\tif _, selected := selectedSet[name]; selected {\\n   325→\\t\\t\\tcontinue\\n   326→\\t\\t}\\n   327→\\t\\tag, err := agent.Get(name)\\n   328→\\t\\tif err != nil {\\n   329→\\t\\t\\tcontinue\\n   330→\\t\\t}\\n   331→\\t\\thookAgent, ok := ag.(agent.HookSupport)\\n   332→\\t\\tif !ok {\\n   333→\\t\\t\\tcontinue\\n   334→\\t\\t}\\n   335→\\t\\tif err := hookAgent.UninstallHooks(ctx); err != nil {\\n   336→\\t\\t\\terrs = append(errs, fmt.Errorf(\\\"failed to uninstall %s hooks: %w\\\", ag.Type(), err))\\n   337→\\t\\t} else {\\n   338→\\t\\t\\tfmt.Fprintf(w, \\\"Removed %s hooks\\\\n\\\", ag.Type())\\n   339→\\t\\t}\\n   340→\\t}\\n   341→\\treturn errors.Join(errs...)\\n   342→}\\n   343→\\n   344→// setupAgentHooks sets up hooks for a given agent.\\n   345→// Returns the number of hooks installed (0 if already installed).\\n   346→func setupAgentHooks(ctx context.Context, ag agent.Agent, localDev, forceHooks bool) (int, error) {\\n   347→\\thookAgent, ok := ag.(agent.HookSupport)\\n   348→\\tif !ok {\\n   349→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   350→\\t}\\n   351→\\n   352→\\tcount, err := hookAgent.InstallHooks(ctx, localDev, forceHooks)\\n   353→\\tif err != nil {\\n   354→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   355→\\t}\\n   356→\\n   357→\\treturn count, nil\\n   358→}\\n   359→\\n   360→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   361→// Returns the detected/selected agents and any error.\\n   362→//\\n   363→// On first run (no hooks installed):\\n   364→//   - Single detected agent: used automatically\\n   365→//   - Multiple/no detected agents: interactive multi-select prompt\\n   366→//\\n   367→// On re-run (hooks already installed):\\n   368→//   - Always shows the interactive multi-select\\n   369→//   - Pre-selects only agents that have hooks installed (respects prior deselection)\\n   370→//\\n   371→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   372→// It receives available agent names and returns the selected names.\\n   373→func detectOrSelectAgent(ctx context.Context, w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   374→\\t// Check for agents with hooks already installed (re-run detection)\\n   375→\\tinstalledAgentNames := GetAgentsWithHooksInstalled(ctx)\\n   376→\\thasInstalledHooks := len(installedAgentNames) > 0\\n   377→\\n   378→\\t// Try auto-detection\\n   379→\\tdetected := agent.DetectAll(ctx)\\n   380→\\n   381→\\t// First run: use existing auto-detect shortcuts\\n   382→\\tif !hasInstalledHooks {\\n   383→\\t\\tswitch {\\n   384→\\t\\tcase len(detected) == 1:\\n   385→\\t\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   386→\\t\\t\\treturn detected, nil\\n   387→\\n   388→\\t\\tcase len(detected) > 1:\\n   389→\\t\\t\\tagentTypes := make([]string, 0, len(detected))\\n   390→\\t\\t\\tfor _, ag := range detected {\\n   391→\\t\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   392→\\t\\t\\t}\\n   393→\\t\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   394→\\t\\t\\tfmt.Fprintln(w)\\n   395→\\t\\t}\\n   396→\\t}\\n   397→\\n   398→\\t// Check if we can prompt interactively\\n   399→\\tif !canPromptInteractively() {\\n   400→\\t\\tif hasInstalledHooks {\\n   401→\\t\\t\\t// Re-run without TTY — keep currently installed agents\\n   402→\\t\\t\\tagents := make([]agent.Agent, 0, len(installedAgentNames))\\n   403→\\t\\t\\tfor _, name := range installedAgentNames {\\n   404→\\t\\t\\t\\tag, err := agent.Get(name)\\n   405→\\t\\t\\t\\tif err != nil {\\n   406→\\t\\t\\t\\t\\tcontinue\\n   407→\\t\\t\\t\\t}\\n   408→\\t\\t\\t\\tagents = append(agents, ag)\\n   409→\\t\\t\\t}\\n   410→\\t\\t\\treturn agents, nil\\n   411→\\t\\t}\\n   412→\\t\\tif len(detected) > 0 {\\n   413→\\t\\t\\treturn detected, nil\\n   414→\\t\\t}\\n   415→\\t\\tdefaultAgent := agent.Default()\\n   416→\\t\\tif defaultAgent == nil {\\n   417→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   418→\\t\\t}\\n   419→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   420→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   421→\\t}\\n   422→\\n   423→\\tif !hasInstalledHooks && len(detected) == 0 {\\n   424→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., \\\"+strings.Join(agent.StringList(), \\\", \\\")+\\\").\\\")\\n   425→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   426→\\t\\tfmt.Fprintln(w)\\n   427→\\t}\\n   428→\\n   429→\\t// Build pre-selection set.\\n   430→\\t// On re-run: only pre-select agents with hooks installed (respect prior deselection).\\n   431→\\t// On first run: pre-select all detected agents.\\n   432→\\tpreSelectedSet := make(map[agent.AgentName]struct{})\\n   433→\\tif hasInstalledHooks {\\n   434→\\t\\tfor _, name := range installedAgentNames {\\n   435→\\t\\t\\tpreSelectedSet[name] = struct{}{}\\n   436→\\t\\t}\\n   437→\\t} else {\\n   438→\\t\\tfor _, ag := range detected {\\n   439→\\t\\t\\tpreSelectedSet[ag.Name()] = struct{}{}\\n   440→\\t\\t}\\n   441→\\t}\\n   442→\\n   443→\\t// Build options from registered agents\\n   444→\\tagentNames := agent.List()\\n   445→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   446→\\tfor _, name := range agentNames {\\n   447→\\t\\tag, err := agent.Get(name)\\n   448→\\t\\tif err != nil {\\n   449→\\t\\t\\tcontinue\\n   450→\\t\\t}\\n   451→\\t\\t// Only show agents that support hooks\\n   452→\\t\\tif _, ok := ag.(agent.HookSupport); !ok {\\n   453→\\t\\t\\tcontinue\\n   454→\\t\\t}\\n   455→\\t\\topt := huh.NewOption(string(ag.Type()), string(name))\\n   456→\\t\\tif _, isPreSelected := preSelectedSet[name]; isPreSelected {\\n   457→\\t\\t\\topt = opt.Selected(true)\\n   458→\\t\\t}\\n   459→\\t\\toptions = append(options, opt)\\n   460→\\t}\\n   461→\\n   462→\\tif len(options) == 0 {\\n   463→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   464→\\t}\\n   465→\\n   466→\\t// Collect available agent names for the selector\\n   467→\\tavailableNames := make([]string, 0, len(options))\\n   468→\\tfor _, opt := range options {\\n   469→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   470→\\t}\\n   471→\\n   472→\\tvar selectedAgentNames []string\\n   473→\\tif selectFn != nil {\\n   474→\\t\\tvar err error\\n   475→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   476→\\t\\tif err != nil {\\n   477→\\t\\t\\treturn nil, err\\n   478→\\t\\t}\\n   479→\\t\\tif len(selectedAgentNames) == 0 {\\n   480→\\t\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   481→\\t\\t}\\n   482→\\t} else {\\n   483→\\t\\tform := NewAccessibleForm(\\n   484→\\t\\t\\thuh.NewGroup(\\n   485→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   486→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   487→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   488→\\t\\t\\t\\t\\tOptions(options...).\\n   489→\\t\\t\\t\\t\\tValidate(func(selected []string) error {\\n   490→\\t\\t\\t\\t\\t\\tif len(selected) == 0 {\\n   491→\\t\\t\\t\\t\\t\\t\\treturn errors.New(\\\"please select at least one agent\\\")\\n   492→\\t\\t\\t\\t\\t\\t}\\n   493→\\t\\t\\t\\t\\t\\treturn nil\\n   494→\\t\\t\\t\\t\\t}).\\n   495→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   496→\\t\\t\\t),\\n   497→\\t\\t)\\n   498→\\t\\tif err := form.Run(); err != nil {\\n   499→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   500→\\t\\t}\\n   501→\\t}\\n   502→\\n   503→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   504→\\tfor _, name := range selectedAgentNames {\\n   505→\\t\\tselectedAgent, err := agent.Get(agent.AgentName(name))\\n   506→\\t\\tif err != nil {\\n   507→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   508→\\t\\t}\\n   509→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   510→\\t}\\n   511→\\n   512→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   513→\\tfor _, ag := range selectedAgents {\\n   514→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   515→\\t}\\n   516→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   517→\\treturn selectedAgents, nil\\n   518→}\\n   519→\\n   520→// canPromptInteractively checks if we can show interactive prompts.\\n   521→// Returns false when running in CI, tests, or other non-interactive environments.\\n   522→func canPromptInteractively() bool {\\n   523→\\t// Check for test environment\\n   524→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   525→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   526→\\t}\\n   527→\\n   528→\\t// Check if /dev/tty is available\\n   529→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   530→\\tif err != nil {\\n   531→\\t\\treturn false\\n   532→\\t}\\n   533→\\t_ = tty.Close()\\n   534→\\treturn true\\n   535→}\\n   536→\\n   537→// printAgentError writes an error message followed by available agents and usage.\\n   538→func printAgentError(w io.Writer, message string) {\\n   539→\\tagents := agent.List()\\n   540→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   541→\\tfmt.Fprintln(w)\\n   542→\\tfor _, a := range agents {\\n   543→\\t\\tsuffix := \\\"\\\"\\n   544→\\t\\tif a == agent.DefaultAgentName {\\n   545→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   546→\\t\\t}\\n   547→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   548→\\t}\\n   549→\\tfmt.Fprintln(w)\\n   550→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   551→}\\n   552→\\n   553→// printMissingAgentError writes a helpful error listing available agents.\\n   554→func printMissingAgentError(w io.Writer) {\\n   555→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   556→}\\n   557→\\n   558→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   559→func printWrongAgentError(w io.Writer, name string) {\\n   560→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   561→}\\n   562→\\n   563→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   564→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   565→func setupAgentHooksNonInteractive(ctx context.Context, w io.Writer, ag agent.Agent, localDev, forceHooks, skipPushSessions, telemetry bool) error {\\n   566→\\tagentName := ag.Name()\\n   567→\\t// Check if agent supports hooks\\n   568→\\thookAgent, ok := ag.(agent.HookSupport)\\n   569→\\tif !ok {\\n   570→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   571→\\t}\\n   572→\\n   573→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   574→\\n   575→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   576→\\tinstalledHooks, err := hookAgent.InstallHooks(ctx, localDev, forceHooks)\\n   577→\\tif err != nil {\\n   578→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   579→\\t}\\n   580→\\n   581→\\t// Setup .entire directory\\n   582→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   583→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   584→\\t}\\n   585→\\n   586→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   587→\\tsettings, err := LoadEntireSettings(ctx)\\n   588→\\tif err != nil {\\n   589→\\t\\t// If we can't load, start with defaults\\n   590→\\t\\tsettings = &EntireSettings{}\\n   591→\\t}\\n   592→\\tsettings.Enabled = true\\n   593→\\tif localDev {\\n   594→\\t\\tsettings.LocalDev = localDev\\n   595→\\t}\\n   596→\\n   597→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   598→\\tif skipPushSessions {\\n   599→\\t\\tif settings.StrategyOptions == nil {\\n   600→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   601→\\t\\t}\\n   602→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   603→\\t}\\n   604→\\n   605→\\t// Handle telemetry for non-interactive mode\\n   606→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   607→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   608→\\t\\tf := false\\n   609→\\t\\tsettings.Telemetry = &f\\n   610→\\t}\\n   611→\\n   612→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   613→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   614→\\t}\\n   615→\\n   616→\\tif _, err := strategy.InstallGitHook(ctx, true, localDev); err != nil {\\n   617→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   618→\\t}\\n   619→\\tstrategy.CheckAndWarnHookManagers(ctx, w, localDev)\\n   620→\\n   621→\\tif installedHooks == 0 {\\n   622→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   623→\\t\\tif ag.IsPreview() {\\n   624→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   625→\\t\\t}\\n   626→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   627→\\t} else {\\n   628→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   629→\\t\\tif ag.IsPreview() {\\n   630→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   631→\\t\\t}\\n   632→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   633→\\t}\\n   634→\\n   635→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   636→\\n   637→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   638→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   639→\\t}\\n   640→\\n   641→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   642→\\n   643→\\treturn nil\\n   644→}\\n   645→\\n   646→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   647→func validateSetupFlags(useLocal, useProject bool) error {\\n   648→\\tif useLocal && useProject {\\n   649→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   650→\\t}\\n   651→\\treturn nil\\n   652→}\\n   653→\\n   654→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   655→// - Whether settings.json already exists\\n   656→// - The --local and --project flags\\n   657→// Returns (useLocal, showNotification).\\n   658→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   659→\\t// Explicit --local flag always uses local settings\\n   660→\\tif useLocal {\\n   661→\\t\\treturn true, false\\n   662→\\t}\\n   663→\\n   664→\\t// Explicit --project flag always uses project settings\\n   665→\\tif useProject {\\n   666→\\t\\treturn false, false\\n   667→\\t}\\n   668→\\n   669→\\t// No flags specified - check if settings file exists\\n   670→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   671→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   672→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   673→\\t\\treturn true, true\\n   674→\\t}\\n   675→\\n   676→\\t// Settings file doesn't exist - create it\\n   677→\\treturn false, false\\n   678→}\\n   679→\\n   680→// setupEntireDirectory creates the .entire directory and gitignore.\\n   681→// Returns true if the directory was created, false if it already existed.\\n   682→func setupEntireDirectory(ctx context.Context) (bool, error) { //nolint:unparam // already present in codebase\\n   683→\\t// Get absolute path for the .entire directory\\n   684→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   685→\\tif err != nil {\\n   686→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   687→\\t}\\n   688→\\n   689→\\t// Check if directory already exists\\n   690→\\tcreated := false\\n   691→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   692→\\t\\tcreated = true\\n   693→\\t}\\n   694→\\n   695→\\t// Create .entire directory\\n   696→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   697→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   698→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   699→\\t}\\n   700→\\n   701→\\t// Create/update .gitignore with all required entries\\n   702→\\tif err := strategy.EnsureEntireGitignore(ctx); err != nil {\\n   703→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   704→\\t}\\n   705→\\n   706→\\treturn created, nil\\n   707→}\\n   708→\\n   709→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   710→func setupGitHook(ctx context.Context) error {\\n   711→\\ts, err := settings.Load(ctx)\\n   712→\\tlocalDev := err == nil && s.LocalDev\\n   713→\\tif _, err := strategy.InstallGitHook(ctx, false, localDev); err != nil {\\n   714→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   715→\\t}\\n   716→\\tstrategy.CheckAndWarnHookManagers(ctx, os.Stderr, localDev)\\n   717→\\treturn nil\\n   718→}\\n   719→\\n   720→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   721→func newSetupGitHookCmd() *cobra.Command {\\n   722→\\tcmd := &cobra.Command{\\n   723→\\t\\tUse:    \\\"git-hook\\\",\\n   724→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   725→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   726→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   727→\\t\\t\\treturn setupGitHook(cmd.Context())\\n   728→\\t\\t},\\n   729→\\t}\\n   730→\\n   731→\\treturn cmd\\n   732→}\\n   733→\\n   734→func newCurlBashPostInstallCmd() *cobra.Command {\\n   735→\\treturn &cobra.Command{\\n   736→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   737→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   738→\\t\\tHidden: true,\\n   739→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   740→\\t\\t\\tw := cmd.OutOrStdout()\\n   741→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   742→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   743→\\t\\t\\t}\\n   744→\\t\\t\\treturn nil\\n   745→\\t\\t},\\n   746→\\t}\\n   747→}\\n   748→\\n   749→// shellCompletionComment is the comment preceding the completion line\\n   750→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   751→\\n   752→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   753→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   754→\\n   755→// shellCompletionTarget returns the rc file path and completion lines for the\\n   756→// user's current shell.\\n   757→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   758→\\thome, err := os.UserHomeDir()\\n   759→\\tif err != nil {\\n   760→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   761→\\t}\\n   762→\\n   763→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   764→\\tswitch {\\n   765→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   766→\\t\\treturn \\\"Zsh\\\",\\n   767→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   768→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   769→\\t\\t\\tnil\\n   770→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   771→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   772→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   773→\\t\\t\\tbashRC = filep