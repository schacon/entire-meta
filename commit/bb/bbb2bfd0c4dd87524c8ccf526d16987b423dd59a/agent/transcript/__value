pleted the flush).\\n  1324→\\t// Skipping the wait avoids a 3s timeout per session in prepare-commit-msg/post-commit hooks.\\n  1325→\\tif state.Phase.IsActive() {\\n  1326→\\t\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n  1327→\\t\\t\\tif prepErr := preparer.PrepareTranscript(ctx, state.TranscriptPath); prepErr != nil {\\n  1328→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prepare transcript failed\\\",\\n  1329→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n  1330→\\t\\t\\t\\t\\tslog.String(\\\"agent_type\\\", string(state.AgentType)),\\n  1331→\\t\\t\\t\\t\\tslog.String(\\\"transcript_path\\\", state.TranscriptPath),\\n  1332→\\t\\t\\t\\t\\tslog.Any(\\\"error\\\", prepErr),\\n  1333→\\t\\t\\t\\t)\\n  1334→\\t\\t\\t}\\n  1335→\\t\\t}\\n  1336→\\t}\\n  1337→\\n  1338→\\tanalyzer, ok := ag.(agent.TranscriptAnalyzer)\\n  1339→\\tif !ok {\\n  1340→\\t\\treturn nil, false\\n  1341→\\t}\"}]},\"uuid\":\"62f2ff90-e770-4237-896c-6a3e533ece6b\",\"timestamp\":\"2026-02-27T19:17:45.697Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"A user with ~95 sessions (88 ended, 6 idle, 1 active) experienced 25.5s commit time. But our performance test with 100 sessions only takes ~1.3s. I need to understand why.\\n\\nInvestigate the following potential differences between the test and real-world scenario:\\n\\n1. **ENDED sessions with shadow branches that still exist** - In the test, ENDED sessions have no shadow branch (only LastCheckpointID). In reality, could ENDED sessions still have shadow branches? Check `listAllSessionStates` in `manual_commit_session.go` - what does it do for each ENDED session that has a LastCheckpointID? Does it still try to resolve the shadow branch ref?\\n\\n2. **PostCommit per-session processing** - Read `postCommitProcessSession` in `manual_commit_hooks.go` fully. For each session, what git operations does it perform? Does it resolve shadow branch refs for ENDED sessions too?\\n\\n3. **filterSessionsWithN