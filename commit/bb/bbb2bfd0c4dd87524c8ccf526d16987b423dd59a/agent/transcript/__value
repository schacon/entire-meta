hen filtering untracked files.\\n   251→//\\n   252→// NOTE: The cache is never invalidated. In production this is fine (the agent registry\\n   253→// is populated at init time and never changes). However, tests that mutate the agent\\n   254→// registry after the first call to protectedDirs/isProtectedPath will see stale results.\\n   255→// If you need to test isProtectedPath with a custom registry, either:\\n   256→//   - run those tests in a separate process, or\\n   257→//   - call resetProtectedDirsForTest() to clear the cache.\\n   258→func protectedDirs() []string {\\n   259→\\tprotectedDirsOnce.Do(func() {\\n   260→\\t\\tprotectedDirsCache = append([]string{gitDir, entireDir}, agent.AllProtectedDirs()...)\\n   261→\\t})\\n   262→\\treturn protectedDirsCache\\n   263→}\\n   264→\\n   265→var (\\n   266→\\tprotectedDirsOnce  sync.Once\\n   267→\\tprotectedDirsCache []string\\n   268→)\\n   269→\\n   270→// resolveAgentType picks the best agent type from the context and existing state.\\n   271→// Priority: existing state > context value.\\n   272→func resolveAgentType(ctxAgentType agent.AgentType, state *SessionState) agent.AgentType {\\n   273→\\tif state != nil && state.AgentType != \\\"\\\" {\\n   274→\\t\\treturn state.AgentType\\n   275→\\t}\\n   276→\\treturn ctxAgentType\\n   277→}\\n   278→\\n   279→// EnsureMetadataBranch creates the local entire/checkpoints/v1 branch if it doesn't exist.\\n   280→// If the remote-tracking branch (origin/entire/checkpoints/v1) exists, creates the local\\n   281→// branch from it to preserve existing checkpoint data. Otherwise creates an empty orphan.\\n   282→func EnsureMetadataBranch(repo *git.Repository) error {\\n   283→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   284→\\n   285→\\t// Check if local branch already exists\\n   286→\\t_, err := repo.Reference(refName, true)\\n   287→\\tif err == nil {\\n   288→\\t\\treturn nil\\n   289→\\t}\\n   290→\\tif !errors.Is(err, plumbing.ErrReferenceNotFound) {\\n   291→\\t\\treturn fmt.Errorf(\\\"failed to check metadata branch: %w\\\", err)\\n   292→\\t}\\n   293→\\n   294→\\t// Local branch doesn't exist — create from remote if available\\n   295→\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n   296→\\tremoteRef, remoteErr := repo.Reference(remoteRefName, true)\\n   297→\\tif remoteErr != nil && !errors.Is(remoteErr, plumbing.ErrReferenceNotFound) {\\n   298→\\t\\treturn fmt.Errorf(\\\"failed to check remote metadata branch: %w\\\", remoteErr)\\n   299→\\t}\\n   300→\\tif remoteErr == nil {\\n   301→\\t\\tref := plumbing.NewHashReference(refName, remoteRef.Hash())\\n   302→\\t\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   303→\\t\\t\\treturn fmt.Errorf(\\\"failed to create metadata branch from remote: %w\\\", err)\\n   304→\\t\\t}\\n   305→\\t\\tfmt.Fprintf(os.Stderr, \\\"✓ Created local branch '%s' from origin\\\\n\\\", paths.MetadataBranchName)\\n   306→\\t\\treturn nil\\n   307→\\t}\\n   308→\\n   309→\\t// No local or remote branch — create empty orphan\\n   310→\\temptyTree := &object.Tree{Entries: []object.TreeEntry{}}\\n   311→\\tobj := repo.Storer.NewEncodedObject()\\n   312→\\tif err := emptyTree.Encode(obj); err != nil {\\n   313→\\t\\treturn fmt.Errorf(\\\"failed to encode empty tree: %w\\\", err)\\n   314→\\t}\\n   315→\\temptyTreeHash, err := repo.Storer.SetEncodedObject(obj)\\n   316→\\tif err != nil {\\n   317→\\t\\treturn fmt.Errorf(\\\"failed to store empty tree: %w\\\", err)\\n   318→\\t}\\n   319→\\n   320→\\t// Create orphan commit (no parent)\\n   321→\\tnow := time.Now()\\n   322→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   323→\\tsig := object.Signature{\\n   324→\\t\\tName:  authorName,\\n   325→\\t\\tEmail: authorEmail,\\n   326→\\t\\tWhen:  now,\\n   327→\\t}\\n   328→\\n   329→\\tcommit := &object.Commit{\\n   330→\\t\\tTreeHash:  emptyTreeHash,\\n   331→\\t\\tAuthor:    sig,\\n   332→\\t\\tCommitter: sig,\\n   333→\\t\\tMessage:   \\\"Initialize metadata branch\\\\n\\\\nThis branch stores session metadata.\\\\n\\\",\\n   334→\\t}\\n   335→\\t// Note: No ParentHashes - this is an orphan commit\\n   336→\\n   337→\\tcommitObj := repo.Storer.NewEncodedObject()\\n   338→\\tif err := commit.Encode(commitObj); err != nil {\\n   339→\\t\\treturn fmt.Errorf(\\\"failed to encode orphan commit: %w\\\", err)\\n   340→\\t}\\n   341→\\tcommitHash, err := repo.Storer.SetEncodedObject(commitObj)\\n   342→\\tif err != nil {\\n   343→\\t\\treturn fmt.Errorf(\\\"failed to store orphan commit: %w\\\", err)\\n   344→\\t}\\n   345→\\n   346→\\t// Create branch reference\\n   347→\\tref := plumbing.NewHashReference(refName, commitHash)\\n   348→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   349→\\t\\treturn fmt.Errorf(\\\"failed to create metadata branch: %w\\\", err)\\n   350→\\t}\\n   351→\\n   352→\\tfmt.Fprintf(os.Stderr, \\\"✓ Created orphan branch '%s' for session metadata\\\\n\\\", paths.MetadataBranchName)\\n   353→\\treturn nil\\n   354→}\\n   355→\\n   356→// readCheckpointMetadata reads metadata.json from a checkpoint path on entire/checkpoints/v1.\\n   357→// With the new format, root metadata.json is a CheckpointSummary with Agents array.\\n   358→// This function reads the summary and extracts relevant fields into CheckpointInfo,\\n   359→// also reading session-level metadata for IsTask/ToolUseID fields.\\n   360→func ReadCheckpointMetadata(tree *object.Tree, checkpointPath string) (*CheckpointInfo, error) {\\n   361→\\tmetadataPath := checkpointPath + \\\"/metadata.json\\\"\\n   362→\\tfile, err := tree.File(metadataPath)\\n   363→\\tif err != nil {\\n   364→\\t\\treturn nil, fmt.Errorf(\\\"failed to find metadata at %s: %w\\\", metadataPath, err)\\n   365→\\t}\\n   366→\\n   367→\\tcontent, err := file.Contents()\\n   368→\\tif err != nil {\\n   369→\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata: %w\\\", err)\\n   370→\\t}\\n   371→\\n   372→\\t// Try to parse as CheckpointSummary first (new format)\\n   373→\\tvar summary checkpoint.CheckpointSummary\\n   374→\\tif err := json.Unmarshal([]byte(content), &summary); err == nil {\\n   375→\\t\\t// If we have sessions array, this is the new format\\n   376→\\t\\tif len(summary.Sessions) > 0 {\\n   377→\\t\\t\\tinfo := &CheckpointInfo{\\n   378→\\t\\t\\t\\tCheckpointID:     summary.CheckpointID,\\n   379→\\t\\t\\t\\tCheckpointsCount: summary.CheckpointsCount,\\n   380→\\t\\t\\t\\tFilesTouched:     summary.FilesTouched,\\n   381→\\t\\t\\t\\tSessionCount:     len(summary.Sessions),\\n   382→\\t\\t\\t}\\n   383→\\n   384→\\t\\t\\t// Read all sessions' metadata to populate SessionIDs and get other fields from first session\\n   385→\\t\\t\\tvar sessionIDs []string\\n   386→\\t\\t\\tfor i, sessionPaths := range summary.Sessions {\\n   387→\\t\\t\\t\\tif sessionPaths.Metadata != \\\"\\\" {\\n   388→\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n   389→\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n   390→\\t\\t\\t\\t\\tsessionMetadataPath := strings.TrimPrefix(sessionPaths.Metadata, \\\"/\\\")\\n   391→\\t\\t\\t\\t\\tif sessionFile, err := tree.File(sessionMetadataPath); err == nil {\\n   392→\\t\\t\\t\\t\\t\\tif sessionContent, err := sessionFile.Contents(); err == nil {\\n   393→\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata checkpoint.CommittedMetadata\\n   394→\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   395→\\t\\t\\t\\t\\t\\t\\t\\tsessionIDs = append(sessionIDs, sessionMetadata.SessionID)\\n   396→\\t\\t\\t\\t\\t\\t\\t\\t// Use first session for Agent, SessionID, CreatedAt, IsTask, ToolUseID\\n   397→\\t\\t\\t\\t\\t\\t\\t\\tif i == 0 {\\n   398→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   399→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\"}]},\"uuid\":\"5d79ac87-f