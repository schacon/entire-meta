eeID, err := paths.GetWorktreeID(dir)\\n   253→\\tif err != nil {\\n   254→\\t\\tt.Fatalf(\\\"worktree ID: %v\\\", err)\\n   255→\\t}\\n   256→\\n   257→\\t// Create state store in .git/entire-sessions/\\n   258→\\tstateDir := filepath.Join(dir, \\\".git\\\", session.SessionStateDirName)\\n   259→\\tif err := os.MkdirAll(stateDir, 0o755); err != nil {\\n   260→\\t\\tt.Fatalf(\\\"mkdir state dir: %v\\\", err)\\n   261→\\t}\\n   262→\\tstore := session.NewStateStoreWithDir(stateDir)\\n   263→\\n   264→\\tmodifiedFiles := []string{\\\"src/file_0.go\\\", \\\"src/file_1.go\\\"}\\n   265→\\n   266→\\t// --- Seed ENDED sessions ---\\n   267→\\t// These have state files with LastCheckpointID but no shadow branch.\\n   268→\\t// In listAllSessionStates, they survive cleanup because LastCheckpointID is set.\\n   269→\\t// In filterSessionsWithNewContent, they trigger a repo.Reference() lookup\\n   270→\\t// for the shadow branch that fails (branch doesn't exist).\\n   271→\\tfor i := range ended {\\n   272→\\t\\tsessionID := fmt.Sprintf(\\\"perf-ended-%d\\\", i)\\n   273→\\t\\tcpID := mustGenerateCheckpointID(t)\\n   274→\\t\\tnow := time.Now()\\n   275→\\n   276→\\t\\tstate := &session.State{\\n   277→\\t\\t\\tSessionID:         sessionID,\\n   278→\\t\\t\\tBaseCommit:        baseCommit,\\n   279→\\t\\t\\tWorktreePath:      dir,\\n   280→\\t\\t\\tWorktreeID:        worktreeID,\\n   281→\\t\\t\\tPhase:             session.PhaseEnded,\\n   282→\\t\\t\\tStartedAt:         now.Add(-time.Duration(i+1) * time.Hour),\\n   283→\\t\\t\\tLastCheckpointID:  cpID,\\n   284→\\t\\t\\tStepCount:         1,\\n   285→\\t\\t\\tFilesTouched:      modifiedFiles,\\n   286→\\t\\t\\tLastInteractionTime: &now,\\n   287→\\t\\t}\\n   288→\\t\\tif err := store.Save(ctx, state); err != nil {\\n   289→\\t\\t\\tt.Fatalf(\\\"save ended state %d: %v\\\", i, err)\\n   290→\\t\\t}\\n   291→\\t}\\n   292→\\n   293→\\t// --- Seed IDLE sessions ---\\n   294→\\t// These have shadow branch checkpoints (via SaveSt