228→\\tout, err := cmd.CombinedOutput()\\n   229→\\tif err != nil {\\n   230→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n   231→\\t}\\n   232→}\\n   233→\\n   234→// createHookPerfSettings writes .entire/settings.json with commit_linking=always\\n   235→// so PrepareCommitMsg auto-links without prompting.\\n   236→func createHookPerfSettings(t *testing.T, dir string) {\\n   237→\\tt.Helper()\\n   238→\\tentireDir := filepath.Join(dir, \\\".entire\\\")\\n   239→\\tif err := os.MkdirAll(entireDir, 0o755); err != nil {\\n   240→\\t\\tt.Fatalf(\\\"mkdir .entire: %v\\\", err)\\n   241→\\t}\\n   242→\\tsettings := `{\\\"enabled\\\": true, \\\"strategy\\\": \\\"manual-commit\\\", \\\"commit_linking\\\": \\\"always\\\"}`\\n   243→\\tif err := os.WriteFile(filepath.Join(entireDir, \\\"settings.json\\\"), []byte(settings), 0o644); err != nil {\\n   244→\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n   245→\\t}\\n   246→}\\n   247→\\n   248→// seedHookPerfSessions creates session state files with realistic phase distribution.\\n   249→//\\n   250→// ENDED sessions: state file with LastCheckpointID set (already condensed).\\n   251→// IDLE sessions: state file + shadow branch checkpoint via SaveStep.\\n   252→// ACTIVE sessions: state file + shadow branch checkpoint + live transcript file.\\n   253→func seedHookPerfSessions(t *testing.T, dir string, ended, idle, active int) {\\n   254→\\tt.Helper()\\n   255→\\n   256→\\tctx := context.Background()\\n   257→\\n   258→\\t// Get HEAD hash for BaseCommit\\n   259→\\trepo, err := git.PlainOpen(dir)\\n   260→\\tif err != nil {\\n   261→\\t\\tt.Fatalf(\\\"open repo: %v\\\", err)\\n   262→\\t}\\n   263→\\thead, err := repo.Head()\\n   264→\\tif err != nil {\\n   265→\\t\\tt.Fatalf(\\\"head: %v\\\", err)\\n   266→\\t}\\n   267→\\tbaseCommit := head.Hash().String()\\n   268→\\n   269→\\t// Get worktree ID (empty string for main worktree)\\n   270→\\tworktreeID, err := paths.GetWorktreeID