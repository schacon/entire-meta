d\\\", state.SessionID),\\n  1490→\\t)\\n  1491→\\n  1492→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n  1493→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n  1494→\\t}\\n  1495→\\treturn nil\\n  1496→}\\n  1497→\\n  1498→// addCheckpointTrailer adds the Entire-Checkpoint trailer to a commit message.\\n  1499→// Handles proper trailer formatting (blank line before trailers if needed).\\n  1500→func addCheckpointTrailer(message string, checkpointID id.CheckpointID) string {\\n  1501→\\ttrailer := trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n  1502→\\n  1503→\\t// If message already ends with trailers (lines starting with key:), just append\\n  1504→\\t// Otherwise, add a blank line first\\n  1505→\\tlines := strings.Split(strings.TrimRight(message, \\\"\\\\n\\\"), \\\"\\\\n\\\")\\n  1506→\\n  1507→\\t// Check if the message already ends with a trailer paragraph.\\n  1508→\\t// Git trailers must be in a separate paragraph (preceded by a blank line).\\n  1509→\\t// A single-paragraph message (e.g., just a subject line) cannot have trailers,\\n  1510→\\t// even if the subject contains \\\": \\\" (like conventional commits: \\\"docs: Add foo\\\").\\n  1511→\\t//\\n  1512→\\t// Scan from the bottom: find the last paragraph of non-comment content,\\n  1513→\\t// then check if it looks like trailers AND has a blank line above it.\\n  1514→\\thasTrailers := false\\n  1515→\\ti := len(lines) - 1\\n  1516→\\n  1517→\\t// Skip trailing comment lines\\n  1518→\\tfor i >= 0 && strings.HasPrefix(strings.TrimSpace(lines[i]), \\\"#\\\") {\\n  1519→\\t\\ti--\\n  1520→\\t}\\n  1521→\\n  1522→\\t// Check if the last non-comment line looks like a trailer\\n  1523→\\tif i >= 0 {\\n  1524→\\t\\tline := strings.TrimSpace(lines[i])\\n  1525→\\t\\tif line != \\\"\\\" && strings.Contains(line, \\\": \\\") {\\n  1526→\\t\\t\\t// Found a trailer-like line. Now scan upward past the trailer block\\n  1527→\\t\\t\\t/