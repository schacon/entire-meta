    70→\\t// Lifecycle:\\n    71→\\t//   - Generated fresh in InitializeSession at each turn start\\n    72→\\t//   - Shared across all checkpoints within the same turn\\n    73→\\t//   - Used to correlate related checkpoints when a turn's work spans multiple commits\\n    74→\\t//   - Persists until the next InitializeSession call generates a new one\\n    75→\\tTurnID string `json:\\\"turn_id,omitempty\\\"`\\n    76→\\n    77→\\t// TurnCheckpointIDs tracks all checkpoint IDs condensed during the current turn.\\n    78→\\t// Lifecycle:\\n    79→\\t//   - Set in PostCommit when a checkpoint is condensed for an ACTIVE session\\n    80→\\t//   - Consumed in HandleTurnEnd to finalize all checkpoints with the full transcript\\n    81→\\t//   - Cleared in HandleTurnEnd after finalization completes\\n    82→\\t//   - Cleared in InitializeSession when a new prompt starts\\n    83→\\t//   - Cleared when session is reset (ResetSession deletes the state file entirely)\\n    84→\\tTurnCheckpointIDs []string `json:\\\"turn_checkpoint_ids,omitempty\\\"`\\n    85→\\n    86→\\t// LastInteractionTime is updated on every hook invocation.\\n    87→\\t// Used for stale session detection in \\\"entire doctor\\\".\\n    88→\\tLastInteractionTime *time.Time `json:\\\"last_interaction_time,omitempty\\\"`\\n    89→\\n    90→\\t// StepCount is the number of checkpoints/steps created in this session.\\n    91→\\t// JSON tag kept as \\\"checkpoint_count\\\" for backward compatibility with existing state files.\\n    92→\\tStepCount int `json:\\\"checkpoint_count\\\"`\\n    93→\\n    94→\\t// CheckpointTranscriptStart is the transcript line offset where the current\\n    95→\\t// checkpoint cycle began. Set to 0 at session start, updated to current\\n    96→\\t// transcript length after each condensation. Used to scope the transcript\\n    97→\\t// for checkpoint condensation: \\\"everything since last checkpoint\\\".\\n    98→\\tCheckpointTranscriptStart int `json:\\\"checkpoint_transcript_start,omitempty\\\"`\\n    99→\\n   100→\\t// Deprecated: CondensedTranscriptLines is replaced by CheckpointTranscriptStart.\\n   101→\\t// Kept for backward compatibility with existing state files.\\n   102→\\t// Use NormalizeAfterLoad() to migrate.\\n   103→\\tCondensedTranscriptLines int `json:\\\"condensed_transcript_lines,omitempty\\\"`\\n   104→\\n   105→\\t// UntrackedFilesAtStart tracks files that existed at session start (to preserve during rewind)\\n   106→\\tUntrackedFilesAtStart []string `json:\\\"untracked_files_at_start,omitempty\\\"`\\n   107→\\n   108→\\t// FilesTouched tracks files modified/created/deleted during this session\\n   109→\\tFilesTouched []string `json:\\\"files_touched,omitempty\\\"`\\n   110→\\n   111→\\t// LastCheckpointID is the checkpoint ID from the most recent condensation.\\n   112→\\t// Used to restore the Entire-Checkpoint trailer on amend and to identify\\n   113→\\t// sessions that have been condensed at least once. Cleared on new prompt.\\n   114→\\tLastCheckpointID id.CheckpointID `json:\\\"last_checkpoint_id,omitempty\\\"`\\n   115→\\n   116→\\t// AgentType identifies the agent that created this session (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\", \\\"Cursor\\\")\\n   117→\\tAgentType agent.AgentType `json:\\\"agent_type,omitempty\\\"`\\n   118→\\n   119→\\t// Token usage tracking (accumulated across all checkpoints in this session)\\n   120→\\tTokenUsage *agent.TokenUsage `json:\\\"token_usage,omitempty\\\"`\\n   121→\\n   122→\\t// Deprecated: TranscriptLinesAtStart is replaced by CheckpointTranscriptStart.\\n   123→\\t// Kept for backward compatibility with existing state files.\\n   124→\\tTranscriptLinesAtStart int `json:\\\"transcript_lines_at_start,omitempty\\\"`\\n   125→\\n   126→\\t// TranscriptIdentifierAtStart is the last transcript identifier when the session started.\\n   127→\\t// Used for identifier-based transcript scoping (UUID for Claude, message ID for Gemini).\\n   128→\\tTranscriptIdentifierAtStart string `json:\\\"transcript_identifier_at_start,omitempty\\\"`\\n   129→\\n   130→\\t// TranscriptPath is the path to the live transcript file (for mid-session commit detection)\\n   131→\\tTranscriptPath string `json:\\\"transcript_path,omitempty\\\"`\\n   132→\\n   133→\\t// FirstPrompt is the first user prompt that started this session (truncated for display)\\n   134→\\tFirstPrompt string `json:\\\"first_prompt,omitempty\\\"`\\n   135→\\n   136→\\t// PromptAttributions tracks user and agent line changes at each prompt start.\\n   137→\\t// This enables accurate attribution by capturing user edits between checkpoints.\\n   138→\\tPromptAttributions []PromptAttribution `json:\\\"prompt_attributions,omitempty\\\"`\\n   139→\\n   140→\\t// PendingPromptAttribution holds attribution calculated at prompt start (before agent runs).\\n   141→\\t// This is moved to PromptAttributions when SaveStep is called.\\n   142→\\tPendingPromptAttribution *PromptAttribution `json:\\\"pending_prompt_attribution,omitempty\\\"`\\n   143→}\\n   144→\\n   145→// PromptAttribution captures line-level attribution data at the start of each prompt.\\n   146→// By recording what changed since the last checkpoint BEFORE the agent works,\\n   147→// we can accurately separate user edits from agent contributions.\\n   148→type PromptAttribution struct {\\n   149→\\t// CheckpointNumber is which checkpoint this was recorded before (1-indexed)\\n   150→\\tCheckpointNumber int `json:\\\"checkpoint_number\\\"`\\n   151→\\n   152→\\t// UserLinesAdded is lines added by user since the last checkpoint\\n   153→\\tUserLinesAdded int `json:\\\"user_lines_added\\\"`\\n   154→\\n   155→\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   156→\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   157→\\n   158→\\t// AgentLinesAdded is total agent lines added so far (base → last checkpoint).\\n   159→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   160→\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   161→\\n   162→\\t// AgentLinesRemoved is total agent lines removed so far (base → last checkpoint).\\n   163→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   164→\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   165→\\n   166→\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   167→\\t// This enables distinguishing user self-modifications from agent modifications.\\n   168→\\t// See docs/architecture/attribution.md for details.\\n   169→\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   170→}\\n   171→\\n   172→// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   173→// Call this after deserializing a State from JSON.\\n   174→func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   175→\\t// Normalize legacy phase values. \\\"active_committed\\\" was removed with the\\n   176→\\t// 1:1 checkpoint model in favor of the state machine handling commits\\n   177→\\t// during ACTIVE phase with immediate condensation.\\n   178→\\tif s.Phase == \\\"active_committed\\\" {\\n   179→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   180→\\t\\tlogging.Info(logCtx, \\\"migrating legacy active_committed phase to active\\\",\\n   181→\\t\\t\\tslog.String(\\\"session_id\\\", s.SessionID),\\n   182→\\t\\t)\\n   183→\\t\\ts.Phase = PhaseActive\\n   184→\\t}\\n   185→\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n   186→\\ts.Phase = PhaseFromString(string(s.Phase))\\n   187→\\n   188→\\t// Migrate transcript fields: CheckpointTranscriptStart replaces both\\n   189→\\t// CondensedTranscriptLines and TranscriptLinesAtStart from older state files.\\n   190→\\tif s.CheckpointTranscriptStart == 0 {\\n   191→\\t\\tif s.CondensedTranscriptLines > 0 {\\n   192→\\t\\t\\ts.CheckpointTranscriptStart = s.CondensedTranscriptLines\\n   193→\\t\\t} else if s.TranscriptLinesAtStart > 0 {\\n   194→\\t\\t\\ts.CheckpointTranscriptStart = s.TranscriptLinesAtStart\\n   195→\\t\\t}\\n   196→\\t}\\n   197→\\t// Clear deprecated fields so they aren't re-persisted.\\n   198→\\t// Note: this is a one-way migration. If the state is re-saved, older CLI versions\\n   199→\\t// will see 0 for these fields and fall back to scoping from the transcript start.\\n   200→\\t// This is acceptable since CLI upgrades are monotonic and the worst case is\\n   201→\\t// redundant transcript content in a condensation, not data loss.\\n   202→\\ts.CondensedTranscriptLines = 0\\n   203→\\ts.TranscriptLinesAtStart = 0\\n   204→\\n   205→\\t// Backfill AttributionBaseCommit for sessions created before this field existed.\\n   206→\\t// Without this, a mid-turn commit would migrate BaseCommit and the fallback in\\n   207→\\t// calculateSessionAttributions would use the migrated value, producing zero attribution.\\n   208→\\tif s.AttributionBaseCommit == \\\"\\\" && s.BaseCommit != \\\"\\\" {\\n   209→\\t\\ts.AttributionBaseCommit = s.BaseCommit\\n   210→\\t}\\n   211→}\\n   212→\\n   213→// IsStale returns true when the last time a session saw interaction exceeds StaleSessionThreshold.\\n   214→// If LastInteractionTime isn't set, we don't consider a session stale to avoid aggressively\\n   215→// deleting things.\\n   216→func (s *State) IsStale() bool {\\n   217→\\treturn s.LastInteractionTime != nil && time.Since(*s.LastInteractionTime) > StaleSessionThreshold\\n   218→}\\n   219→\\n   220→// StateStore provides low-level operations for managing session state files.\\n   221→//\\n   222→// StateStore is a primitive for session state persistence. It is NOT the same as\\n   223→// the Sessions interface - it only handles state files in .git/entire-sessions/,\\n   224→// not the full session data which includes checkpoint content.\\n   225→//\\n   226→// Use StateStore directly in strategies for performance-critical state operations.\\n   227→// Use the Sessions interface (when implemented) for high-level session management.\\n   228→type StateStore struct {\\n   229→\\t// stateDir is the directory where session state files are stored\\n   230→\\tstateDir string\\n   231→}\\n   232→\\n   233→// NewStateStore creates a new state store.\\n   234→// Uses the git common dir to store session state (shared across worktrees).\\n   235→func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   236→\\tcommonDir, err := getGitCommonDir(ctx)\\n   237→\\tif err != nil {\\n   238→\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   239→\\t}\\n   240→\\treturn &StateStore{\\n   241→\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   242→\\t}, nil\\n   243→}\\n   244→\\n   245→// NewStateStoreWithDir creates a new state store with a custom directory.\\n   246→// This is useful for testing.\\n   247→func NewStateStoreWithDir(stateDir string) *StateStore {\\n   248→\\treturn &StateStore{stateDir: stateDir}\\n   249→}\\n   250→\\n   251→// Load loads the session state for the given session ID.\\n   252→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   253→// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   254→func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   255→\\t// Validate session ID to prevent path traversal\\n   256→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   257→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   258→\\t}\\n   259→\\n   260→\\tstateFile := s.stateFilePath(sessionID)\\n   261→\\n   262→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is derived from sessionID\\n   263→\\tif os.IsNotExist(err) {\\n   264→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   265→\\t}\\n   266→\\tif err != nil {\\n   267→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   268→\\t}\\n   269→\\n   270→\\tvar state State\\n   271→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   272→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal session state: %w\\\", err)\\n   273→\\t}\\n   274→\\tstate.NormalizeAfterLoad(ctx)\\n   275→\\n   276→\\tif state.IsStale() {\\n   277→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   278→\\t\\tlogging.Debug(logCtx, \\\"deleting stale session state\\\",\\n   279→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   280→\\t\\t)\\n   281→\\t\\t_ = s.Clear(ctx, sessionID) //nolint:errcheck // best-effort cleanup of stale session\\n   282→\\t\\treturn nil, nil             //nolint:nilnil // stale session treated as not found\\n   283→\\t}\\n   284→\\n   285→\\treturn &state, nil\\n   286→}\\n   287→\\n   288→// Save saves the session state atomically.\\n   289→func (s *StateStore) Save(ctx context.Context, state *State) error {\\n   290→\\t_ = ctx // Reserved for future use\\n   291→\\n   292→\\t// Validate session ID to prevent path traversal\\n   293→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n   294→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   295→\\t}\\n   296→\\n   297→\\tif err := os.MkdirAll(s.stateDir, 0o750); err != nil {\\n   298→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   299→\\t}\\n   300→\\n   301→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   302→\\tif err != nil {\\n   303→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   304→\\t}\\n   305→\\n   306→\\tstateFile := s.stateFilePath(state.SessionID)\\n   307→\\n   308→\\t// Atomic write: write to temp file, then rename\\n   309→\\ttmpFile := stateFile + \\\".tmp\\\"\\n   310→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n   311→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   312→\\t}\\n   313→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n   314→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n   315→\\t}\\n   316→\\treturn nil\\n   317→}\\n   318→\\n   319→// Clear removes the session state file for the given session ID.\\n   320→func (s *StateStore) Clear(ctx context.Context, sessionID string) error {\\n   321→\\t_ = ctx // Reserved for future use\\n   322→\\n   323→\\t// Validate session ID to prevent path traversal\\n   324→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   325→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   326→\\t}\\n   327→\\n   328→\\tstateFile := s.stateFilePath(sessionID)\\n   329→\\n   330→\\tif err := os.Remove(stateFile); err != nil {\\n   331→\\t\\tif os.IsNotExist(err) {\\n   332→\\t\\t\\treturn nil // Already gone, not an error\\n   333→\\t\\t}\\n   334→\\t\\treturn fmt.Errorf(\\\"failed to remove session state file: %w\\\", err)\\n   335→\\t}\\n   336→\\treturn nil\\n   337→}\\n   338→\\n   339→// RemoveAll removes the entire session state directory.\\n   340→// This is used during uninstall to completely remove all session state.\\n   341→func (s *StateStore) RemoveAll() error {\\n   342→\\tif err := os.RemoveAll(s.stateDir); err != nil {\\n   343→\\t\\treturn fmt.Errorf(\\\"failed to remove session state directory: %w\\\", err)\\n   344→\\t}\\n   345→\\treturn nil\\n   346→}\\n   347→\\n   348→// List returns all session states.\\n   349→func (s *StateStore) List(ctx context.Context) ([]*State, error) {\\n   350→\\tentries, err := os.ReadDir(s.stateDir)\\n   351→\\tif os.IsNotExist(err) {\\n   352→\\t\\treturn nil, nil\\n   353→\\t}\\n   354→\\tif err != nil {\\n   355→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state directory: %w\\\", err)\\n   356→\\t}\\n   357→\\n   358→\\tvar states []*State\\n   359