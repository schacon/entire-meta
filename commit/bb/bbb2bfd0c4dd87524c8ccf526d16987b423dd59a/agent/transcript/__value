rr != nil {\\n   102→\\t\\t\\t\\tt.Fatalf(\\\"PrepareCommitMsg: %v\\\", err)\\n   103→\\t\\t\\t}\\n   104→\\t\\t\\tprepDur := time.Since(prepStart)\\n   105→\\n   106→\\t\\t\\t// Read back the commit message to check if trailer was added.\\n   107→\\t\\t\\tmsgBytes, err := os.ReadFile(commitMsgFile) //nolint:gosec // test file\\n   108→\\t\\t\\tif err != nil {\\n   109→\\t\\t\\t\\tt.Fatalf(\\\"read commit msg: %v\\\", err)\\n   110→\\t\\t\\t}\\n   111→\\t\\t\\tcommitMsg := string(msgBytes)\\n   112→\\n   113→\\t\\t\\t// If PrepareCommitMsg didn't add a trailer (e.g., content-aware check\\n   114→\\t\\t\\t// determined no new content), inject one manually so PostCommit exercises\\n   115→\\t\\t\\t// the full condensation path rather than the early-exit path.\\n   116→\\t\\t\\tif _, found := trailers.ParseCheckpoint(commitMsg); !found {\\n   117→\\t\\t\\t\\tcpID, genErr := id.Generate()\\n   118→\\t\\t\\t\\tif genErr != nil {\\n   119→\\t\\t\\t\\t\\tt.Fatalf(\\\"generate checkpoint ID: %v\\\", genErr)\\n   120→\\t\\t\\t\\t}\\n   121→\\t\\t\\t\\tcommitMsg = fmt.Sprintf(\\\"%s\\\\n%s: %s\\\\n\\\",\\n   122→\\t\\t\\t\\t\\tstrings.TrimRight(commitMsg, \\\"\\\\n\\\"),\\n   123→\\t\\t\\t\\t\\ttrailers.CheckpointTrailerKey, cpID)\\n   124→\\t\\t\\t\\tt.Logf(\\\"  Injected trailer (PrepareCommitMsg skipped content-aware check)\\\")\\n   125→\\t\\t\\t}\\n   126→\\n   127→\\t\\t\\t// Create the actual commit with the trailer so PostCommit finds it.\\n   128→\\t\\t\\tgitRun(t, dir, \\\"commit\\\", \\\"-m\\\", commitMsg)\\n   129→\\n   130→\\t\\t\\t// --- Time PostCommit ---\\n   131→\\t\\t\\tpaths.ClearWorktreeRootCache()\\n   132→\\t\\t\\tsession.ClearGitCommonDirCache()\\n   133→\\n   134→\\t\\t\\ts2 := &ManualCommitStrategy{}\\n   135→\\t\\t\\tpostStart := time.Now()\\n   136→\\t\\t\\tif err := s2.PostCommit(context.Background()); err != nil {\\n   137→\\t\\t\\t\\tt.Fatalf(\\\"PostCommit: %v\\\", err)\\n   138→\\t\\t\\t}\\n   139→\\t\\t\\tpostDur := time.Since(postStart)\\n  