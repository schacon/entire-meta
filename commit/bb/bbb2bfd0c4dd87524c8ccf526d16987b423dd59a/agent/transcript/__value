path.Dir(abs), 0o755); err != nil {\\n   106→\\t\\t\\tb.Fatalf(\\\"mkdir: %v\\\", err)\\n   107→\\t\\t}\\n   108→\\t\\tcontent := fmt.Sprintf(\\\"package main\\\\nfunc f%d() {}\\\\n\\\", i)\\n   109→\\t\\tif err := os.WriteFile(abs, []byte(content), 0o644); err != nil {\\n   110→\\t\\t\\tb.Fatalf(\\\"write: %v\\\", err)\\n   111→\\t\\t}\\n   112→\\t\\tif _, err := wt.Add(name); err != nil {\\n   113→\\t\\t\\tb.Fatalf(\\\"add: %v\\\", err)\\n   114→\\t\\t}\\n   115→\\t}\\n   116→\\n   117→\\tif _, err := wt.Commit(\\\"initial commit\\\", &git.CommitOptions{\\n   118→\\t\\tAuthor: &object.Signature{Name: \\\"Bench\\\", Email: \\\"bench@test.com\\\", When: time.Now()},\\n   119→\\t}); err != nil {\\n   120→\\t\\tb.Fatalf(\\\"commit: %v\\\", err)\\n   121→\\t}\\n   122→\\n   123→\\ts := &ManualCommitStrategy{}\\n   124→\\n   125→\\t// Chdir to repo dir for the entire setup (SaveStep, loadSessionState, etc.\\n   126→\\t// all depend on paths.WorktreeRoot() which uses cwd). b.Chdir restores\\n   127→\\t// the original directory when the benchmark function returns.\\n   128→\\tb.Chdir(dir)\\n   129→\\tpaths.ClearWorktreeRootCache()\\n   130→\\n   131→\\t// Set up each session with a shadow branch checkpoint\\n   132→\\tmodifiedFiles := []string{\\\"src/file_0.go\\\", \\\"src/file_1.go\\\"}\\n   133→\\tfor i := range sessionCount {\\n   134→\\t\\tsessionID := fmt.Sprintf(\\\"bench-session-%d\\\", i)\\n   135→\\n   136→\\t\\t// Modify files with agent content\\n   137→\\t\\tfor _, f := range modifiedFiles {\\n   138→\\t\\t\\tabs := filepath.Join(dir, f)\\n   139→\\t\\t\\tcontent := fmt.Sprintf(\\\"package main\\\\n// modified by agent session %d\\\\nfunc f() {}\\\\n\\\", i)\\n   140→\\t\\t\\tif err := os.WriteFile(abs, []byte(content), 0o644); err != nil {\\n   141→\\t\\t\\t\\tb.Fatalf(\\\"write: %v\\\", err)\\n   142→\\t\\t\\t}\\n   143→\\t\\t}\\n   144→\\n   145→\\t\\t// Create metadata directory with transcript\\n   146→\\t\\tmetadataDir := \\\".entire/metadata/\\\" + ses