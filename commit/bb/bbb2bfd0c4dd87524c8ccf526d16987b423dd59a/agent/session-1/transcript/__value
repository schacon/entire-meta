gainst a commit with hooks active.\\n    29→//\\n    30→// It uses a shallow clone of entireio/cli with seeded branches and packed refs\\n    31→// to simulate a realistic repo, then loads session templates from the current\\n    32→// repo's .git/entire-sessions/ to create authentic session state distributions.\\n    33→//\\n    34→// Prerequisites:\\n    35→//   - GitHub access (gh auth login) for cloning the private repo\\n    36→//   - At least one session state file in .git/entire-sessions/\\n    37→//\\n    38→// Run: go test -v -run TestCommitHookPerformance -tags hookperf -timeout 10m ./cmd/entire/cli/strategy/\\n    39→func TestCommitHookPerformance(t *testing.T) {\\n    40→\\t// Load session templates from the current repo before cloning.\\n    41→\\ttemplates := loadSessionTemplates(t)\\n    42→\\n    43→\\t// Clone once, reuse across scenarios via cheap local clones.\\n    44→\\tcacheDir := cloneSourceRepo(t)\\n    45→\\n    46→\\tscenarios := []struct {\\n    47→\\t\\tname   string\\n    48→\\t\\tended  int\\n    49→\\t\\tidle   int\\n    50→\\t\\tactive int\\n    51→\\t}{\\n    52→\\t\\t{\\\"100sessions\\\", 88, 11, 1},\\n    53→\\t\\t{\\\"200sessions\\\", 176, 22, 2},\\n    54→\\t\\t{\\\"500sessions\\\", 440, 55, 5},\\n    55→\\t}\\n    56→\\n    57→\\ttype result struct {\\n    58→\\t\\tname       string\\n    59→\\t\\ttotal      int\\n    60→\\t\\tcontrol    time.Duration\\n    61→\\t\\tprepare    time.Duration\\n    62→\\t\\tpostCommit time.Duration\\n    63→\\t}\\n    64→\\tresults := make([]result, 0, len(scenarios))\\n    65→\\n    66→\\tfor _, sc := range scenarios {\\n    67→\\t\\tt.Run(sc.name, func(t *testing.T) {\\n    68→\\t\\t\\ttotalSessions := sc.ended + sc.idle + sc.active\\n    69→\\n    70→\\t\\t\\tdir := localClone(t, cacheDir)\\n    71→\\t\\t\\tt.Chdir(dir)\\n    72→\\t\\t\\tpaths.ClearWorktreeRootCache()\\n    73→\\t\\t\\tsession.ClearGitCommonDirCache()\\n    74→\\n    75→\\t\\t\\t// Seed 200 branches + pack refs for realistic ref scanning overhead.\\n    76→\\t\\t\\tseedBranches(t, dir, 200)\\n    77→\\t\\t\\tgitRun(t, dir, \\\"pack-refs\\\", \\\"--all\\\")\\n    78→\\n    79→\\t\\t\\t// --- CONTROL: commit without Entire ---\\n    80→\\t\\t\\tcontrolDur := timeControlCommit(t, dir)\\n    81→\\n    82→\\t\\t\\t// Reset back to pre-commit state so the test commit is identical.\\n    83→\\t\\t\\tgitRun(t, dir, \\\"reset\\\", \\\"HEAD~1\\\")\\n    84→\\t\\t\\tgitRun(t, dir, \\\"add\\\", \\\"perf_control.txt\\\")\\n    85→\\n    86→\\t\\t\\t// --- TEST: commit with Entire hooks ---\\n    87→\\t\\t\\tcreateHookPerfSettings(t, dir)\\n    88→\\t\\t\\tseedHookPerfSessions(t, dir, templates, sc.ended, sc.idle, sc.active)\\n    89→\\n    90→\\t\\t\\t// Simulate TTY path with commit_linking=always.\\n    91→\\t\\t\\tt.Setenv(\\\"ENTIRE_TEST_TTY\\\", \\\"1\\\")\\n    92→\\t\\t\\tpaths.ClearWorktreeRootCache()\\n    93→\\t\\t\\tsession.ClearGitCommonDirCache()\\n    94→\\n    95→\\t\\t\\tcommitMsgFile := filepath.Join(dir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n    96→\\t\\t\\tif err := os.WriteFile(commitMsgFile, []byte(\\\"implement feature\\\\n\\\"), 0o644); err != nil {\\n    97→\\t\\t\\t\\tt.Fatalf(\\\"write commit msg: %v\\\", err)\\n    98→\\t\\t\\t}\\n    99→\\n   100→\\t\\t\\ts1 := &ManualCommitStrategy{}\\n   101→\\t\\t\\tprepStart := time.Now()\\n   102→\\t\\t\\tif err := s1.PrepareCommitMsg(context.Background(), commitMsgFile, \\\"message\\\"); err != nil {\\n   103→\\t\\t\\t\\tt.Fatalf(\\\"PrepareCommitMsg: %v\\\", err)\\n   104→\\t\\t\\t}\\n   105→\\t\\t\\tprepDur := time.Since(prepStart)\\n   106→\\n   107→\\t\\t\\t// Read back commit message; inject trailer if content-aware check skipped it.\\n   108→\\t\\t\\tmsgBytes, err := os.ReadFile(commitMsgFile) //nolint:gosec // test file\\n   109→\\t\\t\\tif err != nil {\\n   110→\\t\\t\\t\\tt.Fatalf(\\\"read commit msg: %v\\\", err)\\n   111→\\t\\t\\t}\\n   112→\\t\\t\\tcommitMsg := string(msgBytes)\\n   113→\\n   114→\\t\\t\\tif _, found := trailers.ParseCheckpoint(commitMsg); !found {\\n   115→\\t\\t\\t\\tcpID, genErr := id.Generate()\\n   116→\\t\\t\\t\\tif genErr != nil {\\n   117→\\t\\t\\t\\t\\tt.Fatalf(\\\"generate checkpoint ID: %v\\\", genErr)\\n   118→\\t\\t\\t\\t}\\n   119→\\t\\t\\t\\tcommitMsg = fmt.Sprintf(\\\"%s\\\\n%s: %s\\\\n\\\",\\n   120→\\t\\t\\t\\t\\tstrings.TrimRight(commitMsg, \\\"\\\\n\\\"),\\n   121→\\t\\t\\t\\t\\ttrailers.CheckpointTrailerKey, cpID)\\n   122→\\t\\t\\t\\tt.Logf(\\\"  Injected trailer (PrepareCommitMsg skipped content-aware check)\\\")\\n   123→\\t\\t\\t}\\n   124→\\n   125→\\t\\t\\tgitRun(t, dir, \\\"commit\\\", \\\"-m\\\", commitMsg)\\n   126→\\n   127→\\t\\t\\t// Time PostCommit.\\n   128→\\t\\t\\tpaths.ClearWorktreeRootCache()\\n   129→\\t\\t\\tsession.ClearGitCommonDirCache()\\n   130→\\n   131→\\t\\t\\ts2 := &ManualCommitStrategy{}\\n   132→\\t\\t\\tpostStart := time.Now()\\n   133→\\t\\t\\tif err := s2.PostCommit(context.Background()); err != nil {\\n   134→\\t\\t\\t\\tt.Fatalf(\\\"PostCommit: %v\\\", err)\\n   135→\\t\\t\\t}\\n   136→\\t\\t\\tpostDur := time.Since(postStart)\\n   137→\\n   138→\\t\\t\\toverhead := (prepDur + postDur) - controlDur\\n   139→\\t\\t\\tif overhead < 0 {\\n   140→\\t\\t\\t\\toverhead = 0\\n   141→\\t\\t\\t}\\n   142→\\n   143→\\t\\t\\tt.Logf(\\\"=== %s ===\\\", sc.name)\\n   144→\\t\\t\\tt.Logf(\\\"  Sessions:         %d (ended=%d, idle=%d, active=%d)\\\", totalSessions, sc.ended, sc.idle, sc.active)\\n   145→\\t\\t\\tt.Logf(\\\"  Control commit:   %s\\\", controlDur.Round(time.Millisecond))\\n   146→\\t\\t\\tt.Logf(\\\"  PrepareCommitMsg: %s\\\", prepDur.Round(time.Millisecond))\\n   147→\\t\\t\\tt.Logf(\\\"  PostCommit:       %s\\\", postDur.Round(time.Millisecond))\\n   148→\\t\\t\\tt.Logf(\\\"  TOTAL HOOKS:      %s\\\", (prepDur + postDur).Round(time.Millisecond))\\n   149→\\t\\t\\tt.Logf(\\\"  OVERHEAD:         %s\\\", overhead.Round(time.Millisecond))\\n   150→\\n   151→\\t\\t\\tresults = append(results, result{\\n   152→\\t\\t\\t\\tname:       sc.name,\\n   153→\\t\\t\\t\\ttotal:      totalSessions,\\n   154→\\t\\t\\t\\tcontrol:    controlDur,\\n   155→\\t\\t\\t\\tprepare:    prepDur,\\n   156→\\t\\t\\t\\tpostCommit: postDur,\\n   157→\\t\\t\\t})\\n   158→\\t\\t})\\n   159→\\t}\\n   160→\\n   161→\\t// Print comparison table.\\n   162→\\tt.Log(\\\"\\\")\\n   163→\\tt.Logf(\\\"Session templates: %d loaded from .git/entire-sessions/\\\", len(templates))\\n   164→\\tt.Log(\\\"\\\")\\n   165→\\tt.Log(\\\"========== COMMIT HOOK PERFORMANCE ==========\\\")\\n   166→\\tt.Logf(\\\"%-14s | %8s | %10s | %10s | %12s | %12s | %10s\\\",\\n   167→\\t\\t\\\"Scenario\\\", \\\"Sessions\\\", \\\"Control\\\", \\\"Prepare\\\", \\\"PostCommit\\\", \\\"Total+Hooks\\\", \\\"Overhead\\\")\\n   168→\\tt.Log(strings.Repeat(\\\"-\\\", 95))\\n   169→\\tfor _, r := range results {\\n   170→\\t\\ttotal := r.prepare + r.postCommit\\n   171→\\t\\toverhead := total - r.control\\n   172→\\t\\tif overhead < 0 {\\n   173→\\t\\t\\toverhead = 0\\n   174→\\t\\t}\\n   175→\\t\\tt.Logf(\\\"%-14s | %8d | %10s | %10s | %12s | %12s | %10s\\\",\\n   176→\\t\\t\\tr.name,\\n   177→\\t\\t\\tr.total,\\n   178→\\t\\t\\tr.control.Round(time.Millisecond),\\n   179→\\t\\t\\tr.prepare.Round(time.Millisecond),\\n   180→\\t\\t\\tr.postCommit.Round(time.Millisecond),\\n   181→\\t\\t\\ttotal.Round(time.Millisecond),\\n   182→\\t\\t\\toverhead.Round(time.Millisecond),\\n   183→\\t\\t)\\n   184→\\t}\\n   185→}\\n   186→\\n   187→// sessionTemplate is a parsed session state file used as a template for seeding.\\n   188→type sessionTemplate struct {\\n   189→\\tstate *session.State\\n   190→}\\n   191→\\n   192→// loadSessionTemplates reads .git/entire-sessions/*.json from the current repo\\n   193→// and returns them as templates. Fatals if no templates are found.\\n   194→func loadSessionTemplates(t *testing.T) []sessionTemplate {\\n   195→\\tt.Helper()\\n   196→\\n   197→\\t// Find the current repo's .git/entire-sessions/ directory.\\n   198→\\trepoRoot, err := exec.Command(\\\"git\\\", \\\"rev-parse\\\", \\\"--show-toplevel\\\").Output()\\n   199→\\tif err != nil {\\n   200→\\t\\tt.Fatalf(\\\"git rev-parse --show-toplevel: %v\\\", err)\\n   201→\\t}\\n   202→\\tsessDir := filepath.Join(strings.TrimSpace(string(repoRoot)), \\\".git\\\", session.SessionStateDirName)\\n   203→\\n   204→\\tentries, err := os.ReadDir(sessDir)\\n   205→\\tif err != nil {\\n   206→\\t\\tt.Fatalf(\\\"read %s: %v\\\", sessDir, err)\\n   207→\\t}\\n   208→\\n   209→\\tvar templates []sessionTemplate\\n   210→\\tfor _, entry := range entries {\\n   211→\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   212→\\t\\t\\tcontinue\\n   213→\\t\\t}\\n   214→\\t\\tif strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   215→\\t\\t\\tcontinue\\n   216→\\t\\t}\\n   217→\\n   218→\\t\\tdata, err := os.ReadFile(filepath.Join(sessDir, entry.Name())) //nolint:gosec // test file\\n   219→\\t\\tif err != nil {\\n   220→\\t\\t\\tt.Logf(\\\"  skip %s: %v\\\", entry.Name(), err)\\n   221→\\t\\t\\tcontinue\\n   222→\\t\\t}\\n   223→\\t\\tvar state session.State\\n   224→\\t\\tif err := json.Unmarshal(data, &state); err != nil {\\n   225→\\t\\t\\tt.Logf(\\\"  skip %s: %v\\\", entry.Name(), err)\\n   226→\\t\\t\\tcontinue\\n   227→\\t\\t}\\n   228→\\t\\ttemplates = append(templates, sessionTemplate{state: &state})\\n   229→\\t}\\n   230→\\n   231→\\tif len(templates) == 0 {\\n   232→\\t\\tt.Fatal(\\\"no session templates found in .git/entire-sessions/ — need at least one\\\")\\n   233→\\t}\\n   234→\\tt.Logf(\\\"Loaded %d session templates from .git/entire-sessions/\\\", len(templates))\\n   235→\\treturn templates\\n   236→}\\n   237→\\n   238→// timeControlCommit stages a file and times a bare `git commit` with no Entire\\n   239→// hooks/settings present. Returns the wall-clock duration.\\n   240→func timeControlCommit(t *testing.T, dir string) time.Duration {\\n   241→\\tt.Helper()\\n   242→\\n   243→\\t// Write and stage a file.\\n   244→\\tcontrolFile := filepath.Join(dir, \\\"perf_control.txt\\\")\\n   245→\\tif err := os.WriteFile(controlFile, []byte(\\\"control commit content\\\\n\\\"), 0o644); err != nil {\\n   246→\\t\\tt.Fatalf(\\\"write control file: %v\\\", err)\\n   247→\\t}\\n   248→\\tgitRun(t, dir, \\\"add\\\", \\\"perf_control.txt\\\")\\n   249→\\n   250→\\t// Time the commit.\\n   251→\\tstart := time.Now()\\n   252→\\tgitRun(t, dir, \\\"commit\\\", \\\"-m\\\", \\\"control commit (no Entire)\\\")\\n   253→\\treturn time.Since(start)\\n   254→}\\n   255→\\n   256→// seedBranches creates N branches pointing at HEAD via go-git to simulate\\n   257→// a repo with many refs (affects ref scanning performance).\\n   258→func seedBranches(t *testing.T, dir string, count int) {\\n   259→\\tt.Helper()\\n   260→\\n   261→\\trepo, err := git.PlainOpen(dir)\\n   262→\\tif err != nil {\\n   263→\\t\\tt.Fatalf(\\\"open repo for branch seeding: %v\\\", err)\\n   264→\\t}\\n   265→\\thead, err := repo.Head()\\n   266→\\tif err != nil {\\n   267→\\t\\tt.Fatalf(\\\"head for branch seeding: %v\\\", err)\\n   268→\\t}\\n   269→\\theadHash := head.Hash()\\n   270→\\n   271→\\tfor i := range count {\\n   272→\\t\\tname := fmt.Sprintf(\\\"feature/perf-branch-%03d\\\", i)\\n   273→\\t\\tref := plumbing.NewHashReference(plumbing.NewBranchReferenceName(name), headHash)\\n   274→\\t\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   275→\\t\\t\\tt.Fatalf(\\\"create branch %s: %v\\\", name, err)\\n   276→\\t\\t}\\n   277→\\t}\\n   278→\\tt.Logf(\\\"  Seeded %d branches\\\", count)\\n   279→}\\n   280→\\n   281→// cloneSourceRepo does a one-time shallow clone of entireio/cli into a temp\\n   282→// directory. Returns the path to use as a local clone source for each scenario.\\n   283→func cloneSourceRepo(t *testing.T) string {\\n   284→\\tt.Helper()\\n   285→\\n   286→\\tdir := t.TempDir()\\n   287→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n   288→\\t\\tdir = resolved\\n   289→\\t}\\n   290→\\n   291→\\tt.Logf(\\\"Cloning %s (depth=1) ...\\\", hookPerfRepoURL)\\n   292→\\tstart := time.Now()\\n   293→\\n   294→\\t//nolint:gosec // test-only, URL is a constant\\n   295→\\tcmd := exec.Command(\\\"git\\\", \\\"clone\\\", \\\"--depth\\\", \\\"1\\\", hookPerfRepoURL, dir)\\n   296→\\tout, err := cmd.CombinedOutput()\\n   297→\\tif err != nil {\\n   298→\\t\\tt.Fatalf(\\\"git clone failed: %v\\\\n%s\\\", err, out)\\n   299→\\t}\\n   300→\\tt.Logf(\\\"Source clone completed in %s\\\", time.Since(start).Round(time.Millisecond))\\n   301→\\n   302→\\treturn dir\\n   303→}\\n   304→\\n   305→// localClone creates a fast local clone from the cached source repo.\\n   306→func localClone(t *testing.T, sourceDir string) string {\\n   307→\\tt.Helper()\\n   308→\\n   309→\\tdir := t.TempDir()\\n   310→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n   311→\\t\\tdir = resolved\\n   312→\\t}\\n   313→\\n   314→\\t//nolint:gosec // test-only, sourceDir is from t.TempDir()\\n   315→\\tcmd := exec.Command(\\\"git\\\", \\\"clone\\\", \\\"--local\\\", sourceDir, dir)\\n   316→\\tout, err := cmd.CombinedOutput()\\n   317→\\tif err != nil {\\n   318→\\t\\tt.Fatalf(\\\"local clone failed: %v\\\\n%s\\\", err, out)\\n   319→\\t}\\n   320→\\n   321→\\treturn dir\\n   322→}\\n   323→\\n   324→// gitRun executes a git command in the given directory and fails the test on error.\\n   325→func gitRun(t *testing.T, dir string, args ...string) {\\n   326→\\tt.Helper()\\n   327→\\t//nolint:gosec // test-only helper\\n   328→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   329→\\tcmd.Dir = dir\\n   330→\\tout, err := cmd.CombinedOutput()\\n   331→\\tif err != nil {\\n   332→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n   333→\\t}\\n   334→}\\n   335→\\n   336→// createHookPerfSettings writes .entire/settings.json with commit_linking=always\\n   337→// so PrepareCommitMsg auto-links without pro