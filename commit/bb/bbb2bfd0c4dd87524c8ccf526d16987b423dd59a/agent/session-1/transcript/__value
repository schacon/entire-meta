\\\"\\\" {\\n   245→\\t\\tcpID, err := id.Generate()\\n   246→\\t\\tif err != nil {\\n   247→\\t\\t\\tb.Fatalf(\\\"generate session ID: %v\\\", err)\\n   248→\\t\\t}\\n   249→\\t\\topts.SessionID = fmt.Sprintf(\\\"bench-%s\\\", cpID)\\n   250→\\t}\\n   251→\\tif opts.Phase == \\\"\\\" {\\n   252→\\t\\topts.Phase = session.PhaseActive\\n   253→\\t}\\n   254→\\n   255→\\tif opts.AgentType == \\\"\\\" {\\n   256→\\t\\topts.AgentType = agent.AgentTypeClaudeCode\\n   257→\\t}\\n   258→\\n   259→\\tnow := time.Now()\\n   260→\\tstate := &session.State{\\n   261→\\t\\tSessionID:      opts.SessionID,\\n   262→\\t\\tBaseCommit:     br.HeadHash,\\n   263→\\t\\tWorktreePath:   br.Dir,\\n   264→\\t\\tWorktreeID:     br.WorktreeID,\\n   265→\\t\\tStartedAt:      now,\\n   266→\\t\\tPhase:          opts.Phase,\\n   267→\\t\\tStepCount:      opts.StepCount,\\n   268→\\t\\tFilesTouched:   opts.FilesTouched,\\n   269→\\t\\tTranscriptPath: opts.TranscriptPath,\\n   270→\\t\\tAgentType:      opts.AgentType,\\n   271→\\t}\\n   272→\\n   273→\\t// Write to .git/entire-sessions/<session-id>.json\\n   274→\\tgitDir := filepath.Join(br.Dir, \\\".git\\\")\\n   275→\\tsessDir := filepath.Join(gitDir, session.SessionStateDirName)\\n   276→\\tif err := os.MkdirAll(sessDir, 0o750); err != nil {\\n   277→\\t\\tb.Fatalf(\\\"mkdir sessions: %v\\\", err)\\n   278→\\t}\\n   279→\\n   280→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   281→\\tif err != nil {\\n   282→\\t\\tb.Fatalf(\\\"marshal state: %v\\\", err)\\n   283→\\t}\\n   284→\\n   285→\\tstatePath := filepath.Join(sessDir, opts.SessionID+\\\".json\\\")\\n   286→\\tif err := os.WriteFile(statePath, data, 0o600); err != nil {\\n   287→\\t\\tb.Fatalf(\\\"write state: %v\\\", err)\\n   288→\\t}\\n   289→\\n   290→\\treturn opts.SessionID\\n   291→}\\n   292→\\n   293→// TranscriptOpts configures how GenerateTranscript creates JSONL data.\\n   294→type TranscriptOpts struct {\\n   295→\\t// MessageCount is the number of JSONL messages to generate.\\n   296→\\tMessageCount int\\n   297→\\n   298→\\t// AvgMessageBytes is the approximate size of each message's content field.\\n   299→\\t// Defaults to 500.\\n   300→\\tAvgMessageBytes int\\n   301→\\n   302→\\t// IncludeToolUse adds realistic tool_use messages (file edits, bash commands).\\n   303→\\tIncludeToolUse bool\\n   304→\\n   305→\\t// FilesTouched is the list of files to reference in tool_use messages.\\n   306→\\t// Only used when IncludeToolUse is true.\\n   307→\\tFilesTouched []string\\n   308→}\\n   309→\\n   310→// GenerateTranscript creates realistic Claude Code JSONL transcript data.\\n   311→// Returns the raw bytes suitable for writing to full.jsonl.\\n   312→func GenerateTranscript(opts TranscriptOpts) []byte {\\n   313→\\tif opts.AvgMessageBytes == 0 {\\n   314→\\t\\topts.AvgMessageBytes = 500\\n   315→\\t}\\n   316→\\n   317→\\tvar buf strings.Builder\\n   318→\\tfor i := range opts.MessageCount {\\n   319→\\t\\tmsg := generateTranscriptMessage(i, opts)\\n   320→\\t\\tdata, err := json.Marshal(msg)\\n   321→\\t\\tif err != nil {\\n   322→\\t\\t\\t// Should never happen with map[string]any, but satisfy errcheck\\n   323→\\t\\t\\tcontinue\\n   324→\\t\\t}\\n   325→\\t\\tbuf.Write(data)\\n   326→\\t\\tbuf.WriteByte('\\\\n')\\n   327→\\t}\\n   328→\\treturn []byte(buf.String())\\n   329→}\\n   330→\\n   331→// WriteTranscriptFile writes transcript data to a file and returns the path.\\n   332→func (br *BenchRepo) WriteTranscriptFile(b *testing.B, sessionID string, data []byte) string {\\n   333→\\tb.Helper()\\n   334→\\t// Write to .entire/metadata/<session-id>/full.jsonl (matching real layout)\\n   335→\\trelDir := filepath.Join(\\\".entire\\\", \\\"metadata\\\", sessionID)\\n   336→\\trelPath := filepath.Join(relDir, \\\"full.jsonl\\\")\\n   337→\\tabsDir := filepath.Join(br.Dir, relDir)\\n   338→\\tif err := os.MkdirAll(absDir, 0o750); err != nil {\\n   339→\\t\\tb.Fatalf(\\\"mkdir transcript dir: %v\\\", err)\\n   340→\\t}\\n   341→\\tabsPath := filepath.Join(br.Dir, relPath)\\n   342→\\tif err := os.WriteFile(absPath, data, 0o600); err != nil {\\n   343→\\t\\tb.Fatalf(\\\"write transcript: %v\\\", err)\\n   344→\\t}\\n   345→\\treturn absPath\\n   346→}\\n   347→\\n   348→// SeedShadowBranch creates N checkpoint commits on the shadow branch\\n   349→// for the current HEAD. This simulates a session that already has\\n   350→// prior checkpoints saved.\\n   351→//\\n   352→// Temporarily changes cwd to br.Dir because WriteTemporary uses\\n   353→// paths.WorktreeRoot() which depends on os.Getwd().\\n   354→func (br *BenchRepo) SeedShadowBranch(b *testing.B, sessionID string, checkpointCount int, filesPerCheckpoint int) {\\n   355→\\tb.Helper()\\n   356→\\n   357→\\t// WriteTemporary internally calls paths.WorktreeRoot() which uses os.Getwd().\\n   358→\\t// Switch cwd so it resolves to the bench repo.\\n   359→\\tb.Chdir(br.Dir)\\n   360→\\tpaths.ClearWorktreeRootCache()\\n   361→\\n   362→\\tfor i := range checkpointCount {\\n   363→\\t\\tvar modified []string\\n   364→\\t\\tfor j := range filesPerCheckpoint {\\n   365→\\t\\t\\tname := fmt.Sprintf(\\\"src/file_%03d.go\\\", j)\\n   366→\\t\\t\\tcontent := GenerateGoFile(i*1000+j, 100)\\n   367→\\t\\t\\twriteFile(b, br.Dir, name, content)\\n   368→\\t\\t\\tmodified = append(modified, name)\\n   369→\\t\\t}\\n   370→\\n   371→\\t\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   372→\\t\\tmetadataDirAbs := filepath.Join(br.Dir, metadataDir)\\n   373→\\t\\tif err := os.MkdirAll(metadataDirAbs, 0o750); err != nil {\\n   374→\\t\\t\\tb.Fatalf(\\\"mkdir metadata: %v\\\", err)\\n   375→\\t\\t}\\n   376→\\n   377→\\t\\t// Write a minimal transcript to the metadata dir\\n   378→\\t\\ttranscriptPath := filepath.Join(metadataDirAbs, \\\"full.jsonl\\\")\\n   379→\\t\\ttranscript := GenerateTranscript(TranscriptOpts{MessageCount: 5, AvgMessageBytes: 200})\\n   380→\\t\\tif err := os.WriteFile(transcriptPath, transcript, 0o600); err != nil {\\n   381→\\t\\t\\tb.Fatalf(\\\"write transcript: %v\\\", err)\\n   382→\\t\\t}\\n   383→\\n   384→\\t\\t_, err := br.Store.WriteTemporary(context.Background(), checkpoint.WriteTemporaryOptions{\\n   385→\\t\\t\\tSessionID:         sessionID,\\n   386→\\t\\t\\tBaseCommit:        br.HeadHash,\\n   387→\\t\\t\\tWorktreeID:        br.WorktreeID,\\n   388→\\t\\t\\tModifiedFiles:     modified,\\n   389→\\t\\t\\tMetadataDir:       metadataDir,\\n   390→\\t\\t\\tMetadataDirAbs:    metadataDirAbs,\\n   391→\\t\\t\\tCommitMessage:     fmt.Sprintf(\\\"Checkpoint %d\\\", i+1),\\n   392→\\t\\t\\tAuthorName:        \\\"Bench User\\\",\\n   393→\\t\\t\\tAuthorEmail:       \\\"bench@example.com\\\",\\n   394→\\t\\t\\tIsFirstCheckpoint: i == 0,\\n   395→\\t\\t})\\n   396→\\t\\tif err != nil {\\n   397→\\t\\t\\tb.Fatalf(\\\"write temporary checkpoint %d: %v\\\", i+1, err)\\n   398→\\t\\t}\\n   399→\\t}\\n   400→}\\n   401→\\n   402→// SeedMetadataBranch creates N committed checkpoints on the entire/checkpoints/v1\\n   403→// branch. This simulates a repository with prior checkpoint history.\\n   404→func (br *BenchRepo) SeedMetadataBranch(b *testing.B, checkpointCount int) {\\n   405→\\tb.Helper()\\n   406→\\n   407→\\tfor i := range checkpointCount {\\n   408→\\t\\tcpID, err := id.Generate()\\n   409→\\t\\tif err != nil {\\n   410→\\t\\t\\tb.Fatalf(\\\"generate checkpoint ID: %v\\\", err)\\n   411→\\t\\t}\\n   412→\\t\\tsessionID := fmt.Sprintf(\\\"seed-session-%04d\\\", i)\\n   413→\\t\\ttranscript := GenerateTranscript(TranscriptOpts{\\n   414→\\t\\t\\tMessageCount:    20,\\n   415→\\t\\t\\tAvgMessageBytes: 300,\\n   416→\\t\\t})\\n   417→\\n   418→\\t\\tfiles := make([]string, 0, 5)\\n   419→\\t\\tfor j := range 5 {\\n   420→\\t\\t\\tfiles = append(files, fmt.Sprintf(\\\"src/file_%03d.go\\\", (i*5+j)%100))\\n   421→\\t\\t}\\n   422→\\n   423→\\t\\terr = br.Store.WriteCommitted(context.Background(), checkpoint.WriteCommittedOptions{\\n   424→\\t\\t\\tCheckpointID:     cpID,\\n   425→\\t\\t\\tSessionID:        sessionID,\\n   426→\\t\\t\\tStrategy:         br.Strategy,\\n   427→\\t\\t\\tTranscript:       transcript,\\n   428→\\t\\t\\tPrompts:          []string{fmt.Sprintf(\\\"Implement feature %d\\\", i)},\\n   429→\\t\\t\\tFilesTouched:     files,\\n   430→\\t\\t\\tCheckpointsCount: 3,\\n   431→\\t\\t\\tAuthorName:       \\\"Bench User\\\",\\n   432→\\t\\t\\tAuthorEmail:      \\\"bench@example.com\\\",\\n   433→\\t\\t\\tAgent:            agent.AgentTypeClaudeCode,\\n   434→\\t\\t})\\n   435→\\t\\tif err != nil {\\n   436→\\t\\t\\tb.Fatalf(\\\"write committed checkpoint %d: %v\\\", i+1, err)\\n   437→\\t\\t}\\n   438→\\t}\\n   439→}\\n   440→\\n   441→// GenerateGoFile creates a synthetic Go source file with the given number of lines.\\n   442→// The seed value ensures unique content for each file.\\n   443→func GenerateGoFile(seed, lines int) string {\\n   444→\\tvar buf strings.Builder\\n   445→\\tfmt.Fprintf(&buf, \\\"package pkg%d\\\\n\\\\n\\\", seed%100)\\n   446→\\n   447→\\tlineNum := 2\\n   448→\\tfuncNum := 0\\n   449→\\tfor lineNum < lines {\\n   450→\\t\\tfuncName := fmt.Sprintf(\\\"func%d_%d\\\", seed, funcNum)\\n   451→\\t\\tfmt.Fprintf(&buf, \\\"func %s(ctx context.Context, input string) (string, error) {\\\\n\\\", funcName)\\n   452→\\t\\tlineNum++\\n   453→\\n   454→\\t\\tbodyLines := min(8, lines-lineNum-1)\\n   455→\\t\\tfor j := range bodyLines {\\n   456→\\t\\t\\tfmt.Fprintf(&buf, \\\"\\\\tv%d := fmt.Sprintf(\\\\\\\"processing %%s step %d seed %d\\\\\\\", input)\\\\n\\\", j, j, seed)\\n   457→\\t\\t\\tlineNum++\\n   458→\\t\\t}\\n   459→\\t\\tbuf.WriteString(\\\"\\\\treturn \\\\\\\"\\\\\\\", nil\\\\n}\\\\n\\\\n\\\")\\n   460→\\t\\tlineNum += 2\\n   461→\\t\\tfuncNum++\\n   462→\\t}\\n   463→\\treturn buf.String()\\n   464→}\\n   465→\\n   466→// GenerateFileContent creates generic file content of approximately the given byte size.\\n   467→func GenerateFileContent(seed, sizeBytes int) string {\\n   468→\\tvar buf strings.Builder\\n   469→\\tline := fmt.Sprintf(\\\"// Line content seed=%d \\\", seed)\\n   470→\\tpadding := strings.Repeat(\\\"x\\\", max(1, 80-len(line)))\\n   471→\\tfullLine := line + padding + \\\"\\\\n\\\"\\n   472→\\n   473→\\tfor buf.Len() < sizeBytes {\\n   474→\\t\\tbuf.WriteString(fullLine)\\n   475→\\t}\\n   476→\\treturn buf.String()\\n   477→}\\n   478→\\n   479→//nolint:gosec // G301/G306: benchmark fixtures use standard permissions in temp dirs\\n   480→func writeFile(b *testing.B, dir, relPath, content string) {\\n   481→\\tb.Helper()\\n   482→\\tabs := filepath.Join(dir, relPath)\\n   483→\\tif err := os.MkdirAll(filepath.Dir(abs), 0o755); err != nil {\\n   484→\\t\\tb.Fatalf(\\\"mkdir %s: %v\\\", filepath.Dir(relPath), err)\\n   485→\\t}\\n   486→\\tif err := os.WriteFile(abs, []byte(content), 0o644); err != nil {\\n   487→\\t\\tb.Fatalf(\\\"write %s: %v\\\", relPath, err)\\n   488→\\t}\\n   489→}\\n   490→\\n   491→//nolint:gosec // G301/G306: benchmark fixtures use standard permissions in temp dirs\\n   492→func initEntireSettings(b *testing.B, dir, strategy string) {\\n   493→\\tb.Helper()\\n   494→\\tentireDir := filepath.Join(dir, \\\".entire\\\")\\n   495→\\tif err := os.MkdirAll(filepath.Join(entireDir, \\\"tmp\\\"), 0o755); err != nil {\\n   496→\\t\\tb.Fatalf(\\\"mkdir .entire: %v\\\", err)\\n   497→\\t}\\n   498→\\n   499→\\tsettings := map[string]any{\\n   500→\\t\\t\\\"strategy\\\":  strategy,\\n   501→\\t\\t\\\"local_dev\\\": true,\\n   502→\\t}\\n   503→\\tdata, err := jsonutil.MarshalIndentWithNewline(settings, \\\"\\\", \\\"  \\\")\\n   504→\\tif err != nil {\\n   505→\\t\\tb.Fatalf(\\\"marshal settings: %v\\\", err)\\n   506→\\t}\\n   507→\\tif err := os.WriteFile(filepath.Join(entireDir, paths.SettingsFileName), data, 0o644); err != nil {\\n   508→\\t\\tb.Fatalf(\\\"write settings: %v\\\", err)\\n   509→\\t}\\n   510→}\\n   511→\\n   512→func checkoutBranch(b *testing.B, dir, branch string) {\\n   513→\\tb.Helper()\\n   514→\\tc := exec.CommandContext(context.Background(), \\\"git\\\", \\\"checkout\\\", branch)\\n   515→\\tc.Dir = dir\\n   516→\\tif output, err := c.CombinedOutput(); err != nil {\\n   517→\\t\\tb.Fatalf(\\\"git checkout %s: %v\\\\n%s\\\", branch, err, output)\\n   518→\\t}\\n   519→}\\n   520→\\n   521→// generateTranscriptMessage creates a single JSONL message for a Claude Code transcript.\\n   522→func generateTranscriptMessage(index int, opts TranscriptOpts) map[string]any {\\n   523→\\tmsg := map[string]any{\\n   524→\\t\\t\\\"uuid\\\":        fmt.Sprintf(\\\"msg_%06d\\\", index),\\n   525→\\t\\t\\\"timestamp\\\":   time.Now().Add(time.Duration(index) * time.Second).Format(time.RFC3339),\\n   526→\\t\\t\\\"parent_uuid\\\": fmt.Sprintf(\\\"msg_%06d\\\", max(0, index-1)),\\n   527→\\t}\\n   528→\\n   529→\\tswitch {\\n   530→\\tcase opts.IncludeToolUse && index%3 == 2 && len(opts.FilesTouched) > 0:\\n   531→\\t\\t// Tool use message (every 3rd message)\\n   532→\\t\\tfile := opts.FilesTouched[index%len(opts.FilesTouched)]\\n   533→\\t\\tmsg[\\\"type\\\"] = \\\"tool_use\\\"\\n   534→\\t\\tmsg[\\\"tool_name\\\"] = \\\"write_to_file\\\"\\n   535→\\t\\tmsg[\\\"tool_input\\\"] = map[string]any{\\n   536→\\t\\t\\t\\\"path\\\":    file,\\n   537→\\t\\t\\t\\\"content\\\": GenerateFileContent(index, opts.AvgMessageBytes/2),\\n   538→\\t\\t}\\n   539→\\tcase index%2 == 0:\\n   540→\\t\\t// Assistant message\\n   541→\\t\\tmsg[\\\"type\\\"] = \\\"assistant\\\"\\n   542→\\t\\tmsg[\\\"content\\\"] = generatePadding(\\\"I'll help you implement this feature. \\\", opts.AvgMessageBytes)\\n   543→\\tdefault:\\n   544→\\t\\t// Human message\\n   545→\\t\\tmsg[\\\"type\\\"] = \\\"human\\\"\\n   546→\\t\\tmsg[\\\"content\\\"] = generatePadding(\\\"Please update the implementation. \\\", opts.AvgMessageBytes/3)\\n   547→\\t}\\n   548→\\n   549→\\treturn msg\\n   550→}\\n   551→\\n   552→// SeedBranches creates N branches pointing at the current HEAD.\\n   553→// The branches are named with the given prefix (e.g., \\\"feature/bench-\\\" → \\\"feature/bench-000\\\").\\n   554→// This simulates a repo with many refs, which affects go-git ref scanning performance.\\n   555→func (br *BenchRepo) SeedBranches(b *testing.B, prefix string, count int) {\\n   556→\\tb.Helper()\\n   557→\\theadHash := plumbing.NewHash(br.HeadHash)\\n   558→\\tfor i := range count {\\n   559→\\t\\tname := fmt.Sprintf(\\\"%s%03d\\\", prefix, i)\\n   560→\\t\\tref := plumbing.NewHashReference(plumbing.NewBranchReferenceName(name), headHash)\\n   561→\\t\\tif err := br.Repo.Storer.SetReference(ref); err != nil {\\n   562→\\t\\t\\tb.Fatalf(\\\"create branch %s: %v\\\", name, err)\\n   563→\\t\\t}\\n   564→\\t}\\n   565→}\\n   566→\\n   567→// PackRefs runs `git pack-refs --all` to simulate a real repo where most refs\\n   568→// are in the packed-refs file. Large repos almost always have packed refs.\\n   569→func (br *BenchRepo) PackRefs(b *testing.B) {\\n   570→\\tb.Helper()\\n   571→\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"pack-refs\\\", \\\"--all\\\")\\n   572→\\tcmd.Dir = br.Dir\\n   573→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   574→\\t\\tb.Fatalf(\\\"git pack-refs: %v\\\\n%s\\\", err, output)\\n   575→\\t}\\n   576→}\\n   577→\\n   578→// SeedGitObjects creates loose git objects to bloat .git/objects/.\\n   579→// Each call creates N blob objects via `git hash-object -w`.\\n   580→// After seeding, runs `git gc` to pack them into a packfile (realistic).\\n   581→func (br *BenchRepo) SeedGitObjects(b *testing.B, count int) {\\n   582→\\tb.Helper()\\n   583→\\n   584→\\tfor i := range count {\\n   585→\\t\\tcontent := GenerateFileContent(i, 4096)\\n   586→\\t\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"hash-object\\\", \\\"-w\\\", \\\"--stdin\\\")\\n   587→\\t\\tcmd.Dir = br.Dir\\n   588→\\t\\tcmd.Stdin = strings.NewReader(content)\\n   589→\\t\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   590→\\t\\t\\tb.Fatalf(\\\"git hash-object %d: %v\\\\n%s\\\", i, err, output)\\n   591→\\t\\t}\\n   592→\\t}\\n   593→\\n   594→\\t// Pack into a packfile like a real repo\\n   595→\\tgc := exec.CommandContext(context.Background(), \\\"git\\\", \\\"gc\\\", \\\"--quiet\\\")\\n   596→\\tgc.Dir = br.Dir\\n   597→\\tif output, err := gc.CombinedOutput(); err != nil {\\n   598→\\t\\tb.Fatalf(\\\"git gc: %v\\\\n%s\\\", err, output)\\n   599→\\t}\\n   600→}\\n   601→\\n   602→func generatePadding(prefix string, targetBytes int) string {\\n   603→\\tif len(prefix) >= targetBytes {\\n   604→\\t\\treturn prefix[:targetBytes]\\n   605→\\t}\\n   606→\\tpadding := strings.Repeat(\\\"Lorem ipsum dolor sit amet. \\\", (targetBytes-len(prefix))/28+1)\\n   607→\\tresult := prefix + padding\\n   608→\\tif len(result) > targetBytes {\\n   609→\\t\\treturn result[:targetBytes]\\n   610→\\t}\\n   611→\\treturn result\\n   612→}\\n   613→\"}]},\"uuid\":\"25c0b9e4-69a7-455b-b8d7-166fbfd79e96\",\"timestamp\":\"2026-02-27T19:58:19.691Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/evisdrenova/code/entire/devenv/cli/cmd/entire/cli/benchutil/benchutil.go\",\"content\":\"// Package benchutil provides test fixture helpers for CLI benchmarks.\\n//\\n// It creates realistic git repositories, transcripts, session states,\\n// and checkpoint data for benchmarking the hot paths (SaveStep, PostCommit/Condense).\\npackage benchutil\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"os/exec\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"testing\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/en