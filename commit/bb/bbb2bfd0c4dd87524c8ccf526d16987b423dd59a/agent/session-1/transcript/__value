\tpaths.ClearWorktreeRootCache()\\n   376→\\n   377→\\tif err := s.SaveStep(ctx, StepContext{\\n   378→\\t\\tSessionID:      sessionID,\\n   379→\\t\\tModifiedFiles:  modifiedFiles,\\n   380→\\t\\tNewFiles:       []string{},\\n   381→\\t\\tDeletedFiles:   []string{},\\n   382→\\t\\tMetadataDir:    metadataDir,\\n   383→\\t\\tMetadataDirAbs: metadataDirAbs,\\n   384→\\t\\tCommitMessage:  \\\"Checkpoint 1\\\",\\n   385→\\t\\tAuthorName:     \\\"Perf\\\",\\n   386→\\t\\tAuthorEmail:    \\\"perf@test.com\\\",\\n   387→\\t}); err != nil {\\n   388→\\t\\tt.Fatalf(\\\"SaveStep %s: %v\\\", sessionID, err)\\n   389→\\t}\\n   390→\\n   391→\\t// Set the session phase and files touched\\n   392→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   393→\\tif err != nil {\\n   394→\\t\\tt.Fatalf(\\\"load state %s: %v\\\", sessionID, err)\\n   395→\\t}\\n   396→\\tstate.Phase = phase\\n   397→\\tstate.FilesTouched = modifiedFiles\\n   398→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   399→\\t\\tt.Fatalf(\\\"save state %s: %v\\\", sessionID, err)\\n   400→\\t}\\n   401→}\\n   402→\\n   403→func mustGenerateCheckpointID(t *testing.T) id.CheckpointID {\\n   404→\\tt.Helper()\\n   405→\\tcpID, err := id.Generate()\\n   406→\\tif err != nil {\\n   407→\\t\\tt.Fatalf(\\\"generate checkpoint ID: %v\\\", err)\\n   408→\\t}\\n   409→\\treturn cpID\\n   410→}\\n   411→\"}]},\"uuid\":\"bcad47f1-e407-46a3-8ec2-c9d435fffb7f\",\"timestamp\":\"2026-02-27T19:58:18.953Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/evisdrenova/code/entire/devenv/cli/cmd/entire/cli/strategy/commit_hook_perf_test.go\",\"content\":\"//go:build hookperf\\n\\npackage strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"os/exec\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"testing\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n)\\n\\nconst hookPerfRepoURL = \\\"https://github.com/entireio/cli.git\\\"\\n\\n// TestCommitHookPerformance measures PrepareCommitMsg + PostCommit execution\\n// time across different session counts using a clone of the entireio/cli repo\\n// so that go-git operates on a realistic object database, packed refs, and\\n// working tree.\\n//\\n// Prerequisites:\\n//   - GitHub access (gh auth login) for cloning the private repo\\n//\\n// Run: go test -v -run TestCommitHookPerformance -tags hookperf -timeout 10m ./cmd/entire/cli/strategy/\\nfunc TestCommitHookPerformance(t *testing.T) {\\n\\t// Clone once, reuse across scenarios via cheap local clones.\\n\\tcacheDir := cloneSourceRepo(t)\\n\\n\\tscenarios := []struct {\\n\\t\\tname   string\\n\\t\\tended  int\\n\\t\\tidle   int\\n\\t\\tactive int\\n\\t}{\\n\\t\\t{\\\"10sessions\\\", 8, 1, 1},\\n\\t\\t{\\\"50sessions\\\", 43, 6, 1},\\n\\t\\t{\\\"100sessions\\\", 88, 11, 1},\\n\\t\\t{\\\"200sessions\\\", 180, 19, 1},\\n\\t}\\n\\n\\ttype result struct {\\n\\t\\tname       string\\n\\t\\ttotal      int\\n\\t\\tclone      time.Duration\\n\\t\\tsetup      time.Duration\\n\\t\\tprepare    time.Duration\\n\\t\\tpostCommit time.Duration\\n\\t}\\n\\tresults := make([]result, 0, len(scenarios))\\n\\n\\tfor _, sc := range scenarios {\\n\\t\\tt.Run(sc.name, func(t *testing.T) {\\n\\t\\t\\ttotalSessions := sc.ended + sc.idle + sc.active\\n\\n\\t\\t\\t// Local clone from cached source (copies .git objects via hardlinks).\\n\\t\\t\\tcloneStart := time.Now()\\n\\t\\t\\tdir := localClone(t, cacheDir)\\n\\t\\t\\tcloneDur := time.Since(cloneStart)\\n\\n\\t\\t\\tsetupStart := time.Now()\\n\\t\\t\\tt.Chdir(dir)\\n\\t\\t\\tpaths.ClearWorktreeRootCache()\\n\\t\\t\\tsession.ClearGitCommonDirCache()\\n\\n\\t\\t\\tcreateHookPerfSettings(t, dir)\\n\\t\\t\\tseedHookPerfSessions(t, dir, sc.ended, sc.idle, sc.active)\\n\\n\\t\\t\\t// Stage a file change for the commit using git CLI\\n\\t\\t\\t// (avoids go-git worktree.Add which is slow on large repos).\\n\\t\\t\\ttestFile := filepath.Join(dir, \\\"main.go\\\")\\n\\t\\t\\tif err := os.WriteFile(testFile, []byte(\\\"package main\\\\n// user edit\\\\nfunc main() {}\\\\n\\\"), 0o644); err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"write: %v\\\", err)\\n\\t\\t\\t}\\n\\t\\t\\tgitRun(t, dir, \\\"add\\\", \\\"main.go\\\")\\n\\n\\t\\t\\tsetupDur := time.Since(setupStart)\\n\\n\\t\\t\\t// --- Time PrepareCommitMsg ---\\n\\t\\t\\t// Simulate TTY path (the expensive one) with commit_linking=always\\n\\t\\t\\t// so it auto-links without blocking on the TTY prompt.\\n\\t\\t\\tt.Setenv(\\\"ENTIRE_TEST_TTY\\\", \\\"1\\\")\\n\\t\\t\\tpaths.ClearWorktreeRootCache()\\n\\t\\t\\tsession.ClearGitCommonDirCache()\\n\\n\\t\\t\\tcommitMsgFile := filepath.Join(dir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n\\t\\t\\tif err := os.WriteFile(commitMsgFile, []byte(\\\"implement feature\\\\n\\\"), 0o644); err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"write commit msg: %v\\\", err)\\n\\t\\t\\t}\\n\\n\\t\\t\\ts1 := &ManualCommitStrategy{}\\n\\t\\t\\tprepStart := time.Now()\\n\\t\\t\\tif err := s1.PrepareCommitMsg(context.Background(), commitMsgFile, \\\"message\\\"); err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"PrepareCommitMsg: %v\\\", err)\\n\\t\\t\\t}\\n\\t\\t\\tprepDur := time.Since(prepStart)\\n\\n\\t\\t\\t// Read back the commit message to check if trailer was added.\\n\\t\\t\\tmsgBytes, err := os.ReadFile(commitMsgFile) //nolint:gosec // test file\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"read commit msg: %v\\\", err)\\n\\t\\t\\t}\\n\\t\\t\\tcommitMsg := string(msgBytes)\\n\\n\\t\\t\\t// If PrepareCommitMsg didn't add a trailer (e.g., content-aware check\\n\\t\\t\\t// determined no new content), inject one manually so PostCommit exercises\\n\\t\\t\\t// the full condensation path rather than the early-exit path.\\n\\t\\t\\tif _, found := trailers.ParseCheckpoint(commitMsg); !found {\\n\\t\\t\\t\\tcpID, genErr := id.Generate()\\n\\t\\t\\t\\tif genErr != nil {\\n\\t\\t\\t\\t\\tt.Fatalf(\\\"generate checkpoint ID: %v\\\", genErr)\\n\\t\\t\\t\\t}\\n\\t\\t\\t\\tcommitMsg = fmt.Sprintf(\\\"%s\\\\n%s: %s\\\\n\\\",\\n\\t\\t\\t\\t\\tstrings.TrimRight(commitMsg, \\\"\\\\n\\\"),\\n\\t\\t\\t\\t\\ttrailers.CheckpointTrailerKey, cpID)\\n\\t\\t\\t\\tt.Logf(\\\"  Injected trailer (PrepareCommitMsg skipped content-aware check)\\\")\\n\\t\\t\\t}\\n\\n\\t\\t\\t// Create the actual commit with the trailer so PostCommit finds it.\\n\\t\\t\\tgitRun(t, dir, \\\"commit\\\", \\\"-m\\\", commitMsg)\\n\\n\\t\\t\\t// --- Time PostCommit ---\\n\\t\\t\\tpaths.ClearWorktreeRootCache()\\n\\t\\t\\tsession.ClearGitCommonDirCache()\\n\\n\\t\\t\\ts2 := &ManualCommitStrategy{}\\n\\t\\t\\tpostStart := time.Now()\\n\\t\\t\\tif err := s2.PostCommit(context.Background()); err != nil {\\n\\t\\t\\t\\tt.Fatalf(\\\"PostCommit: %v\\\", err)\\n\\t\\t\\t}\\n\\t\\t\\tpostDur := time.Since(postStart)\\n\\n\\t\\t\\tt.Logf(\\\"=== %s ===\\\", sc.name)\\n\\t\\t\\tt.Logf(\\\"  Sessions:         %d (ended=%d, idle=%d, active=%d)\\\", totalSessions, sc.ended, sc.idle, sc.active)\\n\\t\\t\\tt.Logf(\\\"  Local clone:      %s\\\", cloneDur.Round(time.Millisecond))\\n\\t\\t\\tt.Logf(\\\"  Setup:            %s\\\", setupDur.Round(time.Millisecond))\\n\\t\\t\\tt.Logf(\\\"  PrepareCommitMsg: %s\\\", prepDur.Round(time.Millisecond))\\n\\t\\t\\tt.Logf(\\\"  PostCommit:       %s\\\", postDur.Round(time.Millisecond))\\n\\t\\t\\tt.Logf(\\\"  TOTAL HOOKS:      %s\\\", (prepDur + postDur).Round(time.Millisecond))\\n\\n\\t\\t\\tresults = append(results, result{\\n\\t\\t\\t\\tname:       sc.name,\\n\\t\\t\\t\\ttotal:      totalSessions,\\n\\t\\t\\t\\tclone:      cloneDur,\\n\\t\\t\\t\\tsetup:      setupDur,\\n\\t\\t\\t\\tprepare:    prepDur,\\n\\t\\t\\t\\tpostCommit: postDur,\\n\\t\\t\\t})\\n\\t\\t})\\n\\t}\\n\\n\\t// Print summary table\\n\\tt.Log(\\\"\\\")\\n\\tt.Log(\\\"========== COMMIT HOOK PERFORMANCE SUMMARY ==========\\\")\\n\\tt.Logf(\\\"%-20s | %8s | %12s | %12s | %12s\\\", \\\"Scenario\\\", \\\"Sessions\\\", \\\"Prepare\\\", \\\"PostCommit\\\", \\\"TOTAL\\\")\\n\\tt.Log(\\\"-------------------------------------------------------------------------------------\\\")\\n\\tfor _, r := range results {\\n\\t\\tt.Logf(\\\"%-20s | %8d | %12s | %12s | %12s\\\",\\n\\t\\t\\tr.name,\\n\\t\\t\\tr.total,\\n\\t\\t\\tr.prepare.Round(time.Millisecond),\\n\\t\\t\\tr.postCommit.Round(time.Millisecond),\\n\\t\\t\\t(r.prepare + r.postCommit).Round(time.Millisecond),\\n\\t\\t)\\n\\t}\\n}\\n\\n// cloneSourceRepo does a one-time shallow clone of entireio/cli into a temp\\n// directory. Returns the path to use as a local clone source for each scenario.\\n// Shallow clone keeps all remote refs but only one commit of history.\\nfunc cloneSourceRepo(t *testing.T) string {\\n\\tt.Helper()\\n\\n\\tdir := t.TempDir()\\n\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n\\t\\tdir = resolved\\n\\t}\\n\\n\\tt.Logf(\\\"Cloning %s (depth=1) ...\\\", hookPerfRepoURL)\\n\\tstart := time.Now()\\n\\n\\t//nolint:gosec // test-only, URL is a constant\\n\\tcmd := exec.Command(\\\"git\\\", \\\"clone\\\", \\\"--depth\\\", \\\"1\\\", hookPerfRepoURL, dir)\\n\\tout, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"git clone failed: %v\\\\n%s\\\", err, out)\\n\\t}\\n\\tt.Logf(\\\"Source clone completed in %s\\\", time.Since(start).Round(time.Millisecond))\\n\\n\\treturn dir\\n}\\n\\n// localClone creates a fast local clone from the cached source repo.\\n// Uses --no-hardlinks to get an independent copy (hardlinks don't work\\n// across temp dirs on all platforms).\\nfunc localClone(t *testing.T, sourceDir string) string {\\n\\tt.Helper()\\n\\n\\tdir := t.TempDir()\\n\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n\\t\\tdir = resolved\\n\\t}\\n\\n\\t//nolint:gosec // test-only, sourceDir is from t.TempDir()\\n\\tcmd := exec.Command(\\\"git\\\", \\\"clone\\\", \\\"--local\\\", sourceDir, dir)\\n\\tout, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"local clone failed: %v\\\\n%s\\\", err, out)\\n\\t}\\n\\n\\treturn dir\\n}\\n\\n// gitRun executes a git command in the given directory and fails the test on error.\\nfunc gitRun(t *testing.T, dir string, args ...string) {\\n\\tt.Helper()\\n\\t//nolint:gosec // test-only helper\\n\\tcmd := exec.Command(\\\"git\\\", args...)\\n\\tcmd.Dir = dir\\n\\tout, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n\\t}\\n}\\n\\n// createHookPerfSettings writes .entire/settings.json with commit_linking=always\\n// so PrepareCommitMsg auto-links without prompting.\\nfunc createHookPerfSettings(t *testing.T, dir string) {\\n\\tt.Helper()\\n\\tentireDir := filepath.Join(dir, \\\".entire\\\")\\n\\tif err := os.MkdirAll(entireDir, 0o755); err != nil {\\n\\t\\tt.Fatalf(\\\"mkdir .entire: %v\\\", err)\\n\\t}\\n\\tsettings := `{\\\"enabled\\\": true, \\\"strategy\\\": \\\"manual-commit\\\", \\\"commit_linking\\\": \\\"always\\\"}`\\n\\tif err := os.WriteFile(filepath.Join(entireDir, \\\"settings.json\\\"), []byte(settings), 0o644); err != nil {\\n\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n\\t}\\n}\\n\\n// seedHookPerfSessions creates session state files with realistic phase distribution.\\n//\\n// ENDED sessions: state file with LastCheckpointID set (already condensed).\\n// IDLE sessions: state file + shadow branch checkpoint via SaveStep.\\n// ACTIVE sessions: state file + shadow branch checkpoint + live transcript file.\\nfunc seedHookPerfSessions(t *testing.T, dir string, ended, idle, active int) {\\n\\tt.Helper()\\n\\n\\tctx := context.Background()\\n\\n\\t// Get HEAD hash for BaseCommit\\n\\trepo, err := git.PlainOpen(dir)\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"open repo: %v\\\", err)\\n\\t}\\n\\thead, err := repo.Head(