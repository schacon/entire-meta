nce-critical state operations.\\n   227→// Use the Sessions interface (when implemented) for high-level session management.\\n   228→type StateStore struct {\\n   229→\\t// stateDir is the directory where session state files are stored\\n   230→\\tstateDir string\\n   231→}\\n   232→\\n   233→// NewStateStore creates a new state store.\\n   234→// Uses the git common dir to store session state (shared across worktrees).\\n   235→func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   236→\\tcommonDir, err := getGitCommonDir(ctx)\\n   237→\\tif err != nil {\\n   238→\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   239→\\t}\\n   240→\\treturn &StateStore{\\n   241→\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   242→\\t}, nil\\n   243→}\\n   244→\\n   245→// NewStateStoreWithDir creates a new state store with a custom directory.\\n   246→// This is useful for testing.\\n   247→func NewStateStoreWithDir(stateDir string) *StateStore {\\n   248→\\treturn &StateStore{stateDir: stateDir}\\n   249→}\\n   250→\\n   251→// Load loads the session state for the given session ID.\\n   252→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   253→// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   254→func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   255→\\t// Validate session ID to prevent path traversal\\n   256→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   257→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   258→\\t}\\n   259→\\n   260→\\tstateFile := s.stateFilePath(sessionID)\\n   261→\\n   262→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is derived from sessionID\\n   263→\\tif os.IsNotExist(err) {\\n   264→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   265→\\t}\\n   266→\\tif err != nil {\\n   267→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   268→\\t}\\n   269→\\n   270→\\tvar state State\\n   271→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   272→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal session state: %w\\\", err)\\n   273→\\t}\\n   274→\\tstate.NormalizeAfterLoad(ctx)\\n   275→\\n   276→\\tif state.IsStale() {\\n   277→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   278→\\t\\tlogging.Debug(logCtx, \\\"deleting stale session state\\\",\\n   279→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   280→\\t\\t)\\n   281→\\t\\t_ = s.Clear(ctx, sessionID) //nolint:errcheck // best-effort cleanup of stale session\\n   282→\\t\\treturn nil, nil             //nolint:nilnil // stale session treated as not found\\n   283→\\t}\\n   284→\\n   285→\\treturn &state, nil\\n   286→}\\n   287→\\n   288→// Save saves the session state atomically.\\n   289→func (s *StateStore) Save(ctx context.Context, state *State) error {\\n   290→\\t_ = ctx // Reserved for future use\\n   291→\\n   292→\\t// Validate session ID to prevent path traversal\\n   293→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n   294→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   295→\\t}\\n   296→\\n   297→\\tif err := os.MkdirAll(s.stateDir, 0o750); err != nil {\\n   298→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   299→\\t}\\n   300→\\n   301→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   302→\\tif err != nil {\\n   303→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   304→\\t}\\n   305→\\n   306→\\tstateFile := s.stateFilePath(state.SessionID)\\n   307→\\n   308→\\t// Atomic write: write to temp file, then rename\\n   309→\\ttmpFile := stateFile + \\\".tmp\\\"\\n   310→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n   311→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   312→\\t}\\n   313→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n   314→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n   315→\\t}\\n   316→\\treturn nil\\n   317→}\\n   318→\\n   319→// Clear removes the session state file for the given session ID.\\n   320→func (s *StateStore) Clear(ctx context.Context, sessionID string) error {\\n   321→\\t_ = ctx // Reserved for future use\\n   322→\\n   323→\\t// Validate session ID to prevent path traversal\\n   324→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   325→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   326→\\t}\\n   327→\\n   328→\\tstateFile := s.stateFilePath(sessionID)\\n   329→\\n   330→\\tif err := os.Remove(stateFile); err != nil {\\n   331→\\t\\tif os.IsNotExist(err) {\\n   332→\\t\\t\\treturn nil // Already gone, not an error\\n   333→\\t\\t}\\n   334→\\t\\treturn fmt.Errorf(\\\"failed to remove session state file: %w\\\", err)\\n   335→\\t}\\n   336→\\treturn nil\\n   337→}\\n   338→\\n   339→// RemoveAll removes the entire session state directory.\\n   340→// This is used during uninstall to completely remove all session state.\\n   341→func (s *StateStore) RemoveAll() error {\\n   342→\\tif err := os.RemoveAll(s.stateDir); err != nil {\\n   343→\\t\\treturn fmt.Errorf(\\\"failed to remove session state directory: %w\\\", err)\\n   344→\\t}\\n   345→\\treturn nil\\n   346→}\\n   347→\\n   348→// List returns all session states.\\n   349→func (s *StateStore) List(ctx context.Context) ([]*State, error) {\\n   350→\\tentries, err := os.ReadDir(s.stateDir)\\n   351→\\tif os.IsNotExist(err) {\\n   352→\\t\\treturn nil, nil\\n   353→\\t}\\n   354→\\tif err != nil {\\n   355→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state directory: %w\\\", err)\\n   356→\\t}\\n   357→\\n   358→\\tvar states []*State\\n   359→\\tfor _, entry := range entries {\\n   360→\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   361→\\t\\t\\tcontinue\\n   362→\\t\\t}\\n   363→\\t\\tif strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   364→\\t\\t\\tcontinue // Skip temp files\\n   365→\\t\\t}\\n   366→\\n   367→\\t\\tsessionID := strings.TrimSuffix(entry.Name(), \\\".json\\\")\\n   368→\\t\\tstate, err := s.Load(ctx, sessionID)\\n   369→\\t\\tif err != nil {\\n   370→\\t\\t\\tcontinue // Skip corrupted state files\\n   371→\\t\\t}\\n   372→\\t\\tif state == nil {\\n   373→\\t\\t\\tcontinue // Not found or stale (Load handles cleanup)\\n   374→\\t\\t}\\n   375→\\n   376→\\t\\tstates = append(states, state)\\n   377→\\t}\\n   378→\\treturn states, nil\\n   379→}\\n   380→\\n   381→// stateFilePath returns the path to a session state file.\\n   382→func (s *StateStore) stateFilePath(sessionID string) string {\\n   383→\\treturn filepath.Join(s.stateDir, sessionID+\\\".json\\\")\\n   384→}\\n   385→\\n   386→// gitCommonDirCache caches the git common dir to avoid repeated subprocess calls.\\n   387→// Keyed by working directory to handle directory changes (same pattern as paths.WorktreeRoot).\\n   388→var (\\n   389→\\tgitCommonDirMu       sync.RWMutex\\n   390→\\tgitCommonDirCache    string\\n   391→\\tgitCommonDirCacheDir string\\n   392→)\\n   393→\\n   394→// ClearGitCommonDirCache clears the cached git common dir.\\n   395→// Useful for testing when changing directories.\\n   396→func ClearGitCommonDirCache() {\\n   397→\\tgitCommonDirMu.Lock()\\n   398→\\tgitCommonDirCache = \\\"\\\"\\n   399→\\tgitCommonDirCacheDir = \\\"\\\"\\n   400→\\tgitCommonDirMu.Unlock()\\n   401→}\\n   402→\\n   403→// getGitCommonDir returns the path to the shared git directory.\\n   404→// In a regular checkout, this is .git/\\n   405→// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n   406→// The result is cached per working directory.\\n   407→func getGitCommonDir(ctx context.Context) (string, error) {\\n   408→\\tcwd, err := os.Getwd() //nolint:forbidigo // used for cache key, not git-relative paths\\n   409→\\tif err != nil {\\n   410→\\t\\tcwd = \\\"\\\"\\n   411→\\t}\\n   412→\\n   413→\\t// Check cache with read lock first\\n   414→\\tgitCommonDirMu.RLock()\\n   415→\\tif gitCommonDirCache != \\\"\\\" && gitCommonDirCacheDir == cwd {\\n   416→\\t\\tcached := gitCommonDirCache\\n   417→\\t\\tgitCommonDirMu.RUnlock()\\n   418→\\t\\treturn cached, nil\\n   419→\\t}\\n   420→\\tgitCommonDirMu.RUnlock()\\n   421→\\n   422→\\t// Cache miss — resolve via git subprocess\\n   423→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-common-dir\\\")\\n   424→\\tcmd.Dir = \\\".\\\"\\n   425→\\toutput, err := cmd.Output()\\n   426→\\tif err != nil {\\n   427→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   428→\\t}\\n   429→\\n   430→\\tcommonDir := strings.TrimSpace(string(output))\\n   431→\\n   432→\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\n   433→\\t// so we need to make it absolute if it isn't already\\n   434→\\tif !filepath.IsAbs(commonDir) {\\n   435→\\t\\tcommonDir = filepath.Join(\\\".\\\", commonDir)\\n   436→\\t}\\n   437→\\tcommonDir = filepath.Clean(commonDir)\\n   438→\\n   439→\\tgitCommonDirMu.Lock()\\n   440→\\tgitCommonDirCache = commonDir\\n   441→\\tgitCommonDirCacheDir = cwd\\n   442→\\tgitCommonDirMu.Unlock()\\n   443→\\n   444→\\treturn commonDir, nil\\n   445→}\\n   446→\"}]},\"uuid\":\"efe4b85c-6a5a-4eaf-a65d-94458b2fb1ae\",\"timestamp\":\"2026-02-27T20:06:17.590Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand what drives the latency in PrepareCommitMsg and PostCommit hooks when there are many sessions. \\n\\nLook at these files in depth to trace the hot paths:\\n- `cmd/entire/cli/strategy/manual_commit_hooks.go` - PrepareCommitMsg and PostCommit implementations\\n- `cmd/ent