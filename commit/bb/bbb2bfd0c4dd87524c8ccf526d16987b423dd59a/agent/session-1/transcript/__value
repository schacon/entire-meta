   95→\\t\\t\\tif err := os.WriteFile(commitMsgFile, []byte(\\\"implement feature\\\\n\\\"), 0o644); err != nil {\\n    96→\\t\\t\\t\\tt.Fatalf(\\\"write commit msg: %v\\\", err)\\n    97→\\t\\t\\t}\\n    98→\\n    99→\\t\\t\\ts1 := &ManualCommitStrategy{}\\n   100→\\t\\t\\tprepStart := time.Now()\\n   101→\\t\\t\\tif err := s1.PrepareCommitMsg(context.Background(), commitMsgFile, \\\"message\\\"); err != nil {\\n   102→\\t\\t\\t\\tt.Fatalf(\\\"PrepareCommitMsg: %v\\\", err)\\n   103→\\t\\t\\t}\\n   104→\\t\\t\\tprepDur := time.Since(prepStart)\\n   105→\\n   106→\\t\\t\\t// Read back the commit message to check if trailer was added.\\n   107→\\t\\t\\tmsgBytes, err := os.ReadFile(commitMsgFile) //nolint:gosec // test file\\n   108→\\t\\t\\tif err != nil {\\n   109→\\t\\t\\t\\tt.Fatalf(\\\"read commit msg: %v\\\", err)\\n   110→\\t\\t\\t}\\n   111→\\t\\t\\tcommitMsg := string(msgBytes)\\n   112→\\n   113→\\t\\t\\t// If PrepareCommitMsg didn't add a trailer (e.g., content-aware check\\n   114→\\t\\t\\t// determined no new content), inject one manually so PostCommit exercises\\n   115→\\t\\t\\t// the full condensation path rather than the early-exit path.\\n   116→\\t\\t\\tif _, found := trailers.ParseCheckpoint(commitMsg); !found {\\n   117→\\t\\t\\t\\tcpID, genErr := id.Generate()\\n   118→\\t\\t\\t\\tif genErr != nil {\\n   119→\\t\\t\\t\\t\\tt.Fatalf(\\\"generate checkpoint ID: %v\\\", genErr)\\n   120→\\t\\t\\t\\t}\\n   121→\\t\\t\\t\\tcommitMsg = fmt.Sprintf(\\\"%s\\\\n%s: %s\\\\n\\\",\\n   122→\\t\\t\\t\\t\\tstrings.TrimRight(commitMsg, \\\"\\\\n\\\"),\\n   123→\\t\\t\\t\\t\\ttrailers.CheckpointTrailerKey, cpID)\\n   124→\\t\\t\\t\\tt.Logf(\\\"  Injected trailer (PrepareCommitMsg skipped content-aware check)\\\")\\n   125→\\t\\t\\t}\\n   126→\\n   127→\\t\\t\\t// Create the actual commit with the trailer so PostCommit finds it.\\n   128→\\t\\t\\tgitRun(t, dir, \\\"commit\\\", \\\"-m\\\", commitMsg)\\n   129→\\n   130→\\t\\t\\t// --- Time PostCommit ---\\n   131→\\t\\t\\tpaths.ClearWorktreeRootCache()\\n   132→\\t\\t\\tsession.ClearGitCommonDirCache()\\n   133→\\n   134→\\t\\t\\ts2 := &ManualCommitStrategy{}\\n   135→\\t\\t\\tpostStart := time.Now()\\n   136→\\t\\t\\tif err := s2.PostCommit(context.Background()); err != nil {\\n   137→\\t\\t\\t\\tt.Fatalf(\\\"PostCommit: %v\\\", err)\\n   138→\\t\\t\\t}\\n   139→\\t\\t\\tpostDur := time.Since(postStart)\\n   140→\\n   141→\\t\\t\\tt.Logf(\\\"=== %s ===\\\", sc.name)\\n   142→\\t\\t\\tt.Logf(\\\"  Sessions:         %d (ended=%d, idle=%d, active=%d)\\\", totalSessions, sc.ended, sc.idle, sc.active)\\n   143→\\t\\t\\tt.Logf(\\\"  Local clone:      %s\\\", cloneDur.Round(time.Millisecond))\\n   144→\\t\\t\\tt.Logf(\\\"  Setup:            %s\\\", setupDur.Round(time.Millisecond))\\n   145→\\t\\t\\tt.Logf(\\\"  PrepareCommitMsg: %s\\\", prepDur.Round(time.Millisecond))\\n   146→\\t\\t\\tt.Logf(\\\"  PostCommit:       %s\\\", postDur.Round(time.Millisecond))\\n   147→\\t\\t\\tt.Logf(\\\"  TOTAL HOOKS:      %s\\\", (prepDur + postDur).Round(time.Millisecond))\\n   148→\\n   149→\\t\\t\\tresults = append(results, result{\\n   150→\\t\\t\\t\\tname:       sc.name,\\n   151→\\t\\t\\t\\ttotal:      totalSessions,\\n   152→\\t\\t\\t\\tclone:      cloneDur,\\n   153→\\t\\t\\t\\tsetup:      setupDur,\\n   154→\\t\\t\\t\\tprepare:    prepDur,\\n   155→\\t\\t\\t\\tpostCommit: postDur,\\n   156→\\t\\t\\t})\\n   157→\\t\\t})\\n   158→\\t}\\n   159→\\n   160→\\t// Print summary table\\n   161→\\tt.Log(\\\"\\\")\\n   162→\\tt.Log(\\\"========== COMMIT HOOK PERFORMANCE SUMMARY ==========\\\")\\n   163→\\tt.Logf(\\\"%-20s | %8s | %12s | %12s | %12s\\\", \\\"Scenario\\\", \\\"Sessions\\\", \\\"Prepare\\\", \\\"PostCommit\\\", \\\"TOTAL\\\")\\n   164→\\tt.Log(\\\"-------------------------------------------------------------------------------------\\\")\\n   165→\\tfor _, r := range results {\\n   166→\\t\\tt.Logf(\\\"%-20s | %8d | %12s | %12s | %12s\\\",\\n   167→\\t\\t\\tr.name,\\n   168→\\t\\t\\tr.total,\\n   169→\\t\\t\\tr.prepare.Round(time.Millisecond),\\n   170→\\t\\t\\tr.postCommit.Round(time.Millisecond),\\n   171→\\t\\t\\t(r.prepare + r.postCommit).Round(time.Millisecond),\\n   172→\\t\\t)\\n   173→\\t}\\n   174→}\\n   175→\\n   176→// cloneSourceRepo does a one-time shallow clone of entireio/cli into a temp\\n   177→// directory. Returns the path to use as a local clone source for each scenario.\\n   178→// Shallow clone keeps all remote refs but only one commit of history.\\n   179→func cloneSourceRepo(t *testing.T) string {\\n   180→\\tt.Helper()\\n   181→\\n   182→\\tdir := t.TempDir()\\n   183→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n   184→\\t\\tdir = resolved\\n   185→\\t}\\n   186→\\n   187→\\tt.Logf(\\\"Cloning %s (depth=1) ...\\\", hookPerfRepoURL)\\n   188→\\tstart := time.Now()\\n   189→\\n   190→\\t//nolint:gosec // test-only, URL is a constant\\n   191→\\tcmd := exec.Command(\\\"git\\\", \\\"clone\\\", \\\"--depth\\\", \\\"1\\\", hookPerfRepoURL, dir)\\n   192→\\tout, err := cmd.CombinedOutput()\\n   193→\\tif err != nil {\\n   194→\\t\\tt.Fatalf(\\\"git clone failed: %v\\\\n%s\\\", err, out)\\n   195→\\t}\\n   196→\\tt.Logf(\\\"Source clone completed in %s\\\", time.Since(start).Round(time.Millisecond))\\n   197→\\n   198→\\treturn dir\\n   199→}\\n   200→\\n   201→// localClone creates a fast local clone from the cached source repo.\\n   202→// Uses --no-hardlinks to get an independent copy (hardlinks don't work\\n   203→// across temp dirs on all platforms).\\n   204→func localClone(t *testing.T, sourceDir string) string {\\n   205→\\tt.Helper()\\n   206→\\n   207→\\tdir := t.TempDir()\\n   208→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n   209→\\t\\tdir = resolved\\n   210→\\t}\\n   211→\\n   212→\\t//nolint:gosec // test-only, sourceDir is from t.TempDir()\\n   213→\\tcmd := exec.Command(\\\"git\\\", \\\"clone\\\", \\\"--local\\\", sourceDir, dir)\\n   214→\\tout, err := cmd.CombinedOutput()\\n   215→\\tif err != nil {\\n   216→\\t\\tt.Fatalf(\\\"local clone failed: %v\\\\n%s\\\", err, out)\\n   217→\\t}\\n   218→\\n   219→\\treturn dir\\n   220→}\\n   221→\\n   222→// gitRun executes a git command in the given directory and fails the test on error.\\n   223→func gitRun(t *testing.T, dir string, args ...string) {\\n   224→\\tt.Helper()\\n   225→\\t//nolint:gosec // test-only helper\\n   226→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   227→\\tcmd.Dir = dir\\n   228→\\tout, err := cmd.CombinedOutput()\\n   229→\\tif err != nil {\\n   230→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n   231→\\t}\\n   232→}\\n   233→\\n   234→// createHookPerfSettings writes .entire/settings.json with commit_linking=always\\n   235→// so PrepareCommitMsg auto-links without prompting.\\n   236→func createHookPerfSettings(t *testing.T, dir string) {\\n   237→\\tt.Helper()\\n   238→\\tentireDir := filepath.Join(dir, \\\".entire\\\")\\n   239→\\tif err := os.MkdirAll(entireDir, 0o755); err != nil {\\n   240→\\t\\tt.Fatalf(\\\"mkdir .entire: %v\\\", err)\\n   241→\\t}\\n   242→\\tsettings := `{\\\"enabled\\\": true, \\\"strategy\\\": \\\"manual-commit\\\", \\\"commit_linking\\\": \\\"always\\\"}`\\n   243→\\tif err := os.WriteFile(filepath.Join(entireDir, \\\"settings.json\\\"), []byte(settings), 0o644); err != nil {\\n   244→\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n   245→\\t}\\n   246→}\\n   247→\\n   248→// seedHookPerfSessions creates session state files with realistic phase distribution.\\n   249→//\\n   250→// ENDED sessions: state file with LastCheckpointID set (already condensed).\\n   251→// IDLE sessions: state file + shadow branch checkpoint via SaveStep.\\n   252→// ACTIVE sessions: state file + shadow branch checkpoint + live transcript file.\\n   253→func seedHookPerfSessions(t *testing.T, dir string, ended, idle, active int) {\\n   254→\\tt.Helper()\\n   255→\\n   256→\\tctx := context.Background()\\n   257→\\n   258→\\t// Get HEAD hash for BaseCommit\\n   259→\\trepo, err := git.PlainOpen(dir)\\n   260→\\tif err != nil {\\n   261→\\t\\tt.Fatalf(\\\"open repo: %v\\\", err)\\n   262→\\t}\\n   263→\\thead, err := repo.Head()\\n   264→\\tif err != nil {\\n   265→\\t\\tt.Fatalf(\\\"head: %v\\\", err)\\n   266→\\t}\\n   267→\\tbaseCommit := head.Hash().String()\\n   268→\\n   269→\\t// Get worktree ID (empty string for main worktree)\\n   270→\\tworktreeID, err := paths.GetWorktreeID(dir)\\n   271→\\tif err != nil {\\n   272→\\t\\tt.Fatalf(\\\"worktree ID: %v\\\", err)\\n   273→\\t}\\n   274→\\n   275→\\t// Create state store in .git/entire-sessions/\\n   276→\\tstateDir := filepath.Join(dir, \\\".git\\\", session.SessionStateDirName)\\n   277→\\tif err := os.MkdirAll(stateDir, 0o755); err != nil {\\n   278→\\t\\tt.Fatalf(\\\"mkdir state dir: %v\\\", err)\\n   279→\\t}\\n   280→\\tstore := session.NewStateStoreWithDir(stateDir)\\n   281→\\n   282→\\tmodifiedFiles := []string{\\\"main.go\\\", \\\"go.mod\\\"}\\n   283→\\n   284→\\t// --- Seed ENDED sessions ---\\n   285→\\t// These have state files with LastCheckpointID but no shadow branch.\\n   286→\\t// In listAllSessionStates, they survive cleanup because LastCheckpointID is set.\\n   287→\\t// Each triggers a repo.Reference() lookup for the (missing) shadow branch.\\n   288→\\tfor i := range ended {\\n   289→\\t\\tsessionID := fmt.Sprintf(\\\"perf-ended-%d\\\", i)\\n   290→\\t\\tcpID := mustGenerateCheckpointID(t)\\n   291→\\t\\tnow := time.Now()\\n   292→\\n   293→\\t\\tstate := &session.State{\\n   294→\\t\\t\\tSessionID:           sessionID,\\n   295→\\t\\t\\tBaseCommit:          baseCommit,\\n   296→\\t\\t\\tWorktreePath:        dir,\\n   297→\\t\\t\\tWorktreeID:          worktreeID,\\n   298→\\t\\t\\tPhase:               session.PhaseEnded,\\n   299→\\t\\t\\tStartedAt:           now.Add(-time.Duration(i+1) * time.Hour),\\n   300→\\t\\t\\tLastCheckpointID:    cpID,\\n   301→\\t\\t\\tStepCount:           1,\\n   302→\\t\\t\\tFilesTouched:        modifiedFiles,\\n   303→\\t\\t\\tLastInteractionTime: &now,\\n   304→\\t\\t}\\n   305→\\t\\tif err := store.Save(ctx, state); err != nil {\\n   306→\\t\\t\\tt.Fatalf(\\\"save ended state %d: %v\\\", i, err)\\n   307→\\t\\t}\\n   308→\\t}\\n   309→\\n   310→\\t// --- Seed IDLE sessions ---\\n   311→\\t// These have shadow branch checkpoints (via SaveStep) and state files.\\n   312→\\ts := &ManualCommitStrategy{}\\n   313→\\tfor i := range idle {\\n   314→\\t\\tsessionID := fmt.Sprintf(\\\"perf-idle-%d\\\", i)\\n   315→\\t\\tseedSessionWithShadowBranch(t, s, dir, sessionID, session.PhaseIdle, modifiedFiles)\\n   316→\\t}\\n   317→\\n   318→\\t// --- Seed ACTIVE sessions ---\\n   319→\\t// These have shadow branch checkpoints + a live transcript file.\\n   320→\\tfor i := range active {\\n   321→\\t\\tsessionID := fmt.Sprintf(\\\"perf-active-%d\\\", i)\\n   322→\\t\\tseedSessionWithShadowBranch(t, s, dir, sessionID, session.PhaseActive, modifiedFiles)\\n   323→\\n   324→\\t\\t// Create a live transcript file (simulates agent in progress)\\n   325→\\t\\tclaudeProjectDir := filepath.Join(dir, \\\".claude\\\", \\\"projects\\\", \\\"test\\\", \\\"sessions\\\")\\n   326→\\t\\tif err := os.MkdirAll(claudeProjectDir, 0o755); err != nil {\\n   327→\\t\\t\\tt.Fatalf(\\\"mkdir claude sessions: %v\\\", err)\\n   328→\\t\\t}\\n   329→\\t\\ttranscript := `{\\\"type\\\":\\\"human\\\",\\\"message\\\":{\\\"content\\\":\\\"implement feature\\\"}}\\n   330→{\\\"type\\\":\\\"assistant\\\",\\\"message\\\":{\\\"content\\\":\\\"I'll implement that for you.\\\"}}\\n   331→{\\\"type\\\":\\\"tool_use\\\",\\\"name\\\":\\\"write\\\",\\\"input\\\":{\\\"path\\\":\\\"main.go\\\",\\\"content\\\":\\\"package main\\\\n// modified\\\\nfunc main() {}\\\\n\\\"}}\\n   332→`\\n   333→\\t\\ttranscriptFile := filepath.Join(claudeProjectDir, sessionID+\\\".jsonl\\\")\\n   334→\\t\\tif err := os.WriteFile(transcriptFile, []byte(transcript), 0o644); err != nil {\\n   335→\\