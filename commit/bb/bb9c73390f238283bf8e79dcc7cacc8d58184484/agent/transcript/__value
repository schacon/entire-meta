ointTrailer(t, s.Dir, \\\"HEAD\\\")\\n\\t\\ttestutil.AssertCheckpointExists(t, s.Dir, cpID)\\n\\n\\t\\t// Validate checkpoint metadata completeness.\\n\\t\\tmeta := testutil.ReadCheckpointMetadata(t, s.Dir, cpID)\\n\\t\\tassert.NotEmpty(t, meta.CLIVersion, \\\"cli_version should be set\\\")\\n\\t\\tassert.NotEmpty(t, meta.Strategy, \\\"strategy should be set\\\")\\n\\t\\tassert.NotEmpty(t, meta.Sessions, \\\"should have at least 1 session\\\")\\n\\n\\t\\t// Validate session metadata — agent field should be populated.\\n\\t\\tsm := testutil.ReadSessionMetadata(t, s.Dir, cpID, 0)\\n\\t\\tassert.NotEmpty(t, sm.Agent, \\\"session agent field should be populated\\\")\\n\\t\\tassert.NotEmpty(t, sm.SessionID, \\\"session_id should be set\\\")\\n\\t\\ttestutil.AssertNoShadowBranches(t, s.Dir)\\n\\t})\\n}\\n\",\"numLines\":48,\"startLine\":1,\"totalLines\":48}},\"sourceToolAssistantUUID\":\"e7f965b8-35d0-494e-91fe-12294576ba69\"}\n{\"parentUuid\":\"da4e204d-e04f-4155-a31d-a662e8895310\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli_experiments\",\"sessionId\":\"e24bec4f-0ec1-4a86-bc8d-b2082f315a38\",\"version\":\"2.1.66\",\"gitBranch\":\"soph/fix-droid-e2e-setup\",\"slug\":\"temporal-foraging-volcano\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_012kLDc5XsWKQ3HdQ1MjonER\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"270s and `signal: killed` — it hit the 3-minute timeout. The test uses `RunPrompt` (non-interactive `droid exec`), and the prompt asks to \\\"use a subagent.\\\" \\n\\nHaiku might struggle with the \\\"use a subagent\\\" instruction — it's a complex meta-task. But more likely, droid's `exec` mode is now using the model from `sessionDefaultSettings` (haiku) which is fine, but the subagent spawning might take longer than 3 minutes with haiku.\\n\\nThat said, this is a pre-existing flakiness issue with a complex prompt on a small model — not related to the settings c