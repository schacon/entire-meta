il\\n  1241→}\\n  1242→\\n  1243→// ensureSessionsBranch ensures the entire/checkpoints/v1 branch exists.\\n  1244→func (s *GitStore) ensureSessionsBranch() error {\\n  1245→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1246→\\t_, err := s.repo.Reference(refName, true)\\n  1247→\\tif err == nil {\\n  1248→\\t\\treturn nil // Branch exists\\n  1249→\\t}\\n  1250→\\n  1251→\\t// Create orphan branch with empty tree\\n  1252→\\temptyTreeHash, err := BuildTreeFromEntries(s.repo, make(map[string]object.TreeEntry))\\n  1253→\\tif err != nil {\\n  1254→\\t\\treturn err\\n  1255→\\t}\\n  1256→\\n  1257→\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n  1258→\\tcommitHash, err := s.createCommit(emptyTreeHash, plumbing.ZeroHash, \\\"Initialize sessions branch\\\", authorName, authorEmail)\\n  1259→\\tif err != nil {\\n  1260→\\t\\treturn err\\n  1261→\\t}\\n  1262→\\n  1263→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n  1264→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1265→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1266→\\t}\\n  1267→\\treturn nil\\n  1268→}\\n  1269→\\n  1270→// getSessionsBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\n  1271→// Falls back to origin/entire/checkpoints/v1 if the local branch doesn't exist.\\n  1272→func (s *GitStore) getSessionsBranchTree() (*object.Tree, error) {\\n  1273→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1274→\\tref, err := s.repo.Reference(refName, true)\\n  1275→\\tif err != nil {\\n  1276→\\t\\t// Local branch doesn't exist, try remote-tracking branch\\n  1277→\\t\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n  1278→\\t\\tref, err = s.repo.Reference(remoteRefName, true)\\n  1279→\\t\\tif err != nil {\\n  1280→\\t\\t\\treturn nil, fmt.Errorf(\\\"sessions branch not found: %w\\\", err)\\n  1281→\\t\\t}\\n  128