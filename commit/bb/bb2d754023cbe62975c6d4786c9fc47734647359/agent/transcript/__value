ePaths, nil\\n   380→}\\n   381→\\n   382→// writeCheckpointSummary writes the root-level CheckpointSummary with aggregated statistics.\\n   383→// sessions is the complete sessions array (already built by the caller).\\n   384→func (s *GitStore) writeCheckpointSummary(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry, sessions []SessionFilePaths) error {\\n   385→\\tcheckpointsCount, filesTouched, tokenUsage, err :=\\n   386→\\t\\ts.reaggregateFromEntries(basePath, len(sessions), entries)\\n   387→\\tif err != nil {\\n   388→\\t\\treturn fmt.Errorf(\\\"failed to aggregate session stats: %w\\\", err)\\n   389→\\t}\\n   390→\\n   391→\\tsummary := CheckpointSummary{\\n   392→\\t\\tCheckpointID:     opts.CheckpointID,\\n   393→\\t\\tCLIVersion:       buildinfo.Version,\\n   394→\\t\\tStrategy:         opts.Strategy,\\n   395→\\t\\tBranch:           opts.Branch,\\n   396→\\t\\tCheckpointsCount: checkpointsCount,\\n   397→\\t\\tFilesTouched:     filesTouched,\\n   398→\\t\\tSessions:         sessions,\\n   399→\\t\\tTokenUsage:       tokenUsage,\\n   400→\\t}\\n   401→\\n   402→\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(summary, \\\"\\\", \\\"  \\\")\\n   403→\\tif err != nil {\\n   404→\\t\\treturn fmt.Errorf(\\\"failed to marshal checkpoint summary: %w\\\", err)\\n   405→\\t}\\n   406→\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n   407→\\tif err != nil {\\n   408→\\t\\treturn err\\n   409→\\t}\\n   410→\\tentries[basePath+paths.MetadataFileName] = object.TreeEntry{\\n   411→\\t\\tName: basePath + paths.MetadataFileName,\\n   412→\\t\\tMode: filemode.Regular,\\n   413→\\t\\tHash: metadataHash,\\n   414→\\t}\\n   415→\\treturn nil\\n   416→}\\n   417→\\n   418→// findSessionIndex returns the index of an existing session with the given ID,\\n   419→// or the next available index if not found. This prevents duplicate session entries.\\n   420→func (s *GitStore) findSessionIndex(basePath string, existingSummary *CheckpointSummary, entries map[string]object.TreeEntry, sessionID string) int {\\n   421→\\tif existingSummary == nil {\\n   422→\\t\\treturn 0\\n   423→\\t}\\n   424→\\tfor i := range len(existingSummary.Sessions) {\\n   425→\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n   426→\\t\\tif entry, exists := entries[path]; exists {\\n   427→\\t\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n   428→\\t\\t\\tif err != nil {\\n   429→\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to read session metadata during dedup check\\\",\\n   430→\\t\\t\\t\\t\\tslog.Int(\\\"session_index\\\", i),\\n   431→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   432→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   433→\\t\\t\\t\\t)\\n   434→\\t\\t\\t\\tcontinue\\n   435→\\t\\t\\t}\\n   436→\\t\\t\\tif meta.SessionID == sessionID {\\n   437→\\t\\t\\t\\treturn i\\n   438→\\t\\t\\t}\\n   439→\\t\\t}\\n   440→\\t}\\n   441→\\treturn len(existingSummary.Sessions)\\n   442→}\\n   443→\\n   444→// reaggregateFromEntries reads all session metadata from the entries map and\\n   445→// reaggregates CheckpointsCount, FilesTouched, and TokenUsage.\\n   446→func (s *GitStore) reaggregateFromEntries(basePath string, sessionCount int, entries map[string]object.TreeEntry) (int, []string, *agent.TokenUsage, error) {\\n   447→\\tvar totalCount int\\n   448→\\tvar allFiles []string\\n   449→\\tvar totalTokens *agent.TokenUsage\\n   450→\\n   451→\\tfor i := range sessionCount {\\n   452→\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n   453→\\t\\tentry, exists := entries[path]\\n   454→\\t\\tif !exists {\\n   455→\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"session %d metadata not found at %s\\\", i, path)\\n   456→\\t\\t}\\n   457→\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n   458→\\t\\tif err != nil {\\n   459→\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"failed to read session %d metadata: %w\\\", i, err)\\n   460→\\t\\t}\\n   461→\\t\\ttotalCount += meta.CheckpointsCount\\n   462→\\t\\tallFiles = mergeFilesTouched(allFiles, meta.FilesTouched)\\n   463→\\t\\ttotalTokens = aggregateTokenUsage(totalTokens, meta.TokenUsage)\\n   464→\\t}\\n   465→\\n   466→\\treturn totalCount, allFiles, totalTokens, nil\\n   467→}\\n   468→\\n   469→// readJSONFromBlob reads JSON from a blob hash and decodes it to the given type.\\n   470→func readJSONFromBlob[T any](repo *git.Repository, hash plumbing.Hash) (*T, error) {\\n   471→\\tblob, err := repo.BlobObject(hash)\\n   472→\\tif err != nil {\\n   473→\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob: %w\\\", err)\\n   474→\\t}\\n   475→\\n   476→\\treader, err := blob.Reader()\\n   477→\\tif err != nil {\\n   478→\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob reader: %w\\\", err)\\n   479→\\t}\\n   480→\\tdefer reader.Close()\\n   481→\\n   482→\\tvar result T\\n   483→\\tif err := json.NewDecoder(reader).Decode(&result); err != nil {\\n   484→\\t\\treturn nil, fmt.Errorf(\\\"failed to decode: %w\\\", err)\\n   485→\\t}\\n   486→\\n   487→\\treturn &result, nil\\n   488→}\\n   489→\\n   490→// readSummaryFromBlob reads CheckpointSummary from a blob hash.\\n   491→func (s *GitStore) readSummaryFromBlob(hash plumbing.Hash) (*CheckpointSummary, error) {\\n   492→\\treturn readJSONFromBlob[CheckpointSummary](s.repo, hash)\\n   493→}\\n   494→\\n   495→// aggregateTokenUsage sums two TokenUsage structs.\\n   496→// Returns nil if both inputs are nil.\\n   497→func aggregateTokenUsage(a, b *agent.TokenUsage) *agent.TokenUsage {\\n   498→\\tif a == nil && b == nil {\\n   499→\\t\\treturn nil\\n   500→\\t}\\n   501→\\tresult := &agent.TokenUsage{}\\n   502→\\tif a != nil {\\n   503→\\t\\tresult.InputTokens = a.InputTokens\\n   504→\\t\\tresult.CacheCreationTokens = a.CacheCreationTokens\\n   505→\\t\\tresult.CacheReadTokens = a.CacheReadTokens\\n   506→\\t\\tresult.OutputTokens = a.OutputTokens\\n   507→\\t\\tresult.APICallCount = a.APICallCount\\n   508→\\t}\\n   509→\\tif b != nil {\\n   510→\\t\\tresult.InputTokens += b.InputTokens\\n   511→\\t\\tresult.CacheCreationTokens += b.CacheCreationTokens\\n   512→\\t\\tresult.CacheReadTokens += b.CacheReadTokens\\n   513→\\t\\tresult.OutputTokens += b.OutputTokens\\n   514→\\t\\tresult.APICallCount += b.APICallCount\\n   515→\\t}\\n   516→\\treturn result\\n   517→}\\n   518→\\n   519→// writeTranscript writes the transcript file from in-memory content or file path.\\n   520→// If the transcript exceeds MaxChunkSize, it's split into multiple chunk files.\\n   521→func (s *GitStore) writeTranscript(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry) error {\\n   522→\\ttranscript := opts.Transcript\\n   523→\\tif len(transcript) == 0 && opts.TranscriptPath != \\\"\\\" {\\n   524→\\t\\tvar readErr error\\n   525→\\t\\ttranscript, readErr = os.ReadFile(opts.TranscriptPath)\\n   526→\\t\\tif readErr != nil {\\n   527→\\t\\t\\t// Non-fatal: transcript may not exist yet\\n   528→\\t\\t\\ttranscript = nil\\n   529→\\t\\t}\\n   530→\\t}\\n   531→\\tif len(transcript) == 0 {\\n   532→\\t\\treturn nil\\n   533→\\t}\\n   534→\\n   535→\\t// Redact secrets before chunking so content hash reflects redacted content\\n   536→\\ttranscript, err := redact.JSONLBytes(transcript)\\n   537→\\tif err != nil {\\n   538→\\t\\treturn fmt.Errorf(\\\"failed to redact transcript secrets: %w\\\", err)\\n   539→\\t}\\n   540→\\n   541→\\t// Chunk the transcript if it's too large\\n   542→\\tchunks, err := agent.ChunkTranscript(transcript, opts.Agent)\\n   543→\\tif err != nil {\\n   544→\\t\\treturn fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n   545→\\t}\\n   546→\\n   547→\\t// Write chunk files\\n   548→\\tfor i, chunk := range chunks {\\n   549→\\t\\tchunkPath := basePath + agent.ChunkFileName(paths.TranscriptFileName, i)\\n   550→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, chunk)\\n   551→\\t\\tif err != nil {\\n   552→\\t\\t\\treturn err\\n   553→\\t\\t}\\n   554→\\t\\tentries[chunkPath] = object.TreeEntry{\\n   555→\\t\\t\\tName: chunkPath,\\n   556→\\t\\t\\tMode: filemode.Regular,\\n   557→\\t\\t\\tHash: blobHash,\\n   558→\\t\\t}\\n   559→\\t}\\n   560→\\n   561→\\t// Content hash for deduplication (hash of full transcript)\\n   562→\\tcontentHash := fmt.Sprintf(\\\"sha256:%x\\\", sha256.Sum256(transcript))\\n   563→\\thashBlob, err := CreateBlobFromContent(s.repo, []byte(contentHash))\\n   564→\\tif err != nil {\\n   565→\\t\\treturn err\\n   566→\\t}\\n   567→\\tentries[basePath+paths.ContentHashFileName] = object.TreeEntry{\\n   568→\\t\\tName: basePath + paths.ContentHashFileName,\\n   569→\\t\\tMode: filemode.Regular,\\n   570→\\t\\tHash: hashBlob,\\n   571→\\t}\\n   572→\\treturn nil\\n   573→}\\n   574→\\n   575→// mergeFilesTouched combines two file lists, removing duplicates.\\n   576→func mergeFilesTouched(existing, additional []string) []string {\\n   577→\\tseen := make(map[string]bool)\\n   578→\\tvar result []string\\n   579→\\n   580→\\tfor _, f := range existing {\\n   581→\\t\\tif !seen[f] {\\n   582→\\t\\t\\tseen[f] = true\\n   583→\\t\\t\\tresult = append(result, f)\\n   584→\\t\\t}\\n   585→\\t}\\n   586→\\tfor _, f := range additional {\\n   587→\\t\\tif !seen[f] {\\n   588→\\t\\t\\tseen[f] = true\\n   589→\\t\\t\\tresult = append(result, f)\\n   590→\\t\\t}\\n   591→\\t}\\n   592→\\n   593→\\tsort.Strings(result)\\n   594→\\treturn result\\n   595→}\\n   596→\\n   597→// redactSummary returns a copy of the summary with text fields redacted.\\n   598→// Structural fields (Path, Line, EndLine) are preserved.\\n   599→// NOTE: When adding new text fields to Summary, LearningsSummary, or CodeLearning,\\n   600→// update this function to include them in redaction.\\n   601→func redactSummary(s *Summary) *Summary {\\n   602→\\tif s == nil {\\n   603→\\t\\treturn nil\\n   604→\\t}\\n   605→\\treturn &Summary{\\n   606→\\t\\tIntent:    redact.String(s.Intent),\\n   607→\\t\\tOutcome:   redact.String(s.Outcome),\\n   608→\\t\\tFriction:  redactStringSlice(s.Friction),\\n   609→\\t\\tOpenItems: redactStringSlice(s.OpenItems),\\n   610→\\t\\tLearnings: LearningsSummary{\\n   611→\\t\\t\\tRepo:     redactStringSlice(s.Learnings.Repo),\\n   612→\\t\\t\\tWorkflow: redactStringSlice(s.Learnings.Workflow),\\n   613→\\t\\t\\tCode:     redactCodeLearnings(s.Learnings.Code),\\n   614→\\t\\t},\\n   615→\\t}\\n   616→}\\n   617→\\n   618→// redactStringSlice applies redact.String to each element.\\n   619→func redactStringSlice(ss []string) []string {\\n   620→\\tif ss == nil {\\n   621→\\t\\treturn nil\\n   622→\\t}\\n   623→\\tout := make([]string, len(ss))\\n   624→\\tfor i, s := range ss {\\n   625→\\t\\tout[i] = redact.String(s)\\n   626→\\t}\\n   627→\\treturn out\\n   628→}\\n   629→\\n   630→// redactCodeLearnings redacts only the Finding field, preserving Path/Line/EndLine.\\n   631→func redactCodeLearnings(cls []CodeLearning) []CodeLearning {\\n   632→\\tif cls == nil {\\n   633→\\t\\treturn nil\\n   634→\\t}\\n   635→\\tout := make([]CodeLearning, len(cls))\\n   636→\\tfor i, cl := range cls {\\n   637→\\t\\tout[i] = CodeLearning{\\n   638→\\t\\t\\tPath:    cl.Path,\\n   639→\\t\\t\\tLine:    cl.Line,\\n   640→\\t\\t\\tEndLine: cl.EndLine,\\n   641→\\t\\t\\tFinding: redact.String(cl.Finding),\\n   642→\\t\\t}\\n   643→\\t}\\n   644→\\treturn out\\n   645→}\\n   646→\\n   647→// readMetadataFromBlob reads CommittedMetadata from a blob hash.\\n   648→func (s *GitStore) readMetadataFromBlob(hash plumbing.Hash) (*CommittedMetadata, error) {\\n   649→\\treturn readJSONFromBlob[CommittedMetadata](s.repo, hash)\\n   650→}\\n   651→\\n   652→// buildCommitMessage constructs the commit message with proper trailers.\\n   653→// The commit subject is always \\\"Checkpoint: <id>\\\" for consistency.\\n   654→// If CommitSubject is provided (e.g., for task checkpoints), it's included in the body.\\n   655→func (s *GitStore) buildCommitMessage(opts WriteCommittedOptions, taskMetadataPath string) string {\\n   656→\\tvar commitMsg strings.Builder\\n   657→\\n   658→\\t// Subject line is always the checkpoint ID for consistent formatting\\n   659→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"Checkpoint: %s\\\\n\\\\n\\\", opts.CheckpointID))\\n   660→\\n   661→\\t// Include custom description in body if provided (e.g., task checkpoint details)\\n   662→\\tif opts.CommitSubject != \\\"\\\" {\\n   663→\\t\\tcommitMsg.WriteString(opts.CommitSubject + \\\"\\\\n\\\\n\\\")\\n   664→\\t}\\n   665→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.SessionTrailerKey, opts.SessionID))\\n   666→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.StrategyTrailerKey, opts.Strategy))\\n   667→\\tif opts.Agent != \\\"\\\" {\\n   668→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.AgentTrailerKey, opts.Agent))\\n   669→\\t}\\n   670→\\tif opts.EphemeralBranch != \\\"\\\" {\\n   671→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.EphemeralBranchTrailerKey, opts.EphemeralBranch))\\n   672→\\t}\\n   673→\\tif taskMetadataPath != \\\"\\\" {\\n   674→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.MetadataTaskTrailerKey, taskMetadataPath))\\n   675→\\t}\\n   676→\\n   677→\\treturn commitMsg.String()\\n   678→}\\n   679→\\n   680→// incrementalCheckpointData represents an incremental checkpoint during subagent execution.\\n   681→// This mirrors strategy.SubagentCheckpoint but avoids import cycles.\\n   682→type incrementalCheckpointData struct {\\n   683→\\tType      string          `json:\\\"type\\\"`\\n   684→\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   685→\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n   686→\\tData      json.RawMessage `json:\\\"data\\\"`\\n   687→}\\n   688→\\n   689→// taskCheckpointData represents a final task checkpoint.\\n   690→// This mirrors strategy.TaskCheckpoint but avoids import cycles.\\n   691→type taskCheckpointData struct {\\n   692→\\tSessionID      string `json:\\\"session_id\\\"`\\n   693→\\tToolUseID      string `json:\\\"tool_use_id\\\"`\\n   694→\\tCheckpointUUID string `json:\\\"checkpoint_uuid\\\"`\\n   695→\\tAgentID        string `json:\\\"agent_id,omitempty\\\"`\\n   696→}\\n   697→\\n   698→// ReadCommitted reads a committed checkpoint's summary by ID from the entire/checkpoints/v1 branch.\\n   699→// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n   700→// Use ReadSessionContent to read actual transcript/prompts/context.\\n   701→// Returns nil, nil if the checkpoint doesn't exist.\\n   702→//\\n   703→// The storage format uses numbered subdirectories for each session (0-based):\\n   704→//\\n   705→//\\t<checkpoint-id>/\\n   706→//\\t├── metadata.json      # CheckpointSummary with sessions map\\n   707→//\\t├── 0/                 # First session\\n   708→//\\t│   ├── metadata.json  # Session-specific metadata\\n   709→//\\t│   └── full.jsonl     # Transcript\\n   710→//\\t├── 1/                 # Second session\\n   711→//\\t└── ...\\n   712→func (s *GitStore) ReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error) {\\n   713→\\t_ = ctx // Reserved for future use\\n   714→\\n   715→\\ttree, err := s.getSessionsBranchTree()\\n   716→\\tif err != nil {\\n   717→\\t\\treturn nil, nil //nolint:nilnil,nilerr // No sessions branch means no checkpoint exists\\n   718→\\t}\\n   719→\\n   720→\\tcheckpointPath := checkpointID.Path()\\n   721→\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n   722→\\tif err != nil {\\n   723→\\t\\treturn nil, nil //nolint:nilnil,nilerr // Checkpoint directory not found\\n   724→\\t}\\n   725→\\n   726→\\t// Read root metadata.json as CheckpointSummary\\n   727→\\tmetadataFile, err := checkpointTree.File(paths.MetadataFileName)\\n   728→\\tif err != nil {\\n   729→\\t\\treturn nil, nil //nolint:nilnil,nilerr // metadata.json not found\\n   730→\\t}\\n   731→\\n   732→\\tcontent, err := metadataFile.Contents()\\n   733→\\tif err != nil {\\n   734→\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata.json: %w\\\", err)\\n   735→\\t}\\n   736→\\n   737→\\tvar summary CheckpointSummary\\n   738→\\tif err := json.Unmarshal([]byte(content), &summary); err != nil {\\n   739→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata.json: %w\\\", err)\\n   740→\\t}\\n   741→\\n   742→\\treturn &summary, nil\\n   743→}\\n   744→\\n   745→// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n   746→// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n   747→// Returns the session's metadata, transcript, prompts, and context.\\n   748→// Returns an error if the checkpoint or session doesn't exist.\\n   749→func (s *GitStore) ReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error) {\\n   750→\\t_ = ctx // Reserved for future use\\n   751→\\n   752→\\ttree, err := s.getSessionsBranchTree()\\n   753→\\tif err != nil {\\n   754→\\t\\treturn nil, ErrCheckpointNotFound\\n   755→\\t}\\n   756→\\n   757→\\tcheckpointPath := checkpointID.Path()\\n   758→\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n   759→\\tif err != nil {\\n   760→\\t\\treturn nil, ErrCheckpointNotFound\\n   761→\\t}\\n   762→\\n   763→\\t// Get the session subdirectory\\n   764→\\tsessionDir := strconv.Itoa(sessionIndex)\\n   765→\\tsessionTree, err := checkpointTree.Tree(sessionDir)\\n   766→\\tif err != nil {\\n   767→\\t\\treturn nil, fmt.Errorf(\\\"session %d not found: %w\\\", sessionIndex, err)\\n   768→\\t}\\n   769→\\n   770→\\tresult := &SessionContent{}\\n   771→\\n   772→\\t// Read session-specific metadata\\n   773→\\tvar agentType agent.AgentType\\n   774→\\tif metadataFile, fileErr := sessionTree.File(paths.MetadataFileName); fileErr == nil {\\n   775→\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n   776→\\t\\t\\tif jsonErr := json.Unmarshal([]byte(content), &result.Metadata); jsonErr == nil {\\n   777→\\t\\t\\t\\tagentType = result.Metadata.Agent\\n   778→\\t\\t\\t}\\n   779→\\t\\t}\\n   780→\\t}\\n   781→\\n   782→\\t// Read transcript\\n   783→\\tif transcript, transcriptErr := readTranscriptFromTree(sessionTree, agentType); transcriptErr == nil && transcript != nil {\\n   784→\\t\\tresult.Transcript = transcript\\n   785→\\t}\\n   786→\\n   787→\\t// Read prompts\\n   788→\\tif file, fileErr := sessionTree.File(paths.PromptFileName); fileErr == nil {\\n   789→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   790→\\t\\t\\tresult.Prompts = content\\n   791→\\t\\t}\\n   792→\\t}\\n   793→\\n   794→\\t// Read context\\n   795→\\tif file, fileErr := sessionTree.File(paths.ContextFileName); fileErr == nil {\\n   796→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   797→\\t\\t\\tresult.Context = content\\n   798→\\t\\t}\\n   799→\\t}\\n   800→\\n   801→\\treturn result, nil\\n   802→}\\n   803→\\n   804→// ReadLatestSessionContent is a convenience method that reads the latest session's content.\\n   805→// This is equivalent to ReadSessionContent(ctx, checkpointID, len(summary.Sessions)-1).\\n   806→func (s *GitStore) ReadLatestSessionContent(ctx context.Context, checkpointID id.CheckpointID) (*SessionContent, error) {\\n   807→\\tsummary, err := s.ReadCommitted(ctx, checkpointID)\\n   808→\\tif err != nil {\\n   809→\\t\\treturn nil, err\\n   810→\\t}\\n   811→\\tif summary == nil {\\n   812→\\t\\treturn nil, ErrCheckpointNotFound\\n   813→\\t}\\n   814→\\tif len(summary.Sessions) == 0 {\\n   815→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint has no sessions: %s\\\", checkpointID)\\n   816→\\t}\\n   817→\\n   818→\\tlatestIndex := len(summary.Sessions) - 1\\n   819→\\treturn s.ReadSessionContent(ctx, checkpointID, latestIndex)\\n   820→}\\n   821→\\n   822→// ReadSessionContentByID reads a session's content by its session ID.\\n   823→// This is useful when you have the session ID but don't know its index within the checkpoint.\\n   824→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   825→// Returns an error if no session with the given ID exists in the checkpoint.\\n   826→func (s *GitStore) ReadSessionContentByID(ctx context.Context, checkpointID id.CheckpointID, sessionID string) (*SessionContent, error) {\\n   827→\\tsummary, err := s.ReadCommitted(ctx, checkpointID)\\n   828→\\tif err != nil {\\n   829→\\t\\treturn nil, err\\n   830→\\t}\\n   831→\\tif summary == nil {\\n   832→\\t\\treturn nil, ErrCheckpointNotFound\\n   833→\\t}\\n   834→\\n   835→\\t// Iterate through sessions to find the one with matching session ID\\n   836→\\tfor i := range len(summary.Sessions) {\\n   837→\\t\\tcontent, readErr := s.ReadSessionContent(ctx, checkpointID, i)\\n   838→\\t\\tif readErr != nil {\\n   839→\\t\\t\\tcontinue\\n   840→\\t\\t}\\n   841→\\t\\tif content != nil && content.Metadata.SessionID == sessionID {\\n   842→\\t\\t\\treturn content, nil\\n   843→\\t\\t}\\n   844→\\t}\\n   845→\\n   846→\\treturn nil, fmt.Errorf(\\\"session %q not found in checkpoint %s\\\", sessionID, checkpointID)\\n   847→}\\n   848→\\n   849→// ListCommitted lists all committed checkpoints from the entire/checkpoints/v1 branch.\\n   850→// Scans sharded paths: <id[:2]>/<id[2:]>/ directories containing metadata.json.\\n   851→//\\n   852→\\n   853→func (s *GitStore) ListCommitted(ctx context.Context) ([]CommittedInfo, error) {\\n   854→\\t_ = ctx // Reserved for future use\\n   855→\\n   856→\\ttree, err := s.getSessionsBranchTree()\\n   857→\\tif err != nil {\\n   858→\\t\\treturn []CommittedInfo{}, nil //nolint:nilerr // No sessions branch means empty list\\n   859→\\t}\\n   860→\\n   861→\\tvar checkpoints []CommittedInfo\\n   862→\\n   863→\\t// Scan sharded structure: <2-char-prefix>/<remaining-id>/metadata.json\\n   864→\\tfor _, bucketEntry := range tree.Entries {\\n   865→\\t\\tif bucketEntry.Mode != filemode.Dir {\\n   866→\\t\\t\\tcontinue\\n   867→\\t\\t}\\n   868→\\t\\t// Bucket should be 2 hex chars\\n   869→\\t\\tif len(bucketEntry.Name) != 2 {\\n   870→\\t\\t\\tcontinue\\n   871→\\t\\t}\\n   872→\\n   873→\\t\\tbucketTree, treeErr := s.repo.TreeObject(bucketEntry.Hash)\\n   874→\\t\\tif treeErr != nil {\\n   875→\\t\\t\\tcontinue\\n   876→\\t\\t}\\n   877→\\n   878→\\t\\t// Each entry in the bucket is the remaining part of the checkpoint ID\\n   879→\\t\\tfor _, checkpointEntry := range bucketTree.Entries {\\n   880→\\t\\t\\tif checkpointEntry.Mode != filemode.Dir {\\n   881→\\t\\t\\t\\tcontinue\\n   882→\\t\\t\\t}\\n   883→\\n   884→\\t\\t\\tcheckpointTree, cpTreeErr := s.repo.TreeObject(checkpointEntry.Hash)\\n   885→\\t\\t\\tif cpTreeErr != nil {\\n   886→\\t\\t\\t\\tcontinue\\n   887→\\t\\t\\t}\\n   888→\\n   889→\\t\\t\\t// Reconstruct checkpoint ID: <bucket><remaining>\\n   890→\\t\\t\\tcheckpointIDStr := bucketEntry.Name + checkpointEntry.Name\\n   891→\\t\\t\\tcheckpointID, cpIDErr := id.NewCheckpointID(checkpointIDStr)\\n   892→\\t\\t\\tif cpIDErr != nil {\\n   893→\\t\\t\\t\\t// Skip invalid checkpoint IDs (shouldn't happen with our own data)\\n   894→\\t\\t\\t\\tcontinue\\n   895→\\t\\t\\t}\\n   896→\\n   897→\\t\\t\\tinfo := CommittedInfo{\\n   898→\\t\\t\\t\\tCheckpointID: checkpointID,\\n   899→\\t\\t\\t}\\n   900→\\n   901→\\t\\t\\t// Get details from root metadata file (CheckpointSummary format)\\n   902→\\t\\t\\tif metadataFile, fileErr := checkpointTree.File(paths.MetadataFileName); fileErr == nil {\\n   903→\\t\\t\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n   904→\\t\\t\\t\\t\\tvar summary CheckpointSummary\\n   905→\\t\\t\\t\\t\\tif err := json.Unmarshal([]byte(content), &summary); err == nil {\\n   906→\\t\\t\\t\\t\\t\\tinfo.CheckpointsCount = summary.CheckpointsCount\\n   907→\\t\\t\\t\\t\\t\\tinfo.FilesTouched = summary.FilesTouched\\n   908→\\t\\t\\t\\t\\t\\tinfo.SessionCount = len(summary.Sessions)\\n   909→\\n   910→\\t\\t\\t\\t\\t\\t// Read session metadata from latest session to get Agent, SessionID, CreatedAt\\n   911→\\t\\t\\t\\t\\t\\tif len(summary.Sessions) > 0 {\\n   912→\\t\\t\\t\\t\\t\\t\\tlatestIndex := len(summary.Sessions) - 1\\n   913→\\t\\t\\t\\t\\t\\t\\tlatestDir := strconv.Itoa(latestIndex)\\n   914→\\t\\t\\t\\t\\t\\t\\tif sessionTree, treeErr := checkpointTree.Tree(latestDir); treeErr == nil {\\n   915→\\t\\t\\t\\t\\t\\t\\t\\tif sessionMetadataFile, smErr := sessionTree.File(paths.MetadataFileName); smErr == nil {\\n   916→\\t\\t\\t\\t\\t\\t\\t\\t\\tif sessionContent, scErr := sessionMetadataFile.Contents(); scErr == nil {\\n   917→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata CommittedMetadata\\n   918→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   919→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   920→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   921→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   922→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   923→\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   924→\\t\\t\\t\\t\\t\\t\\t\\t}\\n   925→\\t\\t\\t\\t\\t\\t\\t}\\n   926→\\t\\t\\t\\t\\t\\t}\\n   927→\\t\\t\\t\\t\\t}\\n   928→\\t\\t\\t\\t}\\n   929→\\t\\t\\t}\\n   930→\\n   931→\\t\\t\\tcheckpoints = append(checkpoints, info)\\n   932→\\t\\t}\\n   933→\\t}\\n   934→\\n   935→\\t// Sort by time (most recent first)\\n   936→\\tsort.Slice(checkpoints, func(i, j int) bool {\\n   937→\\t\\treturn checkpoints[i].CreatedAt.After(checkpoints[j].CreatedAt)\\n   938→\\t})\\n   939→\\n   940→\\treturn checkpoints, nil\\n   941→}\\n   942→\\n   943→// GetTranscript retrieves the transcript for a specific checkpoint ID.\\n   944→// Returns the latest session's transcript.\\n   945→func (s *GitStore) GetTranscript(ctx context.Context, checkpointID id.CheckpointID) ([]byte, error) {\\n   946→\\tcontent, err := s.ReadLatestSessionContent(ctx, checkpointID)\\n   947→\\tif err != nil {\\n   948→\\t\\treturn nil, err\\n   949→\\t}\\n   950→\\tif len(content.Transcript) == 0 {\\n   951→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   952→\\t}\\n   953→\\treturn content.Transcript, nil\\n   954→}\\n   955→\\n   956→// GetSessionLog retrieves the session transcript and session ID for a checkpoint.\\n   957→// This is the primary method for looking up session logs by checkpoint ID.\\n   958→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   959→// Returns ErrNoTranscript if the checkpoint exists but has no transcript.\\n   960→func (s *GitStore) GetSessionLog(cpID id.CheckpointID) ([]byte, string, error) {\\n   961→\\tcontent, err := s.ReadLatestSessionContent(context.Background(), cpID)\\n   962→\\tif err != nil {\\n   963→\\t\\tif errors.Is(err, ErrCheckpointNotFound) {\\n   964→\\t\\t\\treturn nil, \\\"\\\", ErrCheckpointNotFound\\n   965→\\t\\t}\\n   966→\\t\\treturn nil, \\\"\\\", fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   967→\\t}\\n   968→\\tif len(content.Transcript) == 0 {\\n   969→\\t\\treturn nil, \\\"\\\", ErrNoTranscript\\n   970→\\t}\\n   971→\\treturn content.Transcript, content.Metadata.SessionID, nil\\n   972→}\\n   973→\\n   974→// LookupSessionLog is a convenience function that opens the repository and retrieves\\n   975→// a session log by checkpoint ID. This is the primary entry point for callers that\\n   976→// don't already have a GitStore instance.\\n   977→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   978→// Returns ErrNoTranscript if the checkpoint exists but has no transcript.\\n   979→func LookupSessionLog(cpID id.CheckpointID) ([]byte, string, error) {\\n   980→\\trepo, err := git.PlainOpenWithOptions(\\\".\\\", &git.PlainOpenOptions{DetectDotGit: true})\\n   981→\\tif err != nil {\\n   982→\\t\\treturn nil, \\\"\\\", fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   983→\\t}\\n   984→\\tstore := NewGitStore(repo)\\n   985→\\treturn store.GetSessionLog(cpID)\\n   986→}\\n   987→\\n   988→// UpdateSummary updates the summary field in the latest session's metadata.\\n   989→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   990→func (s *GitStore) UpdateSummary(ctx context.Context, checkpointID id.CheckpointID, summary *Summary) error {\\n   991→\\t_ = ctx // Reserved for future use\\n   992→\\n   993→\\t// Ensure sessions branch exists\\n   994→\\tif err := s.ensureSessionsBranch(); err != nil {\\n   995→\\t\\treturn fmt.Errorf(\\\"failed to ensure sessions branch: %w\\\", err)\\n   996→\\t}\\n   997→\\n   998→\\t// Get current branch tip and flatten tree\\n   999→\\tref, entries, err := s.getSessionsBranchEntries()\\n  1000→\\tif err != nil {\\n  1001→\\t\\treturn err\\n  1002→\\t}\\n  1003→\\n  1004→\\t// Read root CheckpointSummary to find the latest session\\n  1005→\\tbasePath := checkpointID.Path() + \\\"/\\\"\\n  1006→\\trootMetadataPath := basePath + paths.MetadataFileName\\n  1007→\\tentry, exists := entries[rootMetadataPath]\\n  1008→\\tif !exists {\\n  1009→\\t\\treturn ErrCheckpointNotFound\\n  1010→\\t}\\n  1011→\\n  1012→\\tcheckpointSummary, err := s.readSummaryFromBlob(entry.Hash)\\n  1013→\\tif err != nil {\\n  1014→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint summary: %w\\\", err)\\n  1015→\\t}\\n  1016→\\n  1017→\\t// Find the latest session's metadata path (0-based indexing)\\n  1018→\\tlatestIndex := len(checkpointSummary.Sessions) - 1\\n  1019→\\tsessionMetadataPath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, latestIndex, paths.MetadataFileName)\\n  1020→\\tsessionEntry, exists := entries[sessionMetadataPath]\\n  1021→\\tif !exists {\\n  1022→\\t\\treturn fmt.Errorf(\\\"session metadata not found at %s\\\", sessionMetadataPath)\\n  1023→\\t}\\n  1024→\\n  1025→\\t// Read and update session metadata\\n  1026→\\texistingMetadata, err := s.readMetadataFromBlob(sessionEntry.Hash)\\n  1027→\\tif err != nil {\\n  1028→\\t\\treturn fmt.Errorf(\\\"failed to read session metadata: %w\\\", err)\\n  1029→\\t}\\n  1030→\\n  1031→\\t// Update the summary\\n  1032→\\texistingMetadata.Summary = redactSummary(summary)\\n  1033→\\n  1034→\\t// Write updated session metadata\\n  1035→\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(existingMetadata, \\\"\\\", \\\"  \\\")\\n  1036→\\tif err != nil {\\n  1037→\\t\\treturn fmt.Errorf(\\\"failed to marshal metadata: %w\\\", err)\\n  1038→\\t}\\n  1039→\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n  1040→\\tif err != nil {\\n  1041→\\t\\treturn fmt.Errorf(\\\"failed to create metadata blob: %w\\\", err)\\n  1042→\\t}\\n  1043→\\tentries[sessionMetadataPath] = object.TreeEntry{\\n  1044→\\t\\tName: sessionMetadataPath,\\n  1045→\\t\\tMode: filemode.Regular,\\n  1046→\\t\\tHash: metadataHash,\\n  1047→\\t}\\n  1048→\\n  1049→\\t// Build and commit\\n  1050→\\tnewTreeHash, err := BuildTreeFromEntries(s.repo, entries)\\n  1051→\\tif err != nil {\\n  1052→\\t\\treturn err\\n  1053→\\t}\\n  1054→\\n  1055→\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n  1056→\\tcommitMsg := fmt.Sprintf(\\\"Update summary for checkpoint %s (session: %s)\\\", checkpointID, existingMetadata.SessionID)\\n  1057→\\tnewCommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, authorName, authorEmail)\\n  1058→\\tif err != nil {\\n  1059→\\t\\treturn err\\n  1060→\\t}\\n  1061→\\n  1062→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1063→\\tnewRef := plumbing.NewHashReference(refName, newCommitHash)\\n  1064→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1065→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1066→\\t}\\n  1067→\\n  1068→\\treturn nil\\n  1069→}\\n  1070→\\n  1071→// UpdateCommitted replaces the transcript, prompts, and context for an existing\\n  1072→// committed checkpoint. Uses replace semantics: the full session transcript is\\n  1073→// written, replacing whatever was stored at initial condensation time.\\n  1074→//\\n  1075→// This is called at stop time to finalize all checkpoints from the current turn\\n  1076→// with the complete session transcript (from prompt to stop event).\\n  1077→//\\n  1078→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n  1079→func (s *GitStore) UpdateCommitted(ctx context.Context, opts UpdateCommittedOptions) error {\\n  1080→\\tif opts.CheckpointID.IsEmpty() {\\n  1081→\\t\\treturn errors.New(\\\"invalid update options: checkpoint ID is required\\\")\\n  1082→\\t}\\n  1083→\\n  1084→\\t// Ensure sessions branch exists\\n  1085→\\tif err := s.ensureSessionsBranch(); err != nil {\\n  1086→\\t\\treturn fmt.Errorf(\\\"failed to ensure sessions branch: %w\\\", err)\\n  1087→\\t}\\n  1088→\\n  1089→\\t// Get current branch tip and flatten tree\\n  1090→\\tref, entries, err := s.getSessionsBranchEntries()\\n  1091→\\tif err != nil {\\n  1092→\\t\\treturn err\\n  1093→\\t}\\n  1094→\\n  1095→\\t// Read root CheckpointSummary to find the session slot\\n  1096→\\tbasePath := opts.CheckpointID.Path() + \\\"/\\\"\\n  1097→\\trootMetadataPath := basePath + paths.MetadataFileName\\n  1098→\\tentry, exists := entries[rootMetadataPath]\\n  1099→\\tif !exists {\\n  1100→\\t\\treturn ErrCheckpointNotFound\\n  1101→\\t}\\n  1102→\\n  1103→\\tcheckpointSummary, err := s.readSummaryFromBlob(entry.Hash)\\n  1104→\\tif err != nil {\\n  1105→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint summary: %w\\\", err)\\n  1106→\\t}\\n  1107→\\tif len(checkpointSummary.Sessions) == 0 {\\n  1108→\\t\\treturn ErrCheckpointNotFound\\n  1109→\\t}\\n  1110→\\n  1111→\\t// Find session index matching opts.SessionID\\n  1112→\\tsessionIndex := -1\\n  1113→\\tfor i := range len(checkpointSummary.Sessions) {\\n  1114→\\