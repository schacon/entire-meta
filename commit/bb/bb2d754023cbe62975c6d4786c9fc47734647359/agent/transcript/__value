0→\\tStdout   string\\n    41→\\tStderr   string\\n    42→\\tExitCode int\\n    43→\\tDuration time.Duration\\n    44→}\\n    45→\\n    46→// AgentRunnerConfig holds configuration for agent runners.\\n    47→type AgentRunnerConfig struct {\\n    48→\\tModel   string        // Model to use (e.g., \\\"haiku\\\" for Claude)\\n    49→\\tTimeout time.Duration // Timeout per prompt\\n    50→}\\n    51→\\n    52→// NewAgentRunner creates an agent runner based on the agent name.\\n    53→//\\n    54→//nolint:ireturn // factory pattern intentionally returns interface\\n    55→func NewAgentRunner(name string, config AgentRunnerConfig) AgentRunner {\\n    56→\\tswitch name {\\n    57→\\tcase AgentNameClaudeCode:\\n    58→\\t\\treturn NewClaudeCodeRunner(config)\\n    59→\\tcase AgentNameGemini:\\n    60→\\t\\treturn NewGeminiCLIRunner(config)\\n    61→\\tdefault:\\n    62→\\t\\t// Return a runner that reports as unavailable\\n    63→\\t\\treturn &unavailableRunner{name: name}\\n    64→\\t}\\n    65→}\\n    66→\\n    67→// unavailableRunner is returned for unknown agent names.\\n    68→type unavailableRunner struct {\\n    69→\\tname string\\n    70→}\\n    71→\\n    72→func (r *unavailableRunner) Name() string { return r.name }\\n    73→\\n    74→func (r *unavailableRunner) IsAvailable() (bool, error) {\\n    75→\\treturn false, fmt.Errorf(\\\"unknown agent: %s\\\", r.name)\\n    76→}\\n    77→\\n    78→func (r *unavailableRunner) RunPrompt(_ context.Context, _ string, _ string) (*AgentResult, error) {\\n    79→\\treturn nil, fmt.Errorf(\\\"agent %s is not available\\\", r.name)\\n    80→}\\n    81→\\n    82→func (r *unavailableRunner) RunPromptWithTools(_ context.Context, _ string, _ string, _ []string) (*AgentResult, error) {\\n    83→\\treturn nil, fmt.Errorf(\\\"agent %s is not available\\\", r.name)\\n    84→}\\n    85→\\n    86→// ClaudeCodeRunner implements AgentRunner for Claude Code CLI.\\n    87→type ClaudeCodeRunner struct {\\n    88→\\tModel        string\\n    89→\\tTimeout      time.Duration\\n    90→\\tAllowedTools []string\\n    91→}\\n    92→\\n    93→// NewClaudeCodeRunner creates a new Claude Code runner with the given config.\\n    94→func NewClaudeCodeRunner(config AgentRunnerConfig) *ClaudeCodeRunner {\\n    95→\\tmodel := config.Model\\n    96→\\tif model == \\\"\\\" {\\n    97→\\t\\tmodel = os.Getenv(\\\"E2E_CLAUDE_MODEL\\\")\\n    98→\\t\\tif model == \\\"\\\" {\\n    99→\\t\\t\\tmodel = \\\"haiku\\\"\\n   100→\\t\\t}\\n   101→\\t}\\n   102→\\n   103→\\ttimeout := config.Timeout\\n   104→\\tif timeout == 0 {\\n   105→\\t\\tif envTimeout := os.Getenv(\\\"E2E_TIMEOUT\\\"); envTimeout != \\\"\\\" {\\n   106→\\t\\t\\tif parsed, err := time.ParseDuration(envTimeout); err == nil {\\n   107→\\t\\t\\t\\ttimeout = parsed\\n   108→\\t\\t\\t}\\n   109→\\t\\t}\\n   110→\\t\\tif timeout == 0 {\\n   111→\\t\\t\\ttimeout = 2 * time.Minute\\n   112→\\t\\t}\\n   113→\\t}\\n   114→\\n   115→\\treturn &ClaudeCodeRunner{\\n   116→\\t\\tModel:        model,\\n   117→\\t\\tTimeout:      timeout,\\n   118→\\t\\tAllowedTools: []string{\\\"Edit\\\", \\\"Read\\\", \\\"Write\\\", \\\"Bash\\\", \\\"Glob\\\", \\\"Grep\\\"},\\n   119→\\t}\\n   120→}\\n   121→\\n   122→func (r *ClaudeCodeRunner) Name() string {\\n   123→\\treturn AgentNameClaudeCode\\n   124→}\\n   125→\\n   126→// IsAvailable checks if Claude CLI is installed and responds to --version.\\n   127→// Note: This does NOT verify authentication status. Claude Code uses OAuth\\n   128→// authentication (via `claude login`), not ANTHROPIC_API_KEY. If the CLI is\\n   129→// installed but not logged in, tests will fail at RunPrompt time.\\n   130→func (r *ClaudeCodeRunner) IsAvailable() (bool, error) {\\n   131→\\t// Check if claude CLI is in PATH\\n   132→\\tif _, err := exec.LookPath(\\\"claude\\\"); err != nil {\\n   133→\\t\\treturn false, fmt.Errorf(\\\"claude CLI not found in PATH: %w\\\", err)\\n   134→\\t}\\n   135→\\n   136→\\t// Check if claude is working (--version doesn't r