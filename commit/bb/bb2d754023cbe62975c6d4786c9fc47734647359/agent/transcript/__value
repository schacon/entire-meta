lk(metadataDir, func(path string, info os.FileInfo, err error) error {\\n  1329→\\t\\tif err != nil {\\n  1330→\\t\\t\\treturn err\\n  1331→\\t\\t}\\n  1332→\\n  1333→\\t\\t// Skip symlinks to prevent reading files outside the metadata directory.\\n  1334→\\t\\t// A symlink could point to sensitive files (e.g., /etc/passwd) which would\\n  1335→\\t\\t// then be captured in the checkpoint and stored in git history.\\n  1336→\\t\\t// NOTE: filepath.Walk uses os.Stat (follows symlinks), so info.Mode() never\\n  1337→\\t\\t// reports ModeSymlink. We use os.Lstat to check the entry itself.\\n  1338→\\t\\t// This check MUST come before IsDir() because Walk follows symlinked\\n  1339→\\t\\t// directories and would recurse into them otherwise.\\n  1340→\\t\\tlinfo, lstatErr := os.Lstat(path)\\n  1341→\\t\\tif lstatErr != nil {\\n  1342→\\t\\t\\treturn fmt.Errorf(\\\"failed to lstat %s: %w\\\", path, lstatErr)\\n  1343→\\t\\t}\\n  1344→\\t\\tif linfo.Mode()&os.ModeSymlink != 0 {\\n  1345→\\t\\t\\tif info.IsDir() {\\n  1346→\\t\\t\\t\\treturn filepath.SkipDir\\n  1347→\\t\\t\\t}\\n  1348→\\t\\t\\treturn nil\\n  1349→\\t\\t}\\n  1350→\\n  1351→\\t\\tif info.IsDir() {\\n  1352→\\t\\t\\treturn nil\\n  1353→\\t\\t}\\n  1354→\\n  1355→\\t\\t// Get relative path within metadata dir\\n  1356→\\t\\trelPath, err := filepath.Rel(metadataDir, path)\\n  1357→\\t\\tif err != nil {\\n  1358→\\t\\t\\treturn fmt.Errorf(\\\"failed to get relative path for %s: %w\\\", path, err)\\n  1359→\\t\\t}\\n  1360→\\n  1361→\\t\\t// Prevent path traversal via symlinks pointing outside the metadata dir\\n  1362→\\t\\tif strings.HasPrefix(relPath, \\\"..\\\") {\\n  1363→\\t\\t\\treturn fmt.Errorf(\\\"path traversal detected: %s\\\", relPath)\\n  1364→\\t\\t}\\n  1365→\\n  1366→\\t\\t// Create blob from file with secrets redaction\\n  1367→\\t\\tblobHash, mode, err := createRedactedBlobFromFile(s.repo, path, relPath)\\n  1368→\\t\\tif err != nil {\\n  1369→\\t\\t\\treturn fmt.Errorf(\\\"failed to create bl