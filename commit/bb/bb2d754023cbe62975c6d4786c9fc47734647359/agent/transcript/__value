= nil {\\n   720→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   721→\\t}\\n   722→\\n   723→\\tfmt.Fprintf(os.Stderr, \\\"Writing transcript to: %s\\\\n\\\", sessionFile)\\n   724→\\tif err := os.WriteFile(sessionFile, content, 0o600); err != nil {\\n   725→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   726→\\t}\\n   727→\\n   728→\\treturn sessionID, nil\\n   729→}\\n   730→\\n   731→// restoreTaskCheckpointTranscript restores a truncated transcript for a task checkpoint.\\n   732→// Uses GetTaskCheckpointTranscript to fetch the transcript from the strategy.\\n   733→//\\n   734→// NOTE: The transcript parsing/truncation/writing pipeline (transcript.ParseFromBytes,\\n   735→// TruncateTranscriptAtUUID, writeTranscript) assumes Claude's JSONL format.\\n   736→// This is acceptable because task checkpoints are currently only created by Claude Code's\\n   737→// PostToolUse hook. If other agents gain sub-agent support, this will need a\\n   738→// format-aware refactor (agent-specific parsing, truncation, and serialization).\\n   739→func restoreTaskCheckpointTranscript(strat strategy.Strategy, point strategy.RewindPoint, sessionID, checkpointUUID string, agent agentpkg.Agent) error {\\n   740→\\t// Get transcript content from strategy\\n   741→\\tcontent, err := strat.GetTaskCheckpointTranscript(point)\\n   742→\\tif err != nil {\\n   743→\\t\\treturn fmt.Errorf(\\\"failed to get task checkpoint transcript: %w\\\", err)\\n   744→\\t}\\n   745→\\n   746→\\t// Parse the transcript\\n   747→\\tparsed, err := transcript.ParseFromBytes(content)\\n   748→\\tif err != nil {\\n   749→\\t\\treturn fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   750→\\t}\\n   751→\\n   752→\\t// Truncate at checkpoint UUID\\n   753→\\ttruncated := TruncateTranscriptAtUUID(parsed, checkpointUUID)\\n   754→\\n   755→\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   756→\\tif err