ository: %w\\\", err)\\n   116→\\t}\\n   117→\\n   118→\\tstore := trail.NewStore(repo)\\n   119→\\ttrails, err := store.List()\\n   120→\\tif err != nil {\\n   121→\\t\\treturn fmt.Errorf(\\\"failed to list trails: %w\\\", err)\\n   122→\\t}\\n   123→\\n   124→\\tif trails == nil {\\n   125→\\t\\ttrails = []*trail.Metadata{}\\n   126→\\t}\\n   127→\\n   128→\\t// Apply status filter\\n   129→\\tif statusFilter != \\\"\\\" {\\n   130→\\t\\tstatus := trail.Status(statusFilter)\\n   131→\\t\\tif !status.IsValid() {\\n   132→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusFilter, formatValidStatuses())\\n   133→\\t\\t}\\n   134→\\t\\tvar filtered []*trail.Metadata\\n   135→\\t\\tfor _, t := range trails {\\n   136→\\t\\t\\tif t.Status == status {\\n   137→\\t\\t\\t\\tfiltered = append(filtered, t)\\n   138→\\t\\t\\t}\\n   139→\\t\\t}\\n   140→\\t\\ttrails = filtered\\n   141→\\t}\\n   142→\\n   143→\\t// Sort by updated_at descending\\n   144→\\tsort.Slice(trails, func(i, j int) bool {\\n   145→\\t\\treturn trails[i].UpdatedAt.After(trails[j].UpdatedAt)\\n   146→\\t})\\n   147→\\n   148→\\tif jsonOutput {\\n   149→\\t\\tenc := json.NewEncoder(w)\\n   150→\\t\\tenc.SetIndent(\\\"\\\", \\\"  \\\")\\n   151→\\t\\tif err := enc.Encode(trails); err != nil {\\n   152→\\t\\t\\treturn fmt.Errorf(\\\"failed to encode JSON: %w\\\", err)\\n   153→\\t\\t}\\n   154→\\t\\treturn nil\\n   155→\\t}\\n   156→\\n   157→\\tif len(trails) == 0 {\\n   158→\\t\\tfmt.Fprintln(w, \\\"No trails found.\\\")\\n   159→\\t\\tfmt.Fprintln(w)\\n   160→\\t\\tfmt.Fprintln(w, \\\"Commands:\\\")\\n   161→\\t\\tfmt.Fprintln(w, \\\"  entire trail create   Create a trail for the current branch\\\")\\n   162→\\t\\tfmt.Fprintln(w, \\\"  entire trail list     List all trails\\\")\\n   163→\\t\\tfmt.Fprintln(w, \\\"  entire trail update   Update trail metadata\\\")\\n   164→\\t\\treturn nil\\n   165→\\t}\\n   166→\\n   167→\\t// Table output\\n   168→\\tfmt.Fprintf(w, \\\"%-30s