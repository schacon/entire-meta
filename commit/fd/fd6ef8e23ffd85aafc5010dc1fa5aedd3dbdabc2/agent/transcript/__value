cmd.OutOrStdout()\\n   204→\\terrW := cmd.ErrOrStderr()\\n   205→\\n   206→\\trepo, err := strategy.OpenRepository(context.Background())\\n   207→\\tif err != nil {\\n   208→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   209→\\t}\\n   210→\\n   211→\\t// Determine base branch\\n   212→\\tif base == \\\"\\\" {\\n   213→\\t\\tbase = strategy.GetDefaultBranchName(repo)\\n   214→\\t\\tif base == \\\"\\\" {\\n   215→\\t\\t\\tbase = defaultBaseBranch\\n   216→\\t\\t}\\n   217→\\t}\\n   218→\\n   219→\\t_, currentBranch, _ := IsOnDefaultBranch(context.Background()) //nolint:errcheck // best-effort detection\\n   220→\\tinteractive := !cmd.Flags().Changed(\\\"title\\\") && !cmd.Flags().Changed(\\\"branch\\\")\\n   221→\\n   222→\\tif interactive {\\n   223→\\t\\t// Interactive flow: title → body → branch (derived) → status\\n   224→\\t\\tif err := runTrailCreateInteractive(&title, &body, &branch, &statusStr); err != nil {\\n   225→\\t\\t\\treturn err\\n   226→\\t\\t}\\n   227→\\t} else {\\n   228→\\t\\t// Non-interactive: derive missing values from provided flags\\n   229→\\t\\tif branch == \\\"\\\" {\\n   230→\\t\\t\\tif cmd.Flags().Changed(\\\"title\\\") {\\n   231→\\t\\t\\t\\tbranch = slugifyTitle(title)\\n   232→\\t\\t\\t} else {\\n   233→\\t\\t\\t\\tbranch = currentBranch\\n   234→\\t\\t\\t}\\n   235→\\t\\t}\\n   236→\\t\\tif title == \\\"\\\" {\\n   237→\\t\\t\\ttitle = trail.HumanizeBranchName(branch)\\n   238→\\t\\t}\\n   239→\\t}\\n   240→\\tif branch == \\\"\\\" {\\n   241→\\t\\treturn errors.New(\\\"branch name is required\\\")\\n   242→\\t}\\n   243→\\n   244→\\t// Create the branch if it doesn't exist\\n   245→\\tneedsCreation := branchNeedsCreation(repo, branch)\\n   246→\\tif needsCreation {\\n   247→\\t\\tif err := createBranch(repo, branch); err != nil {\\n   248→\\t\\t\\treturn fmt.Errorf(\\\"failed to create branch %q: %w\\\", branch, err)\\n   249→\\t\\t}\\n   250→\\t\\tfmt.Fprintf(w, \\\"Created branch %s\\\\n\\\", branch)\\n   251→\\t} else if currentBranch != branch {\\n   252→\\t\\tfmt.Fprintf(errW, \\\"Note: trail will be created for branch %q (not the current branch)\\\\n\\\", branch)\\n   253→\\t}\\n   254→\\n   255→\\t// Check if trail already exists for this branch\\n   256→\\tstore := trail.NewStore(repo)\\n   257→\\texisting, err := store.FindByBranch(branch)\\n   258→\\tif err == nil && existing != nil {\\n   259→\\t\\tfmt.Fprintf(w, \\\"Trail already exists for branch %q (ID: %s)\\\\n\\\", branch, existing.TrailID)\\n   260→\\t\\treturn nil\\n   261→\\t}\\n   262→\\n   263→\\t// Determine status\\n   264→\\tvar trailStatus trail.Status\\n   265→\\tif statusStr != \\\"\\\" {\\n   266→\\t\\ttrailStatus = trail.Status(statusStr)\\n   267→\\t\\tif !trailStatus.IsValid() {\\n   268→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusStr, formatValidStatuses())\\n   269→\\t\\t}\\n   270→\\t} else {\\n   271→\\t\\ttrailStatus = trail.StatusDraft\\n   272→\\t}\\n   273→\\n   274→\\t// Generate trail ID\\n   275→\\ttrailID, err := trail.GenerateID()\\n   276→\\tif err != nil {\\n   277→\\t\\treturn fmt.Errorf(\\\"failed to generate trail ID: %w\\\", err)\\n   278→\\t}\\n   279→\\n   280→\\t// Get author (GitHub username, falls back to git user.name)\\n   281→\\tauthorName := getTrailAuthor(repo)\\n   282→\\n   283→\\tnow := time.Now()\\n   284→\\tmetadata := &trail.Metadata{\\n   285→\\t\\tTrailID:   trailID,\\n   286→\\t\\tBranch:    branch,\\n   287→\\t\\tBase:      base,\\n   288→\\t\\tTitle:     title,\\n   289→\\t\\tBody:      body,\\n   290→\\t\\tStatus:    trailStatus,\\n   291→\\t\\tAuthor:    authorName,\\n   292→\\t\\tAssignees: []string{},\\n   293→\\t\\tLabels:    []string{},\\n   294→\\t\\tCreatedAt: now,\\n   295→\\t\\tUpdatedAt: now,\\n   296→\\t}\\n   297→\\n   298→\\tif err := store.Write(metadata, nil, nil); err != nil {\\n   299→\\t\\treturn fmt.Errorf(\\\"failed to create trail: %w\\\", err)\\n   300→\\t}\\n   301→\\n   302→\\tfmt.Fprintf(w, \\\"Created trail %q for branch %s (ID: %s)\\\\n\\\", title, branch, trailID)\\n   303→\\n   304→\\t// Push the branch and trail data to origin\\n   305→\\tif needsCreation {\\n   306→\\t\\tif err := pushBranchToOrigin(branch); err != nil {\\n   307→\\t\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to push branch: %v\\\\n\\\", err)\\n   308→\\t\\t} else {\\n   309→\\t\\t\\tfmt.Fprintf(w, \\\"Pushed branch %s to origin\\\\n\\\", branch)\\n   310→\\t\\t}\\n   311→\\t}\\n   312→\\tif err := strategy.PushTrailsBranch(context.Background(), \\\"origin\\\"); err != nil {\\n   313→\\t\\tfmt.Fprintf(errW, \\\"Warning: failed to push trail data: %v\\\\n\\\", err)\\n   314→\\t}\\n   315→\\n   316→\\t// Checkout the branch if requested or prompted\\n   317→\\tif needsCreation && currentBranch != branch {\\n   318→\\t\\tshouldCheckout := checkout\\n   319→\\t\\tif !shouldCheckout && !cmd.Flags().Changed(\\\"checkout\\\") {\\n   320→\\t\\t\\t// Interactive: ask whether to checkout\\n   321→\\t\\t\\tform := NewAccessibleForm(\\n   322→\\t\\t\\t\\thuh.NewGroup(\\n   323→\\t\\t\\t\\t\\thuh.NewConfirm().\\n   324→\\t\\t\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Check out branch %s?\\\", branch)).\\n   325→\\t\\t\\t\\t\\t\\tValue(&shouldCheckout),\\n   326→\\t\\t\\t\\t),\\n   327→\\t\\t\\t)\\n   328→\\t\\t\\tif formErr := form.Run(); formErr == nil && shouldCheckout {\\n   329→\\t\\t\\t\\tcheckout = true\\n   330→\\t\\t\\t}\\n   331→\\t\\t}\\n   332→\\t\\tif checkout {\\n   333→\\t\\t\\tif err := CheckoutBranch(context.Background(), branch); err != nil {\\n   334→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to checkout branch %q: %w\\\", branch, err)\\n   335→\\t\\t\\t}\\n   336→\\t\\t\\tfmt.Fprintf(w, \\\"Switched to branch %s\\\\n\\\", branch)\\n   337→\\t\\t}\\n   338→\\t}\\n   339→\\n   340→\\treturn nil\\n   341→}\\n   342→\\n   343→func newTrailUpdateCmd() *cobra.Command {\\n   344→\\tvar statusStr, title, body, branch string\\n   345→\\tvar labelAdd, labelRemove []string\\n   346→\\n   347→\\tcmd := &cobra.Command{\\n   348→\\t\\tUse:   \\\"update\\\",\\n   349→\\t\\tShort: \\\"Update trail metadata\\\",\\n   350→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   351→\\t\\t\\treturn runTrailUpdate(cmd.OutOrStdout(), statusStr, title, body, branch, labelAdd, labelRemove)\\n   352→\\t\\t},\\n   353→\\t}\\n   354→\\n   355→\\tcmd.Flags().StringVar(&statusStr, \\\"status\\\", \\\"\\\", \\\"Update status\\\")\\n   356→\\tcmd.Flags().StringVar(&title, \\\"title\\\", \\\"\\\", \\\"Update title\\\")\\n   357→\\tcmd.Flags().StringVar(&body, \\\"body\\\", \\\"\\\", \\\"Update body\\\")\\n   358→\\tcmd.Flags().StringVar(&branch, \\\"branch\\\", \\\"\\\", \\\"Branch to update trail for (defaults to current)\\\")\\n   359→\\tcmd.Flags().StringSliceVar(&labelAdd, \\\"add-label\\\", nil, \\\"Add label(s)\\\")\\n   360→\\tcmd.Flags().StringSliceVar(&labelRemove, \\\"remove-label\\\", nil, \\\"Remove label(s)\\\")\\n   361→\\n   362→\\treturn cmd\\n   363→}\\n   364→\\n   365→func runTrailUpdate(w io.Writer, statusStr, title, body, branch string, labelAdd, labelRemove []string) error {\\n   366→\\trepo, err := strategy.OpenRepository(context.Background())\\n   367→\\tif err != nil {\\n   368→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   369→\\t}\\n   370→\\n   371→\\t// Determine branch\\n   372→\\tif branch == \\\"\\\" {\\n   373→\\t\\tbranch, err = GetCurrentBranch(context.Background())\\n   374→\\t\\tif err != nil {\\n   375→\\t\\t\\treturn fmt.Errorf(\\\"failed to determine current branch: %w\\\", err)\\n   376→\\t\\t}\\n   377→\\t}\\n   378→\\n   379→\\tstore := trail.NewStore(repo)\\n   380→\\tmetadata, err := store.FindByBranch(branch)\\n   381→\\tif err != nil {\\n   382→\\t\\treturn fmt.Errorf(\\\"failed to find trail: %w\\\", err)\\n   383→\\t}\\n   384→\\tif metadata == nil {\\n   385→\\t\\treturn fmt.Errorf(\\\"no trail found for branch %q\\\", branch)\\n   386→\\t}\\n   387→\\n   388→\\t// Interactive mode when no flags are provided\\n   389→\\tnoFlags := statusStr == \\\"\\\" && title == \\\"\\\" && body == \\\"\\\" && labelAdd == nil && labelRemove == nil\\n   390→\\tif noFlags {\\n   391→\\t\\t// Build status options with current value as default.\\n   392→\\t\\t// Exclude \\\"done\\\" and \\\"closed\\\" unless the trail is already in that status\\n   393→\\t\\t// (otherwise the select would silently reset to the first option).\\n   394→\\t\\tvar statusOptions []huh.Option[string]\\n   395→\\t\\tfor _, s := range trail.ValidStatuses() {\\n   396→\\t\\t\\tif (s == trail.StatusDone || s == trail.StatusClosed) && s != metadata.Status {\\n   397→\\t\\t\\t\\tcontinue\\n   398→\\t\\t\\t}\\n   399→\\t\\t\\tlabel := string(s)\\n   400→\\t\\t\\tif s == metadata.Status {\\n   401→\\t\\t\\t\\tlabel += \\\" (current)\\\"\\n   402→\\t\\t\\t}\\n   403→\\t\\t\\tstatusOptions = append(statusOptions, huh.NewOption(label, string(s)))\\n   404→\\t\\t}\\n   405→\\t\\tstatusStr = string(metadata.Status)\\n   406→\\t\\ttitle = metadata.Title\\n   407→\\t\\tbody = metadata.Body\\n   408→\\n   409→\\t\\tform := NewAccessibleForm(\\n   410→\\t\\t\\thuh.NewGroup(\\n   411→\\t\\t\\t\\thuh.NewSelect[string]().\\n   412→\\t\\t\\t\\t\\tTitle(\\\"Status\\\").\\n   413→\\t\\t\\t\\t\\tOptions(statusOptions...).\\n   414→\\t\\t\\t\\t\\tValue(&statusStr),\\n   415→\\t\\t\\t\\thuh.NewInput().\\n   416→\\t\\t\\t\\t\\tTitle(\\\"Title\\\").\\n   417→\\t\\t\\t\\t\\tValue(&title),\\n   418→\\t\\t\\t\\thuh.NewText().\\n   419→\\t\\t\\t\\t\\tTitle(\\\"Body\\\").\\n   420→\\t\\t\\t\\t\\tValue(&body),\\n   421→\\t\\t\\t),\\n   422→\\t\\t)\\n   423→\\t\\tif formErr := form.Run(); formErr != nil {\\n   424→\\t\\t\\treturn fmt.Errorf(\\\"form cancelled: %w\\\", formErr)\\n   425→\\t\\t}\\n   426→\\t}\\n   427→\\n   428→\\t// Validate status if provided\\n   429→\\tif statusStr != \\\"\\\" {\\n   430→\\t\\tstatus := trail.Status(statusStr)\\n   431→\\t\\tif !status.IsValid() {\\n   432→\\t\\t\\treturn fmt.Errorf(\\\"invalid status %q: valid values are %s\\\", statusStr, formatValidStatuses())\\n   433→\\t\\t}\\n   434→\\t}\\n   435→\\n   436→\\terr = store.Update(metadata.TrailID, func(m *trail.Metadata) {\\n   437→\\t\\tif statusStr != \\\"\\\" {\\n   438→\\t\\t\\tm.Status = trail.Status(statusStr)\\n   439→\\t\\t}\\n   440→\\t\\tif title != \\\"\\\" {\\n   441→\\t\\t\\tm.Title = title\\n   442→\\t\\t}\\n   443→\\t\\tif body != \\\"\\\" {\\n   444→\\t\\t\\tm.Body = body\\n   445→\\t\\t}\\n   446→\\t\\tfor _, l := range labelAdd {\\n   447→\\t\\t\\tif !slices.Contains(m.Labels, l) {\\n   448→\\t\\t\\t\\tm.Labels = append(m.Labels, l)\\n   449→\\t\\t\\t}\\n   450→\\t\\t}\\n   451→\\t\\tfor _, l := range labelRemove {\\n   452→\\t\\t\\tm.Labels = slices.DeleteFunc(m.Labels, func(v string) bool { return v == l })\\n   453→\\t\\t}\\n   454→\\t})\\n   455→\\tif err != nil {\\n   456→\\t\\treturn fmt.Errorf(\\\"failed to update trail: %w\\\", err)\\n   457→\\t}\\n   458→\\n   459→\\tfmt.Fprintf(w, \\\"Updated trail for branch %s\\\\n\\\", branch)\\n   460→\\treturn nil\\n   461→}\\n   462→\\n   463→// defaultBaseBranch is the fallback base branch name when it cannot be determined.\\n   464→const defaultBaseBranch = \\\"main\\\"\\n   465→\\n   466→func formatValidStatuses() string {\\n   467→\\tstatuses := trail.ValidStatuses()\\n   468→\\tnames := make([]string, len(statuses))\\n   469→\\tfor i, s := range statuses {\\n   470→\\t\\tnames[i] = string(s)\\n   471→\\t}\\n   472→\\treturn strings.Join(names, \\\", \\\")\\n   473→}\\n   474→\\n   475→// runTrailCreateInteractive runs the interactive form for trail creation.\\n   476→// Prompts for title, body, branch (derived from title), and status.\\n   477→func runTrailCreateInteractive(title, body, branch, statusStr *string) error {\\n   478→\\t// Step 1: Title and body\\n   479→\\tform := NewAccessibleForm(\\n   480→\\t\\thuh.NewGroup(\\n   481→\\t\\t\\thuh.NewInput().\\n   482→\\t\\t\\t\\tTitle(\\\"Trail title\\\").\\n   483→\\t\\t\\t\\tPlaceholder(\\\"What are you working on?\\\").\\n   484→\\t\\t\\t\\tValue(title),\\n   485→\\t\\t\\thuh.NewText().\\n   486→\\t\\t\\t\\tTitle(\\\"Body (optional)\\\").\\n   487→\\t\\t\\t\\tValue(body),\\n   488→\\t\\t),\\n   489→\\t)\\n   490→\\tif err := form.Run(); err != nil {\\n   491→\\t\\treturn fmt.Errorf(\\\"form cancelled: %w\\\", err)\\n   492→\\t}\\n   493→\\t*title = strings.TrimSpace(*title)\\n   494→\\tif *title == \\\"\\\" {\\n   495→\\t\\treturn errors.New(\\\"trail title is required\\\")\\n   496→\\t}\\n   497→\\n   498→\\t// Step 2: Branch (derived from title) and status\\n   499→\\tsuggested := slugifyTitle(*title)\\n   500→\\t*branch = suggested\\n   501→\\n   502→\\t// Build status options, excluding done/closed\\n   503→\\tvar statusOptions []huh.Option[string]\\n   504→\\tfor _, s := range trail.ValidStatuses() {\\n   505→\\t\\tif s == trail.StatusDone || s == trail.StatusClosed {\\n   506→\\t\\t\\tcontinue\\n   507→\\t\\t}\\n   508→\\t\\tstatusOptions = append(statusOptions, huh.NewOption(string(s), string(s)))\\n   509→\\t}\\n   510→\\tif *statusStr == \\\"\\\" {\\n   511→\\t\\t*statusStr = string(trail.StatusDraft)\\n   512→\\t}\\n   513→\\n   514→\\tform = NewAccessibleForm(\\n   515→\\t\\thuh.NewGroup(\\n   516→\\t\\t\\thuh.NewInput().\\n   517→\\t\\t\\t\\tTitle(\\\"Branch name\\\").\\n   518→\\t\\t\\t\\tPlaceholder(suggested).\\n   519→\\t\\t\\t\\tValue(branch),\\n   520→\\t\\t\\thuh.NewSelect[string]().\\n   521→\\t\\t\\t\\tTitle(\\\"Status\\\").\\n   522→\\t\\t\\t\\tOptions(statusOptions...).\\n   523→\\t\\t\\t\\tValue(statusStr),\\n   524→\\t\\t),\\n   525→\\t)\\n   526→\\tif err := form.Run(); err != nil {\\n   527→\\t\\treturn fmt.Errorf(\\\"form cancelled: %w\\\", err)\\n   528→\\t}\\n   529→\\t*branch = strings.TrimSpace(*branch)\\n   530→\\tif *branch == \\\"\\\" {\\n   531→\\t\\t*branch = suggested\\n   532→\\t}\\n   533→\\treturn nil\\n   534→}\\n   535→\\n   536→// fetchTrailsBranch fetches the remote trails branch so we see trails from collaborators.\\n   537→// Best-effort: silently ignores errors (e.g., no remote, no network).\\n   538→func fetchTrailsBranch() {\\n   539→\\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\\n   540→\\tdefer cancel()\\n   541→\\tbranchName := paths.TrailsBranchName\\n   542→\\trefSpec := fmt.Sprintf(\\\"+refs/heads/%s:refs/remotes/origin/%s\\\", branchName, branchName)\\n   543→\\n   544→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"fetch\\\", \\\"origin\\\", refSpec)\\n   545→\\t// Ensure non-interactive fetch in hook/agent contexts\\n   546→\\tcmd.Stdin = nil\\n   547→\\tcmd.Env = append(os.Environ(), \\\"GIT_TERMINAL_PROMPT=0\\\")\\n   548→\\t_ = cmd.Run() //nolint:errcheck // best-effort fetch\\n   549→}\\n   550→\\n   551→// getTrailAuthor returns the GitHub username for the trail author.\\n   552→// Falls back to git user.name if gh CLI is unavailable or not authenticated.\\n   553→func getTrailAuthor(repo *git.Repository) string {\\n   554→\\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\\n   555→\\tdefer cancel()\\n   556→\\tcmd := exec.CommandContext(ctx, \\\"gh\\\", \\\"api\\\", \\\"user\\\", \\\"-q\\\", \\\".login\\\")\\n   557→\\tif output, err := cmd.Output(); err == nil {\\n   558→\\t\\tif login := strings.TrimSpace(string(output)); login != \\\"\\\" {\\n   559→\\t\\t\\treturn login\\n   560→\\t\\t}\\n   561→\\t}\\n   562→\\tname, _ := strategy.GetGitAuthorFromRepo(repo)\\n   563→\\treturn name\\n   564→}\\n   565→\\n   566→// slugifyTitle converts a title string into a branch-friendly slug.\\n   567→// Example: \\\"Add user authentication\\\" -> \\\"add-user-authentication\\\"\\n   568→func slugifyTitle(title string) string {\\n   569→\\ts := strings.ToLower(strings.TrimSpace(title))\\n   570→\\t// Replace spaces and underscores with hyphens\\n   571→\\ts = strings.NewReplacer(\\\" \\\", \\\"-\\\", \\\"_\\\", \\\"-\\\").Replace(s)\\n   572→\\t// Remove anything that's not alphanumeric, hyphen, or slash\\n   573→\\tvar b strings.Builder\\n   574→\\tprevHyphen := false\\n   575→\\tfor _, r := range s {\\n   576→\\t\\tif (r >= 'a' && r <= 'z') || (r >= '0' && r <= '9') || r == '/' {\\n   577→\\t\\t\\tb.WriteRune(r)\\n   578→\\t\\t\\tprevHyphen = false\\n   579→\\t\\t} else if r == '-' && !prevHyphen {\\n   580→\\t\\t\\tb.WriteRune('-')\\n   581→\\t\\t\\tprevHyphen = true\\n   582→\\t\\t}\\n   583→\\t}\\n   584→\\treturn strings.Trim(b.String(), \\\"-\\\")\\n   585→}\\n   586→\\n   587→// branchNeedsCreation checks if a branch exists locally.\\n   588→func branchNeedsCreation(repo *git.Repository, branchName string) bool {\\n   589→\\t_, err := repo.Reference(plumbing.NewBranchReferenceName(branchName), true)\\n   590→\\treturn err != nil\\n   591→}\\n   592→\\n   593→// createBranch creates a new local branch pointing at HEAD without checking it out.\\n   594→func createBranch(repo *git.Repository, branchName string) error {\\n   595→\\thead, err := repo.Head()\\n   596→\\tif err != nil {\\n   597→\\t\\treturn fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   598→\\t}\\n   599→\\tref := plumbing.NewHashReference(plumbing.NewBranchReferenceName(branchName), head.Hash())\\n   600→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   601→\\t\\treturn fmt.Errorf(\\\"failed to create branch ref: %w\\\", err)\\n   602→\\t}\\n   603→\\treturn nil\\n   604→}\\n   605→\\n   606→// pushBranchToOrigin pushes a branch to the origin remote.\\n   607→func pushBranchToOrigin(branchName string) error {\\n   608→\\tctx, cancel := context.WithTimeout(context.Background(), 2*time.Minute)\\n   609→\\tdefer cancel()\\n   610→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"push\\\", \\\"--no-verify\\\", \\\"-u\\\", \\\"origin\\\", branchName)\\n   611→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   612→\\t\\treturn fmt.Errorf(\\\"%s: %w\\\", strings.TrimSpace(string(output)), err)\\n   613→\\t}\\n   614→\\treturn nil\\n   615→}\\n   616→\"}]