rcentage, 100.0,\\n\\t\\t\\t\\\"agent_percentage should be < 100 when human also wrote content\\\")\\n\\t\\t// Shadow branch may persist if agent created extra files beyond\\n\\t\\t// agent.txt — we only stage the two known files for precise\\n\\t\\t// attribution counting.\\n\\t})\\n}\\n\",\"numLines\":193,\"startLine\":1,\"totalLines\":193}},\"sourceToolAssistantUUID\":\"b6cde2e6-e02b-4f1b-9e68-fb5da9a9dbd1\"}\n{\"parentUuid\":\"296e43a4-2d04-4666-8a0b-6b31fc85cb4b\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli\",\"sessionId\":\"fda4b616-9e4e-43ab-909d-d06140a1bd2a\",\"version\":\"2.1.69\",\"gitBranch\":\"main\",\"slug\":\"soft-honking-peach\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01R4637DHsLB7rYts2ZagJMD\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01TDoAMH7PvM38L8nQJ6jCbX\",\"name\":\"Glob\",\"input\":{\"pattern\":\"e2e/vogon/**/*.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":\"tool_use\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":6136,\"cache_read_input_tokens\":32821,\"output_tokens\":418,\"server_tool_use\":{\"web_search_requests\":0,\"web_fetch_requests\":0},\"service_tier\":\"standard\",\"cache_creation\":{\"ephemeral_1h_input_tokens\":6136,\"ephemeral_5m_input_tokens\":0},\"inference_geo\":\"\",\"iterations\":[],\"speed\":\"standard\"}},\"requestId\":\"req_011CYkyyunpXvDTZRL2vHtzh\",\"type\":\"assistant\",\"uuid\":\"e0dbb7dc-ef25-4df4-9ff8-492c9dcafc9a\",\"timestamp\":\"2026-03-06T01:47:08.627Z\"}\n{\"parentUuid\":\"e0dbb7dc-ef25-4df4-9ff8-492c9dcafc9a\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli\",\"sessionId\":\"fda4b616-9e4e-43ab-909d-d06140a1bd2a\",\"version\":\"2.1.69\",\"gitBranch\":\"main\",\"slug\":\"soft-honking-peach\",\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"PostToolUse\",\"hookName\":\"PostToolUse:Glob\",\"comma