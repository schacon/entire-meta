epath\\\"\\n    23→\\t\\\"regexp\\\"\\n    24→\\t\\\"strings\\\"\\n    25→\\t\\\"time\\\"\\n    26→\\n    27→\\t\\\"github.com/google/uuid\\\"\\n    28→)\\n    29→\\n    30→func main() {\\n    31→\\tprompt := \\\"\\\"\\n    32→\\tfor i := 1; i < len(os.Args); i++ {\\n    33→\\t\\tif os.Args[i] == \\\"-p\\\" && i+1 < len(os.Args) {\\n    34→\\t\\t\\tprompt = os.Args[i+1]\\n    35→\\t\\t\\ti++\\n    36→\\t\\t}\\n    37→\\t}\\n    38→\\n    39→\\tdir, err := os.Getwd() //nolint:forbidigo // Standalone binary, not part of CLI — CWD is the repo dir\\n    40→\\tif err != nil {\\n    41→\\t\\tfatal(\\\"getwd: %v\\\", err)\\n    42→\\t}\\n    43→\\n    44→\\tsessionID := uuid.New().String()\\n    45→\\ttranscriptPath := setupTranscript(sessionID)\\n    46→\\n    47→\\tfireHook(dir, \\\"session-start\\\", map[string]string{\\n    48→\\t\\t\\\"session_id\\\":      sessionID,\\n    49→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n    50→\\t})\\n    51→\\n    52→\\tif prompt != \\\"\\\" {\\n    53→\\t\\t// Headless mode: single prompt\\n    54→\\t\\trunTurn(dir, sessionID, transcriptPath, prompt)\\n    55→\\t} else {\\n    56→\\t\\t// Interactive mode: read prompts from stdin\\n    57→\\t\\tfmt.Fprint(os.Stdout, \\\"> \\\")\\n    58→\\t\\tscanner := bufio.NewScanner(os.Stdin)\\n    59→\\t\\tfor scanner.Scan() {\\n    60→\\t\\t\\tline := strings.TrimSpace(scanner.Text())\\n    61→\\t\\t\\tif line == \\\"\\\" || line == \\\"exit\\\" || line == \\\"quit\\\" {\\n    62→\\t\\t\\t\\tbreak\\n    63→\\t\\t\\t}\\n    64→\\t\\t\\t// Give tmux's Send() time to capture the echoed-input state\\n    65→\\t\\t\\t// before we produce any output. Send polls every 200ms; without\\n    66→\\t\\t\\t// this pause, vogon output appears in the same capture window\\n    67→\\t\\t\\t// as the echo, causing stableAtSend to include final output and\\n    68→\\t\\t\\t// preventing WaitFor's contentChanged detection.\\n    69→\\t\\t\\ttime.Sleep(700 * time.Millisecond)\\n    70→\\t\\t\\tfmt.Fprintln(os.Stdout, \\\"Working...\\\")\\n    71→\\t\\t\\trunTurn(dir, sessionID, transcriptPath, line)\\n    72→\\t\\t\\tfmt.Fprint(os.Stdout, \\\"> \\\")\\n    73→\\t\\t}\\n    74→\\t}\\n    75→\\n    76→\\tfireHook(dir, \\\"session-end\\\", map[string]string{\\n    77→\\t\\t\\\"session_id\\\":      sessionID,\\n    78→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n    79→\\t})\\n    80→}\\n    81→\\n    82→func runTurn(dir, sessionID, transcriptPath, prompt string) {\\n    83→\\tfireHook(dir, \\\"user-prompt-submit\\\", map[string]any{\\n    84→\\t\\t\\\"session_id\\\":      sessionID,\\n    85→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n    86→\\t\\t\\\"prompt\\\":          prompt,\\n    87→\\t})\\n    88→\\n    89→\\tappendTranscript(transcriptPath, \\\"user\\\", prompt)\\n    90→\\n    91→\\tactions := parsePrompt(prompt)\\n    92→\\texecuteActions(dir, actions)\\n    93→\\n    94→\\tappendTranscript(transcriptPath, \\\"assistant\\\", fmt.Sprintf(\\\"Done. Executed %d actions.\\\", len(actions)))\\n    95→\\tfmt.Fprintf(os.Stdout, \\\"Done. Executed %d actions.\\\\n\\\", len(actions))\\n    96→\\n    97→\\tfireHook(dir, \\\"stop\\\", map[string]string{\\n    98→\\t\\t\\\"session_id\\\":      sessionID,\\n    99→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   100→\\t})\\n   101→}\\n   102→\\n   103→// --- Prompt Parsing ---\\n   104→\\n   105→type action struct {\\n   106→\\tkind    string // \\\"create\\\", \\\"modify\\\", \\\"delete\\\", \\\"commit\\\"\\n   107→\\tpath    string\\n   108→\\tcontent string\\n   109→}\\n   110→\\n   111→// fileExt is the shared file extension pattern used across all prompt-parsing regexes.\\n   112→const fileExt = `go|md|txt|js|ts|py|rb|rs|toml|yaml|json`\\n   113→\\n   114→var (\\n   115→\\t// \\\"create a [single|new|...] [markdown|text] file [at|called] <path>\\\"\\n   116→\\tcreateFileRe = regexp.MustCompile(`(?i)create\\\\s+(?:a\\\\s+)?(?:\\\\w+\\\\s+)*?(?:markdown\\\\s+|text\\\\s+)?file\\\\s+(?:at\\\\s+|called\\\\s+)?([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   117→\\t// \\\"create N files: <path> about <topic>, <path> about <topic>\\\"\\n   118→\\tcreateMultiRe = regexp.MustCompile(`(?i)create\\\\s+(?:\\\\w+\\\\s+)*?(?:four|three|two|\\\\d+)\\\\s+(?:\\\\w+\\\\s+)*?(?:markdown\\\\s+)?files?:?\\\\s+(.+)`)\\n   119→\\t// \\\"modify <path>\\\"\\n   120→\\tmodifyFileRe = regexp.MustCompile(`(?i)modify\\\\s+(?:the\\\\s+)?(?:file\\\\s+)?(?:at\\\\s+)?([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   121→\\t// \\\"modify [these] N [existing] files[:]\\\"\\n   122→\\tmodifyMultiRe = regexp.MustCompile(`(?i)modify\\\\s+(?:these\\\\s+)?(?:three|four|two|\\\\d+)\\\\s+(?:\\\\w+\\\\s+)*?files?[.:]\\\\s*(.+)`)\\n   123→\\t// \\\"add ... to <path>\\\" (e.g. \\\"add another stanza to poem.txt\\\")\\n   124→\\taddToFileRe = regexp.MustCompile(`(?i)add\\\\s+(?:another\\\\s+|a\\\\s+|some\\\\s+)?\\\\w+\\\\s+to\\\\s+([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   125→\\t// \\\"delete <path>\\\"\\n   126→\\tdeleteFileRe = regexp.MustCompile(`(?i)delete\\\\s+(?:the\\\\s+)?(?:file\\\\s+)?(?:at\\\\s+)?([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   127→\\t// \\\"commit\\\" anywhere in the prompt, but not \\\"do not commit\\\" / \\\"don't commit\\\"\\n   128→\\tcommitRe = regexp.MustCompile(`(?i)(?:then\\\\s+|now\\\\s+)?(?:git\\\\s+)?commit\\\\b`)\\n   129→\\t// Negative: \\\"do not commit\\\" / \\\"don't commit\\\" with optional object, at sentence boundary\\n   130→\\t// Matches: \\\"Do not commit.\\\", \\\"Do not commit the file.\\\", \\\"Do not commit them,\\\"\\n   131→\\t// Does NOT match: \\\"Do not commit any other files\\\" (different intent)\\n   132→\\tnoCommitRe = regexp.MustCompile(`(?i)(?:do\\\\s+not|don'?t)\\\\s+commit(?:\\\\s+(?:it|them|the\\\\s+\\\\w+))?(?:\\\\.|,|$)`)\\n   133→\\t// \\\"commit each file separately\\\" — interleave create+commit\\n   134→\\tcommitSeparatelyRe = regexp.MustCompile(`(?i)commit\\\\s+each\\\\s+file\\\\s+separately`)\\n   135→\\t// Individual file in multi-create: \\\"docs/a.md about apples\\\"\\n   136→\\t// Topic capture stops at comma, \\\"and\\\", period followed by space+uppercase, or end\\n   137→\\tmultiFileItemRe = regexp.MustCompile(`([^\\\\s,]+\\\\.(?:` + fileExt + `))\\\\s+(?:about\\\\s+|with\\\\s+|containing\\\\s+)?(.+?)(?:,\\\\s*|\\\\s+and\\\\s+|\\\\.\\\\s+[A-Z]|\\\\.\\\\s*$)`)\\n   138→\\t// Individual file in multi-modify: \\\"src/model.go should define ...\\\"\\n   139→\\tmodifyItemRe = regexp.MustCompile(`([^\\\\s,]+\\\\.(?:` + fileExt + `))\\\\s+should\\\\s+(.+?)(?:,|$)`)\\n   140→\\t// \\\"In src/a.go, add ...\\\" pattern for multi-modify\\n   141→\\tinFileRe = regexp.MustCompile(`[Ii]n\\\\s+([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   142→\\t// Inline content: \\\"with content 'package main; func Foo() {}'\\\"\\n   143→\\tinlineContentRe = regexp.MustCompile(`(?i)with\\\\s+content\\\\s+['\\\"]([^'\\\"]+)['\\\"]`)\\n   144→\\t// Numbered steps: \\\"(1) ... (2) ... (3) ...\\\"\\n   145→\\tnumberedStepRe = regexp.MustCompile(`\\\\(\\\\d+\\\\)\\\\s+`)\\n   146→\\t// Explicit git command: \\\"Run: git add ... && git commit -m '...'\\\"\\n   147→\\texplicitGitRe = regexp.MustCompile(`(?i)run:?\\\\s+git\\\\s+add\\\\s+.+(?:&&\\\\s*git\\\\s+commit|;\\\\s*git\\\\s+commit)`)\\n   148→\\t// \\\"about the colour red\\\" → \\\"the colour red\\\"\\n   149→\\ttopicRe = regexp.MustCompile(`(?i)about\\\\s+(.+?)(?:\\\\.|,|\\\\s+Do\\\\s|\\\\s+do\\\\s|\\\\s+then\\\\s|$)`)\\n   150→\\t// Fallback: extract any file path from text\\n   151→\\tanyFileRe = regexp.MustCompile(`([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   152→)\\n   153→\\n   154→func parsePrompt(prompt string) []action {\\n   155→\\t// Check for numbered-step prompts — parse each step independently to\\n   156→\\t// preserve ordering (e.g., create, commit, then create more).\\n   157→\\tif numberedStepRe.MatchString(prompt) {\\n   158→\\t\\treturn parseNumberedSteps(prompt)\\n   159→\\t}\\n   160→\\tvar actions []action\\n   161→\\n   162→\\t// Multi-file modify: \\\"modify these three files: src/model.go should ..., src/view.go should ...\\\"\\n   163→\\t// Also matches: \\\"Modify two existing files. In src/a.go, add ...\\\"\\n   164→\\tif m := modifyMultiRe.FindStringSubmatch(prompt); m != nil {\\n   165→\\t\\t// Try \\\"should\\\" pattern first\\n   166→\\t\\titems := modifyItemRe.FindAllStringSubmatch(m[1], -1)\\n   167→\\t\\tfor _, item := range items {\\n   168→\\t\\t\\tactions = append(actions, action{\\n   169→\\t\\t\\t\\tkind:    \\\"modify\\\",\\n   170→\\t\\t\\t\\tpath:    item[1],\\n   171→\\t\\t\\t\\tcontent: \\\"// \\\" + strings.TrimSpace(item[2]) + \\\"\\\\n\\\",\\n   172→\\t\\t\\t})\\n   173→\\t\\t}\\n   174→\\t\\t// Try \\\"In <path>\\\" pattern as fallback\\n   175→\\t\\tif len(actions) == 0 {\\n   176→\\t\\t\\tfor _, item := range inFileRe.FindAllStringSubmatch(m[1], -1) {\\n   177→\\t\\t\\t\\tactions = append(actions, action{\\n   178→\\t\\t\\t\\t\\tkind:    \\\"modify\\\",\\n   179→\\t\\t\\t\\t\\tpath:    item[1],\\n   180→\\t\\t\\t\\t\\tcontent: \\\"// Modified by vogon agent\\\\n\\\",\\n   181→\\t\\t\\t\\t})\\n   182→\\t\\t\\t}\\n   183→\\t\\t}\\n   184→\\t\\t// Last resort: extract any file paths\\n   185→\\t\\tif len(actions) == 0 {\\n   186→\\t\\t\\tfor _, fm := range anyFileRe.FindAllStringSubmatch(m[1], -1) {\\n   187→\\t\\t\\t\\tactions = append(actions, action{\\n   188→\\t\\t\\t\\t\\tkind:    \\\"modify\\\",\\n   189→\\t\\t\\t\\t\\tpath:    fm[1],\\n   190→\\t\\t\\t\\t\\tcontent: \\\"// Modified by vogon agent\\\\n\\\",\\n   191→\\t\\t\\t\\t})\\n   192→\\t\\t\\t}\\n   193→\\t\\t}\\n   194→\\t}\\n   195→\\n   196→\\t// Multi-file create: \\\"create four markdown files: docs/a.md about apples, ...\\\"\\n   197→\\tif len(actions) == 0 || hasModifyOnly(actions) {\\n   198→\\t\\tif m := createMultiRe.FindStringSubmatch(prompt); m != nil {\\n   199→\\t\\t\\titems := multiFileItemRe.FindAllStringSubmatch(m[1], -1)\\n   200→\\t\\t\\tfor _, item := range items {\\n   201→\\t\\t\\t\\tactions = append(actions, action{\\n   202→\\t\\t\\t\\t\\tkind:    \\\"create\\\",\\n   203→\\t\\t\\t\\t\\tpath:    item[1],\\n   204→\\t\\t\\t\\t\\tcontent: fmt.Sprintf(\\\"# %s\\\\n\\\\nA paragraph about %s.\\\\n\\\", strings.TrimSpace(item[2]), strings.TrimSpace(item[2])),\\n   205→\\t\\t\\t\\t})\\n   206→\\t\\t\\t}\\n   207→\\t\\t}\\n   208→\\t}\\n   209→\\n   210→\\t// Single file create — also runs if we only have modifies (combined prompts)\\n   211→\\tif !hasCreate(actions) {\\n   212→\\t\\tif m := createFileRe.FindStringSubmatch(prompt); m != nil {\\n   213→\\t\\t\\ttopic := extractTopic(prompt)\\n   214→\\t\\t\\tcontent := fmt.Sprintf(\\\"# %s\\\\n\\\\nA paragraph about %s.\\\\n\\\", topic, topic)\\n   215→\\t\\t\\tif ic := inlineContentRe.FindStringSubmatch(prompt); ic != nil {\\n   216→\\t\\t\\t\\tcontent = ic[1] + \\\"\\\\n\\\"\\n   217→\\t\\t\\t}\\n   218→\\t\\t\\tactions = append(actions, action{\\n   219→\\t\\t\\t\\tkind:    \\\"create\\\",\\n   220→\\t\\t\\t\\tpath:    m[1],\\n   221→\\t\\t\\t\\tcontent: content,\\n   222→\\t\\t\\t})\\n   223→\\t\\t}\\n   224→\\t}\\n   225→\\n   226→\\t// Single file modify — also runs if we only have creates (combined prompts)\\n   227→\\tif !hasModify(actions) {\\n   228→\\t\\tif m := modifyFileRe.FindStringSubmatch(prompt); m != nil {\\n   229→\\t\\t\\tactions = append(actions, action{\\n   230→\\t\\t\\t\\tkind:    \\\"modify\\\",\\n   231→\\t\\t\\t\\tpath:    m[1],\\n   232→\\t\\t\\t\\tcontent: \\\"// Modified by vogon agent\\\\n\\\",\\n   233→\\t\\t\\t})\\n   234→\\t\\t}\\n   235→\\t}\\n   236→\\n   237→\\t// \\\"add ... to <path>\\\" as modify (e.g. \\\"add another stanza to poem.txt\\\")\\n   238→\\tif !hasModify(actions) {\\n   239→\\t\\tif m := addToFileRe.FindStringSubmatch(prompt); m != nil {\\n   240→\\t\\t\\tactions = append(actions, action{\\n   241→\\t\\t\\t\\tkind:    \\\"modify\\\",\\n   242→\\t\\t\\t\\tpath:    m[1],\\n   243→\\t\\t\\t\\tcontent: \\\"// Modified by vogon agent\\\\n\\\",\\n   244→\\t\\t\\t})\\n   245→\\t\\t}\\n   246→\\t}\\n   247→\\n   248→\\t// Delete\\n   249→\\tif m := deleteFileRe.FindStringSubmatch(prompt); m != nil {\\n   250→\\t\\tactions = append(actions, action{kind: \\\"delete\\\", path: m[1]})\\n   251→\\t}\\n   252→\\n   253→\\t// Commit: check for \\\"commit each file separately\\\" (interleaved) vs normal.\\n   254→\\t// Skip if prompt contains \\\"do not commit\\\" / \\\"don't commit\\\".\\n   255→\\tif !noCommitRe.MatchString(prompt) {\\n   256→\\t\\tif commitSeparatelyRe.MatchString(prompt) {\\n   257→\\t\\t\\tactions = interleaveCommits(actions)\\n   258→\\t\\t} else if commitRe.MatchString(prompt) {\\n   259→\\t\\t\\tactions = append(actions, action{kind: \\\"commit\\\"})\\n   260→\\t\\t}\\n   261→\\t}\\n   262→\\n   263→\\treturn actions\\n   264→}\\n   265→\\n   266→// parseNumberedSteps splits \\\"(1) ... (2) ... (3) ...\\\" prompts into individual\\n   267→// steps and parses each one, preserving ordering. This handles prompts like:\\n   268→// \\\"(1) Create file A. (2) Create file B. (3) git commit. (4) Create file C.\\\"\\n   269→func parseNumberedSteps(prompt string) []action {\\n   270→\\t// Split on numbered markers: \\\"(1) \\\", \\\"(2) \\\", etc.\\n   271→\\tindices := numberedStepRe.FindAllStringIndex(prompt, -1)\\n   272→\\tif len(indices) == 0 {\\n   273→\\t\\treturn nil\\n   274→\\t}\\n   275→\\n   276→\\tvar steps []string\\n   277→\\tfor i, idx := range indices {\\n   278→\\t\\tstart := idx[1] // after the \\\"(N) \\\" marker\\n   279→\\t\\tvar end int\\n   280→\\t\\tif i+1 < len(indices) {\\n   281→\\t\\t\\tend = indices[i+1][0]\\n   282→\\t\\t} else {\\n   283→\\t\\t\\tend = len(prompt)\\n   284→\\t\\t}\\n   285→\\t\\tstep := strings.TrimSpace(prompt[start:end])\\n   286→\\t\\tif step != \\\"\\\" {\\n   287→\\t\\t\\tsteps = append(steps, step)\\n   288→\\t\\t}\\n   289→\\t}\\n   290→\\n   291→\\tvar actions []action\\n   292→\\tfor _, step := range steps {\\n   293→\\t\\t// Explicit git command: \\\"Run: git add ... && git commit ...\\\"\\n   294→\\t\\tif explicitGitRe.MatchString(step) {\\n   295→\\t\\t\\tactions = append(actions, action{kind: \\\"commit\\\"})\\n   296→\\t\\t\\tcontinue\\n   297→\\t\\t}\\n   298→\\n   299→\\t\\t// Create file with optional inline content\\n   300→\\t\\tif m := createFileRe.FindStringSubmatch(step); m != nil {\\n   301→\\t\\t\\tcontent := fmt.Sprintf(\\\"# %s\\\\n\\\\nGenerated content.\\\\n\\\", m[1])\\n   302→\\t\\t\\tif ic := inlineContentRe.FindStringSubmatch(step); ic != nil {\\n   303→\\t\\t\\t\\tcontent = ic[1] + \\\"\\\\n\\\"\\n   304→\\t\\t\\t}\\n   305→\\t\\t\\tactions = append(actions, action{kind: \\\"create\\\", path: m[1], content: content})\\n   306→\\t\\t\\tcontinue\\n   307→\\t\\t}\\n   308→\\n   309→\\t\\t// Modify file\\n   310→\\t\\tif m := modifyFileRe.FindStringSubmatch(step); m != nil {\\n   311→\\t\\t\\tactions = append(actions, action{kind: \\\"modify\\\", path: m[1], content: \\\"// Modified by vogon agent\\\\n\\\"})\\n   312→\\t\\t\\tcontinue\\n   313→\\t\\t}\\n   314→\\n   315→\\t\\t// Delete file\\n   316→\\t\\tif m := deleteFileRe.FindStringSubmatch(step); m != nil {\\n   317→\\t\\t\\tactions = append(actions, action{kind: \\\"delete\\\", path: m[1]})\\n   318→\\t\\t\\tcontinue\\n   319→\\t\\t}\\n   320→\\n   321→\\t\\t// Bare commit instruction\\n   322→\\t\\tif commitRe.MatchString(step) && !noCommitRe.MatchString(step) {\\n   323→\\t\\t\\tactions = append(actions, action{kind: \\\"commit\\\"})\\n   324→\\t\\t}\\n   325→\\t}\\n   326→\\treturn actions\\n   327→}\\n   328→\\n   329→func hasCreate(actions []action) bool {\\n   330→\\tfor _, a := range actions {\\n   331→\\t\\tif a.kind == \\\"create\\\" {\\n   332→\\t\\t\\treturn true\\n   333→\\t\\t}\\n   334→\\t}\\n   335→\\treturn false\\n   336→}\\n   337→\\n   338→func hasModify(actions []action) bool {\\n   339→\\tfor _, a := range actions {\\n   340→\\t\\tif a.kind == \\\"modify\\\" {\\n   341→\\t\\t\\treturn true\\n   342→\\t\\t}\\n   343→\\t}\\n   344→\\treturn false\\n   345→}\