SON transcript to .entire/tmp/\\n   182→// so the lifecycle handler can proceed when the real transcript is unavailable\\n   183→// (e.g., Kiro IDE mode where SQLite is at a different path).\\n   184→func (k *KiroAgent) createPlaceholderTranscript(ctx context.Context, cwd, sessionID string) string {\\n   185→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   186→\\tif err != nil {\\n   187→\\t\\trepoRoot = cwd\\n   188→\\t}\\n   189→\\tif repoRoot == \\\"\\\" {\\n   190→\\t\\treturn \\\"\\\"\\n   191→\\t}\\n   192→\\tcacheDir := filepath.Join(repoRoot, \\\".entire\\\", \\\"tmp\\\")\\n   193→\\tcachePath := filepath.Join(cacheDir, sessionID+\\\".json\\\")\\n   194→\\tif err := os.MkdirAll(cacheDir, 0o750); err != nil {\\n   195→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to create transcript cache dir\\\", \\\"err\\\", err)\\n   196→\\t\\treturn \\\"\\\"\\n   197→\\t}\\n   198→\\tif err := os.WriteFile(cachePath, []byte(\\\"{}\\\"), 0o600); err != nil {\\n   199→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to write placeholder transcript\\\", \\\"err\\\", err)\\n   200→\\t\\treturn \\\"\\\"\\n   201→\\t}\\n   202→\\treturn cachePath\\n   203→}\\n   204→\\n   205→// generateAndCacheSessionID creates a new random session ID and writes it\\n   206→// to .entire/tmp/kiro-active-session for subsequent hooks to read.\\n   207→func (k *KiroAgent) generateAndCacheSessionID(ctx context.Context) string {\\n   208→\\tsid := generateSessionID()\\n   209→\\tcachePath := k.sessionIDCachePath(ctx)\\n   210→\\tif err := os.MkdirAll(filepath.Dir(cachePath), 0o750); err != nil {\\n   211→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to create session ID cache dir\\\", \\\"err\\\", err)\\n   212→\\t\\treturn sid\\n   213→\\t}\\n   214→\\tif err := os.WriteFile(cachePath, []byte(sid), 0o600); err != nil {\\n   215→\\t\\tlogging.Warn(ctx, \\\"kiro: failed to write session ID cache\\\", \\\"err\\\", err)\\n   216→\\t}\\n   217→\\treturn sid\\n   218→}\\n   219→\\n   220→// clearCachedSessionID removes 