\\treturn nil\\n   856→\\t}\\n   857→\\n   858→\\treturn nil\\n   859→}\\n   860→\\n   861→// handleLogsOnlyRestore restores only the session logs without changing files.\\n   862→func handleLogsOnlyRestore(start strategy.Strategy, point strategy.RewindPoint) error {\\n   863→\\t// Resolve agent once for use throughout\\n   864→\\tagent, err := getAgent(point.Agent)\\n   865→\\tif err != nil {\\n   866→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   867→\\t}\\n   868→\\n   869→\\t// Initialize logging context with agent from checkpoint\\n   870→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   871→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   872→\\n   873→\\tlogging.Debug(ctx, \\\"logs-only restore started\\\",\\n   874→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   875→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   876→\\t)\\n   877→\\n   878→\\t// Check if strategy supports logs-only restoration\\n   879→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   880→\\tif !ok {\\n   881→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   882→\\t}\\n   883→\\n   884→\\t// Restore logs\\n   885→\\tsessions, err := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   886→\\tif err != nil {\\n   887→\\t\\tlogging.Error(ctx, \\\"logs-only restore failed\\\",\\n   888→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   889→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   890→\\t\\t)\\n   891→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   892→\\t}\\n   893→\\n   894→\\tlogging.Debug(ctx, \\\"logs-only restore completed\\\",\\n   895→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   896→\\t)\\n   897→\\n   898→\\t// Show resume commands for all sessions\\n   899→\\tfmt.Println(\\\"Restored session logs.\\\")\\n   900→\\tprintMultiSessionResumeCommands(sessions)\\n   901→\\treturn nil\\n   902→}\\n   