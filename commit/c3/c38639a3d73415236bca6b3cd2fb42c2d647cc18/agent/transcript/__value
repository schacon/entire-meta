 redact.JSONLBytes(opts.IncrementalData)\\n   313→\\t\\t\\tif err != nil {\\n   314→\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to redact incremental checkpoint: %w\\\", err)\\n   315→\\t\\t\\t}\\n   316→\\t\\t}\\n   317→\\t\\tincrementalCheckpoint := struct {\\n   318→\\t\\t\\tType      string          `json:\\\"type\\\"`\\n   319→\\t\\t\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   320→\\t\\t\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n   321→\\t\\t\\tData      json.RawMessage `json:\\\"data\\\"`\\n   322→\\t\\t}{\\n   323→\\t\\t\\tType:      opts.IncrementalType,\\n   324→\\t\\t\\tToolUseID: opts.ToolUseID,\\n   325→\\t\\t\\tTimestamp: time.Now().UTC(),\\n   326→\\t\\t\\tData:      incData,\\n   327→\\t\\t}\\n   328→\\t\\tcpData, err := jsonutil.MarshalIndentWithNewline(incrementalCheckpoint, \\\"\\\", \\\"  \\\")\\n   329→\\t\\tif err != nil {\\n   330→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to marshal incremental checkpoint: %w\\\", err)\\n   331→\\t\\t}\\n   332→\\n   333→\\t\\tcpBlobHash, err := CreateBlobFromContent(s.repo, cpData)\\n   334→\\t\\tif err != nil {\\n   335→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create incremental checkpoint blob: %w\\\", err)\\n   336→\\t\\t}\\n   337→\\t\\tcpFilename := fmt.Sprintf(\\\"%03d-%s.json\\\", opts.IncrementalSequence, opts.ToolUseID)\\n   338→\\t\\tcpPath := taskMetadataDir + \\\"/checkpoints/\\\" + cpFilename\\n   339→\\t\\tentries[cpPath] = object.TreeEntry{\\n   340→\\t\\t\\tName: cpPath,\\n   341→\\t\\t\\tMode: filemode.Regular,\\n   342→\\t\\t\\tHash: cpBlobHash,\\n   343→\\t\\t}\\n   344→\\t} else {\\n   345→\\t\\t// Final checkpoint: add transcripts and checkpoint.json\\n   346→\\n   347→\\t\\t// Add session transcript (with chunking support for large transcripts)\\n   348→\\t\\tif opts.TranscriptPath != \\\"\\\" {\\n   349→\\t\\t\\tif transcriptContent, readErr := os.ReadFile(opts.TranscriptPath); readErr == nil {\\n   350→\\t\\t\\t\\t// Detect agent type from content for proper chunking\\n   351→\\t\\t\\t\\tagentType := agent.DetectAgentTypeFromContent(transcriptContent)\\n   352→\\n   353→\\t\\t\\t\\t// Chunk if necessary\\n   354→\\t\\t\\t\\tchunks, chunkErr := agent.ChunkTranscript(transcriptContent, agentType)\\n   355→\\t\\t\\t\\tif chunkErr != nil {\\n   356→\\t\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to chunk transcript, checkpoint will be saved without transcript\\\",\\n   357→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", chunkErr.Error()),\\n   358→\\t\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n   359→\\t\\t\\t\\t\\t)\\n   360→\\t\\t\\t\\t} else {\\n   361→\\t\\t\\t\\t\\tfor i, chunk := range chunks {\\n   362→\\t\\t\\t\\t\\t\\tchunkPath := sessionMetadataDir + \\\"/\\\" + agent.ChunkFileName(paths.TranscriptFileName, i)\\n   363→\\t\\t\\t\\t\\t\\tblobHash, blobErr := CreateBlobFromContent(s.repo, chunk)\\n   364→\\t\\t\\t\\t\\t\\tif blobErr != nil {\\n   365→\\t\\t\\t\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to create blob for transcript chunk\\\",\\n   366→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", blobErr.Error()),\\n   367→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n   368→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"chunk_index\\\", i),\\n   369→\\t\\t\\t\\t\\t\\t\\t)\\n   370→\\t\\t\\t\\t\\t\\t\\tcontinue\\n   371→\\t\\t\\t\\t\\t\\t}\\n   372→\\t\\t\\t\\t\\t\\tentries[chunkPath] = object.TreeEntry{\\n   373→\\t\\t\\t\\t\\t\\t\\tName: chunkPath,\\n   374→\\t\\t\\t\\t\\t\\t\\tMode: filemode.Regular,\\n   375→\\t\\t\\t\\t\\t\\t\\tHash: blobHash,\\n   376→\\t\\t\\t\\t\\t\\t}\\n   377→\\t\\t\\t\\t\\t}\\n   378→\\t\\t\\t\\t}\\n   379→\\t\\t\\t}\\n   380→\\t\\t}\\n   381→\\n   382→\\t\\t// Add subagent transcript if available\\n   383→\\t\\tif opts.SubagentTranscriptPath != \\\"\\\" && opts.AgentID != \\\"\\\" {\\n   384→\\t\\t\\tif agentContent, readErr := os.ReadFile(opts.SubagentTranscriptPath); readErr == nil {\\n   385→\\t\\t\\t\\tredacted, jsonlErr := redact.JSONLBytes(agentContent)\\n   386→\\t\\t\\t\\tif jsonlErr != nil {\\n   387→\\t\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"subagent transcript is not valid JSONL, falling back to plain redaction\\\",\\n   388→\\t\\t\\t\\t\\t\\tslog.String(\\\"path\\\", opts.SubagentTranscriptPath),\\n   389→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", jsonlErr.Error()),\\n   390→\\t\\t\\t\\t\\t)\\n   391→\\t\\t\\t\\t\\tredacted = redact.Bytes(agentContent)\\n   392→\\t\\t\\t\\t}\\n   393→\\t\\t\\t\\tagentContent = redacted\\n   394→\\t\\t\\t\\tif blobHash, blobErr := CreateBlobFromContent(s.repo, agentContent); blobErr == nil {\\n   395→\\t\\t\\t\\t\\tagentPath := taskMetadataDir + \\\"/agent-\\\" + opts.AgentID + \\\".jsonl\\\"\\n   396→\\t\\t\\t\\t\\tentries[agentPath] = object.TreeEntry{\\n   397→\\t\\t\\t\\t\\t\\tName: agentPath,\\n   398→\\t\\t\\t\\t\\t\\tMode: filemode.Regular,\\n   399→\\t\\t\\t\\t\\t\\tHash: blobHash,\\n   400→\\t\\t\\t\\t\\t}\\n   401→\\t\\t\\t\\t}\\n   402→\\t\\t\\t}\\n   403→\\t\\t}\\n   404→\\n   405→\\t\\t// Add checkpoint.json\\n   406→\\t\\tcheckpointJSON := fmt.Sprintf(`{\\n   407→  \\\"session_id\\\": %q,\\n   408→  \\\"tool_use_id\\\": %q,\\n   409→  \\\"checkpoint_uuid\\\": %q,\\n   410→  \\\"agent_id\\\": %q\\n   411→}`, opts.SessionID, opts.ToolUseID, opts.CheckpointUUID, opts.AgentID)\\n   412→\\n   413→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(checkpointJSON))\\n   414→\\t\\tif err != nil {\\n   415→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create checkpoint blob: %w\\\", err)\\n   416→\\t\\t}\\n   417→\\t\\tcheckpointPath := taskMetadataDir + \\\"/checkpoint.json\\\"\\n   418→\\t\\tentries[checkpointPath] = object.TreeEntry{\\n   419→\\t\\t\\tName: checkpointPath,\\n   420→\\t\\t\\tMode: filemode.Regular,\\n   421→\\t\\t\\tHash: blobHash,\\n   422→\\t\\t}\\n   423→\\t}\\n   424→\\n   425→\\t// Build new tree from entries\\n   426→\\treturn BuildTreeFromEntries(s.repo, entries)\\n   427→}\\n   428→\\n   429→// ListTemporaryCheckpoints lists all checkpoint commits on a shadow branch.\\n   430→// This returns individual commits (rewind points), not just branch info.\\n   431→// The sessionID filter, if provided, limits results to commits from that session.\\n   432→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   433→func (s *GitStore) ListTemporaryCheckpoints(ctx context.Context, baseCommit, worktreeID, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   434→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   435→\\treturn s.listCheckpointsForBranch(ctx, shadowBranchName, sessionID, limit)\\n   436→}\\n   437→\\n   438→// ListCheckpointsForBranch lists checkpoint commits for a shadow branch by name.\\n   439→// Use this when you already have the full branch name (e.g., from ListTemporary).\\n   440→// The sessionID filter, if provided, limits results to commits from that session.\\n   441→func (s *GitStore) ListCheckpointsForBranch(ctx context.Context, branchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   442→\\treturn s.listCheckpointsForBranch(ctx, branchName, sessionID, limit)\\n   443→}\\n   444→\\n   445→// listCheckpointsForBranch lists checkpoint commits for a specific shadow branch name.\\n   446→// This is an internal helper used by ListTemporaryCheckpoints, ListCheckpointsForBranch, and ListAllTemporaryCheckpoints.\\n   447→func (s *GitStore) listCheckpointsForBranch(ctx context.Context, shadowBranchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   448→\\t_ = ctx // Reserved for future use\\n   449→\\n   450→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   451→\\n   452→\\tref, err := s.repo.Reference(refName, true)\\n   453→\\tif err != nil {\\n   454→\\t\\treturn nil, nil //nolint:nilerr // No shadow branch