al and malformed data\\n   237→\\tif err := validation.ValidateSessionID(opts.SessionID); err != nil {\\n   238→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n   239→\\t}\\n   240→\\tif err := validation.ValidateToolUseID(opts.ToolUseID); err != nil {\\n   241→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n   242→\\t}\\n   243→\\tif err := validation.ValidateAgentID(opts.AgentID); err != nil {\\n   244→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n   245→\\t}\\n   246→\\n   247→\\t// Get shadow branch name\\n   248→\\tshadowBranchName := ShadowBranchNameForCommit(opts.BaseCommit, opts.WorktreeID)\\n   249→\\n   250→\\t// Get or create shadow branch\\n   251→\\tparentHash, baseTreeHash, err := s.getOrCreateShadowBranch(shadowBranchName)\\n   252→\\tif err != nil {\\n   253→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get shadow branch: %w\\\", err)\\n   254→\\t}\\n   255→\\n   256→\\t// Collect all files to include in the commit\\n   257→\\tallFiles := make([]string, 0, len(opts.ModifiedFiles)+len(opts.NewFiles))\\n   258→\\tallFiles = append(allFiles, opts.ModifiedFiles...)\\n   259→\\tallFiles = append(allFiles, opts.NewFiles...)\\n   260→\\n   261→\\t// Build new tree with code changes (no metadata dir yet)\\n   262→\\tnewTreeHash, err := s.buildTreeWithChanges(baseTreeHash, allFiles, opts.DeletedFiles, \\\"\\\", \\\"\\\")\\n   263→\\tif err != nil {\\n   264→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n   265→\\t}\\n   266→\\n   267→\\t// Add task metadata to tree\\n   268→\\tnewTreeHash, err = s.addTaskMetadataToTree(newTreeHash, opts)\\n   269→\\tif err != nil {\\n   270→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to add task metadata: %w\\\", err)\\n   271→\\t}\\n   272→\\n   273→\\t// Create the commit\\n   274→\\tcommitHash, err := s.createCommit(newTreeHa