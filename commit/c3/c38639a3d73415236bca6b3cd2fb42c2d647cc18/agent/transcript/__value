irectory if specified (to session subdirectory)\\n   273→\\tif opts.MetadataDir != \\\"\\\" {\\n   274→\\t\\tif err := s.copyMetadataDir(opts.MetadataDir, sessionPath, entries); err != nil {\\n   275→\\t\\t\\treturn fmt.Errorf(\\\"failed to copy metadata directory: %w\\\", err)\\n   276→\\t\\t}\\n   277→\\t}\\n   278→\\n   279→\\t// Build the sessions array\\n   280→\\tvar sessions []SessionFilePaths\\n   281→\\tif existingSummary != nil {\\n   282→\\t\\tsessions = make([]SessionFilePaths, max(len(existingSummary.Sessions), sessionIndex+1))\\n   283→\\t\\tcopy(sessions, existingSummary.Sessions)\\n   284→\\t} else {\\n   285→\\t\\tsessions = make([]SessionFilePaths, 1)\\n   286→\\t}\\n   287→\\tsessions[sessionIndex] = sessionFilePaths\\n   288→\\n   289→\\t// Update root metadata.json with CheckpointSummary\\n   290→\\treturn s.writeCheckpointSummary(opts, basePath, entries, sessions)\\n   291→}\\n   292→\\n   293→// writeSessionToSubdirectory writes a single session's files to a numbered subdirectory.\\n   294→// Returns the absolute file paths from the git tree root for the sessions map.\\n   295→func (s *GitStore) writeSessionToSubdirectory(opts WriteCommittedOptions, sessionPath string, entries map[string]object.TreeEntry) (SessionFilePaths, error) {\\n   296→\\tfilePaths := SessionFilePaths{}\\n   297→\\n   298→\\t// Clear any existing entries at this path so stale files from a previous\\n   299→\\t// write (e.g. prompt.txt, context.md) don't persist on overwrite.\\n   300→\\tfor key := range entries {\\n   301→\\t\\tif strings.HasPrefix(key, sessionPath) {\\n   302→\\t\\t\\tdelete(entries, key)\\n   303→\\t\\t}\\n   304→\\t}\\n   305→\\n   306→\\t// Write transcript\\n   307→\\tif err := s.writeTranscript(opts, sessionPath, entries); err != nil {\\n   308→\\t\\treturn filePaths, err\\n   309→\\t}\\n   310→\\tfilePaths.Transcript = \\\"/\\\" + sessionPath + paths.TranscriptFileName\\n   311→\\tfilePaths.ContentHash = \\\"/\\\" + sessionPath + paths.ContentHashFileName\\n   312→\\n   313→\\t// Write prompts\\n   314→\\tif len(opts.Prompts) > 0 {\\n   315→\\t\\tpromptContent := redact.String(strings.Join(opts.Prompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\"))\\n   316→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(promptContent))\\n   317→\\t\\tif err != nil {\\n   318→\\t\\t\\treturn filePaths, err\\n   319→\\t\\t}\\n   320→\\t\\tentries[sessionPath+paths.PromptFileName] = object.TreeEntry{\\n   321→\\t\\t\\tName: sessionPath + paths.PromptFileName,\\n   322→\\t\\t\\tMode: filemode.Regular,\\n   323→\\t\\t\\tHash: blobHash,\\n   324→\\t\\t}\\n   325→\\t\\tfilePaths.Prompt = \\\"/\\\" + sessionPath + paths.PromptFileName\\n   326→\\t}\\n   327→\\n   328→\\t// Write context\\n   329→\\tif len(opts.Context) > 0 {\\n   330→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, redact.Bytes(opts.Context))\\n   331→\\t\\tif err != nil {\\n   332→\\t\\t\\treturn filePaths, err\\n   333→\\t\\t}\\n   334→\\t\\tentries[sessionPath+paths.ContextFileName] = object.TreeEntry{\\n   335→\\t\\t\\tName: sessionPath + paths.ContextFileName,\\n   336→\\t\\t\\tMode: filemode.Regular,\\n   337→\\t\\t\\tHash: blobHash,\\n   338→\\t\\t}\\n   339→\\t\\tfilePaths.Context = \\\"/\\\" + sessionPath + paths.ContextFileName\\n   340→\\t}\\n   341→\\n   342→\\t// Write session-level metadata.json (CommittedMetadata with all fields including initial_attribution)\\n   343→\\tsessionMetadata := CommittedMetadata{\\n   344→\\t\\tCheckpointID:                opts.CheckpointID,\\n   345→\\t\\tSessionID:                   opts.SessionID,\\n   346→\\t\\tStrategy:                    opts.Strategy,\\n   347→\\t\\tCreatedAt:                   time.Now().UTC(),\\n   348→\\t\\tBranch:                      opts.Branch,\\n   349→\\t\\tCheckpointsCount:            opts.CheckpointsCount,\\n   350→\\t\\tFilesTouched:                opts.FilesTouched,\\n   351→\\t\\tAgent:                       opts.Agent,\\n   352→\\t\\tTurnID:                      opts.TurnID,\\n   353→\\t\\tIsTask:                      opts.IsTask,\\n   354→\\t\\tToolUseID:                   opts.ToolUseID,\\n   355→\\t\\tTranscriptIdentifierAtStart: opts.TranscriptIdentifierAtStart,\\n   356→\\t\\tCheckpointTranscriptStart:   opts.CheckpointTranscriptStart,\\n   357→\\t\\tTranscriptLinesAtStart:      opts.CheckpointTranscriptStart, // Deprecated: kept for backward compat\\n   358→\\t\\tTokenUsage:                  opts.TokenUsage,\\n   359→\\t\\tInitialAttribution:          opts.InitialAttribution,\\n   360→\\t\\tSummary:                     redactSummary(opts.Summary),\\n   361→\\t\\tCLIVersion:                  buildinfo.Version,\\n   362→\\t}\\n   363→\\n   364→\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(sessionMetadata, \\\"\\\", \\\"  \\\")\\n   365→\\tif err != nil {\\n   366→\\t\\treturn filePaths, fmt.Errorf(\\\"failed to marshal session metadata: %w\\\", err)\\n   367→\\t}\\n   368→\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n   369→\\tif err != nil {\\n   370→\\t\\treturn filePaths, err\\n   371→\\t}\\n   372→\\tentries[sessionPath+paths.MetadataFileName] = object.TreeEntry{\\n   373→\\t\\tName: sessionPath + paths.MetadataFileName,\\n   374→\\t\\tMode: filemode.Regular,\\n   375→\\t\\tHash: metadataHash,\\n   376→\\t}\\n   377→\\tfilePaths.Metadata = \\\"/\\\" + sessionPath + paths.MetadataFileName\\n   378→\\n   379→\\t// Write export data (optional — for agents with non-file storage, e.g., OpenCode)\\n   380→\\tif len(opts.ExportData) > 0 {\\n   381→\\t\\texportHash, err := CreateBlobFromContent(s.repo, opts.ExportData)\\n   382→\\t\\tif err != nil {\\n   383→\\t\\t\\treturn filePaths, fmt.Errorf(\\\"failed to create export data blob: %w\\\", err)\\n   384→\\t\\t}\\n   385→\\t\\tentries[sessionPath+paths.ExportDataFileName] = object.TreeEntry{\\n   386→\\t\\t\\tName: sessionPath + paths.ExportDataFileName,\\n   387→\\t\\t\\tMode: filemode.Regular,\\n   388→\\t\\t\\tHash: exportHash,\\n   389→\\t\\t}\\n   390→\\t}\\n   391→\\n   392→\\treturn filePaths, nil\\n   393→}\\n   394→\\n   395→// writeCheckpointSummary writes the root-level CheckpointSummary with aggregated statistics.\\n   396→// sessions is the complete sessions array (already built by the caller).\\n   397→func (s *GitStore) writeCheckpointSummary(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry, sessions []SessionFilePaths) error {\\n   398→\\tcheckpointsCount, filesTouched, tokenUsage, err :=\\n   399→\\t\\ts.reaggregateFromEntries(basePath, len(sessions), entries)\\n   400→\\tif err != nil {\\n   401→\\t\\treturn fmt.Errorf(\\\"failed to aggregate session stats: %w\\\", err)\\n   402→\\t}\\n   403→\\n   404→\\tsummary := CheckpointSummary{\\n   405→\\t\\tCheckpointID:     opts.CheckpointID,\\n   406→\\t\\tCLIVersion:       buildinfo.Version,\\n   407→\\t\\tStrategy:         opts.Strategy,\\n   408→\\t\\tBranch:           opts.Branch,\\n   409→\\t\\tCheckpointsCount: checkpointsCount,\\n   410→\\t\\tFilesTouched:     filesTouched,\\n   411→\\t\\tSessions:         sessions,\\n   412→\\t\\tTokenUsage:       tokenUsage,\\n   413→\\t}\\n   414→\\n   415→\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(summary, \\\"\\\", \\\"  \\\")\\n   416→\\tif err != nil {\\n   417→\\t\\treturn fmt.Errorf(\\\"failed to marshal checkpoint summary: %w\\\", err)\\n   418→\\t}\\n   419→\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n   420→\\tif err != nil {\\n   421→\\t\\treturn err\\n   422→\\t}\\n   423→\\tentries[basePath+paths.MetadataFileName] = object.TreeEntry{\\n   424→\\t\\tName: basePath + paths.MetadataFileName,\\n   425→\\t\\tMode: filemode.Regular,\\n   426→\\t\\tHash: metadataHash,\\n   427→\\t}\\n   428→\\treturn nil\\n   429→}\\n   430→\\n   431→// findSessionIndex returns the index of an existing session with the given ID,\\n   432→// or the next available index if not found. This prevents duplicate session entries.\\n   433→func (s *GitStore) findSessionIndex(basePath string, existingSummary *CheckpointSummary, entries map[string]object.TreeEntry, sessionID string) int {\\n   434→\\tif existingSummary == nil {\\n   435→\\t\\treturn 0\\n   436→\\t}\\n   437→\\tfor i := range len(existingSummary.Sessions) {\\n   438→\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n   439→\\t\\tif entry, exists := entries[path]; exists {\\n   440→\\t\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n   441→\\t\\t\\tif err != nil {\\n   442→\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to read session metadata during dedup check\\\",\\n   443→\\t\\t\\t\\t\\tslog.Int(\\\"session_index\\\", i),\\n   444→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   445→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   446→\\t\\t\\t\\t)\\n   447→\\t\\t\\t\\tcontinue\\n   448→\\t\\t\\t}\\n   449→\\t\\t\\tif meta.SessionID == sessionID {\\n   450→\\t\\t\\t\\treturn i\\n   451→\\t\\t\\t}\\n   452→\\t\\t}\\n   453→\\t}\\n   454→\\treturn len(existingSummary.Sessions)\\n   455→}\\n   456→\\n   457→// reaggregateFromEntries reads all session metadata from the entries map and\\n   458→// reaggregates CheckpointsCount, FilesTouched, and TokenUsage.\\n   459→func (s *GitStore) reaggregateFromEntries(basePath string, sessionCount int, entries map[string]object.TreeEntry) (int, []string, *agent.TokenUsage, error) {\\n   460→\\tvar totalCount int\\n   461→\\tvar allFiles []string\\n   462→\\tvar totalTokens *agent.TokenUsage\\n   463→\\n   464→\\tfor i := range sessionCount {\\n   465→\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n   466→\\t\\tentry, exists := entries[path]\\n   467→\\t\\tif !exists {\\n   468→\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"session %d metadata not found at %s\\\", i, path)\\n   469→\\t\\t}\\n   470→\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n   471→\\t\\tif err != nil {\\n   472→\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"failed to read session %d metadata: %w\\\", i, err)\\n   473→\\t\\t}\\n   474→\\t\\ttotalCount += meta.CheckpointsCount\\n   475→\\t\\tallFiles = mergeFilesTouched(allFiles, meta.FilesTouched)\\n   476→\\t\\ttotalTokens = aggregateTokenUsage(totalTokens, meta.TokenUsage)\\n   477→\\t}\\n   478→\\n   479→\\treturn totalCount, allFiles, totalTokens, nil\\n   480→}\\n   481→\\n   482→// readJSONFromBlob reads JSON from a blob hash and decodes it to the given type.\\n   483→func readJSONFromBlob[T any](repo *git.Repository, hash plumbing.Hash) (*T, error) {\\n   484→\\tblob, err := repo.BlobObject(hash)\\n   485→\\tif err != nil {\\n   486→\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob: %w\\\", err)\\n   487→\\t}\\n   488→\\n   489→\\treader, err := blob.Reader()\\n   490→\\tif err != nil {\\n   491→\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob reader: %w\\\", err)\\n   492→\\t}\\n   493→\\tdefer reader.Close()\\n   494→\\n   495→\\tvar result T\\n   496→\\tif err := json.NewDecoder(reader).Decode(&result); err != nil {\\n   497→\\t\\treturn nil, fmt.Errorf(\\\"failed to decode: %w\\\", err)\\n   498→\\t}\\n   499→\\n   500→\\treturn &result, nil\\n   501→}\\n   502→\\n   503→// readSummaryFromBlob reads CheckpointSummary from a blob hash.\\n   504→func (s *GitStore) readSummaryFromBlob(hash plumbing.Hash) (*CheckpointSummary, error) {\\n   505→\\treturn readJSONFromBlob[CheckpointSummary](s.repo, hash)\\n   506→}\\n   507→\\n   508→// aggregateTokenUsage sums two TokenUsage structs.\\n   509→// Returns nil if both inputs are nil.\\n   510→func aggregateTokenUsage(a, b *agent.TokenUsage) *agent.TokenUsage {\\n   511→\\tif a == nil && b == nil {\\n   512→\\t\\treturn nil\\n   513→\\t}\\n   514→\\tresult := &agent.TokenUsage{}\\n   515→\\tif a != nil {\\n   516→\\t\\tresult.InputTokens = a.InputTokens\\n   517→\\t\\tresult.CacheCreationTokens = a.CacheCreationTokens\\n   518→\\t\\tresult.CacheReadTokens = a.CacheReadTokens\\n   519→\\t\\tresult.OutputTokens = a.OutputTokens\\n   520→\\t\\tresult.APICallCount = a.APICallCount\\n   521→\\t}\\n   522→\\tif b != nil {\\n   523→\\t\\tresult.InputTokens += b.InputTokens\\n   524→\\t\\tresult.CacheCreationTokens += b.CacheCreationTokens\\n   525→\\t\\tresult.CacheReadTokens += b.CacheReadTokens\\n   526→\\t\\tresult.OutputTokens += b.OutputTokens\\n   527→\\t\\tresult.APICallCount += b.APICallCount\\n   528→\\t}\\n   529→\\treturn result\\n   530→}\\n   531→\\n   532→// writeTranscript writes the transcript file from in-memory content or file path.\\n   533→// If the transcript exceeds MaxChunkSize, it's split into multiple chunk files.\\n   534→func (s *GitStore) writeTranscript(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry) error {\\n   535→\\ttranscript := opts.Transcript\\n   536→\\tif len(transcript) == 0 && opts.TranscriptPath != \\\"\\\" {\\n   537→\\t\\tvar readErr error\\n   538→\\t\\ttranscript, readErr = os.ReadFile(opts.TranscriptPath)\\n   539→\\t\\tif readErr != nil {\\n   540→\\t\\t\\t// Non-fatal: transcript may not exist yet\\n   541→\\t\\t\\ttranscript = nil\\n   542→\\t\\t}\\n   543→\\t}\\n   544→\\tif len(transcript) == 0 {\\n   545→\\t\\treturn nil\\n   546→\\t}\\n   547→\\n   548→\\t// Redact secrets before chunking so content hash reflects redacted content\\n   549→\\ttranscript, err := redact.JSONLBytes(transcript)\\n   550→\\tif err != nil {\\n   551→\\t\\treturn fmt.Errorf(\\\"failed to redact transcript secrets: %w\\\", err)\\n   552→\\t}\\n   553→\\n   554→\\t// Chunk the transcript if it's too large\\n   555→\\tchunks, err := agent.ChunkTranscript(transcript, opts.Agent)\\n   556→\\tif err != nil {\\n   557→\\t\\treturn fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n   558→\\t}\\n   559→\\n   560→\\t// Write chunk files\\n   561→\\tfor i, chunk := range chunks {\\n   562→\\t\\tchunkPath := basePath + agent.ChunkFileName(paths.TranscriptFileName, i)\\n   563→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, chunk)\\n   564→\\t\\tif err != nil {\\n   565→\\t\\t\\treturn err\\n   566→\\t\\t}\\n   567→\\t\\tentries[chunkPath] = object.TreeEntry{\\n   568→\\t\\t\\tName: chunkPath,\\n   569→\\t\\t\\tMode: filemode.Regular,\\n   570→\\t\\t\\tHash: blobHash,\\n   571→\\t\\t}\\n   572→\\t}\\n   573→\\n   574→\\t// Content hash for deduplication (hash of full transcript)\\n   575→\\tcontentHash := fmt.Sprintf(\\\"sha256:%x\\\", sha256.Sum256(transcript))\\n   576→\\thashBlob, err := CreateBlobFromContent(s.repo, []byte(contentHash))\\n   577→\\tif err != nil {\\n   578→\\t\\treturn err\\n   579→\\t}\\n   580→\\tentries[basePath+paths.ContentHashFileName] = object.TreeEntry{\\n   581→\\t\\tName: basePath + paths.ContentHashFileName,\\n   582→\\t\\tMode: filemode.Regular,\\n   583→\\t\\tHash: hashBlob,\\n   584→\\t}\\n   585→\\treturn nil\\n   586→}\\n   587→\\n   588→// mergeFilesTouched combines two file lists, removing duplicates.\\n   589→func mergeFilesTouched(existing, additional []string) []string {\\n   590→\\tseen := make(map[string]bool)\\n   591→\\tvar result []string\\n   592→\\n   593→\\tfor _, f := range existing {\\n   594→\\t\\tif !seen[f] {\\n   595→\\t\\t\\tseen[f] = true\\n   596→\\t\\t\\tresult = append(result, f)\\n   597→\\t\\t}\\n   598→\\t}\\n   599→\\tfor _, f := range additional {\\n   600→\\t\\tif !seen[f] {\\n   601→\\t\\t\\tseen[f] = true\\n   602→\\t\\t\\tresult = append(result, f)\\n   603→\\t\\t}\\n   604→\\t}\\n   605→\\n   606→\\tsort.Strings(result)\\n   607→\\treturn result\\n   608→}\\n   609→\\n   610→// redactSummary returns a copy of the summary with text fields redacted.\\n   611→// Structural fields (Path, Line, EndLine) are preserved.\\n   612→// NOTE: When adding new text fields to Summary, LearningsSummary, or CodeLearning,\\n   613→// update this function to include them in redaction.\\n   614→func redactSummary(s *Summary) *Summary {\\n   615→\\tif s == nil {\\n   616→\\t\\treturn nil\\n   617→\\t}\\n   618→\\treturn &Summary{\\n   619→\\t\\tIntent:    redact.String(s.Intent),\\n   620→\\t\\tOutcome:   redact.String(s.Outcome),\\n   621→\\t\\tFriction:  redactStringSlice(s.Friction),\\n   622→\\t\\tOpenItems: redactStringSlice(s.OpenItems),\\n   623→\\t\\tLearnings: LearningsSummary{\\n   624→\\t\\t\\tRepo:     redactStringSlice(s.Learnings.Repo),\\n   625→\\t\\t\\tWorkflow: redactStringSlice(s.Learnings.Workflow),\\n   626→\\t\\t\\tCode:     redactCodeLearnings(s.Learnings.Code),\\n   627→\\t\\t},\\n   628→\\t}\\n   629→}\\n   630→\\n   631→// redactStringSlice applies redact.String to each element.\\n   632→func redactStringSlice(ss []string) []string {\\n   633→\\tif ss == nil {\\n   634→\\t\\treturn nil\\n   635→\\t}\\n   636→\\tout := make([]string, len(ss))\\n   637→\\tfor i, s := range ss {\\n   638→\\t\\tout[i] = redact.String(s)\\n   639→\\t}\\n   640→\\treturn out\\n   641→}\\n   642→\\n   643→// redactCodeLearnings redacts only the Finding field, preserving Path/Line/EndLine.\\n   644→func redactCodeLearnings(cls []CodeLearning) []CodeLearning {\\n   645→\\tif cls == nil {\\n   646→\\t\\treturn nil\\n   647→\\t}\\n   648→\\tout := make([]CodeLearning, len(cls))\\n   649→\\tfor i, cl := range cls {\\n   650→\\t\\tout[i] = CodeLearning{\\n   651→\\t\\t\\tPath:    cl.Path,\\n   652→\\t\\t\\tLine:    cl.Line,\\n   653→\\t\\t\\tEndLine: cl.EndLine,\\n   654→\\t\\t\\tFinding: redact.String(cl.Finding),\\n   655→\\t\\t}\\n   656→\\t}\\n   657→\\treturn out\\n   658→}\\n   659→\\n   660→// readMetadataFromBlob reads CommittedMetadata from a blob hash.\\n   661→func (s *GitStore) readMetadataFromBlob(hash plumbing.Hash) (*CommittedMetadata, error) {\\n   662→\\treturn readJSONFromBlob[CommittedMetadata](s.repo, hash)\\n   663→}\\n   664→\\n   665→// buildCommitMessage constructs the commit message with proper trailers.\\n   666→// The commit subject is always \\\"Checkpoint: <id>\\\" for consistency.\\n   667→// If CommitSubject is provided (e.g., for task checkpoints), it's included in the body.\\n   668→func (s *GitStore) buildCommitMessage(opts WriteCommittedOptions, taskMetadataPath string) string {\\n   669→\\tvar commitMsg strings.Builder\\n   670→\\n   671→\\t// Subject line is always the checkpoint ID for consistent formatting\\n   672→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"Checkpoint: %s\\\\n\\\\n\\\", opts.CheckpointID))\\n   673→\\n   674→\\t// Include custom description in body if provided (e.g., task checkpoint details)\\n   675→\\tif opts.CommitSubject != \\\"\\\" {\\n   676→\\t\\tcommitMsg.WriteString(opts.CommitSubject + \\\"\\\\n\\\\n\\\")\\n   677→\\t}\\n   678→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.SessionTrailerKey, opts.SessionID))\\n   679→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.StrategyTrailerKey, opts.Strategy))\\n   680→\\tif opts.Agent != \\\"\\\" {\\n   681→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.AgentTrailerKey, opts.Agent))\\n   682→\\t}\\n   683→\\tif opts.EphemeralBranch != \\\"\\\" {\\n   684→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.EphemeralBranchTrailerKey, opts.EphemeralBranch))\\n   685→\\t}\\n   686→\\tif taskMetadataPath != \\\"\\\" {\\n   687→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.MetadataTaskTrailerKey, taskMetadataPath))\\n   688→\\t}\\n   689→\\n   690→\\treturn commitMsg.String()\\n   691→}\\n   692→\\n   693→// incrementalCheckpointData represents an incremental checkpoint during subagent execution.\\n   694→// This mirrors strategy.SubagentCheckpoint but avoids import cycles.\\n   695→type incrementalCheckpointData struct {\\n   696→\\tType      string          `json:\\\"type\\\"`\\n   697→\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   698→\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n   699→\\tData      json.RawMessage `json:\\\"data\\\"`\\n   700→}\\n   701→\\n   702→// taskCheckpointData represents a final task checkpoint.\\n   703→// This mirrors strategy.TaskCheckpoint but avoids import cycles.\\n   704→type taskCheckpointData struct {\\n   705→\\tSessionID      string `json:\\\"session_id\\\"`\\n   706→\\tToolUseID      string `json:\\\"tool_use_id\\\"`\\n   707→\\tCheckpointUUID string `json:\\\"checkpoint_uuid\\\"`\\n   708→\\tAgentID        string `json:\\\"agent_id,omitempty\\\"`\\n   709→}\\n   710→\\n   711→// ReadCommitted reads a committed checkpoint's summary by ID from the entire/checkpoints/v1 branch.\\n   712→// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n   713→// Use ReadSessionContent to read actual transcript/prompts/context.\\n   714→// Returns nil, nil if the checkpoint doesn't exist.\\n   715→//\\n   716→// The storage format uses numbered subdirectories for each session (0-based):\\n   717→//\\n   718→//\\t<checkpoint-id>/\\n   719→//\\t├── metadata.json      # CheckpointSummary with sessions map\\n   720→//\\t├── 0/                 # First session\\n   721→//\\t│   ├── metadata.json  # Session-specific metadata\\n   722→//\\t│   └── full.jsonl     # Transcript\\n   723→//\\t├── 1/                 # Second session\\n   724→//\\t└── ...\\n   725→func (s *GitStore) ReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error) {\\n   726→\\t_ = ctx // Reserved for future use\\n   727→\\n   728→\\ttree, err := s.getSessionsBranchTree()\\n   729→\\tif err != nil {\\n   730→\\t\\treturn nil, nil //nolint:nilnil,nilerr // No sessions branch means no checkpoint exists\\n   731→\\t}\\n   732→\\n   733→\\tcheckpointPath := checkpointID.Path()\\n   734→\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n   735→\\tif err != nil {\\n   736→\\t\\treturn nil, nil //nolint:nilnil,nilerr // Checkpoint directory not found\\n   737→\\t}\\n   738→\\n   739→\\t// Read root metadata.json as CheckpointSummary\\n   740→\\tmetadataFile, err := checkpointTree.File(paths.MetadataFileName)\\n   741→\\tif err != nil {\\n   742→\\t\\treturn nil, nil //nolint:nilnil,nilerr // metadata.json not found\\n   743→\\t}\\n   744→\\n   745→\\tcontent, err := metadataFile.Contents()\\n   746→\\tif err != nil {\\n   747→\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata.json: %w\\\", err)\\n   748→\\t}\\n   749→\\n   750→\\tvar summary CheckpointSummary\\n   751→\\tif err := json.Unmarshal([]byte(content), &summary); err != nil {\\n   752→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata.json: %w\\\", err)\\n   753→\\t}\\n   754→\\n   755→\\treturn &summary, nil\\n   756→}\\n   757→\\n   758→// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n   759→// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n   760→// Returns the session's metadata, transcript, prompts, and context.\\n   761→// Returns an error if the checkpoint or session doesn't exist.\\n   762→func (s *GitStore) ReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error) {\\n   763→\\t_ = ctx // Reserved for future use\\n   764→\\n   765→\\ttree, err := s.getSessionsBranchTree()\\n   766→\\tif err != nil {\\n   767→\\t\\treturn nil, ErrCheckpointNotFound\\n   768→\\t}\\n   769→\\n   770→\\tcheckpointPath := checkpointID.Path()\\n   771→\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n   772→\\tif err != nil {\\n   773→\\t\\treturn nil, ErrCheckpointNotFound\\n   774→\\t}\\n   775→\\n   776→\\t// Get the session subdirectory\\n   777→\\tsessionDir := strconv.Itoa(sessionIndex)\\n   778→\\tsessionTree, err := checkpointTree.Tree(sessionDir)\\n   779→\\tif err != nil {\\n   780→\\t\\treturn nil, fmt.Errorf(\\\"session %d not found: %w\\\", sessionIndex, err)\\n   781→\\t}\\n   782→\\n   783→\\tresult := &SessionContent{}\\n   784→\\n   785→\\t// Read session-specific metadata\\n   786→\\tvar agentType agent.AgentType\\n   787→\\tif metadataFile, fileErr := sessionTree.File(paths.MetadataFileName); fileErr == nil {\\n   788→\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n   789→\\t\\t\\tif jsonErr := json.Unmarshal([]byte(content), &result.Metadata); jsonErr == nil {\\n   790→\\t\\t\\t\\tagentType = result.Metadata.Agent\\n   791→\\t\\t\\t}\\n   792→\\t\\t}\\n   793→\\t}\\n   794→\\n   795→\\t// Read transcript\\n   796→\\tif transcript, transcriptErr := readTranscriptFromTree(sessionTree, agentType); transcriptErr == nil && transcript != nil {\\n   797→\\t\\tresult.Transcript = transcript\\n   798→\\t}\\n   799→\\n   800→\\t// Read prompts\\n   801→\\tif file, fileErr := sessionTree.File(paths.PromptFileName); fileErr == nil {\\n   802→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   803→\\t\\t\\tresult.Prompts = content\\n   804→\\t\\t}\\n   805→\\t}\\n   806→\\n   807→\\t// Read context\\n   808→\\tif file, fileErr := sessionTree.File(paths.ContextFileName); fileErr == nil {\\n   809→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   810→\\t\\t\\tresult.Context = content\\n   811→\\t\\t}\\n   812→\\t}\\n   813→\\n   814→\\t// Read export data (optional — only present for agents with non-file storage, e.g., OpenCode)\\n   815→\\tif file, fileErr := sessionTree.File(paths.ExportDataFileName); fileErr == nil {\\n   816→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   817→\\t\\t\\tresult.ExportData = []byte(content)\\n   818→\\t\\t}\\n   819→\\t}\\n   820→\\n   821→\\treturn result, nil\\n   822→}\\n   823→\\n   824→// ReadLatestSessionContent is a convenience method that reads the latest session's content.\\n   825→// This is equivalent to ReadSessionContent(ctx, checkpointID, len(summary.Sessions)-1).\\n   826→func (s *GitStore) ReadLatestSessionContent(ctx context.Context, checkpointID id.CheckpointID) (*SessionContent, error) {\\n   827→\\tsummary, err := s.ReadCommitted(ctx, checkpointID)\\n   828→\\tif err != nil {\\n   829→\\t\\treturn nil, err\\n   830→\\t}\\n   831→\\tif summary == nil {\\n   832→\\t\\treturn nil, ErrCheckpointNotFound\\n   833→\\t}\\n   834→\\tif len(summary.Sessions) == 0 {\\n   835→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint has no sessions: %s\\\", checkpointID)\\n   836→\\t}\\n   837→\\n   838→\\tlatestIndex := len(summary.Sessions) - 1\\n   839→\\treturn s.ReadSessionContent(ctx, checkpointID, latestIndex)\\n   840→}\\n   841→\\n   842→// ReadSessionContentByID reads a session's content by its session ID.\\n   843→// This is useful when you have the session ID but don't know its index within the checkpoint.\\n   844→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   845→// Returns an error if no session with the given ID exists in the checkpoint.\\n   846→func (s *GitStore) ReadSessionContentByID(ctx context.Context, checkpointID id.CheckpointID, sessionID string) (*SessionContent, error) {\\n   847→\\tsummary, err := s.ReadCommitted(ctx, checkpointID)\\n   848→\\tif err != nil {\\n   849→\\t\\treturn nil, err\\n   850→\\t}\\n   851→\\tif summary == nil {\\n   852→\\t\\treturn nil, ErrCheckpointNotFound\\n   853→\\t}\\n   854→\\n   855→\\t// Iterate through sessions to find the one with matching session ID\\n   856→\\tfor i := range len(summary.Sessions) {\\n   857→\\t\\tcontent, readErr := s.ReadSessionContent(ctx, checkpointID, i)\\n   858→\\t\\tif readErr != nil {\\n   859→\\t\\t\\tcontinue\\n   860→\\t\\t}\\n   861→\\t\\tif content != nil && content.Metadata.SessionID == sessionID {\\n   862→\\t\\t\\treturn content, nil\\n   863→\\t\\t}\\n   864→\\t}\\n   865→\\n   866→\\treturn nil, fmt.Errorf(\\\"session %q not found in checkpoint %s\\\", sessionID, checkpointID)\\n   867→}\\n   868→\\n   869→// ListCommitted lists all committed checkpoints from the entire/checkpoints/v1 branch.\\n   870→// Scans sharded paths: <id[:2]>/<id[2:]>/ directories containing metadata.json.\\n   871→//\\n   872→\\n   873→func (s *GitStore) ListCommitted(ctx context.Context) ([]CommittedInfo, error) {\\n   874→\\t_ = ctx // Reserved for future use\\n   875→\\n   876→\\ttree, err := s.getSessionsBranchTree()\\n   877→\\tif err != nil {\\n   878→\\t\\treturn []CommittedInfo{}, nil //nolint:nilerr // No sessions branch means empty list\\n   879→\\t}\\n   880→\\n   881→\\tvar checkpoints []CommittedInfo\\n   882→\\n   883→\\t// Scan sharded structure: <2-char-prefix>/<remaining-id>/metadata.json\\n   884→\\tfor _, bucketEntry := range tree.Entries {\\n   885→\\t\\tif bucketEntry.Mode != filemode.Dir {\\n   886→\\t\\t\\tcontinue\\n   887→\\t\\t}\\n   888→\\t\\t// Bucket should be 2 hex chars\\n   889→\\t\\tif len(bucketEntry.Name) != 2 {\\n   890→\\t\\t\\tcontinue\\n   891→\\t\\t}\\n   892→\\n   893→\\t\\tbucketTree, treeErr := s.repo.TreeObject(bucketEntry.Hash)\\n   894→\\t\\tif treeErr != nil {\\n   895→\\t\\t\\tcontinue\\n   896→\\t\\t}\\n   897→\\n   898→\\t\\t// Each entry in the bucket is the remaining part of the checkpoint ID\\n   899→\\t\\tfor _, checkpointEntry := range bucketTree.Entries {\\n   900→\\t\\t\\tif checkpointEntry.Mode != filemode.Dir {\\n   901→\\t\\t\\t\\tcontinue\\n   902→\\t\\t\\t}\\n   903→\\n   904→\\t\\t\\tcheckpointTree, cpTreeErr := s.repo.TreeObject(checkpointEntry.Hash)\\n   905→\\t\\t\\tif cpTreeErr != nil {\\n   906→\\t\\t\\t\\tcontinue\\n   907→\\t\\t\\t}\\n   908→\\n   909→\\t\\t\\t// Reconstruct checkpoint ID: <bucket><remaining>\\n   910→\\t\\t\\tcheckpointIDStr := bucketEntry.Name + checkpointEntry.Name\\n   911→\\t\\t\\tcheckpointID, cpIDErr := id.NewCheckpointID(checkpointIDStr)\\n   912→\\t\\t\\tif cpIDErr != nil {\\n   913→\\t\\t\\t\\t// Skip invalid checkpoint IDs (shouldn't happen with our own data)\\n   914→\\t\\t\\t\\tcontinue\\n   915→\\t\\t\\t}\\n   916→\\n   917→\\t\\t\\tinfo := CommittedInfo{\\n   918→\\t\\t\\t\\tCheckpointID: checkpointID,\\n   919→\\t\\t\\t}\\n   920→\\n   921→\\t\\t\\t// Get details from root metadata file (CheckpointSummary format)\\n   922→\\t\\t\\tif metadataFile, fileErr := checkpointTree.File(paths.MetadataFileName); fileErr == nil {\\n   923→\\t\\t\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n   924→\\t\\t\\t\\t\\tvar summary CheckpointSummary\\n   925→\\t\\t\\t\\t\\tif err := json.Unmarshal([]byte(content), &summary); err == nil {\\n   926→\\t\\t\\t\\t\\t\\tinfo.CheckpointsCount = summary.CheckpointsCount\\n   927→\\t\\t\\t\\t\\t\\tinfo.FilesTouched = summary.FilesTouched\\n   928→\\t\\t\\t\\t\\t\\tinfo.SessionCount = len(summary.Sessions)\\n   929→\\n   930→\\t\\t\\t\\t\\t\\t// Read session metadata from latest session to get Agent, SessionID, CreatedAt\\n   931→\\t\\t\\t\\t\\t\\tif len(summary.Sessions) > 0 {\\n   932→\\t\\t\\t\\t\\t\\t\\tlatestIndex := len(summary.Sessions) - 1\\n   933→\\t\\t\\t\\t\\t\\t\\tlatestDir := strconv.Itoa(latestIndex)\\n   934→\\t\\t\\t\\t\\t\\t\\tif sessionTree, treeErr := checkpointTree.Tree(latestDir); treeErr == nil {\\n   935→\\t\\t\\t\\t\\t\\t\\t\\tif sessionMetadataFile, smErr := sessionTree.File(paths.MetadataFileName); smErr == nil {\\n   936→\\t\\t\\t\\t\\t\\t\\t\\t\\tif sessionContent, scErr := sessionMetadataFile.Contents(); scErr == nil {\\n   937→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata CommittedMetadata\\n   938→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   939→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   940→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   941→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   942→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   943→\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   944→\\t\\t\\t\\t\\t\\t\\t\\t}\\n   945→\\t\\t\\t\\t\\t\\t\\t}\\n   946→\\t\\t\\t\\t\\t\\t}\\n   947→\\t\\t\\t\\t\\t}\\n   948→\\t\\t\\t\\t}\\n   949→\\t\\t\\t}\\n   950→\\n   951→\\t\\t\\tcheckpoints = append(checkpoints, info)\\n   952→\\t\\t}\\n   953→\\t}\\n   954→\\n   955→\\t// Sort by time (most recent first)\\n   956→\\tsort.Slice(checkpoints, func(i, j int) bool {\\n   957→\\t\\treturn checkpoints[i].CreatedAt.After(checkpoints[j].CreatedAt)\\n   958→\\t})\\n   959→\\n   960→\\treturn checkpoints, nil\\n   961→}\\n   962→\\n   963→// GetTranscript retrieves the transcript for a specific checkpoint ID.\\n   964→// Returns the latest session's transcript.\\n   965→func (s *GitStore) GetTranscript(ctx context.Context, checkpointID id.CheckpointID) ([]byte, error) {\\n   966→\\tcontent, err := s.ReadLatestSessionContent(ctx, checkpointID)\\n   967→\\tif err != nil {\\n   968→\\t\\treturn nil, err\\n   969→\\t}\\n   970→\\tif len(content.Transcript) == 0 {\\n   971→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   972→\\t}\\n   973→\\treturn content.Transcript, nil\\n   974→}\\n   975→\\n   976→// GetSessionLog retrieves the session transcript, session ID, and export data for a checkpoint.\\n   977→// This is the primary method for looking up session logs by checkpoint ID.\\n   978→// The export data is optional — only present for agents with non-file storage (e.g., OpenCode).\\n   979→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   980→// Returns ErrNoTranscript if the checkpoint exists but has no transcript.\\n   981→func (s *GitStore) GetSessionLog(cpID id.CheckpointID) ([]byte, string, []byte, error) {\\n   982→\\tcontent, err := s.ReadLatestSessionContent(context.Background(), cpID)\\n   983→\\tif err != nil {\\n   984→\\t\\tif errors.Is(err, ErrCheckpointNotFound) {\\n   985→\\t\\t\\treturn nil, \\\"\\\", nil, ErrCheckpointNotFound\\n   986→\\t\\t}\\n   987→\\t\\treturn nil, \\\"\\\", nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   988→\\t}\\n   989→\\tif len(content.Transcript) == 0 {\\n   990→\\t\\treturn nil, \\\"\\\", nil, ErrNoTranscript\\n   991→\\t}\\n   992→\\treturn content.Transcript, content.Metadata.SessionID, content.ExportData, nil\\n   993→}\\n   994→\\n   995→// LookupSessionLog is a convenience function that opens the repository and retrieves\\n   996→// a session log by checkpoint ID. This is the primary entry point for callers that\\n   997→// don't already have a GitStore instance.\\n   998→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   999→// Returns ErrNoTranscript if the checkpoint exists but has no transcript.\\n  1000→func LookupSessionLog(cpID id.CheckpointID) ([]byte, string, []byte, error) {\\n  1001→\\trepo, err := git.PlainOpenWithOptions(\\\".\\\", &git.PlainOpenOptions{DetectDotGit: true})\\n  1002→\\tif err != nil {\\n  1003→\\t\\treturn nil, \\\"\\\", nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n  1004→\\t}\\n  1005→\\tstore := NewGitStore(repo)\\n  1006→\\treturn store.GetSessionLog(cpID)\\n  1007→}\\n  1008→\\n  1009→// UpdateSummary updates the summary field in the latest session's metadata.\\n  1010→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n  1011→func (s *GitStore) UpdateSummary(ctx context.Context, checkpointID id.CheckpointID, summary *Summary) error {\\n  1012→\\t_ = ctx // Reserved for future use\\n  1013→\\n  1014→\\t// Ensure sessions branch exists\\n  1015→\\tif err := s.ensureSessionsBranch(); err != nil {\\n  1016→\\t\\treturn fmt.Errorf(\\\"failed to ensure sessions branch: %w\\\", err)\\n  1017→\\t}\\n  1018→\\n  1019→\\t// Get current branch tip and flatten tree\\n  1020→\\tref, entries, err := s.getSessionsBranchEntries()\\n  1021→\\tif err != nil {\\n  1022→\\t\\treturn err\\n  1023→\\t}\\n  1024→\\n  1025→\\t// Read root CheckpointSummary to find the latest session\\n  1026→\\tbasePath := checkpointID.Path() + \\\"/\\\"\\n  1027→\\trootMetadataPath := basePath + paths.MetadataFileName\\n  1028→\\tentry, exists := entries[rootMetadataPath]\\n  1029→\\tif !exists {\\n  1030→\\t\\treturn ErrCheckpointNotFound\\n  1031→\\t}\\n  1032→\\n  1033→\\tcheckpointSummary, err := s.readSummaryFromBlob(entry.Hash)\\n  1034→\\tif err != nil {\\n  1035→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint summary: %w\\\", err)\\n  1036→\\t}\\n  1037→\\n  1038→\\t// Find the latest session's metadata path (0-based indexing)\\n  1039→\\tlatestIndex := len(checkpointSummary.Sessions) - 1\\n  1040→\\tsessionMetadataPath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, latestIndex, paths.MetadataFileName)\\n  1041→\\tsessionEntry, exists := entries[sessionMetadataPath]\\n  1042→\\tif !exists {\\n  1043→\\t\\treturn fmt.Errorf(\\\"session metadata not found at %s\\\", sessionMetadataPath)\\n  1044→\\t}\\n  1045→\\n  1046→\\t// Read and update session metadata\\n  1047→\\texistingMetadata, err := s.readMetadataFromBlob(sessionEntry.Hash)\\n  1048→\\tif err != nil {\\n  1049→\\t\\treturn fmt.Errorf(\\\"failed to read session metadata: %w\\\", err)\\n  1050→\\t}\\n  1051→\\n  1052→\\t// Update the summary\\n  1053→\\texistingMetadata.Summary = redactSummary(summary)\\n  1054→\\n  1055→\\t// Write updated session metadata\\n  1056→\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(existingMetadata, \\\"\\\", \\\"  \\\")\\n  1057→\\tif err != nil {\\n  1058→\\t\\treturn fmt.Errorf(\\\"failed to marshal metadata: %w\\\", err)\\n  1059→\\t}\\n  1060→\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n  1061→\\tif err != nil {\\n  1062→\\t\\treturn fmt.Errorf(\\\"failed to create metadata blob: %w\\\", err)\\n  1063→\\t}\\n  1064→\\tentries[sessionMetadataPath] = object.TreeEntry{\\n  1065→\\t\\tName: sessionMetadataPath,\\n  1066→\\t\\tMode: filemode.Regular,\\n  1067→\\t\\tHash: metadataHash,\\n  1068→\\t}\\n  1069→\\n  1070→\\t// Build and commit\\n  1071→\\tnewTreeHash, err := BuildTreeFromEntries(s.repo, entries)\\n  1072→\\tif err != nil {\\n  1073→\\t\\treturn err\\n  1074→\\t}\\n  1075→\\n  1076→\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n  1077→\\tcommitMsg := fmt.Sprintf(\\\"Update summary for checkpoint %s (session: %s)\\\", checkpointID, existingMetadata.SessionID)\\n  1078→\\tnewCommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, authorName, authorEmail)\\n  1079→\\tif err != nil {\\n  1080→\\t\\treturn err\\n  1081→\\t}\\n  1082→\\n  1083→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1084→\\tnewRef := plumbing.NewHashReference(refName, newCommitHash)\\n  1085→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1086→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1087→\\t}\\n  1088→\\n  1089→\\treturn nil\\n  1090→}\\n  1091→\\n  1092→// UpdateCommitted replaces the transcript, prompts, and context for an existing\\n  1093→// committed checkpoint. Uses replace semantics: the full session transcript is\\n  1094→// written, replacing whatever was stored at initial condensation time.\\n  1095→//\\n  1096→// This is called at stop time to finalize all checkpoints from the current turn\\n  1097→// with the complete session transcript (from prompt to stop event).\\n  1098→//\\n  1099→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n  1100→func (s *GitStore) UpdateCommitted(ctx context.Context, opts UpdateCommittedOptions) error {\\n  1101→\\tif opts.CheckpointID.IsEmpty() {\\n  1102→\\t\\treturn errors.New(\\\"invalid update options: checkpoint ID is required\\\")\\n  1103→\\t}\\n  1104→\\n  1105→\\t// Ensure sessions branch exists\\n  1106→\\tif err := s.ensureSessionsBranch(); err != nil {\\n  1107→\\t\\treturn fmt.Errorf(\\\"failed to ensure sessions branch: %w\\\", err)\\n  1108→\\t}\\n  1109→\\n  1110→\\t// Get current branch tip and flatten tree\\n  1111→\\tref, entries, err := s.getSessionsBranchEntries()\\n  1112→\\tif err != nil {\\n  1113→\\t\\treturn err\\n  1114→\\t}\\n  1115→\\n  1116→\\t// Read root CheckpointSummary to find the session slot\\n  1117→\\tbasePath := opts.CheckpointID.Path() + \\\"/\\\"\\n  1118→\\trootMetadataPath := basePath + paths.MetadataFileName\\n  1119→\\tentry, exists := entries[rootMetadataPath]\\n  1120→\\tif !exists {\\n  1121→\\t\\treturn ErrCheckpointNotFound\\n  1122→\\t}\\n  1123→\\n  1124→\\tcheckpointSummary, err := s.readSummaryFromBlob(entry.Hash)\\n  1125→\\tif err != nil {\\n  1126→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint summary: %w\\\", err)\\n  1127→\\t}\\n  1128→\\tif len(checkpointSummary.Sessions) == 0 {\\n  1129→\\t\\treturn ErrCheckpointNotFound\\n  1130→\\t}\\n  1131→\\n  1132→\\t// Find session index matching opts.SessionID\\n  1133→\\tsessionIndex := -1\\n  1134→\\tfor i := range len(checkpointSummary.Sessions) {\\n  1135→\\t\\tmetaPath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n  1136→\\t\\tif metaEntry, metaExists := entries[metaPath]; metaExists {\\n  1137→\\t\\t\\tmeta, metaErr := s.readMetadataFromBlob(metaEntry.Hash)\\n  1138→\\t\\t\\tif metaErr == nil && meta.SessionID == opts.SessionID {\\n  1139→\\t\\t\\t\\tsessionIndex = i\\n  1140→\\t\\t\\t\\tbreak\\n  1141→\\t\\t\\t}\\n  1142→\\t\\t}\\n  1143→\\t}\\n  1144→\\tif sessionIndex == -1 {\\n  1145→\\t\\t// Fall back to latest session; log so mismatches are diagnosable.\\n  1146→\\t\\tsessionIndex = len(checkpointSummary.Sessions) - 1\\n  1147→\\t\\tlogging.Debug(ctx, \\\"UpdateCommitted: session ID not found, falling back to latest\\\",\\n  1148→\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n  1149→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", string(opts.CheckpointID)),\\n  1150→\\t\\t\\tslog.Int(\\\"fallback_index\\\", sessionIndex),\\n  1151→\\t\\t)\\n  1152→\\t}\\n  1153→\\n  1154→\\tsessionPath := fmt.Sprintf(\\\"%s%d/\\\", basePath, sessionIndex)\\n  1155→\\n  1156→\\t// Replace transcript (full replace, not append)\\n  1157→\\t// Apply redaction as safety net (caller should redact, but we ensure it here)\\n  1158→\\tif len(opts.Transcript) > 0 {\\n  1159→\\t\\ttranscript, err := redact.JSONLBytes(opts.Transcript)\\n  1160→\\t\\tif err != nil {\\n  1161→\\t\\t\\treturn fmt.Errorf(\\\"failed to redact transcript secrets: %w\\\", err)\\n  1162→\\t\\t}\\n  1163→\\t\\tif err := s.replaceTranscript(transcript, opts.Agent, sessionPath, entries); err != nil {\\n  1164→\\t\\t\\treturn fmt.Errorf(\\\"failed to replace transcript: %w\\\", err)\\n  1165→\\t\\t}\\n  1166→\\t}\\n  1167→\\n  1168→\\t// Replace prompts (apply redaction as safety net)\\n  1169→\\tif len(opts.Prompts) > 0 {\\n  1170→\\t\\tpromptContent := redact.String(strings.Join(opts.Prompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\"))\\n  1171→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(promptContent))\\n  1172→\\t\\tif err != nil {\\n  1173→\\t\\t\\treturn fmt.Errorf(\\\"failed to create prompt blob: %w\\\", err)\\n  1174→\\t\\t}\\n  1175→\\t\\tentries[sessionPath+paths.PromptFileName] = object.TreeEntry{\\n  1176→\\t\\t\\tName: sessionPath + paths.PromptFileName,\\n  1177→\\t\\t\\tMode: filemode.Regular,\\n  1178→\\t\\t\\tHash: blobHash,\\n  1179→\\t\\t}\\n  1180→\\t}\\n  1181→\\n  1182→\\t// Replace context (apply redaction as safety net)\\n  1183→\\tif len(opts.Context) > 0 {\\n  1184→\\t\\tcontextBlob, err := CreateBlobFromContent(s.repo, redact.Bytes(opts.Context))\\n  1185→\\t\\tif err != nil {\\n  1186→\\t\\t\\treturn fmt.Errorf(\\\"failed to create context blob: %w\\\", err)\\n  1187→\\t\\t}\\n  1188→\\t\\tentries[sessionPath+paths.ContextFileName] = object.TreeEntry{\\n  1189→\\t\\t\\tName: sessionPath + paths.ContextFileName,\\n  1190→\\t\\t\\tMode: filemode.Regular,\\n  1191→\\t\\t\\tHash: contextBlob,\\n  1192→\\t\\t}\\n  1193→\\t}\\n  1194→\\n  1195→\\t// Build and commit\\n  1196→\\tnewTreeHash, err := BuildTreeFromEntries(s.repo, entries)\\n  1197→\\tif err != nil {\\n  1198→\\t\\treturn err\\n  1199→\\t}\\n  1200→\\n  1201→\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n  1202→\\tcommitMsg := fmt.Sprintf(\\\"Finalize transcript for Checkpoint: %s\\\", opts.CheckpointID)\\n  1203→\\tnewCommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, authorName, authorEmail)\\n  1204→\\tif err != nil {\\n  1205→\\t\\treturn err\\n  1206→\\t}\\n  1207→\\n  1208→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1209→\\tnewRef := plumbing.NewHashReference(refName, newCommitHash)\\n  1210→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1211→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1212→\\t}\\n  1213→\\n  1214→\\treturn nil\\n  1215→}\\n  1216→\\n  1217→// replaceTranscript writes the full transcript content, replacing any existing transcript.\\n  1218→// Also removes any chunk files from a previous write and updates the content hash.\\n  1219→func (s *GitStore) replaceTranscript(transcript []byte, agentType agent.AgentType, sessionPath string, entries map[string]object.TreeEntry) error {\\n  1220→\\t// Remove existing transcript files (base + any chunks)\\n  1221→\\ttranscriptBase := sessionPath + paths.TranscriptFileName\\n  1222→\\tfor key := range entries {\\n  1223→\\t\\tif key == transcriptBase || strings.HasPrefix(key, transcriptBase+\\\".\\\") {\\n  1224→\\t\\t\\tdelete(entries, key)\\n  1225→\\t\\t}\\n  1226→\\t}\\n  1227→\\n  1228→\\t// Chunk the transcript (matches writeTranscript behavior)\\n  1229→\\tchunks, err := agent.ChunkTranscript(transcript, agentType)\\n  1230→\\tif err != nil {\\n  1231→\\t\\treturn fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n  1232→\\t}\\n  1233→\\n  1234→\\t// Write chunk files\\n  1235→\\tfor i, chunk := range chunks {\\n  1236→\\t\\tchunkPath := sessionPath + agent.ChunkFileName(paths.TranscriptFileName, i)\\n  1237→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, chunk)\\n  1238→\\t\\tif err != nil {\\n  1239→\\t\\t\\treturn fmt.Errorf(\\\"failed to create transcript blob: %w\\\", err)\\n  1240→\\t\\t}\\n  1241→\\t\\tentries[chunkPath] = object.TreeEntry{\\n  1242→\\t\\t\\tName: chunkPath,\\n  1243→\\t\\t\\tMode: filemode.Regular,\\n  1244→\\t\\t\\tHash: blobHash,\\n  1245→\\t\\t}\\n  1246→\\t}\\n  1247→\\n  1248→\\t// Update content hash\\n  1249→\\tcontentHash := fmt.Sprintf(\\\"sha256:%x\\\", sha256.Sum256(transcript))\\n  1250→\\thashBlob, err := CreateBlobFromContent(s.repo, []byte(contentHash))\\n  1251→\\tif err != nil {\\n  1252→\\t\\treturn fmt.Errorf(\\\"failed to create content hash blob: %w\\\", err)\\n  1253→\\t}\\n  1254→\\thashPath := sessionPath + paths.ContentHashFileName\\n  1255→\\tentries[hashPath] = object.TreeEntry{\\n  1256→\\t\\tName: hashPath,\\n  1257→\\t\\tMode: filemode.Regular,\\n  1258→\\t\\tHash: hashBlob,\\n  1259→\\t}\\n  1260→\\n  1261→\\treturn nil\\n  1262→}\\n  1263→\\n  1264→// ensureSessionsBranch ensures the entire/checkpoints/v1 branch exists.\\n  1265→func (s *GitStore) ensureSessionsBranch() error {\\n  1266→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1267→\\t_, err := s.repo.Reference(refName, true)\\n  1268→\\tif err == nil {\\n  1269→\\t\\treturn nil // Branch exists\\n  1270→\\t}\\n  1271→\\n  1272→\\t// Create orphan branch with empty tree\\n  1273→\\temptyTreeHash, err := BuildTreeFromEntries(s.repo, make(map[string]object.TreeEntry))\\n  1274→\\tif err != nil {\\n  1275→\\t\\treturn err\\n  1276→\\t}\\n  1277→\\n  1278→\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n  1279→\\tcommitHash, err := s.createCommit(emptyTreeHash, plumbing.ZeroHash, \\\"Initialize sessions branch\\\", authorName, authorEmail)\\n  1280→\\tif err != nil {\\n  1281→\\t\\treturn err\\n  1282→\\t}\\n  1283→\\n  1284→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n  1285→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1286→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1287→\\t}\\n  1288→\\treturn nil\\n  1289→}\\n  1290→\\n  1291→// getSessionsBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\n  1292→// Falls back to origin/entire/checkpoints/v1 if the local branch doesn't exist.\\n  1293→func (s *GitStore) getSessionsBranchTree() (*object.Tree, error) {\\n  1294→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1295→\\tref, err := s.repo.Reference(refName, true)\\n  1296→\\tif err != nil {\\n  1297→\\t\\t// Local branch doesn't exist, try remote-tracking branch\\n  1298→\\t\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n  1299→\\t\\tref, err = s.repo.Reference(remoteRefName, true)\\n  1300→\\t\\tif err != nil {\\n  1301→\\t\\t\\treturn nil, fmt.Errorf(\\\"sessions branch not found: %w\\\", err)\\n  1302→\\t\\t}\\n  1303→\\t}\\n  1304→\\n  1305→\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n  1306→\\tif err != nil {\\n  1307→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n  1308→\\t}\\n  1309→\\n  1310→\\ttree, err := commit.Tree()\\n  1311→\\tif err != nil {\\n  1312→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n  1313→\\t}\\n  1314→\\n  1315→\\treturn tree, nil\\n  1316→}\\n  1317→\\n  1318→// CreateBlobFromContent creates a blob object from in-memory content.\\n  1319→// Exported for use by strategy package (session_test.go)\\n  1320→func CreateBlobFromContent(repo *git.Repository, content []byte) (plumbing.Hash, error) {\\n  1321→\\tobj := repo.Storer.NewEncodedObject()\\n  1322→\\tobj.SetType(plumbing.BlobObject)\\n  1323→\\tobj.SetSize(int64(len(content)))\\n  1324→\\n  1325→\\twriter, err := obj.Writer()\\n  1326→\\tif err != nil {\\n  1327→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get object writer: %w\\\", err)\\n  1328→\\t}\\n  1329→\\n  1330→\\t_, err = writer.Write(content)\\n  1331→\\tif err != nil {\\n  1332→\\t\\t_ = writer.Close()\\n  1333→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write blob content: %w\\\", err)\\n  1334→\\t}\\n  1335→\\tif err := writer.Close(); err != nil {\\n  1336→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to close blob writer: %w\\\", err)\\n  1337→\\t}\\n  1338→\\n  1339→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n  1340→\\tif err != nil {\\n  1341→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store blob object: %w\\\", err)\\n  1342→\\t}\\n  1343→\\treturn hash, nil\\n  1344→}\\n  1345→\\n  1346→// copyMetadataDir copies all files from a directory to the checkpoint path.\\n  1347→// Used to include additional metadata files like task checkpoints, subagent transcripts, etc.\\n  1348→func (s *GitStore) copyMetadataDir(metadataDir, basePath string, entries map[string]object.TreeEntry) error {\\n  1349→\\terr := filepath.Walk(metadataDir, func(path string, info os.FileInfo, err error) error {\\n  1350→\\t\\tif err != nil {\\n  1351→\\t\\t\\treturn err\\n  1352→\\t\\t}\\n  1353→\\n  1354→\\t\\t// Skip symlinks to prevent reading files outside the metadata directory.\\n  1355→\\t\\t// A symlink could point to sensitive files (e.g., /etc/passwd) which would\\n  1356→\\t\\t// then be captured in the checkpoint and stored in git history.\\n  1357→\\t\\t// NOTE: filepath.Walk uses os.Stat (follows symlinks), so info.Mode() never\\n  1358→\\t\\t// reports ModeSymlink. We use os.Lstat to check the entry itself.\\n  1359→\\t\\t// This check MUST come before IsDir() because Walk follows symlinked\\n  1360→\\t\\t// directories and would recurse into them otherwise.\\n  1361→\\t\\tlinfo, lstatErr := os.Lstat(path)\\n  1362→\\t\\tif lstatErr != nil {\\n  1363→\\t\\t\\treturn fmt.Errorf(\\\"failed to lstat %s: %w\\\", path, lstatErr)\\n  1364→\\t\\t}\\n  1365→\\t\\tif linfo.Mode()&os.ModeSymlink != 0 {\\n  1366→\\t\\t\\tif info.IsDir() {\\n  1367→\\t\\t\\t\\treturn filepath.SkipDir\\n  1368→\\t\\t\\t}\\n  1369→\\t\\t\\treturn nil\\n  1370→\\t\\t}\\n  1371→\\n  1372→\\t\\tif info.IsDir() {\\n  1373→\\t\\t\\treturn nil\\n  1374→\\t\\t}\\n  1375→\\n  1376→\\t\\t// Get relative path within metadata dir\\n  1377→\\t\\trelPath, err := filepath.Rel(metadataDir, path)\\n  1378→\\t\\tif err != nil {\\n  1379→\\t\\t\\treturn fmt.Errorf(\\\"failed to get relative path for %s: %w\\\", path, err)\\n  1380→\\t\\t}\\n  1381→\\n  1382→\\t\\t// Prevent path traversal via symlinks pointing outside the metadata dir\\n  1383→\\t\\tif strings.HasPrefix(relPath, \\\"..\\\") {\\n  1384→\\t\\t\\treturn fmt.Errorf(\\\"path traversal detected: %s\\\", relPath)\\n  1385→\\t\\t}\\n  1386→\\n  1387→\\t\\t// Create blob from file with secrets redaction\\n  1388→\\t\\tblobHash, mode, err := createRedactedBlobFromFile(s.repo, path, relPath)\\n  1389→\\t\\tif err != nil {\\n  1390→\\t\\t\\treturn fmt.Errorf(\\\"failed to create blob for %s: %w\\\", path, err)\\n  1391→\\t\\t}\\n  1392→\\n  1393→\\t\\t// Store at checkpoint path (use forward slashes for git tree compatibility on Windows)\\n  1394→\\t\\tfullPath := basePath + filepath.ToSlash(relPath)\\n  1395→\\t\\tentries[fullPath] = object.TreeEntry{\\n  1396→\\t\\t\\tName: fullPath,\\n  1397→\\t\\t\\tMode: mode,\\n  1398→\\t\\t\\tHash: blobHash,\\n  1399→\\t\\t}\\n  1400→\\n  1401→\\t\\treturn nil\\n  1402→\\t})\\n  1403→\\tif err != nil {\\n  1404→\\t\\treturn fmt.Errorf(\\\"failed to walk metadata directory: %w\\\", err)\\n  1405→\\t}\\n  1406→\\treturn nil\\n  1407→}\\n  1408→\\n  1409→// createRedactedBlobFromFile reads a file, applies secrets redaction, and creates a git blob.\\n  1410→// JSONL files get JSONL-aware redaction; all other files get plain string redaction.\\n  1411→func createRedactedBlobFromFile(repo *git.Repository, filePath, treePath string) (plumbing.Hash, filemode.FileMode, error) {\\n  1412→\\tinfo, err := os.Stat(filePath)\\n  1413→\\tif err != nil {\\n  1414→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to stat file: %w\\\", err)\\n  1415→\\t}\\n  1416→\\n  1417→\\tmode := filemode.Regular\\n  1418→\\tif info.Mode()&0o111 != 0 {\\n  1419→\\t\\tmode = filemode.Executable\\n  1420→\\t}\\n  1421→\\n  1422→\\tcontent, err := os.ReadFile(filePath) //nolint:gosec // filePath comes from walking the metadata directory\\n  1423→\\tif err != nil {\\n  1424→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to read file: %w\\\", err)\\n  1425→\\t}\\n  1426→\\n  1427→\\t// Skip redaction for binary files — they can't contain text secrets and\\n  1428→\\t// running string replacement on them would corrupt the data.\\n  1429→\\tisBin, binErr := binary.IsBinary(bytes.NewReader(content))\\n  1430→\\tif binErr != nil || isBin {\\n  1431→\\t\\thash, err := CreateBlobFromContent(repo, content)\\n  1432→\\t\\tif err != nil {\\n  1433→\\t\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to create blob: %w\\\", err)\\n  1434→\\t\\t}\\n  1435→\\t\\treturn hash, mode, nil\\n  1436→\\t}\\n  1437→\\n  1438→\\tif strings.HasSuffix(treePath, \\\".jsonl\\\") {\\n  1439→\\t\\tredacted, jsonlErr := redact.JSONLBytes(content)\\n  1440→\\t\\tif jsonlErr != nil {\\n  1441→\\t\\t\\tredacted = redact.Bytes(content)\\n  1442→\\t\\t}\\n  1443→\\t\\tcontent = redacted\\n  1444→\\t} else {\\n  1445→\\t\\tcontent = redact.Bytes(content)\\n  1446→\\t}\\n  1447→\\n  1448→\\thash, err := CreateBlobFromContent(repo, content)\\n  1449→\\tif err != nil {\\n  1450→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to create blob: %w\\\", err)\\n  1451→\\t}\\n  1452→\\treturn hash, mode, nil\\n  1453→}\\n  1454→\\n  1455→// GetGitAuthorFromRepo retrieves the git user.name and user.email,\\n  1456→// checking both the repository-local config and the global ~/.gitconfig.\\n  1457→func GetGitAuthorFromRepo(repo *git.Repository) (name, email string) {\\n  1458→\\t// Get repository config (includes local settings)\\n  1459→\\tcfg, err := repo.Config()\\n  1460→\\tif err == nil {\\n  1461→\\t\\tname = cfg.User.Name\\n  1462→\\t\\temail = cfg.User.Email\\n  1463→\\t}\\n  1464→\\n  1465→\\t// If not found in local config, try global config\\n  1466→\\tif name == \\\"\\\" || email == \\\"\\\" {\\n  1467→\\t\\tglobalCfg, err := config.LoadConfig(config.GlobalScope)\\n  1468→\\t\\tif err == nil {\\n  1469→\\t\\t\\tif name == \\\"\\\" {\\n  1470→\\t\\t\\t\\tname = globalCfg.User.Name\\n  1471→\\t\\t\\t}\\n  1472→\\t\\t\\tif email == \\\"\\\" {\\n  1473→\\t\\t\\t\\temail = globalCfg.User.Email\\n  1474→\\t\\t\\t}\\n  1475→\\t\\t}\\n  1476→\\t}\\n  1477→\\n  1478→\\t// Provide sensible defaults if git user is not configured\\n  1479→\\tif name == \\\"\\\" {\\n  1480→\\t\\tname = \\\"Unknown\\\"\\n  1481→\\t}\\n  1482→\\tif email == \\\"\\\" {\\n  1483→\\t\\temail = \\\"unknown@local\\\"\\n  1484→\\t}\\n  1485→\\n  1486→\\treturn name, email\\n  1487→}\\n  1488→\\n  1489→// readTranscriptFromTree reads a transcript from a git tree, handling both chunked and non-chunked formats.\\n  1490→// It checks for chunk files first (.001, .002, etc.), then falls back to the base file.\\n  1491→// The agentType is used for reassembling chunks in the correct format.\\n  1492→func readTranscriptFromTree(tree *object.Tree, agentType agent.AgentType) ([]byte, error) {\\n  1493→\\t// Collect all transcript-related files\\n  1494→\\tvar chunkFiles []string\\n  1495→\\tvar hasBaseFile bool\\n  1496→\\n  1497→\\tfor _, entry := range tree.Entries {\\n  1498→\\t\\tif entry.Name == paths.TranscriptFileName || entry.Name == paths.TranscriptFileNameLegacy {\\n  1499→\\t\\t\\thasBaseFile = true\\n  1500→\\t\\t}\\n  1501→\\t\\t// Check for chunk files (full.jsonl.001, full.jsonl.002, etc.)\\n  1502→\\t\\tif strings.HasPrefix(entry.Name, paths.TranscriptFileName+\\\".\\\") {\\n  1503→\\t\\t\\tidx := agent.ParseChunkIndex(entry.Name, paths.TranscriptFileName)\\n  1504→\\t\\t\\tif idx > 0 {\\n  1505→\\t\\t\\t\\tchunkFiles = append(chunkFiles, entry.Name)\\n  1506→\\t\\t\\t}\\n  1507→\\t\\t}\\n  1508→\\t}\\n  1509→\\n  1510→\\t// If we have chunk files, read and reassemble them\\n  1511→\\tif len(chunkFiles) > 0 {\\n  1512→\\t\\t// Sort chunk files by index\\n  1513→\\t\\tchunkFiles = agent.SortChunkFiles(chunkFiles, paths.TranscriptFileName)\\n  1514→\\n  1515→\\t\\t// Check if base file should be included as chunk 0.\