ises the full checkpoint/hook lifecycle without\\n     3→// real API calls. Named after the Vogons from The Hitchhiker's Guide to the\\n     4→// Galaxy — bureaucratic, procedural, and deterministic to a fault.\\n     5→package vogon\\n     6→\\n     7→import (\\n     8→\\t\\\"context\\\"\\n     9→\\t\\\"errors\\\"\\n    10→\\t\\\"fmt\\\"\\n    11→\\t\\\"os\\\"\\n    12→\\t\\\"path/filepath\\\"\\n    13→\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    16→)\\n    17→\\n    18→//nolint:gochecknoinits // Agent self-registration is the intended pattern\\n    19→func init() {\\n    20→\\tagent.Register(AgentNameVogon, NewAgent)\\n    21→}\\n    22→\\n    23→const (\\n    24→\\t// AgentNameVogon is the registry key for the vogon agent.\\n    25→\\tAgentNameVogon types.AgentName = \\\"vogon\\\"\\n    26→\\t// AgentTypeVogon is the type identifier stored in metadata.\\n    27→\\tAgentTypeVogon types.AgentType = \\\"Vogon Agent\\\"\\n    28→)\\n    29→\\n    30→// Agent implements agent.Agent and agent.HookSupport for E2E canary tests.\\n    31→type Agent struct{}\\n    32→\\n    33→// NewAgent creates a new vogon agent instance.\\n    34→func NewAgent() agent.Agent { return &Agent{} }\\n    35→\\n    36→func (v *Agent) Name() types.AgentName { return AgentNameVogon }\\n    37→func (v *Agent) Type() types.AgentType { return AgentTypeVogon }\\n    38→func (v *Agent) Description() string {\\n    39→\\treturn \\\"Vogon Agent - deterministic E2E canary (no API calls)\\\"\\n    40→}\\n    41→func (v *Agent) IsPreview() bool         { return false }\\n    42→func (v *Agent) ProtectedDirs() []string { return []string{\\\".vogon\\\"} }\\n    43→\\n    44→// DetectPresence returns false — vogon agent is never auto-detected.\\n    45→func (v *Agent) DetectPresence(_ context.Context) (bool, error) { return false, nil }\\n    46→\\n    47→// IsTestOnly marks this agent as test-only, excluding it from `entire enable`.\\n    48→func (v *Agent) IsTestOnly() bool { return true }\\n    49→\\n    50→// --- Transcript Storage ---\\n    51→\\n    52→func (v *Agent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    53→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from hook input\\n    54→\\tif err != nil {\\n    55→\\t\\treturn nil, fmt.Errorf(\\\"read transcript: %w\\\", err)\\n    56→\\t}\\n    57→\\treturn data, nil\\n    58→}\\n    59→\\n    60→func (v *Agent) ChunkTranscript(_ context.Context, content []byte, maxSize int) ([][]byte, error) {\\n    61→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    62→\\tif err != nil {\\n    63→\\t\\treturn nil, fmt.Errorf(\\\"chunk transcript: %w\\\", err)\\n    64→\\t}\\n    65→\\treturn chunks, nil\\n    66→}\\n    67→\\n    68→func (v *Agent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    69→\\treturn agent.ReassembleJSONL(chunks), nil\\n    70→}\\n    71→\\n    72→// --- Legacy Session Methods ---\\n    73→\\n    74→func (v *Agent) GetSessionID(input *agent.HookInput) string { return input.SessionID }\\n    75→\\n    76→func (v *Agent) GetSessionDir(_ string) (string, error) {\\n    77→\\tif override := os.Getenv(\\\"ENTIRE_TEST_VOGON_PROJECT_DIR\\\"); override != \\\"\\\" {\\n    78→\\t\\treturn override, nil\\n    79→\\t}\\n    80→\\thomeDir, err := os.UserHomeDir()\\n    81→\\tif err != nil {\\n    82→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"get home dir: %w\\\", err)\\n    83→\\t}\\n    84→\\treturn filepath.Join(homeDir, \\\".vogon\\\", \\\"sessions\\\"), nil\\n    85→}\\n    86→\\n    87→func (v *Agent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n    88→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".jsonl\\\")\\n    89→}\\n    90→\\n    91→func (v *Agent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n    92→\\tif input.SessionRef == \\\"\\\" {\\n    93→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n    94→\\t}\\n    95→\\tdata, err := os.ReadFile(input.SessionRef)\\n    96→\\tif err != nil {\\n    97→\\t\\tif os.IsNotExist(err) {\\n    98→\\t\\t\\t// Transcript may not exist yet — return empty session\\n    99→\\t\\t\\treturn &agent.AgentSession{\\n   100→\\t\\t\\t\\tSessionID:  input.SessionID,\\n   101→\\t\\t\\t\\tAgentName:  v.Name(),\\n   102→\\t\\t\\t\\tSessionRef: input.SessionRef,\\n   103→\\t\\t\\t}, nil\\n   104→\\t\\t}\\n   105→\\t\\treturn nil, fmt.Errorf(\\\"read transcript: %w\\\", err)\\n   106→\\t}\\n   107→\\treturn &agent.AgentSession{\\n   108→\\t\\tSessionID:  input.SessionID,\\n   109→\\t\\tAgentName:  v.Name(),\\n   110→\\t\\tSessionRef: input.SessionRef,\\n   111→\\t\\tNativeData: data,\\n   112→\\t}, nil\\n   113→}\\n   114→\\n   115→func (v *Agent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   116→\\tif session == nil {\\n   117→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   118→\\t}\\n   119→\\tif session.SessionRef == \\\"\\\" {\\n   120→\\t\\treturn errors.New(\\\"session reference is required\\\")\\n   121→\\t}\\n   122→\\tif err := os.MkdirAll(filepath.Dir(session.SessionRef), 0o750); err != nil {\\n   123→\\t\\treturn fmt.Errorf(\\\"create session dir: %w\\\", err)\\n   124→\\t}\\n   125→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   126→\\t\\treturn fmt.Errorf(\\\"write session: %w\\\", err)\\n   127→\\t}\\n   128→\\treturn nil\\n   129→}\\n   130→\\n   131→func (v *Agent) FormatResumeCommand(sessionID string) string {\\n   132→\\treturn \\\"vogon --session-id \\\" + sessionID\\n   133→}\\n   134→\"}]},\"uuid\":\"d4174b3e-ac25-4d69-a687-f6778d28c243\",\"timestamp\":\"2026-03-16T13:33:08.282Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a75381846fdfe7fc3\"},\"toolUseID\":\"agent_msg_01F62wBmQjDkETjqSZQUDRNT\",\"parentToolUseID\":\"toolu_01Azk3Yt81BffJbuaosvGTGD\",\"uuid\":\"f7f1ac1f-b7b1-4bf7-89dc-e93d1b84e3b7\",\