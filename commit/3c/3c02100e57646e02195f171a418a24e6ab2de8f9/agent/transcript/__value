{\\\"ENTIRE_TEST_TTY\\\"}, v.Binary())\\n    80→\\tif err != nil {\\n    81→\\t\\treturn nil, err\\n    82→\\t}\\n    83→\\n    84→\\t// Wait for the interactive prompt.\\n    85→\\tif _, err := s.WaitFor(`>`, 10*time.Second); err != nil {\\n    86→\\t\\t_ = s.Close()\\n    87→\\t\\treturn nil, fmt.Errorf(\\\"waiting for startup prompt: %w\\\", err)\\n    88→\\t}\\n    89→\\ts.stableAtSend = \\\"\\\"\\n    90→\\n    91→\\treturn s, nil\\n    92→}\\n    93→\"}]},\"uuid\":\"08c68729-28fb-4bc3-8735-1abab5ae3e31\",\"timestamp\":\"2026-03-16T13:32:58.706Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a75381846fdfe7fc3\"},\"toolUseID\":\"agent_msg_01F62wBmQjDkETjqSZQUDRNT\",\"parentToolUseID\":\"toolu_01Azk3Yt81BffJbuaosvGTGD\",\"uuid\":\"044ab2b5-2563-457c-9384-49f4bf87d863\",\"timestamp\":\"2026-03-16T13:32:58.708Z\",\"userType\":\"external\",\"cwd\":\"/Users/nodo/work/cli\",\"sessionId\":\"023bbea8-22cf-431a-bb57-e38238833ced\",\"version\":\"2.1.76\",\"gitBranch\":\"main\",\"slug\":\"fluttering-kindling-dahl\"}\n{\"parentUuid\":\"044ab2b5-2563-457c-9384-49f4bf87d863\",\"isSidechain\":false,\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-16T13:32:58.774Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01GDrQH4Jne2c1qTW4koVBAy\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01VFRPgaqexVHx3aGpksyv3S\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/nodo/work/cli/e2e/agents/agent.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":6,\"cache_creation_input_tokens\":3554,\"cache_read_input_tokens\":21541,\"cache_creation\":{\"ephemeral_5m_input_tokens\":3554,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CZ6quSgSfyQGT8oPXtQQ4\",\"uuid\":\"d9feb5f7-834c-45a5-938b-