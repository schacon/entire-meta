\n  1006→\\t\\tTranscriptPath: transcriptPath,\\n  1007→\\t\\tenv:            env,\\n  1008→\\t}\\n  1009→}\\n  1010→\\n  1011→// CreateDroidTranscript creates a Droid-envelope JSONL transcript file.\\n  1012→// Droid wraps messages as {\\\"type\\\":\\\"message\\\",\\\"id\\\":\\\"...\\\",\\\"message\\\":{\\\"role\\\":\\\"...\\\",\\\"content\\\":[...]}},\\n  1013→// unlike Claude Code which uses {\\\"type\\\":\\\"assistant\\\",\\\"uuid\\\":\\\"...\\\",\\\"message\\\":{\\\"content\\\":[...]}}.\\n  1014→func (s *FactoryDroidSession) CreateDroidTranscript(prompt string, changes []FileChange) string {\\n  1015→\\tvar lines []map[string]interface{}\\n  1016→\\n  1017→\\t// User message with prompt\\n  1018→\\tlines = append(lines, map[string]interface{}{\\n  1019→\\t\\t\\\"type\\\": \\\"message\\\",\\n  1020→\\t\\t\\\"id\\\":   \\\"m1\\\",\\n  1021→\\t\\t\\\"message\\\": map[string]interface{}{\\n  1022→\\t\\t\\t\\\"role\\\": \\\"user\\\",\\n  1023→\\t\\t\\t\\\"content\\\": []map[string]interface{}{\\n  1024→\\t\\t\\t\\t{\\\"type\\\": \\\"text\\\", \\\"text\\\": prompt},\\n  1025→\\t\\t\\t},\\n  1026→\\t\\t},\\n  1027→\\t})\\n  1028→\\n  1029→\\t// Assistant message with tool uses\\n  1030→\\tassistantContent := []interface{}{\\n  1031→\\t\\tmap[string]interface{}{\\\"type\\\": \\\"text\\\", \\\"text\\\": \\\"I'll help you with that.\\\"},\\n  1032→\\t}\\n  1033→\\tfor i, change := range changes {\\n  1034→\\t\\tassistantContent = append(assistantContent, map[string]interface{}{\\n  1035→\\t\\t\\t\\\"type\\\":  \\\"tool_use\\\",\\n  1036→\\t\\t\\t\\\"id\\\":    fmt.Sprintf(\\\"toolu_%d\\\", i+1),\\n  1037→\\t\\t\\t\\\"name\\\":  \\\"Write\\\",\\n  1038→\\t\\t\\t\\\"input\\\": map[string]string{\\\"file_path\\\": change.Path, \\\"content\\\": change.Content},\\n  1039→\\t\\t})\\n  1040→\\t}\\n  1041→\\tlines = append(lines, map[string]interface{}{\\n  1042→\\t\\t\\\"type\\\": \\\"message\\\",\\n  1043→\\t\\t\\\"id\\\":   \\\"m2\\\",\\n  1044→\\t\\t\\\"message\\\": map[string]interface{}{\\n  1045→\\t\\t\\t\\\"role\\\":    \\\"assistant\\\",\\n  1046→\\t\\t\\t\\\"content\\\": assistantContent,\\n  1047→\\t\\t},\\n  1048→\\t})\\n  1049→\\n  1050→\\t// Tool results\\n  1051→\\ttoolResultContent := make([]map[string]interface{}, 0, len(changes))\\n  1052→\\tfor i := range changes {\\n  1053→\\t\\ttoolResultContent = append(toolResultContent, map[string]interface{}{\\n  1054→\\t\\t\\t\\\"type\\\":        \\\"tool_result\\\",\\n  1055→\\t\\t\\t\\\"tool_use_id\\\": fmt.Sprintf(\\\"toolu_%d\\\", i+1),\\n  1056→\\t\\t\\t\\\"content\\\":     \\\"Success\\\",\\n  1057→\\t\\t})\\n  1058→\\t}\\n  1059→\\tlines = append(lines, map[string]interface{}{\\n  1060→\\t\\t\\\"type\\\": \\\"message\\\",\\n  1061→\\t\\t\\\"id\\\":   \\\"m3\\\",\\n  1062→\\t\\t\\\"message\\\": map[string]interface{}{\\n  1063→\\t\\t\\t\\\"role\\\":    \\\"user\\\",\\n  1064→\\t\\t\\t\\\"content\\\": toolResultContent,\\n  1065→\\t\\t},\\n  1066→\\t})\\n  1067→\\n  1068→\\t// Final assistant message\\n  1069→\\tlines = append(lines, map[string]interface{}{\\n  1070→\\t\\t\\\"type\\\": \\\"message\\\",\\n  1071→\\t\\t\\\"id\\\":   \\\"m4\\\",\\n  1072→\\t\\t\\\"message\\\": map[string]interface{}{\\n  1073→\\t\\t\\t\\\"role\\\": \\\"assistant\\\",\\n  1074→\\t\\t\\t\\\"content\\\": []map[string]interface{}{\\n  1075→\\t\\t\\t\\t{\\\"type\\\": \\\"text\\\", \\\"text\\\": \\\"Done!\\\"},\\n  1076→\\t\\t\\t},\\n  1077→\\t\\t},\\n  1078→\\t})\\n  1079→\\n  1080→\\t// Ensure directory exists\\n  1081→\\tif err := os.MkdirAll(filepath.Dir(s.TranscriptPath), 0o755); err != nil {\\n  1082→\\t\\ts.env.T.Fatalf(\\\"failed to create transcript dir: %v\\\", err)\\n  1083→\\t}\\n  1084→\\n  1085→\\t// Write as JSONL\\n  1086→\\tfile, err := os.Create(s.TranscriptPath)\\n  1087→\\tif err != nil {\\n  1088→\\t\\ts.env.T.Fatalf(\\\"failed to create transcript file: %v\\\", err)\\n  1089→\\t}\\n  1090→\\tdefer func() { _ = file.Close() }()\\n  1091→\\n  1092→\\tencoder := json.NewEncoder(file