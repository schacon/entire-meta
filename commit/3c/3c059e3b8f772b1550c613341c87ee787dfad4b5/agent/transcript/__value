rePush is a no-op\\n   121→// when no sessions or checkpoints exist.\\n   122→func TestPrePush_NoOpWhenNoCheckpoints(t *testing.T) {\\n   123→\\tt.Parallel()\\n   124→\\tenv := NewFeatureBranchEnv(t)\\n   125→\\n   126→\\tbareDir := env.SetupBareRemote()\\n   127→\\n   128→\\t// Run PrePush without any session activity\\n   129→\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n   130→\\t\\tt.Fatalf(\\\"PrePush should not fail when no checkpoints exist: %v\\\", err)\\n   131→\\t}\\n   132→\\n   133→\\t// No checkpoint branches should exist on remote\\n   134→\\tif env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   135→\\t\\tt.Error(\\\"entire/checkpoints/v1 should NOT exist on remote when no checkpoints were created\\\")\\n   136→\\t}\\n   137→}\\n   138→\\n   139→// TestPrePush_IdempotentWhenAlreadyPushed verifies that pushing twice\\n   140→// with no new checkpoints is a no-op (idempotent).\\n   141→func TestPrePush_IdempotentWhenAlreadyPushed(t *testing.T) {\\n   142→\\tt.Parallel()\\n   143→\\tenv := NewFeatureBranchEnv(t)\\n   144→\\n   145→\\tbareDir := env.SetupBareRemote()\\n   146→\\n   147→\\t// Create session, commit, push\\n   148→\\tsession := env.NewSession()\\n   149→\\ttranscriptPath := session.CreateTranscript(\\\"Initial work\\\", []FileChange{\\n   150→\\t\\t{Path: \\\"main.go\\\", Content: \\\"package main\\\"},\\n   151→\\t})\\n   152→\\n   153→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Initial work\\\", transcriptPath); err != nil {\\n   154→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   155→\\t}\\n   156→\\n   157→\\tenv.WriteFile(\\\"main.go\\\", \\\"package main\\\")\\n   158→\\tenv.GitAdd(\\\"main.go\\\")\\n   159→\\n   160→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   161→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   162→\\t}\\n   163→\\n   164→\\tenv.GitCommitWithShadowHooks(\\\"Initial work\\\", \\\"main.go\\\")\\n   165→\\n   166→\\t// First push\\n   167→\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n   168→\\t\\tt.Fatalf(\\\"first PrePush failed: %v\\\", err)\\n   169→\\t}\\n   170→\\n   171→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   172→\\t\\tt.Fatal(\\\"checkpoint branch should exist after first push\\\")\\n   173→\\t}\\n   174→\\n   175→\\t// Get remote ref before second push\\n   176→\\trefBefore := getRemoteBranchHash(t, bareDir, paths.MetadataBranchName)\\n   177→\\n   178→\\t// Second push (no new checkpoints)\\n   179→\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n   180→\\t\\tt.Fatalf(\\\"second PrePush should succeed: %v\\\", err)\\n   181→\\t}\\n   182→\\n   183→\\t// Remote ref should be unchanged\\n   184→\\trefAfter := getRemoteBranchHash(t, bareDir, paths.MetadataBranchName)\\n   185→\\tif refBefore != refAfter {\\n   186→\\t\\tt.Errorf(\\\"remote ref should be unchanged after idempotent push: before=%s, after=%s\\\", refBefore, refAfter)\\n   187→\\t}\\n   188→}\\n   189→\\n   190→// =============================================================================\\n   191→// P0 — Checkpoint Remote Config\\n   192→// =============================================================================\\n   193→\\n   194→// TestPrePush_PushDisabledSkipsCheckpoints verifies that push_sessions: false\\n   195→// disables checkpoint push while trails are still pushed.\\n   196→func TestPrePush_PushDisabledSkipsCheckpoints(t *testing.T) {\\n   197→\\tt.Parallel()\\n   198→\\tenv := NewFeatureBranchEnv(t)\\n   199→\\n   200→\\tbareDir := env.SetupBareRemote()\\n   201→\\n   202→\\t// Configure push_sessions: false\\n   203→\\tenv.PatchSettings(map[string]any{\\n   204→\\t\\t\\\"strategy_options\\\": map[string]any{\\n   205→\\t\\t\\t\\\"push_sessions\\\": false,\\n   206→\\t\\t},\\n   207→\\t})\\n   208→\\n   209→\\t// Create session, checkpoint, and commit\\n