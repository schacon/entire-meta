8→\\t\\tc := &object.Commit{\\n   649→\\t\\t\\tTreeHash:  treeHash,\\n   650→\\t\\t\\tAuthor:    object.Signature{Name: \\\"test\\\", Email: \\\"test@test.com\\\", When: time.Now().Add(time.Duration(i) * time.Second)},\\n   651→\\t\\t\\tCommitter: object.Signature{Name: \\\"test\\\", Email: \\\"test@test.com\\\", When: time.Now().Add(time.Duration(i) * time.Second)},\\n   652→\\t\\t\\tMessage:   \\\"commit\\\\n\\\",\\n   653→\\t\\t}\\n   654→\\t\\tif tip != plumbing.ZeroHash {\\n   655→\\t\\t\\tc.ParentHashes = []plumbing.Hash{tip}\\n   656→\\t\\t}\\n   657→\\t\\tobj := repo.Storer.NewEncodedObject()\\n   658→\\t\\trequire.NoError(t, c.Encode(obj))\\n   659→\\t\\th, sErr := repo.Storer.SetEncodedObject(obj)\\n   660→\\t\\trequire.NoError(t, sErr)\\n   661→\\t\\ttip = h\\n   662→\\t}\\n   663→\\n   664→\\t_, err = collectCommitChain(repo, tip)\\n   665→\\trequire.Error(t, err)\\n   666→\\tassert.Contains(t, err.Error(), \\\"exceeded\\\")\\n   667→\\tassert.Contains(t, err.Error(), \\\"without reaching root\\\")\\n   668→}\\n   669→\\n   670→// TestReconcileDisconnected_AllEmptyOrphans verifies that when all local commits\\n   671→// are empty-tree orphan commits (the exact bug artifact), reconciliation resets\\n   672→// the local branch to the remote tip without cherry-picking.\\n   673→func TestReconcileDisconnected_AllEmptyOrphans(t *testing.T) {\\n   674→\\tt.Parallel()\\n   675→\\n   676→\\tbareDir := initBareWithMetadataBranch(t)\\n   677→\\tcloneDir, run := cloneWithConfig(t, bareDir)\\n   678→\\n   679→\\t// Create a disconnected local branch with ONLY empty-tree commits\\n   680→\\t// (simulating the empty-orphan bug in a repo that never had real checkpoints)\\n   681→\\trun(\\\"checkout\\\", \\\"--orphan\\\", \\\"temp-orphan\\\")\\n   682→\\trun(\\\"rm\\\", \\\"-rf\\\", \\\".\\\")\\n   683→\\t// Commit with empty tree (git allows this with --allow-empty)\\n   684→\\trun(\\\"commit\\\", \\\"--allow-empty\\\", \\\"-m\\\", \\\"empty orphan init\\\")\\n   685→\