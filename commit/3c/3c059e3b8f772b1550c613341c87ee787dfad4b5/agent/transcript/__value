lly (some configurations create it), verify it pushes.\\n    96→\\t// If not, create a minimal orphan trails branch to test the push mechanism.\\n    97→\\tensureTrailsBranchExists(t, env)\\n    98→\\n    99→\\t// Run PrePush\\n   100→\\tenv.RunPrePush(\\\"origin\\\")\\n   101→\\n   102→\\t// Checkpoint branch must be on remote\\n   103→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   104→\\t\\tt.Error(\\\"entire/checkpoints/v1 should exist on remote\\\")\\n   105→\\t}\\n   106→\\n   107→\\t// Trails branch must be on remote after PrePush\\n   108→\\tif !env.BranchExistsOnRemote(bareDir, paths.TrailsBranchName) {\\n   109→\\t\\tt.Error(\\\"entire/trails/v1 should exist on remote after PrePush when present locally\\\")\\n   110→\\t}\\n   111→}\\n   112→\\n   113→// TestPrePush_NoOpWhenNoCheckpoints verifies that PrePush is a no-op\\n   114→// when no sessions or checkpoints exist.\\n   115→func TestPrePush_NoOpWhenNoCheckpoints(t *testing.T) {\\n   116→\\tt.Parallel()\\n   117→\\tenv := NewFeatureBranchEnv(t)\\n   118→\\n   119→\\tbareDir := env.SetupBareRemote()\\n   120→\\n   121→\\t// Run PrePush without any session activity\\n   122→\\tenv.RunPrePush(\\\"origin\\\")\\n   123→\\n   124→\\t// No checkpoint branches should exist on remote\\n   125→\\tif env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   126→\\t\\tt.Error(\\\"entire/checkpoints/v1 should NOT exist on remote when no checkpoints were created\\\")\\n   127→\\t}\\n   128→}\\n   129→\\n   130→// TestPrePush_IdempotentWhenAlreadyPushed verifies that pushing twice\\n   131→// with no new checkpoints is a no-op (idempotent).\\n   132→func TestPrePush_IdempotentWhenAlreadyPushed(t *testing.T) {\\n   133→\\tt.Parallel()\\n   134→\\tenv := NewFeatureBranchEnv(t)\\n   135→\\n   136→\\tbareDir := env.SetupBareRemote()\\n   137→\\n   138→\\t// Create session, commit, push\\n   139→\\tsession := env.NewSession()\\n   140→\\ttranscriptPath := session.CreateTranscript(\\\"Initial work\\\", []FileChange{\\n   141→\\t\\t{Path: \\\"main.go\\\", Content: \\\"package main\\\"},\\n   142→\\t})\\n   143→\\n   144→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Initial work\\\", transcriptPath); err != nil {\\n   145→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   146→\\t}\\n   147→\\n   148→\\tenv.WriteFile(\\\"main.go\\\", \\\"package main\\\")\\n   149→\\tenv.GitAdd(\\\"main.go\\\")\\n   150→\\n   151→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   152→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   153→\\t}\\n   154→\\n   155→\\tenv.GitCommitWithShadowHooks(\\\"Initial work\\\", \\\"main.go\\\")\\n   156→\\n   157→\\t// First push\\n   158→\\tenv.RunPrePush(\\\"origin\\\")\\n   159→\\n   160→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   161→\\t\\tt.Fatal(\\\"checkpoint branch should exist after first push\\\")\\n   162→\\t}\\n   163→\\n   164→\\t// Get remote ref before second push\\n   165→\\trefBefore := getRemoteBranchHash(t, bareDir, paths.MetadataBranchName)\\n   166→\\n   167→\\t// Second push (no new checkpoints)\\n   168→\\tenv.RunPrePush(\\\"origin\\\")\\n   169→\\n   170→\\t// Remote ref should be unchanged\\n   171→\\trefAfter := getRemoteBranchHash(t, bareDir, paths.MetadataBranchName)\\n   172→\\tif refBefore != refAfter {\\n   173→\\t\\tt.Errorf(\\\"remote ref should be unchanged after idempotent push: before=%s, after=%s\\\", refBefore, refAfter)\\n   174→\\t}\\n   175→}\\n   176→\\n   177→// =============================================================================\\n   178→// P0 -- Checkpoint Remote Config\\n   179→// =============================================================================\\n   180→\\n   181→// TestPrePush_PushDisabledSkipsCheckpoints verifies that push_sessions: false\\n   182→// disables checkpoint push while trails are still pushed.\\n   183→func TestPrePush_PushDisabledSkipsCheckpoints(t *testing.T) {\\n   184→\\tt.Parallel()\\n   185→\\tenv := NewFeatureBranchEnv(t)\\n   186→\\n   187→\\tbareDir := env.SetupBareRemote()\\n   188→\\n   189→\\t// Configure push_sessions: false\\n   190→\\tenv.PatchSettings(map[string]any{\\n   191→\\t\\t\\\"strategy_options\\\": map[string]any{\\n   192→\\t\\t\\t\\\"push_sessions\\\": false,\\n   193→\\t\\t},\\n   194→\\t})\\n   195→\\n   196→\\t// Create session, checkpoint, and commit\\n   197→\\tsession := env.NewSession()\\n   198→\\ttranscriptPath := session.CreateTranscript(\\\"Some work\\\", []FileChange{\\n   199→\\t\\t{Path: \\\"work.go\\\", Content: \\\"package work\\\"},\\n   200→\\t})\\n   201→\\n   202→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Some work\\\", transcriptPath); err != nil {\\n   203→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   204→\\t}\\n   205→\\n   206→\\tenv.WriteFile(\\\"work.go\\\", \\\"package work\\\")\\n   207→\\tenv.GitAdd(\\\"work.go\\\")\\n   208→\\n   209→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   210→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   211→\\t}\\n   212→\\n   213→\\tenv.GitCommitWithShadowHooks(\\\"Some work\\\", \\\"work.go\\\")\\n   214→\\n   215→\\t// Verify checkpoint was created locally\\n   216→\\tif !env.BranchExists(paths.MetadataBranchName) {\\n   217→\\t\\tt.Fatal(\\\"should have local checkpoint branch after condensation\\\")\\n   218→\\t}\\n   219→\\n   220→\\t// Run PrePush\\n   221→\\tenv.RunPrePush(\\\"origin\\\")\\n   222→\\n   223→\\t// Checkpoints should NOT be on remote\\n   224→\\tif env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   225→\\t\\tt.Error(\\\"entire/checkpoints/v1 should NOT be on remote when push_sessions is false\\\")\\n   226→\\t}\\n   227→\\n   228→\\t// Guarantee the trails branch exists so we can make an unconditional assertion.\\n   229→\\t// Trails are only created when a trail is explicitly started, not by the basic\\n   230→\\t// session + commit flow. Create one if needed to verify push_sessions: false\\n   231→\\t// does not affect trails.\\n   232→\\tensureTrailsBranchExists(t, env)\\n   233→\\n   234→\\t// Re-run PrePush to push the trails branch\\n   235→\\tenv.RunPrePush(\\\"origin\\\")\\n   236→\\n   237→\\t// Trails SHOULD be on remote (trails are independent of push_sessions)\\n   238→\\tif !env.BranchExistsOnRemote(bareDir, paths.TrailsBranchName) {\\n   239→\\t\\tt.Error(\\\"entire/trails/v1 should be on remote even when push_sessions is false\\\")\\n   240→\\t}\\n   241→}\\n   242→\\n   243→// TestPrePush_CheckpointRemoteRoutesToSeparateRemote verifies that checkpoint data\\n   244→// can be selectively pushed to a separate remote while trails stay on origin.\\n   245→//\\n   246→// This is a data routing verification test. It validates that when the production\\n   247→// code's pushBranchIfNeeded is called with different targets for checkpoints vs\\n   248→// trails, the branches land on the correct remotes with correct data.\\n   249→//\\n   250→// Why not test through PrePush directly: resolvePushSettings derives the checkpoint\\n   251→// URL from origin's protocol (SSH/HTTPS). Since integration tests use local file\\n   252→// paths as remotes, parseGitRemoteURL fails and resolvePushSettings falls back to\\n   253→// origin. The URL derivation logic is unit-tested in checkpoint_remote_test.go\\n   254→// (TestDeriveCheckpointURL, TestResolvePushSettings_WithCheckpointRemote_*).\\n   255→//\\n   256→// The pushBranchIfNeeded function (which PrePush calls with the resolved target)\\n   257→// is exercised in push_common_test.go:TestPushBranchIfNeeded_LocalBareRepo_PushesSuccessfully,\\n   258→// verifying it works with local bare repo paths.\\n   259→func TestPrePush_CheckpointRemoteRoutesToSeparateRemote(t *testing.T) {\\n   260→\\tt.Parallel()\\n   261→\\tenv := NewFeatureBranchEnv(t)\\n   262→\\n   263→\\t// Set up two bare remotes: origin for user code + trails, checkpoint remote for checkpoints\\n   264→\\tbareOrigin := env.SetupBareRemote()\\n   265→\\tbareCheckpoint := env.SetupNamedBareRemote(\\\"checkpoint-store\\\")\\n   266→\\n   267→\\t// Create session, checkpoint, and commit\\n   268→\\tcheckpointID := createCheckpointedCommit(t, env, \\\"Add router\\\", \\\"router.go\\\", \\\"package router\\\", \\\"Add router\\\")\\n   269→\\n   270→\\t// Verify local checkpoint branch exists\\n   271→\\tif !env.BranchExists(paths.MetadataBranchName) {\\n   272→\\t\\tt.Fatal(\\\"should have local checkpoint branch after condensation\\\")\\n   273→\\t}\\n   274→\\n   275→\\t// Simulate checkpoint_remote routing: push checkpoints to the checkpoint bare repo\\n   276→\\t// and trails to origin. This mirrors what PrePush does when resolvePushSettings\\n   277→\\t// returns a checkpointURL: checkpoints go to ps.pushTarget(), trails go to ps.remote.\\n   278→\\tpushBranchToTarget(t, env.RepoDir, bareCheckpoint, paths.MetadataBranchName)\\n   279→\\n   280→\\t// Ensure trails branch exists for a definitive assertion.\\n   281→\\tensureTrailsBranchExists(t, env)\\n   282→\\tpushBranchToTarget(t, env.RepoDir, \\\"origin\\\", paths.TrailsBranchName)\\n   283→\\n   284→\\t// Checkpoints should be on checkpoint remote, NOT on origin\\n   285→\\tif !env.BranchExistsOnRemote(bareCheckpoint, paths.MetadataBranchName) {\\n   286→\\t\\tt.Error(\\\"entire/checkpoints/v1 should exist on checkpoint remote\\\")\\n   287→\\t}\\n   288→\\tif env.BranchExistsOnRemote(bareOrigin, paths.MetadataBranchName) {\\n   289→\\t\\tt.Error(\\\"entire/checkpoints/v1 should NOT be on origin when routed to checkpoint remote\\\")\\n   290→\\t}\\n   291→\\n   292→\\t// Trails should be on origin, NOT on checkpoint remote\\n   293→\\tif !env.BranchExistsOnRemote(bareOrigin, paths.TrailsBranchName) {\\n   294→\\t\\tt.Error(\\\"entire/trails/v1 should be on origin\\\")\\n   295→\\t}\\n   296→\\tif env.BranchExistsOnRemote(bareCheckpoint, paths.TrailsBranchName) {\\n   297→\\t\\tt.Error(\\\"entire/trails/v1 should NOT be on checkpoint remote\\\")\\n   298→\\t}\\n   299→\\n   300→\\t// Verify checkpoint data arrived on checkpoint remote\\n   301→\\tsummaryPath := CheckpointSummaryPath(checkpointID)\\n   302→\\tif !fileExistsOnRemoteBranch(t, bareCheckpoint, summaryPath) {\\n   303→\\t\\tt.Errorf(\\\"checkpoint metadata should exist on checkpoint remote at %s\\\", summaryPath)\\n   304→\\t}\\n   305→}\\n   306→\\n   307→// REDACTED verifies that when\\n   308→// origin is a local file path (not an SSH/HTTPS URL), resolvePushSettings cannot\\n   309→// derive a checkpoint URL and checkpoints fall back to origin.\\n   310→//\\n   311→// This exercises the integration behavior: when checkpoint_remote is configured but\\n   312→// the push remote URL cannot be parsed (local file path), checkpoints still land on\\n   313→// origin. The exact fork detection logic (owner mismatch) is unit-tested in\\n   314→// checkpoint_remote_test.go:TestResolvePushSettings_ForkDetection.\\n   315→func REDACTED(t *testing.T) {\\n   316→\\tt.Parallel()\\n   317→\\tenv := NewFeatureBranchEnv(t)\\n   318→\\n   319→\\tbareDir := env.SetupBareRemote()\\n   320→\\n   321→\\t// Configure checkpoint_remote with a different owner than origin.\\n   322→\\t// Since our bare remote is a local path (not a URL), resolvePushSettings cannot\\n   323→\\t// parse it via parseGitRemoteURL and falls back to origin. The unit test\\n   324→\\t// TestResolvePushSettings_ForkDetection in checkpoint_remote_test.go validates\\n   325→\\t// the exact fork detection logic with real URL parsing.\\n   326→\\tenv.PatchSettings(map[string]any{\\n   327→\\t\\t\\\"strategy_options\\\": map[string]any{\\n   328→\\t\\t\\t\\\"checkpoint_remote\\\": map[string]any{\\n   329→\\t\\t\\t\\t\\\"provider\\\": \\\"github\\\",\\n   330→\\t\\t\\t\\t\\\"repo\\\":     \\\"different-org/checkpoints\\\",\\n   331→\\t\\t\\t},\\n   332→\\t\\t},\\n   333→\\t})\\n   334→\\n   335→\\t// Create session, checkpoint, and commit\\n   336→\\tsession := env.NewSession()\\n   337→\\ttranscriptPath := session.CreateTranscript(\\\"Add middleware\\\", []FileChange{\\n   338→\\t\\t{Path: \\\"middleware.go\\\", Content: \\\"package middleware\\\"},\\n   339→\\t})\\n   340→\\n   341→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Add middleware\\\", transcriptPath); err != nil {\\n   342→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   343→\\t}\\n   344→\\n   345→\\tenv.WriteFile(\\\"middleware.go\\\", \\\"package middleware\\\")\\n   346→\\tenv.GitAdd(\\\"middleware.go\\\")\\n   347→\\n   348→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   349→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   350→\\t}\\n   351→\\n   352→\\tenv.GitCommitWithShadowHooks(\\\"Add middleware\\\", \\\"middleware.go\\\")\\n   353→\\n   354→\\t// Run PrePush -- with a local path remote, checkpoint URL derivation will fail\\n   355→\\t// (parseGitRemoteURL can't parse local paths), so checkpoints fall back to origin.\\n   356→\\tenv.RunPrePush(\\\"origin\\\")\\n   357→\\n   358→\\t// Checkpoints should be on origin (fallback behavior)\\n   359→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   360→\\t\\tt.Error(\\\"entire/checkpoints/v1 should be on origin when checkpoint_remote is unavailable (fork/fallback)\\\")\\n   361→\\t}\\n   362→}\\n   363→\\n   364→// =============================================================================\\n   365→// P0 -- Clone and Resume\\n   366→// =============================================================================\\n   367→\\n   368→// createCheckpointedCommit is a helper that creates a session with a single file change,\\n   369→// runs the full lifecycle (prompt submit -> write -> stop -> commit), and returns the\\n   370→// session and checkpoint ID. This reduces boilerplate in tests where the session setup\\n   371→// is not the focus.\\n   372→func createCheckpointedCommit(t *testing.T, env *TestEnv, prompt, fileName, fileContent, commitMsg string) string {\\n   373→\\tt.Helper()\\n   374→\\n   375→\\tsession := env.NewSession()\\n   376→\\ttranscriptPath := session.CreateTranscript(prompt, []FileChange{\\n   377→\\t\\t{Path: fileName, Content: fileContent},\\n   378→\\t})\\n   379→\\n   380→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, prompt, transcriptPath); err != nil {\\n   381→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   382→\\t}\\n   383→\\n   384→\\tenv.WriteFile(fileName, fileContent)\\n   385→\\tenv.GitAdd(fileName)\\n   386→\\n   387→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   388→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   389→\\t}\\n   390→\\n   391→\\tenv.GitCommitWithShadowHooks(commitMsg, fileName)\\n   392→\\n   393→\\treturn env.GetLatestCheckpointID()\\n   394→}\\n   395→\\n   396→// TestCloneAndResume_FetchesCheckpointMetadata verifies that after pushing\\n   397→// checkpoints to a remote, cloning the repo and fetching the metadata branch\\n   398→// brings the checkpoint data locally.\\n   399→//\\n   400→// Note: This test uses env.FetchMetadataBranch (raw git fetch) rather than\\n   401→// triggering fetchMetadataBranchIfMissing via the production code path, because\\n   402→// fetchMetadataBranchIfMissing uses OpenRepository which requires CWD to be\\n   403→// inside the repo (incompatible with t.Parallel). The production function is\\n   404→// tested directly in checkpoint_remote_test.go (TestFetchBranchIfMissing_*).\\n   405→// This test verifies the \\\"data arrives and is usable\\\" property.\\n   406→func TestCloneAndResume_FetchesCheckpointMetadata(t *testing.T) {\\n   407→\\tt.Parallel()\\n   408→\\tenv := NewFeatureBranchEnv(t)\\n   409→\\n   410→\\tbareDir := env.SetupBareRemote()\\n   411→\\n   412→\\t// Repo A: create session, checkpoint, commit, push\\n   413→\\tcheckpointID := createCheckpointedCommit(t, env, \\\"Build login page\\\", \\\"login.go\\\", \\\"package login\\\", \\\"Build login page\\\")\\n   414→\\tt.Logf(\\\"Original checkpoint ID: %s\\\", checkpointID)\\n   415→\\n   416→\\t// Push user branch + checkpoint branches to remote\\n   417→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   418→\\tenv.RunPrePush(\\\"origin\\\")\\n   419→\\n   420→\\t// Clone into repo B\\n   421→\\tcloneEnv := env.CloneFrom(bareDir)\\n   422→\\n   423→\\t// Fetch the metadata branch (simulates what fetchMetadataBranchIfMissing does)\\n   424→\\tcloneEnv.FetchMetadataBranch(bareDir)\\n   425→\\n   426→\\t// Now the metadata branch should exist locally in the clone\\n   427→\\tif !cloneEnv.BranchExists(paths.MetadataBranchName) {\\n   428→\\t\\tt.Fatal(\\\"entire/checkpoints/v1 should exist in clone after fetch\\\")\\n   429→\\t}\\n   430→\\n   431→\\t// Verify the checkpoint data is present\\n   432→\\tsummaryPath := CheckpointSummaryPath(checkpointID)\\n   433→\\tif !cloneEnv.FileExistsInBranch(paths.MetadataBranchName, summaryPath) {\\n   434→\\t\\tt.Errorf(\\\"checkpoint metadata should exist in clone at %s\\\", summaryPath)\\n   435→\\t}\\n   436→}\\n   437→\\n   438→// TestCloneAndResume_SessionListingWorksAfterClone verifies that checkpoint\\n   439→// metadata can be enumerated after cloning and fetching the metadata branch.\\n   440→func TestCloneAndResume_SessionListingWorksAfterClone(t *testing.T) {\\n   441→\\tt.Parallel()\\n   442→\\tenv := NewFeatureBranchEnv(t)\\n   443→\\n   444→\\tbareDir := env.SetupBareRemote()\\n   445→\\n   446→\\t// Repo A: create session, checkpoint, commit, push\\n   447→\\tcheckpointID := createCheckpointedCommit(t, env, \\\"Implement auth\\\", \\\"auth.go\\\", \\\"package auth\\\", \\\"Implement auth\\\")\\n   448→\\n   449→\\t// Push everything\\n   450→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   451→\\tenv.RunPrePush(\\\"origin\\\")\\n   452→\\n   453→\\t// Clone and fetch metadata\\n   454→\\tcloneEnv := env.CloneFrom(bareDir)\\n   455→\\tcloneEnv.FetchMetadataBranch(bareDir)\\n   456→\\n   457→\\t// List checkpoints from the clone by scanning the metadata branch tree\\n   458→\\tcheckpoints := listCheckpointsInDir(t, cloneEnv.RepoDir)\\n   459→\\n   460→\\tif len(checkpoints) == 0 {\\n   461→\\t\\tt.Fatal(\\\"should find checkpoints from original repo after clone\\\")\\n   462→\\t}\\n   463→\\n   464→\\t// Verify our checkpoint is in the list\\n   465→\\tfound := false\\n   466→\\tfor _, cp := range checkpoints {\\n   467→\\t\\tif cp == checkpointID {\\n   468→\\t\\t\\tfound = true\\n   469→\\t\\t\\tbreak\\n   470→\\t\\t}\\n   471→\\t}\\n   472→\\tif !found {\\n   473→\\t\\tt.Errorf(\\\"checkpoint %s from original repo should be in list, got: %v\\\", checkpointID, checkpoints)\\n   474→\\t}\\n   475→}\\n   476→\\n   477→// TestCloneAndResume_SessionLogRetrievalWorksAfterClone verifies that\\n   478→// checkpoint transcripts can be read after clone + fetch.\\n   479→func TestCloneAndResume_SessionLogRetrievalWorksAfterClone(t *testing.T) {\\n   480→\\tt.Parallel()\\n   481→\\tenv := NewFeatureBranchEnv(t)\\n   482→\\n   483→\\tbareDir := env.SetupBareRemote()\\n   484→\\n   485→\\t// Repo A: create session with a specific transcript content\\n   486→\\tcheckpointID := createCheckpointedCommit(t, env, \\\"Write tests for auth\\\", \\\"auth_test.go\\\", \\\"package auth_test\\\", \\\"Write auth tests\\\")\\n   487→\\n   488→\\t// Push\\n   489→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   490→\\tenv.RunPrePush(\\\"origin\\\")\\n   491→\\n   492→\\t// Clone and fetch metadata\\n   493→\\tcloneEnv := env.CloneFrom(bareDir)\\n   494→\\tcloneEnv.FetchMetadataBranch(bareDir)\\n   495→\\n   496→\\t// Read transcript from the clone\\n   497→\\ttranscriptFilePath := SessionFilePath(checkpointID, paths.TranscriptFileName)\\n   498→\\tcontent, found := cloneEnv.ReadFileFromBranch(paths.MetadataBranchName, transcriptFilePath)\\n   499→\\tif !found {\\n   500→\\t\\tt.Fatalf(\\\"transcript should be readable from clone at %s\\\", transcriptFilePath)\\n   501→\\t}\\n   502→\\n   503→\\tif content == \\\"\\\" {\\n   504→\\t\\tt.Error(\\\"transcript content should not be empty\\\")\\n   505→\\t}\\n   506→\\n   507→\\t// Verify it contains our expected content\\n   508→\\tif !strings.Contains(content, \\\"Write tests for auth\\\") {\\n   509→\\t\\tt.Error(\\\"transcript should contain the user prompt from the original session\\\")\\n   510→\\t}\\n   511→}\\n   512→\\n   513→// TestCloneAndResume_NewSessionPushAppends verifies that after cloning,\\n   514→// creating a new session, and pushing, the remote has BOTH original and\\n   515→// new checkpoint data.\\n   516→func TestCloneAndResume_NewSessionPushAppends(t *testing.T) {\\n   517→\\tt.Parallel()\\n   518→\\tenv := NewFeatureBranchEnv(t)\\n   519→\\n   520→\\tbareDir := env.SetupBareRemote()\\n   521→\\n   522→\\t// Repo A: session + commit + push\\n   523→\\toriginalCheckpointID := createCheckpointedCommit(t, env, \\\"Add models\\\", \\\"models.go\\\", \\\"package models\\\", \\\"Add models\\\")\\n   524→\\tt.Logf(\\\"Original checkpoint: %s\\\", originalCheckpointID)\\n   525→\\n   526→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   527→\\tenv.RunPrePush(\\\"origin\\\")\\n   528→\\n   529→\\t// Clone into repo B and fetch metadata\\n   530→\\tcloneEnv := env.CloneFrom(bareDir)\\n   531→\\tcloneEnv.FetchMetadataBranch(bareDir)\\n   532→\\n   533→\\t// Repo B: create NEW session on a new branch, commit, push\\n   534→\\tcloneEnv.GitCheckoutNewBranch(\\\"feature/clone-work\\\")\\n   535→\\n   536→\\tnewCheckpointID := createCheckpointedCommit(t, cloneEnv, \\\"Add handlers\\\", \\\"handlers.go\\\", \\\"package handlers\\\", \\\"Add handlers\\\")\\n   537→\\tt.Logf(\\\"New checkpoint: %s\\\", newCheckpointID)\\n   538→\\n   539→\\t// Push from clone\\n   540→\\tcloneEnv.RunPrePush(\\\"origin\\\")\\n   541→\\n   542→\\t// Verify remote has BOTH checkpoints\\n   543→\\toriginalSummaryPath := CheckpointSummaryPath(originalCheckpointID)\\n   544→\\tif !fileExistsOnRemoteBranch(t, bareDir, originalSummaryPath) {\\n   545→\\t\\tt.Errorf(\\\"original checkpoint %s should still exist on remote\\\", originalCheckpointID)\\n   546→\\t}\\n   547→\\n   548→\\tnewSummaryPath := CheckpointSummaryPath(newCheckpointID)\\n   549→\\tif !fileExistsOnRemoteBranch(t, bareDir, newSummaryPath) {\\n   550→\\t\\tt.Errorf(\\\"new checkpoint %s should exist on remote\\\", newCheckpointID)\\n   551→\\t}\\n   552→}\\n   553→\\n   554→// =============================================================================\\n   555→// P1 -- Non-Fast-Forward Recovery\\n   556→// =============================================================================\\n   557→\\n   558→// TestConcurrentPush_SecondPusherMergesAndRetries verifies that when two clones\\n   559→// push to the same remote, the second pusher fetches, merges, and retries.\\n   560→func TestConcurrentPush_SecondPusherMergesAndRetries(t *testing.T) {\\n   561→\\tt.Parallel()\\n   562→\\tenv := NewFeatureBranchEnv(t)\\n   563→\\n   564→\\tbareDir := env.SetupBareRemote()\\n   565→\\n   566→\\t// Clone A\\n   567→\\tcloneA := env.CloneFrom(bareDir)\\n   568→\\tcloneA.GitCheckoutNewBranch(\\\"feature/clone-a\\\")\\n   569→\\n   570→\\t// Clone B\\n   571→\\tcloneB := env.CloneFrom(bareDir)\\n   572→\\tcloneB.GitCheckoutNewBranch(\\\"feature/clone-b\\\")\\n   573→\\n   574→\\t// Clone A: session + commit\\n   575→\\tcheckpointA := createCheckpointedCommit(t, cloneA, \\\"Work in clone A\\\", \\\"a.go\\\", \\\"package a\\\", \\\"Work from A\\\")\\n   576→\\tt.Logf(\\\"Clone A checkpoint: %s\\\", checkpointA)\\n   577→\\n   578→\\t// Clone B: session + commit\\n   579→\\tcheckpointB := createCheckpointedCommit(t, cloneB, \\\"Work in clone B\\\", \\\"b.go\\\", \\\"package b\\\", \\\"Work from B\\\")\\n   580→\\tt.Logf(\\\"Clone B checkpoint: %s\\\", checkpointB)\\n   581→\\n   582→\\t// A pushes first (should succeed cleanly)\\n   583→\\tcloneA.RunPrePush(\\\"origin\\\")\\n   584→\\n   585→\\t// B pushes second (will get non-fast-forward, should fetch+merge+retry)\\n   586→\\tcloneB.RunPrePush(\\\"origin\\\")\\n   587→\\n   588→\\t// Remote should have BOTH checkpoints\\n   589→\\tsummaryA := CheckpointSummaryPath(checkpointA)\\n   590→\\tif !fileExistsOnRemoteBranch(t, bareDir, summaryA) {\\n   591→\\t\\tt.Errorf(\\\"remote should have checkpoint from clone A: %s\\\", checkpointA)\\n   592→\\t}\\n   593→\\n   594→\\tsummaryB := CheckpointSummaryPath(checkpointB)\\n   595→\\tif !fileExistsOnRemoteBranch(t, bareDir, summaryB) {\\n   596→\\t\\tt.Errorf(\\\"remote should have checkpoint from clone B: %s\\\", checkpointB)\\n   597→\\t}\\n   598→\\n   599→\\t// Verify B's local metadata branch has a merge commit with 2 parents.\\n   600→\\t// This confirms the fetch+merge+retry path was taken.\\n   601→\\tparentCount := cloneB.GetBranchTipParentCount(paths.MetadataBranchName)\\n   602→\\tif parentCount != 2 {\\n   603→\\t\\tt.Errorf(\\\"clone B's metadata branch tip should have 2 parents (merge commit), got %d\\\", parentCount)\\n   604→\\t}\\n   605→}\\n   606→\\n   607→// =============================================================================\\n   608→// P1 -- Graceful Degradation\\n   609→// =============================================================================\\n   610→\\n   611→// TestGracefulDegradation_UnreachableCheckpointRemotePushContinues verifies that\\n   612→// when checkpoint_remote is configured but cannot be resolved (because origin is a\\n   613→// local path, not an SSH/HTTPS URL), PrePush falls back to pushing checkpoints to\\n   614→// origin. Trails are always pushed to origin regardless of checkpoint_remote config.\\n   615→//\\n   616→// This test exercises the PrePush -> resolvePushSettings -> fallback code path.\\n   617→// The actual doPushBranch graceful degradation (push to unreachable URL returns nil,\\n   618→// not an error) is tested in push_common_test.go:\\n   619→//   - TestDoPushBranch_UnreachableTarget_ReturnsNil\\n   620→//   - TestPushBranchIfNeeded_UnreachableTarget_ReturnsNil\\n   621→func TestGracefulDegradation_UnreachableCheckpointRemotePushContinues(t *testing.T) {\\n   622→\\tt.Parallel()\\n   623→\\tenv := NewFeatureBranchEnv(t)\\n   624→\\n   625→\\tbareOrigin := env.SetupBareRemote()\\n   626→\\n   627→\\t// Configure checkpoint_remote with a nonexistent repo. Since origin is a local\\n   628→\\t// file path, resolvePushSettings cannot parse it as a URL and will silently fall\\n   629→\\t// back to pushing checkpoints to origin (the default behavior).\\n   630→\\tenv.PatchSettings(map[string]any{\\n   631→\\t\\t\\\"strategy_options\\\": map[string]any{\\n   632→\\t\\t\\t\\\"checkpoint_remote\\\": map[string]any{\\n   633→\\t\\t\\t\\t\\\"provider\\\": \\\"github\\\",\\n   634→\\t\\t\\t\\t\\\"repo\\\":     \\\"nonexistent-org/unreachable-repo\\\",\\n   635→\\t\\t\\t},\\n   636→\\t\\t},\\n   637→\\t})\\n   638→\\n   639→\\t// Create session, checkpoint, and commit\\n   640→\\t_ = createCheckpointedCommit(t, env, \\\"Some work\\\", \\\"work.go\\\", \\\"package work\\\", \\\"Some work\\\")\\n   641→\\n   642→\\t// Verify local checkpoint branch exists\\n   643→\\tif !env.BranchExists(paths.MetadataBranchName) {\\n   644→\\t\\tt.Fatal(\\\"should have local checkpoint branch after condensation\\\")\\n   645→\\t}\\n   646→\\n   647→\\t// Ensure trails branch exists so we can verify it pushes independently.\\n   648→\\tensureTrailsBranchExists(t, env)\\n   649→\\n   650→\\t// Run PrePush with checkpoint_remote configured. Since origin is a local path,\\n   651→\\t// resolvePushSettings will fail to derive a checkpoint URL and fall back to\\n   652→\\t// pushing both checkpoints and trails to origin.\\n   653→\\tenv.RunPrePush(\\\"origin\\\")\\n   654→\\n   655→\\t// Checkpoints should be on origin (fallback behavior when checkpoint URL derivation fails)\\n   656→\\tif !env.BranchExistsOnRemote(bareOrigin, paths.MetadataBranchName) {\\n   657→\\t\\tt.Error(\\\"entire/checkpoints/v1 should be on origin when checkpoint_remote URL derivation fails\\\")\\n   658→\\t}\\n   659→\\n   660→\\t// Trails should always be on origin regardless of checkpoint_remote config\\n   661→\\tif !env.BranchExistsOnRemote(bareOrigin, paths.TrailsBranchName) {\\n   662→\\t\\tt.Error(\\\"entire/trails/v1 should be on origin even when checkpoint_remote is configured\\\")\\n   663→\\t}\\n   664→}\\n   665→\\n   666→// TestGracefulDegradation_UnreachableCheckpointRemoteOnCloneIsSilent verifies that\\n   667→// when a clone configures checkpoint_remote pointing to an unreachable path, starting\\n   668→// a session does not error. fetchMetadataBranchIfMissing silently swallows fetch failures.\\n   669→func TestGracefulDegradation_UnreachableCheckpointRemoteOnCloneIsSilent(t *testing.T) {\\n   670→\\tt.Parallel()\\n   671→\\tenv := NewFeatureBranchEnv(t)\\n   672→\\n   673→\\tbareDir := env.SetupBareRemote()\\n   674→\\n   675→\\t// Create a session in repo A and push\\n   676→\\tcreateCheckpointedCommit(t, env, \\\"Initial work\\\", \\\"init.go\\\", \\\"package init\\\", \\\"Initial work\\\")\\n   677→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   678→\\tenv.RunPrePush(\\\"origin\\\")\\n   679→\\n   680→\\t// Clone from origin\\n   681→\\tcloneEnv := env.CloneFrom(bareDir)\\n   682→\\n   683→\\t// Configure checkpoint_remote to an unreachable path in the clone.\\n   684→\\t// When the checkpoint_remote URL can't be reached, fetch fails silently.\\n   685→\\tcloneEnv.PatchSettings(map[string]any{\\n   686→\\t\\t\\\"strategy_options\\\": map[string]any{\\n   687→\\t\\t\\t\\\"checkpoint_remote\\\": map[string]any{\\n   688→\\t\\t\\t\\t\\\"provider\\\": \\\"github\\\",\\n   689→\\t\\t\\t\\t\\\"repo\\\":     \\\"nonexistent-org/nonexistent-repo\\\",\\n   690→\\t\\t\\t},\\n   691→\\t\\t},\\n   692→\\t})\\n   693→\\n   694→\\t// Starting a new session should not error even though checkpoint_remote is unreachable.\\n   695→\\t// The session machinery itself doesn't trigger fetchMetadataBranchIfMissing (that happens\\n   696→\\t// in resolvePushSettings during PrePush), so this verifies the session starts cleanly.\\n   697→\\tsession := cloneEnv.NewSession()\\n   698→\\ttranscriptPath := session.CreateTranscript(\\\"Clone work\\\", []FileChange{\\n   699→\\t\\t{Path: \\\"clone.go\\\", Content: \\\"package clone\\\"},\\n   700→\\t})\\n   701→\\n   702→\\tif err := cloneEnv.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Clone work\\\", transcriptPath); err != nil {\\n   703→\\t\\tt.Fatalf(\\\"session start should not fail with unreachable checkpoint_remote: %v\\\", err)\\n   704→\\t}\\n   705→\\n   706→\\tif err := cloneEnv.SimulateStop(session.ID, transcriptPath); err != nil {\\n   707→\\t\\tt.Fatalf(\\\"session stop should not fail: %v\\\", err)\\n   708→\\t}\\n   709→\\n   710→\\t// PrePush should also not fail -- checkpoint_remote URL derivation will fail\\n   711→\\t// (origin is a local path, can't parse it), so it falls back to pushing to origin.\\n   712→\\tcloneEnv.WriteFile(\\\"clone.go\\\", \\\"package clone\\\")\\n   713→\\tcloneEnv.GitAdd(\\\"clone.go\\\")\\n   714→\\tcloneEnv.GitCommitWithShadowHooks(\\\"Clone work\\\", \\\"clone.go\\\")\\n   715→\\tcloneEnv.RunPrePush(\\\"origin\\\")\\n   716→\\n   717→\\t// Verify that the session actually created a local checkpoint despite the\\n   718→\\t// unreachable checkpoint_remote config.\\n   719→\\tif !cloneEnv.BranchExists(paths.MetadataBranchName) {\\n   720→\\t\\tt.Error(\\\"entire/checkpoints/v1 should exist locally after session + commit in clone\\\")\\n   721→\\t}\\n   722→}\\n   723→\\n   724→// =============================================================================\\n   725→// Helpers\\n   726→// =============================================================================\\n   727→\\n   728→// ensureTrailsBranchExists creates the trails branch if it doesn't already exist.\\n   729→// This is used in tests that need to make unconditional assertions about trails\\n   730→// being pushed, since the basic session + commit flow does not always create trails.\\n   731→func ensureTrailsBranchExists(t *testing.T, env *TestEnv) {\\n   732→\\tt.Helper()\\n   733→\\tif !env.BranchExists(paths.TrailsBranchName) {\\n   734→\\t\\tcreateOrphanBranch(t, env.RepoDir, paths.TrailsBranchName, \\\"trails.json\\\", `{\\\"test\\\": true}`)\\n   735→\\t}\\n   736→}\\n   737→\\n   738→// createOrphanBranch creates a minimal orphan branch with a single file using\\n   739→// go-git plumbing APIs. This avoids switching the working tree (which would\\n   740→// conflict with other files and the test binary).\\n   741→func createOrphanBranch(t *testing.T, repoDir, branchName, fileName, content string) {\\n   742→\\tt.Helper()\\n   743→\\n   744→\\trepo, err := git.PlainOpen(repoDir)\\n   745→\\tif err != nil {\\n   746→\\t\\tt.Fatalf(\\\"failed to open repo: %v\\\", err)\\n   747→\\t}\\n   748→\\n   749→\\t// Create a blob for the file content\\n   750→\\tblobObj := repo.Storer.NewEncodedObject()\\n   751→\\tblobObj.SetType(plumbing.BlobObject)\\n   752→\\tw, err := blobObj.Writer()\\n   753→\\tif err != nil {\\n   754→\\t\\tt.Fatalf(\\\"failed to create blob writer: %v\\\", err)\\n   755→\\t}\\n   756→\\tif _, err := w.Write([]byte(content)); err != nil {\\n   757→\\t\\tt.Fatalf(\\\"failed to write blob: %v\\\", err)\\n   758→\\t}\\n   759→\\tif err := w.Close(); err != nil {\\n   760→\\t\\tt.Fatalf(\\\"failed to close blob writer: %v\\\", err)\\n   761→\\t}\\n   762→\\tblobHash, err := repo.Storer.SetEncodedObject(blobObj)\\n   763→\\tif err != nil {\\n   764→\\t\\tt.Fatalf(\\\"failed to store blob: %v\\\", err)\\n   765→\\t}\\n   766→\\n   767→\\t// Create a tree with the single file\\n   768→\\ttree := &object.Tree{\\n   769→\\t\\tEntries: []object.TreeEntry{\\n   770→\\t\\t\\t{\\n   771→\\t\\t\\t\\tName: fileName,\\n   772→\\t\\t\\t\\tMode: filemode.Regular,\\n   773→\\t\\t\\t\\tHash: blobHash,\\n   774→\\t\\t\\t},\\n   775→\\t\\t},\\n   776→\\t}\\n   777→\\ttreeObj := repo.Storer.NewEncodedObject()\\n   778→\\tif err := tree.Encode(treeObj); err != nil {\\n   779→\\t\\tt.Fatalf(\\\"failed to encode tree: %v\\\", err)\\n   780→\\t}\\n   781→\\ttreeHash, err := repo.Storer.SetEncodedObject(treeObj)\\n   782→\\tif err != nil {\\n   783→\\t\\tt.Fatalf(\\\"failed to store tree: %v\\\", err)\\n   784→\\t}\\n   785→\\n   786→\\t// Create a root commit (no parents = orphan)\\n   787→\\tnow := time.Now()\\n   788→\\tsig := object.Signature{\\n   789→\\t\\tName:  \\\"Test User\\\",\\n   790→\\t\\tEmail: \\\"test@example.com\\\",\\n   791→\\t\\tWhen:  now,\\n   792→\\t}\\n   793→\\tcommit := &object.Commit{\\n   794→\\t\\tTreeHash:  treeHash,\\n   795→\\t\\tAuthor:    sig,\\n   796→\\t\\tCommitter: sig,\\n   797→\\t\\tMessage:   \\\"init \\\" + branchName,\\n   798→\\t}\\n   799→\\tcommitObj := repo.Storer.NewEncodedObject()\\n   800→\\tif err := commit.Encode(commitObj); err != nil {\\n   801→\\t\\tt.Fatalf(\\\"failed to encode commit: %v\\\", err)\\n   802→\\t}\\n   803→\\tcommitHash, err := repo.Storer.SetEncodedObject(commitObj)\\n   804→\\tif err != nil {\\n   805→\\t\\tt.Fatalf(\\\"failed to store commit: %v\\\", err)\\n   806→\\t}\\n   807→\\n   808→\\t// Create the branch reference\\n   809→\\tref := plumbing.NewHashReference(plumbing.NewBranchReferenceName(branchName), commitHash)\\n   810→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   811→\\t\\tt.Fatalf(\\\"failed to create branch ref %s: %v\\\", branchName, err)\\n   812→\\t}\\n   813→}\\n   814→\\n   815→// pushBranchToTarget pushes a branch to a target (remote name or bare repo path).\\n   816→// This simulates what pushBranchIfNeeded does. Fails the test on error.\\n   817→func pushBranchToTarget(t *testing.T, repoDir, target, branchName string) {\\n   818→\\tt.Helper()\\n   819→\\n   820→\\tif err := pushBranchToTargetWithError(t, repoDir, target, branchName); err != nil {\\n   821→\\t\\tt.Fatalf(\\\"push %s to %s failed: %v\\\", branchName, target, err)\\n   822→\\t}\\n   823→}\\n   824→\\n   825→// pushBranchToTargetWithError pushes a branch and returns any error.\\n   826→func pushBranchToTargetWithError(t *testing.T, repoDir, target, branchName string) error {\\n   827→\\tt.Helper()\\n   828→\\n   829→\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"push\\\", \\\"--no-verify\\\", target, branchName)\\n   830→\\tcmd.Dir = repoDir\\n   831→\\tcmd.Env = testutil.GitIsolatedEnv()\\n   832→\\tcmd.Stdin = nil\\n   833→\\n   834→\\toutput, err := cmd.CombinedOutput()\\n   835→\\tif err != nil {\\n   836→\\t\\tt.Logf(\\\"push output: %s\\\", output)\\n   837→\\t\\treturn err\\n   838→\\t}\\n   839→\\treturn nil\\n   840→}\\n   841→\\n   842→// fileExistsOnRemoteBranch checks if a file exists in the metadata branch tree on a bare remote.\\n   843→func fileExistsOnRemoteBranch(t *testing.T, bareDir, filePath string) bool {\\n   844→\\tt.Helper()\\n   845→\\n   846→\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"cat-file\\\", \\\"-t\\\", paths.MetadataBranchName+\\\":\\\"+filePath)\\n   847→\\tcmd.Dir = bareDir\\n   848→\\tcmd.Env = testutil.GitIsolatedEnv()\\n   849→\\treturn cmd.Run() == nil\\n   850→}\\n   851→\\n   852→// getRemoteBranchHash returns the commit hash of a branch on a bare remote.\\n   853→func getRemoteBranchHash(t *testing.T, bareDir, branchName string) string {\\n   854→\\tt.Helper()\\n   855→\\n   856→\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"rev-parse\\\", \\\"refs/heads/\\\"+branchName)\\n   857→\\tcmd.Dir = bareDir\\n   858→\\tcmd.Env = testutil.GitIsolatedEnv()\\n   859→\\toutput, err := cmd.Output()\\n   860→\\tif err != nil {\\n   861→\\t\\tt.Fatalf(\\\"failed to get hash for %s on remote: %v\\\", branchName, err)\\n   862→\\t}\\n   863→\\treturn strings