    29→// or they share a common ancestor (normal divergence handled by push merge).\\n    30→// Returns (true, nil) only when both exist and are truly disconnected.\\n    31→func IsMetadataDisconnected(ctx context.Context, repo *git.Repository) (bool, error) {\\n    32→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n    33→\\tlocalRef, err := repo.Reference(refName, true)\\n    34→\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n    35→\\t\\treturn false, nil\\n    36→\\t}\\n    37→\\tif err != nil {\\n    38→\\t\\treturn false, fmt.Errorf(\\\"failed to check local metadata branch: %w\\\", err)\\n    39→\\t}\\n    40→\\n    41→\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n    42→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n    43→\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n    44→\\t\\treturn false, nil\\n    45→\\t}\\n    46→\\tif err != nil {\\n    47→\\t\\treturn false, fmt.Errorf(\\\"failed to check remote metadata branch: %w\\\", err)\\n    48→\\t}\\n    49→\\n    50→\\tif localRef.Hash() == remoteRef.Hash() {\\n    51→\\t\\treturn false, nil\\n    52→\\t}\\n    53→\\n    54→\\trepoPath, err := getRepoPath(repo)\\n    55→\\tif err != nil {\\n    56→\\t\\treturn false, err\\n    57→\\t}\\n    58→\\n    59→\\treturn isDisconnected(ctx, repoPath, localRef.Hash().String(), remoteRef.Hash().String())\\n    60→}\\n    61→\\n    62→// WarnIfMetadataDisconnected checks (once per process) whether the metadata\\n    63→// branch is disconnected and prints a warning to stderr if so.\\n    64→// It does NOT fix the problem — users are directed to 'entire doctor'.\\n    65→//\\n    66→// Uses sync.Once, so a transient failure on the first call permanently suppresses\\n    67→// the warning. This is acceptable because the check is advisory only and\\n    68→// 'entire doctor' is the authoritative repair path.\\n    69→func WarnIfMetadataDisconnected() {\\n    70→\\tdisconnectedOnce.Do(func() {\\n    71→\\t\\tctx := context.Background()\\n    72→\\t\\trepo, err := OpenRepository(ctx)\\n    73→\\t\\tif err != nil {\\n    74→\\t\\t\\tlogging.Debug(ctx, \\\"metadata disconnection check: could not open repository\\\",\\n    75→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n    76→\\t\\t\\treturn\\n    77→\\t\\t}\\n    78→\\t\\tdisconnected, err := IsMetadataDisconnected(ctx, repo)\\n    79→\\t\\tif err != nil {\\n    80→\\t\\t\\tlogging.Debug(ctx, \\\"metadata disconnection check failed\\\",\\n    81→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n    82→\\t\\t\\treturn\\n    83→\\t\\t}\\n    84→\\t\\tif !disconnected {\\n    85→\\t\\t\\treturn\\n    86→\\t\\t}\\n    87→\\t\\tfmt.Fprintln(os.Stderr, \\\"[entire] Warning: Local and remote session metadata branches are disconnected.\\\")\\n    88→\\t\\tfmt.Fprintln(os.Stderr, \\\"[entire] Some checkpoints from remote may not be visible. Run 'entire doctor' to fix.\\\")\\n    89→\\t})\\n    90→}\\n    91→\\n    92→// ReconcileDisconnectedMetadataBranch detects and repairs disconnected local/remote\\n    93→// entire/checkpoints/v1 branches. Disconnected means no common ancestor, which\\n    94→// only happens due to the empty-orphan bug. Diverged (shared ancestor) is normal\\n    95→// and handled by the push path's tree merge.\\n    96→//\\n    97→// Repair strategy: cherry-pick local commits onto remote tip, preserving all data.\\n    98→// Checkpoint shards use unique paths (<id[:2]>/<id[2:]>/), so cherry-picks always\\n    99→// apply cleanly.\\n   100→//\\n   101→// Progress messages are written to w (typically os.Stderr for hooks or\\n   102→// cmd.ErrOrStderr() for commands).\\n   103→func ReconcileDisconnectedMetadataBranch(ctx context.Context, repo *git.Repository, w io.Writer) error {\\n   104→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   105→\\n   106→\\t// Check local branch\\n   107→\\tlocalRef, err := repo.Reference(refName, true)\\n   108→\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n   109→\\t\\treturn nil // No local branch — nothing to reconcile\\n   110→\\t}\\n   111→\\tif err != nil {\\n   112→\\t\\treturn fmt.Errorf(\\\"failed to check local metadata branch: %w\\\", err)\\n   113→\\t}\\n   114→\\n   115→\\t// Check remote-tracking branch\\n   116→\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n   117→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n   118→\\tif errors.Is(err, plumbing.ErrReferenceNotFound) {\\n   119→\\t\\treturn nil // No remote branch — nothing to reconcile\\n   120→\\t}\\n   121→\\tif err != nil {\\n   122→\\t\\treturn fmt.Errorf(\\\"failed to check remote metadata branch: %w\\\", err)\\n   123→\\t}\\n   124→\\n   125→\\tlocalHash := localRef.Hash()\\n   126→\\tremoteHash := remoteRef.Hash()\\n   127→\\n   128→\\t// Same hash — nothing to do\\n   129→\\tif localHash == remoteHash {\\n   130→\\t\\treturn nil\\n   131→\\t}\\n   132→\\n   133→\\t// Check if disconnected using git merge-base\\n   134→\\trepoPath, err := getRepoPath(repo)\\n   135→\\tif err != nil {\\n   136→\\t\\treturn err\\n   137→\\t}\\n   138→\\n   139→\\tdisconnected, err := isDisconnected(ctx, repoPath, localHash.String(), remoteHash.String())\\n   140→\\tif err != nil {\\n   141→\\t\\treturn fmt.Errorf(\\\"failed to check metadata branch ancestry: %w\\\", err)\\n   142→\\t}\\n   143→\\tif !disconnected {\\n   144→\\t\\t// Shared ancestry (diverged or ancestor) — not our problem\\n   145→\\t\\treturn nil\\n   146→\\t}\\n   147→\\n   148→\\t// Disconnected — cherry-pick local commits onto remote tip\\n   149→\\tfmt.Fprintln(w, \\\"[entire] Detected disconnected session metadata (local and remote share no common ancestor)\\\")\\n   150→\\n   151→\\t// Collect local commits oldest-first\\n   152→\\tlocalCommits, err := collectCommitChain(repo, localHash)\\n   153→\\tif err != nil {\\n   154→\\t\\treturn fmt.Errorf(\\\"failed to collect local commits: %w\\\", err)\\n   155→\\t}\\n   156→\\n   157→\\t// Filter out empty-tree commits (the orphan bug commit)\\n   158→\\tvar dataCommits []*object.Commit\\n   159→\\tfor _, c := range localCommits {\\n   160→\\t\\ttree, treeErr := c.Tree()\\n   161→\\t\\tif treeErr != nil {\\n   162→\\t\\t\\treturn fmt.Errorf(\\\"failed to read tree for commit %s: %w\\\", c.Hash.String()[:7], treeErr)\\n   163→\\t\\t}\\n   164→\\t\\tif len(tree.Entries) > 0 {\\n   165→\\t\\t\\tdataCommits = append(dataCommits, c)\\n   166→\\t\\t}\\n   167→\\t}\\n   168→\\n   169→\\tif len(dataCommits) == 0 {\\n   170→\\t\\t// Local only had empty orphan — just point to remote\\n   171→\\t\\tref := plumbing.NewHashReference(refName, remoteHash)\\n   172→\\t\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   173→\\t\\t\\treturn fmt.Errorf(\\\"failed to reset metadata branch to remote: %w\\\", err)\\n   174→\\t\\t}\\n   175→\\t\\tfmt.Fprintln(w, \\\"[entire] Done — local had no checkpoint data, reset to remote\\\")\\n   176→\\t\\treturn nil\\n   177→\\t}\\n   178→\\n   179→\\tfmt.Fprintf(w, \\\"[entire] Cherry-picking %d local checkpoint(s) onto remote...\\\\n\\\", len(dataCommits))\\n   180→\\n   181→\\tnewTip, err := cherryPickOnto(repo, remoteHash, dataCommits)\\n   182→\\tif err != nil {\\n   183→\\t\\treturn fmt.Errorf(\\\"failed to cherry-pick local commits onto remote: %w\\\", err)\\n   184→\\t}\\n   185→\\n   186→\\t// Update local branch ref\\n   187→\\tref := plumbing.NewHashReference(refName, newTip)\\n   188→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   189→\\t\\treturn fmt.Errorf(\\\"failed to update metadata branch: %w\\\", err)\\n   190→\\t}\\n   191→\\n   192→\\tfmt.Fprintln(w, \\\"[entire] Done — all local and remote checkpoints preserved\\\")\\n   193→\\treturn nil\\n   194→}\\n   195→\\n   196→// isDisconnected checks if two commits have no common ancestor using git merge-base.\\n   197→// Returns (true, nil) if disconnected, (false, nil) if they share ancestry,\\n   198→// or (false, error) if git merge-base failed for another reason.\\n   199→//\\n   200→// git merge-base exit codes:\\n   201→//   - 0: common ancestor found (shared ancestry)\\n   202→//   - 1: no common ancestor (disconnected)\\n   203→//   - 128+: error (corrupt repo, invalid hash, etc.)\\n   204→func isDisconnected(ctx context.Context, repoPath, hashA, hashB string) (bool, error) {\\n   205→\\tctx, cancel := context.WithTimeout(ctx, 10*time.Second)\\n   206→\\tdefer cancel()\\n   207→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"merge-base\\\", hashA, hashB)\\n   208→\\tcmd.Dir = repoPath\\n   209→\\tif err := cmd.Run(); err != nil {\\n   210→\\t\\tvar exitErr *exec.ExitError\\n   211→\\t\\tif errors.As(err, &exitErr) && exitErr.ExitCode() == 1 {\\n   212→\\t\\t\\treturn true, nil // No common ancestor — disconnected\\n   213→\\t\\t}\\n   214→\\t\\treturn false, fmt.Errorf(\\\"git merge-base failed: %w\\\", err)\\n   215→\\t}\\n   216→\\treturn false, nil // Shared ancestry\\n   217→}\\n   218→\\n   219→// collectCommitChain walks from tip to root following first parent, returns oldest-first.\\n   220→func collectCommitChain(repo *git.Repository, tip plumbing.Hash) ([]*object.Commit, error) {\\n   221→\\tvar chain []*object.Commit\\n   222→\\tcurrent := tip\\n   223→\\n   224→\\treachedRoot := false\\n   225→\\tfor range MaxCommitTraversalDepth {\\n   226→\\t\\tcommit, err := repo.CommitObject(current)\\n   227→\\t\\tif err != nil {\\n   228→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit %s: %w\\\", current, err)\\n   229→\\t\\t}\\n   230→\\t\\tchain = append(chain, commit)\\n   231→\\n   232→\\t\\tif len(commit.ParentHashes) == 0 {\\n   233→\\t\\t\\treachedRoot = true\\n   234→\\t\\t\\tbreak\\n   235→\\t\\t}\\n   236→\\t\\tcurrent = commit.ParentHashes[0]\\n   237→\\t}\\n   238→\\n   239→\\tif !reachedRoot {\\n   240→\\t\\treturn nil, fmt.Errorf(\\\"commit chain exceeded %d commits without reaching root; aborting reconciliation\\\", MaxCommitTraversalDepth)\\n   241→\\t}\\n   242→\\n   243→\\t// Reverse to oldest-first\\n   244→\\tfor i, j := 0, len(chain)-1; i < j; i, j = i+1, j-1 {\\n   245→\\t\\tchain[i], chain[j] = chain[j], chain[i]\\n   246→\\t}\\n   247→\\n   248→\\treturn chain, nil\\n   249→}\\n   250→\\n   251→// cherryPickOnto applies each commit's delta onto base, building a linear chain.\\n   252→// For each commit, it computes the full diff from its parent (additions, modifications,\\n   253→// and deletions), then applies that delta onto the current tip's tree.\\n   254→func cherryPickOnto(repo *git.Repository, base plumbing.Hash, commits []*object.Commit) (plumbing.Hash, error) {\\n   255→\\tcurrentTip := base\\n   256→\\n   257→\\tfor _, commit := range commits {\\n   258→\\t\\t// Get the commit's tree entries\\n   259→\\t\\tcommitTree, err := commit.Tree()\\n   260→\\t\\tif err != nil {\\n   261→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get tree for commit %s: %w\\\", commit.Hash, err)\\n   262→\\t\\t}\\n   263→\\n   264→\\t\\tcommitEntries := make(map[string]object.TreeEntry)\\n   265→\\t\\tif err := checkpoint.FlattenTree(repo, commitTree, \\\"\\\", commitEntries); err != nil {\\n   266→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten commit tree: %w\\\", err)\\n   267→\\t\\t}\\n   268→\\n   269→\\t\\t// Get parent's tree entries (empty if root commit)\\n   270→\\t\\tparentEntries := make(map[string]object.TreeEntry)\\n   271→\\t\\tif len(commit.ParentHashes) > 0 {\\n   272→\\t\\t\\tparentCommit, pErr := repo.CommitObject(commit.ParentHashes[0])\\n   273→\\t\\t\\tif pErr != nil {\\n   274→\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get parent commit %s: %w\\\", commit.ParentHashes[0], pErr)\\n   275→\\t\\t\\t}\\n   276→\\t\\t\\tparentTree, ptErr := parentCommit.Tree()\\n   277→\\t\\t\\tif ptErr != nil {\\n   278→\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get parent tree for commit %s: %w\\\", commit.ParentHashes[0], ptErr)\\n   279→\\t\\t\\t}\\n   280→\\t\\t\\tif err := checkpoint.FlattenTree(repo, parentTree, \\\"\\\", parentEntries); err != nil {\\n   281→\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten parent tree for commit %s: %w\\\", commit.ParentHashes[0], err)\\n   282→\\t\\t\\t}\\n   283→\\t\\t}\\n   284→\\n   285→\\t\\t// Compute full delta: additions, modifications, and deletions\\n   286→\\t\\tadded := make(map[string]object.TreeEntry)\\n   287→\\t\\tfor path, entry := range commitEntries {\\n   288→\\t\\t\\tparentEntry, exists := parentEntries[path]\\n   289→\\t\\t\\tif !exists || parentEntry.Hash != entry.Hash {\\n   290→\\t\\t\\t\\tadded[path] = entry // New or modified\\n   291→\\t\\t\\t}\\n   292→\\t\\t}\\n   293→\\t\\tvar deleted []string\\n   294→\\t\\tfor path := range parentEntries {\\n   295→\\t\\t\\tif _, exists := commitEntries[path]; !exists {\\n   296→\\t\\t\\t\\tdeleted = append(deleted, path) // Removed in this commit\\n   297→\\t\\t\\t}\\n   298→\\t\\t}\\n   299→\\n   300→\\t\\tif len(added) == 0 && len(deleted) == 0 {\\n   301→\\t\\t\\tcontinue // Skip no-op commits\\n   302→\\t\\t}\\n   303→\\n   304→\\t\\t// Get current tip's tree and apply delta\\n   305→\\t\\ttipCommit, err := repo.CommitObject(currentTip)\\n   306→\\t\\tif err != nil {\\n   307→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get tip commit: %w\\\", err)\\n   308→\\t\\t}\\n   309→\\t\\ttipTree, err := tipCommit.Tree()\\n   310→\\t\\tif err != nil {\\n   311→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get tip tree: %w\\\", err)\\n   312→\\t\\t}\\n   313→\\n   314→\\t\\tmergedEntries := make(map[string]object.TreeEntry)\\n   315→\\t\\tif err := checkpoint.FlattenTree(repo, tipTree, \\\"\\\", mergedEntries); err != nil {\\n   316→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten tip tree: %w\\\", err)\\n   317→\\t\\t}\\n   318→\\t\\tfor path, entry := range added {\\n   319→\\t\\t\\tmergedEntries[path] = entry\\n   320→\\t\\t}\\n   321→\\t\\tfor _, path := range deleted {\\n   322→\\t\\t\\tdelete(mergedEntries, path)\\n   323→\\t\\t}\\n   324→\\n   325→\\t\\tmergedTreeHash, err := checkpoint.BuildTreeFromEntries(repo, mergedEntries)\\n   326→\\t\\tif err != nil {\\n   327→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to build merged tree: %w\\\", err)\\n   328→\\t\\t}\\n   329→\\n   330→\\t\\t// Create new commit on top of current tip, preserving original message/author\\n   331→\\t\\tnewHash, err := createCherryPickCommit(repo, mergedTreeHash, currentTip, commit)\\n   332→\\t\\tif err != nil {\\n   333→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create cherry-pick commit: %w\\\", err)\\n   334→\\t\\t}\\n   335→\\n   336→\\t\\tcurrentTip = newHash\\n   337→\\t}\\n   338→\\n   339→\\treturn currentTip, nil\\n   340→}\\n   341→\\n   342→// createCherryPickCommit creates a new commit on top of parent, preserving the\\n   343→// original commit's message and author.\\n   344→func createCherryPickCommit(repo *git.Repository, treeHash, parent plumbing.Hash, original *object.Commit) (plumbing.Hash, error) {\\n   345→\\tcommitterName, committerEmail := GetGitAuthorFromRepo(repo)\\n   346→\\tnow := time.Now()\\n   347→\\n   348→\\tcommit := &object.Commit{\\n   349→\\t\\tTreeHash:     treeHash,\\n   350→\\t\\tParentHashes: []plumbing.Hash{parent},\\n   351→\\t\\tAuthor:       original.Author,\\n   352→\\t\\tCommitter: object.Signature{\\n   353→\\t\\t\\tName:  committerName,\\n   354→\\t\\t\\tEmail: committerEmail,\\n   355→\\t\\t\\tWhen:  now,\\n   356→\\t\\t},\\n   357→\\t\\tMessage: original.Message,\\n   358→\\t}\\n   359→\\n   360→\\tobj := repo.Storer.NewEncodedObject()\\n   361→\\tif err := commit.Encode(obj); err != nil {\\n   362→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n   363→\\t}\\n   364→\\n   365→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n   366→\\tif 