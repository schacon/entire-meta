p.MustCompile(`(?i)delete\\\\s+(?:the\\\\s+)?(?:file\\\\s+)?(?:at\\\\s+)?([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   127→\\t// \\\"commit\\\" anywhere in the prompt, but not \\\"do not commit\\\" / \\\"don't commit\\\"\\n   128→\\tcommitRe = regexp.MustCompile(`(?i)(?:then\\\\s+|now\\\\s+)?(?:git\\\\s+)?commit\\\\b`)\\n   129→\\t// Negative: \\\"do not commit\\\" / \\\"don't commit\\\" with optional object, at sentence boundary\\n   130→\\t// Matches: \\\"Do not commit.\\\", \\\"Do not commit the file.\\\", \\\"Do not commit them,\\\"\\n   131→\\t// Does NOT match: \\\"Do not commit any other files\\\" (different intent)\\n   132→\\tnoCommitRe = regexp.MustCompile(`(?i)(?:do\\\\s+not|don'?t)\\\\s+commit(?:\\\\s+(?:it|them|the\\\\s+\\\\w+))?(?:\\\\.|,|$)`)\\n   133→\\t// \\\"commit each file separately\\\" — interleave create+commit\\n   134→\\tcommitSeparatelyRe = regexp.MustCompile(`(?i)commit\\\\s+each\\\\s+file\\\\s+separately`)\\n   135→\\t// Individual file in multi-create: \\\"docs/a.md about apples\\\"\\n   136→\\t// Topic capture stops at comma, \\\"and\\\", period followed by space+uppercase, or end\\n   137→\\tmultiFileItemRe = regexp.MustCompile(`([^\\\\s,]+\\\\.(?:` + fileExt + `))\\\\s+(?:about\\\\s+|with\\\\s+|containing\\\\s+)?(.+?)(?:,\\\\s*|\\\\s+and\\\\s+|\\\\.\\\\s+[A-Z]|\\\\.\\\\s*$)`)\\n   138→\\t// Individual file in multi-modify: \\\"src/model.go should define ...\\\"\\n   139→\\tmodifyItemRe = regexp.MustCompile(`([^\\\\s,]+\\\\.(?:` + fileExt + `))\\\\s+should\\\\s+(.+?)(?:,|$)`)\\n   140→\\t// \\\"In src/a.go, add ...\\\" pattern for multi-modify\\n   141→\\tinFileRe = regexp.MustCompile(`[Ii]n\\\\s+([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   142→\\t// Inline content: \\\"with content 'package main; func Foo() {}'\\\"\\n   143→\\tinlineContentRe = regexp.MustCompile(`(?i)with\\\\s+content\\\\s+['\\\"]([^'\\\"]+)['\\\"]`)\\n   144→\\t// Numbered steps: \\\"(1) ... (2) ... (3) ...\\\"\\n   145→\\tnumberedStepRe = regexp.MustCompile(`\\\\(\\\\d+\\\\)\\\\s+`)\\n   146→\\t// Explicit git command: \\\"Run: git add ... && git commit -m '...'\\\"\\n   147→\\texplicitGitRe = regexp.MustCompile(`(?i)run:?\\\\s+git\\\\s+add\\\\s+.+(?:&&\\\\s*git\\\\s+commit|;\\\\s*git\\\\s+commit)`)\\n   148→\\t// \\\"about the colour red\\\" → \\\"the colour red\\\"\\n   149→\\ttopicRe = regexp.MustCompile(`(?i)about\\\\s+(.+?)(?:\\\\.|,|\\\\s+Do\\\\s|\\\\s+do\\\\s|\\\\s+then\\\\s|$)`)\\n   150→\\t// Fallback: extract any file path from text\\n   151→\\tanyFileRe = regexp.MustCompile(`([^\\\\s,]+\\\\.(?:` + fileExt + `))`)\\n   152→)\\n   153→\\n   154→func parsePrompt(prompt string) []action {\\n   155→\\t// Check for numbered-step prompts — parse each step independently to\\n   156→\\t// preserve ordering (e.g., create, commit, then create more).\\n   157→\\tif numberedStepRe.MatchString(prompt) {\\n   158→\\t\\treturn parseNumberedSteps(prompt)\\n   159→\\t}\\n   160→\\tvar actions []action\\n   161→\\n   162→\\t// Multi-file modify: \\\"modify these three files: src/model.go should ..., src/view.go should ...\\\"\\n   163→\\t// Also matches: \\\"Modify two existing files. In src/a.go, add ...\\\"\\n   164→\\tif m := modifyMultiRe.FindStringSubmatch(prompt); m != nil {\\n   165→\\t\\t// Try \\\"should\\\" pattern first\\n   166→\\t\\titems := modifyItemRe.FindAllStringSubmatch(m[1], -1)\\n   167→\\t\\tfor _, item := range items {\\n   168→\\t\\t\\tactions = append(actions, action{\\n   169→\\t\\t\\t\\tkind:    \\\"modify\\\",\\n   170→\\t\\t\\t\\tpath:    item[1],\\n   171→\\t\\t\\t\\tcontent: \\\"// \\\" + strings.TrimSpace(item[2]) + \\\"\\\\n\\\",\\n   172→\\t\\t\\t})\\n   173→\\t\\t}\\n   174→\\t\\t// Try \\\"In <path>\\\" pattern as fallback\\n   175→\\t\\tif len(actions) == 0 {\\n   176→\\t\\t\\tfor _, item := range inFileRe.FindAllStringSubmatch(m[1], -1) {\\n   177→\\t\\t\\t\\tactions = append(actions, action{\\n   178→\\t\\t\\t\\t\\tkind:    \\\"modify\\\",\\n   179→\\t\\t\\t\\t\\tpath:    item[1],\\n   180→\\t\\t\\