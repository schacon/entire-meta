" {\\n    53→\\t\\t// Headless mode: single prompt\\n    54→\\t\\trunTurn(dir, sessionID, transcriptPath, prompt)\\n    55→\\t} else {\\n    56→\\t\\t// Interactive mode: read prompts from stdin\\n    57→\\t\\tfmt.Fprint(os.Stdout, \\\"> \\\")\\n    58→\\t\\tscanner := bufio.NewScanner(os.Stdin)\\n    59→\\t\\tfor scanner.Scan() {\\n    60→\\t\\t\\tline := strings.TrimSpace(scanner.Text())\\n    61→\\t\\t\\tif line == \\\"\\\" || line == \\\"exit\\\" || line == \\\"quit\\\" {\\n    62→\\t\\t\\t\\tbreak\\n    63→\\t\\t\\t}\\n    64→\\t\\t\\t// Give tmux's Send() time to capture the echoed-input state\\n    65→\\t\\t\\t// before we produce any output. Send polls every 200ms; without\\n    66→\\t\\t\\t// this pause, vogon output appears in the same capture window\\n    67→\\t\\t\\t// as the echo, causing stableAtSend to include final output and\\n    68→\\t\\t\\t// preventing WaitFor's contentChanged detection.\\n    69→\\t\\t\\ttime.Sleep(700 * time.Millisecond)\\n    70→\\t\\t\\tfmt.Fprintln(os.Stdout, \\\"Working...\\\")\\n    71→\\t\\t\\trunTurn(dir, sessionID, transcriptPath, line)\\n    72→\\t\\t\\tfmt.Fprint(os.Stdout, \\\"> \\\")\\n    73→\\t\\t}\\n    74→\\t}\\n    75→\\n    76→\\tfireHook(dir, \\\"session-end\\\", map[string]string{\\n    77→\\t\\t\\\"session_id\\\":      sessionID,\\n    78→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n    79→\\t})\\n    80→}\\n    81→\\n    82→func runTurn(dir, sessionID, transcriptPath, prompt string) {\\n    83→\\tfireHook(dir, \\\"user-prompt-submit\\\", map[string]any{\\n    84→\\t\\t\\\"session_id\\\":      sessionID,\\n    85→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n    86→\\t\\t\\\"prompt\\\":          prompt,\\n    87→\\t})\\n    88→\\n    89→\\tappendTranscript(transcriptPath, \\\"user\\\", prompt)\\n    90→\\n    91→\\tactions := parsePrompt(prompt)\\n    92→\\texecuteActions(dir, actions)\\n    93→\\n    94→\\tappendTranscript(transcriptPath, \\\"assistant\\\", fmt.Sprintf(\\\"Done. Executed %d actions