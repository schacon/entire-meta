r)\\n   588→\\t} else {\\n   589→\\t\\tbareDir = t.TempDir()\\n   590→\\t}\\n   591→\\n   592→\\tGit(t, bareDir, \\\"init\\\", \\\"--bare\\\")\\n   593→\\tGit(t, s.Dir, \\\"remote\\\", \\\"add\\\", \\\"origin\\\", bareDir)\\n   594→\\tGit(t, s.Dir, \\\"push\\\", \\\"-u\\\", \\\"origin\\\", \\\"HEAD\\\")\\n   595→\\treturn bareDir\\n   596→}\\n   597→\\n   598→// GitOutputErr runs a git command and returns (output, error) without\\n   599→// failing the test. For commands expected to fail.\\n   600→func GitOutputErr(dir string, args ...string) (string, error) {\\n   601→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   602→\\tif dir != \\\"\\\" {\\n   603→\\t\\tcmd.Dir = dir\\n   604→\\t}\\n   605→\\tout, err := cmd.CombinedOutput()\\n   606→\\treturn strings.TrimSpace(string(out)), err\\n   607→}\\n   608→\\n   609→// GetCheckpointTrailer extracts the Entire-Checkpoint trailer value from a\\n   610→// code commit. Returns the trimmed trailer value, or an empty string if the\\n   611→// trailer is not present.\\n   612→func GetCheckpointTrailer(t *testing.T, dir string, ref string) string {\\n   613→\\tt.Helper()\\n   614→\\n   615→\\treturn GitOutput(t, dir, \\\"log\\\", \\\"-1\\\", \\\"--format=%(trailers:key=Entire-Checkpoint,valueonly)\\\", ref)\\n   616→}\\n   617→\"}]},\"uuid\":\"a3a5b73a-3c24-4c3d-bbd0-4ef70fd4a09d\",\"timestamp\":\"2026-03-14T13:33:40.310Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a0db8b7180da30f89\"},\"toolUseID\":\"agent_msg_019wBA7esv8bw9EJUHxBZ8H2\",\"parentToolUseID\":\"toolu_01DUfJ49oqTPmjrow1P5kikF\",\"uuid\":\"06b38b77-13cf-4e51-b236-36f0c3f38a7a\",\"timestamp\":\"2026-03-14T13:33:40.312Z\",\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli_worktree1\",\"sessionId\":\"36636388-6a2e-45ad-ac63-5d08a06fbf23\",\"version\":\"2.1.76\",\"gitBranch\":\"soph/e2e-with-git-remote\",\"slug\":\"dazzling-moseying-otter\"}\n{\"parentUuid\":\"06b38b77-13cf-4e51-b236-36f0c3f38a7a\",\"isSidechain\":false,\"type\":