mitChain returns an error\\n   629→// when the commit chain exceeds MaxCommitTraversalDepth without reaching a root commit.\\n   630→func TestCollectCommitChain_DepthLimit(t *testing.T) {\\n   631→\\tt.Parallel()\\n   632→\\n   633→\\tdir := t.TempDir()\\n   634→\\trepo, err := git.PlainInit(dir, false)\\n   635→\\trequire.NoError(t, err)\\n   636→\\n   637→\\t// Create an empty tree for all commits.\\n   638→\\temptyTree := &object.Tree{Entries: []object.TreeEntry{}}\\n   639→\\ttreeObj := repo.Storer.NewEncodedObject()\\n   640→\\trequire.NoError(t, emptyTree.Encode(treeObj))\\n   641→\\ttreeHash, err := repo.Storer.SetEncodedObject(treeObj)\\n   642→\\trequire.NoError(t, err)\\n   643→\\n   644→\\t// Build a linear chain of MaxCommitTraversalDepth+1 commits (all have parents,\\n   645→\\t// so none is a root). collectCommitChain should bail out at the depth limit.\\n   646→\\tvar tip plumbing.Hash\\n   647→\\tfor i := range MaxCommitTraversalDepth + 1 {\\n   648→\\t\\tc := &object.Commit{\\n   649→\\t\\t\\tTreeHash:  treeHash,\\n   650→\\t\\t\\tAuthor:    object.Signature{Name: \\\"test\\\", Email: \\\"test@test.com\\\", When: time.Now().Add(time.Duration(i) * time.Second)},\\n   651→\\t\\t\\tCommitter: object.Signature{Name: \\\"test\\\", Email: \\\"test@test.com\\\", When: time.Now().Add(time.Duration(i) * time.Second)},\\n   652→\\t\\t\\tMessage:   \\\"commit\\\\n\\\",\\n   653→\\t\\t}\\n   654→\\t\\tif tip != plumbing.ZeroHash {\\n   655→\\t\\t\\tc.ParentHashes = []plumbing.Hash{tip}\\n   656→\\t\\t}\\n   657→\\t\\tobj := repo.Storer.NewEncodedObject()\\n   658→\\t\\trequire.NoError(t, c.Encode(obj))\\n   659→\\t\\th, sErr := repo.Storer.SetEncodedObject(obj)\\n   660→\\t\\trequire.NoError(t, sErr)\\n   661→\\t\\ttip = h\\n   662→\\t}\\n   663→\\n   664→\\t_, err = collectCommitChain(repo, tip)\\n   665→\\trequire.Error(t, err)\\n   666→\\tassert.Contains(t, err.Error(), \\\"exceeded\\\")\\n   667→\\tassert.Contains(t, err.Error(), \\\"without reaching root\\