→\\n    18→\\tbranchName := \\\"entire/checkpoints/v1\\\"\\n    19→\\n    20→\\tsetupRepo := func(t *testing.T) (*git.Repository, plumbing.Hash) {\\n    21→\\t\\tt.Helper()\\n    22→\\t\\ttmpDir := t.TempDir()\\n    23→\\t\\ttestutil.InitRepo(t, tmpDir)\\n    24→\\t\\ttestutil.WriteFile(t, tmpDir, \\\"f.txt\\\", \\\"init\\\")\\n    25→\\t\\ttestutil.GitAdd(t, tmpDir, \\\"f.txt\\\")\\n    26→\\t\\ttestutil.GitCommit(t, tmpDir, \\\"init\\\")\\n    27→\\n    28→\\t\\trepo, err := git.PlainOpen(tmpDir)\\n    29→\\t\\trequire.NoError(t, err)\\n    30→\\n    31→\\t\\thead, err := repo.Head()\\n    32→\\t\\trequire.NoError(t, err)\\n    33→\\n    34→\\t\\tlocalRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(branchName), head.Hash())\\n    35→\\t\\trequire.NoError(t, repo.Storer.SetReference(localRef))\\n    36→\\n    37→\\t\\treturn repo, head.Hash()\\n    38→\\t}\\n    39→\\n    40→\\tt.Run(\\\"no remote tracking ref exists\\\", func(t *testing.T) {\\n    41→\\t\\tt.Parallel()\\n    42→\\t\\trepo, headHash := setupRepo(t)\\n    43→\\t\\tassert.True(t, hasUnpushedSessionsCommon(repo, \\\"origin\\\", headHash, branchName))\\n    44→\\t})\\n    45→\\n    46→\\tt.Run(\\\"local and remote same hash\\\", func(t *testing.T) {\\n    47→\\t\\tt.Parallel()\\n    48→\\t\\trepo, headHash := setupRepo(t)\\n    49→\\n    50→\\t\\tremoteRef := plumbing.NewHashReference(\\n    51→\\t\\t\\tplumbing.NewRemoteReferenceName(\\\"origin\\\", branchName),\\n    52→\\t\\t\\theadHash,\\n    53→\\t\\t)\\n    54→\\t\\trequire.NoError(t, repo.Storer.SetReference(remoteRef))\\n    55→\\n    56→\\t\\tassert.False(t, hasUnpushedSessionsCommon(repo, \\\"origin\\\", headHash, branchName))\\n    57→\\t})\\n    58→\\n    59→\\tt.Run(\\\"local differs from remote\\\", func(t *testing.T) {\\n    60→\\t\\tt.Parallel()\\n    61→\\t\\trepo, _ := setupRepo(t)\\n    62→\\n    63→\\t\\tdifferentHash := plumbing.NewHash(\\\"aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa\\\")\\n    64→\\t\\tassert.True(t,