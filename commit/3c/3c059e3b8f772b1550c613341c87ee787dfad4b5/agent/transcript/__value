 1248→\\t}\\n  1249→\\n  1250→\\t// Extract checkpoint ID from commit message\\n  1251→\\t// Format: \\\"Checkpoint: <12-hex-char-id>\\\\n\\\\nSession: ...\\\\nStrategy: ...\\\"\\n  1252→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n  1253→\\t\\tline = strings.TrimSpace(line)\\n  1254→\\t\\tif strings.HasPrefix(line, \\\"Checkpoint: \\\") {\\n  1255→\\t\\t\\treturn strings.TrimPrefix(line, \\\"Checkpoint: \\\")\\n  1256→\\t\\t}\\n  1257→\\t}\\n  1258→\\n  1259→\\tenv.T.Fatalf(\\\"could not find checkpoint ID in %s branch commit message:\\\\n%s\\\",\\n  1260→\\t\\tpaths.MetadataBranchName, commit.Message)\\n  1261→\\treturn \\\"\\\"\\n  1262→}\\n  1263→\\n  1264→// TryGetLatestCheckpointID returns the most recent checkpoint ID from the entire/checkpoints/v1 branch.\\n  1265→// Returns empty string if the branch doesn't exist or has no checkpoint commits yet.\\n  1266→// Use this when you need to check if a checkpoint exists without failing the test.\\n  1267→func (env *TestEnv) TryGetLatestCheckpointID() string {\\n  1268→\\tenv.T.Helper()\\n  1269→\\n  1270→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1271→\\tif err != nil {\\n  1272→\\t\\treturn \\\"\\\"\\n  1273→\\t}\\n  1274→\\n  1275→\\t// Get the entire/checkpoints/v1 branch\\n  1276→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1277→\\tref, err := repo.Reference(refName, true)\\n  1278→\\tif err != nil {\\n  1279→\\t\\treturn \\\"\\\"\\n  1280→\\t}\\n  1281→\\n  1282→\\tcommit, err := repo.CommitObject(ref.Hash())\\n  1283→\\tif err != nil {\\n  1284→\\t\\treturn \\\"\\\"\\n  1285→\\t}\\n  1286→\\n  1287→\\t// Extract checkpoint ID from commit message\\n  1288→\\t// Format: \\\"Checkpoint: <12-hex-char-id>\\\\n\\\\nSession: ...\\\\nStrategy: ...\\\"\\n  1289→\\tfor _, line := range strings.Split(commit.Message, \\\"\\\\n\\\") {\\n  1290→\\t\\tline = strings.TrimSpace(line)\\n  1291→\\t\\tif strings.HasPrefix(line, \\\"Checkpoint: \\\") {\\n  1292→\\t\\t\\treturn strings.TrimPrefix(line, \\\"Checkpoint: \\\")\\n  1293→\\t\\t}\\n  1294→\\t}\\n  1295→\\n  1296→\\treturn \\\"\\\"\\n  1297→}\\n  1298→\\n  1299→// GetLatestCondensationID is an alias for GetLatestCheckpointID for backwards compatibility.\\n  1300→func (env *TestEnv) GetLatestCondensationID() string {\\n  1301→\\treturn env.GetLatestCheckpointID()\\n  1302→}\\n  1303→\\n  1304→// GetCheckpointIDFromCommitMessage extracts the Entire-Checkpoint trailer from a commit message.\\n  1305→// Returns empty string if no trailer found.\\n  1306→func (env *TestEnv) GetCheckpointIDFromCommitMessage(commitSHA string) string {\\n  1307→\\tenv.T.Helper()\\n  1308→\\n  1309→\\tmsg := env.GetCommitMessage(commitSHA)\\n  1310→\\tcpID, found := trailers.ParseCheckpoint(msg)\\n  1311→\\tif !found {\\n  1312→\\t\\treturn \\\"\\\"\\n  1313→\\t}\\n  1314→\\treturn cpID.String()\\n  1315→}\\n  1316→\\n  1317→// GetLatestCheckpointIDFromHistory walks backwards from HEAD on the active branch\\n  1318→// and returns the checkpoint ID from the first commit that has an Entire-Checkpoint trailer.\\n  1319→// This verifies that condensation actually happened (commit has trailer) without relying\\n  1320→// on timestamp-based matching.\\n  1321→func (env *TestEnv) GetLatestCheckpointIDFromHistory() string {\\n  1322→\\tenv.T.Helper()\\n  1323→\\n  1324→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1325→\\tif err != nil {\\n  1326→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1327→\\t}\\n  1328→\\n  1329→\\thead, err := repo.Head()\\n  1330→\\tif err != nil {\\n  1331→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n  1332→\\t}\\n  1333→\\n  1334→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n  1335→\\tif err != nil {\\n  1336→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n  1337→\\t}\\n  1338→\\n  1339→\\tvar checkpointID string\\n  1340→\\t//nolint:errcheck // ForEach callback handles errors\\n  1341→\\tcommitIter.Fo