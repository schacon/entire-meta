1177→\\treturn &OpenCodeHookRunner{\\n  1178→\\t\\tRepoDir:            repoDir,\\n  1179→\\t\\tOpenCodeProjectDir: openCodeProjectDir,\\n  1180→\\t\\tT:                  t,\\n  1181→\\t}\\n  1182→}\\n  1183→\\n  1184→func (r *OpenCodeHookRunner) runOpenCodeHookWithInput(hookName string, input interface{}) error {\\n  1185→\\tr.T.Helper()\\n  1186→\\n  1187→\\tinputJSON, err := json.Marshal(input)\\n  1188→\\tif err != nil {\\n  1189→\\t\\treturn fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n  1190→\\t}\\n  1191→\\n  1192→\\treturn r.runOpenCodeHookInRepoDir(hookName, inputJSON)\\n  1193→}\\n  1194→\\n  1195→func (r *OpenCodeHookRunner) runOpenCodeHookInRepoDir(hookName string, inputJSON []byte) error {\\n  1196→\\t// Command structure: entire hooks opencode <hook-name>\\n  1197→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"opencode\\\", hookName)\\n  1198→\\tcmd.Dir = r.RepoDir\\n  1199→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n  1200→\\tcmd.Env = append(testutil.GitIsolatedEnv(),\\n  1201→\\t\\t\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR=\\\"+r.OpenCodeProjectDir,\\n  1202→\\t\\t\\\"ENTIRE_TEST_OPENCODE_MOCK_EXPORT=1\\\", // Use pre-written mock transcript instead of calling opencode export\\n  1203→\\t)\\n  1204→\\n  1205→\\toutput, err := cmd.CombinedOutput()\\n  1206→\\tif err != nil {\\n  1207→\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n  1208→\\t\\t\\thookName, err, inputJSON, output)\\n  1209→\\t}\\n  1210→\\n  1211→\\tr.T.Logf(\\\"OpenCode hook %s output: %s\\\", hookName, output)\\n  1212→\\treturn nil\\n  1213→}\\n  1214→\\n  1215→// SimulateOpenCodeSessionStart simulates the session-start hook for OpenCode.\\n  1216→// Note: The plugin now sends only session_id, not transcript_path.\\n  1217→func (r *OpenCodeHookRunner) SimulateOpenCodeSessionStart(sessionID, _ string) error {\\n  1218→\\tr.T.Helper()\\n  1219→\\n  1220→\\tinput := map[string]string{\\n  1221→\\t\\t\\\"session_id\\\": sessionID,\\n  1222→\\t}\\n  1223→\\n  1224→\\treturn r.runOpenCodeHookWithInput(\\\"session-start\\\", input)\\n  1225→}\\n  1226→\\n  1227→// SimulateOpenCodeTurnStart simulates the turn-start hook for OpenCode.\\n  1228→// This is equivalent to Claude Code's UserPromptSubmit.\\n  1229→// Note: The plugin now sends only session_id and prompt, not transcript_path.\\n  1230→func (r *OpenCodeHookRunner) SimulateOpenCodeTurnStart(sessionID, _, prompt string) error {\\n  1231→\\tr.T.Helper()\\n  1232→\\n  1233→\\tinput := map[string]string{\\n  1234→\\t\\t\\\"session_id\\\": sessionID,\\n  1235→\\t\\t\\\"prompt\\\":     prompt,\\n  1236→\\t}\\n  1237→\\n  1238→\\treturn r.runOpenCodeHookWithInput(\\\"turn-start\\\", input)\\n  1239→}\\n  1240→\\n  1241→// SimulateOpenCodeTurnEnd simulates the turn-end hook for OpenCode.\\n  1242→// This is equivalent to Claude Code's Stop hook.\\n  1243→// Note: The plugin now sends only session_id. The Go handler calls `opencode export`\\n  1244→// to get the transcript. For tests, we write a mock export JSON file first.\\n  1245→func (r *OpenCodeHookRunner) SimulateOpenCodeTurnEnd(sessionID, transcriptPath string) error {\\n  1246→\\tr.T.Helper()\\n  1247→\\n  1248→\\t// For integration tests, write the mock transcript to the location where the\\n  1249→\\t// lifecycle handler expects it (.entire/tmp/<session_id>.json)\\n  1250→\\tif transcriptPath != \\\"\\\" {\\n  1251→\\t\\tsrcData, err := os.ReadFile(transcriptPath)\\n  1252→\\t\\tif err != nil {\\n  1253→\\t\\t\\tr.T.Fatalf(\\\"SimulateOpenCodeTurnEnd: failed to read transcript from %q: %v\\\", transcriptPath, err)\\n  1254→\\t\\t}\\n  1255→\\t\\tdestDir := filepath.Join(r.RepoDir, \\\".entire\\\", \\\"tmp\\\")\\n  1256→\\t\\tif err := os.MkdirAll(destDir, 0o755); err != nil {\\n  1257→\\t\\t\\tr.T.Fatalf(\\\"SimulateOpenCodeTurnEnd: failed to create directory %q: %v\\\", destDir, err)\\n  1258→\\t\\t}\\n  1259→\\t\\tdestPath := filepath.Join(destDir, sessionID+\\\".json\\\")\\n  1260→\\t