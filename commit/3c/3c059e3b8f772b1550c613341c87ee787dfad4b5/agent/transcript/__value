in verifies that PrePush pushes\\n    25→// the entire/checkpoints/v1 branch to a bare remote after condensation.\\n    26→func TestPrePush_PushesCheckpointBranchToOrigin(t *testing.T) {\\n    27→\\tt.Parallel()\\n    28→\\tenv := NewFeatureBranchEnv(t)\\n    29→\\n    30→\\t// Set up bare remote\\n    31→\\tbareDir := env.SetupBareRemote()\\n    32→\\n    33→\\t// Create a session, make changes, checkpoint, and commit (triggers condensation)\\n    34→\\tsession := env.NewSession()\\n    35→\\ttranscriptPath := session.CreateTranscript(\\\"Add auth module\\\", []FileChange{\\n    36→\\t\\t{Path: \\\"auth.go\\\", Content: \\\"package auth\\\"},\\n    37→\\t})\\n    38→\\n    39→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Add auth module\\\", transcriptPath); err != nil {\\n    40→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n    41→\\t}\\n    42→\\n    43→\\tenv.WriteFile(\\\"auth.go\\\", \\\"package auth\\\")\\n    44→\\tenv.GitAdd(\\\"auth.go\\\")\\n    45→\\n    46→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n    47→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n    48→\\t}\\n    49→\\n    50→\\t// Commit with hooks (triggers prepare-commit-msg + post-commit = condensation)\\n    51→\\tenv.GitCommitWithShadowHooks(\\\"Add auth module\\\", \\\"auth.go\\\")\\n    52→\\n    53→\\t// Verify condensation happened locally\\n    54→\\tif !env.BranchExists(paths.MetadataBranchName) {\\n    55→\\t\\tt.Fatal(\\\"entire/checkpoints/v1 should exist locally after condensation\\\")\\n    56→\\t}\\n    57→\\n    58→\\t// Run PrePush (simulates what happens during git push)\\n    59→\\tenv.RunPrePush(\\\"origin\\\")\\n    60→\\n    61→\\t// Verify the branch arrived on the remote\\n    62→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n    63→\\t\\tt.Error(\\\"entire/checkpoints/v1 should exist on bare remote after PrePush\\\")\\n    64→\\t}\\n    65→\\n    66→\\t// Verify checkpoint metadata is in the remote tree\\n    67→\\tcheckpointID := env.GetLatestCheckpointID()\\n    68→\\tif checkpointID == \\\"\\\" {\\n    69→\\t\\tt.Fatal(\\\"should have a checkpoint ID after condensation\\\")\\n    70→\\t}\\n    71→\\tsummaryPath := CheckpointSummaryPath(checkpointID)\\n    72→\\tif !fileExistsOnRemoteBranch(t, bareDir, paths.MetadataBranchName, summaryPath) {\\n    73→\\t\\tt.Errorf(\\\"checkpoint metadata should exist on remote at %s\\\", summaryPath)\\n    74→\\t}\\n    75→}\\n    76→\\n    77→// TestPrePush_PushesTrailsBranchWhenPresent verifies that PrePush pushes\\n    78→// the entire/trails/v1 branch to the bare remote when it exists locally.\\n    79→//\\n    80→// Trails are only created when a trail is explicitly started (via \\\"trail start\\\")\\n    81→// and a checkpoint is linked to it. The basic session + commit flow does not\\n    82→// always create a trails branch. This test verifies the push mechanism works\\n    83→// when the branch IS present: we manually create the branch and then assert\\n    84→// it arrives on the remote.\\n    85→func TestPrePush_PushesTrailsBranchWhenPresent(t *testing.T) {\\n    86→\\tt.Parallel()\\n    87→\\tenv := NewFeatureBranchEnv(t)\\n    88→\\n    89→\\tbareDir := env.SetupBareRemote()\\n    90→\\n    91→\\t// Create a session, checkpoint, and commit\\n    92→\\t_, _ = createCheckpointedCommit(t, env, \\\"Add feature\\\", \\\"feature.go\\\", \\\"package feature\\\", \\\"Add feature\\\")\\n    93→\\n    94→\\t// If the trails branch exists locally (some configurations create it), verify it pushes.\\n    95→\\t// If not, create a minimal orphan trails branch to test the push mechanism.\\n    96→\\tif !env.BranchExists(paths.TrailsBranchName) {\\n    97→\\t\\tcreateOrphanBranch(t, env.RepoDir, paths.TrailsBranchName, \\\"trails.json\\\", `{\\\"test\\\": true}`)\\n    98→\\t}\\n    99→\\n   100→\\t// Run PrePush\\n   101→\\tenv.RunPrePush(\\\"origin\\\")\\n   102→\\n   103→\\t// Checkpoint branch must be on remote\\n   104→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   105→\\t\\tt.Error(\\\"entire/checkpoints/v1 should exist on remote\\\")\\n   106→\\t}\\n   107→\\n   108→\\t// Trails branch must be on remote after PrePush\\n   109→\\tif !env.BranchExistsOnRemote(bareDir, paths.TrailsBranchName) {\\n   110→\\t\\tt.Error(\\\"entire/trails/v1 should exist on remote after PrePush when present locally\\\")\\n   111→\\t}\\n   112→}\\n   113→\\n   114→// TestPrePush_NoOpWhenNoCheckpoints verifies that PrePush is a no-op\\n   115→// when no sessions or checkpoints exist.\\n   116→func TestPrePush_NoOpWhenNoCheckpoints(t *testing.T) {\\n   117→\\tt.Parallel()\\n   118→\\tenv := NewFeatureBranchEnv(t)\\n   119→\\n   120→\\tbareDir := env.SetupBareRemote()\\n   121→\\n   122→\\t// Run PrePush without any session activity\\n   123→\\tenv.RunPrePush(\\\"origin\\\")\\n   124→\\n   125→\\t// No checkpoint branches should exist on remote\\n   126→\\tif env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   127→\\t\\tt.Error(\\\"entire/checkpoints/v1 should NOT exist on remote when no checkpoints were created\\\")\\n   128→\\t}\\n   129→}\\n   130→\\n   131→// TestPrePush_IdempotentWhenAlreadyPushed verifies that pushing twice\\n   132→// with no new checkpoints is a no-op (idempotent).\\n   133→func TestPrePush_IdempotentWhenAlreadyPushed(t *testing.T) {\\n   134→\\tt.Parallel()\\n   135→\\tenv := NewFeatureBranchEnv(t)\\n   136→\\n   137→\\tbareDir := env.SetupBareRemote()\\n   138→\\n   139→\\t// Create session, commit, push\\n   140→\\tsession := env.NewSession()\\n   141→\\ttranscriptPath := session.CreateTranscript(\\\"Initial work\\\", []FileChange{\\n   142→\\t\\t{Path: \\\"main.go\\\", Content: \\\"package main\\\"},\\n   143→\\t})\\n   144→\\n   145→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Initial work\\\", transcriptPath); err != nil {\\n   146→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   147→\\t}\\n   148→\\n   149→\\tenv.WriteFile(\\\"main.go\\\", \\\"package main\\\")\\n   150→\\tenv.GitAdd(\\\"main.go\\\")\\n   151→\\n   152→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   153→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   154→\\t}\\n   155→\\n   156→\\tenv.GitCommitWithShadowHooks(\\\"Initial work\\\", \\\"main.go\\\")\\n   157→\\n   158→\\t// First push\\n   159→\\tenv.RunPrePush(\\\"origin\\\")\\n   160→\\n   161→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   162→\\t\\tt.Fatal(\\\"checkpoint branch should exist after first push\\\")\\n   163→\\t}\\n   164→\\n   165→\\t// Get remote ref before second push\\n   166→\\trefBefore := getRemoteBranchHash(t, bareDir, paths.MetadataBranchName)\\n   167→\\n   168→\\t// Second push (no new checkpoints)\\n   169→\\tenv.RunPrePush(\\\"origin\\\")\\n   170→\\n   171→\\t// Remote ref should be unchanged\\n   172→\\trefAfter := getRemoteBranchHash(t, bareDir, paths.MetadataBranchName)\\n   173→\\tif refBefore != refAfter {\\n   174→\\t\\tt.Errorf(\\\"remote ref should be unchanged after idempotent push: before=%s, after=%s\\\", refBefore, refAfter)\\n   175→\\t}\\n   176→}\\n   177→\\n   178→// =============================================================================\\n   179→// P0 -- Checkpoint Remote Config\\n   180→// =============================================================================\\n   181→\\n   182→// TestPrePush_PushDisabledSkipsCheckpoints verifies that push_sessions: false\\n   183→// disables checkpoint push while trails are still pushed.\\n   184→func TestPrePush_PushDisabledSkipsCheckpoints(t *testing.T) {\\n   185→\\tt.Parallel()\\n   186→\\tenv := NewFeatureBranchEnv(t)\\n   187→\\n   188→\\tbareDir := env.SetupBareRemote()\\n   189→\\n   190→\\t// Configure push_sessions: false\\n   191→\\tenv.PatchSettings(map[string]any{\\n   192→\\t\\t\\\"strategy_options\\\": map[string]any{\\n   193→\\t\\t\\t\\\"push_sessions\\\": false,\\n   194→\\t\\t},\\n   195→\\t})\\n   196→\\n   197→\\t// Create session, checkpoint, and commit\\n   198→\\tsession := env.NewSession()\\n   199→\\ttranscriptPath := session.CreateTranscript(\\\"Some work\\\", []FileChange{\\n   200→\\t\\t{Path: \\\"work.go\\\", Content: \\\"package work\\\"},\\n   201→\\t})\\n   202→\\n   203→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Some work\\\", transcriptPath); err != nil {\\n   204→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   205→\\t}\\n   206→\\n   207→\\tenv.WriteFile(\\\"work.go\\\", \\\"package work\\\")\\n   208→\\tenv.GitAdd(\\\"work.go\\\")\\n   209→\\n   210→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   211→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   212→\\t}\\n   213→\\n   214→\\tenv.GitCommitWithShadowHooks(\\\"Some work\\\", \\\"work.go\\\")\\n   215→\\n   216→\\t// Verify checkpoint was created locally\\n   217→\\tif !env.BranchExists(paths.MetadataBranchName) {\\n   218→\\t\\tt.Fatal(\\\"should have local checkpoint branch after condensation\\\")\\n   219→\\t}\\n   220→\\n   221→\\t// Run PrePush\\n   222→\\tenv.RunPrePush(\\\"origin\\\")\\n   223→\\n   224→\\t// Checkpoints should NOT be on remote\\n   225→\\tif env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   226→\\t\\tt.Error(\\\"entire/checkpoints/v1 should NOT be on remote when push_sessions is false\\\")\\n   227→\\t}\\n   228→\\n   229→\\t// Trails SHOULD still be pushed (trails are independent of push_sessions)\\n   230→\\tif env.BranchExists(paths.TrailsBranchName) {\\n   231→\\t\\tif !env.BranchExistsOnRemote(bareDir, paths.TrailsBranchName) {\\n   232→\\t\\t\\tt.Error(\\\"entire/trails/v1 should be on remote even when push_sessions is false\\\")\\n   233→\\t\\t}\\n   234→\\t} else {\\n   235→\\t\\tt.Log(\\\"trails branch not created locally in this run; cannot verify remote trail push\\\")\\n   236→\\t}\\n   237→}\\n   238→\\n   239→// TestPrePush_CheckpointRemoteRoutesToSeparateRemote verifies that when\\n   240→// checkpoint_remote is configured, checkpoints are pushed directly to the\\n   241→// checkpoint remote path while trails stay on origin.\\n   242→//\\n   243→// Since resolvePushSettings derives the checkpoint URL from the origin's protocol\\n   244→// (SSH/HTTPS) and our test remotes use local file paths (not URLs), we test at the\\n   245→// pushBranchIfNeeded level. The production PrePush code calls pushBranchIfNeeded\\n   246→// with the resolved target, so this validates the core routing behavior.\\n   247→func TestPrePush_CheckpointRemoteRoutesToSeparateRemote(t *testing.T) {\\n   248→\\tt.Parallel()\\n   249→\\tenv := NewFeatureBranchEnv(t)\\n   250→\\n   251→\\t// Set up two bare remotes: origin for user code + trails, checkpoint remote for checkpoints\\n   252→\\tbareOrigin := env.SetupBareRemote()\\n   253→\\tbareCheckpoint := env.SetupNamedBareRemote(\\\"checkpoint-store\\\")\\n   254→\\n   255→\\t// Create session, checkpoint, and commit\\n   256→\\tsession := env.NewSession()\\n   257→\\ttranscriptPath := session.CreateTranscript(\\\"Add router\\\", []FileChange{\\n   258→\\t\\t{Path: \\\"router.go\\\", Content: \\\"package router\\\"},\\n   259→\\t})\\n   260→\\n   261→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Add router\\\", transcriptPath); err != nil {\\n   262→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   263→\\t}\\n   264→\\n   265→\\tenv.WriteFile(\\\"router.go\\\", \\\"package router\\\")\\n   266→\\tenv.GitAdd(\\\"router.go\\\")\\n   267→\\n   268→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   269→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   270→\\t}\\n   271→\\n   272→\\tenv.GitCommitWithShadowHooks(\\\"Add router\\\", \\\"router.go\\\")\\n   273→\\n   274→\\t// Verify local checkpoint branch exists\\n   275→\\tif !env.BranchExists(paths.MetadataBranchName) {\\n   276→\\t\\tt.Fatal(\\\"should have local checkpoint branch after condensation\\\")\\n   277→\\t}\\n   278→\\n   279→\\t// Simulate checkpoint_remote routing: push checkpoints to the checkpoint bare repo path,\\n   280→\\t// and trails to origin. This matches what PrePush does when resolvePushSettings returns\\n   281→\\t// a checkpointURL: checkpoints go to pushTarget() (the URL), trails go to ps.remote.\\n   282→\\tpushBranchToTarget(t, env.RepoDir, bareCheckpoint, paths.MetadataBranchName)\\n   283→\\n   284→\\t// Push trails to origin if they exist (trails are only created when a trail is started)\\n   285→\\tif env.BranchExists(paths.TrailsBranchName) {\\n   286→\\t\\tpushBranchToTarget(t, env.RepoDir, \\\"origin\\\", paths.TrailsBranchName)\\n   287→\\t}\\n   288→\\n   289→\\t// Checkpoints should be on checkpoint remote, NOT on origin\\n   290→\\tif !env.BranchExistsOnRemote(bareCheckpoint, paths.MetadataBranchName) {\\n   291→\\t\\tt.Error(\\\"entire/checkpoints/v1 should exist on checkpoint remote\\\")\\n   292→\\t}\\n   293→\\tif env.BranchExistsOnRemote(bareOrigin, paths.MetadataBranchName) {\\n   294→\\t\\tt.Error(\\\"entire/checkpoints/v1 should NOT be on origin when routed to checkpoint remote\\\")\\n   295→\\t}\\n   296→\\n   297→\\t// Trails should be on origin, NOT on checkpoint remote (when trails exist)\\n   298→\\tif env.BranchExists(paths.TrailsBranchName) {\\n   299→\\t\\tif !env.BranchExistsOnRemote(bareOrigin, paths.TrailsBranchName) {\\n   300→\\t\\t\\tt.Error(\\\"entire/trails/v1 should be on origin\\\")\\n   301→\\t\\t}\\n   302→\\t\\tif env.BranchExistsOnRemote(bareCheckpoint, paths.TrailsBranchName) {\\n   303→\\t\\t\\tt.Error(\\\"entire/trails/v1 should NOT be on checkpoint remote\\\")\\n   304→\\t\\t}\\n   305→\\t}\\n   306→\\n   307→\\t// Verify checkpoint data arrived on checkpoint remote\\n   308→\\tcheckpointID := env.GetLatestCheckpointID()\\n   309→\\tsummaryPath := CheckpointSummaryPath(checkpointID)\\n   310→\\tif !fileExistsOnRemoteBranch(t, bareCheckpoint, paths.MetadataBranchName, summaryPath) {\\n   311→\\t\\tt.Errorf(\\\"checkpoint metadata should exist on checkpoint remote at %s\\\", summaryPath)\\n   312→\\t}\\n   313→}\\n   314→\\n   315→// TestPrePush_ForkDetectionFallsBackToOrigin verifies that when the push remote\\n   316→// owner differs from the checkpoint remote owner, checkpoint_remote is skipped\\n   317→// and checkpoints are pushed to origin instead (fork detection).\\n   318→//\\n   319→// This tests the resolvePushSettings fork detection logic indirectly: when a fork\\n   320→// is detected, resolvePushSettings returns pushTarget()=origin (no checkpoint URL).\\n   321→// We verify this by configuring origin with a different owner than checkpoint_remote\\n   322→// and ensuring checkpoints end up on origin.\\n   323→func TestPrePush_ForkDetectionFallsBackToOrigin(t *testing.T) {\\n   324→\\tt.Parallel()\\n   325→\\tenv := NewFeatureBranchEnv(t)\\n   326→\\n   327→\\tbareDir := env.SetupBareRemote()\\n   328→\\n   329→\\t// Configure checkpoint_remote with a different owner than origin.\\n   330→\\t// Since our bare remote is a local path (not a URL), resolvePushSettings won't\\n   331→\\t// be able to parse it and will fall back to origin. This simulates the fork detection\\n   332→\\t// behavior where checkpoint URL derivation fails or owner mismatch is detected.\\n   333→\\t//\\n   334→\\t// The unit test TestResolvePushSettings_ForkDetection in checkpoint_remote_test.go\\n   335→\\t// validates the exact fork detection logic with real URL parsing. Here we verify\\n   336→\\t// the integration behavior: when checkpoint URL is not available, checkpoints still\\n   337→\\t// land on origin.\\n   338→\\tenv.PatchSettings(map[string]any{\\n   339→\\t\\t\\\"strategy_options\\\": map[string]any{\\n   340→\\t\\t\\t\\\"checkpoint_remote\\\": map[string]any{\\n   341→\\t\\t\\t\\t\\\"provider\\\": \\\"github\\\",\\n   342→\\t\\t\\t\\t\\\"repo\\\":     \\\"different-org/checkpoints\\\",\\n   343→\\t\\t\\t},\\n   344→\\t\\t},\\n   345→\\t})\\n   346→\\n   347→\\t// Create session, checkpoint, and commit\\n   348→\\tsession := env.NewSession()\\n   349→\\ttranscriptPath := session.CreateTranscript(\\\"Add middleware\\\", []FileChange{\\n   350→\\t\\t{Path: \\\"middleware.go\\\", Content: \\\"package middleware\\\"},\\n   351→\\t})\\n   352→\\n   353→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Add middleware\\\", transcriptPath); err != nil {\\n   354→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   355→\\t}\\n   356→\\n   357→\\tenv.WriteFile(\\\"middleware.go\\\", \\\"package middleware\\\")\\n   358→\\tenv.GitAdd(\\\"middleware.go\\\")\\n   359→\\n   360→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   361→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   362→\\t}\\n   363→\\n   364→\\tenv.GitCommitWithShadowHooks(\\\"Add middleware\\\", \\\"middleware.go\\\")\\n   365→\\n   366→\\t// Run PrePush -- with a local path remote, checkpoint URL derivation will fail\\n   367→\\t// (parseGitRemoteURL can't parse local paths), so checkpoints fall back to origin.\\n   368→\\tenv.RunPrePush(\\\"origin\\\")\\n   369→\\n   370→\\t// Checkpoints should be on origin (fallback behavior)\\n   371→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   372→\\t\\tt.Error(\\\"entire/checkpoints/v1 should be on origin when checkpoint_remote is unavailable (fork/fallback)\\\")\\n   373→\\t}\\n   374→}\\n   375→\\n   376→// =============================================================================\\n   377→// P0 -- Clone and Resume\\n   378→// =============================================================================\\n   379→\\n   380→// createCheckpointedCommit is a helper that creates a session with a single file change,\\n   381→// runs the full lifecycle (prompt submit -> write -> stop -> commit), and returns the\\n   382→// session and checkpoint ID. This reduces boilerplate in tests where the session setup\\n   383→// is not the focus.\\n   384→func createCheckpointedCommit(t *testing.T, env *TestEnv, prompt, fileName, fileContent, commitMsg string) (sessionID, checkpointID string) {\\n   385→\\tt.Helper()\\n   386→\\n   387→\\tsession := env.NewSession()\\n   388→\\ttranscriptPath := session.CreateTranscript(prompt, []FileChange{\\n   389→\\t\\t{Path: fileName, Content: fileContent},\\n   390→\\t})\\n   391→\\n   392→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, prompt, transcriptPath); err != nil {\\n   393→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   394→\\t}\\n   395→\\n   396→\\tenv.WriteFile(fileName, fileContent)\\n   397→\\tenv.GitAdd(fileName)\\n   398→\\n   399→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   400→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   401→\\t}\\n   402→\\n   403→\\tenv.GitCommitWithShadowHooks(commitMsg, fileName)\\n   404→\\n   405→\\treturn session.ID, env.GetLatestCheckpointID()\\n   406→}\\n   407→\\n   408→// TestCloneAndResume_FetchesCheckpointMetadata verifies that after pushing\\n   409→// checkpoints to a remote, cloning the repo and fetching the metadata branch\\n   410→// brings the checkpoint data locally.\\n   411→//\\n   412→// Note: This test uses env.FetchMetadataBranch (raw git fetch) rather than\\n   413→// triggering fetchMetadataBranchIfMissing via the production code path, because\\n   414→// fetchMetadataBranchIfMissing uses OpenRepository which requires CWD to be\\n   415→// inside the repo (incompatible with t.Parallel). The production function is\\n   416→// tested directly in checkpoint_remote_test.go (TestFetchBranchIfMissing_*).\\n   417→// This test verifies the \\\"data arrives and is usable\\\" property.\\n   418→func TestCloneAndResume_FetchesCheckpointMetadata(t *testing.T) {\\n   419→\\tt.Parallel()\\n   420→\\tenv := NewFeatureBranchEnv(t)\\n   421→\\n   422→\\tbareDir := env.SetupBareRemote()\\n   423→\\n   424→\\t// Repo A: create session, checkpoint, commit, push\\n   425→\\t_, checkpointID := createCheckpointedCommit(t, env, \\\"Build login page\\\", \\\"login.go\\\", \\\"package login\\\", \\\"Build login page\\\")\\n   426→\\tt.Logf(\\\"Original checkpoint ID: %s\\\", checkpointID)\\n   427→\\n   428→\\t// Push user branch + checkpoint branches to remote\\n   429→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   430→\\tenv.RunPrePush(\\\"origin\\\")\\n   431→\\n   432→\\t// Clone into repo B\\n   433→\\tcloneEnv := env.CloneFrom(bareDir)\\n   434→\\n   435→\\t// Fetch the metadata branch (simulates what fetchMetadataBranchIfMissing does)\\n   436→\\tcloneEnv.FetchMetadataBranch(bareDir)\\n   437→\\n   438→\\t// Now the metadata branch should exist locally in the clone\\n   439→\\tif !cloneEnv.BranchExists(paths.MetadataBranchName) {\\n   440→\\t\\tt.Fatal(\\\"entire/checkpoints/v1 should exist in clone after fetch\\\")\\n   441→\\t}\\n   442→\\n   443→\\t// Verify the checkpoint data is present\\n   444→\\tsummaryPath := CheckpointSummaryPath(checkpointID)\\n   445→\\tif !cloneEnv.FileExistsInBranch(paths.MetadataBranchName, summaryPath) {\\n   446→\\t\\tt.Errorf(\\\"checkpoint metadata should exist in clone at %s\\\", summaryPath)\\n   447→\\t}\\n   448→}\\n   449→\\n   450→// TestCloneAndResume_SessionListingWorksAfterClone verifies that checkpoint\\n   451→// metadata can be enumerated after cloning and fetching the metadata branch.\\n   452→func TestCloneAndResume_SessionListingWorksAfterClone(t *testing.T) {\\n   453→\\tt.Parallel()\\n   454→\\tenv := NewFeatureBranchEnv(t)\\n   455→\\n   456→\\tbareDir := env.SetupBareRemote()\\n   457→\\n   458→\\t// Repo A: create session, checkpoint, commit, push\\n   459→\\t_, checkpointID := createCheckpointedCommit(t, env, \\\"Implement auth\\\", \\\"auth.go\\\", \\\"package auth\\\", \\\"Implement auth\\\")\\n   460→\\n   461→\\t// Push everything\\n   462→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   463→\\tenv.RunPrePush(\\\"origin\\\")\\n   464→\\n   465→\\t// Clone and fetch metadata\\n   466→\\tcloneEnv := env.CloneFrom(bareDir)\\n   467→\\tcloneEnv.FetchMetadataBranch(bareDir)\\n   468→\\n   469→\\t// List checkpoints from the clone by scanning the metadata branch tree\\n   470→\\tcheckpoints := listCheckpointsInDir(t, cloneEnv.RepoDir)\\n   471→\\n   472→\\tif len(checkpoints) == 0 {\\n   473→\\t\\tt.Fatal(\\\"should find checkpoints from original repo after clone\\\")\\n   474→\\t}\\n   475→\\n   476→\\t// Verify our checkpoint is in the list\\n   477→\\tfound := false\\n   478→\\tfor _, cp := range checkpoints {\\n   479→\\t\\tif cp == checkpointID {\\n   480→\\t\\t\\tfound = true\\n   481→\\t\\t\\tbreak\\n   482→\\t\\t}\\n   483→\\t}\\n   484→\\tif !found {\\n   485→\\t\\tt.Errorf(\\\"checkpoint %s from original repo should be in list, got: %v\\\", checkpointID, checkpoints)\\n   486→\\t}\\n   487→}\\n   488→\\n   489→// TestCloneAndResume_SessionLogRetrievalWorksAfterClone verifies that\\n   490→// checkpoint transcripts can be read after clone + fetch.\\n   491→func TestCloneAndResume_SessionLogRetrievalWorksAfterClone(t *testing.T) {\\n   492→\\tt.Parallel()\\n   493→\\tenv := NewFeatureBranchEnv(t)\\n   494→\\n   495→\\tbareDir := env.SetupBareRemote()\\n   496→\\n   497→\\t// Repo A: create session with a specific transcript content\\n   498→\\t_, checkpointID := createCheckpointedCommit(t, env, \\\"Write tests for auth\\\", \\\"auth_test.go\\\", \\\"package auth_test\\\", \\\"Write auth tests\\\")\\n   499→\\n   500→\\t// Push\\n   501→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   502→\\tenv.RunPrePush(\\\"origin\\\")\\n   503→\\n   504→\\t// Clone and fetch metadata\\n   505→\\tcloneEnv := env.CloneFrom(bareDir)\\n   506→\\tcloneEnv.FetchMetadataBranch(bareDir)\\n   507→\\n   508→\\t// Read transcript from the clone\\n   509→\\ttranscriptFilePath := SessionFilePath(checkpointID, paths.TranscriptFileName)\\n   510→\\tcontent, found := cloneEnv.ReadFileFromBranch(paths.MetadataBranchName, transcriptFilePath)\\n   511→\\tif !found {\\n   512→\\t\\tt.Fatalf(\\\"transcript should be readable from clone at %s\\\", transcriptFilePath)\\n   513→\\t}\\n   514→\\n   515→\\tif content == \\\"\\\" {\\n   516→\\t\\tt.Error(\\\"transcript content should not be empty\\\")\\n   517→\\t}\\n   518→\\n   519→\\t// Verify it contains our expected content\\n   520→\\tif !strings.Contains(content, \\\"Write tests for auth\\\") {\\n   521→\\t\\tt.Error(\\\"transcript should contain the user prompt from the original session\\\")\\n   522→\\t}\\n   523→}\\n   524→\\n   525→// TestCloneAndResume_NewSessionPushAppends verifies that after cloning,\\n   526→// creating a new session, and pushing, the remote has BOTH original and\\n   527→// new checkpoint data.\\n   528→func TestCloneAndResume_NewSessionPushAppends(t *testing.T) {\\n   529→\\tt.Parallel()\\n   530→\\tenv := NewFeatureBranchEnv(t)\\n   531→\\n   532→\\tbareDir := env.SetupBareRemote()\\n   533→\\n   534→\\t// Repo A: session + commit + push\\n   535→\\t_, originalCheckpointID := createCheckpointedCommit(t, env, \\\"Add models\\\", \\\"models.go\\\", \\\"package models\\\", \\\"Add models\\\")\\n   536→\\tt.Logf(\\\"Original checkpoint: %s\\\", originalCheckpointID)\\n   537→\\n   538→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   539→\\tenv.RunPrePush(\\\"origin\\\")\\n   540→\\n   541→\\t// Clone into repo B and fetch metadata\\n   542→\\tcloneEnv := env.CloneFrom(bareDir)\\n   543→\\tcloneEnv.FetchMetadataBranch(bareDir)\\n   544→\\n   545→\\t// Repo B: create NEW session on a new branch, commit, push\\n   546→\\tcloneEnv.GitCheckoutNewBranch(\\\"feature/clone-work\\\")\\n   547→\\n   548→\\t_, newCheckpointID := createCheckpointedCommit(t, cloneEnv, \\\"Add handlers\\\", \\\"handlers.go\\\", \\\"package handlers\\\", \\\"Add handlers\\\")\\n   549→\\tt.Logf(\\\"New checkpoint: %s\\\", newCheckpointID)\\n   550→\\n   551→\\t// Push from clone\\n   552→\\tcloneEnv.RunPrePush(\\\"origin\\\")\\n   553→\\n   554→\\t// Verify remote has BOTH checkpoints\\n   555→\\toriginalSummaryPath := CheckpointSummaryPath(originalCheckpointID)\\n   556→\\tif !fileExistsOnRemoteBranch(t, bareDir, paths.MetadataBranchName, originalSummaryPath) {\\n   557→\\t\\tt.Errorf(\\\"original checkpoint %s should still exist on remote\\\", originalCheckpointID)\\n   558→\\t}\\n   559→\\n   560→\\tnewSummaryPath := CheckpointSummaryPath(newCheckpointID)\\n   561→\\tif !fileExistsOnRemoteBranch(t, bareDir, paths.MetadataBranchName, newSummaryPath) {\\n   562→\\t\\tt.Errorf(\\\"new checkpoint %s should exist on remote\\\", newCheckpointID)\\n   563→\\t}\\n   564→}\\n   565→\\n   566→// =============================================================================\\n   567→// P1 -- Non-Fast-Forward Recovery\\n   568→// =============================================================================\\n   569→\\n   570→// TestConcurrentPush_SecondPusherMergesAndRetries verifies that when two clones\\n   571→// push to the same remote, the second pusher fetches, merges, and retries.\\n   572→func TestConcurrentPush_SecondPusherMergesAndRetries(t *testing.T) {\\n   573→\\tt.Parallel()\\n   574→\\tenv := NewFeatureBranchEnv(t)\\n   575→\\n   576→\\tbareDir := env.SetupBareRemote()\\n   577→\\n   578→\\t// Clone A\\n   579→\\tcloneA := env.CloneFrom(bareDir)\\n   580→\\tcloneA.GitCheckoutNewBranch(\\\"feature/clone-a\\\")\\n   581→\\n   582→\\t// Clone B\\n   583→\\tcloneB := env.CloneFrom(bareDir)\\n   584→\\tcloneB.GitCheckoutNewBranch(\\\"feature/clone-b\\\")\\n   585→\\n   586→\\t// Clone A: session + commit\\n   587→\\t_, checkpointA := createCheckpointedCommit(t, cloneA, \\\"Work in clone A\\\", \\\"a.go\\\", \\\"package a\\\", \\\"Work from A\\\")\\n   588→\\tt.Logf(\\\"Clone A checkpoint: %s\\\", checkpointA)\\n   589→\\n   590→\\t// Clone B: session + commit\\n   591→\\t_, checkpointB := createCheckpointedCommit(t, cloneB, \\\"Work in clone B\\\", \\\"b.go\\\", \\\"package b\\\", \\\"Work from B\\\")\\n   592→\\tt.Logf(\\\"Clone B checkpoint: %s\\\", checkpointB)\\n   593→\\n   594→\\t// A pushes first (should succeed cleanly)\\n   595→\\tcloneA.RunPrePush(\\\"origin\\\")\\n   596→\\n   597→\\t// B pushes second (will get non-fast-forward, should fetch+merge+retry)\\n   598→\\tcloneB.RunPrePush(\\\"origin\\\")\\n   599→\\n   600→\\t// Remote should have BOTH checkpoints\\n   601→\\tsummaryA := CheckpointSummaryPath(checkpointA)\\n   602→\\tif !fileExistsOnRemoteBranch(t, bareDir, paths.MetadataBranchName, summaryA) {\\n   603→\\t\\tt.Errorf(\\\"remote should have checkpoint from clone A: %s\\\", checkpointA)\\n   604→\\t}\\n   605→\\n   606→\\tsummaryB := CheckpointSummaryPath(checkpointB)\\n   607→\\tif !fileExistsOnRemoteBranch(t, bareDir, paths.MetadataBranchName, summaryB) {\\n   608→\\t\\tt.Errorf(\\\"remote should have checkpoint from clone B: %s\\\", checkpointB)\\n   609→\\t}\\n   610→\\n   611→\\t// Verify B's local metadata branch has a merge commit with 2 parents.\\n   612→\\t// This confirms the fetch+merge+retry path was taken.\\n   613→\\tparentCount := cloneB.GetBranchTipParentCount(paths.MetadataBranchName)\\n   614→\\tif parentCount != 2 {\\n   615→\\t\\tt.Errorf(\\\"clone B's metadata branch tip should have 2 parents (merge commit), got %d\\\", parentCount)\\n   616→\\t}\\n   617→}\\n   618→\\n   619→// =============================================================================\\n   620→// P1 -- Graceful Degradation\\n   621→// =============================================================================\\n   622→\\n   623→// TestGracefulDegradation_UnreachableCheckpointRemotePushContinues verifies that\\n   624→// PrePush does not fail when checkpoint_remote points to an unreachable path.\\n   625→// Trails should still be pushed to origin even when checkpoint remote is unreachable.\\n   626→func TestGracefulDegradation_UnreachableCheckpointRemotePushContinues(t *testing.T) {\\n   627→\\tt.Parallel()\\n   628→\\tenv := NewFeatureBranchEnv(t)\\n   629→\\n   630→\\tbareOrigin := env.SetupBareRemote()\\n   631→\\n   632→\\t// Configure checkpoint_remote pointing to a non-existent path.\\n   633→\\t// Since our origin is a local path, resolvePushSettings can't parse it as a URL,\\n   634→\\t// so checkpoint_remote won't be derived. Instead, we directly test what happens\\n   635→\\t// when pushBranchIfNeeded targets an unreachable remote: it should fail gracefully.\\n   636→\\t//\\n   637→\\t// To actually test the checkpoint_remote routing with an unreachable target,\\n   638→\\t// we push checkpoints to a non-existent path directly (simulating what PrePush\\n   639→\\t// would do with a resolved but unreachable checkpoint URL).\\n   640→\\tsession := env.NewSession()\\n   641→\\ttranscriptPath := session.CreateTranscript(\\\"Some work\\\", []FileChange{\\n   642→\\t\\t{Path: \\\"work.go\\\", Content: \\\"package work\\\"},\\n   643→\\t})\\n   644→\\n   645→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Some work\\\", transcriptPath); err != nil {\\n   646→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   647→\\t}\\n   648→\\n   649→\\tenv.WriteFile(\\\"work.go\\\", \\\"package work\\\")\\n   650→\\tenv.GitAdd(\\\"work.go\\\")\\n   651→\\n   652→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   653→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   654→\\t}\\n   655→\\n   656→\\tenv.GitCommitWithShadowHooks(\\\"Some work\\\", \\\"work.go\\\")\\n   657→\\n   658→\\t// Verify local checkpoint branch exists\\n   659→\\tif !env.BranchExists(paths.MetadataBranchName) {\\n   660→\\t\\tt.Fatal(\\\"should have local checkpoint branch after condensation\\\")\\n   661→\\t}\\n   662→\\n   663→\\t// Try to push checkpoints to a non-existent path (simulates unreachable checkpoint remote).\\n   664→\\t// doPushBranch is designed to warn and continue (not fail the main push).\\n   665→\\t// We use git push directly to the non-existent path.\\n   666→\\tnonExistentPath := t.TempDir() + \\\"/nonexistent-remote\\\"\\n   667→\\terr := pushBranchToTargetWithError(t, env.RepoDir, nonExistentPath, paths.MetadataBranchName)\\n   668→\\t// The push to unreachable remote should fail, but this is expected behavior.\\n   669→\\t// In production, doPushBranch catches this and returns nil (warns only).\\n   670→\\tif err == nil {\\n   671→\\t\\tt.Log(\\\"push to non-existent path unexpectedly succeeded (filesystem may have created it)\\\")\\n   672→\\t} else {\\n   673→\\t\\tt.Logf(\\\"push to non-existent path failed as expected: %v\\\", err)\\n   674→\\t}\\n   675→\\n   676→\\t// Trails should still be pushable to origin regardless\\n   677→\\tenv.RunPrePush(\\\"origin\\\")\\n   678→\\n   679→\\t// Verify trails arrived on origin\\n   680→\\tif env.BranchExists(paths.TrailsBranchName) {\\n   681→\\t\\tif !env.BranchExistsOnRemote(bareOrigin, paths.TrailsBranchName) {\\n   682→\\t\\t\\tt.Error(\\\"entire/trails/v1 should be on origin even when checkpoint remote is unreachable\\\")\\n   683→\\t\\t}\\n   684→\\t}\\n   685→\\n   686→\\t// Checkpoints should also be on origin since we ran a normal PrePush\\n   687→\\t// (without checkpoint_remote config, checkpoints default to origin)\\n   688→\\tif !env.BranchExistsOnRemote(bareOrigin, paths.MetadataBranchName) {\\n   689→\\t\\tt.Error(\\\"entire/checkpoints/v1 should be on origin after normal PrePush fallback\\\")\\n   690→\\t}\\n   691→}\\n   692→\\n   693→// TestGracefulDegradation_UnreachableCheckpointRemoteOnCloneIsSilent verifies that\\n   694→// when a clone configures checkpoint_remote pointing to an unreachable path, starting\\n   695→// a session does not error. fetchMetadataBranchIfMissing silently swallows fetch failures.\\n   696→func TestGracefulDegradation_UnreachableCheckpointRemoteOnCloneIsSilent(t *testing.T) {\\n   697→\\tt.Parallel()\\n   698→\\tenv := NewFeatureBranchEnv(t)\\n   699→\\n   700→\\tbareDir := env.SetupBareRemote()\\n   701→\\n   702→\\t// Create a session in repo A and push\\n   703→\\tcreateCheckpointedCommit(t, env, \\\"Initial work\\\", \\\"init.go\\\", \\\"package init\\\", \\\"Initial work\\\")\\n   704→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   705→\\tenv.RunPrePush(\\\"origin\\\")\\n   706→\\n   707→\\t// Clone from origin\\n   708→\\tcloneEnv := env.CloneFrom(bareDir)\\n   709→\\n   710→\\t// Configure checkpoint_remote to an unreachable path in the clone.\\n   711→\\t// When the checkpoint_remote URL can't be reached, fetch fails silently.\\n   712→\\tcloneEnv.PatchSettings(map[string]any{\\n   713→\\t\\t\\\"strategy_options\\\": map[string]any{\\n   714→\\t\\t\\t\\\"checkpoint_remote\\\": map[string]any{\\n   715→\\t\\t\\t\\t\\\"provider\\\": \\\"github\\\",\\n   716→\\t\\t\\t\\t\\\"repo\\\":     \\\"nonexistent-org/nonexistent-repo\\\",\\n   717→\\t\\t\\t},\\n   718→\\t\\t},\\n   719→\\t})\\n   720→\\n   721→\\t// Starting a new session should not error even though checkpoint_remote is unreachable.\\n   722→\\t// The session machinery itself doesn't trigger fetchMetadataBranchIfMissing (that happens\\n   723→\\t// in resolvePushSettings during PrePush), so this verifies the session starts cleanly.\\n   724→\\tsession := cloneEnv.NewSession()\\n   725→\\ttranscriptPath := session.CreateTranscript(\\\"Clone work\\\", []FileChange{\\n   726→\\t\\t{Path: \\\"clone.go\\\", Content: \\\"package clone\\\"},\\n   727→\\t})\\n   728→\\n   729→\\tif err := cloneEnv.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Clone work\\\", transcriptPath); err != nil {\\n   730→\\t\\tt.Fatalf(\\\"session start should not fail with unreachable checkpoint_remote: %v\\\", err)\\n   731→\\t}\\n   732→\\n   733→\\tif err := cloneEnv.SimulateStop(session.ID, transcriptPath); err != nil {\\n   734→\\t\\tt.Fatalf(\\\"session stop should not fail: %v\\\", err)\\n   735→\\t}\\n   736→\\n   737→\\t// PrePush should also not fail -- checkpoint_remote URL derivation will fail\\n   738→\\t// (origin is a local path, can't parse it), so it falls back to pushing to origin.\\n   739→\\tcloneEnv.WriteFile(\\\"clone.go\\\", \\\"package clone\\\")\\n   740→\\tcloneEnv.GitAdd(\\\"clone.go\\\")\\n   741→\\tcloneEnv.GitCommitWithShadowHooks(\\\"Clone work\\\", \\\"clone.go\\\")\\n   742→\\tcloneEnv.RunPrePush(\\\"origin\\\")\\n   743→}\\n   744→\\n   745→// =============================================================================\\n   746→// Helpers\\n   747→// =============================================================================\\n   748→\\n   749→// createOrphanBranch creates a minimal orphan branch with a single file using\\n   750→// go-git plumbing APIs. This avoids switching the working tree (which would\\n   751→// conflict with other files and the test binary).\\n   752→func createOrphanBranch(t *testing.T, repoDir, branchName, fileName, content string) {\\n   753→\\tt.Helper()\\n   754→\\n   755→\\trepo, err := git.PlainOpen(repoDir)\\n   756→\\tif err != nil {\\n   757→\\t\\tt.Fatalf(\\\"failed to open repo: %v\\\", err)\\n   758→\\t}\\n   759→\\n   760→\\t// Create a blob for the file content\\n   761→\\tblobObj := repo.Storer.NewEncodedObject()\\n   762→\\tblobObj.SetType(plumbing.BlobObject)\\n   763→\\tw, err := blobObj.Writer()\\n   764→\\tif err != nil {\\n   765→\\t\\tt.Fatalf(\\\"failed to create blob writer: %v\\\", err)\\n   766→\\t}\\n   767→\\tif _, err := w.Write([]byte(content)); err != nil {\\n   768→\\t\\tt.Fatalf(\\\"failed to write blob: %v\\\", err)\\n   769→\\t}\\n   770→\\tif err := w.Close(); err != nil {\\n   771→\\t\\tt.Fatalf(\\\"failed to close blob writer: %v\\\", err)\\n   772→\\t}\\n   773→\\tblobHash, err := repo.Storer.SetEncodedObject(blobObj)\\n   774→\\tif err != nil {\\n   775→\\t\\tt.Fatalf(\\