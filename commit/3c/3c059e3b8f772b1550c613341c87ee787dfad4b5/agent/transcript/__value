cted true (disconnected), got false\\\")\\n   547→\\t}\\n   548→}\\n   549→\\n   550→func TestReconcileDisconnected_ModifiedEntries(t *testing.T) {\\n   551→\\tt.Parallel()\\n   552→\\n   553→\\tbareDir := initBareWithMetadataBranch(t)\\n   554→\\tcloneDir, run := cloneWithConfig(t, bareDir)\\n   555→\\n   556→\\t// Create a disconnected local branch where commit 2 modifies a file from commit 1\\n   557→\\t// (simulates multi-session condensation updating metadata.json)\\n   558→\\trun(\\\"checkout\\\", \\\"--orphan\\\", \\\"temp-orphan\\\")\\n   559→\\trun(\\\"rm\\\", \\\"-rf\\\", \\\".\\\")\\n   560→\\n   561→\\t// Commit 1: initial checkpoint\\n   562→\\tdir1 := filepath.Join(cloneDir, \\\"aa\\\", \\\"aaaaaaaaaa\\\")\\n   563→\\tif err := os.MkdirAll(dir1, 0o755); err != nil {\\n   564→\\t\\tt.Fatalf(\\\"failed to create dir: %v\\\", err)\\n   565→\\t}\\n   566→\\tif err := os.WriteFile(filepath.Join(dir1, \\\"metadata.json\\\"),\\n   567→\\t\\t[]byte(`{\\\"checkpoint_id\\\":\\\"aaaaaaaaaaaa\\\",\\\"session_count\\\":1}`), 0o644); err != nil {\\n   568→\\t\\tt.Fatalf(\\\"failed to write: %v\\\", err)\\n   569→\\t}\\n   570→\\trun(\\\"add\\\", \\\".\\\")\\n   571→\\trun(\\\"commit\\\", \\\"-m\\\", \\\"Checkpoint: aaaaaaaaaaaa\\\")\\n   572→\\n   573→\\t// Commit 2: update same checkpoint (session_count 1→2) + add new file\\n   574→\\tif err := os.WriteFile(filepath.Join(dir1, \\\"metadata.json\\\"),\\n   575→\\t\\t[]byte(`{\\\"checkpoint_id\\\":\\\"aaaaaaaaaaaa\\\",\\\"session_count\\\":2}`), 0o644); err != nil {\\n   576→\\t\\tt.Fatalf(\\\"failed to write: %v\\\", err)\\n   577→\\t}\\n   578→\\tif err := os.MkdirAll(filepath.Join(dir1, \\\"1\\\"), 0o755); err != nil {\\n   579→\\t\\tt.Fatalf(\\\"failed to create dir: %v\\\", err)\\n   580→\\t}\\n   581→\\tif err := os.WriteFile(filepath.Join(dir1, \\\"1\\\", \\\"metadata.json\\\"),\\n   582→\\t\\t[]byte(`{\\\"session_id\\\":\\\"second-session\\\"}`), 0o644); err != nil {\\n   583→\\t\\tt.Fatalf(\\\"failed to writ