50→\\t\\tTranscript:                  sessionData.Transcript,\\n   251→\\t\\tPrompts:                     sessionData.Prompts,\\n   252→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   253→\\t\\tCheckpointsCount:            state.StepCount,\\n   254→\\t\\tEphemeralBranch:             shadowBranchName,\\n   255→\\t\\tAuthorName:                  authorName,\\n   256→\\t\\tAuthorEmail:                 authorEmail,\\n   257→\\t\\tAgent:                       state.AgentType,\\n   258→\\t\\tModel:                       state.ModelName,\\n   259→\\t\\tTurnID:                      state.TurnID,\\n   260→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   261→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   262→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   263→\\t\\tSessionMetrics:              buildSessionMetrics(state),\\n   264→\\t\\tInitialAttribution:          attribution,\\n   265→\\t\\tSummary:                     summary,\\n   266→\\t}); err != nil {\\n   267→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   268→\\t}\\n   269→\\n   270→\\treturn &CondenseResult{\\n   271→\\t\\tCheckpointID:         checkpointID,\\n   272→\\t\\tSessionID:            state.SessionID,\\n   273→\\t\\tCheckpointsCount:     state.StepCount,\\n   274→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   275→\\t\\tPrompts:              sessionData.Prompts,\\n   276→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   277→\\t\\tTranscript:           sessionData.Transcript,\\n   278→\\t}, nil\\n   279→}\\n   280→\\n   281→// buildSessionMetrics creates a SessionMetrics from session state if any metrics are available.\\n   282→// Returns nil if no hook-provided metrics exist (e.g., for agents that don't report them).\\n   283→func buildSessionMetrics(state *SessionState) *cpkg.SessionMetrics {\\n   284→\\tif state.SessionDurationMs == 0 && state.SessionTurnCount == 0 && state.ContextTokens == 0 && state.ContextWindowSize == 0 {\\n   285→\\t\\treturn nil\\n   286→\\t}\\n   287→\\treturn &cpkg.SessionMetrics{\\n   288→\\t\\tDurationMs:        state.SessionDurationMs,\\n   289→\\t\\tTurnCount:         state.SessionTurnCount,\\n   290→\\t\\tContextTokens:     state.ContextTokens,\\n   291→\\t\\tContextWindowSize: state.ContextWindowSize,\\n   292→\\t}\\n   293→}\\n   294→\\n   295→// attributionOpts provides pre-resolved git objects to avoid redundant reads.\\n   296→type attributionOpts struct {\\n   297→\\theadTree              *object.Tree // HEAD commit tree (already resolved by PostCommit)\\n   298→\\tshadowTree            *object.Tree // Shadow branch tree (already resolved by PostCommit)\\n   299→\\trepoDir               string       // Repository worktree path for git CLI commands\\n   300→\\tattributionBaseCommit string       // Base commit hash for non-agent file detection (empty = fall back to go-git tree walk)\\n   301→\\theadCommitHash        string       // HEAD commit hash for non-agent file detection (empty = fall back to go-git tree walk)\\n   302→}\\n   303→\\n   304→func calculateSessionAttributions(ctx context.Context, repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState, opts ...attributionOpts) *cpkg.InitialAttribution {\\n   305→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   306→\\t// This uses user edits captured at each prompt start (before agent works),\\n   307→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   308→\\t//\\n   309→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   310→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   311→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   312→\\tlogCtx := logging.WithComponent(ctx, \\\"attribution\\\")\\n   313→\\n   314→\\tvar o attributionOpts\\n   315→\\tif len(opts) > 0 {\\n   316→\\t\\to = opts[0]\\n   317→\\t}\\n   318→\\n   319→\\theadTree := o.headTree\\n   320→\\tif headTree == nil {\\n   321→\\t\\theadRef, headErr := repo.Head()\\n   322→\\t\\tif headErr != nil {\\n   323→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   324→\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   325→\\t\\t\\treturn nil\\n   326→\\t\\t}\\n   327→\\n   328→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   329→\\t\\tif commitErr != nil {\\n   330→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   331→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   332→\\t\\t\\treturn nil\\n   333→\\t\\t}\\n   334→\\n   335→\\t\\tvar treeErr error\\n   336→\\t\\theadTree, treeErr = headCommit.Tree()\\n   337→\\t\\tif treeErr != nil {\\n   338→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   339→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   340→\\t\\t\\treturn nil\\n   341→\\t\\t}\\n   342→\\t}\\n   343→\\n   344→\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n   345→\\tshadowTree := o.shadowTree\\n   346→\\tif shadowTree == nil {\\n   347→\\t\\tif shadowRef != nil {\\n   348→\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   349→\\t\\t\\tif shadowErr != nil {\\n   350→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   351→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   352→\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   353→\\t\\t\\t\\treturn nil\\n   354→\\t\\t\\t}\\n   355→\\t\\t\\tvar shadowTreeErr error\\n   356→\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   357→\\t\\t\\tif shadowTreeErr != nil {\\n   358→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   359→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   360→\\t\\t\\t\\treturn nil\\n   361→\\t\\t\\t}\\n   362→\\t\\t} else {\\n   363→\\t\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   364→\\t\\t\\t// because the agent's work is the commit itself.\\n   365→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   366→\\t\\t\\tshadowTree = headTree\\n   367→\\t\\t}\\n   368→\\t}\\n   369→\\n   370→\\t// Get base tree (state before session started)\\n   371→\\tvar baseTree *object.Tree\\n   372→\\tattrBase := state.AttributionBaseCommit\\n   373→\\tif attrBase == \\\"\\\" {\\n   374→\\t\\tattrBase = state.BaseCommit // backward compat\\n   375→\\t}\\n   376→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   377→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   378→\\t\\t\\tbaseTree = tree\\n   379→\\t\\t} else {\\n   380→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   381→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   382→\\t\\t}\\n   383→\\t} else {\\n   384→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   385→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   386→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   387→\\t}\\n   388→\\n   389→\\t// Log accumulated prompt attributions for debugging\\n   390→\\tvar totalUserAdded, totalUserRemoved int\\n   391→\\tfor i, pa := range state.PromptAttributions {\\n   392→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   393→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   394→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   395→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   396→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   397→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   398→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   399→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   400→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   401→\\t}\\n   402→\\n   403→\\tattribution := CalculateAttributionWithAccumulated(\\n   404→\\t\\tctx,\\n   405→\\t\\tbaseTree,\\n   406→\\t\\tshadowTree,\\n   407→\\t\\theadTree,\\n   408→\\t\\tsessionData.FilesTouched,\\n   409→\\t\\tstate.PromptAttributions,\\n   410→\\t\\to.repoDir,\\n   411→\\t\\to.attributionBaseCommit,\\n   412→\\t\\to.headCommitHash,\\n   413→\\t)\\n   414→\\n   415→\\tif attribution != nil {\\n   416→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   417→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   418→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   419→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   420→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   421→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   422→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   423→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   424→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   425→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   426→\\t}\\n   427→\\n   428→\\treturn attribution\\n   429→}\\n   430→\\n   431→// extractSessionData extracts session data from the shadow branch.\\n   432→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   433→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   434→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   435→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   436→// continued growing — the