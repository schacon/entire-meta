n-Fast-Forward Recovery\\n   509→// =============================================================================\\n   510→\\n   511→// TestConcurrentPush_SecondPusherMergesAndRetries verifies that when two clones\\n   512→// push to the same remote, the second pusher fetches, merges, and retries.\\n   513→func TestConcurrentPush_SecondPusherMergesAndRetries(t *testing.T) {\\n   514→\\tt.Parallel()\\n   515→\\tenv := NewFeatureBranchEnv(t)\\n   516→\\n   517→\\tbareDir := env.SetupBareRemote()\\n   518→\\n   519→\\t// Clone A\\n   520→\\tcloneA := env.CloneFrom(bareDir)\\n   521→\\tcloneA.GitCheckoutNewBranch(\\\"feature/clone-a\\\")\\n   522→\\n   523→\\t// Clone B\\n   524→\\tcloneB := env.CloneFrom(bareDir)\\n   525→\\tcloneB.GitCheckoutNewBranch(\\\"feature/clone-b\\\")\\n   526→\\n   527→\\t// Clone A: session + commit\\n   528→\\tsessionA := cloneA.NewSession()\\n   529→\\ttranscriptA := sessionA.CreateTranscript(\\\"Work in clone A\\\", []FileChange{\\n   530→\\t\\t{Path: \\\"a.go\\\", Content: \\\"package a\\\"},\\n   531→\\t})\\n   532→\\n   533→\\tif err := cloneA.SimulateUserPromptSubmitWithPromptAndTranscriptPath(sessionA.ID, \\\"Work in clone A\\\", transcriptA); err != nil {\\n   534→\\t\\tt.Fatalf(\\\"clone A SimulateUserPromptSubmit failed: %v\\\", err)\\n   535→\\t}\\n   536→\\n   537→\\tcloneA.WriteFile(\\\"a.go\\\", \\\"package a\\\")\\n   538→\\tcloneA.GitAdd(\\\"a.go\\\")\\n   539→\\n   540→\\tif err := cloneA.SimulateStop(sessionA.ID, transcriptA); err != nil {\\n   541→\\t\\tt.Fatalf(\\\"clone A SimulateStop failed: %v\\\", err)\\n   542→\\t}\\n   543→\\n   544→\\tcloneA.GitCommitWithShadowHooks(\\\"Work from A\\\", \\\"a.go\\\")\\n   545→\\n   546→\\t// Clone B: session + commit\\n   547→\\tsessionB := cloneB.NewSession()\\n   548→\\ttranscriptB := sessionB.CreateTranscript(\\\"Work in clone B\\\", []FileChange{\\n   549→\\t\\t{Path: \\\"b.go\\\", Content: \\\"package b\\\"},\\n   550→\\t})\\n   551→\\n   552→\\tif err := cloneB.SimulateUserPromptSubmitWithPromptAndTranscriptPath(sessionB.ID, \\\"Work in clone B\\\", transcriptB); err != nil {\\n   553→\\t\\tt.Fatalf(\\\"clone B SimulateUserPromptSubmit failed: %v\\\", err)\\n   554→\\t}\\n   555→\\n   556→\\tcloneB.WriteFile(\\\"b.go\\\", \\\"package b\\\")\\n   557→\\tcloneB.GitAdd(\\\"b.go\\\")\\n   558→\\n   559→\\tif err := cloneB.SimulateStop(sessionB.ID, transcriptB); err != nil {\\n   560→\\t\\tt.Fatalf(\\\"clone B SimulateStop failed: %v\\\", err)\\n   561→\\t}\\n   562→\\n   563→\\tcloneB.GitCommitWithShadowHooks(\\\"Work from B\\\", \\\"b.go\\\")\\n   564→\\n   565→\\t// A pushes first (should succeed cleanly)\\n   566→\\tif err := runPrePushInDir(t, cloneA.RepoDir, \\\"origin\\\"); err != nil {\\n   567→\\t\\tt.Fatalf(\\\"clone A PrePush failed: %v\\\", err)\\n   568→\\t}\\n   569→\\n   570→\\tcheckpointA := cloneA.GetLatestCheckpointID()\\n   571→\\tt.Logf(\\\"Clone A checkpoint: %s\\\", checkpointA)\\n   572→\\n   573→\\t// B pushes second (will get non-fast-forward, should fetch+merge+retry)\\n   574→\\tif err := runPrePushInDir(t, cloneB.RepoDir, \\\"origin\\\"); err != nil {\\n   575→\\t\\tt.Fatalf(\\\"clone B PrePush failed: %v\\\", err)\\n   576→\\t}\\n   577→\\n   578→\\tcheckpointB := cloneB.GetLatestCheckpointID()\\n   579→\\tt.Logf(\\\"Clone B checkpoint: %s\\\", checkpointB)\\n   580→\\n   581→\\t// Remote should have BOTH checkpoints\\n   582→\\tsummaryA := CheckpointSummaryPath(checkpointA)\\n   583→\\tif !fileExistsOnRemoteBranch(t, bareDir, paths.MetadataBranchName, summaryA) {\\n   584→\\t\\tt.Errorf(\\\"remote should have checkpoint from clone A: %s\\\", checkpointA)\\n   585→\\t}\\n   586→\\n   587→\\tsummaryB := CheckpointSummaryPath(checkpointB)\\n   588→\\tif !fileExistsOnRemoteBranch(t, bareDir, paths.MetadataBranchName, summaryB) {\\n   589→\\t\\tt.Errorf(\\\"remote should have checkpoint from clone B: %s\\\", checkpointB)\\n   590→\\t}\\n   591→}\\n   592→\\n   593→// =============================================================================\\n   594→// P1 — Graceful Degradation\\n   595→// =============================================================================\\n   596→\\n   597→// TestGracefulDegradation_UnreachableRemotePushContinues verifies that\\n   598→// PrePush does not fail when a checkpoint remote URL is unreachable.\\n   599→// The push to origin should still succeed for trails.\\n   600→func TestGracefulDegradation_UnreachableRemotePushContinues(t *testing.T) {\\n   601→\\tt.Parallel()\\n   602→\\tenv := NewFeatureBranchEnv(t)\\n   603→\\n   604→\\tbareDir := env.SetupBareRemote()\\n   605→\\n   606→\\t// Create session + commit to generate checkpoints and trails locally\\n   607→\\tsession := env.NewSession()\\n   608→\\ttranscriptPath := session.CreateTranscript(\\\"Some work\\\", []FileChange{\\n   609→\\t\\t{Path: \\\"work.go\\\", Content: \\\"package work\\\"},\\n   610→\\t})\\n   611→\\n   612→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Some work\\\", transcriptPath); err != nil {\\n   613→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   614→\\t}\\n   615→\\n   616→\\tenv.WriteFile(\\\"work.go\\\", \\\"package work\\\")\\n   617→\\tenv.GitAdd(\\\"work.go\\\")\\n   618→\\n   619→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   620→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   621→\\t}\\n   622→\\n   623→\\tenv.GitCommitWithShadowHooks(\\\"Some work\\\", \\\"work.go\\\")\\n   624→\\n   625→\\t// PrePush should not error even if internal operations warn\\n   626→\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n   627→\\t\\tt.Fatalf(\\\"PrePush should not fail: %v\\\", err)\\n   628→\\t}\\n   629→\\n   630→\\t// Trails should be pushed to origin regardless\\n   631→\\tif env.BranchExists(paths.TrailsBranchName) && !env.BranchExistsOnRemote(bareDir, paths.TrailsBranchName) {\\n   632→\\t\\tt.Error(\\\"trails should still be pushed to origin\\\")\\n   633→\\t}\\n   634→}\\n   635→\\n   636→// =============================================================================\\n   637→// Helpers\\n   638→// =============================================================================\\n   639→\\n   640→// runPrePushInDir runs the pre-push hook via the CLI binary in the given directory.\\n   641→func runPrePushInDir(t *testing.T, repoDir, remote string) error {\\n   642→\\tt.Helper()\\n   643→\\n   644→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"pre-push\\\", remote)\\n   645→\\tcmd.Dir = repoDir\\n   646→\\tcmd.Env = testutil.GitIsolatedEnv()\\n   647→\\t// pre-push hook reads stdin for ref info, provide empty input\\n   648→\\tcmd.Stdin = nil\\n   649→\\n   650→\\toutput, err := cmd.CombinedOutput()\\n   651→\\tif err != nil {\\n   652→\\t\\tt.Logf(\\\"pre-push output: %s\\\", output)\\n   653→\\t\\treturn err\\n   654→\\t}\\n   655→\\tt.Logf(\\\"pre-push output: %s\\\", output)\\n   656→\\treturn nil\\n   657→}\\n   658→\\n   659→// fetchMetadataBranch fetches the entire/checkpoints/v1 branch from a remote URL\\n   660→// into a local repo. This simulates what fetchMetadataBranchIfMissing does.\\n   661→func fetchMetadataBranch(t *testing.T, repoDir, remoteURL string) {\\n   662→\\tt.Helper()\\n   663→\\n   664→\\tbranchName := paths.MetadataBranchName\\n   665→\\trefSpec := \\\"+\\\" + \\\"refs/heads/\\\" + branchName + \\\":\\\" + \\\"refs/heads/\\\" + branchName\\n   666→\\tcmd := exec.Command(\\\"git\\\", \\\"fetch\\\", \\\"--no-tags\\\", remoteURL, refSpec)\\n   667→\\tcmd.Dir = repoDir\\n   668→\\tcmd.Env = testutil.GitIsolatedEnv()\\n   669→\\n   670→\\toutput, err := cmd.CombinedOutput()\\n   671→\\tif err != nil {\\n   672→\\t\\t// It is OK if the branch doesn't exist on remote\\n   673→\\t\\tt.Logf(\\\"fetch metadata branch output: %s (err: %v)\\\", output, err)\\n   674→\\t}\\n   675→}\\n   676→\\n   677→// fileExistsOnRemoteBranch checks if a file exists in a branch tree on a bare remote.\\n   678→func fileExistsOnRemoteBranch(t *testing.T, bareDir, branchName, filePath string) bool {\\n   679→\\tt.Helper()\\n   680→\\n   681→\\tcmd := exec.Command(\\\"git\\\", \\\"cat-file\\\", \\\"-t\\\", branchName+\\\":\\\"+filePath)\\n   682→\\tcmd.Dir = bareDir\\n   683→\\tcmd.Env = testutil.GitIsolatedEnv()\\n   684→\\treturn cmd.Run() == nil\\n   685→}\\n   686→\\n   687→// getRemoteBranchHash returns the commit hash of a branch on a bare remote.\\n   688→func getRemoteBranchHash(t *testing.T, bareDir, branchName string) string {\\n   689→\\tt.Helper()\\n   690→\\n   691→\\tcmd := exec.Command(\\\"git\\\", \\\"rev-parse\\\", \\\"refs/heads/\\\"+branchName)\\n   692→\\tcmd.Dir = bareDir\\n   693→\\tcmd.Env = testutil.GitIsolatedEnv()\\n   694→\\toutput, err := cmd.Output()\\n   695→\\tif err != nil {\\n   696→\\t\\tt.Fatalf(\\\"failed to get hash for %s on remote: %v\\\", branchName, err)\\n   697→\\t}\\n   698→\\treturn trimOutput(string(output))\\n   699→}\\n   700→\\n   701→// listCheckpointsInDir calls strategy.ListCheckpoints from within the given directory.\\n   702→// Uses the CLI binary to run `entire sessions --json` in the clone.\\n   703→func listCheckpointsInDir(t *testing.T, repoDir string) []checkpointListEntry {\\n   704→\\tt.Helper()\\n   705→\\n   706→\\t// We read checkpoints directly from the metadata branch using git show\\n   707→\\t// since calling the CLI for session listing would require more setup.\\n   708→\\tcmd := exec.Command(\\\"git\\\", \\\"ls-tree\\\", \\\"-r\\\", \\\"--name-only\\\", paths.MetadataBranchName)\\n   709→\\tcmd.Dir = repoDir\\n   710→\\tcmd.Env = testutil.GitIsolatedEnv()\\n   711→\\toutput, err := cmd.Output()\\n   712→\\tif err != nil {\\n   713→\\t\\tt.Logf(\\\"ls-tree failed (branch may not exist): %v\\\", err)\\n   714→\\t\\treturn nil\\n   715→\\t}\\n   716→\\n   717→\\t// Parse the sharded structure to find checkpoints\\n   718→\\tseen := make(map[string]bool)\\n   719→\\tvar entries []checkpointListEntry\\n   720→\\tfor _, line := range splitLines(string(output)) {\\n   721→\\t\\tparts := filepath.SplitList(line)\\n   722→\\t\\t// Use simple split instead\\n   723→\\t\\tpathParts := splitPath(line)\\n   724→\\t\\t_ = parts\\n   725→\\t\\t// Match <prefix>/<suffix>/metadata.json (top-level, not session-level)\\n   726→\\t\\tif len(pathParts) == 3 && pathParts[2] == \\\"metadata.json\\\" {\\n   727→\\t\\t\\tcpID := pathParts[0] + pathParts[1]\\n   728→\\t\\t\\tif !seen[cpID] {\\n   729→\\t\\t\\t\\tseen[cpID] = true\\n   730→\\t\\t\\t\\tentries = append(entries, checkpointListEntry{CheckpointID: cpID})\\n   731→\\t\\t\\t}\\n   732→\\t\\t}\\n   733→\\t}\\n   734→\\n   735→\\treturn entries\\n   736→}\\n   737→\\n   738→// checkpointListEntry is a simplified checkpoint entry for test assertions.\\n   739→type checkpointListEntry struct {\\n   740→\\tCheckpointID string\\n   741→}\\n   742→\\n   743→func splitLines(s string) []string {\\n   744→\\tlines := make([]string, 0)\\n   745→\\tfor _, line := range splitByNewline(s) {\\n   746→\\t\\tline = trimOutput(line)\\n   747→\\t\\tif line != \\\"\\\" {\\n   748→\\t\\t\\tlines = append(lines, line)\\n   749→\\t\\t}\\n   750→\\t}\\n   751→\\treturn lines\\n   752→}\\n   753→\\n   754→func splitByNewline(s string) []string {\\n   755→\\tvar result []string\\n   756→\\tstart := 0\\n   757→\\tfor i := range len(s) {\\n   758→\\t\\tif s[i] == '\\\\n' {\\n   759→\\t\\t\\tresult = append(result, s[start:i])\\n   760→\\t\\t\\tstart = i + 1\\n   761→\\t\\t}\\n   762→\\t}\\n   763→\\tif start < len(s) {\\n   764→\\t\\tresult = append(result, s[start:])\\n   765→\\t}\\n   766→\\treturn result\\n   767→}\\n   768→\\n   769→func splitPath(s string) []string {\\n   770→\\tvar parts []string\\n   771→\\tstart := 0\\n   772→\\tfor i := range len(s) {\\n   773→\\t\\tif s[i] == '/' {\\n   774→\\t\\t\\tparts = append(parts, s[start:i])\\n   775→\\t\\t\\tstart = i + 1\\n   776→\\t\\t}\\n   777→\\t}\\n   778→\\t