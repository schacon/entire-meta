tchesCheckpointMetadata verifies that after pushing\\n   251→// checkpoints to a remote, cloning the repo and fetching the metadata branch\\n   252→// brings the checkpoint data locally.\\n   253→func TestCloneAndResume_FetchesCheckpointMetadata(t *testing.T) {\\n   254→\\tt.Parallel()\\n   255→\\tenv := NewFeatureBranchEnv(t)\\n   256→\\n   257→\\tbareDir := env.SetupBareRemote()\\n   258→\\n   259→\\t// Repo A: create session, checkpoint, commit, push\\n   260→\\tsession := env.NewSession()\\n   261→\\ttranscriptPath := session.CreateTranscript(\\\"Build login page\\\", []FileChange{\\n   262→\\t\\t{Path: \\\"login.go\\\", Content: \\\"package login\\\"},\\n   263→\\t})\\n   264→\\n   265→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Build login page\\\", transcriptPath); err != nil {\\n   266→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   267→\\t}\\n   268→\\n   269→\\tenv.WriteFile(\\\"login.go\\\", \\\"package login\\\")\\n   270→\\tenv.GitAdd(\\\"login.go\\\")\\n   271→\\n   272→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   273→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   274→\\t}\\n   275→\\n   276→\\tenv.GitCommitWithShadowHooks(\\\"Build login page\\\", \\\"login.go\\\")\\n   277→\\n   278→\\t// Push user branch + checkpoint branches to remote\\n   279→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   280→\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n   281→\\t\\tt.Fatalf(\\\"PrePush failed: %v\\\", err)\\n   282→\\t}\\n   283→\\n   284→\\tcheckpointID := env.GetLatestCheckpointID()\\n   285→\\tt.Logf(\\\"Original checkpoint ID: %s\\\", checkpointID)\\n   286→\\n   287→\\t// Clone into repo B\\n   288→\\tcloneEnv := env.CloneFrom(bareDir)\\n   289→\\n   290→\\t// Fetch the metadata branch explicitly (simulates what happens on first session start)\\n   291→\\tfetchMetadataBranch(t, cloneEnv.RepoDir, bareDir)\\n   292→\\n   293→\\t// Now the metadata branch should exist locally in the clone\\n   294→\\tif !cloneEnv.BranchExists(paths.MetadataBranchName) {\\n   295→\\t\\tt.Fatal(\\\"entire/checkpoints/v1 should exist in clone after fetch\\\")\\n   296→\\t}\\n   297→\\n   298→\\t// Verify the checkpoint data is present\\n   299→\\tsummaryPath := CheckpointSummaryPath(checkpointID)\\n   300→\\tif !cloneEnv.FileExistsInBranch(paths.MetadataBranchName, summaryPath) {\\n   301→\\t\\tt.Errorf(\\\"checkpoint metadata should exist in clone at %s\\\", summaryPath)\\n   302→\\t}\\n   303→}\\n   304→\\n   305→// TestCloneAndResume_SessionListingWorksAfterClone verifies that checkpoint\\n   306→// metadata can be enumerated after cloning and fetching the metadata branch.\\n   307→func TestCloneAndResume_SessionListingWorksAfterClone(t *testing.T) {\\n   308→\\tt.Parallel()\\n   309→\\tenv := NewFeatureBranchEnv(t)\\n   310→\\n   311→\\tbareDir := env.SetupBareRemote()\\n   312→\\n   313→\\t// Repo A: create session, checkpoint, commit, push\\n   314→\\tsession := env.NewSession()\\n   315→\\ttranscriptPath := session.CreateTranscript(\\\"Implement auth\\\", []FileChange{\\n   316→\\t\\t{Path: \\\"auth.go\\\", Content: \\\"package auth\\\"},\\n   317→\\t})\\n   318→\\n   319→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Implement auth\\\", transcriptPath); err != nil {\\n   320→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   321→\\t}\\n   322→\\n   323→\\tenv.WriteFile(\\\"auth.go\\\", \\\"package auth\\\")\\n   324→\\tenv.GitAdd(\\\"auth.go\\\")\\n   325→\\n   326→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   327→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   328→\\t}\\n   329→\\n   330→\\tenv.GitCommitWithShadowHooks(\\\"Implement auth\\\", \\\"auth.go\\\")\\n   331→\\n   332→\\t// Push everything\\n   333→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   334→\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n   335→\\t\\tt.Fatalf(\\\"PrePush failed: %v\\\", err)\\n   336→\\t}\\n   337→\\n   338→\\tcheckpointID := env.GetLatestCheckpointID()\\n   339→\\n   340→\\t// Clone and fetch metadata\\n   341→\\tcloneEnv := env.CloneFrom(bareDir)\\n   342→\\tfetchMetadataBranch(t, cloneEnv.RepoDir, bareDir)\\n   343→\\n   344→\\t// List checkpoints from the clone by scanning the metadata branch tree\\n   345→\\tcheckpoints := listCheckpointsInDir(t, cloneEnv.RepoDir)\\n   346→\\n   347→\\tif len(checkpoints) == 0 {\\n   348→\\t\\tt.Fatal(\\\"should find checkpoints from original repo after clone\\\")\\n   349→\\t}\\n   350→\\n   351→\\t// Verify our checkpoint is in the list\\n   352→\\tfound := false\\n   353→\\tfor _, cp := range checkpoints {\\n   354→\\t\\tif cp == checkpointID {\\n   355→\\t\\t\\tfound = true\\n   356→\\t\\t\\tbreak\\n   357→\\t\\t}\\n   358→\\t}\\n   359→\\tif !found {\\n   360→\\t\\tt.Errorf(\\\"checkpoint %s from original repo should be in list, got: %v\\\", checkpointID, checkpoints)\\n   361→\\t}\\n   362→}\\n   363→\\n   364→// TestCloneAndResume_SessionLogRetrievalWorksAfterClone verifies that\\n   365→// checkpoint transcripts can be read after clone + fetch.\\n   366→func TestCloneAndResume_SessionLogRetrievalWorksAfterClone(t *testing.T) {\\n   367→\\tt.Parallel()\\n   368→\\tenv := NewFeatureBranchEnv(t)\\n   369→\\n   370→\\tbareDir := env.SetupBareRemote()\\n   371→\\n   372→\\t// Repo A: create session with a specific transcript content\\n   373→\\tsession := env.NewSession()\\n   374→\\ttranscriptPath := session.CreateTranscript(\\\"Write tests for auth\\\", []FileChange{\\n   375→\\t\\t{Path: \\\"auth_test.go\\\", Content: \\\"package auth_test\\\"},\\n   376→\\t})\\n   377→\\n   378→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Write tests for auth\\\", transcriptPath); err != nil {\\n   379→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   380→