nit.go\\\", \\\"package init\\\", \\\"Initial work\\\")\\n   704→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   705→\\tenv.RunPrePush(\\\"origin\\\")\\n   706→\\n   707→\\t// Clone from origin\\n   708→\\tcloneEnv := env.CloneFrom(bareDir)\\n   709→\\n   710→\\t// Configure checkpoint_remote to an unreachable path in the clone.\\n   711→\\t// When the checkpoint_remote URL can't be reached, fetch fails silently.\\n   712→\\tcloneEnv.PatchSettings(map[string]any{\\n   713→\\t\\t\\\"strategy_options\\\": map[string]any{\\n   714→\\t\\t\\t\\\"checkpoint_remote\\\": map[string]any{\\n   715→\\t\\t\\t\\t\\\"provider\\\": \\\"github\\\",\\n   716→\\t\\t\\t\\t\\\"repo\\\":     \\\"nonexistent-org/nonexistent-repo\\\",\\n   717→\\t\\t\\t},\\n   718→\\t\\t},\\n   719→\\t})\\n   720→\\n   721→\\t// Starting a new session should not error even though checkpoint_remote is unreachable.\\n   722→\\t// The session machinery itself doesn't trigger fetchMetadataBranchIfMissing (that happens\\n   723→\\t// in resolvePushSettings during PrePush), so this verifies the session starts cleanly.\\n   724→\\tsession := cloneEnv.NewSession()\\n   725→\\ttranscriptPath := session.CreateTranscript(\\\"Clone work\\\", []FileChange{\\n   726→\\t\\t{Path: \\\"clone.go\\\", Content: \\\"package clone\\\"},\\n   727→\\t})\\n   728→\\n   729→\\tif err := cloneEnv.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Clone work\\\", transcriptPath); err != nil {\\n   730→\\t\\tt.Fatalf(\\\"session start should not fail with unreachable checkpoint_remote: %v\\\", err)\\n   731→\\t}\\n   732→\\n   733→\\tif err := cloneEnv.SimulateStop(session.ID, transcriptPath); err != nil {\\n   734→\\t\\tt.Fatalf(\\\"session stop should not fail: %v\\\", err)\\n   735→\\t}\\n   736→\\n   737→\\t// PrePush should also not fail -- checkpoint_remote URL derivation will fail\\n   738→\\t// (origin is a local path, can't parse it), so it falls back to pushing to origin.\\n   739→\\tcloneEnv.WriteFile(\\\"clone.go\\\", \\\"package clone\\\")\\n   740→\\tcloneEnv.GitAdd(\\\"clone.go\\\")\\n   741→\\tcloneEnv.GitCommitWithShadowHooks(\\\"Clone work\\\", \\\"clone.go\\\")\\n   742→\\tcloneEnv.RunPrePush(\\\"origin\\\")\\n   743→}\\n   744→\\n   745→// =============================================================================\\n   746→// Helpers\\n   747→// =============================================================================\\n   748→\\n   749→// createOrphanBranch creates a minimal orphan branch with a single file using\\n   750→// go-git plumbing APIs. This avoids switching the working tree (which would\\n   751→// conflict with other files and the test binary).\\n   752→func createOrphanBranch(t *testing.T, repoDir, branchName, fileName, content string) {\\n   753→\\tt.Helper()\\n   754→\\n   755→\\trepo, err := git.PlainOpen(repoDir)\\n   756→\\tif err != nil {\\n   757→\\t\\tt.Fatalf(\\\"failed to open repo: %v\\\", err)\\n   758→\\t}\\n   759→\\n   760→\\t// Create a blob for the file content\\n   761→\\tblobObj := repo.Storer.NewEncodedObject()\\n   762→\\tblobObj.SetType(plumbing.BlobObject)\\n   763→\\tw, err := blobObj.Writer()\\n   764→\\tif err != nil {\\n   765→\\t\\tt.Fatalf(\\\"failed to create blob writer: %v\\\", err)\\n   766→\\t}\\n   767→\\tif _, err := w.Write([]byte(content)); err != nil {\\n   768→\\t\\tt.Fatalf(\\\"failed to write blob: %v\\\", err)\\n   769→\\t}\\n   770→\\tif err := w.Close(); err != nil {\\n   771→\\t\\tt.Fatalf(\\\"failed to close blob writer: %v\\\", err)\\n   772→\\t}\\n   773→\\tblobHash, err := repo.Storer.SetEncodedObject(blobObj)\\n   774→\\tif err != nil {\\n   775→\\t\\tt.Fatalf(\\\"failed to store blob: %v\\\", err)\\n   776→\\t}\\n   777→\\n   778→\\t// Create a tree with the single file\\n   779→\\ttree := &object.Tree{\\n   780→\\t\\tEntries: []object.TreeEntry{\\n   781→\\t\\t\\t{\\n   782→\\t\\t\\t\\tName: fileName,\\n   783→\\t\\t\\t\\tMode: filemode.Regular,\\n   784→\\t\\t\\t\\tHash: blobHash,\\n