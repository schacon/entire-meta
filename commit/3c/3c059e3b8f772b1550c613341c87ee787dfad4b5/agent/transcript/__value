rAll(localDir, 0o755); err != nil {\\n   526→\\t\\tt.Fatalf(\\\"failed to create dir: %v\\\", err)\\n   527→\\t}\\n   528→\\tif err := os.WriteFile(filepath.Join(localDir, \\\"metadata.json\\\"), []byte(`{\\\"checkpoint_id\\\":\\\"abcdef012345\\\"}`), 0o644); err != nil {\\n   529→\\t\\tt.Fatalf(\\\"failed to write: %v\\\", err)\\n   530→\\t}\\n   531→\\trun(\\\"add\\\", \\\".\\\")\\n   532→\\trun(\\\"commit\\\", \\\"-m\\\", \\\"Checkpoint: abcdef012345\\\")\\n   533→\\trun(\\\"branch\\\", \\\"-f\\\", paths.MetadataBranchName, \\\"temp-orphan\\\")\\n   534→\\trun(\\\"checkout\\\", \\\"main\\\")\\n   535→\\n   536→\\trepo, err := git.PlainOpen(cloneDir)\\n   537→\\tif err != nil {\\n   538→\\t\\tt.Fatalf(\\\"failed to open repo: %v\\\", err)\\n   539→\\t}\\n   540→\\n   541→\\tdisconnected, err := IsMetadataDisconnected(context.Background(), repo)\\n   542→\\tif err != nil {\\n   543→\\t\\tt.Fatalf(\\\"unexpected error: %v\\\", err)\\n   544→\\t}\\n   545→\\tif !disconnected {\\n   546→\\t\\tt.Error(\\\"expected true (disconnected), got false\\\")\\n   547→\\t}\\n   548→}\\n   549→\\n   550→func TestReconcileDisconnected_ModifiedEntries(t *testing.T) {\\n   551→\\tt.Parallel()\\n   552→\\n   553→\\tbareDir := initBareWithMetadataBranch(t)\\n   554→\\tcloneDir, run := cloneWithConfig(t, bareDir)\\n   555→\\n   556→\\t// Create a disconnected local branch where commit 2 modifies a file from commit 1\\n   557→\\t// (simulates multi-session condensation updating metadata.json)\\n   558→\\trun(\\\"checkout\\\", \\\"--orphan\\\", \\\"temp-orphan\\\")\\n   559→\\trun(\\\"rm\\\", \\\"-rf\\\", \\\".\\\")\\n   560→\\n   561→\\t// Commit 1: initial checkpoint\\n   562→\\tdir1 := filepath.Join(cloneDir, \\\"aa\\\", \\\"aaaaaaaaaa\\\")\\n   563→\\tif err := os.MkdirAll(dir1, 0o755); err != nil {\\n   564→\\t\\tt.Fatalf(\\\"failed to create dir: %v\\\", err)\\n   565→\\t}\\n   566→\\tif err := os.WriteFile(filepath.Join(dir1, \\\"metadata.json\\\"),\\n   567→\\t\\t[]byte(`{\\\"che