aryB) {\\n   584→\\t\\tt.Errorf(\\\"remote should have checkpoint from clone B: %s\\\", checkpointB)\\n   585→\\t}\\n   586→}\\n   587→\\n   588→// =============================================================================\\n   589→// P1 — Graceful Degradation\\n   590→// =============================================================================\\n   591→\\n   592→// TestGracefulDegradation_UnreachableRemotePushContinues verifies that\\n   593→// PrePush does not fail when pushing to origin (no checkpoint remote configured).\\n   594→func TestGracefulDegradation_UnreachableRemotePushContinues(t *testing.T) {\\n   595→\\tt.Parallel()\\n   596→\\tenv := NewFeatureBranchEnv(t)\\n   597→\\n   598→\\tenv.SetupBareRemote()\\n   599→\\n   600→\\t// Create session + commit to generate checkpoints locally\\n   601→\\tsession := env.NewSession()\\n   602→\\ttranscriptPath := session.CreateTranscript(\\\"Some work\\\", []FileChange{\\n   603→\\t\\t{Path: \\\"work.go\\\", Content: \\\"package work\\\"},\\n   604→\\t})\\n   605→\\n   606→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Some work\\\", transcriptPath); err != nil {\\n   607→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   608→\\t}\\n   609→\\n   610→\\tenv.WriteFile(\\\"work.go\\\", \\\"package work\\\")\\n   611→\\tenv.GitAdd(\\\"work.go\\\")\\n   612→\\n   613→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   614→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   615→\\t}\\n   616→\\n   617→\\tenv.GitCommitWithShadowHooks(\\\"Some work\\\", \\\"work.go\\\")\\n   618→\\n   619→\\t// PrePush should not error\\n   620→\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n   621→\\t\\tt.Fatalf(\\\"PrePush should not fail: %v\\\", err)\\n   622→\\t}\\n   623→}\\n   624→\\n   625→// =============================================================================\\n   626→// Helpers\\n   627→// =========