eckpointID is the expected checkpoint ID\\n  1383→\\tCheckpointID string\\n  1384→\\n  1385→\\t// SessionID is the expected session ID\\n  1386→\\tSessionID string\\n  1387→\\n  1388→\\t// Strategy is the expected strategy name\\n  1389→\\tStrategy string\\n  1390→\\n  1391→\\t// FilesTouched are the expected files in files_touched\\n  1392→\\tFilesTouched []string\\n  1393→\\n  1394→\\t// ExpectedPrompts are strings that should appear in prompt.txt\\n  1395→\\tExpectedPrompts []string\\n  1396→\\n  1397→\\t// ExpectedTranscriptContent are strings that should appear in full.jsonl\\n  1398→\\tExpectedTranscriptContent []string\\n  1399→\\n  1400→\\t// CheckpointsCount is the expected checkpoint count (0 means don't validate)\\n  1401→\\tCheckpointsCount int\\n  1402→}\\n  1403→\\n  1404→// ValidateCheckpoint performs comprehensive validation of a checkpoint on the metadata branch.\\n  1405→// It validates:\\n  1406→// - Root metadata.json (CheckpointSummary) structure and expected fields\\n  1407→// - Session metadata.json (CommittedMetadata) structure and expected fields\\n  1408→// - Transcript file (full.jsonl) is valid JSONL and contains expected content\\n  1409→// - Content hash file (content_hash.txt) matches SHA256 of transcript\\n  1410→// - Prompt file (prompt.txt) contains expected prompts\\n  1411→func (env *TestEnv) ValidateCheckpoint(v CheckpointValidation) {\\n  1412→\\tenv.T.Helper()\\n  1413→\\n  1414→\\t// Validate root metadata.json (CheckpointSummary)\\n  1415→\\tenv.validateCheckpointSummary(v)\\n  1416→\\n  1417→\\t// Validate session metadata.json (CommittedMetadata)\\n  1418→\\tenv.validateSessionMetadata(v)\\n  1419→\\n  1420→\\t// Validate transcript is valid JSONL\\n  1421→\\tenv.validateTranscriptJSONL(v.CheckpointID, v.ExpectedTranscriptContent)\\n  1422→\\n  1423→\\t// Validate content hash matches transcript\\n  1424→\\tenv.validateContentHash(v.CheckpointID)\\n  1425→\\n  1426→\\t// Validate prompt.txt contains expected prompts\\n  142