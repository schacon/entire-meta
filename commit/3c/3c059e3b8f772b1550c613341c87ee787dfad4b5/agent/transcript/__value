or(\\\"entire/checkpoints/v1 should NOT be on remote when push_sessions is false\\\")\\n   243→\\t}\\n   244→}\\n   245→\\n   246→// =============================================================================\\n   247→// P0 — Clone and Resume\\n   248→// =============================================================================\\n   249→\\n   250→// TestCloneAndResume_FetchesCheckpointMetadata verifies that after pushing\\n   251→// checkpoints to a remote, cloning the repo and fetching the metadata branch\\n   252→// brings the checkpoint data locally.\\n   253→func TestCloneAndResume_FetchesCheckpointMetadata(t *testing.T) {\\n   254→\\tt.Parallel()\\n   255→\\tenv := NewFeatureBranchEnv(t)\\n   256→\\n   257→\\tbareDir := env.SetupBareRemote()\\n   258→\\n   259→\\t// Repo A: create session, checkpoint, commit, push\\n   260→\\tsession := env.NewSession()\\n   261→\\ttranscriptPath := session.CreateTranscript(\\\"Build login page\\\", []FileChange{\\n   262→\\t\\t{Path: \\\"login.go\\\", Content: \\\"package login\\\"},\\n   263→\\t})\\n   264→\\n   265→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Build login page\\\", transcriptPath); err != nil {\\n   266→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   267→\\t}\\n   268→\\n   269→\\tenv.WriteFile(\\\"login.go\\\", \\\"package login\\\")\\n   270→\\tenv.GitAdd(\\\"login.go\\\")\\n   271→\\n   272→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   273→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   274→\\t}\\n   275→\\n   276→\\tenv.GitCommitWithShadowHooks(\\\"Build login page\\\", \\\"login.go\\\")\\n   277→\\n   278→\\t// Push user branch + checkpoint branches to remote\\n   279→\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n   280→\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n   281→\\t\\tt.Fatalf(\\\"PrePush failed: %v\\\", err)\\n   282→\\t}\\n   283→\\n   284→\\tcheckpointID