") or a URL for direct push.\\n    23→// When pushing to a URL, the \\\"has unpushed\\\" optimization is skipped since there are\\n    24→// no remote tracking refs — git itself handles the no-op case.\\n    25→// Does not check any settings — callers are responsible for gating.\\n    26→func pushBranchIfNeeded(ctx context.Context, target, branchName string) error {\\n    27→\\trepo, err := OpenRepository(ctx)\\n    28→\\tif err != nil {\\n    29→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n    30→\\t}\\n    31→\\n    32→\\t// Check if branch exists locally\\n    33→\\tbranchRef := plumbing.NewBranchReferenceName(branchName)\\n    34→\\tlocalRef, err := repo.Reference(branchRef, true)\\n    35→\\tif err != nil {\\n    36→\\t\\t// No branch, nothing to push\\n    37→\\t\\treturn nil //nolint:nilerr // Expected when no sessions exist yet\\n    38→\\t}\\n    39→\\n    40→\\t// Only check remote tracking refs when target is a remote name (not a URL).\\n    41→\\t// URLs don't have tracking refs, so we always attempt the push and let git handle it.\\n    42→\\tif !isURL(target) && !hasUnpushedSessionsCommon(repo, target, localRef.Hash(), branchName) {\\n    43→\\t\\treturn nil\\n    44→\\t}\\n    45→\\n    46→\\treturn doPushBranch(ctx, target, branchName)\\n    47→}\\n    48→\\n    49→// hasUnpushedSessionsCommon checks if the local branch differs from the remote.\\n    50→// Returns true if there's any difference that needs syncing (local ahead, remote ahead, or diverged).\\n    51→func hasUnpushedSessionsCommon(repo *git.Repository, remote string, localHash plumbing.Hash, branchName string) bool {\\n    52→\\t// Check for remote tracking ref: refs/remotes/<remote>/<branch>\\n    53→\\tremoteRefName := plumbing.NewRemoteReferenceName(remote, branchName)\\n    54→\\tremoteRef, err := repo.Reference(remoteRefName, true)\\n    55→\\tif err != nil {\\n    56→\\t\\t// Remote branch doesn't exist yet - we have content to push\\n    57→\\t\\treturn true\\n    58→\\t}\\n    59→\\n    60→\\t// If local and remote point to same commit, nothing to sync\\n    61→\\t// This is the only case where we skip - any difference needs handling\\n    62→\\treturn localHash != remoteRef.Hash()\\n    63→}\\n    64→\\n    65→// doPushBranch pushes the given branch to the target with fetch+merge recovery.\\n    66→// The target can be a remote name or a URL.\\n    67→func doPushBranch(ctx context.Context, target, branchName string) error {\\n    68→\\tdisplayTarget := target\\n    69→\\tif isURL(target) {\\n    70→\\t\\tdisplayTarget = \\\"checkpoint remote\\\"\\n    71→\\t}\\n    72→\\n    73→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Pushing %s to %s...\\\", branchName, displayTarget)\\n    74→\\tstop := startProgressDots(os.Stderr)\\n    75→\\n    76→\\t// Try pushing first\\n    77→\\tif err := tryPushSessionsCommon(ctx, target, branchName); err == nil {\\n    78→\\t\\tstop(\\\" done\\\")\\n    79→\\t\\treturn nil\\n    80→\\t}\\n    81→\\tstop(\\\"\\\")\\n    82→\\n    83→\\t// Push failed - likely non-fast-forward. Try to fetch and merge.\\n    84→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Syncing %s with remote...\\\", branchName)\\n    85→\\tstop = startProgressDots(os.Stderr)\\n    86→\\n    87→\\tif err := fetchAndMergeSessionsCommon(ctx, target, branchName); err != nil {\\n    88→\\t\\tstop(\\\"\\\")\\n    89→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: couldn't sync %s: %v\\\\n\\\", branchName, err)\\n    90→\\t\\tprintCheckpointRemoteHint(target)\\n    91→\\t\\treturn nil // Don't fail the main push\\n    92→\\t}\\n    93→\\tstop(\\\" done\\\")\\n    94→\\n    95→\\t// Try pushing again after merge\\n    96→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Pushing %s to %s...\\\", branchName, displayTarget)\\n    97→\\tstop = startProgressDots(os.Stderr)\\n    98→\\n    99→\\tif err := tryPushSessionsCommon(ctx, target, branchName); err != nil {\\n   100→\\t\\tstop(\\\"\\\")\\n   101→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: failed to push %s after sync: %v\\\\n\\\", branchName, err)\\n   102→\\t\\tprintCheckpointRemoteHint(target)\\n   103→\\t} else {\\n   104→\\t\\tstop(\\\" done\\\")\\n   105→\\t}\\n   106→\\n   107→\\treturn nil\\n   108→}\\n   109→\\n   110→// printCheckpointRemoteHint prints a hint when a push to a checkpoint URL fails.\\n   111→// Only prints when the target is a URL (not the user's default remote).\\n   112→func printCheckpointRemoteHint(target string) {\\n   113→\\tif !isURL(target) {\\n   114→\\t\\treturn\\n   115→\\t}\\n   116→\\tfmt.Fprintln(os.Stderr, \\\"[entire] A checkpoint remote is configured in Entire settings (.entire/settings.json or .entire/settings.local.json) but could not be reached.\\\")\\n   117→\\tfmt.Fprintln(os.Stderr, \\\"[entire] Checkpoints are saved locally but not synced. Ensure you have access to the checkpoint remote.\\\")\\n   118→}\\n   119→\\n   120→// tryPushSessionsCommon attempts to push the sessions branch.\\n   121→func tryPushSessionsCommon(ctx context.Context, remote, branchName string) error {\\n   122→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   123→\\tdefer cancel()\\n   124→\\n   125→\\t// Use --no-verify to prevent recursive hook calls\\n   126→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"push\\\", \\\"--no-verify\\\", remote, branchName)\\n   127→\\tcmd.Stdin = nil // Disconnect stdin to prevent hanging in hook context\\n   128→\\n   129→\\toutput, err := cmd.CombinedOutput()\\n   130→\\tif err != nil {\\n   131→\\t\\t// Check if it's a non-fast-forward error (we can try to recover)\\n   132→\\t\\tif strings.Contains(string(output), \\\"non-fast-forward\\\") ||\\n   133→\\t\\t\\tstrings.Contains(string(output), \\\"rejected\\\") {\\n   134→\\t\\t\\treturn errors.New(\\\"non-fast-forward\\\")\\n   135→\\t\\t}\\n   136→\\t\\treturn fmt.Errorf(\\\"push failed: %s\\\", output)\\n   137→\\t}\\n   138→\\treturn nil\\n   139→}\\n   140→\\n   141→// fetchAndMergeSessionsCommon fetches remote sessions and merges into local using go-git.\\n   142→// Since session logs are append-only (unique cond-* directories), we just combine trees.\\n   143→// The target can be a remote name or a URL.\\n   144→func fetchAndMergeSessionsCommon(ctx context.Context, target, branchName string) error {\\n   145→\\tctx, cancel := context.WithTimeout(ctx, 2*time.Minute)\\n   146→\\tdefer cancel()\\n   147→\\n   148→\\t// Determine fetch refspec. When target is a URL, use a temp ref;\\n   149→\\t// when it's a remote name, use the standard remote-tracking ref.\\n   150→\\tvar fetchedRefName plumbing.ReferenceName\\n   151→\\tvar refSpec string\\n   152→\\tif isURL(target) {\\n   153→\\t\\ttmpRef := \\\"refs/entire-fetch-tmp/\\\" + branchName\\n   154→\\t\\trefSpec = fmt.Sprintf(\\\"+refs/heads/%s:%s\\\", branchName, tmpRef)\\n   155→\\t\\tfetchedRefName = plumbing.ReferenceName(tmpRef)\\n   156→\\t} else {\\n   157→\\t\\trefSpec = fmt.Sprintf(\\\"+refs/heads/%s:refs/remotes/%s/%s\\\", branchName, target, branchName)\\n   158→\\t\\tfetchedRefName = plumbing.NewRemoteReferenceName(target, branchName)\\n   159→\\t}\\n   160→\\n   161→\\t// Use git CLI for fetch (go-git's fetch can be tricky with auth)\\n   162→\\tfetchCmd := exec.CommandContext(ctx, \\\"git\\\", \\\"fetch\\\", target, refSpec)\\n   163→\\tfetchCmd.Stdin = nil\\n   164→\\tif output, err := fetchCmd.CombinedOutput(); err != nil {\\n   165→\\t\\treturn fmt.Errorf(\\\"fetch failed: %s\\\", output)\\n   166→\\t}\\n   167→\\n   168→\\trepo, err := OpenRepository(ctx)\\n   169→\\tif err != nil {\\n   170→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   171→\\t}\\n   172→\\n   173→\\t// Reconcile disconnected metadata branches before merging trees.\\n   174→\\t// The fetch above updated the remote-tracking ref, so reconciliation\\n   175→\\t// can compare fresh local vs remote. If disconnected (empty-orphan bug),\\n   176→\\t// this cherry-picks local commits onto remote tip, updating the local ref.