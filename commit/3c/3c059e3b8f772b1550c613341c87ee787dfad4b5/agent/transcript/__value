data, 0o644); err != nil {\\n   283→\\t\\tenv.T.Fatalf(\\\"failed to write %s: %v\\\", paths.SettingsFileName, err)\\n   284→\\t}\\n   285→}\\n   286→\\n   287→// WriteFile creates a file with the given content in the test repo.\\n   288→// It creates parent directories as needed.\\n   289→func (env *TestEnv) WriteFile(path, content string) {\\n   290→\\tenv.T.Helper()\\n   291→\\n   292→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   293→\\n   294→\\t// Create parent directories\\n   295→\\tdir := filepath.Dir(fullPath)\\n   296→\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   297→\\t\\tenv.T.Fatalf(\\\"failed to create directory %s: %v\\\", dir, err)\\n   298→\\t}\\n   299→\\n   300→\\tif err := os.WriteFile(fullPath, []byte(content), 0o644); err != nil {\\n   301→\\t\\tenv.T.Fatalf(\\\"failed to write file %s: %v\\\", path, err)\\n   302→\\t}\\n   303→}\\n   304→\\n   305→// ReadFile reads a file from the test repo.\\n   306→func (env *TestEnv) ReadFile(path string) string {\\n   307→\\tenv.T.Helper()\\n   308→\\n   309→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   310→\\tdata, err := os.ReadFile(fullPath)\\n   311→\\tif err != nil {\\n   312→\\t\\tenv.T.Fatalf(\\\"failed to read file %s: %v\\\", path, err)\\n   313→\\t}\\n   314→\\treturn string(data)\\n   315→}\\n   316→\\n   317→// ReadFileAbsolute reads a file using an absolute path.\\n   318→func (env *TestEnv) ReadFileAbsolute(path string) string {\\n   319→\\tenv.T.Helper()\\n   320→\\n   321→\\tdata, err := os.ReadFile(path)\\n   322→\\tif err != nil {\\n   323→\\t\\tenv.T.Fatalf(\\\"failed to read file %s: %v\\\", path, err)\\n   324→\\t}\\n   325→\\treturn string(data)\\n   326→}\\n   327→\\n   328→// FileExists checks if a file exists in the test repo.\\n   329→func (env *TestEnv) FileExists(path string) bool {\\n   330→\\tenv.T.Helper()\\n   331→\\n   332→\\tfullPath := filepath.Join(env.RepoDir, path)\\n   333→\\t_, err := os.Stat(fullPath)\\n   334→\\treturn err == nil\\n   335→}\\n   336→\\n   337→// GitAdd stages files for commit.\\n   338→func (env *TestEnv) GitAdd(paths ...string) {\\n   339→\\tenv.T.Helper()\\n   340→\\n   341→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   342→\\tif err != nil {\\n   343→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   344→\\t}\\n   345→\\n   346→\\tworktree, err := repo.Worktree()\\n   347→\\tif err != nil {\\n   348→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   349→\\t}\\n   350→\\n   351→\\tfor _, path := range paths {\\n   352→\\t\\tif _, err := worktree.Add(path); err != nil {\\n   353→\\t\\t\\tenv.T.Fatalf(\\\"failed to add file %s: %v\\\", path, err)\\n   354→\\t\\t}\\n   355→\\t}\\n   356→}\\n   357→\\n   358→// GitCommit creates a commit with all staged files.\\n   359→func (env *TestEnv) GitCommit(message string) {\\n   360→\\tenv.T.Helper()\\n   361→\\n   362→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   363→\\tif err != nil {\\n   364→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   365→\\t}\\n   366→\\n   367→\\tworktree, err := repo.Worktree()\\n   368→\\tif err != nil {\\n   369→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   370→\\t}\\n   371→\\n   372→\\t_, err = worktree.Commit(message, &git.CommitOptions{\\n   373→\\t\\tAuthor: &object.Signature{\\n   374→\\t\\t\\tName:  \\\"Test User\\\",\\n   375→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   376→\\t\\t\\tWhen:  time.Now(),\\n   377→\\t\\t},\\n   378→\\t})\\n   379→\\tif err != nil {\\n   380→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   381→\\t}\\n   382→}\\n   383→\\n   384→// GitCommitWithMetadata creates a commit with Entire-Metadata trailer.\\n   385→// This simulates commits created by the commit strategy.\\n   386→func (env *TestEnv) GitCommitWithMetadata(message, metadataDir string) {\\n   387→\\tenv.T.Helper()\\n   388→\\n   389→\\t// Format message with metadata trailer\\n   390→\\tfullMessage := message + \\\"\\\\n\\\\nEntire-Metadata: \\\" + metadataDir + \\\"\\\\n\\\"\\n   391→\\n   392→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   393→\\tif err != nil {\\n   394→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   395→\\t}\\n   396→\\n   397→\\tworktree, err := repo.Worktree()\\n   398→\\tif err != nil {\\n   399→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   400→\\t}\\n   401→\\n   402→\\t_, err = worktree.Commit(fullMessage, &git.CommitOptions{\\n   403→\\t\\tAuthor: &object.Signature{\\n   404→\\t\\t\\tName:  \\\"Test User\\\",\\n   405→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   406→\\t\\t\\tWhen:  time.Now(),\\n   407→\\t\\t},\\n   408→\\t})\\n   409→\\tif err != nil {\\n   410→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   411→\\t}\\n   412→}\\n   413→\\n   414→// GitCommitWithCheckpointID creates a commit with Entire-Checkpoint trailer.\\n   415→// This simulates commits.\\n   416→func (env *TestEnv) GitCommitWithCheckpointID(message, checkpointID string) {\\n   417→\\tenv.T.Helper()\\n   418→\\n   419→\\t// Format message with checkpoint trailer\\n   420→\\tfullMessage := message + \\\"\\\\n\\\\nEntire-Checkpoint: \\\" + checkpointID + \\\"\\\\n\\\"\\n   421→\\n   422→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   423→\\tif err != nil {\\n   424→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   425→\\t}\\n   426→\\n   427→\\tworktree, err := repo.Worktree()\\n   428→\\tif err != nil {\\n   429→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   430→\\t}\\n   431→\\n   432→\\t_, err = worktree.Commit(fullMessage, &git.CommitOptions{\\n   433→\\t\\tAuthor: &object.Signature{\\n   434→\\t\\t\\tName:  \\\"Test User\\\",\\n   435→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   436→\\t\\t\\tWhen:  time.Now(),\\n   437→\\t\\t},\\n   438→\\t})\\n   439→\\tif err != nil {\\n   440→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   441→\\t}\\n   442→}\\n   443→\\n   444→// GitCommitWithMultipleSessions creates a commit with multiple Entire-Session trailers.\\n   445→// This simulates merge commits that combine work from multiple sessions.\\n   446→func (env *TestEnv) GitCommitWithMultipleSessions(message string, sessionIDs []string) {\\n   447→\\tenv.T.Helper()\\n   448→\\n   449→\\t// Format message with multiple session trailers\\n   450→\\tfullMessage := message + \\\"\\\\n\\\\n\\\"\\n   451→\\tvar fullMessageSb404 strings.Builder\\n   452→\\tfor _, sessionID := range sessionIDs {\\n   453→\\t\\tfullMessageSb404.WriteString(\\\"Entire-Session: \\\" + sessionID + \\\"\\\\n\\\")\\n   454→\\t}\\n   455→\\tfullMessage += fullMessageSb404.String()\\n   456→\\n   457→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   458→\\tif err != nil {\\n   459→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   460→\\t}\\n   461→\\n   462→\\tworktree, err := repo.Worktree()\\n   463→\\tif err != nil {\\n   464→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   465→\\t}\\n   466→\\n   467→\\t_, err = worktree.Commit(fullMessage, &git.CommitOptions{\\n   468→\\t\\tAuthor: &object.Signature{\\n   469→\\t\\t\\tName:  \\\"Test User\\\",\\n   470→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   471→\\t\\t\\tWhen:  time.Now(),\\n   472→\\t\\t},\\n   473→\\t})\\n   474→\\tif err != nil {\\n   475→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   476→\\t}\\n   477→}\\n   478→\\n   479→// GitCommitWithMultipleCheckpoints creates a commit with multiple Entire-Checkpoint trailers.\\n   480→// This simulates a GitHub squash merge commit where multiple individual commits with\\n   481→// checkpoint trailers are combined into a single commit message.\\n   482→func (env *TestEnv) GitCommitWithMultipleCheckpoints(message string, checkpointIDs []string) {\\n   483→\\tenv.T.Helper()\\n   484→\\n   485→\\t// Format message with multiple checkpoint trailers (simulating squash merge format)\\n   486→\\tvar sb strings.Builder\\n   487→\\tsb.WriteString(message)\\n   488→\\tsb.WriteString(\\\"\\\\n\\\\n\\\")\\n   489→\\tfor _, cpID := range checkpointIDs {\\n   490→\\t\\tsb.WriteString(\\\"Entire-Checkpoint: \\\" + cpID + \\\"\\\\n\\\")\\n   491→\\t}\\n   492→\\n   493→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   494→\\tif err != nil {\\n   495→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   496→\\t}\\n   497→\\n   498→\\tworktree, err := repo.Worktree()\\n   499→\\tif err != nil {\\n   500→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   501→\\t}\\n   502→\\n   503→\\t_, err = worktree.Commit(sb.String(), &git.CommitOptions{\\n   504→\\t\\tAuthor: &object.Signature{\\n   505→\\t\\t\\tName:  \\\"Test User\\\",\\n   506→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   507→\\t\\t\\tWhen:  time.Now(),\\n   508→\\t\\t},\\n   509→\\t})\\n   510→\\tif err != nil {\\n   511→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n   512→\\t}\\n   513→}\\n   514→\\n   515→// GetHeadHash returns the current HEAD commit hash.\\n   516→func (env *TestEnv) GetHeadHash() string {\\n   517→\\tenv.T.Helper()\\n   518→\\n   519→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   520→\\tif err != nil {\\n   521→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   522→\\t}\\n   523→\\n   524→\\thead, err := repo.Head()\\n   525→\\tif err != nil {\\n   526→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   527→\\t}\\n   528→\\n   529→\\treturn head.Hash().String()\\n   530→}\\n   531→\\n   532→// GetShadowBranchName returns the worktree-specific shadow branch name for the current HEAD.\\n   533→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   534→func (env *TestEnv) GetShadowBranchName() string {\\n   535→\\tenv.T.Helper()\\n   536→\\n   537→\\theadHash := env.GetHeadHash()\\n   538→\\tworktreeID, err := paths.GetWorktreeID(env.RepoDir)\\n   539→\\tif err != nil {\\n   540→\\t\\tenv.T.Fatalf(\\\"failed to get worktree ID: %v\\\", err)\\n   541→\\t}\\n   542→\\treturn checkpoint.ShadowBranchNameForCommit(headHash, worktreeID)\\n   543→}\\n   544→\\n   545→// GetShadowBranchNameForCommit returns the worktree-specific shadow branch name for a given commit.\\n   546→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   547→func (env *TestEnv) GetShadowBranchNameForCommit(commitHash string) string {\\n   548→\\tenv.T.Helper()\\n   549→\\n   550→\\tworktreeID, err := paths.GetWorktreeID(env.RepoDir)\\n   551→\\tif err != nil {\\n   552→\\t\\tenv.T.Fatalf(\\\"failed to get worktree ID: %v\\\", err)\\n   553→\\t}\\n   554→\\treturn checkpoint.ShadowBranchNameForCommit(commitHash, worktreeID)\\n   555→}\\n   556→\\n   557→// GetGitLog returns a list of commit hashes from HEAD.\\n   558→func (env *TestEnv) GetGitLog() []string {\\n   559→\\tenv.T.Helper()\\n   560→\\n   561→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   562→\\tif err != nil {\\n   563→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   564→\\t}\\n   565→\\n   566→\\thead, err := repo.Head()\\n   567→\\tif err != nil {\\n   568→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   569→\\t}\\n   570→\\n   571→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   572→\\tif err != nil {\\n   573→\\t\\tenv.T.Fatalf(\\\"failed to get log: %v\\\", err)\\n   574→\\t}\\n   575→\\n   576→\\tvar commits []string\\n   577→\\terr = commitIter.ForEach(func(c *object.Commit) error {\\n   578→\\t\\tcommits = append(commits, c.Hash.String())\\n   579→\\t\\treturn nil\\n   580→\\t})\\n   581→\\tif err != nil {\\n   582→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   583→\\t}\\n   584→\\n   585→\\treturn commits\\n   586→}\\n   587→\\n   588→// GitCheckoutNewBranch creates and checks out a new branch.\\n   589→// Uses git CLI instead of go-git to work around go-git v5 bug where Checkout\\n   590→// deletes untracked files (see https://github.com/go-git/go-git/issues/970).\\n   591→func (env *TestEnv) GitCheckoutNewBranch(branchName string) {\\n   592→\\tenv.