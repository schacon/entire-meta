riteString(entry)\\n   242→\\tb.WriteByte('\\\\n')\\n   243→\\n   244→\\tif err := os.MkdirAll(filepath.Dir(excludePath), 0o755); err != nil {\\n   245→\\t\\treturn fmt.Errorf(\\\"create %s: %w\\\", filepath.Dir(excludePath), err)\\n   246→\\t}\\n   247→\\tif err := os.WriteFile(excludePath, []byte(b.String()), 0o644); err != nil {\\n   248→\\t\\treturn fmt.Errorf(\\\"write %s: %w\\\", excludePath, err)\\n   249→\\t}\\n   250→\\treturn nil\\n   251→}\\n   252→\\n   253→// ForEachAgent runs fn as a parallel subtest for every registered agent.\\n   254→// It handles repo setup, concurrency gating, context timeout, and cleanup.\\n   255→// The timeout is scaled by each agent's TimeoutMultiplier.\\n   256→//\\n   257→// If RunPrompt detects a transient API error (e.g. rate limit, token refresh\\n   258→// failure), it panics with errScenarioRestart. ForEachAgent recovers from the\\n   259→// panic and restarts the entire scenario with a fresh repository, up to\\n   260→// maxScenarioRestarts times. This avoids stale CLI session state from the\\n   261→// failed attempt poisoning the retry.\\n   262→func ForEachAgent(t *testing.T, timeout time.Duration, fn func(t *testing.T, s *RepoState, ctx context.Context)) {\\n   263→\\tt.Helper()\\n   264→\\tt.Parallel()\\n   265→\\tall := agents.All()\\n   266→\\tif len(all) == 0 {\\n   267→\\t\\tt.Skip(\\\"no agents registered (check E2E_AGENT filter)\\\")\\n   268→\\t}\\n   269→\\tfor _, agent := range all {\\n   270→\\t\\tt.Run(agent.Name(), func(t *testing.T) {\\n   271→\\t\\t\\t// Use the global test deadline for slot wait so we don't\\n   272→\\t\\t\\t// skip prematurely — only bail if the whole binary is dying.\\n   273→\\t\\t\\tslotCtx := context.Background()\\n   274→\\t\\t\\tif deadline, ok := t.Deadline(); ok {\\n   275→\\t\\t\\t\\tvar cancel context.CancelFunc\\n   276→\\t\\t\\t\\tslotCtx, cancel = context.WithDeadline(slotCtx, deadline)\\n   277→\\t\\t\\t\\tdefer cancel()\\n   278→\\t\\t\\t}\\n   279→\\t\\t\\tif err := agents.AcquireSlot(slotCtx, agent); err != nil {\\n   280→\\t\\t\\t\\tt.Fatalf(\\\"timed out waiting for agent slot: %v\\\", err)\\n   281→\\t\\t\\t}\\n   282→\\t\\t\\tdefer agents.ReleaseSlot(agent)\\n   283→\\n   284→\\t\\t\\t// Per-test timeout starts after slot is acquired, scaled\\n   285→\\t\\t\\t// by the agent's multiplier (e.g. 2.5× for gemini).\\n   286→\\t\\t\\tscaled := time.Duration(float64(timeout) * agent.TimeoutMultiplier())\\n   287→\\n   288→\\t\\t\\tvar prevState *RepoState\\n   289→\\t\\t\\tfor attempt := range maxScenarioRestarts + 1 {\\n   290→\\t\\t\\t\\ts := SetupRepo(t, agent)\\n   291→\\t\\t\\t\\tctx, cancel := context.WithTimeout(context.Background(), scaled)\\n   292→\\n   293→\\t\\t\\t\\t// On restart, suppress artifact capture from the previous\\n   294→\\t\\t\\t\\t// failed attempt so it doesn't overwrite the final one.\\n   295→\\t\\t\\t\\tif prevState != nil {\\n   296→\\t\\t\\t\\t\\tprevState.skipArtifacts = true\\n   297→\\t\\t\\t\\t}\\n   298→\\n   299→\\t\\t\\t\\trestarted := runScenario(t, s, ctx, fn)\\n   300→\\t\\t\\t\\tcancel()\\n   301→\\n   302→\\t\\t\\t\\tif !restarted {\\n   303→\\t\\t\\t\\t\\treturn\\n   304→\\t\\t\\t\\t}\\n   305→\\t\\t\\t\\tprevState = s\\n   306→\\t\\t\\t\\tif attempt >= maxScenarioRestarts {\\n   307→\\t\\t\\t\\t\\tt.Fatalf(\\\"exhausted %d scenario attempts due to transient API errors\\\", maxScenarioRestarts+1)\\n   308→\\t\\t\\t\\t}\\n   309→\\t\\t\\t\\tt.Logf(\\\"transient error, restarting scenario (attempt %d/%d)\\\", attempt+2, maxScenarioRestarts+1)\\n   310→\\t\\t\\t}\\n   311→\\t\\t})\\n   312→\\t}\\n   313→}\\n   314→\\n   315→// runScenario runs the test function and recovers from errScenarioRestart\\n   316→// panics triggered by transient API errors in RunPrompt. Returns true if\\n   317→// the scenario should be restarted with a fresh repository.\\n   318→func runScenario(t *testing.T, s *RepoState, ctx context.Context, fn func(t *testing.T, s *RepoState, ctx context.Context)) (restarted bool) {\\n   319→\\tt.Helper()\\n   320→\\tdefer func() {\\n   321→\\t\\tif r := recover(); r != nil {\\n   322→\\t\\t\\tif _, ok := r.(errScenarioRestart); ok {\\n   323→\\t\\t\\t\\trestarted = true\\n   324→\\t\\t\\t\\treturn\\n   325→\\t\\t\\t}\\n   326→\\t\\t\\tpanic(r) // re-panic for unexpected panics\\n   327→\\t\\t}\\n   328→\\t}()\\n   329→\\tfn(t, s, ctx)\\n   330→\\treturn false\\n   331→}\\n   332→\\n   333→const maxScenarioRestarts = 2 // restart up to 2 times = 3 total attempts\\n   334→\\n   335→// errScenarioRestart is panicked by RunPrompt when a transient API error is\\n   336→// detected. ForEachAgent recovers from this panic and restarts the test\\n   337→// scenario with a fresh repository, avoiding stale CLI state from the failed\\n   338→// attempt.\\n   339→type errScenarioRestart struct {\\n   340→\\tmsg string\\n   341→}\\n   342→\\n   343→// RunPrompt runs an agent prompt, logs the command and output to ConsoleLog,\\n   344→// and returns the result. If the agent reports a transient API error, it\\n   345→// panics with errScenarioRestart to trigger a full scenario restart in\\n   346→// ForEachAgent (see runScenario).\\n   347→func (s *RepoState) RunPrompt(t *testing.T, ctx context.Context, prompt string, opts ...agents.Option) (agents.Output, error) {\\n   348→\\tt.Helper()\\n   349→\\tout, err := s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n   350→\\ts.logPromptResult(out)\\n   351→\\n   352→\\tif err != nil && s.Agent.IsTransientError(out, err) {\\n   353→\\t\\terrMsg := fmt.Sprintf(\\\"transient API error (stderr: %s)\\\", strings.TrimSpace(out.Stderr))\\n   354→\\t\\tt.Logf(\\\"%s — restarting scenario\\\", errMsg)\\n   355→\\t\\tfmt.Fprintf(s.ConsoleLog, \\\"> [transient] %s — restarting scenario\\\\n\\\", errMsg)\\n   356→\\t\\tpanic(errScenarioRestart{msg: errMsg})\\n   357→\\t}\\n   358→\\n   359→\\treturn out, err\\n   360→}\\n   361→\\n   362→func (s *RepoState) logPromptResult(out agents.Output) {\\n   363→\\ts.ConsoleLog.WriteString(\\\"> \\\" + out.Command + \\\"\\\\n\\\")\\n   364→\\ts.ConsoleLog.WriteString(\\\"stdout:\\\\n\\\" + out.Stdout + \\\"\\\\n\\\")\\n   365→\\ts.ConsoleLog.WriteString(\\\"stderr:\\\\n\\\" + out.Stderr + \\\"\\\\n\\\")\\n   366→}\\n   367→\\n   368→// Git runs a git command in the repo and logs it to ConsoleLog.\\n   369→func (s *RepoState) Git(t *testing.T, args ...string) {\\n   370→\\tt.Helper()\\n   371→\\ts.ConsoleLog.WriteString(\\\"> git \\\" + strings.Join(args, \\\" \\\") + \\\"\\\\n\\\")\\n   372→\\tGit(t, s.Dir, args...)\\n   373→}\\n   374→\\n   375→// StartSession starts an interactive session and registers it for pane\\n   376→// capture in artifacts. Returns nil if the agent does not support interactive\\n   377→// mode. The session is closed automatically during test cleanup.\\n   378→func (s *RepoState) StartSession(t *testing.T, ctx context.Context) agents.Session {\\n   379→\\tt.Helper()\\n   380→\\tsession, err := s.Agent.StartSession(ctx, s.Dir)\\n   381→\\tif err != nil {\\n   382→\\t\\tt.Fatalf(\\\"start session: %v\\\", err)\\n   383→\\t}\\n   384→\\tif session == nil {\\n   385→\\t\\treturn nil\\n   386→\\t}\\n   387→\\ts.session = session\\n   388→\\treturn session\\n   389→}\\n   390→\\n   391→// WaitFor waits for a pattern in the interactive session's pane and logs the\\n   392→// pane content to ConsoleLog after the wait completes (success or failure).\\n   393→func (s *RepoState) WaitFor(t *testing.T, session agents.Session, pattern string, timeout time.Duration) {\\n   394→\\tt.Helper()\\n   395→\\tcontent, err := session.WaitFor(pattern, timeout)\\n   396→\\tfmt.Fprintf(s.ConsoleLog, \\\"> pane after WaitFor(%q):\\\\n%s\\\\n\\\", pattern, content)\\n   397→\\tif err != nil {\\n   398→\\t\\tt.Fatalf(\\\"WaitFor(%q): %v\\\", pattern, err)\\n   399→\\t}\\n   400→}\\n   401→\\n   402→// Send sends input to an interactive session and logs it to ConsoleLog.\\n   403→// Fails the test on error.\\n   404→func (s *RepoState) Send(t *testing.T, session agents.Session, input string) {\\n   405→\\tt.Helper()\\n   406→\\ts.ConsoleLog.WriteString(\\\"> send: \\\" + input + \\\"\\\\n\\\")\\n   407→\\tif err := session.Send(input); err != nil {\\n   408→\\t\\tt.Fatalf(\\\"send failed: %v\\\", err)\\n   409→\\t}\\n   410→}\\n   411→\\n   412→// PatchSettings merges extra keys into .entire/settings.json.\\n   413→func PatchSettings(t *testing.T, dir string, extra map[string]any) {\\n   414→\\tt.Helper()\\n   415→\\tpath := filepath.Join(dir, \\\".entire\\\", \\\"settings.json\\\")\\n   416→\\tdata, err := os.ReadFile(path)\\n   417→\\tif err != nil {\\n   418→\\t\\tt.Fatalf(\\\"read settings: %v\\\", err)\\n   419→\\t}\\n   420→\\tvar settings map[string]any\\n   421→\\tif err := json.Unmarshal(data, &settings); err != nil {\\n   422→\\t\\tt.Fatalf(\\\"parse settings: %v\\\", err)\\n   423→\\t}\\n   424→\\tfor k, v := range extra {\\n   425→\\t\\tsettings[k] = v\\n   426→\\t}\\n   427→\\tout, err := json.MarshalIndent(settings, \\\"\\\", \\\"  \\\")\\n   428→\\tif err != nil {\\n   429→\\t\\tt.Fatalf(\\\"marshal settings: %v\\\", err)\\n   430→\\t}\\n   431→\\tif err := os.WriteFile(path, out, 0o644); err != nil {\\n   432→\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n   433→\\t}\\n   434→}\\n   435→\\n   436→// Git runs a git command in the given directory and fails the test if it\\n   437→// returns a non-zero exit code.\\n   438→func Git(t *testing.T, dir string, args ...string) {\\n   439→\\tt.Helper()\\n   440→\\n   441→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   442→\\tif dir != \\\"\\\" {\\n   443→\\t\\tcmd.Dir = dir\\n   444→\\t}\\n   445→\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   446→\\n   447→\\tout, err := cmd.CombinedOutput()\\n   448→\\tif err != nil {\\n   449→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n   450→\\t}\\n   451→}\\n   452→\\n   453→// GitOutput runs a git command in the given directory, returns its trimmed\\n   454→// stdout, and fails the test on error.\\n   455→func GitOutput(t *testing.T, dir string, args ...string) string {\\n   456→\\tt.Helper()\\n   457→\\n   458→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   459→\\tif dir != \\\"\\\" {\\n   460→\\t\\tcmd.Dir = dir\\n   461→\\t}\\n   462→\\n   463→\\tout, err := cmd.Output()\\n   464→\\tif err != nil {\\n   465→\\t\\tvar stderr string\\n   466→\\t\\tee := &exec.ExitError{}\\n   467→\\t\\tif errors.As(err, &ee) {\\n   468→\\t\\t\\tstderr = string(ee.Stderr)\\n   469→\\t\\t}\\n   470→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, stderr)\\n   471→\\t}\\n   472→\\n   473→\\treturn strings.TrimSpace(string(out))\\n   474→}\\n   475→\\n   476→// NewCheckpointCommits returns the SHAs of commits added to the\\n   477→// entire/checkpoints/v1 branch since the test was set up, oldest first.\\n   478→func NewCheckpointCommits(t *testing.T, s *RepoState) []string {\\n   479→\\tt.Helper()\\n   480→\\n   481→\\tlog := GitOutput(t, s.Dir, \\\"log\\\", \\\"--reverse\\\", \\\"--format=%H\\\", s.CheckpointBefore+\\\"..entire/checkpoints/v1\\\")\\n   482→\\tif log == \\\"\\\" {\\n   483→\\t\\treturn nil\\n   484→\\t}\\n   485→\\treturn strings.Split(log, \\\"\\\\n\\\")\\n   486→}\\n   487→\\n   488→// CheckpointIDs lists all checkpoint IDs from the tree at the tip of the\\n   489→// checkpoint branch. It parses the two-level directory structure\\n   490→// ({prefix}/{suffix}/metadata.json) and returns the concatenated IDs.\\n   491→func CheckpointIDs(t *testing.T, dir string) []string {\\n   492→\\tt.Helper()\\n   493→\\tout := gitOutputSafe(dir, \\\"ls-tree\\\", \\\"-r\\\", \\\"--name-only\\\", \\\"entire/checkpoints/v1\\\")\\n   494→\\tif out == \\\"\\\" {\\n   495→\\t\\treturn nil\\n   496→\\t}\\n   497→\\tseen := map[string]bool{}\\n   498→\\tvar ids []string\\n   499→\\tfor _, line := range strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\") {\\n   500→\\t\\t// Match {prefix}/{suffix}/metadata.json (top-level, not session-level)\\n   501→\\t\\tparts := strings.Split(line, \\\"/\\\")\\n   502→\\t\\tif len(parts) == 3 && parts[2] == \\\"metadata.json\\\" {\\n   503→\\t\\t\\tid := parts[0] + parts[1]\\n   504→\\t\\t\\tif !seen[id] {\\n   505→\\t\\t\\t\\tseen[id] = true\\n   506→\\t\\t\\t\\tids = append(ids, id)\\n   507→\\t\\t\\t}\\n   508→\\t\\t}\\n   509→\\t}\\n   510→\\treturn ids\\n   511→}\\n   512→\\n   513→// ReadCheckpointMetadata reads the checkpoint-level metadata.json from the\\n   514→// tip of the checkpoint branch for the given checkpoint ID.\\n   515→func ReadCheckpointMetadata(t *testing.T, dir string, checkpointID string) CheckpointMetadata {\\n   516→\\tt.Helper()\\n   517→\\n   518→\\tpath := CheckpointPath(checkpointID) + \\\"/metadata.json\\\"\\n   519→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   520→\\n   521→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   522→\\n   523→\\tvar meta CheckpointMetadata\\n   524→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   525→\\t\\tt.Fatalf(\\\"unmarshal checkpoint metadata from %s: %v\\\", blob, err)\\n   526→\\t}\\n   527→\\n   528→\\treturn meta\\n   529→}\\n   530→\\n   531→// ReadSessionMetadata reads a session's metadata.json from the tip of the\\n   532→// checkpoint branch for the given checkpoint ID and session index.\\n   533→func ReadSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int) SessionMetadata {\\n   534→\\tt.Helper()\\n   535→\\n   536→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   537→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   538→\\n   539→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   540→\\n   541→\\tvar meta SessionMetadata\\n   542→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   543→\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   544→\\t}\\n   545→\\n   546→\\treturn meta\