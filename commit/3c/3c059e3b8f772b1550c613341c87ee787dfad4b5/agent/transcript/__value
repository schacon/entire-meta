ring condensation on certain branches.\\n    76→// This test verifies the push mechanism works when the branch is present.\\n    77→func TestPrePush_PushesTrailsBranchWhenItExists(t *testing.T) {\\n    78→\\tt.Parallel()\\n    79→\\tenv := NewFeatureBranchEnv(t)\\n    80→\\n    81→\\tbareDir := env.SetupBareRemote()\\n    82→\\n    83→\\t// Create a session, checkpoint, and commit\\n    84→\\tsession := env.NewSession()\\n    85→\\ttranscriptPath := session.CreateTranscript(\\\"Add feature\\\", []FileChange{\\n    86→\\t\\t{Path: \\\"feature.go\\\", Content: \\\"package feature\\\"},\\n    87→\\t})\\n    88→\\n    89→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Add feature\\\", transcriptPath); err != nil {\\n    90→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n    91→\\t}\\n    92→\\n    93→\\tenv.WriteFile(\\\"feature.go\\\", \\\"package feature\\\")\\n    94→\\tenv.GitAdd(\\\"feature.go\\\")\\n    95→\\n    96→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n    97→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n    98→\\t}\\n    99→\\n   100→\\tenv.GitCommitWithShadowHooks(\\\"Add feature\\\", \\\"feature.go\\\")\\n   101→\\n   102→\\t// Run PrePush\\n   103→\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n   104→\\t\\tt.Fatalf(\\\"PrePush failed: %v\\\", err)\\n   105→\\t}\\n   106→\\n   107→\\t// Checkpoint branch must be on remote\\n   108→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   109→\\t\\tt.Error(\\\"entire/checkpoints/v1 should exist on remote\\\")\\n   110→\\t}\\n   111→\\n   112→\\t// Trails branch: only check if it exists locally (may or may not be created)\\n   113→\\tif env.BranchExists(paths.TrailsBranchName) {\\n   114→\\t\\tif !env.BranchExistsOnRemote(bareDir, paths.TrailsBranchName) {\\n   115→\\t\\t\\tt.Error(\\\"entire/trails/v1 should be on remote when it exists locally\\\")\\n   116→\\t\\t}\\n   117→\\t} else {\\n   118→\\t\\tt.Log(\\\"trails branch not created locally (expected for some configurations)\\\")\\n   119→\\t}\\n   120→}\\n   121→\\n   122→// TestPrePush_NoOpWhenNoCheckpoints verifies that PrePush is a no-op\\n   123→// when no sessions or checkpoints exist.\\n   124→func TestPrePush_NoOpWhenNoCheckpoints(t *testing.T) {\\n   125→\\tt.Parallel()\\n   126→\\tenv := NewFeatureBranchEnv(t)\\n   127→\\n   128→\\tbareDir := env.SetupBareRemote()\\n   129→\\n   130→\\t// Run PrePush without any session activity\\n   131→\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n   132→\\t\\tt.Fatalf(\\\"PrePush should not fail when no checkpoints exist: %v\\\", err)\\n   133→\\t}\\n   134→\\n   135→\\t// No checkpoint branches should exist on remote\\n   136→\\tif env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   137→\\t\\tt.Error(\\\"entire/checkpoints/v1 should NOT exist on remote when no checkpoints were created\\\")\\n   138→\\t}\\n   139→}\\n   140→\\n   141→// TestPrePush_IdempotentWhenAlreadyPushed verifies that pushing twice\\n   142→// with no new checkpoints is a no-op (idempotent).\\n   143→func TestPrePush_IdempotentWhenAlreadyPushed(t *testing.T) {\\n   144→\\tt.Parallel()\\n   145→\\tenv := NewFeatureBranchEnv(t)\\n   146→\\n   147→\\tbareDir := env.SetupBareRemote()\\n   148→\\n   149→\\t// Create session, commit, push\\n   150→\\tsession := env.NewSession()\\n   151→\\ttranscriptPath := session.CreateTranscript(\\\"Initial work\\\", []FileChange{\\n   152→\\t\\t{Path: \\\"main.go\\\", Content: \\\"package main\\\"},\\n   153→\\t})\\n   154→\\n   155→\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Initial work\\\", transcriptPath); err != nil {\\n   156→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   157→\\t}\\n   158→\\n   159→\\tenv.WriteFile(\\\"main.go\\\", \\\"package main\\\")\\n   160→\\tenv.GitAdd(\\\"main.go\\\")\\n   161→\\n   162→\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n   163→\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n   164→\\t}\\n   165→\\n   166→\\tenv.GitCommitWithShadowHooks(\\\"Initial work\\\", \\\"main.go\\\")\\n   167→\\n   168→\\t// First push\\n   169→\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n   170→\\t\\tt.Fatalf(\\\"first PrePush failed: %v\\\", err)\\n   171→\\t}\\n   172→\\n   173→\\tif !env.BranchExistsOnRemote(bareDir, paths.MetadataBranchName) {\\n   174→\\t\\tt.Fatal(\\\"checkpoint branch should exist after first push\\\")\\n   175→\\t}\\n   176→\\n   177→\\t// Get remote ref before second push\\n   178→\\trefBefore := getRemoteBranchHash(t, bareDir, paths.MetadataBranchName)\\n   179→\\n   180→\\t// Second push (no new checkpoints)\\n   181→\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n   182→\\t\\tt.Fatalf(\\\"second PrePush should succeed: %v\\\", err)\\n   183→\\t}\\n   184→\\n   185→\\t// Remote ref should be unchanged\\n   186→\\trefAfter := getRemoteBranchHash(t, bareDir, paths.MetadataBranchName)\\n   187→\\tif refBefore != refAfter {\\n   188→\\t\\tt.Errorf(\\\"remote ref should be unchanged after idempotent push: before=%s, after=%s\\\", refBefore, refAfter)\\n   189→\\t}\\n   190→}\\n   191→\\n   192→// =============================================================================\\n   193→// P0 — Checkpoint Remote Config\\n   194→// =============================================================================\\n   195→\\n   196→// TestPrePush_PushDisabledSkipsCheckpoints verifies that push_sessions: false\\n   197→// disables checkpoint push while trails are still pushed if they exist.\\n   198→func TestPrePush_PushDisabledSkipsCheckpoints(t *testing.T) {\\n   199→\\tt.Parallel()\\n   200→\\tenv := NewFeatureBranchEnv(t)\\n   201→\\n   202→\\tbareDir := env.SetupBareRemote()\\n   203→\\n   204→\\t// Configure push_sessions: false\\n   205→\\tenv.Patch