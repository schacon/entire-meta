ses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    68→func (s *ManualCommitStrategy) getCheckpointLog(ctx context.Context, checkpointID id.CheckpointID) ([]byte, error) {\\n    69→\\tstore, err := s.getCheckpointStore()\\n    70→\\tif err != nil {\\n    71→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    72→\\t}\\n    73→\\n    74→\\tcontent, err := store.ReadLatestSessionContent(ctx, checkpointID)\\n    75→\\tif err != nil {\\n    76→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    77→\\t}\\n    78→\\tif content == nil {\\n    79→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n    80→\\t}\\n    81→\\tif len(content.Transcript) == 0 {\\n    82→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n    83→\\t}\\n    84→\\n    85→\\treturn content.Transcript, nil\\n    86→}\\n    87→\\n    88→// condenseOpts provides pre-resolved git objects to avoid redundant reads.\\n    89→type condenseOpts struct {\\n    90→\\tshadowRef      *plumbing.Reference // Pre-resolved shadow branch ref (nil = resolve from repo)\\n    91→\\theadTree       *object.Tree        // Pre-resolved HEAD tree (passed through to calculateSessionAttributions)\\n    92→\\trepoDir        string              // Repository worktree path for git CLI commands\\n    93→\\theadCommitHash string              // HEAD commit hash (passed through for attribution)\\n    94→}\\n    95→\\n    96→// CondenseSession condenses a session's shadow branch to permanent storage.\\n    97→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n    98→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n    99→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   100→//\\n   101→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   102→// In this case, data is extracted from the live transcript instead.\\n   103→func (s *ManualCommitStrategy) CondenseSession(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}, opts ...condenseOpts) (*CondenseResult, error) {\\n   104→\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   105→\\tvar o condenseOpts\\n   106→\\tif len(opts) > 0 {\\n   107→\\t\\to = opts[0]\\n   108→\\t}\\n   109→\\n   110→\\t// Get shadow branch — use pre-resolved ref if available, otherwise resolve from repo.\\n   111→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   112→\\tref := o.shadowRef\\n   113→\\tvar hasShadowBranch bool\\n   114→\\tif ref != nil {\\n   115→\\t\\thasShadowBranch = true\\n   116→\\t} else {\\n   117→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   118→\\t\\tvar err error\\n   119→\\t\\tref, err = repo.Reference(refName, true)\\n   120→\\t\\thasShadowBranch = err == nil\\n   121→\\t}\\n   122→\\n   123→\\tvar sessionData *ExtractedSessionData\\n   124→\\tif hasShadowBranch {\\n   125→\\t\\tvar extractErr error\\n   126→\\t\\tsessionData, extractErr = s.extractSessionData(ctx, repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n   127→\\t\\tif extractErr != nil {\\n   128→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", extractErr)\\n   129→\\t\\t}\\n   130→\\t} else {\\n   131→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   132→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   133→\\t\\t}\\n   134→\\t\\tif state.Phase.IsActive() {\\n   135→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, state.TranscriptPath)\\n   136→\\t\\t}\\n   137→\\t\\tvar extractErr error\\n   138→\\t\\tsessionData, extractErr = s.extractSessionDataFromLiveTranscript(ctx, state)\\n   139→\\t\\tif extractErr != nil {\\n   140→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", extractErr)\\n   141→\\t\\t}\\n   142→\\t}\\n   143→\\n   144→\\t// Backfill session state token usage from the freshly-extracted transcript.\\n   145→\\t// Some agents (e.g., Copilot CLI) write aggregate token data (session.shutdown)\\n   146→\\t// AFTER all hooks return, so state.TokenUsage from turn-end only has fallback data.\\n   147→\\t// By condensation time, the transcript has the authoritative totals.\\n   148→\\t// Only replace when we got authoritative data (e.g., session.shutdown provides\\n   149→\\t// InputTokens; the fallback path only captures OutputTokens). This avoids\\n   150→\\t// overwriting accumulated multi-checkpoint totals with partial checkpoint data.\\n   151→\\tif sessionData.TokenUsage != nil && sessionData.TokenUsage.InputTokens > 0 {\\n   152→\\t\\tstate.TokenUsage = sessionData.TokenUsage\\n   153→\\t}\\n   154→\\n   155→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   156→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   157→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   158→\\tif len(committedFiles) > 0 {\\n   159→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   160→\\n   161→\\t\\tif hadFilesBeforeFiltering {\\n   162→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   163→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   164→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   165→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   166→\\t\\t\\t\\t}\\n   167→\\t\\t\\t}\\n   168→\\t\\t\\tsessionData.FilesTouched = filtered\\n   169→\\t\\t}\\n   170→\\n   171→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   172→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   173→\\t\\t\\tfor f := range committedFiles {\\n   174→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   175→\\t\\t\\t}\\n   176→\\t\\t}\\n   177→\\t}\\n   178→\\n   179→\\t// Get checkpoint store\\n   180→\\tstore, err := s.getCheckpointStore()\\n   181→\\tif err != nil {\\n   182→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   183→\\t}\\n   184→\\n   185→\\t// Get author info\\n   186→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   187→\\n   188→\\t// Determine attribution base commit\\n   189→\\tattrBase := state.AttributionBaseCommit\\n   190→\\tif attrBase == \\\"\\\" {\\n   191→\\t\\tattrBase = state.BaseCommit\\n   192→\\t}\\n   193→\\n   194→\\tattribution := calculateSessionAttributions(ctx, repo, ref, sessionData, state, attributionOpts{\\n   195→\\t\\theadTree:              o.headTree,\\n   196→\\t\\trepoDir:               o.repoDir,\\n   197→\\t\\tattributionBaseCommit: attrBase,\\n   198→\\t\\theadCommitHash:        o.headCommitHash,\\n   199→\\t})\\n   200→\\n   201→\\t// Get current branch name\\n   202→\\tbranchName := GetCurrentBranchName(repo)\\n   203→\\n   204→\\t// Generate summary if enabled\\n   205→\\tvar summary *cpkg.Summary\\n   206→\\tif settings.IsSummarizeEnabled(ctx) && len(sessionData.Transcript) > 0 {\\n   207→\\t\\tsummarizeCtx := logging.WithComponent(ctx, \\\"summarize\\\")\\n   208→\\n   209→\\t\\tvar scopedTranscript []byte\\n   210→\\t\\tswitch state.AgentType {\\n   211→\\t\\tcase agent.AgentTypeGemini:\\n   212→\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   213→\\t\\t\\tif sliceErr != nil {\\n   214→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n   215→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   216→\\t\\t\\t\\t\\ts