Path); err != nil {\\n\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n\\t}\\n\\n\\tenv.GitCommitWithShadowHooks(\\\"Write auth tests\\\", \\\"auth_test.go\\\")\\n\\n\\t// Push\\n\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n\\t\\tt.Fatalf(\\\"PrePush failed: %v\\\", err)\\n\\t}\\n\\n\\tcheckpointID := env.GetLatestCheckpointID()\\n\\n\\t// Clone and fetch metadata\\n\\tcloneEnv := env.CloneFrom(bareDir)\\n\\tfetchMetadataBranch(t, cloneEnv.RepoDir, bareDir)\\n\\n\\t// Read transcript from the clone\\n\\ttranscriptFilePath := SessionFilePath(checkpointID, paths.TranscriptFileName)\\n\\tcontent, found := cloneEnv.ReadFileFromBranch(paths.MetadataBranchName, transcriptFilePath)\\n\\tif !found {\\n\\t\\tt.Fatalf(\\\"transcript should be readable from clone at %s\\\", transcriptFilePath)\\n\\t}\\n\\n\\tif content == \\\"\\\" {\\n\\t\\tt.Error(\\\"transcript content should not be empty\\\")\\n\\t}\\n\\n\\t// Verify it contains our expected content\\n\\tif !containsString(content, \\\"Write tests for auth\\\") {\\n\\t\\tt.Error(\\\"transcript should contain the user prompt from the original session\\\")\\n\\t}\\n}\\n\\n// TestCloneAndResume_NewSessionPushAppends verifies that after cloning,\\n// creating a new session, and pushing, the remote has BOTH original and\\n// new checkpoint data.\\nfunc TestCloneAndResume_NewSessionPushAppends(t *testing.T) {\\n\\tt.Parallel()\\n\\tenv := NewFeatureBranchEnv(t)\\n\\n\\tbareDir := env.SetupBareRemote()\\n\\n\\t// Repo A: session + commit + push\\n\\tsessionA := env.NewSession()\\n\\ttranscriptA := sessionA.CreateTranscript(\\\"Add models\\\", []FileChange{\\n\\t\\t{Path: \\\"models.go\\\", Content: \\\"package models\\\"},\\n\\t})\\n\\n\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(sessionA.ID, \\\"Add models\\\", transcriptA); err != nil {\\n\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n\\t}\\n\\n\\tenv.WriteFile(\\\"models.go\\\", \\\"package models\\\")\\n\\tenv.GitAdd(\\\"models.go\\\")\\n\\n\\tif err := env.SimulateStop(sessionA.ID, transcriptA); err != nil {\\n\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n\\t}\\n\\n\\tenv.GitCommitWithShadowHooks(\\\"Add models\\\", \\\"models.go\\\")\\n\\tenv.GitPush(\\\"origin\\\", \\\"HEAD\\\")\\n\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n\\t\\tt.Fatalf(\\\"PrePush from repo A failed: %v\\\", err)\\n\\t}\\n\\n\\toriginalCheckpointID := env.GetLatestCheckpointID()\\n\\tt.Logf(\\\"Original checkpoint: %s\\\", originalCheckpointID)\\n\\n\\t// Clone into repo B\\n\\tcloneEnv := env.CloneFrom(bareDir)\\n\\tfetchMetadataBranch(t, cloneEnv.RepoDir, bareDir)\\n\\n\\t// Repo B: create NEW session + commit + push\\n\\tcloneEnv.GitCheckoutNewBranch(\\\"feature/clone-work\\\")\\n\\tsessionB := cloneEnv.NewSession()\\n\\ttranscriptB := sessionB.CreateTranscript(\\\"Add handlers\\\", []FileChange{\\n\\t\\t{Path: \\\"handlers.go\\\", Content: \\\"package handlers\\\"},\\n\\t})\\n\\n\\tif err := cloneEnv.SimulateUserPromptSubmitWithPromptAndTranscriptPath(sessionB.ID, \\\"Add handlers\\\", transcriptB); err != nil {\\n\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit in clone failed: %v\\\", err)\\n\\t}\\n\\n\\tcloneEnv.WriteFile(\\\"handlers.go\\\", \\\"package handlers\\\")\\n\\tcloneEnv.GitAdd(\\\"handlers.go\\\")\\n\\n\\tif err := cloneEnv.SimulateStop(sessionB.ID, transcriptB); err != nil {\\n\\t\\tt.Fatalf(\\\"SimulateStop in clone failed: %v\\\", err)\\n\\t}\\n\\n\\tcloneEnv.GitCommitWithShadowHooks(\\\"Add handlers\\\", \\\"handlers.go\\\")\\n\\n\\t// Push from clone\\n\\tif err := runPrePushInDir(t, cloneEnv.RepoDir, \\\"origin\\\"); err != nil {\\n\\t\\tt.Fatalf(\\\"PrePush from clone failed: %v\\\", err)\\n\\t}\\n\\n\\tnewCheckpointID := cloneEnv.GetLatestCheckpointID()\\n\\tt.Logf(\\\"New checkpoint: %s\\\", newCheckpointID)\\n\\n\\t// Verify remote has BOTH checkpoints\\n\\toriginalSummaryPath := CheckpointSummaryPath(originalCheckpointID)\\n\\tif !fileExistsOnRemoteBranch(t, bareDir, paths.MetadataBranchName, originalSummaryPath) {\\n\\t\\tt.Errorf(\\\"original checkpoint %s should still exist on remote\\\", originalCheckpointID)\\n\\t}\\n\\n\\tnewSummaryPath := CheckpointSummaryPath(newCheckpointID)\\n\\tif !fileExistsOnRemoteBranch(t, bareDir, paths.MetadataBranchName, newSummaryPath) {\\n\\t\\tt.Errorf(\\\"new checkpoint %s should exist on remote\\\", newCheckpointID)\\n\\t}\\n}\\n\\n// =============================================================================\\n// P1 — Non-Fast-Forward Recovery\\n// =============================================================================\\n\\n// TestConcurrentPush_SecondPusherMergesAndRetries verifies that when two clones\\n// push to the same remote, the second pusher fetches, merges, and retries.\\nfunc TestConcurrentPush_SecondPusherMergesAndRetries(t *testing.T) {\\n\\tt.Parallel()\\n\\tenv := NewFeatureBranchEnv(t)\\n\\n\\tbareDir := env.SetupBareRemote()\\n\\n\\t// Clone A\\n\\tcloneA := env.CloneFrom(bareDir)\\n\\tcloneA.GitCheckoutNewBranch(\\\"feature/clone-a\\\")\\n\\n\\t// Clone B\\n\\tcloneB := env.CloneFrom(bareDir)\\n\\tcloneB.GitCheckoutNewBranch(\\\"feature/clone-b\\\")\\n\\n\\t// Clone A: session + commit\\n\\tsessionA := cloneA.NewSession()\\n\\ttranscriptA := sessionA.CreateTranscript(\\\"Work in clone A\\\", []FileChange{\\n\\t\\t{Path: \\\"a.go\\\", Content: \\\"package a\\\"},\\n\\t})\\n\\n\\tif err := cloneA.SimulateUserPromptSubmitWithPromptAndTranscriptPath(sessionA.ID, \\\"Work in clone A\\\", transcriptA); err != nil {\\n\\t\\tt.Fatalf(\\\"clone A SimulateUserPromptSubmit failed: %v\\\", err)\\n\\t}\\n\\n\\tcloneA.WriteFile(\\\"a.go\\\", \\\"package a\\\")\\n\\tcloneA.GitAdd(\\\"a.go\\\")\\n\\n\\tif err := cloneA.SimulateStop(sessionA.ID, transcriptA); err != nil {\\n\\t\\tt.Fatalf(\\\"clone A SimulateStop failed: %v\\\", err)\\n\\t}\\n\\n\\tcloneA.GitCommitWithShadowHooks(\\\"Work from A\\\", \\\"a.go\\\")\\n\\n\\t// Clone B: session + commit\\n\\tsessionB := cloneB.NewSession()\\n\\ttranscriptB := sessionB.CreateTranscript(\\\"Work in clone B\\\", []FileChange{\\n\\t\\t{Path: \\\"b.go\\\", Content: \\\"package b\\\"},\\n\\t})\\n\\n\\tif err := cloneB.SimulateUserPromptSubmitWithPromptAndTranscriptPath(sessionB.ID, \\\"Work in clone B\\\", transcriptB); err != nil {\\n\\t\\tt.Fatalf(\\\"clone B SimulateUserPromptSubmit failed: %v\\\", err)\\n\\t}\\n\\n\\tcloneB.WriteFile(\\\"b.go\\\", \\\"package b\\\")\\n\\tcloneB.GitAdd(\\\"b.go\\\")\\n\\n\\tif err := cloneB.SimulateStop(sessionB.ID, transcriptB); err != nil {\\n\\t\\tt.Fatalf(\\\"clone B SimulateStop failed: %v\\\", err)\\n\\t}\\n\\n\\tcloneB.GitCommitWithShadowHooks(\\\"Work from B\\\", \\\"b.go\\\")\\n\\n\\t// A pushes first (should succeed cleanly)\\n\\tif err := runPrePushInDir(t, cloneA.RepoDir, \\\"origin\\\"); err != nil {\\n\\t\\tt.Fatalf(\\\"clone A PrePush failed: %v\\\", err)\\n\\t}\\n\\n\\tcheckpointA := cloneA.GetLatestCheckpointID()\\n\\tt.Logf(\\\"Clone A checkpoint: %s\\\", checkpointA)\\n\\n\\t// B pushes second (will get non-fast-forward, should fetch+merge+retry)\\n\\tif err := runPrePushInDir(t, cloneB.RepoDir, \\\"origin\\\"); err != nil {\\n\\t\\tt.Fatalf(\\\"clone B PrePush failed: %v\\\", err)\\n\\t}\\n\\n\\tcheckpointB := cloneB.GetLatestCheckpointID()\\n\\tt.Logf(\\\"Clone B checkpoint: %s\\\", checkpointB)\\n\\n\\t// Remote should have BOTH checkpoints\\n\\tsummaryA := CheckpointSummaryPath(checkpointA)\\n\\tif !fileExistsOnRemoteBranch(t, bareDir, paths.MetadataBranchName, summaryA) {\\n\\t\\tt.Errorf(\\\"remote should have checkpoint from clone A: %s\\\", checkpointA)\\n\\t}\\n\\n\\tsummaryB := CheckpointSummaryPath(checkpointB)\\n\\tif !fileExistsOnRemoteBranch(t, bareDir, paths.MetadataBranchName, summaryB) {\\n\\t\\tt.Errorf(\\\"remote should have checkpoint from clone B: %s\\\", checkpointB)\\n\\t}\\n}\\n\\n// =============================================================================\\n// P1 — Graceful Degradation\\n// =============================================================================\\n\\n// TestGracefulDegradation_UnreachableRemotePushContinues verifies that\\n// PrePush does not fail when a checkpoint remote URL is unreachable.\\n// The push to origin should still succeed for trails.\\nfunc TestGracefulDegradation_UnreachableRemotePushContinues(t *testing.T) {\\n\\tt.Parallel()\\n\\tenv := NewFeatureBranchEnv(t)\\n\\n\\tbareDir := env.SetupBareRemote()\\n\\n\\t// Create session + commit to generate checkpoints and trails locally\\n\\tsession := env.NewSession()\\n\\ttranscriptPath := session.CreateTranscript(\\\"Some work\\\", []FileChange{\\n\\t\\t{Path: \\\"work.go\\\", Content: \\\"package work\\\"},\\n\\t})\\n\\n\\tif err := env.SimulateUserPromptSubmitWithPromptAndTranscriptPath(session.ID, \\\"Some work\\\", transcriptPath); err != nil {\\n\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n\\t}\\n\\n\\tenv.WriteFile(\\\"work.go\\\", \\\"package work\\\")\\n\\tenv.GitAdd(\\\"work.go\\\")\\n\\n\\tif err := env.SimulateStop(session.ID, transcriptPath); err != nil {\\n\\t\\tt.Fatalf(\\\"SimulateStop failed: %v\\\", err)\\n\\t}\\n\\n\\tenv.GitCommitWithShadowHooks(\\\"Some work\\\", \\\"work.go\\\")\\n\\n\\t// PrePush should not error even if internal operations warn\\n\\tif err := runPrePushInDir(t, env.RepoDir, \\\"origin\\\"); err != nil {\\n\\t\\tt.Fatalf(\\\"PrePush should not fail: %v\\\", err)\\n\\t}\\n\\n\\t// Trails should be pushed to origin regardless\\n\\tif env.BranchExists(paths.TrailsBranchName) && !env.BranchExistsOnRemote(bareDir, paths.TrailsBranchName) {\\n\\t\\tt.Error(\\\"trails should still be pushed to origin\\\")\\n\\t}\\n}\\n\\n// =============================================================================\\n// Helpers\\n// =============================================================================\\n\\n// runPrePushInDir runs the pre-push hook via the CLI binary in the given directory.\\nfunc runPrePushInDir(t *testing.T, repoDir, remote string) error {\\n\\tt.Helper()\\n\\n\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"pre-push\\\", remote)\\n\\tcmd.Dir = repoDir\\n\\tcmd.Env = testutil.GitIsolatedEnv()\\n\\t// pre-push hook reads stdin for ref info, provide empty input\\n\\tcmd.Stdin = nil\\n\\n\\toutput, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\tt.Logf(\\\"pre-push output: %s\\\", output)\\n\\t\\treturn err\\n\\t}\\n\\tt.Logf(\\\"pre-push output: %s\\\", output)\\n\\treturn nil\\n}\\n\\n// fetchMetadataBranch fetches the entire/checkpoints/v1 branch from a remote URL\\n// into a local repo. This simulates what fetchMetadataBranchIfMissing does.\\nfunc fetchMetadataBranch(t *testing.T, repoDir, remoteURL string) {\\n\\tt.Helper()\\n\\n\\tbranchName := paths.MetadataBranchName\\n\\trefSpec := \\\"+\\\" + \\\"refs/heads/\\\" + branchName + \\\":\\\" + \\\"refs/heads/\\\" + branchName\\n\\tcmd := exec.Command(\\\"git\\\", \\\"fetch\\\", \\\"--no-tags\\\", remoteURL, refSpec)\\n\\tcmd.Dir = repoDir\\n\\tcmd.Env = testutil.GitIsolatedEnv()\\n\\n\\toutput, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\t// It is OK if the branch doesn't exist on remote\\n\\t\\tt.Logf(\\\"fetch metadata branch output: %s (err: %v)\\\", output, err)\\n\\t}\\n}\\n\\n// fileExistsOnRemoteBranch checks if a file exists in a branch tree on a bare remote.\\nfunc fileExistsOnRemoteBranch(t *testing.T, bareDir, branchName, filePath string) bool {\\n\\tt.Helper()\\n\\n\\tcmd := exec.Command(\\\"git\\\", \\\"cat-file\\\", \\\"-t\\\", branchName+\\\":\\\"+filePath)\\n\\tcmd.Dir = bareDir\\n\\tcmd.Env = testutil.GitIsolatedEnv()\\n\\treturn cmd.Run() == nil\\n}\\n\\n// getRemoteBranchHash returns the commit hash of a branch on a bare remote.\\nfunc getRemoteBranchHash(t *testing.T, bareDir, branchName string) string {\\n\\tt.Helper()\\n\\n\\tcmd := exec.Command(\\\"git\\\", \\\"rev-parse\\\", \\\"refs/heads/\\\"+branchName)\\n\\tcmd.Dir = bareDir\\n\\tcmd.Env = testutil.GitIsolatedEnv()\\n\\toutput, err := cmd.Output()\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"failed to get hash for %s on remote: %v\\\", branchName, err)\\n\\t}\\n\\treturn trimOutput(string(output))\\n}\\n\\n// listCheckpointsInDir calls strategy.ListCheckpoints from within the given directory.\\n// Uses the CLI binary to run `entire sessions --json` in the clone.\\nfunc listCheckpointsInDir(t *testing.T, repoDir string) []checkpointListEntry {\\n\\tt.Helper()\\n\\n\\t// We read checkpoints directly from the metadata branch using git show\\n\\t// since calling the CLI for session listing would require more setup.\\n\\tcmd := exec.Command(\\\"git\\\", \\\"ls-tree\\\", \\\"-r\\\", \\\"--name-only\\\", paths.MetadataBranchName)\\n\\tcmd.Dir = repoDir\\n\\tcmd.Env = testutil.GitIsolatedEnv()\\n\\toutput, err := cmd.Output()\\n\\tif err != nil {\\n\\t\\tt.Logf(\\\"ls-tree failed (branch may not exist): %v\\\", err)\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Parse the sharded structure to find checkpoints\\n\\tseen := make(map[string]bool)\\n\\tvar entries []checkpointListEntry\\n\\tfor _, line := range splitLines(string(output)) {\\n\\t\\tparts := filepath.SplitList(line)\\n\\t\\t// Use simple split instead\\n\\t\\tpathParts := splitPath(line)\\n\\t\\t_ = parts\\n\\t\\t// Match <prefix>/<suffix>/metadata.json (top-level, not session-level)\\n\\t\\tif len(pathParts) == 3 && pathParts[2] == \\\"metadata.json\\\" {\\n\\t\\t\\tcpID := pathParts[0] + pathParts[1]\\n\\t\\t\\tif !seen[cpID] {\\n\\t\\t\\t\\tseen[cpID] = true\\n\\t\\t\\t\\tentries = append(entries, checkpointListEntry{CheckpointID: cpID})\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\treturn entries\\n}\\n\\n// checkpointListEntry is a simplified checkpoint entry for test assertions.\\ntype checkpointListEntry struct {\\n\\tCheckpointID string\\n}\\n\\nfunc splitLines(s string) []string {\\n\\tlines := make([]string, 0)\\n\\tfor _, line := range splitByN