T.Fatalf(\\\"failed to clone from %s: %v\\\\n%s\\\", bareDir, err, output)\\n\\t}\",\"new_string\":\"// CloneFrom clones from a bare repo into a new temp directory and returns a new TestEnv\\n// pointing at the clone. The clone has its own .entire directory initialized.\\n// The clone checks out the same branch as the current env's HEAD.\\nfunc (env *TestEnv) CloneFrom(bareDir string) *TestEnv {\\n\\tenv.T.Helper()\\n\\n\\tcloneDir := env.T.TempDir()\\n\\tif resolved, err := filepath.EvalSymlinks(cloneDir); err == nil {\\n\\t\\tcloneDir = resolved\\n\\t}\\n\\n\\t// Get the current branch name to clone the right branch\\n\\tcurrentBranch := env.GetCurrentBranch()\\n\\n\\t// Clone the bare repo, explicitly checking out the right branch.\\n\\t// Bare repos may have HEAD pointing to a non-existent default branch\\n\\t// when the original was on a feature branch.\\n\\tcloneArgs := []string{\\\"clone\\\"}\\n\\tif currentBranch != \\\"\\\" {\\n\\t\\tcloneArgs = append(cloneArgs, \\\"--branch\\\", currentBranch)\\n\\t}\\n\\tcloneArgs = append(cloneArgs, bareDir, cloneDir)\\n\\tcmd := exec.Command(\\\"git\\\", cloneArgs...)\\n\\tcmd.Env = testutil.GitIsolatedEnv()\\n\\tif output, err := cmd.CombinedOutput(); err != nil {\\n\\t\\tenv.T.Fatalf(\\\"failed to clone from %s: %v\\\\n%s\\\", bareDir, err, output)\\n\\t}\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":436,\"cache_read_input_tokens\":193660,\"cache_creation\":{\"ephemeral_5m_input_tokens\":436,\"ephemeral_1h_input_tokens\":0},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CZ3CfbQMUBBgwJAkUwo1z\",\"uuid\":\"ae54b405-6d78-4a86-ad1b-0af514a949bf\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"ac0c89dfc205d20a0\"},\"toolUseID\":\"agent_msg_01LWncSPcpvzNZH5mzVAu7hF\",\"parentToolUseID\":\"toolu_01TPXnNTs1EdDfGZbG6UKcbX\",\"u