5→\\tvar shellCmdSb25 strings.Builder\\n    26→\\tfor _, v := range unsetEnv {\\n    27→\\t\\tshellCmdSb25.WriteString(\\\"env -u \\\" + v + \\\" \\\")\\n    28→\\t}\\n    29→\\tshellCmd += shellCmdSb25.String()\\n    30→\\tshellCmd += command\\n    31→\\tvar shellCmdSb29 strings.Builder\\n    32→\\tfor _, a := range args {\\n    33→\\t\\tshellCmdSb29.WriteString(\\\" \\\" + a)\\n    34→\\t}\\n    35→\\tshellCmd += shellCmdSb29.String()\\n    36→\\ttmuxArgs = append(tmuxArgs, shellCmd)\\n    37→\\n    38→\\tcmd := exec.Command(\\\"tmux\\\", tmuxArgs...)\\n    39→\\tif out, err := cmd.CombinedOutput(); err != nil {\\n    40→\\t\\treturn nil, fmt.Errorf(\\\"tmux new-session: %w\\\\n%s\\\", err, out)\\n    41→\\t}\\n    42→\\t// Keep the pane around after the command exits so we can capture error output.\\n    43→\\tsetCmd := exec.Command(\\\"tmux\\\", \\\"set-option\\\", \\\"-t\\\", name, \\\"remain-on-exit\\\", \\\"on\\\")\\n    44→\\t_ = setCmd.Run()\\n    45→\\treturn s, nil\\n    46→}\\n    47→\\n    48→func (s *TmuxSession) Send(input string) error {\\n    49→\\ts.stableAtSend = stableContent(s.Capture())\\n    50→\\t// Send text and Enter separately — Claude's TUI can swallow Enter\\n    51→\\t// if it arrives before the input handler finishes processing the text.\\n    52→\\tif err := s.SendKeys(input); err != nil {\\n    53→\\t\\treturn err\\n    54→\\t}\\n    55→\\ttime.Sleep(200 * time.Millisecond)\\n    56→\\treturn s.SendKeys(\\\"Enter\\\")\\n    57→}\\n    58→\\n    59→// SendKeys sends raw tmux key names without appending Enter.\\n    60→func (s *TmuxSession) SendKeys(keys ...string) error {\\n    61→\\targs := append([]string{\\\"send-keys\\\", \\\"-t\\\", s.name}, keys...)\\n    62→\\tcmd := exec.Command(\\\"tmux\\\", args...)\\n    63→\\tout, err := cmd.CombinedOutput()\\n    64→\\tif err != nil {\\n    65→\\t\\treturn fmt.Errorf(\\\"tmux send-keys: %w\\\\n%s\\\", err, out)\\n    66→\\t}\\n    67→\\treturn nil\\n    68→}\\n    69→\\n    70→const settl