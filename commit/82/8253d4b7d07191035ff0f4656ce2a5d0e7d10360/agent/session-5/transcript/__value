rePrePromptState(ag agent.Agent, sessionID, sessionRef string) error {\\n    93Ôćĺ\\tif sessionID == \\\"\\\" {\\n    94Ôćĺ\\t\\tsessionID = unknownSessionID\\n    95Ôćĺ\\t}\\n    96Ôćĺ\\n    97Ôćĺ\\t// Get absolute path for tmp directory\\n    98Ôćĺ\\ttmpDirAbs, err := paths.AbsPath(paths.EntireTmpDir)\\n    99Ôćĺ\\tif err != nil {\\n   100Ôćĺ\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   101Ôćĺ\\t}\\n   102Ôćĺ\\n   103Ôćĺ\\t// Create tmp directory if it doesn't exist\\n   104Ôćĺ\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   105Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n   106Ôćĺ\\t}\\n   107Ôćĺ\\n   108Ôćĺ\\t// Get list of untracked files (excluding .entire directory itself)\\n   109Ôćĺ\\tuntrackedFiles, err := getUntrackedFilesForState()\\n   110Ôćĺ\\tif err != nil {\\n   111Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n   112Ôćĺ\\t}\\n   113Ôćĺ\\n   114Ôćĺ\\t// Get transcript position using TranscriptAnalyzer if available\\n   115Ôćĺ\\tvar transcriptOffset int\\n   116Ôćĺ\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok && sessionRef != \\\"\\\" {\\n   117Ôćĺ\\t\\tpos, posErr := analyzer.GetTranscriptPosition(sessionRef)\\n   118Ôćĺ\\t\\tif posErr != nil {\\n   119Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to get transcript position: %v\\\\n\\\", posErr)\\n   120Ôćĺ\\t\\t} else {\\n   121Ôćĺ\\t\\t\\ttranscriptOffset = pos\\n   122Ôćĺ\\t\\t}\\n   123Ôćĺ\\t}\\n   124Ôćĺ\\n   125Ôćĺ\\t// Create state file\\n   126Ôćĺ\\tstateFile := prePromptStateFile(sessionID)\\n   127Ôćĺ\\tstate := PrePromptState{\\n   128Ôćĺ\\t\\tSessionID:        sessionID,\\n   129Ôćĺ\\t\\tTimestamp:        time.Now().UTC().Format(time.RFC3339),\\n   130Ôćĺ\\t\\tUntrackedFiles:   untrackedFiles,\\n   131Ôćĺ\\t\\tTranscriptOffset: transcriptOffset,\\n   132Ôćĺ\\t}\\n   133Ôćĺ\\n   134Ôćĺ\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   135Ôćĺ\\tif err != nil {\\n   136Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n   137Ôćĺ\\t}\\n   138Ôćĺ\\n   139Ôćĺ\\tif err := os.WriteFile(stateFile, data, 0o600); err != nil {\\n   140Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   141Ôćĺ\\t}\\n   142Ôćĺ\\n   143Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"Captured state before prompt: %d untracked files, transcript offset: %d\\\\n\\\",\\n   144Ôćĺ\\t\\tlen(untrackedFiles), transcriptOffset)\\n   145Ôćĺ\\treturn nil\\n   146Ôćĺ}\\n   147Ôćĺ\\n   148Ôćĺ// LoadPrePromptState loads previously captured state.\\n   149Ôćĺ// Returns nil if no state file exists.\\n   150Ôćĺfunc LoadPrePromptState(sessionID string) (*PrePromptState, error) {\\n   151Ôćĺ\\tstateFile := prePromptStateFile(sessionID)\\n   152Ôćĺ\\n   153Ôćĺ\\tif !fileExists(stateFile) {\\n   154Ôćĺ\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   155Ôćĺ\\t}\\n   156Ôćĺ\\n   157Ôćĺ\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // Reading from controlled git metadata path\\n   158Ôćĺ\\tif err != nil {\\n   159Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to read state file: %w\\\", err)\\n   160Ôćĺ\\t}\\n   161Ôćĺ\\n   162Ôćĺ\\tvar state PrePromptState\\n   163Ôćĺ\\tif err := json.Unmarshal(data, &state); err != nil {\\n   164Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal state: %w\\\", err)\\n   165Ôćĺ\\t}\\n   166Ôćĺ\\n   167Ôćĺ\\tstate.normalizePrePromptState()\\n   168Ôćĺ\\n   169Ôćĺ\\treturn &state, nil\\n   170Ôćĺ}\\n   171Ôćĺ\\n   172Ôćĺ// CleanupPrePromptState removes the state file after use\\n   173Ôćĺfunc CleanupPrePromptState(sessionID string) error {\\n   174Ôćĺ\\tstateFile := prePromptStateFile(sessionID)\\n   175Ôćĺ\\tif fileExists(stateFile) {\\n   176Ôćĺ\\t\\treturn os.Remove(stateFile) //nolint:wrapcheck // already present in codebase\\n   177Ôćĺ\\t}\\n   178Ôćĺ\\treturn nil\\n   179Ôćĺ}\\n   180Ôćĺ\\n   181Ôćĺ// FileChanges holds categorized file changes from git status.\\n   182Ôćĺtype FileChanges struct {\\n   183Ôćĺ\\tModified []string // Modified or staged files\\n   184Ôćĺ\\tNew      []string // Untracked files (filtered if previouslyUntracked provided)\\n   185Ôćĺ\\tDeleted  []string // Deleted files (staged or unstaged)\\n   186Ôćĺ}\\n   187Ôćĺ\\n   188Ôćĺ// DetectFileChanges returns categorized file changes from the current git status.\\n   189Ôćĺ//\\n   190Ôćĺ// previouslyUntracked controls new-file detection:\\n   191Ôćĺ//   - nil: all untracked files go into New\\n   192Ôćĺ//   - non-nil: only untracked files NOT in the pre-existing set go into New\\n   193Ôćĺ//\\n   194Ôćĺ// Modified includes both worktree and staging modified/added files.\\n   195Ôćĺ// Deleted includes both staged and unstaged deletions.\\n   196Ôćĺ// All results exclude .entire/ directory.\\n   197Ôćĺfunc DetectFileChanges(previouslyUntracked []string) (*FileChanges, error) {\\n   198Ôćĺ\\trepo, err := openRepository()\\n   199Ôćĺ\\tif err != nil {\\n   200Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   201Ôćĺ\\t}\\n   202Ôćĺ\\n   203Ôćĺ\\tworktree, err := repo.Worktree()\\n   204Ôćĺ\\tif err != nil {\\n   205Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   206Ôćĺ\\t}\\n   207Ôćĺ\\n   208Ôćĺ\\tstatus, err := worktree.Status()\\n   209Ôćĺ\\tif err != nil {\\n   210Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n   211Ôćĺ\\t}\\n   212Ôćĺ\\n   213Ôćĺ\\t// Build set of pre-existing untracked files for quick lookup\\n   214Ôćĺ\\tvar preExisting map[string]bool\\n   215Ôćĺ\\tif previouslyUntracked != nil {\\n   216Ôćĺ\\t\\tpreExisting = make(map[string]bool, len(previouslyUntracked))\\n   217Ôćĺ\\t\\tfor _, f := range previouslyUntracked {\\n   218Ôćĺ\\t\\t\\tpreExisting[f] = true\\n   219Ôćĺ\\t\\t}\\n   220Ôćĺ\\t}\\n   221Ôćĺ\\n   222Ôćĺ\\tvar changes FileChanges\\n   223Ôćĺ\\tfor file, st := range status {\\n   224Ôćĺ\\t\\tif paths.IsInfrastructurePath(file) {\\n   225Ô