mmits\\n   308Ôćĺ\\tmainBranchHash := GetMainBranchHash(repo)\\n   309Ôćĺ\\n   310Ôćĺ\\t// Walk current branch history looking for commits with checkpoint trailers\\n   311Ôćĺ\\titer, err := repo.Log(&git.LogOptions{\\n   312Ôćĺ\\t\\tFrom:  head.Hash(),\\n   313Ôćĺ\\t\\tOrder: git.LogOrderCommitterTime,\\n   314Ôćĺ\\t})\\n   315Ôćĺ\\tif err != nil {\\n   316Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   317Ôćĺ\\t}\\n   318Ôćĺ\\n   319Ôćĺ\\tvar points []RewindPoint\\n   320Ôćĺ\\tcount := 0\\n   321Ôćĺ\\n   322Ôćĺ\\terr = iter.ForEach(func(c *object.Commit) error {\\n   323Ôćĺ\\t\\tif count >= logsOnlyScanLimit || len(points) >= limit {\\n   324Ôćĺ\\t\\t\\treturn errStop\\n   325Ôćĺ\\t\\t}\\n   326Ôćĺ\\t\\tcount++\\n   327Ôćĺ\\n   328Ôćĺ\\t\\t// Check for Entire-Checkpoint trailer\\n   329Ôćĺ\\t\\tcpID, found := trailers.ParseCheckpoint(c.Message)\\n   330Ôćĺ\\t\\tif !found {\\n   331Ôćĺ\\t\\t\\treturn nil\\n   332Ôćĺ\\t\\t}\\n   333Ôćĺ\\n   334Ôćĺ\\t\\t// Look up metadata from sharded path\\n   335Ôćĺ\\t\\tcheckpointPath := cpID.Path()\\n   336Ôćĺ\\t\\tmetadata, err := ReadCheckpointMetadata(metadataTree, checkpointPath)\\n   337Ôćĺ\\t\\tif err != nil {\\n   338Ôćĺ\\t\\t\\t// Checkpoint exists in commit but no metadata found - skip this commit\\n   339Ôćĺ\\t\\t\\treturn nil //nolint:nilerr // Intentional: skip commits without metadata\\n   340Ôćĺ\\t\\t}\\n   341Ôćĺ\\n   342Ôćĺ\\t\\tmessage := strings.Split(c.Message, \\\"\\\\n\\\")[0]\\n   343Ôćĺ\\n   344Ôćĺ\\t\\t// Determine if this is a full rewind or logs-only\\n   345Ôćĺ\\t\\t// Full rewind is allowed if commit is only on this branch (not reachable from main)\\n   346Ôćĺ\\t\\tisLogsOnly := false\\n   347Ôćĺ\\t\\tif mainBranchHash != plumbing.ZeroHash {\\n   348Ôćĺ\\t\\t\\tif IsAncestorOf(repo, c.Hash, mainBranchHash) {\\n   349Ôćĺ\\t\\t\\t\\tisLogsOnly = true\\n   350Ôćĺ\\t\\t\\t}\\n   351Ôćĺ\\t\\t}\\n   352Ôćĺ\\n   353Ôćĺ\\t\\t// Build metadata path - for task checkpoints, includ