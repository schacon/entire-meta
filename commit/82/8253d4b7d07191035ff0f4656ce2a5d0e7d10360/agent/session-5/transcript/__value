om hook input.\\n   148Ôćĺfunc (c *ClaudeCodeAgent) GetSessionID(input *agent.HookInput) string {\\n   149Ôćĺ\\treturn input.SessionID\\n   150Ôćĺ}\\n   151Ôćĺ\\n   152Ôćĺ// ResolveSessionFile returns the path to a Claude session file.\\n   153Ôćĺ// Claude names files directly as <id>.jsonl.\\n   154Ôćĺfunc (c *ClaudeCodeAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   155Ôćĺ\\treturn filepath.Join(sessionDir, agentSessionID+\\\".jsonl\\\")\\n   156Ôćĺ}\\n   157Ôćĺ\\n   158Ôćĺ// ProtectedDirs returns directories that Claude uses for config/state.\\n   159Ôćĺfunc (c *ClaudeCodeAgent) ProtectedDirs() []string { return []string{\\\".claude\\\"} }\\n   160Ôćĺ\\n   161Ôćĺ// GetSessionDir returns the directory where Claude stores session transcripts.\\n   162Ôćĺfunc (c *ClaudeCodeAgent) GetSessionDir(repoPath string) (string, error) {\\n   163Ôćĺ\\t// Check for test environment override\\n   164Ôćĺ\\tif override := os.Getenv(\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR\\\"); override != \\\"\\\" {\\n   165Ôćĺ\\t\\treturn override, nil\\n   166Ôćĺ\\t}\\n   167Ôćĺ\\n   168Ôćĺ\\thomeDir, err := os.UserHomeDir()\\n   169Ôćĺ\\tif err != nil {\\n   170Ôćĺ\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   171Ôćĺ\\t}\\n   172Ôćĺ\\n   173Ôćĺ\\tprojectDir := SanitizePathForClaude(repoPath)\\n   174Ôćĺ\\treturn filepath.Join(homeDir, \\\".claude\\\", \\\"projects\\\", projectDir), nil\\n   175Ôćĺ}\\n   176Ôćĺ\\n   177Ôćĺ// ReadSession reads a session from Claude's storage (JSONL transcript file).\\n   178Ôćĺ// The session data is stored in NativeData as raw JSONL bytes.\\n   179Ôćĺ// ModifiedFiles is computed by parsing the transcript.\\n   180Ôćĺfunc (c *ClaudeCodeAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   181Ôćĺ\\tif input.SessionRef == \\\"\\\" {\\n   182Ôćĺ\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   183Ôćĺ\\t}\\n   184Ôćĺ\\n   185Ôćĺ\\t// Read the