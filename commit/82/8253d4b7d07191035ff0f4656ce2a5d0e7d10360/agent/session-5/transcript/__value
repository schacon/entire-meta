2\",\"version\":\"2.1.44\",\"gitBranch\":\"soph/agent-refactor\",\"slug\":\"snazzy-jingling-candy\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01Tqv1WeBg7YujE9XhjWhdTv\",\"type\":\"tool_result\",\"content\":\"     1Ôćĺ// Package strategy provides an interface for different git strategies\\n     2Ôćĺ// that can be used to save and manage Claude Code session changes.\\n     3Ôćĺpackage strategy\\n     4Ôćĺ\\n     5Ôćĺimport (\\n     6Ôćĺ\\t\\\"encoding/json\\\"\\n     7Ôćĺ\\t\\\"errors\\\"\\n     8Ôćĺ\\t\\\"os\\\"\\n     9Ôćĺ\\t\\\"strings\\\"\\n    10Ôćĺ\\t\\\"time\\\"\\n    11Ôćĺ\\n    12Ôćĺ\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    13Ôćĺ\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    14Ôćĺ\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    15Ôćĺ)\\n    16Ôćĺ\\n    17Ôćĺ// ErrNoMetadata is returned when a commit does not have an Entire metadata trailer.\\n    18Ôćĺvar ErrNoMetadata = errors.New(\\\"commit has no entire metadata\\\")\\n    19Ôćĺ\\n    20Ôćĺ// ErrNoSession is returned when no session info is available.\\n    21Ôćĺvar ErrNoSession = errors.New(\\\"no session info available\\\")\\n    22Ôćĺ\\n    23Ôćĺ// ErrNotTaskCheckpoint is returned when a rewind point is not a task checkpoint.\\n    24Ôćĺvar ErrNotTaskCheckpoint = errors.New(\\\"not a task checkpoint\\\")\\n    25Ôćĺ\\n    26Ôćĺ// ErrNotImplemented is returned when a feature is not yet implemented.\\n    27Ôćĺvar ErrNotImplemented = errors.New(\\\"not implemented\\\")\\n    28Ôćĺ\\n    29Ôćĺ// ErrEmptyRepository is returned when the repository has no commits yet.\\n    30Ôćĺvar ErrEmptyRepository = errors.New(\\\"repository has no commits yet\\\")\\n    31Ôćĺ\\n    32Ôćĺ// SessionIDConflictError is returned when trying to start a new session\\n    33Ôćĺ// but the shadow branch already has commits from a different session ID.\\n    34Ôćĺ// This prevents orphaning existing session work.\\n    35Ôćĺtype SessionIDConflictError struct {\\n    36Ôćĺ\\tExistingSession string // Session ID found in the shadow branch\\n    37Ôćĺ\\tNewSession      string // Session ID being initialized\\n    38Ôćĺ\\tShadowBranch    string // The shadow branch name (e.g., \\\"entire/abc1234\\\")\\n    39Ôćĺ}\\n    40Ôćĺ\\n    41Ôćĺfunc (e *SessionIDConflictError) Error() string {\\n    42Ôćĺ\\treturn \\\"session ID conflict: shadow branch has commits from a different session\\\"\\n    43Ôćĺ}\\n    44Ôćĺ\\n    45Ôćĺ// ExtractToolUseIDFromTaskMetadataDir extracts the ToolUseID from a task metadata directory path.\\n    46Ôćĺ// Task metadata dirs have format: .entire/metadata/<session>/tasks/<toolUseID>\\n    47Ôćĺ// Returns empty string if not a task metadata directory.\\n    48Ôćĺfunc ExtractToolUseIDFromTaskMetadataDir(metadataDir string) string {\\n    49Ôćĺ\\tparts := strings.Split(metadataDir, \\\"/\\\")\\n    50Ôćĺ\\tif len(parts) >= 2 && parts[len(parts)-2] == \\\"tasks\\\" {\\n    51Ôćĺ\\t\\treturn parts[len(parts)-1]\\n    52Ôćĺ\\t}\\n    53Ôćĺ\\treturn \\\"\\\"\\n    54Ôćĺ}\\n    55Ôćĺ\\n    56Ôćĺ// SessionInfo contains information about the current session state.\\n    57Ôćĺ// This is used to generate trailers for linking commits to their AI session.\\n    58Ôćĺtype SessionInfo struct {\\n    59Ôćĺ\\t// SessionID is the session identifier extracted from the latest commit's metadata\\n    60Ôćĺ\\tSessionID string\\n    61Ôćĺ\\n    62Ôćĺ\\t// Reference is a strategy-specific reference string.\\n    63Ôćĺ\\t// For manual-commit strategy: \\\"entire/abc1234\\\" (the shadow branch name)\\n    64Ôćĺ\\t// Empty for commit strategy (metadata is in the same commit).\\n    65Ôćĺ\\tReference string\\n    66Ôćĺ\\n    67Ôćĺ\\t// CommitHash is the full SHA of the commit containing the session metadata.\\n    68Ôćĺ\\t// Empty for commit strategy.\\n    69Ôćĺ\\tCommitHash string\\n    70Ôćĺ}\\n    71Ôćĺ\\n    72Ôćĺ// RewindPoint represents a point to which the user can rewind.\\n    73Ôćĺ// This abstraction allows different strategies to use different\\n    74Ôćĺ// identifiers (commit hashes, branch names, stash refs, etc.)\\n    75Ôćĺtype RewindPoint struct {\\n    76Ôćĺ\\t// ID is the unique identifier for this rewind point\\n    77Ôćĺ\\t// (commit hash, branch name, stash ref, etc.)\\n    78Ôćĺ\\tID string\\n    79Ôćĺ\\n    80Ôćĺ\\t// Message is the human-readable description/summary\\n    81Ôćĺ\\tMessage string\\n    82Ôćĺ\\n    83Ôćĺ\\t// MetadataDir is the path to the metadata directory\\n    84Ôćĺ\\tMetadataDir string\\n    85Ôćĺ\\n    86Ôćĺ\\t// Date is when this rewind point was created\\n    87Ôćĺ\\tDate time.Time\\n    88Ôćĺ\\n    89Ôćĺ\\t// IsTaskCheckpoint indicates if this is a task checkpoint (vs a session checkpoint)\\n    90Ôćĺ\\tIsTaskCheckpoint bool\\n    91Ôćĺ\\n    92Ôćĺ\\t// ToolUseID is the tool use ID for task checkpoints (empty for session checkpoints)\\n    93Ôćĺ\\tToolUseID string\\n    94Ôćĺ\\n    95Ôćĺ\\t// IsLogsOnly indicates this is a commit with session logs but no shadow branch state.\\n    96Ôćĺ\\t// The logs can be restored from entire/checkpoints/v1, but file state requires git checkout.\\n    97Ôćĺ\\tIsLogsOnly bool\\n    98Ôćĺ\\n    99Ôćĺ\\t// CheckpointID is the stable 12-hex-char identifier for logs-only points.\\n   100Ôćĺ\\t// Used to retrieve logs from entire/checkpoints/v1/<id[:2]>/<id[2:]>/full.jsonl\\n   101Ôćĺ\\t// Empty for shadow branch checkpoints (uncommitted).\\n   102Ôćĺ\\tCheckpointID id.CheckpointID\\n   103Ôćĺ\\n   104Ôćĺ\\t// Agent is the human-readable name of the agent that created this checkpoint\\n   105Ôćĺ\\t// (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   106Ôćĺ\\tAgent agent.AgentType\\n   107Ôćĺ\\n   108Ôćĺ\\t// SessionID is the session identifier for this checkpoint.\\n   109Ôćĺ\\t// Used to distinguish checkpoints from different concurrent sessions.\\n   110Ôćĺ\\tSessionID string\\n   111Ôćĺ\\n   112Ôćĺ\\t// SessionPrompt is the initial prompt that started this session.\\n   113Ôćĺ\\t// Used to help users identify which session a checkpoint belongs to.\\n   114Ôćĺ\\tSessionPrompt string\\n   115Ôćĺ\\n   116Ôćĺ\\t// SessionCount is the number of sessions in this checkpoint (1 for single-session).\\n   117Ôćĺ\\t// Only populated for logs-only points with multi-session checkpoints.\\n   118Ôćĺ\\tSessionCount int\\n   119Ôćĺ\\n   120Ôćĺ\\t// SessionIDs contains all session IDs when this is a multi-session checkpoint.\\n   121Ôćĺ\\t// The last entry is the most recent session (same as SessionID).\\n   122Ôćĺ\\t// Only populated for logs-only points with multi-session checkpoints.\\n   123Ôćĺ\\tSessionIDs []string\\n   124Ôćĺ\\n   125Ôćĺ\\t// SessionPrompts contains the first prompt for each session (parallel to SessionIDs).\\n   126Ôćĺ\\t// Used to display context when showing resume commands for multi-session checkpoints.\\n   127Ôćĺ\\tSessionPrompts []string\\n   128Ôćĺ}\\n   129Ôćĺ\\n   130Ôćĺ// RewindPreview describes what will happen when rewinding to a checkpoint.\\n   131Ôćĺ// Used to warn users about files that will be modified or deleted.\\n   132Ôćĺtype RewindPreview struct {\\n   133Ôćĺ\\t// FilesToRestore are files from the checkpoint that will be written/restored.\\n   134Ôćĺ\\tFilesToRestore []string\\n   135Ôćĺ\\n   136Ôćĺ\\t// FilesToDelete are untracked files that will be removed.\\n   137Ôćĺ\\t// These are files created after the checkpoint that aren't in the checkpoint tree\\n   138Ôćĺ\\t// and weren't present at session start.\\n   139Ôćĺ\\tFilesToDelete []string\\n   140Ôćĺ\\n   141Ôćĺ\\t// TrackedChanges are tracked files with uncommitted changes that will be reverted.\\n   142Ôćĺ\\t// These come from the existing CanRewind() warning.\\n   143Ôćĺ\\tTrackedChanges []string\\n   144Ôćĺ}\\n   145Ôćĺ\\n   146Ôćĺ// StepContext contains all information needed for saving a step checkpoint.\\n   147Ôćĺ// All file paths should be pre-filtered and normalized by the CLI layer.\\n   148Ôćĺtype StepContext struct {\\n   149Ôćĺ\\t// SessionID is the Claude Code session identifier\\n   150Ôćĺ\\tSessionID string\\n   151Ôćĺ\\n   152Ôćĺ\\t// ModifiedFiles is the list of files modified during the session\\n   153Ôćĺ\\t// (extracted from the transcript, already filtered and relative)\\n   154Ôćĺ\\tModifiedFiles []string\\n   155Ôćĺ\\n   156Ôćĺ\\t// NewFiles is the list of new files created during the session\\n   157Ôćĺ\\t// (pre-computed by CLI from pre-prompt state comparison)\\n   158Ôćĺ\\tNewFiles []string\\n   159Ôćĺ\\n   160Ôćĺ\\t// DeletedFiles is the list of files deleted during the session\\n   161Ôćĺ\\t// (tracked files that no longer exist)\\n   162Ôćĺ\\tDeletedFiles []string\\n   163Ôćĺ\\n   164Ôćĺ\\t// MetadataDir is the path to the session metadata directory\\n   165Ôćĺ\\tMetadataDir string\\n   166Ôćĺ\\n   167Ôćĺ\\t// MetadataDirAbs is the absolute path to the session metadata directory\\n   168Ôćĺ\\tMetadataDirAbs string\\n   169Ôćĺ\\n   170Ôćĺ\\t// CommitMessage is the generated commit message\\n   171Ôćĺ\\tCommitMessage string\\n   172Ôćĺ\\n   173Ôćĺ\\t// TranscriptPath is the path to the transcript file\\n   174Ôćĺ\\tTranscriptPath string\\n   175Ôćĺ\\n   176Ôćĺ\\t// AuthorName is the name to use for commits\\n   177Ôćĺ\\tAuthorName string\\n   178Ôćĺ\\n   179Ôćĺ\\t// AuthorEmail is the email to use for commits\\n   180Ôćĺ\\tAuthorEmail string\\n   181Ôćĺ\\n   182Ôćĺ\\t// AgentType is the human-readable agent name (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   183Ôćĺ\\tAgentType agent.AgentType\\n   184Ôćĺ\\n   185Ôćĺ\\t// Transcript position at step/turn start - tracks what was added during this step\\n   186Ôćĺ\\tStepTranscriptIdentifier string // Last identifier when step started (UUID for Claude, message ID for Gemini)\\n   187Ôćĺ\\tStepTranscriptStart      int    // Transcript line count when this step/turn started\\n   188Ôćĺ\\n   189Ôćĺ\\t// TokenUsage contains the token usage for this checkpoint\\n   190Ôćĺ\\tTokenUsage *agent.TokenUsage\\n   191Ôćĺ}\\n   192Ôćĺ\\n   193Ôćĺ// TaskStepContext contains all information needed for saving a task step checkpoint.\\n   194Ôćĺ// This is called by the PostToolUse[Task] hook when a subagent completes.\\n   195Ôćĺ// The strategy is responsible for creating metadata structures and storing them\\n   196Ôćĺ// according to its storage approach.\\n   197Ôćĺtype TaskStepContext struct {\\n   198Ôćĺ\\t// SessionID is the Claude Code session identifier\\n   199Ôćĺ\\tSessionID string\\n   200Ôćĺ\\n   201Ôćĺ\\t// ToolUseID is the unique identifier for this Task tool invocation\\n   202Ôćĺ\\tToolUseID string\\n   203Ôćĺ\\n   204Ôćĺ\\t// AgentID is the subagent identifier (from tool_response.agentId)\\n   205Ôćĺ\\tAgentID string\\n   206Ôćĺ\\n   207Ôćĺ\\t// ModifiedFiles is the list of files modified by the subagent\\n   208Ôćĺ\\t// (extracted from the subagent's transcript)\\n   209Ôćĺ\\tModifiedFiles []string\\n   210Ôćĺ\\n   211Ôćĺ\\t// NewFiles is the list of new files created by the subagent\\n   212Ôćĺ\\t// (computed from pre-task state comparison)\\n   213Ôćĺ\\tNewFiles []string\\n   214Ôćĺ\\n   215Ôćĺ\\t// DeletedFiles is the list of files deleted by the subagent\\n   216Ôćĺ\\tDeletedFiles []string\\n   217Ôćĺ\\n   218Ôćĺ\\t// TranscriptPath is the path to the main session transcript\\n   219Ôćĺ\\tTranscriptPath string\\n   220Ôćĺ\\n   221Ôćĺ\\t// SubagentTranscriptPath is the path to the subagent's transcript (if available)\\n   222Ôćĺ\\tSubagentTranscriptPath string\\n   223Ôćĺ\\n   224Ôćĺ\\t// CheckpointUUID is the UUID for transcript truncation when rewinding\\n   225Ôćĺ\\tCheckpointUUID string\\n   226Ôćĺ\\n   227Ôćĺ\\t// AuthorName is the name to use for commits\\n   228Ôćĺ\\tAuthorName string\\n   229Ôćĺ\\n   230Ôćĺ\\t// AuthorEmail is the email to use for commits\\n   231Ôćĺ\\tAuthorEmail string\\n   232Ôćĺ\\n   233Ôćĺ\\t// IsIncremental indicates this is an incremental checkpoint during task execution,\\n   234Ôćĺ\\t// not a final task completion checkpoint. When true:\\n   235Ôćĺ\\t// - Writes to checkpoints/NNN-{tool-use-id}.json instead of checkpoint.json\\n   236Ôćĺ\\t// - Skips transcript handling\\n   237Ôćĺ\\t// - Uses incremental commit message\\n   238Ôćĺ\\tIsIncremental bool\\n   239Ôćĺ\\n   240Ôćĺ\\t// IncrementalSequence is the checkpoint sequence number (1, 2, 3, ...)\\n   241Ôćĺ\\t// Only used when IsIncremental is true\\n   242Ôćĺ\\tIncrementalSequence int\\n   243Ôćĺ\\n   244Ôćĺ\\t// IncrementalType is the tool that triggered this checkpoint (\\\"TodoWrite\\\", \\\"Edit\\\", etc.)\\n   245Ôćĺ\\t// Only used when IsIncremental is true\\n   246Ôćĺ\\tIncrementalType string\\n   247Ôćĺ\\n   248Ôćĺ\\t// IncrementalData is the tool_input payload for this checkpoint\\n   249Ôćĺ\\t// Only used when IsIncremental is true\\n   250Ôćĺ\\tIncrementalData json.RawMessage\\n   251Ôćĺ\\n   252Ôćĺ\\t// SubagentType is the type of subagent (e.g., \\\"dev\\\", \\\"reviewer\\\")\\n   253Ôćĺ\\t// Extracted from tool_input.subagent_type in Task tool\\n   254Ôćĺ\\t// Used for descriptive commit messages\\n   255Ôćĺ\\tSubagentType string\\n   256Ôćĺ\\n   257Ôćĺ\\t// TaskDescription is the task description provided to the subagent\\n   258Ôćĺ\\t// Extracted from tool_input.description in Task tool\\n   259Ôćĺ\\t// Used for descriptive commit messages\\n   260Ôćĺ\\tTaskDescription string\\n   261Ôćĺ\\n   262Ôćĺ\\t// TodoContent is the content of the in-progress todo item\\n   263Ôćĺ\\t// Extracted from tool_input.todos where status == \\\"in_progress\\\"\\n   264Ôćĺ\\t// Used for descriptive incremental checkpoint messages\\n   265Ôćĺ\\tTodoContent string\\n   266Ôćĺ\\n   267Ôćĺ\\t// AgentType is the human-readable agent name (e.g., \\\"Claude Code\\\", \\\"Cursor\\\")\\n   268Ôćĺ\\tAgentType agent.AgentType\\n   269Ôćĺ}\\n   270Ôćĺ\\n   271Ôćĺ// TaskCheckpoint contains the checkpoint information written to checkpoint.json\\n   272Ôćĺtype TaskCheckpoint struct {\\n   273Ôćĺ\\tSessionID      string `json:\\\"session_id\\\"`\\n   274Ôćĺ\\tToolUseID      string `json:\\\"tool_use_id\\\"`\\n   275Ôćĺ\\tCheckpointUUID string `json:\\\"checkpoint_uuid\\\"`\\n   276Ôćĺ\\tAgentID        string `json:\\\"agent_id,omitempty\\\"`\\n   277Ôćĺ}\\n   278Ôćĺ\\n   279Ôćĺ// SubagentCheckpoint represents an intermediate checkpoint created during subagent execution.\\n   280Ôćĺ// These are created by PostToolUse hooks for tools like TodoWrite, Edit, Write.\\n   281Ôćĺtype SubagentCheckpoint struct {\\n   282Ôćĺ\\tType      string          `json:\\\"type\\\"`        // Tool name: \\\"TodoWrite\\\", \\\"Edit\\\", \\\"Write\\\"\\n   283Ôćĺ\\tToolUseID string          `json:\\\"tool_use_id\\\"` // The tool use ID that created this checkpoint\\n   284Ôćĺ\\tTimestamp time.Time       `json:\\\"timestamp\\\"`   // When the checkpoint was created\\n   285Ôćĺ\\tData      json.RawMessage `json:\\\"data\\\"`        // Type-specific payload (tool_input)\\n   286Ôćĺ}\\n   287Ôćĺ\\n   288Ôćĺ// TaskMetadataDir returns the path to a task's metadata directory\\n   289Ôćĺ// within the session metadata directory.\\n   290Ôćĺfunc TaskMetadataDir(sessionMetadataDir, toolUseID string) string {\\n   291Ôćĺ\\treturn sessionMetadataDir + \\\"/tasks/\\\" + toolUseID\\n   292Ôćĺ}\\n   293Ôćĺ\\n   294Ôćĺ// ReadTaskCheckpoint reads the checkpoint.json file from a task metadata directory.\\n   295Ôćĺ// This is used during rewind to get the checkpoint UUID for transcript truncation.\\n   296Ôćĺfunc ReadTaskCheckpoint(taskMetadataDir string) (*TaskCheckpoint, error) {\\n   297Ôćĺ\\tcheckpointFile := taskMetadataDir + \\\"/checkpoint.json\\\"\\n   298Ôćĺ\\n   299Ôćĺ\\tdata, err := os.ReadFile(checkpointFile) //nolint:gosec // Reading from controlled git metadata path\\n   300Ôćĺ\\tif err != nil {\\n   301Ôćĺ\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   302Ôćĺ\\t}\\n   303Ôćĺ\\n   304Ôćĺ\\tvar checkpoint TaskCheckpoint\\n   305Ôćĺ\\tif err := json.Unmarshal(data, &checkpoint); err != nil {\\n   306Ôćĺ\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   307Ôćĺ\\t}\\n   308Ôćĺ\\n   309Ôćĺ\\treturn &checkpoint, nil\\n   310Ôćĺ}\\n   311Ôćĺ\\n   312Ôćĺ// Strategy defines the interface for git operation strategies.\\n   313Ôćĺ// Different implementations can use commits, branches, stashes, etc.\\n   314Ôćĺ//\\n   315Ôćĺ// Note: State capture (tracking untracked files before a session) is handled\\n   316Ôćĺ// by the CLI layer, not the strategy. The strategy receives pre-computed\\n   317Ôćĺ// file lists in StepContext.\\n   318Ôćĺtype Strategy interface {\\n   319Ôćĺ\\t// Name returns the strategy identifier (e.g., \\\"commit\\\", \\\"branch\\\", \\\"stash\\\")\\n   320Ôćĺ\\tName() string\\n   321Ôćĺ\\n   322Ôćĺ\\t// Description returns a human-readable description for the setup wizard\\n   323Ôćĺ\\tDescription() string\\n   324Ôćĺ\\n   325Ôćĺ\\t// ValidateRepository checks if the repository is in a valid state\\n   326Ôćĺ\\t// for this strategy to operate. Returns an error if validation fails.\\n   327Ôćĺ\\tValidateRepository() error\\n   328Ôćĺ\\n   329Ôćĺ\\t// SaveStep is called on Stop to save all session changes\\n   330Ôćĺ\\t// using this strategy's approach (commit, branch, stash, etc.)\\n   331Ôćĺ\\tSaveStep(ctx StepContext) error\\n   332Ôćĺ\\n   333Ôćĺ\\t// SaveTaskStep is called by PostToolUse[Task] hook when a subagent completes.\\n   334Ôćĺ\\t// Creates a checkpoint commit with task metadata for later rewind.\\n   335Ôćĺ\\t// Different strategies may handle this differently:\\n   336Ôćĺ\\t// - Commit strategy: commits to active branch\\n   337Ôćĺ\\t// - Manual-commit strategy: commits to shadow branch\\n   338Ôćĺ\\t// - Auto-commit strategy: commits logs to shadow only (code deferred to Stop)\\n   339Ôćĺ\\tSaveTaskStep(ctx TaskStepContext) error\\n   340Ôćĺ\\n   341Ôćĺ\\t// GetRewindPoints returns available points to rewind to.\\n   342Ôćĺ\\t// The limit parameter controls the maximum number of points to return.\\n   343Ôćĺ\\tGetRewindPoints(limit int) ([]RewindPoint, error)\\n   344Ôćĺ\\n   345Ôćĺ\\t// Rewind restores the repository to the given rewind point.\\n   346Ôćĺ\\t// The metadataDir in the point is used to restore the session transcript.\\n   347Ôćĺ\\tRewind(point RewindPoint) error\\n   348Ôćĺ\\n   349Ôćĺ\\t// CanRewind checks if rewinding is currently possible.\\n   350Ôćĺ\\t// Returns (canRewind, reason if not, error)\\n   351Ôćĺ\\tCanRewind() (bool, string, error)\\n   352Ôćĺ\\n   353Ôćĺ\\t// PreviewRewind returns what will happen if rewinding to the given point.\\n   354Ôćĺ\\t// This allows showing warnings about files that will be deleted before the rewind.\\n   355Ôćĺ\\t// Returns nil if preview is not supported (e.g., auto-commit strategy).\\n   356Ôćĺ\\tPreviewRewind(point RewindPoint) (*RewindPreview, error)\\n   357Ôćĺ\\n   358Ôćĺ\\t// GetTaskCheckpoint returns the task checkpoint for a given rewind point.\\n   359Ôćĺ\\t// For strategies that store checkpoints in git (auto-commit), this reads from the branch.\\n   360Ôćĺ\\t// For strategies that store checkpoints on disk (commit, manual-commit), this reads from the filesystem.\\n   361Ôćĺ\\t// Returns nil, nil if not a task checkpoint or checkpoint not found.\\n   362Ôćĺ\\tGetTaskCheckpoint(point RewindPoint) (*TaskCheckpoint, error)\\n   363Ôćĺ\\n   364Ôćĺ\\t// GetTaskCheckpointTranscript returns the session transcript for a task checkpoint.\\n   365Ôćĺ\\t// For strategies that store transcripts in git (auto-commit), this reads from the branch.\\n   366Ôćĺ\\t// For strategies that store transcripts on disk (commit, manual-commit), this reads from the filesystem.\\n   367Ôćĺ\\tGetTaskCheckpointTranscript(point RewindPoint) ([]byte, error)\\n   368Ôćĺ\\n   369Ôćĺ\\t// GetSessionInfo returns session information for linking commits.\\n   370Ôćĺ\\t// This is used by the context command to generate trailers.\\n   371Ôćĺ\\t// Returns ErrNoSession if no session info is available.\\n   372Ôćĺ\\tGetSessionInfo() (*SessionInfo, error)\\n   373Ôćĺ\\n   374Ôćĺ\\t// EnsureSetup ensures the strategy's required setup is in place,\\n   375Ôćĺ\\t// installing any missing pieces (git hooks, gitignore entries, etc.).\\n   376Ôćĺ\\t// Returns nil if setup is complete or was successfully installed.\\n   377Ôćĺ\\tEnsureSetup() error\\n   378Ôćĺ\\n   379Ôćĺ\\t// NOTE: ListSessions and GetSession are standalone functions in session.go.\\n   380Ôćĺ\\t// They read from entire/checkpoints/v1 and merge with SessionSource if implemented.\\n   381Ôćĺ\\n   382Ôćĺ\\t// GetMetadataRef returns a reference to the metadata commit for the given checkpoint.\\n   383Ôćĺ\\t// Format: \\\"<branch>@<commit-sha>\\\" (e.g., \\\"entire/checkpoints/v1@abc123\\\").\\n   384Ôćĺ\\t// Returns empty string if not applicable (e.g., commit strategy with filesystem metadata).\\n   385Ôćĺ\\tGetMetadataRef(checkpoint Checkpoint) string\\n   386Ôćĺ\\n   387Ôćĺ\\t// GetSessionMetadataRef returns a reference to the most recent metadata commit for a session.\\n   388Ôćĺ\\t// Format: \\\"<branch>@<commit-sha>\\\" (e.g., \\\"entire/checkpoints/v1@abc123\\\").\\n   389Ôćĺ\\t// Returns empty string if not applicable or session not found.\\n   390Ôćĺ\\tGetSessionMetadataRef(sessionID string) string\\n   391Ôćĺ\\n   392Ôćĺ\\t// GetSessionContext returns the context.md content for a session.\\n   393Ôćĺ\\t// Returns empty string if not available.\\n   394Ôćĺ\\tGetSessionContext(sessionID string) string\\n   395Ôćĺ\\n   396Ôćĺ\\t// GetCheckpointLog returns the session transcript for a specific checkpoint.\\n   397Ôćĺ\\t// For strategies that store transcripts in git branches (auto-commit, manual-commit),\\n   398Ôćĺ\\t// this reads from the checkpoint's commit tree.\\n   399Ôćĺ\\t// For strategies that store on disk (commit), reads from the filesystem.\\n   400Ôćĺ\\t// Returns ErrNoMetadata if transcript is not available.\\n   401Ôćĺ\\tGetCheckpointLog(checkpoint Checkpoint) ([]byte, error)\\n   402Ôćĺ}\\n   403Ôćĺ\\n   404Ôćĺ// SessionInitializer is an optional interface for strategies that need to\\n   405Ôćĺ// initialize session state when a user prompt is submitted.\\n   406Ôćĺ// Strategies like manual-commit use this to create session state files that\\n   407Ôćĺ// the git prepare-commit-msg hook can detect.\\n   408Ôćĺtype SessionInitializer interface {\\n   409Ôćĺ\\t// InitializeSession creates session state for a new session.\\n   410Ôćĺ\\t// Called during UserPromptSubmit hook before any checkpoints are created.\\n   411Ôćĺ\\t// agentType is the human-readable name of the agent (e.g., \\\"Claude Code\\\").\\n   412Ôćĺ\\t// transcriptPath is the path to the live transcript file (for mid-session commit detection).\\n   413Ôćĺ\\t// userPrompt is the user's prompt text (stored truncated as FirstPrompt for display).\\n   414Ôćĺ\\tInitializeSession(sessionID string, agentType agent.AgentType, transcriptPath string, userPrompt string) error\\n   415Ôćĺ}\\n   416Ôćĺ\\n   417Ôćĺ// PrepareCommitMsgHandler is an optional interface for strategies that need to\\n   418Ôćĺ// handle the git prepare-commit-msg hook.\\n   419Ôćĺtype PrepareCommitMsgHandler interface {\\n   420Ôćĺ\\t// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   421Ôćĺ\\t// It can modify the commit message file to add trailers, etc.\\n   422Ôćĺ\\t// The source parameter indicates how the commit was initiated:\\n   423Ôćĺ\\t//   - \\\"\\\" or \\\"template\\\": normal editor flow\\n   424Ôćĺ\\t//   - \\\"message\\\": using -m or -F flag\\n   425Ôćĺ\\t//   - \\\"merge\\\": merge commit\\n   426Ôćĺ\\t//   - \\\"squash\\\": squash merge\\n   427Ôćĺ\\t//   - \\\"commit\\\": amend with -c/-C\\n   428Ôćĺ\\t// Should return nil on errors to not block commits (log warnings to stderr).\\n   429Ôćĺ\\tPrepareCommitMsg(commitMsgFile string, source string) error\\n   430Ôćĺ}\\n   431Ôćĺ\\n   432Ôćĺ// PostCommitHandler is an optional interface for strategies that need to\\n   433Ôćĺ// handle the git post-commit hook.\\n   434Ôćĺtype PostCommitHandler interface {\\n   435Ôćĺ\\t// PostCommit is called by the git post-commit hook after a commit is created.\\n   436Ôćĺ\\t// Used to perform actions like condensing session data after commits.\\n   437Ôćĺ\\t// Should return nil on errors to not block subsequent operations (log warnings to stderr).\\n   438Ôćĺ\\tPostCommit() error\\n   439Ôćĺ}\\n   440Ôćĺ\\n   441Ôćĺ// CommitMsgHandler is an optional interface for strategies that need to\\n   442Ôćĺ// handle the git commit-msg hook.\\n   443Ôćĺtype CommitMsgHandler interface {\\n   444Ôćĺ\\t// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   445Ôćĺ\\t// Used to validate or modify the final commit message before the commit is created.\\n   446Ôćĺ\\t// If this returns an error, the commit is aborted.\\n   447Ôćĺ\\tCommitMsg(commitMsgFile string) error\\n   448Ôćĺ}\\n   449Ôćĺ\\n   450Ôćĺ// PrePushHandler is an optional interface for strategies that need to\\n   451Ôćĺ// handle the git pre-push hook.\\n   452Ôćĺtype PrePushHandler interface {\\n   453Ôćĺ\\t// PrePush is called by the git pre-push hook before pushing to a remote.\\n   454Ôćĺ\\t// Used to push session branches (e.g., entire/checkpoints/v1) alongside user pushes.\\n   455Ôćĺ\\t// The remote parameter is the name of the remote being pushed to.\\n   456Ôćĺ\\t// Should return nil on errors to not block pushes (log warnings to stderr).\\n   457Ôćĺ\\tPrePush(remote string) error\\n   458Ôćĺ}\\n   459Ôćĺ\\n   460Ôćĺ// TurnEndHandler is an optional interface for strategies that need to\\n   461Ôćĺ// perform work when an agent turn ends (ACTIVE Ôćĺ IDLE).\\n   462Ôćĺ// For example, manual-commit strategy uses this to finalize checkpoints\\n   463Ôćĺ// with the full session transcript.\\n   464Ôćĺtype TurnEndHandler interface {\\n   465Ôćĺ\\t// HandleTurnEnd performs strategy-specific cleanup at the end of a turn.\\n   466Ôćĺ\\t// Work items are read from state (e.g. TurnCheckpointIDs), not from the\\n   467Ôćĺ\\t// action list. The state has already been updated by ApplyTransition;\\n   468Ôćĺ\\t// the caller saves it after this method returns.\\n   469Ôćĺ\\tHandleTurnEnd(state *session.State) error\\n   470Ôćĺ}\\n   471Ôćĺ\\n   472Ôćĺ// RestoredSession describes a single session that was restored by RestoreLogsOnly.\\n   473Ôćĺ// Each session may come from a different agent, so callers use this to print\\n   474Ôćĺ// per-session resume commands without re-reading the metadata tree.\\n   475Ôćĺtype RestoredSession struct {\\n   476Ôćĺ\\tSessionID string\\n   477Ôćĺ\\tAgent     agent.AgentType\\n   478Ôćĺ\\tPrompt    string\\n   479Ôćĺ}\\n   480Ôćĺ\\n   481Ôćĺ// LogsOnlyRestorer is an optional interface for strategies that support\\n   482Ôćĺ// restoring session logs without file state restoration.\\n   483Ôćĺ// This is used for \\\"logs-only\\\" rewind points where only the session transcript\\n   484Ôćĺ// can be restored (file state requires git checkout).\\n   485Ôćĺtype LogsOnlyRestorer interface {\\n   486Ôćĺ\\t// RestoreLogsOnly restores session logs from a logs-only rewind point.\\n   487Ôćĺ\\t// Does not modify the working directory - only restores the transcript\\n   488Ôćĺ\\t// to the agent's session directory (determined per-session from checkpoint metadata).\\n   489Ôćĺ\\t// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   490Ôćĺ\\t// Returns info about each restored session so callers can print correct resume commands.\\n   491Ôćĺ\\tRestoreLogsOnly(point RewindPoint, force bool) ([]RestoredSession, error)\\n   492Ôćĺ}\\n   493Ôćĺ\\n   494Ôćĺ// SessionResetter is an optional interface for strategies that support\\n   495Ôćĺ// resetting session state and shadow branches.\\n   496Ôćĺ// This is used by the \\\"reset\\\" command to clean up shadow branches\\n   497Ôćĺ// and session state when a user wants to start fresh.\\n   498Ôćĺtype SessionResetter interface {\\n   499Ôćĺ\\t// Reset deletes the shadow branch and session state for the current HEAD.\\n   500Ôćĺ\\t// Returns nil if there's nothing to reset (no shadow branch).\\n   501Ôćĺ\\tReset() error\\n   502Ôćĺ\\n   503Ôćĺ\\t// ResetSession clears the state for a single session and cleans up\\n   504Ôćĺ\\t// the shadow branch if no other sessions reference it.\\n   505Ôćĺ\\t// File changes remain in the working directory.\\n   506Ôćĺ\\tResetSession(sessionID string) error\\n   507Ôćĺ}\\n   508Ôćĺ\\n   509Ôćĺ// SessionCondenser is an optional interface for strategies that support\\n   510Ôćĺ// force-condensing a session. This is used by \\\"entire doctor\\\" to\\n   511Ôćĺ// salvage stuck sessions by condensing their data to permanent storage.\\n   512Ôćĺtype SessionCondenser interface {\\n   513Ôćĺ\\t// CondenseSessionByID force-condenses a session and cleans up.\\n   514Ôćĺ\\t// Generates a new checkpoint ID, condenses to entire/checkpoints/v1,\\n   515Ôćĺ\\t// updates the session state, and removes the shadow branch\\n   516Ôćĺ\\t// if no other active sessions need it.\\n   517Ôćĺ\\tCondenseSessionByID(sessionID string) error\\n   518Ôćĺ}\\n   519Ôćĺ\\n   520Ôćĺ// ConcurrentSessionChecker is an optional interface for strategies that support\\n   521Ôćĺ// counting concurrent sessions with uncommitted changes.\\n   522Ôćĺ// This is used by the SessionStart hook to show an informational message about\\n   523Ôćĺ// how many other active conversations will be included in the next commit.\\n   524Ôćĺtype ConcurrentSessionChecker interface {\\n   525Ôćĺ\\t// CountOtherActiveSessionsWithCheckpoints returns the number of other active sessions\\n   526Ôćĺ\\t// with uncommitted checkpoints on the same base commit.\\n   527Ôćĺ\\t// Returns 0, nil if no such sessions exist.\\n   528Ôćĺ\\tCountOtherActiveSessionsWithCheckpoints(currentSessionID string) (int, error)\\n   529Ôćĺ}\\n   530Ôćĺ\\n   531Ôćĺ// SessionSource is an optional interface for strategies that provide additional\\n   532Ôćĺ// sessions beyond those stored on the entire/checkpoints/v1 branch.\\n   53