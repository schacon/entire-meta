c handleLifecycleSessionStart(ag agent.Agent, event *agent.Event) error {\\n    62Ôćĺ\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n    63Ôćĺ\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    64Ôćĺ\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    65Ôćĺ\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    66Ôćĺ\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    67Ôćĺ\\t)\\n    68Ôćĺ\\n    69Ôćĺ\\tif event.SessionID == \\\"\\\" {\\n    70Ôćĺ\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    71Ôćĺ\\t}\\n    72Ôćĺ\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    73Ôćĺ\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    74Ôćĺ\\t}\\n    75Ôćĺ\\n    76Ôćĺ\\t// Build informational message\\n    77Ôćĺ\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    78Ôćĺ\\n    79Ôćĺ\\t// Check for concurrent sessions and append count if any\\n    80Ôćĺ\\tstrat := GetStrategy()\\n    81Ôćĺ\\tif concurrentChecker, ok := strat.(strategy.ConcurrentSessionChecker); ok {\\n    82Ôćĺ\\t\\tif count, err := concurrentChecker.CountOtherActiveSessionsWithCheckpoints(event.SessionID); err == nil && count > 0 {\\n    83Ôćĺ\\t\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    84Ôćĺ\\t\\t}\\n    85Ôćĺ\\t}\\n    86Ôćĺ\\n    87Ôćĺ\\t// Output informational message\\n    88Ôćĺ\\tif event.ResponseMessage != \\\"\\\" {\\n    89Ôćĺ\\t\\tmessage = event.ResponseMessage\\n    90Ôćĺ\\t}\\n    91Ôćĺ\\tif err := outputHookResponse(message); err != nil {\\n    92Ôćĺ\\t\\treturn err\\n    93Ôćĺ\\t}\\n    94Ôćĺ\\n    95Ôćĺ\\t// Fire EventSessionStart for the current session (if state exists).\\n    96Ôćĺ\\tif state, loadErr := strategy.LoadSessionState(event.SessionID); loadErr != nil {\\n    97Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state on start: %v\\\\n\\\", loadErr)\\n    98Ôćĺ\\t} else if state != nil {\\n    99Ôćĺ\\t\\tif transErr := strategy.TransitionAndLog(state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   100Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: session start transition failed: %v\\\\n\\\", transErr)\\n   101Ôćĺ\\t\\t}\\n   102Ôćĺ\\t\\tif saveErr := strategy.SaveSessionState(state); saveErr != nil {\\n   103Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session state on start: %v\\\\n\\\", saveErr)\\n   104Ôćĺ\\t\\t}\\n   105Ôćĺ\\t}\\n   106Ôćĺ\\n   107Ôćĺ\\treturn nil\\n   108Ôćĺ}\\n   109Ôćĺ\\n   110Ôćĺ// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   111Ôćĺ// ensures strategy setup, initializes session.\\n   112Ôćĺfunc handleLifecycleTurnStart(ag agent.Agent, event *agent.Event) error {\\n   113Ôćĺ\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   114Ôćĺ\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   115Ôćĺ\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   116Ôćĺ\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   117Ôćĺ\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   118Ôćĺ\\t)\\n   119Ôćĺ\\n   120Ôćĺ\\tsessionID := event.SessionID\\n   121Ôćĺ\\tif sessionID == \\\"\\\" {\\n   122Ôćĺ\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   123Ôćĺ\\t}\\n   124Ôćĺ\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   125Ôćĺ\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   126Ôćĺ\\t}\\n   127Ôćĺ\\n   128Ôćĺ\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   129Ôćĺ\\tif err := CapturePrePromptState(ag, sessionID, event.SessionRef); err != nil {\\n   130Ôćĺ\\t\\treturn err\\n   131Ôćĺ\\t}\\n   132Ôćĺ\\n   133Ôćĺ\\t// Ensure strategy setup and initialize session\\n   134Ôćĺ\\tstrat := GetStrategy()\\n   135Ôćĺ\\n   136Ôćĺ\\tif err := strat.EnsureSetup(); err != nil {\\n   137Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to ensure strategy setup: %v\\\\n\\\", err)\\n   138Ôćĺ\\t}\\n   139Ôćĺ\\n   140Ôćĺ\\tif initializer, ok := strat.(strategy.SessionInitializer); ok {\\n   141Ôćĺ\\t\\tagentType := ag.Type()\\n   142Ôćĺ\\t\\tif err := initializer.InitializeSession(sessionID, agentType, event.SessionRef, event.Prompt); err != nil {\\n   143Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to initialize session state: %v\\\\n\\\", err)\\n   144Ôćĺ\\t\\t}\\n   145Ôćĺ\\t}\\n   146Ôćĺ\\n   147Ôćĺ\\treturn nil\\n   148Ôćĺ}\\n   149Ôćĺ\\n   150Ôćĺ// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   151Ôćĺ// detects file changes, saves step + checkpoint, transitions phase.\\n   152Ôćĺ//\\n   153Ôćĺ//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   154Ôćĺfunc handleLifecycleTurnEnd(ag agent.Agent, event *agent.Event) error {\\n   155Ôćĺ\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   156Ôćĺ\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   157Ôćĺ\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   158Ôćĺ\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   159Ôćĺ\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   160Ôćĺ\\t)\\n   161Ôćĺ\\n   162Ôćĺ\\tsessionID := event.SessionID\\n   163Ôćĺ\\tif sessionID == \\\"\\\" {\\n   164Ôćĺ\\t\\tsessionID = unknownSessionID\\n   165Ôćĺ\\t}\\n   166Ôćĺ\\n   167Ôćĺ\\ttranscriptRef := event.SessionRef\\n   168Ôćĺ\\tif transcriptRef == \\\"\\\" {\\n   169Ôćĺ\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   170Ôćĺ\\t}\\n   171Ôćĺ\\tif !fileExists(transcriptRef) {\\n   172Ôćĺ\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   173Ôćĺ\\t}\\n   174Ôćĺ\\n   175Ôćĺ\\t// Early check: bail out quickly if the repo has no commits yet.\\n   176Ôćĺ\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n   177Ôćĺ\\t\\tfmt.Fprintln(os.Stderr, \\\"Entire: skipping checkpoint. Will activate after first commit.\\\")\\n   178Ôćĺ\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   179Ôćĺ\\t}\\n   180Ôćĺ\\n   181Ôćĺ\\t// Create session metadata directory\\n   182Ôćĺ\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   183Ôćĺ\\tsessionDirAbs, err := paths.AbsPath(sessionDir)\\n   184Ôćĺ\\tif err != nil {\\n   185Ôćĺ\\t\\tsessionDirAbs = sessionDir\\n   186Ôćĺ\\t}\\n   187Ôćĺ\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   188Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   189Ôćĺ\\t}\\n   190Ôćĺ\\n   191Ôćĺ\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n   192Ôćĺ\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n   193Ôćĺ\\t\\tif err := preparer.PrepareTranscript(transcriptRef); err != nil {\\n   194Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to prepare transcript: %v\\\\n\\\", err)\\n   195Ôćĺ\\t\\t}\\n   196Ôćĺ\\t}\\n   197Ôćĺ\\n   198Ôćĺ\\t// Copy transcript to session directory\\n   199Ôćĺ\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   200Ôćĺ\\tif err != nil {\\n   201Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   202Ôćĺ\\t}\\n   203Ôćĺ\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   204Ôćĺ\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   205Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   206Ôćĺ\\t}\\n   207Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"Copied transcript to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName)\\n   208Ôćĺ\\n   209Ôćĺ\\t// Load pre-prompt state (captured on TurnStart)\\n   210Ôćĺ\\tpreState, err := LoadPrePromptState(sessionID)\\n   211Ôćĺ\\tif err != nil {\\n   212Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-prompt state: %v\\\\n\\\", err)\\n   213Ôćĺ\\t}\\n   214Ôćĺ\\n   215Ôćĺ\\t// Determine transcript offset\\n   216Ôćĺ\\ttranscriptOffset := resolveTranscriptOffset(preState, sessionID)\\n   217Ôćĺ\\n   218Ôćĺ\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n   219Ôćĺ\\tvar allPrompts []string\\n   220Ôćĺ\\tvar summary string\\n   221Ôćĺ\\tvar modifiedFiles []string\\n   222Ôćĺ\\tvar newTranscriptPosition int\\n   223Ôćĺ\\n   224Ôćĺ\\t// Compute subagents directory for agents that support subagent extraction.\\n   225Ôćĺ\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   226Ôćĺ\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   227Ôćĺ\\n   228Ôćĺ\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   229Ôćĺ\\t\\t// Extract prompts\\n   230Ôćĺ\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n   231Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract prompts: %v\\\\n\\\", promptErr)\\n   232Ôćĺ\\t\\t} else {\\n   233Ôćĺ\\t\\t\\tallPrompts = prompts\\n   234Ôćĺ\\t\\t}\\n   235Ôćĺ\\n   236Ôćĺ\\t\\t// Extract summary\\n   237Ôćĺ\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n   238Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract summary: %v\\\\n\\\", sumErr)\\n   239Ôćĺ\\t\\t} else {\\n   240Ôćĺ\\t\\t\\tsummary = s\\n   241Ôćĺ\\t\\t}\\n   242Ôćĺ\\n   243Ôćĺ\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   244Ôćĺ\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n   245Ôćĺ\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptRef, transcriptOffset, subagentsDir); fileErr != nil {\\n   246Ôćĺ\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files (with subagents): %v\\\\n\\\", fileErr)\\n   247Ôćĺ\\t\\t\\t} else {\\n   248Ôćĺ\\t\\t\\t\\tmodifiedFiles = files\\n   249Ôćĺ\\t\\t\\t}\\n   250Ôćĺ\\t\\t\\t// Get position from basic analyzer\\n   251Ôćĺ\\t\\t\\tif _, pos, posErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); posErr == nil {\\n   252Ôćĺ\\t\\t\\t\\tnewTranscriptPosition = pos\\n   253Ôćĺ\\t\\t\\t}\\n   254Ôćĺ\\t\\t} else {\\n   255Ôćĺ\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   256Ôćĺ\\t\\t\\tif files, pos, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   257Ôćĺ\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files: %v\\\\n\\\", fileErr)\\n   258Ôćĺ\\t\\t\\t} else {\\n   259Ôćĺ\\t\\t\\t\\tmodifiedFiles = files\\n   260Ôćĺ\\t\\t\\t\\tnewTranscriptPosition = pos\\n   261Ôćĺ\\t\\t\\t}\\n   262Ôćĺ\\t\\t}\\n   263Ôćĺ\\t}\\n   264Ôćĺ\\n   265Ôćĺ\\t// Write prompts file\\n   266Ôćĺ\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   267Ôćĺ\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   268Ôćĺ\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   269Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   270Ôćĺ\\t}\\n   271Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"Extracted %d prompt(s) to: %s\\\\n\\\", len(allPrompts), sessionDir+\\\"/\\\"+paths.PromptFileName)\\n   272Ôćĺ\\n   273Ôćĺ\\t// Write summary file\\n   274Ôćĺ\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   275Ôćĺ\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   276Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   277Ôćĺ\\t}\\n   278Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"Extracted summary to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName)\\n   279Ôćĺ\\n   280Ôćĺ\\t// Generate commit message from last prompt\\n   281Ôćĺ\\tlastPrompt := \\\"\\\"\\n   282Ôćĺ\\tif len(allPrompts) > 0 {\\n   283Ôćĺ\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   284Ôćĺ\\t}\\n   285Ôćĺ\\tcommitMessage := generateCommitMessage(lastPrompt)\\n   286Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"Using commit message: %s\\\\n\\\", commitMessage)\\n   287Ôćĺ\\n   288Ôćĺ\\t// Get repo root for path normalization\\n   289Ôćĺ\\trepoRoot, err := paths.RepoRoot()\\n   290Ôćĺ\\tif err != nil {\\n   291Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   292Ôćĺ\\t}\\n   293Ôćĺ\\n   294Ôćĺ\\tvar preUntrackedFiles []string\\n   295Ôćĺ\\tif preState != nil {\\n   296Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state: %d pre-existing untracked files\\\\n\\\", len(preState.UntrackedFiles))\\n   297Ôćĺ\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   298Ôćĺ\\t}\\n   299Ôćĺ\\n   300Ôćĺ\\t// Detect file changes via git status\\n   301Ôćĺ\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n   302Ôćĺ\\tif err != nil {\\n   303Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   304Ôćĺ\\t}\\n   305Ôćĺ\\n   306Ôćĺ\\t// Filter and normalize all paths\\n   307Ôćĺ\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   308Ôćĺ\\tvar relNewFiles, relDeletedFiles []string\\n   309Ôćĺ\\tif changes != nil {\\n   310Ôćĺ\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   311Ôćĺ\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   312Ôćĺ\\t}\\n   313Ôćĺ\\n   314Ôćĺ\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   315Ôćĺ\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   316Ôćĺ\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   317Ôćĺ\\t// if it exists in HEAD with the same content as the working tree.\\n   318Ôćĺ\\trelModifiedFiles = filterToUncommittedFiles(relModifiedFiles, repoRoot)\\n   319Ôćĺ\\n   320Ôćĺ\\t// Check if there are any changes\\n   321Ôćĺ\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   322Ôćĺ\\tif totalChanges == 0 {\\n   323Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"No files were modified during this session\\\\n\\\")\\n   324Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipping commit\\\\n\\\")\\n   325Ôćĺ\\t\\ttransitionSessionTurnEnd(sessionID)\\n   326Ôćĺ\\t\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n   327Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   328Ôćĺ\\t\\t}\\n   329Ôćĺ\\t\\treturn nil\\n   330Ôćĺ\\t}\\n   331Ôćĺ\\n   332Ôćĺ\\t// Log file changes\\n   333Ôćĺ\\tlogFileChanges(relModifiedFiles, relNewFiles, relDeletedFiles)\\n   334Ôćĺ\\n   335Ôćĺ\\t// Create context file\\n   336Ôćĺ\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n   337Ôćĺ\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n   338Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n   339Ôćĺ\\t}\\n   340Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"Created context file: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.ContextFileName)\\n   341Ôćĺ\\n   342Ôćĺ\\t// Get git author\\n   343Ôćĺ\\tauthor, err := GetGitAuthor()\\n   344Ôćĺ\\tif err != nil {\\n   345Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   346Ôćĺ\\t}\\n   347Ôćĺ\\n   348Ôćĺ\\t// Get strategy and agent type\\n   349Ôćĺ\\tstrat := GetStrategy()\\n   350Ôćĺ\\tagentType := ag.Type()\\n   351Ôćĺ\\n   352Ôćĺ\\t// Get transcript position/identifier from pre-prompt state\\n   353Ôćĺ\\tvar transcriptIdentifierAtStart string\\n   354Ôćĺ\\tvar transcriptLinesAtStart int\\n   355Ôćĺ\\tif preState != nil {\\n   356Ôćĺ\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   357Ôćĺ\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   358Ôćĺ\\t}\\n   359Ôćĺ\\n   360Ôćĺ\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   361Ôćĺ\\tvar tokenUsage *agent.TokenUsage\\n   362Ôćĺ\\tif subagentExtractor, ok := ag.(agent.SubagentAwareExtractor); ok {\\n   363Ôćĺ\\t\\tusage, tokenErr := subagentExtractor.CalculateTotalTokenUsage(transcriptRef, transcriptLinesAtStart, subagentsDir)\\n   364Ôćĺ\\t\\tif tokenErr != nil {\\n   365Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage (with subagents): %v\\\\n\\\", tokenErr)\\n   366Ôćĺ\\t\\t} else {\\n   367Ôćĺ\\t\\t\\ttokenUsage = usage\\n   368Ôćĺ\\t\\t}\\n   369Ôćĺ\\t} else if calculator, ok := ag.(agent.TokenCalculator); ok {\\n   370Ôćĺ\\t\\t// Fall back to basic token calculation (main transcript only)\\n   371Ôćĺ\\t\\tusage, tokenErr := calculator.CalculateTokenUsage(transcriptRef, transcriptLinesAtStart)\\n   372Ôćĺ\\t\\tif tokenErr != nil {\\n   373Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage: %v\\\\n\\\", tokenErr)\\n   374Ôćĺ\\t\\t} else {\\n   375Ôćĺ\\t\\t\\ttokenUsage = usage\\n   376Ôćĺ\\t\\t}\\n   377Ôćĺ\\t}\\n   378Ôćĺ\\n   379Ôćĺ\\t// Build fully-populated step context and delegate to strategy\\n   380Ôćĺ\\tctx := strategy.StepContext{\\n   381Ôćĺ\\t\\tSessionID:                sessionID,\\n   382Ôćĺ\\t\\tModifiedFiles:            relModifiedFiles,\\n   383Ôćĺ\\t\\tNewFiles:                 relNewFiles,\\n   384Ôćĺ\\t\\tDeletedFiles:             relDeletedFiles,\\n   385Ôćĺ\\t\\tMetadataDir:              sessionDir,\\n   386Ôćĺ\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   387Ôćĺ\\t\\tCommitMessage:            commitMessage,\\n   388Ôćĺ\\t\\tTranscriptPath:           transcriptRef,\\n   389Ôćĺ\\t\\tAuthorName:               author.Name,\\n   390Ôćĺ\\t\\tAuthorEmail:              author.Email,\\n   391Ôćĺ\\t\\tAgentType:                agentType,\\n   392Ôćĺ\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   393Ôćĺ\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   394Ôćĺ\\t\\tTokenUsage:               tokenUsage,\\n   395Ôćĺ\\t}\\n   396Ôćĺ\\n   397Ôćĺ\\tif err := strat.SaveStep(ctx); err != nil {\\n   398Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   399Ôćĺ\\t}\\n   400Ôćĺ\\n   401Ôćĺ\\t// Update session state transcript position for auto-commit strategy\\n   402Ôćĺ\\tif strat.Name() == strategy.StrategyNameAutoCommit && newTranscriptPosition > 0 {\\n   403Ôćĺ\\t\\tupdateAutoCommitTranscriptPosition(sessionID, newTranscriptPosition)\\n   404Ôćĺ\\t}\\n   405Ôćĺ\\n   406Ôćĺ\\t// Transition session phase and cleanup\\n   407Ôćĺ\\ttransitionSessionTurnEnd(sessionID)\\n   408Ôćĺ\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n   409Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   410Ôćĺ\\t}\\n   411Ôćĺ\\n   412Ôćĺ\\treturn nil\\n   413Ôćĺ}\\n   414Ôćĺ\\n   415Ôćĺ// handleLifecycleCompaction handles context compaction: saves current progress\\n   416Ôćĺ// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   417Ôćĺ// Also resets the transcript offset since the transcript may be truncated.\\n   418Ôćĺfunc handleLifecycleCompaction(ag agent.Agent, event *agent.Event) error {\\n   419Ôćĺ\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   420Ôćĺ\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   421Ôćĺ\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   422Ôćĺ\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   423Ôćĺ\\t)\\n   424Ôćĺ\\n   425Ôćĺ\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   426Ôćĺ\\tsessionID := event.SessionID\\n   427Ôćĺ\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   428Ôćĺ\\tif loadErr != nil {\\n   429Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for compaction: %v\\\\n\\\", loadErr)\\n   430Ôćĺ\\t}\\n   431Ôćĺ\\tif sessionState != nil {\\n   432Ôćĺ\\t\\tif transErr := strategy.TransitionAndLog(sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   433Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: compaction transition failed: %v\\\\n\\\", transErr)\\n   434Ôćĺ\\t\\t}\\n   435Ôćĺ\\n   436Ôćĺ\\t\\t// Reset transcript offset since the transcript may be truncated/reorganized\\n   437Ôćĺ\\t\\tsessionState.CheckpointTranscriptStart = 0\\n   438Ôćĺ\\n   439Ôćĺ\\t\\tif saveErr := strategy.SaveSessionState(sessionState); saveErr != nil {\\n   440Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to save session state after compaction: %v\\\\n\\\", saveErr)\\n   441Ôćĺ\\t\\t}\\n   442Ôćĺ\\t}\\n   443Ôćĺ\\n   444Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"Context compaction: transcript offset reset\\\\n\\\")\\n   445Ôćĺ\\treturn nil\\n   446Ôćĺ}\\n   447Ôćĺ\\n   448Ôćĺ// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   449Ôćĺfunc handleLifecycleSessionEnd(ag agent.Agent, event *agent.Event) error {\\n   450Ôćĺ\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   451Ôćĺ\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   452Ôćĺ\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   453Ôćĺ\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   454Ôćĺ\\t)\\n   455Ôćĺ\\n   456Ôćĺ\\tif event.SessionID == \\\"\\\" {\\n   457Ôćĺ\\t\\treturn nil // No session to update\\n   458Ôćĺ\\t}\\n   459Ôćĺ\\n   460Ôćĺ\\tif err := markSessionEnded(event.SessionID); err != nil {\\n   461Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to mark session ended: %v\\\\n\\\", err)\\n   462Ôćĺ\\t}\\n   463Ôćĺ\\treturn nil\\n   464Ôćĺ}\\n   465Ôćĺ\\n   466Ôćĺ// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   467Ôćĺfunc handleLifecycleSubagentStart(ag agent.Agent, event *agent.Event) error {\\n   468Ôćĺ\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   469Ôćĺ\\tlogging.Info(logCtx, \\\"subagent-start\\\",\\n   470Ôćĺ\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   471Ôćĺ\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   472Ôćĺ\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   473Ôćĺ\\t)\\n   474Ôćĺ\\n   475Ôćĺ\\t// Log context\\n   476Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent started\\\\n\\\")\\n   477Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n   478Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n   479Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"  Transcript: %s\\\\n\\\", event.SessionRef)\\n   480Ôćĺ\\n   481Ôćĺ\\t// Capture pre-task state\\n   482Ôćĺ\\tif err := CapturePreTaskState(event.ToolUseID); err != nil {\\n   483Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   484Ôćĺ\\t}\\n   485Ôćĺ\\n   486Ôćĺ\\treturn nil\\n   487Ôćĺ}\\n   488Ôćĺ\\n   489Ôćĺ// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   490Ôćĺfunc handleLifecycleSubagentEnd(ag agent.Agent, event *agent.Event) error {\\n   491Ôćĺ\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   492Ôćĺ\\tlogging.Info(logCtx, \\\"subagent-end\\\",\\n   493Ôćĺ\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   494Ôćĺ\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   495Ôćĺ\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   496Ôćĺ\\t\\tslog.String(\\\"subagent_id\\\", event.SubagentID),\\n   497Ôćĺ\\t)\\n   498Ôćĺ\\n   499Ôćĺ\\t// Extract subagent type and description from tool input\\n   500Ôćĺ\\tsubagentType, taskDescription := ParseSubagentTypeAndDescription(event.ToolInput)\\n   501Ôćĺ\\n   502Ôćĺ\\t// Determine subagent transcript path\\n   503Ôćĺ\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   504Ôćĺ\\tvar subagentTranscriptPath string\\n   505Ôćĺ\\tif event.SubagentID != \\\"\\\" {\\n   506Ôćĺ\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   507Ôćĺ\\t\\tif !fileExists(subagentTranscriptPath) {\\n   508Ôćĺ\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   509Ôćĺ\\t\\t}\\n   510Ôćĺ\\t}\\n   511Ôćĺ\\n   512Ôćĺ\\t// Log context\\n   513Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent completed\\\\n\\\")\\n   514Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n   515Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n   516Ôćĺ\\tif event.SubagentID != \\\"\\\" {\\n   517Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"  Agent ID: %s\\\\n\\\", event.SubagentID)\\n   518Ôćĺ\\t}\\n   519Ôćĺ\\tif subagentTranscriptPath != \\\"\\\" {\\n   520Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"  Subagent Transcript: %s\\\\n\\\", subagentTranscriptPath)\\n   521Ôćĺ\\t}\\n   522Ôćĺ\\n   523Ôćĺ\\t// Extract modified files from subagent transcript\\n   524Ôćĺ\\tvar modifiedFiles []string\\n   525Ôćĺ\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   526Ôćĺ\\t\\ttranscriptToScan := event.SessionRef\\n   527Ôćĺ\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n   528Ôćĺ\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n   529Ôćĺ\\t\\t}\\n   530Ôćĺ\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n   531Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files from subagent: %v\\\\n\\\", fileErr)\\n   532Ôćĺ\\t\\t} else {\\n   533Ôćĺ\\t\\t\\tmodifiedFiles = files\\n   534Ôćĺ\\t\\t}\\n   535Ôćĺ\\t}\\n   536Ôćĺ\\n   537Ôćĺ\\t// Load pre-task state and detect file changes\\n   538Ôćĺ\\tpreState, err := LoadPreTaskState(event.ToolUseID)\\n   539Ôćĺ\\tif err != nil {\\n   540Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-task state: %v\\\\n\\\", err)\\n   541Ôćĺ\\t}\\n   542Ôćĺ\\tchanges, err := DetectFileChanges(preState.PreUntrackedFiles())\\n   543Ôćĺ\\tif err != nil {\\n   544Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   545Ôćĺ\\t}\\n   546Ôćĺ\\n   547Ôćĺ\\t// Get repo root and normalize paths\\n   548Ôćĺ\\trepoRoot, err := paths.RepoRoot()\\n   549Ôćĺ\\tif err != nil {\\n   550Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   551Ôćĺ\\t}\\n   552Ôćĺ\\n   553Ôćĺ\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   554Ôćĺ\\tvar relNewFiles, relDeletedFiles []string\\n   555Ôćĺ\\tif changes != nil {\\n   556Ôćĺ\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   557Ôćĺ\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   558Ôćĺ\\t}\\n   559Ôćĺ\\n   560Ôćĺ\\t// If no changes, skip\\n   561Ôćĺ\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n   562Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] No file changes detected, skipping task checkpoint\\\\n\\\")\\n   563Ôćĺ\\t\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   564Ôćĺ\\t\\treturn nil\\n   565Ôćĺ\\t}\\n   566Ôćĺ\\n   567Ôćĺ\\t// Find checkpoint UUID from main transcript (best-effort)\\n   568Ôćĺ\\tvar checkpointUUID string\\n   569Ôćĺ\\t// Use the existing CLI-level checkpoint UUID finder\\n   570Ôćĺ\\tmainLines, _, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n   571Ôćĺ\\tif mainLines != nil {\\n   572Ôćĺ\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n   573Ôćĺ\\t}\\n   574Ôćĺ\\n   575Ôćĺ\\t// Get git author\\n   576Ôćĺ\\tauthor, err := GetGitAuthor()\\n   577Ôćĺ\\tif err != nil {\\n   578Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   579Ôćĺ\\t}\\n   580Ôćĺ\\n   581Ôćĺ\\t// Build task checkpoint context\\n   582Ôćĺ\\tstrat := GetStrategy()\\n   583Ôćĺ\\tagentType := ag.Type()\\n   584Ôćĺ\\n   585Ôćĺ\\tctx := strategy.TaskStepContext{\\n   586Ôćĺ\\t\\tSessionID:              event.SessionID,\\n   587Ôćĺ\\t\\tToolUseID:              event.ToolUseID,\\n   588Ôćĺ\\t\\tAgentID:                event.SubagentID,\\n   589Ôćĺ\\t\\tModifiedFiles:          relModifiedFiles,\\n   590Ôćĺ\\t\\tNewFiles:               relNewFiles,\\n   591Ôćĺ\\t\\tDeletedFiles:           relDeletedFiles,\\n   592Ôćĺ\\t\\tTranscriptPath:         event.SessionRef,\\n   593Ôćĺ\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   594Ôćĺ\\t\\tCheckpointUUID:         checkpointUUID,\\n   595Ôćĺ\\t\\tAuthorName:             author.Name,\\n   596Ôćĺ\\t\\tAuthorEmail:            author.Email,\\n   597Ôćĺ\\t\\tSubagentType:           subagentType,\\n   598Ôćĺ\\t\\tTaskDescription:        taskDescription,\\n   599Ôćĺ\\t\\tAgentType:              agentType,\\n   600Ôćĺ\\t}\\n   601Ôćĺ\\n   602Ôćĺ\\tif err := strat.SaveTaskStep(ctx); err != nil {\\n   603Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n   604Ôćĺ\\t}\\n   605Ôćĺ\\n   606Ôćĺ\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   607Ôćĺ\\treturn nil\\n   608Ôćĺ}\\n   609Ôćĺ\\n   610Ôćĺ// --- Helper functions ---\\n   611Ôćĺ\\n   612Ôćĺ// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n   613Ôćĺ// Prefers pre-prompt state, falls back to session state.\\n   614Ôćĺfunc resolveTranscriptOffset(preState *PrePromptState, sessionID string) int {\\n   615Ôćĺ\\tif preState != nil && preState.TranscriptOffset > 0 {\\n   616Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state found: parsing transcript from offset %d\\\\n\\\", preState.TranscriptOffset)\\n   617Ôćĺ\\t\\treturn preState.TranscriptO