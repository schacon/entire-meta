201Ôćĺ\\n   202Ôćĺ\\t// Get HEAD hash before commit to detect if commitOrHead actually creates a new commit\\n   203Ôćĺ\\t// (commitOrHead returns HEAD hash without error when git.ErrEmptyCommit occurs)\\n   204Ôćĺ\\theadBefore, err := repo.Head()\\n   205Ôćĺ\\tif err != nil {\\n   206Ôćĺ\\t\\treturn commitCodeResult{}, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   207Ôćĺ\\t}\\n   208Ôćĺ\\n   209Ôćĺ\\t// Stage code changes\\n   210Ôćĺ\\tStageFiles(worktree, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles, StageForSession)\\n   211Ôćĺ\\n   212Ôćĺ\\t// Add checkpoint ID trailer to commit message\\n   213Ôćĺ\\tcommitMsg := ctx.CommitMessage + \\\"\\\\n\\\\n\\\" + trailers.CheckpointTrailerKey + \\\": \\\" + checkpointID.String()\\n   214Ôćĺ\\n   215Ôćĺ\\tauthor := &object.Signature{\\n   216Ôćĺ\\t\\tName:  ctx.AuthorName,\\n   217Ôćĺ\\t\\tEmail: ctx.AuthorEmail,\\n   218Ôćĺ\\t\\tWhen:  time.Now(),\\n   219Ôćĺ\\t}\\n   220Ôćĺ\\tcommitHash, err := commitOrHead(repo, worktree, commitMsg, author)\\n   221Ôćĺ\\tif err != nil {\\n   222Ôćĺ\\t\\treturn commitCodeResult{}, err\\n   223Ôćĺ\\t}\\n   224Ôćĺ\\n   225Ôćĺ\\t// Check if a new commit was actually created by comparing with HEAD before\\n   226Ôćĺ\\tcreated := commitHash != headBefore.Hash()\\n   227Ôćĺ\\tif created {\\n   228Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Committed code changes to active branch (%s)\\\\n\\\", commitHash.String()[:7])\\n   229Ôćĺ\\t}\\n   230Ôćĺ\\treturn commitCodeResult{CommitHash: commitHash, Created: created}, nil\\n   231Ôćĺ}\\n   232Ôćĺ\\n   233Ôćĺ// commitMetadataToMetadataBranch commits session metadata to the entire/checkpoints/v1 branch.\\n   234Ôćĺ// Metadata is stored at sharded path: <checkpointID[:2]>/<checkpointID[2:]>/\\n   235Ôćĺ// This allows direct lookup from the checkpoint ID trailer on the code commit.\\n   236Ôćĺ// Uses checkpoint.WriteCommitted for git operations.\\n   237Ôćĺfunc (s *AutoCommitStrategy) commitMetadataToMetadataBranch(repo *git.Repository, ctx StepContext, checkpointID id.CheckpointID) (plumbing.Hash, error) {\\n   238Ôćĺ\\tstore, err := s.getCheckpointStore()\\n   239Ôćĺ\\tif err != nil {\\n   240Ôćĺ\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   241Ôćĺ\\t}\\n   242Ôćĺ\\n   243Ôćĺ\\t// Extract session ID from metadata dir\\n   244Ôćĺ\\tsessionID := filepath.Base(ctx.MetadataDir)\\n   245Ôćĺ\\n   246Ôćĺ\\t// Get current branch name\\n   247Ôćĺ\\tbranchName := GetCurrentBranchName(repo)\\n   248Ôćĺ\\n   249Ôćĺ\\t// Combine all file changes into FilesTouched (same as manual-commit)\\n   250Ôćĺ\\tfilesTouched := mergeFilesTouched(nil, ctx.ModifiedFiles, ctx.NewFiles, ctx.DeletedFiles)\\n   251Ôćĺ\\n   252Ôćĺ\\t// Load TurnID from session state (correlates checkpoints from the same turn)\\n   253Ôćĺ\\tvar turnID string\\n   254Ôćĺ\\tif state, loadErr := LoadSessionState(sessionID); loadErr == nil && state != nil {\\n   255Ôćĺ\\t\\tturnID = state.TurnID\\n   256Ôćĺ\\t}\\n   257Ôćĺ\\n   258Ôćĺ\\t// Write committed checkpoint using the checkpoint store\\n   259Ôćĺ\\t// Pass TranscriptPath so writeTranscript generates content_hash.txt\\n   260Ôćĺ\\ttranscriptPath := filepath.Join(ctx.MetadataDirAbs, paths.TranscriptFileName)\\n   261Ôćĺ\\terr = store.WriteCommitted(context.Background(), checkpoint.WriteCommittedOptions{\\n   262Ôćĺ\\t\\tCheckpointID:                checkpointID,\\n   263Ôćĺ\\t\\tSessionID:                   sessionID,\\n   264Ôćĺ\\t\\tStrategy:                    StrategyNameAutoCommit, // Use new strategy name\\n   265Ôćĺ\\t\\tBranch:                      branchName,\\n   266Ôćĺ\\t\\tMetadataDir:                 ctx.MetadataDirAbs, // Copy all files from metadata dir\\n   267Ôćĺ\\t\\tTranscriptPath:              transcriptPath,     // For content hash generation\\n   268Ôćĺ\\t\\tAuthorName:                  ctx.AuthorName,\\n   269Ôćĺ\\t\\tAuthorEmail:                 ctx.AuthorEmail,\\n   270Ôćĺ\\t\\tAgent:                       ctx.AgentType,\\n   271Ô