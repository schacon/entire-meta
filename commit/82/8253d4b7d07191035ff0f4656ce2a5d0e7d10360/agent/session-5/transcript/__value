sion_id, got: %v\\\", err)\\n   185Ôćĺ\\t}\\n   186Ôćĺ}\\n   187Ôćĺ\\n   188Ôćĺ// --- handleLifecycleTurnEnd tests ---\\n   189Ôćĺ\\n   190Ôćĺfunc TestHandleLifecycleTurnEnd_EmptyTranscriptRef(t *testing.T) {\\n   191Ôćĺ\\tt.Parallel()\\n   192Ôćĺ\\n   193Ôćĺ\\tag := newMockAgent()\\n   194Ôćĺ\\tevent := &agent.Event{\\n   195Ôćĺ\\t\\tType:       agent.TurnEnd,\\n   196Ôćĺ\\t\\tSessionID:  \\\"test-session\\\",\\n   197Ôćĺ\\t\\tSessionRef: \\\"\\\", // Empty transcript path\\n   198Ôćĺ\\t}\\n   199Ôćĺ\\n   200Ôćĺ\\terr := handleLifecycleTurnEnd(ag, event)\\n   201Ôćĺ\\tif err == nil {\\n   202Ôćĺ\\t\\tt.Error(\\\"expected error for empty transcript ref, got nil\\\")\\n   203Ôćĺ\\t}\\n   204Ôćĺ\\tif !strings.Contains(err.Error(), \\\"transcript file not specified\\\") {\\n   205Ôćĺ\\t\\tt.Errorf(\\\"expected error about transcript file, got: %v\\\", err)\\n   206Ôćĺ\\t}\\n   207Ôćĺ}\\n   208Ôćĺ\\n   209Ôćĺfunc TestHandleLifecycleTurnEnd_NonexistentTranscript(t *testing.T) {\\n   210Ôćĺ\\tt.Parallel()\\n   211Ôćĺ\\n   212Ôćĺ\\tag := newMockAgent()\\n   213Ôćĺ\\tevent := &agent.Event{\\n   214Ôćĺ\\t\\tType:       agent.TurnEnd,\\n   215Ôćĺ\\t\\tSessionID:  \\\"test-session\\\",\\n   216Ôćĺ\\t\\tSessionRef: \\\"/nonexistent/path/to/transcript.jsonl\\\",\\n   217Ôćĺ\\t}\\n   218Ôćĺ\\n   219Ôćĺ\\terr := handleLifecycleTurnEnd(ag, event)\\n   220Ôćĺ\\tif err == nil {\\n   221Ôćĺ\\t\\tt.Error(\\\"expected error for nonexistent transcript, got nil\\\")\\n   222Ôćĺ\\t}\\n   223Ôćĺ\\tif !strings.Contains(err.Error(), \\\"transcript file not found\\\") {\\n   224Ôćĺ\\t\\tt.Errorf(\\\"expected error about transcript file, got: %v\\\", err)\\n   225Ôćĺ\\t}\\n   226Ôćĺ}\\n   227Ôćĺ\\n   228Ôćĺfunc TestHandleLifecycleTurnEnd_EmptyRepository(t *testing.T) {\\n   229Ôćĺ\\t// Cannot use t.Parallel() because we use t.Chdir()\\n   230Ôćĺ\\ttmpDir := t.TempDir()\\n   231Ôćĺ\\tt.Chdir(tmpDir)\\n   232Ôćĺ\\n   233Ôćĺ\\t// Initialize an empty git repo (no commits)\\n   234Ôćĺ\\tif err := os.MkdirAll(\\\".git/objects\\\", 0o755); err != nil {\\n   235Ôćĺ\\t\\tt.Fatalf(\\\"Failed to create .git: %v\\\", err)\\n   236Ôćĺ\\t}\\n   237Ôćĺ\\tif err := os.WriteFile(\\\".git/HEAD\\\", []byte(\\\"ref: refs/heads/main\\\\n\\\"), 0o644); err != nil {\\n   238Ôćĺ\\t\\tt.Fatalf(\\\"Failed to create HEAD: %v\\\", err)\\n   239Ôćĺ\\t}\\n   240Ôćĺ\\tpaths.ClearRepoRootCache()\\n   241Ôćĺ\\n   242Ôćĺ\\t// Create a transcript file\\n   243Ôćĺ\\ttranscriptPath := filepath.Join(tmpDir, \\\"transcript.jsonl\\\")\\n   244Ôćĺ\\tif err := os.WriteFile(transcriptPath, []byte(`{\\\"type\\\":\\\"user\\\",\\\"message\\\":\\\"test\\\"}`+\\\"\\\\n\\\"), 0o644); err != nil {\\n   245Ôćĺ\\t\\tt.Fatalf(\\\"Failed to create transcript: %v\\\", err)\\n   246Ôćĺ\\t}\\n   247Ôćĺ\\n   248Ôćĺ\\tag := newMockAgent()\\n   249Ôćĺ\\tevent := &agent.Event{\\n   250Ôćĺ\\t\\tType:       agent.TurnEnd,\\n   251Ôćĺ\\t\\tSessionID:  \\\"test-session\\\",\\n   252Ôćĺ\\t\\tSessionRef: transcriptPath,\\n   253Ôćĺ\\t}\\n   254Ôćĺ\\n   255Ôćĺ\\terr := handleLifecycleTurnEnd(ag, event)\\n   256Ôćĺ\\n   257Ôćĺ\\t// Should return a SilentError wrapping ErrEmptyRepository\\n   258Ôćĺ\\tif err == nil {\\n   259Ôćĺ\\t\\tt.Error(\\\"expected error for empty repository, got nil\\\")\\n   260Ôćĺ\\t}\\n   261Ôćĺ\\n   262Ôćĺ\\tvar silentErr *SilentError\\n   263Ôćĺ\\tif !errors.As(err, &silentErr) {\\n   264Ôćĺ\\t\\tt.Errorf(\\\"expected SilentError, got: %T\\\", err)\\n   265Ôćĺ\\t}\\n   266Ôćĺ\\tif !errors.Is(silentErr.Unwrap(), strategy.ErrEmptyRepository) {\\n   267Ôćĺ\\t\\tt.Errorf(\\\"expected ErrEmptyRepository, got: %v\\\", silentErr.Unwrap())\\n   268Ôćĺ\\t}\\n   269Ôćĺ}\\n   270Ôćĺ\\n   271Ôćĺ// --- handleLifecycleCompaction tests ---\\n   272Ôćĺ\\n   273Ôćĺfunc TestHandleLifecycleCompaction_ResetsTranscriptOffset(t *testing.T) {\\n   274Ôćĺ\\t// Cannot use t.Parallel() because we use t.Chdir()\\n   275Ôćĺ\\ttmpDir := t.TempDir()\\n   276Ôćĺ\\tt.Chdir(tmpDir)\\n   277Ôćĺ\\n   278Ôćĺ\\t// Initialize git repo with a commit (not empty)\\n   279Ôćĺ\\tsetupGitRepoWithCommit(t, tmpDir)\\n   280Ôćĺ\\tpaths.ClearRepoRootCache()\\n   281Ôćĺ\\n   282Ôćĺ\\t// Create .entire directory structure\\n   283Ôćĺ\\tif err := os.MkdirAll(paths.EntireDir, 0o755); err != nil {\\n   284Ôćĺ\\t\\tt.Fatalf(\\\"Failed to create .entire: %v\\\", err)\\n   285Ôćĺ\\t}\\n   286Ôćĺ\\n   287Ôćĺ\\t// Create a transcript file\\n   288Ôćĺ\\ttranscriptPath := filepath.Join(tmpDir, \\\"transcript.jsonl\\\")\\n   289Ôćĺ\\ttranscriptContent := `{\\\"type\\\":\\\"user\\\",\\\"message\\\":{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"test prompt\\\"}}` + \\\"\\\\n\\\"\\n   290Ôćĺ\\tif err := os.WriteFile(transcriptPath, []byte(transcriptContent), 0o644); err != nil {\\n   291Ôćĺ\\t\\tt.Fatalf(\\\"Failed to create transcript: %v\\\", err)\\n   292Ôćĺ\\t}\\n   293Ôćĺ\\n   294Ôćĺ\\tsessionID := \\\"compaction-test-session\\\"\\n   295Ôćĺ\\n   296Ôćĺ\\t// Create session state with non-zero transcript offset\\n   297Ôćĺ\\tsessionState := &strategy.SessionState{\\n   298Ôćĺ\\t\\tSessionID:                 sessionID,\\n   299Ôćĺ\\t\\tCheckpointTranscriptStart: 50, // Non-zero offset to be reset\\n   300Ôćĺ\\t}\\n   301Ôćĺ\\tif err := strategy.SaveSessionState(sessionState); err != nil {\\n   302Ôćĺ\\t\\tt.Fatalf(\\\"Failed to save session state: %v\\\", err)\\n   303Ôćĺ\\t}\\n   304Ôćĺ\\n   305Ôćĺ\\tag := newMockAgent()\\n   306Ôćĺ\\tevent := &agent.Event{\\n   307Ôćĺ\\t\\tType:       agent.Compaction,\\n   308Ôćĺ\\t\\tSessionID:  sessionID,\\n   309Ôćĺ\\t\\tSessionRef: transcriptPath,\\n   310Ôćĺ\\t}\\n   311Ôćĺ\\n   312Ôćĺ\\t// handleLifecycleCompaction resets the transcript offset regardless of other operations.\\n   313Ôćĺ\\t// It fires EventCompaction which stays in ACTIVE phase and resets CheckpointTranscriptStart.\\n   314Ôćĺ\\terr := handleLifecycleCompaction(ag, event)\\n   315Ôćĺ\\tif err != nil {\\n   316Ôćĺ\\t\\tt.Logf(\\\"handleLifecycleCompaction returned error (expected in minimal test): %v\\\", err)\\n   317Ôćĺ\\t}\\n   318Ôćĺ\\n   319Ôćĺ\\t// Verify CheckpointTranscriptStart was reset to 0\\n   320Ôćĺ\\tloadedState, loadErr := strategy.LoadSessionState(sessionID)\\n   321Ôćĺ\\tif loadErr != nil {\\n   322Ôćĺ\\t\\tt.Fatalf(\\\"Failed to load session state after compaction: %v\\\", loadErr)\\n   323Ôćĺ\\t}\\n   324Ôćĺ\\tif loadedState == nil {\\n   325Ôćĺ\\t\\tt.Fatal(\\\"Session state is nil after compaction\\\")\\n   326Ôćĺ\\t}\\n   327Ôćĺ\\tif loadedState.CheckpointTranscriptStart != 0 {\\n   328Ôćĺ\\t\\tt.Errorf(\\\"CheckpointTranscriptStart = %d, want 0 (should be reset on compaction)\\\",\\n   329Ôćĺ\\t\\t\\tloadedState.CheckpointTranscriptStart)\\n   330Ôćĺ\\t}\\n   331Ôćĺ}\\n   332Ôćĺ\\n   333Ôćĺ// --- handleLifecycleSessionEnd tests ---\\n   334Ôćĺ\\n   335Ôćĺfunc TestHandleLifecycleSessionEnd_EmptySessionID(t *testing.T) {\\n   336Ôćĺ\\tt.Parallel()\\n   337Ôćĺ\\n   338Ôćĺ\\tag := newMockAgent()\\n   339Ôćĺ\\tevent := &agent.Event{\\n   340Ôćĺ\\t\\tType:      agent.SessionEnd,\\n   341Ôćĺ\\t\\tSessionID: \\\"\\\", // Empty\\n   342Ôćĺ\\t}\\n   343Ôćĺ\\n   344Ôćĺ\\t// Empty session ID should return nil (no error, just no-op)\\n   345Ôćĺ\\terr := handleLifecycleSessionEnd(ag, event)\\n   346Ôćĺ\\tif err != nil {\\n   347Ôćĺ\\t\\tt.Errorf(\\\"expected no error for empty session ID on SessionEnd, got: %v\\\", err)\\n   348Ôćĺ\\t}\\n   349Ôćĺ}\\n   350Ôćĺ\\n   351Ôćĺ// --- resolveTranscriptOffset tests ---\\n   352Ôćĺ\\n   353Ôćĺfunc TestResolveTranscriptOffset_PrefersPrePromptState(t *testing.T) {\\n   354Ôćĺ\\tt.Parallel()\\n   355Ôćĺ\\n   356Ôćĺ\\tpreState := &PrePromptState{\\n   357Ôćĺ\\t\\tTranscriptOffset: 42,\\n   358Ôćĺ\\t}\\n   359Ôćĺ\\n   360Ôćĺ\\toffset := resolveTranscriptOffset(preState, \\\"test-session\\\")\\n   361Ôćĺ\\tif offset != 42 {\\n   362Ôćĺ\\t\\tt.Errorf(\\\"expected offset 42 from pre-prompt state, got %d\\\", offset)\\n   363Ôćĺ\\t}\\n   364Ôćĺ}\\n   365Ôćĺ\\n   366Ôćĺfunc TestResolveTranscriptOffset_NilPrePromptState(t *testi