\tfmt.Printf(\\\"Reset to commit %s\\\\n\\\", shortID)\\n   440Ôćĺ\\tfmt.Println()\\n   441Ôćĺ\\n   442Ôćĺ\\treturn nil\\n   443Ôćĺ}\\n   444Ôćĺ\\n   445Ôćĺfunc (s *AutoCommitStrategy) CanRewind() (bool, string, error) {\\n   446Ôćĺ\\treturn checkCanRewind()\\n   447Ôćĺ}\\n   448Ôćĺ\\n   449Ôćĺ// PreviewRewind returns what will happen if rewinding to the given point.\\n   450Ôćĺ// For auto-commit strategy, this returns nil since git reset doesn't delete untracked files.\\n   451Ôćĺfunc (s *AutoCommitStrategy) PreviewRewind(_ RewindPoint) (*RewindPreview, error) {\\n   452Ôćĺ\\t// Auto-commit uses git reset --hard which doesn't affect untracked files\\n   453Ôćĺ\\t// Return empty preview to indicate no untracked files will be deleted\\n   454Ôćĺ\\treturn &RewindPreview{}, nil\\n   455Ôćĺ}\\n   456Ôćĺ\\n   457Ôćĺ// EnsureSetup ensures the strategy's required setup is in place.\\n   458Ôćĺ// For auto-commit strategy:\\n   459Ôćĺ// - Ensure .entire/.gitignore has all required entries\\n   460Ôćĺ// - Create orphan entire/checkpoints/v1 branch if it doesn't exist\\n   461Ôćĺ// - Install git hooks if missing (self-healing for third-party overwrites)\\n   462Ôćĺfunc (s *AutoCommitStrategy) EnsureSetup() error {\\n   463Ôćĺ\\tif err := EnsureEntireGitignore(); err != nil {\\n   464Ôćĺ\\t\\treturn err\\n   465Ôćĺ\\t}\\n   466Ôćĺ\\n   467Ôćĺ\\trepo, err := OpenRepository()\\n   468Ôćĺ\\tif err != nil {\\n   469Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   470Ôćĺ\\t}\\n   471Ôćĺ\\n   472Ôćĺ\\t// Ensure the entire/checkpoints/v1 orphan branch exists\\n   473Ôćĺ\\tif err := EnsureMetadataBranch(repo); err != nil {\\n   474Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n   475Ôćĺ\\t}\\n   476Ôćĺ\\n   477Ôćĺ\\t// Install generic hooks if missing (they delegate to strategy at runtime)\\n   478Ôćĺ\\tif !IsGitHookInstalled() {\\n   479Ôćĺ\\t\\tif _, err := InstallGitHook(true); err != nil {\\n   480Ôćĺ\\t\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   481Ôćĺ\\t\\t}\\n   482Ôćĺ\\t}\\n   483Ôćĺ\\n   484Ôćĺ\\treturn nil\\n   485Ôćĺ}\\n   486Ôćĺ\\n   487Ôćĺ// GetSessionInfo returns session information for linking commits.\\n   488Ôćĺ// For auto-commit strategy, we don't track active sessions - metadata is stored on\\n   489Ôćĺ// entire/checkpoints/v1 branch when SaveStep is called. Active branch commits\\n   490Ôćĺ// are kept clean (no trailers), so this returns ErrNoSession.\\n   491Ôćĺ// Use ListSessions() or GetSession() to retrieve session info from the metadata branch.\\n   492Ôćĺfunc (s *AutoCommitStrategy) GetSessionInfo() (*SessionInfo, error) {\\n   493Ôćĺ\\t// Dual strategy doesn't track active sessions like shadow does.\\n   494Ôćĺ\\t// Session metadata is stored on entire/checkpoints/v1 branch and can be\\n   495Ôćĺ\\t// retrieved via ListSessions() or GetSession().\\n   496Ôćĺ\\treturn nil, ErrNoSession\\n   497Ôćĺ}\\n   498Ôćĺ\\n   499Ôćĺ// SaveTaskStep creates a checkpoint commit for a completed task.\\n   500Ôćĺ// For auto-commit strategy:\\n   501Ôćĺ// 1. Commit code changes to active branch (no trailers - clean history)\\n   502Ôćĺ// 2. Commit task metadata to entire/checkpoints/v1 branch with checkpoint format\\n   503Ôćĺfunc (s *AutoCommitStrategy) SaveTaskStep(ctx TaskStepContext) error {\\n   504Ôćĺ\\trepo, err := OpenRepository()\\n   505Ôćĺ\\tif err != nil {\\n   506Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   507Ôćĺ\\t}\\n   508Ôćĺ\\n   509Ôćĺ\\t// Ensure entire/checkpoints/v1 branch exists\\n   510Ôćĺ\\tif err := EnsureMetadataBranch(repo); err != nil {\\n   511Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n   512Ôćĺ\\t}\\n   513Ôćĺ\\n   514Ôćĺ\\t// Generate checkpoint ID for this task checkpoint\\n   515Ôćĺ\\tcpID, err := id.Generate()\\n   516Ôćĺ\\tif err != nil {\\n   517Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   518Ôćĺ\\t}\\n   519Ôćĺ\\n   520Ôćĺ\\t// Step 1: Commit code changes to active branch with checkpoint ID trailer\\n   521Ôćĺ\\t// We do code first to avoid orphaned metadata if this step fails.\\n   522Ôćĺ\\t_, err = s.commitTaskCodeToActive(repo, ctx, cpID)\\n   523Ôćĺ\\tif err != nil {\\n   524Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to commit task code to active branch: %w\\\", err)\\n   525Ôćĺ\\t}\\n   526Ôćĺ\\n   527Ôćĺ\\t// Step 2: Commit task metadata to entire/checkpoints/v1 branch at sharded path\\n   528Ôćĺ\\t_, err = s.commitTaskMetadataToMetadataBranch(repo, ctx, cpID)\\n   529Ôćĺ\\tif err != nil {\\n   530Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to commit task metadata to entire/checkpoints/v1 branch: %w\\\", err)\\n   531Ôćĺ\\t}\\n   532Ôćĺ\\n   533Ôćĺ\\t// Log task checkpoint creation\\n   534Ôćĺ\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   535Ôćĺ\\tattrs := []any{\\n   536Ôćĺ\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n   537Ôćĺ\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"task\\\"),\\n   538Ôćĺ\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   539Ôćĺ\\t\\tslog.String(\\\"checkpoint_uuid\\\", ctx.CheckpointUUID),\\n   540Ôćĺ\\t\\tslog.String(\\\"tool_use_id\\\", ctx.ToolUseID),\\n   541Ôćĺ\\t\\tslog.String(\\\"subagent_type\\\", ctx.SubagentType),\\n   542Ôćĺ\\t\\tslog.Int(\\\"modified_files\\\", len(ctx.ModifiedFiles)),\\n   543Ôćĺ\\t\\tslog.Int(\\\"new_files\\\", len(ctx.NewFiles)),\\n   544Ôćĺ\\t\\tslog.Int(\\\"deleted_files\\\", len(ctx.DeletedFiles)),\\n   545Ôćĺ\\t}\\n   546Ôćĺ\\tif ctx.IsIncremental {\\n   547Ôćĺ\\t\\tattrs = append(attrs,\\n   548Ôćĺ\\t\\t\\tslog.Bool(\\\"is_incremental\\\", true),\\n   549Ôćĺ\\t\\t\\tslog.String(\\\"incremental_type\\\", ctx.IncrementalType),\\n   550Ôćĺ\\t\\t\\tslog.Int(\\\"incremental_sequence\\\", ctx.IncrementalSequence),\\n   551Ôćĺ\\t\\t)\\n   552Ôćĺ\\t}\\n   553Ôćĺ\\tlogging.Info(logCtx, \\\"task checkpoint saved\\\", attrs...)\\n   554Ôćĺ\\n   555Ôćĺ\\tre