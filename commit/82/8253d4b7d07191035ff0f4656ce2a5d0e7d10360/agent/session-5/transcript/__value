06Ôćĺ// isProtectedPath returns true if relPath is inside a directory that should\\n   207Ôćĺ// never be modified or deleted during rewind or other destructive operations.\\n   208Ôćĺ// Protected directories include git internals, entire metadata, and all\\n   209Ôćĺ// registered agent config directories.\\n   210Ôćĺfunc isProtectedPath(relPath string) bool {\\n   211Ôćĺ\\tfor _, dir := range protectedDirs() {\\n   212Ôćĺ\\t\\tif relPath == dir || strings.HasPrefix(relPath, dir+string(filepath.Separator)) {\\n   213Ôćĺ\\t\\t\\treturn true\\n   214Ôćĺ\\t\\t}\\n   215Ôćĺ\\t}\\n   216Ôćĺ\\treturn false\\n   217Ôćĺ}\\n   218Ôćĺ\\n   219Ôćĺ// protectedDirs returns the list of directories to protect. This combines\\n   220Ôćĺ// static infrastructure dirs with agent-reported dirs from the registry.\\n   221Ôćĺ// The result is cached via sync.Once since it's called per-file during filepath.Walk.\\n   222Ôćĺ//\\n   223Ôćĺ// NOTE: The cache is never invalidated. In production this is fine (the agent registry\\n   224Ôćĺ// is populated at init time and never changes). However, tests that mutate the agent\\n   225Ôćĺ// registry after the first call to protectedDirs/isProtectedPath will see stale results.\\n   226Ôćĺ// If you need to test isProtectedPath with a custom registry, either:\\n   227Ôćĺ//   - run those tests in a separate process, or\\n   228Ôćĺ//   - call resetProtectedDirsForTest() to clear the cache.\\n   229Ôćĺfunc protectedDirs() []string {\\n   230Ôćĺ\\tprotectedDirsOnce.Do(func() {\\n   231Ôćĺ\\t\\tprotectedDirsCache = append([]string{gitDir, entireDir}, agent.AllProtectedDirs()...)\\n   232Ôćĺ\\t})\\n   233Ôćĺ\\treturn protectedDirsCache\\n   234Ôćĺ}\\n   235Ôćĺ\\n   236Ôćĺvar (\\n   237Ôćĺ\\tprotectedDirsOnce  sync.Once\\n   238Ôćĺ\\tprotectedDirsCache []string\\n   239Ôćĺ)\\n   240Ôćĺ\\n   241Ôćĺ// homeRelativePath strips the $HOME/ prefix from an absolute path,\\n   242Ôćĺ// returning a home-relative path suitable for persisting in metadata.\\n   243Ôćĺ// Returns \\\"\\\" if the path is empty or not under $HOME.\\n   244Ôćĺfunc homeRelativePath(absPath string) string {\\n   245Ôćĺ\\tif absPath == \\\"\\\" {\\n   246Ôćĺ\\t\\treturn \\\"\\\"\\n   247Ôćĺ\\t}\\n   248Ôćĺ\\thome, err := os.UserHomeDir()\\n   249Ôćĺ\\tif err != nil || home == \\\"\\\" {\\n   250Ôćĺ\\t\\treturn \\\"\\\"\\n   251Ôćĺ\\t}\\n   252Ôćĺ\\tprefix := home + string(filepath.Separator)\\n   253Ôćĺ\\tif !strings.HasPrefix(absPath, prefix) {\\n   254Ôćĺ\\t\\treturn \\\"\\\"\\n   255Ôćĺ\\t}\\n   256Ôćĺ\\treturn absPath[len(prefix):]\\n   257Ôćĺ}\\n   258Ôćĺ\\n   259Ôćĺ// isSpecificAgentType returns true if the agent type is a known, specific value\\n   260Ôćĺ// (not empty and not the generic \\\"Agent\\\" fallback).\\n   261Ôćĺfunc isSpecificAgentType(t agent.AgentType) bool {\\n   262Ôćĺ\\treturn t != \\\"\\\" && t != DefaultAgentType\\n   263Ôćĺ}\\n   264Ôćĺ\\n   265Ôćĺ// resolveAgentType picks the best agent type from the context and existing state.\\n   266Ôćĺ// Priority: existing state (if specific) > context value > default fallback.\\n   267Ôćĺfunc resolveAgentType(ctxAgentType agent.AgentType, state *SessionState) agent.AgentType {\\n   268Ôćĺ\\tif state != nil && isSpecificAgentType(state.AgentType) {\\n   269Ôćĺ\\t\\treturn state.AgentType\\n   270Ôćĺ\\t}\\n   271Ôćĺ\\tif ctxAgentType != \\\"\\\" {\\n   272Ôćĺ\\t\\treturn ctxAgentType\\n   273Ôćĺ\\t}\\n   274Ôćĺ\\treturn DefaultAgentType\\n   275Ôćĺ}\\n   276Ôćĺ\\n   277Ôćĺ// ensureMetadataBranch creates the orphan entire/checkpoints/v1 branch if it doesn't exist.\\n   278Ôćĺ// This branch has no parent and starts with an empty tree.\\n   279Ôćĺfunc EnsureMetadataBranch(repo *git.Repository) error {\\n   280Ôćĺ\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   281Ôćĺ\\n   282Ôćĺ\\t// Check if branch already exists\\n   283Ôćĺ\\t_, err := repo.Reference(refName, true)\\n   284Ôćĺ\\tif err == nil {\\n   285Ôćĺ\\t\\t// Branch already exists\\n   286Ôćĺ\\t\\treturn nil\\n   287Ôćĺ\\t}\\n   288Ôćĺ\\n   289Ôćĺ\\t// Create empty tree (no files)\\n   290Ôćĺ\\temptyTree := &object.Tree{Entries: []object.TreeEntry{}}\\n   291Ôćĺ\\tobj := repo.Storer.NewEncodedObject()\\n   292Ôćĺ\\tif err := emptyTree.Encode(obj); err != nil {\\n   293Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to encode empty tree: %w\\\", err)\\n   294Ôćĺ\\t}\\n   295Ôćĺ\\temptyTreeHash, err := repo.Storer.SetEncodedObject(obj)\\n   296Ôćĺ\\tif err != nil {\\n   297Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to store empty tree: %w\\\", err)\\n   298Ôćĺ\\t}\\n   299Ôćĺ\\n   300Ôćĺ\\t// Create orphan commit (no parent)\\n   301Ôćĺ\\tnow := time.Now()\\n   302Ôćĺ\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   303Ôćĺ\\tsig := object.Signature{\\n   304Ôćĺ\\t\\tName:  authorName,\\n   305Ôćĺ\\t\\tEmail: authorEmail,\\n   306Ôćĺ\\t\\tWhen:  now,\\n   307Ôćĺ\\t}\\n   308Ôćĺ\\n   309Ôćĺ\\tcommit := &object.Commit{\\n   310Ôćĺ\\t\\tTreeHash:  emptyTreeHash,\\n   311Ôćĺ\\t\\tAuthor:    sig,\\n   312Ôćĺ\\t\\tCommitter: sig,\\n   313Ôćĺ\\t\\tMessage:   \\\"Initialize metadata branch\\\\n\\\\nThis branch stores session metadata for the auto-commit strategy.\\\\n\\\",\\n   314Ôćĺ\\t}\\n   315Ôćĺ\\t// Note: No ParentHashes - this is an orphan commit\\n   316Ôćĺ\\n   317Ôćĺ\\tcommitObj := repo.Storer.NewEncodedObject()\\n   318Ôćĺ\\tif err := commit.Encode(commitObj); err != nil {\\n   319Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to encode orphan commit: %w\\\", err)\\n   320Ôćĺ\\t}\\n   321Ôćĺ\\tcommitHash, err := repo.Storer.SetEncodedObject(commitObj)\\n   322Ôćĺ\\tif err != nil {\\n   323Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to store orphan commit: %w\\\", err)\\n   324Ôćĺ\\t}\\n   325Ôćĺ\\n   326Ôćĺ\\t// Create branch reference\\n   327Ôćĺ\\tref := plumbing.NewHashReference(refName, commitHash)\\n   328Ôćĺ\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   329Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to create metadata branch: %w\\\", err)\\n   330Ôćĺ\\t}\\n   331Ôćĺ\\n   332Ôćĺ\\tfmt.Fprintf(os.Stderr, \\\"Ôťô Created orphan branch '%s' for session metadata\\\\n\\\", paths.MetadataBranchName)\\n   333Ôćĺ\\treturn nil\\n   334Ôćĺ}\\n   335Ôćĺ\\n   336Ôćĺ// readCheckpointMetadata reads metadata.json from a checkpoint path on entire/checkpoints/v1.\\n   337Ôćĺ// With the new format, root metadata.json is a CheckpointSummary with Agents array.\\n   338Ôćĺ// This function reads the summary and extracts relevant fields into CheckpointInfo,\\n   339Ôćĺ// also reading session-level metadata for IsTask/ToolUseID fields.\\n   340Ôćĺfunc ReadCheckpointMetadata(tree *object.Tree, checkpointPath string) (*CheckpointInfo, error) {\\n   341Ôćĺ\\tmetadataPath := checkpointPath + \\\"/metadata.json\\\"\\n   342Ôćĺ\\tfile, err := tree.File(metadataPath)\\n   343Ôćĺ\\tif err != nil {\\n   344Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to find metadata at %s: %w\\\", metadataPath, err)\\n   345Ôćĺ\\t}\\n   346Ôćĺ\\n   347Ôćĺ\\tcontent, err := file.Contents()\\n   348Ôćĺ\\tif err != nil {\\n   349Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata: %w\\\", err)\\n   350Ôćĺ\\t}\\n   351Ôćĺ\\n   352Ôćĺ\\t// Try to parse as CheckpointSummary first (new format)\\n   353Ôćĺ\\tvar summary checkpoint.CheckpointSummary\\n   354Ôćĺ\\tif err := json.Unmarshal([]byte(content), &summary); err == nil {\\n   355Ôćĺ\\t\\t// If we have sessions array, this is the new format\\n   356Ôćĺ\\t\\tif len(summary.Sessions) > 0 {\\n   357Ôćĺ\\t\\t\\tinfo := &CheckpointInfo{\\n   358Ôćĺ\\t\\t\\t\\tCheckpointID:     summary.CheckpointID,\\n   359Ôćĺ\\t\\t\\t\\tCheckpointsCount: summary.CheckpointsCount,\\n   360Ôćĺ\\t\\t\\t\\tFilesTouched:     summary.FilesTouched,\\n   361Ôćĺ\\t\\t\\t\\tSessionCount:     len(summary.Sessions),\\n   362Ôćĺ\\t\\t\\t}\\n   363Ôćĺ\\n   364Ôćĺ\\t\\t\\t// Read all sessions' metadata to populate SessionIDs and get other fields from first session\\n   365Ôćĺ\\t\\t\\tvar sessionIDs []string\\n   366Ôćĺ\\t\\t\\tfor i, sessionPaths := range summary.Sessions {\\n   367Ôćĺ\\t\\t\\t\\tif sessionPaths.Metadata != \\\"\\\" {\\n   368Ôćĺ\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n   369Ôćĺ\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n   370Ôćĺ\\t\\t\\t\\t\\tsessionMetadataPath := strings.TrimPrefix(sessionPaths.Metadata, \\\"/\\\")\\n   371Ôćĺ\\t\\t\\t\\t\\tif sessionFile, err := tree.File(sessionMetadataPath); err == nil {\\n   372Ôćĺ\\t\\t\\t\\t\\t\\tif sessionContent, err := sessionFile.Contents(); err == nil {\\n   373Ôćĺ\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata checkpoint.CommittedMetadata\\n   374Ôćĺ\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   375Ôćĺ\\t\\t\\t\\t\\t\\t\\t\\tsessionIDs = append(sessionIDs, sessionMetadata.SessionID)\\n   376Ôćĺ\\t\\t\\t\\t\\t\\t\\t\\t// Use first session for Agent, SessionID, CreatedAt, IsTask, ToolUseID\\n   377Ôćĺ\\t\\t\\t\\t\\t\\t\\t\\tif i == 0 {\\n   378Ôćĺ\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   379Ôćĺ\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   380Ôćĺ\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   381Ôćĺ\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.IsTask = sessionMetadata.IsTask\\n   382Ôćĺ\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.ToolUseID = sessionMetadata.ToolUseID\\n   383Ôćĺ\\t\\t\\t\\t\\t\\t\\t\\t}\\n   384Ôćĺ\\t\\t\\t\\t\\t\\t\\t}\\n   385Ôćĺ\\t\\t\\t\\t\\t\\t}\\n   386Ôćĺ\\t\\t\\t\\t\\t}\\n   387Ôćĺ\\t\\t\\t\\t}\\n   388Ôćĺ\\t\\t\\t}\\n   389Ôćĺ\\t\\t\\tinfo.SessionIDs = sessionIDs\\n   390Ôćĺ\\n   391Ôćĺ\\t\\t\\treturn info, nil\\n   392Ôćĺ\\t\\t}\\n   393Ôćĺ\\t}\\n   394Ôćĺ\\n   395Ôćĺ\\t// Fall back to parsing as CheckpointInfo (old format or direct info)\\n   396Ôćĺ\\tvar metadata CheckpointInfo\\n   397Ôćĺ\\tif err := json.Unmarshal([]byte(content), &metadata); err != nil {\\n   398Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata: %w\\\", err)\\n   399Ôćĺ\\t}\\n   400Ôćĺ\\n   401Ôćĺ\\treturn &metadata, nil\\n   402Ôćĺ}\\n   403Ôćĺ\\n   404Ôćĺ// GetMetadataBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\n   405Ôćĺfunc GetMetadataBranchTree(repo *git.Repository) (*object.Tree, error) {\\n   406Ôćĺ\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   407Ôćĺ\\tref, err := repo.Reference(refName, true)\\n   408Ôćĺ\\tif err != nil {\\n   409Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch reference: %w\\\", err)\\n   410Ôćĺ\\t}\\n   411Ôćĺ\\n   412Ôćĺ\\tcommit, err := repo.CommitObject(ref.Hash())\\n   413Ôćĺ\\tif err != nil {\\n   414Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch commit: %w\\\", err)\\n   415Ôćĺ\\t}\\n   416Ôćĺ\\n   417Ôćĺ\\ttree, err := commit.Tree()\\n   418Ôćĺ\\tif err != nil {\\n   419Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch tree: %w\\\", err)\\n   420Ôćĺ\\t}\\n   421Ôćĺ\\treturn tree, nil\\n   422Ôćĺ}\\n   423Ôćĺ\\n   424Ôćĺ// ExtractFirstPrompt extracts and truncates the first meaningful prompt from prompt content.\\n   425Ôćĺ// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\". Skips empty prompts and separator-only content.\\n   426Ôćĺ// Returns empty string if no valid prompt is found.\\n   427Ôćĺfunc ExtractFirstPrompt(content string) string {\\n   428Ôćĺ\\tif content == \\\"\\\" {\\n   429Ôćĺ\\t\\treturn \\\"\\\"\\n   430Ôćĺ\\t}\\n   431Ôćĺ\\n   432Ôćĺ\\t// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\"\\n   433Ôćĺ\\t// Find the first non-empty prompt\\n   434Ôćĺ\\tprompts := strings.Split(content, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   435Ôćĺ\\tvar firstPrompt string\\n   436Ôćĺ\\tfor _, p := range prompts {\\n   437Ôćĺ\\t\\tcleaned := strings.TrimSpace(p)\\n   438Ôćĺ\\t\\t// Skip empty prompts or prompts that are just dashes/separators\\n   439Ôćĺ\\t\\tif cleaned == \\\"\\\" || isOnlySeparators(cleaned) {\\n   440Ôćĺ\\t\\t\\tcontinue\\n   441Ôćĺ\\t\\t}\\n   442Ôćĺ\\t\\tfirstPrompt = cleaned\\n   443Ôćĺ\\t\\tbreak\\n   444Ôćĺ\\t}\\n   445Ôćĺ\\n   446Ôćĺ\\tif firstPrompt == \\\"\\\" {\\n   447Ôćĺ\\t\\treturn \\\"\\\"\\n   448Ôćĺ\\t}\\n   449Ôćĺ\\n   450Ôćĺ\\treturn TruncateDescription(firstPrompt, MaxDescriptionLength)\\n   451Ôćĺ}\\n   452Ôćĺ\\n   453Ôćĺ// ReadSessionPromptFromTree reads the first meaningful prompt from a checkpoint's prompt.txt file in a git tree.\\n   454Ôćĺ// Returns an empty string if the prompt cannot be read.\\n   455Ôćĺfunc ReadSessionPromptFromTree(tree *object.Tree, checkpointPath string) string {\\n   456Ôćĺ\\tpromptPath := checkpointPath + \\\"/\\\" + paths.PromptFileName\\n   457Ôćĺ\\tfile, err := tree.File(promptPath)\\n   458Ôćĺ\\tif err != nil {\\n   459Ôćĺ\\t\\treturn \\\"\\\"\\n   460Ôćĺ\\t}\\n   461Ôćĺ\\n   462Ôćĺ\\tcontent, err := file.Contents()\\n   463Ôćĺ\\tif err != nil {\\n   464Ôćĺ\\t\\treturn \\\"\\\"\\n   465Ôćĺ\\t}\\n   466Ôćĺ\\n   467Ôćĺ\\treturn ExtractFirstPrompt(content)\\n   468Ôćĺ}\\n   469Ôćĺ\\n   470Ôćĺ// ReadAgentTypeFromTree reads the agent type from a checkpoint's metadata.json file in a git tree.\\n   471Ôćĺ// If metadata.json doesn't exist (shadow branches), it falls back to detecting the agent\\n   472Ôćĺ// from the presence of agent-specific config files (.gemini/settings.json or .claude/).\\n   473Ôćĺ// Returns agent.AgentTypeUnknown if the agent type cannot be determined.\\n   474Ôćĺfunc ReadAgentTypeFromTree(tree *object.Tree, checkpointPath string) agent.AgentType {\\n   475Ôćĺ\\t// First, try to read from metadata.json (present in condensed/committed checkpoints)\\n   476Ôćĺ\\tmetadataPath := checkpointPath + \\\"/\\\" + paths.MetadataFileName\\n   477Ôćĺ\\tif file, err := tree.File(metadataPath); err == nil {\\n   478Ôćĺ\\t\\tif content, err := file.Contents(); err == nil {\\n   479Ôćĺ\\t\\t\\tvar metadata checkpoint.CommittedMetadata\\n   480Ôćĺ\\t\\t\\tif err := json.Unmarshal([]byte(content), &metadata); err == nil && metadata.Agent != \\\"\\\" {\\n   481Ôćĺ\\t\\t\\t\\treturn metadata.Agent\\n   482Ôćĺ\\t\\t\\t}\\n   483Ôćĺ\\t\\t}\\n   484Ôćĺ\\t}\\n   485Ôćĺ\\n   486Ôćĺ\\t// Fall back to detecting agent from config files (shadow branches don't have metadata.json)\\n   487Ôćĺ\\t// Check for Gemini config\\n   488Ôćĺ\\tif _, err := tree.File(\\\".gemini/settings.json\\\"); err == nil {\\n   489Ôćĺ\\t\\treturn agent.AgentTypeGemini\\n   490Ôćĺ\\t}\\n   491Ôćĺ\\t// Check for Claude config (either settings.local.json or settings.json in .claude/)\\n   492Ôćĺ\\tif _, err := tree.Tree(\\\".claude\\\"); err == nil {\\n   493Ôćĺ\\t\\treturn agent.AgentTypeClaudeCode\\n   494Ôćĺ\\t}\\n   495Ôćĺ\\n   496Ôćĺ\\treturn agent.AgentTypeUnknown\\n   497Ôćĺ}\\n   498Ôćĺ\\n   499Ôćĺ// isOnlySeparators checks if a string contains only dashes, spaces, and newlines.\\n   500Ôćĺfunc isOnlySeparators(s string) bool {\\n   501Ôćĺ\\tfor _, r := range s {\\n   502Ôćĺ\\t\\tif r != '-' && r != ' ' && r != '\\\\n' && r != '\\\\r' && r != '\\\\t' {\\n   503Ôćĺ\\t\\t\\treturn false\\n   504Ôćĺ\\t\\t}\\n   505Ôćĺ\\t}\\n   506Ôćĺ\\treturn true\\n   507Ôćĺ}\\n   508Ôćĺ\\n   509Ôćĺ// ReadAllSessionPromptsFromTree reads the first prompt for all sessions in a multi-session checkpoint.\\n   510Ôćĺ// Returns a slice of prompts parallel to sessionIDs (oldest to newest).\\n   511Ôćĺ// For single-session checkpoints, returns a slice with just the root prompt.\\n   512Ôćĺfunc ReadAllSessionPromptsFromTree(tree *object.Tree, checkpointPath string, sessionCount int, sessionIDs []string) []string {\\n   513Ôćĺ\\tif sessionCount <= 1 || len(sessionIDs) <= 1 {\\n   514Ôćĺ\\t\\t// Single session - just return the root prompt\\n   515Ôćĺ\\t\\tprompt := ReadSessionPromptFromTree(tree, checkpointPath)\\n   516Ôćĺ\\t\\tif prompt != \\\"\\\" {\\n   517Ôćĺ\\t\\t\\treturn []string{prompt}\\n   518Ôćĺ\\t\\t}\\n   519Ôćĺ\\t\\treturn nil\\n   520Ôćĺ\\t}\\n   521Ôćĺ\\n   522Ôćĺ\\t// Multi-session: read prompts from archived folders (0/, 1/, etc.) and root\\n   523Ôćĺ\\tprompts := make([]string, len(sessionIDs))\\n   524Ôćĺ\\n   525Ôćĺ\\t// Read archived session prompts (folders 0, 1, ... N-2)\\n   526Ôćĺ\\tfor i := range sessionCount - 1 {\\n   527Ôćĺ\\t\\tarchivedPath := fmt.Sprintf(\\\"%s/%d\\\", checkpointPath, i)\\n   528Ôćĺ\\t\\tprompts[i] = ReadSessionPromptFromTree(tree, archivedPath)\\n   529Ôćĺ\\t}\\n   530Ôćĺ\\n   531Ôćĺ\\t// Read the most recent session prompt (at root level)\\n   532Ôćĺ\\tprompts[len(prompts)-1] = ReadSessionPromptFromTree(tree, checkpointPath)\\n   533Ôćĺ\\n   534Ôćĺ\\treturn prompts\\n   535Ôćĺ}\\n   536Ôćĺ\\n   537Ôćĺ// ReadSessionPromptFromShadow reads the first prompt for a session from the shadow branch.\\n   538Ôćĺ// Returns an empty string if the prompt cannot be read.\\n   539Ôćĺfunc ReadSessionPromptFromShadow(repo *git.Repository, baseCommit, worktreeID, sessionID string) string {\\n   540Ôćĺ\\t// Get shadow branch for this base commit using worktree-specific naming\\n   541Ôćĺ\\tshadowBranchName := checkpoint.ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   542Ôćĺ\\tref, err := repo.Reference(plumbing.NewBranchReferenceName(shadowBranchName), true)\\n   543Ôćĺ\\tif err != nil {\\n   544Ôćĺ\\t\\treturn \\\"\\\"\\n   545Ôćĺ\\t}\\n   546Ôćĺ\\n   547Ôćĺ\\tcommit, err := repo.CommitObject(ref.Hash())\\n   548Ôćĺ\\tif err != nil {\\n   549Ôćĺ\\t\\treturn \\\"\\\"\\n   550Ôćĺ\\t}\\n   551Ôćĺ\\n   552Ôćĺ\\ttree, err := commit.Tree()\\n   553Ôćĺ\\tif err != nil {\\n   554Ôćĺ\\t\\treturn \\\"\\\"\\n   555Ôćĺ\\t}\\n   556Ôćĺ\\n   557Ôćĺ\\t// Build the path to prompt.txt: .entire/metadata/<session-id>/prompt.txt\\n   558Ôćĺ\\tcheckpointPath := paths.EntireMetadataDir + \\\"/\\\" + sessionID\\n   559Ôćĺ\\treturn ReadSessionPromptFromTree(tree, checkpointPath)\\n   560Ôćĺ}\\n   561Ôćĺ\\n   562Ôćĺ// GetRemoteMetadataBranchTree returns the tree object for origin/entire/checkpoints/v1.\\n   563Ôćĺfunc GetRemoteMetadataBranchTree(repo *git.Repository) (*object.Tree, error) {\\n   564Ôćĺ\\trefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n   565Ôćĺ\\tref, err := repo.Reference(refName, true)\\n   566Ôćĺ\\tif err != nil {\\n   567Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch reference: %w\\\", err)\\n   568Ôćĺ\\t}\\n   569Ôćĺ\\n   570Ôćĺ\\tcommit, err := repo.CommitObject(ref.Hash())\\n   571Ôćĺ\\tif err != nil {\\n   572Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch commit: %w\\\", err)\\n   573Ôćĺ\\t}\\n   574Ôćĺ\\n   575Ôćĺ\\ttree, err := commit.Tree()\\n   576Ôćĺ\\tif err != nil {\\n   577Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to get remote metadata branch tree: %w\\\", err)\\n   578Ôćĺ\\t}\\n   579Ôćĺ\\treturn tree, nil\\n   580Ôćĺ}\\n   581Ôćĺ\\n   582Ôćĺ// OpenRepository opens the git repository with linked worktree support enabled.\\n   583Ôćĺ// It uses git.PlainOpenWithOptions with EnableDotGitCommonDir set to true,\\n   584Ôćĺ// which is required for proper operation in git worktrees created via 'git worktree add'.\\n   585Ôćĺ//\\n   586Ôćĺ// Without EnableDotGitCommonDir, go-git operations in worktrees can silently fail:\\n   587Ôćĺ// - Commits appear to succeed but are not persisted\\n   588Ôćĺ// - Refs are written to incorrect locations\\n   589Ôćĺ// - The worktree's HEAD/index don't get updated properly\\n   590Ôćĺ//\\n   591Ôćĺ// This happens because worktrees use .git as a file (pointing to the main repo)\\n   592Ôćĺ// rather than a directory, and go-git needs to route paths correctly between\\n   593Ôćĺ// shared (.git/) and per-worktree (.git/worktrees/<name>/) locations.\\n   594Ôćĺ//\\n   595Ôćĺ// The function first uses 'git rev-parse --show-toplevel' to find the repository\\n   596Ôćĺ// root, which works correctly even when called from a subdirectory within the repo.\\n   597Ôćĺfunc OpenRepository() (*git.Repository, error) {\\n   598Ôćĺ\\t// First, find the repository root using git rev-parse --show-toplevel\\n   599Ôćĺ\\t// This works correctly from any subdirectory within the repository\\n   600Ôćĺ\\trepoRoot, err := GetWorktreePath()\\n   601Ôćĺ\\tif err != nil {\\n   602Ôćĺ\\t\\t// Fallback to current directory if git command fails\\n   603Ôćĺ\\t\\t// (e.g., if git is not installed or we're not in a repo)\\n   604Ôćĺ\\t\\trepoRoot = \\\".\\\"\\n   605Ôćĺ\\t}\\n   606Ôćĺ\\n   607Ôćĺ\\trepo, err := git.PlainOpenWithOptions(repoRoot, &git.PlainOpenOptions{\\n   608Ôćĺ\\t\\tEnableDotGitCommonDir: true,\\n   609Ôćĺ\\t})\\n   610Ôćĺ\\tif err != nil {\\n   611Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   612Ôćĺ\\t}\\n   613Ôćĺ\\treturn repo, nil\\n   614Ôćĺ}\\n   615Ôćĺ\\n   616Ôćĺ// IsInsideWorktree returns true if the current directory is inside a git worktree\\n   617Ôćĺ// (as opposed to the main repository). Worktrees have .git as a file pointing\\n   618Ôćĺ// to the main repo, while the main repo has .git as a directory.\\n   619Ôćĺ// This function works correctly from any subdirectory within the repository.\\n   620Ôćĺfunc IsInsideWorktree() bool {\\n   621Ôćĺ\\t// First find the repository root\\n   622Ôćĺ\\trepoRoot, err := GetWorktreePath()\\n   623Ôćĺ\\tif err != nil {\\n   624Ôćĺ\\t\\treturn false\\n   625Ôćĺ\\t}\\n   626Ôćĺ\\n   627Ôćĺ\\tgitPath := filepath.Join(repoRoot, gitDir)\\n   628Ôćĺ\\tgitInfo, err := os.Stat(gitPath)\\n   629Ôćĺ\\tif err != nil {\\n   630Ôćĺ\\t\\treturn false\\n   631Ôćĺ\\t}\\n   632Ôćĺ\\treturn !gitInfo.IsDir()\\n   633Ôćĺ}\\n   634Ôćĺ\\n   635Ôćĺ// GetMainRepoRoot returns the root directory of the main repository.\\n   636Ôćĺ// In the main repo, this is the worktree path (repo root).\\n   637Ôćĺ// In a worktree, this parses the .git file to find the main repo.\\n   638Ôćĺ// This function works correctly from any subdirectory within the repository.\\n   639Ôćĺ//\\n   640Ôćĺ// Per gitrepository-layout(5), a worktree's .git file is a \\\"gitfile\\\" containing\\n   641Ôćĺ// \\\"gitdir: <path>\\\" pointing to $GIT_DIR/worktrees/<id> in the main repository.\\n   642Ôćĺ// See: https://git-scm.com/docs/gitrepository-layout\\n   643Ôćĺfunc GetMainRepoRoot() (string, error) {\\n   644Ôćĺ\\t// First find the worktree/repo root\\n   645Ôćĺ\\trepoRoot, err := GetWorktreePath()\\n   646Ôćĺ\\tif err != nil {\\n   647Ôćĺ\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get worktree path: %w\\\", err)\\n   648Ôćĺ\\t}\\n   649Ôćĺ\\n   650Ôćĺ\\tif !IsInsideWorktree() {\\n   651Ôćĺ\\t\\treturn repoRoot, nil\\n   652Ôćĺ\\t}\\n   653Ôćĺ\\n   654Ôćĺ\\t// Worktree .git file contains: \\\"gitdir: /path/to/main/.git/worktrees/<id>\\\"\\n   655Ôćĺ\\tgitFilePath := filepath.Join(repoRoot, gitDir)\\n   656Ôćĺ\\tcontent, err := os.ReadFile(gitFilePath) //nolint:gosec // G304: gitFilePath is constructed from repo root, not user input\\n   657Ôćĺ\\tif err != nil {\\n   658Ôćĺ\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read .git file: %w\\\", err)\\n   659Ôćĺ\\t}\\n   660Ôćĺ\\n   661Ôćĺ\\tgitdir := strings.TrimSpace(string(content))\\n   662Ôćĺ\\tgitdir = strings.TrimPrefix(gitdir, \\\"gitdir: \\\")\\n   663Ôćĺ\\n   664Ôćĺ\\t// Extract main repo root: everything before \\\"/.git/\\\"\\n   665Ôćĺ\\tidx := strings.LastIndex(gitdir, \\\"/.git/\\\")\\n   666Ôćĺ\\tif idx < 0 {\\n   667Ôćĺ\\t\\treturn \\\"\\\", fmt.Errorf(\\\"unexpected gitdir format: %s\\\", gitdir)\\n   668Ôćĺ\\t}\\n   669Ôćĺ\\treturn gitdir[:idx], nil\\n   670Ôćĺ}\\n   671Ôćĺ\\n   672Ôćĺ// GetGitCommonDir returns the path to the shared git directory.\\n   673Ôćĺ// In a regular checkout, this is .git/\\n   674Ôćĺ// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n   675Ôćĺ// Uses git rev-parse --git-common-dir for reliable handling of worktrees.\\n   676Ôćĺfunc GetGitCommonDir() (string, error) {\\n   677Ôćĺ\\tctx := context.Background()\\n   678Ôćĺ\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-common-dir\\\")\\n   679Ôćĺ\\tcmd.Dir = \\\".\\\"\\n   680Ôćĺ\\toutput, err := cmd.Output()\\n   681Ôćĺ\\tif err != nil {\\n   682Ôćĺ\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   683Ôćĺ\\t}\\n   684Ôćĺ\\n   685Ôćĺ\\tcommonDir := strings.TrimSpace(string(output))\\n   686Ôćĺ\\n   687Ôćĺ\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\n   688Ôćĺ\\t// so we need to make it absolute if it isn't already\\n   689Ôćĺ\\tif !filepath.IsAbs(commonDir) {\\n   690Ôćĺ\\t\\tcommonDir = filepath.Join(\\\".\\\", commonDir)\\n   691Ôćĺ\\t}\\n   692Ôćĺ\\n   693Ôćĺ\\treturn filepath.Clean(commonDir), nil\\n   694Ôćĺ}\\n   695Ôćĺ\\n   696Ôćĺ// GetWorktreePath returns the absolute path to the current worktree root.\\n   697Ôćĺ// This is the working directory path, not the git directory.\\n   698Ôćĺfunc GetWorktreePath() (string, error) {\\n   699Ôćĺ\\tctx := context.Background()\\n   700Ôćĺ\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--show-toplevel\\\")\\n   701Ôćĺ\\toutput, err := cmd.Output()\\n   702Ôćĺ\\tif err != nil {\\n   703Ôćĺ\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get worktree path: %w\\\", err)\\n   704Ôćĺ\\t}\\n   705Ôćĺ\\treturn strings.TrimSpace(string(output)), nil\\n   706Ôćĺ}\\n   707Ôćĺ\\n   708Ôćĺ// EnsureEntireGitignore ensures all required entries are in .entire/.gitignore\\n   709Ôćĺ// Works correctly from any subdirectory within the repository.\\n   710Ôćĺfunc EnsureEntireGitignore() error {\\n   711Ôćĺ\\t// Get absolute path for the gitignore file\\n   712Ôćĺ\\tgitignoreAbs, err := paths.AbsPath(entireGitignore)\\n   713Ôćĺ\\tif err != nil {\\n   714Ôćĺ\\t\\tgitignoreAbs = entireGitignore // Fallback to relative\\n   715Ôćĺ\\t}\\n   716Ôćĺ\\n   717Ôćĺ\\t// Read existing content\\n   718Ôćĺ\\tvar content string\\n   719Ôćĺ\\tif data, err := os.ReadFile(gitignoreAbs); err == nil { //nolint:gosec // path is from AbsPath or constant\\n   720Ôćĺ\\t\\tcontent = string(data)\\n   721Ôćĺ\\t}\\n   722Ôćĺ\\n   723Ôćĺ\\t// All entries that should be in .entire/.gitignore\\n   724Ôćĺ\\trequiredEntries := []string{\\n   725Ôćĺ\\t\\t\\\"tmp/\\\",\\n   726Ôćĺ\\t\\t\\\"settings.local.json\\\",\\n   727Ôćĺ\\t\\t\\\"metadata/\\\",\\n   728Ôćĺ\\t\\t\\\"logs/\\\",\\n   729Ôćĺ\\t}\\n   730Ôćĺ\\n   731Ôćĺ\\t// Track what needs to be added\\n   732Ôćĺ\\tvar toAdd []string\\n   733Ôćĺ\\tfor _, entry := range requiredEntries {\\n   734Ôćĺ\\t\\tif !strings.Contains(content, entry) {\\n   735Ôćĺ\\t\\t\\ttoAdd = append(toAdd, entry)\\n   736Ôćĺ\\t\\t}\\n   737Ôćĺ\\t}\\n   738Ôćĺ\\n   739Ôćĺ\\t// Nothing to add\\n   740Ôćĺ\\tif len(toAdd) == 0 {\\n   741Ôćĺ\\t\\treturn nil\\n   742Ôćĺ\\t}\\n   743Ôćĺ\\n   744Ôćĺ\\t// Ensure .entire directory exists\\n   745Ôćĺ\\tif err := os.MkdirAll(filepath.Dir(gitignoreAbs), 0o750); err != nil {\\n   746Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   747Ôćĺ\\t}\\n   748Ôćĺ\\n   749Ôćĺ\\t// Append missing entries to gitignore\\n   750Ôćĺ\\tvar sb strings.Builder\\n   751Ôćĺ\\tfor _, entry := range toAdd {\\n   752Ôćĺ\\t\\tsb.WriteString(entry + \\\"\\\\n\\\")\\n   753Ôćĺ\\t}\\n   754Ôćĺ\\tcontent += sb.String()\\n   755Ôćĺ\\n   756Ôćĺ\\tif err := os.WriteFile(gitignoreAbs, []byte(content), 0o644); err != nil { //nolint:gosec // path is from AbsPath or constant\\n   757Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to write gitignore: %w\\\", err)\\n   758Ôćĺ\\t}\\n   759Ôćĺ\\treturn nil\\n   760Ôćĺ}\\n   761Ôćĺ\\n   762Ôćĺ// checkCanRewind checks if working directory is clean enough for rewind.\\n   763Ôćĺ// Returns (canRewind, reason, error). Shared by shadow and linear-shadow strategies.\\n   764Ôćĺfunc checkCanRewind() (bool, string, error) {\\n   765Ôćĺ\\trepo, err := OpenRepository()\\n   766Ôćĺ\\tif err != nil {\\n   767Ôćĺ\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   768Ôćĺ\\t}\\n   769Ôćĺ\\n   770Ôćĺ\\tworktree, err := repo.Worktree()\\n   771Ôćĺ\\tif err != nil {\\n   772Ôćĺ\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   773Ôćĺ\\t}\\n   774Ôćĺ\\n   775Ôćĺ\\tstatus, err := worktree.Status()\\n   776Ôćĺ\\tif err != nil {\\n   777Ôćĺ\\t\\treturn false, \\\"\\\", fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n   778Ôćĺ\\t}\\n   779Ôćĺ\\n   780Ôćĺ\\tif status.IsClean() {\\n   781Ôćĺ\\t\\treturn true, \\\"\\\", nil\\n   782Ôćĺ\\t}\\n   783Ôćĺ\\n   784Ôćĺ\\tvar modified, added, deleted []string\\n   785Ôćĺ\\tfor file, st := range status {\\n   786Ôćĺ\\t\\t// Skip .entire directory\\n   787Ôćĺ\\t\\tif paths.IsInfrastructurePath(file) {\\n   788Ôćĺ\\t\\t\\tcontinue\\n   789Ôćĺ\\t\\t}\\n   790Ôćĺ\\n   791Ôćĺ\\t\\t// Skip untracked files\\n   792Ôćĺ\\t\\tif st.Worktree == git.Untracked {\\n   793Ôćĺ\\t\\t\\tcontinue\\n   794Ôćĺ\\t\\t}\\n   795Ôćĺ\\n   796Ôćĺ\\t\\tswitch {\\n   797Ôćĺ\\t\\tcase st.Staging == git.Added || st.Worktree == git.Added:\\n   798Ôćĺ\\t\\t\\tadded = append(added, file)\\n   799Ôćĺ\\t\\tcase st.Staging == git.Deleted || st.Worktree == git.Deleted:\\n   800Ôćĺ\\t\\t\\tdeleted = append(deleted, file)\\n   801Ôćĺ\\t\\tcase st.Staging == git.Modified || st.Worktree == git.Modified:\\n   802Ôćĺ\\t\\t\\tmodified = append(modified, file)\\n   803Ôćĺ\\t\\t}\\n   804Ôćĺ\\t}\\n   805Ôćĺ\\n   806Ôćĺ\\tif len(modified) == 0 && len(added) == 0 && len(deleted) == 0 {\\n   807Ôćĺ\\t\\treturn true, \\\"\\\", nil\\n   808Ôćĺ\\t}\\n   809Ôćĺ\\n   810Ôćĺ\\tvar msg strings.Builder\\n   811Ôćĺ\\tmsg.WriteString(\\\"You have uncommitted changes:\\\\n\\\")\\n   812Ôćĺ\\tfor _, f := range modified {\\n   813Ôćĺ\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  modified:   %s\\\\n\\\", f))\\n   814Ôćĺ\\t}\\n   815Ôćĺ\\tfor _, f := range added {\\n   816Ôćĺ\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  added:      %s\\\\n\\\", f))\\n   817Ôćĺ\\t}\\n   818Ôćĺ\\tfor _, f := range deleted {\\n   819Ôćĺ\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  deleted:    %s\\\\n\\\", f))\\n   820Ôćĺ\\t}\\n   821Ôćĺ\\tmsg.WriteString(\\\"\\\\nPlease commit or stash your changes before rewinding.\\\")\\n   822Ô