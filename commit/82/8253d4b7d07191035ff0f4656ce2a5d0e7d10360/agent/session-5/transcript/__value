nes)\\n   353Ôćĺ\\tif state.TranscriptOffset != 3 {\\n   354Ôćĺ\\t\\tt.Errorf(\\\"TranscriptOffset = %d, want 3\\\", state.TranscriptOffset)\\n   355Ôćĺ\\t}\\n   356Ôćĺ\\n   357Ôćĺ\\t// Cleanup\\n   358Ôćĺ\\tif err := CleanupPrePromptState(sessionID); err != nil {\\n   359Ôćĺ\\t\\tt.Errorf(\\\"CleanupPrePromptState() error = %v\\\", err)\\n   360Ôćĺ\\t}\\n   361Ôćĺ}\\n   362Ôćĺ\\n   363Ôćĺfunc TestPrePromptState_WithEmptyTranscriptPath(t *testing.T) {\\n   364Ôćĺ\\tsetupTestRepoWithTranscript(t, \\\"\\\", \\\"\\\") // No transcript file\\n   365Ôćĺ\\n   366Ôćĺ\\tsessionID := \\\"test-session-empty-transcript\\\"\\n   367Ôćĺ\\tag := claudecode.NewClaudeCodeAgent()\\n   368Ôćĺ\\n   369Ôćĺ\\t// Capture state with empty transcript path\\n   370Ôćĺ\\tif err := CapturePrePromptState(ag, sessionID, \\\"\\\"); err != nil {\\n   371Ôćĺ\\t\\tt.Fatalf(\\\"CapturePrePromptState() error = %v\\\", err)\\n   372Ôćĺ\\t}\\n   373Ôćĺ\\n   374Ôćĺ\\t// Load and verify\\n   375Ôćĺ\\tstate, err := LoadPrePromptState(sessionID)\\n   376Ôćĺ\\tif err != nil {\\n   377Ôćĺ\\t\\tt.Fatalf(\\\"LoadPrePromptState() error = %v\\\", err)\\n   378Ôćĺ\\t}\\n   379Ôćĺ\\tif state == nil {\\n   380Ôćĺ\\t\\tt.Fatal(\\\"LoadPrePromptState() returned nil\\\")\\n   381Ôćĺ\\t\\treturn // unreachable but satisfies staticcheck\\n   382Ôćĺ\\t}\\n   383Ôćĺ\\n   384Ôćĺ\\t// Transcript position should be zero when no transcript provided\\n   385Ôćĺ\\tif state.TranscriptOffset != 0 {\\n   386Ôćĺ\\t\\tt.Errorf(\\\"TranscriptOffset = %d, want 0\\\", state.TranscriptOffset)\\n   387Ôćĺ\\t}\\n   388Ôćĺ\\n   389Ôćĺ\\t// Cleanup\\n   390Ôćĺ\\tif err := CleanupPrePromptState(sessionID); err != nil {\\n   391Ôćĺ\\t\\tt.Errorf(\\\"CleanupPrePromptState() error = %v\\\", err)\\n   392Ôćĺ\\t}\\n   393Ôćĺ}\\n   394Ôćĺ\\n   395Ôćĺfunc TestPrePromptState_WithSummaryOnlyTranscript(t *testing.T) {\\n   396Ôćĺ\\t// Summary rows have leafUuid but not uuid\\n   397Ôćĺ\\ttranscriptContent := `{\\\"type\\\":\\\"summary\\\",\\\"leafUuid\\\":\\\"leaf-1\\\",\\\"summary\\\":\\\"Previous context\\\"}\\n   398Ôćĺ{\\\"type\\\":\\\"summary\\\",\\\"leafUuid\\\":\\\"leaf-2\\\",\\\"summary\\\":\\\"More context\\\"}`\\n   399Ôćĺ\\n   400Ôćĺ\\ttranscriptPath := setupTestRepoWithTranscript(t, transcriptContent, \\\"transcript-summary.jsonl\\\")\\n   401Ôćĺ\\n   402Ôćĺ\\tsessionID := \\\"test-session-summary-only\\\"\\n   403Ôćĺ\\tag := claudecode.NewClaudeCodeAgent()\\n   404Ôćĺ\\n   405Ôćĺ\\t// Capture state\\n   406Ôćĺ\\tif err := CapturePrePromptState(ag, sessionID, transcriptPath); err != nil {\\n   407Ôćĺ\\t\\tt.Fatalf(\\\"CapturePrePromptState() error = %v\\\", err)\\n   408Ôćĺ\\t}\\n   409Ôćĺ\\n   410Ôćĺ\\t// Load and verify\\n   411Ôćĺ\\tstate, err := LoadPrePromptState(sessionID)\\n   412Ôćĺ\\tif err != nil {\\n   413Ôćĺ\\t\\tt.Fatalf(\\\"LoadPrePromptState() error = %v\\\", err)\\n   414Ôćĺ\\t}\\n   415Ôćĺ\\tif state == nil {\\n   416Ôćĺ\\t\\tt.Fatal(\\\"LoadPrePromptState() returned nil\\\")\\n   417Ôćĺ\\t}\\n   418Ôćĺ\\n   419Ôćĺ\\t// TranscriptOffset should be 2 (2 JSONL lines counted by ClaudeCodeAgent)\\n   420Ôćĺ\\tif state.TranscriptOffset != 2 {\\n   421Ôćĺ\\t\\tt.Errorf(\\\"TranscriptOffset = %d, want 2\\\", state.TranscriptOffset)\\n   422Ôćĺ\\t}\\n   423Ôćĺ\\n   424Ôćĺ\\t// Cleanup\\n   425Ôćĺ\\tif err := CleanupPrePromptState(sessionID); err != nil {\\n   426Ôćĺ\\t\\tt.Errorf(\\\"CleanupPrePromptState() error = %v\\\", err)\\n   427Ôćĺ\\t}\\n   428Ôćĺ}\\n   429Ôćĺ\\n   430Ôćĺfunc TestDetectFileChanges_DeletedFilesWithNilPreState(t *testing.T) {\\n   431Ôćĺ\\t// This test verifies that DetectFileChanges detects deleted files\\n   432Ôćĺ\\t// even when previouslyUntracked is nil. Deleted file detection\\n   433Ôćĺ\\t// doesn't depend on pre-prompt state.\\n   434Ôćĺ\\n   435Ôćĺ\\ttmpDir := t.TempDir()\\n   436Ôćĺ\\tt.Chdir(tmpDir)\\n   437Ôćĺ\\n   438Ôćĺ\\t// Initialize git repo with go-git\\n   439Ôćĺ\\trepo, err := git.PlainInit(tmpDir, false)\\n   440Ôćĺ\\tif err != nil {\\n   441Ôćĺ\\t\\tt.Fatalf(\\\"failed to init repo: %v\\\", err)\\n   442Ôćĺ\\t}\\n   443Ôćĺ\\n   444Ôćĺ\\t// Create and commit a tracked file\\n   445Ôćĺ\\ttrackedFile := filepath.Join(tmpDir, \\\"tracked.txt\\\")\\n   446Ôćĺ\\tif err := os.WriteFile(trackedFile, []byte(\\\"tracked content\\\"), 0o644); err != nil {\\n   447Ôćĺ\\t\\tt.Fatalf(\\\"failed to write tracked file: %v\\\", err)\\n   448Ôćĺ\\t}\\n   449Ôćĺ\\n   450Ôćĺ\\tworktree, err := repo.Worktree()\\n   451Ôćĺ\\tif err != nil {\\n   452Ôćĺ\\t\\tt.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   453Ôćĺ\\t}\\n   454Ôćĺ\\n   455Ôćĺ\\tif _, err := worktree.Add(\\\"tracked.txt\\\"); err != nil {\\n   456Ôćĺ\\t\\tt.Fatalf(\\\"failed to add file: %v\\\", err)\\n   457Ôćĺ\\t}\\n   458Ôćĺ\\n   459Ôćĺ\\tif _, err := worktree.Commit(\\\"Initial commit\\\", &git.CommitOptions{\\n   460Ôćĺ\\t\\tAuthor: &object.Signature{\\n   461Ôćĺ\\t\\t\\tName:  \\\"Test User\\\",\\n   462Ôćĺ\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   463Ôćĺ\\t\\t},\\n   464Ôćĺ\\t}); err != nil {\\n   465Ôćĺ\\t\\tt.Fatalf(\\\"failed to commit: %v\\\", err)\\n   466Ôćĺ\\t}\\n   467Ôćĺ\\n   468Ôćĺ\\t// Delete the tracked file (simulating user deletion during session)\\n   469Ôćĺ\\tif err := os.Remove(trackedFile); err != nil {\\n   470Ôćĺ\\t\\tt.Fatalf(\\\"failed to delete tracked file: %v\\\", err)\\n   471Ôćĺ\\t}\\n   472Ôćĺ\\n   473Ôćĺ\\t// Call DetectFileChanges with nil previouslyUntracked\\n   474Ôćĺ\\tchanges, err := DetectFileChanges(nil)\\n   475Ôćĺ\\tif err != nil {\\n   476Ôćĺ\\t\\tt.Fatalf(\\\"DetectFileChanges(nil) error = %v\\\", err)\\n   477Ôćĺ\\t}\\n   478Ôćĺ\\n   479Ôćĺ\\t// New should be nil when there are no untracked files\\n   480Ôćĺ\\tif len(changes.New) != 0 {\\n   481Ôćĺ\\t\\tt.Errorf(\\\"DetectFileChanges(nil) New = %v, want empty\\\", changes.New)\\n   482Ôćĺ\\t}\\n   483Ôćĺ\\n   484Ôćĺ\\t// Deleted should contain the deleted tracked file\\n   485Ôćĺ\\tif len(changes.Deleted) != 1 {\\n   486Ôćĺ\\t\\tt.Errorf(\\\"DetectFileChanges(