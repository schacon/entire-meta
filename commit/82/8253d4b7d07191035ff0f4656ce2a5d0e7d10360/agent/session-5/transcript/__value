ion.NativeData, 0o600); err != nil {\\n   230Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   231Ôćĺ\\t}\\n   232Ôćĺ\\n   233Ôćĺ\\treturn nil\\n   234Ôćĺ}\\n   235Ôćĺ\\n   236Ôćĺ// FormatResumeCommand returns the command to resume a Claude Code session.\\n   237Ôćĺfunc (c *ClaudeCodeAgent) FormatResumeCommand(sessionID string) string {\\n   238Ôćĺ\\treturn \\\"claude -r \\\" + sessionID\\n   239Ôćĺ}\\n   240Ôćĺ\\n   241Ôćĺ// Session helper methods - work on AgentSession with Claude's native JSONL data\\n   242Ôćĺ\\n   243Ôćĺ// GetLastUserPrompt extracts the last user prompt from the session.\\n   244Ôćĺ// Requires NativeData to be populated (call ReadSession first).\\n   245Ôćĺfunc (c *ClaudeCodeAgent) GetLastUserPrompt(session *agent.AgentSession) string {\\n   246Ôćĺ\\tif session == nil || len(session.NativeData) == 0 {\\n   247Ôćĺ\\t\\treturn \\\"\\\"\\n   248Ôćĺ\\t}\\n   249Ôćĺ\\n   250Ôćĺ\\tlines, err := transcript.ParseFromBytes(session.NativeData)\\n   251Ôćĺ\\tif err != nil {\\n   252Ôćĺ\\t\\treturn \\\"\\\"\\n   253Ôćĺ\\t}\\n   254Ôćĺ\\n   255Ôćĺ\\treturn ExtractLastUserPrompt(lines)\\n   256Ôćĺ}\\n   257Ôćĺ\\n   258Ôćĺ// TruncateAtUUID returns a new session truncated at the given UUID (inclusive).\\n   259Ôćĺ// This is used for rewind operations to restore transcript state.\\n   260Ôćĺ// Requires NativeData to be populated.\\n   261Ôćĺfunc (c *ClaudeCodeAgent) TruncateAtUUID(session *agent.AgentSession, uuid string) (*agent.AgentSession, error) {\\n   262Ôćĺ\\tif session == nil {\\n   263Ôćĺ\\t\\treturn nil, errors.New(\\\"session is nil\\\")\\n   264Ôćĺ\\t}\\n   265Ôćĺ\\n   266Ôćĺ\\tif len(session.NativeData) == 0 {\\n   267Ôćĺ\\t\\treturn nil, errors.New(\\\"session has no native data\\\")\\n   268Ôćĺ\\t}\\n   269Ôćĺ\\n   270Ôćĺ\\tif uuid == \\\"\\\" {\\n   271Ôćĺ\\t\\t// No truncation needed, return copy\\n   272Ôćĺ\\t\\treturn &agent.AgentSession{\\n   273Ôćĺ\\t\\t\\tSessionID:     session.SessionID,\\n   274Ôćĺ\\t\\t\\tAgen