\\", err)\\n   285Ôćĺ\\t}\\n   286Ôćĺ\\n   287Ôćĺ\\t// Create a transcript file\\n   288Ôćĺ\\ttranscriptPath := filepath.Join(tmpDir, \\\"transcript.jsonl\\\")\\n   289Ôćĺ\\ttranscriptContent := `{\\\"type\\\":\\\"user\\\",\\\"message\\\":{\\\"role\\\":\\\"user\\\",\\\"content\\\":\\\"test prompt\\\"}}` + \\\"\\\\n\\\"\\n   290Ôćĺ\\tif err := os.WriteFile(transcriptPath, []byte(transcriptContent), 0o644); err != nil {\\n   291Ôćĺ\\t\\tt.Fatalf(\\\"Failed to create transcript: %v\\\", err)\\n   292Ôćĺ\\t}\\n   293Ôćĺ\\n   294Ôćĺ\\tsessionID := \\\"compaction-test-session\\\"\\n   295Ôćĺ\\n   296Ôćĺ\\t// Create session state with non-zero transcript offset\\n   297Ôćĺ\\tsessionState := &strategy.SessionState{\\n   298Ôćĺ\\t\\tSessionID:                 sessionID,\\n   299Ôćĺ\\t\\tCheckpointTranscriptStart: 50, // Non-zero offset to be reset\\n   300Ôćĺ\\t}\\n   301Ôćĺ\\tif err := strategy.SaveSessionState(sessionState); err != nil {\\n   302Ôćĺ\\t\\tt.Fatalf(\\\"Failed to save session state: %v\\\", err)\\n   303Ôćĺ\\t}\\n   304Ôćĺ\\n   305Ôćĺ\\tag := newMockAgent()\\n   306Ôćĺ\\tevent := &agent.Event{\\n   307Ôćĺ\\t\\tType:       agent.Compaction,\\n   308Ôćĺ\\t\\tSessionID:  sessionID,\\n   309Ôćĺ\\t\\tSessionRef: transcriptPath,\\n   310Ôćĺ\\t}\\n   311Ôćĺ\\n   312Ôćĺ\\t// handleLifecycleCompaction resets the transcript offset regardless of other operations.\\n   313Ôćĺ\\t// It fires EventCompaction which stays in ACTIVE phase and resets CheckpointTranscriptStart.\\n   314Ôćĺ\\terr := handleLifecycleCompaction(ag, event)\\n   315Ôćĺ\\tif err != nil {\\n   316Ôćĺ\\t\\tt.Logf(\\\"handleLifecycleCompaction returned error (expected in minimal test): %v\\\", err)\\n   317Ôćĺ\\t}\\n   318Ôćĺ\\n   319Ôćĺ\\t// Verify CheckpointTranscriptStart was reset to 0\\n   320Ôćĺ\\tloadedState, loadErr := strategy.LoadSessionState(sessionID)\\n   321Ôćĺ\\tif loadErr != nil {\\n   322Ôćĺ\\t\\tt.Fatalf(\\\"Failed to load session state after compaction: %v\\\", loadErr)\\n   323Ôćĺ\\t}\\n   324Ôćĺ\\tif loadedState == nil {\\n   325Ôćĺ\\t\\tt.Fatal(\\\"Session state is nil after compaction\\\")\\n   326Ôćĺ\\t}\\n   327Ôćĺ\\tif loadedState.CheckpointTranscriptStart != 0 {\\n   328Ôćĺ\\t\\tt.Errorf(\\\"CheckpointTranscriptStart = %d, want 0 (should be reset on compaction)\\\",\\n   329Ôćĺ\\t\\t\\tloadedState.CheckpointTranscriptStart)\\n   330Ôćĺ\\t}\\n   331Ôćĺ}\\n   332Ôćĺ\\n   333Ôćĺ// --- handleLifecycleSessionEnd tests ---\\n   334Ôćĺ\\n   335Ôćĺfunc TestHandleLifecycleSessionEnd_EmptySessionID(t *testing.T) {\\n   336Ôćĺ\\tt.Parallel()\\n   337Ôćĺ\\n   338Ôćĺ\\tag := newMockAgent()\\n   339Ôćĺ\\tevent := &agent.Event{\\n   340Ôćĺ\\t\\tType:      agent.SessionEnd,\\n   341Ôćĺ\\t\\tSessionID: \\\"\\\", // Empty\\n   342Ôćĺ\\t}\\n   343Ôćĺ\\n   344Ôćĺ\\t// Empty session ID should return nil (no error, just no-op)\\n   345Ôćĺ\\terr := handleLifecycleSessionEnd(ag, event)\\n   346Ôćĺ\\tif err != nil {\\n   347Ôćĺ\\t\\tt.Errorf(\\\"expected no error for empty session ID on SessionEnd, got: %v\\\", err)\\n   348Ôćĺ\\t}\\n   349Ôćĺ}\\n   350Ôćĺ\\n   351Ôćĺ// --- resolveTranscriptOffset tests ---\\n   352Ôćĺ\\n   353Ôćĺfunc TestResolveTranscriptOffset_PrefersPrePromptState(t *testing.T) {\\n   354Ôćĺ\\tt.Parallel()\\n   355Ôćĺ\\n   356Ôćĺ\\tpreState := &PrePromptState{\\n   357Ôćĺ\\t\\tTranscriptOffset: 42,\\n   358Ôćĺ\\t}\\n   359Ôćĺ\\n   360Ôćĺ\\toffset := resolveTranscriptOffset(preState, \\\"test-session\\\")\\n   361Ôćĺ\\tif offset != 42 {\\n   362Ôćĺ\\t\\tt.Errorf(\\\"expected offset 42 from pre-prompt state, got %d\\\", offset)\\n   363Ôćĺ\\t}\\n   364Ôćĺ}\\n   365Ôćĺ\\n   366Ôćĺfunc TestResolveTranscriptOffset_NilPrePromptState(t *testing.T) {\\n   367Ôćĺ\\tt.Parallel()\\n   368Ôćĺ\\n   369Ôćĺ\\t// With nil pre-prompt state and no session state, should return 0\\n   370Ôćĺ\\toffset := resolveTranscriptOffset(nil, \\\"nonexistent-session\\\")\\n   371Ôćĺ\\tif offset != 0 {\\n   372Ôćĺ\\t\\tt.Errorf(\\\"expected offset 0 for nil pre-prompt state, got %d\\\", offset)\\n   373Ôćĺ\\t}\\n   374Ôćĺ}\\n   375Ôćĺ\\n   376Ôćĺfunc TestResolveTranscriptOffset_ZeroOffsetInPrePromptState(t *testing.T) {\\n   377Ôćĺ\\tt.Parallel()\\n   378Ôćĺ\\n   379Ôćĺ\\tpreState := &PrePromptState{\\n   380Ôćĺ\\t\\tTranscriptOffset: 0, // Zero should fall through to session state\\n   381Ôćĺ\\t}\\n   382Ôćĺ\\n   383Ôćĺ\\t// With zero in pre-prompt state and no session state, should return 0\\n   384Ôćĺ\\toffset := resolveTranscriptOffset(preState, \\\"nonexistent-session\\\")\\n   385Ôćĺ\\tif offset != 0 {\\n   386Ôćĺ\\t\\tt.Errorf(\\\"expected offset 0, got %d\\\", offset)\\n   387Ôćĺ\\t}\\n   388Ôćĺ}\\n   389Ôćĺ\\n   390Ôćĺ// --- createContextFile tests ---\\n   391Ôćĺ\\n   392Ôćĺfunc TestCreateContextFile_Format(t *testing.T) {\\n   393Ôćĺ\\tt.Parallel()\\n   394Ôćĺ\\n   395Ôćĺ\\ttmpDir := t.TempDir()\\n   396Ôćĺ\\tcontextFile := filepath.Join(tmpDir, \\\"context.md\\\")\\n   397Ôćĺ\\n   398Ôćĺ\\tprompts := []string{\\\"What is the meaning of life?\\\", \\\"Follow-up question here\\\"}\\n   399Ôćĺ\\tsummary := \\\"This session explored philosophical questions.\\\"\\n   400Ôćĺ\\n   401Ôćĺ\\terr := createContextFile(contextFile, \\\"feat: add philosophy\\\", \\\"session-123\\\", prompts, summary)\\n   402Ôćĺ\\tif err != nil {\\n   403Ôćĺ\\t\\tt.Fatalf(\\\"createContextFile failed: %v\\\", err)\\n   404Ôćĺ\\t}\\n   405Ôćĺ\\n   406Ôćĺ\\tcontent, err := os.ReadFile(contextFile)\\n   407Ôćĺ\\tif err != nil {\\n   408Ôćĺ\\t\\tt.Fatalf(\\\"failed to read context file: %v\\\", err)\\n   409Ôćĺ\\t}\\n   410Ôćĺ\\n   411Ôćĺ\\tcontentStr := string(content)\\n   412Ôćĺ\\n   413Ôćĺ\\t// Check for expected sections\\n   414Ôćĺ\\tif !strings.Contains(contentStr, \\\"# Session Context\\\") {\\n   415Ôćĺ\\t\\tt.Error(\\\"expected '# Session Context' header\\\")\\n   416Ôćĺ\\t}\\n   417Ôćĺ\\tif !strings.Contains(contentStr, \\\"Session ID: session-123\\\") {\\n   418Ôćĺ\\t\\tt.Error(\\\"expected session ID in context file\\\")\\n   419Ôćĺ\\t}\\n   420Ôćĺ\\tif !strings.Contains(contentStr, \\\"Commit Message: feat: add philosophy\\\") {\\n   421Ôćĺ\\t\\tt.Error(\\\"expected commit message in context file\\\")\\n   422Ôćĺ\\t}\\n   423Ôćĺ\\tif !strings.Contains(contentStr, \\\"## Prompts\\\") {\\n   424Ôćĺ\\t\\tt.Error(\\\"expected '## Prompts' section\\\")\\n   425Ôćĺ\\t}\\n   426Ôćĺ\\tif !strings.Contains(contentStr, \\\"### Prompt 1\\\") {\\n   427Ôćĺ\\t\\tt.Error(\\\"expected '### Prompt 1' subsection\\\")\\n   428Ôćĺ\\t}\\n   429Ôćĺ\\tif !strings.Contains(contentStr, \\\"What is the meaning of life?\\\") {\\n   430Ôćĺ\\t\\tt.Error(\\\"expected first prompt content\\\")\\n   431Ôćĺ\\t}\\n   432Ôćĺ\\tif !strings.Contains(contentStr, \\\"### Prompt 2\\\") {\\n   433Ôćĺ\\t\\tt.Error(\\\"expected '### Prompt 2' subsection\\\")\\n   434Ôćĺ\\t}\\n   435Ôćĺ\\tif !strings.Contains(contentStr, \\\"## Summary\\\") {\\n   436Ôćĺ\\t\\tt.Error(\\\"expected '## Summary' section\\\")\\n   437Ôćĺ\\t}\\n   438Ôćĺ\\tif !strings.Contains(contentStr, \\\"philosophical questions\\\") {\\n   439Ôćĺ\\t\\tt.Error(\\\"expected summary content\\\")\\n   440Ôćĺ\\t}\\n   441Ôćĺ}\\n   442Ôćĺ\\n   443Ôćĺfunc TestCreateContextFile_EmptyPrompts(t *testing.T) {\\n   444Ôćĺ\\tt.Parallel()\\n   445Ôćĺ\\n   446Ôćĺ\\ttmpDir := t.TempDir()\\n   447Ôćĺ\\tcontextFile := filepath.Join(tmpDir, \\\"context.md\\\")\\n   448Ôćĺ\\n   449Ôćĺ\\terr := createContextFile(contextFile, \\\"fix: bug\\\", \\\"session-456\\\", nil, \\\"\\\")\\n   450Ôćĺ\\tif err != nil {\\n   451Ôćĺ\\t\\tt.Fatalf(\\\"createContextFile failed: %v\\\", err)\\n   452Ôćĺ\\t}\\n   453Ôćĺ\\n   454Ôćĺ\\tcontent, err := os.ReadFile(contextFile)\\n   455Ôćĺ\\tif err != nil {\\n   456Ôćĺ\\t\\tt.Fatalf(\\\"failed to read context file: %v\\\", err)\\n   457Ôćĺ\\t}\\n   458Ôćĺ\\n   459Ôćĺ\\tcontentStr := string(content)\\n   460Ôćĺ\\n   461Ôćĺ\\t// Should still have header and session info\\n   462Ôćĺ\\tif !strings.Contains(contentStr, \\\"# Session Context\\\") {\\n   463Ôćĺ\\t\\tt.Error(\\\"expected '# Session Context' header\\\")\\n   464Ôćĺ\\t}\\n   465Ôćĺ\\t// Should NOT have prompts section when empty\\n   466Ôćĺ\\tif strings.Contains(contentStr, \\\"## Prompts\\\") {\\n   467Ôćĺ\\t\\tt.Error(\\\"unexpected '## Prompts' section when prompts are empty\\\")\\n   468Ôćĺ\\t}\\n   469Ôćĺ\\t// Should NOT have summary section when empty\\n   470Ôćĺ\\tif strings.Contains(contentStr, \\\"## Summary\\\") {\\n   471Ôćĺ\\t\\tt.Error(\\\"unexpected '## Summary' section when summary is empty\\\")\\n   472Ôćĺ\\t}\\n   473Ôćĺ}\\n   474Ôćĺ\\n   475Ôćĺ// --- Event type routing tests ---\\n   476Ôćĺ\\n   477Ôćĺfunc TestDispatchLifecycleEvent_RoutesToCorrectHandler(t *testing.T) {\\n   478Ôćĺ\\tt.Parallel()\\n   479Ôćĺ\\n   480Ôćĺ\\t// Test that each event type is routed (we can't easily verify which handler\\n   481Ôćĺ\\t// was called without dependency injection, but we can verify no panic and\\n   482Ôćĺ\\t// expected error types for each event type with minimal required data)\\n   483Ôćĺ\\n   484Ôćĺ\\ttestCases := []struct {\\n   485Ôćĺ\\t\\tname        string\\n   486Ôćĺ\\t\\teventType   agent.EventType\\n   487Ôćĺ\\t\\tsessionID   string\\n   488Ôćĺ\\t\\texpectError bool\\n   489Ôćĺ\\t\\terrorSubstr string\\n   490Ôćĺ\\t}{\\n   491Ôćĺ\\t\\t{\\n   492Ôćĺ\\t\\t\\tname:        \\\"SessionStart with empty session ID\\\",\\n   493Ôćĺ\\t\\t\\teventType:   agent.SessionStart,\\n   494Ôćĺ\\t\\t\\tsessionID:   \\\"\\\",\\n   495Ôćĺ\\t\\t\\texpectError: true,\\n   496Ôćĺ\\t\\t\\terrorSubstr: \\\"no session_id\\\",\\n   497Ôćĺ\\t\\t},\\n   498Ôćĺ\\t\\t{\\n   499Ôćĺ\\t\\t\\tname:        \\\"TurnStart with empty session ID\\\",\\n   500Ôćĺ\\t\\t\\teventType:   agent.TurnStart,\\n   501Ôćĺ\\t\\t\\tsessionID:   \\\"\\\",\\n   502Ôćĺ\\t\\t\\texpectError: true,\\n   503Ôćĺ\\t\\t\\terrorSubstr: \\\"no session_id\\\",\\n   504Ôćĺ\\t\\t},\\n   505Ôćĺ\\t\\t{\\n   506Ôćĺ\\t\\t\\tname:        \\\"TurnEnd with empty transcript\\\",\\n   507Ôćĺ\\t\\t\\teventType:   agent.TurnEnd,\\n   50