Ôćĺ\\t\\t\\t}\\n   910Ôćĺ\\t\\tcase st.Staging == git.Modified || st.Worktree == git.Modified:\\n   911Ôćĺ\\t\\t\\tchange.status = \\\"modified\\\"\\n   912Ôćĺ\\t\\t\\t// Modified file - compute diff stats\\n   913Ôćĺ\\t\\t\\tvar headContent, workContent []byte\\n   914Ôćĺ\\t\\t\\tif entry, err := headTree.File(file); err == nil {\\n   915Ôćĺ\\t\\t\\t\\tif content, err := entry.Contents(); err == nil {\\n   916Ôćĺ\\t\\t\\t\\t\\theadContent = []byte(content)\\n   917Ôćĺ\\t\\t\\t\\t}\\n   918Ôćĺ\\t\\t\\t}\\n   919Ôćĺ\\t\\t\\tabsPath := filepath.Join(repoRoot, file)\\n   920Ôćĺ\\t\\t\\tif content, err := os.ReadFile(absPath); err == nil { //nolint:gosec // absPath is repo root + relative path from git status\\n   921Ôćĺ\\t\\t\\t\\tworkContent = content\\n   922Ôćĺ\\t\\t\\t}\\n   923Ôćĺ\\t\\t\\tif headContent != nil && workContent != nil {\\n   924Ôćĺ\\t\\t\\t\\tchange.added, change.removed = computeDiffStats(headContent, workContent)\\n   925Ôćĺ\\t\\t\\t}\\n   926Ôćĺ\\t\\tdefault:\\n   927Ôćĺ\\t\\t\\tcontinue\\n   928Ôćĺ\\t\\t}\\n   929Ôćĺ\\n   930Ôćĺ\\t\\tchanges = append(changes, change)\\n   931Ôćĺ\\t}\\n   932Ôćĺ\\n   933Ôćĺ\\tif len(changes) == 0 {\\n   934Ôćĺ\\t\\treturn true, \\\"\\\", nil\\n   935Ôćĺ\\t}\\n   936Ôćĺ\\n   937Ôćĺ\\t// Sort changes by filename for consistent output\\n   938Ôćĺ\\tsort.Slice(changes, func(i, j int) bool {\\n   939Ôćĺ\\t\\treturn changes[i].filename < changes[j].filename\\n   940Ôćĺ\\t})\\n   941Ôćĺ\\n   942Ôćĺ\\tvar msg strings.Builder\\n   943Ôćĺ\\tmsg.WriteString(\\\"The following uncommitted changes will be reverted:\\\\n\\\")\\n   944Ôćĺ\\n   945Ôćĺ\\ttotalAdded, totalRemoved := 0, 0\\n   946Ôćĺ\\tfor _, c := range changes {\\n   947Ôćĺ\\t\\ttotalAdded += c.added\\n   948Ôćĺ\\t\\ttotalRemoved += c.removed\\n   949Ôćĺ\\n   950Ôćĺ\\t\\tvar stats string\\n   951Ôćĺ\\t\\tswitch {\\n   952Ôćĺ\\t\\tcase c.added > 0 && c.removed > 0:\\n   953Ôćĺ\\t\\t\\tstats = fmt.Sprintf(\\\"+%d/-%d\\\", c.added, c.removed)\\n   954Ôćĺ\\t\\tcase c.added > 0:\\n   955Ôćĺ\\t\\t\\tstats = fmt.Sprintf(\\\"+%d\\\", c.added)\\n   956Ôćĺ\\t\\tcase c.removed > 0:\\n   957Ôćĺ\\t\\t\\tstats = fmt.Sprintf(\\\"-%d\\\", c.removed)\\n   958Ôćĺ\\t\\t}\\n   959Ôćĺ\\n   960Ôćĺ\\t\\tmsg.WriteString(fmt.Sprintf(\\\"  %-10s %s\\\", c.status+\\\":\\\", c.filename))\\n   961Ôćĺ\\t\\tif stats != \\\"\\\" {\\n   962Ôćĺ\\t\\t\\tmsg.WriteString(fmt.Sprintf(\\\" (%s)\\\", stats))\\n   963Ôćĺ\\t\\t}\\n   964Ôćĺ\\t\\tmsg.WriteString(\\\"\\\\n\\\")\\n   965Ôćĺ\\t}\\n   966Ôćĺ\\n   967Ôćĺ\\tif totalAdded > 0 || totalRemoved > 0 {\\n   968Ôćĺ\\t\\tmsg.WriteString(fmt.Sprintf(\\\"\\\\nTotal: +%d/-%d lines\\\\n\\\", totalAdded, totalRemoved))\\n   969Ôćĺ\\t}\\n   970Ôćĺ\\n   971Ôćĺ\\treturn true, msg.String(), nil\\n   972Ôćĺ}\\n   973Ôćĺ\\n   974Ôćĺ// countLines counts the number of lines in content.\\n   975Ôćĺfunc countLines(content []byte) int {\\n   976Ôćĺ\\tif len(content) == 0 {\\n   977Ôćĺ\\t\\treturn 0\\n   978Ôćĺ\\t}\\n   979Ôćĺ\\tcount := 1\\n   980Ôćĺ\\tfor _, b := range content {\\n   981Ôćĺ\\t\\tif b == '\\\\n' {\\n   982Ôćĺ\\t\\t\\tcount++\\n   983Ôćĺ\\t\\t}\\n   984Ôćĺ\\t}\\n   985Ôćĺ\\t// Don't count trailing newline as extra line\\n   986Ôćĺ\\tif len(content) > 0 && content[len(content)-1] == '\\\\n' {\\n   987Ôćĺ\\t\\tcount--\\n   988Ôćĺ\\t}\\n   989Ôćĺ\\treturn count\\n   990Ôćĺ}\\n   991Ôćĺ\\n   992Ôćĺ// computeDiffStats computes added and removed line counts between old and new content.\\n   993Ôćĺ// Uses a simple line-based diff algorithm.\\n   994Ôćĺfunc computeDiffStats(oldContent, newContent []byte) (added, removed int) {\\n   995Ôćĺ\\toldLines := splitLines(oldContent)\\n   996Ôćĺ\\tnewLines := splitLines(newContent)\\n   997Ôćĺ\\n   998Ôćĺ\\t// Build a set of old lines with counts\\n   999Ôćĺ\\toldSet := make(map[string]int)\\n  1000Ôćĺ\\tfor _, line := range oldLines {\\n  1001Ôćĺ\\t\\toldSet[line]++\\n  1002Ôćĺ\\t}\\n  1003Ôćĺ\\n  1004Ôćĺ\\t// Check which new lines are truly new\\n  1005Ôćĺ\\tfor _, line := range newLines {\\n  1006Ôćĺ\\t\\tif oldSet[line] > 0 {\\n  1007Ôćĺ\\t\\t\\toldSet[line]--\\n  1008Ôćĺ\\t\\t} else {\\n  1009Ôćĺ\\t\\t\\tadded++\\n  1010Ôćĺ\\t\\t}\\n  1011Ôćĺ\\t}\\n  1012Ôćĺ\\n  1013Ôćĺ\\t// Remaining old lines are removed\\n  1014Ôćĺ\\tfor _, count := range oldSet {\\n  1015Ôćĺ\\t\\tremoved += count\\n  1016Ôćĺ\\t}\\n  1017Ôćĺ\\n  1018Ôćĺ\\treturn added, removed\\n  1019Ôćĺ}\\n  1020Ôćĺ\\n  1021Ôćĺ// splitLines splits content into lines, preserving empty lines.\\n  1022Ôćĺfunc splitLines(content []byte) []string {\\n  1023Ôćĺ\\tif len(content) == 0 {\\n  1024Ôćĺ\\t\\treturn nil\\n  1025Ôćĺ\\t}\\n  1026Ôćĺ\\ts := string(content)\\n  1027Ôćĺ\\t// Remove trailing newline to avoid empty last element\\n  1028Ôćĺ\\ts = strings.TrimSuffix(s, \\\"\\\\n\\\")\\n  1029Ôćĺ\\treturn strings.Split(s, \\\"\\\\n\\\")\\n  1030Ôćĺ}\\n  1031Ôćĺ\\n  1032Ôćĺ// fileExists checks if a file exists at the given path.\\n  1033Ôćĺfunc fileExists(path string) bool {\\n  1034Ôćĺ\\t_, err := os.Stat(path)\\n  1035Ôćĺ\\treturn err == nil\\n  1036Ôćĺ}\\n  1037Ôćĺ\\n  1038Ôćĺ// StageFilesContext describes what type of staging operation this is (for messages).\\n  1039Ôćĺtype StageFilesContext string\\n  1040Ôćĺ\\n  1041Ôćĺconst (\\n  1042Ôćĺ\\t// StageForSession is used when staging files for a session checkpoint.\\n  1043Ôćĺ\\tStageForSession StageFilesContext = \\\"session\\\"\\n  1044Ôćĺ\\t// StageForTask is used when staging files for a task checkpoint.\\n  1045Ôćĺ\\tStageForTask StageFilesContext = \\\"task\\\"\\n  1046Ôćĺ)\\n  1047Ôćĺ\\n  1048Ôćĺ// StageFiles stages modified, new, and deleted files to the git worktree.\\n  1049Ôćĺ//\\n  1050Ôćĺ// This function handles three categories of file changes:\\n  1051Ôćĺ//  1. Modified files: existing files that have been changed\\n  1052Ôćĺ//  2. New files: files that were created during the session\\n  1053Ôćĺ//  3. Deleted files: files that were removed during the session\\n  1054Ôćĺ//\\n  1055Ôćĺ// Error Handling Strategy:\\n  1056Ôćĺ//   - Individual file staging errors are logged to stderr but don't fail the operation\\n  1057Ôćĺ//   - This ensures that partial staging succeeds even if some files have issues\\n  1058Ôćĺ//   - If a modified file no longer exists, it's treated as a deletion\\n  1059Ôćĺ//\\n  1060Ôćĺ// The stageCtx parameter is used for user-facing messages to indicate whether\\n  1061Ôćĺ// this is staging for a session checkpoint or a task checkpoint.\\n  1062Ôćĺfunc StageFiles(worktree *git.Worktree, modified, newFiles, deleted []string, stageCtx StageFilesContext) {\\n  1063Ôćĺ\\t// Get repo root for resolving file paths\\n  1064Ôćĺ\\t// This is critical because fileExists() uses os.Stat() which resolves relative to CWD,\\n  1065Ôćĺ\\t// but worktree.Add/Remove resolve relative to repo root. If CWD != repo root,\\n  1066Ôćĺ\\t// fileExists() could return false for existing files, causing worktree.Remove()\\n  1067Ôćĺ\\t// to incorrectly delete them.\\n  1068Ôćĺ\\trepoRoot := worktree.Filesystem.Root()\\n  1069Ôćĺ\\n  1070Ôćĺ\\t// Stage modified files\\n  1071Ôćĺ\\tfor _, file := range modified {\\n  1072Ôćĺ\\t\\t// Resolve path relative to repo root for existence check\\n  1073Ôćĺ\\t\\tabsPath := filepath.Join(repoRoot, file)\\n  1074Ôćĺ\\t\\tif fileExists(absPath) {\\n  1075Ôćĺ\\t\\t\\tif _, err := worktree.Add(file); err != nil {\\n  1076Ôćĺ\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage %s: %v\\\\n\\\", file, err)\\n  1077Ôćĺ\\t\\t\\t} else {\\n  1078Ôćĺ\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged: %s\\\\n\\\", file)\\n  1079Ôćĺ\\t\\t\\t}\\n  1080Ôćĺ\\t\\t} else {\\n  1081Ôćĺ\\t\\t\\t// File was deleted - stage the deletion\\n  1082Ôćĺ\\t\\t\\tif _, err := worktree.Remove(file); err != nil {\\n  1083Ôćĺ\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  File not found or deleted: %s\\\\n\\\", file)\\n  1084Ôćĺ\\t\\t\\t}\\n  1085Ôćĺ\\t\\t}\\n  1086Ôćĺ\\t}\\n  1087Ôćĺ\\n  1088Ôćĺ\\t// Stage new files\\n  1089Ôćĺ\\tif len(newFiles) > 0 {\\n  1090Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Staging %d new files created during %s:\\\\n\\\", len(newFiles), stageCtx)\\n  1091Ôćĺ\\t\\tfor _, file := range newFiles {\\n  1092Ôćĺ\\t\\t\\tif _, err := worktree.Add(file); err != nil {\\n  1093Ôćĺ\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage %s: %v\\\\n\\\", file, err)\\n  1094Ôćĺ\\t\\t\\t} else {\\n  1095Ôćĺ\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged new file: %s\\\\n\\\", file)\\n  1096Ôćĺ\\t\\t\\t}\\n  1097Ôćĺ\\t\\t}\\n  1098Ôćĺ\\t}\\n  1099Ôćĺ\\n  1100Ôćĺ\\t// Stage deleted files\\n  1101Ôćĺ\\tfor _, file := range deleted {\\n  1102Ôćĺ\\t\\tif _, err := worktree.Remove(file); err != nil {\\n  1103Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Failed to stage deleted file %s: %v\\\\n\\\", file, err)\\n  1104Ôćĺ\\t\\t} else {\\n  1105Ôćĺ\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Staged deleted file: %s\\\\n\\\", file)\\n  1106Ôćĺ\\t\\t}\\n  1107Ôćĺ\\t}\\n  1108Ôćĺ}\\n  1109Ôćĺ\\n  1110Ôćĺ// getTaskCheckpointFromTree retrieves a task checkpoint from a commit tree.\\n  1111Ôćĺ// Shared implementation for shadow and linear-shadow strategies.\\n  1112Ôćĺfunc getTaskCheckpointFromTree(point RewindPoint) (*TaskCheckpoint, error) {\\n  1113Ôćĺ\\tif !point.IsTaskCheckpoint {\\n  1114Ôćĺ\\t\\treturn nil, ErrNotTaskCheckpoint\\n  1115Ôćĺ\\t}\\n  1116Ôćĺ\\n  1117Ôćĺ\\trepo, err := OpenRepository()\\n  1118Ôćĺ\\tif err != nil {\\n  1119Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n  1120Ôćĺ\\t}\\n  1121Ôćĺ\\n  1122Ôćĺ\\tcommitHash := plumbing.NewHash(point.ID)\\n  1123Ôćĺ\\tcommit, err := repo.CommitObject(commitHash)\\n  1124Ôćĺ\\tif err != nil {\\n  1125Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n  1126Ôćĺ\\t}\\n  1127Ôćĺ\\n  1128Ôćĺ\\ttree, err := commit.Tree()\\n  1129Ôćĺ\\tif err != nil {\\n  1130Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n  1131Ôćĺ\\t}\\n  1132Ôćĺ\\n  1133Ôćĺ\\t// Read checkpoint.json from the tree\\n  1134Ôćĺ\\tcheckpointPath := point.MetadataDir + \\\"/checkpoint.json\\\"\\n  1135Ôćĺ\\tfile, err := tree.File(checkpointPath)\\n  1136Ôćĺ\\tif err != nil {\\n  1137Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to find checkpoint at %s: %w\\\", checkpointPath, err)\\n  1138Ôćĺ\\t}\\n  1139Ôćĺ\\n  1140Ôćĺ\\tcontent, err := file.Contents()\\n  1141Ôćĺ\\tif err != nil {\\n  1142Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n  1143Ôćĺ\\t}\\n  1144Ôćĺ\\n  1145Ôćĺ\\tvar checkpoint TaskCheckpoint\\n  1146Ôćĺ\\tif err := json.Unmarshal([]byte(content), &checkpoint); err != nil {\\n  1147Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to parse checkpoint: %w\\\", err)\\n  1148Ôćĺ\\t}\\n  1149Ôćĺ\\n  1150Ôćĺ\\treturn &checkpoint, nil\\n  1151Ôćĺ}\\n  1152Ôćĺ\\n  1153Ôćĺ// getTaskTranscriptFromTree retrieves a task transcript from a commit tree.\\n  1154Ôćĺ// Shared implementation for shadow and linear-shadow strategies.\\n  1155Ôćĺfunc getTaskTranscriptFromTree(point RewindPoint) ([]byte, error) {\\n  1156Ôćĺ\\tif !point.IsTaskCheckpoint {\\n  1157Ôćĺ\\t\\treturn nil, ErrNotTaskCheckpoint\\n  1158Ôćĺ\\t}\\n  1159Ôćĺ\\n  1160Ôćĺ\\trepo, err := OpenRepository()\\n  1161Ôćĺ\\tif err != nil {\\n  1162Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n  1163Ôćĺ\\t}\\n  1164Ôćĺ\\n  1165Ôćĺ\\tcommitHash := plumbing.NewHash(point.ID)\\n  1166Ôćĺ\\tcommit, err := repo.CommitObject(commitHash)\\n  1167Ôćĺ\\tif err != nil {\\n  1168Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n  1169Ôćĺ\\t}\\n  1170Ôćĺ\\n  1171Ôćĺ\\ttree, err := commit.Tree()\\n  1172Ôćĺ\\tif err != nil {\\n  1173Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to get tree: %w\\\", err)\\n  1174Ôćĺ\\t}\\n  1175Ôćĺ\\n  1176Ôćĺ\\t// MetadataDir format: .entire/metadata/<session>/tasks/<toolUseID>\\n  1177Ôćĺ\\t// Session transcript is at: .entire/metadata/<session>/<TranscriptFileName>\\n  1178Ôćĺ\\tsessionDir := filepath.Dir(filepath.Dir(point.MetadataDir))\\n  1179Ôćĺ\\n  1180Ôćĺ\\t// Try current format first, then legacy\\n  1181Ôćĺ\\ttranscriptPath := sessionDir + \\\"/\\\" + paths.TranscriptFileName\\n  1182Ôćĺ\\tfile, err := tree.File(transcriptPath)\\n  1183Ôćĺ\\tif err != nil {\\n  1184Ôćĺ\\t\\ttranscriptPath = sessionDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n  1185Ôćĺ\\t\\tfile, err = tree.File(transcriptPath)\\n  1186Ôćĺ\\t\\tif err != nil {\\n  1187Ôćĺ\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to find transcript: %w\\\", err)\\n  1188Ôćĺ\\t\\t}\\n  1189Ôćĺ\\t}\\n  1190Ôćĺ\\n  1191Ôćĺ\\tcontent, err := file.Contents()\\n  1192Ôćĺ\\tif err != nil {\\n  1193Ôćĺ\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n  1194Ôćĺ\\t}\\n  1195Ôćĺ\\n  1196Ôćĺ\\treturn []byte(content), nil\\n  1197Ôćĺ}\\n  1198Ôćĺ\\n  1199Ôćĺ// ErrBranchNotFound is returned by DeleteBranchCLI when the branch does not exist.\\n  1200Ôćĺvar ErrBranchNotFound = errors.New(\\\"branch not found\\\")\\n  1201Ôćĺ\\n  1202Ôćĺ// DeleteBranchCLI deletes a git branch using the git CLI.\\n  1203Ôćĺ// Uses `git branch -D` instead of go-git's RemoveReference because go-git v5\\n  1204Ôćĺ// doesn't properly persist deletions when refs are packed (.git/packed-refs)\\n  1205Ôćĺ// or in a worktree context. This is the same class of go-git v5 bug that\\n  1206Ôćĺ// affects checkout and reset --hard (see HardResetWithProtection).\\n  1207Ôćĺ//\\n  1208Ôćĺ// Returns ErrBranchNotFound if the branch does not exist, allowing callers\\n  1209Ôćĺ// to use errors.Is for idempotent deletion patterns.\\n  1210Ôćĺfunc DeleteBranchCLI(branchName string) error {\\n  1211Ôćĺ\\tctx := context.Background()\\n  1212Ôćĺ\\n  1213Ôćĺ\\t// Pre-check: verify the branch exists so callers get a structured error\\n  1214Ôćĺ\\t// instead of parsing git's output string (which varies across locales).\\n  1215Ôćĺ\\t// git show-ref exits 1 for \\\"not found\\\" and 128+ for fatal errors (corrupt\\n  1216Ôćĺ\\t// repo, permissions, not a git directory). Only map exit code 1 to\\n  1217Ôćĺ\\t// ErrBranchNotFound; propagate other failures as-is.\\n  1218Ôćĺ\\tcheck := exec.CommandContext(ctx, \\\"git\\\", \\\"show-ref\\\", \\\"--verify\\\", \\\"--quiet\\\", \\\"refs/heads/\\\"+branchName) //nolint:gosec // branchName comes from internal shadow branch naming\\n  1219Ôćĺ\\tif err := check.Run(); err != nil {\\n  1220Ôćĺ\\t\\tvar exitErr *exec.ExitError\\n  1221Ôćĺ\\t\\tif errors.As(err, &exitErr) && exitErr.ExitCode() == 1 {\\n  1222Ôćĺ\\t\\t\\treturn fmt.Errorf(\\\"%w: %s\\\", ErrBranchNotFound, branchName)\\n  1223Ôćĺ\\t\\t}\\n  1224Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to check branch %s: %w\\\", branchName, err)\\n  1225Ôćĺ\\t}\\n  1226Ôćĺ\\n  1227Ôćĺ\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", branchName)\\n  1228Ôćĺ\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1229Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to delete branch %s: %s: %w\\\", branchName, strings.TrimSpace(string(output)), err)\\n  1230Ôćĺ\\t}\\n  1231Ôćĺ\\treturn nil\\n  1232Ôćĺ}\\n  1233Ôćĺ\\n  1234Ôćĺ// branchExistsCLI checks if a branch exists using git CLI.\\n  1235Ôćĺ// Returns nil if the branch exists, or an error if it does not.\\n  1236Ôćĺfunc branchExistsCLI(branchName string) error {\\n  1237Ôćĺ\\tctx := context.Background()\\n  1238Ôćĺ\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"show-ref\\\", \\\"--verify\\\", \\\"--quiet\\\", \\\"refs/heads/\\\"+branchName) //nolint:gosec // branchName comes from internal shadow branch naming\\n  1239Ôćĺ\\tif err := cmd.Run(); err != nil {\\n  1240Ôćĺ\\t\\treturn fmt.Errorf(\\\"branch %s not found: %w\\\", branchName, err)\\n  1241Ôćĺ\\t}\\n  1242Ôćĺ\\treturn nil\\n  1243Ôćĺ}\\n  1244Ôćĺ\\n  1245Ôćĺ// HardResetWithProtection performs a git reset --hard to the specified commit.\\n  1246Ôćĺ// Uses the git CLI instead of go-git because go-git's HardReset incorrectly\\n  1247Ôćĺ// deletes untracked directories (like .entire/) even when they're in .gitignore.\\n  1248Ôćĺ// Returns the short commit I