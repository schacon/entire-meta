n    87Ôćĺfunc NewAutoCommitStrategy() Strategy {\\n    88Ôćĺ\\treturn &AutoCommitStrategy{}\\n    89Ôćĺ}\\n    90Ôćĺ\\n    91Ôćĺfunc (s *AutoCommitStrategy) Name() string {\\n    92Ôćĺ\\treturn StrategyNameAutoCommit\\n    93Ôćĺ}\\n    94Ôćĺ\\n    95Ôćĺfunc (s *AutoCommitStrategy) Description() string {\\n    96Ôćĺ\\treturn \\\"Auto-commits code to active branch with metadata on entire/checkpoints/v1\\\"\\n    97Ôćĺ}\\n    98Ôćĺ\\n    99Ôćĺfunc (s *AutoCommitStrategy) ValidateRepository() error {\\n   100Ôćĺ\\trepo, err := OpenRepository()\\n   101Ôćĺ\\tif err != nil {\\n   102Ôćĺ\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   103Ôćĺ\\t}\\n   104Ôćĺ\\n   105Ôćĺ\\t_, err = repo.Worktree()\\n   106Ôćĺ\\tif err != nil {\\n   107Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to access worktree: %w\\\", err)\\n   108Ôćĺ\\t}\\n   109Ôćĺ\\n   110Ôćĺ\\treturn nil\\n   111Ôćĺ}\\n   112Ôćĺ\\n   113Ôćĺ// PrePush is called by the git pre-push hook before pushing to a remote.\\n   114Ôćĺ// It pushes the entire/checkpoints/v1 branch alongside the user's push.\\n   115Ôćĺ// Configuration options (stored in .entire/settings.json under strategy_options.push_sessions):\\n   116Ôćĺ//   - \\\"auto\\\": always push automatically\\n   117Ôćĺ//   - \\\"prompt\\\" (default): ask user with option to enable auto\\n   118Ôćĺ//   - \\\"false\\\"/\\\"off\\\"/\\\"no\\\": never push\\n   119Ôćĺfunc (s *AutoCommitStrategy) PrePush(remote string) error {\\n   120Ôćĺ\\treturn pushSessionsBranchCommon(remote, paths.MetadataBranchName)\\n   121Ôćĺ}\\n   122Ôćĺ\\n   123Ôćĺfunc (s *AutoCommitStrategy) SaveStep(ctx StepContext) error {\\n   124Ôćĺ\\trepo, err := OpenRepository()\\n   125Ôćĺ\\tif err != nil {\\n   126Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   127Ôćĺ\\t}\\n   128Ôćĺ\\n   129Ôćĺ\\t// Generate checkpoint ID for this commit\\n   130Ôćĺ\\tcpID, err := id.Generate()\\n   131Ôćĺ\\tif err != nil {\\n   132Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   133Ôćĺ\\t}\\n   134Ôćĺ\\t// Step 1: Commit code changes to active branch with checkpoint ID trailer\\n   135Ôćĺ\\t// We do code first to avoid orphaned metadata if this step fails.\\n   136Ôćĺ\\t// If metadata commit fails after this, the code commit exists but GetRewindPoints\\n   137Ôćĺ\\t// already handles missing metadata gracefully (skips commits without metadata).\\n   138Ôćĺ\\tcodeResult, err := s.commitCodeToActive(repo, ctx, cpID)\\n   139Ôćĺ\\tif err != nil {\\n   140Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to commit code to active branch: %w\\\", err)\\n   141Ôćĺ\\t}\\n   142Ôćĺ\\n   143Ôćĺ\\t// If no code commit was created (no changes), skip metadata creation\\n   144Ôćĺ\\t// This prevents orphaned metadata commits that don't correspond to any code commit\\n   145Ôćĺ\\tif !codeResult.Created {\\n   146Ôćĺ\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   147Ôćĺ\\t\\tlogging.Info(logCtx, \\\"checkpoint skipped (no changes)\\\",\\n   148Ôćĺ\\t\\t\\tslog.String(\\\"strategy\\\", \\\"auto-commit\\\"),\\n   149Ôćĺ\\t\\t\\tslog.String(\\\"checkpoint_type\\\", \\\"session\\\"),\\n   150Ôćĺ\\t\\t)\\n   151Ôćĺ\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipped checkpoint (no changes since last commit)\\\\n\\\")\\n   152Ôćĺ\\t\\treturn nil\\n   153Ôćĺ\\t}\\n   154Ôćĺ\\n   155Ôćĺ\\t// Step 2: Commit metadata to entire/checkpoints/v1 branch using sharded path\\n   156Ôćĺ\\t// Path is <checkpointID[:2]>/<checkpointID[2:]>/ for direct lookup\\n   157Ôćĺ\\t_, err = s.commitMetadataToMetadataBranch(repo, ctx, cpID)\\n   158Ôćĺ\\tif err != nil {\\n   159Ôćĺ\\t\\treturn fmt.Errorf(\\\"failed to commit metadata to entire/checkpoints/v1 branch: %w\\\", err)\\n   160Ôćĺ\\t}\\n   161Ôćĺ\\n   162Ôćĺ\\t// Log checkpoint creation\\n   163Ôćĺ\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   164Ôćĺ\\tlogging.Info(logCtx, \\\"checkpoint saved\\\",\\n   165Ôćĺ\\t\\tslog.String(\\\"strategy\\