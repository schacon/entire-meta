y fully set up.\\n   177→// Returns whether it's fully enabled, and if so, the agent type display name and config file path.\\n   178→func isFullyEnabled() (enabled bool, agentDesc string, configPath string) {\\n   179→\\t// Check settings exist and Enabled == true\\n   180→\\ts, err := LoadEntireSettings()\\n   181→\\tif err != nil || !s.Enabled {\\n   182→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   183→\\t}\\n   184→\\n   185→\\t// Check any agent hooks installed (not just Claude Code — works with Gemini too)\\n   186→\\tinstalledAgents := GetAgentsWithHooksInstalled()\\n   187→\\tif len(installedAgents) == 0 {\\n   188→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   189→\\t}\\n   190→\\n   191→\\t// Check git hooks installed\\n   192→\\tif !strategy.IsGitHookInstalled() {\\n   193→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   194→\\t}\\n   195→\\n   196→\\t// Check .entire directory exists\\n   197→\\tif !checkEntireDirExists() {\\n   198→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   199→\\t}\\n   200→\\n   201→\\t// Determine agent description from first installed agent\\n   202→\\tdesc := string(installedAgents[0]) // fallback to agent name\\n   203→\\tif ag, err := agent.Get(installedAgents[0]); err == nil {\\n   204→\\t\\tdesc = string(ag.Type())\\n   205→\\t}\\n   206→\\n   207→\\t// Determine config path - check if local settings exists, otherwise show project settings\\n   208→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   209→\\tif err != nil {\\n   210→\\t\\tentireDirAbs = paths.EntireDir\\n   211→\\t}\\n   212→\\tconfigDisplay := configDisplayProject\\n   213→\\tlocalSettingsPath := filepath.Join(entireDirAbs, \\\"settings.local.json\\\")\\n   214→\\tif _, err := os.Stat(localSettingsPath); err == nil {\\n   215→\\t\\tconfigDisplay = configDisplayLocal\\n   216→\\t}\\n   217→\\n   218→\\treturn true, desc, configDisplay\\n   219→}\\n   220→\\n   221→// runEnableWithStrategy enables Entire with a specified strategy (non-interactive).\\n   222→// The