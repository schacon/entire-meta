oks); err != nil {\\n   347→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   348→\\t\\t}\\n   349→\\t}\\n   350→\\n   351→\\t// Setup .entire directory\\n   352→\\tif _, err := setupEntireDirectory(); err != nil {\\n   353→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   354→\\t}\\n   355→\\n   356→\\t// Use the default strategy (manual-commit)\\n   357→\\tinternalStrategy := strategy.DefaultStrategyName\\n   358→\\n   359→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   360→\\tsettings, err := LoadEntireSettings()\\n   361→\\tif err != nil {\\n   362→\\t\\t// If we can't load, start with defaults\\n   363→\\t\\tsettings = &EntireSettings{}\\n   364→\\t}\\n   365→\\t// Update the specific fields\\n   366→\\tsettings.Strategy = internalStrategy\\n   367→\\tsettings.LocalDev = localDev\\n   368→\\tsettings.Enabled = true\\n   369→\\n   370→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   371→\\tif skipPushSessions {\\n   372→\\t\\tif settings.StrategyOptions == nil {\\n   373→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   374→\\t\\t}\\n   375→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   376→\\t}\\n   377→\\n   378→\\t// Determine which settings file to write to\\n   379→\\t// First run always creates settings.json (no prompt)\\n   380→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   381→\\tif err != nil {\\n   382→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   383→\\t}\\n   384→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   385→\\n   386→\\tif showNotification {\\n   387→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   388→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   389→\\t}\\n   390→\\n   391→\\t// Helper to save settings to the appropriate file\\n   392→\\tsaveSettings := func() error {\\n   393→\\t\\tif shouldUseLocal {\\n   394→\\t\\t\\treturn SaveEntireSettingsLocal(settings)\\n   395→\\t\\t}\\n   396→\\t\\treturn SaveEntireSettings(settings)\\n   397→\\t}\\n   398→\\n   399→\\t// Save settings before telemetry prompt so config is persisted even if the user cancels\\n   400→\\tif err := saveSettings(); err != nil {\\n   401→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   402→\\t}\\n   403→\\n   404→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   405→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   406→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   407→\\t}\\n   408→\\tstrategy.CheckAndWarnHookManagers(w)\\n   409→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   410→\\n   411→\\tconfigDisplay := configDisplayProject\\n   412→\\tif shouldUseLocal {\\n   413→\\t\\tconfigDisplay = configDisplayLocal\\n   414→\\t}\\n   415→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   416→\\n   417→\\t// Ask about telemetry consent (only if not already asked)\\n   418→\\tfmt.Fprintln(w)\\n   419→\\tif err := promptTelemetryConsent(settings, telemetry); err != nil {\\n   420→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   421→\\t}\\n   422→\\t// Save again to persist telemetry choice\\n   423→\\tif err := saveSettings(); err != nil {\\n   424→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   425→\\t}\\n   426→\\n   427→\\t// Let the strategy handle its own setup requirements\\n   428→\\tstrat, err := strategy.Get(internalStrategy)\\n   429→\\tif err != nil {\\n   430→\\t\\treturn fmt.Errorf(\\\"failed to get strategy: %w\\\", err)\\n   431→\\t}\\n   432→\\tif err := strat.EnsureSetup(); err != nil {\\n   433→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   434→\\t}\\n   435→\\n   436→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   437→\\n   438→\\treturn nil\\n   439→}\\n   440→\\n   441→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   442→func runEnable(w io.Writer) error {\\n   443→\\tsettings, err := LoadEntireSettings()\\n   444→\\tif err != nil {\\n   445→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   446→\\t}\\n   447→\\n   448→\\tsettings.Enabled = true\\n   449→\\tif err := SaveEntireSettings(settings); err != nil {\\n   450→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   451→\\t}\\n   452→\\n   453→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   454→\\treturn nil\\n   455→}\\n   456→\\n   457→func runDisable(w io.Writer, useProjectSettings bool) error {\\n   458→\\tsettings, err := LoadEntireSettings()\\n   459→\\tif err != nil {\\n   460→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   461→\\t}\\n   462→\\n   463→\\tsettings.Enabled = false\\n   464→\\n   465→\\t// If --project flag is specified, always write to project settings\\n   466→\\tif useProjectSettings {\\n   467→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   468→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   469→\\t\\t}\\n   470→\\t} else {\\n   471→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   472→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   473→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   474→\\t\\t}\\n   475→\\t}\\n   476→\\n   477→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   478→\\treturn nil\\n   479→}\\n   480→\\n   481→// DisabledMessage is the message shown when Entire is disabled\\n   482→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   483→\\n   484→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   485→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   486→// On error reading settings, defaults to enabled (returns false).\\n   487→func checkDisabledGuard(w io.Writer) bool {\\n   488→\\tenabled, err := IsEnabled()\\n   489→\\tif err != nil {\\n   490→\\t\\t// Default to enabled on error\\n   491→\\t\\treturn false\\n   492→\\t}\\n   493→\\tif !enabled {\\n   494→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   495→\\t\\treturn true\\n   496→\\t}\\n   497→\\treturn false\\n   498→}\\n   499→\\n   500→// setupAgentHooks sets up hooks for a given agent.\\n   501→// Returns the number of hooks installed (0 if already installed).\\n   502→func setupAgentHooks(ag agent.Agent, localDev, forceHooks bool) (int, error) { //nolint:unparam // return value used by setupAgentHooksNonInteractive\\n   503→\\thookAgent, ok := ag.(agent.HookSupport)\\n   504→\\tif !ok {\\n   505→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   506→\\t}\\n   507→\\n   508→\\tcount, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   509→\\tif err != nil {\\n   510→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   511→\\t}\\n   512→\\n   513→\\treturn count, nil\\n   514→}\\n   515→\\n   516→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   517→// Returns the detected/selected agents and any error.\\n   518→// When exactly one agent is detected, it is used automatically.\\n   519→// When multiple agents are detected, the user is prompted to confirm.\\n   520→// If no agent is detected and no TTY is available, falls back to the default agent.\\n   521→func detectOrSelectAgent(w io.Writer) ([]agent.Agent, error) {\\n   522→\\t// Try auto-detection first\\n   523→\\tdetected := agent.DetectAll()\\n   524→\\n   525→\\tswitch {\\n   526→\\tcase len(detected) == 1:\\n   527→\\t\\t// Single agent detected — use it directly\\n   528→\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   529→\\t\\treturn detected, nil\\n   530→\\n   531→\\tcase len(detected) > 1:\\n   532→\\t\\t// Multiple agents detected — prompt the user to confirm which to enable\\n   533→\\t\\tagentTypes := make([]string, 0, len(detected))\\n   534→\\t\\tfor _, ag := range detected {\\n   535→\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   536→\\t\\t}\\n   537→\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   538→\\t\\tfmt.Fprintln(w)\\n   539→\\t\\t// Fall through to the interactive multi-select below\\n   540→\\t}\\n   541→\\n   542→\\t// No agent detected (or multiple detected) — check if we can prompt interactively\\n   543→\\tif !canPromptInteractively() {\\n   544→\\t\\tif len(detected) > 0 {\\n   545→\\t\\t\\t// Multiple agents detected but no TTY — use all of them\\n   546→\\t\\t\\treturn detected, nil\\n   547→\\t\\t}\\n   548→\\t\\t// No TTY available (e.g., running in CI or tests) - fall back to default agent\\n   549→\\t\\tdefaultAgent := agent.Default()\\n   550→\\t\\tif defaultAgent == nil {\\n   551→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   552→\\t\\t}\\n   553→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   554→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   555→\\t}\\n   556→\\n   557→\\tif len(detected) == 0 {\\n   558→\\t\\t// Show message only when nothing was detected\\n   559→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., .claude or .gemini directory).\\\")\\n   560→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   561→\\t\\tfmt.Fprintln(w)\\n   562→\\t}\\n   563→\\n   564→\\t// Build a set of detected agent names for pre-selection\\n   565→\\tdetectedSet := make(map[agent.AgentName]struct{}, len(detected))\\n   566→\\tfor _, ag := range detected {\\n   567→\\t\\tdetectedSet[ag.Name()] = struct{}{}\\n   568→\\t}\\n   569→\\n   570→\\t// Build options from registered agents\\n   571→\\tagentNames := agent.List()\\n   572→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   573→\\tfor _, name := range agentNames {\\n   574→\\t\\tag, err := agent.Get(name)\\n   575→\\t\\tif err != nil {\\n   576→\\t\\t\\tcontinue\\n   577→\\t\\t}\\n   578→\\t\\t// Only show agents that support hooks\\n   579→\\t\\tif _, ok := ag.(agent.HookSupport); !ok {\\n   580→\\t\\t\\tcontinue\\n   581→\\t\\t}\\n   582→\\t\\tlabel := string(ag.Type())\\n   583→\\t\\tif name == agent.DefaultAgentName {\\n   584→\\t\\t\\tlabel += \\\" (default)\\\"\\n   585→\\t\\t}\\n   586→\\t\\topt := huh.NewOption(label, string(name))\\n   587→\\t\\tif _, isDetected := detectedSet[name]; isDetected {\\n   588→\\t\\t\\topt = opt.Selected(true)\\n   589→\\t\\t}\\n   590→\\t\\toptions = append(options, opt)\\n   591→\\t}\\n   592→\\n   593→\\tif len(options) == 0 {\\n   594→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   595→\\t}\\n   596→\\n   597→\\tvar selectedAgentNames []string\\n   598→\\tform := NewAccessibleForm(\\n   599→\\t\\thuh.NewGroup(\\n   600→\\t\\t\\thuh.NewMultiSelect[string]().\\n   601→\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   602→\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   603→\\t\\t\\t\\tOptions(options...).\\n   604→\\t\\t\\t\\tValue(&selectedAgentNames),\\n   605→\\t\\t),\\n   606→\\t)\\n   607→\\n   608→\\tif err := form.Run(); err != nil {\\n   609→\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   610→\\t}\\n   611→\\n   612→\\tif len(selectedAgentNames) == 0 {\\n   613→\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   614→\\t}\\n   615→\\n   616→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   617→\\tfor _, name := range selectedAgentNames {\\n   618→\\t\\tselectedAgent, err := agent.Get(agent.AgentName(name))\\n   619→\\t\\tif err != nil {\\n   620→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   621→\\t\\t}\\n   622→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   623→\\t}\\n   624→\\n   625→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   626→\\tfor _, ag := range selectedAgents {\\n   627→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   628→\\t}\\n   629→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   630→\\treturn selectedAgents, nil\\n   631→}\\n   632→\\n   633→// canPromptInteractively checks if we can show interactive prompts.\\n   634→// Returns false when running in CI, tests, or other non-interactive environments.\\n   635→func canPromptInteractively() bool {\\n   636→\\t// Check for test environment\\n   637→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   638→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   639→\\t}\\n   640→\\n   641→\\t// Check if /dev/tty is available\\n   642→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   643→\\tif err != nil {\\n   644→\\t\\treturn false\\n   645→\\t}\\n   646→\\t_ = tty.Close()\\n   647→\\treturn true\\n   648→}\\n   649→\\n   650→// printAgentError writes an error message followed by available agents and usage.\\n   651→func printAgentError(w io.Writer, message string) {\\n   652→\\tagents := agent.List()\\n   653→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   654→\\tfmt.Fprintln(w)\\n   655→\\tfor _, a := range agents {\\n   656→\\t\\tsuffix := \\\"\\\"\\n   657→\\t\\tif a == agent.DefaultAgentName {\\n   658→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   659→\\t\\t}\\n   660→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   661→\\t}\\n   662→\\tfmt.Fprintln(w)\\n   663→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   664→}\\n   665→\\n   666→// printMissingAgentError writes a helpful error listing available agents.\\n   667→func printMissingAgentError(w io.Writer) {\\n   668→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   669→}\\n   670→\\n   671→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   672→func printWrongAgentError(w io.Writer, name string) {\\n   673→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   674→}\\n   675→\\n   676→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   677→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   678→func setupAgentHooksNonInteractive(w io.Writer, ag agent.Agent, strategyName string, localDev, forceHooks, skipPushSessions, telemetry bool) error {\\n   679→\\tagentName := ag.Name()\\n   680→\\t// Check if agent supports hooks\\n   681→\\thookAgent, ok := ag.(agent.HookSupport)\\n   682→\\tif !ok {\\n   683→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   684→\\t}\\n   685→\\n   686→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   687→\\n   688→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   689→\\tinstalledHooks, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   690→\\tif err != nil {\\n   691→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   692→\\t}\\n   693→\\n   694→\\t// Setup .entire directory\\n   695→\\tif _, err := setupEntireDirectory(); err != nil {\\n   696→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   697→\\t}\\n   698→\\n   699→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   700→\\tsettings, err := LoadEntireSettings()\\n   701→\\tif err != nil {\\n   702→\\t\\t// If we can't load, start with defaults\\n   703→\\t\\tsettings = &EntireSettings{Strategy: strategy.DefaultStrategyName}\\n   704→\\t}\\n   705→\\tsettings.Enabled = true\\n   706→\\tif localDev {\\n   707→\\t\\tsettings.LocalDev = localDev\\n   708→\\t}\\n   709→\\n   710→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   711→\\tif skipPushSessions {\\n   712→\\t\\tif settings.StrategyOptions == nil {\\n   713→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   714→\\t\\t}\\n   715→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   716→\\t}\\n   717→\\n   718→\\t// Set strategy if provided\\n   719→\\tif strategyName != \\\"\\\" {\\n   720→\\t\\t// Map display name to internal name if needed\\n   721→\\t\\tinternalStrategy := strategyName\\n   722→\\t\\tif mapped, ok := strategyDisplayToInternal[strategyName]; ok {\\n   723→\\t\\t\\tinternalStrategy = mapped\\n   724→\\t\\t}\\n   725→\\t\\t// Validate the strategy exists\\n   726→\\t\\tif _, err := strategy.Get(internalStrategy); err != nil {\\n   727→\\t\\t\\treturn fmt.Errorf(\\\"unknown strategy: %s (use manual-commit or auto-commit)\\\", strategyName)\\n   728→\\t\\t}\\n   729→\\t\\tsettings.Strategy = internalStrategy\\n   730→\\t}\\n   731→\\n   732→\\t// Handle telemetry for non-interactive mode\\n   733→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   734→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   735→\\t\\tf := false\\n   736→\\t\\tsettings.Telemetry = &f\\n   737→\\t}\\n   738→\\n   739→\\tif err := SaveEntireSettings(settings); err != nil {\\n   740→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   741→\\t}\\n   742→\\n   743→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   744→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   745→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   746→\\t}\\n   747→\\tstrategy.CheckAndWarnHookManagers(w)\\n   748→\\n   749→\\tif installedHooks == 0 {\\n   750→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   751→\\t\\tif agentName == agent.AgentNameGemini {\\n   752→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   753→\\t\\t}\\n   754→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   755→\\t} else {\\n   756→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   757→\\t\\tif agentName == agent.AgentNameGemini {\\n   758→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   759→\\t\\t}\\n   760→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   761→\\t}\\n   762→\\n   763→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   764→\\n   765→\\t// Let the strategy handle its own setup requirements (creates entire/checkpoints/v1 branch, etc.)\\n   766→\\tstrat, err := strategy.Get(settings.Strategy)\\n   767→\\tif err != nil {\\n   768→\\t\\treturn fmt.Errorf(\\\"failed to get strategy: %w\\\", err)\\n   769→\\t}\\n   770→\\tif err := strat.EnsureSetup(); err != nil {\\n   771→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   772→\\t}\\n   773→\\n   774→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   775→\\n   776→\\treturn nil\\n   777→}\\n   778→\\n   779→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   780→func validateSetupFlags(useLocal, useProject bool) error {\\n   781→\\tif useLocal && useProject {\\n   782→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   783→\\t}\\n   784→\\treturn nil\\n   785→}\\n   786→\\n   787→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   788→// - Whether settings.json already exists\\n   789→// - The --local and --project flags\\n   790→// Returns (useLocal, showNotification).\\n   791→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   792→\\t// Explicit --local flag always uses local settings\\n   793→\\tif useLocal {\\n   794→\\t\\treturn true, false\\n   795→\\t}\\n   796→\\n   797→\\t// Explicit --project flag always uses project settings\\n   798→\\tif useProject {\\n   799→\\t\\treturn false, false\\n   800→\\t}\\n   801→\\n   802→\\t// No flags specified - check if settings file exists\\n   803→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   804→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   805→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   806→\\t\\treturn true, true\\n   807→\\t}\\n   808→\\n   809→\\t// Settings file doesn't exist - create it\\n   810→\\treturn false, false\\n   811→}\\n   812→\\n   813→// setupEntireDirectory creates the .entire directory and gitignore.\\n   814→// Returns true if the directory was created, false if it already existed.\\n   815→func setupEntireDirectory() (bool, error) { //nolint:unparam // already present in codebase\\n   816→\\t// Get absolute path for the .entire directory\\n   817→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   818→\\tif err != nil {\\n   819→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   820→\\t}\\n   821→\\n   822→\\t// Check if directory already exists\\n   823→\\tcreated := false\\n   824→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   825→\\t\\tcreated = true\\n   826→\\t}\\n   827→\\n   828→\\t// Create .entire directory\\n   829→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   830→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   831→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   832→\\t}\\n   833→\\n   834→\\t// Create/update .gitignore with all required entries\\n   835→\\tif err := strategy.EnsureEntireGitignore(); err != nil {\\n   836→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   837→\\t}\\n   838→\\n   839→\\treturn created, nil\\n   840→}\\n   841→\\n   842→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   843→func setupGitHook() error {\\n   844→\\t// Use shared implementation from strategy package\\n   845→\\t// The localDev setting is read from settings.json\\n   846→\\t_, err := strategy.InstallGitHook(false) // not silent - show output during setup\\n   847→\\tif err != nil {\\n   848→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   849→\\t}\\n   850→\\tstrategy.CheckAndWarnHookManagers(os.Stderr)\\n   851→\\treturn nil\\n   852→}\\n   853→\\n   854→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   855→func newSetupGitHookCmd() *cobra.Command {\\n   856→\\tcmd := &cobra.Command{\\n   857→\\t\\tUse:    \\\"git-hook\\\",\\n   858→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   859→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   860→\\t\\tRunE: func(_ *cobra.Command, _ []string) error {\\n   861→\\t\\t\\treturn setupGitHook()\\n   862→\\t\\t},\\n   863→\\t}\\n   864→\\n   865→\\treturn cmd\\n   866→}\\n   867→\\n   868→func newCurlBashPostInstallCmd() *cobra.Command {\\n   869→\\treturn &cobra.Command{\\n   870→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   871→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   872→\\t\\tHidden: true,\\n   873→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   874→\\t\\t\\tw := cmd.OutOrStdout()\\n   875→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   876→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   877→\\t\\t\\t}\\n   878→\\t\\t\\treturn nil\\n   879→\\t\\t},\\n   880→\\t}\\n   881→}\\n   882→\\n   883→// shellCompletionComment is the comment preceding the completion line\\n   884→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   885→\\n   886→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   887→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   888→\\n   889→// shellCompletionTarget returns the rc file path and completion lines for the\\n   890→// user's current shell.\\n   891→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   892→\\thome, err := os.UserHomeDir()\\n   893→\\tif err != nil {\\n   894→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   895→\\t}\\n   896→\\n   897→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   898→\\tswitch {\\n   899→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   900→\\t\\treturn \\\"Zsh\\\",\\n   901→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   902→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   903→\\t\\t\\tnil\\n   904→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   905→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   906→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   907→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   908→\\t\\t}\\n   909→\\t\\treturn \\\"Bash\\\",\\n   910→\\t\\t\\tbashRC,\\n   911→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   912→\\t\\t\\tnil\\n   913→\\tcase strings.Contains(shell, \\\"fish\\\"):\\n   914→\\t\\treturn \\\"Fish\\\",\\n   915→\\t\\t\\tfilepath.Join(home, \\\".config\\\", \\\"fish\\\", \\\"config.fish\\\"),\\n   916→\\t\\t\\t\\\"entire completion fish | source\\\",\\n   917→\\t\\t\\tnil\\n   918→\\tdefault:\\n   919→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   920→\\t}\\n   921→}\\n   922→\\n   923→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   924→// Only prompts if completion is not already configured.\\n   925→func promptShellCompletion(w io.Writer) error {\\n   926→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   927→\\tif err != nil {\\n   928→\\t\\tif errors.Is(err, errUnsupportedShell) {\\n   929→\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion not available for your shell. Supported: zsh, bash, fish.\\\\n\\\")\\n   930→\\t\\t\\treturn nil\\n   931→\\t\\t}\\n   932→\\t\\treturn fmt.Errorf(\\\"shell completion: %w\\\", err)\\n   933→\\t}\\n   934→\\n   935→\\tif isCompletionConfigured(rcFile) {\\n   936→\\t\\tfmt.Fprintf(w, \\\"✓ Shell completion already configured in %s\\\\n\\\", rcFile)\\n   937→\\t\\treturn nil\\n   938→\\t}\\n   939→\\n   940→\\tvar selected string\\n   941→\\tform := NewAccessibleForm(\\n   942→\\t\\thuh.NewGroup(\\n   943→\\t\\t\\thuh.NewSelect[string]().\\n   944→\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Enable shell completion? (detected: %s)\\\", shellName)).\\n   945→\\t\\t\\t\\tOptions(\\n   946→\\t\\t\\t\\t\\thuh.NewOption(\\\"Yes\\\", \\\"yes\\\"),\\n   947→\\t\\t\\t\\t\\thuh.NewOption(\\\"No\\\", \\\"no\\\"),\\n   948→\\t\\t\\t\\t).\\n   949→\\t\\t\\t\\tValue(&selected),\\n   950→\\t\\t),\\n   951→\\t)\\n   952→\\n   953→\\tif err := form.Run(); err != nil {\\n   954→\\t\\t//nolint:nilerr // User cancelled - not a fatal error, just skip\\n   955→\\t\\treturn nil\\n   956→\\t}\\n   957→\\n   958→\\tif selected != \\\"yes\\\" {\\n   959→\\t\\treturn nil\\n   960→\\t}\\n   961→\\n   962→\\tif err := appendShellCompletion(rcFile, completionLine); err != nil {\\n   963→\\t\\treturn fmt.Errorf(\\\"failed to update %s: %w\\\", rcFile, err)\\n   964→\\t}\\n   965→\\n   966→\\tfmt.Fprintf(w, \\\"✓ Shell completion added to %s\\\\n\\\", rcFile)\\n   967→\\tfmt.Fprintln(w, \\\"  Restart your shell to activate\\\")\\n   968→\\n   969→\\treturn nil\\n   970→}\\n   971→\\n   972→// isCompletionConfigured checks if shell completion is already in the rc file.\\n   973→func isCompletionConfigured(rcFile string) bool {\\n   974→\\t//nolint:gosec // G304: rcFile is constructed from home dir + known filename, not user input\\n   975→\\tcontent, err := os.ReadFile(rcFile)\\n   976→\\tif err != nil {\\n   977→\\t\\treturn false // File doesn't exist or can't read, treat as not configured\\n   978→\\t}\\n   979→\\treturn strings.Contains(string(content), \\\"entire completion\\\")\\n   980→}\\n   981→\\n   982→// appendShellCompletion adds the completion line to the rc file.\\n   983→func appendShellCompletion(rcFile, completionLine string) error {\\n   984→\\tif err := os.MkdirAll(filepath.Dir(rcFile), 0o700); err != nil {\\n   985→\\t\\treturn fmt.Errorf(\\\"creating directory: %w\\\", err)\\n   986→\\t}\\n   987→\\t//nolint:gosec // G302: Shell rc files need 0644 for user readability\\n   988→\\tf, err := os.OpenFile(rcFile, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0o644)\\n   989→\\tif err != nil {\\n   990→\\t\\treturn fmt.Errorf(\\\"opening file: %w\\\", err)\\n   991→\\t}\\n   992→\\tdefer f.Close()\\n   993→\\n   994→\\t_, err = f.WriteString(\\\"\\\\n\\\" + shellCompletionComment + \\\"\\\\n\\\" + completionLine + \\\"\\\\n\\\")\\n   995→\\tif err != nil {\\n   996→\\t\\treturn fmt.Errorf(\\\"writing completion: %w\\\", err)\\n   997→\\t}\\n   998→\\treturn nil\\n   999→}\\n  1000→\\n  1001→// promptTelemetryConsent asks the user if they want to enable telemetry.\\n  1002→// It modifies settings.Telemetry based on the user's choice or flags.\\n  1003→// The caller is responsible for saving settings.\\n  1004→func promptTelemetryConsent(settings *EntireSettings, telemetryFlag bool) error {\\n  1005→\\t// Handle --telemetry=false flag first (always overrides existing setting)\\n  1006→\\tif !telemetryFlag {\\n  1007→\\t\\tf := false\\n  1008→\\t\\tsettings.Telemetry = &f\\n  1009→\\t\\treturn nil\\n  1010→\\t}\\n  1011→\\n  1012→\\t// Skip if already asked\\n  1013→\\tif settings.Telemetry != nil {\\n  1014→\\t\\treturn nil\\n  1015→\\t}\\n  1016→\\n  1017→\\t// Skip if env var disables telemetry (record as disabled)\\n  1018→\\tif os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n  1019→\\t\\tf := false\\n  1020→\\t\\tsettings.Telemetry = &f\\n  1021→\\t\\treturn nil\\n  1022→\\t}\\n  1023→\\n  1024→\\tconsent := true // Default to Yes\\n  1025→\\tform := NewAccessibleFor