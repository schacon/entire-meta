us checkpoint, so the write is skipped.\\n   197→func benchWriteTemporaryDedup() func(*testing.B) {\\n   198→\\treturn func(b *testing.B) {\\n   199→\\t\\trepo := benchutil.NewBenchRepo(b, benchutil.RepoOpts{FileCount: 10})\\n   200→\\t\\tsessionID := repo.CreateSessionState(b, benchutil.SessionOpts{})\\n   201→\\t\\trepo.SeedShadowBranch(b, sessionID, 1, 3)\\n   202→\\n   203→\\t\\t// Don't modify any files — tree will match the previous checkpoint\\n   204→\\t\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   205→\\t\\tmetadataDirAbs := filepath.Join(repo.Dir, metadataDir)\\n   206→\\n   207→\\t\\tb.Chdir(repo.Dir)\\n   208→\\n   209→\\t\\tctx := context.Background()\\n   210→\\t\\tb.ResetTimer()\\n   211→\\t\\tfor range b.N {\\n   212→\\t\\t\\tresult, writeErr := repo.Store.WriteTemporary(ctx, checkpoint.WriteTemporaryOptions{\\n   213→\\t\\t\\t\\tSessionID:         sessionID,\\n   214→\\t\\t\\t\\tBaseCommit:        repo.HeadHash,\\n   215→\\t\\t\\t\\tWorktreeID:        repo.WorktreeID,\\n   216→\\t\\t\\t\\tModifiedFiles:     []string{\\\"src/file_000.go\\\", \\\"src/file_001.go\\\", \\\"src/file_002.go\\\"},\\n   217→\\t\\t\\t\\tMetadataDir:       metadataDir,\\n   218→\\t\\t\\t\\tMetadataDirAbs:    metadataDirAbs,\\n   219→\\t\\t\\t\\tCommitMessage:     \\\"benchmark checkpoint\\\",\\n   220→\\t\\t\\t\\tAuthorName:        \\\"Bench\\\",\\n   221→\\t\\t\\t\\tAuthorEmail:       \\\"bench@test.com\\\",\\n   222→\\t\\t\\t\\tIsFirstCheckpoint: false,\\n   223→\\t\\t\\t})\\n   224→\\t\\t\\tif writeErr != nil {\\n   225→\\t\\t\\t\\tb.Fatalf(\\\"WriteTemporary: %v\\\", writeErr)\\n   226→\\t\\t\\t}\\n   227→\\t\\t\\tif !result.Skipped {\\n   228→\\t\\t\\t\\tb.Fatal(\\\"expected dedup skip\\\")\\n   229→\\t\\t\\t}\\n   230→\\t\\t}\\n   231→\\t}\\n   232→}\\n   233→\\n   234→// benchWriteTemporaryWithHistory benchmarks WriteTemporary when the shadow branch\\n   235→// already has many prior checkpoint commits.\\n   236→func benchWriteTemporaryWithHis