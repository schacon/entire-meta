riteCommitted benchmarks ---\\n   279→// WriteCommitted fires during PostCommit condensation when the user does `git commit`.\\n   280→// It writes session metadata to the entire/checkpoints/v1 branch.\\n   281→\\n   282→func BenchmarkWriteCommitted(b *testing.B) {\\n   283→\\tb.Run(\\\"SmallTranscript\\\", benchWriteCommitted(20, 500, 3, 0))\\n   284→\\tb.Run(\\\"MediumTranscript\\\", benchWriteCommitted(200, 500, 15, 0))\\n   285→\\tb.Run(\\\"LargeTranscript\\\", benchWriteCommitted(2000, 500, 50, 0))\\n   286→\\tb.Run(\\\"HugeTranscript\\\", benchWriteCommitted(10000, 1000, 100, 0))\\n   287→\\tb.Run(\\\"EmptyMetadataBranch\\\", benchWriteCommitted(200, 500, 15, 0))\\n   288→\\tb.Run(\\\"FewPriorCheckpoints\\\", benchWriteCommitted(200, 500, 15, 10))\\n   289→\\tb.Run(\\\"ManyPriorCheckpoints\\\", benchWriteCommitted(200, 500, 15, 200))\\n   290→}\\n   291→\\n   292→// benchWriteCommitted benchmarks writing to the entire/checkpoints/v1 branch.\\n   293→func benchWriteCommitted(messageCount, avgMsgBytes, filesTouched, priorCheckpoints int) func(*testing.B) {\\n   294→\\treturn func(b *testing.B) {\\n   295→\\t\\trepo := benchutil.NewBenchRepo(b, benchutil.RepoOpts{\\n   296→\\t\\t\\tFileCount: max(filesTouched, 10),\\n   297→\\t\\t})\\n   298→\\n   299→\\t\\t// Seed prior checkpoints if requested\\n   300→\\t\\tif priorCheckpoints > 0 {\\n   301→\\t\\t\\trepo.SeedMetadataBranch(b, priorCheckpoints)\\n   302→\\t\\t}\\n   303→\\n   304→\\t\\t// Pre-generate transcript data (not part of the benchmark)\\n   305→\\t\\tfiles := make([]string, 0, filesTouched)\\n   306→\\t\\tfor i := range filesTouched {\\n   307→\\t\\t\\tfiles = append(files, fmt.Sprintf(\\\"src/file_%03d.go\\\", i))\\n   308→\\t\\t}\\n   309→\\t\\ttranscript := benchutil.GenerateTranscript(benchutil.TranscriptOpts{\\n   310→\\t\\t\\tMessageCount:    messageCount,\\n   311→\\t\\t\\tAvgMessageBytes: avgMsgBytes,\\n   312→\\t\\t\\tIncludeToolUse:  true,\\n   313→\\t\\t\\tFilesTouched:    files,\\n   314→\