lements the Agent interface for Cursor.\\n    25→//\\n    26→//nolint:revive // CursorAgent is clearer than Agent in this context\\n    27→type CursorAgent struct{}\\n    28→\\n    29→// NewCursorAgent creates a new Cursor agent instance.\\n    30→func NewCursorAgent() agent.Agent {\\n    31→\\treturn &CursorAgent{}\\n    32→}\\n    33→\\n    34→// Name returns the agent registry key.\\n    35→func (c *CursorAgent) Name() types.AgentName {\\n    36→\\treturn agent.AgentNameCursor\\n    37→}\\n    38→\\n    39→// Type returns the agent type identifier.\\n    40→func (c *CursorAgent) Type() types.AgentType {\\n    41→\\treturn agent.AgentTypeCursor\\n    42→}\\n    43→\\n    44→// Description returns a human-readable description.\\n    45→func (c *CursorAgent) Description() string {\\n    46→\\treturn \\\"Cursor - AI-powered code editor\\\"\\n    47→}\\n    48→\\n    49→func (c *CursorAgent) IsPreview() bool { return true }\\n    50→\\n    51→// DetectPresence checks if Cursor is configured in the repository.\\n    52→func (c *CursorAgent) DetectPresence(ctx context.Context) (bool, error) {\\n    53→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    54→\\tif err != nil {\\n    55→\\t\\tworktreeRoot = \\\".\\\"\\n    56→\\t}\\n    57→\\n    58→\\tcursorDir := filepath.Join(worktreeRoot, \\\".cursor\\\")\\n    59→\\tif _, err := os.Stat(cursorDir); err == nil {\\n    60→\\t\\treturn true, nil\\n    61→\\t}\\n    62→\\treturn false, nil\\n    63→}\\n    64→\\n    65→// GetSessionID extracts the session ID from hook input.\\n    66→func (c *CursorAgent) GetSessionID(input *agent.HookInput) string {\\n    67→\\treturn input.SessionID\\n    68→}\\n    69→\\n    70→// ResolveSessionFile returns the path to a Cursor session file.\\n    71→// Cursor IDE uses a nested layout: <dir>/<id>/<id>.jsonl\\n    72→// Cursor CLI uses a flat layout: <dir>/<id>.jsonl\\n    73→// We prefer nested if the file OR directory exists (the directory may be created\\n    74→// before the file is flushed), otherwise fall back to flat.\\n    75→func (c *CursorAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n    76→\\tnestedDir := filepath.Join(sessionDir, agentSessionID)\\n    77→\\tnested := filepath.Join(nestedDir, agentSessionID+\\\".jsonl\\\")\\n    78→\\tif _, err := os.Stat(nested); err == nil {\\n    79→\\t\\treturn nested\\n    80→\\t}\\n    81→\\t// IDE creates the directory before the transcript file — predict nested path.\\n    82→\\tif info, err := os.Stat(nestedDir); err == nil && info.IsDir() {\\n    83→\\t\\treturn nested\\n    84→\\t}\\n    85→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".jsonl\\\")\\n    86→}\\n    87→\\n    88→// ProtectedDirs returns directories that Cursor uses for config/state.\\n    89→func (c *CursorAgent) ProtectedDirs() []string { return []string{\\\".cursor\\\"} }\\n    90→\\n    91→// GetSessionDir returns the directory where Cursor stores session transcripts.\\n    92→func (c *CursorAgent) GetSessionDir(repoPath string) (string, error) {\\n    93→\\tif override := os.Getenv(\\\"ENTIRE_TEST_CURSOR_PROJECT_DIR\\\"); override != \\\"\\\" {\\n    94→\\t\\treturn override, nil\\n    95→\\t}\\n    96→\\n    97→\\thomeDir, err := os.UserHomeDir()\\n    98→\\tif err != nil {\\n    99→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   100→\\t}\\n   101→\\n   102→\\tprojectDir := sanitizePathForCursor(repoPath)\\n   103→\\treturn filepath.Join(homeDir, \\\".cursor\\\", \\\"projects\\\", projectDir, \\\"agent-transcripts\\\"), nil\\n   104→}\\n   105→\\n   106→// ReadSession reads a session from Cursor's storage (JSONL transcript file).\\n   107→// Note: ModifiedFiles is left empty because Cursor's transcript does not contain\\n   108→// tool_use blocks for file detection. TranscriptAnalyzer extracts prompts and\\n   109→// summaries; file detection relies on git status.\\n   110→func (c *CursorAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   111→\\tif input.SessionRef == \\\"\\\" {\\n   112→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   113→\\t}\\n   114→\\n   115→\\tdata, err := os.ReadFile(input.SessionRef)\\n   116→\\tif err != nil {\\n   117→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   118→\\t}\\n   119→\\n   120→\\treturn &agent.AgentSession{\\n   121→\\t\\tSessionID:  input.SessionID,\\n   122→\\t\\tAgentName:  c.Name(),\\n   123→\\t\\tSessionRef: input.SessionRef,\\n   124→\\t\\tStartTime:  time.Now(),\\n   125→\\t\\tNativeData: data,\\n   126→\\t}, nil\\n   127→}\\n   128→\\n   129→// WriteSession writes a session to Cursor's storage (JSONL transcript file).\\n   130→func (c *CursorAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   131→\\tif session == nil {\\n   132→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   133→\\t}\\n   134→\\n   135→\\tif session.AgentName != \\\"\\\" && session.AgentName != c.Name() {\\n   136→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, c.Name())\\n   137→\\t}\\n   138→\\n   139→\\tif session.SessionRef == \\\"\\\" {\\n   140→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   141→\\t}\\n   142→\\n   143→\\tif len(session.NativeData) == 0 {\\n   144→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   145→\\t}\\n   146→\\n   147→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   148→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   149→\\t}\\n   150→\\n   151→\\treturn nil\\n   152→}\\n   153→\\n   154→// FormatResumeCommand returns an instruction to resume a Cursor session.\\n   155→// Cursor is a GUI IDE, so there's no CLI command to resume a session directly.\\n   156→func (c *CursorAgent) FormatResumeCommand(_ string) string {\\n   157→\\treturn \\\"Open this project in Cursor t