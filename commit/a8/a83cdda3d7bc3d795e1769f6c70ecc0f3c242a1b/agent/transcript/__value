g\\\")\\n   134→\\t\\t\\t}\\n   135→\\n   136→\\t\\t\\t// Convert short flag to verbose (verbose = !short)\\n   137→\\t\\t\\tverbose := !shortFlag\\n   138→\\t\\t\\treturn runExplain(cmd.Context(), cmd.OutOrStdout(), cmd.ErrOrStderr(), sessionFlag, commitFlag, checkpointFlag, noPagerFlag, verbose, fullFlag, rawTranscriptFlag, generateFlag, forceFlag, searchAllFlag)\\n   139→\\t\\t},\\n   140→\\t}\\n   141→\\n   142→\\tcmd.Flags().StringVar(&sessionFlag, \\\"session\\\", \\\"\\\", \\\"Filter checkpoints by session ID (or prefix)\\\")\\n   143→\\tcmd.Flags().StringVar(&commitFlag, \\\"commit\\\", \\\"\\\", \\\"Explain a specific commit (SHA or ref, \\\\\\\"commit-ish\\\\\\\")\\\")\\n   144→\\tcmd.Flags().StringVarP(&checkpointFlag, \\\"checkpoint\\\", \\\"c\\\", \\\"\\\", \\\"Explain a specific checkpoint (ID or prefix)\\\")\\n   145→\\tcmd.Flags().BoolVar(&noPagerFlag, \\\"no-pager\\\", false, \\\"Disable pager output\\\")\\n   146→\\tcmd.Flags().BoolVarP(&shortFlag, \\\"short\\\", \\\"s\\\", false, \\\"Show summary only (omit prompts and files)\\\")\\n   147→\\tcmd.Flags().BoolVar(&fullFlag, \\\"full\\\", false, \\\"Show full parsed transcript (all prompts/responses)\\\")\\n   148→\\tcmd.Flags().BoolVar(&rawTranscriptFlag, \\\"raw-transcript\\\", false, \\\"Show raw transcript file (JSONL format)\\\")\\n   149→\\tcmd.Flags().BoolVar(&generateFlag, \\\"generate\\\", false, \\\"Generate an AI summary for the checkpoint\\\")\\n   150→\\tcmd.Flags().BoolVar(&forceFlag, \\\"force\\\", false, \\\"Regenerate summary even if one already exists (requires --generate)\\\")\\n   151→\\tcmd.Flags().BoolVar(&searchAllFlag, \\\"search-all\\\", false, \\\"Search all commits (no branch/depth limit, may be slow)\\\")\\n   152→\\n   153→\\t// Make --short, --full, and --raw-transcript mutually exclusive\\n   154→\\tcmd.MarkFlagsMutuallyExclusive(\\\"short\\\", \\\"full\\\", \\\"raw-transcript\\\")\\n   155→\\t// --generate and --raw-transcript are incompatible (summary would be generated but not shown)\\n   156→\\tcmd.MarkFlagsMutuallyExclusive(\\\"generate\\\", \\\"raw-transcript\\\")\\n   157→\\n   158→\\treturn cmd\\n   159→}\\n   160→\\n   161→// runExplain routes to the appropriate explain function based on flags.\\n   162→func runExplain(ctx context.Context, w, errW io.Writer, sessionID, commitRef, checkpointID string, noPager, verbose, full, rawTranscript, generate, force, searchAll bool) error {\\n   163→\\t// Count mutually exclusive flags (--commit and --checkpoint are mutually exclusive)\\n   164→\\t// --session is now a filter for the list view, not a separate mode\\n   165→\\tflagCount := 0\\n   166→\\tif commitRef != \\\"\\\" {\\n   167→\\t\\tflagCount++\\n   168→\\t}\\n   169→\\tif checkpointID != \\\"\\\" {\\n   170→\\t\\tflagCount++\\n   171→\\t}\\n   172→\\t// If --session is combined with --commit or --checkpoint, that's still an error\\n   173→\\tif sessionID != \\\"\\\" && flagCount > 0 {\\n   174→\\t\\treturn errors.New(\\\"cannot specify multiple of --session, --commit, --checkpoint\\\")\\n   175→\\t}\\n   176→\\tif flagCount > 1 {\\n   177→\\t\\treturn errors.New(\\\"cannot specify multiple of --session, --commit, --checkpoint\\\")\\n   178→\\t}\\n   179→\\n   180→\\t// Route to appropriate handler\\n   181→\\tif commitRef != \\\"\\\" {\\n   182→\\t\\treturn runExplainCommit(ctx, w, commitRef, noPager, verbose, full, searchAll)\\n   183→\\t}\\n   184→\\tif checkpointID != \\\"\\\" {\\n   185→\\t\\treturn runExplainCheckpoint(ctx, w, errW, checkpointID, noPager, verbose, full, rawTranscript, generate, force, searchAll)\\n   186→\\t}\\n   187→\\n   188→\\t// Default or with session filter: show list view (optionally filtered by session)\\n   189→\\treturn runExplainBranchWithFilter(ctx, w, noPager, sessionID)\\n   190→}\\n   191→\\n   192→// runExplainCheckpoint explains a specific checkpoint.\\n   193→// Supports both committed checkpoints (by checkpoint ID) and temporary checkpoints (by git SHA).\\n   194→// First tries to match committed checkpoints, then falls back to temporary checkpoints.\\n   195→// When generate is true, generates an AI summary for the checkpoint.\\n   196→// When force is true, regenerates even if a summary already exists.\\n   197→// When rawTranscript is true, outputs only the raw transcript file (JSONL format).\\n   198→// When searchAll is true, searches all commits without branch/depth limits (used for finding associated commits).\\n   199→func runExplainCheckpoint(ctx context.Context, w, errW io.Writer, checkpointIDPrefix string, noPager, verbose, full, rawTranscript, generate, force, searchAll bool) error {\\n   200→\\trepo, err := openRepository(ctx)\\n   201→\\tif err != nil {\\n   202→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   203→\\t}\\n   204→\\n   205→\\tstore := checkpoint.NewGitStore(repo)\\n   206→\\n   207→\\t// First, try to find in committed checkpoints by checkpoint ID prefix\\n   208→\\tcommitted, err := store.ListCommitted(ctx)\\n   209→\\tif err != nil {\\n   210→\\t\\treturn fmt.Errorf(\\\"failed to list checkpoints: %w\\\", err)\\n   211→\\t}\\n   212→\\n   213→\\t// Collect all matching checkpoint IDs to detect ambiguity\\n   214→\\tvar matches []id.CheckpointID\\n   215→\\tfor _, info := range committed {\\n   216→\\t\\tif strings.HasPrefix(info.CheckpointID.String(), checkpointIDPrefix) {\\n   217→\\t\\t\\tmatches = append(matches, info.CheckpointID)\\n   218→\\t\\t}\\n   219→\\t}\\n   220→\\n   221→\\tvar fullCheckpointID id.CheckpointID\\n   222→\\tswitch len(matches) {\\n   223→\\tcase 0:\\n   224→\\t\\t// Not found in committed, try temporary checkpoints by git SHA\\n   225→\\t\\tif generate {\\n   226→\\t\\t\\treturn fmt.Errorf(\\\"cannot generate summary for temporary checkpoint %s (only committed checkpoints supported)\\\", checkpointIDPrefix)\\n   227→\\t\\t}\\n   228→\\t\\toutput, found := explainTemporaryCheckpoint(ctx, w, repo, store, checkpointIDPrefix, verbose, full, rawTranscript)\\n   229→\\t\\tif found {\\n   230→\\t\\t\\toutputExplainContent(ctx, w, output, noPager)\\n   231→\\t\\t\\treturn nil\\n   232→\\t\\t}\\n   233→\\t\\t// If output is non-empty, it contains an error message (e.g., ambiguous prefix)\\n   234→\\t\\tif output != \\\"\\\" {\\n   235→\\t\\t\\treturn errors.New(output)\\n   236→\\t\\t}\\n   237→\\t\\treturn fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointIDPrefix)\\n   238→\\tcase 1:\\n   239→\\t\\tfullCheckpointID = matches[0]\\n   240→\\tdefault:\\n   241→\\t\\t// Ambiguous prefix - show up to 5 examples\\n   242→\\t\\texamples := make([]string, 0, 5)\\n   243→\\t\\tfor i := 0; i < len(matches) && i < 5; i++ {\\n   244→\\t\\t\\texamples = append(examples, matches[i].String())\\n   245→\\t\\t}\\n   246→\\t\\treturn fmt.Errorf(\\\"ambiguous checkpoint prefix %q matches %d checkpoints: %s\\\", checkpointIDPrefix, len(matches), strings.Join(examples, \\\", \\\"))\\n   247→\\t}\\n   248→\\n   249→\\t// Load checkpoint summary\\n   250→\\tsummary, err := store.ReadCommitted(ctx, fullCheckpointID)\\n   251→\\tif err != nil {\\n   252→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   253→\\t}\\n   254→\\tif summary == nil {\\n   255→\\t\\treturn fmt.Errorf(\\\"checkpoint not found: %s\\\", fullCheckpointID)\\n   256→\\t}\\n   257→\\n   258→\\t// Load latest session content (needed for transcript and metadata)\\n   259→\\tcontent, err := store.ReadLatestSessionContent(ctx, fullCheckpointID)\\n   260→\\tif err != nil {\\n   261→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint content: %w\\\", err)\\n   262→\\t}\\n   263→\\n   264→\\t// Handle summary generation\\n   265→\\tif generate {\\n   266→\\t\\tif err := generateCheckpointSummary(ctx, w, errW, store, fullCheckpointID, summary, content, force); err != nil {\\n   267→\\t\\t\\treturn err\\n   268→\\t\\t}\\n   269→\\t\\t// Reload the content to get the updated summary\\n   270→\\t\\tcontent, err = store.ReadLatestSessionContent(ctx, fullCheckpointID)\\n 