 6→import (\\n     7→\\t\\\"context\\\"\\n     8→\\t\\\"io\\\"\\n     9→\\n    10→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    11→)\\n    12→\\n    13→// Agent defines the interface for interacting with a coding agent.\\n    14→// Each agent implementation (Claude Code, Cursor, Aider, etc.) converts its\\n    15→// native format to the normalized types defined in this package.\\n    16→//\\n    17→// The interface is organized into three groups:\\n    18→//   - Identity (5 methods): Name, Type, Description, DetectPresence, ProtectedDirs\\n    19→//   - Transcript Storage (3 methods): ReadTranscript, ChunkTranscript, ReassembleTranscript\\n    20→//   - Legacy (6 methods): Will be moved to optional interfaces or removed in a future phase\\n    21→type Agent interface {\\n    22→\\t// --- Identity ---\\n    23→\\n    24→\\t// Name returns the agent registry key (e.g., \\\"claude-code\\\", \\\"gemini\\\")\\n    25→\\tName() types.AgentName\\n    26→\\n    27→\\t// Type returns the agent type identifier (e.g., \\\"Claude Code\\\", \\\"Gemini CLI\\\")\\n    28→\\t// This is stored in metadata and trailers.\\n    29→\\tType() types.AgentType\\n    30→\\n    31→\\t// Description returns a human-readable description for UI\\n    32→\\tDescription() string\\n    33→\\n    34→\\t// IsPreview returns whether the agent integration is in preview or stable\\n    35→\\tIsPreview() bool\\n    36→\\n    37→\\t// DetectPresence checks if this agent is configured in the repository\\n    38→\\tDetectPresence(ctx context.Context) (bool, error)\\n    39→\\n    40→\\t// ProtectedDirs returns repo-root-relative directories that should never be\\n    41→\\t// modified or deleted during rewind or other destructive operations.\\n    42→\\t// Examples: [\\\".claude\\\"] for Claude, [\\\".gemini\\\"] for Gemini.\\n    43→\\tProtectedDirs() []string\\n    44→\\n    45→\\t// --- Transcript Storage ---\\n    46→\\n    47→\\t// ReadTranscript reads the raw transcript bytes for a session.\\n    48→\\tReadTranscript(sessionRef string) ([]byte, error)\\n    49→\\n    50→\\t// ChunkTranscript splits a transcript into chunks if it exceeds maxSize.\\n    51→\\t// Returns a slice of chunks. If the transcript fits in one chunk, returns single-element slice.\\n    52→\\t// The chunking is format-aware: JSONL splits at line boundaries, JSON splits message arrays.\\n    53→\\tChunkTranscript(ctx context.Context, content []byte, maxSize int) ([][]byte, error)\\n    54→\\n    55→\\t// ReassembleTranscript combines chunks back into a single transcript.\\n    56→\\t// Handles format-specific reassembly (JSONL concatenation, JSON message merging).\\n    57→\\tReassembleTranscript(chunks [][]byte) ([]byte, error)\\n    58→\\n    59→\\t// --- Legacy methods (will move to optional interfaces in Phase 4) ---\\n    60→\\n    61→\\t// GetSessionID extracts session ID from hook input.\\n    62→\\tGetSessionID(input *HookInput) string\\n    63→\\n    64→\\t// GetSessionDir returns where agent stores session data for this repo.\\n    65→\\tGetSessionDir(repoPath string) (string, error)\\n    66→\\n    67→\\t// ResolveSessionFile returns the path to the session transcript file.\\n    68→\\tResolveSessionFile(sessionDir, agentSessionID string) string\\n    69→\\n    70→\\t// ReadSession reads session data from agent's storage.\\n    71→\\tReadSession(input *HookInput) (*AgentSession, error)\\n    72→\\n    73→\\t// WriteSession writes session data for resumption.\\n    74→\\tWriteSession(ctx context.Context, session *AgentSession) error\\n    75→\\n    76→\\t// FormatResumeCommand returns command to resume a session.\\n    77→\\tFormatResumeCommand(sessionID string) string\\n    78→}\\n    79→\\n    80→// HookSupport is implemented by agents with lifecycle hooks.\\n    81→// This optional interface allows agents like Claude Code and Cursor to\\n    82→// install and manage hooks that notify Entire of agent events.\\n    83→//\\n    84→// The interface is organized into two groups:\\n    85→//   - Hook Mapping (2 methods): HookNames, ParseHookEvent\\n    86→//   - Hook Management (3 methods): InstallHooks, UninstallHooks, AreHooksInstalled\\n    87→type HookSupport interface {\\n    88→\\tAgent\\n    89→\\n    90→\\t// HookNames returns the hook verbs this agent supports.\\n    91→\\t// These become subcommands under `entire hooks <agent>`.\\n    92→\\t// e.g., [\\\"stop\\\", \\\"user-prompt-submit\\\", \\\"session-start\\\", \\\"session-end\\\"]\\n    93→\\tHookNames() []string\\n    94→\\n    95→\\t// ParseHookEvent translates an agent-native hook into a normalized lifecycle Event.\\n    96→\\t// Returns nil if the hook has no lifecycle significance (e.g., pass-through hooks).\\n    97→\\t// This is the core contribution surface for new agent implementations.\\n    98→\\tParseHookEvent(ctx context.Context, hookName string, stdin io.Reader) (*Event, error)\\n    99→\\n   100→\\t// InstallHooks installs agent-specific hooks.\\n   101→\\t// If localDev is true, hooks point to local development build.\\n   102→\\t// If force is true, removes existing Entire hooks before installing.\\n   103→\\t// Returns the number of hooks installed.\\n   104→\\tInstallHooks(ctx context.Context, localDev bool, force bool) (int, error)\\n   105→\\n   106→\\t// UninstallHooks removes installed hooks\\n   107→\\tUninstallHooks(ctx context.Context) error\\n   108→\\n   109→\\t// AreHooksInstalled checks if hooks are currently installed\\n   110→\\tAreHooksInstalled(ctx context.Context) bool\\n   111→}\\n   112→\\n   113→// FileWatcher is implemented by agents that use file-based detection.\\n   114→// Agents like Aider that don't support hooks can use file watching\\n   115→// to detect session activity.\\n   116→type FileWatcher interface {\\n   117→\\tAgent\\n   118→\\n   119→\\t// GetWatchPaths returns paths to watch for session changes\\n   120→\\tGetWatchPaths() ([]string, error)\\n   121→\\n   122→\\t// OnFileChange handles a detected file change and returns session info\\n   123→\\tOnFileChange(path string) (*SessionChange, error)\\n   124→}\\n   125→\\n   126→// TranscriptAnalyzer provides format-specific transcript parsing.\\n   127→// Agents that implement this get richer checkpoints (transcript-derived file lists,\\n   128→// prompts, summaries). Agents that don't still participate in the checkpoint lifecycle\\n   129→// via git-status-based file detection and raw transcript storage.\\n   130→type TranscriptAnalyzer interface {\\n   131→\\tAgent\\n   132→\\n   133→\\t// GetTranscriptPosition returns the current position (length) of a transcript.\\n   134→\\t// For JSONL formats (Claude Code), this is the line count.\\n   135→\\t// For JSON formats (Gemini CLI), this is the message count.\\n   136→\\t// Returns 0 if the file doesn't exist or is empty.\\n   137→\\tGetTranscriptPosition(path string) (int, error)\\n   138→\\n   139→\\t// ExtractModifiedFilesFromOffset extracts files modified since a given offset.\\n   140→\\t// For JSONL formats (Claude Code), offset is the starting line number.\\n   141→\\t// For JSON formats (Gemini CLI), offset is the starting message index.\\n   142→\\t// Returns:\\n   143→\\t//   - files: list of file paths modified by the agent (from Write/Edit tools)\\n   144→\\t//   - currentPosition: the current position (line count or message count)\\n   145→\\t//   - error: any error encountered during reading\\n   146→\\tExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error)\\n   147→\\n   148→\\t// ExtractPrompts extracts user prompts from the transcript starting at the given offset.\\n   149→\\tExtractPrompts(sessionRef string, fromOffset int) ([]string, error)\\n   150→\\n   151→\\t// ExtractSummary extracts a summary of the session from the transcript.\\n   152→\\tExtractSummary(sessionRef string) (string, error)\\n   153→}\\n   154→\\n   155→// TranscriptPreparer is called before ReadTranscript to handle agent-specific\\n   156→// flush/sync requirements (e.g., Claude Code's async transcript writing).\\n   157→// The framework calls PrepareTranscript before ReadTranscript if implemented.\\n   158→type TranscriptPreparer interface {\\n   159→\\tAgent\\n   160→\\n   161→\\t// PrepareTranscript ensures the transcript is ready to read.\\n   162→\\t// For Claude Code, this waits for the async transcript flush to complete.\\n   163→\\tPrepareTranscript(ctx context.Context, sessionRef string) error\\n   164→}\\n   165→\\n   166→// TokenCalculator provides token usage calculation for a session.\\n   167→// The framework calls this during step save and checkpoint if implemented.\\n   168→type TokenCalculator interface {\\n   169→\\tAgent\\n   170→\\n   171→\\t// CalculateTokenUsage computes token usage from the transcript starting at the given offset.\\n   172→\\tCalculateTokenUsage(transcriptData []byte, fromOffset int) (*TokenUsage, error)\\n   173→}\\n   174→\\n   175→// SubagentAwareExtractor provides methods for extracting files and tokens including subagents.\\n   176→// Agents that support spawning subagents (like Claude Code's Task tool) should implement this\\n   177→// to ensure subagent contributions are included in checkpoints.\\n   178→type SubagentAwareExtractor interface {\\n   179→\\tAgent\\n   180→\\n   181→\\t// ExtractAllModifiedFiles extracts files modified by both the main agent and any spawned subagents.\\n   182→\\t// The subagentsDir parameter specifies where subagent transcripts are stored.\\n   183→\\t// Returns a deduplicated list of all modified file paths.\\n   184→\\tExtractAllModifiedFiles(transcriptData []byte, fromOffset int, subagentsDir string) ([]string, error)\\n   185→\\n   186→\\t// CalculateTotalTokenUsage computes token usage including all spawned subagents.\\n   187→\\t// The subagentsDir parameter specifies where subagent transcripts are stored.\\n   188→\\tCalculateTotalTokenUsage(transcriptData []byte, fromOffset int, subagentsDir string) (*TokenUsage, error)\\n   189→}\\n   190→\"}]},\"uuid\":\"b4f768cd-32e8-4a3c-b148-c38d1c1b6123\",\"timestamp\":\"2026-03-01T22:53:15.753Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a68681856a1de802f\"},\"toolUseID\":\"agent_msg_0147CJcDBwVYQa3odUMs5wF2\",\"parentToolUseID\":\"toolu_01VUbsGAepJMqKDu63t5FTnk\",\"uuid\":\"dea416c4-37c5-4354-9fc1-b61efb306abb\",\"timestamp\":\"2026-03-01T22:53:15.977Z\"}\n{\"parentUuid\":\"dea416c4-37c5-4354-9fc1-b61efb306abb\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/1\",\"sessionId\":\"ee198057-0f22-496f-9674-0af8f6e0aa80\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/improve-agent-integration-skill\",\"slug\":\"snoopy-napping-lollipop\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-01T22:53:15.978Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01VoSj36tX7bi2vZRFHQ8MA6\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01LrNCApWgnceFdW5eUfdRpg\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/alex/workspace/cli/.worktrees/1/cmd/entire/cli/agent/event.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":4,\"cache_creation_input_tokens\":744,\"cache_read_input_tokens\":47443,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":744},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYdBVoQBdadsfoT4AsqAw\",\"uuid\":\"4659eba4-976d-41f3-8b97-52b269a45594\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a68681856a1de802f\"},\"toolUseID\":\"agent_msg_0147CJcDBwVYQa3odUMs5wF2\",\"parentToolUseID\":\"toolu_01VUbsGAepJMqKDu63t5FTnk\",\"uuid\":\"2b26465b-1bf7-4c57-8ded-a364b0ad8b36\",\"timestamp\":\"2026-03-01T22:53:15.978Z\"}\n{\"parentUuid\":\"2b26465b-1bf7-4c57-8ded-a364b0ad8b36\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/1\",\"sessionId\":\"ee198057-0f22-496f-9674-0af8f6e0aa80\",\"version\":\"2.1.63\",\"gitBranch\":\"alisha/improve-agent-integration-skill\",\"slug\":\"snoopy-napping-lollipop\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01LrNCApWgnceFdW5eUfdRpg\",\"type\":\"tool_result\",\"content\":\"     1→package agent\\n     2→\\n     3→import (\\n     4→\\t\\\"encoding/json\\\"\\n     5→\\t\\\"errors\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"io\\\"\\n     8→\\t\\\"time\\\"\\n     9→)\\n    10→\\n    11→// EventType represents a normalized lifecycle event from any agent.\\n    12→// Agents translate their native hooks into these event types via ParseHookEvent.\\n    13→type EventType int\\n    14→\\n    15→const (\\n    16→\\t// SessionStart indicates the agent session has begun.\\n    17→\\tSessionStart EventType = iota + 1\\n    18→\\n    19→\\t// TurnStart indicates the user submitted a prompt and the agent is about to work.\\n    20→\\tTurnStart\\n    21→\\n    22→\\t// TurnEnd indicates the agent finished responding to a prompt.\\n    23→\\tTurnEnd\\n    24→\\n    25→\\t// Compaction indicates the agent is about to compress its context window.\\n    26→\\t// This triggers the same save logic as TurnEnd but also resets the transcript offset.\\n    27→\\tCompaction\\n    28→\\n    29→\\t// SessionEnd indicates the session has been terminated.\\n    30→\\tSessionEnd\\n    31→\\n    32→\\t// SubagentStart indicates a subagent (task) has been spawned.\\n    33→\\tSubagentStart\\n    34→\\n    35→\\t// SubagentEnd indicates a subagent (task) has completed.\\n    36→\\tSubagentEnd\\n    37→)\\n    38→\\n    39→// String returns a human-readable name for the event type.\\n    40→func (e EventType) String() string {\\n    41→\\tswitch e {\\n    42→\\tcase SessionStart:\\n    43→\\t\\treturn \\\"SessionStart\\\"\\n    44→\\tcase TurnStart:\\n    45→\\t\\treturn \\\"TurnStart\\\"\\n    46→\\tcase TurnEnd:\\n    47→\\t\\treturn \\\"TurnEnd\\\"\\n    48→\\tcase Compaction:\\n    49→\\t\\treturn \\\"Compaction\\\"\\n    50→\\tcase SessionEnd:\\n    51→\\t\\treturn \\\"SessionEnd\\\"\\n    52→\\tcase SubagentStart:\\n    53→\\t\\treturn \\\"SubagentStart\\\"\\n    54→\\tcase SubagentEnd:\\n    55→\\t\\treturn \\\"SubagentEnd\\\"\\n    56→\\tdefault:\\n    57→\\t\\treturn \\\"Unknown\\\"\\n    58→\\t}\\n    59→}\\n    60→\\n    61→// Event is a normalized lifecycle event produced by an agent's ParseHookEvent method.\\n    62→// The framework dispatcher uses these events to drive checkpoint/session lifecycle actions.\\n    63→type Event struct {\\n    64→\\t// Type is the kind of lifecycle event.\\n    65→\\tType EventType\\n    66→\\n    67→\\t// SessionID identifies the agent session.\\n    68→\\tSessionID string\\n    69→\\n    70→\\t// PreviousSessionID is non-empty when this event represents a session continuation\\n    71→\\t// or handoff (e.g., Claude starting a new session ID after exiting plan mode).\\n    72→\\tPreviousSessionID string\\n    73→\\n    74→\\t// SessionRef is an agent-specific reference to the transcript (typically a file path).\\n    75→\\tSessionRef string\\n    76→\\n    77→\\t// Prompt is the user's prompt text (populated on TurnStart events).\\n    78→\\tPrompt string\\n    79→\\n    80→\\t// Timestamp is when the event occurred.\\n    81→\\tTimestamp time.Time\\n    82→\\n    83→\\t// ToolUseID identifies the tool invocation (for SubagentStart/SubagentEnd events).\\n    84→\\tToolUseID string\\n    85→\\n    86→\\t// SubagentID identifies the subagent instance (for SubagentEnd events).\\n    87→\\tSubagentID string\\n    88→\\n    89→\\t// ToolInput is the raw tool input JSON (for subagent type/description extraction).\\n    90→\\t// Used when both SubagentType and TaskDescription are empty (agents that don't provide\\n    91→\\t// these fields directly parse them from ToolInput).\\n    92→\\tToolInput json.RawMessage\\n    93→\\n    94→\\t// SubagentType is the kind of subagent (for SubagentStart/SubagentEnd events).\\n    95→\\t// Used with TaskDescription instead of ToolInput\\n    96→\\tSubagentType    string\\n    97→\\tTaskDescription string\\n    98→\\n    99→\\t// ResponseMessage is an optional message to display to the user via the agent.\\n   100→\\tResponseMessage string\\n   101→\\n   102→\\t// Metadata holds agent-specific state that the framework stores and makes available\\n   103→\\t// on subsequent events. Examples: Pi's activeLeafId, Cursor's is_background_agent.\\n   104→\\tMetadata map[string]string\\n   105→}\\n   106→\\n   107→// ReadAndParseHookInput reads all bytes from stdin and unmarshals JSON into the given type.\\n   108→// This is a shared helper for agent ParseHookEvent implementations.\\n   109→func ReadAndParseHookInput[T any](stdin io.Reader) (*T, error) {\\n   110→\\tdata, err := io.ReadAll(stdin)\\n   111→\\tif err != nil {\\n   112→\\t\\treturn nil, fmt.Errorf(\\\"failed to read hook input: %w\\\", err)\\n   113→\\t}\\n   114→\\tif len(data) == 0 {\\n   115→\\t\\treturn nil, errors.New(\\\"empty hook input\\\")\\n   116→\\t}\\n   117→\\tvar result T\\n   118→\\tif err := json.Unmarshal(data, &result); err != nil {\\n   119→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse hook input: %w\\\", err)\\n   120→\\t}\\n   121→\\treturn &result, nil\\n   122→}\\n   123→\"}]},\"uuid\":\"ade99f38-3878-4ed1-a884-818fd14ba112\",\"timestamp\":\"2026-03-01T22:53:15.993Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a68681856a1de802f\"},\"toolUseID\":\"agent_msg_0147CJcDBwVYQa3odUMs5wF2\",\"parentToolUseID\":\"toolu_01VUbsGAepJMqKDu63t5FTnk\",\"uuid\":\"b0c1c2db-db10-4a57-8fed-d346dc59940a\",\"timestamp\":\"2026-03-01T22:53:16.212Z\"}\n{\"parentUuid\":\"b0c1c2db-db10-4a57-8fe