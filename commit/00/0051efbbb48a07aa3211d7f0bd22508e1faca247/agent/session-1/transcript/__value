icli, opencode, cursor, etc.) only import from allowed packages.\\n    15→//\\n    16→// This prevents agent implementations from coupling to framework internals\\n    17→// (strategy, checkpoint, session, commands, hook_registry, lifecycle) which\\n    18→// would create brittle dependencies that break when internals change.\\n    19→//\\n    20→// Agents should depend only on:\\n    21→//   - The agent contract package (agent, agent/types, agent/testutil)\\n    22→//   - Utility packages (logging, paths, jsonutil, textutil, transcript, etc.)\\n    23→//   - Standard library and external dependencies\\n    24→func TestAgentPackages_NoForbiddenImports(t *testing.T) {\\n    25→\\tt.Parallel()\\n    26→\\n    27→\\tconst repoPrefix = \\\"github.com/entireio/cli/cmd/entire/cli/\\\"\\n    28→\\n    29→\\t// Packages that agent implementations must NOT import.\\n    30→\\t// These are framework internals that agents should be decoupled from.\\n    31→\\tforbiddenSuffixes := []string{\\n    32→\\t\\t\\\"strategy\\\",\\n    33→\\t\\t\\\"checkpoint\\\",\\n    34→\\t\\t\\\"session\\\",\\n    35→\\t\\t\\\"commands\\\",\\n    36→\\t}\\n    37→\\n    38→\\t// Individual files in the cli package that agents must not depend on.\\n    39→\\t// We check for the cli package import itself since these are all in\\n    40→\\t// the top-level cli package (not sub-packages).\\n    41→\\tforbiddenCLIPackage := repoPrefix[:len(repoPrefix)-1] // \\\"github.com/entireio/cli/cmd/entire/cli\\\"\\n    42→\\n    43→\\t// Packages within the repo that agents ARE allowed to import.\\n    44→\\tallowedPrefixes := []string{\\n    45→\\t\\trepoPrefix + \\\"agent\\\",      // agent contract + sub-packages\\n    46→\\t\\trepoPrefix + \\\"logging\\\",    // logging utilities\\n    47→\\t\\trepoPrefix + \\\"paths\\\",      // path utilities\\n    48→\\t\\trepoPrefix + \\\"jsonutil\\\",   // JSON utilities\\n    49→\\t\\trepoPrefix + \\\"textutil\\\",   // text utilities\\n    50→\\t\\trepoPrefix + \\\"transcript\\\", // transcript utilities\\n    51→\\t\\trepoPrefix + \\\"trailers\\\",   // git trailer utilities\\n    52→\\t\\trepoPrefix + \\\"stringutil\\\", // string utilities\\n    53→\\t\\trepoPrefix + \\\"telemetry\\\",  // telemetry\\n    54→\\t\\trepoPrefix + \\\"validation\\\", // validation utilities\\n    55→\\t\\trepoPrefix + \\\"settings\\\",   // settings (read-only access)\\n    56→\\t}\\n    57→\\n    58→\\tagentDir := findAgentDir(t)\\n    59→\\tagentPkgs := discoverAgentPackages(t, agentDir)\\n    60→\\n    61→\\tif len(agentPkgs) == 0 {\\n    62→\\t\\tt.Fatal(\\\"no agent packages found — test setup is broken\\\")\\n    63→\\t}\\n    64→\\n    65→\\tfor _, pkgDir := range agentPkgs {\\n    66→\\t\\tpkgName := filepath.Base(pkgDir)\\n    67→\\t\\tt.Run(pkgName, func(t *testing.T) {\\n    68→\\t\\t\\tt.Parallel()\\n    69→\\t\\t\\timports := extractImports(t, pkgDir)\\n    70→\\t\\t\\tfor _, imp := range imports {\\n    71→\\t\\t\\t\\tif !strings.HasPrefix(imp, repoPrefix) && imp != forbiddenCLIPackage {\\n    72→\\t\\t\\t\\t\\tcontinue // external or stdlib — allowed\\n    73→\\t\\t\\t\\t}\\n    74→\\n    75→\\t\\t\\t\\t// Check if it's the top-level cli package itself\\n    76→\\t\\t\\t\\tif imp == forbiddenCLIPackage {\\n    77→\\t\\t\\t\\t\\tt.Errorf(\\\"forbidden import %q — agent packages must not import the top-level cli package directly\\\", imp)\\n    78→\\t\\t\\t\\t\\tcontinue\\n    79→\\t\\t\\t\\t}\\n    80→\\n    81→\\t\\t\\t\\t// Check forbidden suffixes\\n    82→\\t\\t\\t\\trel := strings.TrimPrefix(imp, repoPrefix)\\n    83→\\t\\t\\t\\tfor _, forbidden := range forbiddenSuffixes {\\n    84→\\t\\t\\t\\t\\tif rel == forbidden || strings.HasPrefix(rel, forbidden+\\\"/\\\") {\\n    85→\\t\\t\\t\\t\\t\\tt.Errorf(\\\"forbidden import %q — agent packages must not import %s internals\\\", imp, forbidden)\\n    86→\\t\\t\\t\\t\\t}\\n    87→\\t\\t\\t\\t}\\n    88→\\n    89→\\t\\t\\t\\t// Check it's in the allowed list\\n    90→\\t\\t\\t\\tallowed := false\\n    91→\\t\\t\\t\\tfor _, prefix := range allowedPrefixes {\\n    92→\\t\\t\\t\\t\\tif imp == prefix || strings.HasPrefix(imp, prefix+\\\"/\\\") {\\n    93→\\t\\t\\t\\t\\t\\tallowed = true\\n    94→\\t\\t\\t\\t\\t\\tbreak\\n    95→\\t\\t\\t\\t\\t}\\n    96→\\t\\t\\t\\t}\\n    97→\\t\\t\\t\\tif !allowed {\\n    98→\\t\\t\\t\\t\\tt.Errorf(\\\"unexpected internal import %q — if this is intentional, add it to allowedPrefixes in architecture_test.go\\\", imp)\\n    99→\\t\\t\\t\\t}\\n   100→\\t\\t\\t}\\n   101→\\t\\t})\\n   102→\\t}\\n   103→}\\n   104→\\n   105→// findAgentDir returns the absolute path to cmd/entire/cli/agent/.\\n   106→func findAgentDir(t *testing.T) string {\\n   107→\\tt.Helper()\\n   108→\\t// Walk up from the test file location to find the repo root.\\n   109→\\twd, err := os.Getwd()\\n   110→\\tif err != nil {\\n   111→\\t\\tt.Fatalf(\\\"os.Getwd: %v\\\", err)\\n   112→\\t}\\n   113→\\t// We're in cmd/entire/cli/agent/ since the test is in that package.\\n   114→\\treturn wd\\n   115→}\\n   116→\\n   117→// discoverAgentPackages finds all subdirectories of the agent dir that contain\\n   118→// Go files, excluding \\\"types\\\" and \\\"testutil\\\" (those are contract/shared packages).\\n   119→func discoverAgentPackages(t *testing.T, agentDir string) []string {\\n   120→\\tt.Helper()\\n   121→\\n   122→\\tskipDirs := map[string]bool{\\n   123→\\t\\t\\\"types\\\":    true, // contract types, not an agent implementation\\n   124→\\t\\t\\\"testutil\\\": true, // shared test utilities\\n   125→\\t}\\n   126→\\n   127→\\tentries, err := os.ReadDir(agentDir)\\n   128→\\tif err != nil {\\n   129→\\t\\tt.Fatalf(\\\"ReadDir(%s): %v\\\", agentDir, err)\\n   130→\\t}\\n   131→\\n   132→\\tvar pkgs []string\\n   133→\\tfor _, e := range entries {\\n   134→\\t\\tif !e.IsDir() || skipDirs[e.Name()] {\\n   135→\\t\\t\\tcontinue\\n   136→\\t\\t}\\n   137→\\t\\tdir := filepath.Join(agentDir, e.Name())\\n   138→\\t\\t// Only include if it has Go file