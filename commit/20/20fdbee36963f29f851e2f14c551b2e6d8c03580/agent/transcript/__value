psTWmRWeC11\",\"type\":\"tool_result\",\"content\":\"     1→package testutil\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"encoding/json\\\"\\n     6→\\t\\\"errors\\\"\\n     7→\\t\\\"fmt\\\"\\n     8→\\t\\\"os\\\"\\n     9→\\t\\\"os/exec\\\"\\n    10→\\t\\\"path/filepath\\\"\\n    11→\\t\\\"strings\\\"\\n    12→\\t\\\"testing\\\"\\n    13→\\t\\\"time\\\"\\n    14→\\n    15→\\t\\\"github.com/entireio/cli/e2e/agents\\\"\\n    16→\\t\\\"github.com/entireio/cli/e2e/entire\\\"\\n    17→)\\n    18→\\n    19→// RepoState holds the working state for a single test's cloned repository.\\n    20→type RepoState struct {\\n    21→\\tAgent            agents.Agent\\n    22→\\tDir              string\\n    23→\\tArtifactDir      string\\n    24→\\tHeadBefore       string\\n    25→\\tCheckpointBefore string\\n    26→\\tConsoleLog       *os.File\\n    27→}\\n    28→\\n    29→// SetupRepo creates a fresh git repository in a temporary directory, seeds it\\n    30→// with an initial commit, and runs `entire enable` for the given agent.\\n    31→// Artifact capture is registered as a cleanup function.\\n    32→//\\n    33→// When E2E_KEEP_REPOS is set, the temporary directory is not cleaned up\\n    34→// so it can be inspected after the test. A symlink in the artifact dir\\n    35→// points to the preserved repo.\\n    36→func SetupRepo(t *testing.T, agent agents.Agent) *RepoState {\\n    37→\\tt.Helper()\\n    38→\\n    39→\\tkeepRepos := os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\"\\n    40→\\n    41→\\t// Always use os.MkdirTemp instead of t.TempDir(). Go's t.TempDir()\\n    42→\\t// creates nested subdirectories (TestName.../001/) whose structure\\n    43→\\t// confuses some agents' (e.g. opencode) working-directory resolution.\\n    44→\\tdir, err := os.MkdirTemp(\\\"\\\", \\\"e2e-repo-*\\\")\\n    45→\\tif err != nil {\\n    46→\\t\\tt.Fatalf(\\\"create temp dir: %v\\\", err)\\n    47→\\t}\\n    48→\\tif keepRepos {\\n    49→\\t\\tt.Logf(\\\"E2E_KEEP_REPOS: repo will be preserved at %s\\\", dir)\\n    50→\\t} else {\\n    51→\\t\\tt.Cleanup(func() { os.RemoveAll(dir) })\\n    52→\\t}\\n    53→\\n    54→\\t// Resolve symlinks (macOS: /var -> /private/var) so paths match\\n    55→\\t// what agent CLIs see when they resolve their own CWD.\\n    56→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n    57→\\t\\tdir = resolved\\n    58→\\t}\\n    59→\\n    60→\\tGit(t, dir, \\\"init\\\")\\n    61→\\tGit(t, dir, \\\"config\\\", \\\"user.name\\\", \\\"E2E Test\\\")\\n    62→\\tGit(t, dir, \\\"config\\\", \\\"user.email\\\", \\\"e2e@test.local\\\")\\n    63→\\tGit(t, dir, \\\"commit\\\", \\\"--allow-empty\\\", \\\"-m\\\", \\\"initial commit\\\")\\n    64→\\n    65→\\tentire.Enable(t, dir, agent.EntireAgent(), \\\"\\\")\\n    66→\\tPatchSettings(t, dir, map[string]any{\\\"log_level\\\": \\\"debug\\\"})\\n    67→\\n    68→\\t// OpenCode's non-interactive mode auto-rejects external_directory permission\\n    69→\\t// since there's no user to prompt. Write a config to allow it.\\n    70→\\tif agent.Name() == \\\"opencode\\\" {\\n    71→\\t\\tcfg := `{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}}`\\n    72→\\t\\tif key := os.Getenv(\\\"ANTHROPIC_API_KEY\\\"); key != \\\"\\\" {\\n    73→\\t\\t\\tcfg = fmt.Sprintf(`{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}, \\\"provider\\\": {\\\"anthropic\\\": {\\\"options\\\": {\\\"apiKey\\\": %q}}}}`, key)\\n    74→\\t\\t}\\n    75→\\t\\tif err := os.WriteFile(filepath.Join(dir, \\\"opencode.json\\\"), []byte(cfg+\\\"\\\\n\\\"), 0o644); err != nil {\\n    76→\\t\\t\\tt.Fatalf(\\\"write opencode.json: %v\\\", err)\\n    77→\\t\\t}\\n    78→\\t}\\n    79→\\n    80→\\t// Create artifact dir eagerly so console.log is written to disk\\n    81→\\t// incrementally. Even if the test is killed by a global timeout,\\n    82→\\t// partial output survives.\\n    83→\\tartDir := artifactDir(t)\\n    84→\\tconsoleLog, err := os.Create(filepath.Join(artDir, \\\"console.log\\\"))\\n    85→\\tif err != nil {\\n    86→\\t\\tt.Fatalf(\\\"create console.log: %v\\\", err)\\n    87→\\t}\\n    88→\\n    89→\\tstate := &RepoState{\\n    90→\\t\\tAgent:            agent,\\n    91→\\t\\tDir:              dir,\\n    92→\\t\\tArtifactDir:      artDir,\\n    93→\\t\\tHeadBefore:       GitOutput(t, dir, \\\"rev-parse\\\", \\\"HEAD\\\"),\\n    94→\\t\\tCheckpointBefore: GitOutput(t, dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\"),\\n    95→\\t\\tConsoleLog:       consoleLog,\\n    96→\\t}\\n    97→\\n    98→\\tt.Cleanup(func() {\\n    99→\\t\\t_ = consoleLog.Close()\\n   100→\\t\\tCaptureArtifacts(t, state)\\n   101→\\t})\\n   102→\\n   103→\\treturn state\\n   104→}\\n   105→\\n   106→// ForEachAgent runs fn as a parallel subtest for every registered agent.\\n   107→// It handles repo setup, concurrency gating, context timeout, and cleanup.\\n   108→// The timeout is scaled by each agent's TimeoutMultiplier.\\n   109→func ForEachAgent(t *testing.T, timeout time.Duration, fn func(t *testing.T, s *RepoState, ctx context.Context)) {\\n   110→\\tt.Helper()\\n   111→\\tt.Parallel()\\n   112→\\tfor _, agent := range agents.All() {\\n   113→\\t\\tt.Run(agent.Name(), func(t *testing.T) {\\n   114→\\t\\t\\ts := SetupRepo(t, agent)\\n   115→\\n   116→\\t\\t\\t// Use the global test deadline for slot wait so we don't\\n   117→\\t\\t\\t// skip prematurely — only bail if the whole binary is dying.\\n   118→\\t\\t\\tslotCtx := context.Background()\\n   119→\\t\\t\\tif deadline, ok := t.Deadline(); ok {\\n   120→\\t\\t\\t\\tvar cancel context.CancelFunc\\n   121→\\t\\t\\t\\tslotCtx, cancel = context.WithDeadline(slotCtx, deadline)\\n   122→\\t\\t\\t\\tdefer cancel()\\n   123→\\t\\t\\t}\\n   124→\\t\\t\\tif err := agents.AcquireSlot(slotCtx, agent); err != nil {\\n   125→\\t\\t\\t\\tt.Fatalf(\\\"timed out waiting for agent slot: %v\\\", err)\\n   126→\\t\\t\\t}\\n   127→\\t\\t\\tdefer agents.ReleaseSlot(agent)\\n   128→\\n   129→\\t\\t\\t// Per-test timeout starts after slot is acquired, scaled\\n   130→\\t\\t\\t// by the agent's multiplier (e.g. 2.5× for gemini).\\n   131→\\t\\t\\tscaled := time.Duration(float64(timeout) * agent.TimeoutMultiplier())\\n   132→\\t\\t\\tctx, cancel := context.WithTimeout(context.Background(), scaled)\\n   133→\\t\\t\\tdefer cancel()\\n   134→\\t\\t\\tfn(t, s, ctx)\\n   135→\\t\\t})\\n   136→\\t}\\n   137→}\\n   138→\\n   139→// RunPrompt runs an agent prompt, logs the command and output to ConsoleLog,\\n   140→// and returns the result. If the agent reports a transient API error, the\\n   141→// prompt is retried once after a short delay. The caller should still check err.\\n   142→func (s *RepoState) RunPrompt(t *testing.T, ctx context.Context, prompt string, opts ...agents.Option) (agents.Output, error) {\\n   143→\\tt.Helper()\\n   144→\\tout, err := s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n   145→\\ts.logPromptResult(out)\\n   146→\\n   147→\\tif err != nil && s.Agent.IsTransientError(out, err) {\\n   148→\\t\\tt.Logf(\\\"transient API error detected, retrying in 5s: %v\\\", err)\\n   149→\\t\\ts.ConsoleLog.WriteString(\\\"> [retry] transient error, waiting 5s...\\\\n\\\")\\n   150→\\t\\tselect {\\n   151→\\t\\tcase <-time.After(5 * time.Second):\\n   152→\\t\\tcase <-ctx.Done():\\n   153→\\t\\t\\treturn out, err\\n   154→\\t\\t}\\n   155→\\t\\tout, err = s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n   156→\\t\\ts.logPromptResult(out)\\n   157→\\t}\\n   158→\\n   159→\\treturn out, err\\n   160→}\\n   161→\\n   162→func (s *RepoState) logPromptResult(out agents.Output) {\\n   163→\\ts.ConsoleLog.WriteString(\\\"> \\\" + out.Command + \\\"\\\\n\\\")\\n   164→\\ts.ConsoleLog.WriteString(\\\"stdout:\\\\n\\\" + out.Stdout + \\\"\\\\n\\\")\\n   165→\\ts.ConsoleLog.WriteString(\\\"stderr:\\\\n\\\" + out.Stderr + \\\"\\\\n\\\")\\n   166→}\\n   167→\\n   168→// Git runs a git command in the repo and logs it to ConsoleLog.\\n   169→func (s *RepoState) Git(t *testing.T, args ...string) {\\n   170→\\tt.Helper()\\n   171→\\ts.ConsoleLog.WriteString(\\\"> git \\\" + strings.Join(args, \\\" \\\") + \\\"\\\\n\\\")\\n   172→\\tGit(t, s.Dir, args...)\\n   173→}\\n   174→\\n   175→// Send sends input to an interactive session and logs it to ConsoleLog.\\n   176→// Fails the test on error.\\n   177→func (s *RepoState) Send(t *testing.T, session agents.Session, input string) {\\n   178→\\tt.Helper()\\n   179→\\ts.ConsoleLog.WriteString(\\\"> send: \\\" + input + \\\"\\\\n\\\")\\n   180→\\tif err := session.Send(input); err != nil {\\n   181→\\t\\tt.Fatalf(\\\"send failed: %v\\\", err)\\n   182→\\t}\\n   183→}\\n   184→\\n   185→// PatchSettings merges extra keys into .entire/settings.json.\\n   186→func PatchSettings(t *testing.T, dir string, extra map[string]any) {\\n   187→\\tt.Helper()\\n   188→\\tpath := filepath.Join(dir, \\\".entire\\\", \\\"settings.json\\\")\\n   189→\\tdata, err := os.ReadFile(path)\\n   190→\\tif err != nil {\\n   191→\\t\\tt.Fatalf(\\\"read settings: %v\\\", err)\\n   192→\\t}\\n   193→\\tvar settings map[string]any\\n   194→\\tif err := json.Unmarshal(data, &settings); err != nil {\\n   195→\\t\\tt.Fatalf(\\\"parse settings: %v\\\", err)\\n   196→\\t}\\n   197→\\tfor k, v := range extra {\\n   198→\\t\\tsettings[k] = v\\n   199→\\t}\\n   200→\\tout, err := json.MarshalIndent(settings, \\\"\\\", \\\"  \\\")\\n   201→\\tif err != nil {\\n   202→\\t\\tt.Fatalf(\\\"marshal settings: %v\\\", err)\\n   203→\\t}\\n   204→\\tif err := os.WriteFile(path, out, 0o644); err != nil {\\n   205→\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n   206→\\t}\\n   207→}\\n   208→\\n   209→// Git runs a git command in the given directory and fails the test if it\\n   210→// returns a non-zero exit code.\\n   211→func Git(t *testing.T, dir string, args ...string) {\\n   212→\\tt.Helper()\\n   213→\\n   214→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   215→\\tif dir != \\\"\\\" {\\n   216→\\t\\tcmd.Dir = dir\\n   217→\\t}\\n   218→\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   219→\\n   220→\\tout, err := cmd.CombinedOutput()\\n   221→\\tif err != nil {\\n   222→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n   223→\\t}\\n   224→}\\n   225→\\n   226→// GitOutput runs a git command in the given directory, returns its trimmed\\n   227→// stdout, and fails the test on error.\\n   228→func GitOutput(t *testing.T, dir string, args ...string) string {\\n   229→\\tt.Helper()\\n   230→\\n   231→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   232→\\tif dir != \\\"\\\" {\\n   233→\\t\\tcmd.Dir = dir\\n   234→\\t}\\n   235→\\n   236→\\tout, err := cmd.Output()\\n   237→\\tif err != nil {\\n   238→\\t\\tvar stderr string\\n   239→\\t\\tee := &exec.ExitError{}\\n   240→\\t\\tif errors.As(err, &ee) {\\n   241→\\t\\t\\tstderr = string(ee.Stderr)\\n   242→\\t\\t}\\n   243→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, stderr)\\n   244→\\t}\\n   245→\\n   246→\\treturn strings.TrimSpace(string(out))\\n   247→}\\n   248→\\n   249→// NewCheckpointCommits returns the SHAs of commits added to the\\n   250→// entire/checkpoints/v1 branch since the test was set up, oldest first.\\n   251→func NewCheckpointCommits(t *testing.T, s *RepoState) []string {\\n   252→\\tt.Helper()\\n   253→\\n   254→\\tlog := GitOutput(t, s.Dir, \\\"log\\\", \\\"--reverse\\\", \\\"--format=%H\\\", s.CheckpointBefore+\\\"..entire/checkpoints/v1\\\")\\n   255→\\tif log == \\\"\\\" {\\n   256→\\t\\treturn nil\\n   257→\\t}\\n   258→\\treturn strings.Split(log, \\\"\\\\n\\\")\\n   259→}\\n   260→\\n   261→// CheckpointIDs lists all checkpoint IDs from the tree at the tip of the\\n   262→// checkpoint branch. It parses the two-level directory structure\\n   263→// ({prefix}/{suffix}/metadata.json) and returns the concatenated IDs.\\n   264→func CheckpointIDs(t *testing.T, dir string) []string {\\n   265→\\tt.Helper()\\n   266→\\tout := gitOutputSafe(dir, \\\"ls-tree\\\", \\\"-r\\\", \\\"--name-only\\\", \\\"entire/checkpoints/v1\\\")\\n   267→\\tif out == \\\"\\\" {\\n   268→\\t\\treturn nil\\n   269→\\t}\\n   270→\\tseen := map[string]bool{}\\n   271→\\tvar ids []string\\n   272→\\tfor _, line := range strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\") {\\n   273→\\t\\t// Match {prefix}/{suffix}/metadata.json (top-level, not session-level)\\n   274→\\t\\tparts := strings.Split(line, \\\"/\\\")\\n   275→\\t\\tif len(parts) == 3 && parts[2] == \\\"metadata.json\\\" {\\n   276→\\t\\t\\tid := parts[0] + parts[1]\\n   277→\\t\\t\\tif !seen[id] {\\n   278→\\t\\t\\t\\tseen[id] = true\\n   279→\\t\\t\\t\\tids = append(ids, id)\\n   280→\\t\\t\\t}\\n   281→\\t\\t}\\n   282→\\t}\\n   283→\\treturn ids\\n   284→}\\n   285→\\n   286→// ReadCheckpointMetadata reads the checkpoint-level metadata.json from the\\n   287→// tip of the checkpoint branch for the given checkpoint ID.\\n   288→func ReadCheckpointMetadata(t *testing.T, dir string, checkpointID string) CheckpointMetadata {\\n   289→\\tt.Helper()\\n   290→\\n   291→\\tpath := CheckpointPath(checkpointID) + \\\"/metadata.json\\\"\\n   292→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   293→\\n   294→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   295→\\n   296→\\tvar meta CheckpointMetadata\\n   297→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   298→\\t\\tt.Fatalf(\\\"unmarshal checkpoint metadata from %s: %v\\\", blob, err)\\n   299→\\t}\\n   300→\\n   301→\\treturn meta\\n   302→}\\n   303→\\n   304→// ReadSessionMetadata reads a session's metadata.json from the tip of the\\n   305→// checkpoint branch for the given checkpoint ID and session index.\\n   306→func ReadSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int) SessionMetadata {\\n   307→\\tt.Helper()\\n   308→\\n   309→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   310→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   311→\\n   312→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   313→\\n   314→\\tvar meta SessionMetadata\\n   315→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   316→\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   317→\\t}\\n   318→\\n   319→\\treturn meta\\n   320→}\\n   321→\\n   322→// WaitForSessionMetadata polls until session metadata exists on the checkpoint\\n   323→// branch for the given checkpoint ID and session index, then returns it.\\n   324→// This handles the race where the checkpoint branch advances before session\\n   325→// metadata is fully committed.\\n   326→func WaitForSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int, timeout time.Duration) SessionMetadata {\\n   327→\\tt.Helper()\\n   328→\\n   329→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   330→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   331→\\n   332→\\tdeadline := time.Now().Add(timeout)\\n   333→\\tfor time.Now().Before(deadline) {\\n   334→\\t\\traw := gitOutputSafe(dir, \\\"show\\\", blob)\\n   335→\\t\\tif raw != \\\"\\\" {\\n   336→\\t\\t\\tvar meta SessionMetadata\\n   337→\\t\\t\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   338→\\t\\t\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   339→\\t\\t\\t}\\n   340→\\t\\t\\treturn meta\\n   341→\\t\\t}\\n   342→\\t\\ttime.Sleep(500 * time.Millisecond)\\n   343→\\t}\\n   344→\\tt.Fatalf(\\\"session metadata %s did not appear within %s\\\", blob, timeout)\\n   345→\\treturn SessionMetadata{}\\n   346→}\\n   347→\\n   348→// SetupBareRemote creates a bare git repo, adds it as \\\"origin\\\", and pushes\\n   349→// the initial commit. Returns the bare repo path.\\n   350→func SetupBareRemote(t *testing.T, s *RepoState) string {\\n   351→\\tt.Helper()\\n   352→\\n   353→\\tvar bareDir string\\n   354→\\tif os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\" {\\n   355→\\t\\tvar err error\\n   356→\\t\\tbareDir, err = os.MkdirTemp(\\\"\\\", \\\"e2e-bare-*\\\")\\n   357→\\t\\tif err != nil {\\n   358→\\t\\t\\tt.Fatalf(\\\"create bare remote dir: %v\\\", err)\\n   359→\\t\\t}\\n   360→\\t\\tt.Logf(\\\"E2E_KEEP_REPOS: bare remote will be preserved at %s\\\", bareDir)\\n   361→\\t} else {\\n   362→\\t\\tbareDir = t.TempDir()\\n   363→\\t}\\n   364→\\n   365→\\tGit(t, bareDir, \\\"init\\\", \\\"--bare\\\")\\n   366→\\tGit(t, s.Dir, \\\"remote\\\", \\\"add\\\", \\\"origin\\\", bareDir)\\n   367→\\tGit(t, s.Dir, \\\"push\\\", \\\"-u\\\", \\\"origin\\\", \\\"HEAD\\\")\\n   368→\\treturn bareDir\\n   369→}\\n   370→\\n   371→// GitOutputErr runs a git command and returns (output, error) without\\n   372→// failing the test. For commands expected to fail.\\n   373→func GitOutputErr(dir string, args ...string) (string, error) {\\n   374→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   375→\\tif dir != \\\"\\\" {\\n   376→\\t\\tcmd.Dir = dir\\n   377→\\t}\\n   378→\\tout, err := cmd.CombinedOutput()\\n   379→\\treturn strings.TrimSpace(string(out)), err\\n   380→}\\n   381→\\n   382→// GetCheckpointTrailer extracts the Entire-Checkpoint trailer value from a\\n   383→// code commit. Returns the trimmed trailer value, or an empty string if the\\n   384→// trailer is not present.\\n   385→func GetCheckpointTrailer(t *testing.T, dir string, ref string) string {\\n   386→\\tt.Helper()\\n   387→\\n   388→\\treturn GitOutput(t, dir, \\\"log\\\", \\\"-1\\\", \\\"--format=%(trailers:key=Entire-Checkpoint,valueonly)\\\", ref)\\n   389→}\\n   390→\"}]},\"uuid\":\"0d5a6912-9a19-4e91-8147-1a331285ed1c\",\"timestamp\":\"2026-02-25T02:39:22.329Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Look at the e2e test framework to understand how `RunPrompt` works 