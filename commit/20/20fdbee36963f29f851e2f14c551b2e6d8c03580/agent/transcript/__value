ode string) Option {\\n    26→\\treturn func(c *runConfig) { c.PermissionMode = mode }\\n    27→}\\n    28→\\n    29→type Agent interface {\\n    30→\\tName() string\\n    31→\\t// Binary returns the CLI binary name (e.g. \\\"claude\\\", \\\"gemini\\\").\\n    32→\\tBinary() string\\n    33→\\tEntireAgent() string\\n    34→\\tPromptPattern() string\\n    35→\\t// TimeoutMultiplier returns a factor applied to per-test timeouts.\\n    36→\\t// Slower agents (e.g. Gemini) return values > 1.\\n    37→\\tTimeoutMultiplier() float64\\n    38→\\tRunPrompt(ctx context.Context, dir string, prompt string, opts ...Option) (Output, error)\\n    39→\\tStartSession(ctx context.Context, dir string) (Session, error)\\n    40→\\t// Bootstrap performs one-time CI setup (auth config, warmup, etc.).\\n    41→\\t// Called before any tests run. Implementations should be idempotent.\\n    42→\\tBootstrap() error\\n    43→\\t// IsTransientError returns true if the error from RunPrompt looks like\\n    44→\\t// a transient API failure (e.g. 500, rate limit, network error) that\\n    45→\\t// is worth retrying.\\n    46→\\tIsTransientError(out Output, err error) bool\\n    47→}\\n    48→\\n    49→type Session interface {\\n    50→\\tSend(input string) error\\n    51→\\tWaitFor(pattern string, timeout time.Duration) (string, error)\\n    52→\\tCapture() string\\n    53→\\tClose() error\\n    54→}\\n    55→\\n    56→var registry []Agent\\n    57→var gates = map[string]chan struct{}{}\\n    58→\\n    59→func Register(a Agent) {\\n    60→\\tregistry = append(registry, a)\\n    61→}\\n    62→\\n    63→// RegisterGate sets a concurrency limit for an agent's tests.\\n    64→// Tests call AcquireSlot/ReleaseSlot to respect this limit.\\n    65→func RegisterGate(name string, max int) {\\n    66→\\tgates[name] = make(chan struct{}, max)\\n    67→}\\n    68→\\n    69→// AcquireSlot blocks until a test slot is available for the agent or the\\n    70→// context is cancelled. Returns a non-nil error if the context expires\\n    71→// before a slot opens.\\n    72→func AcquireSlot(ctx context.Context, a Agent) error {\\n    73→\\tg, ok := gates[a.Name()]\\n    74→\\tif !ok {\\n    75→\\t\\treturn nil\\n    76→\\t}\\n    77→\\tselect {\\n    78→\\tcase g <- struct{}{}:\\n    79→\\t\\treturn nil\\n    80→\\tcase <-ctx.Done():\\n    81→\\t\\treturn ctx.Err()\\n    82→\\t}\\n    83→}\\n    84→\\n    85→// ReleaseSlot frees a test slot for the agent.\\n    86→func ReleaseSlot(a Agent) {\\n    87→\\tif g, ok := gates[a.Name()]; ok {\\n    88→\\t\\t<-g\\n    89→\\t}\\n    90→}\\n    91→\\n    92→func All() []Agent {\\n    93→\\treturn registry\\n    94→}\\n    95→\"}]},\"uuid\":\"932a0bce-8dc3-4382-ac16-824528c0a93e\",\"timestamp\":\"2026-02-25T02:39:22.252Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Look at the e2e test framework to understand how `RunPrompt` works for the opencode agent. Specifically:\\n1. Read `e2e/testutil/repo_state.go` or wherever `RunPrompt` is defined\\n2. Read `e2e/agents/opencode.go` to understand how the opencode agent runs\\n3. Determine: does `RunPrompt` return an error when the agent itself fails (like \\\"Token refresh failed: 400\\\")? Or does it only return errors for execution failures?\\n\\nReport what you find about the error handling path.\",\"agentId\":\"a88f6d4d10f0684ab\"},\"toolUseID\":\"agent_msg_01BauNE9aHEwGNPjzAiB8aag\",\"parentToolUseID\":\"toolu_01F7sFZgZsRQkNDVUpeK4uji\",\"uuid\":\"bb043ad2-a323-4ed5-b8f8-5cc3bf814947\",\"timestamp\":\"2026-02-25T02:39:22.255Z\"}\n{\"parentUuid\":\"bb043ad2-a323-4ed5-b8f8-5cc3bf814947\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli\",\"sessionId\":\"1f9e0bfc-824b-4ba6-8710-8a77d3ff041f\",\"version\":\"2.1.53\",\"gitBranch\":\"alex/consolidate-e2e-tests\",\"slug\":\"cryptic-weaving-noodle\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-02-25T02:39:22.323Z\",\"message\":{\"model\":\"claud