sertCheckpointNotAdvanced asserts the checkpoint branch has NOT moved.\\n    85→func AssertCheckpointNotAdvanced(t *testing.T, s *RepoState) {\\n    86→\\tt.Helper()\\n    87→\\tafter := GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n    88→\\tassert.Equal(t, s.CheckpointBefore, after, \\\"checkpoint branch advanced unexpectedly\\\")\\n    89→}\\n    90→\\n    91→// AssertCheckpointIDFormat asserts the checkpoint ID is 12 lowercase hex chars.\\n    92→func AssertCheckpointIDFormat(t *testing.T, checkpointID string) {\\n    93→\\tt.Helper()\\n    94→\\tassert.Regexp(t, hexIDPattern, checkpointID,\\n    95→\\t\\t\\\"checkpoint ID %q should be 12 lowercase hex chars\\\", checkpointID)\\n    96→}\\n    97→\\n    98→// AssertHasCheckpointTrailer asserts the commit has an Entire-Checkpoint trailer,\\n    99→// validates its format, and returns its value.\\n   100→func AssertHasCheckpointTrailer(t *testing.T, dir string, ref string) string {\\n   101→\\tt.Helper()\\n   102→\\ttrailer := GetCheckpointTrailer(t, dir, ref)\\n   103→\\trequire.NotEmpty(t, trailer, \\\"no Entire-Checkpoint trailer on %s\\\", ref)\\n   104→\\tAssertCheckpointIDFormat(t, trailer)\\n   105→\\treturn trailer\\n   106→}\\n   107→\\n   108→// AssertCheckpointInLastN asserts the given checkpoint ID appears in the\\n   109→// last n commits on the checkpoint branch (e.g. initial + catchup).\\n   110→func AssertCheckpointInLastN(t *testing.T, dir string, checkpointID string, n int) {\\n   111→\\tt.Helper()\\n   112→\\tout := GitOutput(t, dir, \\\"log\\\", \\\"-n\\\", strconv.Itoa(n),\\n   113→\\t\\t\\\"--format=%s\\\", \\\"entire/checkpoints/v1\\\")\\n   114→\\tlines := strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\")\\n   115→\\trequire.Len(t, lines, n,\\n   116→\\t\\t\\\"expected %d commits on checkpoint branch, got %d\\\", n, len(lines))\\n   117→\\tfor i, line := range lines {\\n   118→\\t\\tassert.Contains(t, line, checkpointID,\\n   119→\\t\\t\\t\\\"checkpoint commit %d/%d does not mention %s: %s\\\", i+1, n, checkpointID, line)\\n   120→\\t}\\n   121→}\\n   122→\\n   123→// AssertCheckpointExists asserts that the checkpoint ID is mentioned on\\n   124→// the checkpoint branch and that its metadata.json exists in the tree.\\n   125→func AssertCheckpointExists(t *testing.T, dir string, checkpointID string) {\\n   126→\\tt.Helper()\\n   127→\\tout := GitOutput(t, dir, \\\"log\\\", \\\"entire/checkpoints/v1\\\", \\\"--grep=\\\"+checkpointID, \\\"--oneline\\\")\\n   128→\\tassert.NotEmpty(t, out, \\\"checkpoint %s not found on checkpoint branch\\\", checkpointID)\\n   129→\\n   130→\\tpath := CheckpointPath(checkpointID) + \\\"/metadata.json\\\"\\n   131→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   132→\\traw := gitOutputSafe(dir, \\\"show\\\", blob)\\n   133→\\tassert.NotEmpty(t, raw,\\n   134→\\t\\t\\\"checkpoint %s metadata not found at %s\\\", checkpointID, path)\\n   135→}\\n   136→\\n   137→// AssertCommitLinkedToCheckpoint asserts the trailer exists AND the\\n   138→// checkpoint data exists on the checkpoint branch.\\n   139→func AssertCommitLinkedToCheckpoint(t *testing.T, dir string, ref string) {\\n   140→\\tt.Helper()\\n   141→\\ttrailer := AssertHasCheckpointTrailer(t, dir, ref)\\n   142→\\tAssertCheckpointExists(t, dir, trailer)\\n   143→}\\n   144→\\n   145→// AssertCheckpointHasSingleSession asserts checkpoint metadata has exactly one session.\\n   146→func AssertCheckpointHasSingleSession(t *testing.T, dir string, checkpointID string) {\\n   147→\\tt.Helper()\\n   148→\\tmeta := ReadCheckpointMetadata(t, dir, checkpointID)\\n   149→\\tassert.Len(t, meta.Sessions, 1,\\n   150→\\t\\t\\\"expected 1 session in checkpoint %s, got %d\\\", checkpointID, len(meta.Sessions))\\n   151→}\\n   152→\\n   153→// AssertCheckpointMetadataComplete asserts essential fields in checkpoint metadata are populated.\\n   154→func AssertCheckpointMetadataComplete(t *testing.T, dir string, checkpointID string) {\\n   155→\\tt.Helper(