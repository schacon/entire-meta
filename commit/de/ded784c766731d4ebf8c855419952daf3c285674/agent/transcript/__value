message editing.\\n  1069→// This tests the opt-out behavior where removing the trailer skips condensation.\\n  1070→func (env *TestEnv) GitCommitWithTrailerRemoved(message string, files ...string) {\\n  1071→\\tenv.T.Helper()\\n  1072→\\n  1073→\\t// Stage files using go-git\\n  1074→\\tfor _, file := range files {\\n  1075→\\t\\tenv.GitAdd(file)\\n  1076→\\t}\\n  1077→\\n  1078→\\t// Create a temp file for the commit message (prepare-commit-msg hook modifies this)\\n  1079→\\tmsgFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"COMMIT_EDITMSG\\\")\\n  1080→\\tif err := os.WriteFile(msgFile, []byte(message), 0o644); err != nil {\\n  1081→\\t\\tenv.T.Fatalf(\\\"failed to write commit message file: %v\\\", err)\\n  1082→\\t}\\n  1083→\\n  1084→\\t// Run prepare-commit-msg hook using the shared binary.\\n  1085→\\t// Set ENTIRE_TEST_TTY=1 to simulate human (this tests the editor flow where\\n  1086→\\t// the user removes the trailer before committing).\\n  1087→\\tprepCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"prepare-commit-msg\\\", msgFile)\\n  1088→\\tprepCmd.Dir = env.RepoDir\\n  1089→\\tprepCmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=1\\\")\\n  1090→\\tif output, err := prepCmd.CombinedOutput(); err != nil {\\n  1091→\\t\\tenv.T.Logf(\\\"prepare-commit-msg output: %s\\\", output)\\n  1092→\\t}\\n  1093→\\n  1094→\\t// Read the modified message (with trailer added by hook)\\n  1095→\\tmodifiedMsg, err := os.ReadFile(msgFile)\\n  1096→\\tif err != nil {\\n  1097→\\t\\tenv.T.Fatalf(\\\"failed to read modified commit message: %v\\\", err)\\n  1098→\\t}\\n  1099→\\n  1100→\\t// REMOVE the Entire-Checkpoint trailer (simulating user editing the message)\\n  1101→\\tlines := strings.Split(string(modifiedMsg), \\\"\\\\n\\\")\\n  1102→\\tvar cleanedLines []string\\n  1103→\\tfor _, line := range lines {\\n  1104→\\t\\t// Skip the trailer and the comments about it\\n  1105→\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n  1106→\\t\\t\\tcontinue\\n  1107→\\t\\t}\\n  1108→\\t\\tif strings.Contains(line, \\\"Remove the Entire-Checkpoint trailer\\\") {\\n  1109→\\t\\t\\tcontinue\\n  1110→\\t\\t}\\n  1111→\\t\\tif strings.Contains(line, \\\"trailer will be added to your next commit\\\") {\\n  1112→\\t\\t\\tcontinue\\n  1113→\\t\\t}\\n  1114→\\t\\tcleanedLines = append(cleanedLines, line)\\n  1115→\\t}\\n  1116→\\tcleanedMsg := strings.TrimRight(strings.Join(cleanedLines, \\\"\\\\n\\\"), \\\"\\\\n\\\") + \\\"\\\\n\\\"\\n  1117→\\n  1118→\\t// Create the commit using go-git with the cleaned message (no trailer)\\n  1119→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1120→\\tif err != nil {\\n  1121→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1122→\\t}\\n  1123→\\n  1124→\\tworktree, err := repo.Worktree()\\n  1125→\\tif err != nil {\\n  1126→\\t\\tenv.T.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n  1127→\\t}\\n  1128→\\n  1129→\\t_, err = worktree.Commit(cleanedMsg, &git.CommitOptions{\\n  1130→\\t\\tAuthor: &object.Signature{\\n  1131→\\t\\t\\tName:  \\\"Test User\\\",\\n  1132→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n  1133→\\t\\t\\tWhen:  time.Now(),\\n  1134→\\t\\t},\\n  1135→\\t})\\n  1136→\\tif err != nil {\\n  1137→\\t\\tenv.T.Fatalf(\\\"failed to commit: %v\\\", err)\\n  1138→\\t}\\n  1139→\\n  1140→\\t// Run post-commit hook - since trailer was removed, no condensation should happen\\n  1141→\\tpostCmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"git\\\", \\\"post-commit\\\")\\n  1142→\\tpostCmd.Dir = env.RepoDir\\n  1143→\\tif output, err := postCmd.CombinedOutput(); err != nil {\\n  1144→\\t\\tenv.T.Logf(\\\"post-commit output: %s\\\", output)\\n  1145→\\t}\\n  1146→}\\n  1147→\\n  1148→// GitRm stages file deletions using git rm.\\n  1149→func (env *TestEnv) GitRm(paths ...string) {\\n  1150→\\tenv.T.Helper()\\n  1151→\\n  1152→\\targs := append([]string{\\\"rm\\\", \\\"--\\\"}, paths...)\\n  1153→\\tcmd := exec.Command(\\\"git\\\", args...)