 337→\\t\\t\\tHash: blobHash,\\n   338→\\t\\t}\\n   339→\\t\\tfilePaths.Context = \\\"/\\\" + sessionPath + paths.ContextFileName\\n   340→\\t}\\n   341→\\n   342→\\t// Write session-level metadata.json (CommittedMetadata with all fields including initial_attribution)\\n   343→\\tsessionMetadata := CommittedMetadata{\\n   344→\\t\\tCheckpointID:                opts.CheckpointID,\\n   345→\\t\\tSessionID:                   opts.SessionID,\\n   346→\\t\\tStrategy:                    opts.Strategy,\\n   347→\\t\\tCreatedAt:                   time.Now().UTC(),\\n   348→\\t\\tBranch:                      opts.Branch,\\n   349→\\t\\tCheckpointsCount:            opts.CheckpointsCount,\\n   350→\\t\\tFilesTouched:                opts.FilesTouched,\\n   351→\\t\\tAgent:                       opts.Agent,\\n   352→\\t\\tTurnID:                      opts.TurnID,\\n   353→\\t\\tIsTask:                      opts.IsTask,\\n   354→\\t\\tToolUseID:                   opts.ToolUseID,\\n   355→\\t\\tTranscriptIdentifierAtStart: opts.TranscriptIdentifierAtStart,\\n   356→\\t\\tCheckpointTranscriptStart:   opts.CheckpointTranscriptStart,\\n   357→\\t\\tTranscriptLinesAtStart:      opts.CheckpointTranscriptStart, // Deprecated: kept for backward compat\\n   358→\\t\\tTokenUsage:                  opts.TokenUsage,\\n   359→\\t\\tInitialAttribution:          opts.InitialAttribution,\\n   360→\\t\\tSummary:                     redactSummary(opts.Summary),\\n   361→\\t\\tCLIVersion:                  buildinfo.Version,\\n   362→\\t}\\n   363→\\n   364→\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(sessionMetadata, \\\"\\\", \\\"  \\\")\\n   365→\\tif err != nil {\\n   366→\\t\\treturn filePaths, fmt.Errorf(\\\"failed to marshal session metadata: %w\\\", err)\\n   367→\\t}\\n   368→\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n   369→\\tif err != nil {\\n   370→\\t\\treturn filePaths, err\\n   371→\\t}\\n   372→\\tentries[sessionPath+paths.MetadataFileName] = object.TreeEntry{\\n   373→\\t\\tName: sessionPath + paths.MetadataFileName,\\n   374→\\t\\tMode: filemode.Regular,\\n   375→\\t\\tHash: metadataHash,\\n   376→\\t}\\n   377→\\tfilePaths.Metadata = \\\"/\\\" + sessionPath + paths.MetadataFileName\\n   378→\\n   379→\\t// Write export data (optional — for agents with non-file storage, e.g., OpenCode)\\n   380→\\tif len(opts.ExportData) > 0 {\\n   381→\\t\\texportHash, err := CreateBlobFromContent(s.repo, opts.ExportData)\\n   382→\\t\\tif err != nil {\\n   383→\\t\\t\\treturn filePaths, fmt.Errorf(\\\"failed to create export data blob: %w\\\", err)\\n   384→\\t\\t}\\n   385→\\t\\tentries[sessionPath+paths.ExportDataFileName] = object.TreeEntry{\\n   386→\\t\\t\\tName: sessionPath + paths.ExportDataFileName,\\n   387→\\t\\t\\tMode: filemode.Regular,\\n   388→\\t\\t\\tHash: exportHash,\\n   389→\\t\\t}\\n   390→\\t}\\n   391→\\n   392→\\treturn filePaths, nil\\n   393→}\\n   394→\\n   395→// writeCheckpointSummary writes the root-level CheckpointSummary with aggregated statistics.\\n   396→// sessions is the complete sessions array (already built by the caller).\\n   397→func (s *GitStore) writeCheckpointSummary(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry, sessions []SessionFilePaths) error {\\n   398→\\tcheckpointsCount, filesTouched, tokenUsage, err :=\\n   399→\\t\\ts.reaggregateFromEntries(basePath, len(sessions), entries)\\n   400→\\tif err != nil {\\n   401→\\t\\treturn fmt.Errorf(\\\"failed to aggregate session stats: %w\\\", err)\\n   402→\\t}\\n   403→\\n   404→\\tsummary := CheckpointSummary{\\n   405→\\t\\tCheckpointID:     opts.CheckpointID,\\n   406→\\t\\tCLIVersion:       buildinfo.Version,\\n   407→\\t\\tStrategy:         opts.Strategy,\\n   408→\\t\\tBranch:           opts.Branch,\\n   409→\\t\\tCheckpointsCount: checkpointsCount,\\n   410→\\t\\tFilesTouched:     filesTouched,\\n   411→\\t\\tSessions:         sessions,\\n   412→\\t\\tTokenUsage:       tokenUsage,\\n   413→\\t}\\n   414→\\n   415→\\tmetadataJSON, err := jsonutil.MarshalIndentWithNewline(summary, \\\"\\\", \\\"  \\\")\\n   416→\\tif err != nil {\\n   417→\\t\\treturn fmt.Errorf(\\\"failed to marshal checkpoint summary: %w\\\", err)\\n   418→\\t}\\n   419→\\tmetadataHash, err := CreateBlobFromContent(s.repo, metadataJSON)\\n   420→\\tif err != nil {\\n   421→\\t\\treturn err\\n   422→\\t}\\n   423→\\tentries[basePath+paths.MetadataFileName] = object.TreeEntry{\\n   424→\\t\\tName: basePath + paths.MetadataFileName,\\n   425→\\t\\tMode: filemode.Regular,\\n   426→\\t\\tHash: metadataHash,\\n   427→\\t}\\n   428→\\treturn nil\\n   429→}\\n   430→\\n   431→// findSessionIndex returns the index of an existing session with the given ID,\\n   432→// or the next available index if not found. This prevents duplicate session entries.\\n   433→func (s *GitStore) findSessionIndex(basePath string, existingSummary *CheckpointSummary, entries map[string]object.TreeEntry, sessionID string) int {\\n   434→\\tif existingSummary == nil {\\n   435→\\t\\treturn 0\\n   436→\\t}\\n   437→\\tfor i := range len(existingSummary.Sessions) {\\n   438→\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n   439→\\t\\tif entry, exists := entries[path]; exists {\\n   440→\\t\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n   441→\\t\\t\\tif err != nil {\\n   442→\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to read session metadata during dedup check\\\",\\n   443→\\t\\t\\t\\t\\tslog.Int(\\\"session_index\\\", i),\\n   444→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   445→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   446→\\t\\t\\t\\t)\\n   447→\\t\\t\\t\\tcontinue\\n   448→\\t\\t\\t}\\n   449→\\t\\t\\tif meta.SessionID == sessionID {\\n   450→\\t\\t\\t\\treturn i\\n   451→\\t\\t\\t}\\n   452→\\t\\t}\\n   453→\\t}\\n   454→\\treturn len(existingSummary.Sessions)\\n   455→}\\n   456→\\n   457→// reaggregateFromEntries reads all session metadata from the entries map and\\n   458→// reaggregates CheckpointsCount, FilesTouched, and TokenUsage.\\n   459→func (s *GitStore) reaggregateFromEntries(basePath string, sessionCount int, entries map[string]object.TreeEntry) (int, []string, *agent.TokenUsage, error) {\\n   460→\\tvar totalCount int\\n   461→\\tvar allFiles []string\\n   462→\\tvar totalTokens *agent.TokenUsage\\n   463→\\n   464→\\tfor i := range sessionCount {\\n   465→\\t\\tpath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n   466→\\t\\tentry, exists := entries[path]\\n   467→\\t\\tif !exists {\\n   468→\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"session %d metadata not found at %s\\\", i, path)\\n   469→\\t\\t}\\n   470→\\t\\tmeta, err := s.readMetadataFromBlob(entry.Hash)\\n   471→\\t\\tif err != nil {\\n   472→\\t\\t\\treturn 0, nil, nil, fmt.Errorf(\\\"failed to read session %d metadata: %w\\\", i, err)\\n   473→\\t\\t}\\n   474→\\t\\ttotalCount += meta.CheckpointsCount\\n   475→\\t\\tallFiles = mergeFilesTouched(allFiles, meta.FilesTouched)\\n   476→\\t\\ttotalTokens = aggregateTokenUsage(totalTokens, meta.TokenUsage)\\n   477→\\t}\\n   478→\\n   479→\\treturn totalCount, allFiles, totalTokens, nil\\n   480→}\\n   481→\\n   482→// readJSONFromBlob reads JSON from a blob hash and decodes it to the given type.\\n   483→func readJSONFromBlob[T any](repo *git.Repository, hash plumbing.Hash) (*T, error) {\\n   484→\\tblob, err := repo.BlobObject(hash)\\n   485→\\tif err != nil {\\n   486→\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob: %w\\\", err)\\n   487→\\t}\\n   488→\\n   489→\\treader, err := blob.Reader()\\n   490→\\tif err != nil {\\n   491→\\t\\treturn nil, fmt.Errorf(\\\"failed to get blob reader: %w\\\", err)\\n   492→\\t}\\n   493→\\tdefer reader.Close()\\n   494→\\n   495→\\tvar result T\\n   496→\\tif err := json.NewDecoder(reader).Decode(&result); err != nil {\\n   497→\\t\\treturn nil, fmt.Errorf(\\\"failed to decode: %w\\\", err)\\n   498→\\t}\\n   499→\\n   500→\\treturn &result, nil\\n   501→}\\n   502→\\n   503→// readSummaryFromBlob reads CheckpointSummary from a blob hash.\\n   504→func (s *GitStore) readSummaryFromBlob(hash plumbing.Hash) (*CheckpointSummary, error) {\\n   505→\\treturn readJSONFromBlob[CheckpointSummary](s.repo, hash)\\n   506→}\\n   507→\\n   508→// aggregateTokenUsage sums two TokenUsage structs.\\n   509→// Returns nil if both inputs are nil.\\n   510→func aggregateTokenUsage(a, b *agent.TokenUsage) *agent.TokenUsage {\\n   511→\\tif a == nil && b == nil {\\n   512→\\t\\treturn nil\\n   513→\\t}\\n   514→\\tresult := &agent.TokenUsage{}\\n   515→\\tif a != nil {\\n   516→\\t\\tresult.InputTokens = a.InputTokens\\n   517→\\t\\tresult.CacheCreationTokens = a.CacheCreationTokens\\n   518→\\t\\tresult.CacheReadTokens = a.CacheReadTokens\\n   519→\\t\\tresult.OutputTokens = a.OutputTokens\\n   520→\\t\\tresult.APICallCount = a.APICallCount\\n   521→\\t}\\n   522→\\tif b != nil {\\n   523→\\t\\tresult.InputTokens += b.InputTokens\\n   524→\\t\\tresult.CacheCreationTokens += b.CacheCreationTokens\\n   525→\\t\\tresult.CacheReadTokens += b.CacheReadTokens\\n   526→\\t\\tresult.OutputTokens += b.OutputTokens\\n   527→\\t\\tresult.APICallCount += b.APICallCount\\n   528→\\t}\\n   529→\\treturn result\\n   530→}\\n   531→\\n   532→// writeTranscript writes the transcript file from in-memory content or file path.\\n   533→// If the transcript exceeds MaxChunkSize, it's split into multiple chunk files.\\n   534→func (s *GitStore) writeTranscript(opts WriteCommittedOptions, basePath string, entries map[string]object.TreeEntry) error {\\n   535→\\ttranscript := opts.Transcript\\n   536→\\tif len(transcript) == 0 && opts.TranscriptPath != \\\"\\\" {\\n   537→\\t\\tvar readErr error\\n   538→\\t\\ttranscript, readErr = os.ReadFile(opts.TranscriptPath)\\n   539→\\t\\tif readErr != nil {\\n   540→\\t\\t\\t// Non-fatal: transcript may not exist yet\\n   541→\\t\\t\\ttranscript = nil\\n   542→\\t\\t}\\n   543→\\t}\\n   544→\\tif len(transcript) == 0 {\\n   545→\\t\\treturn nil\\n   546→\\t}\\n   547→\\n   548→\\t// Redact secrets before chunking so content hash reflects redacted content\\n   549→\\ttranscript, err := redact.JSONLBytes(transcript)\\n   550→\\tif err != nil {\\n   551→\\t\\treturn fmt.Errorf(\\\"failed to redact transcript secrets: %w\\\", err)\\n   552→\\t}\\n   553→\\n   554→\\t// Chunk the transcript if it's too large\\n   555→\\tchunks, err := agent.ChunkTranscript(transcript, opts.Agent)\\n   556→\\tif err != nil {\\n   557→\\t\\treturn fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n   558→\\t}\\n   559→\\n   560→\\t// Write chunk files\\n   561→\\tfor i, chunk := range chunks {\\n   562→\\t\\tchunkPath := basePath + agent.ChunkFileName(paths.TranscriptFileName, i)\\n   563→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, chunk)\\n   564→\\t\\tif err != nil {\\n   565→\\t\\t\\treturn err\\n   566→\\t\\t}\\n   567→\\t\\tentries[chunkPath] = object.TreeEntry{\\n   568→\\t\\t\\tName: chunkPath,\\n   569→\\t\\t\\tMode: filemode.Regular,\\n   570→\\t\\t\\tHash: blobHash,\\n   571→\\t\\t}\\n   572→\\t}\\n   573→\\n   574→\\t// Content hash for deduplication (hash of full transcript)\\n   575→\\tcontentHash := fmt.Sprintf(\\\"sha256:%x\\\", sha256.Sum256(transcript))\\n   576→\\thashBlob, err := CreateBlobFromContent(s.repo, []byte(contentHash))\\n   577→\\tif err != nil {\\n   578→\\t\\treturn err\\n   579→\\t}\\n   580→\\tentries[basePath+paths.ContentHashFileName] = object.TreeEntry{\\n   581→\\t\\tName: basePath + paths.ContentHashFileName,\\n   582→\\t\\tMode: filemode.Regular,\\n   583→\\t\\tHash: hashBlob,\\n   584→\\t}\\n   585→\\treturn nil\\n   586→}\\n   587→\\n   588→// mergeFilesTouched combines two file lists, removing duplicates.\\n   589→func mergeFilesTouched(existing, additional []string) []string {\\n   590→\\tseen := make(map[string]bool)\\n   591→\\tvar result []string\\n   592→\\n   593→\\tfor _, f := range existing {\\n   594→\\t\\tif !seen[f] {\\n   595→\\t\\t\\tseen[f] = true\\n   596→\\t\\t\\tresult = append(result, f)\\n   597→\\t\\t}\\n   598→\\t}\\n   599→\\tfor _, f := range additional {\\n   600→\\t\\tif !seen[f] {\\n   601→\\t\\t\\tseen[f] = true\\n   602→\\t\\t\\tresult = append(result, f)\\n   603→\\t\\t}\\n   604→\\t}\\n   605→\\n   606→\\tsort.Strings(result)\\n   607→\\treturn result\\n   608→}\\n   609→\\n   610→// redactSummary returns a copy of the summary with text fields redacted.\\n   611→// Structural fields (Path, Line, EndLine) are preserved.\\n   612→// NOTE: When adding new text fields to Summary, LearningsSummary, or CodeLearning,\\n   613→// update this function to include them in redaction.\\n   614→func redactSummary(s *Summary) *Summary {\\n   615→\\tif s == nil {\\n   616→\\t\\treturn nil\\n   617→\\t}\\n   618→\\treturn &Summary{\\n   619→\\t\\tIntent:    redact.String(s.Intent),\\n   620→\\t\\tOutcome:   redact.String(s.Outcome),\\n   621→\\t\\tFriction:  redactStringSlice(s.Friction),\\n   622→\\t\\tOpenItems: redactStringSlice(s.OpenItems),\\n   623→\\t\\tLearnings: LearningsSummary{\\n   624→\\t\\t\\tRepo:     redactStringSlice(s.Learnings.Repo),\\n   625→\\t\\t\\tWorkflow: redactStringSlice(s.Learnings.Workflow),\\n   626→\\t\\t\\tCode:     redactCodeLearnings(s.Learnings.Code),\\n   627→\\t\\t},\\n   628→\\t}\\n   629→}\\n   630→\\n   631→// redactStringSlice applies redact.String to each element.\\n   632→func redactStringSlice(ss []string) []string {\\n   633→\\tif ss == nil {\\n   634→\\t\\treturn nil\\n   635→\\t}\\n   636→\\tout := make([]string, len(ss))\\n   637→\\tfor i, s := range ss {\\n   638→\\t\\tout[i] = redact.String(s)\\n   639→\\t}\\n   640→\\treturn out\\n   641→}\\n   642→\\n   643→// redactCodeLearnings redacts only the Finding field, preserving Path/Line/EndLine.\\n   644→func redactCodeLearnings(cls []CodeLearning) []CodeLearning {\\n   645→\\tif cls == nil {\\n   646→\\t\\treturn nil\\n   647→\\t}\\n   648→\\tout := make([]CodeLearning, len(cls))\\n   649→\\tfor i, cl := range cls {\\n   650→\\t\\tout[i] = CodeLearning{\\n   651→\\t\\t\\tPath:    cl.Path,\\n   652→\\t\\t\\tLine:    cl.Line,\\n   653→\\t\\t\\tEndLine: cl.EndLine,\\n   654→\\t\\t\\tFinding: redact.String(cl.Finding),\\n   655→\\t\\t}\\n   656→\\t}\\n   657→\\treturn out\\n   658→}\\n   659→\\n   660→// readMetadataFromBlob reads CommittedMetadata from a blob hash.\\n   661→func (s *GitStore) readMetadataFromBlob(hash plumbing.Hash) (*CommittedMetadata, error) {\\n   662→\\treturn readJSONFromBlob[CommittedMetadata](s.repo, hash)\\n   663→}\\n   664→\\n   665→// buildCommitMessage constructs the commit message with proper trailers.\\n   666→// The commit subject is always \\\"Checkpoint: <id>\\\" for consistency.\\n   667→// If CommitSubject is provided (e.g., for task checkpoints), it's included in the body.\\n   668→func (s *GitStore) buildCommitMessage(opts WriteCommittedOptions, taskMetadataPath string) string {\\n   669→\\tvar commitMsg strings.Builder\\n   670→\\n   671→\\t// Subject line is always the checkpoint ID for consistent formatting\\n   672→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"Checkpoint: %s\\\\n\\\\n\\\", opts.CheckpointID))\\n   673→\\n   674→\\t// Include custom description in body if provided (e.g., task checkpoint details)\\n   675→\\tif opts.CommitSubject != \\\"\\\" {\\n   676→\\t\\tcommitMsg.WriteString(opts.CommitSubject + \\\"\\\\n\\\\n\\\")\\n   677→\\t}\\n   678→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.SessionTrailerKey, opts.SessionID))\\n   679→\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.StrategyTrailerKey, opts.Strategy))\\n   680→\\tif opts.Agent != \\\"\\\" {\\n   681→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.AgentTrailerKey, opts.Agent))\\n   682→\\t}\\n   683→\\tif opts.EphemeralBranch != \\\"\\\" {\\n   684→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.EphemeralBranchTrailerKey, opts.EphemeralBranch))\\n   685→\\t}\\n   686→\\tif taskMetadataPath != \\\"\\\" {\\n   687→\\t\\tcommitMsg.WriteString(fmt.Sprintf(\\\"%s: %s\\\\n\\\", trailers.MetadataTaskTrailerKey, taskMetadataPath))\\n   688→\\t}\\n   689→\\n   690→\\treturn commitMsg.String()\\n   691→}\\n   692→\\n   693→// incrementalCheckpointData represents an incremental checkpoint during subagent execution.\\n   694→// This mirrors strategy.SubagentCheckpoint but avoids import cycles.\\n   695→type incrementalCheckpointData struct {\\n   696→\\tType      string          `json:\\\"type\\\"`\\n   697→\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   698→\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n   699→\\tData      json.RawMessage `json:\\\"data\\\"`\\n   700→}\\n   701→\\n   702→// taskCheckpointData represents a final task checkpoint.\\n   703→// This mirrors strategy.TaskCheckpoint but avoids import cycles.\\n   704→type taskCheckpointData struct {\\n   705→\\tSessionID      string `json:\\\"session_id\\\"`\\n   706→\\tToolUseID      string `json:\\\"tool_use_id\\\"`\\n   707→\\tCheckpointUUID string `json:\\\"checkpoint_uuid\\\"`\\n   708→\\tAgentID        string `json:\\\"agent_id,omitempty\\\"`\\n   709→}\\n   710→\\n   711→// ReadCommitted reads a committed checkpoint's summary by ID from the entire/checkpoints/v1 branch.\\n   712→// Returns only the CheckpointSummary (paths + aggregated stats), not actual content.\\n   713→// Use ReadSessionContent to read actual transcript/prompts/context.\\n   714→// Returns nil, nil if the checkpoint doesn't exist.\\n   715→//\\n   716→// The storage format uses numbered subdirectories for each session (0-based):\\n   717→//\\n   718→//\\t<checkpoint-id>/\\n   719→//\\t├── metadata.json      # CheckpointSummary with sessions map\\n   720→//\\t├── 0/                 # First session\\n   721→//\\t│   ├── metadata.json  # Session-specific metadata\\n   722→//\\t│   └── full.jsonl     # Transcript\\n   723→//\\t├── 1/                 # Second session\\n   724→//\\t└── ...\\n   725→func (s *GitStore) ReadCommitted(ctx context.Context, checkpointID id.CheckpointID) (*CheckpointSummary, error) {\\n   726→\\t_ = ctx // Reserved for future use\\n   727→\\n   728→\\ttree, err := s.getSessionsBranchTree()\\n   729→\\tif err != nil {\\n   730→\\t\\treturn nil, nil //nolint:nilnil,nilerr // No sessions branch means no checkpoint exists\\n   731→\\t}\\n   732→\\n   733→\\tcheckpointPath := checkpointID.Path()\\n   734→\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n   735→\\tif err != nil {\\n   736→\\t\\treturn nil, nil //nolint:nilnil,nilerr // Checkpoint directory not found\\n   737→\\t}\\n   738→\\n   739→\\t// Read root metadata.json as CheckpointSummary\\n   740→\\tmetadataFile, err := checkpointTree.File(paths.MetadataFileName)\\n   741→\\tif err != nil {\\n   742→\\t\\treturn nil, nil //nolint:nilnil,nilerr // metadata.json not found\\n   743→\\t}\\n   744→\\n   745→\\tcontent, err := metadataFile.Contents()\\n   746→\\tif err != nil {\\n   747→\\t\\treturn nil, fmt.Errorf(\\\"failed to read metadata.json: %w\\\", err)\\n   748→\\t}\\n   749→\\n   750→\\tvar summary CheckpointSummary\\n   751→\\tif err := json.Unmarshal([]byte(content), &summary); err != nil {\\n   752→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata.json: %w\\\", err)\\n   753→\\t}\\n   754→\\n   755→\\treturn &summary, nil\\n   756→}\\n   757→\\n   758→// ReadSessionContent reads the actual content for a specific session within a checkpoint.\\n   759→// sessionIndex is 0-based (0 for first session, 1 for second, etc.).\\n   760→// Returns the session's metadata, transcript, prompts, and context.\\n   761→// Returns an error if the checkpoint or session doesn't exist.\\n   762→func (s *GitStore) ReadSessionContent(ctx context.Context, checkpointID id.CheckpointID, sessionIndex int) (*SessionContent, error) {\\n   763→\\t_ = ctx // Reserved for future use\\n   764→\\n   765→\\ttree, err := s.getSessionsBranchTree()\\n   766→\\tif err != nil {\\n   767→\\t\\treturn nil, ErrCheckpointNotFound\\n   768→\\t}\\n   769→\\n   770→\\tcheckpointPath := checkpointID.Path()\\n   771→\\tcheckpointTree, err := tree.Tree(checkpointPath)\\n   772→\\tif err != nil {\\n   773→\\t\\treturn nil, ErrCheckpointNotFound\\n   774→\\t}\\n   775→\\n   776→\\t// Get the session subdirectory\\n   777→\\tsessionDir := strconv.Itoa(sessionIndex)\\n   778→\\tsessionTree, err := checkpointTree.Tree(sessionDir)\\n   779→\\tif err != nil {\\n   780→\\t\\treturn nil, fmt.Errorf(\\\"session %d not found: %w\\\", sessionIndex, err)\\n   781→\\t}\\n   782→\\n   783→\\tresult := &SessionContent{}\\n   784→\\n   785→\\t// Read session-specific metadata\\n   786→\\tvar agentType agent.AgentType\\n   787→\\tif metadataFile, fileErr := sessionTree.File(paths.MetadataFileName); fileErr == nil {\\n   788→\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n   789→\\t\\t\\tif jsonErr := json.Unmarshal([]byte(content), &result.Metadata); jsonErr == nil {\\n   790→\\t\\t\\t\\tagentType = result.Metadata.Agent\\n   791→\\t\\t\\t}\\n   792→\\t\\t}\\n   793→\\t}\\n   794→\\n   795→\\t// Read transcript\\n   796→\\tif transcript, transcriptErr := readTranscriptFromTree(sessionTree, agentType); transcriptErr == nil && transcript != nil {\\n   797→\\t\\tresult.Transcript = transcript\\n   798→\\t}\\n   799→\\n   800→\\t// Read prompts\\n   801→\\tif file, fileErr := sessionTree.File(paths.PromptFileName); fileErr == nil {\\n   802→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   803→\\t\\t\\tresult.Prompts = content\\n   804→\\t\\t}\\n   805→\\t}\\n   806→\\n   807→\\t// Read context\\n   808→\\tif file, fileErr := sessionTree.File(paths.ContextFileName); fileErr == nil {\\n   809→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   810→\\t\\t\\tresult.Context = content\\n   811→\\t\\t}\\n   812→\\t}\\n   813→\\n   814→\\t// Read export data (optional — only present for agents with non-file storage, e.g., OpenCode)\\n   815→\\tif file, fileErr := sessionTree.File(paths.ExportDataFileName); fileErr == nil {\\n   816→\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   817→\\t\\t\\tresult.ExportData = []byte(content)\\n   818→\\t\\t}\\n   819→\\t}\\n   820→\\n   821→\\treturn result, nil\\n   822→}\\n   823→\\n   824→// ReadLatestSessionContent is a convenience method that reads the latest session's content.\\n   825→// This is equivalent to ReadSessionContent(ctx, checkpointID, len(summary.Sessions)-1).\\n   826→func (s *GitStore) ReadLatestSessionContent(ctx context.Context, checkpointID id.CheckpointID) (*SessionContent, error) {\\n   827→\\tsummary, err := s.ReadCommitted(ctx, checkpointID)\\n   828→\\tif err != nil {\\n   829→\\t\\treturn nil, err\\n   830→\\t}\\n   831→\\tif summary == nil {\\n   832→\\t\\treturn nil, ErrCheckpointNotFound\\n   833→\\t}\\n   834→\\tif len(summary.Sessions) == 0 {\\n   835→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint has no sessions: %s\\\", checkpointID)\\n   836→\\t}\\n   837→\\n   838→\\tlatestIndex := len(summary.Sessions) - 1\\n   839→\\treturn s.ReadSessionContent(ctx, checkpointID, latestIndex)\\n   840→}\\n   841→\\n   842→// ReadSessionContentByID reads a session's content by its session ID.\\n   843→// This is useful when you have the session ID but don't know its index within the checkpoint.\\n   844→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   845→// Returns an error if no session with the given ID exists in the checkpoint.\\n   846→func (s *GitStore) ReadSessionContentByID(ctx context.Context, checkpointID id.CheckpointID, sessionID string) (*SessionContent, error) {\\n   847→\\tsummary, err := s.ReadCommitted(ctx, checkpointID)\\n   848→\\tif err != nil {\\n   849→\\t\\treturn nil, err\\n   850→\\t}\\n   851→\\tif summary == nil {\\n   852→\\t\\treturn nil, ErrCheckpointNotFound\\n   853→\\t}\\n   854→\\n   855→\\t// Iterate through sessions to find the one with matching session ID\\n   856→\\tfor i := range len(summary.Sessions) {\\n   857→\\t\\tcontent, readErr := s.ReadSessionContent(ctx, checkpointID, i)\\n   858→\\t\\tif readErr != nil {\\n   859→\\t\\t\\tcontinue\\n   860→\\t\\t}\\n   861→\\t\\tif content != nil && content.Metadata.SessionID == sessionID {\\n   862→\\t\\t\\treturn content, nil\\n   863→\\t\\t}\\n   864→\\t}\\n   865→\\n   866→\\treturn nil, fmt.Errorf(\\\"session %q not found in checkpoint %s\\\", sessionID, checkpointID)\\n   867→}\\n   868→\\n   869→// ListCommitted lists all committed checkpoints from the entire/checkpoints/v1 branch.\\n   870→// Scans sharded paths: <id[:2]>/<id[2:]>/ directories containing metadata.json.\\n   871→//\\n   872→\\n   873→func (s *GitStore) ListCommitted(ctx context.Context) ([]CommittedInfo, error) {\\n   874→\\t_ = ctx // Reserved for future use\\n   875→\\n   876→\\ttree, err := s.getSessionsBranchTree()\\n   877→\\tif err != nil {\\n   878→\\t\\treturn []CommittedInfo{}, nil //nolint:nilerr // No sessions branch means empty list\\n   879→\\t}\\n   880→\\n   881→\\tvar checkpoints []CommittedInfo\\n   882→\\n   883→\\t// Scan sharded structure: <2-char-prefix>/<remaining-id>/metadata.json\\n   884→\\tfor _, bucketEntry := range tree.Entries {\\n   885→\\t\\tif bucketEntry.Mode != filemode.Dir {\\n   886→\\t\\t\\tcontinue\\n   887→\\t\\t}\\n   888→\\t\\t// Bucket should be 2 hex chars\\n   889→\\t\\tif len(bucketEntry.Name) != 2 {\\n   890→\\t\\t\\tcontinue\\n   891→\\t\\t}\\n   892→\\n   893→\\t\\tbucketTree, treeErr := s.repo.TreeObject(bucketEntry.Hash)\\n   894→\\t\\tif treeErr != nil {\\n   895→\\t\\t\\tcontinue\\n   896→\\t\\t}\\n   897→\\n   898→\\t\\t// Each entry in the bucket is the remaining part of the checkpoint ID\\n   899→\\t\\tfor _, checkpointEntry := range bucketTree.Entries {\\n   900→\\t\\t\\tif checkpointEntry.Mode != filemode.Dir {\\n   901→\\t\\t\\t\\tcontinue\\n   902→\\t\\t\\t}\\n   903→\\n   904→\\t\\t\\tcheckpointTree, cpTreeErr := s.repo.TreeObject(checkpointEntry.Hash)\\n   905→\\t\\t\\tif cpTreeErr != nil {\\n   906→\\t\\t\\t\\tcontinue\\n   907→\\t\\t\\t}\\n   908→\\n   909→\\t\\t\\t// Reconstruct checkpoint ID: <bucket><remaining>\\n   910→\\t\\t\\tcheckpointIDStr := bucketEntry.Name + checkpointEntry.Name\\n   911→\\t\\t\\tcheckpointID, cpIDErr := id.NewCheckpointID(checkpointIDStr)\\n   912→\\t\\t\\tif cpIDErr != nil {\\n   913→\\t\\t\\t\\t// Skip invalid checkpoint IDs (shouldn't happen with our own data)\\n   914→\\t\\t\\t\\tcontinue\\n   915→\\t\\t\\t}\\n   916→\\n   917→\\t\\t\\tinfo := CommittedInfo{\\n   918→\\t\\t\\t\\tCheckpointID: checkpointID,\\n   919→\\t\\t\\t}\\n   920→\\n   921→\\t\\t\\t// Get details from root metadata file (CheckpointSummary format)\\n   922→\\t\\t\\tif metadataFile, fileErr := checkpointTree.File(paths.MetadataFileName); fileErr == nil {\\n   923→\\t\\t\\t\\tif content, contentErr := metadataFile.Contents(); contentErr == nil {\\n   924→\\t\\t\\t\\t\\tvar summary CheckpointSummary\\n   925→\\t\\t\\t\\t\\tif err := json.Unmarshal([]byte(content), &summary); err == nil {\\n   926→\\t\\t\\t\\t\\t\\tinfo.CheckpointsCount = summary.CheckpointsCount\\n   927→\\t\\t\\t\\t\\t\\tinfo.FilesTouched = summary.FilesTouched\\n   928→\\t\\t\\t\\t\\t\\tinfo.SessionCount = len(summary.Sessions)\\n   929→\\n   930→\\t\\t\\t\\t\\t\\t// Read session metadata from latest session to get Agent, SessionID, CreatedAt\\n   931→\\t\\t\\t\\t\\t\\tif len(summary.Sessions) > 0 {\\n   932→\\t\\t\\t\\t\\t\\t\\tlatestIndex := len(summary.Sessions) - 1\\n   933→\\t\\t\\t\\t\\t\\t\\tlatestDir := strconv.Itoa(latestIndex)\\n   934→\\t\\t\\t\\t\\t\\t\\tif sessionTree, treeErr := checkpointTree.Tree(latestDir); treeErr == nil {\\n   935→\\t\\t\\t\\t\\t\\t\\t\\tif sessionMetadataFile, smErr := sessionTree.File(paths.MetadataFileName); smErr == nil {\\n   936→\\t\\t\\t\\t\\t\\t\\t\\t\\tif sessionContent, scErr := sessionMetadataFile.Contents(); scErr == nil {\\n   937→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata CommittedMetadata\\n   938→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   939→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   940→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   941→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   942→\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   943→\\t\\t\\t\\t\\t\\t\\t\\t\\t}\\n   944→\\t\\t\\t\\t\\t\\t\\t\\t}\\n   945→\\t\\t\\t\\t\\t\\t\\t}\\n   946→\\t\\t\\t\\t\\t\\t}\\n   947→\\t\\t\\t\\t\\t}\\n   948→\\t\\t\\t\\t}\\n   949→\\t\\t\\t}\\n   950→\\n   951→\\t\\t\\tcheckpoints = append(checkpoints, info)\\n   952→\\t\\t}\\n   953→\\t}\\n   954→\\n   955→\\t// Sort by time (most recent first)\\n   956→\\tsort.Slice(checkpoints, func(i, j int) bool {\\n   957→\\t\\treturn checkpoints[i].CreatedAt.After(checkpoints[j].CreatedAt)\\n   958→\\t})\\n   959→\\n   960→\\treturn checkpoints, nil\\n   961→}\\n   962→\\n   963→// GetTranscript retrieves the transcript for a specific checkpoint ID.\\n   964→// Returns the latest session's transcript.\\n   965→func (s *GitStore) GetTranscript(ctx context.Context, checkpointID id.CheckpointID) ([]byte, error) {\\n   966→\\tcontent, err := s.ReadLatestSessionContent(ctx, checkpointID)\\n   967→\\tif err != nil {\\n   968→\\t\\treturn nil, err\\n   969→\\t}\\n   970→\\tif len(content.Transcript) == 0 {\\n   971→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   972→\\t}\\n   973→\\treturn content.Transcript, nil\\n   974→}\\n   975→\\n   976→// GetSessionLog retrieves the session transcript, session ID, and export data for a checkpoint.\\n   977→// This is the primary method for looking up session logs by checkpoint ID.\\n   978→// The export data is optional — only present for agents with non-file storage (e.g., OpenCode).\\n   979→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   980→// Returns ErrNoTranscript if the checkpoint exists but has no transcript.\\n   981→func (s *GitStore) GetSessionLog(cpID id.CheckpointID) ([]byte, string, []byte, error) {\\n   982→\\tcontent, err := s.ReadLatestSessionContent(context.Background(), cpID)\\n   983→\\tif err != nil {\\n   984→\\t\\tif errors.Is(err, ErrCheckpointNotFound) {\\n   985→\\t\\t\\treturn nil, \\\"\\\", nil, ErrCheckpointNotFound\\n   986→\\t\\t}\\n   987→\\t\\treturn nil, \\\"\\\", nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   988→\\t}\\n   989→\\tif len(content.Transcript) == 0 {\\n   990→\\t\\treturn nil, \\\"\\\", nil, ErrNoTranscript\\n   991→\\t}\\n   992→\\treturn content.Transcript, content.Metadata.SessionID, content.ExportData, nil\\n   993→}\\n   994→\\n   995→// LookupSessionLog is a convenience function that opens the repository and retrieves\\n   996→// a session log by checkpoint ID. This is the primary entry point for callers that\\n   997→// don't already have a GitStore instance.\\n   998→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n   999→// Returns ErrNoTranscript if the checkpoint exists but has no transcript.\\n  1000→func LookupSessionLog(cpID id.CheckpointID) ([]byte, string, []byte, error) {\\n  1001→\\trepo, err := git.PlainOpenWithOptions(\\\".\\\", &git.PlainOpenOptions{DetectDotGit: true})\\n  1002→\\tif err != nil {\\n  1003→\\t\\treturn nil, \\\"\\\", nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n  1004→\\t}\\n  1005→\\tstore := NewGitStore(repo)\\n  1006→\\treturn store.GetSessionLog(cpID)\\n  1007→}\\n  1008→\\n  1009→// UpdateSummary updates the summary field in the latest session's metadata.\\n  1010→// Returns ErrCheckpointNotFound if the checkpoint doesn't exist.\\n  1011→func (s *GitStore) UpdateSummary(ctx context.Context, checkpointID id.CheckpointID, summary *Summary) error {\\n  1012→\\t_ = ctx // Reserv