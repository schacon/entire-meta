  635→+\\t// Phase 6: Verify session 2 WAS condensed\\n   636→+\\t// ========================================\\n   637→+\\tt.Log(\\\"Phase 6: Verifying session 2 WAS condensed\\\")\\n   638→+\\n   639→+\\tstate2After, err := env.GetSessionState(session2.ID)\\n   640→+\\tif err != nil {\\n   641→+\\t\\tt.Fatalf(\\\"GetSessionState for session2 after commit failed: %v\\\", err)\\n   642→+\\t}\\n   643→+\\n   644→+\\tif state2After.BaseCommit != finalHead {\\n   645→+\\t\\tt.Errorf(\\\"Session 2 BaseCommit should be updated. Expected %s, got %s\\\",\\n   646→+\\t\\t\\tfinalHead[:7], state2After.BaseCommit[:7])\\n   647→+\\t}\\n   648→+\\n   649→+\\t// ========================================\\n   650→+\\t// Phase 7: Finally commit file2.txt (session 1's carry-forward file)\\n   651→+\\t// ========================================\\n   652→+\\tt.Log(\\\"Phase 7: Committing file2.txt (session 1's carry-forward file)\\\")\\n   653→+\\n   654→+\\tenv.GitAdd(\\\"file2.txt\\\")\\n   655→+\\tenv.GitCommitWithShadowHooks(\\\"Add file2 (session 1 carry-forward)\\\", \\\"file2.txt\\\")\\n   656→+\\n   657→+\\t// ========================================\\n   658→+\\t// Phase 8: Verify session 1 WAS condensed this time\\n   659→+\\t// ========================================\\n   660→+\\tt.Log(\\\"Phase 8: Verifying session 1 WAS condensed when its carry-forward file was committed\\\")\\n   661→+\\n   662→+\\tstate1Final, err := env.GetSessionState(session1.ID)\\n   663→+\\tif err != nil {\\n   664→+\\t\\tt.Fatalf(\\\"GetSessionState for session1 after file2 commit failed: %v\\\", err)\\n   665→+\\t}\\n   666→+\\n   667→+\\t// StepCount should be reset to 0 (condensation happened)\\n   668→+\\tif state1Final.StepCount != 0 {\\n   669→+\\t\\tt.Errorf(\\\"Session 1 StepCount should be 0 after condensation, got %d\\\", state1Final.StepCount)\\n   670→+\\t}\\n   671→+\\n   672→+\\t// FilesTouched should be empty (carry-forward consumed)\\n   673→+\\tif len(state1Final.FilesTouched) != 