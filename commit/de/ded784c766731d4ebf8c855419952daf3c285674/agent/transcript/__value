\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    14→)\\n    15→\\n    16→//nolint:gochecknoinits // Agent self-registration is the intended pattern\\n    17→func init() {\\n    18→\\tagent.Register(agent.AgentNameOpenCode, NewOpenCodeAgent)\\n    19→}\\n    20→\\n    21→//nolint:revive // OpenCodeAgent is clearer than Agent in this context\\n    22→type OpenCodeAgent struct{}\\n    23→\\n    24→// NewOpenCodeAgent creates a new OpenCode agent instance.\\n    25→func NewOpenCodeAgent() agent.Agent {\\n    26→\\treturn &OpenCodeAgent{}\\n    27→}\\n    28→\\n    29→// --- Identity ---\\n    30→\\n    31→func (a *OpenCodeAgent) Name() agent.AgentName   { return agent.AgentNameOpenCode }\\n    32→func (a *OpenCodeAgent) Type() agent.AgentType   { return agent.AgentTypeOpenCode }\\n    33→func (a *OpenCodeAgent) Description() string     { return \\\"OpenCode - AI-powered terminal coding agent\\\" }\\n    34→func (a *OpenCodeAgent) IsPreview() bool         { return true }\\n    35→func (a *OpenCodeAgent) ProtectedDirs() []string { return []string{\\\".opencode\\\"} }\\n    36→\\n    37→func (a *OpenCodeAgent) DetectPresence() (bool, error) {\\n    38→\\trepoRoot, err := paths.RepoRoot()\\n    39→\\tif err != nil {\\n    40→\\t\\trepoRoot = \\\".\\\"\\n    41→\\t}\\n    42→\\t// Check for .opencode directory or opencode.json config\\n    43→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\".opencode\\\")); err == nil {\\n    44→\\t\\treturn true, nil\\n    45→\\t}\\n    46→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\"opencode.json\\\")); err == nil {\\n    47→\\t\\treturn true, nil\\n    48→\\t}\\n    49→\\treturn false, nil\\n    50→}\\n    51→\\n    52→// --- Transcript Storage ---\\n    53→\\n    54→func (a *OpenCodeAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    55→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    56→\\tif err != nil {\\n    57→\\t\\treturn nil, fmt.Errorf(\\\"failed to read opencode transcript: %w\\\", err)\\n    58→\\t}\\n    59→\\treturn data, nil\\n    60→}\\n    61→\\n    62→func (a *OpenCodeAgent) ChunkTranscript(content []byte, maxSize int) ([][]byte, error) {\\n    63→\\t// OpenCode uses JSONL (one message per line) — use the shared JSONL chunker.\\n    64→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    65→\\tif err != nil {\\n    66→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk opencode transcript: %w\\\", err)\\n    67→\\t}\\n    68→\\treturn chunks, nil\\n    69→}\\n    70→\\n    71→func (a *OpenCodeAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    72→\\t// JSONL reassembly is simple concatenation.\\n    73→\\treturn agent.ReassembleJSONL(chunks), nil\\n    74→}\\n    75→\\n    76→// --- Legacy methods ---\\n    77→\\n    78→func (a *OpenCodeAgent) GetSessionID(input *agent.HookInput) string {\\n    79→\\treturn input.SessionID\\n    80→}\\n    81→\\n    82→// GetSessionDir returns the directory where Entire stores OpenCode session transcripts.\\n    83→// Transcripts are ephemeral handoff files between the TS plugin and the Go hook handler.\\n    84→// Once checkpointed, the data lives on git refs and the file is disposable.\\n    85→// Stored in os.TempDir()/entire-opencode/<sanitized-path>/ to avoid squatting on\\n    86→// OpenCode's own directories (~/.opencode/ is project-level, not home-level).\\n    87→func (a *OpenCodeAgent) GetSessionDir(repoPath string) (string, error) {\\n    88→\\t// Check for test environment override\\n    89→\\tif override := os.Getenv(\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR\\\"); override != \\\"\\\" {\\n    90→\\t\\treturn override, nil\\n    91→\\t}\\n    92→\\n    93→\\tprojectDir := SanitizePathForOpenCode(repoPath)\\n    94→\\treturn filepath.Join(os.TempDir(), \\\"entire-opencode\\\", projectDir), nil\\n    95→}\\n    96→\\n    97→func (a *OpenCodeAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n    98→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".jsonl\\\")\\n    99→}\\n   100→\\n   101→func (a *OpenCodeAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   102→\\tif input.SessionRef == \\\"\\\" {\\n   103→\\t\\treturn nil, errors.New(\\\"no session ref provided\\\")\\n   104→\\t}\\n   105→\\tdata, err := os.ReadFile(input.SessionRef)\\n   106→\\tif err != nil {\\n   107→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session: %w\\\", err)\\n   108→\\t}\\n   109→\\n   110→\\t// Parse to extract computed fields\\n   111→\\tmodifiedFiles, err := ExtractModifiedFiles(data)\\n   112→\\tif err != nil {\\n   113→\\t\\t// Non-fatal: we can still return the session without modified files\\n   114→\\t\\tmodifiedFiles = nil\\n   115→\\t}\\n   116→\\n   117→\\treturn &agent.AgentSession{\\n   118→\\t\\tAgentName:     a.Name(),\\n   119→\\t\\tSessionID:     input.SessionID,\\n   120→\\t\\tSessionRef:    input.SessionRef,\\n   121→\\t\\tNativeData:    data,\\n   122→\\t\\tModifiedFiles: modifiedFiles,\\n   123→\\t}, nil\\n   124→}\\n   125→\\n   126→func (a *OpenCodeAgent) WriteSession(session *agent.AgentSession) error {\\n   127→\\tif session == nil {\\n   128→\\t\\treturn errors.New(\\\"nil session\\\")\\n   129→\\t}\\n   130→\\tif session.SessionRef == \\\"\\\" {\\n   131→\\t\\treturn errors.New(\\\"no session ref to write to\\\")\\n   132→\\t}\\n   133→\\tif len(session.NativeData) == 0 {\\n   134→\\t\\treturn errors.New(\\\"no session data to write\\\")\\n   135→\\t}\\n   136→\\n   137→\\t// 1. Write JSONL file (for Entire's internal checkpoint use)\\n   138→\\tdir := filepath.Dir(session.SessionRef)\\n   139→\\t//nolint:gosec // G301: Session directory needs standard permissions\\n   140→\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   141→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   142→\\t}\\n   143→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   144→\\t\\treturn fmt.Errorf(\\\"failed to write session data: %w\\\", err)\\n   145→\\t}\\n   146→\\n   147→\\t// 2. If we have export data, import the session into OpenCode.\\n   148→\\t//    This enables `opencode -s <id>` for both resume and rewind.\\n   149→\\tif len(session.ExportData) == 0 {\\n   150→\\t\\treturn nil // No export data — skip import (graceful degradation)\\n   151→\\t}\\n   152→\\n   153→\\tif err := a.importSessionIntoOpenCode(session.SessionID, session.ExportData); err != nil {\\n   154→\\t\\t// Non-fatal: import is best-effort. The JSONL file is written,\\n   155→\\t\\t// and the user can always run `opencode import <file>` manually.\\n   156→\\t\\tfmt.Fprintf(os.Stderr, \\\"warning: could not import session into OpenCode: %v\\\\n\\\", err)\\n   157→\\t}\\n   158→\\n   159→\\treturn nil\\n   160→}\\n   161→\\n   162→// importSessionIntoOpenCode writes the export JSON to a temp file and runs\\n   163→// `opencode import` to restore the session into OpenCode's database.\\n   164→// For rewind (session already exists), the session is deleted first so the\\n   165→// reimport replaces it with the checkpoint-state messages.\\n   166→func (a *OpenCodeAgent) importSessionIntoOpenCode(sessionID string, exportData []byte) error {\\n   167→\\t// Delete the session first so reimport replaces it cleanly.\\n   168→\\t// opencode import uses ON CONFLICT DO NOTHING, so existing messages\\n   169→\\t// would be skipped without this step (breaking rewind).\\n   170→\\t// runOpenCodeSessionDelete treats \\\"not found\\\" as success.\\n   171→\\tif err := runOpenCodeSessionDelete(sessionID); err != nil {\\n   172→\\t\\treturn fmt.Errorf(\\\"failed to delete existing session: %w\\\", err)\\n   173→\\t}\\n   174→\\n   175→\\t// Write export JSON to a temp file for opencode import\\n   176→\\ttmpFile, err := os.CreateTemp(\\\"\\\", \\\"entire-opencode-export-*.json\\\")\\n   177→\\tif err != nil {\\n   178→\\t\\treturn fmt.Errorf(\\\"failed to create temp file: %w\\\", err)\\n   179→\\t}\\n   180→\\tdefer os.Remove(tmpFile.Name())\\n   181→\\n   182→\\tif _, err := tmpFile.Write(exportData); err != nil {\\n   183→\\t\\t_ = tmpFile.Close()\\n   184→\\t\\treturn fmt.Errorf(\\\"failed to write export data: %w\\\", err)\\n   185→\\t}\\n   186→\\tif err := tmpFile.Close(); err != nil {\\n   187→\\t\\treturn fmt.Errorf(\\\"failed to close temp file: %w\\\", err)\\n   188→\\t}\\n   189→\\n   190→\\treturn runOpenCodeImport(tmpFile.Name())\\n   191→}\\n   192→\\n   193→func (a *OpenCodeAgent) FormatResumeCommand(sessionID string) string {\\n   194→\\tif strings.TrimSpace(sessionID) == \\\"\\\" {\\n   195→\\t\\treturn \\\"opencode\\\"\\n   196→\\t}\\n   197→\\treturn \\\"opencode -s \\\" + sessionID\\n   198→}\\n   199→\\n   200→// nonAlphanumericRegex matches any non-alphanumeric character.\\n   201→var nonAlphanumericRegex = regexp.MustCompile(`[^a-zA-Z0-9]`)\\n   202→\\n   203→// SanitizePathForOpenCode converts a path to a safe directory name.\\n   204→// Replaces any non-alphanumeric character with a dash (same approach as Claude/Gemini).\\n   205→func SanitizePathForOpenCode(path string) string {\\n   206→\\treturn nonAlphanumericRegex.ReplaceAllString(path, \\\"-\\\")\\n   207→}\\n   208→\\n\\n<system-reminder>\\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\\n</system-reminder>\\n\"}]},\"uuid\":\"5664d86d-2025-4400-833e-2499637e9d19\",\"timestamp\":\"2026-02-20T09:24:27.652Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Review the CLI command and setup changes in this branch (feat/add-opencode vs main). Focus on:\\n\\n1. Command changes:\\n   - cmd/entire/cli/rewind.go\\n   - cmd/entire/cli/resume.go\\n   - cmd/entire/cli/explain.go\\n   - cmd/entire/cli/setup.go\\n   - cmd/entire/cli/lifecycle.go\\n   - cmd/entire/cli/hooks_cmd.go\\n   - cmd/entire/cli/hook_registry.go\\n\\n2. Summarize changes:\\n   - cmd/entire/cli/summarize/summarize.go\\n   - cmd/entire/cli/summarize/summarize_test.go\\n\\n3. Check for:\\n   - User experience consistency\\n   - Error messages clarity\\n   - Proper integration with OpenCode agent\\n   - Command flag/option handling\\n   - Backwards compatibility\\n\\nUse `git diff main...HEAD` to see the actual changes. Provide specific feedback with file:line references.\",\"agentId\":\"a5781b6\"},\"toolUseID\":\"agent_msg_011m6vKUQcfmFT1p2T8EZmb3\",\"parentToolUseID\":\"toolu_015zJ85SZcS98YZCGZstre5a\",\"uuid\":\"434ea476-b15f-446d-ba10-e4fd55e3e959\",\"timestamp\":\"2026-02-20T09:24:27.677Z\"}\n{\"parentUuid\":\"434ea476-b15f-446d-ba10-e4fd55e3e959\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli\",\"sessionId\":\"a8533fc6-4167-49d5-9143-32f1d83dd315\",\"version\":\"2.1.17\",\"gitBranch\":\"feat/add-opencode\",\"slug\":\"calm-brewing-cerf\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01NwvoY165yDnbzPAGeeQdWU\",\"type\":\"tool_result\",\"content\":\"     1→//go:build integration\\n     2→\\n     3→package integration\\n     4→\\n     5→import (\\n     6→\\t\\\"testing\\\"\\n     7→\\n     8→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n     9→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    10→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    11→)\\n    12→\\n    13→// TestOpenCodeHookFlow verifies the full hook flow for OpenCode:\\n    14→// session-start → turn-start → file changes → turn-end → checkpoint → commit → condense → session-end.\\n    15→func TestOpenCodeHookFlow(t *testing.T) {\\n    16→\\tt.Parallel()\\n    17→\\n    18→\\tRunForAllStrategies(t, func(t *testing.T, env *TestEnv, strategyName string) {\\n    19→\\t\\tenv.InitEntireWithAgent(strategyName, agent.AgentNameOpenCode)\\n    20→\\n    21→\\t\\t// Create OpenCode session\\n    22→\\t\\tsession := env.NewOpenCodeSession()\\n    23→\\n    24→\\t\\t// 1. session-start\\n    25→\\t\\tif err := env.SimulateOpenCodeSessionStart(session.ID, session.TranscriptPath); err != nil {\\n    26→\\t\\t\\tt.Fatalf(\\\"session-start error: %v\\\", err)\\n    27→\\t\\t}\\n    28→\\n    29→\\t\\t// 2. turn-start (equivalent to UserPromptSubmit — captures pre-prompt state)\\n    30→\\t\\tif err := env.SimulateOpenCodeTurnStart(session.ID, session.TranscriptPath, \\\"Add a feature\\\"); err != nil {\\n    31→\\t\\t\\tt.Fatalf(\\\"turn-start error: %v\\\", err)\\n    32→\\t\\t}\\n    33→\\n    34→\\t\\t// 3. Agent makes file changes (AFTER turn-start so they're detected as new)\\n    35→\\t\\tenv.WriteFile(\\\"feature.go\\\", \\\"package main\\\\n// new feature\\\")\\n    36→\\n    37→\\t\\t// 4. Create transcript with the file change\\n    38→\\t\\tsession.CreateOpenCodeTranscript(\\\"Add a feature\\\", []FileChange{\\n    39→\\t\\t\\t{Path: \\\"feature.go\\\", Content: \\\"package main\\\\n// new feature\\\"},\\n    40→\\t\\t})\\n    41→\\n    42→\\t\\t// 5. turn-end (equivalent to Stop — creates checkpoint)\\n    43→\\t\\tif err := env.SimulateOpenCodeTurnEnd(session.ID, session.TranscriptPath); err != nil {\\n    44→\\t\\t\\tt.Fatalf(\\\"turn-end error: %v\\\", err)\\n    45→\\t\\t}\\n    46→\\n    47→\\t\\t// 6. Verify checkpoint was created\\n    48→\\t\\tpoints := env.GetRewindPoints()\\n    49→\\t\\tif len(points) == 0 {\\n    50→\\t\\t\\tt.Fatal(\\\"expected at least 1 rewind point after turn-end\\\")\\n    51→\\t\\t}\\n    52→\\n    53→\\t\\t// 7. For manual-commit, user commits manually (triggers condensation).\\n    54→\\t\\t// For auto-commit, the commit was already made during turn-end.\\n    55→\\t\\tif strategyName == strategy.StrategyNameManualCommit {\\n    56→\\t\\t\\tenv.GitCommitWithShadowHooks(\\\"Add feature\\\", \\\"feature.go\\\")\\n    57→\\t\\t}\\n    58→\\n    59→\\t\\t// 8. session-end\\n    60→\\t\\tif err := env.SimulateOpenCodeSessionEnd(session.ID, session.TranscriptPath); err != nil {\\n    61→\\t\\t\\tt.Fatalf(\\\"session-end error: %v\\\", err)\\n    62→\\t\\t}\\n    63→\\n    64→\\t\\t// 9. Verify condensation happened (checkpoint on metadata branch)\\n    65→\\t\\tcheckpointID := env.TryGetLatestCheckpointID()\\n    66→\\t\\tif checkpointID == \\\"\\\" {\\n    67→\\t\\t\\tt.Fatal(\\\"expected checkpoint on metadata branch after commit\\\")\\n    68→\\t\\t}\\n    69→\\n    70→\\t\\t// 10. Verify condensed data\\n    71→\\t\\ttranscriptPath := SessionFilePath(checkpointID, paths.TranscriptFileName)\\n    72→\\t\\t_, found := env.ReadFileFromBranch(paths.MetadataBranchName, transcriptPath)\\n    73→\\t\\tif !found {\\n    74→\\t\\t\\tt.Error(\\\"condensed transcript should exist on metadata branch\\\")\\n    75→\\t\\t}\\n    76→\\t})\\n    77→}\\n    78→\\n    79→// TestOpenCodeAgentStrategyComposition verifies that the OpenCode agent and strategy\\n    80→// work together correctly — agent parses session, strategy saves checkpoint, rewind works.\\n    81→func TestOpenCodeAgentStrategyComposition(t *testing.T) {\\n    82→\\tt.Parallel()\\n    83→\\n    84→\\tRunForAllStrategies(t, func(t *testing.T, env *TestEnv, strategyName string) {\\n    85→\\t\\tenv.InitEntireWithAgent(strategyName, agent.AgentNameOpenCode)\\n    86→\\n    87→\\t\\tag, err := agent.Get(\\\"opencode\\\")\\n    88→\\t\\tif err != nil {\\n    89→\\t\\t\\tt.Fatalf(\\\"Get(opencode) error = %v\\\", err)\\n    90→\\t\\t}\\n    91→\\n    92→\\t\\t_, err = strategy.Get(strategyName)\\n    93→\\t\\tif err != nil {\\n    94→\\t\\t\\tt.Fatalf(\\\"Get(%s) error = %v\\\", strategyName, err)\\n    95→\\t\\t}\\n    96→\\n    97→\\t\\t// Create session and transcript for agent interface testing.\\n    98→\\t\\t// The transcript references feature.go but the actual file doesn't need\\n    99→\\t\\t// to exist for ReadSession — it only parses the transcript JSONL.\\n   100→\\t\\tsession := env.NewOpenCodeSession()\\n   101→\\t\\ttranscriptPath := session.CreateOpenCodeTranscript(\\\"Add a feature\\\", []FileChange{\\n   102→\\t\\t\\t{Path: \\\"feature.go\\\", Content: \\\"package main\\\\n// new feature\\\"},\\n   103→\\t\\t})\\n   104→\\n   105→\\t\\t// Read session via agent interface\\n   106→\\t\\tagentSession, err := ag.ReadSession(&agent.HookInput{\\n   107→\\t\\t\\tSessionID:  session.ID,\\n   108→\\t\\t\\tSessionRef: transcriptPath,\\n   109→\\t\\t})\\n   110→\\t\\tif err != nil {\\n   111→\\t\\t\\tt.Fatalf(\\\"ReadSession() error = %v\\\", err)\\n   112→\\t\\t}\\n   113→\\n   114→\\t\\t// Verify agent computed modified files\\n   115→\\t\\tif len(agentSession.ModifiedFiles) == 0 {\\n   116→\\t\\t\\tt.Error(\\\"agent.ReadSession() should compute ModifiedFiles\\\")\\n   117→\\t\\t}\\n   118→\\n   119→\\t\\t// Simulate session flow: session-start → turn-start → file changes → turn-end\\n   120→\\t\\tif err := env.SimulateOpenCodeSessionStart(session.ID, transcriptPath); err != nil {\\n   121→\\t\\t\\tt.Fatalf(\\\"session-start error = %v\\\", err)\\n   122→\\t\\t}\\n   123→\\t\\tif err := env.SimulateOpenCodeTurnStart(session.ID, transcriptPath, \\\"Add a feature\\\"); err != nil {\\n   124→\\t\\t\\tt.Fatalf(\\\"turn-start error = %v\\\", err)\\n   125→\\t\\t}\\n   126→\\n   127→\\t\\t// Create the actual file AFTER turn-start so the strategy detects it as new\\n   128→\\t\\tenv.WriteFile(\\\"feature.go\\\", \\\"package main\\\\n// new feature\\\")\\n   129→\\n   130→\\t\\tif err := env.SimulateOpenCodeTurnEnd(session.ID, transcriptPath); err != nil {\\n   131→\\t\\t\\tt.Fatalf(\\\"turn-end error = %v\\\", err)\\n   132→\\t\\t}\\n   133→\\n   134→\\t\\t// Verify checkpoint was created\\n   135→\\t\\tpoints := env.GetRewindPoints()\\n   136→\\t\\tif len(points) == 0 {\\n   137→\\t\\t\\tt.Fatal(\\\"expected at least 1 rewind point after turn-end\\\")\\n   138→\\t\\t}\\n   139→\\t})\\n   140→}\\n   141→\\n   142→// TestOpenCodeRewind verifies that rewind works with OpenCode checkpoints.\\n   143→func TestOpenCodeRewind(t *testing.T) {\\n   144→\\tt.Parallel()\\n   145→\\n   146→\\t// Test with manual-commit strategy as it has full file restoration on rewind\\n   147→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   148→\\tenv.InitEntireWithAgent(strategy.StrategyNameManualCommit, agent.AgentNameOpenCode)\\n   149→\\n   150→\\t// First session\\n   151→\\tsession := env.NewOpenCodeSession()\\n   152→\\ttranscriptPath := session.TranscriptPath\\n   153→\\n   154→\\tif err := env.SimulateOpenCodeSessionStart(session.ID, transcriptPath); err != nil {\\n   155→\\t\\tt.Fatalf(\\\"session-start error: %v\\\", err)\\n   156→\\t}\\n   157→\\n   158→\\t// Turn 1: create file1.go (AFTER turn-start so it's detected as new)\\n   159→\\tif err := env.SimulateOpenCodeTurnStart(session.ID, transcriptPath, \\\"Create file1\\\"); err != nil {\\n   160→\\t\\tt.Fatalf(\\\"turn-start error: %v\\\", err)\\n   161→\\t}\\n   162→\\n   163→\\tenv.WriteFile(\\\"file1.go\\\", \\\"package main\\\\n// file1 v1\\\")\\n   164→\\tsession.CreateOpenCodeTranscript(\\\"Create file1\\\", []FileChange{\\n   165→\\t\\t{Path: \\\"file1.go\\\", Content: \\\"package main\\\\n// file1 v1\\\"},\\n   166→\\t})\\n   167→\\n   168→\\tif err := env.SimulateOpenCodeTurnEnd(session.ID, transcriptPath); err != nil {\\n   169→\\t\\tt.Fatalf(\\\"turn-end error: %v\\\", err)\\n   170→\\t}\\n   171→\\n   172→\\tpoints1 := env.GetRewindPoints()\\n   173→\\tif len(points1) == 0 {\\n   174→\\t\\tt.Fatal(\\\"no rewind point after first turn\\\")\\n   175→\\t}\\n   176→\\tcheckpoint1ID := points1[0].ID\\n   177→\\n   178→\\t// Turn 2: modify file1 and create file2 (AFTER turn-start)\\n   179→\\tif err := env.SimulateOpenCodeTurnStart(session.ID, transcriptPath, \\\"Modify file1\\\"); err != nil {\\n   180→\\t\\tt.Fatalf(\\\"turn-start error: %v\\\", err)\\n   181→\\t}\\n   182→\\n   183→\\tenv.WriteFile(\\\"file1.go\\\", \\\"package main\\\\n// file1 v2\\\")\\n   184→\\tenv.WriteFile(\\\"file2.go\\\", \\\"package main\\\\n// file2\\\")\\n   185→\\tsession.CreateOpenCodeTranscript(\\\"Modify file1, create file2\\\", []FileChange{\\n   186→\\t\\t{Path: \\\"file1.go\\\", Content: \\\"package main\\\\n// file1 v2\\\"},\\n   187→\\t\\t{Path: \\\"file2.go\\\", Content: \\\"package main\\\\n// file2\\\"},\\n   188→\\t})\\n   189→\\n   190→\\tif err := env.SimulateOpenCodeTurnEnd(session.ID, transcriptPath); err != nil {\\n   191→\\t\\tt.Fatalf(\\\"turn-end error: %v\\\", err)\\n   192→\\t}\\n   193→\\n   194→\\t// Verify 2 checkpoints\\n   195→\\tpoints2 := env.GetRewindPoints()\\n   196→\\tif len(points2) < 2 {\\n   197→\\t\\tt.Fatalf(\\\"expected at least 2 rewind points, got %d\\\", len(points2))\\n   198→\\t}\\n   199→\\n   200→\\t// Rewind to first checkpoint\\n   201→\\tif err := env.Rewind(checkpoint1ID); err != nil {\\n   202→\\t\\tt.Fatalf(\\\"Rewind() error = %v\\\", err)\\n   203→\\t}\\n   204→\\n   205→\\t// Verify file1 is restored to v1\\n   206→\\tcontent := env.ReadFile(\\\"file1.go\\\")\\n   207→\\tif content != \\\"package main\\\\n// file1 v1\\\" {\\n   208→\\t\\tt.Errorf(\\\"file1.go after rewind = %q, want v1 content\\\", content)\\n   209→\\t}\\n   210→\\n   211→\\t// file2 should not exist after rewind to checkpoint 1\\n   212→\\tif env.FileExists(\\\"file2.go\\\") {\\n   213→\\t\\tt.Error(\\\"file2.go should not exist after rewind to checkpoint 1\\\")\\n   214→\\t}\\n   215→}\\n   216→\\n   217→// TestOpenCodeMultiTurnCondensation verifies that multiple turns in a session\\n   218→// are correctly condensed when the user commits.\\n   219→func TestOpenCodeMultiTurnCondensation(t *testing.T) {\\n   220→\\tt.Parallel()\\n   221→\\n   222→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   223→\\tenv.InitEntireWithAgent(strategy.StrategyNameManualCommit, agent.AgentNameOpenCode)\\n   224→\\n   225→\\tsession := env.NewOpenCodeSession()\\n   226→\\ttranscriptPath := session.TranscriptPath\\n   227→\\n   228→\\t// session-start\\n   229→\\tif err := env.SimulateOpenCodeSessionStart(session.ID, transcriptPath); err != nil {\\n   230→\\t\\tt.Fatalf(\\\"session-start error: %v\\\", err)\\n   231→\\t}\\n   232→\\n   233→\\t// Turn 1: create file (AFTER turn-start so it's detected as new)\\n   234→\\tif err := env.SimulateOpenCodeTurnStart(session.ID, transcriptPath, \\\"Create app.go\\\"); err != nil {\\n   235→\\t\\tt.Fatalf(\\\"turn-start error: %v\\\", err)\\n   236→\\t}\\n   237→\\n   238→\\tenv.WriteFile(\\\"app.go\\\", \\\"package main\\\\nfunc main() {}\\\")\\n   239→\\tsession.CreateOpenCodeTranscript(\\\"Create app.go\\\", []FileChange{\\n   240→\\t\\t{Path: \\\"app.go\\\", Content: \\\"package main\\\\nfunc main() {}\\\"},\\n   241→\\t})\\n   242→\\n   243→\\tif err := env.SimulateOpenCodeTurnEnd(session.ID, transcriptPath); err != nil {\\n   244→\\t\\tt.Fatalf(\\\"turn-end error: %v\\\", err)\\n   245→\\t}\\n   246→\\n   247→\\t// Verify checkpoint\\n   248→\\tpoints := env.GetRewindPoints()\\n   249→\\tif len(points) == 0 {\\n   250→\\t\\tt.Fatal(\\\"expected rewind point after first turn\\\")\\n   251→\\t}\\n   252→\\n   253→\\t// Commit with hooks (triggers condensation)\\n   254→\\tenv.GitCommitWithShadowHooks(\\\"Implement app\\\", \\\"app.go\\\")\\n   255→\\n   256→\\t// session-end\\n   257→\\tif err := env.SimulateOpenCodeSessionEnd(session.ID, transcriptPath); err != nil {\\n   258→\\t\\tt.Fatalf(\\\"session-end error: %v\\\", err)\\n   259→\\t}\\n   260→\\n   261→\\t// Verify checkpoint was condensed to metadata branch\\n   262→\\tcheckpointID := env.TryGetLatestCheckpointID()\\n   263→\\tif checkpointID == \\\"\\\" {\\n   264→\\t\\tt.Fatal(\\\"expected checkpoint on metadata branch after commit\\\")\\n   265→\\t}\\n   266→\\n   267→\\t// Verify files are on metadata branch\\n   268→\\tenv.ValidateCheckpoint(CheckpointValidation{\\n   269→\\t\\tCheckp