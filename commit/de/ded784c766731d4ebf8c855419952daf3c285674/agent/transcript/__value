gent.AgentType   { return agent.AgentTypeOpenCode }\\n    33→func (a *OpenCodeAgent) Description() string     { return \\\"OpenCode - AI-powered terminal coding agent\\\" }\\n    34→func (a *OpenCodeAgent) IsPreview() bool         { return true }\\n    35→func (a *OpenCodeAgent) ProtectedDirs() []string { return []string{\\\".opencode\\\"} }\\n    36→\\n    37→func (a *OpenCodeAgent) DetectPresence() (bool, error) {\\n    38→\\trepoRoot, err := paths.RepoRoot()\\n    39→\\tif err != nil {\\n    40→\\t\\trepoRoot = \\\".\\\"\\n    41→\\t}\\n    42→\\t// Check for .opencode directory or opencode.json config\\n    43→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\".opencode\\\")); err == nil {\\n    44→\\t\\treturn true, nil\\n    45→\\t}\\n    46→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\"opencode.json\\\")); err == nil {\\n    47→\\t\\treturn true, nil\\n    48→\\t}\\n    49→\\treturn false, nil\\n    50→}\\n    51→\\n    52→// --- Transcript Storage ---\\n    53→\\n    54→func (a *OpenCodeAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    55→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    56→\\tif err != nil {\\n    57→\\t\\treturn nil, fmt.Errorf(\\\"failed to read opencode transcript: %w\\\", err)\\n    58→\\t}\\n    59→\\treturn data, nil\\n    60→}\\n    61→\\n    62→func (a *OpenCodeAgent) ChunkTranscript(content []byte, maxSize int) ([][]byte, error) {\\n    63→\\t// OpenCode uses JSONL (one message per line) — use the shared JSONL chunker.\\n    64→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    65→\\tif err != nil {\\n    66→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk opencode transcript: %w\\\", err)\\n    67→\\t}\\n    68→\\treturn chunks, nil\\n    69→}\\n    70→\\n    71→func (a *OpenCodeAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    72→\\t// JSONL reassembly is simple concatenation.\\n    73→\\treturn agent.ReassembleJSONL(chunks), nil\\n    74→}\\n    75→\\n    76→// --- Legacy methods ---\\n    77→\\n    78→func (a *OpenCodeAgent) GetSessionID(input *agent.HookInput) string {\\n    79→\\treturn input.SessionID\\n    80→}\\n    81→\\n    82→// GetSessionDir returns the directory where Entire stores OpenCode session transcripts.\\n    83→// Transcripts are ephemeral handoff files between the TS plugin and the Go hook handler.\\n    84→// Once checkpointed, the data lives on git refs and the file is disposable.\\n    85→// Stored in os.TempDir()/entire-opencode/<sanitized-path>/ to avoid squatting on\\n    86→// OpenCode's own directories (~/.opencode/ is project-level, not home-level).\\n    87→func (a *OpenCodeAgent) GetSessionDir(repoPath string) (string, error) {\\n    88→\\t// Check for test environment override\\n    89→\\tif override := os.Getenv(\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR\\\"); override != \\\"\\\" {\\n    90→\\t\\treturn override, nil\\n    91→\\t}\\n    92→\\n    93→\\tprojectDir := SanitizePathForOpenCode(repoPath)\\n    94→\\treturn filepath.Join(os.TempDir(), \\\"entire-opencode\\\", projectDir), nil\\n    95→}\\n    96→\\n    97→func (a *OpenCodeAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n    98→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".jsonl\\\")\\n    99→}\\n   100→\\n   101→func (a *OpenCodeAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   102→\\tif input.SessionRef == \\\"\\\" {\\n   103→\\t\\treturn nil, errors.New(\\\"no session ref provided\\\")\\n   104→\\t}\\n   105→\\tdata, err := os.ReadFile(input.SessionRef)\\n   106→\\tif err != nil {\\n   107→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session: %w\\\", err)\\n   108→\\t}\\n   109→\\n   110→\\t// Parse to extract computed fields\\n   111→\\tmodifiedFiles, err := ExtractModifiedFiles(data)\\n   112→\\tif err != nil {\\n   113→\\t\\t// Non-fatal: we can still return the session without modified files\\n   114→\\t\\tmodifiedFiles = nil\\n   115→\\t}\\n   116