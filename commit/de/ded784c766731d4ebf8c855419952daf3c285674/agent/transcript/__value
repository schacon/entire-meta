put()\\n   549→\\tif err != nil {\\n   550→\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n   551→\\t\\t\\thookName, err, inputJSON, output)\\n   552→\\t}\\n   553→\\n   554→\\tr.T.Logf(\\\"Gemini hook %s output: %s\\\", hookName, output)\\n   555→\\treturn nil\\n   556→}\\n   557→\\n   558→// runGeminiHookWithOutput runs a Gemini hook and returns both stdout and stderr separately.\\n   559→func (r *GeminiHookRunner) runGeminiHookWithOutput(hookName string, inputJSON []byte) HookOutput {\\n   560→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n   561→\\tcmd.Dir = r.RepoDir\\n   562→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   563→\\tcmd.Env = append(os.Environ(),\\n   564→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n   565→\\t)\\n   566→\\n   567→\\tvar stdout, stderr bytes.Buffer\\n   568→\\tcmd.Stdout = &stdout\\n   569→\\tcmd.Stderr = &stderr\\n   570→\\n   571→\\terr := cmd.Run()\\n   572→\\treturn HookOutput{\\n   573→\\t\\tStdout: stdout.Bytes(),\\n   574→\\t\\tStderr: stderr.Bytes(),\\n   575→\\t\\tErr:    err,\\n   576→\\t}\\n   577→}\\n   578→\\n   579→// SimulateGeminiBeforeAgent simulates the BeforeAgent hook for Gemini CLI.\\n   580→// This is equivalent to Claude Code's UserPromptSubmit.\\n   581→func (r *GeminiHookRunner) SimulateGeminiBeforeAgent(sessionID string) error {\\n   582→\\tr.T.Helper()\\n   583→\\n   584→\\tinput := map[string]string{\\n   585→\\t\\t\\\"session_id\\\":      sessionID,\\n   586→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   587→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   588→\\t\\t\\\"hook_event_name\\\": \\\"BeforeAgent\\\",\\n   589→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   590→\\t\\t\\\"prompt\\\":          \\\"test prompt\\\",\\n   591→\\t}\\n   592→\\n   593→\\treturn r.runGeminiHookWithInput(\\\"before-agent\\\", input)\\n   594→}\\n   595→\\n   596→// SimulateGeminiBeforeAgentWithOutput simulates th