g.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get HEAD commit, falling back to filename check\\\",\\n   193→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   194→\\t\\t)\\n   195→\\t\\treturn hasOverlappingFiles(stagedFiles, filesTouched)\\n   196→\\t}\\n   197→\\theadTree, err := headCommit.Tree()\\n   198→\\tif err != nil {\\n   199→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get HEAD tree, falling back to filename check\\\",\\n   200→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   201→\\t\\t)\\n   202→\\t\\treturn hasOverlappingFiles(stagedFiles, filesTouched)\\n   203→\\t}\\n   204→\\n   205→\\t// Get the git index to access staged file hashes\\n   206→\\tidx, err := repo.Storer.Index()\\n   207→\\tif err != nil {\\n   208→\\t\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: failed to get index, falling back to filename check\\\",\\n   209→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   210→\\t\\t)\\n   211→\\t\\treturn hasOverlappingFiles(stagedFiles, filesTouched)\\n   212→\\t}\\n   213→\\n   214→\\t// Build a map of index entries for O(1) lookup (avoid O(n*m) nested loop)\\n   215→\\tindexEntries := make(map[string]plumbing.Hash, len(idx.Entries))\\n   216→\\tfor _, entry := range idx.Entries {\\n   217→\\t\\tindexEntries[entry.Name] = entry.Hash\\n   218→\\t}\\n   219→\\n   220→\\t// Check each staged file\\n   221→\\tfor _, stagedPath := range stagedFiles {\\n   222→\\t\\tif !touchedSet[stagedPath] {\\n   223→\\t\\t\\tcontinue // Not in filesTouched, skip\\n   224→\\t\\t}\\n   225→\\n   226→\\t\\t// Check if this is a modified file (exists in HEAD) or new file\\n   227→\\t\\t_, headErr := headTree.File(stagedPath)\\n   228→\\t\\tisModified := headErr == nil\\n   229→\\n   230→\\t\\t// Modified files always count as overlap (user edited session's work)\\n   231→\\t\\t// This includes deletions - if file exists in HEAD and is being deleted,\\n   232→\\t\\t// that's the agent's work being