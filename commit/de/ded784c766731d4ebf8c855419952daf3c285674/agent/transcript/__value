\\\", err.Error()),\\n   460→\\t\\t)\\n   461→\\t\\treturn err //nolint:wrapcheck // already present in codebase\\n   462→\\t}\\n   463→\\n   464→\\tlogging.Debug(ctx, \\\"rewind completed\\\",\\n   465→\\t\\tslog.String(\\\"checkpoint_id\\\", selectedPoint.ID),\\n   466→\\t)\\n   467→\\n   468→\\t// Handle transcript restoration\\n   469→\\tvar sessionID string\\n   470→\\tvar transcriptFile string\\n   471→\\n   472→\\tif selectedPoint.IsTaskCheckpoint {\\n   473→\\t\\tcheckpoint, err := start.GetTaskCheckpoint(*selectedPoint)\\n   474→\\t\\tif err != nil {\\n   475→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to read task checkpoint: %v\\\\n\\\", err)\\n   476→\\t\\t\\treturn nil\\n   477→\\t\\t}\\n   478→\\n   479→\\t\\tsessionID = checkpoint.SessionID\\n   480→\\n   481→\\t\\tif checkpoint.CheckpointUUID != \\\"\\\" {\\n   482→\\t\\t\\t// Use strategy-based transcript restoration for task checkpoints\\n   483→\\t\\t\\tif err := restoreTaskCheckpointTranscript(start, *selectedPoint, sessionID, checkpoint.CheckpointUUID, agent); err != nil {\\n   484→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to restore truncated session transcript: %v\\\\n\\\", err)\\n   485→\\t\\t\\t} else {\\n   486→\\t\\t\\t\\tfmt.Printf(\\\"Rewound to task checkpoint. %s\\\\n\\\", agent.FormatResumeCommand(sessionID))\\n   487→\\t\\t\\t}\\n   488→\\t\\t\\treturn nil\\n   489→\\t\\t}\\n   490→\\t} else {\\n   491→\\t\\t// Prefer SessionID from trailer over path-based extraction\\n   492→\\t\\tsessionID = selectedPoint.SessionID\\n   493→\\t\\tif sessionID == \\\"\\\" {\\n   494→\\t\\t\\tsessionID = filepath.Base(selectedPoint.MetadataDir)\\n   495→\\t\\t}\\n   496→\\t\\ttranscriptFile = filepath.Join(selectedPoint.MetadataDir, paths.TranscriptFileNameLegacy)\\n   497→\\t}\\n   498→\\n   499→\\t// Try to restore transcript using the appropriate method:\\n   500→\\t// 1. Checkpoint storage (committed checkpoints with valid checkpoint ID)\\n   501→\\t// 2. Shadow branch (uncommitted checkpoints with commit hash)\\n   502→\\t// 3. Local file (active sessions)\\n   503→\\tvar restored bool\\n   504→\\tif !selectedPoint.CheckpointID.IsEmpty() {\\n   505→\\t\\t// Try checkpoint storage first for committed checkpoints\\n   506→\\t\\tif returnedSessionID, err := restoreSessionTranscriptFromStrategy(selectedPoint.CheckpointID, sessionID, agent); err == nil {\\n   507→\\t\\t\\tsessionID = returnedSessionID\\n   508→\\t\\t\\trestored = true\\n   509→\\t\\t}\\n   510→\\t}\\n   511→\\n   512→\\tif !restored && selectedPoint.MetadataDir != \\\"\\\" && len(selectedPoint.ID) == 40 {\\n   513→\\t\\t// Try shadow branch for uncommitted checkpoints (ID is a 40-char commit hash)\\n   514→\\t\\tif returnedSessionID, err := restoreSessionTranscriptFromShadow(selectedPoint.ID, selectedPoint.MetadataDir, sessionID, agent); err == nil {\\n   515→\\t\\t\\tsessionID = returnedSessionID\\n   516→\\t\\t\\trestored = true\\n   517→\\t\\t}\\n   518→\\t}\\n   519→\\n   520→\\tif !restored {\\n   521→\\t\\t// Fall back to local file\\n   522→\\t\\tif err := restoreSessionTranscript(transcriptFile, sessionID, agent); err != nil {\\n   523→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to restore session transcript: %v\\\\n\\\", err)\\n   524→\\t\\t}\\n   525→\\t}\\n   526→\\n   527→\\tfmt.Printf(\\\"Rewound to %s. %s\\\\n\\\", selectedPoint.ID[:7], agent.FormatResumeCommand(sessionID))\\n   528→\\treturn nil\\n   529→}\\n   530→\\n   531→// handleLogsOnlyRewindNonInteractive handles logs-only rewind in non-interactive mode.\\n   532→// Defaults to restoring logs only (no checkout) for safety.\\n   533→func handleLogsOnlyRewindNonInteractive(start strategy.Strategy, point strategy.RewindPoint) error {\\n   534→\\t// Resolve agent once for use throughout\\n   535→\\tagent, err := getAgent(point.Agent)\\n   536→\\tif err != nil {\\n   537→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   538→\\t}\\n   539→\\n   540→\\t// Initialize logging context with agent from checkpoint\\n   541→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   542→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   543→\\n   544→\\tlogging.Debug(ctx, \\\"logs-only rewind started\\\",\\n   545→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   546→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   547→\\t)\\n   548→\\n   549→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   550→\\tif !ok {\\n   551→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   552→\\t}\\n   553→\\n   554→\\tsessions, err := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   555→\\tif err != nil {\\n   556→\\t\\tlogging.Error(ctx, \\\"logs-only rewind failed\\\",\\n   557→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   558→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   559→\\t\\t)\\n   560→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   561→\\t}\\n   562→\\n   563→\\tlogging.Debug(ctx, \\\"logs-only rewind completed\\\",\\n   564→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   565→\\t)\\n   566→\\n   567→\\t// Show resume commands for all sessions\\n   568→\\tprintMultiSessionResumeCommands(sessions)\\n   569→\\n   570→\\tfmt.Println(\\\"Note: Working directory unchanged. Use interactive mode for full checkout.\\\")\\n   571→\\treturn nil\\n   572→}\\n   573→\\n   574→// handleLogsOnlyResetNonInteractive handles reset in non-interactive mode.\\n   575→// This performs a git reset --hard to the target commit.\\n   576→func handleLogsOnlyResetNonInteractive(start strategy.Strategy, point strategy.RewindPoint) error {\\n   577→\\t// Resolve agent once for use throughout\\n   578→\\tagent, err := getAgent(point.Agent)\\n   579→\\tif err != nil {\\n   580→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   581→\\t}\\n   582→\\n   583→\\t// Initialize logging context with agent from checkpoint\\n   584→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   585→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   586→\\n   587→\\tlogging.Debug(ctx, \\\"logs-only reset started\\\",\\n   588→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   589→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   590→\\t)\\n   591→\\n   592→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   593→\\tif !ok {\\n   594→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   595→\\t}\\n   596→\\n   597→\\t// Get current HEAD before reset (for recovery message)\\n   598→\\tcurrentHead, headErr := getCurrentHeadHash()\\n   599→\\tif headErr != nil {\\n   600→\\t\\tcurrentHead = \\\"\\\"\\n   601→\\t}\\n   602→\\n   603→\\t// Restore logs first\\n   604→\\tsessions, err := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   605→\\tif err != nil {\\n   606→\\t\\tlogging.Error(ctx, \\\"logs-only reset failed during log restoration\\\",\\n   607→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   608→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   609→\\t\\t)\\n   610→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   611→\\t}\\n   612→\\n   613→\\t// Perform git reset --hard\\n   614→\\tif err := performGitResetHard(point.ID); err != nil {\\n   615→\\t\\tlogging.Error(ctx, \\\"logs-only reset failed during git reset\\\",\\n   616→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   617→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   618→\\t\\t)\\n   619→\\t\\treturn fmt.Errorf(\\\"failed to reset branch: %w\\\", err)\\n   620→\\t}\\n   621→\\n   622→\\tlogging.Debug(ctx, \\\"logs-only reset completed\\\",\\n   623→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   624→\\t)\\n   625→\\n   626→\\tshortID := point.ID\\n   627→\\tif len(shortID) > 7 {\\n   628→\\t\\tshortID = shortID[:7]\\n   629→\\t}\\n   630→\\n   631→\\tfmt.Printf(\\\"Reset branch to %s.\\\\n\\\", shortID)\\n   632→\\n   633→\\t// Show resume commands for all sessions\\n   634→\\tprintMultiSessionResumeCommands(sessions)\\n   635→\\n   636→\\t// Show recovery instructions\\n   637→\\tif currentHead != \\\"\\\" && currentHead != point.ID {\\n   638→\\t\\tcurrentShort := currentHead\\n   639→\\t\\tif len(currentShort) > 7 {\\n   640→\\t\\t\\tcurrentShort = currentShort[:7]\\n   641→\\t\\t}\\n   642→\\t\\tfmt.Printf(\\\"\\\\nTo undo this reset: git reset --hard %s\\\\n\\\", currentShort)\\n   643→\\t}\\n   644→\\n   645→\\treturn nil\\n   646→}\\n   647→\\n   648→func restoreSessionTranscript(transcriptFile, sessionID string, agent agentpkg.Agent) error {\\n   649→\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   650→\\tif err != nil {\\n   651→\\t\\treturn err\\n   652→\\t}\\n   653→\\n   654→\\t// Ensure parent directory exists\\n   655→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   656→\\t\\treturn fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   657→\\t}\\n   658→\\n   659→\\tfmt.Fprintf(os.Stderr, \\\"Copying transcript:\\\\n  From: %s\\\\n  To: %s\\\\n\\\", transcriptFile, sessionFile)\\n   660→\\tif err := copyFile(transcriptFile, sessionFile); err != nil {\\n   661→\\t\\treturn fmt.Errorf(\\\"failed to copy transcript: %w\\\", err)\\n   662→\\t}\\n   663→\\n   664→\\treturn nil\\n   665→}\\n   666→\\n   667→// restoreSessionTranscriptFromStrategy restores a session transcript from checkpoint storage.\\n   668→// This is used for strategies that store transcripts in git branches rather than local files.\\n   669→// Returns the session ID that was actually used (may differ from input if checkpoint provides one).\\n   670→func restoreSessionTranscriptFromStrategy(cpID id.CheckpointID, sessionID string, agent agentpkg.Agent) (string, error) {\\n   671→\\t// Get transcript content from checkpoint storage\\n   672→\\tcontent, returnedSessionID, exportData, err := checkpoint.LookupSessionLog(cpID)\\n   673→\\tif err != nil {\\n   674→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get session log: %w\\\", err)\\n   675→\\t}\\n   676→\\n   677→\\t// Use session ID returned from checkpoint if available\\n   678→\\t// Otherwise fall back to the passed-in sessionID\\n   679→\\tif returnedSessionID != \\\"\\\" {\\n   680→\\t\\tsessionID = returnedSessionID\\n   681→\\t}\\n   682→\\n   683→\\t// If export data is available (e.g., OpenCode), use WriteSession which handles\\n   684→\\t// both file writing and native storage import (SQLite for OpenCode).\\n   685→\\tif len(exportData) > 0 {\\n   686→\\t\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   687→\\t\\tif err != nil {\\n   688→\\t\\t\\treturn \\\"\\\", err\\n   689→\\t\\t}\\n   690→\\t\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   691→\\t\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   692→\\t\\t}\\n   693→\\t\\tagentSession := &agentpkg.AgentSession{\\n   694→\\t\\t\\tSessionID:  sessionID,\\n   695→\\t\\t\\tAgentName:  agent.Name(),\\n   696→\\t\\t\\tSessionRef: sessionFile,\\n   697→\\t\\t\\tNativeData: content,\\n   698→\\t\\t\\tExportData: exportData,\\n   699→\\t\\t}\\n   700→\\t\\tif err := agent.WriteSession(agentSession); err != nil {\\n   701→\\t\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write session: %w\\\", err)\\n   702→\\t\\t}\\n   703→\\t\\treturn sessionID, nil\\n   704→\\t}\\n   705→\\n   706→\\treturn writeTranscriptToAgentSession(content, sessionID, agent)\\n   707→}\\n   708→\\n   709→// restoreSessionTranscriptFromShadow restores a session transcript from a shadow branch commit.\\n   710→// This is used for uncommitted checkpoints where the transcript is stored in the shadow branch tree.\\n   711→func restoreSessionTranscriptFromShadow(commitHash, metadataDir, sessionID string, agent agentpkg.Agent) (string, error) {\\n   712→\\t// Open repository\\n   713→\\trepo, err := git.PlainOpenWithOptions(\\\".\\\", &git.PlainOpenOptions{DetectDotGit: true})\\n   714→\\tif err != nil {\\n   715→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   716→\\t}\\n   717→\\n   718→\\t// Parse commit hash\\n   719→\\thash := plumbing.NewHash(commitHash)\\n   720→\\tif hash.IsZero() {\\n   721→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"invalid commit hash: %s\\\", commitHash)\\n   722→\\t}\\n   723→\\n   724→\\t// Get transcript from shadow branch commit tree\\n   725→\\tstore := checkpoint.NewGitStore(repo)\\n   726→\\tcontent, err := store.GetTranscriptFromCommit(hash, metadataDir, agent.Type())\\n   727→\\tif err != nil {\\n   728→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get transcript from shadow branch: %w\\\", err)\\n   729→\\t}\\n   730→\\n   731→\\t// Read export data from shadow branch tree if available (e.g., OpenCode export JSON).\\n   732→\\texportData := store.GetExportDataFromCommit(hash, metadataDir)\\n   733→\\n   734→\\t// If export data is available, use WriteSession which handles both file writing\\n   735→\\t// and native storage import (SQLite for OpenCode).\\n   736→\\tif len(exportData) > 0 {\\n   737→\\t\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   738→\\t\\tif err != nil {\\n   739→\\t\\t\\treturn \\\"\\\", err\\n   740→\\t\\t}\\n   741→\\t\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   742→\\t\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   743→\\t\\t}\\n   744→\\t\\tagentSession := &agentpkg.AgentSession{\\n   745→\\t\\t\\tSessionID:  sessionID,\\n   746→\\t\\t\\tAgentName:  agent.Name(),\\n   747→\\t\\t\\tSessionRef: sessionFile,\\n   748→\\t\\t\\tNativeData: content,\\n   749→\\t\\t\\tExportData: exportData,\\n   750→\\t\\t}\\n   751→\\t\\tif err := agent.WriteSession(agentSession); err != nil {\\n   752→\\t\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write session: %w\\\", err)\\n   753→\\t\\t}\\n   754→\\t\\treturn sessionID, nil\\n   755→\\t}\\n   756→\\n   757→\\treturn writeTranscriptToAgentSession(content, sessionID, agent)\\n   758→}\\n   759→\\n   760→// writeTranscriptToAgentSession writes transcript content to the agent's session storage.\\n   761→func writeTranscriptToAgentSession(content []byte, sessionID string, agent agentpkg.Agent) (string, error) {\\n   762→\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   763→\\tif err != nil {\\n   764→\\t\\treturn \\\"\\\", err\\n   765→\\t}\\n   766→\\n   767→\\t// Ensure parent directory exists\\n   768→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   769→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   770→\\t}\\n   771→\\n   772→\\tfmt.Fprintf(os.Stderr, \\\"Writing transcript to: %s\\\\n\\\", sessionFile)\\n   773→\\tif err := os.WriteFile(sessionFile, content, 0o600); err != nil {\\n   774→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   775→\\t}\\n   776→\\n   777→\\treturn sessionID, nil\\n   778→}\\n   779→\\n   780→// restoreTaskCheckpointTranscript restores a truncated transcript for a task checkpoint.\\n   781→// Uses GetTaskCheckpointTranscript to fetch the transcript from the strategy.\\n   782→//\\n   783→// NOTE: The transcript parsing/truncation/writing pipeline (transcript.ParseFromBytes,\\n   784→// TruncateTranscriptAtUUID, writeTranscript) assumes Claude's JSONL format.\\n   785→// This is acceptable because task checkpoints are currently only created by Claude Code's\\n   786→// PostToolUse hook. If other agents gain sub-agent support, this will need a\\n   787→// format-aware refactor (agent-specific parsing, truncation, and serialization).\\n   788→func restoreTaskCheckpointTranscript(strat strategy.Strategy, point strategy.RewindPoint, sessionID, checkpointUUID string, agent agentpkg.Agent) error {\\n   789→\\t// Get transcript content from strategy\\n   790→\\tcontent, err := strat.GetTaskCheckpointTranscript(point)\\n   791→\\tif err != nil {\\n   792→\\t\\treturn fmt.Errorf(\\\"failed to get task checkpoint transcript: %w\\\", err)\\n   793→\\t}\\n   794→\\n   795→\\t// Parse the transcript\\n   796→\\tparsed, err := transcript.ParseFromBytes(content)\\n   797→\\tif err != nil {\\n   798→\\t\\treturn fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   799→\\t}\\n   800→\\n   801→\\t// Truncate at checkpoint UUID\\n   802→\\ttruncated := TruncateTranscriptAtUUID(parsed, checkpointUUID)\\n   803→\\n   804→\\tsessionFile, err := resolveTranscriptPath(sessionID, agent)\\n   805→\\tif err != nil {\\n   806→\\t\\treturn err\\n   807→\\t}\\n   808→\\n   809→\\t// Ensure parent directory exists\\n   810→\\tif err := os.MkdirAll(filepath.Dir(sessionFile), 0o750); err != nil {\\n   811→\\t\\treturn fmt.Errorf(\\\"failed to create agent session directory: %w\\\", err)\\n   812→\\t}\\n   813→\\n   814→\\tfmt.Fprintf(os.Stderr, \\\"Writing truncated transcript to: %s\\\\n\\\", sessionFile)\\n   815→\\n   816→\\tif err := writeTranscript(sessionFile, truncated); err != nil {\\n   817→\\t\\treturn fmt.Errorf(\\\"failed to write truncated transcript: %w\\\", err)\\n   818→\\t}\\n   819→\\n   820→\\treturn nil\\n   821→}\\n   822→\\n   823→// handleLogsOnlyRewindInteractive handles rewind for logs-only points with a sub-choice menu.\\n   824→func handleLogsOnlyRewindInteractive(start strategy.Strategy, point strategy.RewindPoint, shortID string) error {\\n   825→\\tvar action string\\n   826→\\n   827→\\tform := NewAccessibleForm(\\n   828→\\t\\thuh.NewGroup(\\n   829→\\t\\t\\thuh.NewSelect[string]().\\n   830→\\t\\t\\t\\tTitle(\\\"Logs-only point: \\\"+shortID).\\n   831→\\t\\t\\t\\tDescription(\\\"This commit has session logs but no checkpoint state. Choose an action:\\\").\\n   832→\\t\\t\\t\\tOptions(\\n   833→\\t\\t\\t\\t\\thuh.NewOption(\\\"Restore logs only (keep current files)\\\", \\\"logs\\\"),\\n   834→\\t\\t\\t\\t\\thuh.NewOption(\\\"Checkout commit (detached HEAD, for viewing)\\\", \\\"checkout\\\"),\\n   835→\\t\\t\\t\\t\\thuh.NewOption(\\\"Reset branch to this commit (destructive!)\\\", \\\"reset\\\"),\\n   836→\\t\\t\\t\\t\\thuh.NewOption(\\\"Cancel\\\", \\\"cancel\\\"),\\n   837→\\t\\t\\t\\t).\\n   838→\\t\\t\\t\\tValue(&action),\\n   839→\\t\\t),\\n   840→\\t)\\n   841→\\n   842→\\tif err := form.Run(); err != nil {\\n   843→\\t\\treturn fmt.Errorf(\\\"action selection cancelled: %w\\\", err)\\n   844→\\t}\\n   845→\\n   846→\\tswitch action {\\n   847→\\tcase \\\"logs\\\":\\n   848→\\t\\treturn handleLogsOnlyRestore(start, point)\\n   849→\\tcase \\\"checkout\\\":\\n   850→\\t\\treturn handleLogsOnlyCheckout(start, point, shortID)\\n   851→\\tcase \\\"reset\\\":\\n   852→\\t\\treturn handleLogsOnlyReset(start, point, shortID)\\n   853→\\tcase \\\"cancel\\\":\\n   854→\\t\\tfmt.Println(\\\"Rewind cancelled.\\\")\\n   855→\\t\\treturn nil\\n   856→\\t}\\n   857→\\n   858→\\treturn nil\\n   859→}\\n   860→\\n   861→// handleLogsOnlyRestore restores only the session logs without changing files.\\n   862→func handleLogsOnlyRestore(start strategy.Strategy, point strategy.RewindPoint) error {\\n   863→\\t// Resolve agent once for use throughout\\n   864→\\tagent, err := getAgent(point.Agent)\\n   865→\\tif err != nil {\\n   866→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   867→\\t}\\n   868→\\n   869→\\t// Initialize logging context with agent from checkpoint\\n   870→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   871→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   872→\\n   873→\\tlogging.Debug(ctx, \\\"logs-only restore started\\\",\\n   874→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   875→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   876→\\t)\\n   877→\\n   878→\\t// Check if strategy supports logs-only restoration\\n   879→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   880→\\tif !ok {\\n   881→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   882→\\t}\\n   883→\\n   884→\\t// Restore logs\\n   885→\\tsessions, err := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   886→\\tif err != nil {\\n   887→\\t\\tlogging.Error(ctx, \\\"logs-only restore failed\\\",\\n   888→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   889→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   890→\\t\\t)\\n   891→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   892→\\t}\\n   893→\\n   894→\\tlogging.Debug(ctx, \\\"logs-only restore completed\\\",\\n   895→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   896→\\t)\\n   897→\\n   898→\\t// Show resume commands for all sessions\\n   899→\\tfmt.Println(\\\"Restored session logs.\\\")\\n   900→\\tprintMultiSessionResumeCommands(sessions)\\n   901→\\treturn nil\\n   902→}\\n   903→\\n   904→// handleLogsOnlyCheckout restores logs and checks out the commit (detached HEAD).\\n   905→func handleLogsOnlyCheckout(start strategy.Strategy, point strategy.RewindPoint, shortID string) error {\\n   906→\\t// Resolve agent once for use throughout\\n   907→\\tagent, err := getAgent(point.Agent)\\n   908→\\tif err != nil {\\n   909→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   910→\\t}\\n   911→\\n   912→\\t// Initialize logging context with agent from checkpoint\\n   913→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   914→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   915→\\n   916→\\tlogging.Debug(ctx, \\\"logs-only checkout started\\\",\\n   917→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   918→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   919→\\t)\\n   920→\\n   921→\\t// First, restore the logs\\n   922→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   923→\\tif !ok {\\n   924→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   925→\\t}\\n   926→\\n   927→\\tsessions, err := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   928→\\tif err != nil {\\n   929→\\t\\tlogging.Error(ctx, \\\"logs-only checkout failed during log restoration\\\",\\n   930→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   931→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   932→\\t\\t)\\n   933→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", err)\\n   934→\\t}\\n   935→\\n   936→\\t// Show warning about detached HEAD\\n   937→\\tvar confirm bool\\n   938→\\tconfirmForm := NewAccessibleForm(\\n   939→\\t\\thuh.NewGroup(\\n   940→\\t\\t\\thuh.NewConfirm().\\n   941→\\t\\t\\t\\tTitle(\\\"Create detached HEAD?\\\").\\n   942→\\t\\t\\t\\tDescription(\\\"This will checkout the commit directly. You'll be in 'detached HEAD' state.\\\\nAny uncommitted changes will be lost!\\\").\\n   943→\\t\\t\\t\\tValue(&confirm),\\n   944→\\t\\t),\\n   945→\\t)\\n   946→\\n   947→\\tif err := confirmForm.Run(); err != nil {\\n   948→\\t\\treturn fmt.Errorf(\\\"confirmation cancelled: %w\\\", err)\\n   949→\\t}\\n   950→\\n   951→\\tif !confirm {\\n   952→\\t\\tfmt.Println(\\\"Checkout cancelled. Session logs were still restored.\\\")\\n   953→\\t\\tprintMultiSessionResumeCommands(sessions)\\n   954→\\t\\treturn nil\\n   955→\\t}\\n   956→\\n   957→\\t// Perform git checkout\\n   958→\\tif err := CheckoutBranch(point.ID); err != nil {\\n   959→\\t\\tlogging.Error(ctx, \\\"logs-only checkout failed during git checkout\\\",\\n   960→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   961→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   962→\\t\\t)\\n   963→\\t\\treturn fmt.Errorf(\\\"failed to checkout commit: %w\\\", err)\\n   964→\\t}\\n   965→\\n   966→\\tlogging.Debug(ctx, \\\"logs-only checkout completed\\\",\\n   967→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   968→\\t)\\n   969→\\n   970→\\tfmt.Printf(\\\"Checked out %s (detached HEAD).\\\\n\\\", shortID)\\n   971→\\tprintMultiSessionResumeCommands(sessions)\\n   972→\\treturn nil\\n   973→}\\n   974→\\n   975→// handleLogsOnlyReset restores logs and resets the branch to the commit (destructive).\\n   976→func handleLogsOnlyReset(start strategy.Strategy, point strategy.RewindPoint, shortID string) error {\\n   977→\\t// Resolve agent once for use throughout\\n   978→\\tagent, agentErr := getAgent(point.Agent)\\n   979→\\tif agentErr != nil {\\n   980→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", agentErr)\\n   981→\\t}\\n   982→\\n   983→\\t// Initialize logging context with agent from checkpoint\\n   984→\\tctx := logging.WithComponent(context.Background(), \\\"rewind\\\")\\n   985→\\tctx = logging.WithAgent(ctx, agent.Name())\\n   986→\\n   987→\\tlogging.Debug(ctx, \\\"logs-only reset (interactive) started\\\",\\n   988→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n   989→\\t\\tslog.String(\\\"session_id\\\", point.SessionID),\\n   990→\\t)\\n   991→\\n   992→\\t// First, restore the logs\\n   993→\\trestorer, ok := start.(strategy.LogsOnlyRestorer)\\n   994→\\tif !ok {\\n   995→\\t\\treturn errors.New(\\\"strategy does not support logs-only restoration\\\")\\n   996→\\t}\\n   997→\\n   998→\\tsessions, restoreErr := restorer.RestoreLogsOnly(point, true) // force=true for explicit rewind\\n   999→\\tif restoreErr != nil {\\n  1000→\\t\\tlogging.Error(ctx, \\\"logs-only reset failed during log restoration\\\",\\n  1001→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n  1002→\\t\\t\\tslog.String(\\\"error\\\", restoreErr.Error()),\\n  1003→\\t\\t)\\n  1004→\\t\\treturn fmt.Errorf(\\\"failed to restore logs: %w\\\", restoreErr)\\n  1005→\\t}\\n  1006→\\n  1007→\\t// Get current HEAD before reset (for recovery message)\\n  1008→\\tcurrentHead, err := getCurrentHeadHash()\\n  1009→\\tif err != nil {\\n  1010→\\t\\t// Non-fatal - just won't show recovery message\\n  1011→\\t\\tcurrentHead = \\\"\\\"\\n  1012→\\t}\\n  1013→\\n  1014→\\t// Get detailed uncommitted changes warning from strategy\\n  1015→\\tvar uncommittedWarning string\\n  1016→\\tif _, warn, err := start.CanRewind(); err == nil {\\n  1017→\\t\\tuncommittedWarning = warn\\n  1018→\\t}\\n  1019→\\n  1020→\\t// Check for safety issues\\n  1021→\\twarnings, err := checkResetSafety(point.ID, uncommittedWarning)\\n  1022→\\tif err != nil {\\n  1023→\\t\\treturn fmt.Errorf(\\\"failed to check reset safety: %w\\\", err)\\n  1024→\\t}\\n  1025→\\n  1026→\\t// Build confirmation message based on warnings\\n  1027→\\tvar confirmTitle, confirmDesc string\\n  1028→\\tif len(warnings) > 0 {\\n  1029→\\t\\tconfirmTitle = \\\"⚠️  Reset branch with warnings?\\\"\\n  1030→\\t\\tconfirmDesc = \\\"WARNING - the following issues were detected:\\\\n\\\" +\\n  1031→\\t\\t\\tstrings.Join(warnings, \\\"\\\\n\\\") +\\n  1032→\\t\\t\\t\\\"\\\\n\\\\nThis will move your branch to \\\" + shortID + \\\" and DISCARD commits after it!\\\"\\n  1033→\\t} else {\\n  1034→\\t\\tconfirmTitle = \\\"Reset branch to \\\" + shortID + \\\"?\\\"\\n  1035→\\t\\tconfirmDesc = \\\"This will move your branch pointer to this commit.\\\\nCommits after this point will be orphaned (but recoverable via reflog).\\\"\\n  1036→\\t}\\n  1037→\\n  1038→\\tvar confirm bool\\n  1039→\\tconfirmForm := NewAccessibleForm(\\n  1040→\\t\\thuh.NewGroup(\\n  1041→\\t\\t\\thuh.NewConfirm().\\n  1042→\\t\\t\\t\\tTitle(confirmTitle).\\n  1043→\\t\\t\\t\\tDescription(confirmDesc).\\n  1044→\\t\\t\\t\\tValue(&confirm),\\n  1045→\\t\\t),\\n  1046→\\t)\\n  1047→\\n  1048→\\tif err := confirmForm.Run(); err != nil {\\n  1049→\\t\\treturn fmt.Errorf(\\\"confirmation cancelled: %w\\\", err)\\n  1050→\\t}\\n  1051→\\n  1052→\\tif !confirm {\\n  1053→\\t\\tfmt.Println(\\\"Reset cancelled. Session logs were still restored.\\\")\\n  1054→\\t\\tprintMultiSessionResumeCommands(sessions)\\n  1055→\\t\\treturn nil\\n  1056→\\t}\\n  1057→\\n  1058→\\t// Perform git reset --hard\\n  1059→\\tif err := performGitResetHard(point.ID); err != nil {\\n  1060→\\t\\tlogging.Error(ctx, \\\"logs-only reset failed during git reset\\\",\\n  1061→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n  1062→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n  1063→\\t\\t)\\n  1064→\\t\\treturn fmt.Errorf(\\\"failed to reset branch: %w\\\", err)\\n  1065→\\t}\\n  1066→\\n  1067→\\tlogging.Debug(ctx, \\\"logs-only reset (interactive) completed\\\",\\n  1068→\\t\\tslog.String(\\\"checkpoint_id\\\", point.ID),\\n  1069→\\t)\\n  1070→\\n  1071→\\tfmt.Printf(\\\"Reset branch to %s.\\\\n\\\", shortID)\\n  1072→\\tprintMultiSessionResumeCommands(sessions)\\n  1073→\\n  1074→\\t// Show recovery instructions\\n  1075→\\tif currentHead != \\\"\\\" && currentHead != point.ID {\\n  1076→\\t\\tcurrentShort := currentHead\\n  1077→\\t\\tif len(currentShort) > 7 {\\n  1078→\\t\\t\\tcurrentShort = currentShort[:7]\\n  1079→\\t\\t}\\n  1080→\\t\\tfmt.Printf(\\\"\\\\nTo undo this reset: git reset --hard %s\\\\n\\\", currentShort)\\n  1081→\\t}\\n  1082→\\n  1083→\\treturn nil\\n  1084→}\\n  1085→\\n  1086→// getCurrentHeadHash returns the current HEAD commit hash.\\n  1087→func getCurrentHeadHash() (string, error) {\\n  1088→\\trepo, err := openRepository()\\n  1089→\\tif err != nil {\\n  1090→\\t\\treturn \\\"\\\", err\\n  1091→\\t}\\n  1092→\\n  1093→\\thead, err := repo.Head()\\n  1094→\\tif err != nil {\\n  1095→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n  1096→\\t}\\n  1097→\\n  1098→\\treturn head.Hash().String(), nil\\n  1099→}\\n  1100→\\n  1101→// checkResetSafety checks for potential issues before a git reset --hard.\\n  1102→// Returns a list of warning messages (empty if safe to proceed without warnings).\\n  1103→// If uncommittedChangesWarning is provided, it will be used instead of a generic warning.\\n  1104→func checkResetSafety(targetCommitHash string, uncommittedChangesWarning string) ([]string, error) {\\n  1105→\\tvar warnings []string\\n  1106→\\n  1107→\\trepo, err := openRepository()\\n  1108→\\tif err != nil {\\n  1109→\\t\\treturn nil, err\\n  1110→\\t}\\n  1111→\\n  1112→\\t// Check for uncommitted changes\\n  1113→\\tif uncommittedChangesWarning != \\\"\\\" {\\n  1114→\\t\\t// Use the detailed warning from strategy's CanRewind()\\n  1115→\\t\\twarnings = append(warnings, uncommittedChangesWarning)\\n  1116→\\t} else {\\n  1117→\\t\\t// Fall back to generic check\\n  1118→\\t\\tworktree, err := repo.Worktree()\\n  1119→\\t\\tif err != nil {\\n  1120→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n  1121→\\t\\t}\\n  1122→\\n  1123→\\t\\tstatus, err := worktree.Status()\\n  1124→\\t\\tif err != nil {\\n  1125→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n  1126→\\t\\t}\\n  1127→\\n  1128→\\t\\tif !status.IsClean() {\\n  1129→\\t\\t\\twarnings = append(warnings, \\\"• You have uncommitted changes that will be LOST\\\")\\n  1130→\\t\\t}\\n  1131→\\t}\\n  1132→\\n  1133→\\t// Check if current HEAD is ahead of target (we'd be discarding commits)\\n  1134→\\thead, err := repo.Head()\\n  1135→\\tif err != nil {\\n  1136→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n  1137→\\t}\\n  1138→\\n  1139→\\ttargetHash := plumbing.NewHash(targetCommitHash)\\n  1140→\\n  1141→\\t// Count commits between target and HEAD\\n  1142→\\tcommitsAhead, err := countCommitsBetween(repo, targetHash, head.Hash())\\n  1143→\\tif err != nil {\\n  1144→\\t\\t// Non-fatal - just can't show commit count\\n  1145→\\t\\tcommitsAhead = -1\\n  1146→\\t}\\n  1147→\\n  1148→\\tif commitsAhead > 0 {\\n  1149→\\t\\twarnings = append(warnings, fmt.Sprintf(\\\"• %d commit(s) after this point will be orphaned\\\", commitsAhead))\\n  1150→\\t}\\n  1151→\\n  1152→\\treturn warnings, nil\\n  1153→}\\n  1154→\\n  1155→// countCommitsBetween counts commits between ancestor and descendant.\\n  1156→// Returns 0 if ancestor == descendant, -1 on error.\\n  1157→func countCommitsBetween(repo *git.Repository, ancestor, descendant plumbing.Hash) (int, error) {\\n  1158→\\tif ancestor == descendant {\\n  1159→\\t\\treturn 0, nil\\n  1160→\\t}\\n  1161→\\n  1162→\\t// Walk from descendant back to ancestor\\n  1163→\\tcount := 0\\n  1164→\\tcurrent := descendant\\n  1165→\\n  1166→\\tfor count < 1000 { // Safety limit\\n  1167→\\t\\tif current == ancestor {\\n  1168→\\t\\t\\treturn count, nil\\n  1169→\\t\\t}\\n  1170→\\n  1171→\\t\\tcommit, err := repo.CommitObject(current)\\n  1172→\\t\\tif err != nil {\\n  1173→\\t\\t\\treturn -1, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n  1174→\\t\\t}\\n  1175→\\n  1176→\\t\\tif commit.NumParents() == 0 {\\n  1177→\\t\\t\\t// Reached root without finding ancestor - ancestor not in history\\n  1178→\\t\\t\\treturn -1, nil\\n  1179→\\t\\t}\\n  1180→\\n  1181→\\t\\tcount++\\n  1182→\\t\\tcurrent = commit.ParentHashes[0] // Follow first parent\\n  1183→\\t}\\n  1184→\\n  1185→\\treturn -1, nil\\n  1186→}\\n  1187→\\n  1188→// performGitResetHard performs a git reset --hard to the specified commit.\\n  1189→// Uses the git CLI instead of go-git because go-git's HardReset incorrectly\\n  1190→// deletes untracked directories (like .entire/) even when they're in .gitignore.\\n  1191→func performGitResetHard(commitHash string) error {\\n  1192→\\tctx := context.Background()\\n  1193→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"reset\\\", \\\"--hard\\\", commitHash)\\n  1194→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n  1195→\\t\\treturn fmt.Errorf(\\\"reset failed: %s: %w\\\", strings.TrimSpace(string(output)), err)\\n  1196→\\t}\\n  1197→\\treturn nil\\n  1198→}\\n  1199→\\n  1200→// sanitizeForTerminal removes or replaces characters that cause rendering issues\\n  1201→// in terminal UI components. This includes emojis with skin-tone modifiers and\\n  1202→// other multi-codepoint characters that confuse width calculations.\\n  1203→func sanitizeForTerminal(s string) string {\\n  1204→\\tvar result strings.Builder\\n  1205→\\tresult.Grow(len(s))\\n  1206→\\n  1207→\\tfor _, r := range s {\\n  1208→\\t\\t// Skip emoji skin tone modifiers (U+1F3FB to U+1F3FF)\\n  1209→\\t\\tif r >= 0x1F3FB && r <= 0x1F3FF {\\n  1210→\\t\\t\\tcontinue\\n  1211→\\t\\t}\\n  1212→\\t\\t// Skip zero-width joiners used in emoji sequences\\n  1213→\\t\\tif r == 0x200D {\\n  1214→\\t\\t\\tcontinue\\n  1215→\\t\\t}\\n  1216→\\t\\t// Skip variation selectors (U+FE00 to U+FE0F)\\n  1217→\\t\\tif r >= 0xFE00 && r <= 0xFE0F {\\n  1218→\\t\\t\\tcontinue\\n  1219→\\t\\t}\\n  1220→\\t\\t// Keep printable characters and common whitespace\\n  1221→\\t\\tif unicode.IsPrint(r) || r == '\\\\t' || r == '\\\\n' {\\n  1222→\\t\\t\\tresult.WriteRune(r)\\n  1223→\\t\\t}\\n  1224→\\t}\\n  1225→\\n  1226→\\treturn result.String()\\n  1227→}\\n  1228→\\n  1229→// printMultiSessionResumeCommands prints resume commands for restored sessions.\\n  1230→// Each session may have a different agent, so per-session agent resolution is used.\\n  1231→func printMultiSessionResumeCommands(sessions []strategy.RestoredSession) {\\n  1232→\\tif len(sessions) == 0 {\\n  1233→\\t\\treturn\\n  1234→\\t}\\n  1235→\\n  1236→\\tif len(sessions) > 1 {\\n  1237→\\t\\tfmt.Printf(\\\"\\\\nRestored %d sessions. Resume with:\\\\n\\\", len(sessions))\\n  1238→\\t}\\n  1239→\\n  1240→\\tfor i, sess := range sessions {\\n  1241→\\t\\tag, err := strategy.ResolveAgentForRewind(sess.Agent)\\n  1242→\\t\\tif err != nil {\\n  1243→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: could not resolve agent %q for session %s, skipping\\\\n\\\", sess.Agent, sess.SessionID)\\n  1244→\\t\\t\\tcontinue\\n  1245→\\t\\t}\\n  1246→\\n  1247→\\t\\tcmd := ag.FormatResumeCommand(sess.SessionID)\\n  1248→\\n  1249→\\t\\tif len(sessions) > 1 {\\n  1250→\\t\\t\\t// Add \\\"(most recent)\\\" label to the last session\\n  1251→\\t\\t\\tif i == len(sessions)-1 {\\n  1252→\\t\\t\\t\\tif sess.Prompt != \\\"\\\" {\\n  1253→\\