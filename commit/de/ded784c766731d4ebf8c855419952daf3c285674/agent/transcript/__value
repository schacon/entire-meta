  474→+// the old session is NOT condensed into the new session's commit.\\n   475→+//\\n   476→+// This is a regression test for the bug where sessions with carry-forward files\\n   477→+// would be re-condensed into every subsequent commit indefinitely.\\n   478→+//\\n   479→+// This integration test complements the unit tests in phase_postcommit_test.go by\\n   480→+// testing the full hook invocation path with multiple sessions interacting.\\n   481→+//\\n   482→+// Scenario:\\n   483→+// 1. Session 1 creates file1.txt and file2.txt\\n   484→+// 2. User commits only file1.txt (partial commit)\\n   485→+// 3. Session 1 gets carry-forward: FilesTouched = [\\\"file2.txt\\\"]\\n   486→+// 4. Session 1 ends\\n   487→+// 5. Make some unrelated commits (simulating time passing)\\n   488→+// 6. New session 2 creates and commits file6.txt\\n   489→+// 7. Verify: Session 1 was NOT condensed into session 2's commit\\n   490→+// 8. Finally commit file2.txt\\n   491→+// 9. Verify: Session 1 IS condensed (carry-forward consumed)\\n   492→+func TestCarryForward_NewSessionCommitDoesNotCondenseOldSession(t *testing.T) {\\n   493→+\\tt.Parallel()\\n   494→+\\tenv := NewTestEnv(t)\\n   495→+\\tdefer env.Cleanup()\\n   496→+\\n   497→+\\t// ========================================\\n   498→+\\t// Setup\\n   499→+\\t// ========================================\\n   500→+\\tenv.InitRepo()\\n   501→+\\tenv.WriteFile(\\\"README.md\\\", \\\"# Test Repository\\\")\\n   502→+\\tenv.GitAdd(\\\"README.md\\\")\\n   503→+\\tenv.GitCommit(\\\"Initial commit\\\")\\n   504→+\\tenv.GitCheckoutNewBranch(\\\"feature/multi-session-carry-forward\\\")\\n   505→+\\tenv.InitEntire(strategy.StrategyNameManualCommit)\\n   506→+\\n   507→+\\t// ========================================\\n   508→+\\t// Phase 1: Session 1 creates files, partial commit, ends with carry-forward\\n   509→+\\t// ========================================\\n   510→+\\tt.Log(\\\"Phase 1: Session 1 creates file1.txt and file2.txt\\\")\