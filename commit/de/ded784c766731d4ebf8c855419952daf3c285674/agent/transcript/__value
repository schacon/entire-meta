tartWithOutput(sessionID)\\n   456→}\\n   457→\\n   458→// GetSessionState reads and returns the session state for the given session ID.\\n   459→func (env *TestEnv) GetSessionState(sessionID string) (*strategy.SessionState, error) {\\n   460→\\tenv.T.Helper()\\n   461→\\n   462→\\tstateFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\", sessionID+\\\".json\\\")\\n   463→\\n   464→\\tdata, err := os.ReadFile(stateFile)\\n   465→\\tif os.IsNotExist(err) {\\n   466→\\t\\treturn nil, nil\\n   467→\\t}\\n   468→\\tif err != nil {\\n   469→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   470→\\t}\\n   471→\\n   472→\\tvar state strategy.SessionState\\n   473→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   474→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse session state: %w\\\", err)\\n   475→\\t}\\n   476→\\treturn &state, nil\\n   477→}\\n   478→\\n   479→// WriteSessionState writes the session state for the given session ID.\\n   480→// This is useful for tests that need to manipulate session state directly.\\n   481→func (env *TestEnv) WriteSessionState(sessionID string, state *strategy.SessionState) error {\\n   482→\\tenv.T.Helper()\\n   483→\\n   484→\\tstateDir := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\")\\n   485→\\tif err := os.MkdirAll(stateDir, 0o755); err != nil {\\n   486→\\t\\treturn fmt.Errorf(\\\"failed to create session state dir: %w\\\", err)\\n   487→\\t}\\n   488→\\n   489→\\tstateFile := filepath.Join(stateDir, sessionID+\\\".json\\\")\\n   490→\\n   491→\\tdata, err := json.MarshalIndent(state, \\\"\\\", \\\"  \\\")\\n   492→\\tif err != nil {\\n   493→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   494→\\t}\\n   495→\\n   496→\\tif err := os.WriteFile(stateFile, data, 0o644); err != nil {\\n   497→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   498→\\t}\\n   499→\\treturn nil\\n   500→}\\n   501→\\