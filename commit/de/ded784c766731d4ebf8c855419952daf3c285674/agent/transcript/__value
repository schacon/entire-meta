n  1597→\\n  1598→// validateContentHash validates that content_hash.txt matches the SHA256 of the transcript.\\n  1599→func (env *TestEnv) validateContentHash(checkpointID string) {\\n  1600→\\tenv.T.Helper()\\n  1601→\\n  1602→\\t// Read transcript\\n  1603→\\ttranscriptPath := SessionFilePath(checkpointID, paths.TranscriptFileName)\\n  1604→\\ttranscript, found := env.ReadFileFromBranch(paths.MetadataBranchName, transcriptPath)\\n  1605→\\tif !found {\\n  1606→\\t\\tenv.T.Fatalf(\\\"Transcript not found at %s\\\", transcriptPath)\\n  1607→\\t}\\n  1608→\\n  1609→\\t// Read content hash\\n  1610→\\thashPath := SessionFilePath(checkpointID, \\\"content_hash.txt\\\")\\n  1611→\\tstoredHash, found := env.ReadFileFromBranch(paths.MetadataBranchName, hashPath)\\n  1612→\\tif !found {\\n  1613→\\t\\tenv.T.Fatalf(\\\"Content hash not found at %s\\\", hashPath)\\n  1614→\\t}\\n  1615→\\tstoredHash = strings.TrimSpace(storedHash)\\n  1616→\\n  1617→\\t// Calculate expected hash with sha256: prefix (matches format in committed.go)\\n  1618→\\thash := sha256.Sum256([]byte(transcript))\\n  1619→\\texpectedHash := \\\"sha256:\\\" + hex.EncodeToString(hash[:])\\n  1620→\\n  1621→\\tif storedHash != expectedHash {\\n  1622→\\t\\tenv.T.Errorf(\\\"Content hash mismatch:\\\\n  stored:   %s\\\\n  expected: %s\\\", storedHash, expectedHash)\\n  1623→\\t}\\n  1624→}\\n  1625→\\n  1626→// validatePromptContent validates that prompt.txt contains the expected prompts.\\n  1627→func (env *TestEnv) validatePromptContent(checkpointID string, expectedPrompts []string) {\\n  1628→\\tenv.T.Helper()\\n  1629→\\n  1630→\\tpromptPath := SessionFilePath(checkpointID, paths.PromptFileName)\\n  1631→\\tcontent, found := env.ReadFileFromBranch(paths.MetadataBranchName, promptPath)\\n  1632→\\tif !found {\\n  1633→\\t\\tenv.T.Fatalf(\\\"Prompt file not found at %s\\\", promptPath)\\n  1634→\\t}\\n  1635→\\n  1636→\\tfor _, expected := range expectedPrompts {\\n  1637→\\t\\tif !strings.Contains(content