nch = true\\n    76→\\t\\t\\tbreak\\n    77→\\t\\t}\\n    78→\\t}\\n    79→\\tif hasShadowBranch {\\n    80→\\t\\tt.Error(\\\"Shadow branch should not exist before Stop is called\\\")\\n    81→\\t}\\n    82→\\n    83→\\t// Get HEAD before commit\\n    84→\\theadBefore := env.GetHeadHash()\\n    85→\\n    86→\\t// Commit with shadow hooks - should add trailer because transcript shows file modifications\\n    87→\\tenv.GitCommitWithShadowHooks(\\\"Add file from Claude (mid-session)\\\", \\\"claude_file.txt\\\")\\n    88→\\n    89→\\t// Get the commit\\n    90→\\tcommitHash := env.GetHeadHash()\\n    91→\\tif commitHash == headBefore {\\n    92→\\t\\tt.Fatal(\\\"Commit was not created\\\")\\n    93→\\t}\\n    94→\\n    95→\\t// CRITICAL: Verify commit has a checkpoint trailer\\n    96→\\t// This is the fix for ENT-112 scenario 2: detect work from live transcript\\n    97→\\tcheckpointID := env.GetCheckpointIDFromCommitMessage(commitHash)\\n    98→\\tif checkpointID == \\\"\\\" {\\n    99→\\t\\tt.Error(\\\"Mid-session commit should have Entire-Checkpoint trailer when transcript shows file modifications\\\")\\n   100→\\t} else {\\n   101→\\t\\tt.Logf(\\\"Mid-session commit has checkpoint ID: %s\\\", checkpointID)\\n   102→\\t}\\n   103→}\\n   104→\\n   105→// TestShadowStrategy_MidSessionCommit_NoTrailerWithoutTranscriptPath tests that\\n   106→// when TranscriptPath is not set in session state, commits don't get erroneous\\n   107→// checkpoint trailers (graceful fallback).\\n   108→func TestShadowStrategy_MidSessionCommit_NoTrailerWithoutTranscriptPath(t *testing.T) {\\n   109→\\tt.Parallel()\\n   110→\\n   111→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   112→\\n   113→\\tsession := env.NewSession()\\n   114→\\n   115→\\t// Simulate user prompt WITHOUT transcript path (legacy behavior)\\n   116→\\tif err := env.SimulateUserPromptSubmit(session.ID); err != nil {\\n   117→\\t\\tt.Fatalf(\\\"SimulateUserPromptSubmit failed: %v\\\", err)\\n   118→\\t}\\n   119→\\n   120→\\t// Create a file manually (not through Claude)\\n   121→\\tenv.WriteFile(\\\"manual_file.txt\\\", \\\"manual content\\\")\\n   122→\\n   123→\\t// Don't create transcript - simulating a case where transcript path isn't available\\n   124→\\n   125→\\t// Commit with shadow hooks\\n   126→\\tenv.GitCommitWithShadowHooks(\\\"Manual commit without transcript\\\", \\\"manual_file.txt\\\")\\n   127→\\n   128→\\t// Commit should NOT have checkpoint trailer (no session activity detected)\\n   129→\\tcommitHash := env.GetHeadHash()\\n   130→\\tcheckpointID := env.GetCheckpointIDFromCommitMessage(commitHash)\\n   131→\\tif checkpointID != \\\"\\\" {\\n   132→\\t\\tt.Errorf(\\\"Commit without session activity should not have checkpoint trailer, got: %s\\\", checkpointID)\\n   133→\\t}\\n   134→}\\n   135→\\n   136→// TestShadowStrategy_MidSessionCommit_NoTrailerForUnrelatedFile tests that\\n   137→// when Claude has modified files but the committed file is unrelated,\\n   138→// no checkpoint trailer is added.\\n   139→func TestShadowStrategy_MidSessionCommit_NoTrailerForUnrelatedFile(t *testing.T) {\\n   140→\\tt.Parallel()\\n   141→\\n   142→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   143→\\n   144→\\tsession := env.NewSession()\\n   145→\\n   146→\\t// Simulate user prompt with transcript path\\n   147→\\tinput := map[string]string{\\n   148→\\t\\t\\\"session_id\\\":      session.ID,\\n   149→\\t\\t\\\"transcript_path\\\": session.TranscriptPath,\\n   150→\\t}\\n   151→\\tinputJSON, _ := json.Marshal(input)\\n   152→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"claude-code\\\", \\\"user-prompt-submit\\\")\\n   153→\\tcmd.Dir = env.RepoDir\\n   154→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   155→\\tcmd.Env = append(os.Environ(),\\n   156→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+env.ClaudeProjectDir,\\n   157→\\t)\\n   158→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   159→\\t\\tt.Fatalf(\\\"user-prompt-submit failed: %v\\\\nOutput: %s\\\", err, output)\\n   160→\\t}\\n   161→\\n   162→\\t// Create transcript showing Claude modified a DIFFERENT file\\n   163→\\tsession.CreateTranscript(\\\"Create a file\\\", []FileChange{\\n   164→\\t\\t{Path: \\\"claude_file.txt\\\", Content: \\\"content from Claude\\\"},\\n   165→\\t})\\n   166→\\n   167→\\t// Create and commit an UNRELATED file (not in transcript)\\n   168→\\tenv.WriteFile(\\\"unrelated_file.txt\\\", \\\"unrelated content\\\")\\n   169→\\n   170→\\t// Commit with shadow hooks - should NOT add trailer because files don't overlap\\n   171→\\tenv.GitCommitWithShadowHooks(\\\"Unrelated file commit\\\", \\\"unrelated_file.txt\\\")\\n   172→\\n   173→\\tcommitHash := env.GetHeadHash()\\n   174→\\tcheckpointID := env.GetCheckpointIDFromCommitMessage(commitHash)\\n   175→\\n   176→\\t// CRITICAL: No checkpoint trailer should be added for unrelated files\\n   177→\\t// The overlap check in sessionHasNewContentFromLiveTranscript ensures this\\n   178→\\tif checkpointID != \\\"\\\" {\\n   179→\\t\\tt.Errorf(\\\"Unrelated file commit should NOT have checkpoint trailer, but got: %s\\\", checkpointID)\\n   180→\\t} else {\\n   181→\\t\\tt.Log(\\\"Correctly omitted checkpoint trailer for unrelated file commit\\\")\\n   182→\\t}\\n   183→}\\n   184→\\n   185→// TestShadowStrategy_AgentCommit_AlwaysGetsTrailer tests that when an agent commits\\n   186→// (ACTIVE session + no TTY), the trailer is always added regardless of content\\n   187→// detection. This is the fast path that bypasses transcript analysis.\\n   188→func TestShadowStrategy_AgentCommit_AlwaysGetsTrailer(t *testing.T) {\\n   189→\\tt.Parallel()\\n   190→\\n   191→\\tenv := NewFeatureBranchEnv(t, strategy.StrategyNameManualCommit)\\n   192→\\n   193→\\tsession := env.NewSession()\\n   194→\\n   195→\\t// Start session (sets phase to ACTIVE)\\n   196→\\tif err := env.SimulateUserPromptSubmit(session.ID); err != nil {\\n   197→\\t\\tt.Fatalf(\\\"