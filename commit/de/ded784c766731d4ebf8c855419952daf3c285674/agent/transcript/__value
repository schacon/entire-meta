  24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    25→\\n    26→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    27→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    28→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    29→)\\n    30→\\n    31→// listCheckpoints returns all checkpoints from the metadata branch.\\n    32→// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\n    33→func (s *ManualCommitStrategy) listCheckpoints() ([]CheckpointInfo, error) {\\n    34→\\tstore, err := s.getCheckpointStore()\\n    35→\\tif err != nil {\\n    36→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    37→\\t}\\n    38→\\n    39→\\tcommitted, err := store.ListCommitted(context.Background())\\n    40→\\tif err != nil {\\n    41→\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n    42→\\t}\\n    43→\\n    44→\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n    45→\\tresult := make([]CheckpointInfo, 0, len(committed))\\n    46→\\tfor _, c := range committed {\\n    47→\\t\\tresult = append(result, CheckpointInfo{\\n    48→\\t\\t\\tCheckpointID:     c.CheckpointID,\\n    49→\\t\\t\\tSessionID:        c.SessionID,\\n    50→\\t\\t\\tCreatedAt:        c.CreatedAt,\\n    51→\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n    52→\\t\\t\\tFilesTouched:     c.FilesTouched,\\n    53→\\t\\t\\tAgent:            c.Agent,\\n    54→\\t\\t\\tIsTask:           c.IsTask,\\n    55→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    56→\\t\\t\\tSessionCount:     c.SessionCount,\\n    57→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    58→\\t\\t})\\n    59→\\t}\\n    60→\\n    61→\\treturn result, nil\\n    62→}\\n    63→\\n    64→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    65→func (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n    66→\\tall, err := s.listCheckpoints()\\n    67→\\tif err != nil {\\n    68→\\t\\treturn nil, err\\n    69→\\t}\\n    70→\\n    71→\\tvar result []CheckpointInfo\\n    72→\\tfor _, cp := range all {\\n    73→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    74→\\t\\t\\tresult = append(result, cp)\\n    75→\\t\\t}\\n    76→\\t}\\n    77→\\n    78→\\tif len(result) == 0 {\\n    79→\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n    80→\\t}\\n    81→\\n    82→\\treturn result, nil\\n    83→}\\n    84→\\n    85→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    86→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    87→func (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n    88→\\tstore, err := s.getCheckpointStore()\\n    89→\\tif err != nil {\\n    90→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    91→\\t}\\n    92→\\n    93→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n    94→\\tif err != nil {\\n    95→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    96→\\t}\\n    97→\\tif content == nil {\\n    98→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n    99→\\t}\\n   100→\\tif len(content.Transcript) == 0 {\\n   101→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   102→\\t}\\n   103→\\n   104→\\treturn content.Transcript, nil\\n   105→}\\n   106→\\n   107→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   108→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   109→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   110→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   111→//\\n   112→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   113→// In this case, data is extracted from the live transcript instead.\\n   114→func (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n   115→\\t// Get shadow branch (may not exist for mid-session commits)\\n   116→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   117→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   118→\\tref, err := repo.Reference(refName, true)\\n   119→\\thasShadowBranch := err == nil\\n   120→\\n   121→\\tvar sessionData *ExtractedSessionData\\n   122→\\tif hasShadowBranch {\\n   123→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   124→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   125→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   126→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   127→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   128→\\t\\t// last turn had no code changes).\\n   129→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   130→\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n   131→\\t\\tif err != nil {\\n   132→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n   133→\\t\\t}\\n   134→\\t} else {\\n   135→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   136→\\t\\t// Extract data directly from live transcript.\\n   137→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   138→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   139→\\t\\t}\\n   140→\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n   141→\\t\\tif err != nil {\\n   142→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n   143→\\t\\t}\\n   144→\\t}\\n   145→\\n   146→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   147→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   148→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   149→\\tif len(committedFiles) > 0 {\\n   150→\\t\\t// Track if we had files before filtering to distinguish between:\\n   151→\\t\\t// - Session had files but none were committed (don't fallback)\\n   152→\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n   153→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   154→\\n   155→\\t\\tif hadFilesBeforeFiltering {\\n   156→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   157→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   158→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   159→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   160→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   161→\\t\\t\\t\\t}\\n   162→\\t\\t\\t}\\n   163→\\t\\t\\tsessionData.FilesTouched = filtered\\n   164→\\t\\t}\\n   165→\\n   166→\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n   167→\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n   168→\\t\\t// the session had files that simply didn't overlap with the commit - that\\n   169→\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n   170→\\t\\t// overwritten with unrelated committed files.\\n   171→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   172→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   173→\\t\\t\\tfor f := range committedFiles {\\n   174→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   175→\\t\\t\\t}\\n   176→\\t\\t}\\n   177→\\t}\\n   178→\\n   179→\\t// Get checkpoint store\\n   180→\\tstore, err := s.getCheckpointStore()\\n   181→\\tif err != nil {\\n   182→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   183→\\t}\\n   184→\\n   185→\\t// Get author info\\n   186→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   187→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   188→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   189→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   190→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n   191→\\t// Get current branch name\\n   192→\\tbranchName := GetCurrentBranchName(repo)\\n   193→\\n   194→\\t// Generate summary if enabled\\n   195→\\tvar summary *cpkg.Summary\\n   196→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   197→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   198→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   199→\\n   200→\\t\\t// Scope transcript to this checkpoint's portion.\\n   201→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   202→\\t\\t// For Gemini (JSON), CheckpointTranscriptStart is a message index.\\n   203→\\t\\tvar scopedTranscript []byte\\n   204→\\t\\tif state.AgentType == agent.AgentTypeGemini {\\n   205→\\t\\t\\tscopedTranscript = geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   206→\\t\\t} else {\\n   207→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   208→\\t\\t}\\n   209→\\t\\tif len(scopedTranscript) > 0 {\\n   210→\\t\\t\\tvar err error\\n   211→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   212→\\t\\t\\tif err != nil {\\n   213→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   214→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   215→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   216→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   217→\\t\\t\\t} else {\\n   218→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   219→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   220→\\t\\t\\t}\\n   221→\\t\\t}\\n   222→\\t}\\n   223→\\n   224→\\t// Write checkpoint metadata using the checkpoint store\\n   225→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   226→\\t\\tCheckpointID:                checkpointID,\\n   227→\\t\\tSessionID:                   state.SessionID,\\n   228→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   229→\\t\\tBranch:                      branchName,\\n   230→\\t\\tTranscript:                  sessionData.Transcript,\\n   231→\\t\\tPrompts:                     sessionData.Prompts,\\n   232→\\t\\tContext:                     sessionData.Context,\\n   233→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   234→\\t\\tCheckpointsCount:            state.StepCount,\\n   235→\\t\\tEphemeralBranch:             shadowBranchName,\\n   236→\\t\\tAuthorName:                  authorName,\\n   237→\\t\\tAuthorEmail:                 authorEmail,\\n   238→\\t\\tAgent:                       state.AgentType,\\n   239→\\t\\tTurnID:                      state.TurnID,\\n   240→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   241→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   242→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   243→\\t\\tExportData:                  sessionData.ExportData,\\n   244→\\t\\tInitialAttribution:          attribution,\\n   245→\\t\\tSummary:                     summary,\\n   246→\\t}); err != nil {\\n   247→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   248→\\t}\\n   249→\\n   250→\\treturn &CondenseResult{\\n   251→\\t\\tCheckpointID:         checkpointID,\\n   252→\\t\\tSessionID:            state.SessionID,\\n   253→\\t\\tCheckpointsCount:     state.StepCount,\\n   254→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   255→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   256→\\t}, nil\\n   257→}\\n   258→\\n   259→func calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n   260→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   261→\\t// This uses user edits captured at each prompt start (before agent works),\\n   262→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   263→\\t//\\n   264→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   265→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   266→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   267→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   268→\\n   269→\\theadRef, headErr := repo.Head()\\n   270→\\tif headErr != nil {\\n   271→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   272→\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   273→\\t\\treturn nil\\n   274→\\t}\\n   275→\\n   276→\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   277→\\tif commitErr != nil {\\n   278→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   279→\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   280→\\t\\treturn nil\\n   281→\\t}\\n   282→\\n   283→\\theadTree, treeErr := headCommit.Tree()\\n   284→\\tif treeErr != nil {\\n   285→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   286→\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   287→\\t\\treturn nil\\n   288→\\t}\\n   289→\\n   290→\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n   291→\\tvar shadowTree *object.Tree\\n   292→\\tif shadowRef != nil {\\n   293→\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   294→\\t\\tif shadowErr != nil {\\n   295→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   296→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   297→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   298→\\t\\t\\treturn nil\\n   299→\\t\\t}\\n   300→\\t\\tvar shadowTreeErr error\\n   301→\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   302→\\t\\tif shadowTreeErr != nil {\\n   303→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   304→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   305→\\t\\t\\treturn nil\\n   306→\\t\\t}\\n   307→\\t} else {\\n   308→\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   309→\\t\\t// because the agent's work is the commit itself.\\n   310→\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   311→\\t\\tshadowTree = headTree\\n   312→\\t}\\n   313→\\n   314→\\t// Get base tree (state before session started)\\n   315→\\tvar baseTree *object.Tree\\n   316→\\tattrBase := state.AttributionBaseCommit\\n   317→\\tif attrBase == \\\"\\\" {\\n   318→\\t\\tattrBase = state.BaseCommit // backward compat\\n   319→\\t}\\n   320→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   321→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   322→\\t\\t\\tbaseTree = tree\\n   323→\\t\\t} else {\\n   324→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   325→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   326→\\t\\t}\\n   327→\\t} else {\\n   328→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   329→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   330→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   331→\\t}\\n   332→\\n   333→\\t// Log accumulated prompt attributions for debugging\\n   334→\\tvar totalUserAdded, totalUserRemoved int\\n   335→\\tfor i, pa := range state.PromptAttributions {\\n   336→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   337→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   338→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   339→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   340→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   341→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   342→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   343→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   344→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   345→\\t}\\n   346→\\n   347→\\tattribution := CalculateAttributionWithAccumulated(\\n   348→\\t\\tbaseTree,\\n   349→\\t\\tshadowTree,\\n   350→\\t\\theadTree,\\n   351→\\t\\tsessionData.FilesTouched,\\n   352→\\t\\tstate.PromptAttributions,\\n   353→\\t)\\n   354→\\n   355→\\tif attribution != nil {\\n   356→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   357→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   358→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   359→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   360→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   361→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   362→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   363→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   364→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   365→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   366→\\t}\\n   367→\\n   368→\\treturn attribution\\n   369→}\\n   370→\\n   371→// extractSessionData extracts session data from the shadow branch.\\n   372→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   373→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   374→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   375→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   376→// continued growing — the shadow branch copy would be stale.\\n   377→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   378→func (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n   379→\\tcommit, err := repo.CommitObject(shadowRef)\\n   380→\\tif err != nil {\\n   381→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   382→\\t}\\n   383→\\n   384→\\ttree, err := commit.Tree()\\n   385→\\tif err != nil {\\n   386→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   387→\\t}\\n   388→\\n   389→\\tdata := &ExtractedSessionData{}\\n   390→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   391→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   392→\\n   393→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   394→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   395→\\t// (SaveStep is only called when there are file modifications).\\n   396→\\tvar fullTranscript string\\n   397→\\tif liveTranscriptPath != \\\"\\\" {\\n   398→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   399→\\t\\t\\tfullTranscript = string(liveData)\\n   400→\\t\\t}\\n   401→\\t}\\n   402→\\tif fullTranscript == \\\"\\\" {\\n   403→\\t\\t// Fall back to shadow branch copy\\n   404→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   405→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   406→\\t\\t\\t\\tfullTranscript = content\\n   407→\\t\\t\\t}\\n   408→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   409→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   410→\\t\\t\\t\\tfullTranscript = content\\n   411→\\t\\t\\t}\\n   412→\\t\\t}\\n   413→\\t}\\n   414→\\n   415→\\t// Process transcript based on agent type\\n   416→\\tif fullTranscript != \\\"\\\" {\\n   417→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   418→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   419→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   420→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   421→\\t}\\n   422→\\n   423→\\t// Use tracked files from session state (not all files in tree)\\n   424→\\tdata.FilesTouched = filesTouched\\n   425→\\n   426→\\t// Read export data from local metadata directory (e.g., OpenCode SQLite export).\\n   427→\\t// This is written by lifecycle.go during TurnEnd and must be stored in the\\n   428→\\t// committed checkpoint so resume/rewind can re-import the session.\\n   429→\\texportRelPath := metadataDir + \\\"/\\\" + paths.ExportDataFileName\\n   430→\\tif exportAbsPath, absErr := paths.AbsPath(exportRelPath); absErr == nil {\\n   431→\\t\\tif exportBytes, readErr := os.ReadFile(exportAbsPath); readErr == nil && len(exportBytes) > 0 { //nolint:gosec // path from session metadata\\n   432→\\t\\t\\tdata.ExportData = exportBytes\\n   433→\\t\\t}\\n   434→\\t}\\n   435→\\n   436→\\t// Calculate token usage from the extracted transcript portion\\n   437→\\tif len(data.Transcript) > 0 {\\n   438→\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n   439→\\t}\\n   440→\\n   441→\\treturn data, nil\\n   442→}\\n   443→\\n   444→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   445→// This is used for mid-session commits where no shadow branch exists yet.\\n   446→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n   447→\\tdata := &ExtractedSessionData{}\\n   448→\\n   449→\\t// Read the live transcript\\n   450→\\tif state.TranscriptPath == \\\"\\\" {\\n   451→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   452→\\t}\\n   453→\\n   454→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   455→\\tif err != nil {\\n   456→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   457→\\t}\\n   458→\\n   459→\\tif len(liveData) == 0 {\\n   460→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   461→\\t}\\n   462→\\n   463→\\tfullTranscript := string(liveData)\\n   464→\\tdata.Transcript = liveData\\n   465→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   466→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   467→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   468→\\n   469→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   470→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   471→\\tif len(state.FilesTouched) > 0 {\\n   472→\\t\\tdata.FilesTouched = state.FilesTouched\\n   473→\\t} else {\\n   474→\\t\\t// Use the shared helper which includes subagent transcripts\\n   475→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n   476→\\t}\\n   477→\\n   478→\\t// Read export data from local metadata directory\\n   479→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(state.SessionID)\\n   480→\\texportRelPath := metadataDir + \\\"/\\\" + paths.ExportDataFileName\\n   481→\\tif exportAbsPath, absErr := paths.AbsPath(exportRelPath); absErr == nil {\\n   482→\\t\\tif exportBytes, readErr := os.ReadFile(exportAbsPath); readErr == nil && len(exportBytes) > 0 { //nolint:gosec // path from session metadata\\n   483→\\t\\t\\tdata.ExportData = exportBytes\\n   484→\\t\\t}\\n   485→\\t}\\n   486→\\n   487→\\t// Calculate token usage from the extracted transcript portion\\n   488→\\tif len(data.Transcript) > 0 {\\n   489→\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n   490→\\t}\\n   491→\\n   492→\\treturn data, nil\\n   493→}\\n   494→\\n   495→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   496→// For Claude Code and JSONL-based agents, this counts lines.\\n   497→// For Gemini CLI and JSON-based agents, this counts messages.\\n   498→// Returns 0 if the content is empty or malformed.\\n   499→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   500→\\tif content == \\\"\\\" {\\n   501→\\t\\treturn 0\\n   502→\\t}\\n   503→\\n   504→\\t// Try Gemini format first